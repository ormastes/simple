# ============================================================================

describe "FMA3 emit_vfmsub132ps_ymm ymm0 ymm1 ymm2 golden":
    # vfmsub132ps %ymm2, %ymm1, %ymm0 → [0xc4,0xe2,0x75,0x9a,0xc2]
    it "emits 5 bytes":
