        expect result.len() == 5

    it "byte3 is opcode 0x9A":
        val result = emit_vfmsub132ps_ymm(0, 1, 2)
        expect result[3] == 154

    it "byte2 is 0x75 (W=0 ~vvvv=14 L=1 pp=01)":
        val result = emit_vfmsub132ps_ymm(0, 1, 2)
        expect result[2] == 117

describe "FMA3 emit_vfmsub132ps_ymm extended rd ymm9":
    # rd=9, rn=1, rm=2 → byte1=0x62, byte4=0xCA
    it "byte1 is 0x62 (~R=0 ~X=1 ~B=1 mmmmm=2)":
        val result = emit_vfmsub132ps_ymm(9, 1, 2)
        expect result[1] == 98

    it "byte4 is ModRM 0xCA (mod=11 reg=1 rm=2)":
        val result = emit_vfmsub132ps_ymm(9, 1, 2)
        expect result[4] == 202

