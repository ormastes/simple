# ============================================================================
# VFNMADD213PS — VEX.256.66.0F38.W0 AC /r
# ============================================================================

describe "FMA3 emit_vfnmadd213ps_ymm ymm0 ymm1 ymm2 golden":
    # vfnmadd213ps %ymm2, %ymm1, %ymm0 → [0xc4,0xe2,0x75,0xac,0xc2]
    it "emits 5 bytes":
        val result = emit_vfnmadd213ps_ymm(0, 1, 2)
        expect result.len() == 5

    it "byte3 is opcode 0xAC":
        val result = emit_vfnmadd213ps_ymm(0, 1, 2)
        expect result[3] == 172

    it "byte2 is 0x75 (W=0 ~vvvv=14 L=1 pp=01)":
        val result = emit_vfnmadd213ps_ymm(0, 1, 2)
        expect result[2] == 117

describe "FMA3 emit_vfnmadd213ps_ymm extended rn ymm9":
    # rd=0, rn=9, rm=2 → byte2=0x35 (~vvvv=6)
    it "byte2 is 0x35 (W=0 ~vvvv=6 L=1 pp=01)":
        # ~vvvv=(15-rn=9)=6 → 6*8+5=53
        val result = emit_vfnmadd213ps_ymm(0, 9, 2)
        expect result[2] == 53

    it "byte4 is ModRM 0xC2 (mod=11 reg=0 rm=2)":
        val result = emit_vfnmadd213ps_ymm(0, 9, 2)
        expect result[4] == 194

# ============================================================================
# VFMADD132PD — VEX.256.66.0F38.W1 98 /r
# ============================================================================

describe "FMA3 emit_vfmadd132pd_ymm ymm0 ymm1 ymm2 golden":
    # vfmadd132pd %ymm2, %ymm1, %ymm0 → [0xc4,0xe2,0xf5,0x98,0xc2]
    it "emits 5 bytes":
        val result = emit_vfmadd132pd_ymm(0, 1, 2)
        expect result.len() == 5

    it "byte0 is VEX escape 0xC4":
        val result = emit_vfmadd132pd_ymm(0, 1, 2)
        expect result[0] == 196

    it "byte1 is 0xE2 (~R=1 ~X=1 ~B=1 mmmmm=2)":
        val result = emit_vfmadd132pd_ymm(0, 1, 2)
        expect result[1] == 226

    it "byte2 is 0xF5 (W=1 ~vvvv=14 L=1 pp=01)":
        # W=1 adds 128, ~vvvv=14, L=1, pp=01 → 128+14*8+5=245
        val result = emit_vfmadd132pd_ymm(0, 1, 2)
        expect result[2] == 245

    it "byte3 is opcode 0x98":
        val result = emit_vfmadd132pd_ymm(0, 1, 2)
        expect result[3] == 152

    it "byte4 is ModRM 0xC2 (mod=11 reg=0 rm=2)":
        val result = emit_vfmadd132pd_ymm(0, 1, 2)
        expect result[4] == 194

describe "FMA3 emit_vfmadd132pd_ymm extended rd ymm9":
    # rd=9(ymm9), rn=1, rm=2 → [0xc4,0x62,0xf5,0x98,0xca]
    it "byte1 is 0x62 (~R=0 ~X=1 ~B=1 mmmmm=2)":
        # rd>=8 → ~R=0 → 226-128=98
        val result = emit_vfmadd132pd_ymm(9, 1, 2)
        expect result[1] == 98

    it "byte2 is 0xF5 (W=1 ~vvvv=14 L=1 pp=01)":
        val result = emit_vfmadd132pd_ymm(9, 1, 2)
        expect result[2] == 245

    it "byte4 is ModRM 0xCA (mod=11 reg=1 rm=2)":
        # mod=11, reg=9%8=1, rm=2%8=2 → 192+1*8+2=202
        val result = emit_vfmadd132pd_ymm(9, 1, 2)
        expect result[4] == 202
