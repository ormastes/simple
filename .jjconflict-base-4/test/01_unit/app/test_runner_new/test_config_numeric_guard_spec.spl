extern fn rt_file_read_text(path: text) -> text?

describe "test config numeric guard":
    it "defaults malformed integer config values":
        val source = rt_file_read_text("src/app/test_runner_new/test_config.spl") ?? ""

        expect(source).to_contain("fn to_int_or(s: text, default: i64) -> i64")
        expect(source).to_contain("trimmed.to_int() ?? default")
        expect(source.contains("trimmed.to_int()\n")).to_equal(false)
