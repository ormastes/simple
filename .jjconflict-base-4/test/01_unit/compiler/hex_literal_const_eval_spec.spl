"""Hex/binary integer literal const-evaluation.

Regression guard for the parser's `0x` digit-by-digit value mapping
(src/compiler/10.frontend/core/_ParserPrimary/primary_expr.spl). It previously
used `int(hc) - int("a")` to map a hex letter to its value; `int()`
numeric-parses, so `int("a")`/`int("c")` errored ("cannot parse 'c' as i64"),
breaking const-eval of any hex literal with an a-f digit (e.g. kernel 0xc...
LIMINE constants) on the native-build path. Now mapped via a lookup string.
"""

use std.spec
use testing.{describe, it, expect}

describe "hex literal const-eval":
    it "maps lowercase a-f digits":
        expect(0xca).to_equal(202)
    it "maps a full lowercase word literal":
        expect(0xdeadbeef).to_equal(3735928559)
    it "maps uppercase A-F digits":
        expect(0xDEAD).to_equal(57005)
    it "maps mixed-case digits":
        expect(0xAbCdEf).to_equal(11259375)
    it "still maps pure-digit hex":
        expect(0x10).to_equal(16)
    it "leaves binary literals intact":
        expect(0b1010).to_equal(10)
    it "leaves octal literals intact":
        expect(0o17).to_equal(15)
