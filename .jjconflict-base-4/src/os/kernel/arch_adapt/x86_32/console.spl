# x86_32 Console Adapter Scaffold
#
# Thin wrapper layer over the concrete x86_32 console module.

use os.kernel.arch.x86_32.console.{serial_init, serial_write_byte, serial_write, serial_writeln}

fn console_init():
    """Initialize the x86_32 early serial console."""
    serial_init()

fn console_write_byte(byte: u8):
    """Write one byte to the x86_32 early serial console."""
    serial_write_byte(byte)

fn console_write(msg: text):
    """Write text to the x86_32 early serial console."""
    serial_write(msg)

fn console_writeln(msg: text):
    """Write text plus newline to the x86_32 early serial console."""
    serial_writeln(msg)
