fn _hex_digit(v: i64) -> text:
    if v == 0: "0"
    elif v == 1: "1"
    elif v == 2: "2"
    elif v == 3: "3"
    elif v == 4: "4"
    elif v == 5: "5"
    elif v == 6: "6"
    elif v == 7: "7"
    elif v == 8: "8"
    elif v == 9: "9"
    elif v == 10: "a"
    elif v == 11: "b"
    elif v == 12: "c"
    elif v == 13: "d"
    elif v == 14: "e"
    else: "f"

fn format_hex(value: i64) -> text:
    val masked = value & 0xff
    _hex_digit((masked >> 4) & 0xf) + _hex_digit(masked & 0xf)

fn format_hex_width(value: u64, width: i64) -> text:
    if width <= 1:
        return format_hex(value.to_i64())
    var out = ""
    var shift: i64 = (width - 1) * 4
    while shift >= 0:
        out = out + _hex_digit(((value >> shift.to_u64()) & 0xfu64).to_i64())
        shift = shift - 4
    out
