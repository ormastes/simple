class LayoutSplit:
    direction: text
    ratio: int
    split_id: int
    depth: int

    me is_horizontal() -> bool:
        return direction == "horizontal"

    me is_vertical() -> bool:
        return direction == "vertical"

    me invert() -> LayoutSplit:
        var new_dir = "vertical"
        if direction == "vertical":
            new_dir = "horizontal"
        return LayoutSplit(direction: new_dir, ratio: ratio, split_id: split_id, depth: depth)

    static fn horizontal(id: int, r: int) -> LayoutSplit:
        return LayoutSplit(direction: "horizontal", ratio: r, split_id: id, depth: 0)

    static fn vertical(id: int, r: int) -> LayoutSplit:
        return LayoutSplit(direction: "vertical", ratio: r, split_id: id, depth: 0)


class LayoutNode:
    node_id: int
    pane_index: int
    split: LayoutSplit
    is_leaf: bool

    me has_pane() -> bool:
        return pane_index >= 0

    me to_text() -> text:
        return "node[" + node_id.to_text() + "] pane=" + pane_index.to_text()

    static fn leaf(id: int, pane_idx: int) -> LayoutNode:
        val dummy_split = LayoutSplit(direction: "horizontal", ratio: 50, split_id: 0, depth: 0)
        return LayoutNode(node_id: id, pane_index: pane_idx, split: dummy_split, is_leaf: true)

    static fn internal(id: int, s: LayoutSplit) -> LayoutNode:
        return LayoutNode(node_id: id, pane_index: -1, split: s, is_leaf: false)


class LayoutTree:
    f0_node: LayoutNode
    f1_node: LayoutNode
    f2_node: LayoutNode
    f3_node: LayoutNode
    node_count: int

    me find_pane(pane_idx: int) -> LayoutNode:
        if f0_node.pane_index == pane_idx:
            return f0_node
        if f1_node.pane_index == pane_idx:
            return f1_node
        if f2_node.pane_index == pane_idx:
            return f2_node
        if f3_node.pane_index == pane_idx:
            return f3_node
        return f0_node

    me add_node(n: LayoutNode) -> LayoutTree:
        if node_count == 0:
            return LayoutTree(f0_node: n, f1_node: f1_node, f2_node: f2_node, f3_node: f3_node, node_count: 1)
        if node_count == 1:
            return LayoutTree(f0_node: f0_node, f1_node: n, f2_node: f2_node, f3_node: f3_node, node_count: 2)
        if node_count == 2:
            return LayoutTree(f0_node: f0_node, f1_node: f1_node, f2_node: n, f3_node: f3_node, node_count: 3)
        return LayoutTree(f0_node: f0_node, f1_node: f1_node, f2_node: f2_node, f3_node: n, node_count: 4)

    me root() -> LayoutNode:
        return f0_node

    static fn create() -> LayoutTree:
        val dummy_split = LayoutSplit(direction: "horizontal", ratio: 50, split_id: 0, depth: 0)
        val dummy_node = LayoutNode(node_id: -1, pane_index: -1, split: dummy_split, is_leaf: false)
        return LayoutTree(f0_node: dummy_node, f1_node: dummy_node, f2_node: dummy_node, f3_node: dummy_node, node_count: 0)


class ResizeOp:
    target_node_id: int
    new_width: int
    new_height: int
    applied: bool

    me mark_applied() -> ResizeOp:
        return ResizeOp(target_node_id: target_node_id, new_width: new_width, new_height: new_height, applied: true)

    me to_text() -> text:
        return "resize node[" + target_node_id.to_text() + "] to " + new_width.to_text() + "x" + new_height.to_text()

    me is_valid() -> bool:
        return (new_width > 0 and
            new_height > 0)

    static fn create(nid: int, w: int, h: int) -> ResizeOp:
        return ResizeOp(target_node_id: nid, new_width: w, new_height: h, applied: false)
