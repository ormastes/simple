# Manual Pointer Borrow - Borrow checker model generation
# Generates Lean verification for manual pointer borrow checking

use verification.lean.codegen.{build_class, build_enum_with_deriving, build_function, build_theorem, LeanCodegen, make_simple_type}

fn regenerate_manual_pointer_borrow() -> text:
    var lgen = LeanCodegen.create("ManualPointerBorrow")

    # Namespace
    lgen = lgen.add_namespace("ManualPointerBorrow")

    # BorrowState structure
    lgen = lgen.add_doc_comment("A tiny borrow checker for manual pointers: `exclusive` tracks a unique borrow,\n    `shared` counts active shared borrows.")
    borrow_state = build_class("BorrowState", [
        ("exclusive", make_simple_type("bool")),
        ("shared", make_simple_type("Nat"))
    ])
    lgen = lgen.add_structure(borrow_state)

    # ValidBorrowState inductive
    lgen = lgen.add_doc_comment("Type-safe borrow state where invalid states are unrepresentable.\n    The invariant \"exclusive → shared = 0\" is encoded in the inductive structure.")
    valid_state = build_enum_with_deriving("ValidBorrowState", [
        ("unborrowed", []),
        ("exclusive", []),
        ("shared", [("count", make_simple_type("Nat")), ("h", make_simple_type("count > 0"))])
    ], ["Repr"])
    lgen = lgen.add_inductive(valid_state)

    # valid definition
    valid_def = build_function(
        "valid",
        [("s", make_simple_type("BorrowState"))],
        make_simple_type("Prop"),
        "if s.exclusive then s.shared = 0 else True"
    )
    lgen = lgen.add_function(valid_def)

    # Conversion functions
    lgen = lgen.add_doc_comment("Convert ValidBorrowState to BorrowState. Always produces a valid state.")
    to_state_def = build_function(
        "ValidBorrowState.toState",
        [("_", make_simple_type("ValidBorrowState"))],
        make_simple_type("BorrowState"),
        "match _ with\n| .unborrowed => {{ exclusive := false, shared := 0 }}\n| .exclusive => {{ exclusive := true, shared := 0 }}\n| .shared count _ => {{ exclusive := false, shared := count }}"
    )
    lgen = lgen.add_raw_line("def ValidBorrowState.toState : ValidBorrowState → BorrowState")
    lgen = lgen.add_raw_line("  | .unborrowed => {{ exclusive := false, shared := 0 }}")
    lgen = lgen.add_raw_line("  | .exclusive => {{ exclusive := true, shared := 0 }}")
    lgen = lgen.add_raw_line("  | .shared count _ => {{ exclusive := false, shared := count }}")
    lgen = lgen.add_blank()

    lgen = lgen.add_doc_comment("Convert BorrowState to ValidBorrowState if valid.")
    lgen = lgen.add_raw_line("def BorrowState.toValid (s : BorrowState) : Option ValidBorrowState :=")
    lgen = lgen.add_raw_line("  match s.exclusive, s.shared with")
    lgen = lgen.add_raw_line("  | false, 0 => some .unborrowed")
    lgen = lgen.add_raw_line("  | true, 0 => some .exclusive")
    lgen = lgen.add_raw_line("  | false, n + 1 => some (.shared (n + 1) (Nat.succ_pos n))")
    lgen = lgen.add_raw_line("  | true, _ + 1 => none")
    lgen = lgen.add_blank()

    # Key theorems
    lgen = lgen.add_theorem(build_theorem(
        "validState_always_valid",
        [("vs", "ValidBorrowState")],
        "valid vs.toState",
        "cases vs with\n| unborrowed => simp [ValidBorrowState.toState, valid]\n| exclusive => simp [ValidBorrowState.toState, valid]\n| shared count h => simp [ValidBorrowState.toState, valid]"
    ))

    lgen = lgen.add_theorem(build_theorem(
        "toValid_toState",
        [("vs", "ValidBorrowState")],
        "vs.toState.toValid = some vs",
        "cases vs with\n| unborrowed => simp [ValidBorrowState.toState, BorrowState.toValid]\n| exclusive => simp [ValidBorrowState.toState, BorrowState.toValid]\n| shared count h =>\n  simp [ValidBorrowState.toState, BorrowState.toValid]\n  cases count with\n  | zero => exact absurd rfl (Nat.ne_of_gt h)\n  | succ n => rfl"
    ))

    # Operation functions
    take_excl_def = build_function(
        "takeExclusive",
        [("s", make_simple_type("BorrowState"))],
        make_simple_type("BorrowState"),
        "if s.shared = 0 then {{ s with exclusive := true }} else s"
    )
    lgen = lgen.add_function(take_excl_def)

    take_shared_def = build_function(
        "takeShared",
        [("s", make_simple_type("BorrowState"))],
        make_simple_type("BorrowState"),
        "if s.exclusive then s else {{ s with shared := s.shared + 1 }}"
    )
    lgen = lgen.add_function(take_shared_def)

    release_shared_def = build_function(
        "releaseShared",
        [("s", make_simple_type("BorrowState"))],
        make_simple_type("BorrowState"),
        "{{ s with shared := s.shared.pred }}"
    )
    lgen = lgen.add_function(release_shared_def)

    release_excl_def = build_function(
        "releaseExclusive",
        [("s", make_simple_type("BorrowState"))],
        make_simple_type("BorrowState"),
        "{{ s with exclusive := false }}"
    )
    lgen = lgen.add_function(release_excl_def)

    # Preservation theorems
    lgen = lgen.add_theorem(build_theorem(
        "exclusive_ok",
        [("s", "BorrowState"), ("hv", "valid s")],
        "valid (takeExclusive s)",
        "unfold takeExclusive valid at *\nsplit\n· assumption\n· exact hv"
    ))

    lgen = lgen.add_theorem(build_theorem(
        "shared_ok",
        [("s", "BorrowState"), ("hv", "valid s")],
        "valid (takeShared s)",
        "unfold takeShared valid at *\nsplit\n· split at hv\n  · exact hv\n  · trivial\n· simp"
    ))

    lgen = lgen.add_theorem(build_theorem(
        "release_ok",
        [("s", "BorrowState"), ("hv", "valid s")],
        "valid (releaseShared s) ∧ valid (releaseExclusive s)",
        "unfold releaseShared releaseExclusive valid at *\nconstructor\n· split\n  case isTrue hex =>\n    split at hv\n    case isTrue => simp_all\n    case isFalse h => exact absurd hex h\n  case isFalse => trivial\n· simp"
    ))

    # End namespace
    lgen = lgen.end_namespace("ManualPointerBorrow")

    return lgen.emit()


# ============================================================================
# 5. ModuleResolution - Module path resolution (146 lines)
