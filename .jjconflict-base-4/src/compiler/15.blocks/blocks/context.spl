# Block parsing context and diagnostics.

use compiler.common.diagnostics.span.{Span}

enum BlockErrorKind:
    Parse
    Validation
    Resolution

enum DiagnosticLevel:
    Error
    Warning
    Info

struct Diagnostic:
    level: DiagnosticLevel
    message: text
    span: Span

struct BlockContext:
    source: text
    block_kind: text
    span: Span
    payload_span: Span

struct BlockError:
    kind: BlockErrorKind
    message: text
    has_span: bool
    span: Span
    has_suggestion: bool
    suggestion: text
    has_note: bool
    note: text

impl BlockError:
    static fn parse(message: text) -> BlockError:
        BlockError(
            kind: BlockErrorKind.Parse,
            message: message,
            has_span: false,
            span: Span.empty(),
            has_suggestion: false,
            suggestion: "",
            has_note: false,
            note: ""
        )

    static fn validation(message: text) -> BlockError:
        BlockError(
            kind: BlockErrorKind.Validation,
            message: message,
            has_span: false,
            span: Span.empty(),
            has_suggestion: false,
            suggestion: "",
            has_note: false,
            note: ""
        )

    fn with_span(span: Span) -> BlockError:
        var next = self
        next.has_span = true
        next.span = span
        next

    fn with_suggestion(suggestion: text) -> BlockError:
        var next = self
        next.has_suggestion = true
        next.suggestion = suggestion
        next

    fn with_note(note: text) -> BlockError:
        var next = self
        next.has_note = true
        next.note = note
        next

fn blockerror_parse(message: text) -> BlockError:
    BlockError.parse(message)

fn blockerror_validation(message: text) -> BlockError:
    BlockError.validation(message)

fn blockerror_parse_at(message: text, span: Span) -> BlockError:
    BlockError.parse(message).with_span(span)
