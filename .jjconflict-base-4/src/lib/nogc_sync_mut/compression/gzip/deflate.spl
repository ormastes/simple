# DEFLATE Compression Algorithm
#
# Purpose: DEFLATE compression (LZ77 + Huffman coding)
#
# Contains:
# - DEFLATE block creation (stored, fixed Huffman)
# - Length/distance code mapping
# - Block encoding with Huffman codes
# - Token-to-block conversion

use std.nogc_sync_mut.compression.gzip.types.{
    BLOCK_STORED, BLOCK_FIXED, BLOCK_DYNAMIC
}
use std.nogc_sync_mut.compression.gzip.huffman.{
    deflate_fixed_huffman, deflate_fixed_distances, huffman_lookup,
    bitstream_new, bitstream_write_bits_lsb, bitstream_write_huffman,
    bitstream_finish, deflate_length_extra, deflate_distance_extra
}

# =============================================================================
# DEFLATE BLOCKS
# =============================================================================

# Create DEFLATE stored block (uncompressed)
fn deflate_block_stored(data, is_final):
    if data == nil:
        return []

    var block = []

    # Block header (3 bits)
    var header = BLOCK_STORED << 1
    if is_final:
        header = header | 1

    block.push(header)

    # Length (2 bytes)
    val len = data.len()
    block.push(len & 0xff)
    block.push((len >> 8) & 0xff)

    # One's complement of length
    val nlen = (~len) & 0xffff
    block.push(nlen & 0xff)
    block.push((nlen >> 8) & 0xff)

    # Data bytes
    var i = 0
    loop:
        if i >= data.len():
            break
        block.push(data[i])
        i = i + 1

    return block

# Create DEFLATE fixed Huffman block (RFC 1951 §3.2.6)
# Produces a proper bitstream: BFINAL+BTYPE LSB-first, Huffman codes MSB-first packed LSB into bytes.
fn deflate_block_fixed(tokens, is_final):
    if tokens == nil:
        return []

    val lit_codes  = deflate_fixed_huffman()
    val dist_codes = deflate_fixed_distances()

    # Start bit stream — write BFINAL (1 bit) and BTYPE (2 bits) LSB-first
    var bfinal = 0
    if is_final:
        bfinal = 1
    var bs = bitstream_new()
    bs = bitstream_write_bits_lsb(bs, bfinal, 1)
    bs = bitstream_write_bits_lsb(bs, BLOCK_FIXED, 2)

    # Encode tokens
    var i = 0
    loop:
        if i >= tokens.len():
            break

        val token = tokens[i]
        val token_type = token[0]
        val value = token[1]

        if token_type == 0:
            # Literal byte
            val code_info = huffman_lookup(lit_codes, value)
            if code_info != nil:
                bs = bitstream_write_huffman(bs, code_info[0], code_info[1])
        else:
            # Match: token = [1, distance, length]
            val distance = value
            val length   = token[2]

            # Length code
            val len_code = deflate_length_code(length)
            val len_info = huffman_lookup(lit_codes, len_code)
            if len_info != nil:
                bs = bitstream_write_huffman(bs, len_info[0], len_info[1])

            # Length extra bits (LSB-first)
            val len_extra = deflate_length_extra(length)
            val len_ex_val = len_extra[0]
            val len_ex_cnt = len_extra[1]
            if len_ex_cnt > 0:
                bs = bitstream_write_bits_lsb(bs, len_ex_val, len_ex_cnt)

            # Distance code (5-bit, MSB-first)
            val dist_code = deflate_distance_code(distance)
            val dist_info = huffman_lookup(dist_codes, dist_code)
            if dist_info != nil:
                bs = bitstream_write_huffman(bs, dist_info[0], dist_info[1])

            # Distance extra bits (LSB-first)
            val dist_extra = deflate_distance_extra(distance)
            val dist_ex_val = dist_extra[0]
            val dist_ex_cnt = dist_extra[1]
            if dist_ex_cnt > 0:
                bs = bitstream_write_bits_lsb(bs, dist_ex_val, dist_ex_cnt)

        i = i + 1

    # End-of-block symbol (256)
    val eob_info = huffman_lookup(lit_codes, 256)
    if eob_info != nil:
        bs = bitstream_write_huffman(bs, eob_info[0], eob_info[1])

    return bitstream_finish(bs)

# Get length code for match length
fn deflate_length_code(length):
    if length < 3:
        return 257
    if length <= 10:
        return 257 + (length - 3)
    if length <= 18:
        return 265 + ((length - 11) / 2)
    if length <= 34:
        return 269 + ((length - 19) / 4)
    if length <= 66:
        return 273 + ((length - 35) / 8)
    if length <= 130:
        return 277 + ((length - 67) / 16)
    if length <= 257:
        return 281 + ((length - 131) / 32)
    return 285

# Get distance code for match distance
fn deflate_distance_code(distance):
    if distance <= 4:
        return distance - 1
    if distance <= 8:
        return 4 + ((distance - 5) / 2)
    if distance <= 16:
        return 6 + ((distance - 9) / 4)
    if distance <= 32:
        return 8 + ((distance - 17) / 8)
    if distance <= 64:
        return 10 + ((distance - 33) / 16)
    if distance <= 128:
        return 12 + ((distance - 65) / 32)
    if distance <= 256:
        return 14 + ((distance - 129) / 64)
    if distance <= 512:
        return 16 + ((distance - 257) / 128)
    if distance <= 1024:
        return 18 + ((distance - 513) / 256)
    if distance <= 2048:
        return 20 + ((distance - 1025) / 512)
    if distance <= 4096:
        return 22 + ((distance - 2049) / 1024)
    if distance <= 8192:
        return 24 + ((distance - 4097) / 2048)
    if distance <= 16384:
        return 26 + ((distance - 8193) / 4096)
    return 28

