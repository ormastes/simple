"""Deterministic software replay counters for the browser WebGPU MVP."""

use std.gc_async_mut.gpu.browser_engine.webgpu_context.{WebGPUQueue}

pub class WebGPUSoftwareExecutionResult:
    valid: bool
    queue_write_count: i32
    render_pass_count: i32
    draw_call_count: i32
    compute_pass_count: i32
    dispatched_workgroups: i64

pub fn webgpu_software_execute_queue(queue: WebGPUQueue) -> WebGPUSoftwareExecutionResult:
    var render_passes = 0
    var draw_calls = 0
    var compute_passes = 0
    var workgroups = 0
    for command_buffer in queue.submitted:
        if not command_buffer.valid:
            return WebGPUSoftwareExecutionResult(valid: false, queue_write_count: queue.write_count, render_pass_count: render_passes, draw_call_count: draw_calls, compute_pass_count: compute_passes, dispatched_workgroups: workgroups)
        render_passes = render_passes + command_buffer.render_pass_count
        draw_calls = draw_calls + command_buffer.draw_call_count
        compute_passes = compute_passes + command_buffer.compute_pass_count
        workgroups = workgroups + command_buffer.dispatched_workgroups
    WebGPUSoftwareExecutionResult(valid: true, queue_write_count: queue.write_count, render_pass_count: render_passes, draw_call_count: draw_calls, compute_pass_count: compute_passes, dispatched_workgroups: workgroups)

pub class WebGPUSoftwareExecutor:
    fn execute(queue: WebGPUQueue) -> WebGPUSoftwareExecutionResult:
        webgpu_software_execute_queue(queue)

pub fn webgpu_software_execute_command_buffer(queue: WebGPUQueue) -> WebGPUSoftwareExecutionResult:
    webgpu_software_execute_queue(queue)

export WebGPUSoftwareExecutor
export webgpu_software_execute_command_buffer
