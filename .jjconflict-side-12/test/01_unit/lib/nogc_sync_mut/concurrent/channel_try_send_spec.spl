# Channel try_send / closed-state signaling regression spec (H7)
#
# Verifies: try_send returns false on closed channel; send-after-close remains
# a no-op (backward compat); is_closed() reflects close() correctly.
#
# NOTE: Channel is a Rust-backed handle — we test through the pure-Simple
# try_send wrapper added in W2-7.  All assertions use .to_equal() because
# bare expect(cond) is a no-op in the interpreter.

use std.spec.*
use std.concurrent.channel.{channel_new}

describe "Channel try_send (H7 — closed-state signaling)":

    context "try_send on open channel":
        it "returns true when channel is open":
            val ch = channel_new()
            val result = ch.try_send(42)
            expect(result).to_equal(true)

    context "try_send on closed channel":
        it "returns false after close()":
            val ch = channel_new()
            ch.close()
            val result = ch.try_send(99)
            expect(result).to_equal(false)

        it "returns false on second try_send after close":
            val ch = channel_new()
            ch.close()
            val r1 = ch.try_send(1)
            val r2 = ch.try_send(2)
            expect(r1).to_equal(false)
            expect(r2).to_equal(false)

    context "is_closed reflects close()":
        it "is_closed returns false before close":
            val ch = channel_new()
            val closed = ch.is_closed()
            expect(closed).to_equal(false)

        it "is_closed returns true after close":
            val ch = channel_new()
            ch.close()
            val closed = ch.is_closed()
            expect(closed).to_equal(true)

    context "send() backward compatibility":
        it "send() to closed channel is still a silent no-op (compat)":
            # send() must not crash or change the closed state
            val ch = channel_new()
            ch.close()
            ch.send(7)
            # channel remains closed, no crash
            val closed = ch.is_closed()
            expect(closed).to_equal(true)

        it "send() to open channel still delivers message":
            val ch = channel_new()
            ch.send(123)
            val got = ch.try_recv()
            expect(got).to_equal(123)
