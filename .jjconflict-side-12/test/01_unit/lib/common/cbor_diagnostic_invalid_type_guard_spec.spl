use std.spec.{describe, it, assert_equal}
use std.common.cbor.utilities.{cbor_to_diagnostic}

describe "CBOR diagnostic invalid type guard":
    it "rejects malformed initial byte values":
        val negative_result = cbor_to_diagnostic([-1], 0)
        val high_result = cbor_to_diagnostic([300], 0)
        assert_equal(negative_result.0, "")
        assert_equal(negative_result.1, 0)
        assert_equal(high_result.0, "")
        assert_equal(high_result.1, 0)

    it "keeps valid unknown simple values as diagnostic unknown":
        val result = cbor_to_diagnostic([0xF0], 0)
        assert_equal(result.0, "?")
        assert_equal(result.1, 1)
