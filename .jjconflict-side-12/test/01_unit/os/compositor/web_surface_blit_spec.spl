## Spec for Wave 3 plumbing: COMP_CREATE_WEB_WINDOW opcode +
## src/app/ui.browser/renderer.spl::render_into().
##
## Verifies:
##   * COMP_CREATE_WEB_WINDOW is present and distinct from COMP_CREATE_WINDOW.
##   * render_into() returns a Framebuffer of the requested size.
##   * render_into() with a URL produces a non-uniform framebuffer (chrome
##     band + body), so a golden pixel test can detect the rect content.
##
## The apply-side conversion from a "create_web_window" WmAction into a
## Simple Web render-request compositor surface is covered by
## wm_action_applier_spec.spl. This spec keeps the opcode and rect renderer
## contract bounded and independent.

use std.spec.{describe, it, expect}
use os.userlib.ipc_protocol.{COMP_CREATE_WINDOW, COMP_CREATE_WEB_WINDOW}
use app.ui.browser.renderer.{Framebuffer, render_into}

describe "ipc_protocol.COMP_CREATE_WEB_WINDOW":
    """New opcode must be distinct from the legacy create opcode."""

    it "is a non-zero u32":
        expect(COMP_CREATE_WEB_WINDOW > (0 as u32)).to_equal(true)

    it "is distinct from COMP_CREATE_WINDOW":
        expect(COMP_CREATE_WEB_WINDOW).to_not_equal(COMP_CREATE_WINDOW)

describe "renderer.render_into":
    """Rect-scoped framebuffer for a simple-web window."""

    it "returns a framebuffer of the requested width":
        val fb = render_into(32, 24, "about:blank")
        expect(fb.width).to_equal(32)

    it "returns a framebuffer of the requested height":
        val fb = render_into(32, 24, "about:blank")
        expect(fb.height).to_equal(24)

    it "paints chrome + body when the URL is non-empty":
        val fb = render_into(40, 40, "https://example.com")
        val chrome_px = fb.pixels[0]
        val body_px = fb.pixels[39 * 40 + 20]
        expect(chrome_px).to_not_equal(body_px)

    it "still returns a full-size framebuffer for an empty URL":
        val fb = render_into(64, 48, "")
        expect(fb.width).to_equal(64)
        expect(fb.height).to_equal(48)

    it "has a body pixel from the canonical Simple Web renderer":
        val fb = render_into(40, 40, "about:blank")
        val body_px = fb.pixels[30 * 40 + 20]
        expect(body_px).to_not_equal(0)
