## match arm early-return propagation spec
##
## Regression for bug: interp_match_or_pattern_early_return_swallowed_2026-06-13
## Root cause: exec_block_fn used exec_if_expr/exec_match_expr for last-statement
## if/match nodes, which collapsed Control::Return into a plain value instead
## of propagating the early return to the enclosing function.
## Fix: use exec_if_core/exec_match_core which preserve Control::Return.
##
## Finding: the bug affects ALL pattern kinds (not just or-patterns) when the
## arm's last statement is an if/match containing an explicit return.

spec "match arm early-return propagation":

    enum Dir:
        North
        South
        East
        West

    fn or_pattern_if_return(d: Dir) -> i64:
        match d:
            Dir.North | Dir.South:
                if true:
                    return 1
        return 0

    fn single_pattern_if_return(d: Dir) -> i64:
        match d:
            Dir.North:
                if true:
                    return 1
        return 0

    fn arm_value_no_return(d: Dir) -> i64:
        match d:
            Dir.North | Dir.South:
                42
            _:
                0

    fn false_cond_fallthrough(d: Dir) -> i64:
        match d:
            Dir.North | Dir.South:
                if false:
                    return 1
        return 0

    fn nested_match_return(d: Dir) -> i64:
        match d:
            Dir.North | Dir.South:
                match d:
                    Dir.North:
                        return 10
                    _:
                        return 20
        return 0

    it "or-pattern first variant: explicit return inside if propagates":
        assert_equal(or_pattern_if_return(Dir.North), 1)

    it "or-pattern second variant: explicit return inside if propagates":
        assert_equal(or_pattern_if_return(Dir.South), 1)

    it "or-pattern: non-matching arm falls through to post-match return":
        assert_equal(or_pattern_if_return(Dir.East), 0)

    it "single-pattern: explicit return inside if propagates":
        assert_equal(single_pattern_if_return(Dir.North), 1)

    it "single-pattern: non-matching falls through":
        assert_equal(single_pattern_if_return(Dir.South), 0)

    it "arm value with no early return still works correctly":
        assert_equal(arm_value_no_return(Dir.North), 42)
        assert_equal(arm_value_no_return(Dir.East), 0)

    it "false if-condition: arm does not return, falls through":
        assert_equal(false_cond_fallthrough(Dir.North), 0)

    it "nested match as last statement: return propagates":
        assert_equal(nested_match_return(Dir.North), 10)
        assert_equal(nested_match_return(Dir.South), 20)
