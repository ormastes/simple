extern fn rt_env_get(key: text) -> text
extern fn rt_time_now_unix_micros() -> i64
extern fn rt_io_tcp_connect(addr: text) -> i64
extern fn rt_io_tcp_read(fd: i64, size: i64) -> [u8]
extern fn rt_io_tcp_read_exact_len(fd: i64, size: i64) -> i64
extern fn rt_io_tcp_write_text(fd: i64, data: text) -> i64
extern fn rt_io_tcp_write_text_read_exact_len(fd: i64, data: text) -> i64
extern fn rt_io_tcp_set_nodelay(fd: i64, enabled: bool) -> bool
extern fn rt_io_tcp_close(fd: i64) -> bool

fn env_text(key: text, default_value: text) -> text:
    val value = rt_env_get(key) ?? ""
    if value.len() > 0:
        value
    else:
        default_value

fn env_i64(key: text, default_value: i64) -> i64:
    val value = env_text(key, "")
    if value.len() > 0:
        value.parse_int() ?? default_value
    else:
        default_value

fn payload_text(size: i64) -> text:
    var chunk = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
    while chunk.len() < size:
        chunk = chunk + chunk
    chunk.slice(0, size)

fn read_exact(fd: i64, size: i64) -> i64:
    rt_io_tcp_read_exact_len(fd, size)

fn main():
    val addr = env_text("NET_PARITY_ADDR", "127.0.0.1:39091")
    val iterations = env_i64("NET_PARITY_ITERS", 10000)
    val payload_size = env_i64("NET_PARITY_PAYLOAD", 1024)
    val fd = rt_io_tcp_connect(addr)
    if fd < 0:
        print "[netbench-error] lang=simple case=tcp_echo connect"
        return
    rt_io_tcp_set_nodelay(fd, true)

    val payload = payload_text(payload_size)
    var checksum: i64 = 0
    var i: i64 = 0
    val start = rt_time_now_unix_micros()
    while i < iterations:
        val got = rt_io_tcp_write_text_read_exact_len(fd, payload)
        if got != payload_size:
            print "[netbench-error] lang=simple case=tcp_echo roundtrip got={got}"
            rt_io_tcp_close(fd)
            return
        checksum = checksum + got
        i = i + 1
    val elapsed = rt_time_now_unix_micros() - start
    rt_io_tcp_close(fd)
    print "[netbench] lang=simple case=tcp_echo bytes={checksum} iters={iterations} micros={elapsed} checksum={checksum}"
