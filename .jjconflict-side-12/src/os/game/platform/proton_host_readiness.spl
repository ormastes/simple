"""Proton host readiness checks for SimpleOS.

Validates prerequisites before claiming Steam Runtime and Proton support.
Follows coordination rule: no Proton claim without Linux personality + device readiness.
"""

class ProtonHostCheck:
    check_name: text
    category: text
    passed: bool
    detail: text

    static fn pass_check(name: text, cat: text) -> ProtonHostCheck:
        ProtonHostCheck(check_name: name, category: cat, passed: true, detail: "")

    static fn fail_check(name: text, cat: text, reason: text) -> ProtonHostCheck:
        ProtonHostCheck(check_name: name, category: cat, passed: false, detail: reason)

    me summary() -> text:
        val status = if self.passed { "PASS" } else { "FAIL" }
        status + " [" + self.category + "] " + self.check_name +
            if self.detail == "" { "" } else { ": " + self.detail }


class ProtonHostReadiness:
    linux_abi_ok: bool
    vulkan_ok: bool
    audio_ok: bool
    input_ok: bool
    prefix_ok: bool
    steam_runtime_version: text
    proton_version: text
    check_count: i64
    pass_count: i64

    static fn create() -> ProtonHostReadiness:
        ProtonHostReadiness(
            linux_abi_ok: false,
            vulkan_ok: false,
            audio_ok: false,
            input_ok: false,
            prefix_ok: false,
            steam_runtime_version: "",
            proton_version: "",
            check_count: 0,
            pass_count: 0
        )

    me set_linux_abi(ok: bool):
        self.linux_abi_ok = ok
        self.check_count = self.check_count + 1
        if ok:
            self.pass_count = self.pass_count + 1

    me set_vulkan(ok: bool):
        self.vulkan_ok = ok
        self.check_count = self.check_count + 1
        if ok:
            self.pass_count = self.pass_count + 1

    me set_audio(ok: bool):
        self.audio_ok = ok
        self.check_count = self.check_count + 1
        if ok:
            self.pass_count = self.pass_count + 1

    me set_input(ok: bool):
        self.input_ok = ok
        self.check_count = self.check_count + 1
        if ok:
            self.pass_count = self.pass_count + 1

    me set_prefix(ok: bool):
        self.prefix_ok = ok
        self.check_count = self.check_count + 1
        if ok:
            self.pass_count = self.pass_count + 1

    me set_steam_runtime(ver: text):
        self.steam_runtime_version = ver

    me set_proton(ver: text):
        self.proton_version = ver

    me is_host_ready() -> bool:
        self.linux_abi_ok and self.vulkan_ok and self.audio_ok and self.input_ok and self.prefix_ok

    me blocker_count() -> i64:
        self.check_count - self.pass_count

    me readiness_percent() -> i64:
        if self.check_count == 0:
            return 0
        (self.pass_count * 100) / self.check_count

    me report() -> text:
        "proton_host: linux_abi=" + self.linux_abi_ok.to_text() +
            " vulkan=" + self.vulkan_ok.to_text() +
            " audio=" + self.audio_ok.to_text() +
            " input=" + self.input_ok.to_text() +
            " prefix=" + self.prefix_ok.to_text() +
            " sr=" + self.steam_runtime_version +
            " proton=" + self.proton_version +
            " ready=" + self.is_host_ready().to_text() +
            " blockers=" + self.blocker_count().to_text()


fn assess_proton_host(
    linux_abi: bool, has_vulkan: bool,
    has_audio: bool, has_input: bool, has_prefix: bool,
    sr_ver: text, proton_ver: text
) -> ProtonHostReadiness:
    var host = ProtonHostReadiness.create()
    host.set_linux_abi(linux_abi)
    host.set_vulkan(has_vulkan)
    host.set_audio(has_audio)
    host.set_input(has_input)
    host.set_prefix(has_prefix)
    host.set_steam_runtime(sr_ver)
    host.set_proton(proton_ver)
    host
