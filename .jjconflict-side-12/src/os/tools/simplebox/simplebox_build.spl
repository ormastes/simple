# simplebox build wiring — cross-compile the simplebox userland binary for SimpleOS.
#
# Produces build/os/rootfs/bin/simplebox via native-build, compiling
# simplebox_main.spl and (via --entry-closure) its full import closure — which
# includes the pure-Simple libc it consumes — then links freestanding against
# the SimpleOS sysroot linker script. The image builder packs the result at
# /bin/simplebox. Mirrors scripts/os/simpleos-native-build.shs and the riscv
# kernel lane (--entry-closure + --linker-script + freestanding --target).
#
# Prereq: the sysroot must exist (sh src/os/port/llvm/sysroot.shs) so the libc
# archive, crt0, and linker script are available.

use std.process

val SIMPLEBOX_ENTRY: text = "src/os/tools/simplebox/simplebox_main.spl"
val SIMPLEOS_LINKER_SCRIPT: text = "build/os/sysroot/share/simpleos/simpleos.ld"
val DEFAULT_TARGET_TRIPLE: text = "x86_64-unknown-none"

fn simplebox_output_path() -> text:
    """Rootfs path of the compiled simplebox binary (packed at /bin/simplebox)."""
    "build/os/rootfs/bin/simplebox"

fn simplebox_native_build_cmd(target_triple: text) -> [text]:
    """native-build argv that cross-compiles simplebox for a freestanding
    SimpleOS target. target_triple e.g. x86_64-unknown-none / riscv64gc-unknown-none."""
    [
        "native-build", "--backend", "llvm",
        "--source", "src/os", "--source", "src/lib",
        "--entry", SIMPLEBOX_ENTRY, "--entry-closure",
        "--target", target_triple,
        "--linker-script", SIMPLEOS_LINKER_SCRIPT,
        "-o", simplebox_output_path()
    ]

fn _is_freestanding_target(target_triple: text) -> bool:
    target_triple.ends_with("-none") or target_triple.contains("-none-")

fn build_simplebox(target_triple: text) -> i32:
    """Cross-compile simplebox for a freestanding SimpleOS target into the rootfs.
    Returns the native-build exit code (2 if the triple is not freestanding). The
    caller must ensure the sysroot exists first (sh src/os/port/llvm/sysroot.shs)."""
    if not _is_freestanding_target(target_triple):
        return 2
    val args = simplebox_native_build_cmd(target_triple)
    val (out, err, rc) = process.run("bin/simple", args)
    rc
