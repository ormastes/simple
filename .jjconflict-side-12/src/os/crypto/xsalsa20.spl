# =============================================================================
# XSalsa20 and HSalsa20 — Extended-Nonce Stream Cipher
#
# XSalsa20 extends Salsa20 with a 192-bit (24-byte) nonce by using HSalsa20
# as a key-derivation step before the normal Salsa20/20 encryption.
#
# References:
#   DJB, "Extending the Salsa20 nonce" (2008/2011) —
#     https://cr.yp.to/snuffle/xsalsa-20110204.pdf
#   NaCl crypto_stream_xsalsa20 — https://nacl.cr.yp.to/stream.html
#
# Implementation delegates to os.crypto.salsa20 for all core operations.
# =============================================================================

mod os.crypto.xsalsa20

use os.crypto.salsa20.{hsalsa20, xsalsa20_xor}

fn hsalsa20(key: [u8], nonce16: [u8]) -> [u8]:
    """HSalsa20 sub-key derivation.

    Runs the Salsa20/20 permutation on (key, nonce16) without the final
    state-addition step and extracts words [0,5,10,15,6,7,8,9] as 32 bytes.

    Args:
        key: 32-byte key.
        nonce16: 16-byte input (typically the first 16 bytes of an XSalsa20 nonce).

    Returns: 32-byte derived sub-key.

    Example:
        val subkey = hsalsa20(key32, nonce_head16)
    """
    os.crypto.salsa20.hsalsa20(key, nonce16)

fn xsalsa20_encrypt(key: [u8], nonce: [u8], plaintext: [u8]) -> [u8]:
    """Encrypt using XSalsa20 — 32-byte key, 24-byte nonce.

    Derives a sub-key via HSalsa20(key, nonce[0..16]) then runs
    Salsa20/20 with the sub-key and nonce[16..24].

    Args:
        key: 32-byte key.
        nonce: 24-byte nonce.
        plaintext: Plaintext bytes to encrypt.

    Returns: Ciphertext bytes, same length as plaintext.

    Example:
        val ct = xsalsa20_encrypt(key32, nonce24, message)
    """
    xsalsa20_xor(key, nonce, plaintext)

fn xsalsa20_decrypt(key: [u8], nonce: [u8], ciphertext: [u8]) -> [u8]:
    """Decrypt using XSalsa20 — 32-byte key, 24-byte nonce.

    XSalsa20 is a stream cipher; decryption is identical to encryption
    (XOR with the same keystream).

    Args:
        key: 32-byte key.
        nonce: 24-byte nonce.
        ciphertext: Ciphertext bytes to decrypt.

    Returns: Plaintext bytes, same length as ciphertext.

    Example:
        val pt = xsalsa20_decrypt(key32, nonce24, ct)
    """
    xsalsa20_xor(key, nonce, ciphertext)
