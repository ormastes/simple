# Unit: Nit
# Kind: Luminance
# Symbol: nit
# Canonical scale: 1.0 cd_per_m2

class Nit:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Nit) -> Nit: Nit(value: self.value + other.value)
    fn sub(other: Nit) -> Nit: Nit(value: self.value - other.value)

    static fn kind() -> text: "Luminance"
    static fn symbol() -> text: "nit"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "cd_per_m2"
    static fn zero() -> Nit: Nit(value: 0.0)

export Nit
