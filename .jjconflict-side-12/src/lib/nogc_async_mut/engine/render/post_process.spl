# Post-Processing — screen-space effects applied after scene rendering
#
# Configurable post-processing stack with bloom, blur, color grading,
# vignette, and chromatic aberration. Effects are ordered by priority
# and can be individually toggled.
#
# Usage:
#   var stack = PostProcessStack.new()
#   stack.enable_bloom(default_bloom())
#   stack.enable_vignette(default_vignette())
#   val active = stack.active_effects()

# ============================================================================
# PostEffectType — available post-processing effect kinds
# ============================================================================

enum PostEffectType:
    Bloom
    Blur
    ColorGrade
    Vignette
    ChromaticAberration

impl PostEffectType:
    fn to_text() -> text:
        """Convert effect type to human-readable text."""
        match self:
            case Bloom: "Bloom"
            case Blur: "Blur"
            case ColorGrade: "ColorGrade"
            case Vignette: "Vignette"
            case ChromaticAberration: "ChromaticAberration"

    fn order_value() -> i32:
        """Default ordering for effect application."""
        match self:
            case Bloom: 10
            case Blur: 20
            case ColorGrade: 30
            case Vignette: 40
            case ChromaticAberration: 50

# ============================================================================
# Effect configurations
# ============================================================================

struct BloomConfig:
    threshold: f64
    intensity: f64
    radius: f64

struct BlurConfig:
    radius: f64
    passes: i32

struct ColorGradeConfig:
    brightness: f64
    contrast: f64
    saturation: f64
    gamma: f64

struct VignetteConfig:
    intensity: f64
    radius: f64
    softness: f64

struct ChromaticAberrationConfig:
    offset: f64

# ============================================================================
# Default configuration constructors
# ============================================================================

fn default_bloom() -> BloomConfig:
    """Standard bloom: threshold 0.8, intensity 1.0, radius 4.0."""
    BloomConfig(threshold: 0.8, intensity: 1.0, radius: 4.0)

fn default_blur() -> BlurConfig:
    """Standard Gaussian blur: radius 2.0, 2 passes."""
    BlurConfig(radius: 2.0, passes: 2)

fn default_color_grade() -> ColorGradeConfig:
    """Neutral color grade (no adjustment)."""
    ColorGradeConfig(brightness: 1.0, contrast: 1.0, saturation: 1.0, gamma: 1.0)

fn default_vignette() -> VignetteConfig:
    """Subtle vignette: intensity 0.5, radius 0.8, softness 0.4."""
    VignetteConfig(intensity: 0.5, radius: 0.8, softness: 0.4)

fn default_chromatic_aberration() -> ChromaticAberrationConfig:
    """Mild chromatic aberration: 2px offset."""
    ChromaticAberrationConfig(offset: 2.0)

# ============================================================================
# PostEffect — individual effect entry in the stack
# ============================================================================

struct PostEffect:
    effect_type: PostEffectType
    enabled: bool
    order: i32

# ============================================================================
# PostProcessStack — ordered collection of post-processing effects
# ============================================================================

class PostProcessStack:
    effects: [PostEffect]
    bloom: BloomConfig
    blur: BlurConfig
    color_grade: ColorGradeConfig
    vignette: VignetteConfig
    chromatic: ChromaticAberrationConfig
    enabled: bool

impl PostProcessStack:
    static fn new() -> PostProcessStack:
        """Create an empty post-process stack with default configurations."""
        PostProcessStack(
            effects: [],
            bloom: default_bloom(),
            blur: default_blur(),
            color_grade: default_color_grade(),
            vignette: default_vignette(),
            chromatic: default_chromatic_aberration(),
            enabled: true
        )

    me enable_bloom(config: BloomConfig):
        """Enable bloom with the given configuration."""
        self.bloom = config
        self._set_effect_enabled(PostEffectType.Bloom, true)

    me enable_blur(config: BlurConfig):
        """Enable blur with the given configuration."""
        self.blur = config
        self._set_effect_enabled(PostEffectType.Blur, true)

    me enable_color_grade(config: ColorGradeConfig):
        """Enable color grading with the given configuration."""
        self.color_grade = config
        self._set_effect_enabled(PostEffectType.ColorGrade, true)

    me enable_vignette(config: VignetteConfig):
        """Enable vignette with the given configuration."""
        self.vignette = config
        self._set_effect_enabled(PostEffectType.Vignette, true)

    me enable_chromatic(config: ChromaticAberrationConfig):
        """Enable chromatic aberration with the given configuration."""
        self.chromatic = config
        self._set_effect_enabled(PostEffectType.ChromaticAberration, true)

    me disable_effect(effect_type: PostEffectType):
        """Disable a specific effect by type."""
        self._set_effect_enabled(effect_type, false)

    me set_enabled(enabled: bool):
        """Enable or disable the entire post-process stack."""
        self.enabled = enabled

    me _set_effect_enabled(effect_type: PostEffectType, enabled: bool):
        """Internal: toggle an effect, adding it to the list if new."""
        var found = false
        var i = 0
        while i < self.effects.len():
            val eff = self.effects[i]
            if eff.effect_type.to_text() == effect_type.to_text():
                self.effects[i] = PostEffect(
                    effect_type: effect_type,
                    enabled: enabled,
                    order: eff.order
                )
                found = true
                i = self.effects.len()  # break
            else:
                i = i + 1
        if not found:
            val eff = PostEffect(
                effect_type: effect_type,
                enabled: enabled,
                order: effect_type.order_value()
            )
            self.effects = self.effects.push(eff)

    fn active_effects(self) -> [PostEffect]:
        """Return only the enabled effects, sorted by order (insertion sort)."""
        if not self.enabled:
            return []
        # Collect enabled effects
        var result: [PostEffect] = []
        var i = 0
        while i < self.effects.len():
            if self.effects[i].enabled:
                result = result.push(self.effects[i])
            i = i + 1
        # Insertion sort by order
        val n = result.len()
        var si = 1
        while si < n:
            val key = result[si]
            val key_order = key.order
            var j = si - 1
            while j >= 0:
                if result[j].order > key_order:
                    result[j + 1] = result[j]
                    j = j - 1
                else:
                    j = -1  # break
            result[j + 1] = key
            si = si + 1
        result

    fn effect_count(self) -> i32:
        """Return the number of registered effects (enabled or disabled)."""
        self.effects.len()
