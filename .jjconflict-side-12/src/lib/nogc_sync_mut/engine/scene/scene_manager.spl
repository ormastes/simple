# Scene Manager — Multi-Scene Load/Unload
#
# Manages multiple scenes within a shared NodeStore. Each scene is a subtree
# rooted at a dedicated node. Supports additive loading (multiple scenes
# active simultaneously) and scene switching.
#
# Usage:
#   var store = NodeStore.new()
#   var mgr = SceneManager.new(store)
#   val handle = mgr.load_scene("level_1")
#   mgr.set_active(handle.id)

use std.common.engine.ids.{NodeId}
use std.nogc_sync_mut.engine.scene.node.{NodeStore}

# ============================================================================
# SceneHandle — lightweight reference to a loaded scene
# ============================================================================

struct SceneHandle:
    """Identifies a loaded scene by id, name, and its root node in the store."""
    id: i64
    name: text
    root_node: NodeId

# ============================================================================
# SceneManager — orchestrates multiple scenes in a shared NodeStore
# ============================================================================

class SceneManager:
    """Manages multiple scenes as subtrees within a single NodeStore.

    Each loaded scene gets its own root node. One scene can be marked
    active at a time, while additive scenes coexist alongside it.
    """
    scenes: [SceneHandle]
    active_scene: i64
    next_id: i64
    store: NodeStore

impl SceneManager:
    static fn new(store: NodeStore) -> SceneManager:
        """Create a scene manager that operates on the given NodeStore."""
        SceneManager(
            scenes: [],
            active_scene: -1,
            next_id: 1,
            store: store
        )

    me load_scene(name: text) -> SceneHandle:
        """Create a new scene with its own root node and set it as active.

        Returns the SceneHandle for the newly loaded scene.
        """
        val root_id = self.store.create_node(name)
        val handle = SceneHandle(
            id: self.next_id,
            name: name,
            root_node: root_id
        )
        self.scenes.push(handle)
        self.active_scene = self.next_id
        self.next_id = self.next_id + 1
        handle

    me unload_scene(scene_id: i64) -> bool:
        """Remove a scene and destroy its root node. Returns false if not found."""
        var idx = -1
        var i = 0
        while i < self.scenes.len():
            if self.scenes[i].id == scene_id:
                idx = i
            i = i + 1

        if idx < 0:
            return false

        val handle = self.scenes[idx]
        self.store.destroy_node(handle.root_node)

        # Remove from scenes list
        var new_scenes: [SceneHandle] = []
        var j = 0
        while j < self.scenes.len():
            if self.scenes[j].id != scene_id:
                new_scenes.push(self.scenes[j])
            j = j + 1
        self.scenes = new_scenes

        # Clear active if it was the unloaded scene
        if self.active_scene == scene_id:
            self.active_scene = -1

        true

    me load_additive(name: text) -> SceneHandle:
        """Load a scene alongside the current active scene.

        Does not change the active scene. The new scene's root node is
        added to the store as a separate root.
        """
        val root_id = self.store.create_node(name)
        val handle = SceneHandle(
            id: self.next_id,
            name: name,
            root_node: root_id
        )
        self.scenes.push(handle)
        self.next_id = self.next_id + 1
        handle

    me set_active(scene_id: i64) -> bool:
        """Set the active scene by id. Returns false if not found."""
        var i = 0
        while i < self.scenes.len():
            if self.scenes[i].id == scene_id:
                self.active_scene = scene_id
                return true
            i = i + 1
        false

    fn get_active() -> SceneHandle?:
        """Get the currently active scene, or nil if none."""
        if self.active_scene < 0:
            return nil
        var i = 0
        while i < self.scenes.len():
            if self.scenes[i].id == self.active_scene:
                return self.scenes[i]
            i = i + 1
        nil

    fn get_scene(scene_id: i64) -> SceneHandle?:
        """Look up a scene by id. Returns nil if not found."""
        var i = 0
        while i < self.scenes.len():
            if self.scenes[i].id == scene_id:
                return self.scenes[i]
            i = i + 1
        nil

    fn scene_count() -> i64:
        """Number of currently loaded scenes."""
        self.scenes.len()

    fn get_all_scenes() -> [SceneHandle]:
        """Return a copy of all loaded scene handles."""
        self.scenes
