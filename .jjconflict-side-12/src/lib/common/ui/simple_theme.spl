use common.ui.glass.tokens.{GlassDesignTokens}

class SimpleTheme:
    name: text
    css: text
    tokens: GlassDesignTokens
    token_map: Dict<text, text>

    static fn from_css(name: text, css: text) -> SimpleTheme:
        SimpleTheme(
            name: name,
            css: css,
            tokens: _simple_theme_tokens_for_name(name),
            token_map: _simple_theme_token_map_from_css(css)
        )

    fn resolve_token(key: text) -> text:
        val normalized = if key.starts_with("--"): key else: "--{key}"
        if self.token_map.contains_key(normalized):
            return self.token_map[normalized]
        return _simple_theme_fallback_token(normalized, self.tokens)

fn _simple_theme_tokens_for_name(name: text) -> GlassDesignTokens:
    val lower = name.to_lower()
    if lower == "light" or lower == "ios_light" or lower == "obsidian_light":
        return GlassDesignTokens.obsidian_light()
    if lower == "dark" or lower == "ios_dark":
        return GlassDesignTokens.dark()
    GlassDesignTokens.obsidian_dark()

fn _simple_theme_token_map_from_css(css: text) -> Dict<text, text>:
    var out: Dict<text, text> = {}
    for line in css.split("\n"):
        val trimmed = line.trim()
        if trimmed.starts_with("--") and trimmed.contains(":"):
            val parts = trimmed.split(":")
            if parts.len() >= 2:
                val key = parts[0].trim()
                var value = parts[1].trim()
                if value.ends_with(";"):
                    value = value.substring(0, value.len() - 1).trim()
                out[key] = value
    out

fn _simple_theme_fallback_token(key: text, tokens: GlassDesignTokens) -> text:
    val colors = tokens.colors
    if key == "--ui-bg":
        return colors.surface_level_0
    if key == "--ui-fg":
        return colors.text_primary
    if key == "--ui-accent":
        return colors.accent
    if key == "--app-bg":
        return colors.surface_level_0
    if key == "--app-surface":
        return colors.surface_primary
    if key == "--app-border":
        return colors.border_subtle
    if key == "--app-surface-hover":
        return colors.surface_secondary
    if key == "--ui-error":
        return colors.error
    if key == "--ui-warning":
        return colors.warning
    if key == "--ui-success":
        return colors.success
    if key == "--ui-info":
        return colors.info
    ""
