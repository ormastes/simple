# Re-exports for std.skia.feature.text.
#
# This module bundles the simple text line breaker (UAX#14-simplified,
# English/Latin focused) that mirrors Skia's SkShaper line break logic.
#
# Exported surface:
#
#   - BreakKind (enum)
#       Variants:
#           Hard   — mandatory break (newline)
#           Soft   — optional break (space, tab, hyphen, slash)
#           None   — sentinel, not emitted by find_break_opportunities
#
#   - BreakPoint (class)
#       Fields:
#           position: i64      — codeunit offset in the source text
#           kind: BreakKind
#           break_before: bool — true for whitespace/newline, false for
#                                break-after characters (hyphen, slash)
#
#   - WrappedLine (class)
#       Fields:
#           start: i64         — inclusive codeunit offset
#           end: i64           — exclusive codeunit offset
#           width: f64         — measured pixel width of the slice
#
#   - find_break_opportunities(text: String) -> [BreakPoint]
#       Scans text and emits a BreakPoint for every whitespace, hyphen, or
#       slash encountered.
#
#   - wrap_text(text: String, max_width: f64, char_width: f64)
#         -> [WrappedLine]
#       Greedy line packing. Because Simple does not yet expose first-class
#       fn callbacks stably across modules, width measurement is done with a
#       caller-supplied fixed per-character width. Callers who need a real
#       proportional font measurement should pre-scale max_width to units of
#       char_width.

use std.skia.feature.text.line_break.{
    BreakKind,
    BreakPoint,
    WrappedLine,
    find_break_opportunities,
    wrap_text
}
