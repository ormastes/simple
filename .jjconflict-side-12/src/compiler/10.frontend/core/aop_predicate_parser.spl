# AOP Predicate Parser — Validates pc{...} expressions
#
# Validates that pointcut expressions use only supported selectors
# and have correct syntax. Returns error text on failure, empty on success.
#
# Supported selectors: execution(...), within(...), attr(...)
# Supported operators: & (AND), | (OR), ! (NOT), ( ) (grouping)
# Deferred selectors: get, set, init, effect → E1507

# ============================================================================
# Predicate Validation
# ============================================================================

fn validate_predicate(input: text) -> text:
    """Validate a pointcut expression. Returns empty string on success, error message on failure."""
    if input == nil or input.len() == 0:
        return "E1501: empty pointcut expression"
    val trimmed = text_trim(input)
    if trimmed.len() == 0:
        return "E1501: empty pointcut expression"
    # Wildcard-only is always valid
    if trimmed == "*":
        return ""
    # Check for balanced parentheses
    var paren_depth = 0
    var ci = 0
    while ci < trimmed.len():
        if trimmed[ci] == "(":
            paren_depth = paren_depth + 1
        elif trimmed[ci] == ")":
            paren_depth = paren_depth - 1
            if paren_depth < 0:
                return "E1501: unmatched closing parenthesis in pointcut"
        ci = ci + 1
    if paren_depth != 0:
        return "E1501: unmatched opening parenthesis in pointcut"
    # Tokenize and validate selectors
    val selectors = extract_selectors(trimmed)
    for sel in selectors:
        val err = validate_selector(sel)
        if err.len() > 0:
            return err
    ""

fn extract_selectors(expr: text) -> [text]:
    """Extract selector names from a pointcut expression (e.g. 'execution', 'within')."""
    var result: [text] = []
    var i = 0
    while i < expr.len():
        val ch = expr[i]
        # Skip operators and whitespace
        if ch == "&" or ch == "|" or ch == "!" or ch == " " or ch == "(" or ch == ")":
            i = i + 1
        elif is_alpha(ch):
            # Collect identifier
            var ident = ""
            while i < expr.len() and is_alpha_num(expr[i]):
                ident = ident + expr[i]
                i = i + 1
            # Check if followed by '(' — then it's a selector call
            if i < expr.len() and expr[i] == "(":
                result.push(ident)
                # Skip past the '(' and content to matching ')'
                var depth = 1
                i = i + 1
                while i < expr.len() and depth > 0:
                    if expr[i] == "(":
                        depth = depth + 1
                    elif expr[i] == ")":
                        depth = depth - 1
                    i = i + 1
            # else: bare identifier (e.g. glob pattern), skip
        else:
            i = i + 1
    result

fn validate_selector(name: text) -> text:
    """Validate that a selector name is in the supported set."""
    if name == "execution": return ""
    if name == "within": return ""
    if name == "attr": return ""
    # Deferred selectors — reject with E1507
    if name == "get": return "E1507: selector 'get' is deferred — not supported in current AOP subset"
    if name == "set": return "E1507: selector 'set' is deferred — not supported in current AOP subset"
    if name == "init": return "E1507: selector 'init' is deferred — not supported in current AOP subset"
    if name == "effect": return "E1507: selector 'effect' is deferred — not supported in current AOP subset"
    "E1507: unknown pointcut selector '{name}'"

fn validate_advice_form(form: text) -> text:
    """Validate that an advice form is supported."""
    if form == "before": return ""
    if form == "after_success": return ""
    if form == "after_error": return ""
    if form == "around": return ""
    "E1503: invalid advice type '{form}' — supported: before, after_success, after_error, around"

# ============================================================================
# Helper Functions
# ============================================================================

fn text_trim(s: text) -> text:
    """Trim leading and trailing whitespace."""
    var start = 0
    while start < s.len() and s[start] == " ":
        start = start + 1
    var end = s.len()
    while end > start and s[end - 1] == " ":
        end = end - 1
    if start >= end: return ""
    s.slice(start, end)

fn is_alpha(ch: text) -> bool:
    if ch == nil: return false
    if ch.len() != 1: return false
    val c = ch[0]
    val lower = c >= "a" and c <= "z"
    val upper = c >= "A" and c <= "Z"
    val under = c == "_"
    lower or upper or under

fn is_alpha_num(ch: text) -> bool:
    if is_alpha(ch): return true
    val c = ch[0]
    c >= "0" and c <= "9"
