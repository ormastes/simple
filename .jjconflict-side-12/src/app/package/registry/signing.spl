# Package Signing
# Ed25519 / HMAC-SHA256 signature types and hex helpers for .spk packages.

# Signature metadata stored in the registry index.
class PackageSignature:
    signer_fingerprint: text
    signature: text
    algorithm: text
    signed_at: text

fn hex_to_bytes(hex: text) -> [u8]:
    var result: [u8] = []
    val len = hex.len()
    var i = 0
    while i + 1 < len:
        val hi = hex_digit_value(hex.char_at(i))
        val lo = hex_digit_value(hex.char_at(i + 1))
        if hi >= 0 and lo >= 0:
            result.push((hi * 16 + lo).to_u8())
        i = i + 2
    result

fn bytes_to_hex(data: [u8]) -> text:
    val hex_chars = "0123456789abcdef"
    var result = ""
    for b in data:
        val hi = (b.to_i64() >> 4) & 15
        val lo = b.to_i64() & 15
        result = result + hex_chars.slice(hi, hi + 1) + hex_chars.slice(lo, lo + 1)
    result

fn hex_digit_value(ch: i64) -> i64:
    if ch >= 48 and ch <= 57:
        return ch - 48
    if ch >= 65 and ch <= 70:
        return ch - 55
    if ch >= 97 and ch <= 102:
        return ch - 87
    -1
