# Pure Simple entrypoint for `simple vscode`.

use std.cli.cli_util.{get_cli_args}
use app.io.process_ops.{process_run_timeout}

val OUTPUT_LIMIT = 12000

fn args_after_command() -> [text]:
    val raw = get_cli_args()
    var args: [text] = []
    var start = 1
    var i = 0
    while i < raw.len():
        if raw[i].ends_with("vscode_entry.spl") or raw[i] == "vscode":
            start = i + 1
            break
        i = i + 1
    i = start
    while i < raw.len():
        args.push(raw[i])
        i = i + 1
    args

fn print_help():
    print "Usage: simple vscode <build|package|publish> [options]"
    print ""
    print "Commands:"
    print "  build <source.spl>      Build the VSCode extension workspace"
    print "  package [dir]           Package extension with npm/vsce"
    print "  publish <vsix>          Publish package with npm/vsce"

fn shell_join(args: [text]) -> text:
    args.join(" ")

fn print_bounded(output: text):
    if output.len() == 0:
        return
    if output.len() <= OUTPUT_LIMIT:
        print output
        return
    print output[0:OUTPUT_LIMIT]
    print "[output truncated by vscode entry]"

fn eprint_bounded(output: text):
    if output.len() == 0:
        return
    if output.len() <= OUTPUT_LIMIT:
        eprint output
        return
    eprint output[0:OUTPUT_LIMIT]
    eprint "[stderr truncated by vscode entry]"

fn run_shell(command: text) -> i64:
    val (stdout, stderr, code) = process_run_timeout("sh", ["-c", command], 120000)
    print_bounded(stdout)
    eprint_bounded(stderr)
    code as i64

fn main() -> i64:
    val args = args_after_command()
    if args.len() == 0 or args.contains("-h") or args.contains("--help"):
        print_help()
        if args.len() == 0:
            return 1
        return 0

    val sub = args[0]
    if sub == "build":
        if args.len() < 2:
            eprint "error: vscode build requires a source file"
            return 1
        return run_shell("npm --prefix src/app/vscode_extension run compile")
    if sub == "package":
        return run_shell("cd src/app/vscode_extension && if [ -x node_modules/.bin/vsce ]; then node_modules/.bin/vsce package; else echo 'error: local VSCE package command not installed; run npm install with @vscode/vsce in this workspace' >&2; exit 1; fi")
    if sub == "publish":
        if args.len() < 2:
            eprint "error: vscode publish requires a .vsix path"
            return 1
        return run_shell("cd src/app/vscode_extension && if [ -x node_modules/.bin/vsce ]; then node_modules/.bin/vsce publish " + shell_join(args.slice(1, args.len())) + "; else echo 'error: local VSCE publish command not installed; run npm install with @vscode/vsce in this workspace' >&2; exit 1; fi")

    eprint "error: unknown vscode subcommand '{sub}'"
    1
