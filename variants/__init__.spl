# Variant overlay manifest (resolver-owned, SDN).
#
# This is the canonical `variants/` overlay manifest. It is parsed by the module
# resolver via the bootstrap-safe line reader in
# src/compiler/99.loader/module_resolver/var_resolution.spl (var_parse_manifest),
# NOT by the full SDN parser. `variants/` is a resolver-only root: source code
# imports stable module names (e.g. `use crypto.provider`) and config selects the
# active variant. `use variants.*` / `use var.*` are rejected (E-VAR005).
#
# Every group MUST contain `default`; every fallback chain MUST end at `default`.
# See doc/02_requirements/feature/var_resolution_rules.md.

var:
  version: 1
  default: default
  order: [platform, hw, lib.crypto, ui.renderer]
  groups:
    platform: { values: [default, mac, linux, windows, freebsd, baremetal], select_default: auto }
    hw: { values: [default, x86_64, arm64, riscv64, wasm32], select_default: auto }
    lib.crypto: { values: [default, openssl, mbedtls], select_default: default }
    ui.renderer: { values: [default, cpu, metal, vulkan, webgpu], select_default: default }
  policy:
    unknown_group: error
    unknown_value: error
    duplicate_same_rank: error
    direct_var_import: error
    default_required: error
    src_is_default: true
    cache_includes_var_fingerprint: true
