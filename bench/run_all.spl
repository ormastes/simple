# bench/run_all.spl — Run all Phase 9 storage benchmarks sequentially.
#
# Prints combined CSV table and a markdown summary to stdout.
# Redirect stdout to capture baselines:
#   bin/simple run bench/run_all.spl > doc/08_tracking/bench/baseline_YYYY-MM-DD.csv
#
# DISCLAIMER: All benchmarks measure in-memory / in-process implementations.
# None reflect real SSD hardware. See bench/README.md for the full disclaimer
# and the 4 SSD-iq criteria that require Phase 10+ NVMe driver work.
#
# Run: bin/simple run bench/run_all.spl

use bench.lib.timing.{BenchResult, bench_print, bench_csv, bench_csv_header, bench_now_ns}
use std.fs_driver.mount_table.{MountTable}
use std.fs_driver.types.{Path, MountOptions}
use std.fs_driver.instance.{DriverInstance, RamFsStub}

# ── Shared helpers ────────────────────────────────────────────────────────────

fn _drv() -> DriverInstance:
    DriverInstance.RamFs(driver: RamFsStub(name: "bench"))

fn _opts() -> MountOptions:
    MountOptions.default()

fn _path(raw: text) -> Path:
    Path(raw: raw)

# ── Inline sort + result builder (keep run_all self-contained) ────────────────

fn _rsort(s: [i64]) -> [i64]:
    var r: [i64] = s
    val n: i64 = r.len() as i64
    var i: i64 = 1
    while i < n:
        val key: i64 = r[i as i32]
        var j: i64 = i - 1
        while j >= 0 and r[j as i32] > key:
            r[(j + 1) as i32] = r[j as i32]
            j = j - 1
        r[(j + 1) as i32] = key
        i = i + 1
    r

fn _rpct(sorted: [i64], num: i64, den: i64) -> i64:
    val n: i64 = sorted.len() as i64
    if n == 0:
        return 0
    var idx: i64 = (n * num) / den
    if idx >= n:
        idx = n - 1
    sorted[idx as i32]

fn _mk(label: text, iters: i64, samples: [i64]) -> BenchResult:
    val s: [i64] = _rsort(samples)
    val n: i64 = s.len() as i64
    val mn: i64 = if n > 0: s[0] else: 0
    val mx: i64 = if n > 0: s[(n - 1) as i32] else: 0
    var total: i64 = 0
    var k: i64 = 0
    while k < n:
        total = total + s[k as i32]
        k = k + 1
    val tput: i64 = if total > 0: (iters * 1000) / total else: 0
    BenchResult(
        label: label, iters: iters,
        p50_ns: _rpct(s, 50, 100), p99_ns: _rpct(s, 99, 100),
        p99_9_ns: _rpct(s, 999, 1000),
        min_ns: mn, max_ns: mx, total_ns: total,
        throughput_ops_per_s: tput,
    )

# ── Mini mount-table bench (representative scenario) ─────────────────────────

fn run_mount_bench() -> BenchResult:
    var mt: MountTable = MountTable.new()
    mt.mount(_path("/"), _drv(), _opts())
    mt.mount(_path("/mnt"), _drv(), _opts())
    mt.mount(_path("/mnt/data"), _drv(), _opts())
    val target: Path = _path("/mnt/data/file")
    val iters: i64 = 10000
    var samples: [i64] = []
    var i: i64 = 0
    while i < iters:
        val t0: i64 = bench_now_ns()
        val _r = mt.resolve(target)
        val t1: i64 = bench_now_ns()
        samples.push(t1 - t0)
        i = i + 1
    _mk("mount_resolve_3mount_10k", iters, samples)

# ── Mini WAL bench (representative scenario) ──────────────────────────────────
# Inline shim rather than importing spostgre_wal_append to avoid circular use.

class _RunWal:
    total_bytes: i64
    record_count: i64

fn _wal_append(w: _RunWal, body: i64) -> _RunWal:
    _RunWal(total_bytes: w.total_bytes + 16 + body, record_count: w.record_count + 1)

fn run_wal_bench() -> BenchResult:
    val iters: i64 = 1000
    var samples: [i64] = []
    var i: i64 = 0
    while i < iters:
        var w: _RunWal = _RunWal(total_bytes: 0, record_count: 0)
        val t0: i64 = bench_now_ns()
        w = _wal_append(w, 256)
        val t1: i64 = bench_now_ns()
        samples.push(t1 - t0)
        i = i + 1
    _mk("wal_append_256B_x1000", iters, samples)

# ── Markdown summary row ──────────────────────────────────────────────────────

fn _md_row(r: BenchResult) -> text:
    "| {r.label} | {r.iters} | {r.p50_ns} | {r.p99_ns} | {r.p99_9_ns} | {r.min_ns} | {r.max_ns} |"

# ── Main ──────────────────────────────────────────────────────────────────────

fn main():
    print "# Phase 9 Storage Benchmark — run_all"
    print "# DISCLAIMER: in-memory/in-process only. NOT real SSD. See bench/README.md."
    print "# Ticks = loop-counter proxy (FR-BENCH-CLOCK-001). Not real nanoseconds."
    print ""

    val r_mount: BenchResult = run_mount_bench()
    val r_wal: BenchResult   = run_wal_bench()

    print "## Markdown summary"
    print ""
    print "| scenario | iters | p50 | p99 | p99.9 | min | max |"
    print "|---|---|---|---|---|---|---|"
    print _md_row(r_mount)
    print _md_row(r_wal)

    print ""
    print "## CSV (save as baseline)"
    print bench_csv_header()
    print bench_csv(r_mount)
    print bench_csv(r_wal)

    print ""
    print "## Full results"
    bench_print(r_mount)
    print ""
    bench_print(r_wal)

    print ""
    print "## Notes"
    print "- For full per-scenario detail: bin/simple run bench/fs_driver_mount_table.spl"
    print "- For arena detail:            bin/simple run bench/nvfs_arena_throughput.spl"
    print "- For WAL detail:              bin/simple run bench/spostgre_wal_append.spl"
    print "- To save baseline: bin/simple run bench/run_all.spl > doc/08_tracking/bench/baseline_YYYY-MM-DD.csv"
