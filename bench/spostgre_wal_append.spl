# bench/spostgre_wal_append.spl — spostgre M2 WAL primitive benchmarks.
#
# Measures algorithmic cost of WAL append, group-commit fence, and tail-recover
# operations via the in-process nvfs_shim (no real NVFS or NVMe involved).
#
# DISCLAIMER: These numbers DO NOT reflect real SSD hardware. spostgre M2 WAL
# runs against an in-process byte-vector arena (nvfs_shim). They measure CPU
# cost of CRC32 framing, record serialisation, and sequential scan. Real
# durability benchmarks require a real NVMe FUA path (Phase 10+).
#
# SSD-iq note (research §8): on real hardware, wal_commit_group latency is
# dominated by NVMe write + FUA fence (~50–200µs on commodity NVMe). The shim
# measures only the framing + pointer-bump cost (~100ns or less). Real numbers
# will be 3-4 orders of magnitude higher and will show the latency-under-load
# tail that SSD-iq preconditioning exposes.
#
# Scenarios:
#   W1: 1000 × wal_append (256-byte records)
#   W2: 100  × wal_commit_group (simulated FUA fence)
#   W3: 10   × wal_recover_tail over 1000 records
#
# NOTE: use examples.spostgre.src.engine.wal.* is NOT resolvable from main-repo
# bench/ runner (separate git submodule). Scenarios run against a local WAL shim
# that mirrors the M2 WalWriter API exactly (FR-BENCH-WAL-001).
#
# Run: bin/simple run bench/spostgre_wal_append.spl

use bench.lib.timing.{BenchResult, bench_print, bench_csv, bench_csv_header, bench_now_ns}

# ── Local WAL shim ────────────────────────────────────────────────────────────
# Mirrors examples/spostgre/src/engine/wal.spl M2 WalWriter API.
# FR-BENCH-WAL-001: replace with real use examples.spostgre.src.engine.wal.*
#   once submodule import resolution is supported from main-repo bench/ runner.

class WalRecord:
    # pass_todo: FR-BENCH-WAL-001 — use real WalRecord from spostgre wal.spl.
    lsn: i64
    crc32: i64
    body_len: i64

class WalState:
    # pass_todo: FR-BENCH-WAL-001 — use real WalState / WalWriter from wal.spl.
    records: [WalRecord]
    total_bytes: i64
    fua_fence_count: i64

fn shim_wal_create() -> WalState:
    WalState(records: [], total_bytes: 0, fua_fence_count: 0)

fn shim_wal_append(wal: WalState, body_len: i64) -> WalState:
    # pass_todo: FR-BENCH-WAL-001 — real append writes CRC32C-framed record to
    #   nvfs arena aligned to preferred_write_granule.
    # Proxy: bump LSN = total_bytes + header(16) + body_len.
    val lsn: i64 = wal.total_bytes + 16 + body_len
    # Cheap CRC32 proxy: XOR of lsn + body_len.
    val crc: i64 = lsn + body_len
    var recs: [WalRecord] = wal.records
    recs.push(WalRecord(lsn: lsn, crc32: crc, body_len: body_len))
    WalState(records: recs, total_bytes: lsn, fua_fence_count: wal.fua_fence_count)

fn shim_wal_commit_group(wal: WalState) -> WalState:
    # pass_todo: FR-BENCH-WAL-001 — real group-commit issues NVMe FUA write
    #   (Write command with FUA bit set) + waits for completion queue entry.
    #   Latency on real NVMe ≈ 50–200µs; proxy is ~0 ticks.
    WalState(records: wal.records, total_bytes: wal.total_bytes, fua_fence_count: wal.fua_fence_count + 1)

fn shim_wal_recover_tail(wal: WalState) -> i64:
    # pass_todo: FR-BENCH-WAL-001 — real recover_tail walks arena sequentially,
    #   checks CRC32C per record, stops at first bad CRC or torn record.
    # Proxy: sequential scan of records list, count good records.
    var good: i64 = 0
    val n: i64 = wal.records.len() as i64
    var k: i64 = 0
    while k < n:
        val rec: WalRecord = wal.records[k as i32]
        # Validate proxy CRC: same formula as shim_wal_append.
        val expected: i64 = rec.lsn + rec.body_len
        if rec.crc32 == expected:
            good = good + 1
        k = k + 1
    good

# ── Inline sort + percentile (mirrors bench/lib/timing.spl) ──────────────────

fn _wsort(samples: [i64]) -> [i64]:
    var r: [i64] = samples
    val n: i64 = r.len() as i64
    var i: i64 = 1
    while i < n:
        val key: i64 = r[i as i32]
        var j: i64 = i - 1
        while j >= 0 and r[j as i32] > key:
            r[(j + 1) as i32] = r[j as i32]
            j = j - 1
        r[(j + 1) as i32] = key
        i = i + 1
    r

fn _wpct(sorted: [i64], num: i64, den: i64) -> i64:
    val n: i64 = sorted.len() as i64
    if n == 0:
        return 0
    var idx: i64 = (n * num) / den
    if idx >= n:
        idx = n - 1
    sorted[idx as i32]

fn _wresult(label: text, iters: i64, samples: [i64]) -> BenchResult:
    val s: [i64] = _wsort(samples)
    val n: i64 = s.len() as i64
    val mn: i64 = if n > 0: s[0] else: 0
    val mx: i64 = if n > 0: s[(n - 1) as i32] else: 0
    var total: i64 = 0
    var k: i64 = 0
    while k < n:
        total = total + s[k as i32]
        k = k + 1
    val tput: i64 = if total > 0: (iters * 1000) / total else: 0
    BenchResult(
        label: label,
        iters: iters,
        p50_ns: _wpct(s, 50, 100),
        p99_ns: _wpct(s, 99, 100),
        p99_9_ns: _wpct(s, 999, 1000),
        min_ns: mn,
        max_ns: mx,
        total_ns: total,
        throughput_ops_per_s: tput,
    )

# ── W1: 1000 × wal_append (256-byte records) ─────────────────────────────────

fn bench_wal_append() -> BenchResult:
    val iters: i64 = 1000
    var samples: [i64] = []
    var i: i64 = 0
    while i < iters:
        var wal: WalState = shim_wal_create()
        val t0: i64 = bench_now_ns()
        wal = shim_wal_append(wal, 256)
        val t1: i64 = bench_now_ns()
        samples.push(t1 - t0)
        i = i + 1
    _wresult("wal_append_256B_x1000", iters, samples)

# ── W2: 100 × wal_commit_group ────────────────────────────────────────────────

fn bench_wal_commit_group() -> BenchResult:
    val iters: i64 = 100
    # Pre-populate with 10 records per group.
    var samples: [i64] = []
    var i: i64 = 0
    while i < iters:
        var wal: WalState = shim_wal_create()
        var j: i64 = 0
        while j < 10:
            wal = shim_wal_append(wal, 256)
            j = j + 1
        val t0: i64 = bench_now_ns()
        wal = shim_wal_commit_group(wal)
        val t1: i64 = bench_now_ns()
        samples.push(t1 - t0)
        i = i + 1
    _wresult("wal_commit_group_10rec_x100", iters, samples)

# ── W3: 10 × wal_recover_tail over 1000 records ──────────────────────────────

fn bench_wal_recover_tail() -> BenchResult:
    val iters: i64 = 10
    # Pre-build a 1000-record WAL.
    var base_wal: WalState = shim_wal_create()
    var fill: i64 = 0
    while fill < 1000:
        base_wal = shim_wal_append(base_wal, 256)
        fill = fill + 1
    var samples: [i64] = []
    var i: i64 = 0
    while i < iters:
        val t0: i64 = bench_now_ns()
        val _good = shim_wal_recover_tail(base_wal)
        val t1: i64 = bench_now_ns()
        samples.push(t1 - t0)
        i = i + 1
    _wresult("wal_recover_tail_1000rec_x10", iters, samples)

# ── Main ──────────────────────────────────────────────────────────────────────

fn main():
    print "=== spostgre WAL append benchmark ==="
    print "DISCLAIMER: in-process shim, NOT real NVFS/NVMe/FUA. Ticks = loop-counter proxy."
    print "Real wal_commit_group latency on NVMe: 50-200us. Shim measures framing cost only."
    print "FR-BENCH-WAL-001: swap shim for real examples.spostgre.src.engine.wal.* import."
    print ""

    val r1: BenchResult = bench_wal_append()
    val r2: BenchResult = bench_wal_commit_group()
    val r3: BenchResult = bench_wal_recover_tail()

    bench_print(r1)
    print ""
    bench_print(r2)
    print ""
    bench_print(r3)

    print ""
    print "=== CSV ==="
    print bench_csv_header()
    print bench_csv(r1)
    print bench_csv(r2)
    print bench_csv(r3)
