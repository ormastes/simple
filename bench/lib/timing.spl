# bench/lib/timing.spl — Benchmark timing primitives for Phase 9 storage components.
#
# LIMITATION: Simple does not yet expose a nanosecond-precision monotonic clock.
# rt_time_now_unix() returns seconds. bench_now_ns() uses a global loop-counter
# proxy: each call increments g_bench_tick by 1. Units are TICKS, not real ns.
# All percentile math is correct; only the unit label is inaccurate until
# FR-BENCH-CLOCK-001 lands a real CLOCK_MONOTONIC binding.
#
# FR-BENCH-CLOCK-001: expose extern fn rt_time_now_ns() -> i64 backed by
#   clock_gettime(CLOCK_MONOTONIC, &ts) → ts.tv_sec*1_000_000_000 + ts.tv_nsec.

# ── Global tick counter proxy ─────────────────────────────────────────────────

var g_bench_tick: i64 = 0

fn bench_now_ns() -> i64:
    # pass_todo: FR-BENCH-CLOCK-001 — replace with real CLOCK_MONOTONIC binding.
    # Until then, returns a monotone counter in units of "ticks" (not real ns).
    g_bench_tick = g_bench_tick + 1
    g_bench_tick

# ── Result type ───────────────────────────────────────────────────────────────

class BenchResult:
    label: text
    iters: i64
    p50_ns: i64
    p99_ns: i64
    p99_9_ns: i64
    min_ns: i64
    max_ns: i64
    total_ns: i64
    throughput_ops_per_s: i64

# ── Inline insertion sort (ascending) ────────────────────────────────────────
# Avoids stdlib sort dependency.

fn _bench_sort(samples: [i64]) -> [i64]:
    var result: [i64] = samples
    var n: i64 = result.len() as i64
    var i: i64 = 1
    while i < n:
        val key: i64 = result[i as i32]
        var j: i64 = i - 1
        while j >= 0 and result[j as i32] > key:
            result[(j + 1) as i32] = result[j as i32]
            j = j - 1
        result[(j + 1) as i32] = key
        i = i + 1
    result

fn _percentile(sorted: [i64], pct_num: i64, pct_den: i64) -> i64:
    val n: i64 = sorted.len() as i64
    if n == 0:
        return 0
    var idx: i64 = (n * pct_num) / pct_den
    if idx >= n:
        idx = n - 1
    sorted[idx as i32]

# ── Core measurement function ─────────────────────────────────────────────────

fn bench_measure(label: text, iters: i64, body: fn() -> ()) -> BenchResult:
    var samples: [i64] = []
    var total: i64 = 0
    var i: i64 = 0
    while i < iters:
        val t0: i64 = bench_now_ns()
        body()
        val t1: i64 = bench_now_ns()
        val elapsed: i64 = t1 - t0
        samples.push(elapsed)
        total = total + elapsed
        i = i + 1
    val sorted: [i64] = _bench_sort(samples)
    val mn: i64 = if sorted.len() > 0: sorted[0] else: 0
    val mx: i64 = if sorted.len() > 0: sorted[(sorted.len() - 1) as i32] else: 0
    val p50: i64 = _percentile(sorted, 50, 100)
    val p99: i64 = _percentile(sorted, 99, 100)
    val p99_9: i64 = _percentile(sorted, 999, 1000)
    # throughput: iters per total_tick (meaningless without real clock; shown as ratio)
    val tput: i64 = if total > 0: (iters * 1000) / total else: 0
    BenchResult(
        label: label,
        iters: iters,
        p50_ns: p50,
        p99_ns: p99,
        p99_9_ns: p99_9,
        min_ns: mn,
        max_ns: mx,
        total_ns: total,
        throughput_ops_per_s: tput,
    )

# ── Pretty-print ──────────────────────────────────────────────────────────────

fn bench_print(r: BenchResult):
    print "bench: {r.label}"
    print "  iters={r.iters}  total_ticks={r.total_ns}"
    print "  min={r.min_ns}  p50={r.p50_ns}  p99={r.p99_ns}  p99.9={r.p99_9_ns}  max={r.max_ns}"
    print "  throughput(ops/ktick)={r.throughput_ops_per_s}"
    print "  [NOTE: ticks are loop-counter proxy, not real ns — FR-BENCH-CLOCK-001]"

# ── CSV row ───────────────────────────────────────────────────────────────────

fn bench_csv(r: BenchResult) -> text:
    "{r.label},{r.iters},{r.p50_ns},{r.p99_ns},{r.p99_9_ns},{r.min_ns},{r.max_ns},{r.total_ns},{r.throughput_ops_per_s}"

fn bench_csv_header() -> text:
    "label,iters,p50_ticks,p99_ticks,p99_9_ticks,min_ticks,max_ticks,total_ticks,ops_per_ktick"
