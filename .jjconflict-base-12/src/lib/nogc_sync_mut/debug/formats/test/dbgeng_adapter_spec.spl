#![allow(primitive_api)]
use std.io_runtime
use std.nogc_sync_mut.spec.{describe, it, expect}
use std.nogc_sync_mut.dap.adapter.dbgeng.{DbgEngAdapter, dbgeng_config}
use std.nogc_sync_mut.dap.adapter.mod.{AdapterCapabilities, AdapterConfig}

fn main():
    describe("DbgEngAdapter name"):
        it("returns dbgeng"):
            val config = dbgeng_config("localhost", 5555, "test.exe")
            val adapter = DbgEngAdapter(
                client: nil,
                config: config,
                attached: false,
                capabilities: AdapterCapabilities.basic()
            )
            expect(adapter.name()).to_equal("dbgeng")

    describe("DbgEngAdapter create"):
        it("returns error on Linux because DbgEngClient fails"):
            val config = dbgeng_config("localhost", 5555, "test.exe")
            val result = DbgEngAdapter.create(config)
            match result:
                Ok(_): expect(true).to_equal(false)
                Err(e): expect(e).to_contain("Windows")

    describe("DbgEngAdapter from_dump"):
        it("returns error on Linux"):
            val result = DbgEngAdapter.from_dump("crash.dmp")
            match result:
                Ok(_): expect(true).to_equal(false)
                Err(e): expect(e).to_contain("Windows")

    describe("DbgEngAdapter disconnected state"):
        it("is_attached returns false when no client"):
            val config = dbgeng_config("localhost", 5555, "test.exe")
            val adapter = DbgEngAdapter(
                client: nil,
                config: config,
                attached: false,
                capabilities: AdapterCapabilities.basic()
            )
            expect(adapter.is_attached()).to_equal(false)

        it("resume returns not connected error"):
            val config = dbgeng_config("localhost", 5555, "test.exe")
            val adapter = DbgEngAdapter(
                client: nil,
                config: config,
                attached: false,
                capabilities: AdapterCapabilities.basic()
            )
            val result = adapter.resume()
            match result:
                Ok(_): expect(true).to_equal(false)
                Err(e): expect(e).to_equal("not connected")

        it("halt returns not connected error"):
            val config = dbgeng_config("localhost", 5555, "test.exe")
            val adapter = DbgEngAdapter(
                client: nil,
                config: config,
                attached: false,
                capabilities: AdapterCapabilities.basic()
            )
            val result = adapter.halt()
            match result:
                Ok(_): expect(true).to_equal(false)
                Err(e): expect(e).to_equal("not connected")

        it("stack_trace returns not connected error"):
            val config = dbgeng_config("localhost", 5555, "test.exe")
            val adapter = DbgEngAdapter(
                client: nil,
                config: config,
                attached: false,
                capabilities: AdapterCapabilities.basic()
            )
            val result = adapter.stack_trace()
            match result:
                Ok(_): expect(true).to_equal(false)
                Err(e): expect(e).to_equal("not connected")

        it("read_memory returns not connected error"):
            val config = dbgeng_config("localhost", 5555, "test.exe")
            val adapter = DbgEngAdapter(
                client: nil,
                config: config,
                attached: false,
                capabilities: AdapterCapabilities.basic()
            )
            val result = adapter.read_memory(0, 16)
            match result:
                Ok(_): expect(true).to_equal(false)
                Err(e): expect(e).to_equal("not connected")

        it("evaluate returns not connected error"):
            val config = dbgeng_config("localhost", 5555, "test.exe")
            val adapter = DbgEngAdapter(
                client: nil,
                config: config,
                attached: false,
                capabilities: AdapterCapabilities.basic()
            )
            val result = adapter.evaluate("$rax")
            match result:
                Ok(_): expect(true).to_equal(false)
                Err(e): expect(e).to_equal("not connected")

    describe("dbgeng_config factory"):
        it("creates config with correct adapter type"):
            val config = dbgeng_config("localhost", 5555, "test.exe")
            expect(config.adapter_type).to_equal("dbgeng")

        it("creates config with correct host"):
            val config = dbgeng_config("192.168.1.100", 4444, "app.exe")
            expect(config.host).to_equal("192.168.1.100")

        it("creates config with correct port"):
            val config = dbgeng_config("localhost", 5555, "test.exe")
            expect(config.port).to_equal(5555)

        it("creates config with correct program"):
            val config = dbgeng_config("localhost", 5555, "myapp.exe")
            expect(config.program).to_equal("myapp.exe")

        it("creates config with x86_64 architecture"):
            val config = dbgeng_config("localhost", 5555, "test.exe")
            expect(config.architecture).to_equal("x86_64")

        it("creates config with 30s timeout"):
            val config = dbgeng_config("localhost", 5555, "test.exe")
            expect(config.timeout_ms).to_equal(30000)

    describe("DbgEngAdapter capabilities"):
        it("supports memory access"):
            val config = dbgeng_config("localhost", 5555, "test.exe")
            val caps = AdapterCapabilities.basic()
                .with_memory()
                .with_registers()
                .with_watchpoints(256)
            val adapter = DbgEngAdapter(
                client: nil,
                config: config,
                attached: false,
                capabilities: caps
            )
            val c = adapter.capabilities()
            expect(c.supports_memory).to_equal(true)

        it("supports registers"):
            val config = dbgeng_config("localhost", 5555, "test.exe")
            val caps = AdapterCapabilities.basic()
                .with_memory()
                .with_registers()
                .with_watchpoints(256)
            val adapter = DbgEngAdapter(
                client: nil,
                config: config,
                attached: false,
                capabilities: caps
            )
            val c = adapter.capabilities()
            expect(c.supports_registers).to_equal(true)

        it("supports watchpoints"):
            val config = dbgeng_config("localhost", 5555, "test.exe")
            val caps = AdapterCapabilities.basic()
                .with_memory()
                .with_registers()
                .with_watchpoints(256)
            val adapter = DbgEngAdapter(
                client: nil,
                config: config,
                attached: false,
                capabilities: caps
            )
            val c = adapter.capabilities()
            expect(c.supports_watchpoints).to_equal(true)
            expect(c.max_watchpoints).to_equal(256)
