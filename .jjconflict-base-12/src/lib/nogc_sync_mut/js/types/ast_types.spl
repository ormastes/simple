# JS AST node types for the Simple Browser JS parser and interpreter.
# JsExpression covers all expression forms; JsStatement covers all statement forms.
# SwitchCase represents one case/default clause in a switch statement.
# DestructProp is an AST-level property (key + unevaluated expression) used in
# object literals (ObjectExpr) and destructuring patterns (ObjectPattern).

use std.js.types.js_types.JsValue

# AST-level object property: key is a text name, value is an unevaluated expression.
# Used in JsExpression.ObjectExpr and JsExpression.ObjectPattern.
class DestructProp:
    key: text
    value: JsExpression

# One clause in a switch statement.
# `test` is nil for the default clause; present for case clauses.
# `consequent` is the list of statements to execute when matched.
class SwitchCase:
    test: JsExpression?
    consequent: [JsStatement]

# All JS expression AST nodes.
enum JsExpression:
    # Literal value (number, string, boolean, null, undefined)
    Literal(value: JsValue)
    # Variable or name reference
    Identifier(name: text)
    # Binary operation: op is operator string ("+", "===", "&&", etc.)
    Binary(op: text, left: JsExpression, right: JsExpression)
    # Unary operation: op is operator string ("!", "-", "typeof", etc.)
    Unary(op: text, operand: JsExpression)
    # Function call: callee expression + argument list
    Call(callee: JsExpression, args: [JsExpression])
    # Static member access: obj.property
    Member(object: JsExpression, property: text)
    # Computed member access: obj[expr]
    ComputedMember(object: JsExpression, property: JsExpression)
    # Assignment: target = value (target may be Member/ComputedMember/Identifier)
    Assignment(target: JsExpression, value: JsExpression)
    # Array literal: [elem, ...]
    Array(elements: [JsExpression])
    # Object literal: {key: expr, ...}
    ObjectExpr(properties: [DestructProp])
    # Ternary: condition ? consequent : alternate
    Ternary(condition: JsExpression, consequent: JsExpression, alternate: JsExpression)
    # Arrow function expression: (params) => body
    ArrowFunction(params: [text], body: [JsStatement])
    # Spread element: ...argument
    SpreadElement(argument: JsExpression)
    # Template literal: quasis are the string parts, expressions are the interpolated values
    TemplateLiteral(quasis: [text], expressions: [JsExpression])
    # delete expr
    Delete(del_expr: JsExpression)
    # expr instanceof Constructor
    InstanceOf(left: JsExpression, right: JsExpression)
    # key in object
    InExpr(left: JsExpression, right: JsExpression)
    # new Constructor(args)
    NewExpr(callee: JsExpression, args: [JsExpression])
    # Object destructuring pattern: {a, b} = ...
    ObjectPattern(props: [DestructProp])
    # Array destructuring pattern: [a, b] = ...
    ArrayPattern(elements: [JsExpression])

# All JS statement AST nodes.
enum JsStatement:
    # var x = expr
    VarDecl(name: text, init: JsExpression)
    # let x = expr
    LetDecl(name: text, init: JsExpression)
    # const x = expr
    ConstDecl(name: text, init: JsExpression)
    # Destructuring variable declaration: const {a} = obj  (kind: "var"/"let"/"const")
    DestructVarDecl(pattern: JsExpression, init: JsExpression, kind: text)
    # Bare expression statement
    ExprStmt(expr: JsExpression)
    # return expr
    Return(value: JsExpression)
    # if/else
    If(cond: JsExpression, then_body: [JsStatement], else_body: [JsStatement])
    # while loop
    While(cond: JsExpression, body: [JsStatement])
    # do-while loop
    DoWhile(cond: JsExpression, body: [JsStatement])
    # for (init; cond; update) body
    For(init: JsStatement?, cond: JsExpression?, update: JsExpression?, body: [JsStatement])
    # for (binding in object) body
    ForIn(binding: text, object: JsExpression, body: [JsStatement])
    # for (binding of iterable) body
    ForOf(binding: text, iterable: JsExpression, body: [JsStatement])
    # Block of statements { ... }
    Block(stmts: [JsStatement])
    # Function declaration: function name(params) { body }
    FnDecl(name: text, params: [text], body: [JsStatement])
    # try/catch/finally
    TryCatch(try_body: [JsStatement], catch_param: text, catch_body: [JsStatement], finally_body: [JsStatement])
    # switch (discriminant) { cases }
    Switch(discriminant: JsExpression, cases: [SwitchCase])
    # throw expr
    ThrowStmt(expr: JsExpression)
    # break
    BreakStmt
    # continue
    ContinueStmt
    # class Name extends Parent { constructor; methods }
    ClassDecl(name: text, parent_name: text, constructor: JsStatement, methods: [JsStatement])
    # label: stmt
    LabeledStmt(label: text, body: JsStatement)
