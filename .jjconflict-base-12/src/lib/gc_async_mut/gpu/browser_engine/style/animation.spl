#![allow(REQC001)]
#![allow(REQC004)]
#![allow(unnamed_duplicate_typed_args)]

use std.common.color.types.{from_rgb}
use std.common.animation.timing.{TimingFunction, evaluate_timing, cubic_bezier_at}
use std.gc_async_mut.gpu.browser_engine.shared.logging.{Logger, LogLevel}

# ---------------------------------------------------------------------------
# CSS value type — enum matching the examples/browser css_types definition.
# Defined locally so the animation engine can pattern-match variants.
# ---------------------------------------------------------------------------

enum CSSValue:
    Keyword(v: text)
    Length(v: f64, unit: text)
    Percentage(v: f64)
    Color(color: std.common.color.types.Color)
    Number(v: f64)
    Url(v: text)
    Function(name: text, args: [CSSValue])
    List(values: [CSSValue])
    Var(name: text, fallback: CSSValue?)
    Inherit
    Initial
    Unset

class CSSDeclaration:
    property: text
    value: CSSValue
    important: bool

    static fn create(property: text, value: CSSValue) -> CSSDeclaration:
        CSSDeclaration(property: property, value: value, important: false)

# ---------------------------------------------------------------------------
# Animation lifecycle states.
# ---------------------------------------------------------------------------

enum AnimationState:
    Idle
    Running
    Paused
    Finished

# ---------------------------------------------------------------------------
# Fill mode — what styles apply before/after animation.
# ---------------------------------------------------------------------------

enum FillMode:
    None
    Forwards
    Backwards
    Both

# ---------------------------------------------------------------------------
# Play direction — iteration direction control.
# ---------------------------------------------------------------------------

enum PlayDirection:
    Normal
    Reverse
    Alternate
    AlternateReverse

# ---------------------------------------------------------------------------
# Keyframe — a single snapshot at a given offset [0.0, 1.0].
# ---------------------------------------------------------------------------

class Keyframe:
    offset: f64
    properties: [CSSDeclaration]

    static fn create(offset: f64, properties: [CSSDeclaration]) -> Keyframe:
        Keyframe(offset: offset, properties: properties)

# ---------------------------------------------------------------------------
# Animation — a full @keyframes animation instance.
# ---------------------------------------------------------------------------

class Animation:
    name: text
    keyframes: [Keyframe]
    duration_ms: f64
    delay_ms: f64
    timing: TimingFunction
    iteration_count: f64
    direction: PlayDirection
    fill_mode: FillMode
    state: AnimationState
    current_time: f64

    static fn create(name: text, keyframes: [Keyframe], duration_ms: f64) -> Animation:
        Animation(
            name: name,
            keyframes: keyframes,
            duration_ms: duration_ms,
            delay_ms: 0.0,
            timing: TimingFunction.Ease,
            iteration_count: 1.0,
            direction: PlayDirection.Normal,
            fill_mode: FillMode.None,
            state: AnimationState.Idle,
            current_time: 0.0
        )

# ---------------------------------------------------------------------------
# Transition — a single property transition between two values.
# ---------------------------------------------------------------------------

class Transition:
    property: text
    from_value: CSSValue
    to_value: CSSValue
    duration_ms: f64
    delay_ms: f64
    timing: TimingFunction
    start_time: f64
    state: AnimationState

    static fn create(property: text, from_value: CSSValue, to_value: CSSValue, duration_ms: f64) -> Transition:
        Transition(
            property: property,
            from_value: from_value,
            to_value: to_value,
            duration_ms: duration_ms,
            delay_ms: 0.0,
            timing: TimingFunction.Ease,
            start_time: 0.0,
            state: AnimationState.Idle
        )

# ---------------------------------------------------------------------------
# StyleUpdate — a single property change emitted by the animation engine.
# ---------------------------------------------------------------------------

class StyleUpdate:
    node_id: i64
    property: text
    value: CSSValue

    static fn create(node_id: i64, property: text, value: CSSValue) -> StyleUpdate:
        StyleUpdate(node_id: node_id, property: property, value: value)

# ---------------------------------------------------------------------------
# AnimationEngine — drives all active animations and transitions.
# ---------------------------------------------------------------------------

class AnimationEngine:
    animations: [Animation]
    transitions: [Transition]
    logger: Logger

    static fn new(logger: Logger) -> AnimationEngine:
        val empty_a: [Animation] = []
        val empty_t: [Transition] = []
        AnimationEngine(
            animations: empty_a,
            transitions: empty_t,
            logger: logger
        )

    me add_animation(anim: Animation):
        self.animations.push(anim)
        self.logger.debug("animation added: '{anim.name}', duration={anim.duration_ms}ms")

    me add_transition(trans: Transition):
        self.transitions.push(trans)
        self.logger.debug("transition added: property='{trans.property}', duration={trans.duration_ms}ms")

    me tick(current_time_ms: f64) -> [StyleUpdate]:
        var updates: [StyleUpdate] = []
        var new_animations: [Animation] = []

        for anim in self.animations:
            var next_anim = anim
            match anim.state:
                AnimationState.Idle:
                    next_anim = Animation(
                        name: anim.name,
                        keyframes: anim.keyframes,
                        duration_ms: anim.duration_ms,
                        delay_ms: anim.delay_ms,
                        timing: anim.timing,
                        iteration_count: anim.iteration_count,
                        direction: anim.direction,
                        fill_mode: anim.fill_mode,
                        state: AnimationState.Running,
                        current_time: current_time_ms
                    )
                AnimationState.Running:
                    val elapsed = current_time_ms - anim.current_time - anim.delay_ms
                    if elapsed < 0.0:
                        pass_dn
                    else:
                        val total_duration = anim.duration_ms * anim.iteration_count
                        if elapsed >= total_duration:
                            next_anim = Animation(
                                name: anim.name,
                                keyframes: anim.keyframes,
                                duration_ms: anim.duration_ms,
                                delay_ms: anim.delay_ms,
                                timing: anim.timing,
                                iteration_count: anim.iteration_count,
                                direction: anim.direction,
                                fill_mode: anim.fill_mode,
                                state: AnimationState.Finished,
                                current_time: anim.current_time
                            )
                        else:
                            val iteration_progress = elapsed / anim.duration_ms
                            var local_progress = iteration_progress - iteration_progress.floor()
                            if local_progress == 0.0 and elapsed > 0.0:
                                local_progress = 1.0

                            val current_iteration = iteration_progress.floor().to_i64()
                            val effective_progress = apply_direction(local_progress, anim.direction, current_iteration)
                            val eased = ease_value(effective_progress, anim.timing)
                            val kf_updates = interpolate_keyframes(anim.keyframes, eased)
                            for u in kf_updates:
                                updates.push(u)
                AnimationState.Paused:
                    pass_dn
                AnimationState.Finished:
                    pass_dn
            new_animations.push(next_anim)

        self.animations = new_animations

        var new_transitions: [Transition] = []
        for trans in self.transitions:
            var next_trans = trans
            match trans.state:
                AnimationState.Idle:
                    next_trans = Transition(
                        property: trans.property,
                        from_value: trans.from_value,
                        to_value: trans.to_value,
                        duration_ms: trans.duration_ms,
                        delay_ms: trans.delay_ms,
                        timing: trans.timing,
                        start_time: current_time_ms,
                        state: AnimationState.Running
                    )
                AnimationState.Running:
                    val elapsed = current_time_ms - trans.start_time - trans.delay_ms
                    if elapsed < 0.0:
                        pass_dn
                    else if elapsed >= trans.duration_ms:
                        updates.push(StyleUpdate.create(0, trans.property, trans.to_value))
                        next_trans = Transition(
                            property: trans.property,
                            from_value: trans.from_value,
                            to_value: trans.to_value,
                            duration_ms: trans.duration_ms,
                            delay_ms: trans.delay_ms,
                            timing: trans.timing,
                            start_time: trans.start_time,
                            state: AnimationState.Finished
                        )
                    else:
                        val raw_progress = elapsed / trans.duration_ms
                        val eased = ease_value(raw_progress, trans.timing)
                        val interp = interpolate(trans.from_value, trans.to_value, eased)
                        updates.push(StyleUpdate.create(0, trans.property, interp))
                AnimationState.Paused:
                    pass_dn
                AnimationState.Finished:
                    pass_dn
            new_transitions.push(next_trans)

        self.transitions = new_transitions

        self.logger.trace("tick at {current_time_ms}ms produced {updates.len()} updates")
        updates

# ---------------------------------------------------------------------------
# Value interpolation.
# ---------------------------------------------------------------------------

fn interpolate(from: CSSValue, to: CSSValue, progress: f64) -> CSSValue:
    match from:
        CSSValue.Length(fv, fu):
            match to:
                CSSValue.Length(tv, tu):
                    val result = interpolate_length(fv, tv, progress)
                    CSSValue.Length(v: result, unit: fu)
                _: to
        CSSValue.Number(fv):
            match to:
                CSSValue.Number(tv):
                    val result = interpolate_length(fv, tv, progress)
                    CSSValue.Number(v: result)
                _: to
        CSSValue.Color(color):
            match to:
                CSSValue.Color(to_color):
                    interpolate_color(color.r, color.g, color.b, to_color.r, to_color.g, to_color.b, progress)
                _: to
        CSSValue.Percentage(fv):
            match to:
                CSSValue.Percentage(tv):
                    val result = interpolate_length(fv, tv, progress)
                    CSSValue.Percentage(v: result)
                _: to
        _:
            if progress < 0.5:
                from
            else:
                to

fn interpolate_color(from_r: i64, from_g: i64, from_b: i64, to_r: i64, to_g: i64, to_b: i64, t: f64) -> CSSValue:
    val r = (from_r.to_f64() + (to_r.to_f64() - from_r.to_f64()) * t).to_i64()
    val g = (from_g.to_f64() + (to_g.to_f64() - from_g.to_f64()) * t).to_i64()
    val b = (from_b.to_f64() + (to_b.to_f64() - from_b.to_f64()) * t).to_i64()
    CSSValue.Color(color: from_rgb(r, g, b))

fn interpolate_length(from: f64, to: f64, t: f64) -> f64:
    from + (to - from) * t

# ---------------------------------------------------------------------------
# Easing / timing functions.
# ---------------------------------------------------------------------------

fn ease_value(t: f64, timing: TimingFunction) -> f64:
    evaluate_timing(timing, t)

fn cubic_bezier(t: f64, x1: f64, y1: f64, x2: f64, y2: f64) -> f64:
    cubic_bezier_at(t, x1, y1, x2, y2)

# ---------------------------------------------------------------------------
# Direction helpers.
# ---------------------------------------------------------------------------

fn apply_direction(progress: f64, direction: PlayDirection, iteration: i64) -> f64:
    match direction:
        PlayDirection.Normal:
            progress
        PlayDirection.Reverse:
            1.0 - progress
        PlayDirection.Alternate:
            if iteration % 2 == 0:
                progress
            else:
                1.0 - progress
        PlayDirection.AlternateReverse:
            if iteration % 2 == 0:
                1.0 - progress
            else:
                progress

# Interpolate between keyframes at a given progress [0.0, 1.0].
# Finds the two surrounding keyframes and interpolates their properties.
fn interpolate_keyframes(keyframes: [Keyframe], progress: f64) -> [StyleUpdate]:
    var updates: [StyleUpdate] = []

    if keyframes.len() == 0:
        return updates

    if keyframes.len() == 1:
        for kf in keyframes:
            for decl in kf.properties:
                updates.push(StyleUpdate.create(0, decl.property, decl.value))
        return updates

    var kf_list: [Keyframe] = []
    for kf in keyframes:
        kf_list.push(kf)

    var from_offset = 0.0
    var from_props: [CSSDeclaration] = []
    var to_offset = 1.0
    var to_props: [CSSDeclaration] = []
    var first = true
    for kf in kf_list:
        if first:
            from_offset = kf.offset
            from_props = kf.properties
            to_offset = kf.offset
            to_props = kf.properties
            first = false
        else:
            to_offset = kf.offset
            to_props = kf.properties

    var prev_offset = from_offset
    var prev_props = from_props
    var found_segment = false
    for kf in kf_list:
        if not found_segment:
            if progress >= prev_offset and progress <= kf.offset:
                from_offset = prev_offset
                from_props = prev_props
                to_offset = kf.offset
                to_props = kf.properties
                found_segment = true
            prev_offset = kf.offset
            prev_props = kf.properties

    val range = to_offset - from_offset
    var local_t = 0.0
    if range > 0.0:
        local_t = (progress - from_offset) / range

    for from_decl in from_props:
        for to_decl in to_props:
            if from_decl.property == to_decl.property:
                val interp = interpolate(from_decl.value, to_decl.value, local_t)
                updates.push(StyleUpdate.create(0, from_decl.property, interp))

    updates
