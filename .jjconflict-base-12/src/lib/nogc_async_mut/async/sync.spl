# Sync - Cooperative Async Mutex and Semaphore
#
# Built on cooperative polling (single-carrier assumption).
# No OS locks. try_acquire is non-blocking; acquire() returns a
# Future that is Pending while the resource is held.

use nogc_async_mut.async.poll.{Poll}
use nogc_async_mut.async.future.{Future}

# ============================================================
# AsyncMutex
# ============================================================

class AsyncMutex:
    """Cooperative async mutex.

    Cooperative single-carrier assumption: only one task polls at a time.
    acquire() returns a Future that is Ready(()) when the lock is free,
    Pending while it is held.

    Example:
        var m = AsyncMutex(locked: false)
        val f = m.acquire()
        val p = f.poll()   # Poll.Ready(()) -- was free
        m.release()
    """
    locked: bool

impl AsyncMutex:
    me try_acquire() -> bool:
        """Try to acquire the mutex without waiting.

        Returns true and locks if free; false if already held.
        """
        if self.locked:
            false
        else:
            self.locked = true
            true

    fn acquire() -> Future<()>:
        """Return a Future that resolves when the lock is acquired.

        Under cooperative single-carrier, we poll once: if free,
        lock and return Ready(()); otherwise return Pending so the
        caller retries on the next scheduler tick.
        """
        if self.locked:
            Future.pending<()>()
        else:
            self.locked = true
            Future.from_value(())

    me release():
        """Release the mutex so the next acquire() can succeed."""
        self.locked = false

# ============================================================
# AsyncSemaphore
# ============================================================

class AsyncSemaphore:
    """Cooperative async semaphore with a permit counter.

    acquire() returns Pending when no permits are available and
    Ready(()) when a permit is granted.

    Example:
        var sem = AsyncSemaphore(permits: 2, max_permits: 2)
        val f1 = sem.acquire()   # Ready -- 1 permit left
        val f2 = sem.acquire()   # Ready -- 0 permits left
        val f3 = sem.acquire()   # Pending -- no permits
        sem.release()
        val f4 = sem.acquire()   # Ready -- permit returned
    """
    permits: i64
    max_permits: i64

impl AsyncSemaphore:
    me try_acquire() -> bool:
        """Try to acquire a permit without waiting.

        Returns true and decrements permits if available; false otherwise.
        """
        if self.permits > 0:
            self.permits = self.permits - 1
            true
        else:
            false

    fn acquire() -> Future<()>:
        """Return a Future that resolves when a permit is acquired.

        Under cooperative single-carrier, polls once and either grants
        the permit (Ready) or signals no availability (Pending).
        """
        if self.permits > 0:
            self.permits = self.permits - 1
            Future.from_value(())
        else:
            Future.pending<()>()

    me release():
        """Return a permit. Clamps at max_permits."""
        if self.permits < self.max_permits:
            self.permits = self.permits + 1
