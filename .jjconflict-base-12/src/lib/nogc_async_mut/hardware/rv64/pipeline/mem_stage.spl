@allow(unnamed_duplicate_typed_args) # reason: memory load/store APIs use positional i64 params
# RV64 Memory (MEM) Stage
#
# Performs load and store operations against the data memory. Supports
# byte, halfword, word, and doubleword accesses with sign/zero extension
# as specified by funct3. Produces the MEM/WB latch.
#
# Feature IDs: #HW-RV64-PIPE-MEM
# Category: Hardware / RTL Simulation
# Status: Implemented

use std.hardware.rv64.pipeline.types.{
    Rv64Memory, Rv64ExMemLatch, Rv64MemWbLatch, create_mem_wb_latch
}

# ============================================================================
# Memory Stage
# ============================================================================

struct Rv64MemStage:
    """Memory access stage -- loads and stores."""
    placeholder: i64

fn create_rv64_mem_stage() -> Rv64MemStage:
    Rv64MemStage(placeholder: 0)

impl Rv64MemStage:
    fn tick(ex_mem: Rv64ExMemLatch, mem: Rv64Memory) -> Rv64MemWbLatch:
        """Execute one clock cycle of the MEM stage (read path).

        For loads, reads from memory and passes to MEM/WB latch.
        For non-memory instructions, passes the ALU result through.

        Args:
            ex_mem: Latch data from the EX stage.
            mem: Data memory.

        Returns:
            MEM/WB latch with load data or ALU result.
        """
        if not ex_mem.valid:
            return create_mem_wb_latch()

        var mem_data: i64 = 0

        if ex_mem.mem_read:
            mem_data = mem.load_funct3(ex_mem.alu_result, ex_mem.funct3)

        Rv64MemWbLatch(
            alu_result: ex_mem.alu_result,
            mem_data: mem_data,
            rd: ex_mem.rd,
            mem_to_reg: ex_mem.mem_to_reg,
            reg_write: ex_mem.reg_write,
            valid: true
        )

    me tick_store(ex_mem: Rv64ExMemLatch, mem: Rv64Memory):
        """Execute the store path of the MEM stage (write path).

        Must be called separately so the caller controls memory mutation.

        Args:
            ex_mem: Latch data from the EX stage.
            mem: Data memory (mutated in place).
        """
        if not ex_mem.valid:
            return
        if not ex_mem.mem_write:
            return

        mem.store_funct3(ex_mem.alu_result, ex_mem.rs2_val, ex_mem.funct3)

# ============================================================================
# Load Logic (funct3-based width and sign extension)
# ============================================================================

fn sign_ext_byte(v: i64) -> i64:
    """Sign-extend an 8-bit value."""
    val masked = v & 0xFF
    if (masked & 0x80) != 0:
        return masked | (-1 << 8)
    masked

fn sign_ext_half(v: i64) -> i64:
    """Sign-extend a 16-bit value."""
    val masked = v & 0xFFFF
    if (masked & 0x8000) != 0:
        return masked | (-1 << 16)
    masked

fn sign_ext_word(v: i64) -> i64:
    """Sign-extend a 32-bit value."""
    val masked = v & 0xFFFFFFFF
    if (masked & 0x80000000) != 0:
        return masked | (-1 << 32)
    masked

# NOTE: load/store logic moved to Rv64Memory.load_funct3 / store_funct3
# methods in types.spl to ensure proper mutation semantics.
