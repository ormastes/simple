# Privilege Principal — identity of the entity requesting authority.
#
# Provides: Principal, PrincipalKind, principal_is_local, principal_validate.

enum PrincipalKind:
    Anonymous
    Local
    Remote
    User
    Service
    System

class Principal:
    id: text
    kind: PrincipalKind

    static fn default_local(id: text) -> Principal:
        Principal(kind: PrincipalKind.Local, id: id)

struct PrincipalValidateResult:
    ok: bool
    error: text

fn principal_is_local(p: Principal) -> bool:
    p.kind == PrincipalKind.Local

fn principal_validate(p: Principal) -> PrincipalValidateResult:
    if p.kind == PrincipalKind.Local:
        PrincipalValidateResult(ok: true, error: "")
    else:
        PrincipalValidateResult(ok: false, error: "only local principals are supported in this release")
