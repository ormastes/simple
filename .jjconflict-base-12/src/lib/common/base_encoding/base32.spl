# ============================================================================
# Base32 / Base32hex — RFC 4648 §6, §7
# ============================================================================
#
# Exported functions:
#   base32_encode(data: [u8]) -> text        — standard A-Z2-7, padded
#   base32_encode_no_pad(data: [u8]) -> text — standard, no '=' padding
#   base32_encode_hex(data: [u8]) -> text    — extended hex 0-9A-V, padded
#   base32_encode_hex_no_pad(data: [u8]) -> text
#   base32_decode(encoded: text) -> [u8]
#   base32_decode_hex(encoded: text) -> [u8]
#
# NOTE: `and`/`or` are boolean in Simple; use `&`/`|` for bitwise.

# Standard Base32 alphabet: A–Z 2–7 (RFC 4648 §6)
val B32_STD = "ABCDEFGHIJKLMNOPQRSTUVWXYZ234567"

# Extended hex Base32 alphabet: 0–9 A–V (RFC 4648 §7)
val B32_HEX = "0123456789ABCDEFGHIJKLMNOPQRSTUV"

# ============================================================================
# Internal: map a standard base32 char to its 5-bit value.
# Returns 255 for '=' or any invalid character.
# ============================================================================

fn _b32_val(c: i64) -> i64:
    if c >= 65 and c <= 90:
        c - 65
    else if c >= 50 and c <= 55:
        c - 50 + 26
    else:
        255

# ============================================================================
# Internal: map a base32hex char to its 5-bit value.
# Returns 255 for '=' or any invalid character.
# ============================================================================

fn _b32hex_val(c: i64) -> i64:
    if c >= 48 and c <= 57:
        c - 48
    else if c >= 65 and c <= 86:
        c - 65 + 10
    else:
        255

# ============================================================================
# Core encoder: 5-byte groups → 8 base32 chars each.
# alphabet : 32-char lookup string.
# with_pad : append '=' chars to pad output to a multiple of 8.
# ============================================================================

fn _encode(data: [u8], alphabet: text, with_pad: bool) -> text:
    val n = data.len()
    var out = ""
    var i = 0
    while i < n:
        val b0 = data[i] as i64
        var b1: i64 = 0
        var b2: i64 = 0
        var b3: i64 = 0
        var b4: i64 = 0
        var rem = n - i
        if rem > 5:
            rem = 5
        if rem >= 2:
            b1 = data[i + 1] as i64
        if rem >= 3:
            b2 = data[i + 2] as i64
        if rem >= 4:
            b3 = data[i + 3] as i64
        if rem >= 5:
            b4 = data[i + 4] as i64

        # Extract eight 5-bit groups from up to 5 input bytes.
        val c0 = b0 >> 3
        val c1 = ((b0 & 7) << 2) | (b1 >> 6)
        val c2 = (b1 >> 1) & 31
        val c3 = ((b1 & 1) << 4) | (b2 >> 4)
        val c4 = ((b2 & 15) << 1) | (b3 >> 7)
        val c5 = (b3 >> 2) & 31
        val c6 = ((b3 & 3) << 3) | (b4 >> 5)
        val c7 = b4 & 31

        # First 2 chars always present (one input byte).
        out = out + alphabet.char_at(c0) + alphabet.char_at(c1)
        if rem >= 2:
            out = out + alphabet.char_at(c2) + alphabet.char_at(c3)
            if rem >= 3:
                out = out + alphabet.char_at(c4)
                if rem >= 4:
                    out = out + alphabet.char_at(c5) + alphabet.char_at(c6)
                    if rem >= 5:
                        out = out + alphabet.char_at(c7)
                    else if with_pad:
                        out = out + "="
                else if with_pad:
                    out = out + "==="
            else if with_pad:
                out = out + "===="
        else if with_pad:
            out = out + "======"
        i = i + 5
    out

# ============================================================================
# Core decoder: non-pad chars collected in groups of 8 → 5 bytes each.
# is_hex: false = standard A-Z2-7 alphabet; true = hex 0-9A-V alphabet.
# ============================================================================

fn _decode(encoded: text, is_hex: bool) -> [u8]:
    val n = encoded.length()
    var out: [u8] = []
    var g0: i64 = 0
    var g1: i64 = 0
    var g2: i64 = 0
    var g3: i64 = 0
    var g4: i64 = 0
    var g5: i64 = 0
    var g6: i64 = 0
    var g7: i64 = 0
    var gcount = 0
    var saw_pad = false
    var i = 0
    while i < n:
        val c = encoded.char_at(i) as i64
        i = i + 1
        if c == 61:
            if gcount != 2 and gcount != 4 and gcount != 5 and gcount != 7:
                return []
            saw_pad = true
        else:
            if saw_pad:
                return []
            var v: i64 = 255
            if is_hex:
                v = _b32hex_val(c)
            else:
                v = _b32_val(c)
            if v != 255:
                if gcount == 0:
                    g0 = v
                else if gcount == 1:
                    g1 = v
                else if gcount == 2:
                    g2 = v
                else if gcount == 3:
                    g3 = v
                else if gcount == 4:
                    g4 = v
                else if gcount == 5:
                    g5 = v
                else if gcount == 6:
                    g6 = v
                else:
                    g7 = v
                gcount = gcount + 1
                if gcount == 8:
                    out = out.push(((g0 << 3) | (g1 >> 2)) as u8)
                    out = out.push((((g1 & 3) << 6) | (g2 << 1) | (g3 >> 4)) as u8)
                    out = out.push((((g3 & 15) << 4) | (g4 >> 1)) as u8)
                    out = out.push((((g4 & 1) << 7) | (g5 << 2) | (g6 >> 3)) as u8)
                    out = out.push((((g6 & 7) << 5) | g7) as u8)
                    gcount = 0
                    g0 = 0
                    g1 = 0
                    g2 = 0
                    g3 = 0
                    g4 = 0
                    g5 = 0
                    g6 = 0
                    g7 = 0
    # Handle final partial group. RFC 4648 only permits residues
    # 0, 2, 4, 5, or 7; residues 1, 3, and 6 are malformed.
    if gcount != 0 and gcount != 2 and gcount != 4 and gcount != 5 and gcount != 7:
        return []
    if gcount >= 2:
        out = out.push(((g0 << 3) | (g1 >> 2)) as u8)
    if gcount >= 4:
        out = out.push((((g1 & 3) << 6) | (g2 << 1) | (g3 >> 4)) as u8)
    if gcount >= 5:
        out = out.push((((g3 & 15) << 4) | (g4 >> 1)) as u8)
    if gcount >= 7:
        out = out.push((((g4 & 1) << 7) | (g5 << 2) | (g6 >> 3)) as u8)
    out

# ============================================================================
# Public API
# ============================================================================

pub fn base32_encode(data: [u8]) -> text:
    """Encode bytes as standard Base32 (RFC 4648 §6, alphabet A-Z2-7, padded with '=')."""
    _encode(data, B32_STD, true)

pub fn base32_encode_no_pad(data: [u8]) -> text:
    """Encode bytes as standard Base32 without '=' padding."""
    _encode(data, B32_STD, false)

pub fn base32_encode_hex(data: [u8]) -> text:
    """Encode bytes as Base32hex (RFC 4648 §7, alphabet 0-9A-V, padded with '=')."""
    _encode(data, B32_HEX, true)

pub fn base32_encode_hex_no_pad(data: [u8]) -> text:
    """Encode bytes as Base32hex without '=' padding."""
    _encode(data, B32_HEX, false)

pub fn base32_decode(encoded: text) -> [u8]:
    """Decode standard Base32 (RFC 4648 §6). Accepts padded or unpadded input."""
    _decode(encoded, false)

pub fn base32_decode_hex(encoded: text) -> [u8]:
    """Decode Base32hex (RFC 4648 §7). Accepts padded or unpadded input."""
    _decode(encoded, true)
