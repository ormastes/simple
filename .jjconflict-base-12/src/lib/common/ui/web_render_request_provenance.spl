# Shared render-request provenance checks for UI adapters.

use common.ui.web_render_api.{WEB_RENDER_ENGINE2D_STATUS_NOT_REQUESTED, WEB_RENDER_TARGET_ELECTRON, WEB_RENDER_TARGET_PURE_SIMPLE, WEB_RENDER_TARGET_TAURI, WebRenderArtifact, WebRenderRequest}

class WebRenderRequestProvenanceEvidence:
    target: text
    surface_id: text
    width: i32
    height: i32
    request_has_body: bool
    semantic_attached: bool
    artifact_target_matches: bool
    artifact_dimensions_match: bool
    artifact_has_html: bool
    artifact_has_ipc_or_pixels: bool
    engine2d_status: text
    engine2d_backend: text
    engine2d_reason: text
    ready: bool
    reason: text

    fn summary() -> text:
        "WebRenderRequestProvenanceEvidence[target={self.target} surface={self.surface_id} ready={self.ready.to_text()} engine2d_status={self.engine2d_status} engine2d_backend={self.engine2d_backend} reason={self.reason}]"

fn web_render_request_provenance_reason(req: WebRenderRequest, artifact: WebRenderArtifact, semantic_json: text) -> text:
    if req.target == "":
        return "missing-target"
    if req.body_html == "":
        return "missing-body"
    if req.viewport_w <= 0 or req.viewport_h <= 0:
        return "missing-dimensions"
    if semantic_json == "" or not semantic_json.contains("\"protocol_version\""):
        return "missing-semantic-json"
    if artifact.target != req.target:
        return "artifact-target-mismatch"
    if artifact.viewport_w != req.viewport_w or artifact.viewport_h != req.viewport_h:
        return "artifact-dimensions-mismatch"
    if artifact.html == "":
        return "missing-artifact-html"
    if req.target == WEB_RENDER_TARGET_ELECTRON or req.target == WEB_RENDER_TARGET_TAURI:
        if artifact.ipc_json == "":
            return "missing-ipc-json"
    if req.target == WEB_RENDER_TARGET_PURE_SIMPLE and req.wants_pixels:
        if artifact.engine2d_status == WEB_RENDER_ENGINE2D_STATUS_NOT_REQUESTED:
            return "missing-engine2d-provenance"
    if artifact.engine2d_status == "":
        return "missing-engine2d-status"
    if artifact.engine2d_reason == "":
        return "missing-engine2d-reason"
    "pass"

fn web_render_request_provenance_evidence(req: WebRenderRequest, artifact: WebRenderArtifact, semantic_json: text) -> WebRenderRequestProvenanceEvidence:
    val reason = web_render_request_provenance_reason(req, artifact, semantic_json)
    WebRenderRequestProvenanceEvidence(
        target: req.target,
        surface_id: req.surface_id,
        width: req.viewport_w,
        height: req.viewport_h,
        request_has_body: req.body_html != "",
        semantic_attached: semantic_json.contains("\"protocol_version\""),
        artifact_target_matches: artifact.target == req.target,
        artifact_dimensions_match: artifact.viewport_w == req.viewport_w and artifact.viewport_h == req.viewport_h,
        artifact_has_html: artifact.html != "",
        artifact_has_ipc_or_pixels: artifact.ipc_json != "" or artifact.pixels.len() > 0 or (req.target != WEB_RENDER_TARGET_ELECTRON and req.target != WEB_RENDER_TARGET_TAURI),
        engine2d_status: artifact.engine2d_status,
        engine2d_backend: artifact.engine2d_backend,
        engine2d_reason: artifact.engine2d_reason,
        ready: reason == "pass",
        reason: reason
    )
