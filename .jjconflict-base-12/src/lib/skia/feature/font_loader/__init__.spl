# Font loader — stub for SkFontMgr.
#
# Re-exports the in-memory FontRegistry and its enums. A real backend can
# replace this module with platform-specific font enumeration (FontConfig,
# DWrite, CoreText) while preserving the public interface.

use std.skia.feature.font_loader.registry.{
    FontWeight,
    FontSlant,
    FontStyle,
    FontFamilyEntry,
    FontRegistry,
    font_weight_value,
    font_registry_new,
    default_font_registry
}
