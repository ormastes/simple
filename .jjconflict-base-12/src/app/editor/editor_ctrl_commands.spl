# Editor Controller Commands
#
# Command palette dispatch helpers and dock utility functions.

use app.editor.editor_controller_types.*
use app.editor.editor_controller.*

fn ctrl_show_right_dock(ctrl: EditorController, panel: text):
    var session = ctrl.session
    var layout = session.dock_layout
    layout.show_right(panel)
    session.dock_layout = layout
    ctrl.session = session
