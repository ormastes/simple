use std.fs.{list_dir}
use std.nogc_sync_mut.io.file_ops.{file_exists, file_read_text}
use app.llm_dashboard.data.types.{ManagedTask, TaskKind, TaskState}

val TASK_DAEMON_TASK_DIR = ".build/task_daemon/tasks"

fn _field(content: text, name: text) -> text:
    val prefix = name + "="
    for line in content.split("\n"):
        if line.starts_with(prefix):
            return line.substring(prefix.len())
    ""

fn _state_from_status(status: text) -> TaskState:
    match status:
        case "working":
            TaskState.Active
        case "completed":
            TaskState.Completed
        case "failed":
            TaskState.Failed
        case "cancelled":
            TaskState.Cancelled
        case _:
            TaskState.Pending

fn _id_from_filename(filename: text) -> text:
    if filename.ends_with(".task"):
        return filename.substring(0, filename.len() - ".task".len())
    filename

pub fn _parse_task_file(filename: text, content: text) -> ManagedTask:
    var id = _field(content, "id")
    if id == "":
        id = _id_from_filename(filename)
    val command = _field(content, "command")
    val status = _field(content, "status")
    ManagedTask(
        id: id,
        kind: TaskKind.Job,
        title: if command == "": id else: command,
        command: command,
        state: _state_from_status(status),
        pid: -1,
        exit_code: -1,
        start_time: ""
    )

pub fn collect_task_daemon_tasks() -> [ManagedTask]:
    if not file_exists(TASK_DAEMON_TASK_DIR):
        return []
    val files = list_dir(TASK_DAEMON_TASK_DIR) ?? []
    var tasks: [ManagedTask] = []
    for filename in files:
        if filename.ends_with(".task"):
            val content = file_read_text(TASK_DAEMON_TASK_DIR + "/" + filename) ?? ""
            tasks.push(_parse_task_file(filename, content))
    tasks
