# Package Registry Types
# Core data types for the Simple package registry.

# Registry connection configuration.
class RegistryConfig:
    registry_url: text
    index_url: text
    cache_dir: text
    credentials_path: text

# Stored credentials for registry authentication.
class Credentials:
    token: text
    token_type: text

# Metadata about a package.
class PackageInfo:
    name: text
    description: text
    homepage: text
    license: text
    repository: text

# A single published version entry in the index.
class VersionEntry:
    version: text
    checksum: text
    oci_ref: text
    yanked: bool
    published_at: text

# A dependency declared for a specific version.
class VersionDependency:
    version: text
    name: text
    constraint: text

# Full index entry for a package (all versions + deps).
class IndexEntry:
    package: PackageInfo
    versions: [VersionEntry]
    dependencies: [VersionDependency]

# Result of searching the package index.
class SearchResult:
    name: text
    description: text
    latest_version: text

# Result of publishing a package to the registry.
class PublishResult:
    success: bool
    message: text
    oci_ref: text
