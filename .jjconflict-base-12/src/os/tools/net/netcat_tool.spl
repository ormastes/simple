# nc / netcat — Network utility
# MDSOC: feature dimension, apps layer

use os.userlib.net.{IpAddr, SockAddr, Socket, socket, connect, bind, listen, accept, send, recv}
use common.string_core.{char_from_code}

fn netcat_bytes_to_text(bytes: [u8]) -> text:
    var result = ""
    var i = 0
    while i < bytes.len():
        val b = bytes[i] as i64
        if b == 10:
            result = result + "\n"
        elif b == 13:
            result = result + "\r"
        elif b == 9:
            result = result + "\t"
        else:
            result = result + char_from_code(b)
        i = i + 1
    result

fn run_netcat(args: [text]) -> i32:
    """Netcat — read/write data across network connections.

    Usage: nc HOST PORT            (connect mode)
           nc -l PORT              (listen mode)
    """
    if args.len() == 0:
        print "nc: missing host or port"
        print "Usage: nc HOST PORT | nc -l PORT"
        return 1

    if args[0] == "-l":
        return _netcat_listen(args)
    return _netcat_connect(args)

fn _netcat_connect(args: [text]) -> i32:
    """Connect to HOST PORT and enter read/write loop."""
    if args.len() < 2:
        print "nc: connect mode requires HOST and PORT"
        return 1
    val host = args[0]
    val port_val = args[1].parse_u64()
    if port_val == 0:
        print "nc: invalid port: {args[1]}"
        return 1

    val ip_result = IpAddr.from_text(host)
    var ip = IpAddr()
    match ip_result:
        Ok(parsed_ip):
            ip = parsed_ip
        Err(err):
            print "nc: {err}"
            return 1

    val sock_result = socket(2, 1)
    var sock = 0
    match sock_result:
        Ok(open_sock):
            sock = open_sock
        Err(err):
            print "nc: socket: {err}"
            return 1

    val addr = SockAddr(ip: ip, port: port_val as u16)
    val conn_result = connect(sock, addr)
    match conn_result:
        Ok(_):
            pass_dn
        Err(err):
            print "nc: connect: {err}"
            return 1

    # Read/write loop — receive until connection closed
    var running = true
    while running:
        val data = recv(sock, 4096)
        match data:
            Ok(bytes):
                if bytes.len() == 0:
                    running = false
                else:
                    print netcat_bytes_to_text(bytes)
            Err(_):
                running = false
    return 0

fn _netcat_listen(args: [text]) -> i32:
    """Listen on PORT and enter read/write loop on accepted connection."""
    if args.len() < 2:
        print "nc: listen mode requires PORT"
        return 1
    val port_val = args[1].parse_u64()
    if port_val == 0:
        print "nc: invalid port: {args[1]}"
        return 1

    val sock_result = socket(2, 1)
    var sock = 0
    match sock_result:
        Ok(open_sock):
            sock = open_sock
        Err(err):
            print "nc: socket: {err}"
            return 1

    val loopback_result = IpAddr.from_text("0.0.0.0")
    var loopback = IpAddr()
    match loopback_result:
        Ok(parsed_ip):
            loopback = parsed_ip
        Err(_):
            print "nc: internal error building bind address"
            return 1
    val bind_addr = SockAddr(ip: loopback, port: port_val as u16)

    val bind_result = bind(sock, bind_addr)
    match bind_result:
        Ok(_):
            pass_dn
        Err(err):
            print "nc: bind: {err}"
            return 1

    val listen_result = listen(sock, 1)
    match listen_result:
        Ok(_):
            pass_dn
        Err(err):
            print "nc: listen: {err}"
            return 1

    # Poll accept until a connection arrives
    var conn_sock_result = accept(sock)
    var retries = 0
    while conn_sock_result.is_err() and retries < 100:
        conn_sock_result = accept(sock)
        retries = retries + 1

    var conn_sock = 0
    match conn_sock_result:
        Ok(open_sock):
            conn_sock = open_sock
        Err(err):
            print "nc: accept: {err}"
            return 1

    # Read/write loop on accepted connection
    var running = true
    while running:
        val data = recv(conn_sock, 4096)
        match data:
            Ok(bytes):
                if bytes.len() == 0:
                    running = false
                else:
                    print netcat_bytes_to_text(bytes)
            Err(_):
                running = false
    return 0
