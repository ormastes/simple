#!/usr/bin/env python3
import sys, socket, os

args = sys.argv[1:]
# Handle: socat - UNIX-CONNECT:/path/to.sock
if len(args) == 2 and args[0] == '-' and args[1].startswith('UNIX-CONNECT:'):
    sock_path = args[1][len('UNIX-CONNECT:'):]
    data = sys.stdin.buffer.read()
    s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    s.connect(sock_path)
    s.sendall(data)
    s.shutdown(socket.SHUT_WR)
    response = b''
    while True:
        chunk = s.recv(4096)
        if not chunk:
            break
        response += chunk
    s.close()
    sys.stdout.buffer.write(response)
else:
    sys.stderr.write(f"socat shim: unsupported args {args}\n")
    sys.exit(1)
