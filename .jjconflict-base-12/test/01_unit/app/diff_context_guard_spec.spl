extern fn rt_file_read_text(path: text) -> text?

describe "diff context guard":
    it "guards malformed context values":
        val source = rt_file_read_text("src/app/diff/main.spl") ?? ""

        expect(source).to_contain("fn parse_context_or_default(value: text, default_value: i64) -> i64")
        expect(source).to_contain("context = parse_context_or_default(arg[10:], context)")
        expect(source.contains("context = arg[10:].to_int()")).to_equal(false)
