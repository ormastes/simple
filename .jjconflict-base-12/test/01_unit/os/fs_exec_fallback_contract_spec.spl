"""
FS-Exec Fallback Contract — per-arch rejection specs.
**Feature IDs:** #FS-EXEC-MULTIARCH-AC2
**Category:** OS serial acceptance

Verifies that the shared fs_exec_fallback_contract correctly detects
resident-manifest fallback patterns, and that all five architecture lanes
(x86_64, riscv64, riscv32, arm64, arm32) would reject serial output
containing those patterns as completion evidence.

No QEMU needed — pure contract functions on text input.
"""
use std.spec.*
use os.fs_exec_fallback_contract.{
    fs_exec_serial_has_fallback,
    fs_exec_serial_rejects_fallback,
    FS_EXEC_FALLBACK_PATTERN_RESIDENT_ACTIVE,
    FS_EXEC_FALLBACK_PATTERN_LAUNCHER
}

# ---------------------------------------------------------------------------
# Helper: build serial outputs
# ---------------------------------------------------------------------------

fn _clean_serial() -> text:
    "[vfs] mounted fat32\n[launcher] loaded app /sys/apps/simple_browser\n[desktop-e2e] process-backed:ok app=simple_browser pid=42\n"

fn _fallback_serial_both_patterns() -> text:
    "[vfs] mounted fat32\n[desktop-e2e] resident-fallback:active app=simple_browser\n[launcher] fallback=resident-manifest app_id=/sys/apps/simple_browser\n"

fn _fallback_serial_resident_active_only() -> text:
    "[vfs] mounted fat32\n[desktop-e2e] resident-fallback:active app=simple_compiler\n"

fn _fallback_serial_launcher_only() -> text:
    "[vfs] mounted fat32\n[launcher] fallback=resident-manifest app_id=/sys/apps/simple_loader\n"

# ---------------------------------------------------------------------------
# Shared contract — basic detection
# ---------------------------------------------------------------------------

describe "fs_exec_fallback_contract — detection":

    it "clean serial has no fallback":
        expect(fs_exec_serial_has_fallback(_clean_serial())).to_equal(false)

    it "clean serial passes rejects_fallback":
        expect(fs_exec_serial_rejects_fallback(_clean_serial())).to_equal(true)

    it "detects resident-fallback:active pattern alone":
        expect(fs_exec_serial_has_fallback(_fallback_serial_resident_active_only())).to_equal(true)

    it "detects launcher fallback=resident-manifest pattern alone":
        expect(fs_exec_serial_has_fallback(_fallback_serial_launcher_only())).to_equal(true)

    it "detects both patterns together":
        expect(fs_exec_serial_has_fallback(_fallback_serial_both_patterns())).to_equal(true)

    it "rejects_fallback is false when fallback detected (both patterns)":
        expect(fs_exec_serial_rejects_fallback(_fallback_serial_both_patterns())).to_equal(false)

    it "rejects_fallback is false for resident-active-only serial":
        expect(fs_exec_serial_rejects_fallback(_fallback_serial_resident_active_only())).to_equal(false)

    it "rejects_fallback is false for launcher-only serial":
        expect(fs_exec_serial_rejects_fallback(_fallback_serial_launcher_only())).to_equal(false)

    it "pattern constants match expected strings":
        expect(FS_EXEC_FALLBACK_PATTERN_RESIDENT_ACTIVE).to_equal("[desktop-e2e] resident-fallback:active")
        expect(FS_EXEC_FALLBACK_PATTERN_LAUNCHER).to_equal("[launcher] fallback=resident-manifest")

# ---------------------------------------------------------------------------
# Per-arch lanes — each lane must reject fallback serial as NOT complete
#
# Each test represents the arch lane check: if the lane's serial acceptance
# path calls fs_exec_serial_rejects_fallback, it returns false (reject).
# ---------------------------------------------------------------------------

describe "fs_exec fallback rejection — x86_64 lane":

    it "x86_64: resident-fallback:active pattern is rejected":
        val serial = _fallback_serial_resident_active_only()
        expect(fs_exec_serial_rejects_fallback(serial)).to_equal(false)

    it "x86_64: launcher fallback=resident-manifest pattern is rejected":
        val serial = _fallback_serial_launcher_only()
        expect(fs_exec_serial_rejects_fallback(serial)).to_equal(false)

    it "x86_64: clean serial is accepted (not a fallback)":
        val serial = _clean_serial()
        expect(fs_exec_serial_rejects_fallback(serial)).to_equal(true)

describe "fs_exec fallback rejection — riscv64 lane":

    it "riscv64: resident-fallback:active pattern is rejected":
        val serial = _fallback_serial_resident_active_only()
        expect(fs_exec_serial_rejects_fallback(serial)).to_equal(false)

    it "riscv64: launcher fallback=resident-manifest pattern is rejected":
        val serial = _fallback_serial_launcher_only()
        expect(fs_exec_serial_rejects_fallback(serial)).to_equal(false)

    it "riscv64: clean serial is accepted":
        val serial = _clean_serial()
        expect(fs_exec_serial_rejects_fallback(serial)).to_equal(true)

describe "fs_exec fallback rejection — riscv32 lane":

    it "riscv32: resident-fallback:active pattern is rejected":
        val serial = _fallback_serial_resident_active_only()
        expect(fs_exec_serial_rejects_fallback(serial)).to_equal(false)

    it "riscv32: launcher fallback=resident-manifest pattern is rejected":
        val serial = _fallback_serial_launcher_only()
        expect(fs_exec_serial_rejects_fallback(serial)).to_equal(false)

    it "riscv32: clean serial is accepted":
        val serial = _clean_serial()
        expect(fs_exec_serial_rejects_fallback(serial)).to_equal(true)

describe "fs_exec fallback rejection — arm64 lane":

    it "arm64: resident-fallback:active pattern is rejected":
        val serial = _fallback_serial_resident_active_only()
        expect(fs_exec_serial_rejects_fallback(serial)).to_equal(false)

    it "arm64: launcher fallback=resident-manifest pattern is rejected":
        val serial = _fallback_serial_launcher_only()
        expect(fs_exec_serial_rejects_fallback(serial)).to_equal(false)

    it "arm64: clean serial is accepted":
        val serial = _clean_serial()
        expect(fs_exec_serial_rejects_fallback(serial)).to_equal(true)

describe "fs_exec fallback rejection — arm32 lane":

    it "arm32: resident-fallback:active pattern is rejected":
        val serial = _fallback_serial_resident_active_only()
        expect(fs_exec_serial_rejects_fallback(serial)).to_equal(false)

    it "arm32: launcher fallback=resident-manifest pattern is rejected":
        val serial = _fallback_serial_launcher_only()
        expect(fs_exec_serial_rejects_fallback(serial)).to_equal(false)

    it "arm32: clean serial is accepted":
        val serial = _clean_serial()
        expect(fs_exec_serial_rejects_fallback(serial)).to_equal(true)
