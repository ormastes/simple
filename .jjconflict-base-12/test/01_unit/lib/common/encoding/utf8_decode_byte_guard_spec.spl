use std.spec.{describe, it, assert_equal}
use std.common.encoding.utf8.{utf8_decode_one}

describe "utf8 decode byte guards":
    it "keeps valid two byte decode":
        assert_equal(utf8_decode_one([0xC3, 0xA9], 0), [0xE9, 2])

    it "rejects continuation bytes above 255":
        assert_equal(utf8_decode_one([0xC3, 0x180], 0), [0xFFFD, 1])

    it "rejects negative continuation bytes":
        assert_equal(utf8_decode_one([0xE0, -128, 0x80], 0), [0xFFFD, 1])
