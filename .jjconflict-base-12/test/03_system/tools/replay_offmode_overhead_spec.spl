# SReplay Track 2.10 — Off-Mode Overhead Benchmark
#
# Verifies that kernel replay hooks with mode=Off complete 1000 calls in <100ms.
# Each hook returns immediately after a single load+branch when replay is off.

use std.spec.*
use std.timing.{time_now, Instant}
use os.kernel.replay.mode.{KernelReplayMode, replay_set_mode, replay_mode, replay_is_off}
use os.kernel.replay.hooks.{replay_hook_schedule, replay_hook_syscall_enter, replay_hook_irq, replay_hook_timer_read}

# ============================================================================
# Benchmark helpers — module-level to avoid it-block var mutation issues
# ============================================================================

fn _bench_schedule() -> i64:
    replay_set_mode(KernelReplayMode.Off)
    val s = time_now()
    var i: i64 = 0
    while i < 1000:
        replay_hook_schedule(0, 1, i)
        i = i + 1
    s.elapsed_ms()

fn _bench_syscall_enter() -> i64:
    replay_set_mode(KernelReplayMode.Off)
    val s = time_now()
    var i: i64 = 0
    while i < 1000:
        replay_hook_syscall_enter(1, 42, 0, 0, i)
        i = i + 1
    s.elapsed_ms()

fn _bench_irq() -> i64:
    replay_set_mode(KernelReplayMode.Off)
    val s = time_now()
    var i: i64 = 0
    while i < 1000:
        replay_hook_irq(32, 0, i)
        i = i + 1
    s.elapsed_ms()

fn _bench_timer_read() -> i64:
    replay_set_mode(KernelReplayMode.Off)
    val s = time_now()
    var i: i64 = 0
    while i < 1000:
        val r = replay_hook_timer_read(0, i)
        i = i + 1
    s.elapsed_ms()

fn _mode_off_after_init() -> bool:
    # Module starts with g_replay_mode == 0 which maps to Off
    replay_set_mode(KernelReplayMode.Off)
    replay_is_off()

fn _bench_off_record_off() -> i64:
    # Toggle Off -> Record -> Off, then measure Off path again
    replay_set_mode(KernelReplayMode.Off)
    replay_set_mode(KernelReplayMode.Record)
    replay_set_mode(KernelReplayMode.Off)
    val s = time_now()
    var i: i64 = 0
    while i < 1000:
        replay_hook_schedule(0, 1, i)
        i = i + 1
    s.elapsed_ms()

# ============================================================================
# Spec
# ============================================================================

describe "SReplay Track 2.10 — off-mode overhead":
    it "replay_hook_schedule 1000 calls in Off mode completes <100ms":
        val ms = _bench_schedule()
        expect(ms).to_be_less_than(100)

    it "replay_hook_syscall_enter 1000 calls in Off mode completes <100ms":
        val ms = _bench_syscall_enter()
        expect(ms).to_be_less_than(100)

    it "replay_hook_irq 1000 calls in Off mode completes <100ms":
        val ms = _bench_irq()
        expect(ms).to_be_less_than(100)

    it "replay_hook_timer_read 1000 calls in Off mode returns quickly <100ms":
        val ms = _bench_timer_read()
        expect(ms).to_be_less_than(100)

    it "mode is Off after explicit init":
        val ok = _mode_off_after_init()
        expect(ok).to_equal(true)

    it "Off -> Record -> Off leaves no residual overhead (<100ms)":
        val ms = _bench_off_record_off()
        expect(ms).to_be_less_than(100)
