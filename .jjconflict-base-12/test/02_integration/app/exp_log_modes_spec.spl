use std.spec.{describe, it, expect}

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

fn _run_exp(args: [text]) -> (text, text, i64):
    val joined = args.join(" ")
    rt_process_run("/bin/sh", [
        "-c",
        "REPO=$(pwd); SIMPLE_LIB=\"$REPO/src\" \"$REPO/bin/simple\" run \"$REPO/src/app/exp/main.spl\" " + joined
    ])

fn _run_exp_temp_script() -> (text, text, i64):
    rt_process_run("/bin/sh", [
        "-c",
        "TMP=/tmp/simple_exp_run_$$.spl; printf 'print \"exp-run-ok\"\\n' > \"$TMP\"; REPO=$(pwd); SIMPLE_LIB=\"$REPO/src\" \"$REPO/bin/simple\" run \"$REPO/src/app/exp/main.spl\" run \"$TMP\"; CODE=$?; rm -f \"$TMP\"; exit $CODE"
    ])

describe "exp log mode CLI options":
    it "shows shared log options in help":
        val (out, err, code) = _run_exp(["--help"])
        expect(code).to_equal(0)
        expect(out).to_contain("Usage: exp")
        expect(out).to_contain("--log-mode")
        expect(out).to_contain("--progress")

    it "supports log-mode json ready output":
        val (out, err, code) = _run_exp(["--log-mode=json"])
        expect(code).to_equal(0)
        expect(out).to_contain("\"command\":\"exp\"")
        expect(out).to_contain("\"status\":\"ready\"")

    it "supports dot progress for help output":
        val (out, err, code) = _run_exp(["--progress=dot", "--help"])
        expect(code).to_equal(0)
        expect(out).to_start_with(".")
        expect(out).to_contain("Usage: exp")

    it "rejects invalid log mode":
        val (out, err, code) = _run_exp(["--log-mode=noisy"])
        expect(code).to_equal(1)

    it "delegates experiment script execution":
        val (out, err, code) = _run_exp_temp_script()
        expect(code).to_equal(0)
        expect(out).to_contain("exp-run-ok")
