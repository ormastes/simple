# R1 — class definitions inside `it` blocks must compile and execute.
#
# Before this fix, the HIR rejected `class Foo:` appearing as a statement in a
# function body with "Definition type Class cannot appear as a statement in
# function body", and lenient mode silently dropped it (leaving downstream
# lookups of `Foo` as "undefined identifier"). The fix lifts every nested
# type definition to module scope before the type-check + HIR-lower passes
# run, so the cases below now succeed.
#
# Companion to doc/08_tracking/todo/compiler_bugs_for_crypto_2026-04-25.md (R1).

describe "R1 nested class definitions":
    it "instantiates a class defined inside the it block":
        class Point:
            x: i32
            y: i32

        val p = Point(x: 7, y: 11)
        expect p.x == 7
        expect p.y == 11

    it "calls a static factory on a class defined inside the it block":
        class IP:
            value: text

            static fn from(s: text) -> IP:
                IP(value: s)

        val addr = IP.from("127.0.0.1")
        expect addr.value == "127.0.0.1"

    it "supports two it-blocks declaring the same class name (first wins)":
        class Box:
            v: i32

        val b = Box(v: 42)
        expect b.v == 42

    it "supports two it-blocks declaring the same class name (second occurrence)":
        # The hoist policy keeps the first declaration of `Box` and drops
        # this one; the runtime semantics of the BDD interpreter still
        # construct `Box(v: 99)` because it walks AST per `it` block.
        class Box:
            v: i32

        val b = Box(v: 99)
        expect b.v == 99

    it "handles a class with multiple fields and a method":
        class Rect:
            w: i32
            h: i32

            fn area(self) -> i32:
                self.w * self.h

        val r = Rect(w: 4, h: 5)
        expect r.area() == 20
