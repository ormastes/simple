enum Inst:
    Call(i64, text, [i64])
    CallIndirect(i64, text, [i64], i64)
    Nop

fn classify(inst: Inst) -> i64:
    match inst:
        case Call(_, name, args):
            args.len()
        case CallIndirect(_, ptr, args, _):
            args.len() + 100
        case _:
            0

fn main():
    print("a={classify(Inst.Call(1, \"f\", [1,2]))}")
    print("b={classify(Inst.CallIndirect(1, \"g\", [1,2,3], 7))}")
    print("c={classify(Inst.Nop)}")
