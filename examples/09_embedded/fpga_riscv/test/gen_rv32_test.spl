# Simple program that generates RV32I assembly for GHDL simulation
# Generates: sum(1..10) = 55, writes to LED register
# Run: simple gen_rv32_test.spl > test_gen.s

fn main():
    print "# Generated by Simple Language - sum(1..10) test"
    print "# Expected LED value: 55"
    print ""
    print ".section .text"
    print ".globl _start"
    print "_start:"
    # Initialize sum = 0
    print "    li   a0, 0             # sum = 0"
    # Loop from 1 to 10
    print "    li   a1, 1             # i = 1"
    print "    li   a2, 11            # limit = 11"
    print "loop:"
    print "    add  a0, a0, a1        # sum += i"
    print "    addi a1, a1, 1         # i++"
    print "    blt  a1, a2, loop      # if i < 11, loop"
    # Write result to LED register
    print "    lui  t0, 0x80000       # LED base = 0x80000000"
    print "    sw   a0, 0(t0)         # LED = sum"
    print "    ecall                   # halt"
