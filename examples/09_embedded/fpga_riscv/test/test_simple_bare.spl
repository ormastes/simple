#![allow(unnamed_duplicate_typed_args)]
# Baremetal Simple program for GHDL simulation
# Pure computation: 7 * 8 = 56, store to 0x80000000 (LED register)
# No runtime, no extern fns - just integer math + memory store

fn main():
    val x = 7
    val y = 8
    val result = x * y  # 56
    # Store result to memory-mapped LED register
    # Using raw pointer store (baremetal)
    unsafe_store_u32(0x80000000, result)

fn unsafe_store_u32(addr: i64, value: i64):
    # Compiler intrinsic for raw memory write
    __store_u32(addr, value)
