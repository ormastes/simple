# RISC-V FPGA Linux RTL bundle generator.
#
# Usage:
#   bin/simple run examples/09_embedded/fpga_riscv/generate_linux_rtl.spl
#   bin/simple run examples/09_embedded/fpga_riscv/generate_linux_rtl.spl build/fpga/try_rtl/riscv_linux

use hardware.fpga_linux.riscv_fpga_linux.{generate_default_riscv_fpga_rtl_bundle}

extern fn sys_get_args() -> [text]

fn main() -> i32:
    val args = sys_get_args()
    var out_dir = "build/fpga/try_rtl/riscv_linux"
    if args.len() >= 2:
        out_dir = args[1]

    match generate_default_riscv_fpga_rtl_bundle(out_dir):
        Ok(bundle):
            print "Generated RISC-V FPGA RTL bundle: {bundle.root_dir}"
            for path in bundle.generated_files:
                print "Output: {path}"
            return 0
        Err(error):
            print "error: {error}"
            return 1
