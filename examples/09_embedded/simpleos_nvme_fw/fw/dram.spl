"""
dram — fixed DRAM write buffer floor for the NVMe firmware simulation (gap-closure P5).

Pure bounded buffer: host write bytes stage here before the FTL programs media.
"""

use nvme_types.*

val WRITE_BUFFER_CAP_BLOCKS: i64 = 16
val WRITE_BUFFER_ENTRY_BYTES: i64 = 4096
val WRITE_BUFFER_DRAM_BUDGET_BYTES: i64 = 65536

fn dram_fill(size: i64, fill: i64) -> [i64]:
    var arr: [i64] = []
    var i: i64 = 0
    while i < size:
        arr.push(fill)
        i = i + 1
    arr

struct DramWriteBuffer:
    data: [i64]
    cap: i64
    count: i64
    overflows: i64

fn dram_write_buffer_new() -> DramWriteBuffer:
    DramWriteBuffer(data: dram_fill(WRITE_BUFFER_CAP_BLOCKS, 0), cap: WRITE_BUFFER_CAP_BLOCKS, count: 0, overflows: 0)

impl DramWriteBuffer:
    me clear():
        me.count = 0

    me stage(index: i64, byte: i64) -> i64:
        if index < 0:
            me.overflows = me.overflows + 1
            return SC_NS_NOT_READY
        if index >= me.cap:
            me.overflows = me.overflows + 1
            return SC_NS_NOT_READY
        me.data[index] = byte & 0xFF
        if index + 1 > me.count:
            me.count = index + 1
        SC_SUCCESS

    me byte(index: i64) -> i64:
        if index < 0:
            return 0
        if index >= me.count:
            return 0
        me.data[index]

    me used() -> i64:
        me.count

    me overflow_count() -> i64:
        me.overflows

fn dram_selftest() -> i64:
    var fail: i64 = 0
    var b: DramWriteBuffer = dram_write_buffer_new()
    fail = fail + expect_eq(b.cap * WRITE_BUFFER_ENTRY_BYTES, WRITE_BUFFER_DRAM_BUDGET_BYTES, "write buffer fits DRAM budget")
    fail = fail + expect_eq(b.stage(0, 0x123), SC_SUCCESS, "stage byte 0")
    fail = fail + expect_eq(b.stage(1, 0x45), SC_SUCCESS, "stage byte 1")
    fail = fail + expect_eq(b.byte(0), 0x23, "stage masks byte")
    fail = fail + expect_eq(b.byte(1), 0x45, "stage keeps byte")
    fail = fail + expect_eq(b.used(), 2, "used count")
    fail = fail + expect_eq(b.stage(WRITE_BUFFER_CAP_BLOCKS, 1), SC_NS_NOT_READY, "over-capacity stage fails")
    fail = fail + expect_eq(b.overflow_count(), 1, "overflow counted")
    b.clear()
    fail = fail + expect_eq(b.used(), 0, "clear resets count")
    fail
