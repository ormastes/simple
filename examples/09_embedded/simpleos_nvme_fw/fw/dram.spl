"""
dram — bounded DRAM write arena floor for the NVMe firmware simulation (gap-closure P5).

Pure fixed arena: host write bytes allocate a span here before the FTL programs media.
"""

use nvme_types.*

val WRITE_BUFFER_CAP_BLOCKS: i64 = 16
val WRITE_BUFFER_ENTRY_BYTES: i64 = 4096
val WRITE_BUFFER_DRAM_BUDGET_BYTES: i64 = 65536

fn dram_fill(size: i64, fill: i64) -> [i64]:
    var arr: [i64] = []
    var i: i64 = 0
    while i < size:
        arr.push(fill)
        i = i + 1
    arr

struct DramWriteBuffer:
    data: [i64]
    used_slots: [i64]
    cap: i64
    count: i64
    overflows: i64

struct DramSpan:
    base: i64
    len: i64
    ok: bool

fn dram_write_buffer_new() -> DramWriteBuffer:
    DramWriteBuffer(data: dram_fill(WRITE_BUFFER_CAP_BLOCKS, 0), used_slots: dram_fill(WRITE_BUFFER_CAP_BLOCKS, 0), cap: WRITE_BUFFER_CAP_BLOCKS, count: 0, overflows: 0)

impl DramWriteBuffer:
    me effective_cap() -> i64:
        var c: i64 = me.cap
        if c < 0:
            return 0
        if c > WRITE_BUFFER_CAP_BLOCKS:
            c = WRITE_BUFFER_CAP_BLOCKS
        if c > me.data.len():
            c = me.data.len()
        if c > me.used_slots.len():
            c = me.used_slots.len()
        c

    me clear():
        me.count = 0
        val cap: i64 = me.effective_cap()
        var i: i64 = 0
        while i < cap:
            me.used_slots[i] = 0
            i = i + 1

    me alloc(nblocks: i64) -> DramSpan:
        val cap: i64 = me.effective_cap()
        if nblocks <= 0:
            return DramSpan(base: 0, len: 0, ok: true)
        if nblocks > cap:
            me.overflows = me.overflow_count() + 1
            return DramSpan(base: -1, len: 0, ok: false)
        var start: i64 = 0
        while start + nblocks <= cap:
            var i: i64 = 0
            var free: bool = true
            while i < nblocks:
                if me.used_slots[start + i] != 0:
                    free = false
                i = i + 1
            if free:
                i = 0
                while i < nblocks:
                    me.used_slots[start + i] = 1
                    me.data[start + i] = 0
                    i = i + 1
                me.count = me.count + nblocks
                return DramSpan(base: start, len: nblocks, ok: true)
            start = start + 1
        me.overflows = me.overflow_count() + 1
        DramSpan(base: -1, len: 0, ok: false)

    me release(span: DramSpan):
        if not span.ok:
            return
        val cap: i64 = me.effective_cap()
        if span.base < 0 or span.len < 0 or span.base + span.len > cap:
            return
        var i: i64 = 0
        while i < span.len:
            val idx: i64 = span.base + i
            if idx >= 0 and idx < cap:
                if me.used_slots[idx] != 0:
                    me.used_slots[idx] = 0
                    me.data[idx] = 0
                    if me.count > 0:
                        me.count = me.count - 1
            i = i + 1

    me stage(span: DramSpan, index: i64, byte: i64) -> i64:
        val cap: i64 = me.effective_cap()
        if not span.ok:
            me.overflows = me.overflow_count() + 1
            return SC_NS_NOT_READY
        if index < 0:
            me.overflows = me.overflow_count() + 1
            return SC_NS_NOT_READY
        if index >= span.len:
            me.overflows = me.overflow_count() + 1
            return SC_NS_NOT_READY
        if span.base < 0 or span.len < 0 or span.base + span.len > cap:
            me.overflows = me.overflow_count() + 1
            return SC_NS_NOT_READY
        val slot: i64 = span.base + index
        if slot < 0 or slot >= cap:
            me.overflows = me.overflow_count() + 1
            return SC_NS_NOT_READY
        if me.used_slots[slot] == 0:
            me.overflows = me.overflow_count() + 1
            return SC_NS_NOT_READY
        me.data[slot] = byte & 0xFF
        if slot + 1 > me.count:
            me.count = slot + 1
        SC_SUCCESS

    me byte(span: DramSpan, index: i64) -> i64:
        val cap: i64 = me.effective_cap()
        if not span.ok:
            return 0
        if index < 0:
            return 0
        if index >= span.len:
            return 0
        if span.base < 0 or span.len < 0 or span.base + span.len > cap:
            return 0
        val slot: i64 = span.base + index
        if slot < 0 or slot >= cap:
            return 0
        if me.used_slots[slot] == 0:
            return 0
        me.data[slot]

    me used() -> i64:
        if me.count < 0:
            return 0
        val cap: i64 = me.effective_cap()
        if me.count > cap:
            return cap
        me.count

    me overflow_count() -> i64:
        if me.overflows < 0:
            return 0
        me.overflows

fn dram_selftest() -> i64:
    var fail: i64 = 0
    var b: DramWriteBuffer = dram_write_buffer_new()
    fail = fail + expect_eq(b.cap * WRITE_BUFFER_ENTRY_BYTES, WRITE_BUFFER_DRAM_BUDGET_BYTES, "write buffer fits DRAM budget")
    val s: DramSpan = b.alloc(2)
    fail = fail + expect_eq(if s.ok: 1 else: 0, 1, "alloc span")
    fail = fail + expect_eq(b.stage(s, 0, 0x123), SC_SUCCESS, "stage byte 0")
    fail = fail + expect_eq(b.stage(s, 1, 0x45), SC_SUCCESS, "stage byte 1")
    fail = fail + expect_eq(b.byte(s, 0), 0x23, "stage masks byte")
    fail = fail + expect_eq(b.byte(s, 1), 0x45, "stage keeps byte")
    fail = fail + expect_eq(b.used(), 2, "used count")
    b.count = -3
    fail = fail + expect_eq(b.used(), 0, "corrupted negative DRAM usage clamps to zero")
    b.count = WRITE_BUFFER_CAP_BLOCKS + 3
    fail = fail + expect_eq(b.used(), WRITE_BUFFER_CAP_BLOCKS, "corrupted oversized DRAM usage clamps to capacity")
    b.count = 2
    b.cap = WRITE_BUFFER_CAP_BLOCKS + 5
    fail = fail + expect_eq(b.effective_cap(), WRITE_BUFFER_CAP_BLOCKS, "corrupted oversized DRAM cap clamps to backing arena")
    fail = fail + expect_eq(b.stage(DramSpan(base: WRITE_BUFFER_CAP_BLOCKS, len: 1, ok: true), 0, 1), SC_NS_NOT_READY, "corrupted oversized DRAM cap cannot stage past backing arena")
    b.cap = -1
    fail = fail + expect_eq(b.effective_cap(), 0, "corrupted negative DRAM cap clamps to zero")
    fail = fail + expect_eq(if b.alloc(1).ok: 1 else: 0, 0, "corrupted negative DRAM cap rejects allocation")
    b.cap = WRITE_BUFFER_CAP_BLOCKS
    b.overflows = -4
    fail = fail + expect_eq(b.overflow_count(), 0, "corrupted negative DRAM overflow count clamps to zero")
    fail = fail + expect_eq(b.stage(s, 2, 1), SC_NS_NOT_READY, "corrupted negative DRAM overflow count recovers on stage error")
    fail = fail + expect_eq(b.overflow_count(), 1, "corrupted negative DRAM overflow count increments from zero")
    b.overflows = 0
    fail = fail + expect_eq(b.stage(s, 2, 1), SC_NS_NOT_READY, "over-span stage fails")
    fail = fail + expect_eq(b.overflow_count(), 1, "overflow counted")
    val forged: DramSpan = DramSpan(base: 5, len: 1, ok: true)
    fail = fail + expect_eq(b.stage(forged, 0, 0xAA), SC_NS_NOT_READY, "forged unallocated span stage fails")
    fail = fail + expect_eq(b.byte(forged, 0), 0, "forged unallocated span read returns zero")
    b.release(DramSpan(base: -1, len: 3, ok: true))
    fail = fail + expect_eq(b.used(), 2, "forged negative release leaves live slots")
    b.release(DramSpan(base: 1, len: WRITE_BUFFER_CAP_BLOCKS, ok: true))
    fail = fail + expect_eq(b.used(), 2, "forged overrun release leaves live slots")
    b.release(s)
    fail = fail + expect_eq(b.used(), 0, "release resets live usage")
    val full: DramSpan = b.alloc(WRITE_BUFFER_CAP_BLOCKS)
    fail = fail + expect_eq(if full.ok: 1 else: 0, 1, "release frees arena")
    fail = fail + expect_eq(b.used(), WRITE_BUFFER_CAP_BLOCKS, "full alloc tracks live usage")
    val over: DramSpan = b.alloc(1)
    fail = fail + expect_eq(if over.ok: 1 else: 0, 0, "over-budget alloc fails")
    fail = fail + expect_eq(b.overflow_count(), 3, "alloc overflow counted")
    b.release(full)
    fail = fail + expect_eq(b.used(), 0, "full release resets live usage")
    fail
