"""
ftl — Flash Translation Layer core.

Composes the FIL (fil), the DFTL map cache (ftl_map), the log-structured allocator
(ftl_band), and the journal (ftl_journal) into the host-visible block device:
  - log-structured write (allocate a fresh page, journal, remap, invalidate the old)
  - read / read-status (ECC-aware)
  - trim / deallocate
  - checkpoint + dirty-shutdown recovery (committed-prefix property via WAL replay)
  - garbage collection (relocate live pages off a victim, erase, reclaim)
"""

use nvme_types.*
use fil.*
use ftl_map.*
use ftl_band.*
use ftl_journal.*
use ftl_gc.*

struct Ftl:
    fil:       Fil
    map:       L2pMap
    band:      BandAlloc
    journal:   Journal
    seq:       i64
    rd_disturb: [i64]   # per-block read counter (volatile) driving read-disturb scrub

fn ftl_new() -> Ftl:
    Ftl(fil: fil_new(), map: ftl_map_new(), band: ftl_band_new(), journal: ftl_journal_new(), seq: 0, rd_disturb: ftl_fill(NUM_BLOCKS, 0))

impl Ftl:
    # Write one logical block (log-structured): program a fresh physical page with OOB
    # {lba, seq}, journal the remap, update L2P, invalidate the previous version.
    me write(lba: i64, data: i64) -> i64:
        # Host writes never consume the GC scratch reserve (over-provisioning headroom),
        # so garbage collection can always relocate a victim and reclaim stale space.
        val ppn: i64 = me.band.alloc_page_host(GC_RESERVE)
        if ppn == NO_PPN:
            return SC_NS_NOT_READY
        me.seq = me.seq + 1
        val s: i64 = me.seq
        val old_ppn: i64 = me.map.lookup(lba)
        val pc: i64 = me.fil.program(ppn, lba, s, data)
        if pc != NAND_OK:
            return SC_INTERNAL
        me.ensure_journal_room()
        me.journal.append(0, lba, old_ppn, ppn, s)
        me.map.update(lba, ppn)
        me.band.mark_valid(ppn)
        if old_ppn != UNMAP:
            me.band.mark_invalid(old_ppn)
        SC_SUCCESS

    # Read one logical block; an unmapped (never-written / trimmed) LBA reads 0.
    # Each read accumulates read-disturb on the backing block (drives scrub_once).
    me read(lba: i64) -> i64:
        val ppn: i64 = me.map.lookup(lba)
        if ppn == UNMAP:
            return 0
        val blk: i64 = ppn_block(ppn)
        me.rd_disturb[blk] = me.rd_disturb[blk] + 1
        val rd: FilRead = me.fil.read(ppn)
        rd.data

    # Read status: SC_MEDIA_ERR if ECC could not recover the page, else SC_SUCCESS.
    me read_status(lba: i64) -> i64:
        val ppn: i64 = me.map.lookup(lba)
        if ppn == UNMAP:
            return SC_SUCCESS
        val rd: FilRead = me.fil.read(ppn)
        var st: i64 = SC_SUCCESS
        if rd.code == NAND_ECC_FAIL:
            st = SC_MEDIA_ERR
        st

    # Trim/deallocate: drop the mapping and invalidate the physical page.
    me trim(lba: i64) -> i64:
        val ppn: i64 = me.map.lookup(lba)
        if ppn != UNMAP:
            me.band.mark_invalid(ppn)
            me.map.update(lba, UNMAP)
            me.seq = me.seq + 1
            me.ensure_journal_room()
            me.journal.append(0, lba, ppn, UNMAP, me.seq)
        SC_SUCCESS

    # Persist a checkpoint: flush the dirty map cache to the flash-resident L2P,
    # advance the journal checkpoint, and truncate the now-durable WAL prefix. After
    # this the L2P alone reflects all state up to me.seq, so the dropped WAL records
    # are not needed for recovery.
    me checkpoint():
        me.map.flush()
        me.journal.checkpoint(me.seq)
        me.journal.truncate_checkpointed()

    # Guarantee room for one more WAL record. If the ring is full, checkpoint first
    # (flush durable + truncate) so the record is never silently dropped — which would
    # otherwise ack a write to the host whose mapping is lost on the next power cycle.
    me ensure_journal_room():
        if me.journal.is_full():
            me.checkpoint()

    # Simulate a power loss: lose ALL volatile DRAM state. The write-back map cache
    # (un-flushed dirty entries) and the band valid bitmap + allocator frontier are
    # gone; the flash-resident L2P, the journal, the NAND array + OOB, and the
    # bad-block table are persistent and survive. recover() rebuilds the volatile
    # state from this persistent media.
    me crash():
        me.map.crash_volatile()
        me.band.reset_volatile()
        me.rd_disturb = ftl_fill(NUM_BLOCKS, 0)

    # Power-on recovery. Rebuild all volatile state from persistent media:
    #  1. Replay the journal (WAL) onto the flash-resident L2P in append order
    #     (= ascending seq) so the newest mapping per LBA wins and trim records
    #     (new_ppn == UNMAP) clear the entry. Records <= the last checkpoint are
    #     already durable in the L2P; replaying them is idempotent.
    #  2. Reconstruct the band valid bitmap from the now-authoritative L2P.
    #  3. Re-apply persistently-retired blocks so the allocator skips them.
    me recover():
        val n: i64 = me.journal.wal_len()
        var i: i64 = 0
        while i < n:
            val lba: i64 = me.journal.record_lba(i)
            val newp: i64 = me.journal.record_new(i)
            me.map.update(lba, newp)
            i = i + 1
        me.map.flush()
        var lba2: i64 = 0
        while lba2 < LBA_COUNT:
            val ppn: i64 = me.map.l2p_entry(lba2)
            if ppn != UNMAP:
                me.band.rebuild_mark(ppn)
            lba2 = lba2 + 1
        var blk: i64 = 0
        while blk < NUM_BLOCKS:
            if me.fil.block_bad(blk):
                me.band.set_bad(blk)
            blk = blk + 1
        me.band.rebuild_finalize()

    me free_blocks() -> i64:
        me.band.free_blocks()

    me erase_count(blk: i64) -> i64:
        me.fil.erase_count(blk)

    # ── Wear / health introspection (SMART) ──────────────────────────────────
    me total_erases() -> i64:
        var t: i64 = 0
        var b: i64 = 0
        while b < NUM_BLOCKS:
            t = t + me.fil.erase_count(b)
            b = b + 1
        t

    me max_erase() -> i64:
        var m: i64 = 0
        var b: i64 = 0
        while b < NUM_BLOCKS:
            val e: i64 = me.fil.erase_count(b)
            if e > m:
                m = e
            b = b + 1
        m

    me bad_blocks() -> i64:
        me.fil.bad_count()

    # test hook: inject NAND read bit-errors at a physical page (forwarded to FIL).
    me inject_read_bitflip(ppn: i64, n: i64):
        me.fil.inject_read_bitflip(ppn, n)

    # ── Read-only introspection (migration capture) ──────────────────────────
    # Physical page currently backing a logical block (UNMAP if unmapped).
    me physical_ppn(lba: i64) -> i64:
        me.map.lookup(lba)

    # Physical block currently backing a logical block (UNMAP if unmapped).
    me physical_block(lba: i64) -> i64:
        val p: i64 = me.map.lookup(lba)
        if p == UNMAP:
            return UNMAP
        ppn_block(p)

    # Raw NAND page payload stored at a physical page.
    me nand_word(ppn: i64) -> i64:
        me.fil.read(ppn).data

    # OOB logical-block tag stored at a physical page (UNMAP if erased/empty).
    me nand_lba(ppn: i64) -> i64:
        me.fil.read(ppn).lba

    me block_valid_count(blk: i64) -> i64:
        me.band.valid_count(blk)

    me page_live(ppn: i64) -> i64:
        var v: i64 = 0
        if me.band.is_valid(ppn):
            v = 1
        v

    # Reclaim one block: relocate its live pages to fresh pages (durable + journaled
    # BEFORE the block is erased), then erase and free it. Returns the block, or UNMAP
    # if it could not be fully drained.
    #
    # SAFETY (data-loss guard): the block is erased ONLY after EVERY live page has been
    # relocated. If a relocation cannot allocate a fresh page (device full / GC reserve
    # exhausted), this aborts and returns UNMAP, leaving the block — and the host data it
    # still holds — intact. Erasing a block with un-relocated live pages would destroy
    # committed data while the L2P map still points into it. A crash mid-reclaim leaves
    # the new copy discoverable by recovery (newest seq wins).
    me reclaim_block(blk: i64) -> i64:
        val base: i64 = block_first_ppn(blk)
        var p: i64 = 0
        while p < PAGES_PER_BLOCK:
            val ppn: i64 = base + p
            val live: bool = me.band.is_valid(ppn)
            if live:
                val rd: FilRead = me.fil.read(ppn)
                val newp: i64 = me.band.alloc_page()
                if newp == NO_PPN:
                    return UNMAP    # cannot relocate -> do NOT erase; block stays intact
                me.seq = me.seq + 1
                me.fil.program(newp, rd.lba, me.seq, rd.data)
                me.ensure_journal_room()
                me.journal.append(0, rd.lba, ppn, newp, me.seq)
                me.map.update(rd.lba, newp)
                me.band.mark_valid(newp)
                me.band.mark_invalid(ppn)
            p = p + 1
        me.fil.erase(blk)
        me.band.free_block(blk)
        me.rd_disturb[blk] = 0      # erased -> read-disturb accumulation cleared
        blk

    # Garbage-collect one victim: the greedy (fewest-valid) CLOSED block. Returns the
    # reclaimed block, or UNMAP if nothing is collectable / it could not be drained.
    me gc_once() -> i64:
        val victim: i64 = gc_select_victim(me.band)
        if victim == UNMAP:
            return UNMAP
        me.reclaim_block(victim)

    # Static wear leveling: when the erase-count spread between the most- and least-worn
    # live blocks exceeds WL_THRESHOLD, reclaim the coldest (least-erased) block so the
    # static data it holds moves and that lightly-worn block rejoins the write rotation.
    # Returns the leveled block, or UNMAP if wear is already balanced.
    me wear_level_once() -> i64:
        val cold: i64 = gc_select_wear_victim(me.band, me.fil)
        if cold == UNMAP:
            return UNMAP
        if me.max_erase() - me.fil.erase_count(cold) <= WL_THRESHOLD:
            return UNMAP
        me.reclaim_block(cold)

    # Read-disturb scrub: reclaim a CLOSED block whose accumulated read count exceeds
    # READ_DISTURB_THRESHOLD, rewriting its live pages fresh (clearing disturb) and
    # erasing it. Returns the scrubbed block, or UNMAP if none needs it.
    me scrub_once() -> i64:
        var target: i64 = UNMAP
        var blk: i64 = 0
        while blk < NUM_BLOCKS:
            if me.band.block_state(blk) == BLK_CLOSED:
                if me.band.valid_count(blk) > 0 and me.rd_disturb[blk] > READ_DISTURB_THRESHOLD:
                    if target == UNMAP:
                        target = blk
            blk = blk + 1
        if target == UNMAP:
            return UNMAP
        me.reclaim_block(target)

# ── Self-test ─────────────────────────────────────────────────────────────────

fn ftl_selftest() -> i64:
    var fail: i64 = 0
    var ftl: Ftl = ftl_new()

    # basic write / read / overwrite
    fail = fail + expect_eq(ftl.write(10, 0xAB), SC_SUCCESS, "write lba10")
    fail = fail + expect_eq(ftl.write(20, 0xCD), SC_SUCCESS, "write lba20")
    fail = fail + expect_eq(ftl.read(10), 0xAB, "read lba10")
    fail = fail + expect_eq(ftl.read(20), 0xCD, "read lba20")
    ftl.write(10, 0x99)
    fail = fail + expect_eq(ftl.read(10), 0x99, "overwrite lba10 (newest wins)")

    # trim
    ftl.trim(20)
    fail = fail + expect_eq(ftl.read(20), 0, "trim lba20 -> reads 0")

    # crash + recovery: committed state survives a lost L2P
    ftl.crash()
    fail = fail + expect_eq(ftl.read(10), 0, "after crash: volatile L2P lost")
    ftl.recover()
    fail = fail + expect_eq(ftl.read(10), 0x99, "recover: lba10 newest survives")
    fail = fail + expect_eq(ftl.read(20), 0, "recover: lba20 stays trimmed")

    # garbage collection: create a CLOSED block full of mostly-stale data, reclaim it
    var i: i64 = 0
    while i < PAGES_PER_BLOCK:
        ftl.write(100 + i, 200 + i)
        i = i + 1
    ftl.write(900, 0x55)                 # opens a new block; block 0 is now CLOSED
    i = 0
    while i < PAGES_PER_BLOCK - 4:        # overwrite most of block 0 -> stale
        ftl.write(100 + i, 111)
        i = i + 1
    val victim: i64 = ftl.gc_once()
    var reclaimed: i64 = 0
    if victim != UNMAP:
        reclaimed = 1
    fail = fail + expect_eq(reclaimed, 1, "gc reclaimed a victim block")
    # logical view preserved across GC (relocated live pages still read correctly)
    fail = fail + expect_eq(ftl.read(100), 111, "post-GC read overwritten lba100")
    fail = fail + expect_eq(ftl.read(163), 263, "post-GC read relocated lba163")
    fail = fail + expect_eq(ftl.erase_count(victim), 1, "gc erased + reclaimed the victim block")

    fail
