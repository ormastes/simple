"""
ftl — Flash Translation Layer core.

Composes the FIL (fil), the DFTL map cache (ftl_map), the log-structured allocator
(ftl_band), and the journal (ftl_journal) into the host-visible block device:
  - log-structured write (allocate a fresh page, journal, remap, invalidate the old)
  - read / read-status (ECC-aware)
  - trim / deallocate
  - checkpoint + dirty-shutdown recovery (committed-prefix property via WAL replay)
  - garbage collection (relocate live pages off a victim, erase, reclaim)
"""

use nvme_types.*
use fil.*
use ftl_map.*
use ftl_band.*
use ftl_journal.*
use ftl_gc.*

struct Ftl:
    fil:     Fil
    map:     L2pMap
    band:    BandAlloc
    journal: Journal
    seq:     i64

fn ftl_new() -> Ftl:
    Ftl(fil: fil_new(), map: ftl_map_new(), band: ftl_band_new(), journal: ftl_journal_new(), seq: 0)

impl Ftl:
    # Write one logical block (log-structured): program a fresh physical page with OOB
    # {lba, seq}, journal the remap, update L2P, invalidate the previous version.
    me write(lba: i64, data: i64) -> i64:
        val ppn: i64 = me.band.alloc_page()
        if ppn == NO_PPN:
            return SC_NS_NOT_READY
        me.seq = me.seq + 1
        val s: i64 = me.seq
        val old_ppn: i64 = me.map.lookup(lba)
        val pc: i64 = me.fil.program(ppn, lba, s, data)
        if pc != NAND_OK:
            return SC_INTERNAL
        me.journal.append(0, lba, old_ppn, ppn, s)
        me.map.update(lba, ppn)
        me.band.mark_valid(ppn)
        if old_ppn != UNMAP:
            me.band.mark_invalid(old_ppn)
        SC_SUCCESS

    # Read one logical block; an unmapped (never-written / trimmed) LBA reads 0.
    me read(lba: i64) -> i64:
        val ppn: i64 = me.map.lookup(lba)
        if ppn == UNMAP:
            return 0
        val rd: FilRead = me.fil.read(ppn)
        rd.data

    # Read status: SC_MEDIA_ERR if ECC could not recover the page, else SC_SUCCESS.
    me read_status(lba: i64) -> i64:
        val ppn: i64 = me.map.lookup(lba)
        if ppn == UNMAP:
            return SC_SUCCESS
        val rd: FilRead = me.fil.read(ppn)
        var st: i64 = SC_SUCCESS
        if rd.code == NAND_ECC_FAIL:
            st = SC_MEDIA_ERR
        st

    # Trim/deallocate: drop the mapping and invalidate the physical page.
    me trim(lba: i64) -> i64:
        val ppn: i64 = me.map.lookup(lba)
        if ppn != UNMAP:
            me.band.mark_invalid(ppn)
            me.map.update(lba, UNMAP)
            me.seq = me.seq + 1
            me.journal.append(0, lba, ppn, UNMAP, me.seq)
        SC_SUCCESS

    # Persist a checkpoint: flush the dirty map cache and advance the journal checkpoint.
    me checkpoint():
        me.map.flush()
        me.journal.checkpoint(me.seq)

    # Simulate a dirty shutdown: lose the volatile L2P (map cache + table).
    me crash():
        me.map = ftl_map_new()

    # Dirty-shutdown recovery: replay the WAL in append order (= ascending seq), so the
    # newest mapping per LBA wins. Trimmed records (new_ppn == UNMAP) clear the entry.
    me recover():
        val n: i64 = me.journal.wal_len()
        var i: i64 = 0
        while i < n:
            val lba: i64 = me.journal.record_lba(i)
            val newp: i64 = me.journal.record_new(i)
            me.map.update(lba, newp)
            i = i + 1
        me.map.flush()

    me free_blocks() -> i64:
        me.band.free_blocks()

    me erase_count(blk: i64) -> i64:
        me.fil.erase_count(blk)

    # ── Read-only introspection (migration capture) ──────────────────────────
    # Physical page currently backing a logical block (UNMAP if unmapped).
    me physical_ppn(lba: i64) -> i64:
        me.map.lookup(lba)

    # Physical block currently backing a logical block (UNMAP if unmapped).
    me physical_block(lba: i64) -> i64:
        val p: i64 = me.map.lookup(lba)
        if p == UNMAP:
            return UNMAP
        ppn_block(p)

    # Raw NAND page payload stored at a physical page.
    me nand_word(ppn: i64) -> i64:
        me.fil.read(ppn).data

    # Garbage-collect one victim block: relocate its live pages to fresh pages
    # (durable + journaled BEFORE the victim is erased), then erase and reclaim it.
    # A crash mid-GC leaves the new copy discoverable by recovery (newest seq wins).
    # Returns the reclaimed block, or UNMAP if there is nothing to collect.
    me gc_once() -> i64:
        val victim: i64 = gc_select_victim(me.band)
        if victim == UNMAP:
            return UNMAP
        val base: i64 = block_first_ppn(victim)
        var p: i64 = 0
        while p < PAGES_PER_BLOCK:
            val ppn: i64 = base + p
            val live: bool = me.band.is_valid(ppn)
            if live:
                val rd: FilRead = me.fil.read(ppn)
                val newp: i64 = me.band.alloc_page()
                if newp != NO_PPN:
                    me.seq = me.seq + 1
                    me.fil.program(newp, rd.lba, me.seq, rd.data)
                    me.journal.append(0, rd.lba, ppn, newp, me.seq)
                    me.map.update(rd.lba, newp)
                    me.band.mark_valid(newp)
                    me.band.mark_invalid(ppn)
            p = p + 1
        me.fil.erase(victim)
        me.band.free_block(victim)
        victim

# ── Self-test ─────────────────────────────────────────────────────────────────

fn ftl_selftest() -> i64:
    var fail: i64 = 0
    var ftl: Ftl = ftl_new()

    # basic write / read / overwrite
    fail = fail + expect_eq(ftl.write(10, 0xAB), SC_SUCCESS, "write lba10")
    fail = fail + expect_eq(ftl.write(20, 0xCD), SC_SUCCESS, "write lba20")
    fail = fail + expect_eq(ftl.read(10), 0xAB, "read lba10")
    fail = fail + expect_eq(ftl.read(20), 0xCD, "read lba20")
    ftl.write(10, 0x99)
    fail = fail + expect_eq(ftl.read(10), 0x99, "overwrite lba10 (newest wins)")

    # trim
    ftl.trim(20)
    fail = fail + expect_eq(ftl.read(20), 0, "trim lba20 -> reads 0")

    # crash + recovery: committed state survives a lost L2P
    ftl.crash()
    fail = fail + expect_eq(ftl.read(10), 0, "after crash: volatile L2P lost")
    ftl.recover()
    fail = fail + expect_eq(ftl.read(10), 0x99, "recover: lba10 newest survives")
    fail = fail + expect_eq(ftl.read(20), 0, "recover: lba20 stays trimmed")

    # garbage collection: create a CLOSED block full of mostly-stale data, reclaim it
    var i: i64 = 0
    while i < PAGES_PER_BLOCK:
        ftl.write(100 + i, 200 + i)
        i = i + 1
    ftl.write(900, 0x55)                 # opens a new block; block 0 is now CLOSED
    i = 0
    while i < PAGES_PER_BLOCK - 4:        # overwrite most of block 0 -> stale
        ftl.write(100 + i, 111)
        i = i + 1
    val victim: i64 = ftl.gc_once()
    var reclaimed: i64 = 0
    if victim != UNMAP:
        reclaimed = 1
    fail = fail + expect_eq(reclaimed, 1, "gc reclaimed a victim block")
    # logical view preserved across GC (relocated live pages still read correctly)
    fail = fail + expect_eq(ftl.read(100), 111, "post-GC read overwritten lba100")
    fail = fail + expect_eq(ftl.read(163), 263, "post-GC read relocated lba163")
    fail = fail + expect_eq(ftl.erase_count(victim), 1, "gc erased + reclaimed the victim block")

    fail
