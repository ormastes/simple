"""
ecc_check — wired SECDED ECC floor (gap-closure P3).

Run: bin/simple run examples/09_embedded/simpleos_nvme_fw/fw/ecc_check.spl
"""

use nvme_types.*
use fil.*

fn main():
    var fail: i64 = 0
    var fil: Fil = fil_new()
    val ppn: i64 = block_first_ppn(3) + 1

    fail = fail + expect_eq(fil.program(ppn, 7, 1, 0x5A), NAND_OK, "program page")

    fil.corrupt_page_data(ppn, 0x5B)
    val one: FilRead = fil.read(ppn)
    fail = fail + expect_eq(one.code, NAND_ECC_FIXED, "single silent payload bit corrected")
    fail = fail + expect_eq(one.data, 0x5A, "corrected byte returned to FIL caller")

    fil.corrupt_page_data(ppn, 0x59)
    val two: FilRead = fil.read(ppn)
    fail = fail + expect_eq(two.code, NAND_ECC_FAIL, "double silent payload bit fails closed")

    if fail == 0:
        print "ECC OK"
    else:
        print "ECC FAIL ({fail})"
