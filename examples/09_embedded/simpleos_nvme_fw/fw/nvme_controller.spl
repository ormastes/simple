"""
nvme_controller — the full NVMe controller front end.

Composes the admin path and the multi-queue IO path over the existing
translation/flash stack:

  AdminQueue (qid 0) ─► admin_process ─► QueueSet create/delete, Identify,
                                          Get/Set Features, Get Log Page
  QueueSet IO SQ/CQ pairs ─► io_process ─► FTL ─► FIL ─► (emulated) NAND
                                          behind a generation-handle task context

This is the "full SSD firmware" front end. The legacy single-queue
hil.spl/firmware.spl path stays untouched (its 225 self-test assertions remain
the regression gate); this controller is the admin-driven, many-IO-queue layer.
"""

use nvme_types.*
use nvme_admin_types.*
use nvme_admin.*
use nvme_qset.*
use hil_command.*
use hil_queue.*
use fw_pool.*
use ftl.*
use power_thermal.*
use dram.*

# Result of dispatching one admin command. `post` is false only for an Async Event
# Request held outstanding (its completion is posted later, when an event is raised).
struct AdminResult:
    status: i64
    data:   i64
    post:   bool

struct NvmeController:
    aq:       AdminQueue
    qset:     QueueSet
    features: FeatureStore
    ftl:      Ftl
    pool:     TaskPool
    last_id:  IdentifyData
    smart:    SmartLog
    reads:    i64
    writes:   i64
    power_cycles: i64
    abort_count:  i64
    format_count: i64
    aer_held_cid: i64   # cid of a single outstanding AER, or -1 if none
    aer_event:    i64   # event awaiting an AER (0 = none), if one arrived first
    fw_revision:  i64   # active firmware revision (bumped on commit)
    fw_dl_bytes:  i64   # bytes accumulated by the in-progress firmware download
    media_errors: i64   # uncorrectable read errors observed (SMART)
    unsafe_shutdowns: i64   # power cycles without a clean checkpoint (SMART)
    error_count:  i64   # IO commands completed with a non-success status (error log)
    last_error:   i64   # status code of the most recent failed IO command
    fw_slot:         i64   # firmware slot of the most recent successful Commit (0 = none yet)
    last_abort_sqid: i64   # SQID decoded from the most recent Abort (-1 = none)
    last_abort_cid:  i64   # CID  decoded from the most recent Abort (-1 = none)
    pt:           PowerThermal   # power-state + thermal model, driven by live IO (SMART temperature)
    wb:           DramWriteBuffer # fixed DRAM write buffer staged before FTL program

fn nvme_controller_new() -> NvmeController:
    NvmeController(aq: admin_queue_new(), qset: queue_set_new(), features: feature_store_new(), ftl: ftl_new(), pool: task_pool_new(), last_id: identify_empty(), smart: smart_empty(), reads: 0, writes: 0, power_cycles: 0, abort_count: 0, format_count: 0, aer_held_cid: -1, aer_event: 0, fw_revision: 1, fw_dl_bytes: 0, media_errors: 0, unsafe_shutdowns: 0, error_count: 0, last_error: 0, fw_slot: 0, last_abort_sqid: -1, last_abort_cid: -1, pt: power_thermal_new(), wb: dram_write_buffer_new())

impl NvmeController:
    # ── Admin path ───────────────────────────────────────────────────────────
    me admin_submit(c: AdminCmd) -> bool:
        me.aq.submit(c)

    me admin_completions() -> i64:
        me.aq.cq_pending()

    me admin_reap() -> NvmeCpl:
        me.aq.cq_reap()

    me last_identify() -> IdentifyData:
        me.last_id

    me last_smart() -> SmartLog:
        me.smart

    # Service every queued admin command, posting a completion for each (except an
    # Async Event Request held outstanding). Returns the number of completions posted.
    me admin_process() -> i64:
        var n: i64 = 0
        var pend: i64 = me.aq.pending()
        while pend > 0:
            val cmd: AdminCmd = me.aq.fetch()
            val r: AdminResult = me.admin_exec(cmd)
            if r.post:
                me.aq.cq_post(cpl_make(cmd.cid, r.status, r.data))
                n = n + 1
            pend = me.aq.pending()
        n

    # Dispatch one admin command to its handler.
    me admin_exec(cmd: AdminCmd) -> AdminResult:
        if cmd.opcode == ADMIN_CREATE_CQ:
            return AdminResult(status: me.qset.create_cq(admin_qid(cmd.cdw10), admin_qsize(cmd.cdw10)), data: 0, post: true)
        if cmd.opcode == ADMIN_CREATE_SQ:
            return AdminResult(status: me.qset.create_sq(admin_qid(cmd.cdw10), admin_qsize(cmd.cdw10), admin_cqid(cmd.cdw11)), data: 0, post: true)
        if cmd.opcode == ADMIN_DELETE_SQ:
            return AdminResult(status: me.qset.delete_sq(admin_qid(cmd.cdw10)), data: 0, post: true)
        if cmd.opcode == ADMIN_DELETE_CQ:
            return AdminResult(status: me.qset.delete_cq(admin_qid(cmd.cdw10)), data: 0, post: true)
        if cmd.opcode == ADMIN_IDENTIFY:
            return AdminResult(status: me.do_identify(cmd), data: 0, post: true)
        if cmd.opcode == ADMIN_SET_FEATURES:
            me.features.set(admin_fid(cmd.cdw10), cmd.cdw11)
            return AdminResult(status: SC_SUCCESS, data: cmd.cdw11, post: true)
        if cmd.opcode == ADMIN_GET_FEATURES:
            return AdminResult(status: SC_SUCCESS, data: me.features.get(admin_fid(cmd.cdw10)), post: true)
        if cmd.opcode == ADMIN_GET_LOG:
            return me.do_get_log(cmd)
        if cmd.opcode == ADMIN_ABORT:
            me.abort_count = me.abort_count + 1
            # Decode and record the Abort target (SQID in cdw10 low 16, CID in high 16).
            me.last_abort_sqid = admin_qid(cmd.cdw10)
            me.last_abort_cid = admin_abort_cid(cmd.cdw10)
            # Synchronous controller: a submitted IO command completes inline within
            # io_process, so no host command is ever in flight when an Abort is serviced.
            # Per NVMe, completion dword0 bit0 = 1 means "command not aborted" (already done).
            return AdminResult(status: SC_SUCCESS, data: 1, post: true)
        if cmd.opcode == ADMIN_FORMAT_NVM:
            me.ftl.format()                    # erase user data; preserve bad-block table + wear
            me.format_count = me.format_count + 1
            return AdminResult(status: SC_SUCCESS, data: 0, post: true)
        if cmd.opcode == ADMIN_FW_DOWNLOAD:
            me.fw_dl_bytes = me.fw_dl_bytes + cmd.cdw10 * 4   # NUMD dwords accumulated
            return AdminResult(status: SC_SUCCESS, data: 0, post: true)
        if cmd.opcode == ADMIN_FW_COMMIT:
            val fw_slot: i64 = admin_fw_slot(cmd.cdw10)       # cdw10 bits 0..2
            val fw_action: i64 = admin_fw_action(cmd.cdw10)   # cdw10 bits 3..5
            if not admin_fw_slot_valid(fw_slot):
                return AdminResult(status: SC_INVALID_FIELD, data: 0, post: true)
            me.fw_slot = fw_slot
            # Commit action 0 = replace image only (no activation); actions 1..3 activate it,
            # so the running firmware revision advances. (The model collapses "activate on next
            # reset" to immediate, since it does not model a controller reset.)
            if fw_action != 0:
                me.fw_revision = me.fw_revision + 1
            me.fw_dl_bytes = 0
            return AdminResult(status: SC_SUCCESS, data: 0, post: true)
        if cmd.opcode == ADMIN_ASYNC_EVENT:
            return me.admin_async_event(cmd)
        AdminResult(status: SC_INVALID_OPCODE, data: 0, post: true)

    # Async Event Request: complete immediately if an event is already pending,
    # otherwise hold the request outstanding (no completion) until one is raised.
    me admin_async_event(cmd: AdminCmd) -> AdminResult:
        if me.aer_event != 0:
            val evt: i64 = me.aer_event
            me.aer_event = 0
            return AdminResult(status: SC_SUCCESS, data: evt, post: true)
        if me.aer_held_cid == -1:
            me.aer_held_cid = cmd.cid
            return AdminResult(status: SC_SUCCESS, data: 0, post: false)
        AdminResult(status: SC_INVALID_FIELD, data: 0, post: true)   # AER limit (1) exceeded

    # Raise an asynchronous event: complete a held AER now, or remember it for the
    # next AER the host posts.
    me raise_async_event(evt: i64):
        if me.aer_held_cid != -1:
            me.aq.cq_post(cpl_make(me.aer_held_cid, SC_SUCCESS, evt))
            me.aer_held_cid = -1
        else:
            me.aer_event = evt

    me aer_outstanding() -> i64:
        var n: i64 = 0
        if me.aer_held_cid != -1:
            n = 1
        n

    me firmware_revision() -> i64:
        me.fw_revision

    # Firmware slot recorded by the most recent successful Commit (0 = none yet).
    me committed_fw_slot() -> i64:
        me.fw_slot

    # Target SQID / CID decoded from the most recent Abort (-1 = none seen).
    me aborted_sqid() -> i64:
        me.last_abort_sqid

    me aborted_cid() -> i64:
        me.last_abort_cid

    me format_passes() -> i64:
        me.format_count

    me do_identify(cmd: AdminCmd) -> i64:
        val cns: i64 = admin_cns(cmd.cdw10)
        if cns == CNS_CONTROLLER:
            me.last_id = build_identify_controller()
            return SC_SUCCESS
        if cns == CNS_NAMESPACE:
            var nsid: i64 = cmd.nsid
            if nsid == 0:
                nsid = 1
            me.last_id = build_identify_namespace(nsid)
            return SC_SUCCESS
        SC_INVALID_FIELD

    me do_get_log(cmd: AdminCmd) -> AdminResult:
        val logid: i64 = admin_logid(cmd.cdw10)
        if logid == LOG_SMART:
            val pu: i64 = smart_percent_used(me.ftl.max_erase())
            val spare: i64 = smart_avail_spare(me.ftl.bad_blocks())
            val tk: i64 = me.pt.temperature_k()      # live composite temperature, driven by IO load
            val tc: i64 = me.pt.critical_warning()   # thermal critical-warning bit
            me.smart = build_smart_log(me.reads, me.writes, me.power_cycles, me.unsafe_shutdowns, me.media_errors, pu, spare, tk, tc)
            # Host reads the full SMART page via last_smart(); the completion carries the
            # critical-warning bit so a host that only polls completions still sees health.
            return AdminResult(status: SC_SUCCESS, data: me.smart.crit_warning, post: true)
        if logid == LOG_ERROR:
            # Error Information log: the completion reports the number of error-log entries
            # the host would retrieve (this model's width-1 log-page datum).
            return AdminResult(status: SC_SUCCESS, data: me.error_count, post: true)
        if logid == LOG_FW_SLOT:
            # Firmware Slot Information log: the completion reports the active firmware revision.
            return AdminResult(status: SC_SUCCESS, data: me.fw_revision, post: true)
        AdminResult(status: SC_INVALID_FIELD, data: 0, post: true)

    # Error-log introspection (the Get Log Page ERROR data the host would read).
    me error_log_count() -> i64:
        me.error_count

    me last_error_status() -> i64:
        me.last_error

    # ── IO path (multi-queue) ────────────────────────────────────────────────
    me io_submit(qid: i64, c: NvmeCmd) -> bool:
        me.qset.sq_submit(qid, c)

    me io_completions(qid: i64) -> i64:
        me.qset.cq_pending(qid)

    me io_reap(qid: i64) -> NvmeCpl:
        me.qset.cq_reap(qid)

    # Run one command end-to-end through the translation/flash stack.
    me process_one_io(cmd: NvmeCmd) -> NvmeCpl:
        var status: i64 = cmd_validate(cmd)
        var rdata: i64 = 0
        if status == SC_SUCCESS:
            if cmd_is_write(cmd):
                val h: Handle = me.pool.acquire(cmd.cid, cmd.lba, cmd.nblocks, cmd.data)
                me.pool.set_phase(h, PH_PROGRAM)
                var i: i64 = 0
                me.wb.clear()
                while i < cmd.nblocks and status == SC_SUCCESS:
                    status = me.wb.stage(i, prp_byte(cmd, i))
                    i = i + 1
                i = 0
                while i < cmd.nblocks and status == SC_SUCCESS:
                    status = me.ftl.write(cmd.lba + i, me.wb.byte(i))
                    i = i + 1
                me.pool.set_status(h, status)
                me.pool.set_phase(h, PH_DONE)
                me.pool.release(h)
                me.writes = me.writes + 1
                me.pt.tick(2)   # a program burns more energy than a read
            else:
                if cmd_is_read(cmd):
                    rdata = me.ftl.read(cmd.lba)
                    status = me.ftl.read_status(cmd.lba)
                    me.reads = me.reads + 1
                    me.pt.tick(1)
                else:
                    if cmd_is_trim(cmd):
                        status = me.ftl.trim(cmd.lba)
                    else:
                        if cmd_is_flush(cmd):
                            me.ftl.checkpoint()
                            status = SC_SUCCESS
                        else:
                            status = SC_INVALID_OPCODE
        # Health telemetry: record uncorrectable reads and the error log.
        if status != SC_SUCCESS:
            me.error_count = me.error_count + 1
            me.last_error = status
            if status == SC_MEDIA_ERR:
                me.media_errors = me.media_errors + 1
        cpl_make(cmd.cid, status, rdata)

    # Round-robin across all active IO submission queues; post each completion
    # to that SQ's bound completion queue. Bounded -> always terminates.
    me io_process() -> i64:
        var n: i64 = 0
        var guard: i64 = 0
        val limit: i64 = MAX_IO_QUEUES * MAX_QUEUE_SIZE
        var qid: i64 = me.qset.next_pending_sq()
        while qid >= 1 and guard < limit:
            val cmd: NvmeCmd = me.qset.sq_fetch(qid)
            val cpl: NvmeCpl = me.process_one_io(cmd)
            me.qset.cq_post(me.qset.sq_bound_cq(qid), cpl)
            n = n + 1
            guard = guard + 1
            qid = me.qset.next_pending_sq()
        n

    # ── Maintenance / durability passthrough ─────────────────────────────────
    me gc() -> i64:
        me.ftl.gc_once()

    me free_blocks() -> i64:
        me.ftl.free_blocks()

    me checkpoint():
        me.ftl.checkpoint()

    # Physical page backing a logical block (introspection / test hook).
    me physical_ppn(lba: i64) -> i64:
        me.ftl.physical_ppn(lba)

    # test hook: inject NAND read bit-errors at a physical page.
    me inject_read_bitflip(ppn: i64, n: i64):
        me.ftl.inject_read_bitflip(ppn, n)

    me power_cycle():
        # A power cycle is a dirty (unsafe) shutdown: the controller did not flush a
        # clean checkpoint before losing power.
        me.ftl.crash()
        me.ftl.recover()
        me.power_cycles = me.power_cycles + 1
        me.unsafe_shutdowns = me.unsafe_shutdowns + 1

# ── Self-test (compact; full admin-driven e2e lives in nvme_main.spl) ─────────
fn nvme_controller_selftest() -> i64:
    var fail: i64 = 0
    var c: NvmeController = nvme_controller_new()

    # Identify the controller via the admin queue
    c.admin_submit(admin_identify_cmd(1, CNS_CONTROLLER))
    c.admin_process()
    val ic: NvmeCpl = c.admin_reap()
    fail = fail + expect_eq(ic.status, SC_SUCCESS, "identify controller ok")
    val id: IdentifyData = c.last_identify()
    fail = fail + expect_eq(id.max_queues, MAX_IO_QUEUES, "identify reports max IO queues")

    # Bring up one IO queue pair (CQ then SQ) via admin
    c.admin_submit(admin_create_cq_cmd(2, 1, 64))
    c.admin_submit(admin_create_sq_cmd(3, 1, 64, 1))
    c.admin_process()
    val cc: NvmeCpl = c.admin_reap()
    val cs: NvmeCpl = c.admin_reap()
    fail = fail + expect_eq(cc.status, SC_SUCCESS, "create IO CQ 1 ok")
    fail = fail + expect_eq(cs.status, SC_SUCCESS, "create IO SQ 1 ok")

    # Write then read on the new IO queue
    c.io_submit(1, cmd_make(100, OP_WRITE, 9, 1, 0x55))
    c.io_process()
    val w: NvmeCpl = c.io_reap(1)
    fail = fail + expect_eq(w.status, SC_SUCCESS, "IO write completed")
    c.io_submit(1, cmd_make(101, OP_READ, 9, 1, 0))
    c.io_process()
    val r: NvmeCpl = c.io_reap(1)
    fail = fail + expect_eq(r.data, 0x55, "IO read returns written byte")

    c.io_submit(1, cmd_make(102, OP_WRITE, 20, 3, prp_pack(0x60, 0xA0)))
    c.io_process()
    val wm: NvmeCpl = c.io_reap(1)
    fail = fail + expect_eq(wm.status, SC_SUCCESS, "multi-block IO write completed")
    c.io_submit(1, cmd_make(103, OP_READ, 20, 1, 0))
    c.io_submit(1, cmd_make(104, OP_READ, 21, 1, 0))
    c.io_submit(1, cmd_make(105, OP_READ, 22, 1, 0))
    c.io_process()
    val r0: NvmeCpl = c.io_reap(1)
    val r1: NvmeCpl = c.io_reap(1)
    val r2: NvmeCpl = c.io_reap(1)
    fail = fail + expect_eq(r0.data, 0x60, "multi-block IO read byte 0")
    fail = fail + expect_eq(r1.data, 0x61, "multi-block IO read byte 1")
    fail = fail + expect_eq(r2.data, 0xA0, "multi-block IO read byte 2")

    c.io_submit(1, cmd_make(106, OP_WRITE, 30, WRITE_BUFFER_CAP_BLOCKS + 1, 0x70))
    c.io_process()
    val wob: NvmeCpl = c.io_reap(1)
    fail = fail + expect_eq(wob.status, SC_NS_NOT_READY, "oversized IO write buffer command rejected")
    c.io_submit(1, cmd_make(107, OP_READ, 30, 1, 0))
    c.io_process()
    val rob: NvmeCpl = c.io_reap(1)
    fail = fail + expect_eq(rob.data, 0, "oversized IO write leaves first LBA untouched")

    # Get/Set Features through the admin path
    c.admin_submit(admin_set_feature_cmd(4, FEAT_TEMP_THRESH, 345))
    c.admin_submit(admin_get_feature_cmd(5, FEAT_TEMP_THRESH))
    c.admin_process()
    val sf: NvmeCpl = c.admin_reap()
    val gf: NvmeCpl = c.admin_reap()
    fail = fail + expect_eq(sf.status, SC_SUCCESS, "set feature ok")
    fail = fail + expect_eq(gf.data, 345, "get feature returns the set value")

    # Abort (best-effort): completes; the synchronous target is already done.
    c.admin_submit(admin_abort_cmd(30, 1, 100))
    c.admin_process()
    val ab: NvmeCpl = c.admin_reap()
    fail = fail + expect_eq(ab.status, SC_SUCCESS, "abort completes SC_SUCCESS")
    fail = fail + expect_eq(ab.data, 1, "abort reports target not in flight")
    fail = fail + expect_eq(c.aborted_sqid(), 1, "abort decoded the target SQID from cdw10")
    fail = fail + expect_eq(c.aborted_cid(), 100, "abort decoded the target CID from cdw10")

    # Async Event Request: held outstanding (no completion) until an event is raised.
    c.admin_submit(admin_async_event_cmd(31))
    c.admin_process()
    fail = fail + expect_eq(c.admin_completions(), 0, "AER held: no completion yet")
    fail = fail + expect_eq(c.aer_outstanding(), 1, "AER outstanding == 1")
    c.raise_async_event(AER_SMART_HEALTH)
    fail = fail + expect_eq(c.admin_completions(), 1, "AER completes after event raised")
    val aer: NvmeCpl = c.admin_reap()
    fail = fail + expect_eq(aer.data, AER_SMART_HEALTH, "AER reports the event type")

    # Firmware Download + Commit advances the active firmware revision.
    val rev0: i64 = c.firmware_revision()
    c.admin_submit(admin_fw_download_cmd(32, 1024, 0))
    c.admin_submit(admin_fw_commit_cmd(33, 1, 1))
    c.admin_process()
    val fd: NvmeCpl = c.admin_reap()
    val fc2: NvmeCpl = c.admin_reap()
    fail = fail + expect_eq(fd.status, SC_SUCCESS, "fw download accepted")
    fail = fail + expect_eq(fc2.status, SC_SUCCESS, "fw commit accepted")
    fail = fail + expect_eq(c.firmware_revision(), rev0 + 1, "fw commit advances revision")
    fail = fail + expect_eq(c.committed_fw_slot(), 1, "fw commit recorded the target slot")
    # Commit action 0 = replace-only: the slot is recorded but the running revision does NOT advance.
    val rev1: i64 = c.firmware_revision()
    c.admin_submit(admin_fw_commit_cmd(35, 2, 0))
    c.admin_process()
    val fc3: NvmeCpl = c.admin_reap()
    fail = fail + expect_eq(fc3.status, SC_SUCCESS, "fw commit (replace-only) accepted")
    fail = fail + expect_eq(c.committed_fw_slot(), 2, "replace-only commit still records the slot")
    fail = fail + expect_eq(c.firmware_revision(), rev1, "replace-only commit does NOT advance the revision")
    # An invalid firmware slot is rejected (slot 0 is reserved).
    c.admin_submit(admin_fw_commit_cmd(36, 0, 1))
    c.admin_process()
    val fc4: NvmeCpl = c.admin_reap()
    fail = fail + expect_eq(fc4.status, SC_INVALID_FIELD, "fw commit with invalid slot 0 is rejected")

    # Format NVM erases user data: write, format, then the LBA reads back 0.
    c.io_submit(1, cmd_make(110, OP_WRITE, 5, 1, 0xEE))
    c.io_process()
    c.io_reap(1)
    c.admin_submit(admin_format_cmd(34, 1))
    c.admin_process()
    val fmt: NvmeCpl = c.admin_reap()
    fail = fail + expect_eq(fmt.status, SC_SUCCESS, "format completes")
    c.io_submit(1, cmd_make(111, OP_READ, 5, 1, 0))
    c.io_process()
    val rr: NvmeCpl = c.io_reap(1)
    fail = fail + expect_eq(rr.data, 0, "format erased user data (read -> 0)")

    # SMART: an uncorrectable read is counted in media_errors and raises crit_warning.
    c.io_submit(1, cmd_make(120, OP_WRITE, 8, 1, 0xDD))
    c.io_process()
    c.io_reap(1)
    val pp: i64 = c.physical_ppn(8)
    c.inject_read_bitflip(pp, 2)                 # 2 flips -> uncorrectable
    c.io_submit(1, cmd_make(121, OP_READ, 8, 1, 0))
    c.io_process()
    val mederr: NvmeCpl = c.io_reap(1)
    fail = fail + expect_eq(mederr.status, SC_MEDIA_ERR, "uncorrectable read -> SC_MEDIA_ERR")
    c.admin_submit(admin_get_log_cmd(40, LOG_SMART))
    c.admin_process()
    c.admin_reap()
    val sm: SmartLog = c.last_smart()
    fail = fail + expect_eq(sm.media_errors, 1, "SMART media_errors counts the uncorrectable read")
    fail = fail + expect_eq(sm.crit_warning, 1, "SMART critical warning set on media error")
    var duw_ok: i64 = 0
    if sm.data_units_written > 0:
        duw_ok = 1
    fail = fail + expect_eq(duw_ok, 1, "SMART data units written reflects activity")

    # P7 wiring proof: the SMART composite temperature is produced by the live thermal
    # model that the IO path heats — not a hardcoded constant. A sustained write burst
    # raises it above the idle baseline, and SMART reports exactly the model's value.
    var hb: i64 = 0
    while hb < 40:
        c.io_submit(1, cmd_make(130, OP_WRITE, 9, 1, 0xAB))
        c.io_process()
        c.io_reap(1)
        hb = hb + 1
    c.admin_submit(admin_get_log_cmd(42, LOG_SMART))
    c.admin_process()
    c.admin_reap()
    val sm_hot: SmartLog = c.last_smart()
    val t_live: i64 = c.pt.temperature_k()
    fail = fail + expect_eq(sm_hot.temperature, t_live, "SMART temperature reads the live thermal model")
    var heated: i64 = 0
    if sm_hot.temperature > THERMAL_BASE_K:
        heated = 1
    fail = fail + expect_eq(heated, 1, "sustained IO load heats the device above the idle baseline")

    # Error log records a failed IO command (status + count).
    val ec0: i64 = c.error_log_count()
    c.io_submit(1, cmd_make(122, OP_WRITE, LBA_COUNT + 1, 1, 0))
    c.io_process()
    c.io_reap(1)
    fail = fail + expect_eq(c.error_log_count(), ec0 + 1, "error log counts the failed write")
    fail = fail + expect_eq(c.last_error_status(), SC_LBA_RANGE, "error log records the last status")

    # Get Log Page (ERROR) reports the error-entry count; (FW_SLOT) reports the active fw revision.
    c.admin_submit(admin_get_log_cmd(43, LOG_ERROR))
    c.admin_process()
    val gle: NvmeCpl = c.admin_reap()
    fail = fail + expect_eq(gle.data, c.error_log_count(), "get-log ERROR returns the error entry count")
    c.admin_submit(admin_get_log_cmd(44, LOG_FW_SLOT))
    c.admin_process()
    val glf: NvmeCpl = c.admin_reap()
    fail = fail + expect_eq(glf.data, c.firmware_revision(), "get-log FW_SLOT returns the active fw revision")

    # SMART: a power cycle is recorded as an unsafe shutdown.
    c.power_cycle()
    c.admin_submit(admin_get_log_cmd(41, LOG_SMART))
    c.admin_process()
    c.admin_reap()
    fail = fail + expect_eq(c.last_smart().unsafe_shutdowns, 1, "power cycle counted as unsafe shutdown")

    fail
