"""
Combined self-test for all NVMe firmware leaf modules (HIL/FTL/FIL).
Run: bin/simple run examples/09_embedded/simpleos_nvme_fw/fw/test_leaves.spl
Gate: prints "ALL LEAVES OK" and exits 0 when every module self-test passes.
"""

use nvme_types.*
use fil_ecc.*
use fil_badblock.*
use fil_nand.*
use ftl_map.*
use ftl_band.*
use ftl_journal.*
use hil_queue.*
use hil_command.*
use fw_pool.*

fn main():
    var f: i64 = 0
    print "-- FIL --"
    f = f + ecc_selftest()
    f = f + bbt_selftest()
    f = f + nand_selftest()
    print "-- FTL --"
    f = f + ftl_map_selftest()
    f = f + ftl_band_selftest()
    f = f + ftl_journal_selftest()
    print "-- HIL + core --"
    f = f + hil_queue_selftest()
    f = f + hil_command_selftest()
    f = f + fw_pool_selftest()
    print ""
    if f == 0:
        print "ALL LEAVES OK"
    else:
        print "LEAVES FAIL ({f})"
