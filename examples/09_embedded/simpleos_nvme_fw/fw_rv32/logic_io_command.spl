fn _rv32_io_known_opcode(op: i64) -> i32:
    if op == 0:
        return 0
    if op == 1:
        return 0
    if op == 2:
        return 0
    if op == 8:
        return 0
    if op == 9:
        return 0
    1

fn _rv32_io_command_valid(cid: i64, op: i64, lba: i64, nblocks: i64, data: i64) -> i32:
    if cid < 0:
        return 1
    if cid > 65535:
        return 1
    if _rv32_io_known_opcode(op) != 0:
        return 1
    if op == 0:
        if lba != 0:
            return 1
        if nblocks != 0:
            return 1
        if data != 0:
            return 1
        return 0
    if lba < 0:
        return 1
    if nblocks <= 0:
        return 1
    if lba >= 3072:
        return 1
    if nblocks > 3072:
        return 1
    if lba > 3072 - nblocks:
        return 1
    if op == 9 and data != 0:
        return 1
    if op == 8 and data != 0:
        return 1
    if op == 2 and data != 0:
        return 1
    0

fn rv32_io_command_selftest() -> i32:
    if _rv32_io_command_valid(1, 1, 0, 1, 7) != 0:
        return 1
    if _rv32_io_command_valid(2, 2, 0, 1, 0) != 0:
        return 1
    if _rv32_io_command_valid(3, 0, 0, 0, 0) != 0:
        return 1
    if _rv32_io_command_valid(4, 8, 3071, 1, 0) != 0:
        return 1
    if _rv32_io_command_valid(5, 9, 10, 1, 0) != 0:
        return 1
    if _rv32_io_command_valid(65536, 1, 0, 1, 0) == 0:
        return 1
    if _rv32_io_command_valid(6, 127, 0, 1, 0) == 0:
        return 1
    if _rv32_io_command_valid(7, 1, -1, 1, 0) == 0:
        return 1
    if _rv32_io_command_valid(8, 1, 3072, 1, 0) == 0:
        return 1
    if _rv32_io_command_valid(9, 1, 3070, 3, 0) == 0:
        return 1
    if _rv32_io_command_valid(10, 1, 0, 0, 0) == 0:
        return 1
    if _rv32_io_command_valid(11, 0, 1, 0, 0) == 0:
        return 1
    if _rv32_io_command_valid(12, 2, 1, 1, 1) == 0:
        return 1
    if _rv32_io_command_valid(13, 8, 1, 1, 1) == 0:
        return 1
    if _rv32_io_command_valid(14, 9, 1, 1, 1) == 0:
        return 1
    0
