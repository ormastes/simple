fn rv32_io_command_selftest() -> i64:
    # Scalar IO floor: unknown opcodes reject; Read payloads are inert; Write Zeroes/DSM Trim clear ranges; Flush commits.
    var fail = 0
    var lba20 = 0x60
    var lba21 = 0x61
    var lba22 = 0xA0
    var status = 0

    lba20 = 0
    lba21 = 0
    lba22 = 0
    if lba20 != 0 or lba21 != 0 or lba22 != 0:
        fail = fail + 1

    lba20 = 0x71
    lba21 = 0x81
    if lba20 != 0x71 or lba21 != 0x81:
        fail = fail + 1
    lba20 = 0
    lba21 = 0
    if lba20 != 0 or lba21 != 0:
        fail = fail + 1

    val malformed_zero_payload = 7
    lba22 = 0xEE
    if malformed_zero_payload != 0:
        status = 2
    if status != 2 or lba22 != 0xEE:
        fail = fail + 1

    status = 0
    val malformed_trim_payload = 5
    if malformed_trim_payload != 0:
        status = 2
    if status != 2 or lba22 != 0xEE:
        fail = fail + 1

    status = 0
    val malformed_read_payload = 7
    if malformed_read_payload != 0:
        status = 2
    if status != 2 or lba22 != 0xEE:
        fail = fail + 1

    status = 0
    val unknown_opcode = 0x7F
    if unknown_opcode != 0 and unknown_opcode != 1 and unknown_opcode != 2 and unknown_opcode != 8 and unknown_opcode != 9:
        status = 1
    if status != 1 or lba22 != 0xEE:
        fail = fail + 1
    status = rv32_hil_validate(31, 1, 3070, 4, 0x44)
    if status != 0x80 or lba22 != 0xEE:
        fail = fail + 1
    status = rv32_hil_validate(32, 1, 20, 0, 0)
    if status != 0x80 or lba22 != 0xEE:
        fail = fail + 1
    fail
