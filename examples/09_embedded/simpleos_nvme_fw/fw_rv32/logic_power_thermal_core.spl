fn _rv32_pt_power_state_valid(ps: i64) -> i32:
    if ps < 0:
        return 1
    if ps >= 5:
        return 1
    0

fn _rv32_pt_temperature_threshold_valid(kelvin: i64) -> i32:
    if kelvin <= 313:
        return 1
    0

fn _rv32_pt_next_temp(temp_k: i64, power_state: i64, ops: i64) -> i64:
    var safe_temp: i64 = temp_k
    if safe_temp < 313:
        safe_temp = 313
    var safe_ps: i64 = power_state
    if safe_ps < 0:
        safe_ps = 0
    if safe_ps >= 5:
        safe_ps = 4
    var safe_ops: i64 = ops
    if safe_ops < 0:
        safe_ops = 0
    if safe_ops > 200000000000000000:
        safe_ops = 200000000000000000
    val heat: i64 = safe_ops * (5 - safe_ps) / 3
    var next: i64 = safe_temp + heat
    val excess: i64 = next - 313
    if excess > 0:
        next = next - (excess / 4 + 1)
    if next < 313:
        return 313
    next

fn _rv32_pt_throttled(temp_k: i64) -> i32:
    if temp_k >= 353:
        return 1
    0

fn _rv32_pt_critical_warning(temp_k: i64, crit_k: i64) -> i32:
    var safe_temp: i64 = temp_k
    if safe_temp < 313:
        safe_temp = 313
    var safe_crit: i64 = crit_k
    if safe_crit <= 313:
        safe_crit = 363
    if safe_temp >= safe_crit:
        return 1
    0
