fn _rv32_policy_hook_allowed(kind: i64) -> i32:
    if kind == 0:
        return 1
    if kind == 1:
        return 1
    if kind == 2:
        return 1
    if kind == 3:
        return 1
    0

fn _rv32_policy_rejected_after(kind: i64, rejected: i64) -> i64:
    if rejected > 1000000000000000000:
        return 1000000000000000000
    if _rv32_policy_hook_allowed(kind) == 1:
        if rejected < 0:
            return 0
        return rejected
    if rejected < 0:
        return 1
    if rejected >= 1000000000000000000:
        return 1000000000000000000
    rejected + 1

fn _rv32_policy_clamp_priority(priority: i64) -> i64:
    if priority < 0:
        return 0
    if priority > 3:
        return 3
    priority

fn _rv32_policy_clamp_bool(value: i64) -> i64:
    if value <= 0:
        return 0
    1

fn _rv32_policy_gc_score(valid_pages: i64, custom_score: i64, fuel_used: i64, fuel_budget: i64) -> i64:
    if fuel_used > fuel_budget:
        return valid_pages
    custom_score

fn _rv32_policy_gc_victim(score0: i64, score1: i64, closed0: i32, closed1: i32) -> i64:
    if closed0 == 0 and closed1 == 0:
        return -1
    if closed0 != 0 and closed1 == 0:
        return 0
    if closed0 == 0 and closed1 != 0:
        return 1
    if score1 < score0:
        return 1
    0

fn _rv32_target_channels(target_id: i64) -> i64:
    if target_id == 1:
        return 2
    if target_id == 2:
        return 8
    8

fn _rv32_target_ways(target_id: i64) -> i64:
    if target_id == 1:
        return 8
    if target_id == 2:
        return 8
    1

fn _rv32_target_hardware(target_id: i64) -> i32:
    if target_id == 1:
        return 1
    if target_id == 2:
        return 1
    0

fn _rv32_target_blocks_per_slice(target_id: i64) -> i64:
    if target_id == 1:
        return 4
    if target_id == 2:
        return 4
    1

fn _rv32_target_pcie_vendor_id(target_id: i64) -> i64:
    if target_id == 1:
        return 0x10EE
    if target_id == 2:
        return 0x10EE
    0x1B36
