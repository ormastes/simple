fn rv32_admin_smart_nonnegative(v: i64) -> i32:
    if v < 0:
        return 1
    0

fn _rv32_admin_smart_temperature_valid(kelvin: i64) -> i32:
    if kelvin < 0:
        return 1
    0

fn _rv32_admin_log_id_valid(log_id: i64) -> i32:
    if log_id == 1:
        return 0
    if log_id == 2:
        return 0
    if log_id == 3:
        return 0
    1

fn _rv32_admin_feature_id_valid(fid: i64) -> i32:
    if fid == 2:
        return 0
    if fid == 4:
        return 0
    if fid == 6:
        return 0
    if fid == 7:
        return 0
    1

fn _rv32_admin_fw_commit_valid(slot: i64, action: i64, downloaded_bytes: i64) -> i32:
    if slot < 1:
        return 1
    if slot > 3:
        return 1
    if action < 0:
        return 1
    if action > 3:
        return 1
    if downloaded_bytes <= 0:
        return 1
    0

fn _rv32_admin_fw_revision_after(current: i64, action: i64, commit_status: i32) -> i64:
    var rev: i64 = current
    if rev < 1:
        rev = 1
    if rev > 1000000000000000000:
        rev = 1000000000000000000
    if commit_status != 0:
        return rev
    if action == 0:
        return rev
    if rev >= 1000000000000000000:
        return 1000000000000000000
    rev + 1
