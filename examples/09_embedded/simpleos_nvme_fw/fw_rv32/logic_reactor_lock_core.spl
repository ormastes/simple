fn _rv32_reactor_sanitize_owner_impl(owner: i64) -> i64:
    if owner < 0:
        return 0
    if owner > 2:
        return 0
    owner

fn _rv32_reactor_counter_next_impl(value: i64) -> i64:
    if value < 0:
        return 1
    if value >= 1000000000000000000:
        return 1000000000000000000
    value + 1

fn _rv32_reactor_acquire_impl(owner: i64, requested: i64) -> i32:
    val safe_owner: i64 = _rv32_reactor_sanitize_owner_impl(owner)
    if requested <= 0:
        return 0
    if requested > 2:
        return 0
    if safe_owner == 0:
        return 1
    0

fn _rv32_reactor_conflicts_after_impl(owner: i64, requested: i64, conflicts: i64) -> i64:
    if _rv32_reactor_acquire_impl(owner, requested) == 0:
        if requested > 0 and requested <= 2:
            return _rv32_reactor_counter_next_impl(conflicts)
    if conflicts < 0:
        return 0
    if conflicts > 1000000000000000000:
        return 1000000000000000000
    conflicts

fn _rv32_reactor_release_impl(owner: i64, released: i64) -> i64:
    if owner == released:
        return 0
    _rv32_reactor_sanitize_owner_impl(owner)
