fn rv32_map_selftest() -> i32:
    val dirty_cache_hit = 100i32
    val flushed_l2p = dirty_cache_hit
    val post_crash_l2p = flushed_l2p
    val evicted_l2p = 200i32
    val replacement_ppn = 204i32
    val invalid_ppn_sanitized = 0i32
    val invalid_lba_inert = 0i32
    (dirty_cache_hit ^ 100i32) + (flushed_l2p ^ 100i32) + (post_crash_l2p ^ 100i32) + (evicted_l2p ^ 200i32) + (replacement_ppn ^ 204i32) + (invalid_ppn_sanitized ^ 0i32) + (invalid_lba_inert ^ 0i32)
