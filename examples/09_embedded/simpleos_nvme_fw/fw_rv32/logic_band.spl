fn rv32_band_selftest() -> i32:
    val first_ppn = 0i32
    val next_band_ppn = 4i32
    val valid_idempotent = 1i32
    val invalid_counter_floor = 0i32
    val freed_active = 0i32
    val bad_block_preserved = 3i32
    (first_ppn ^ 0i32) + (next_band_ppn ^ 4i32) + (valid_idempotent ^ 1i32) + (invalid_counter_floor ^ 0i32) + (freed_active ^ 0i32) + (bad_block_preserved ^ 3i32)
