fn rv32_queue_phase_selftest() -> i32:
    val slot_zero = 0i32
    val max_doorbell = 3i32
    val sq_full_tail = 0i32
    val sq_empty_head = sq_full_tail
    val cq_wrap_tail = 0i32
    val cq_phase_after_wrap = 0i32
    val host_seen_phase = cq_phase_after_wrap
    val second_wrap_phase = 1i32
    (slot_zero ^ 0i32) + (max_doorbell ^ 3i32) + (sq_full_tail ^ 0i32) + (sq_empty_head ^ 0i32) + (cq_wrap_tail ^ 0i32) + (cq_phase_after_wrap ^ 0i32) + (host_seen_phase ^ 0i32) + (second_wrap_phase ^ 1i32)
