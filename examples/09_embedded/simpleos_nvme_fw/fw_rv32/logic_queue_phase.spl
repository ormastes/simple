fn _rv32_queue_len_pending(length: i64, depth: i64) -> i64:
    if length < 0:
        return 0
    if length > depth:
        return depth
    length

fn _rv32_queue_submit_valid(cid: i64, length: i64, tail: i64, depth: i64) -> i32:
    if cid < 0:
        return 1
    if cid > 65535:
        return 1
    if length < 0:
        return 1
    if length >= depth:
        return 1
    if tail < 0:
        return 1
    if tail >= depth:
        return 1
    0

fn _rv32_queue_fetch_valid(length: i64, head: i64, depth: i64) -> i32:
    if length <= 0:
        return 1
    if head < 0:
        return 1
    if head >= depth:
        return 1
    0

fn _rv32_queue_next(index: i64, depth: i64) -> i64:
    (index + 1) % depth

fn rv32_queue_phase_selftest() -> i32:
    if _rv32_queue_len_pending(0, 64) != 0:
        return 1
    if _rv32_queue_len_pending(65, 64) != 64:
        return 1
    if _rv32_queue_len_pending(-1, 64) != 0:
        return 1
    if _rv32_queue_submit_valid(1, 0, 0, 64) != 0:
        return 1
    if _rv32_queue_submit_valid(65535, 63, 63, 64) != 0:
        return 1
    if _rv32_queue_submit_valid(65536, 0, 0, 64) == 0:
        return 1
    if _rv32_queue_submit_valid(-1, 0, 0, 64) == 0:
        return 1
    if _rv32_queue_submit_valid(1, -1, 0, 64) == 0:
        return 1
    if _rv32_queue_submit_valid(1, 64, 0, 64) == 0:
        return 1
    if _rv32_queue_submit_valid(1, 0, 64, 64) == 0:
        return 1
    if _rv32_queue_fetch_valid(1, 0, 64) != 0:
        return 1
    if _rv32_queue_fetch_valid(0, 0, 64) == 0:
        return 1
    if _rv32_queue_fetch_valid(1, -1, 64) == 0:
        return 1
    if _rv32_queue_fetch_valid(1, 64, 64) == 0:
        return 1
    if _rv32_queue_next(63, 64) != 0:
        return 1
    if _rv32_queue_next(2, 64) != 3:
        return 1
    0
