fn _rv32_wear_counter_clamped(value: i64) -> i64:
    if value < 0:
        return 0
    value

fn _rv32_scrub_needed(valid_pages: i64, read_disturb: i64) -> i32:
    if valid_pages <= 0:
        return 0
    if read_disturb > 50:
        return 1
    0

fn _rv32_wear_level_needed(max_erase: i64, cold_erase: i64) -> i32:
    val safe_max: i64 = _rv32_wear_counter_clamped(max_erase)
    val safe_cold: i64 = _rv32_wear_counter_clamped(cold_erase)
    if safe_max - safe_cold > 2:
        return 1
    0

fn _rv32_wear_percent_used(max_erase: i64) -> i64:
    val safe_max: i64 = _rv32_wear_counter_clamped(max_erase)
    var pct: i64 = safe_max
    if pct > 100:
        return 100
    pct

fn _rv32_scrub_result_block(block: i64, valid_pages: i64, read_disturb: i64) -> i64:
    if block < 0:
        return -1
    if block >= 64:
        return -1
    if _rv32_scrub_needed(valid_pages, read_disturb) != 1:
        return -1
    block
