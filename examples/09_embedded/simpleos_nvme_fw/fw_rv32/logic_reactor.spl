fn rv32_reactor_selftest() -> i32:
    val handle0_index = 0i32
    val handle1_index = 1i32
    val recycled_generation = 1i32
    val stale_handle_rejected = 0i32
    val owner_conflict = 1i32
    val foreground_completions = 2i32
    val background_ticks = 1i32
    val free_blocks = 4i32
    (handle0_index ^ 0i32) + (handle1_index ^ 1i32) + (recycled_generation ^ 1i32) + (stale_handle_rejected ^ 0i32) + (owner_conflict ^ 1i32) + (foreground_completions ^ 2i32) + (background_ticks ^ 1i32) + (free_blocks ^ 4i32)
