fn rv32_reactor_owner_valid(owner: i64) -> i64:
    if owner < 0 or owner > 2:
        return 0
    owner

fn rv32_pool_live(live: i64, used0: i64, used1: i64, cap: i64) -> i64:
    if live < 0:
        return 0
    var n = 0
    if cap > 0 and used0 == 1:
        n = n + 1
    if cap > 1 and used1 == 1:
        n = n + 1
    if live < n:
        return live
    n

fn rv32_reactor_selftest() -> i64:
    # Two scalar task slots prove generation handles and cooperative owner tokens.
    var fail = 0
    var gen0 = 0
    var gen1 = 0
    var used0 = 0
    var used1 = 0
    var live = 0
    var h0_index = -1
    var h0_gen = -1
    var h1_index = -1
    var h1_gen = -1
    var phase0 = 0
    var phase1 = 0
    var old0 = -1
    var new0 = -1
    var seq0 = 0

    if rv32_pool_live(-4, used0, used1, 2) != 0:
        fail = fail + 1
    used0 = 1
    live = 1
    h0_index = 0
    h0_gen = gen0
    phase0 = 0
    if h0_index != 0 or h0_gen != 0 or phase0 != 0 or rv32_pool_live(live, used0, used1, 2) != 1:
        fail = fail + 1
    phase0 = 1
    if phase0 != 1:
        fail = fail + 1
    phase0 = 2
    old0 = 7
    new0 = 8
    seq0 = 9
    if phase0 != 2 or old0 != 7 or new0 != 8 or seq0 != 9:
        fail = fail + 1
    used1 = 1
    live = 2
    h1_index = 1
    h1_gen = gen1
    phase1 = 0
    if h1_index == h0_index or h1_gen != 0 or phase1 != 0 or rv32_pool_live(live, used0, used1, 2) != 2:
        fail = fail + 1
    used1 = 7
    if rv32_pool_live(live, used0, used1, 2) != 1:
        fail = fail + 1
    used1 = 1
    used0 = 0
    gen0 = gen0 + 1
    live = live - 1
    if used0 != 0 or gen0 == h0_gen or rv32_pool_live(live, used0, used1, 2) != 1:
        fail = fail + 1
    if used0 == 1 and gen0 == h0_gen:
        fail = fail + 1
    used0 = 1
    h0_gen = gen0
    live = live + 1
    if live != 2:
        fail = fail + 1
    if live >= 2:
        val invalid_index = -1
        if invalid_index != -1:
            fail = fail + 1

    var owner = 0
    var conflicts = 0
    var fg_ticks = 0
    var bg_ticks = 0
    var pending = 2
    var completions = 0
    owner = 2
    if rv32_reactor_owner_valid(owner) == 0:
        owner = 0
    if owner != 0:
        conflicts = conflicts + 1
    if conflicts != 1 or pending != 2:
        fail = fail + 1
    owner = 0
    if owner == 0 and pending > 0:
        owner = 1
        pending = pending - 1
        completions = completions + 1
        fg_ticks = fg_ticks + 1
        owner = 0
    if pending != 1 or completions != 1 or fg_ticks != 1 or owner != 0:
        fail = fail + 1
    # ponytail: fixed two-command floor; use an explicit second drain step until
    # rv32 baremetal loop lowering is proven on this firmware path.
    if pending > 0 and owner == 0:
        owner = 1
        pending = pending - 1
        completions = completions + 1
        fg_ticks = fg_ticks + 1
        owner = 0
    if pending != 0 or completions != 2 or fg_ticks != 2:
        fail = fail + 1
    var free_blocks = 3
    if free_blocks < 4 and owner == 0:
        owner = 2
        bg_ticks = bg_ticks + 1
        free_blocks = free_blocks + 1
        owner = 0
    if bg_ticks != 1 or free_blocks != 4 or owner != 0:
        fail = fail + 1
    owner = -9
    owner = rv32_reactor_owner_valid(owner)
    if owner != 0:
        fail = fail + 1
    fail
