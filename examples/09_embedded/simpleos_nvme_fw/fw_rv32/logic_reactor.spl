fn _rv32_reactor_sanitize_owner(owner: i64) -> i64:
    if owner < 0:
        return 0
    if owner > 2:
        return 0
    owner

fn _rv32_reactor_acquire(owner: i64, requested: i64) -> i32:
    val safe_owner: i64 = _rv32_reactor_sanitize_owner(owner)
    if requested <= 0:
        return 0
    if requested > 2:
        return 0
    if safe_owner == 0:
        return 1
    0

fn _rv32_reactor_conflicts_after(owner: i64, requested: i64, conflicts: i64) -> i64:
    if conflicts < 0:
        return 0
    if _rv32_reactor_acquire(owner, requested) == 0:
        if requested > 0 and requested <= 2:
            return conflicts + 1
    conflicts

fn _rv32_reactor_release(owner: i64, released: i64) -> i64:
    if owner == released:
        return 0
    _rv32_reactor_sanitize_owner(owner)

fn _rv32_reactor_fg_tick(pending: i64, owner: i64) -> i64:
    if pending <= 0:
        return 0
    if _rv32_reactor_acquire(owner, 1) == 0:
        return 0
    1

fn _rv32_reactor_service(pending: i64, guard_limit: i64) -> i64:
    if pending <= 0:
        return 0
    if guard_limit <= 0:
        return 0
    if pending < guard_limit:
        return pending
    guard_limit

fn _rv32_reactor_bg_needed(free_blocks: i64) -> i32:
    if free_blocks < 4:
        return 1
    0

fn _rv32_reactor_gc_sweep(reclaimable: i64) -> i64:
    if reclaimable <= 0:
        return 0
    if reclaimable > 3:
        return 3
    reclaimable

fn _rv32_reactor_power_cycle_read(checkpointed: i64, dirty: i64) -> i64:
    if dirty != 0:
        return checkpointed
    checkpointed

fn rv32_reactor_selftest() -> i32:
    if _rv32_reactor_sanitize_owner(-9) != 0:
        return 1
    if _rv32_reactor_sanitize_owner(3) != 0:
        return 1
    if _rv32_reactor_acquire(0, 1) != 1:
        return 1
    if _rv32_reactor_acquire(2, 1) != 0:
        return 1
    if _rv32_reactor_conflicts_after(2, 1, 0) != 1:
        return 1
    if _rv32_reactor_conflicts_after(0, 1, -3) != 0:
        return 1
    if _rv32_reactor_release(1, 1) != 0:
        return 1
    if _rv32_reactor_release(2, 1) != 2:
        return 1
    if _rv32_reactor_fg_tick(1, 0) != 1:
        return 1
    if _rv32_reactor_fg_tick(2, 2) != 0:
        return 1
    if _rv32_reactor_service(2, 4096) != 2:
        return 1
    if _rv32_reactor_service(5000, 4096) != 4096:
        return 1
    if _rv32_reactor_bg_needed(3) != 1:
        return 1
    if _rv32_reactor_bg_needed(4) != 0:
        return 1
    if _rv32_reactor_gc_sweep(0) != 0:
        return 1
    if _rv32_reactor_gc_sweep(2) != 2:
        return 1
    if _rv32_reactor_gc_sweep(9) != 3:
        return 1
    if _rv32_reactor_power_cycle_read(66, 0) != 66:
        return 1
    if _rv32_reactor_power_cycle_read(66, 1) != 66:
        return 1
    0
