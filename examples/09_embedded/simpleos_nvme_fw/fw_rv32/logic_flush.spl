fn rv32_flush_selftest() -> i64:
    # Scalar NVMe Flush floor: dirty data becomes committed; repeat flush is inert.
    var fail = 0
    var dirty = 1
    var committed_lba = 0
    var cache_lba = 0x5A
    var status = 0

    if dirty == 1:
        committed_lba = cache_lba
        dirty = 0
    if status != 0 or dirty != 0 or committed_lba != 0x5A:
        fail = fail + 1

    cache_lba = 0x99
    if dirty == 1:
        committed_lba = cache_lba
    if status != 0 or dirty != 0 or committed_lba != 0x5A:
        fail = fail + 1

    val bad_nsid = 99
    if bad_nsid != 1:
        status = 2
    if status != 2 or dirty != 0 or committed_lba != 0x5A:
        fail = fail + 1
    val zero_nsid = 0
    status = 0
    if zero_nsid != 1:
        status = 2
    if status != 2 or dirty != 0 or committed_lba != 0x5A:
        fail = fail + 1
    status = 0
    dirty = 1
    cache_lba = 0x77
    if bad_nsid != 1:
        status = 2
    else:
        committed_lba = cache_lba
        dirty = 0
    if status != 2 or dirty != 1 or committed_lba != 0x5A:
        fail = fail + 1
    status = 0
    dirty = 1
    cache_lba = 0x88
    if zero_nsid != 1:
        status = 2
    else:
        committed_lba = cache_lba
        dirty = 0
    if status != 2 or dirty != 1 or committed_lba != 0x5A:
        fail = fail + 1
    fail
