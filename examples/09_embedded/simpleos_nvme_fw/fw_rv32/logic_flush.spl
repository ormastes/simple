fn rv32_flush_selftest() -> i32:
    val first_commit = 90i32
    val repeat_commit = first_commit
    val invalid_nsid_status = 2i32
    val zero_nsid_status = 2i32
    val invalid_keeps_dirty = 1i32
    val invalid_keeps_commit = first_commit
    (first_commit ^ 90i32) + (repeat_commit ^ 90i32) + (invalid_nsid_status ^ 2i32) + (zero_nsid_status ^ 2i32) + (invalid_keeps_dirty ^ 1i32) + (invalid_keeps_commit ^ 90i32)
