use logic_journal_checkpoint_cases.*
use logic_journal_lba_cases.*
use logic_journal_seq_cases.*

fn rv32_journal_record_cases_selftest() -> i32:
    if rv32_journal_lba_cases_selftest() != 0:
        return 1
    if rv32_journal_seq_cases_selftest() != 0:
        return 1
    if rv32_journal_checkpoint_cases_selftest() != 0:
        return 1
    0
