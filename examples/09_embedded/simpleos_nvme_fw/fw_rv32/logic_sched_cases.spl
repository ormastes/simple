use logic_sched_core.*

fn rv32_sched_cases_selftest() -> i32:
    if _rv32_sched_channel_of(0) != 0:
        return 1
    if _rv32_sched_channel_of(8) != 0:
        return 1
    if _rv32_sched_channel_of(5) != 5:
        return 1
    if _rv32_sched_channel_of(-1) != 0:
        return 1
    if _rv32_sched_depth_clamped(8) != 8:
        return 1
    if _rv32_sched_depth_clamped(-3) != 0:
        return 1
    if _rv32_sched_balanced_steps(0) != 0:
        return 1
    if _rv32_sched_balanced_steps(1) != 1:
        return 1
    if _rv32_sched_balanced_steps(16) != 2:
        return 1
    if _rv32_sched_balanced_steps(17) != 3:
        return 1
    if _rv32_sched_same_channel_steps(8) != 8:
        return 1
    if _rv32_sched_same_channel_steps(-1) != 0:
        return 1
    if _rv32_sched_completed(16) != 16:
        return 1
    if _rv32_sched_completed(-4) != 0:
        return 1
    0
