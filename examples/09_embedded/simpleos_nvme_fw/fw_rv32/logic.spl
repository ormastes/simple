        sq_tail = slot_zero
        sq_len = sq_len + 1
    if sq_tail != 0 or sq_len != 1:
        fail = fail + 1
    sq_tail = 0
    sq_len = 0

    val max_doorbell = depth - 1
    if max_doorbell < 0 or max_doorbell >= depth:
        fail = fail + 1
    else:
        sq_tail = max_doorbell
        sq_len = sq_len + 1
    if sq_tail != max_doorbell or sq_len != 1:
        fail = fail + 1
    sq_tail = 0
    sq_len = 0

    val doorbell = 1
    if doorbell < 0 or doorbell >= depth:
        fail = fail + 1
    else:
        sq_tail = doorbell
        sq_len = sq_len + 1
    if sq_tail != 1 or sq_len != 1:
        fail = fail + 1

    val neg_doorbell = -1
    if neg_doorbell >= 0 and neg_doorbell < depth:
        sq_tail = neg_doorbell
        sq_len = sq_len + 1
    if sq_tail != 1 or sq_len != 1:
        fail = fail + 1

    val bad_doorbell = depth
    if bad_doorbell >= 0 and bad_doorbell < depth:
        sq_tail = bad_doorbell
        sq_len = sq_len + 1
    if sq_tail != 1 or sq_len != 1:
        fail = fail + 1

    while sq_len < depth:
        sq_tail = (sq_tail + 1) % depth
        sq_len = sq_len + 1
    if sq_tail != 0 or sq_len != depth:
        fail = fail + 1
    if sq_len < depth:
        sq_tail = (sq_tail + 1) % depth
        sq_len = sq_len + 1
    if sq_tail != 0 or sq_len != depth:
        fail = fail + 1

    while sq_len > 0:
        sq_head = (sq_head + 1) % depth
        sq_len = sq_len - 1
    if sq_head != sq_tail or sq_len != 0:
        fail = fail + 1

    while cq_len < depth:
        cq_tail = (cq_tail + 1) % depth
        cq_len = cq_len + 1
        if cq_tail == 0:
            cq_phase = 1 - cq_phase
    if cq_tail != 0 or cq_phase != 0 or cq_len != depth:
        fail = fail + 1
    if cq_len < depth:
        cq_tail = (cq_tail + 1) % depth
        cq_len = cq_len + 1
        if cq_tail == 0:
            cq_phase = 1 - cq_phase
    if cq_tail != 0 or cq_phase != 0 or cq_len != depth:
        fail = fail + 1
    if host_seen_phase == cq_phase:
        fail = fail + 1
    host_seen_phase = cq_phase

    val neg_cq_head = -1
    if neg_cq_head >= 0 and neg_cq_head < depth and cq_len > 0:
        cq_head = neg_cq_head
        cq_len = cq_len - 1
    if cq_head != 0 or cq_len != depth:
        fail = fail + 1
    val hi_cq_head = depth
    if hi_cq_head >= 0 and hi_cq_head < depth and cq_len > 0:
        cq_head = hi_cq_head
        cq_len = cq_len - 1
    if cq_head != 0 or cq_len != depth:
        fail = fail + 1

    while cq_len > 0:
        cq_head = (cq_head + 1) % depth
        cq_len = cq_len - 1
    if cq_head != 0 or cq_len != 0 or host_seen_phase != 0:
        fail = fail + 1
    while cq_len < depth:
        cq_tail = (cq_tail + 1) % depth
        cq_len = cq_len + 1
        if cq_tail == 0:
            cq_phase = 1 - cq_phase
    if cq_tail != 0 or cq_head != 0 or cq_len != depth or cq_phase != 1 or host_seen_phase != 0:
        fail = fail + 1
    fail

fn rv32_io_command_selftest() -> i64:
    # Scalar IO floor: unknown opcodes reject; Read payloads are inert; Write Zeroes/DSM Trim clear ranges; Flush commits.
    var fail = 0
    var lba20 = 0x60
    var lba21 = 0x61
    var lba22 = 0xA0
    var status = 0

    lba20 = 0
    lba21 = 0
    lba22 = 0
    if lba20 != 0 or lba21 != 0 or lba22 != 0:
        fail = fail + 1

    lba20 = 0x71
    lba21 = 0x81
    if lba20 != 0x71 or lba21 != 0x81:
        fail = fail + 1
    lba20 = 0
    lba21 = 0
    if lba20 != 0 or lba21 != 0:
        fail = fail + 1

    val malformed_zero_payload = 7
    lba22 = 0xEE
    if malformed_zero_payload != 0:
        status = 2
    if status != 2 or lba22 != 0xEE:
        fail = fail + 1

    status = 0
    val malformed_trim_payload = 5
    if malformed_trim_payload != 0:
        status = 2
    if status != 2 or lba22 != 0xEE:
        fail = fail + 1

    status = 0
    val malformed_read_payload = 7
    if malformed_read_payload != 0:
        status = 2
    if status != 2 or lba22 != 0xEE:
        fail = fail + 1

    status = 0
    val unknown_opcode = 0x7F
    if unknown_opcode != 0 and unknown_opcode != 1 and unknown_opcode != 2 and unknown_opcode != 8 and unknown_opcode != 9:
        status = 1
    if status != 1 or lba22 != 0xEE:
        fail = fail + 1
    status = rv32_hil_validate(31, 1, 3070, 4, 0x44)
    if status != 0x80 or lba22 != 0xEE:
        fail = fail + 1
    status = rv32_hil_validate(32, 1, 20, 0, 0)
    if status != 0x80 or lba22 != 0xEE:
        fail = fail + 1
    fail

fn rv32_flush_selftest() -> i64:
    # Scalar NVMe Flush floor: dirty data becomes committed; repeat flush is inert.
    var fail = 0
    var dirty = 1
    var committed_lba = 0
    var cache_lba = 0x5A
    var status = 0

    if dirty == 1:
        committed_lba = cache_lba
        dirty = 0
    if status != 0 or dirty != 0 or committed_lba != 0x5A:
        fail = fail + 1

    cache_lba = 0x99
    if dirty == 1:
        committed_lba = cache_lba
    if status != 0 or dirty != 0 or committed_lba != 0x5A:
        fail = fail + 1

    val bad_nsid = 99
    if bad_nsid != 1:
        status = 2
    if status != 2 or dirty != 0 or committed_lba != 0x5A:
        fail = fail + 1
    val zero_nsid = 0
    status = 0
    if zero_nsid != 1:
        status = 2
    if status != 2 or dirty != 0 or committed_lba != 0x5A:
        fail = fail + 1
    status = 0
    dirty = 1
    cache_lba = 0x77
    if bad_nsid != 1:
        status = 2
    else:
        committed_lba = cache_lba
        dirty = 0
    if status != 2 or dirty != 1 or committed_lba != 0x5A:
        fail = fail + 1
    status = 0
    dirty = 1
    cache_lba = 0x88
    if zero_nsid != 1:
        status = 2
    else:
        committed_lba = cache_lba
        dirty = 0
    if status != 2 or dirty != 1 or committed_lba != 0x5A:
        fail = fail + 1
    fail
 
fn rv32_namespace_guard_selftest() -> i64:
    # Scalar NVMe namespace/reserved-field floor: malformed admin commands are inert.
    var fail = 0
    val sc_success = 0
    val sc_invalid_field = 2
    var status = sc_success
    var user_lba = 0xEE
    var fw_revision = 2
    var fw_dl_bytes = 0
    var format_count = 1
    val nsid = 1

    if nsid != 0:
        status = sc_invalid_field
    if status != sc_invalid_field:
        fail = fail + 1

    status = sc_success
    if nsid != 1:
        status = sc_invalid_field
    if status != sc_success:
        fail = fail + 1
    val zero_nsid = 0
    status = sc_success
    if zero_nsid != 1:
        status = sc_invalid_field
    if status != sc_invalid_field or user_lba != 0xEE or format_count != 1:
        fail = fail + 1
    val bad_nsid = 99
    status = sc_success
    if bad_nsid != 1:
        status = sc_invalid_field
    if status != sc_invalid_field:
        fail = fail + 1

    status = sc_success
    if bad_nsid != 1:
        status = sc_invalid_field
    if status == sc_success:
        user_lba = 0
    if status != sc_invalid_field or user_lba != 0xEE or format_count != 1:
        fail = fail + 1

    val reserved_cdw = 1
    status = sc_success
    if reserved_cdw != 0:
        status = sc_invalid_field
    if status != sc_invalid_field or user_lba != 0xEE or format_count != 1:
        fail = fail + 1

    status = sc_success
    if nsid != 0:
        status = sc_invalid_field
    if status != sc_invalid_field or fw_revision != 2 or fw_dl_bytes != 0:
        fail = fail + 1

    status = sc_success
    if reserved_cdw != 0:
        status = sc_invalid_field
    if status != sc_invalid_field or fw_revision != 2:
        fail = fail + 1
    status = sc_success
    val log_id = 1
    if log_id != 1:
        status = sc_invalid_field
    if status != sc_success or fw_revision != 2 or fw_dl_bytes != 0:
        fail = fail + 1
    status = sc_success
    val reserved_log_id = 1 | (1 << 16)
    if reserved_log_id != 1:
        status = sc_invalid_field
    if status != sc_invalid_field or fw_revision != 2 or fw_dl_bytes != 0:
        fail = fail + 1
    status = sc_success
    val get_log_nsid = 1
    if get_log_nsid != 0:
        status = sc_invalid_field
    if status != sc_invalid_field or fw_revision != 2 or fw_dl_bytes != 0:
        fail = fail + 1
    status = sc_success
    val controller_log_nsid = 0
    if controller_log_nsid != 0:
        status = sc_invalid_field
    if status != sc_success:
        fail = fail + 1
    fail

fn nvme_fw_rv32_logic_selftest() -> i64:
    rv32_rain_selftest() + rv32_ecc_selftest() + rv32_journal_selftest() + rv32_map_selftest() + rv32_band_selftest() + rv32_sched_selftest() + rv32_pt_selftest() + rv32_hil_selftest() + rv32_queue_phase_selftest() + rv32_io_command_selftest() + rv32_flush_selftest() + rv32_admin_selftest() + rv32_reactor_selftest() + rv32_policy_target_selftest() + rv32_dram_durability_selftest() + rv32_wear_scrub_selftest() + rv32_media_retire_selftest() + rv32_power_cycle_selftest() + rv32_backpressure_abort_selftest() + rv32_feature_guard_selftest() + rv32_namespace_guard_selftest()
