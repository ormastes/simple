# RV32 no-alloc NVMe firmware logic reference.
#
# Scalar-only: no arrays, no heap, no strings in the logic path. Host and bare-metal entries share
# this so P9 evidence exercises the same RAIN + ECC + fixed scheduler + power/thermal + map-cache + band + journal-ring + HIL command/queue + queue-phase + read/zero/trim/flush + admin/format/fw-log + reactor + policy/target + DRAM/durability + wear/scrub + media-retire + power-cycle + backpressure/abort + feature-guard + namespace-guard floor.

fn rv32_rain_selftest() -> i64:
    val d0 = 256
    val d1 = 263
    val d2 = 270
    val d3 = 277
    val d4 = 284
    val d5 = 291
    val d6 = 298
    val d7 = 305
    val parity = d0 ^ d1 ^ d2 ^ d3 ^ d4 ^ d5 ^ d6 ^ d7

    var fail = 0
    if (parity ^ d1 ^ d2 ^ d3 ^ d4 ^ d5 ^ d6 ^ d7) != d0:
        fail = fail + 1
    if (parity ^ d0 ^ d2 ^ d3 ^ d4 ^ d5 ^ d6 ^ d7) != d1:
        fail = fail + 1
    if (parity ^ d0 ^ d1 ^ d3 ^ d4 ^ d5 ^ d6 ^ d7) != d2:
        fail = fail + 1
    if (parity ^ d0 ^ d1 ^ d2 ^ d4 ^ d5 ^ d6 ^ d7) != d3:
        fail = fail + 1
    if (parity ^ d0 ^ d1 ^ d2 ^ d3 ^ d5 ^ d6 ^ d7) != d4:
        fail = fail + 1
    if (parity ^ d0 ^ d1 ^ d2 ^ d3 ^ d4 ^ d6 ^ d7) != d5:
        fail = fail + 1
    if (parity ^ d0 ^ d1 ^ d2 ^ d3 ^ d4 ^ d5 ^ d7) != d6:
        fail = fail + 1
    if (parity ^ d0 ^ d1 ^ d2 ^ d3 ^ d4 ^ d5 ^ d6) != d7:
        fail = fail + 1

    val recovered3 = parity ^ d0 ^ d1 ^ d2 ^ d4 ^ d5 ^ d6 ^ d7
    if recovered3 != d3:
        fail = fail + 1
    fail

fn rv32_bit(v: i64, bit: i64) -> i64:
    (v >> bit) & 1

fn rv32_ecc_parity_pos(pos: i64) -> bool:
    pos == 1 or pos == 2 or pos == 4 or pos == 8 or pos == 16

fn rv32_ecc_pos_for_data_bit(bit: i64) -> i64:
    var pos = 1
    var seen = 0
    while pos <= 22:
        if not rv32_ecc_parity_pos(pos):
            if seen == bit:
                return pos
            seen = seen + 1
        pos = pos + 1
    0

fn rv32_ecc_payload(data: i64) -> i64:
    var p1 = 0
    var p2 = 0
    var p4 = 0
    var p8 = 0
    var p16 = 0
    var overall = 0
    var pos = 1
    var data_bit = 0
    while pos <= 22:
        if not rv32_ecc_parity_pos(pos):
            val bit = rv32_bit(data, data_bit)
            overall = overall ^ bit
            if (pos & 1) != 0:
                p1 = p1 ^ bit
            if (pos & 2) != 0:
                p2 = p2 ^ bit
            if (pos & 4) != 0:
                p4 = p4 ^ bit
            if (pos & 8) != 0:
                p8 = p8 ^ bit
            if (pos & 16) != 0:
                p16 = p16 ^ bit
            data_bit = data_bit + 1
        pos = pos + 1
    p1 | (p2 << 1) | (p4 << 2) | (p8 << 3) | (p16 << 4) | (overall << 5)

fn rv32_ecc_flip_data_pos(data: i64, pos: i64) -> i64:
    var bit = 0
    while bit < 17:
        if rv32_ecc_pos_for_data_bit(bit) == pos:
            return data ^ (1 << bit)
        bit = bit + 1
    data

fn rv32_ecc_status(data: i64, stored: i64) -> i64:
    val recomputed = rv32_ecc_payload(data)
    val syndrome = (stored ^ recomputed) & 0x1F
    val overall = ((stored >> 5) ^ (recomputed >> 5)) & 1
    if syndrome == 0:
        if overall == 0:
            return 0
        return 1
    if overall == 0:
        return 2
    1

fn rv32_ecc_correct(data: i64, stored: i64) -> i64:
    val recomputed = rv32_ecc_payload(data)
    val syndrome = (stored ^ recomputed) & 0x1F
    val overall = ((stored >> 5) ^ (recomputed >> 5)) & 1
    if syndrome != 0 and overall != 0 and not rv32_ecc_parity_pos(syndrome):
        return rv32_ecc_flip_data_pos(data, syndrome)
    data

fn rv32_ecc_selftest() -> i64:
    var fail = 0
    val data = 0x123456
    val stored = rv32_ecc_payload(data)
    val one = 0x133456
    if rv32_ecc_status(one, stored) != 1:
        fail = fail + 1
    if rv32_ecc_correct(one, stored) != data:
        fail = fail + 1
    val two = data ^ 1 ^ 2
    if rv32_ecc_status(two, stored) != 2:
        fail = fail + 1
    fail

fn rv32_journal_effective_count(count: i64, cap: i64) -> i64:
    if count < 0:
        return 0
    if cap < 0:
        return 0
    var c = cap
    if c > 4:
        c = 4
    if count > c:
        return c
    count

fn rv32_journal_selftest() -> i64:
    # Four scalar slots stand in for the host Journal's pre-sized WAL arrays.
    var fail = 0
    var cap = 4
    var count = 0
    var ckpt_seq = 0
    var ckpt_valid = 0
    var sb_gen = 0
    var sb_ckpt_ptr = -1

    var lba0 = -1
    var new0 = -1
    var seq0 = 0
    var lba1 = -1
    var new1 = -1
    var seq1 = 0
    var lba2 = -1
    var new2 = -1
    var seq2 = 0
    var lba3 = -1
    var new3 = -1
    var seq3 = 0

    if rv32_journal_effective_count(-3, cap) != 0:
        fail = fail + 1
    if rv32_journal_effective_count(6, cap) != 4:
        fail = fail + 1
    if rv32_journal_effective_count(1, -1) != 0:
        fail = fail + 1

    lba0 = 100
    new0 = 20
    seq0 = 1
    count = count + 1
    lba1 = 101
    new1 = 21
    seq1 = 2
    count = count + 1
    lba2 = 102
    new2 = 22
    seq2 = 3
    count = count + 1
    if count != 3:
        fail = fail + 1
    if lba0 != 100 or new0 != 20 or seq0 != 1:
        fail = fail + 1
    if lba2 != 102 or new2 != 22 or seq2 != 3:
        fail = fail + 1

    lba3 = 103
    new3 = 23
    seq3 = 4
    count = count + 1
    if rv32_journal_effective_count(count, cap) != 4:
        fail = fail + 1
    if rv32_journal_effective_count(count + 1, cap) != 4:
        fail = fail + 1

    ckpt_seq = 2
    ckpt_valid = 1
    sb_gen = sb_gen + 1
    sb_ckpt_ptr = ckpt_seq
    if ckpt_valid != 1 or sb_gen != 1 or sb_ckpt_ptr != 2:
        fail = fail + 1
    ckpt_valid = 0
    if ckpt_valid == 1:
        sb_gen = sb_gen + 1
        sb_ckpt_ptr = 99
    if sb_gen != 1 or sb_ckpt_ptr != 2:
        fail = fail + 1

    # Truncate checkpointed records: seq 3 and 4 survive and compact into slots 0 and 1.
    lba0 = lba2
    new0 = new2
    seq0 = seq2
    lba1 = lba3
    new1 = new3
    seq1 = seq3
    lba2 = -1
    new2 = -1
    seq2 = 0
    lba3 = -1
    new3 = -1
    seq3 = 0
    count = 2
    if count != 2:
        fail = fail + 1
    if lba0 != 102 or new0 != 22 or seq0 != 3:
        fail = fail + 1
    if lba1 != 103 or new1 != 23 or seq1 != 4:
        fail = fail + 1
    if lba2 != -1 or new2 != -1 or seq2 != 0:
        fail = fail + 1

    ckpt_seq = 4
    sb_gen = sb_gen + 1
    sb_ckpt_ptr = ckpt_seq
    if sb_gen != 2 or sb_ckpt_ptr != 4:
        fail = fail + 1
    fail

fn rv32_map_cap_limit(cap: i64) -> i64:
    if cap < 0:
        return 0
    if cap > 4:
        return 4
    cap

fn rv32_map_lba_valid(lba: i64) -> bool:
    lba >= 0 and lba < 128

fn rv32_map_ppn_valid(ppn: i64) -> bool:
    ppn == -1 or (ppn >= 0 and ppn < 4096)

fn rv32_map_sanitize_ppn(ppn: i64) -> i64:
    if rv32_map_ppn_valid(ppn):
        return ppn
    -1

fn rv32_map_selftest() -> i64:
    # Four scalar slots stand in for the host L2pMap's pre-sized write-back cache.
    var fail = 0
    var cap = 4
    var tick = 0
    var hits = 0
    var misses = 0
    var evicts = 0

    var l2p10 = -1
    var l2p11 = -1
    var l2p12 = -1
    var l2p13 = -1

    var lba0 = -1
    var ppn0 = -1
    var dirty0 = 0
    var age0 = 0
    var lba1 = -1
    var ppn1 = -1
    var dirty1 = 0
    var age1 = 0
    var lba2 = -1
    var ppn2 = -1
    var dirty2 = 0
    var age2 = 0
    var lba3 = -1
    var ppn3 = -1
    var dirty3 = 0
    var age3 = 0

    if rv32_map_cap_limit(-1) != 0:
        fail = fail + 1
    if rv32_map_cap_limit(7) != 4:
        fail = fail + 1
    if rv32_map_sanitize_ppn(4096) != -1:
        fail = fail + 1
    if rv32_map_lba_valid(128):
        fail = fail + 1

    # update(10, 100), then lookup(10): served from dirty cache, not backing L2P.
    if rv32_map_lba_valid(10) and rv32_map_ppn_valid(100):
        tick = tick + 1
        lba0 = 10
        ppn0 = 100
        dirty0 = 1
        age0 = tick
    if lba0 == 10:
        hits = hits + 1
        tick = tick + 1
        age0 = tick
        if rv32_map_sanitize_ppn(ppn0) != 100:
            fail = fail + 1
    if hits != 1 or l2p10 != -1:
        fail = fail + 1

    # flush(): dirty cache entry becomes the authoritative flash-resident L2P.
    if dirty0 == 1 and lba0 == 10 and rv32_map_ppn_valid(ppn0):
        l2p10 = ppn0
        dirty0 = 0
    if l2p10 != 100 or dirty0 != 0:
        fail = fail + 1

    # crash_volatile(): cache is gone, backing L2P survives.
    lba0 = -1
    ppn0 = -1
    age0 = 0
    tick = 0
    misses = misses + 1
    if lba0 != -1 or ppn0 != -1 or l2p10 != 100:
        fail = fail + 1
    if misses != 1:
        fail = fail + 1

    # Fill all slots, then evict the oldest dirty entry on the next distinct update.
    lba0 = 10
    ppn0 = 200
    dirty0 = 1
    age0 = 1
    lba1 = 11
    ppn1 = 201
    dirty1 = 1
    age1 = 2
    lba2 = 12
    ppn2 = 202
    dirty2 = 1
    age2 = 3
    lba3 = 13
    ppn3 = 203
    dirty3 = 1
    age3 = 4
    tick = 4
    if rv32_map_cap_limit(cap) == 4 and age0 < age1 and age0 < age2 and age0 < age3:
        if dirty0 == 1 and lba0 == 10 and rv32_map_ppn_valid(ppn0):
            l2p10 = ppn0
        evicts = evicts + 1
        tick = tick + 1
        lba0 = 14
        ppn0 = 204
        dirty0 = 1
        age0 = tick
    if l2p10 != 200 or lba0 != 14 or ppn0 != 204 or evicts != 1:
        fail = fail + 1

    # Invalid writes are inert.
    if rv32_map_lba_valid(12) and rv32_map_ppn_valid(4096):
        l2p12 = 4096
    if l2p12 != -1:
        fail = fail + 1
    if rv32_map_lba_valid(128) and rv32_map_ppn_valid(300):
        l2p13 = 300
    if l2p13 != -1:
        fail = fail + 1
    if l2p11 != -1 or l2p13 != -1:
        fail = fail + 1
    fail

fn rv32_band_block_valid(blk: i64) -> bool:
    blk >= 0 and blk < 4

fn rv32_band_ppn_valid(ppn: i64) -> bool:
    ppn >= 0 and ppn < 16

fn rv32_band_block_of(ppn: i64) -> i64:
    if not rv32_band_ppn_valid(ppn):
        return -1
    ppn / 4

fn rv32_band_valid_count(count: i64) -> i64:
    if count < 0:
        return 0
    if count > 4:
        return 4
    count

fn rv32_band_selftest() -> i64:
    # Four blocks × four pages mirror the host BandAlloc lifecycle without arrays.
    val BLK_FREE = 0
    val BLK_OPEN = 1
    val BLK_CLOSED = 2
    val BLK_BAD = 3
    var fail = 0
    var active_blk = -1
    var active_wp = 0
    var free_count = 4

    var state0 = BLK_FREE
    var state1 = BLK_FREE
    var state2 = BLK_FREE
    var state3 = BLK_FREE
    var valid0 = 0
    var valid1 = 0
    var valid2 = 0
    var valid3 = 0
    var page0_live = 0

    if rv32_band_valid_count(-3) != 0:
        fail = fail + 1
    if rv32_band_valid_count(7) != 4:
        fail = fail + 1
    if rv32_band_block_valid(4):
        fail = fail + 1
    if rv32_band_block_of(16) != -1:
        fail = fail + 1

    # First allocation opens block 0 and returns PPN 0.
    if active_blk == -1:
        active_blk = 0
        state0 = BLK_OPEN
        active_wp = 0
        free_count = free_count - 1
    val p0 = active_blk * 4 + active_wp
    active_wp = active_wp + 1
    if p0 != 0 or free_count != 3 or state0 != BLK_OPEN:
        fail = fail + 1

    # Finish block 0, then next allocation closes it and opens block 1.
    active_wp = 4
    if active_wp == 4:
        state0 = BLK_CLOSED
        active_blk = 1
        state1 = BLK_OPEN
        active_wp = 0
        free_count = free_count - 1
    val p4 = active_blk * 4 + active_wp
    active_wp = active_wp + 1
    if p4 != 4 or state0 != BLK_CLOSED or state1 != BLK_OPEN or free_count != 2:
        fail = fail + 1

    # mark_valid is idempotent and ignores bad blocks.
    if rv32_band_ppn_valid(p0) and state0 != BLK_FREE and state0 != BLK_BAD and page0_live == 0:
        page0_live = 1
        valid0 = valid0 + 1
    if rv32_band_ppn_valid(p0) and state0 != BLK_FREE and state0 != BLK_BAD and page0_live == 0:
        page0_live = 1
        valid0 = valid0 + 1
    if valid0 != 1 or page0_live != 1:
        fail = fail + 1
    state2 = BLK_BAD
    if state2 != BLK_BAD:
        valid2 = valid2 + 1
    if valid2 != 0:
        fail = fail + 1

    # mark_invalid and corrupted counters fail closed.
    if page0_live == 1:
        page0_live = 0
        valid0 = valid0 - 1
    if page0_live != 0 or valid0 != 0:
        fail = fail + 1
    valid1 = -9
    if rv32_band_valid_count(valid1) != 0:
        fail = fail + 1
    valid1 = 9
    if rv32_band_valid_count(valid1) != 4:
        fail = fail + 1

    # free_block clears active state and live-page accounting.
    page0_live = 1
    valid0 = 1
    state0 = BLK_CLOSED
    val fc_before = free_count
    state0 = BLK_FREE
    valid0 = 0
    page0_live = 0
    free_count = free_count + 1
    if state0 != BLK_FREE or valid0 != 0 or page0_live != 0 or free_count != fc_before + 1:
        fail = fail + 1
    state1 = BLK_FREE
    valid1 = 0
    if active_blk == 1:
        active_blk = -1
        active_wp = 0
    if active_blk != -1 or active_wp != 0:
        fail = fail + 1
    if state3 != BLK_FREE or valid3 != 0:
        fail = fail + 1
    state2 = BLK_BAD
    val free_before_bad = free_count
    if state2 != BLK_BAD:
        state2 = BLK_FREE
        free_count = free_count + 1
    if state2 != BLK_BAD or free_count != free_before_bad:
        fail = fail + 1
    fail

fn rv32_sched_channel_of(blk: i64) -> i64:
    if blk < 0:
        return 0
    blk % 2

fn rv32_sched_depth(v: i64) -> i64:
    if v < 0:
        return 0
    if v > 4:
        return 4
    v

fn rv32_sched_selftest() -> i64:
    # Two scalar channels are enough to prove per-channel serialization vs parallel drain.
    var fail = 0
    var pending0 = 0
    var pending1 = 0
    var done = 0
    var steps = 0

    if rv32_sched_channel_of(0) != 0:
        fail = fail + 1
    if rv32_sched_channel_of(3) != 1:
        fail = fail + 1
    if rv32_sched_channel_of(-1) != 0:
        fail = fail + 1

    # Balanced batch: two ops per channel drain in two parallel steps.
    pending0 = pending0 + 1
    pending1 = pending1 + 1
    pending0 = pending0 + 1
    pending1 = pending1 + 1
    while rv32_sched_depth(pending0) + rv32_sched_depth(pending1) > 0:
        var dispatched = 0
        if pending0 > 0:
            pending0 = pending0 - 1
            done = done + 1
            dispatched = dispatched + 1
        if pending1 > 0:
            pending1 = pending1 - 1
            done = done + 1
            dispatched = dispatched + 1
        if dispatched > 0:
            steps = steps + 1
    if steps != 2 or done != 4:
        fail = fail + 1

    # Same-channel batch serializes: four ops on channel 0 take four steps.
    pending0 = 4
    pending1 = 0
    done = -3
    steps = -2
    if done < 0:
        done = 0
    if steps < 0:
        steps = 0
    while rv32_sched_depth(pending0) + rv32_sched_depth(pending1) > 0:
        var dispatched2 = 0
        if pending0 > 0:
            pending0 = pending0 - 1
            done = done + 1
            dispatched2 = dispatched2 + 1
        if pending1 > 0:
            pending1 = pending1 - 1
            done = done + 1
            dispatched2 = dispatched2 + 1
        if dispatched2 > 0:
            steps = steps + 1
    if steps != 4 or done != 4:
        fail = fail + 1

    pending0 = 3
    pending1 = -7
    if rv32_sched_depth(pending0) + rv32_sched_depth(pending1) != 3:
        fail = fail + 1
    pending0 = 99
    pending1 = 1
    if rv32_sched_depth(pending0) + rv32_sched_depth(pending1) != 5:
        fail = fail + 1
    fail

fn rv32_pt_power_state(ps: i64) -> i64:
    if ps < 0:
        return 0
    if ps >= 5:
        return 4
    ps

fn rv32_pt_temperature(temp_k: i64) -> i64:
    if temp_k < 313:
        return 313
    temp_k

fn rv32_pt_selftest() -> i64:
    var fail = 0
    var power_state = 0
    var temp_k = 313
    var crit_k = 363
    var throttled = 0
    var throttle_events = 0

    if rv32_pt_power_state(-1) != 0:
        fail = fail + 1
    if rv32_pt_power_state(99) != 4:
        fail = fail + 1
    if rv32_pt_temperature(-9) != 313:
        fail = fail + 1

    # Valid Set Features changes state; invalid values leave the previous state alone.
    power_state = 3
    if power_state != 3:
        fail = fail + 1
    if 99 >= 0 and 99 < 5:
        power_state = 99
    if power_state != 3:
        fail = fail + 1
    if 313 > 313:
        crit_k = 313
    if crit_k != 363:
        fail = fail + 1
    if 340 > 313:
        crit_k = 340
    if crit_k != 340:
        fail = fail + 1
    val bad_crit_k = 500
    if bad_crit_k > 313 and bad_crit_k <= 450:
        crit_k = bad_crit_k
    if crit_k != 340:
        fail = fail + 1
    val max_crit_k = 450
    if max_crit_k > 313 and max_crit_k <= 450:
        crit_k = max_crit_k
    if crit_k != 450:
        fail = fail + 1

    # Sustained PS0 work heats past throttle and critical thresholds.
    power_state = 0
    temp_k = 313
    crit_k = 340
    throttled = 0
    throttle_events = 0
    var i = 0
    while i < 20:
        val ps = rv32_pt_power_state(power_state)
        val heat = 10 * (5 - ps) / 3
        temp_k = temp_k + heat
        val excess = temp_k - 313
        if excess > 0:
            temp_k = temp_k - (excess / 4 + 1)
        if temp_k < 313:
            temp_k = 313
        if temp_k >= 353:
            if throttled == 0:
                throttle_events = throttle_events + 1
            throttled = 1
        if temp_k < 353:
            throttled = 0
        i = i + 1
    if throttled != 1:
        fail = fail + 1
    if throttle_events <= 0:
        fail = fail + 1
    if temp_k < crit_k:
        fail = fail + 1
    val hot_crit = if temp_k >= crit_k: 1 else: 0
    if hot_crit != 1:
        fail = fail + 1
    val factor = if throttled == 1: 1 else: 8
    if factor != 1:
        fail = fail + 1

    # Idle ticks cool below throttle/critical thresholds and restore full dispatch budget.
    var j = 0
    while j < 100:
        val excess2 = temp_k - 313
        if excess2 > 0:
            temp_k = temp_k - (excess2 / 4 + 1)
        if temp_k < 313:
            temp_k = 313
        if temp_k < 353:
            throttled = 0
        j = j + 1
    if throttled != 0:
        fail = fail + 1
    val cool_factor = if throttled == 1: 1 else: 8
    if cool_factor != 8:
        fail = fail + 1
    val cool_crit = if temp_k >= crit_k: 1 else: 0
    if cool_crit != 0:
        fail = fail + 1
    fail

fn rv32_hil_cid_valid(cid: i64) -> bool:
    cid >= 0 and cid <= 65535

fn rv32_hil_known_opcode(op: i64) -> bool:
    op == 0 or op == 1 or op == 2 or op == 8 or op == 9

fn rv32_hil_validate(cid: i64, op: i64, lba: i64, nblocks: i64, data: i64) -> i64:
    if not rv32_hil_cid_valid(cid):
        return 2
    if not rv32_hil_known_opcode(op):
        return 1
    if op == 0:
        if lba != 0 or nblocks != 0 or data != 0:
            return 2
        return 0
    if lba < 0:
        return 0x80
    if nblocks <= 0:
        return 0x80
    if lba >= 3072:
        return 0x80
    if nblocks > 3072:
        return 0x80
    if lba > 3072 - nblocks:
        return 0x80
    if op == 9 and data != 0:
        return 2
    if op == 8 and data != 0:
        return 2
    if op == 2 and data != 0:
        return 2
    0

fn rv32_hil_prp_pack(first_base: i64, second_base: i64) -> i64:
    (first_base & 0xFF) | ((second_base & 0xFF) << 8)

fn rv32_hil_prp_byte(data: i64, i: i64) -> i64:
    val first = data & 0xFF
    val second = (data >> 8) & 0xFF
    if second == 0:
        return (first + i) & 0xFF
    if i < 2:
        return (first + i) & 0xFF
    (second + (i - 2)) & 0xFF

fn rv32_hil_pending(len: i64, depth: i64) -> i64:
    if len < 0:
        return 0
    if len > depth:
        return depth
    len

fn rv32_hil_selftest() -> i64:
    # Four scalar ring slots mirror the queue invariants without arrays or heap.
    var fail = 0
    val depth = 4
    var sq_head = 0
    var sq_tail = 0
    var sq_len = 0
    var cq_head = 0
    var cq_tail = 0
    var cq_len = 0
    var cid0 = -1
    var cid1 = -1
    var cid2 = -1
    var cid3 = -1
    var cpl_cid0 = -1
    var cpl_status0 = -1

    if rv32_hil_validate(1, 1, 100, 16, 7) != 0:
        fail = fail + 1
    if rv32_hil_validate(2, 1, 3071, 1, 0) != 0:
        fail = fail + 1
    if rv32_hil_validate(26, 1, 3070, 2, 0) != 0:
        fail = fail + 1
    if rv32_hil_validate(3, 1, -1, 1, 0) != 0x80:
        fail = fail + 1
    if rv32_hil_validate(4, 1, 0, 3072, 0) != 0:
        fail = fail + 1
    if rv32_hil_validate(5, 1, 3072, 1, 0) != 0x80:
        fail = fail + 1
    if rv32_hil_validate(6, 1, 0, 3073, 0) != 0x80:
        fail = fail + 1
    if rv32_hil_validate(0, 1, 100, 1, 7) != 0:
        fail = fail + 1
    if rv32_hil_validate(65535, 1, 100, 1, 7) != 0:
        fail = fail + 1
    if rv32_hil_validate(65536, 1, 100, 1, 7) != 2:
        fail = fail + 1
    if rv32_hil_validate(-1, 1, 100, 1, 7) != 2:
        fail = fail + 1
    if rv32_hil_validate(14, 0x7F, 0, 1, 0) != 1:
        fail = fail + 1
    if rv32_hil_validate(20, -1, 0, 1, 0) != 1:
        fail = fail + 1
    if rv32_hil_validate(11, 1, 3000, 100, 0) != 0x80:
        fail = fail + 1
    if rv32_hil_validate(15, 1, 9223372036854775000, 9223372036854775000, 0) != 0x80:
        fail = fail + 1
    if rv32_hil_validate(13, 0, 0, 0, 0) != 0:
        fail = fail + 1
    if rv32_hil_validate(12, 0, 7, 0, 0) != 2:
        fail = fail + 1
    if rv32_hil_validate(16, 0, 0, 1, 0) != 2:
        fail = fail + 1
    if rv32_hil_validate(17, 0, 0, 0, 9) != 2:
        fail = fail + 1
    if rv32_hil_validate(18, 0, 7, 1, 9) != 2:
        fail = fail + 1
    if rv32_hil_validate(19, 9, 10, 1, 7) != 2:
        fail = fail + 1
    if rv32_hil_validate(24, 9, 10, 1, 0) != 0:
        fail = fail + 1
    if rv32_hil_validate(23, 8, 10, 1, 7) != 2:
        fail = fail + 1
    if rv32_hil_validate(22, 8, 10, 1, 0) != 0:
        fail = fail + 1
    if rv32_hil_validate(25, 2, 10, 1, 7) != 2:
        fail = fail + 1
    if rv32_hil_validate(21, 2, 10, 1, 0) != 0:
        fail = fail + 1
    if rv32_hil_validate(33, 1, 10, 0, 0) != 0x80:
        fail = fail + 1
    if rv32_hil_validate(30, 2, 10, 0, 0) != 0x80:
        fail = fail + 1
    if rv32_hil_validate(31, 8, 10, 0, 0) != 0x80:
        fail = fail + 1
    if rv32_hil_validate(32, 9, 10, 0, 0) != 0x80:
        fail = fail + 1
    val packed = rv32_hil_prp_pack(0x10, 0x80)
    if rv32_hil_prp_byte(packed, 2) != 0x80:
        fail = fail + 1
    if rv32_hil_prp_byte(packed, 0) != 0x10 or rv32_hil_prp_byte(packed, 3) != 0x81:
        fail = fail + 1
    val single_prp = rv32_hil_prp_pack(0x20, 0)
    if rv32_hil_prp_byte(single_prp, 2) != 0x22:
        fail = fail + 1

    # Submit two commands, fetch FIFO, and leave the ring empty.
    cid0 = 1
    sq_tail = (sq_tail + 1) % depth
    sq_len = sq_len + 1
    cid1 = 2
    sq_tail = (sq_tail + 1) % depth
    sq_len = sq_len + 1
    if rv32_hil_pending(sq_len, depth) != 2:
        fail = fail + 1
    val f0 = cid0
    sq_head = (sq_head + 1) % depth
    sq_len = sq_len - 1
    val f1 = cid1
    sq_head = (sq_head + 1) % depth
    sq_len = sq_len - 1
    if f0 != 1 or f1 != 2 or rv32_hil_pending(sq_len, depth) != 0:
        fail = fail + 1

    sq_len = -3
    if rv32_hil_pending(sq_len, depth) != 0:
        fail = fail + 1
    sq_len = depth + 3
    if rv32_hil_pending(sq_len, depth) != depth:
        fail = fail + 1
    sq_len = depth
    if rv32_hil_pending(sq_len, depth) != depth:
        fail = fail + 1
    sq_len = 0

    # Fill across the wrap boundary; a fifth submit is refused by the full-ring guard.
    cid2 = 100
    sq_tail = 3
    sq_head = 3
    sq_len = 0
    cid3 = 101
    sq_tail = 0
    sq_len = sq_len + 1
    cid0 = 102
    sq_tail = 1
    sq_len = sq_len + 1
    cid1 = 103
    sq_tail = 2
    sq_len = sq_len + 1
    cid2 = 104
    sq_tail = 3
    sq_len = sq_len + 1
    if sq_len != depth:
        fail = fail + 1
    if sq_len < depth:
        cid3 = 999
    if cid3 != 101:
        fail = fail + 1

    cpl_cid0 = 42
    cpl_status0 = 0
    cq_tail = (cq_tail + 1) % depth
    cq_len = cq_len + 1
    if rv32_hil_pending(cq_len, depth) != 1:
        fail = fail + 1
    val rcid = cpl_cid0
    val rstatus = cpl_status0
    cq_head = (cq_head + 1) % depth
    cq_len = cq_len - 1
    if rcid != 42 or rstatus != 0 or cq_len != 0:
        fail = fail + 1
    cq_len = -4
    if rv32_hil_pending(cq_len, depth) != 0:
        fail = fail + 1
    fail

fn rv32_admin_qid(cdw10: i64) -> i64:
    cdw10 & 0xFFFF

fn rv32_admin_qsize(cdw10: i64) -> i64:
    (cdw10 >> 16) & 0xFFFF

fn rv32_admin_cqid(cdw11: i64) -> i64:
    (cdw11 >> 16) & 0xFFFF

fn rv32_admin_fid(cdw10: i64) -> i64:
    cdw10 & 0xFF

fn rv32_admin_fw_slot(cdw10: i64) -> i64:
    cdw10 & 0x7

fn rv32_admin_fw_action(cdw10: i64) -> i64:
    (cdw10 >> 3) & 0x7

fn rv32_admin_smart_percent(v: i64) -> i64:
    if v < 0:
        return 0
    if v > 100:
        return 100
    v

fn rv32_admin_smart_nonnegative(v: i64) -> i64:
    if v < 0:
        return 0
    v

fn rv32_admin_selftest() -> i64:
    var fail = 0
    val max_io_queues = 8
    val lba_count = 3072
    val lba_bytes = 4096
    val feat_num_queues = 7
    val feat_power_mgmt = 2
    val feat_volatile_wc = 6
    val sc_success = 0
    val sc_invalid_field = 2
    val sc_lba_range = 0x80
    var status = sc_success

    val create_cq_cdw10 = (64 << 16) | 3
    if rv32_admin_qid(create_cq_cdw10) != 3:
        fail = fail + 1
    if rv32_admin_qsize(create_cq_cdw10) != 64:
        fail = fail + 1
    val create_sq_cdw11 = (2 << 16) | 1
    if rv32_admin_cqid(create_sq_cdw11) != 2:
        fail = fail + 1
    val feature_cdw10 = feat_power_mgmt | (1 << 16)
    if rv32_admin_fid(feature_cdw10) != feat_power_mgmt:
        fail = fail + 1
    val fw_commit_cdw10 = (3 << 3) | 2
    if rv32_admin_fw_slot(fw_commit_cdw10) != 2 or rv32_admin_fw_action(fw_commit_cdw10) != 3:
        fail = fail + 1

    # AER floor: held request completes exactly once, bad held state preserves the event.
    var aer_held_cid = 60
    var aer_event = 1
    var admin_cpls = 0
    if aer_held_cid >= 0 and aer_held_cid < 65536 and aer_event != 0:
        admin_cpls = admin_cpls + 1
        aer_held_cid = -1
        aer_event = 0
    if admin_cpls != 1 or aer_held_cid != -1 or aer_event != 0:
        fail = fail + 1
    aer_held_cid = 70000
    aer_event = 1
    if aer_held_cid >= 0 and aer_held_cid < 65536 and aer_event != 0:
        admin_cpls = admin_cpls + 1
        aer_event = 0
    if admin_cpls != 1 or aer_event != 1:
        fail = fail + 1
    aer_held_cid = 61
    if aer_held_cid >= 0 and aer_held_cid < 65536 and aer_event != 0:
        admin_cpls = admin_cpls + 1
        aer_event = 0
    if admin_cpls != 2 or aer_event != 0:
        fail = fail + 1
    aer_held_cid = 65535
    aer_event = 1
    if aer_held_cid >= 0 and aer_held_cid < 65536 and aer_event != 0:
        admin_cpls = admin_cpls + 1
        aer_held_cid = -1
        aer_event = 0
    if admin_cpls != 3 or aer_held_cid != -1 or aer_event != 0:
        fail = fail + 1
    val aer_reserved = 1
    if aer_reserved != 0:
        status = sc_invalid_field
        aer_held_cid = -1
    if status != sc_invalid_field or aer_held_cid != -1:
        fail = fail + 1
    status = sc_success
    aer_held_cid = 62
    if aer_held_cid != -1:
        status = sc_invalid_field
    if status != sc_invalid_field or aer_held_cid != 62:
        fail = fail + 1
    status = sc_success
    aer_held_cid = -1
    aer_event = 1
    if aer_event != 0 and aer_held_cid == -1:
        admin_cpls = admin_cpls + 1
        aer_event = 0
    if status != sc_success or admin_cpls != 4 or aer_event != 0:
        fail = fail + 1

    # Firmware download/commit floor: sequential image required; slot/action fail closed.
    var fw_revision = 1
    var fw_slot = 1
    var fw_dl_bytes = 0
    status = sc_success
    val fw_len = 1024
    val fw_off = 0
    if fw_len <= 0 or fw_off != fw_dl_bytes:
        status = sc_invalid_field
    else:
        fw_dl_bytes = fw_dl_bytes + fw_len
    if status != sc_success or fw_dl_bytes != 1024:
        fail = fail + 1
    val commit_slot = 2
    val commit_action = 1
    if commit_slot <= 0 or commit_slot > 7 or commit_action < 0 or commit_action > 3 or fw_dl_bytes <= 0:
        status = sc_invalid_field
    else:
        fw_slot = commit_slot
        fw_revision = fw_revision + 1
        fw_dl_bytes = 0
        status = sc_success
    if status != sc_success or fw_revision != 2 or fw_slot != 2 or fw_dl_bytes != 0:
        fail = fail + 1
    fw_dl_bytes = 4
    status = sc_success
    val bad_commit_action = 7
    if commit_slot <= 0 or commit_slot > 7 or bad_commit_action < 0 or bad_commit_action > 3 or fw_dl_bytes <= 0:
        status = sc_invalid_field
    else:
        fw_slot = commit_slot
    if status != sc_invalid_field or fw_revision != 2 or fw_slot != 2 or fw_dl_bytes != 4:
        fail = fail + 1
    fw_dl_bytes = 4
    status = sc_success
    val bad_commit_slot_zero = 0
    if bad_commit_slot_zero <= 0 or bad_commit_slot_zero > 7 or commit_action < 0 or commit_action > 3 or fw_dl_bytes <= 0:
        status = sc_invalid_field
    else:
        fw_slot = bad_commit_slot_zero
        fw_revision = fw_revision + 1
        fw_dl_bytes = 0
    if status != sc_invalid_field or fw_revision != 2 or fw_slot != 2 or fw_dl_bytes != 4:
        fail = fail + 1
    fw_dl_bytes = 128
    val bad_commit_slot = 8
    if bad_commit_slot <= 0 or bad_commit_slot > 7 or commit_action < 0 or commit_action > 3 or fw_dl_bytes <= 0:
        status = sc_invalid_field
    else:
        fw_slot = bad_commit_slot
        fw_revision = fw_revision + 1
        fw_dl_bytes = 0
    if status != sc_invalid_field or fw_revision != 2 or fw_slot != 2 or fw_dl_bytes != 128:
        fail = fail + 1
    fw_dl_bytes = 64
    status = sc_success
    val max_commit_slot = 7
    val max_commit_action = 3
    if max_commit_slot <= 0 or max_commit_slot > 7 or max_commit_action < 0 or max_commit_action > 3 or fw_dl_bytes <= 0:
        status = sc_invalid_field
    else:
        fw_slot = max_commit_slot
        fw_revision = fw_revision + 1
        fw_dl_bytes = 0
    if status != sc_success or fw_revision != 3 or fw_slot != 7 or fw_dl_bytes != 0:
        fail = fail + 1
    fw_dl_bytes = 0
    if 4 <= 0 or 8 != fw_dl_bytes:
        status = sc_invalid_field
    if status != sc_invalid_field:
        fail = fail + 1
    fw_dl_bytes = -16
    if fw_dl_bytes < 0:
        fw_dl_bytes = 0
    if 4 <= 0 or 0 != fw_dl_bytes:
        status = sc_invalid_field
    else:
        fw_dl_bytes = 4
        status = sc_success
    if status != sc_success or fw_dl_bytes != 4:
        fail = fail + 1
    if 0 <= 0 or 4 != fw_dl_bytes:
        status = sc_invalid_field
    if status != sc_invalid_field:
        fail = fail + 1
    if rv32_admin_fw_slot((4 << 3) | 1) != 1 or rv32_admin_fw_action((4 << 3) | 1) != 4:
        fail = fail + 1
    fw_revision = -4
    fw_slot = 9
    if rv32_admin_smart_nonnegative(fw_revision) != 0:
        fail = fail + 1
    if fw_slot < 1 or fw_slot > 7:
        fw_slot = 0
    if fw_slot != 0:
        fail = fail + 1

    # Format + error-log floor: failed format keeps data; good format erases data, preserves media state, and bad counters clamp.
    var lba5 = 0xEE
    var block10_erase_count = 2
    var block20_retired = 1
    var format_count = 0
    val bad_blocks_before_format = block20_retired
    status = sc_invalid_field
    if status != sc_invalid_field or lba5 != 0xEE or format_count != 0:
        fail = fail + 1
    status = sc_success
    if status == sc_success:
        lba5 = 0
        block10_erase_count = block10_erase_count + 1
        format_count = format_count + 1
    if lba5 != 0:
        fail = fail + 1
    if block10_erase_count != 3 or block20_retired != 1 or bad_blocks_before_format != 1 or format_count != 1:
        fail = fail + 1
    lba5 = 0x44
    status = sc_invalid_field
    if status != sc_invalid_field or lba5 != 0x44 or block10_erase_count != 3 or format_count != 1:
        fail = fail + 1
    var error_count = 0
    var last_error = 0
    status = sc_lba_range
    if status != sc_success:
        error_count = error_count + 1
        last_error = status
    if error_count != 1 or last_error != sc_lba_range:
        fail = fail + 1
    last_error = -9
    if last_error < 0:
        last_error = sc_invalid_field
    if last_error != sc_invalid_field:
        fail = fail + 1
    error_count = -7
    if rv32_admin_smart_nonnegative(error_count) != 0:
        fail = fail + 1
    error_count = rv32_admin_smart_nonnegative(error_count) + 1
    if error_count != 1:
        fail = fail + 1
    val get_log_error_data = error_count
    val get_log_fw_slot_data = rv32_admin_smart_nonnegative(fw_revision)
    if get_log_error_data != 1 or get_log_fw_slot_data != 0:
        fail = fail + 1

    # Identify controller/namespace floor: one namespace, eight IO queues, 4 KiB LBAs.
    var identify_kind = 1
    var identify_num_ns = 1
    var identify_max_queues = max_io_queues
    if identify_kind != 1 or identify_num_ns != 1 or identify_max_queues != 8:
        fail = fail + 1
    identify_kind = 0
    var identify_nsid = 1
    var identify_ns_size = lba_count
    var identify_lba_bytes = lba_bytes
    if identify_kind != 0 or identify_nsid != 1 or identify_ns_size != 3072 or identify_lba_bytes != 4096:
        fail = fail + 1
    identify_nsid = 0
    if identify_nsid != 1:
        status = sc_invalid_field
    if status != sc_invalid_field or identify_ns_size != 3072 or identify_lba_bytes != 4096:
        fail = fail + 1
    status = sc_success
    identify_nsid = 99
    if identify_nsid != 1:
        status = sc_invalid_field
    if status != sc_invalid_field or identify_ns_size != 3072 or identify_lba_bytes != 4096:
        fail = fail + 1
    status = sc_success

    # Feature store floor: defaults and Set/Get Features round-trip.
    var feat_num_queues_value = ((max_io_queues - 1) << 16) | (max_io_queues - 1)
    var feat_power_value = 0
    var feat_wc_value = 1
    if rv32_admin_fid(feat_num_queues) != feat_num_queues:
        fail = fail + 1
    if feat_num_queues_value != 0x00070007:
        fail = fail + 1
    feat_power_value = 3
    if feat_power_value != 3:
        fail = fail + 1
    if 99 >= 0 and 99 < 5:
        feat_power_value = 99
    if feat_power_value != 3:
        fail = fail + 1
    if -1 >= 0 and -1 < 5:
        feat_power_value = -1
    if feat_power_value != 3:
        fail = fail + 1
    if feat_wc_value != 1:
        fail = fail + 1
    if 0 == 0 or 0 == 1:
        feat_wc_value = 0
    if feat_wc_value != 0:
        fail = fail + 1
    if 2 == 0 or 2 == 1:
        feat_wc_value = 2
    if feat_wc_value != 0:
        fail = fail + 1
    if feat_volatile_wc != 6:
        fail = fail + 1

    # SMART/log floor: clamp corrupted counters and raise critical warning for health events.
    val spare = rv32_admin_smart_percent(120)
    val used = rv32_admin_smart_percent(-3)
    val reads = rv32_admin_smart_nonnegative(-5)
    val media_err = rv32_admin_smart_nonnegative(2)
    var crit = 0
    if media_err > 0:
        crit = 1
    if spare < 10:
        crit = 1
    if spare != 100 or used != 0 or reads != 0 or crit != 1:
        fail = fail + 1
    val low_spare = rv32_admin_smart_percent(8)
    crit = 0
    if low_spare < 10:
        crit = 1
    if crit != 1:
        fail = fail + 1
    crit = 0
    if media_err > 0:
        crit = 1
    if low_spare < 10:
        crit = 1
    if crit != 1:
        fail = fail + 1
    val boundary_spare = rv32_admin_smart_percent(10)
    crit = 0
    if boundary_spare < 10:
        crit = 1
    if crit != 0:
        fail = fail + 1
    val healthy_spare = rv32_admin_smart_percent(100)
    val healthy_media_err = rv32_admin_smart_nonnegative(0)
    crit = 0
    if healthy_media_err > 0:
        crit = 1
    if healthy_spare < 10:
        crit = 1
    if crit != 0:
        fail = fail + 1
    fail

fn rv32_reactor_owner_valid(owner: i64) -> i64:
    if owner < 0 or owner > 2:
        return 0
    owner

fn rv32_pool_live(live: i64, used0: i64, used1: i64, cap: i64) -> i64:
    if live < 0:
        return 0
    var n = 0
    if cap > 0 and used0 == 1:
        n = n + 1
    if cap > 1 and used1 == 1:
        n = n + 1
    if live < n:
        return live
    n

fn rv32_reactor_selftest() -> i64:
    # Two scalar task slots prove generation handles and cooperative owner tokens.
    var fail = 0
    var gen0 = 0
    var gen1 = 0
    var used0 = 0
    var used1 = 0
    var live = 0
    var h0_index = -1
    var h0_gen = -1
    var h1_index = -1
    var h1_gen = -1
    var phase0 = 0
    var phase1 = 0
    var old0 = -1
    var new0 = -1
    var seq0 = 0

    if rv32_pool_live(-4, used0, used1, 2) != 0:
        fail = fail + 1
    used0 = 1
    live = 1
    h0_index = 0
    h0_gen = gen0
    phase0 = 0
    if h0_index != 0 or h0_gen != 0 or phase0 != 0 or rv32_pool_live(live, used0, used1, 2) != 1:
        fail = fail + 1
    phase0 = 1
    if phase0 != 1:
        fail = fail + 1
    phase0 = 2
    old0 = 7
    new0 = 8
    seq0 = 9
    if phase0 != 2 or old0 != 7 or new0 != 8 or seq0 != 9:
        fail = fail + 1
    used1 = 1
    live = 2
    h1_index = 1
    h1_gen = gen1
    phase1 = 0
    if h1_index == h0_index or h1_gen != 0 or phase1 != 0 or rv32_pool_live(live, used0, used1, 2) != 2:
        fail = fail + 1
    used1 = 7
    if rv32_pool_live(live, used0, used1, 2) != 1:
        fail = fail + 1
    used1 = 1
    used0 = 0
    gen0 = gen0 + 1
    live = live - 1
    if used0 != 0 or gen0 == h0_gen or rv32_pool_live(live, used0, used1, 2) != 1:
        fail = fail + 1
    if used0 == 1 and gen0 == h0_gen:
        fail = fail + 1
    used0 = 1
    h0_gen = gen0
    live = live + 1
    if live != 2:
        fail = fail + 1
    if live >= 2:
        val invalid_index = -1
        if invalid_index != -1:
            fail = fail + 1

    var owner = 0
    var conflicts = 0
    var fg_ticks = 0
    var bg_ticks = 0
    var pending = 2
    var completions = 0
    owner = 2
    if rv32_reactor_owner_valid(owner) == 0:
        owner = 0
    if owner != 0:
        conflicts = conflicts + 1
    if conflicts != 1 or pending != 2:
        fail = fail + 1
    owner = 0
    if owner == 0 and pending > 0:
        owner = 1
        pending = pending - 1
        completions = completions + 1
        fg_ticks = fg_ticks + 1
        owner = 0
    if pending != 1 or completions != 1 or fg_ticks != 1 or owner != 0:
        fail = fail + 1
    while pending > 0:
        if owner == 0:
            owner = 1
            pending = pending - 1
            completions = completions + 1
            fg_ticks = fg_ticks + 1
            owner = 0
    if pending != 0 or completions != 2 or fg_ticks != 2:
        fail = fail + 1
    var free_blocks = 3
    if free_blocks < 4 and owner == 0:
        owner = 2
        bg_ticks = bg_ticks + 1
        free_blocks = free_blocks + 1
        owner = 0
    if bg_ticks != 1 or free_blocks != 4 or owner != 0:
        fail = fail + 1
    owner = -9
    owner = rv32_reactor_owner_valid(owner)
    if owner != 0:
        fail = fail + 1
    fail

fn rv32_policy_kind_allowed(kind: i64) -> bool:
    kind == 0 or kind == 1 or kind == 2 or kind == 3

fn rv32_policy_clamp_priority(p: i64) -> i64:
    if p < 0:
        return 0
    if p > 3:
        return 3
    p

fn rv32_policy_clamp_bool(v: i64) -> i64:
    if v != 0:
        return 1
    0

fn rv32_target_channels(target: i64) -> i64:
    if target == 1:
        return 2
    if target == 2:
        return 8
    8

fn rv32_target_hardware(target: i64) -> i64:
    if target == 1 or target == 2:
        return 1
    0

fn rv32_policy_target_selftest() -> i64:
    var fail = 0
    if not rv32_policy_kind_allowed(0):
        fail = fail + 1
    if not rv32_policy_kind_allowed(3):
        fail = fail + 1
    if rv32_policy_kind_allowed(-1):
        fail = fail + 1
    if rv32_policy_kind_allowed(100):
        fail = fail + 1
    if rv32_policy_kind_allowed(105):
        fail = fail + 1
    if rv32_policy_clamp_priority(-5) != 0:
        fail = fail + 1
