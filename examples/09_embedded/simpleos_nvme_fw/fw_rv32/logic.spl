    if cap < 0:
        return 0
    if count > cap:
        return cap
    count

fn rv32_dram_durability_selftest() -> i64:
    # Scalar DRAM arena + power-loss/regression floor: no partial writes, GC reserve, WAL survives.
    var fail = 0
    val cap = 4
    var used0 = 0
    var used1 = 0
    var used2 = 0
    var used3 = 0
    var data0 = 0
    var data1 = 0
    var live_count = 0
    var overflows = 0

    if cap * 4096 != 16384:
        fail = fail + 1
    used0 = 1
    used1 = 1
    live_count = 2
    data0 = 0x123 & 0xFF
    data1 = 0x45 & 0xFF
    if data0 != 0x23 or data1 != 0x45 or rv32_dram_used(live_count, cap) != 2:
        fail = fail + 1
    if rv32_dram_used(-3, cap) != 0:
        fail = fail + 1
    if rv32_dram_used(1, -1) != 0:
        fail = fail + 1
    if rv32_dram_used(cap, cap) != cap:
        fail = fail + 1
    if rv32_dram_used(99, cap) != cap:
        fail = fail + 1
    if used2 == 0:
        overflows = overflows + 1
    if overflows != 1:
        fail = fail + 1
    used0 = 0
    used1 = 0
    live_count = 0
    if rv32_dram_used(live_count, cap) != 0:
        fail = fail + 1
    used0 = 1
    used1 = 1
    used2 = 1
    used3 = 1
    live_count = 4
    if live_count >= cap:
        overflows = overflows + 1
    if overflows != 2:
        fail = fail + 1

    # GC reserve/write-cliff floor: host stops at reserve, GC frees scratch, write resumes.
    var free_blocks = 2
    val gc_reserve = 2
    var status = 0
    if free_blocks <= gc_reserve:
        status = 0x82
    if status != 0x82:
        fail = fail + 1
    var lba1_value = 1001
    var victim_live = lba1_value
    if victim_live != 1001:
        fail = fail + 1
    free_blocks = free_blocks + 1
    if free_blocks <= gc_reserve:
        status = 0x82
    else:
        status = 0
    if status != 0 or victim_live != 1001:
        fail = fail + 1

    # Durability floor: checkpointed value visible after crash; WAL replay restores newer writes/trims.
    var l2p10 = 1010
    var l2p20 = 1020
    var cache10 = 9999
    var cache30 = 1030
    var trim20 = 1
    var wal_count = 3
    var post_crash_10 = l2p10
    val pre_trim_20 = l2p20
    var post_crash_30 = 0
    if post_crash_10 != 1010 or post_crash_30 != 0:
        fail = fail + 1
    if wal_count > 0:
        l2p10 = cache10
        if trim20 == 1:
            l2p20 = -1
        post_crash_30 = cache30
        if l2p10 != 9999 or post_crash_30 != 1030:
            fail = fail + 1
    if (trim20 == 1 and l2p20 != -1) or (trim20 != 1 and l2p20 != pre_trim_20):
        fail = fail + 1
    trim20 = 0
    l2p20 = pre_trim_20
    if trim20 == 1:
        l2p20 = -1
    if l2p20 != pre_trim_20:
        fail = fail + 1
    var writes = 600
    var wal_cap = 512
    var checkpointed = 0
    if writes > wal_cap:
        checkpointed = 1
    if checkpointed != 1:
        fail = fail + 1
    writes = wal_cap
    checkpointed = 0
    if writes >= wal_cap:
        checkpointed = 1
    if checkpointed != 1:
        fail = fail + 1
    writes = wal_cap - 1
    checkpointed = 0
    if writes >= wal_cap:
        checkpointed = 1
    if checkpointed != 0:
        fail = fail + 1
    fail

