# RV32 no-alloc NVMe firmware logic reference.
#
# Aggregates scalar-only selftest sections split across small files so the
# self-hosted parser does not spend minutes on one oversized module.

use logic_rain.{rv32_rain_selftest}
use logic_ecc.{rv32_ecc_selftest}
use logic_journal.{rv32_journal_selftest}
use logic_map.{rv32_map_selftest}
use logic_band.{rv32_band_selftest}
use logic_sched.{rv32_sched_selftest}
use logic_power_thermal.{rv32_pt_selftest}
use logic_hil.{rv32_hil_selftest}
use logic_admin.{rv32_admin_selftest}
use logic_reactor.{rv32_reactor_selftest}
use logic_policy_target.{rv32_policy_target_selftest}
use logic_dram_durability.{rv32_dram_durability_selftest}
use logic_wear_scrub.{rv32_wear_scrub_selftest}
use logic_media_retire.{rv32_media_retire_selftest}
use logic_power_cycle.{rv32_power_cycle_selftest}
use logic_backpressure_abort.{rv32_backpressure_abort_selftest}
use logic_feature_guard.{rv32_feature_guard_selftest}
use logic_queue_phase.{rv32_queue_phase_selftest}
use logic_io_command.{rv32_io_command_selftest}
use logic_flush.{rv32_flush_selftest}
use logic_namespace_guard.{rv32_namespace_guard_selftest}

fn _nvme_fw_rv32_section_flag(result: i64, bit: i64) -> i64:
    if result != 0:
        return bit
    0

fn nvme_fw_rv32_logic_selftest() -> i64:
    var fail = 0
    fail = fail + _nvme_fw_rv32_section_flag(rv32_rain_selftest(), 1)
    fail = fail + _nvme_fw_rv32_section_flag(rv32_ecc_selftest(), 2)
    fail = fail + _nvme_fw_rv32_section_flag(rv32_journal_selftest(), 4)
    fail = fail + _nvme_fw_rv32_section_flag(rv32_map_selftest(), 8)
    fail = fail + _nvme_fw_rv32_section_flag(rv32_band_selftest(), 16)
    fail = fail + _nvme_fw_rv32_section_flag(rv32_sched_selftest(), 32)
    fail = fail + _nvme_fw_rv32_section_flag(rv32_pt_selftest(), 64)
    fail = fail + _nvme_fw_rv32_section_flag(rv32_hil_selftest(), 128)
    fail = fail + _nvme_fw_rv32_section_flag(rv32_queue_phase_selftest(), 256)
    fail = fail + _nvme_fw_rv32_section_flag(rv32_io_command_selftest(), 512)
    fail = fail + _nvme_fw_rv32_section_flag(rv32_flush_selftest(), 1024)
    fail = fail + _nvme_fw_rv32_section_flag(rv32_admin_selftest(), 2048)
    fail = fail + _nvme_fw_rv32_section_flag(rv32_reactor_selftest(), 4096)
    fail = fail + _nvme_fw_rv32_section_flag(rv32_policy_target_selftest(), 8192)
    fail = fail + _nvme_fw_rv32_section_flag(rv32_dram_durability_selftest(), 16384)
    fail = fail + _nvme_fw_rv32_section_flag(rv32_wear_scrub_selftest(), 32768)
    fail = fail + _nvme_fw_rv32_section_flag(rv32_media_retire_selftest(), 65536)
    fail = fail + _nvme_fw_rv32_section_flag(rv32_power_cycle_selftest(), 131072)
    fail = fail + _nvme_fw_rv32_section_flag(rv32_backpressure_abort_selftest(), 262144)
    fail = fail + _nvme_fw_rv32_section_flag(rv32_feature_guard_selftest(), 524288)
    fail = fail + _nvme_fw_rv32_section_flag(rv32_namespace_guard_selftest(), 1048576)
    fail
