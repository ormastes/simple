# RV32 no-alloc NVMe firmware logic reference.
#
# Scalar-only: no arrays, no heap, no strings in the logic path. Host and bare-metal entries share
# this so P9 evidence exercises the same RAIN + ECC + fixed map-cache + journal-ring floor.

fn rv32_rain_selftest() -> i64:
    val d0 = 256
    val d1 = 263
    val d2 = 270
    val d3 = 277
    val d4 = 284
    val d5 = 291
    val d6 = 298
    val d7 = 305
    val parity = d0 ^ d1 ^ d2 ^ d3 ^ d4 ^ d5 ^ d6 ^ d7

    var fail = 0
    if (parity ^ d1 ^ d2 ^ d3 ^ d4 ^ d5 ^ d6 ^ d7) != d0:
        fail = fail + 1
    if (parity ^ d0 ^ d2 ^ d3 ^ d4 ^ d5 ^ d6 ^ d7) != d1:
        fail = fail + 1
    if (parity ^ d0 ^ d1 ^ d3 ^ d4 ^ d5 ^ d6 ^ d7) != d2:
        fail = fail + 1
    if (parity ^ d0 ^ d1 ^ d2 ^ d4 ^ d5 ^ d6 ^ d7) != d3:
        fail = fail + 1
    if (parity ^ d0 ^ d1 ^ d2 ^ d3 ^ d5 ^ d6 ^ d7) != d4:
        fail = fail + 1
    if (parity ^ d0 ^ d1 ^ d2 ^ d3 ^ d4 ^ d6 ^ d7) != d5:
        fail = fail + 1
    if (parity ^ d0 ^ d1 ^ d2 ^ d3 ^ d4 ^ d5 ^ d7) != d6:
        fail = fail + 1
    if (parity ^ d0 ^ d1 ^ d2 ^ d3 ^ d4 ^ d5 ^ d6) != d7:
        fail = fail + 1

    val recovered3 = parity ^ d0 ^ d1 ^ d2 ^ d4 ^ d5 ^ d6 ^ d7
    if recovered3 != d3:
        fail = fail + 1
    fail

fn rv32_bit(v: i64, bit: i64) -> i64:
    (v >> bit) & 1

fn rv32_ecc_parity_pos(pos: i64) -> bool:
    pos == 1 or pos == 2 or pos == 4 or pos == 8 or pos == 16

fn rv32_ecc_pos_for_data_bit(bit: i64) -> i64:
    var pos = 1
    var seen = 0
    while pos <= 22:
        if not rv32_ecc_parity_pos(pos):
            if seen == bit:
                return pos
            seen = seen + 1
        pos = pos + 1
    0

fn rv32_ecc_payload(data: i64) -> i64:
    var p1 = 0
    var p2 = 0
    var p4 = 0
    var p8 = 0
    var p16 = 0
    var overall = 0
    var pos = 1
    var data_bit = 0
    while pos <= 22:
        if not rv32_ecc_parity_pos(pos):
            val bit = rv32_bit(data, data_bit)
            overall = overall ^ bit
            if (pos & 1) != 0:
                p1 = p1 ^ bit
            if (pos & 2) != 0:
                p2 = p2 ^ bit
            if (pos & 4) != 0:
                p4 = p4 ^ bit
            if (pos & 8) != 0:
                p8 = p8 ^ bit
            if (pos & 16) != 0:
                p16 = p16 ^ bit
            data_bit = data_bit + 1
        pos = pos + 1
    p1 | (p2 << 1) | (p4 << 2) | (p8 << 3) | (p16 << 4) | (overall << 5)

fn rv32_ecc_flip_data_pos(data: i64, pos: i64) -> i64:
    var bit = 0
    while bit < 17:
        if rv32_ecc_pos_for_data_bit(bit) == pos:
            return data ^ (1 << bit)
        bit = bit + 1
    data

fn rv32_ecc_status(data: i64, stored: i64) -> i64:
    val recomputed = rv32_ecc_payload(data)
    val syndrome = (stored ^ recomputed) & 0x1F
    val overall = ((stored >> 5) ^ (recomputed >> 5)) & 1
    if syndrome == 0:
        if overall == 0:
            return 0
        return 1
    if overall == 0:
        return 2
    1

fn rv32_ecc_correct(data: i64, stored: i64) -> i64:
    val recomputed = rv32_ecc_payload(data)
    val syndrome = (stored ^ recomputed) & 0x1F
    val overall = ((stored >> 5) ^ (recomputed >> 5)) & 1
    if syndrome != 0 and overall != 0 and not rv32_ecc_parity_pos(syndrome):
        return rv32_ecc_flip_data_pos(data, syndrome)
    data

fn rv32_ecc_selftest() -> i64:
    var fail = 0
    val data = 0x123456
    val stored = rv32_ecc_payload(data)
    val one = 0x133456
    if rv32_ecc_status(one, stored) != 1:
        fail = fail + 1
    if rv32_ecc_correct(one, stored) != data:
        fail = fail + 1
    val two = data ^ 1 ^ 2
    if rv32_ecc_status(two, stored) != 2:
        fail = fail + 1
    fail

fn rv32_journal_effective_count(count: i64, cap: i64) -> i64:
    if count < 0:
        return 0
    if cap < 0:
        return 0
    var c = cap
    if c > 4:
        c = 4
    if count > c:
        return c
    count

fn rv32_journal_selftest() -> i64:
    # Four scalar slots stand in for the host Journal's pre-sized WAL arrays.
    var fail = 0
    var cap = 4
    var count = 0
    var ckpt_seq = 0
    var ckpt_valid = 0
    var sb_gen = 0
    var sb_ckpt_ptr = -1

    var lba0 = -1
    var new0 = -1
    var seq0 = 0
    var lba1 = -1
    var new1 = -1
    var seq1 = 0
    var lba2 = -1
    var new2 = -1
    var seq2 = 0
    var lba3 = -1
    var new3 = -1
    var seq3 = 0

    if rv32_journal_effective_count(-3, cap) != 0:
        fail = fail + 1
    if rv32_journal_effective_count(6, cap) != 4:
        fail = fail + 1
    if rv32_journal_effective_count(1, -1) != 0:
        fail = fail + 1

    lba0 = 100
    new0 = 20
    seq0 = 1
    count = count + 1
    lba1 = 101
    new1 = 21
    seq1 = 2
    count = count + 1
    lba2 = 102
    new2 = 22
    seq2 = 3
    count = count + 1
    if count != 3:
        fail = fail + 1
    if lba0 != 100 or new0 != 20 or seq0 != 1:
        fail = fail + 1
    if lba2 != 102 or new2 != 22 or seq2 != 3:
        fail = fail + 1

    lba3 = 103
    new3 = 23
    seq3 = 4
    count = count + 1
    if rv32_journal_effective_count(count, cap) != 4:
        fail = fail + 1
    if rv32_journal_effective_count(count + 1, cap) != 4:
        fail = fail + 1

    ckpt_seq = 2
    ckpt_valid = 1
    sb_gen = sb_gen + 1
    sb_ckpt_ptr = ckpt_seq
    if ckpt_valid != 1 or sb_gen != 1 or sb_ckpt_ptr != 2:
        fail = fail + 1

    # Truncate checkpointed records: seq 3 and 4 survive and compact into slots 0 and 1.
    lba0 = lba2
    new0 = new2
    seq0 = seq2
    lba1 = lba3
    new1 = new3
    seq1 = seq3
    lba2 = -1
    new2 = -1
    seq2 = 0
    lba3 = -1
    new3 = -1
    seq3 = 0
    count = 2
    if count != 2:
        fail = fail + 1
    if lba0 != 102 or new0 != 22 or seq0 != 3:
        fail = fail + 1
    if lba1 != 103 or new1 != 23 or seq1 != 4:
        fail = fail + 1
    if lba2 != -1 or new2 != -1 or seq2 != 0:
        fail = fail + 1

    ckpt_seq = 4
    sb_gen = sb_gen + 1
    sb_ckpt_ptr = ckpt_seq
    if sb_gen != 2 or sb_ckpt_ptr != 4:
        fail = fail + 1
    fail

fn rv32_map_cap_limit(cap: i64) -> i64:
    if cap < 0:
        return 0
    if cap > 4:
        return 4
    cap

fn rv32_map_lba_valid(lba: i64) -> bool:
    lba >= 0 and lba < 128

fn rv32_map_ppn_valid(ppn: i64) -> bool:
    ppn == -1 or (ppn >= 0 and ppn < 4096)

fn rv32_map_sanitize_ppn(ppn: i64) -> i64:
    if rv32_map_ppn_valid(ppn):
        return ppn
    -1

fn rv32_map_selftest() -> i64:
    # Four scalar slots stand in for the host L2pMap's pre-sized write-back cache.
    var fail = 0
    var cap = 4
    var tick = 0
    var hits = 0
    var misses = 0
    var evicts = 0

    var l2p10 = -1
    var l2p11 = -1
    var l2p12 = -1
    var l2p13 = -1

    var lba0 = -1
    var ppn0 = -1
    var dirty0 = 0
    var age0 = 0
    var lba1 = -1
    var ppn1 = -1
    var dirty1 = 0
    var age1 = 0
    var lba2 = -1
    var ppn2 = -1
    var dirty2 = 0
    var age2 = 0
    var lba3 = -1
    var ppn3 = -1
    var dirty3 = 0
    var age3 = 0

    if rv32_map_cap_limit(-1) != 0:
        fail = fail + 1
    if rv32_map_cap_limit(7) != 4:
        fail = fail + 1
    if rv32_map_sanitize_ppn(4096) != -1:
        fail = fail + 1
    if rv32_map_lba_valid(128):
        fail = fail + 1

    # update(10, 100), then lookup(10): served from dirty cache, not backing L2P.
    if rv32_map_lba_valid(10) and rv32_map_ppn_valid(100):
        tick = tick + 1
        lba0 = 10
        ppn0 = 100
        dirty0 = 1
        age0 = tick
    if lba0 == 10:
        hits = hits + 1
        tick = tick + 1
        age0 = tick
        if rv32_map_sanitize_ppn(ppn0) != 100:
            fail = fail + 1
    if hits != 1 or l2p10 != -1:
        fail = fail + 1

    # flush(): dirty cache entry becomes the authoritative flash-resident L2P.
    if dirty0 == 1 and lba0 == 10 and rv32_map_ppn_valid(ppn0):
        l2p10 = ppn0
        dirty0 = 0
    if l2p10 != 100 or dirty0 != 0:
        fail = fail + 1

    # crash_volatile(): cache is gone, backing L2P survives.
    lba0 = -1
    ppn0 = -1
    age0 = 0
    tick = 0
    misses = misses + 1
    if lba0 != -1 or ppn0 != -1 or l2p10 != 100:
        fail = fail + 1
    if misses != 1:
        fail = fail + 1

    # Fill all slots, then evict the oldest dirty entry on the next distinct update.
    lba0 = 10
    ppn0 = 200
    dirty0 = 1
    age0 = 1
    lba1 = 11
    ppn1 = 201
    dirty1 = 1
    age1 = 2
    lba2 = 12
    ppn2 = 202
    dirty2 = 1
    age2 = 3
    lba3 = 13
    ppn3 = 203
    dirty3 = 1
    age3 = 4
    tick = 4
    if rv32_map_cap_limit(cap) == 4 and age0 < age1 and age0 < age2 and age0 < age3:
        if dirty0 == 1 and lba0 == 10 and rv32_map_ppn_valid(ppn0):
            l2p10 = ppn0
        evicts = evicts + 1
        tick = tick + 1
        lba0 = 14
        ppn0 = 204
        dirty0 = 1
        age0 = tick
    if l2p10 != 200 or lba0 != 14 or ppn0 != 204 or evicts != 1:
        fail = fail + 1

    # Invalid writes are inert.
    if rv32_map_lba_valid(12) and rv32_map_ppn_valid(4096):
        l2p12 = 4096
    if l2p12 != -1:
        fail = fail + 1
    if l2p11 != -1 or l2p13 != -1:
        fail = fail + 1
    fail

fn nvme_fw_rv32_logic_selftest() -> i64:
    rv32_rain_selftest() + rv32_ecc_selftest() + rv32_journal_selftest() + rv32_map_selftest()
