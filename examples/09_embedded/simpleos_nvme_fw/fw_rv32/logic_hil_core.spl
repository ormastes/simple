fn rv32_hil_validate(cid: i64, op: i64, lba: i64, nblocks: i64, data: i64) -> i32:
    if cid < 0:
        return 1
    if cid > 65535:
        return 1
    if op < 1:
        return 1
    if op > 4:
        return 1
    if lba < 0:
        return 1
    if nblocks <= 0:
        return 1
    if op == 2 and data == 0:
        return 1
    0
