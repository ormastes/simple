#!/bin/sh
# Build the bare-metal RV32 NVMe-firmware on-device self-test ELF (gap-closure P9).
#
# STATUS (2026-06-30): native-build exits 255 with no diagnostic for this standalone
# bare-metal entry — see doc/08_tracking/bug/native_build_rv32_baremetal_silent_255_2026-06-30.md.
# The entry is `bin/simple check`-clean and the QEMU rv32 boot path works (boot.shs boots the
# prebuilt OS ELF); only this build step is blocked. Recipe kept so it runs once that is fixed.
#
# Usage: sh examples/09_embedded/simpleos_nvme_fw/fw_rv32/build.shs
set -e
cd "$(git rev-parse --show-toplevel 2>/dev/null || echo .)"
OUT="build/nvme_fw_rv32.elf"
rm -f "$OUT"
SIMPLE_BOOTSTRAP=1 bin/simple native-build --backend llvm \
  --source src/os --source src/lib \
  --source examples/09_embedded/simpleos_nvme_fw/fw_rv32 \
  --entry examples/09_embedded/simpleos_nvme_fw/fw_rv32/entry.spl --entry-closure \
  --linker-script src/os/kernel/arch/riscv32/linker.ld \
  --target riscv32-unknown-none \
  -o "$OUT"
echo "build exit=$?"
ls -la "$OUT" 2>/dev/null && file "$OUT" 2>/dev/null
