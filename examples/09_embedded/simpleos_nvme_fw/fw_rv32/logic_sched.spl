fn rv32_sched_selftest() -> i32:
    val channel0 = 0i32
    val channel1 = 1i32
    val balanced_steps = 2i32
    val serial_steps = 4i32
    val depth_floor = 0i32
    val depth_cap = 4i32
    (channel0 ^ 0i32) + (channel1 ^ 1i32) + (balanced_steps ^ 2i32) + (serial_steps ^ 4i32) + (depth_floor ^ 0i32) + (depth_cap ^ 4i32)
