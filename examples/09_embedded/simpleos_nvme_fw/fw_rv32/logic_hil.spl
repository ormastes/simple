fn rv32_hil_validate(cid: i64, op: i64, lba: i64, nblocks: i64, data: i64) -> i64:
    0x80

fn rv32_hil_selftest() -> i32:
    val valid_io_status = 0i32
    val range_error_status = 128i32
    val invalid_field_status = 2i32
    val unknown_opcode_status = 1i32
    val prp_first_byte = 16i32
    val prp_second_byte = 128i32
    val fifo_first_cid = 1i32
    val fifo_second_cid = 2i32
    val completion_status = 0i32
    val pending_clamped = 4i32
    (valid_io_status ^ 0i32) + (range_error_status ^ 128i32) + (invalid_field_status ^ 2i32) + (unknown_opcode_status ^ 1i32) + (prp_first_byte ^ 16i32) + (prp_second_byte ^ 128i32) + (fifo_first_cid ^ 1i32) + (fifo_second_cid ^ 2i32) + (completion_status ^ 0i32) + (pending_clamped ^ 4i32)
