fn rv32_hil_cid_valid(cid: i64) -> bool:
    cid >= 0 and cid <= 65535

fn rv32_hil_known_opcode(op: i64) -> bool:
    op == 0 or op == 1 or op == 2 or op == 8 or op == 9

fn rv32_hil_validate(cid: i64, op: i64, lba: i64, nblocks: i64, data: i64) -> i64:
    if not rv32_hil_cid_valid(cid):
        return 2
    if not rv32_hil_known_opcode(op):
        return 1
    if op == 0:
        if lba != 0 or nblocks != 0 or data != 0:
            return 2
        return 0
    if lba < 0:
        return 0x80
    if nblocks <= 0:
        return 0x80
    if lba >= 3072:
        return 0x80
    if nblocks > 3072:
        return 0x80
    if lba > 3072 - nblocks:
        return 0x80
    if op == 9 and data != 0:
        return 2
    if op == 8 and data != 0:
        return 2
    if op == 2 and data != 0:
        return 2
    0

fn rv32_hil_prp_pack(first_base: i64, second_base: i64) -> i64:
    (first_base & 0xFF) | ((second_base & 0xFF) << 8)

fn rv32_hil_prp_byte(data: i64, i: i64) -> i64:
    if i < 0:
        return 0
    val first = data & 0xFF
    val second = (data >> 8) & 0xFF
    if second == 0:
        return (first + i) & 0xFF
    if i < 2:
        return (first + i) & 0xFF
    (second + (i - 2)) & 0xFF

fn rv32_hil_pending(len: i64, depth: i64) -> i64:
    if len < 0:
        return 0
    if depth < 0:
        return 0
    if len > depth:
        return depth
    len

fn rv32_hil_selftest() -> i64:
    # Four scalar ring slots mirror the queue invariants without arrays or heap.
    var fail = 0
    val depth = 4
    var sq_head = 0
    var sq_tail = 0
    var sq_len = 0
    var cq_head = 0
    var cq_tail = 0
    var cq_len = 0
    var cid0 = -1
    var cid1 = -1
    var cid2 = -1
    var cid3 = -1
    var cpl_cid0 = -1
    var cpl_status0 = -1

    if rv32_hil_validate(1, 1, 100, 16, 7) != 0:
        fail = fail + 1
    if rv32_hil_validate(2, 1, 3071, 1, 0) != 0:
        fail = fail + 1
    if rv32_hil_validate(26, 1, 3070, 2, 0) != 0:
        fail = fail + 1
    if rv32_hil_validate(3, 1, -1, 1, 0) != 0x80:
        fail = fail + 1
    if rv32_hil_validate(4, 1, 0, 3072, 0) != 0:
        fail = fail + 1
    if rv32_hil_validate(5, 1, 3072, 1, 0) != 0x80:
        fail = fail + 1
    if rv32_hil_validate(6, 1, 0, 3073, 0) != 0x80:
        fail = fail + 1
    if rv32_hil_validate(0, 1, 100, 1, 7) != 0:
        fail = fail + 1
    if rv32_hil_validate(65535, 1, 100, 1, 7) != 0:
        fail = fail + 1
    if rv32_hil_validate(65536, 1, 100, 1, 7) != 2:
        fail = fail + 1
    if rv32_hil_validate(-1, 1, 100, 1, 7) != 2:
        fail = fail + 1
    if rv32_hil_validate(14, 0x7F, 0, 1, 0) != 1:
        fail = fail + 1
    if rv32_hil_validate(20, -1, 0, 1, 0) != 1:
        fail = fail + 1
    if rv32_hil_validate(11, 1, 3000, 100, 0) != 0x80:
        fail = fail + 1
    if rv32_hil_validate(15, 1, 9223372036854775000, 9223372036854775000, 0) != 0x80:
        fail = fail + 1
    if rv32_hil_validate(13, 0, 0, 0, 0) != 0:
        fail = fail + 1
    if rv32_hil_validate(12, 0, 7, 0, 0) != 2:
        fail = fail + 1
    if rv32_hil_validate(16, 0, 0, 1, 0) != 2:
        fail = fail + 1
    if rv32_hil_validate(17, 0, 0, 0, 9) != 2:
        fail = fail + 1
    if rv32_hil_validate(18, 0, 7, 1, 9) != 2:
        fail = fail + 1
    if rv32_hil_validate(19, 9, 10, 1, 7) != 2:
        fail = fail + 1
    if rv32_hil_validate(24, 9, 10, 1, 0) != 0:
        fail = fail + 1
    if rv32_hil_validate(23, 8, 10, 1, 7) != 2:
        fail = fail + 1
    if rv32_hil_validate(22, 8, 10, 1, 0) != 0:
        fail = fail + 1
    if rv32_hil_validate(25, 2, 10, 1, 7) != 2:
        fail = fail + 1
    if rv32_hil_validate(21, 2, 10, 1, 0) != 0:
        fail = fail + 1
    if rv32_hil_validate(33, 1, 10, 0, 0) != 0x80:
        fail = fail + 1
    if rv32_hil_validate(30, 2, 10, 0, 0) != 0x80:
        fail = fail + 1
    if rv32_hil_validate(31, 8, 10, 0, 0) != 0x80:
        fail = fail + 1
    if rv32_hil_validate(32, 9, 10, 0, 0) != 0x80:
        fail = fail + 1
    val packed = rv32_hil_prp_pack(0x10, 0x80)
    if rv32_hil_prp_byte(packed, 2) != 0x80:
        fail = fail + 1
    if rv32_hil_prp_byte(packed, -1) != 0:
        fail = fail + 1
    if rv32_hil_prp_byte(packed, 0) != 0x10 or rv32_hil_prp_byte(packed, 3) != 0x81:
        fail = fail + 1
    val single_prp = rv32_hil_prp_pack(0x20, 0)
    if rv32_hil_prp_byte(single_prp, 2) != 0x22:
        fail = fail + 1

    # Submit two commands, fetch FIFO, and leave the ring empty.
    cid0 = 1
    sq_tail = (sq_tail + 1) % depth
    sq_len = sq_len + 1
    cid1 = 2
    sq_tail = (sq_tail + 1) % depth
    sq_len = sq_len + 1
    if rv32_hil_pending(sq_len, depth) != 2:
        fail = fail + 1
    val f0 = cid0
    sq_head = (sq_head + 1) % depth
    sq_len = sq_len - 1
    val f1 = cid1
    sq_head = (sq_head + 1) % depth
    sq_len = sq_len - 1
    if f0 != 1 or f1 != 2 or rv32_hil_pending(sq_len, depth) != 0:
        fail = fail + 1

    sq_len = -3
    if rv32_hil_pending(sq_len, depth) != 0:
        fail = fail + 1
    sq_len = depth + 3
    if rv32_hil_pending(sq_len, depth) != depth:
        fail = fail + 1
    sq_len = depth
    if rv32_hil_pending(sq_len, depth) != depth:
        fail = fail + 1
    sq_len = 0

    # Fill across the wrap boundary; a fifth submit is refused by the full-ring guard.
    cid2 = 100
    sq_tail = 3
    sq_head = 3
    sq_len = 0
    cid3 = 101
    sq_tail = 0
    sq_len = sq_len + 1
    cid0 = 102
    sq_tail = 1
    sq_len = sq_len + 1
    cid1 = 103
    sq_tail = 2
    sq_len = sq_len + 1
    cid2 = 104
    sq_tail = 3
    sq_len = sq_len + 1
    if sq_len != depth:
        fail = fail + 1
    if sq_len < depth:
        cid3 = 999
    if cid3 != 101:
        fail = fail + 1

    cpl_cid0 = 42
    cpl_status0 = 0
    cq_tail = (cq_tail + 1) % depth
    cq_len = cq_len + 1
    if rv32_hil_pending(cq_len, depth) != 1:
        fail = fail + 1
    val rcid = cpl_cid0
    val rstatus = cpl_status0
    cq_head = (cq_head + 1) % depth
    cq_len = cq_len - 1
    if rcid != 42 or rstatus != 0 or cq_len != 0:
        fail = fail + 1
    cq_len = -4
    if rv32_hil_pending(cq_len, depth) != 0:
        fail = fail + 1
    if rv32_hil_pending(1, -1) != 0:
        fail = fail + 1
    fail
