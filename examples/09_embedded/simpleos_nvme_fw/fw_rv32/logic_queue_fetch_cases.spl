use logic_queue_phase_core.*

fn rv32_queue_fetch_cases_selftest() -> i32:
    if _rv32_queue_fetch_valid(1, 0, 64) != 0:
        return 1
    if _rv32_queue_fetch_valid(0, 0, 64) == 0:
        return 1
    if _rv32_queue_fetch_valid(1, -1, 64) == 0:
        return 1
    if _rv32_queue_fetch_valid(1, 64, 64) == 0:
        return 1
    if _rv32_queue_next(63, 64) != 0:
        return 1
    if _rv32_queue_next(2, 64) != 3:
        return 1
    0
