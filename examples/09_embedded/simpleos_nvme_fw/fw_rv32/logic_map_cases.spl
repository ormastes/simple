use logic_map_flush_cases.*
use logic_map_update_cases.*
use logic_map_valid_cases.*

fn rv32_map_cases_selftest() -> i32:
    if rv32_map_valid_cases_selftest() != 0:
        return 1
    if rv32_map_update_cases_selftest() != 0:
        return 1
    if rv32_map_flush_cases_selftest() != 0:
        return 1
    0
