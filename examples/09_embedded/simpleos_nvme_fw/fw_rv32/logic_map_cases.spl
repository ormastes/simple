use logic_map_core.*

fn rv32_map_cases_selftest() -> i32:
    if _rv32_map_lba_valid(0) != 1:
        return 1
    if _rv32_map_lba_valid(1023) != 1:
        return 1
    if _rv32_map_lba_valid(-1) != 0:
        return 1
    if _rv32_map_lba_valid(1024) != 0:
        return 1
    if _rv32_map_ppn_valid(-1) != 1:
        return 1
    if _rv32_map_ppn_valid(4095) != 1:
        return 1
    if _rv32_map_ppn_valid(4096) != 0:
        return 1
    if _rv32_map_sanitize_ppn(4096) != -1:
        return 1
    if _rv32_map_counter(-3) != 0:
        return 1
    if _rv32_map_dirty_after_update(10, 100) != 1:
        return 1
    if _rv32_map_dirty_after_update(1024, 100) != 0:
        return 1
    if _rv32_map_dirty_after_update(10, 4096) != 0:
        return 1
    if _rv32_map_l2p_after_flush(10, 100, 1) != 100:
        return 1
    if _rv32_map_l2p_after_flush(10, 100, 0) != -1:
        return 1
    if _rv32_map_l2p_after_flush(1024, 100, 1) != -1:
        return 1
    if _rv32_map_l2p_after_crash(77) != 77:
        return 1
    if _rv32_map_l2p_after_crash(4096) != -1:
        return 1
    0
