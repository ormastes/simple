# NVMe firmware — bare-metal RV32 on-device self-test (gap-closure P9).
#
# Array-free, scalar re-expression of the firmware's core RAIN parity reconstruct
# (../fw/rain.spl, proven in ../fw/proofs/Rain.lean) so it can run inside the bare-metal rv32
# boot path with NO heap and NO arrays — matching the constraint documented in
# src/os/kernel/arch/riscv32/boot.spl ("keep this module freestanding and minimal ... without
# pulling runtime formatting, arrays, or boot metadata into the first-stage entry object").
# UART output uses rt_riscv_uart_put exactly like boot.spl's `_line_*` helpers — one byte at a
# time, no string runtime.
#
# Integration: call `nvme_fw_rv32_selftest()` from the rv32 boot chain (boot.spl `boot_main`,
# after `riscv_noalloc_log_init`), then build with the proven recipe (fw_rv32/build.shs) and boot
# (fw_rv32/boot.shs). It prints `ALL RV32 NVME FW CHECKS PASS` on success.
#
# BUILD STATUS (2026-06-30): the native-build TOOLCHAIN bug is FIXED — `native-build --target
# riscv32-unknown-none` now routes to the in-process Rust LLVM handler, compiles this entry to
# riscv objects, and links with real errors (previously a silent 255). The remaining blocker to
# an *observed boot* is the incomplete bare-metal rv32 RUNTIME: the freestanding link has no
# `rt_native_eq`/`rt_native_neq` (emitted for `==`/`!=`), no `rt_riscv_uart_put` (the C stub is
# riscv64-only), and no rooted bare-metal `_start` (without one the linker GCs all code; the
# build's `__simple_sandbox_start` wrapper is not a bare-metal entry). Verified NOT resolved by
# `--release` or `--runtime-bundle`, so it is a genuine runtime gap, not an opt/config artifact.
# Tracked in doc/08_tracking/bug/native_build_rv32_baremetal_silent_255_2026-06-30.md. The
# self-test logic below is host-verified (XOR-cancel reproduces fail=0); completing the
# freestanding rv32 runtime + entry is the next step. Full 22-module no-alloc port is the ceiling.

extern fn rt_riscv_uart_put(byte: u64)

fn _uart_put(byte: i64):
    rt_riscv_uart_put(byte as u64)

# Emit a NUL-terminated-style fixed byte sequence one byte at a time (no arrays, no string
# runtime, no `;` statement separators — native-build's parser rejects those).
fn _emit_pass():
    # "ALL RV32 NVME FW CHECKS PASS\n"
    _uart_put(65)
    _uart_put(76)
    _uart_put(76)
    _uart_put(32)
    _uart_put(82)
    _uart_put(86)
    _uart_put(51)
    _uart_put(50)
    _uart_put(32)
    _uart_put(78)
    _uart_put(86)
    _uart_put(77)
    _uart_put(69)
    _uart_put(32)
    _uart_put(70)
    _uart_put(87)
    _uart_put(32)
    _uart_put(67)
    _uart_put(72)
    _uart_put(69)
    _uart_put(67)
    _uart_put(75)
    _uart_put(83)
    _uart_put(32)
    _uart_put(80)
    _uart_put(65)
    _uart_put(83)
    _uart_put(83)
    _uart_put(10)

fn _emit_fail():
    # "RV32 NVME FW FAIL\n"
    _uart_put(82)
    _uart_put(86)
    _uart_put(51)
    _uart_put(50)
    _uart_put(32)
    _uart_put(78)
    _uart_put(86)
    _uart_put(77)
    _uart_put(69)
    _uart_put(32)
    _uart_put(70)
    _uart_put(87)
    _uart_put(32)
    _uart_put(70)
    _uart_put(65)
    _uart_put(73)
    _uart_put(76)
    _uart_put(10)

# RAIN reconstruct on 8 scalar channels (no arrays): parity = XOR of all channels; for any lost
# channel, parity XOR the survivors recovers the exact lost word (XOR is its own inverse). This is
# the property proven in ../fw/proofs/Rain.lean, exercised here entirely with scalars.
fn nvme_fw_rv32_selftest() -> i64:
    val d0 = 256
    val d1 = 263
    val d2 = 270
    val d3 = 277
    val d4 = 284
    val d5 = 291
    val d6 = 298
    val d7 = 305
    val parity = d0 ^ d1 ^ d2 ^ d3 ^ d4 ^ d5 ^ d6 ^ d7

    var fail = 0
    # Lose each channel in turn; parity XOR the seven survivors must equal the lost word.
    if (parity ^ d1 ^ d2 ^ d3 ^ d4 ^ d5 ^ d6 ^ d7) != d0:
        fail = fail + 1
    if (parity ^ d0 ^ d2 ^ d3 ^ d4 ^ d5 ^ d6 ^ d7) != d1:
        fail = fail + 1
    if (parity ^ d0 ^ d1 ^ d3 ^ d4 ^ d5 ^ d6 ^ d7) != d2:
        fail = fail + 1
    if (parity ^ d0 ^ d1 ^ d2 ^ d4 ^ d5 ^ d6 ^ d7) != d3:
        fail = fail + 1
    if (parity ^ d0 ^ d1 ^ d2 ^ d3 ^ d5 ^ d6 ^ d7) != d4:
        fail = fail + 1
    if (parity ^ d0 ^ d1 ^ d2 ^ d3 ^ d4 ^ d6 ^ d7) != d5:
        fail = fail + 1
    if (parity ^ d0 ^ d1 ^ d2 ^ d3 ^ d4 ^ d5 ^ d7) != d6:
        fail = fail + 1
    if (parity ^ d0 ^ d1 ^ d2 ^ d3 ^ d4 ^ d5 ^ d6) != d7:
        fail = fail + 1

    # Channel-failure rebuild: with parity sealed, channel 3 goes uncorrectable; reconstruct it
    # from the parity and the surviving channels and confirm it matches the original word.
    val recovered3 = parity ^ d0 ^ d1 ^ d2 ^ d4 ^ d5 ^ d6 ^ d7
    if recovered3 != d3:
        fail = fail + 1

    if fail == 0:
        _emit_pass()
    else:
        _emit_fail()
    fail

fn main() -> i64:
    nvme_fw_rv32_selftest()
