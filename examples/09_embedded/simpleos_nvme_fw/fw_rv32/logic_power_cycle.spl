fn rv32_power_cycle_selftest() -> i64:
    # Scalar controller floor: SMART unsafe shutdowns follow dirty media state and VWC policy.
    var fail = 0
    var power_cycles = 0
    var unsafe_shutdowns = 0
    var dirty_since_checkpoint = 0
    var volatile_wc = 1
    var lba12 = 0

    dirty_since_checkpoint = 1
    dirty_since_checkpoint = 0
    power_cycles = power_cycles + 1
    if dirty_since_checkpoint == 1:
        unsafe_shutdowns = unsafe_shutdowns + 1
    if power_cycles != 1 or unsafe_shutdowns != 0:
        fail = fail + 1

    dirty_since_checkpoint = 1
    lba12 = 0x5A
    power_cycles = power_cycles + 1
    if dirty_since_checkpoint == 1:
        unsafe_shutdowns = unsafe_shutdowns + 1
    dirty_since_checkpoint = 0
    if power_cycles != 2 or unsafe_shutdowns != 1 or lba12 != 0x5A:
        fail = fail + 1

    dirty_since_checkpoint = 1
    power_cycles = power_cycles + 1
    if dirty_since_checkpoint == 1:
        unsafe_shutdowns = unsafe_shutdowns + 1
    dirty_since_checkpoint = 0
    if power_cycles != 3 or unsafe_shutdowns != 2 or lba12 != 0x5A:
        fail = fail + 1

    volatile_wc = 0
    dirty_since_checkpoint = 1
    if volatile_wc == 0:
        dirty_since_checkpoint = 0
    power_cycles = power_cycles + 1
    if dirty_since_checkpoint == 1:
        unsafe_shutdowns = unsafe_shutdowns + 1
    if power_cycles != 4 or unsafe_shutdowns != 2 or dirty_since_checkpoint != 0 or lba12 != 0x5A:
        fail = fail + 1

    volatile_wc = 1
    dirty_since_checkpoint = 0
    power_cycles = power_cycles + 1
    if dirty_since_checkpoint == 1:
        unsafe_shutdowns = unsafe_shutdowns + 1
    if power_cycles != 5 or unsafe_shutdowns != 2 or dirty_since_checkpoint != 0 or volatile_wc != 1 or lba12 != 0x5A:
        fail = fail + 1

    power_cycles = -3
    unsafe_shutdowns = -1
    if rv32_admin_smart_nonnegative(power_cycles) != 0:
        fail = fail + 1
    if rv32_admin_smart_nonnegative(unsafe_shutdowns) != 0:
        fail = fail + 1
    fail
