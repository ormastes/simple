fn _rv32_power_counter_clamped(value: i64) -> i64:
    if value < 0:
        return 0
    value

fn _rv32_power_cycles_after(power_cycles: i64) -> i64:
    _rv32_power_counter_clamped(power_cycles) + 1

fn _rv32_unsafe_after(unsafe_shutdowns: i64, dirty_since_checkpoint: i64) -> i64:
    val safe_unsafe: i64 = _rv32_power_counter_clamped(unsafe_shutdowns)
    if dirty_since_checkpoint != 0:
        return safe_unsafe + 1
    safe_unsafe

fn _rv32_dirty_after_checkpoint() -> i64:
    0

fn _rv32_dirty_after_write(write_status: i64, volatile_write_cache: i64) -> i64:
    if write_status != 0:
        return 0
    if volatile_write_cache == 0:
        return 0
    1

fn _rv32_dirty_after_power_cycle() -> i64:
    0

fn rv32_power_cycle_selftest() -> i32:
    if _rv32_power_counter_clamped(-1) != 0:
        return 1
    if _rv32_power_cycles_after(0) != 1:
        return 1
    if _rv32_power_cycles_after(-4) != 1:
        return 1
    if _rv32_unsafe_after(0, 0) != 0:
        return 1
    if _rv32_unsafe_after(0, 1) != 1:
        return 1
    if _rv32_unsafe_after(-3, 1) != 1:
        return 1
    if _rv32_dirty_after_checkpoint() != 0:
        return 1
    if _rv32_dirty_after_write(0, 1) != 1:
        return 1
    if _rv32_dirty_after_write(0, 0) != 0:
        return 1
    if _rv32_dirty_after_write(2, 1) != 0:
        return 1
    if _rv32_dirty_after_power_cycle() != 0:
        return 1
    0
