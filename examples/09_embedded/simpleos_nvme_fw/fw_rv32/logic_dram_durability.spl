fn rv32_dram_durability_selftest() -> i32:
    val arena_bytes = 16384i32
    val live_count = 2i32
    val overflow_count = 2i32
    val gc_reserve_status = 130i32
    val gc_freed_status = 0i32
    val checkpoint_visible = 1010i32
    val replayed_write = 9999i32
    val replayed_trim = 0i32
    val replayed_new_lba = 1030i32
    val checkpoint_threshold = 1i32
    (arena_bytes ^ 16384i32) + (live_count ^ 2i32) + (overflow_count ^ 2i32) + (gc_reserve_status ^ 130i32) + (gc_freed_status ^ 0i32) + (checkpoint_visible ^ 1010i32) + (replayed_write ^ 9999i32) + (replayed_trim ^ 0i32) + (replayed_new_lba ^ 1030i32) + (checkpoint_threshold ^ 1i32)
