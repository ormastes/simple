use logic_dram_durability_core.*

fn rv32_dram_durability_cases_selftest() -> i32:
    if _rv32_dram_effective_cap(16, 16, 16) != 16:
        return 1
    if _rv32_dram_effective_cap(99, 16, 16) != 16:
        return 1
    if _rv32_dram_effective_cap(-1, 16, 16) != 0:
        return 1
    if _rv32_dram_effective_cap(16, 8, 16) != 8:
        return 1
    if _rv32_dram_alloc_ok(2, 0, 16) != 1:
        return 1
    if _rv32_dram_alloc_ok(17, 0, 16) != 0:
        return 1
    if _rv32_dram_alloc_ok(2, 15, 16) != 0:
        return 1
    if _rv32_dram_stage_status(1, 0, 2, 1, 16, 1) != 0:
        return 1
    if _rv32_dram_stage_status(1, 0, 2, 2, 16, 1) != 130:
        return 1
    if _rv32_dram_stage_status(1, 16, 1, 0, 16, 1) != 130:
        return 1
    if _rv32_dram_stage_status(1, 5, 1, 0, 16, 0) != 130:
        return 1
    if _rv32_dram_mask_byte(291) != 35:
        return 1
    if _rv32_dram_used(-3, 16) != 0:
        return 1
    if _rv32_dram_used(99, 16) != 16:
        return 1
    if _rv32_dram_overflows(-1) != 0:
        return 1
    if _rv32_durability_after_crash(10, 1010, 1020) != 1010:
        return 1
    if _rv32_durability_after_crash(30, 1010, 1020) != 0:
        return 1
    if _rv32_durability_after_recover(10, 1010, 1020, 9999, 0, 1030) != 9999:
        return 1
    if _rv32_durability_after_recover(20, 1010, 1020, 9999, 0, 1030) != 0:
        return 1
    if _rv32_durability_after_recover(30, 1010, 1020, 9999, 0, 1030) != 1030:
        return 1
    if _rv32_journal_overflow_checkpointed(600, 512) != 1:
        return 1
    if _rv32_journal_overflow_checkpointed(512, 512) != 0:
        return 1
    0
