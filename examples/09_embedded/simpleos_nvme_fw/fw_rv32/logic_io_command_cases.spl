use logic_io_command_core.*

fn rv32_io_command_cases_selftest() -> i32:
    if _rv32_io_command_valid(1, 1, 0, 1, 7) != 0:
        return 1
    if _rv32_io_command_valid(2, 2, 0, 1, 0) != 0:
        return 1
    if _rv32_io_command_valid(3, 0, 0, 0, 0) != 0:
        return 1
    if _rv32_io_command_valid(4, 8, 3071, 1, 0) != 0:
        return 1
    if _rv32_io_command_valid(5, 9, 10, 1, 0) != 0:
        return 1
    if _rv32_io_command_valid(65536, 1, 0, 1, 0) == 0:
        return 1
    if _rv32_io_command_valid(6, 127, 0, 1, 0) == 0:
        return 1
    if _rv32_io_command_valid(7, 1, -1, 1, 0) == 0:
        return 1
    if _rv32_io_command_valid(8, 1, 3072, 1, 0) == 0:
        return 1
    if _rv32_io_command_valid(9, 1, 3070, 3, 0) == 0:
        return 1
    if _rv32_io_command_valid(10, 1, 0, 0, 0) == 0:
        return 1
    if _rv32_io_command_valid(11, 0, 1, 0, 0) == 0:
        return 1
    if _rv32_io_command_valid(12, 2, 1, 1, 1) == 0:
        return 1
    if _rv32_io_command_valid(13, 8, 1, 1, 1) == 0:
        return 1
    if _rv32_io_command_valid(14, 9, 1, 1, 1) == 0:
        return 1
    0
