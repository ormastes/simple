use logic_backpressure_abort_core.*

fn rv32_bpa_status_cases_selftest() -> i32:
    val cdw10: i64 = (100 << 16) | 1
    if _rv32_abort_status(1, cdw10, 0, 0, 1) != 2:
        return 1
    if _rv32_abort_status(0, cdw10, 1, 0, 1) != 2:
        return 1
    if _rv32_abort_status(0, cdw10, 0, 1, 1) != 2:
        return 1
    if _rv32_abort_status(0, -1, 0, 0, 1) != 2:
        return 1
    if _rv32_abort_status(0, 4294967296, 0, 0, 1) != 2:
        return 1
    if _rv32_abort_status(0, (100 << 16) | 99, 0, 0, 0) != 3:
        return 1
    if _rv32_abort_status(0, (100 << 16) | 8, 0, 0, 1) != 0:
        return 1
    if _rv32_abort_status(0, (100 << 16) | 9, 0, 0, 1) != 3:
        return 1
    if _rv32_abort_recorded_sqid(1, 3, (100 << 16) | 99) != 1:
        return 1
    0
