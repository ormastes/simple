fn rv32_wear_scrub_selftest() -> i64:
    # Scalar read-disturb scrub + static wear-level floor: relocate live data, reset counters.
    var fail = 0
    val unmap = -1
    val read_disturb_threshold = 50
    val wl_threshold = 2

    var block_closed = 1
    var block_valid = 64
    var read_disturb = read_disturb_threshold + 1
    var lba100 = 200
    var lba163 = 263
    var erased = 0
    var scrubbed = unmap
    if block_closed == 1 and block_valid > 0 and read_disturb > read_disturb_threshold:
        scrubbed = 0
        read_disturb = 0
        erased = erased + 1
    if scrubbed == unmap or read_disturb != 0 or erased != 1:
        fail = fail + 1
    if lba100 != 200 or lba163 != 263:
        fail = fail + 1
    scrubbed = unmap
    read_disturb = read_disturb_threshold
    if block_closed == 1 and block_valid > 0 and read_disturb > read_disturb_threshold:
        scrubbed = 0
    if scrubbed != unmap:
        fail = fail + 1
    scrubbed = unmap
    read_disturb = 0
    if block_closed == 1 and block_valid > 0 and read_disturb > read_disturb_threshold:
        scrubbed = 0
    if scrubbed != unmap:
        fail = fail + 1
    block_valid = 0
    read_disturb = read_disturb_threshold + 9
    if block_closed == 1 and block_valid > 0 and read_disturb > read_disturb_threshold:
        scrubbed = 0
        erased = erased + 1
    if scrubbed != unmap or erased != 1:
        fail = fail + 1

    var cold_block = 0
    var cold_erase = 0
    var max_erase = 3
    var cold_lba0 = 1000
    var cold_lba63 = 1063
    var leveled = unmap
    if max_erase - cold_erase > wl_threshold:
        leveled = cold_block
        cold_erase = cold_erase + 1
    if leveled != 0 or cold_erase != 1:
        fail = fail + 1
    if cold_lba0 != 1000 or cold_lba63 != 1063:
        fail = fail + 1
    leveled = unmap
    max_erase = 2
    cold_erase = 1
    if max_erase - cold_erase > wl_threshold:
        leveled = cold_block
    if leveled != unmap:
        fail = fail + 1
    leveled = unmap
    max_erase = 3
    cold_erase = 1
    if max_erase - cold_erase > wl_threshold:
        leveled = cold_block
    if leveled != unmap:
        fail = fail + 1
    fail
