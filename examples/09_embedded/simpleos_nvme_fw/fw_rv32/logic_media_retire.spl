fn _rv32_media_block_valid(block: i64) -> i32:
    if block < 0:
        return 1
    if block >= 64:
        return 1
    0

fn _rv32_media_spare_valid(block: i64) -> i32:
    if _rv32_media_block_valid(block) != 0:
        return 1
    if block < 56:
        return 1
    0

fn _rv32_media_result_retires(code: i64) -> i32:
    if code == 3:
        return 1
    if code == 4:
        return 1
    if code == 5:
        return 1
    0

fn _rv32_media_bad_count_clamped(count: i64) -> i64:
    if count < 0:
        return 0
    if count > 64:
        return 64
    count

fn _rv32_media_program_allowed(block: i64, bad: i64) -> i32:
    if _rv32_media_block_valid(block) != 0:
        return 1
    if bad != 0:
        return 1
    0

fn rv32_media_retire_selftest() -> i32:
    if _rv32_media_block_valid(0) != 0:
        return 1
    if _rv32_media_block_valid(63) != 0:
        return 1
    if _rv32_media_block_valid(-1) == 0:
        return 1
    if _rv32_media_block_valid(64) == 0:
        return 1
    if _rv32_media_spare_valid(56) != 0:
        return 1
    if _rv32_media_spare_valid(63) != 0:
        return 1
    if _rv32_media_spare_valid(55) == 0:
        return 1
    if _rv32_media_result_retires(3) != 1:
        return 1
    if _rv32_media_result_retires(4) != 1:
        return 1
    if _rv32_media_result_retires(5) != 1:
        return 1
    if _rv32_media_result_retires(0) != 0:
        return 1
    if _rv32_media_bad_count_clamped(-1) != 0:
        return 1
    if _rv32_media_bad_count_clamped(65) != 64:
        return 1
    if _rv32_media_program_allowed(5, 0) != 0:
        return 1
    if _rv32_media_program_allowed(5, 1) == 0:
        return 1
    if _rv32_media_program_allowed(64, 0) == 0:
        return 1
    0
