fn rv32_media_retire_selftest() -> i64:
    # Scalar FIL floor: program/erase faults retire blocks; bad media stays out of service.
    var fail = 0
    val nand_ok = 0
    val nand_prog_fail = 3
    val nand_erase_fail = 4
    val nand_bad_block = 5
    val num_blocks = 64
    val spare_start = 56
    var bad5 = 0
    var bad6 = 0
    var bad_count = 0
    var spare_next = spare_start
    var status = nand_ok

    val inject_prog_fail5 = 1
    if inject_prog_fail5 == 1:
        status = nand_prog_fail
        bad5 = 1
        bad_count = bad_count + 1
    if status != nand_prog_fail or bad5 != 1 or bad_count != 1:
        fail = fail + 1
    if bad5 == 1:
        status = nand_bad_block
    if status != nand_bad_block:
        fail = fail + 1
    val duplicate_prog_fail5 = 1
    if duplicate_prog_fail5 == 1 and bad5 == 0:
        bad5 = 1
        bad_count = bad_count + 1
    if bad5 != 1 or bad_count != 1:
        fail = fail + 1

    val inject_erase_fail6 = 1
    if inject_erase_fail6 == 1:
        status = nand_erase_fail
        bad6 = 1
        bad_count = bad_count + 1
    if status != nand_erase_fail or bad6 != 1 or bad_count != 2:
        fail = fail + 1
    val duplicate_erase_fail6 = 1
    if duplicate_erase_fail6 == 1 and bad6 == 0:
        bad6 = 1
        bad_count = bad_count + 1
    if bad6 != 1 or bad_count != 2:
        fail = fail + 1
    if num_blocks >= 64:
        status = nand_bad_block
    if status != nand_bad_block:
        fail = fail + 1

    var spare1 = -1
    if spare_next == 56:
        spare_next = spare_next + 1
    if spare_next == 57:
        spare_next = spare_next + 1
    if spare_next < num_blocks:
        spare1 = spare_next
        spare_next = spare_next + 1
    if spare1 != 58:
        fail = fail + 1
    var spare_count_good = 7
    var spare_available = -1
    if spare_count_good < 8:
        spare_available = spare_next
    if spare_available != 59:
        fail = fail + 1
    var spare_count_bad = 8
    var spare2 = -1
    if spare_count_bad < 8:
        spare2 = spare_next
    if spare2 != -1 or spare_next != 59:
        fail = fail + 1
    var spare_count_negative = -2
    if spare_count_negative < 0:
        spare_count_negative = 0
    var spare_negative = -1
    if spare_count_negative < 8:
        spare_negative = spare_next
    if spare_count_negative != 0 or spare_negative != 59:
        fail = fail + 1
    var avail_spare = 100 - ((bad_count * 100) / 8)
    if avail_spare != 75:
        fail = fail + 1
    bad_count = -4
    if bad_count < 0:
        bad_count = 0
    avail_spare = 100 - ((bad_count * 100) / 8)
    if avail_spare != 100:
        fail = fail + 1
    bad_count = 9
    avail_spare = 100 - ((bad_count * 100) / 8)
    if avail_spare < 0:
        avail_spare = 0
    if avail_spare != 0:
        fail = fail + 1
    fail
