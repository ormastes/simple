use logic_power_thermal_core.*

fn rv32_pt_cases_selftest() -> i32:
    if _rv32_pt_power_state_valid(0) != 0:
        return 1
    if _rv32_pt_power_state_valid(4) != 0:
        return 1
    if _rv32_pt_power_state_valid(-1) == 0:
        return 1
    if _rv32_pt_power_state_valid(5) == 0:
        return 1
    if _rv32_pt_temperature_threshold_valid(340) != 0:
        return 1
    if _rv32_pt_temperature_threshold_valid(313) == 0:
        return 1
    if _rv32_pt_next_temp(313, 0, 3) != 316:
        return 1
    if _rv32_pt_next_temp(-10, 0, -1) != 313:
        return 1
    if _rv32_pt_next_temp(313, 99, 3) != 313:
        return 1
    if _rv32_pt_throttled(352) != 0:
        return 1
    if _rv32_pt_throttled(353) != 1:
        return 1
    if _rv32_pt_critical_warning(313, -1) != 0:
        return 1
    if _rv32_pt_critical_warning(363, -1) != 1:
        return 1
    if _rv32_pt_critical_warning(340, 340) != 1:
        return 1
    0
