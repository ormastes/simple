use logic_power_thermal_state_cases.*
use logic_power_thermal_temp_cases.*
use logic_power_thermal_warning_cases.*

fn rv32_pt_cases_selftest() -> i32:
    if rv32_pt_state_cases_selftest() != 0:
        return 1
    if rv32_pt_temp_cases_selftest() != 0:
        return 1
    if rv32_pt_warning_cases_selftest() != 0:
        return 1
    0
