fn rv32_namespace_guard_selftest() -> i64:
    # Scalar NVMe namespace/reserved-field floor: malformed admin commands are inert.
    var fail = 0
    val sc_success = 0
    val sc_invalid_field = 2
    var status = sc_success
    var user_lba = 0xEE
    var fw_revision = 2
    var fw_dl_bytes = 0
    var format_count = 1
    val nsid = 1

    if nsid != 0:
        status = sc_invalid_field
    if status != sc_invalid_field:
        fail = fail + 1

    status = sc_success
    if nsid != 1:
        status = sc_invalid_field
    if status != sc_success:
        fail = fail + 1
    val zero_nsid = 0
    status = sc_success
    if zero_nsid != 1:
        status = sc_invalid_field
    if status != sc_invalid_field or user_lba != 0xEE or format_count != 1:
        fail = fail + 1
    val bad_nsid = 99
    status = sc_success
    if bad_nsid != 1:
        status = sc_invalid_field
    if status != sc_invalid_field:
        fail = fail + 1
    val negative_nsid = -1
    status = sc_success
    if negative_nsid != 1:
        status = sc_invalid_field
    if status != sc_invalid_field or user_lba != 0xEE or format_count != 1:
        fail = fail + 1

    status = sc_success
    if bad_nsid != 1:
        status = sc_invalid_field
    if status == sc_success:
        user_lba = 0
    if status != sc_invalid_field or user_lba != 0xEE or format_count != 1:
        fail = fail + 1

    val reserved_cdw = 1
    status = sc_success
    if reserved_cdw != 0:
        status = sc_invalid_field
    if status != sc_invalid_field or user_lba != 0xEE or format_count != 1:
        fail = fail + 1

    status = sc_success
    if nsid != 0:
        status = sc_invalid_field
    if status != sc_invalid_field or fw_revision != 2 or fw_dl_bytes != 0:
        fail = fail + 1

    status = sc_success
    if reserved_cdw != 0:
        status = sc_invalid_field
    if status != sc_invalid_field or fw_revision != 2:
        fail = fail + 1
    status = sc_success
    val log_id = 1
    if log_id != 1:
        status = sc_invalid_field
    if status != sc_success or fw_revision != 2 or fw_dl_bytes != 0:
        fail = fail + 1
    status = sc_success
    val reserved_log_id = 1 | (1 << 16)
    if reserved_log_id != 1:
        status = sc_invalid_field
    if status != sc_invalid_field or fw_revision != 2 or fw_dl_bytes != 0:
        fail = fail + 1
    status = sc_success
    val get_log_nsid = 1
    if get_log_nsid != 0:
        status = sc_invalid_field
    if status != sc_invalid_field or fw_revision != 2 or fw_dl_bytes != 0:
        fail = fail + 1
    status = sc_success
    val negative_log_nsid = -1
    if negative_log_nsid != 0:
        status = sc_invalid_field
    if status != sc_invalid_field or fw_revision != 2 or fw_dl_bytes != 0:
        fail = fail + 1
    status = sc_success
    val controller_log_nsid = 0
    if controller_log_nsid != 0:
        status = sc_invalid_field
    if status != sc_success:
        fail = fail + 1
    fail
