fn _rv32_namespace_cmd_valid(nsid: i64, lba: i64, nblocks: i64, capacity_blocks: i64) -> i32:
    if nsid != 1:
        return 1
    if lba < 0:
        return 1
    if nblocks <= 0:
        return 1
    if capacity_blocks <= 0:
        return 1
    if lba >= capacity_blocks:
        return 1
    if nblocks > capacity_blocks:
        return 1
    if lba > capacity_blocks - nblocks:
        return 1
    0

fn rv32_namespace_guard_selftest() -> i32:
    if _rv32_namespace_cmd_valid(1, 0, 1, 1024) != 0:
        return 1
    if _rv32_namespace_cmd_valid(1, 1023, 1, 1024) != 0:
        return 1
    if _rv32_namespace_cmd_valid(0, 0, 1, 1024) == 0:
        return 1
    if _rv32_namespace_cmd_valid(1, -1, 1, 1024) == 0:
        return 1
    if _rv32_namespace_cmd_valid(1, 0, 0, 1024) == 0:
        return 1
    if _rv32_namespace_cmd_valid(1, 1024, 1, 1024) == 0:
        return 1
    if _rv32_namespace_cmd_valid(1, 1020, 5, 1024) == 0:
        return 1
    0
