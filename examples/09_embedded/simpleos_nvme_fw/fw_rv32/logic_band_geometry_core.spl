fn _rv32_band_block_valid_impl(block: i64) -> i32:
    if block < 0:
        return 0
    if block >= 64:
        return 0
    1

fn _rv32_band_ppn_valid_impl(ppn: i64) -> i32:
    if ppn < 0:
        return 0
    if ppn >= 4096:
        return 0
    1

fn _rv32_band_block_of_impl(ppn: i64) -> i64:
    if _rv32_band_ppn_valid_impl(ppn) == 0:
        return -1
    ppn / 64

fn _rv32_band_first_ppn_impl(block: i64) -> i64:
    if _rv32_band_block_valid_impl(block) == 0:
        return -1
    block * 64

fn _rv32_band_valid_count_impl(raw: i64) -> i64:
    if raw < 0:
        return 0
    if raw > 64:
        return 64
    raw
