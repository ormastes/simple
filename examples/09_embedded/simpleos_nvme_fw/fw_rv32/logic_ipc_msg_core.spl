"""
logic_ipc_msg_core — pure codec for 4-word IPC message format.

Message w0 layout: opcode | (tag<<8) | (status<<16)
w0 = opcode + tag*256 + status*65536

All functions are fail-closed: invalid inputs return -1.
Extractors on negative w0 return -1.

Opcode constants (1..9 valid range; 0 and 10+ are invalid):
  OP_WRITE=1, OP_READ=2, OP_FLUSH=3, OP_PROG=4, OP_RD=5, OP_ERASE=6,
  NOP_PROG=7, NOP_READ=8, NOP_ERASE=9

Status constants (0..3 valid range; 4+ are invalid):
  ST_OK=0, ST_ERR=1, ST_MEDIA=2, ST_BOUNDS=3
"""

# Opcode constants
fn OP_WRITE() -> i64: 1
fn OP_READ() -> i64: 2
fn OP_FLUSH() -> i64: 3
fn OP_PROG() -> i64: 4
fn OP_RD() -> i64: 5
fn OP_ERASE() -> i64: 6
fn NOP_PROG() -> i64: 7
fn NOP_READ() -> i64: 8
fn NOP_ERASE() -> i64: 9

# Status constants
fn ST_OK() -> i64: 0
fn ST_ERR() -> i64: 1
fn ST_MEDIA() -> i64: 2
fn ST_BOUNDS() -> i64: 3

# Validity check: opcode must be in range 1..9
fn msg_opcode_valid(opcode: i64) -> i32:
    if opcode < 1:
        return 0
    if opcode > 9:
        return 0
    1

# Validity check: status must be in range 0..3
fn msg_status_valid(status: i64) -> i32:
    if status < 0:
        return 0
    if status > 3:
        return 0
    1

# Pack w0: opcode | (tag<<8) | (status<<16)
# Returns -1 if any field is out of range, otherwise packed value
fn msg_w0_pack(opcode: i64, tag: i64, status: i64) -> i64:
    # Validate opcode (1..9)
    if msg_opcode_valid(opcode) == 0:
        return -1
    # Validate tag (0..255)
    if tag < 0:
        return -1
    if tag > 255:
        return -1
    # Validate status (0..3)
    if msg_status_valid(status) == 0:
        return -1
    opcode + tag * 256 + status * 65536

# Extract opcode from w0
# Returns -1 if w0 is negative (invalid), otherwise opcode
fn msg_w0_opcode(w0: i64) -> i64:
    if w0 < 0:
        return -1
    w0 % 256

# Extract tag from w0
# Returns -1 if w0 is negative (invalid), otherwise tag
fn msg_w0_tag(w0: i64) -> i64:
    if w0 < 0:
        return -1
    (w0 / 256) % 256

# Extract status from w0
# Returns -1 if w0 is negative (invalid), otherwise status
fn msg_w0_status(w0: i64) -> i64:
    if w0 < 0:
        return -1
    (w0 / 65536) % 4

# Replace status field in w0, preserving opcode and tag
# Returns -1 if w0 is negative or new_status is invalid, otherwise modified w0
fn msg_w0_with_status(w0: i64, new_status: i64) -> i64:
    if w0 < 0:
        return -1
    if msg_status_valid(new_status) == 0:
        return -1
    val opcode = msg_w0_opcode(w0)
    val tag = msg_w0_tag(w0)
    if opcode < 0:
        return -1
    if tag < 0:
        return -1
    opcode + tag * 256 + new_status * 65536
