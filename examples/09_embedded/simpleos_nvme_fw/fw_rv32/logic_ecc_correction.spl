use logic_ecc_bits.*

fn _rv32_ecc_pos_for_data_bit(bit: i64) -> i64:
    var pos: i64 = 1
    var seen: i64 = 0
    while pos <= 22:
        if _rv32_ecc_parity_pos(pos) == 0:
            if seen == bit:
                return pos
            seen = seen + 1
        pos = pos + 1
    0

fn _rv32_ecc_flip_data_pos(data: i64, pos: i64) -> i64:
    var bit: i64 = 0
    while bit < 17:
        if _rv32_ecc_pos_for_data_bit(bit) == pos:
            return data ^ (1 << bit)
        bit = bit + 1
    data

fn _rv32_ecc_correct_with_recomputed(data: i64, stored: i64, recomputed: i64) -> i64:
    val syndrome: i64 = (stored ^ recomputed) & 31
    if syndrome == 0:
        return data
    if _rv32_ecc_parity_pos(syndrome) != 0:
        return data
    _rv32_ecc_flip_data_pos(data, syndrome)
