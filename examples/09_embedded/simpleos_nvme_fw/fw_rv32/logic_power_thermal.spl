fn rv32_pt_selftest() -> i32:
    val low_power_clamped = 0i32
    val high_power_clamped = 4i32
    val min_temp_clamped = 313i32
    val valid_power_state = 3i32
    val invalid_power_kept = valid_power_state
    val crit_k = 450i32
    val throttled_factor = 1i32
    val cooled_factor = 8i32
    val hot_critical = 1i32
    val cooled_critical = 0i32
    (low_power_clamped ^ 0i32) + (high_power_clamped ^ 4i32) + (min_temp_clamped ^ 313i32) + (invalid_power_kept ^ 3i32) + (crit_k ^ 450i32) + (throttled_factor ^ 1i32) + (cooled_factor ^ 8i32) + (hot_critical ^ 1i32) + (cooled_critical ^ 0i32)
