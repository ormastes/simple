use logic_queue_phase_core.*

fn rv32_queue_len_cases_selftest() -> i32:
    if _rv32_queue_len_pending(0, 64) != 0:
        return 1
    if _rv32_queue_len_pending(65, 64) != 64:
        return 1
    if _rv32_queue_len_pending(-1, 64) != 0:
        return 1
    if _rv32_queue_len_pending(4, 0) != 0:
        return 1
    if _rv32_queue_len_pending(4, -1) != 0:
        return 1
    0
