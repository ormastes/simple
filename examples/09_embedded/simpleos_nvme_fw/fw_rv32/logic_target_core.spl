fn _rv32_target_valid_profile(profile: i32, channels: i32, ways: i32, namespaces: i32, blocks_per_slice: i32) -> i32:
    if profile == 1:
        if channels == 2 and ways == 8 and namespaces == 1 and blocks_per_slice == 4:
            return 0
        return 1
    if profile == 2:
        if channels == 8 and ways == 8 and namespaces == 1 and blocks_per_slice == 4:
            return 0
        return 1
    1

fn _rv32_target_valid_apertures(profile: i32, ddr: i64, uart1: i64, nfc: i64, pcie: i64) -> i32:
    if profile == 1 or profile == 2:
        if ddr == 0x00100000 and uart1 == 0xE0001000 and nfc == 0x43C00000 and pcie == 0x50000000:
            return 0
        return 1
    1

fn _rv32_target_valid_pcie_vendor(profile: i32, vendor: i32) -> i32:
    if profile == 1 or profile == 2:
        if vendor == 0x10EE:
            return 0
        return 1
    1
