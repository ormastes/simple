use logic_admin_core.*

fn rv32_admin_fw_cases_selftest() -> i32:
    if _rv32_admin_fw_commit_valid(1, 1, 4) != 0:
        return 1
    if _rv32_admin_fw_commit_valid(3, 3, 4) != 0:
        return 1
    if _rv32_admin_fw_commit_valid(0, 1, 4) == 0:
        return 1
    if _rv32_admin_fw_commit_valid(4, 1, 4) == 0:
        return 1
    if _rv32_admin_fw_commit_valid(1, 4, 4) == 0:
        return 1
    if _rv32_admin_fw_commit_valid(1, 1, 0) == 0:
        return 1
    if _rv32_admin_fw_revision_after(7, 0, 0) != 7:
        return 1
    if _rv32_admin_fw_revision_after(7, 1, 0) != 8:
        return 1
    if _rv32_admin_fw_revision_after(-4, 1, 0) != 2:
        return 1
    if _rv32_admin_fw_revision_after(1000000000000000000, 1, 0) != 1000000000000000000:
        return 1
    if _rv32_admin_fw_revision_after(7, 1, 1) != 7:
        return 1
    0
