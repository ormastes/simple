fn _rv32_reactor_sanitize_owner(owner: i64) -> i64:
    if owner < 0:
        return 0
    if owner > 2:
        return 0
    owner

fn _rv32_reactor_acquire(owner: i64, requested: i64) -> i32:
    val safe_owner: i64 = _rv32_reactor_sanitize_owner(owner)
    if requested <= 0:
        return 0
    if requested > 2:
        return 0
    if safe_owner == 0:
        return 1
    0

fn _rv32_reactor_conflicts_after(owner: i64, requested: i64, conflicts: i64) -> i64:
    if conflicts < 0:
        return 0
    if _rv32_reactor_acquire(owner, requested) == 0:
        if requested > 0 and requested <= 2:
            return conflicts + 1
    conflicts

fn _rv32_reactor_release(owner: i64, released: i64) -> i64:
    if owner == released:
        return 0
    _rv32_reactor_sanitize_owner(owner)

fn _rv32_reactor_fg_tick(pending: i64, owner: i64) -> i64:
    if pending <= 0:
        return 0
    if _rv32_reactor_acquire(owner, 1) == 0:
        return 0
    1

fn _rv32_reactor_service(pending: i64, guard_limit: i64) -> i64:
    if pending <= 0:
        return 0
    if guard_limit <= 0:
        return 0
    if pending < guard_limit:
        return pending
    guard_limit

fn _rv32_reactor_bg_needed(free_blocks: i64) -> i32:
    if free_blocks < 4:
        return 1
    0

fn _rv32_reactor_gc_sweep(reclaimable: i64) -> i64:
    if reclaimable <= 0:
        return 0
    if reclaimable > 3:
        return 3
    reclaimable

fn _rv32_reactor_power_cycle_read(checkpointed: i64, dirty: i64) -> i64:
    if dirty != 0:
        return checkpointed
    checkpointed
