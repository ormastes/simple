# RV32 no-alloc NVMe firmware logic reference.
#
# Scalar-only: no arrays, no heap, no strings in the logic path. Host and bare-metal entries share
# this so P9 evidence exercises the same RAIN + ECC + fixed scheduler + power/thermal + map-cache + band + journal-ring + HIL command/queue + queue-phase + read/zero/trim/flush + admin/format/fw-log + reactor + policy/target + DRAM/durability + wear/scrub + media-retire + power-cycle + backpressure/abort + feature-guard + namespace-guard floor.

fn rv32_xor7(a: i64, b: i64, c: i64, d: i64, e: i64, f: i64, g: i64) -> i64:
    var x = a ^ b
    x = x ^ c
    x = x ^ d
    x = x ^ e
    x = x ^ f
    x = x ^ g
    x

fn rv32_xor8(a: i64, b: i64, c: i64, d: i64, e: i64, f: i64, g: i64, h: i64) -> i64:
    rv32_xor7(a, b, c, d, e, f, g) ^ h

fn rv32_rain_selftest() -> i64:
    val d0 = 256
    val d1 = 263
    val d2 = 270
    val d3 = 277
    val d4 = 284
    val d5 = 291
    val d6 = 298
    val d7 = 305
    val parity = rv32_xor8(d0, d1, d2, d3, d4, d5, d6, d7)

    var fail = 0
    if rv32_xor8(parity, d1, d2, d3, d4, d5, d6, d7) != d0:
        fail = fail + 1
    if rv32_xor8(parity, d0, d2, d3, d4, d5, d6, d7) != d1:
        fail = fail + 1
    if rv32_xor8(parity, d0, d1, d3, d4, d5, d6, d7) != d2:
        fail = fail + 1
    if rv32_xor8(parity, d0, d1, d2, d4, d5, d6, d7) != d3:
        fail = fail + 1
    if rv32_xor8(parity, d0, d1, d2, d3, d5, d6, d7) != d4:
        fail = fail + 1
    if rv32_xor8(parity, d0, d1, d2, d3, d4, d6, d7) != d5:
        fail = fail + 1
    if rv32_xor8(parity, d0, d1, d2, d3, d4, d5, d7) != d6:
        fail = fail + 1
    if rv32_xor8(parity, d0, d1, d2, d3, d4, d5, d6) != d7:
        fail = fail + 1

    val recovered3 = rv32_xor8(parity, d0, d1, d2, d4, d5, d6, d7)
    if recovered3 != d3:
        fail = fail + 1
    fail
