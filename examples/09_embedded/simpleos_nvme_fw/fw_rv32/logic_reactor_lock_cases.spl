use logic_reactor_lock_core.*

fn rv32_reactor_lock_cases_selftest() -> i32:
    if _rv32_reactor_sanitize_owner_impl(-9) != 0:
        return 1
    if _rv32_reactor_sanitize_owner_impl(3) != 0:
        return 1
    if _rv32_reactor_acquire_impl(0, 1) != 1:
        return 1
    if _rv32_reactor_acquire_impl(2, 1) != 0:
        return 1
    if _rv32_reactor_conflicts_after_impl(2, 1, 0) != 1:
        return 1
    if _rv32_reactor_conflicts_after_impl(2, 1, -3) != 1:
        return 1
    if _rv32_reactor_conflicts_after_impl(2, 1, 1000000000000000000) != 1000000000000000000:
        return 1
    if _rv32_reactor_conflicts_after_impl(0, 1, -3) != 0:
        return 1
    if _rv32_reactor_conflicts_after_impl(0, 1, 1000000000000000001) != 1000000000000000000:
        return 1
    if _rv32_reactor_release_impl(1, 1) != 0:
        return 1
    if _rv32_reactor_release_impl(2, 1) != 2:
        return 1
    0
