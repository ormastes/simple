use logic_backpressure_abort_core.*

fn rv32_backpressure_abort_cases_selftest() -> i32:
    val cdw10: i64 = (100 << 16) | 1
    val ok_status: i64 = _rv32_abort_status(0, cdw10, 0, 0, 1)
    if ok_status != 0:
        return 1
    if _rv32_abort_data(ok_status) != 1:
        return 1
    if _rv32_abort_recorded_sqid(-1, ok_status, cdw10) != 1:
        return 1
    if _rv32_abort_recorded_cid(-1, ok_status, cdw10) != 100:
        return 1
    if _rv32_abort_status(1, cdw10, 0, 0, 1) != 2:
        return 1
    if _rv32_abort_status(0, cdw10, 1, 0, 1) != 2:
        return 1
    if _rv32_abort_status(0, cdw10, 0, 1, 1) != 2:
        return 1
    if _rv32_abort_status(0, (100 << 16) | 99, 0, 0, 0) != 3:
        return 1
    if _rv32_abort_recorded_sqid(1, 3, (100 << 16) | 99) != 1:
        return 1
    if _rv32_abort_get_sqid(99) != -1:
        return 1
    if _rv32_abort_get_cid(70000) != -1:
        return 1
    if _rv32_abort_get_sqid(1) != 1:
        return 1
    if _rv32_abort_get_cid(100) != 100:
        return 1
    0
