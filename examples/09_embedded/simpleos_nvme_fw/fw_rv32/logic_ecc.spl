use logic_ecc_core.{_rv32_ecc_compute, _rv32_ecc_check, _rv32_ecc_correct}

fn rv32_ecc_selftest() -> i32:
    val e1: i64 = _rv32_ecc_compute(171, 7, 3)
    if e1 != _rv32_ecc_compute(171, 7, 3):
        return 1
    if (_rv32_ecc_compute(255, 255, 63) >> 6) <= 0:
        return 1
    if _rv32_ecc_compute(1, 0, 0) == _rv32_ecc_compute(2, 0, 0):
        return 1
    if _rv32_ecc_compute(2, 1, 1) == _rv32_ecc_compute(2, 2, 1):
        return 1

    val data: i64 = 66
    val lba: i64 = 100
    val seq: i64 = 5
    val ecc: i64 = _rv32_ecc_compute(data, lba, seq)
    if _rv32_ecc_check(data, lba, seq, ecc, 0) != 0:
        return 1
    if _rv32_ecc_check(data, lba, seq, ecc, -1) != 0:
        return 1
    if _rv32_ecc_check(data, lba, seq, ecc, 1) != 1:
        return 1
    if _rv32_ecc_check(data, lba, seq, ecc, 2) != 2:
        return 1
    if _rv32_ecc_check(data, lba, seq, ecc ^ 1, 0) != 2:
        return 1
    if _rv32_ecc_check(data ^ 1, lba, seq, ecc, 0) != 1:
        return 1
    if _rv32_ecc_correct(data ^ 1, lba, seq, ecc) != data:
        return 1
    if _rv32_ecc_check(data ^ 3, lba, seq, ecc, 0) != 2:
        return 1
    0
