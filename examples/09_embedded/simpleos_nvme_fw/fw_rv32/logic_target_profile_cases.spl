use logic_target_core.*

fn rv32_target_profile_cases_selftest() -> i32:
    if _rv32_target_valid_profile(1, 2, 8, 1, 4) != 0:
        return 1
    if _rv32_target_valid_profile(2, 8, 8, 1, 4) != 0:
        return 1
    if _rv32_target_valid_profile(1, 8, 8, 1, 4) == 0:
        return 1
    if _rv32_target_valid_profile(2, 1, 1, 1, 4) == 0:
        return 1
    if _rv32_target_valid_profile(2, 8, 8, 1, 1) == 0:
        return 1
    if _rv32_target_valid_profile(99, 8, 8, 1, 4) == 0:
        return 1
    0
