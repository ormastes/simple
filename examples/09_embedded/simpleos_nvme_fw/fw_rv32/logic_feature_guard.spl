fn _rv32_feature_id_valid(fid: i64) -> i32:
    if fid < 0:
        return 1
    if fid >= 16:
        return 1
    0

fn _rv32_feature_value_valid(fid: i64, value: i64) -> i32:
    if _rv32_feature_id_valid(fid) != 0:
        return 1
    if fid == 2:
        if value < 0:
            return 1
        if value >= 5:
            return 1
    if fid == 4:
        if value <= 313:
            return 1
    if fid == 6:
        if value < 0:
            return 1
        if value > 1:
            return 1
    0

fn _rv32_feature_default_valid(fid: i64, value: i64) -> i32:
    if fid == 6:
        if value != 1:
            return 1
    if fid == 7:
        if value != 458759:
            return 1
    0

fn rv32_feature_guard_selftest() -> i32:
    if _rv32_feature_id_valid(0) != 0:
        return 1
    if _rv32_feature_id_valid(15) != 0:
        return 1
    if _rv32_feature_id_valid(-1) == 0:
        return 1
    if _rv32_feature_id_valid(16) == 0:
        return 1
    if _rv32_feature_value_valid(2, 0) != 0:
        return 1
    if _rv32_feature_value_valid(2, 4) != 0:
        return 1
    if _rv32_feature_value_valid(2, 5) == 0:
        return 1
    if _rv32_feature_value_valid(4, 340) != 0:
        return 1
    if _rv32_feature_value_valid(4, 313) == 0:
        return 1
    if _rv32_feature_value_valid(6, 0) != 0:
        return 1
    if _rv32_feature_value_valid(6, 1) != 0:
        return 1
    if _rv32_feature_value_valid(6, 2) == 0:
        return 1
    if _rv32_feature_default_valid(6, 1) != 0:
        return 1
    if _rv32_feature_default_valid(7, 458759) != 0:
        return 1
    if _rv32_feature_default_valid(7, 0) == 0:
        return 1
    0
