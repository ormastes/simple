fn rv32_feature_guard_selftest() -> i64:
    # Scalar feature floor: invalid values and reserved fields fail closed without state drift.
    var fail = 0
    val sc_success = 0
    val sc_invalid_field = 2
    val feat_temp_thresh = 4
    val feat_power_mgmt = 2
    val feat_volatile_wc = 6
    val feat_max = 16
    var temp_thresh = 345
    var power_state = 3
    var volatile_wc = 1
    var status = sc_success

    if 313 <= 313:
        status = sc_invalid_field
    if status != sc_invalid_field or temp_thresh != 345:
        fail = fail + 1
    if (feat_temp_thresh | (1 << 16)) != feat_temp_thresh:
        status = sc_invalid_field
    if status != sc_invalid_field or temp_thresh != 345:
        fail = fail + 1
    status = sc_success
    val malformed_get_temp = feat_temp_thresh | (1 << 16)
    if malformed_get_temp != feat_temp_thresh:
        status = sc_invalid_field
    if status != sc_invalid_field or temp_thresh != 345:
        fail = fail + 1
    temp_thresh = 313
    if temp_thresh <= 313:
        temp_thresh = 363
    if temp_thresh != 363:
        fail = fail + 1
    status = sc_success
    val high_temp_thresh = 451
    if high_temp_thresh <= 313 or high_temp_thresh > 450:
        status = sc_invalid_field
    else:
        temp_thresh = high_temp_thresh
    if status != sc_invalid_field or temp_thresh != 363:
        fail = fail + 1
    if feat_max >= 16:
        status = sc_invalid_field
    if status != sc_invalid_field:
        fail = fail + 1
    status = sc_success
    val unknown_fid = 15
    if unknown_fid != feat_temp_thresh and unknown_fid != feat_power_mgmt and unknown_fid != feat_volatile_wc:
        status = sc_invalid_field
    if status != sc_invalid_field or temp_thresh != 363 or power_state != 3 or volatile_wc != 1:
        fail = fail + 1
    status = sc_success
    val max_temp_thresh = 450
    if max_temp_thresh <= 313 or max_temp_thresh > 450:
        status = sc_invalid_field
    else:
        temp_thresh = max_temp_thresh
    if status != sc_success or temp_thresh != 450:
        fail = fail + 1

    status = sc_success
    if power_state < 0 or power_state > 4:
        status = sc_invalid_field
    if status != sc_success or power_state != 3:
        fail = fail + 1
    val bad_power = 99
    if bad_power < 0 or bad_power > 4:
        status = sc_invalid_field
    if status != sc_invalid_field or power_state != 3:
        fail = fail + 1
    status = sc_success
    val low_power = -1
    if low_power < 0 or low_power > 4:
        status = sc_invalid_field
    if status != sc_invalid_field or power_state != 3:
        fail = fail + 1
    status = sc_success
    val max_power = 4
    if max_power < 0 or max_power > 4:
        status = sc_invalid_field
    else:
        power_state = max_power
    if status != sc_success or power_state != 4:
        fail = fail + 1
    power_state = -8
    if power_state < 0:
        power_state = 0
    if power_state != 0:
        fail = fail + 1

    val bad_wc = 2
    status = sc_success
    if bad_wc != 0 and bad_wc != 1:
        status = sc_invalid_field
    if status != sc_invalid_field or volatile_wc != 1:
        fail = fail + 1
    status = sc_success
    val low_wc = -1
    if low_wc != 0 and low_wc != 1:
        status = sc_invalid_field
    if status != sc_invalid_field or volatile_wc != 1:
        fail = fail + 1
    volatile_wc = 0
    if volatile_wc != 0 or feat_power_mgmt != 2 or feat_volatile_wc != 6:
        fail = fail + 1
    volatile_wc = 1
    if volatile_wc != 1:
        fail = fail + 1
    status = sc_success
    if unknown_fid != feat_temp_thresh and unknown_fid != feat_power_mgmt and unknown_fid != feat_volatile_wc:
        status = sc_invalid_field
    if status != sc_invalid_field or power_state != 0 or volatile_wc != 1:
        fail = fail + 1
    fail
