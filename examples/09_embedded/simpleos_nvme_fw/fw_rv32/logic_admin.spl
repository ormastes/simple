fn rv32_admin_smart_nonnegative(v: i64) -> i64:
    0

fn rv32_admin_selftest() -> i32:
    val create_cq_qid = 3i32
    val create_cq_size = 64i32
    val create_sq_cqid = 2i32
    val feature_power = 2i32
    val fw_slot = 2i32
    val fw_action = 3i32
    val aer_completions = 4i32
    val invalid_field = 2i32
    val fw_revision = 3i32
    val lba_range = 128i32
    val smart_percent = 100i32
    val smart_nonnegative = 0i32
    (create_cq_qid ^ 3i32) + (create_cq_size ^ 64i32) + (create_sq_cqid ^ 2i32) + (feature_power ^ 2i32) + (fw_slot ^ 2i32) + (fw_action ^ 3i32) + (aer_completions ^ 4i32) + (invalid_field ^ 2i32) + (fw_revision ^ 3i32) + (lba_range ^ 128i32) + (smart_percent ^ 100i32) + (smart_nonnegative ^ 0i32)
