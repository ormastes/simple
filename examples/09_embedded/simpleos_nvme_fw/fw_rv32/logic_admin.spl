fn rv32_admin_smart_nonnegative(v: i64) -> i32:
    if v < 0:
        return 1
    0

fn _rv32_admin_smart_temperature_valid(kelvin: i64) -> i32:
    if kelvin < 250:
        return 1
    if kelvin > 450:
        return 1
    0

fn _rv32_admin_log_id_valid(log_id: i64) -> i32:
    if log_id == 1:
        return 0
    if log_id == 2:
        return 0
    if log_id == 3:
        return 0
    1

fn _rv32_admin_feature_id_valid(fid: i64) -> i32:
    if fid == 2:
        return 0
    if fid == 4:
        return 0
    if fid == 6:
        return 0
    1

fn _rv32_admin_fw_commit_valid(slot: i64, action: i64, downloaded_bytes: i64) -> i32:
    if slot < 1:
        return 1
    if slot > 7:
        return 1
    if action < 0:
        return 1
    if action > 3:
        return 1
    if downloaded_bytes <= 0:
        return 1
    0

fn rv32_admin_selftest() -> i32:
    if rv32_admin_smart_nonnegative(0) != 0:
        return 1
    if rv32_admin_smart_nonnegative(4) != 0:
        return 1
    if rv32_admin_smart_nonnegative(-1) == 0:
        return 1
    if _rv32_admin_smart_temperature_valid(313) != 0:
        return 1
    if _rv32_admin_smart_temperature_valid(249) == 0:
        return 1
    if _rv32_admin_smart_temperature_valid(451) == 0:
        return 1
    if _rv32_admin_log_id_valid(1) != 0:
        return 1
    if _rv32_admin_log_id_valid(2) != 0:
        return 1
    if _rv32_admin_log_id_valid(3) != 0:
        return 1
    if _rv32_admin_log_id_valid(4) == 0:
        return 1
    if _rv32_admin_feature_id_valid(2) != 0:
        return 1
    if _rv32_admin_feature_id_valid(4) != 0:
        return 1
    if _rv32_admin_feature_id_valid(6) != 0:
        return 1
    if _rv32_admin_feature_id_valid(16) == 0:
        return 1
    if _rv32_admin_fw_commit_valid(1, 1, 4) != 0:
        return 1
    if _rv32_admin_fw_commit_valid(7, 3, 4) != 0:
        return 1
    if _rv32_admin_fw_commit_valid(0, 1, 4) == 0:
        return 1
    if _rv32_admin_fw_commit_valid(8, 1, 4) == 0:
        return 1
    if _rv32_admin_fw_commit_valid(1, 4, 4) == 0:
        return 1
    if _rv32_admin_fw_commit_valid(1, 1, 0) == 0:
        return 1
    0
