fn rv32_admin_qid(cdw10: i64) -> i64:
    cdw10 & 0xFFFF

fn rv32_admin_qsize(cdw10: i64) -> i64:
    (cdw10 >> 16) & 0xFFFF

fn rv32_admin_cqid(cdw11: i64) -> i64:
    (cdw11 >> 16) & 0xFFFF

fn rv32_admin_fid(cdw10: i64) -> i64:
    cdw10 & 0xFF

fn rv32_admin_fw_slot(cdw10: i64) -> i64:
    cdw10 & 0x7

fn rv32_admin_fw_action(cdw10: i64) -> i64:
    (cdw10 >> 3) & 0x7

fn rv32_admin_smart_percent(v: i64) -> i64:
    if v < 0:
        return 0
    if v > 100:
        return 100
    v

fn rv32_admin_smart_nonnegative(v: i64) -> i64:
    if v < 0:
        return 0
    v

fn rv32_admin_selftest() -> i64:
    var fail = 0
    val max_io_queues = 8
    val lba_count = 3072
    val lba_bytes = 4096
    val feat_num_queues = 7
    val feat_power_mgmt = 2
    val feat_volatile_wc = 6
    val sc_success = 0
    val sc_invalid_field = 2
    val sc_lba_range = 0x80
    var status = sc_success

    val create_cq_cdw10 = (64 << 16) | 3
    if rv32_admin_qid(create_cq_cdw10) != 3:
        fail = fail + 1
    if rv32_admin_qsize(create_cq_cdw10) != 64:
        fail = fail + 1
    val create_sq_cdw11 = (2 << 16) | 1
    if rv32_admin_cqid(create_sq_cdw11) != 2:
        fail = fail + 1
    val feature_cdw10 = feat_power_mgmt | (1 << 16)
    if rv32_admin_fid(feature_cdw10) != feat_power_mgmt:
        fail = fail + 1
    val fw_commit_cdw10 = (3 << 3) | 2
    if rv32_admin_fw_slot(fw_commit_cdw10) != 2 or rv32_admin_fw_action(fw_commit_cdw10) != 3:
        fail = fail + 1

    # AER floor: held request completes exactly once, bad held state preserves the event.
    var aer_held_cid = 60
    var aer_event = 1
    var admin_cpls = 0
    if aer_held_cid >= 0 and aer_held_cid < 65536 and aer_event != 0:
        admin_cpls = admin_cpls + 1
        aer_held_cid = -1
        aer_event = 0
    if admin_cpls != 1 or aer_held_cid != -1 or aer_event != 0:
        fail = fail + 1
    aer_held_cid = 70000
    aer_event = 1
    if aer_held_cid >= 0 and aer_held_cid < 65536 and aer_event != 0:
        admin_cpls = admin_cpls + 1
        aer_event = 0
    if admin_cpls != 1 or aer_event != 1:
        fail = fail + 1
    aer_held_cid = 61
    if aer_held_cid >= 0 and aer_held_cid < 65536 and aer_event != 0:
        admin_cpls = admin_cpls + 1
        aer_event = 0
    if admin_cpls != 2 or aer_event != 0:
        fail = fail + 1
    aer_held_cid = 65535
    aer_event = 1
    if aer_held_cid >= 0 and aer_held_cid < 65536 and aer_event != 0:
        admin_cpls = admin_cpls + 1
        aer_held_cid = -1
        aer_event = 0
    if admin_cpls != 3 or aer_held_cid != -1 or aer_event != 0:
        fail = fail + 1
    val aer_reserved = 1
    if aer_reserved != 0:
        status = sc_invalid_field
        aer_held_cid = -1
    if status != sc_invalid_field or aer_held_cid != -1:
        fail = fail + 1
    status = sc_success
    aer_held_cid = 62
    if aer_held_cid != -1:
        status = sc_invalid_field
    if status != sc_invalid_field or aer_held_cid != 62:
        fail = fail + 1
    status = sc_success
    aer_held_cid = -1
    aer_event = 1
    if aer_event != 0 and aer_held_cid == -1:
        admin_cpls = admin_cpls + 1
        aer_event = 0
    if status != sc_success or admin_cpls != 4 or aer_event != 0:
        fail = fail + 1

    # Firmware download/commit floor: sequential image required; slot/action fail closed.
    var fw_revision = 1
    var fw_slot = 1
    var fw_dl_bytes = 0
    status = sc_success
    val fw_len = 1024
    val fw_off = 0
    if fw_len <= 0 or fw_off != fw_dl_bytes:
        status = sc_invalid_field
    else:
        fw_dl_bytes = fw_dl_bytes + fw_len
    if status != sc_success or fw_dl_bytes != 1024:
        fail = fail + 1
    val commit_slot = 2
    val commit_action = 1
    if commit_slot <= 0 or commit_slot > 7 or commit_action < 0 or commit_action > 3 or fw_dl_bytes <= 0:
        status = sc_invalid_field
    else:
        fw_slot = commit_slot
        fw_revision = fw_revision + 1
        fw_dl_bytes = 0
        status = sc_success
    if status != sc_success or fw_revision != 2 or fw_slot != 2 or fw_dl_bytes != 0:
        fail = fail + 1
    fw_dl_bytes = 4
    status = sc_success
    val bad_commit_action = 7
    if commit_slot <= 0 or commit_slot > 7 or bad_commit_action < 0 or bad_commit_action > 3 or fw_dl_bytes <= 0:
        status = sc_invalid_field
    else:
        fw_slot = commit_slot
    if status != sc_invalid_field or fw_revision != 2 or fw_slot != 2 or fw_dl_bytes != 4:
        fail = fail + 1
    fw_dl_bytes = 4
    status = sc_success
    val bad_commit_slot_zero = 0
    if bad_commit_slot_zero <= 0 or bad_commit_slot_zero > 7 or commit_action < 0 or commit_action > 3 or fw_dl_bytes <= 0:
        status = sc_invalid_field
    else:
        fw_slot = bad_commit_slot_zero
        fw_revision = fw_revision + 1
        fw_dl_bytes = 0
    if status != sc_invalid_field or fw_revision != 2 or fw_slot != 2 or fw_dl_bytes != 4:
        fail = fail + 1
    fw_dl_bytes = 128
    val bad_commit_slot = 8
    if bad_commit_slot <= 0 or bad_commit_slot > 7 or commit_action < 0 or commit_action > 3 or fw_dl_bytes <= 0:
        status = sc_invalid_field
    else:
        fw_slot = bad_commit_slot
        fw_revision = fw_revision + 1
        fw_dl_bytes = 0
    if status != sc_invalid_field or fw_revision != 2 or fw_slot != 2 or fw_dl_bytes != 128:
        fail = fail + 1
    fw_dl_bytes = 64
    status = sc_success
    val max_commit_slot = 7
    val max_commit_action = 3
    if max_commit_slot <= 0 or max_commit_slot > 7 or max_commit_action < 0 or max_commit_action > 3 or fw_dl_bytes <= 0:
        status = sc_invalid_field
    else:
        fw_slot = max_commit_slot
        fw_revision = fw_revision + 1
        fw_dl_bytes = 0
    if status != sc_success or fw_revision != 3 or fw_slot != 7 or fw_dl_bytes != 0:
        fail = fail + 1
    fw_dl_bytes = 0
    if 4 <= 0 or 8 != fw_dl_bytes:
        status = sc_invalid_field
    if status != sc_invalid_field:
        fail = fail + 1
    fw_dl_bytes = -16
    if fw_dl_bytes < 0:
        fw_dl_bytes = 0
    if 4 <= 0 or 0 != fw_dl_bytes:
        status = sc_invalid_field
    else:
        fw_dl_bytes = 4
        status = sc_success
    if status != sc_success or fw_dl_bytes != 4:
        fail = fail + 1
    if 0 <= 0 or 4 != fw_dl_bytes:
        status = sc_invalid_field
    if status != sc_invalid_field:
        fail = fail + 1
    if rv32_admin_fw_slot((4 << 3) | 1) != 1 or rv32_admin_fw_action((4 << 3) | 1) != 4:
        fail = fail + 1
    fw_revision = -4
    fw_slot = 9
    if rv32_admin_smart_nonnegative(fw_revision) != 0:
        fail = fail + 1
    if fw_slot < 1 or fw_slot > 7:
        fw_slot = 0
    if fw_slot != 0:
        fail = fail + 1

    # Format + error-log floor: failed format keeps data; good format erases data, preserves media state, and bad counters clamp.
    var lba5 = 0xEE
    var block10_erase_count = 2
    var block20_retired = 1
    var format_count = 0
    val bad_blocks_before_format = block20_retired
    status = sc_invalid_field
    if status != sc_invalid_field or lba5 != 0xEE or format_count != 0:
        fail = fail + 1
    status = sc_success
    if status == sc_success:
        lba5 = 0
        block10_erase_count = block10_erase_count + 1
        format_count = format_count + 1
    if lba5 != 0:
        fail = fail + 1
    if block10_erase_count != 3 or block20_retired != 1 or bad_blocks_before_format != 1 or format_count != 1:
        fail = fail + 1
    lba5 = 0x44
    status = sc_invalid_field
    if status != sc_invalid_field or lba5 != 0x44 or block10_erase_count != 3 or format_count != 1:
        fail = fail + 1
    var error_count = 0
    var last_error = 0
    status = sc_lba_range
    if status != sc_success:
        error_count = error_count + 1
        last_error = status
    if error_count != 1 or last_error != sc_lba_range:
        fail = fail + 1
    last_error = -9
    if last_error < 0:
        last_error = sc_invalid_field
    if last_error != sc_invalid_field:
        fail = fail + 1
    error_count = -7
    if rv32_admin_smart_nonnegative(error_count) != 0:
        fail = fail + 1
    error_count = rv32_admin_smart_nonnegative(error_count) + 1
    if error_count != 1:
        fail = fail + 1
    val get_log_error_data = error_count
    val get_log_fw_slot_data = rv32_admin_smart_nonnegative(fw_revision)
    if get_log_error_data != 1 or get_log_fw_slot_data != 0:
        fail = fail + 1

    # Identify controller/namespace floor: one namespace, eight IO queues, 4 KiB LBAs.
    var identify_kind = 1
    var identify_num_ns = 1
    var identify_max_queues = max_io_queues
    if identify_kind != 1 or identify_num_ns != 1 or identify_max_queues != 8:
        fail = fail + 1
    identify_kind = 0
    var identify_nsid = 1
    var identify_ns_size = lba_count
    var identify_lba_bytes = lba_bytes
    if identify_kind != 0 or identify_nsid != 1 or identify_ns_size != 3072 or identify_lba_bytes != 4096:
        fail = fail + 1
    identify_nsid = 0
    if identify_nsid != 1:
        status = sc_invalid_field
    if status != sc_invalid_field or identify_ns_size != 3072 or identify_lba_bytes != 4096:
        fail = fail + 1
    status = sc_success
    identify_nsid = 99
    if identify_nsid != 1:
        status = sc_invalid_field
    if status != sc_invalid_field or identify_ns_size != 3072 or identify_lba_bytes != 4096:
        fail = fail + 1
    status = sc_success

    # Feature store floor: defaults and Set/Get Features round-trip.
    var feat_num_queues_value = ((max_io_queues - 1) << 16) | (max_io_queues - 1)
    var feat_power_value = 0
    var feat_wc_value = 1
    if rv32_admin_fid(feat_num_queues) != feat_num_queues:
        fail = fail + 1
    if feat_num_queues_value != 0x00070007:
        fail = fail + 1
    feat_power_value = 3
    if feat_power_value != 3:
        fail = fail + 1
    if 99 >= 0 and 99 < 5:
        feat_power_value = 99
    if feat_power_value != 3:
        fail = fail + 1
    if -1 >= 0 and -1 < 5:
        feat_power_value = -1
    if feat_power_value != 3:
        fail = fail + 1
    if feat_wc_value != 1:
        fail = fail + 1
    if 0 == 0 or 0 == 1:
        feat_wc_value = 0
    if feat_wc_value != 0:
        fail = fail + 1
    if 2 == 0 or 2 == 1:
        feat_wc_value = 2
    if feat_wc_value != 0:
        fail = fail + 1
    feat_wc_value = 1
    if -1 == 0 or -1 == 1:
        feat_wc_value = -1
    if feat_wc_value != 1:
        fail = fail + 1
    if feat_volatile_wc != 6:
        fail = fail + 1

    # SMART/log floor: clamp corrupted counters and raise critical warning for health events.
    val spare = rv32_admin_smart_percent(120)
    val used = rv32_admin_smart_percent(-3)
    val reads = rv32_admin_smart_nonnegative(-5)
    val media_err = rv32_admin_smart_nonnegative(2)
    var crit = 0
    if media_err > 0:
        crit = 1
    if spare < 10:
        crit = 1
    if spare != 100 or used != 0 or reads != 0 or crit != 1:
        fail = fail + 1
    val low_spare = rv32_admin_smart_percent(8)
    crit = 0
    if low_spare < 10:
        crit = 1
    if crit != 1:
        fail = fail + 1
    crit = 0
    if media_err > 0:
        crit = 1
    if low_spare < 10:
        crit = 1
    if crit != 1:
        fail = fail + 1
    val boundary_spare = rv32_admin_smart_percent(10)
    crit = 0
    if boundary_spare < 10:
        crit = 1
    if crit != 0:
        fail = fail + 1
    val healthy_spare = rv32_admin_smart_percent(100)
    val healthy_media_err = rv32_admin_smart_nonnegative(0)
    crit = 0
    if healthy_media_err > 0:
        crit = 1
    if healthy_spare < 10:
        crit = 1
    if crit != 0:
        fail = fail + 1
    fail
