fn _rv32_journal_effective_count(wal_count: i64, cap: i64) -> i64:
    var n: i64 = wal_count
    var c: i64 = cap
    if n < 0:
        return 0
    if c < 0:
        return 0
    if c > 512:
        c = 512
    if n > c:
        n = c
    if n > 512:
        n = 512
    n

fn _rv32_journal_is_full(wal_count: i64, cap: i64) -> i32:
    val count: i64 = _rv32_journal_effective_count(wal_count, cap)
    if count >= cap:
        return 1
    if count >= 512:
        return 1
    0

fn _rv32_journal_append_count(wal_count: i64, cap: i64) -> i64:
    val count: i64 = _rv32_journal_effective_count(wal_count, cap)
    if count >= cap:
        return count
    if count >= 512:
        return count
    count + 1

fn _rv32_journal_record_lba(ridx: i64, wal_count: i64, cap: i64, lba0: i64, lba1: i64, lba2: i64) -> i64:
    if ridx < 0:
        return -1
    if ridx >= _rv32_journal_effective_count(wal_count, cap):
        return -1
    if ridx >= 512:
        return -1
    if ridx == 0:
        return lba0
    if ridx == 1:
        return lba1
    if ridx == 2:
        return lba2
    -1

fn _rv32_journal_record_seq(ridx: i64, wal_count: i64, cap: i64, seq0: i64, seq1: i64, seq2: i64) -> i64:
    if ridx < 0:
        return 0
    if ridx >= _rv32_journal_effective_count(wal_count, cap):
        return 0
    if ridx >= 512:
        return 0
    if ridx == 0:
        return seq0
    if ridx == 1:
        return seq1
    if ridx == 2:
        return seq2
    0

fn _rv32_journal_checkpoint_valid(seq: i64) -> i32:
    if seq < 0:
        return 0
    1

fn _rv32_journal_checkpoint_ptr(seq: i64) -> i64:
    if _rv32_journal_checkpoint_valid(seq) == 0:
        return -1
    seq

fn _rv32_journal_truncate_count(ckpt_seq: i64, seq0: i64, seq1: i64, seq2: i64) -> i64:
    var kept: i64 = 0
    if seq0 > ckpt_seq:
        kept = kept + 1
    if seq1 > ckpt_seq:
        kept = kept + 1
    if seq2 > ckpt_seq:
        kept = kept + 1
    kept

fn rv32_journal_selftest() -> i32:
    if _rv32_journal_effective_count(3, 512) != 3:
        return 1
    if _rv32_journal_effective_count(-4, 512) != 0:
        return 1
    if _rv32_journal_effective_count(513, 512) != 512:
        return 1
    if _rv32_journal_effective_count(3, -1) != 0:
        return 1
    if _rv32_journal_append_count(3, 512) != 4:
        return 1
    if _rv32_journal_append_count(512, 512) != 512:
        return 1
    if _rv32_journal_append_count(512, 513) != 512:
        return 1
    if _rv32_journal_is_full(511, 512) != 0:
        return 1
    if _rv32_journal_is_full(512, 512) != 1:
        return 1
    if _rv32_journal_record_lba(0, 3, 512, 100, 101, 102) != 100:
        return 1
    if _rv32_journal_record_lba(2, 3, 512, 100, 101, 102) != 102:
        return 1
    if _rv32_journal_record_lba(-1, 3, 512, 100, 101, 102) != -1:
        return 1
    if _rv32_journal_record_lba(3, 3, 512, 100, 101, 102) != -1:
        return 1
    if _rv32_journal_record_seq(1, 3, 512, 1, 2, 3) != 2:
        return 1
    if _rv32_journal_record_seq(3, 3, 512, 1, 2, 3) != 0:
        return 1
    if _rv32_journal_checkpoint_valid(2) != 1:
        return 1
    if _rv32_journal_checkpoint_valid(-1) != 0:
        return 1
    if _rv32_journal_checkpoint_ptr(2) != 2:
        return 1
    if _rv32_journal_checkpoint_ptr(-1) != -1:
        return 1
    if _rv32_journal_truncate_count(2, 1, 2, 3) != 1:
        return 1
    if _rv32_journal_truncate_count(3, 1, 2, 3) != 0:
        return 1
    0
