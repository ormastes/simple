use logic_journal_core.{_rv32_journal_effective_count, _rv32_journal_append_count, _rv32_journal_is_full, _rv32_journal_record_lba, _rv32_journal_record_seq, _rv32_journal_checkpoint_valid, _rv32_journal_checkpoint_ptr, _rv32_journal_truncate_count}

fn rv32_journal_selftest() -> i32:
    if _rv32_journal_effective_count(3, 512) != 3:
        return 1
    if _rv32_journal_effective_count(-4, 512) != 0:
        return 1
    if _rv32_journal_effective_count(513, 512) != 512:
        return 1
    if _rv32_journal_effective_count(3, -1) != 0:
        return 1
    if _rv32_journal_append_count(3, 512) != 4:
        return 1
    if _rv32_journal_append_count(512, 512) != 512:
        return 1
    if _rv32_journal_append_count(512, 513) != 512:
        return 1
    if _rv32_journal_is_full(511, 512) != 0:
        return 1
    if _rv32_journal_is_full(512, 512) != 1:
        return 1
    if _rv32_journal_record_lba(0, 3, 512, 100, 101, 102) != 100:
        return 1
    if _rv32_journal_record_lba(2, 3, 512, 100, 101, 102) != 102:
        return 1
    if _rv32_journal_record_lba(-1, 3, 512, 100, 101, 102) != -1:
        return 1
    if _rv32_journal_record_lba(3, 3, 512, 100, 101, 102) != -1:
        return 1
    if _rv32_journal_record_seq(1, 3, 512, 1, 2, 3) != 2:
        return 1
    if _rv32_journal_record_seq(3, 3, 512, 1, 2, 3) != 0:
        return 1
    if _rv32_journal_checkpoint_valid(2) != 1:
        return 1
    if _rv32_journal_checkpoint_valid(-1) != 0:
        return 1
    if _rv32_journal_checkpoint_ptr(2) != 2:
        return 1
    if _rv32_journal_checkpoint_ptr(-1) != -1:
        return 1
    if _rv32_journal_truncate_count(2, 1, 2, 3) != 1:
        return 1
    if _rv32_journal_truncate_count(3, 1, 2, 3) != 0:
        return 1
    0
