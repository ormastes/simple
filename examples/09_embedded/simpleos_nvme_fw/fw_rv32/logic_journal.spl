fn rv32_journal_effective_count(count: i64, cap: i64) -> i64:
    if count < 0:
        return 0
    if cap < 0:
        return 0
    var c = cap
    if c > 4:
        c = 4
    if count > c:
        return c
    count

fn rv32_journal_selftest() -> i64:
    # Four scalar slots stand in for the host Journal's pre-sized WAL arrays.
    var fail = 0
    var cap = 4
    var count = 0
    var ckpt_seq = 0
    var ckpt_valid = 0
    var sb_gen = 0
    var sb_ckpt_ptr = -1

    var lba0 = -1
    var new0 = -1
    var seq0 = 0
    var lba1 = -1
    var new1 = -1
    var seq1 = 0
    var lba2 = -1
    var new2 = -1
    var seq2 = 0
    var lba3 = -1
    var new3 = -1
    var seq3 = 0

    if rv32_journal_effective_count(-3, cap) != 0:
        fail = fail + 1
    if rv32_journal_effective_count(6, cap) != 4:
        fail = fail + 1
    if rv32_journal_effective_count(1, -1) != 0:
        fail = fail + 1

    lba0 = 100
    new0 = 20
    seq0 = 1
    count = count + 1
    lba1 = 101
    new1 = 21
    seq1 = 2
    count = count + 1
    lba2 = 102
    new2 = 22
    seq2 = 3
    count = count + 1
    if count != 3:
        fail = fail + 1
    if lba0 != 100 or new0 != 20 or seq0 != 1:
        fail = fail + 1
    if lba2 != 102 or new2 != 22 or seq2 != 3:
        fail = fail + 1

    lba3 = 103
    new3 = 23
    seq3 = 4
    count = count + 1
    if rv32_journal_effective_count(count, cap) != 4:
        fail = fail + 1
    if rv32_journal_effective_count(count + 1, cap) != 4:
        fail = fail + 1

    ckpt_seq = 2
    ckpt_valid = 1
    sb_gen = sb_gen + 1
    sb_ckpt_ptr = ckpt_seq
    if ckpt_valid != 1 or sb_gen != 1 or sb_ckpt_ptr != 2:
        fail = fail + 1
    ckpt_valid = 0
    if ckpt_valid == 1:
        sb_gen = sb_gen + 1
        sb_ckpt_ptr = 99
    if sb_gen != 1 or sb_ckpt_ptr != 2:
        fail = fail + 1

    # Truncate checkpointed records: seq 3 and 4 survive and compact into slots 0 and 1.
    lba0 = lba2
    new0 = new2
    seq0 = seq2
    lba1 = lba3
    new1 = new3
    seq1 = seq3
    lba2 = -1
    new2 = -1
    seq2 = 0
    lba3 = -1
    new3 = -1
    seq3 = 0
    count = 2
    if count != 2:
        fail = fail + 1
    if lba0 != 102 or new0 != 22 or seq0 != 3:
        fail = fail + 1
    if lba1 != 103 or new1 != 23 or seq1 != 4:
        fail = fail + 1
    if lba2 != -1 or new2 != -1 or seq2 != 0:
        fail = fail + 1

    ckpt_seq = 4
    sb_gen = sb_gen + 1
    sb_ckpt_ptr = ckpt_seq
    if sb_gen != 2 or sb_ckpt_ptr != 4:
        fail = fail + 1
    fail
