use logic_map_core.*

fn rv32_map_update_cases_selftest() -> i32:
    if _rv32_map_counter(-3) != 0:
        return 1
    if _rv32_map_dirty_after_update(10, 100) != 1:
        return 1
    if _rv32_map_dirty_after_update(1024, 100) != 0:
        return 1
    if _rv32_map_dirty_after_update(10, 4096) != 0:
        return 1
    0
