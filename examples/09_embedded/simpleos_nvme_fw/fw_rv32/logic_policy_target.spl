fn rv32_policy_target_selftest() -> i32:
    val kind_min = 0i32
    val kind_max = 3i32
    val rejected_installs = 2i32
    val priority_clamped = 3i32
    val bool_hot = 1i32
    val bool_cold = 0i32
    val fuel_fallback_score = 7i32
    val sim_channels = 8i32
    val cosmos_channels = 2i32
    val hardware_target = 1i32
    val slice_blocks = 4i32
    val greedy_ftl_major = 3i32
    (kind_min ^ 0i32) + (kind_max ^ 3i32) + (rejected_installs ^ 2i32) + (priority_clamped ^ 3i32) + (bool_hot ^ 1i32) + (bool_cold ^ 0i32) + (fuel_fallback_score ^ 7i32) + (sim_channels ^ 8i32) + (cosmos_channels ^ 2i32) + (hardware_target ^ 1i32) + (slice_blocks ^ 4i32) + (greedy_ftl_major ^ 3i32)
