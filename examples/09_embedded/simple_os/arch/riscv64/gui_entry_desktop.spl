# codex-impl
# Canonical RV64 production desktop over dynamic VirtIO-GPU scanout.

use os.kernel.arch.riscv64.display.{
    riscv64_display_boot_memory_initialize,
    riscv64_display_initialize,
    riscv64_display_framebuffer_address,
    riscv64_display_width,
    riscv64_display_height,
    riscv64_display_pitch,
    riscv64_display_bpp,
    riscv64_display_present
}
use os.drivers.framebuffer.fb_driver.{FramebufferDriver}
use os.compositor.compositor.{Compositor}
use os.compositor.compositor_engine2d.{Engine2dCompositorBackend}
use os.compositor.engine2d_display.{create_fb_engine_sized}
use os.compositor.engine2d_wm_frame_executor.{Engine2dWmFrameExecutor}
use os.desktop.shell.{DesktopShell}
use os.kernel.arch.riscv64.console.{serial_init, serial_read_byte}
use os.gui.input_event.{WmAction}
use os.gui.shortcut.{uart_char_to_action}
use os.kernel.ipc.host_gpu_ivshmem_map.{
    map_qemu_host_gpu_ivshmem_bar2,
    qemu_host_gpu_ivshmem_window_base
}
use os.kernel.boot.monotonic_hardware.{boot_monotonic_prepare, boot_monotonic_now_us}
use common.gpu.simpleos_host_gpu_protocol.{
    SIMPLEOS_HOST_GPU_BACKEND_METAL,
    SIMPLEOS_HOST_GPU_ISA_RISCV64
}

extern fn serial_println(msg: text)
extern fn __simple_call_module_inits()

fn boot_main(hart_id: u64, dtb_addr: u64):
    val _hart_id = hart_id
    val _dtb_addr = dtb_addr
    serial_println("[desktop-gui-riscv64] boot")

    if not riscv64_display_boot_memory_initialize():
        serial_println("[desktop-gui-riscv64] fatal reason=display-memory")
        return
    __simple_call_module_inits()
    serial_init()
    if not riscv64_display_initialize():
        serial_println("[desktop-gui-riscv64] fatal reason=scanout-init")
        return

    val width = riscv64_display_width()
    val height = riscv64_display_height()
    val pitch = riscv64_display_pitch()
    val bpp = riscv64_display_bpp()
    val address = riscv64_display_framebuffer_address()
    if address == 0u64 or width == 0u32 or height == 0u32 or pitch != width * 4u32 or bpp != 32u32:
        serial_println("[desktop-gui-riscv64] fatal reason=scanout-metadata")
        return
    serial_println("[desktop-gui-riscv64] scanout-ready width={width} height={height} stride={pitch}")
    val screen_w = width.to_i64()
    val screen_h = height.to_i64()

    var framebuffer = FramebufferDriver.from_scanout_raw(address, width, height, pitch, bpp)
    var engine = create_fb_engine_sized(framebuffer, width.to_i32(), height.to_i32())
    val compositor_backend = Engine2dCompositorBackend.create(engine)
    var compositor = Compositor.with_backends(
        compositor_backend, nil, width.to_i32(), height.to_i32()
    )

    val terminal_id = compositor.compositor_materialize_process_surface_scalar(
        "Terminal", (screen_w / 20).to_i32(), (screen_h / 8).to_i32(),
        (screen_w * 9 / 20).to_i32(), (screen_h * 2 / 5).to_i32(),
        0, "terminal", "<pre>simple$ uname -m\nriscv64\nsimple$ simple check\nAll checks passed\nsimple$</pre>"
    )
    val editor_id = compositor.compositor_materialize_process_surface_scalar(
        "Editor", (screen_w * 7 / 20).to_i32(), (screen_h / 4).to_i32(),
        (screen_w / 2).to_i32(), (screen_h / 2).to_i32(),
        0, "editor", "<pre>fn main():\n    val x = 42\n    print x\n\n# Comment\nfn square(n):\n    n * n</pre>"
    )
    val finder_id = compositor.compositor_materialize_process_surface_scalar(
        "Finder", (screen_w * 3 / 5).to_i32(), (screen_h * 3 / 5).to_i32(),
        (screen_w * 7 / 20).to_i32(), (screen_h * 3 / 10).to_i32(),
        0, "finder", "<h2>Favorites</h2><p>Desktop</p><p>Documents</p><p>Downloads</p><h3>Project</h3><p>Photos</p>"
    )
    if terminal_id <= 0 or editor_id <= 0 or finder_id <= 0:
        serial_println("[desktop-gui-riscv64] fatal reason=surface-materialization")
        return
    compositor.focus_window(editor_id.to_i32())

    var shell = DesktopShell.new(compositor)
    shell.init_baremetal()

    boot_monotonic_prepare()
    val mapped_slot = map_qemu_host_gpu_ivshmem_bar2()
    val host_gpu_base = qemu_host_gpu_ivshmem_window_base(mapped_slot)
    val negotiation_started_us = boot_monotonic_now_us()
    var executor = Engine2dWmFrameExecutor.create(engine, framebuffer)
    if host_gpu_base != 0u64:
        executor = Engine2dWmFrameExecutor.create_host_gpu(
            engine, framebuffer, host_gpu_base,
            SIMPLEOS_HOST_GPU_ISA_RISCV64,
            SIMPLEOS_HOST_GPU_BACKEND_METAL,
            0, 0, negotiation_started_us
        )

    val revision = shell.render_baremetal_first_frame(executor)
    if revision <= 0:
        serial_println("[desktop-gui-riscv64] fatal reason=first-frame")
        return
    if not riscv64_display_present():
        serial_println("[desktop-gui-riscv64] fatal reason=scanout-present")
        return

    serial_println("[desktop-gui-riscv64] present-ok revision={revision}")
    serial_println("[desktop-gui-riscv64] desktop-ready revision={revision}")
    serial_println("[backend-evidence] present=virtio-gpu-transfer+flush source=shared-wm-draw-ir-engine2d")
    serial_println("TEST PASSED")
    serial_println("SIMPLEOS_RISCV_DISPLAY_SMOKE_READY")
    serial_println("[desktop-gui-riscv64] controls Tab=cycle 1/2/3=focus m=minimize w=close r=restore q=quit")

    var running = true
    while running:
        val input_byte = serial_read_byte()
        if input_byte < 0:
            continue

        val action = uart_char_to_action(input_byte.to_u64())
        var input_compositor = shell.compositor
        var changed = false

        match action:
            case WmAction.CycleFocus:
                input_compositor.cycle_focus()
                changed = true
            case WmAction.FocusWindow(idx: surface_index):
                if surface_index < input_compositor.surfaces.len().to_u64():
                    input_compositor.focus_window(
                        input_compositor.surfaces[surface_index.to_i64()].id.to_i32()
                    )
                    changed = true
            case WmAction.Quit:
                running = false
            case WmAction.Minimize:
                val focused = input_compositor.focused_idx
                if focused >= 0 and focused < input_compositor.surfaces.len():
                    input_compositor.minimize_window(input_compositor.surfaces[focused].id.to_u64())
                    changed = true
            case WmAction.Close:
                val focused = input_compositor.focused_idx
                if focused >= 0 and focused < input_compositor.surfaces.len():
                    input_compositor.destroy_window(input_compositor.surfaces[focused].id)
                    changed = true
            case WmAction.Restore:
                var surface_index = 0
                while surface_index < input_compositor.surfaces.len():
                    input_compositor.restore_window(input_compositor.surfaces[surface_index].id.to_u64())
                    surface_index = surface_index + 1
                changed = true
            case WmAction.ToggleTheme:
                pass
            case WmAction.None:
                pass

        if changed:
            shell.compositor = input_compositor
            val rendered_revision = shell.render_baremetal_frame(executor)
            if rendered_revision <= 0:
                serial_println("[desktop-gui-riscv64] fatal reason=changed-frame")
                running = false
            elif not riscv64_display_present():
                serial_println("[desktop-gui-riscv64] fatal reason=changed-present")
                running = false

    serial_println("[desktop-gui-riscv64] shutdown")
