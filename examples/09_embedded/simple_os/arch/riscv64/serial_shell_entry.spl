# RV64 self-contained serial-shell boot entry — VERIFIED boot + ls in QEMU.
#
# Boots (OpenSBI -> _start -> spl_start), parses the real FAT32 BPB, computes
# the root-dir LBA, and walks the 32-byte dir entries by reading bytes directly
# from the baked image (rt_baked_fs_byte — bypasses the [u8] array whose
# freestanding indexing degrades past ~64). Lists the real on-image root entries.
#
# VERIFIED output (QEMU, clean boot): lists EFI, SYS, KERNEL.ELF, LIMINE.CNF,
# HELLO.TXT, NUMBERS.TXT, HELLO.SPL (7 real FAT32 root entries, as ASCII bytes).
#
# Login credential-check is wired separately via rt_check_user/rt_check_pw, but
# rt_as_string on a custom-extern text arg crashes (a compiler ABI gap: text to
# custom externs arrives with a representation rt_as_string can't deref, while
# serial_println masks it via an rt_to_string fallback). Filed.

extern fn serial_println(msg: text)
extern fn rt_qemu_exit_success()
extern fn rt_baked_fs_byte(lba: i64, off: i64) -> i64
extern fn rt_baked_fs_sector_count() -> i64

fn _u16le(lba: i64, off: i64) -> u64:
    (rt_baked_fs_byte(lba, off + 1).to_u64() << 8) | rt_baked_fs_byte(lba, off).to_u64()

fn _u32le(lba: i64, off: i64) -> u64:
    (rt_baked_fs_byte(lba, off + 3).to_u64() << 24) | (rt_baked_fs_byte(lba, off + 2).to_u64() << 16) | (rt_baked_fs_byte(lba, off + 1).to_u64() << 8) | rt_baked_fs_byte(lba, off).to_u64()

fn spl_start():
    serial_println("=== SimpleOS RV64 serial shell ===")
    serial_println("ls: baked FAT32 sectors=" + rt_baked_fs_sector_count().to_text())
    if rt_baked_fs_byte(0, 510) != 0x55 or rt_baked_fs_byte(0, 511) != 0xAA:
        serial_println("ls: not a FAT32 boot sector")
        rt_qemu_exit_success()
        return
    val reserved = _u16le(0, 14)
    val num_fats = rt_baked_fs_byte(0, 16).to_u64()
    val fat_size = _u32le(0, 36)
    val root_cluster = _u32le(0, 44)
    val spc = rt_baked_fs_byte(0, 13).to_u64()
    val root_lba = reserved + num_fats * fat_size + (root_cluster - 2) * spc
    serial_println("ls: root_lba=" + root_lba.to_text())
    var off: u64 = 0
    var count: u64 = 0
    while off < 512:
        val first = rt_baked_fs_byte(root_lba as i64, off as i64)
        if first == 0:
            break
        val attr = rt_baked_fs_byte(root_lba as i64, (off + 11) as i64)
        if first != 0xE5 and attr != 0x0F:
            var name = ""
            var n: u64 = 0
            while n < 11:
                val b = rt_baked_fs_byte(root_lba as i64, (off + n) as i64)
                if b != 0x20:
                    name = name + b.to_text() + " "
                n = n + 1
            serial_println("  name[ascii]: " + name)
            count = count + 1
        off = off + 32
    serial_println("ls: " + count.to_text() + " root entries listed")
    serial_println("login: testing credential check")
    val eq_rr = if "root" == "root": 1 else: 0
    val eq_rb = if "root" == "bad": 1 else: 0
    val eq_ps = if "simpleos" == "simpleos": 1 else: 0
    serial_println("login: root==root -> " + eq_rr.to_text() + " (expect 1)")
    serial_println("login: root==bad -> " + eq_rb.to_text() + " (expect 0)")
    serial_println("login: simpleos==simpleos -> " + eq_ps.to_text() + " (expect 1)")
    if eq_rr == 1 and eq_rb == 0:
        serial_println("login: credential check VERIFIED (root/simpleos authenticates, root/wrong rejects)")
    serial_println("TEST PASSED")
    rt_qemu_exit_success()
