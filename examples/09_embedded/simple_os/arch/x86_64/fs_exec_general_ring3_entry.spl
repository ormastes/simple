# x86_64 GENERAL-spawn ring-3 verification entry.
#
# The rung above ring3_smoke_entry.spl. ring3_smoke mapped a raw embedded machine-
# code buffer to prove the bare ring-3 handoff. This entry proves the SAME handoff
# for bytes that flow through the REAL general spawn image builder:
#
#   1. Materialise a small known ELF (build/os/elfexec/fsexec_hello.elf, embedded
#      into the kernel as a .rodata blob by scripts/os/build_fsexec_general_ring3.shs)
#      into a Simple [u8].
#   2. Feed it to build_user_process_image_unchecked — the GENERAL spawn image
#      builder used by fs_exec_prepare_spawn_from_bytes — producing a real
#      UserProcessImage (this exercises the general path; its file_bytes is always
#      valid even though its module-val-bound structured fields are unreliable
#      under freestanding native-build).
#   3. Hand the image to x86_64_fs_exec_enter_image_ring3 — the missing control-
#      transfer handoff — which maps it into a fresh user AS and iretq's to CPL3.
#
# The payload writes "FDR\n" via `out` (only possible when CPL <= IOPL, i.e.
# genuinely ring 3) then "FSEXEC_OK rc=42\n" via syscall 60, then exits QEMU via
# `out 0xf4`. "FDR" on serial alone is definitive ring-3 proof.
#
# Freestanding discipline (module-level `val` initializers do not run under
# native-build): all constants function-local, explicit parens on zero-arg calls.

extern fn serial_println(msg: text)
extern fn rt_debug_exit_success()
extern fn rt_x86_tss_init() -> i64
extern fn fsexec_hello_blob_size() -> u64
extern fn fsexec_hello_blob_byte(i: u64) -> u8

use os.kernel.arch.x86_64.arch_init.{arch_x86_64_early_init}
use os.kernel.memory.pmm.{pmm_init_identity_range, g_pmm}
use os.kernel.memory.vmm.{vmm_init}
use os.kernel.arch.arch_context.{Architecture}
use os.kernel.loader.process_image.{build_user_process_image_unchecked}
use os.kernel.loader.x86_64_fs_exec_ring3.{x86_64_fs_exec_enter_image_ring3}

fn _materialize_blob() -> [u8]:
    """Copy the embedded ELF blob into a Simple [u8] via a C per-byte accessor
    (C indexes its own array — no MMIO / addr translation). This is the byte-
    source bridge the general builder consumes."""
    val size = fsexec_hello_blob_size()
    var out: [u8] = []
    var i: u64 = 0
    while i < size:
        out.push(fsexec_hello_blob_byte(i))
        i = i + 1
    out

fn spl_start():
    serial_println("")
    serial_println("=== SimpleOS x86_64 general-spawn ring-3 ===")

    arch_x86_64_early_init()
    serial_println("[gen] arch-init + syscall MSRs done")
    rt_x86_tss_init()

    # Materialise the embedded ELF blob into a Simple [u8] BEFORE pmm/vmm init.
    # The blob's rodata lives in the tail of the ~20 MB kernel image, and the
    # early VMM page-table allocator bump-allocates frames right after the image
    # (observed: blob at 0x1450b30, cr3 at 0x145f000) — clobbering the blob if it
    # is read after vmm_init. Copying it to the Simple heap first keeps it intact.
    val bytes = _materialize_blob()
    var b0: i64 = 0
    var b1: i64 = 0
    var b2: i64 = 0
    var b3: i64 = 0
    if bytes.len() >= 4:
        b0 = bytes[0].to_i64()
        b1 = bytes[1].to_i64()
        b2 = bytes[2].to_i64()
        b3 = bytes[3].to_i64()
    serial_println("[gen] blob materialized len={bytes.len()} magic={b0},{b1},{b2},{b3}")

    if not pmm_init_identity_range(0x20000000, 0x100000, 0x14000000):
        serial_println("[gen] FAIL pmm_init")
        serial_println("TEST FAILED")
        rt_debug_exit_success()
        return
    vmm_init(g_pmm, 0)
    serial_println("[gen] pmm+vmm online")

    # THE GENERAL SPAWN IMAGE BUILDER (same one fs_exec_prepare_spawn_from_bytes
    # calls). Not the hardcoded smoke blob path.
    val image = build_user_process_image_unchecked(
        "/sys/apps/fsexec_hello.elf", bytes, Architecture.X86_64, [], []
    )
    serial_println("[gen] general image built")

    # THE MISSING HANDOFF: map + enter ring 3. Does not return on success.
    val rc = x86_64_fs_exec_enter_image_ring3(image)
    serial_println("[gen] handoff returned rc={rc} (unexpected)")
    serial_println("TEST FAILED")
    rt_debug_exit_success()
