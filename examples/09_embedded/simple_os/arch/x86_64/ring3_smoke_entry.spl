# x86_64 ring-3 execution smoke — P0-C QEMU keystone.
#
# Boots via Multiboot1 on q35, brings PMM/VMM online, builds a user address
# space, maps a tiny freestanding user program, and iretq's into CPL 3. The
# user program writes "USEROK\n" one byte at a time DIRECTLY to COM1 (port
# 0x3F8) via `out` (enabled by IOPL=3 in the ring-3 RFLAGS), then exits QEMU by
# writing to the isa-debug-exit port 0xf4 — all from ring 3.
#
# Ring-3 proof on serial: "USEROK" is produced by `out` instructions that can
# only run when CPL <= IOPL, i.e. genuinely from the ring-3 task. A subsequent
# clean QEMU exit (code 1) driven by the ring-3 `out 0xf4` confirms control
# reached and left ring 3 deterministically.
#
# The ring-3 user CS/DS/SS selectors (0x28/0x20 DPL3) come from the GDT that
# crt0.s already loaded at boot, so no new GDT is installed here. (The Simple
# gdt_init() in os.kernel.interrupts.gdt would install a GDT+TSS, but that whole
# `interrupts` package is dead code that does not currently compile under
# native-build; wiring it is tracked separately.)
#
# No syscalls / VFS / FAT32 / SMF / ELF parsing: the user machine code is an
# embedded raw byte buffer so the only thing under test is the ring-3 handoff
# mechanism (per-process paging + iretq).

extern fn serial_println(msg: text)
extern fn rt_debug_exit_success()
extern fn pmm_alloc_page_raw() -> u64

use os.kernel.arch.x86_64.arch_init.{arch_x86_64_early_init}
use os.kernel.memory.pmm.{pmm_init_identity_range, g_pmm}
use os.kernel.memory.vmm.{vmm_init}
use os.kernel.memory.vmm_address_space.{
    create_user_address_space, vmm_map_page_in,
    vmm_clone_kernel_low_identity
}
use os.kernel.types.memory_types.{VmFlags, VirtAddr, PhysAddr}
use os.kernel.types.task_types.{TaskContext, AddressSpace}
use os.kernel.arch.x86_64.context.{arch_x86_64_enter_user_task}
use os.kernel.boot.mmio.{mmio_write64}

# User virtual layout — placed in PML4[1] (>= 512GB) so the fresh USER page
# chain never collides with the shared kernel identity subtree in PML4[0].
# NOTE: these are computed as function-local `val`s inside `spl_start` (see
# below), not module-level `val`s: freestanding native-build does not run
# module-level `val` initializers, so a top-level `val USER_CODE_VA = 0x80...`
# reads garbage at runtime (observed: RIP=0xc35d... non-canonical -> triple
# fault before user code executes).

fn _write_hello_code(dst_phys: u64):
    """Write the freestanding x86-64 user machine code (35 bytes) to `dst_phys`
    as five little-endian u64 words via mmio_write64 (hhdm=0: phys==virt).

    Byte stream: 66 BA F8 03 (mov dx,0x3F8/COM1) then for each byte of
    "USEROK\n": B0 <ch> EE (mov al,ch / out dx,al); then 66 BA F4 00 B0 00 EE
    (dx=0xF4, al=0, out -> isa-debug-exit, QEMU exits code 1); F4 EB FD
    (hlt; jmp $-3 guard).

    Written as u64 literals instead of a `[u8]` array literal: under
    freestanding cranelift native-build the array literal's data pointer is
    garbage (code[0] read 0x30 instead of 0x66 and vmm_copy_bytes_to_phys
    copied nothing, leaving the page zeroed -> ring-3 executed 00 00 and
    faulted with CR2=0)."""
    mmio_write64(dst_phys,      0xB0EE55B003F8BA66)  # 66 BA F8 03 B0 55 EE B0
    mmio_write64(dst_phys + 8,  0xEE52B0EE45B0EE53)  # 53 EE B0 45 EE B0 52 EE
    mmio_write64(dst_phys + 16, 0x0AB0EE4BB0EE4FB0)  # B0 4F EE B0 4B EE B0 0A
    mmio_write64(dst_phys + 24, 0xEE00B000F4BA66EE)  # EE 66 BA F4 00 B0 00 EE
    mmio_write64(dst_phys + 32, 0x0000000000FDEBF4)  # F4 EB FD 00 00 00 00 00

fn spl_start():
    serial_println("")
    serial_println("=== SimpleOS x86_64 ring-3 smoke ===")

    # User virtual layout (function-local: module-level `val` initializers do
    # not run under freestanding native-build). PML4[1] (>= 512GB).
    val USER_CODE_VA: u64  = 0x8000000000
    val USER_STACK_VA: u64 = 0x8000100000

    # 1. Early arch init (rich fault hook so any unexpected ring-3 fault prints a
    #    CS RPL=3 register frame; also programs the SYSCALL MSRs, unused here).
    arch_x86_64_early_init()
    serial_println("[ring3] arch-init done")

    # 2. Bring PMM + VMM online (identity, hhdm=0). Same recipe as desktop-e2e.
    if not pmm_init_identity_range(0x20000000, 0x100000, 0x14000000):
        serial_println("[ring3] FAIL pmm_init")
        serial_println("TEST FAILED")
        rt_debug_exit_success()
        return
    vmm_init(g_pmm, 0)
    serial_println("[ring3] pmm+vmm online")

    # 3. Fresh user address space + clone the kernel low identity so the running
    #    kernel survives the CR3 swap inside the iretq trampoline.
    val space = create_user_address_space()
    if space.phys_root == 0 or space.phys_root == 1:
        serial_println("[ring3] FAIL user-AS synthetic root={space.phys_root}")
        serial_println("TEST FAILED")
        rt_debug_exit_success()
        return
    vmm_clone_kernel_low_identity(space.phys_root)
    serial_println("[ring3] user AS ready root={space.phys_root}")

    # 4. Map the user code page (rx) and a user stack page (rw), writing the
    #    machine code into the freshly-allocated code frame word-by-word.
    val code_phys = pmm_alloc_page_raw()
    val stack_phys = pmm_alloc_page_raw()
    if code_phys == 0 or stack_phys == 0:
        serial_println("[ring3] FAIL user page alloc")
        serial_println("TEST FAILED")
        rt_debug_exit_success()
        return
    _write_hello_code(code_phys)
    val mapped_code = vmm_map_page_in(space, VirtAddr(addr: USER_CODE_VA), PhysAddr(addr: code_phys), VmFlags.user_rx())
    val mapped_stack = vmm_map_page_in(space, VirtAddr(addr: USER_STACK_VA), PhysAddr(addr: stack_phys), VmFlags.user_rw())
    if not mapped_code or not mapped_stack:
        serial_println("[ring3] FAIL page map code={mapped_code} stack={mapped_stack}")
        serial_println("TEST FAILED")
        rt_debug_exit_success()
        return
    serial_println("[ring3] user pages mapped code_va=0x{USER_CODE_VA} stack_va=0x{USER_STACK_VA}")

    # 5. Build the ring-3 iret frame and jump. User CS=0x2b (0x28|3), SS=0x23
    #    (0x20|3) from crt0's GDT. RFLAGS=0x3002: IOPL=3 (ring-3 `out` allowed),
    #    IF cleared (no timer interrupt), reserved bit 1 set.
    val user_rsp = USER_STACK_VA + 0x1000 - 16
    val ctx = TaskContext(
        rax: 0, rbx: 0, rcx: 0, rdx: 0,
        rsi: 0, rdi: 0, rbp: 0, rsp: user_rsp,
        r8: 0, r9: 0, r10: 0, r11: 0,
        r12: 0, r13: 0, r14: 0, r15: 0,
        rip: USER_CODE_VA,
        rflags: 0x3002,
        cs: 0x2b,
        ss: 0x23,
        fpu_state: 0
    )
    serial_println("[ring3] entering user cs=0x2b iopl=3 rip=0x{USER_CODE_VA}")
    arch_x86_64_enter_user_task(ctx, space.phys_root)

    # Only reached if the trampoline returns (it should not).
    serial_println("[ring3] returned from user (unexpected)")
    serial_println("TEST FAILED")
    rt_debug_exit_success()
