# codex-impl
# Canonical ARM64 production desktop entry for QEMU virt ramfb.

use std.nogc_sync_mut.ptr.raw.{raw_alloc}
use examples.simple_os.arch.arm64.wm_entry_io.{
    FRAMEBUFFER_SIZE,
    SCREEN_H,
    SCREEN_W,
    setup_ramfb,
    uart_char_to_action,
    uart_data_ready,
    uart_read_char
}
use os.kernel.arch.arm64.console.{uart_writeln}
use os.drivers.framebuffer.fb_driver.{FramebufferDriver}
use os.compositor.compositor.{Compositor}
use os.compositor.compositor_engine2d.{Engine2dCompositorBackend}
use os.compositor.engine2d_display.{create_fb_engine_sized}
use os.compositor.engine2d_wm_frame_executor.{Engine2dWmFrameExecutor}
use os.desktop.shell.{DesktopShell}
use os.kernel.ipc.host_gpu_ivshmem_map.{
    map_qemu_host_gpu_ivshmem_bar2,
    qemu_host_gpu_ivshmem_window_base
}
use common.gpu.simpleos_host_gpu_protocol.{
    SIMPLEOS_HOST_GPU_BACKEND_METAL,
    SIMPLEOS_HOST_GPU_ISA_AARCH64
}

fn spl_start():
    val screen_width = SCREEN_W.to_i32()
    val screen_height = SCREEN_H.to_i32()

    uart_writeln("[desktop-gui-arm64] boot")
    val framebuffer_address = raw_alloc(FRAMEBUFFER_SIZE.to_i64())
    if framebuffer_address == 0:
        uart_writeln("[desktop-gui-arm64] fatal reason=framebuffer-allocation")
        return

    if setup_ramfb(framebuffer_address.to_u64()) == 0:
        uart_writeln("[desktop-gui-arm64] ramfb unavailable; rendering remains local")

    var framebuffer = FramebufferDriver.from_scanout_raw(
        framebuffer_address.to_u64(),
        screen_width.to_u32(),
        screen_height.to_u32(),
        (screen_width * 4).to_u32(),
        32u32
    )
    var engine = create_fb_engine_sized(framebuffer, screen_width, screen_height)
    val compositor_backend = Engine2dCompositorBackend.create(engine)
    var compositor = Compositor.with_backends(
        compositor_backend,
        nil,
        screen_width,
        screen_height
    )

    val terminal_id = compositor.compositor_materialize_process_surface_scalar(
        "Terminal", 60, 60, 420, 260, 0, "terminal",
        "<pre>simple$ uname -m\naarch64\nsimple$ simple check\nAll checks passed\nsimple$</pre>"
    )
    val editor_id = compositor.compositor_materialize_process_surface_scalar(
        "Editor", 300, 160, 480, 300, 0, "editor",
        "<pre>fn main():\n    val x = 42\n    print x\n\n# Comment\nfn square(n):\n    n * n</pre>"
    )
    val finder_id = compositor.compositor_materialize_process_surface_scalar(
        "Finder", 540, 300, 360, 240, 0, "finder",
        "<h2>Favorites</h2><p>Desktop</p><p>Documents</p><p>Downloads</p><h3>Project</h3><p>Photos</p>"
    )
    if terminal_id <= 0 or editor_id <= 0 or finder_id <= 0:
        uart_writeln("[desktop-gui-arm64] fatal reason=surface-materialization")
        return
    compositor.focus_window(editor_id.to_i32())

    var shell = DesktopShell.new(compositor)
    shell.init_baremetal()

    val mapped_slot = map_qemu_host_gpu_ivshmem_bar2()
    val host_gpu_base = qemu_host_gpu_ivshmem_window_base(mapped_slot)
    var wm_frame_executor = Engine2dWmFrameExecutor.create(engine, framebuffer)
    if host_gpu_base != 0u64:
        wm_frame_executor = Engine2dWmFrameExecutor.create_host_gpu(
            engine, framebuffer, host_gpu_base,
            SIMPLEOS_HOST_GPU_ISA_AARCH64,
            SIMPLEOS_HOST_GPU_BACKEND_METAL
        )

    val first_revision = shell.render_baremetal_first_frame(wm_frame_executor)
    if first_revision <= 0:
        uart_writeln("[desktop-gui-arm64] fatal reason=first-frame")
        return
    uart_writeln("[desktop-gui-arm64] desktop-ready revision={first_revision}")
    uart_writeln("[desktop-gui-arm64] controls Tab=cycle 1/2/3=focus m=minimize w=close r=restore q=quit")

    var running = true
    while running:
        if uart_data_ready() == 1:
            val action = uart_char_to_action(uart_read_char())
            var input_compositor = shell.compositor
            var changed = false

            if action == 1:
                input_compositor.cycle_focus()
                changed = true
            elif action == 10:
                input_compositor.focus_window(terminal_id.to_i32())
                changed = true
            elif action == 11:
                input_compositor.focus_window(editor_id.to_i32())
                changed = true
            elif action == 12:
                input_compositor.focus_window(finder_id.to_i32())
                changed = true
            elif action == 3:
                running = false
            elif action == 4:
                val focused = input_compositor.focused_idx
                if focused >= 0 and focused < input_compositor.surfaces.len():
                    input_compositor.minimize_window(input_compositor.surfaces[focused].id.to_u64())
                    changed = true
            elif action == 5:
                val focused = input_compositor.focused_idx
                if focused >= 0 and focused < input_compositor.surfaces.len():
                    input_compositor.destroy_window(input_compositor.surfaces[focused].id)
                    changed = true
            elif action == 6:
                var surface_index = 0
                while surface_index < input_compositor.surfaces.len():
                    input_compositor.restore_window(input_compositor.surfaces[surface_index].id.to_u64())
                    surface_index = surface_index + 1
                changed = true

            if changed:
                shell.compositor = input_compositor
                val rendered_revision = shell.render_baremetal_frame(wm_frame_executor)
                if rendered_revision <= 0:
                    uart_writeln("[desktop-gui-arm64] fatal reason=changed-frame")
                    running = false

    uart_writeln("[desktop-gui-arm64] shutdown")
