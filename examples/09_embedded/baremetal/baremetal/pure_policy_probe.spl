use std.nogc_async_mut_noalloc.baremetal.interrupt_policy.{
    BAREMETAL_VECTOR_EXTERNAL_IRQ,
    baremetal_interrupt_choose,
    baremetal_interrupt_vector_kind
}
use std.nogc_async_mut_noalloc.baremetal.startup_policy.{
    baremetal_startup_stack_top
}
use std.nogc_async_mut_noalloc.baremetal.semihost_policy.{
    BAREMETAL_SEMIHOST_OP_WRITE0
}
use std.nogc_async_mut_noalloc.baremetal.stdout_plan.{
    baremetal_stdout_plan,
    baremetal_stdout_plan_uses_uart
}

fn main() -> i64:
    val stdout = baremetal_stdout_plan(false, false, false, true, 1u32)
    val stack_top = baremetal_startup_stack_top(0x80000000u32, 0x10000u32)
    val interrupt = baremetal_interrupt_choose("riscv32", 0x0C000000u32)
    if not baremetal_stdout_plan_uses_uart(stdout):
        return 2
    if stdout.semihost_op != BAREMETAL_SEMIHOST_OP_WRITE0:
        return 3
    if stack_top != 0x80010000u32:
        return 4
    if baremetal_interrupt_vector_kind(interrupt, 11) != BAREMETAL_VECTOR_EXTERNAL_IRQ:
        return 5
    0
