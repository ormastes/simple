# VCD Waveform Dumper
#
# Generates Value Change Dump (VCD) files compatible with GTKWave (REQ-SIM-007).
# IEEE 1364-2001 compliant VCD format.

# ============================================================================
# Signal Trace Entry
# ============================================================================

struct SignalTrace:
    """One signal change event."""
    time: i64
    signal_id: text
    value: i64
    width: i64

impl SignalTrace:
    static fn new(time: i64, signal_id: text, value: i64, width: i64) -> SignalTrace:
        SignalTrace(time: time, signal_id: signal_id, value: value, width: width)

# ============================================================================
# VCD Signal Definition
# ============================================================================

struct VcdSignalDef:
    """Definition of a signal in the VCD header."""
    name: text
    short_id: text      # Short identifier (e.g., "!", "#", "$")
    width: i64
    is_register: bool

impl VcdSignalDef:
    static fn new(name: text, short_id: text, width: i64, is_register: bool) -> VcdSignalDef:
        VcdSignalDef(name: name, short_id: short_id, width: width, is_register: is_register)

# ============================================================================
# Waveform Dumper
# ============================================================================

class WaveformDumper:
    """Generates VCD waveform output (AC-005).

    Usage:
        var dumper = WaveformDumper.new("rv32_sim")
        dumper.add_signal("clk", 1, true)
        dumper.add_signal("pc", 32, true)
        dumper.add_signal("inst_word", 32, false)
        dumper.begin_dump()
        dumper.set_time(0)
        dumper.emit_change("pc", 0x80000000, 32)
        dumper.set_time(10)
        dumper.emit_change("pc", 0x80000004, 32)
        val vcd_text = dumper.finish()
    """
    module_name: text
    signals: [VcdSignalDef]
    traces: [SignalTrace]
    current_time: i64
    _next_id: i64
    _signal_map: [text]     # index -> short_id lookup for fast emit

impl WaveformDumper:
    static fn new(module_name: text) -> WaveformDumper:
        WaveformDumper(
            module_name: module_name,
            signals: [],
            traces: [],
            current_time: 0,
            _next_id: 0,
            _signal_map: []
        )

    me add_signal(name: text, width: i64, is_register: bool):
        """Register a signal for the VCD header."""
        val short_id = self._make_id()
        self.signals.push(VcdSignalDef.new(name, short_id, width, is_register))
        self._signal_map.push(short_id)

    me set_time(time: i64):
        """Advance the VCD time."""
        self.current_time = time

    me emit_change(name: text, value: i64, width: i64):
        """Record a signal value change at the current time."""
        val short_id = self._find_signal_id(name)
        if short_id != "":
            self.traces.push(SignalTrace.new(self.current_time, short_id, value, width))

    fn finish() -> text:
        """Generate complete VCD text output."""
        var out = self._header()
        out = out + self._initial_values()
        out = out + self._value_changes()
        out

    fn signal_count() -> i64:
        self.signals.len()

    fn trace_count() -> i64:
        self.traces.len()

    # ========================================================================
    # Internal helpers
    # ========================================================================

    fn _header() -> text:
        var out = "$date\n  2026-03-30\n$end\n"
        out = out + "$version\n  Simple RV32 Hybrid Simulator VCD 1.0\n$end\n"
        out = out + "$timescale\n  1ns\n$end\n"
        out = out + "$scope module {self.module_name} $end\n"
        for sig in self.signals:
            val var_type = if sig.is_register: "reg" else: "wire"
            out = out + "$var {var_type} {sig.width} {sig.short_id} {sig.name} $end\n"
        out = out + "$upscope $end\n"
        out = out + "$enddefinitions $end\n"
        out

    fn _initial_values() -> text:
        var out = "$dumpvars\n"
        for sig in self.signals:
            if sig.width == 1:
                out = out + "0{sig.short_id}\n"
            else:
                out = out + "b"
                out = out + self._to_binary(0, sig.width)
                out = out + " {sig.short_id}\n"
        out = out + "$end\n"
        out

    fn _value_changes() -> text:
        var out = ""
        var last_time: i64 = -1
        for trace in self.traces:
            if trace.time != last_time:
                out = out + "#{trace.time}\n"
                last_time = trace.time
            if trace.width == 1:
                val bit = if trace.value != 0: "1" else: "0"
                out = out + "{bit}{trace.signal_id}\n"
            else:
                out = out + "b"
                out = out + self._to_binary(trace.value, trace.width)
                out = out + " {trace.signal_id}\n"
        out

    fn _to_binary(value: i64, width: i64) -> text:
        """Convert a value to a binary string of the given width."""
        var result = ""
        var remaining = value
        var bits: [text] = []
        var i: i64 = 0
        while i < width:
            val bit = remaining & 1
            if bit == 1:
                bits.push("1")
            else:
                bits.push("0")
            remaining = remaining / 2
            i = i + 1
        # Reverse the bits
        var reversed = ""
        var j = bits.len() - 1
        while j >= 0:
            reversed = reversed + bits[j]
            j = j - 1
        reversed

    me _make_id() -> text:
        """Generate a short VCD signal identifier."""
        # Use ASCII characters starting from '!' (33)
        val char_code = 33 + self._next_id
        self._next_id = self._next_id + 1
        # Simple approach: use the character code as a string
        # VCD identifiers are printable ASCII from '!' to '~'
        _id_char(char_code)

    fn _find_signal_id(name: text) -> text:
        for sig in self.signals:
            if sig.name == name:
                return sig.short_id
        ""

# ============================================================================
# Helper: convert character code to single-character text
# ============================================================================

fn _id_char(code: i64) -> text:
    """Map a code 33..126 to a VCD identifier character."""
    # Use a lookup table for printable ASCII
    val chars = "!\"#$%&'()*+,-./0123456789:;<=>?@ABCDEFGHIJKLMNOPQRSTUVWXYZ[\\]^_`abcdefghijklmnopqrstuvwxyz{|}~"
    val idx = code - 33
    if idx >= 0:
        if idx < chars.len():
            return chars.slice(idx, idx + 1)
    "!"
