# IR_TC Verifier
#
# Validates IR_TC modules for correctness:
# - Type consistency (operand types match)
# - SSA form (each value defined once, used after definition)
# - Block termination (every block ends with a terminator)
# - Mode enforcement (emulation ops only in emulation/mixed mode)

use core.types.{IrTcTypeKind, IrTcValue}
use core.ops.{IrTcOp, IrTcInst}
use core.block.{BlockId, IrTcBlock, IrTcFunction, IrTcModule, IrTcModuleMode}

# ============================================================================
# Verification Errors
# ============================================================================

struct VerifyError:
    """A verification error with location context."""
    message: text
    function_name: text?
    block_id: i64?
    instruction_index: i64?

impl VerifyError:
    static fn new(msg: text) -> VerifyError:
        VerifyError(message: msg, function_name: nil, block_id: nil, instruction_index: nil)

    fn in_function(name: text) -> VerifyError:
        VerifyError(..self, function_name: Some(name))

    fn in_block(id: i64) -> VerifyError:
        VerifyError(..self, block_id: Some(id))

    fn at_inst(index: i64) -> VerifyError:
        VerifyError(..self, instruction_index: Some(index))

    fn to_text() -> text:
        var loc = ""
        if val fn_name = self.function_name:
            loc = loc + " in @{fn_name}"
        if val bid = self.block_id:
            loc = loc + " at bb{bid}"
        if val idx = self.instruction_index:
            loc = loc + " inst#{idx}"
        "verify error{loc}: {self.message}"

# ============================================================================
# Verifier
# ============================================================================

class IrTcVerifier:
    """Validates IR_TC modules for well-formedness."""
    errors: [VerifyError]
    mode: IrTcModuleMode

impl IrTcVerifier:
    static fn new(mode: IrTcModuleMode) -> IrTcVerifier:
        IrTcVerifier(errors: [], mode: mode)

    fn verify_module(module: IrTcModule) -> [VerifyError]:
        """Verify an entire module. Returns list of errors (empty = valid)."""
        var verifier = IrTcVerifier.new(module.mode)
        for func in module.functions:
            verifier.verify_function(func)
        verifier.errors

    # ── Function verification ──

    me verify_function(func: IrTcFunction):
        if func.is_declaration:
            return

        # Must have at least one block
        if func.blocks.len() == 0:
            self.errors.push(
                VerifyError.new("function has no blocks").in_function(func.name)
            )
            return

        # Verify each block
        for block in func.blocks:
            self.verify_block(block, func)

    # ── Block verification ──

    me verify_block(block: IrTcBlock, func: IrTcFunction):
        val fn_name = func.name
        val bid = block.id.id

        # Block must have at least one instruction
        if block.instructions.len() == 0:
            self.errors.push(
                VerifyError.new("empty block").in_function(fn_name).in_block(bid)
            )
            return

        # Last instruction must be a terminator
        val last = block.instructions[block.instructions.len() - 1]
        if not last.kind.is_terminator():
            self.errors.push(
                VerifyError.new("block not terminated")
                    .in_function(fn_name).in_block(bid)
            )

        # No terminator before the last instruction
        for i in 0..(block.instructions.len() - 1):
            if block.instructions[i].kind.is_terminator():
                self.errors.push(
                    VerifyError.new("terminator before end of block")
                        .in_function(fn_name).in_block(bid).at_inst(i)
                )

        # Verify each instruction
        for i in 0..block.instructions.len():
            self.verify_instruction(block.instructions[i], i, fn_name, bid)

    # ── Instruction verification ──

    me verify_instruction(inst: IrTcInst, index: i64, fn_name: text, bid: i64):
        val op = inst.kind

        # Mode enforcement: emulation ops only in emulation/mixed mode
        if op.is_emulation_only() and not self.mode.allows_emulation_ops():
            self.errors.push(
                VerifyError.new("emulation-only op in compilation mode")
                    .in_function(fn_name).in_block(bid).at_inst(index)
            )

        # Type checking per instruction category
        match op:
            # Arithmetic: operands must have same type, dest must match
            Add(dest, a, b): self.check_binary_types(dest, a, b, "add", fn_name, bid, index)
            Sub(dest, a, b): self.check_binary_types(dest, a, b, "sub", fn_name, bid, index)
            Mul(dest, a, b): self.check_binary_types(dest, a, b, "mul", fn_name, bid, index)
            Div(dest, a, b, _): self.check_binary_types(dest, a, b, "div", fn_name, bid, index)
            Rem(dest, a, b, _): self.check_binary_types(dest, a, b, "rem", fn_name, bid, index)

            # Bitwise: integer operands only
            And(dest, a, b): self.check_integer_binary(dest, a, b, "and", fn_name, bid, index)
            Or(dest, a, b): self.check_integer_binary(dest, a, b, "or", fn_name, bid, index)
            Xor(dest, a, b): self.check_integer_binary(dest, a, b, "xor", fn_name, bid, index)
            Shl(dest, a, b): self.check_integer_binary(dest, a, b, "shl", fn_name, bid, index)
            Shr(dest, a, b): self.check_integer_binary(dest, a, b, "shr", fn_name, bid, index)
            Sar(dest, a, b): self.check_integer_binary(dest, a, b, "sar", fn_name, bid, index)
            RotL(dest, a, b): self.check_integer_binary(dest, a, b, "rotl", fn_name, bid, index)
            RotR(dest, a, b): self.check_integer_binary(dest, a, b, "rotr", fn_name, bid, index)

            # Cmp: dest must be i1
            Cmp(dest, _, _, _):
                if dest.type_ != IrTcTypeKind.I1:
                    self.errors.push(
                        VerifyError.new("cmp dest must be i1, got {dest.type_.to_text()}")
                            .in_function(fn_name).in_block(bid).at_inst(index)
                    )

            # Ext: dest must be wider than src
            Ext(dest, src, _):
                if dest.type_.bit_width() <= src.type_.bit_width():
                    self.errors.push(
                        VerifyError.new("ext dest must be wider than src")
                            .in_function(fn_name).in_block(bid).at_inst(index)
                    )

            # Trunc: dest must be narrower than src
            Trunc(dest, src):
                if dest.type_.bit_width() >= src.type_.bit_width():
                    self.errors.push(
                        VerifyError.new("trunc dest must be narrower than src")
                            .in_function(fn_name).in_block(bid).at_inst(index)
                    )

            # BrCond: condition must be i1
            BrCond(cond, _, _):
                if cond.type_ != IrTcTypeKind.I1:
                    self.errors.push(
                        VerifyError.new("brcond condition must be i1")
                            .in_function(fn_name).in_block(bid).at_inst(index)
                    )

            _: pass_do_nothing

    # ── Type check helpers ──

    me check_binary_types(dest: IrTcValue, a: IrTcValue, b: IrTcValue, op_name: text, fn_name: text, bid: i64, index: i64):
        if a.type_ != b.type_:
            self.errors.push(
                VerifyError.new("{op_name}: operand types mismatch ({a.type_.to_text()} vs {b.type_.to_text()})")
                    .in_function(fn_name).in_block(bid).at_inst(index)
            )
        if dest.type_ != a.type_:
            self.errors.push(
                VerifyError.new("{op_name}: dest type ({dest.type_.to_text()}) != operand type ({a.type_.to_text()})")
                    .in_function(fn_name).in_block(bid).at_inst(index)
            )

    me check_integer_binary(dest: IrTcValue, a: IrTcValue, b: IrTcValue, op_name: text, fn_name: text, bid: i64, index: i64):
        self.check_binary_types(dest, a, b, op_name, fn_name, bid, index)
        if not a.type_.is_integer():
            self.errors.push(
                VerifyError.new("{op_name}: operands must be integer, got {a.type_.to_text()}")
                    .in_function(fn_name).in_block(bid).at_inst(index)
            )
