# IR_TC -> LLVM Bitcode Adapter
#
# MDSOC transform dimension adapter that wraps the bc_export module
# with a standardized interface for converting IR_TC modules into
# logical LLVM bitcode (BcModule) representations.

use core.block.{IrTcModule, IrTcFunction}
use format.bc_export.{BcModule, BcFunction, BcBasicBlock, BcInst, export_to_bc}
use frontend.llvm_types.{LlvmType}

# ============================================================================
# IR_TC -> BC Adapter
# ============================================================================

class IrtcToBcAdapter:
    """MDSOC-compliant adapter: IR_TC module -> LLVM bitcode representation.

    Wraps the bc_export format module and provides additional convenience
    methods for text IR generation.

    Usage:
        val adapter = IrtcToBcAdapter.new()
        val bc = adapter.export(module)
        val ll_text = adapter.export_to_text(module)
    """
    # Track export statistics
    modules_exported: i64

impl IrtcToBcAdapter:
    static fn new() -> IrtcToBcAdapter:
        IrtcToBcAdapter(modules_exported: 0)

    me export(module: IrTcModule) -> BcModule:
        """Convert an IR_TC module to a logical LLVM BC representation.

        Delegates to the bc_export module's export_to_bc() function.
        """
        self.modules_exported = self.modules_exported + 1
        export_to_bc(module)

    me export_to_text(module: IrTcModule) -> text:
        """Convert an IR_TC module to LLVM text IR (.ll) representation.

        Produces a complete .ll file as a text string, suitable for
        writing to disk or passing to llvm-as/llc.
        """
        self.modules_exported = self.modules_exported + 1
        val bc = export_to_bc(module)
        _render_module(bc)

    # ── Text IR rendering ──

    fn _render_module(bc: BcModule) -> text:
        """Render a BcModule as LLVM text IR."""
        var lines: [text] = []

        # Module header
        lines.push("; ModuleID = '{bc.name}'")
        if bc.target_triple.len() > 0:
            lines.push("target triple = \"{bc.target_triple}\"")
        if bc.data_layout.len() > 0:
            lines.push("target datalayout = \"{bc.data_layout}\"")
        lines.push("")

        # Globals
        for g in bc.globals:
            var decl = "@{g.name} = "
            if g.is_const:
                decl = decl + "constant "
            else:
                decl = decl + "global "
            decl = decl + _llvm_type_text(g.type_)
            if val init = g.initializer:
                decl = decl + " {init}"
            else:
                decl = decl + " zeroinitializer"
            lines.push(decl)
        if bc.globals.len() > 0:
            lines.push("")

        # Intrinsic declarations
        for intr in bc.intrinsic_decls:
            var param_strs: [text] = []
            for pt in intr.param_types:
                param_strs.push(_llvm_type_text(pt))
            lines.push("declare {_llvm_type_text(intr.return_type)} {intr.name}({param_strs.join(", ")})")
        if bc.intrinsic_decls.len() > 0:
            lines.push("")

        # Functions
        for func in bc.functions:
            _render_function(func, lines)
            lines.push("")

        # Metadata
        for md in bc.metadata:
            lines.push("!{md.id} = !\\{!\"{md.key}\", !\"{md.value}\"\\}")

        lines.join("\n")

    fn _render_function(func: BcFunction, lines: [text]):
        """Render a single function."""
        var param_strs: [text] = []
        for p in func.params:
            param_strs.push("{_llvm_type_text(p.type_)} %{p.name}")

        val sig = "{_llvm_type_text(func.return_type)} @{func.name}({param_strs.join(", ")})"

        if func.is_declaration:
            lines.push("declare {sig}")
            return

        lines.push("define {sig} \\{")

        for block in func.blocks:
            lines.push("{block.label}:")
            for inst in block.instructions:
                lines.push("  {inst.to_text()}")

        lines.push("\\}")

    fn _llvm_type_text(ty: LlvmType) -> text:
        """Format an LlvmType as text IR."""
        match ty:
            VoidType: "void"
            IntType(bits): "i{bits}"
            FloatType: "float"
            DoubleType: "double"
            PointerType(_): "ptr"
            ArrayType(elem, count): "[{count} x {_llvm_type_text(elem)}]"
            StructType(fields):
                var parts: [text] = []
                for f in fields:
                    parts.push(_llvm_type_text(f))
                "\\{ {parts.join(", ")} \\}"
            FunctionType(ret, params):
                var param_strs: [text] = []
                for p in params:
                    param_strs.push(_llvm_type_text(p))
                "{_llvm_type_text(ret)} ({param_strs.join(", ")})"
            _: "i64"
