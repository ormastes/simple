#![allow(unnamed_duplicate_typed_args)]
# RISC-V ELF Writer
#
# Generates ELF executables for RISC-V 32-bit and 64-bit targets.
# Supports:
#   - ELF32 for RV32 (32-bit RISC-V)
#   - ELF64 for RV64 (64-bit RISC-V)
#   - Single PT_LOAD segment (flat memory for QEMU virt machine)
#
# Memory layout (QEMU virt machine):
#   RAM:  0x80000000 – 0x87FFFFFF (128MB default)
#   UART: 0x10000000 (16550-compatible)

use format.irtc_binary.{encode_u16_le, encode_u32_le}
use linker.linker.{
    LinkerConfig, LinkerError, LinkResult,
    MergedSection, ResolvedSymbol, OutputFormat
}

# ============================================================================
# RISC-V ELF Constants
# ============================================================================

# ELF identification
val ELF_MAGIC_0: i64 = 0x7F
val ELF_MAGIC_1: i64 = 0x45         # 'E'
val ELF_MAGIC_2: i64 = 0x4C         # 'L'
val ELF_MAGIC_3: i64 = 0x46         # 'F'

val ELFCLASS32: i64 = 1             # 32-bit ELF
val ELFCLASS64: i64 = 2             # 64-bit ELF
val ELFDATA2LSB: i64 = 1            # Little-endian
val EV_CURRENT: i64 = 1             # Current ELF version
val ELFOSABI_NONE: i64 = 0          # No OS/ABI

# ELF type
val ET_EXEC: i64 = 2                # Executable file

# ELF machine
val EM_RISCV: i64 = 243             # RISC-V

# ELF header sizes
val ELF32_EHDR_SIZE: i64 = 52       # ELF32 header size
val ELF32_PHDR_SIZE: i64 = 32       # ELF32 program header size
val ELF32_SHDR_SIZE: i64 = 40       # ELF32 section header size

val ELF64_EHDR_SIZE: i64 = 64       # ELF64 header size
val ELF64_PHDR_SIZE: i64 = 56       # ELF64 program header size
val ELF64_SHDR_SIZE: i64 = 64       # ELF64 section header size

# Program header types
val PT_NULL: i64 = 0
val PT_LOAD: i64 = 1

# Program header flags
val PF_X: i64 = 1                   # Execute
val PF_W: i64 = 2                   # Write
val PF_R: i64 = 4                   # Read

# Section header types
val SHT_NULL: i64 = 0
val SHT_PROGBITS: i64 = 1           # Program data
val SHT_STRTAB: i64 = 3             # String table
val SHT_NOBITS: i64 = 8             # BSS (no file data)

# Section header flags
val SHF_WRITE: i64 = 1
val SHF_ALLOC: i64 = 2
val SHF_EXECINSTR: i64 = 4

# RISC-V entry point default (QEMU virt RAM base)
val RV_ENTRY_DEFAULT: i64 = 0x80000000

# RISC-V ELF flags
val EF_RISCV_RVC: i64 = 0x0001              # RVC (compressed) extension
val EF_RISCV_FLOAT_ABI_SOFT: i64 = 0x0000   # Soft-float ABI
val EF_RISCV_FLOAT_ABI_DOUBLE: i64 = 0x0004 # Double-float ABI

# ============================================================================
# RISC-V ELF Writer
# ============================================================================

struct RiscvElfWriter:
    """Writes ELF binaries for RISC-V targets."""
    is_64bit: bool
    entry_point: i64

impl RiscvElfWriter:
    static fn new_rv32() -> RiscvElfWriter:
        RiscvElfWriter(is_64bit: false, entry_point: RV_ENTRY_DEFAULT)

    static fn new_rv64() -> RiscvElfWriter:
        RiscvElfWriter(is_64bit: true, entry_point: RV_ENTRY_DEFAULT)

    fn elf_class() -> i64:
        if self.is_64bit: ELFCLASS64 else: ELFCLASS32

    fn ehdr_size() -> i64:
        if self.is_64bit: ELF64_EHDR_SIZE else: ELF32_EHDR_SIZE

    fn phdr_size() -> i64:
        if self.is_64bit: ELF64_PHDR_SIZE else: ELF32_PHDR_SIZE

    fn shdr_size() -> i64:
        if self.is_64bit: ELF64_SHDR_SIZE else: ELF32_SHDR_SIZE

# ============================================================================
# ELF32 Writer for RV32
# ============================================================================

fn write_riscv32_elf(result: LinkResult, config: LinkerConfig) -> Result<[i64], LinkerError>:
    """Generate an ELF32 executable for RISC-V 32-bit targets.

    Sections:
      .text — code (RX), starting at entry address
      .data — initialized data (RW)
      .bss  — zero-initialized data (RW, SHT_NOBITS)
    """
    var output: [i64] = []

    # Classify sections
    var text_sections: [MergedSection] = []
    var data_sections: [MergedSection] = []
    var bss_sections: [MergedSection] = []

    for sect in result.sections:
        if sect.name == ".bss":
            bss_sections.push(sect)
        else if sect.is_writable():
            data_sections.push(sect)
        else:
            text_sections.push(sect)

    # Calculate total sizes
    var text_size: i64 = 0
    for s in text_sections:
        text_size = text_size + s.size()
    var data_size: i64 = 0
    for s in data_sections:
        data_size = data_size + s.size()
    var bss_size: i64 = 0
    for s in bss_sections:
        bss_size = bss_size + s.size()

    # Program headers: text segment + optional data segment
    var phdr_count: i64 = 1
    if data_size > 0 or bss_size > 0:
        phdr_count = 2

    # Section header string table
    var shstrtab = _build_shstrtab(text_sections, data_sections, bss_sections)

    # Section count: null + sections + .shstrtab
    val section_count = 1 + text_sections.len() + data_sections.len() + bss_sections.len() + 1

    # Layout computation
    val phdr_offset = ELF32_EHDR_SIZE
    val sections_start = phdr_offset + phdr_count * ELF32_PHDR_SIZE

    var text_file_offset = sections_start
    var data_file_offset = text_file_offset + text_size
    var shstrtab_file_offset = data_file_offset + data_size
    var shdr_offset = shstrtab_file_offset + shstrtab.len()
    # Align section headers to 4 bytes
    if shdr_offset % 4 != 0:
        shdr_offset = shdr_offset + (4 - shdr_offset % 4)

    # --- ELF Header (52 bytes) ---
    # e_ident[16]
    output.push(ELF_MAGIC_0)
    output.push(ELF_MAGIC_1)
    output.push(ELF_MAGIC_2)
    output.push(ELF_MAGIC_3)
    output.push(ELFCLASS32)              # EI_CLASS
    output.push(ELFDATA2LSB)             # EI_DATA
    output.push(EV_CURRENT)              # EI_VERSION
    output.push(ELFOSABI_NONE)           # EI_OSABI
    for _ in 0..8:
        output.push(0)                  # EI_ABIVERSION + padding

    _push_u16_le(output, ET_EXEC)                    # e_type
    _push_u16_le(output, EM_RISCV)                   # e_machine
    _push_u32_le(output, EV_CURRENT)                 # e_version
    _push_u32_le(output, result.entry_address)       # e_entry
    _push_u32_le(output, phdr_offset)                # e_phoff
    _push_u32_le(output, shdr_offset)                # e_shoff
    _push_u32_le(output, EF_RISCV_FLOAT_ABI_SOFT)   # e_flags
    _push_u16_le(output, ELF32_EHDR_SIZE)            # e_ehsize
    _push_u16_le(output, ELF32_PHDR_SIZE)            # e_phentsize
    _push_u16_le(output, phdr_count)                 # e_phnum
    _push_u16_le(output, ELF32_SHDR_SIZE)            # e_shentsize
    _push_u16_le(output, section_count)              # e_shnum
    _push_u16_le(output, section_count - 1)          # e_shstrndx

    # --- Program Headers ---
    # LOAD segment for .text (RX)
    val text_base = if text_sections.len() > 0: text_sections[0].addr else: RV_ENTRY_DEFAULT
    _push_u32_le(output, PT_LOAD)                # p_type
    _push_u32_le(output, text_file_offset)       # p_offset
    _push_u32_le(output, text_base)              # p_vaddr
    _push_u32_le(output, text_base)              # p_paddr
    _push_u32_le(output, text_size)              # p_filesz
    _push_u32_le(output, text_size)              # p_memsz
    _push_u32_le(output, PF_R + PF_X)           # p_flags
    _push_u32_le(output, 4)                      # p_align

    # LOAD segment for .data + .bss (RW) if present
    if phdr_count > 1:
        val data_base = if data_sections.len() > 0: data_sections[0].addr else: text_base + text_size
        val mem_size = data_size + bss_size
        _push_u32_le(output, PT_LOAD)           # p_type
        _push_u32_le(output, data_file_offset)   # p_offset
        _push_u32_le(output, data_base)          # p_vaddr
        _push_u32_le(output, data_base)          # p_paddr
        _push_u32_le(output, data_size)          # p_filesz
        _push_u32_le(output, mem_size)           # p_memsz (includes BSS)
        _push_u32_le(output, PF_R + PF_W)       # p_flags
        _push_u32_le(output, 4)                  # p_align

    # --- Section Data ---
    for sect in text_sections:
        for b in sect.data:
            output.push(b)

    for sect in data_sections:
        for b in sect.data:
            output.push(b)

    # .shstrtab data
    val shstrtab_actual_offset = output.len()
    for b in shstrtab:
        output.push(b)

    # Padding to align section headers
    while output.len() % 4 != 0:
        output.push(0)

    val actual_shdr_offset = output.len()

    # --- Section Headers ---
    # SHT_NULL (index 0)
    _write_shdr32(output, 0, SHT_NULL, 0, 0, 0, 0, 0, 0, 0, 0)

    # Text sections
    var strtab_pos: i64 = 1
    var file_off = text_file_offset
    for sect in text_sections:
        val sh_flags = SHF_ALLOC + SHF_EXECINSTR
        _write_shdr32(output, strtab_pos, SHT_PROGBITS, sh_flags,
                    sect.addr, file_off, sect.size(), 0, 0, 4, 0)
        strtab_pos = strtab_pos + sect.name.len() + 1
        file_off = file_off + sect.size()

    # Data sections
    for sect in data_sections:
        val sh_flags = SHF_ALLOC + SHF_WRITE
        _write_shdr32(output, strtab_pos, SHT_PROGBITS, sh_flags,
                    sect.addr, file_off, sect.size(), 0, 0, 4, 0)
        strtab_pos = strtab_pos + sect.name.len() + 1
        file_off = file_off + sect.size()

    # BSS sections
    for sect in bss_sections:
        val sh_flags = SHF_ALLOC + SHF_WRITE
        _write_shdr32(output, strtab_pos, SHT_NOBITS, sh_flags,
                    sect.addr, 0, sect.size(), 0, 0, 4, 0)
        strtab_pos = strtab_pos + sect.name.len() + 1

    # .shstrtab
    _write_shdr32(output, strtab_pos, SHT_STRTAB, 0,
                0, shstrtab_actual_offset, shstrtab.len(), 0, 0, 1, 0)

    # Patch e_shoff with actual value
    var shoff_bytes = encode_u32_le(actual_shdr_offset)
    output[32] = shoff_bytes[0]
    output[33] = shoff_bytes[1]
    output[34] = shoff_bytes[2]
    output[35] = shoff_bytes[3]

    Ok(output)

# ============================================================================
# ELF64 Writer for RV64
# ============================================================================

fn write_riscv64_elf(result: LinkResult, config: LinkerConfig) -> Result<[i64], LinkerError>:
    """Generate an ELF64 executable for RISC-V 64-bit targets.

    Same layout as RV32 but with 64-bit ELF structures.
    """
    var output: [i64] = []

    # Classify sections
    var text_sections: [MergedSection] = []
    var data_sections: [MergedSection] = []
    var bss_sections: [MergedSection] = []

    for sect in result.sections:
        if sect.name == ".bss":
            bss_sections.push(sect)
        else if sect.is_writable():
            data_sections.push(sect)
        else:
            text_sections.push(sect)

    # Calculate total sizes
    var text_size: i64 = 0
    for s in text_sections:
        text_size = text_size + s.size()
    var data_size: i64 = 0
    for s in data_sections:
        data_size = data_size + s.size()
    var bss_size: i64 = 0
    for s in bss_sections:
        bss_size = bss_size + s.size()

    var phdr_count: i64 = 1
    if data_size > 0 or bss_size > 0:
        phdr_count = 2

    var shstrtab = _build_shstrtab(text_sections, data_sections, bss_sections)
    val section_count = 1 + text_sections.len() + data_sections.len() + bss_sections.len() + 1

    # Layout
    val phdr_offset = ELF64_EHDR_SIZE
    val sections_start = phdr_offset + phdr_count * ELF64_PHDR_SIZE

    var text_file_offset = sections_start
    var data_file_offset = text_file_offset + text_size
    var shstrtab_file_offset = data_file_offset + data_size
    var shdr_offset = shstrtab_file_offset + shstrtab.len()
    if shdr_offset % 8 != 0:
        shdr_offset = shdr_offset + (8 - shdr_offset % 8)

    # --- ELF64 Header (64 bytes) ---
    output.push(ELF_MAGIC_0)
    output.push(ELF_MAGIC_1)
    output.push(ELF_MAGIC_2)
    output.push(ELF_MAGIC_3)
    output.push(ELFCLASS64)              # EI_CLASS
    output.push(ELFDATA2LSB)             # EI_DATA
    output.push(EV_CURRENT)              # EI_VERSION
    output.push(ELFOSABI_NONE)           # EI_OSABI
    for _ in 0..8:
        output.push(0)

    _push_u16_le(output, ET_EXEC)                    # e_type
    _push_u16_le(output, EM_RISCV)                   # e_machine
    _push_u32_le(output, EV_CURRENT)                 # e_version
    _push_u64_le(output, result.entry_address)       # e_entry (64-bit)
    _push_u64_le(output, phdr_offset)                # e_phoff (64-bit)
    _push_u64_le(output, shdr_offset)                # e_shoff (64-bit)
    _push_u32_le(output, EF_RISCV_FLOAT_ABI_SOFT)   # e_flags
    _push_u16_le(output, ELF64_EHDR_SIZE)            # e_ehsize
    _push_u16_le(output, ELF64_PHDR_SIZE)            # e_phentsize
    _push_u16_le(output, phdr_count)                 # e_phnum
    _push_u16_le(output, ELF64_SHDR_SIZE)            # e_shentsize
    _push_u16_le(output, section_count)              # e_shnum
    _push_u16_le(output, section_count - 1)          # e_shstrndx

    # --- Program Headers (ELF64) ---
    val text_base = if text_sections.len() > 0: text_sections[0].addr else: RV_ENTRY_DEFAULT
    _push_u32_le(output, PT_LOAD)                # p_type
    _push_u32_le(output, PF_R + PF_X)           # p_flags (note: flags before offset in ELF64)
    _push_u64_le(output, text_file_offset)       # p_offset
    _push_u64_le(output, text_base)              # p_vaddr
    _push_u64_le(output, text_base)              # p_paddr
    _push_u64_le(output, text_size)              # p_filesz
    _push_u64_le(output, text_size)              # p_memsz
    _push_u64_le(output, 8)                      # p_align

    if phdr_count > 1:
        val data_base = if data_sections.len() > 0: data_sections[0].addr else: text_base + text_size
        val mem_size = data_size + bss_size
        _push_u32_le(output, PT_LOAD)           # p_type
        _push_u32_le(output, PF_R + PF_W)       # p_flags
        _push_u64_le(output, data_file_offset)   # p_offset
        _push_u64_le(output, data_base)          # p_vaddr
        _push_u64_le(output, data_base)          # p_paddr
        _push_u64_le(output, data_size)          # p_filesz
        _push_u64_le(output, mem_size)           # p_memsz
        _push_u64_le(output, 8)                  # p_align

    # --- Section Data ---
    for sect in text_sections:
        for b in sect.data:
            output.push(b)

    for sect in data_sections:
        for b in sect.data:
            output.push(b)

    val shstrtab_actual_offset = output.len()
    for b in shstrtab:
        output.push(b)

    while output.len() % 8 != 0:
        output.push(0)

    val actual_shdr_offset = output.len()

    # --- Section Headers (ELF64) ---
    _write_shdr64(output, 0, SHT_NULL, 0, 0, 0, 0, 0, 0, 0, 0)

    var strtab_pos: i64 = 1
    var file_off = text_file_offset
    for sect in text_sections:
        val sh_flags = SHF_ALLOC + SHF_EXECINSTR
        _write_shdr64(output, strtab_pos, SHT_PROGBITS, sh_flags,
                    sect.addr, file_off, sect.size(), 0, 0, 8, 0)
        strtab_pos = strtab_pos + sect.name.len() + 1
        file_off = file_off + sect.size()

    for sect in data_sections:
        val sh_flags = SHF_ALLOC + SHF_WRITE
        _write_shdr64(output, strtab_pos, SHT_PROGBITS, sh_flags,
                    sect.addr, file_off, sect.size(), 0, 0, 8, 0)
        strtab_pos = strtab_pos + sect.name.len() + 1
        file_off = file_off + sect.size()

    for sect in bss_sections:
        val sh_flags = SHF_ALLOC + SHF_WRITE
        _write_shdr64(output, strtab_pos, SHT_NOBITS, sh_flags,
                    sect.addr, 0, sect.size(), 0, 0, 8, 0)
        strtab_pos = strtab_pos + sect.name.len() + 1

    _write_shdr64(output, strtab_pos, SHT_STRTAB, 0,
                0, shstrtab_actual_offset, shstrtab.len(), 0, 0, 1, 0)

    # Patch e_shoff (at offset 40 in ELF64 header)
    var shoff_bytes = _encode_u64_le(actual_shdr_offset)
    for i in 0..8:
        output[40 + i] = shoff_bytes[i]

    Ok(output)

# ============================================================================
# Section Header String Table Builder
# ============================================================================

fn _build_shstrtab(text_sects: [MergedSection], data_sects: [MergedSection], bss_sects: [MergedSection]) -> [i64]:
    """Build the .shstrtab section containing all section names."""
    var table: [i64] = []
    table.push(0)    # Leading null byte

    for s in text_sects:
        _push_string(table, s.name)
    for s in data_sects:
        _push_string(table, s.name)
    for s in bss_sects:
        _push_string(table, s.name)
    _push_string(table, ".shstrtab")

    table

fn _push_string(table: [i64], s: text):
    """Push a null-terminated ASCII string into the table."""
    for i in 0..s.len():
        val ch = s[i:i + 1]
        table.push(_ascii_char(ch))
    table.push(0)

fn _ascii_char(ch: text) -> i64:
    """Map a single character to ASCII byte value."""
    if ch == ".": return 46
    if ch == "_": return 95
    if ch == "a": return 97
    if ch == "b": return 98
    if ch == "c": return 99
    if ch == "d": return 100
    if ch == "e": return 101
    if ch == "f": return 102
    if ch == "g": return 103
    if ch == "h": return 104
    if ch == "i": return 105
    if ch == "j": return 106
    if ch == "k": return 107
    if ch == "l": return 108
    if ch == "m": return 109
    if ch == "n": return 110
    if ch == "o": return 111
    if ch == "p": return 112
    if ch == "q": return 113
    if ch == "r": return 114
    if ch == "s": return 115
    if ch == "t": return 116
    if ch == "u": return 117
    if ch == "v": return 118
    if ch == "w": return 119
    if ch == "x": return 120
    if ch == "y": return 121
    if ch == "z": return 122
    if ch == "0": return 48
    if ch == "1": return 49
    if ch == "2": return 50
    if ch == "3": return 51
    if ch == "4": return 52
    if ch == "5": return 53
    if ch == "6": return 54
    if ch == "7": return 55
    if ch == "8": return 56
    if ch == "9": return 57
    63   # '?' fallback

# ============================================================================
# ELF32 Section Header Writer
# ============================================================================

fn _write_shdr32(output: [i64], name: i64, type_: i64, flags: i64,
                 addr: i64, offset: i64, size: i64, link: i64,
                 info: i64, addralign: i64, entsize: i64):
    """Write one ELF32 section header entry (40 bytes)."""
    _push_u32_le(output, name)
    _push_u32_le(output, type_)
    _push_u32_le(output, flags)
    _push_u32_le(output, addr)
    _push_u32_le(output, offset)
    _push_u32_le(output, size)
    _push_u32_le(output, link)
    _push_u32_le(output, info)
    _push_u32_le(output, addralign)
    _push_u32_le(output, entsize)

# ============================================================================
# ELF64 Section Header Writer
# ============================================================================

fn _write_shdr64(output: [i64], name: i64, type_: i64, flags: i64,
                 addr: i64, offset: i64, size: i64, link: i64,
                 info: i64, addralign: i64, entsize: i64):
    """Write one ELF64 section header entry (64 bytes)."""
    _push_u32_le(output, name)       # sh_name (4 bytes)
    _push_u32_le(output, type_)      # sh_type (4 bytes)
    _push_u64_le(output, flags)      # sh_flags (8 bytes)
    _push_u64_le(output, addr)       # sh_addr (8 bytes)
    _push_u64_le(output, offset)     # sh_offset (8 bytes)
    _push_u64_le(output, size)       # sh_size (8 bytes)
    _push_u32_le(output, link)       # sh_link (4 bytes)
    _push_u32_le(output, info)       # sh_info (4 bytes)
    _push_u64_le(output, addralign)  # sh_addralign (8 bytes)
    _push_u64_le(output, entsize)    # sh_entsize (8 bytes)

# ============================================================================
# Byte Encoding Helpers
# ============================================================================

fn _push_u16_le(output: [i64], value: i64):
    """Append a 16-bit little-endian value to the output."""
    output.push(value % 256)
    output.push((value / 256) % 256)

fn _push_u32_le(output: [i64], value: i64):
    """Append a 32-bit little-endian value to the output."""
    output.push(value % 256)
    output.push((value / 256) % 256)
    output.push((value / 65536) % 256)
    output.push((value / 16777216) % 256)

fn _push_u64_le(output: [i64], value: i64):
    """Append a 64-bit little-endian value to the output."""
    output.push(value % 256)
    output.push((value / 256) % 256)
    output.push((value / 65536) % 256)
    output.push((value / 16777216) % 256)
    output.push((value / 4294967296) % 256)
    output.push((value / 1099511627776) % 256)
    output.push((value / 281474976710656) % 256)
    output.push((value / 72057594037927936) % 256)

fn _encode_u64_le(value: i64) -> [i64]:
    """Encode a 64-bit value as 8 little-endian bytes."""
    var result: [i64] = []
    result.push(value % 256)
    result.push((value / 256) % 256)
    result.push((value / 65536) % 256)
    result.push((value / 16777216) % 256)
    result.push((value / 4294967296) % 256)
    result.push((value / 1099511627776) % 256)
    result.push((value / 281474976710656) % 256)
    result.push((value / 72057594037927936) % 256)
    result
