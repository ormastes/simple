# =========================================================================
# Metadata Builder
# =========================================================================

fn _build_metadata(snap: BrowserSnapshot) -> Dict<text, text>:
    var meta: Dict<text, text> = {}
    meta["adapter"] = "browser"
    meta["tab_count"] = "{snap.tabs.len()}"
    meta["active_tab_id"] = "{snap.active_tab_id}"
    meta["current_url"] = snap.current_url
    meta["page_title"] = snap.page_title
    meta["is_secure"] = if snap.is_secure: "true" else: "false"
    meta["bytes_transferred"] = "{snap.bytes_transferred}"
    meta["load_time_ms"] = "{snap.load_time_ms}"
    meta["load_progress"] = "{snap.load_progress}"
    meta["network_requests"] = "{snap.network_entries.len()}"
    meta["console_entries"] = "{snap.console_entries.len()}"
    meta["dom_nodes"] = "{snap.dom_nodes.len()}"
    meta["cookies"] = "{snap.cookies.len()}"
    return meta

# =========================================================================
# Helpers
# =========================================================================

fn _join_lines(lines: [text]) -> text:
    var result = ""
    var first = true
    for line in lines:
        if not first:
            result = "{result}\n"
        result = "{result}{line}"
        first = false
    return result
