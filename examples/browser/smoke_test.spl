# Simple Browser Platform Smoke Test
#
# Builds confidence in the runnable browser skeleton without depending on the
# full historical test runner command path.

use examples.browser.shared.config.{load_config}
use examples.browser.transform.pipeline.{RenderPipeline}
use examples.browser.shared.logging.{Logger, LogLevel}

fn main():
    val config = load_config("examples/browser/config.sdn")
    match config:
        Ok(cfg): pass_do_nothing
        Err(err): return

    val logger = Logger(name: "browser_smoke")
    val pipeline = RenderPipeline.create_pipeline(logger)
    val dom = pipeline.parse("<html><body><p>hello smoke</p></body></html>")
    match dom:
        Ok(parsed):
            val styled = pipeline.resolve_styles(parsed)
            match styled:
                Ok(tree):
                    val layout = pipeline.compute_layout(tree)
                    match layout:
                        Ok(box_tree):
                            val display_list = pipeline.paint(box_tree)
                            match display_list:
                                Ok(list): pass_do_nothing
                                Err(err): return
                        Err(err): return
                Err(err): return
        Err(err): return
