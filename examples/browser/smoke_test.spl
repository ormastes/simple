# Simple Browser Platform Smoke Test
#
# Builds confidence in the runnable browser skeleton without depending on the
# full historical test runner command path.

use examples.browser.shared.config.{load_config}
use examples.browser.transform.pipeline.{RenderPipeline}
use examples.browser.shared.logging.{Logger, LogLevel}

fn main():
    val config = load_config("examples/browser/config.sdn")
    match config:
        Ok(cfg):
            print "CONFIG_OK {cfg.name} {cfg.version} {cfg.homepage}"
        Err(err):
            print "CONFIG_ERR {err.message}"
            return

    val logger = Logger.new("browser_smoke", LogLevel.Info)
    val pipeline = RenderPipeline.new(logger)
    val result = pipeline.run_full_pipeline("<html><body><p>hello smoke</p></body></html>")
    match result:
        Ok(display_list):
            print "PIPELINE_OK {display_list.ops.len()} {display_list.commands.len()}"
        Err(err):
            print "PIPELINE_ERR {err.message}"
