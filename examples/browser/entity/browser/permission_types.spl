# Permission types for origin-scoped capability grants.
# Models the Permissions API state machine (prompt -> granted/denied).

enum PermissionState:
    Granted
    Denied
    Prompt

class PermissionDescriptor:
    name: text
    origin: text

    static fn create(name: text, origin: text) -> PermissionDescriptor:
        PermissionDescriptor(name: name, origin: origin)

class PermissionGrant:
    descriptor: PermissionDescriptor
    state: PermissionState
    granted_at: i64

    static fn create(descriptor: PermissionDescriptor, state: PermissionState, granted_at: i64) -> PermissionGrant:
        PermissionGrant(descriptor: descriptor, state: state, granted_at: granted_at)
