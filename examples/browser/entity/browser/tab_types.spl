#![allow(REQC001)]
#![allow(REQC004)]
#![allow(unnamed_duplicate_typed_args)]
# Tab types for browser tab management.
# Models tab identity, state, grouping, and pinning.

enum TabState:
    Loading
    Complete
    Error
    Crashed
    Frozen

class TabId:
    id: i64

    static fn create(id: i64) -> TabId:
        TabId(id: id)

class TabGroup:
    id: i64
    name: text
    color: text
    tab_ids: [TabId]

    static fn create(id: i64, name: text, color: text) -> TabGroup:
        TabGroup(id: id, name: name, color: color, tab_ids: [TabId]())

class Tab:
    id: TabId
    title: text
    url: text
    state: TabState
    renderer_pid: i64
    favicon_url: text
    is_pinned: bool
    group_id: i64

    static fn create(id: TabId, title: text, url: text) -> Tab:
        Tab(
            id: id, title: title, url: url,
            state: TabState.Loading, renderer_pid: 0,
            favicon_url: "", is_pinned: false, group_id: 0
        )
