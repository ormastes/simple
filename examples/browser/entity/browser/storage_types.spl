# Storage types for web storage APIs.
# Models localStorage, sessionStorage, and IndexedDB schemas.

enum StorageKind:
    Local
    Session
    IndexedDb

class StorageArea:
    kind: StorageKind
    origin: text
    entries: [Pair<text, text>]

    static fn create(kind: StorageKind, origin: text) -> StorageArea:
        StorageArea(kind: kind, origin: origin, entries: [Pair<text, text>]())

class IndexedDbSchema:
    name: text
    version: i64
    object_stores: [text]

    static fn create(name: text, version: i64) -> IndexedDbSchema:
        IndexedDbSchema(name: name, version: version, object_stores: [text]())
