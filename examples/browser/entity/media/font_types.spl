# Font types for text rendering.
# Models font faces, glyph metrics, and font collections.

class FontFace:
    family: text
    weight: i64
    style: text
    size: f64

    static fn create(family: text, weight: i64, style: text, size: f64) -> FontFace:
        FontFace(family: family, weight: weight, style: style, size: size)

    static fn default(family: text, size: f64) -> FontFace:
        FontFace(family: family, weight: 400, style: "normal", size: size)

class GlyphMetrics:
    advance_width: f64
    ascent: f64
    descent: f64
    line_gap: f64

    static fn create(advance_width: f64, ascent: f64, descent: f64, line_gap: f64) -> GlyphMetrics:
        GlyphMetrics(advance_width: advance_width, ascent: ascent, descent: descent, line_gap: line_gap)

class FontCollection:
    fonts: List<FontFace>

    static fn empty() -> FontCollection:
        FontCollection(fonts: List<FontFace>())
