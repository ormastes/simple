# Image types for decoded image data and animated frame sequences.
# Supports common web image formats.
#
# TODO: ImageData stores pixel data as List<i64> — consider aligning with engine's packed pixel format
# (SoftwareRenderer uses i64 RGBA packed as (r<<24)|(g<<16)|(b<<8)|a in std.nogc_sync_mut.engine.render.pipeline).

enum ImageFormat:
    Png
    Jpeg
    Gif
    Webp
    Svg
    Bmp
    Ico

class ImageData:
    width: i64
    height: i64
    format: ImageFormat
    data: List<i64>

    static fn create(width: i64, height: i64, format: ImageFormat) -> ImageData:
        ImageData(width: width, height: height, format: format, data: List<i64>())

class DecodedFrame:
    image: ImageData
    duration_ms: i64
    frame_index: i64

    static fn create(image: ImageData, duration_ms: i64, frame_index: i64) -> DecodedFrame:
        DecodedFrame(image: image, duration_ms: duration_ms, frame_index: frame_index)
