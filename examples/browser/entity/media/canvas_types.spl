# Canvas 2D types for the HTML Canvas API.
# Models drawing operations, paths, and rendering context state.
#
# TODO: Back CanvasContext with the GPU graphics module (feature/gpu/graphics.spl)
# for hardware-accelerated 2D rendering — sprite batching, path tessellation,
# and texture atlas integration via the shared 2D game rendering engine.
#
# TODO: CanvasOp uses text for color (e.g. "#000000") — replace with std.common.color.types.Color (i64 RGBA)
# or std.common.engine.color.EngineColor (f64 normalized) for type-safe color handling.
# TODO: CanvasOp inlines point coordinates (x,y) — consider std.common.engine.math2d.Vec2 for point params.
# TODO: Path2D parallels std.nogc_sync_mut.io.graphics2d_ffi.PathBuilder — evaluate shared path abstraction.

enum CanvasOp:
    MoveTo(x: f64, y: f64)
    LineTo(x: f64, y: f64)
    ArcTo(x: f64, y: f64, radius: f64)
    ClosePath
    Fill(color: text)
    Stroke(color: text, width: f64)
    FillText(text_content: text, x: f64, y: f64)
    DrawImage(id: i64, x: f64, y: f64, w: f64, h: f64)

class Path2D:
    ops: List<CanvasOp>

    static fn empty() -> Path2D:
        Path2D(ops: List<CanvasOp>())

class CanvasContext:
    width: i64
    height: i64
    ops: List<CanvasOp>
    fill_style: text
    stroke_style: text
    line_width: f64

    static fn create(width: i64, height: i64) -> CanvasContext:
        CanvasContext(
            width: width, height: height,
            ops: List<CanvasOp>(),
            fill_style: "#000000",
            stroke_style: "#000000",
            line_width: 1.0
        )
