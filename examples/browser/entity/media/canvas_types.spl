# Canvas 2D types for the HTML Canvas API.
# Models drawing operations, paths, and rendering context state.

enum CanvasOp:
    MoveTo(x: f64, y: f64)
    LineTo(x: f64, y: f64)
    ArcTo(x: f64, y: f64, radius: f64)
    ClosePath
    Fill(color: text)
    Stroke(color: text, width: f64)
    FillText(text_content: text, x: f64, y: f64)
    DrawImage(id: i64, x: f64, y: f64, w: f64, h: f64)

class Path2D:
    ops: List<CanvasOp>

    static fn empty() -> Path2D:
        Path2D(ops: List<CanvasOp>())

class CanvasContext:
    width: i64
    height: i64
    ops: List<CanvasOp>
    fill_style: text
    stroke_style: text
    line_width: f64

    static fn create(width: i64, height: i64) -> CanvasContext:
        CanvasContext(
            width: width, height: height,
            ops: List<CanvasOp>(),
            fill_style: "#000000",
            stroke_style: "#000000",
            line_width: 1.0
        )
