# JavaScript value types for the JS engine.
# Models the JS type system including objects, properties, and prototype chain.

enum JsValue:
    Undefined
    Null
    Boolean(v: bool)
    Number(v: f64)
    String(v: text)
    Object(id: i64)
    Array(id: i64)
    Function(id: i64)
    Symbol(id: i64)

class JsProperty:
    key: text
    value: JsValue
    writable: bool
    enumerable: bool
    configurable: bool

    static fn data(key: text, value: JsValue) -> JsProperty:
        JsProperty(key: key, value: value, writable: true, enumerable: true, configurable: true)

    static fn readonly(key: text, value: JsValue) -> JsProperty:
        JsProperty(key: key, value: value, writable: false, enumerable: true, configurable: false)

class JsObject:
    id: i64
    properties: [JsProperty]
    prototype_id: i64

    static fn create(id: i64) -> JsObject:
        JsObject(id: id, properties: [JsProperty](), prototype_id: -1)

    static fn with_prototype(id: i64, prototype_id: i64) -> JsObject:
        JsObject(id: id, properties: [JsProperty](), prototype_id: prototype_id)
