# Bytecode types for the JS bytecode compiler and VM.
# Models opcodes, bytecode chunks, and the constant pool.

enum OpCode:
    LoadConst(idx: i64)
    LoadLocal(idx: i64)
    StoreLocal(idx: i64)
    LoadGlobal(name: text)
    StoreGlobal(name: text)
    Add
    Sub
    Mul
    Div
    Mod
    Eq
    Ne
    Lt
    Gt
    Le
    Ge
    Not
    Neg
    Call(argc: i64)
    Return
    Jump(offset: i64)
    JumpIfFalse(offset: i64)
    Pop
    Dup
    GetProperty(name: text)
    SetProperty(name: text)
    NewObject
    NewArray(count: i64)
    Halt

class ConstantPool:
    values: List<JsValue>

    static fn empty() -> ConstantPool:
        ConstantPool(values: List<JsValue>())

class BytecodeChunk:
    ops: List<OpCode>
    constants: ConstantPool
    name: text

    static fn create(name: text) -> BytecodeChunk:
        BytecodeChunk(ops: List<OpCode>(), constants: ConstantPool.empty(), name: name)
