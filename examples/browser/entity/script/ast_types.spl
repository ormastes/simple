#![allow(REQC001)]
#![allow(REQC004)]
#![allow(unnamed_duplicate_typed_args)]
# JavaScript AST types for the JS parser output.
# Models statements and expressions as recursive enum trees.

enum BrowserExpression:
    Literal(value: JsValue)
    Identifier(name: text)
    Binary(op: text, left: BrowserExpression, right: BrowserExpression)
    Unary(op: text, operand: BrowserExpression)
    Call(callee: BrowserExpression, args: [BrowserExpression])
    Member(object: BrowserExpression, property: text)
    Assignment(target: BrowserExpression, value: BrowserExpression)
    Array(elements: [BrowserExpression])
    ObjectExpr(properties: [Pair<text, BrowserExpression>])
    Ternary(condition: BrowserExpression, consequent: BrowserExpression, alternate: BrowserExpression)
    ArrowFunction(params: [text], body: [BrowserStatement])
    SpreadElement(argument: BrowserExpression)
    TemplateLiteral(quasis: [text], expressions: [BrowserExpression])
    Delete(expr: BrowserExpression)
    InstanceOf(left: BrowserExpression, right: BrowserExpression)
    InExpr(left: BrowserExpression, right: BrowserExpression)

enum BrowserStatement:
    VarDecl(name: text, init: BrowserExpression)
    ExprStmt(expr: BrowserExpression)
    Return(value: BrowserExpression)
    If(cond: BrowserExpression, then_body: [BrowserStatement], else_body: [BrowserStatement])
    While(cond: BrowserExpression, body: [BrowserStatement])
    For(init: BrowserStatement, cond: BrowserExpression, update: BrowserExpression, body: [BrowserStatement])
    Block(stmts: [BrowserStatement])
    FnDecl(name: text, params: [text], body: [BrowserStatement])
    TryCatch(try_body: [BrowserStatement], catch_param: text, catch_body: [BrowserStatement], finally_body: [BrowserStatement])
    Switch(discriminant: BrowserExpression, cases: [BrowserSwitchCase])
    ForIn(binding: text, object: BrowserExpression, body: [BrowserStatement])
    ForOf(binding: text, iterable: BrowserExpression, body: [BrowserStatement])
    ThrowStmt(expr: BrowserExpression)
    BreakStmt
    ContinueStmt
    ClassDecl(name: text, parent_name: text, constructor: BrowserStatement, methods: [BrowserStatement])

class BrowserSwitchCase:
    test: Option<BrowserExpression>
    consequent: [BrowserStatement]

    static fn case_clause(test: BrowserExpression, body: [BrowserStatement]) -> BrowserSwitchCase:
        BrowserSwitchCase(test: Some(test), consequent: body)

    static fn default_clause(body: [BrowserStatement]) -> BrowserSwitchCase:
        BrowserSwitchCase(test: None, consequent: body)

class BrowserJsAstNode:
    kind: text
    children: [BrowserJsAstNode]
    token_start: i64
    token_end: i64

    static fn create(kind: text, token_start: i64, token_end: i64) -> BrowserJsAstNode:
        BrowserJsAstNode(kind: kind, children: [BrowserJsAstNode](), token_start: token_start, token_end: token_end)
