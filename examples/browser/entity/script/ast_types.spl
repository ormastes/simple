# JavaScript AST types for the JS parser output.
# Models statements and expressions as recursive enum trees.

enum Expression:
    Literal(value: JsValue)
    Identifier(name: text)
    Binary(op: text, left: Expression, right: Expression)
    Unary(op: text, operand: Expression)
    Call(callee: Expression, args: List<Expression>)
    Member(object: Expression, property: text)
    Assignment(target: Expression, value: Expression)
    Array(elements: List<Expression>)
    ObjectExpr(properties: List<Pair<text, Expression>>)

enum Statement:
    VarDecl(name: text, init: Expression)
    ExprStmt(expr: Expression)
    Return(value: Expression)
    If(cond: Expression, then_body: List<Statement>, else_body: List<Statement>)
    While(cond: Expression, body: List<Statement>)
    For(init: Statement, cond: Expression, update: Expression, body: List<Statement>)
    Block(stmts: List<Statement>)
    FnDecl(name: text, params: List<text>, body: List<Statement>)

class JsAstNode:
    kind: text
    children: List<JsAstNode>
    token_start: i64
    token_end: i64

    static fn create(kind: text, token_start: i64, token_end: i64) -> JsAstNode:
        JsAstNode(kind: kind, children: List<JsAstNode>(), token_start: token_start, token_end: token_end)
