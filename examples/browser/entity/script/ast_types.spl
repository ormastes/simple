# JavaScript AST types for the JS parser output.
# Models statements and expressions as recursive enum trees.

enum Expression:
    Literal(value: JsValue)
    Identifier(name: text)
    Binary(op: text, left: Expression, right: Expression)
    Unary(op: text, operand: Expression)
    Call(callee: Expression, args: List<Expression>)
    Member(object: Expression, property: text)
    Assignment(target: Expression, value: Expression)
    Array(elements: List<Expression>)
    ObjectExpr(properties: List<Pair<text, Expression>>)
    Ternary(condition: Expression, consequent: Expression, alternate: Expression)
    ArrowFunction(params: List<text>, body: List<Statement>)
    SpreadElement(argument: Expression)
    TemplateLiteral(quasis: List<text>, expressions: List<Expression>)
    Delete(expr: Expression)
    InstanceOf(left: Expression, right: Expression)
    InExpr(left: Expression, right: Expression)

enum Statement:
    VarDecl(name: text, init: Expression)
    ExprStmt(expr: Expression)
    Return(value: Expression)
    If(cond: Expression, then_body: List<Statement>, else_body: List<Statement>)
    While(cond: Expression, body: List<Statement>)
    For(init: Statement, cond: Expression, update: Expression, body: List<Statement>)
    Block(stmts: List<Statement>)
    FnDecl(name: text, params: List<text>, body: List<Statement>)
    TryCatch(try_body: List<Statement>, catch_param: text, catch_body: List<Statement>, finally_body: List<Statement>)
    Switch(discriminant: Expression, cases: List<SwitchCase>)
    ForIn(binding: text, object: Expression, body: List<Statement>)
    ForOf(binding: text, iterable: Expression, body: List<Statement>)
    ThrowStmt(expr: Expression)
    BreakStmt
    ContinueStmt
    ClassDecl(name: text, parent_name: text, constructor: Statement, methods: List<Statement>)

class SwitchCase:
    test: Option<Expression>
    consequent: List<Statement>

    static fn case_clause(test: Expression, body: List<Statement>) -> SwitchCase:
        SwitchCase(test: Some(test), consequent: body)

    static fn default_clause(body: List<Statement>) -> SwitchCase:
        SwitchCase(test: None, consequent: body)

class JsAstNode:
    kind: text
    children: List<JsAstNode>
    token_start: i64
    token_end: i64

    static fn create(kind: text, token_start: i64, token_end: i64) -> JsAstNode:
        JsAstNode(kind: kind, children: List<JsAstNode>(), token_start: token_start, token_end: token_end)
