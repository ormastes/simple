# JavaScript AST types for the JS parser output.
# Models statements and expressions as recursive enum trees.

enum Expression:
    Literal(value: JsValue)
    Identifier(name: text)
    Binary(op: text, left: Expression, right: Expression)
    Unary(op: text, operand: Expression)
    Call(callee: Expression, args: [Expression])
    Member(object: Expression, property: text)
    Assignment(target: Expression, value: Expression)
    Array(elements: [Expression])
    ObjectExpr(properties: [Pair<text, Expression>])
    Ternary(condition: Expression, consequent: Expression, alternate: Expression)
    ArrowFunction(params: [text], body: [Statement])
    SpreadElement(argument: Expression)
    TemplateLiteral(quasis: [text], expressions: [Expression])
    Delete(expr: Expression)
    InstanceOf(left: Expression, right: Expression)
    InExpr(left: Expression, right: Expression)

enum Statement:
    VarDecl(name: text, init: Expression)
    ExprStmt(expr: Expression)
    Return(value: Expression)
    If(cond: Expression, then_body: [Statement], else_body: [Statement])
    While(cond: Expression, body: [Statement])
    For(init: Statement, cond: Expression, update: Expression, body: [Statement])
    Block(stmts: [Statement])
    FnDecl(name: text, params: [text], body: [Statement])
    TryCatch(try_body: [Statement], catch_param: text, catch_body: [Statement], finally_body: [Statement])
    Switch(discriminant: Expression, cases: [SwitchCase])
    ForIn(binding: text, object: Expression, body: [Statement])
    ForOf(binding: text, iterable: Expression, body: [Statement])
    ThrowStmt(expr: Expression)
    BreakStmt
    ContinueStmt
    ClassDecl(name: text, parent_name: text, constructor: Statement, methods: [Statement])

class SwitchCase:
    test: Option<Expression>
    consequent: [Statement]

    static fn case_clause(test: Expression, body: [Statement]) -> SwitchCase:
        SwitchCase(test: Some(test), consequent: body)

    static fn default_clause(body: [Statement]) -> SwitchCase:
        SwitchCase(test: None, consequent: body)

class JsAstNode:
    kind: text
    children: [JsAstNode]
    token_start: i64
    token_end: i64

    static fn create(kind: text, token_start: i64, token_end: i64) -> JsAstNode:
        JsAstNode(kind: kind, children: [JsAstNode](), token_start: token_start, token_end: token_end)
