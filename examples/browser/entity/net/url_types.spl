#![allow(REQC001)]
#![allow(REQC004)]
#![allow(unnamed_duplicate_typed_args)]
# URL types for resource identification and origin comparison.
# Implements URL decomposition and same-origin checks per the URL specification.

class Url:
    scheme: text
    host: text
    port: i64
    path: text
    query: text
    fragment: text
    raw: text

    static fn create(scheme: text, host: text, port: i64, path: text) -> Url:
        Url(scheme: scheme, host: host, port: port, path: path, query: "", fragment: "", raw: "")

    static fn parse(raw: text) -> Url:
        Url(scheme: "", host: "", port: 0, path: "", query: "", fragment: "", raw: raw)

    fn to_text() -> text:
        val port_str = if self.port > 0: ":{self.port}" else: ""
        val query_str = if self.query != "": "?{self.query}" else: ""
        val frag_str = if self.fragment != "": "#{self.fragment}" else: ""
        "{self.scheme}://{self.host}{port_str}{self.path}{query_str}{frag_str}"

class Origin:
    scheme: text
    host: text
    port: i64

    static fn from_url(url: Url) -> Origin:
        Origin(scheme: url.scheme, host: url.host, port: url.port)

    fn to_text() -> text:
        val port_str = if self.port > 0: ":{self.port}" else: ""
        "{self.scheme}://{self.host}{port_str}"

class UrlSearchParams:
    params: [Pair<text, text>]

    static fn empty() -> UrlSearchParams:
        UrlSearchParams(params: List<Pair<text, text>>())

fn is_same_origin(a: Origin, b: Origin) -> bool:
    a.scheme == b.scheme and a.host == b.host and a.port == b.port
