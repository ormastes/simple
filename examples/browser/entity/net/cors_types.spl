# CORS (Cross-Origin Resource Sharing) types.
# Models CORS policies, preflight requests, and access control decisions.

class CorsPolicy:
    allowed_origins: List<text>
    allowed_methods: List<text>
    allowed_headers: List<text>
    max_age: i64
    allow_credentials: bool

    static fn permissive() -> CorsPolicy:
        CorsPolicy(
            allowed_origins: List<text>(),
            allowed_methods: List<text>(),
            allowed_headers: List<text>(),
            max_age: 0,
            allow_credentials: false
        )

    static fn create(allowed_origins: List<text>, allowed_methods: List<text>, allowed_headers: List<text>, max_age: i64, allow_credentials: bool) -> CorsPolicy:
        CorsPolicy(
            allowed_origins: allowed_origins,
            allowed_methods: allowed_methods,
            allowed_headers: allowed_headers,
            max_age: max_age,
            allow_credentials: allow_credentials
        )

class CorsRequest:
    origin: Origin
    method: text
    headers: List<text>

    static fn create(origin: Origin, method: text, headers: List<text>) -> CorsRequest:
        CorsRequest(origin: origin, method: method, headers: headers)

enum PreflightResult:
    Allowed
    Denied(reason: text)
