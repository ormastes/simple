class BundleModule:
    id: text
    path: text
    imports: [text]
    exports: [text]
    size: i64
    content_hash: text

    static fn create(id: text, path: text, imports: [text], exports: [text], size: i64, content_hash: text) -> BundleModule:
        BundleModule(id: id, path: path, imports: imports, exports: exports, size: size, content_hash: content_hash)

class BundleEdge:
    from_id: text
    to_id: text

    static fn create(from_id: text, to_id: text) -> BundleEdge:
        BundleEdge(from_id: from_id, to_id: to_id)

class SharedChunk:
    id: text
    modules: [text]
    content_hash: text
    size: i64
    ref_count: i64

    static fn create(id: text, modules: [text], content_hash: text, size: i64, ref_count: i64) -> SharedChunk:
        SharedChunk(id: id, modules: modules, content_hash: content_hash, size: size, ref_count: ref_count)

class SplitPoint:
    entry_id: text
    chunks: [text]
    shared_chunks: [text]

    static fn create(entry_id: text, chunks: [text], shared_chunks: [text]) -> SplitPoint:
        SplitPoint(entry_id: entry_id, chunks: chunks, shared_chunks: shared_chunks)

class BundleManifest:
    entries: [SplitPoint]
    shared: [SharedChunk]
    total_size: i64
    dedup_savings: i64

    static fn create(entries: [SplitPoint], shared: [SharedChunk], total_size: i64, dedup_savings: i64) -> BundleManifest:
        BundleManifest(entries: entries, shared: shared, total_size: total_size, dedup_savings: dedup_savings)
