#![allow(REQC001)]
#![allow(REQC004)]
#![allow(unnamed_duplicate_typed_args)]
# HTTP request and response types for the Fetch API.
# Models the full request lifecycle including method, mode, credentials, and headers.

enum HttpMethod:
    Get
    Post
    Put
    Delete
    Head
    Options
    Patch

enum RequestMode:
    Navigate
    SameOrigin
    NoCors
    Cors

enum RequestCredentials:
    Omit
    SameOrigin
    Include

class Headers:
    entries: [Pair<text, text>]

    static fn empty() -> Headers:
        Headers(entries: List<Pair<text, text>>())

class FetchRequest:
    url: Url
    method: HttpMethod
    headers: [Pair<text, text>]
    body: text
    mode: RequestMode
    credentials: RequestCredentials

    static fn get(url: Url) -> FetchRequest:
        FetchRequest(
            url: url, method: HttpMethod.Get,
            headers: List<Pair<text, text>>(), body: "",
            mode: RequestMode.Cors, credentials: RequestCredentials.SameOrigin
        )

    static fn create(url: Url, method: HttpMethod, body: text) -> FetchRequest:
        FetchRequest(
            url: url, method: method,
            headers: List<Pair<text, text>>(), body: body,
            mode: RequestMode.Cors, credentials: RequestCredentials.SameOrigin
        )

class FetchResponse:
    status: i64
    status_text: text
    headers: [Pair<text, text>]
    body: text
    url: Url
    redirected: bool

    static fn ok(body: text, url: Url) -> FetchResponse:
        FetchResponse(
            status: 200, status_text: "OK",
            headers: List<Pair<text, text>>(), body: body,
            url: url, redirected: false
        )
