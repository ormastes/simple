# HTTP cache types for resource caching and revalidation.
# Models Cache-Control directives, ETags, and cache entry storage.

enum CacheControl:
    NoCache
    NoStore
    MaxAge(seconds: i64)
    Public
    Private
    MustRevalidate

class ETag:
    value: text
    weak: bool

    static fn strong(value: text) -> ETag:
        ETag(value: value, weak: false)

    static fn weak(value: text) -> ETag:
        ETag(value: value, weak: true)

class CachePolicy:
    controls: [CacheControl]
    etag: ETag
    last_modified: i64

    static fn create(controls: [CacheControl], etag: ETag, last_modified: i64) -> CachePolicy:
        CachePolicy(controls: controls, etag: etag, last_modified: last_modified)

class CacheEntry:
    url: text
    body: text
    headers: [Pair<text, text>]
    policy: CachePolicy
    stored_at: i64

    static fn create(url: text, body: text, policy: CachePolicy, stored_at: i64) -> CacheEntry:
        CacheEntry(url: url, body: body, headers: [Pair<text, text>](), policy: policy, stored_at: stored_at)
