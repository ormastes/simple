# TLS configuration and certificate chain types.
# Models TLS version negotiation, certificate verification, and ALPN protocol selection.

enum TlsVersion:
    Tls12
    Tls13

class TlsConfig:
    min_version: TlsVersion
    verify_certs: bool
    alpn_protocols: List<text>

    static fn default() -> TlsConfig:
        TlsConfig(min_version: TlsVersion.Tls12, verify_certs: true, alpn_protocols: List<text>())

    static fn create(min_version: TlsVersion, verify_certs: bool, alpn_protocols: List<text>) -> TlsConfig:
        TlsConfig(min_version: min_version, verify_certs: verify_certs, alpn_protocols: alpn_protocols)

class CertChain:
    certs: List<text>
    ca_certs: List<text>

    static fn create(certs: List<text>, ca_certs: List<text>) -> CertChain:
        CertChain(certs: certs, ca_certs: ca_certs)
