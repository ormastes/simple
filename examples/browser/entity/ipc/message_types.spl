# IPC message types for multi-process browser communication.
# Defines message envelope, method variants, and flags for Browser<->Renderer,
# Browser<->Network, and Browser<->GPU IPC channels.

enum BrowserIpcMethod:
    # Browser <-> Renderer
    NavigateTo
    CommitNavigation
    UpdateTitle
    PaintFrame
    RequestLayout
    DomUpdate

    # Browser <-> Network
    FetchResource
    FetchResponse
    CancelFetch
    CookieRequest
    CookieResponse

    # Browser <-> GPU
    CreateSurface
    DestroySurface
    SubmitFrame
    SwapBuffers
    GpuMemoryReport

enum IpcFlag:
    Sync
    Async
    CapTransfer
    Reply

class BrowserIpcMsg:
    src: ProcessId
    dst: ProcessId
    method: BrowserIpcMethod
    flags: List<IpcFlag>
    request_id: i64

    static fn create(src: ProcessId, dst: ProcessId, method: BrowserIpcMethod, flags: List<IpcFlag>, request_id: i64) -> BrowserIpcMsg:
        BrowserIpcMsg(src: src, dst: dst, method: method, flags: flags, request_id: request_id)
