# IPC message types for multi-process browser communication.
# Defines message envelope, method variants, and flags for Browser<->Renderer,
# Browser<->Network, and Browser<->GPU IPC channels.
# IPC-2: Typed key-value payload support via List<IpcPayloadEntry>.

enum BrowserIpcMethod:
    # Browser <-> Renderer
    NavigateTo
    CommitNavigation
    UpdateTitle
    PaintFrame
    RequestLayout
    DomUpdate

    # Browser <-> Network
    FetchResource
    FetchResponse
    CancelFetch
    CookieRequest
    CookieResponse

    # Browser <-> GPU
    CreateSurface
    DestroySurface
    SubmitFrame
    SwapBuffers
    GpuMemoryReport

enum IpcFlag:
    Sync
    Async
    CapTransfer
    Reply

# IPC-2: Key-value payload entry for typed IPC data
class IpcPayloadEntry:
    key: text
    value: text

    static fn create(key: text, value: text) -> IpcPayloadEntry:
        IpcPayloadEntry(key: key, value: value)

class BrowserIpcMsg:
    src: ProcessId
    dst: ProcessId
    method: BrowserIpcMethod
    flags: List<IpcFlag>
    request_id: i64
    payload: List<IpcPayloadEntry>

    static fn create(src: ProcessId, dst: ProcessId, method: BrowserIpcMethod, flags: List<IpcFlag>, request_id: i64) -> BrowserIpcMsg:
        BrowserIpcMsg(src: src, dst: dst, method: method, flags: flags, request_id: request_id, payload: List<IpcPayloadEntry>())

    static fn create_with_payload(src: ProcessId, dst: ProcessId, method: BrowserIpcMethod, flags: List<IpcFlag>, request_id: i64, payload: List<IpcPayloadEntry>) -> BrowserIpcMsg:
        BrowserIpcMsg(src: src, dst: dst, method: method, flags: flags, request_id: request_id, payload: payload)

    fn get_payload(key: text) -> Option<text>:
        # IPC-2: Lookup a payload value by key.
        var i = 0
        while i < self.payload.len():
            val entry = self.payload.get(i)
            if entry.key == key:
                return Some(entry.value)
            i = i + 1
        nil
