# Layout box model types for CSS box layout.
# Each DOM element maps to a LayoutBox with margin, border, and padding geometry.

enum BoxKind:
    Block
    Inline
    InlineBlock
    Flex
    Grid
    Table
    TableRow
    TableCell
    None

class BoxModel:
    margin_top: f64
    margin_right: f64
    margin_bottom: f64
    margin_left: f64
    border_top: f64
    border_right: f64
    border_bottom: f64
    border_left: f64
    padding_top: f64
    padding_right: f64
    padding_bottom: f64
    padding_left: f64

    static fn zero() -> BoxModel:
        BoxModel(
            margin_top: 0.0, margin_right: 0.0, margin_bottom: 0.0, margin_left: 0.0,
            border_top: 0.0, border_right: 0.0, border_bottom: 0.0, border_left: 0.0,
            padding_top: 0.0, padding_right: 0.0, padding_bottom: 0.0, padding_left: 0.0
        )

class LayoutBox:
    node_id: i64
    kind: BoxKind
    x: f64
    y: f64
    width: f64
    height: f64
    box_model: BoxModel
    children: List<LayoutBox>

    static fn create(node_id: i64, kind: BoxKind) -> LayoutBox:
        LayoutBox(
            node_id: node_id, kind: kind,
            x: 0.0, y: 0.0, width: 0.0, height: 0.0,
            box_model: BoxModel.zero(),
            children: List<LayoutBox>()
        )
