# Compatibility re-export for legacy examples.browser paint type imports.
# Also defines web-rendering optimisation types for AC-8:
#   StyleCacheInvalidation, GlyphCacheEntry, ScrollDamageRect, PaintBatch.

use std.common.color.types.{Color, from_rgb, from_rgba, black, white}
use std.common.color.convert.{from_hex, from_name}
use common.render_scene.paint_types.{
    transparent,
    GradientStop,
    Gradient,
    PaintOp,
    paint_op_rect,
    DisplayList,
    DisplayItem
}

# ============================================================================
# AC-8: Style cache invalidation tracking
# ============================================================================

class StyleCacheInvalidation:
    """Tracks why a style recalc was triggered for a node.

    Fields:
        node_id       — DOM node identifier
        reason        — "class_change" | "attr_change" | "parent_restyle" | "force"
        subtree       — true if the invalidation propagates to all descendants
        generation    — monotone counter; incremented each full style flush
    """
    var node_id:    i64
    var reason:     text
    var subtree:    bool
    var generation: i64

fn make_style_cache_invalidation(node_id: i64, reason: text, subtree: bool) -> StyleCacheInvalidation:
    StyleCacheInvalidation(
        node_id:    node_id,
        reason:     reason,
        subtree:    subtree,
        generation: 0,
    )

# ============================================================================
# AC-8: Glyph cache entry
# ============================================================================

class GlyphCacheEntry:
    """One cached rasterised glyph.

    The cache key is (codepoint, font_size_px, subpixel_x).  Entries are
    evicted LRU when the atlas exceeds the size limit set by the renderer.

    Fields:
        codepoint     — Unicode code point
        font_size_px  — rendered size in device pixels
        subpixel_x    — sub-pixel x offset × 64 (freetype convention)
        atlas_x       — x origin in the glyph atlas texture
        atlas_y       — y origin in the glyph atlas texture
        width         — glyph width in pixels
        height        — glyph height in pixels
        advance_x     — horizontal advance × 64
        lru_tick      — frame counter at last use (for LRU eviction)
    """
    var codepoint:    i64
    var font_size_px: i64
    var subpixel_x:   i64
    var atlas_x:      i64
    var atlas_y:      i64
    var width:        i64
    var height:       i64
    var advance_x:    i64
    var lru_tick:     i64

fn make_glyph_cache_entry(codepoint: i64, font_size_px: i64) -> GlyphCacheEntry:
    GlyphCacheEntry(
        codepoint:    codepoint,
        font_size_px: font_size_px,
        subpixel_x:   0,
        atlas_x:      0,
        atlas_y:      0,
        width:        0,
        height:       0,
        advance_x:    0,
        lru_tick:     0,
    )

# ============================================================================
# AC-8: Scroll damage rect tracking
# ============================================================================

class ScrollDamageRect:
    """Region that must be repainted after a scroll event.

    The compositor clips paint commands to the union of active damage rects
    before issuing GPU blits, reducing the repaint area for partially-visible
    scrolling content.

    Fields:
        x, y          — top-left corner in viewport coordinates
        w, h          — width and height in pixels
        scroll_dx     — horizontal scroll delta that caused this damage
        scroll_dy     — vertical scroll delta that caused this damage
        frame_id      — frame on which the scroll was recorded
    """
    var x:         i64
    var y:         i64
    var w:         i64
    var h:         i64
    var scroll_dx: i64
    var scroll_dy: i64
    var frame_id:  i64

fn make_scroll_damage_rect(x: i64, y: i64, w: i64, h: i64, dx: i64, dy: i64) -> ScrollDamageRect:
    ScrollDamageRect(
        x:         x,
        y:         y,
        w:         w,
        h:         h,
        scroll_dx: dx,
        scroll_dy: dy,
        frame_id:  0,
    )

fn scroll_damage_rect_union(a: ScrollDamageRect, b: ScrollDamageRect) -> ScrollDamageRect:
    """Return the bounding rect that covers both a and b."""
    val lx = if a.x < b.x: a.x else: b.x
    val ly = if a.y < b.y: a.y else: b.y
    val rx = if (a.x + a.w) > (b.x + b.w): (a.x + a.w) else: (b.x + b.w)
    val ry = if (a.y + a.h) > (b.y + b.h): (a.y + a.h) else: (b.y + b.h)
    ScrollDamageRect(
        x:         lx,
        y:         ly,
        w:         rx - lx,
        h:         ry - ly,
        scroll_dx: a.scroll_dx,
        scroll_dy: a.scroll_dy,
        frame_id:  a.frame_id,
    )

# ============================================================================
# AC-8: Paint-command batching
# ============================================================================

class PaintBatch:
    """An ordered list of PaintOp commands grouped for a single GPU draw call.

    Batching paint commands reduces the number of GPU state changes and draw
    calls per frame.  The renderer flushes a batch when:
      - the batch reaches MAX_BATCH_OPS operations, or
      - the next command requires a different texture/blend mode, or
      - end-of-display-list is reached.

    Fields:
        ops           — the paint operations in this batch
        texture_id    — shared texture atlas id for all ops (0 = solid colour)
        blend_mode    — 0 = opaque, 1 = alpha, 2 = multiply
        op_count      — number of active ops (may be < ops.len() after flush)
        flushed       — true once the batch has been submitted to the GPU
    """
    var ops:        [PaintOp]
    var texture_id: i64
    var blend_mode: i64
    var op_count:   i64
    var flushed:    bool

val MAX_BATCH_OPS: i64 = 256

fn make_paint_batch(texture_id: i64, blend_mode: i64) -> PaintBatch:
    PaintBatch(
        ops:        [],
        texture_id: texture_id,
        blend_mode: blend_mode,
        op_count:   0,
        flushed:    false,
    )

fn paint_batch_push(batch: PaintBatch, op: PaintOp):
    """Append op to batch.  Caller must flush when op_count >= MAX_BATCH_OPS."""
    batch.ops.push(op)
    batch.op_count = batch.op_count + 1

fn paint_batch_needs_flush(batch: PaintBatch) -> bool:
    batch.op_count >= MAX_BATCH_OPS or batch.flushed
