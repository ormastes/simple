# DOM attribute types for element attribute storage and token lists.
# Attr represents a single name-value pair with optional namespace.
# NamedNodeMap and DOMTokenList provide collection wrappers.

class Attr:
    name: text
    value: text
    namespace: text

    static fn create(name: text, value: text) -> Attr:
        Attr(name: name, value: value, namespace: "")

    static fn with_namespace(name: text, value: text, namespace: text) -> Attr:
        Attr(name: name, value: value, namespace: namespace)

class NamedNodeMap:
    attrs: List<Attr>

    static fn empty() -> NamedNodeMap:
        NamedNodeMap(attrs: List<Attr>())

class DOMTokenList:
    tokens: List<text>

    static fn empty() -> DOMTokenList:
        DOMTokenList(tokens: List<text>())
