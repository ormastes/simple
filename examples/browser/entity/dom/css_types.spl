# CSS value, rule, selector, and specificity types.
# Used by the style engine to represent parsed stylesheets and computed values.

enum CSSValue:
    Keyword(v: text)
    Length(v: f64, unit: text)
    Percentage(v: f64)
    Color(r: i64, g: i64, b: i64, a: i64)
    Number(v: f64)
    Url(v: text)
    Inherit
    Initial
    Unset

class CSSDeclaration:
    property: text
    value: CSSValue
    important: bool

    static fn create(property: text, value: CSSValue) -> CSSDeclaration:
        CSSDeclaration(property: property, value: value, important: false)

enum SelectorPart:
    Type(name: text)
    Class(name: text)
    Id(name: text)
    Universal
    Attribute(name: text, op: text, value: text)
    PseudoClass(name: text)
    PseudoElement(name: text)
    Combinator(kind: text)

class Selector:
    parts: List<SelectorPart>

    static fn create(parts: List<SelectorPart>) -> Selector:
        Selector(parts: parts)

class CSSRule:
    selector: Selector
    declarations: List<CSSDeclaration>

    static fn create(selector: Selector, declarations: List<CSSDeclaration>) -> CSSRule:
        CSSRule(selector: selector, declarations: declarations)

class Specificity:
    ids: i64
    classes: i64
    elements: i64

    static fn zero() -> Specificity:
        Specificity(ids: 0, classes: 0, elements: 0)

    static fn create(ids: i64, classes: i64, elements: i64) -> Specificity:
        Specificity(ids: ids, classes: classes, elements: elements)
