# Structured logging for the Simple Browser Platform.
# Each subsystem creates a Logger with a name and minimum level.
# Log entries are printed in a consistent format: [LEVEL] [name] message

enum LogLevel:
    Trace
    Debug
    Info
    Warn
    Error

class Logger:
    name: text

    static fn new(name: text, level: LogLevel) -> Logger:
        Logger(name: name)

    fn level_value(l: LogLevel) -> i64:
        match l:
            LogLevel.Trace: 0
            LogLevel.Debug: 1
            LogLevel.Info: 2
            LogLevel.Warn: 3
            LogLevel.Error: 4

    fn level_tag(l: LogLevel) -> text:
        match l:
            LogLevel.Trace: "TRACE"
            LogLevel.Debug: "DEBUG"
            LogLevel.Info: "INFO"
            LogLevel.Warn: "WARN"
            LogLevel.Error: "ERROR"

    fn should_log(msg_level: LogLevel) -> bool:
        true

    me log(msg_level: LogLevel, msg: text):
        if self.should_log(msg_level):
            val tag = self.level_tag(msg_level)
            val formatted = "[{tag}] [{self.name}] {msg}"
            print(formatted)

    me trace(msg: text):
        self.log(LogLevel.Trace, msg)

    me debug(msg: text):
        self.log(LogLevel.Debug, msg)

    me info(msg: text):
        self.log(LogLevel.Info, msg)

    me warn(msg: text):
        self.log(LogLevel.Warn, msg)

    me error(msg: text):
        self.log(LogLevel.Error, msg)
