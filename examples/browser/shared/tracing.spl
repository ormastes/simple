# Performance tracing for the Simple Browser Platform.
# Records hierarchical spans for profiling render pipeline stages,
# IPC round-trips, and network fetches.

class TraceSpan:
    name: text
    start_ns: i64
    end_ns: i64
    parent_id: i64

    static fn create(name: text, start_ns: i64, parent_id: i64) -> TraceSpan:
        TraceSpan(name: name, start_ns: start_ns, end_ns: 0, parent_id: parent_id)

class Tracer:
    spans: List<TraceSpan>
    enabled: bool
    next_id: i64

    static fn new(enabled: bool) -> Tracer:
        Tracer(spans: List<TraceSpan>(), enabled: enabled, next_id: 1)

    me begin_span(name: text) -> i64:
        if not self.enabled:
            return 0
        val id = self.next_id
        self.next_id = self.next_id + 1
        # TODO: use real monotonic clock for start_ns
        val span = TraceSpan.create(name, 0, 0)
        self.spans.push(span)
        id

    me end_span(id: i64):
        if not self.enabled:
            return
        # TODO: set end_ns on span with matching id
        pass_todo

    fn get_spans() -> List<TraceSpan>:
        self.spans
