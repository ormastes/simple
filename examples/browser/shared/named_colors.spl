# CSS Level 4 Named Colors — full 148-color table.
# Spec: https://www.w3.org/TR/css-color-4/#named-colors
#
# Returns (r, g, b) as i64 triple via lookup. Used by both the full
# CSS parser and the runtime color parser.

use std.common.color.types.{Color, from_rgb, from_rgba}

class NamedColorEntry:
    name: text
    r: i64
    g: i64
    b: i64

# Build the color table once and cache.
var _color_table: [NamedColorEntry]? = nil

