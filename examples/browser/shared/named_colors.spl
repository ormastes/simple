fn get_color_table() -> [NamedColorEntry]:
    if val Some(table) = _color_table:
        return table
    val table = _build_color_table()
    _color_table = table
    table

fn named_color_lookup(name: text) -> Color?:
    """Look up a CSS named color. Returns Color on match, nil otherwise.
    Handles 'transparent' as a special case (rgba 0,0,0,0).
    """
    val lower = name.to_lower()
    if lower == "transparent":
        return from_rgba(0, 0, 0, 0)
    val table = get_color_table()
    for entry in table:
        if entry.name == lower:
            return from_rgb(entry.r, entry.g, entry.b)
    nil

fn named_color_to_u32(name: text) -> u32?:
    """Look up a CSS named color, returning u32 RGBA value.
    Used by the runtime renderer which uses u32 colors.
    """
    val lower = name.to_lower()
    if lower == "transparent":
        return 0x00000000
    val table = get_color_table()
    for entry in table:
        if entry.name == lower:
            val r = entry.r.to_u32()
            val g = entry.g.to_u32()
            val b = entry.b.to_u32()
            return (r * 16777216) + (g * 65536) + (b * 256) + 255
    nil
