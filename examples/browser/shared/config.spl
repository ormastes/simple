# SDN configuration loader for the Simple Browser Platform.
# Reads config.sdn and produces a typed BrowserConfig.

use std.io_runtime.{file_read}
use std.sdn.parser.{parse}
use examples.browser.shared.error.{BrowserResult, config_error}

class BrowserConfig:
    name: text
    version: text
    homepage: text
    user_agent: text
    tab_limit: i64
    process_model: text
    default_encoding: text
    max_history_entries: i64
    max_connections_per_host: i64
    max_total_connections: i64
    dns_cache_ttl: i64
    http_cache_size_mb: i64
    cookie_policy: text
    connect_timeout_ms: i64
    read_timeout_ms: i64
    gpu_compositing: bool
    hardware_acceleration: bool
    max_texture_size: i64
    tile_size: i64
    target_fps: i64
    csp_default: text
    mixed_content: text

    static fn default() -> BrowserConfig:
        BrowserConfig(
            name: "simple-browser-platform",
            version: "0.1.0",
            homepage: "about:blank",
            user_agent: "SimpleBrowser/0.1 (Simple Language)",
            tab_limit: 64,
            process_model: "site-per-process",
            default_encoding: "utf-8",
            max_history_entries: 1000,
            max_connections_per_host: 6,
            max_total_connections: 64,
            dns_cache_ttl: 300,
            http_cache_size_mb: 256,
            cookie_policy: "same-site-lax",
            connect_timeout_ms: 30000,
            read_timeout_ms: 60000,
            gpu_compositing: true,
            hardware_acceleration: true,
            max_texture_size: 4096,
            tile_size: 256,
            target_fps: 60,
            csp_default: "default-src 'self'",
            mixed_content: "block"
        )

fn load_config(path: text) -> BrowserResult<BrowserConfig>:
    val content = file_read(path)
    match parse(content):
        case Ok(root):
            var config = BrowserConfig.default()

            val project = root.get("project")
            if project.?:
                val name = _get_text(project, "name")
                if name.len() > 0:
                    config.name = name
                val version = _get_text(project, "version")
                if version.len() > 0:
                    config.version = version

            val browser = root.get("browser")
            if browser.?:
                _apply_browser_section(config, browser)

            val network = root.get("network")
            if network.?:
                _apply_network_section(config, network)

            val rendering = root.get("rendering")
            if rendering.?:
                _apply_rendering_section(config, rendering)

            val security = root.get("security")
            if security.?:
                _apply_security_section(config, security)

            Ok(config)
        case Err(err):
            Err(config_error("Failed to parse browser config '{path}': {err}"))

fn _apply_browser_section(config: BrowserConfig, section):
    val homepage = _get_text(section, "homepage")
    if homepage.len() > 0:
        config.homepage = homepage
    val user_agent = _get_text(section, "user_agent")
    if user_agent.len() > 0:
        config.user_agent = user_agent
    config.tab_limit = _get_int_or(section, "tab_limit", config.tab_limit)
    val process_model = _get_text(section, "process_model")
    if process_model.len() > 0:
        config.process_model = process_model
    val default_encoding = _get_text(section, "default_encoding")
    if default_encoding.len() > 0:
        config.default_encoding = default_encoding
    config.max_history_entries = _get_int_or(section, "max_history_entries", config.max_history_entries)

fn _apply_network_section(config: BrowserConfig, section):
    config.max_connections_per_host = _get_int_or(section, "max_connections_per_host", config.max_connections_per_host)
    config.max_total_connections = _get_int_or(section, "max_total_connections", config.max_total_connections)
    config.dns_cache_ttl = _get_int_or(section, "dns_cache_ttl", config.dns_cache_ttl)
    config.http_cache_size_mb = _get_int_or(section, "http_cache_size_mb", config.http_cache_size_mb)
    val cookie_policy = _get_text(section, "cookie_policy")
    if cookie_policy.len() > 0:
        config.cookie_policy = cookie_policy
    config.connect_timeout_ms = _get_int_or(section, "connect_timeout_ms", config.connect_timeout_ms)
    config.read_timeout_ms = _get_int_or(section, "read_timeout_ms", config.read_timeout_ms)

fn _apply_rendering_section(config: BrowserConfig, section):
    config.gpu_compositing = _get_bool_or(section, "gpu_compositing", config.gpu_compositing)
    config.hardware_acceleration = _get_bool_or(section, "hardware_acceleration", config.hardware_acceleration)
    config.max_texture_size = _get_int_or(section, "max_texture_size", config.max_texture_size)
    config.tile_size = _get_int_or(section, "tile_size", config.tile_size)
    config.target_fps = _get_int_or(section, "target_fps", config.target_fps)

fn _apply_security_section(config: BrowserConfig, section):
    val csp_default = _get_text(section, "csp_default")
    if csp_default.len() > 0:
        config.csp_default = csp_default
    val mixed_content = _get_text(section, "mixed_content")
    if mixed_content.len() > 0:
        config.mixed_content = mixed_content

fn _get_text(section, key: text) -> text:
    val field = section.get(key)
    if field.?:
        match field:
            case SdnValue.String(s): return s
            case SdnValue.Int(n): return "{n}"
            case SdnValue.Bool(b):
                if b:
                    return "true"
                return "false"
            case _: pass_dn
    ""

fn _get_int_or(section, key: text, fallback: i64) -> i64:
    val field = section.get(key)
    if field.?:
        match field:
            case SdnValue.Int(n): return n
            case _: pass_dn
    fallback

fn _get_bool_or(section, key: text, fallback: bool) -> bool:
    val field = section.get(key)
    if field.?:
        match field:
            case SdnValue.Bool(b): return b
            case _: pass_dn
    fallback
