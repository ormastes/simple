#![allow(REQC001)]
#![allow(REQC004)]
#![allow(unnamed_duplicate_typed_args)]
# Site isolation policy for the Simple Browser Platform.
# Ensures different origins run in separate renderer processes,
# preventing Spectre-class cross-origin data leaks.
# MP-3: Wired into tab opening flow — checks origin against existing
# renderer processes, reuses same-origin process, spawns cross-origin.

use sbp.entity.ipc.process_types.{ProcessId, ProcessKind}
use sbp.shared.error.{BrowserResult, BrowserError, ipc_error}

class Origin:
    scheme: text
    host: text
    port: i64

    static fn create(scheme: text, host: text, port: i64) -> Origin:
        Origin(scheme: scheme, host: host, port: port)

    static fn from_url(url: text) -> Origin:
        # Parse a URL into an Origin. Simplified: extract scheme://host:port
        var scheme = "https"
        var host = ""
        var port = 443
        var rest = url

        # Extract scheme
        val scheme_end = rest.index_of("://")
        if scheme_end >= 0:
            scheme = rest.substring(0, scheme_end)
            rest = rest.substring(scheme_end + 3, rest.len())

        # Default port by scheme
        if scheme == "http":
            port = 80

        # Extract host (and optional port)
        val slash_pos = rest.index_of("/")
        val host_part = if slash_pos >= 0: rest.substring(0, slash_pos) else: rest

        val colon_pos = host_part.index_of(":")
        if colon_pos >= 0:
            host = host_part.substring(0, colon_pos)
            val port_str = host_part.substring(colon_pos + 1, host_part.len())
            port = port_str.to_i64()
        else:
            host = host_part

        Origin(scheme: scheme, host: host, port: port)

    fn to_site() -> text:
        # Extract registrable domain (eTLD+1).
        # Simplified: just returns host for now.
        self.host

class OriginMapping:
    origin_site: text
    pid_id: i64

    static fn create(origin_site: text, pid_id: i64) -> OriginMapping:
        OriginMapping(origin_site: origin_site, pid_id: pid_id)

# MP-3: Result of an isolation decision — reuse existing or spawn new
enum IsolationDecision:
    ReuseProcess
    SpawnNew

class IsolationResult:
    decision: IsolationDecision
    pid_id: i64
    origin_site: text

    static fn reuse(pid_id: i64, origin_site: text) -> IsolationResult:
        IsolationResult(decision: IsolationDecision.ReuseProcess, pid_id: pid_id, origin_site: origin_site)

    static fn spawn(pid_id: i64, origin_site: text) -> IsolationResult:
        IsolationResult(decision: IsolationDecision.SpawnNew, pid_id: pid_id, origin_site: origin_site)

class SiteIsolationPolicy:
    process_map: [OriginMapping]
    next_pid_hint: i64

    static fn new() -> SiteIsolationPolicy:
        SiteIsolationPolicy(process_map: [OriginMapping](), next_pid_hint: 100)

    me assign_process_for_tab(url: text) -> IsolationResult:
        # MP-3: Called when opening a new tab. Checks origin against existing
        # renderer processes. Returns reuse if same-origin, spawn if cross-origin.
        val origin = Origin.from_url(url)

        if not self.should_isolate(origin):
            # Non-isolatable origins (data:, about:) share a utility process
            val utility_pid = self.get_or_create_utility_pid()
            return IsolationResult.reuse(utility_pid, origin.to_site())

        val site = origin.to_site()

        # Check existing mappings for same-origin reuse
        var i = 0
        while i < self.process_map.len():
            val mapping = self.process_map.get(i)
            if mapping.origin_site == site:
                return IsolationResult.reuse(mapping.pid_id, site)
            i = i + 1

        # Cross-origin: assign a new renderer process
        val new_pid = self.next_pid_hint
        self.next_pid_hint = self.next_pid_hint + 1
        self.process_map.push(OriginMapping.create(site, new_pid))
        IsolationResult.spawn(new_pid, site)

    fn get_process_for_origin(origin: Origin) -> ProcessId:
        # Returns existing process for this site, or assigns a new PID hint.
        val site = origin.to_site()
        var i = 0
        while i < self.process_map.len():
            val mapping = self.process_map.get(i)
            if mapping.origin_site == site:
                return ProcessId.create(mapping.pid_id, ProcessKind.Renderer)
            i = i + 1
        # No existing mapping — assign new PID
        val pid_id = self.next_pid_hint
        self.next_pid_hint = self.next_pid_hint + 1
        self.process_map.push(OriginMapping.create(site, pid_id))
        ProcessId.create(pid_id, ProcessKind.Renderer)

    fn lookup_process(url: text) -> Option<i64>:
        # MP-3: Check if a renderer process already exists for this URL's origin.
        val origin = Origin.from_url(url)
        val site = origin.to_site()
        var i = 0
        while i < self.process_map.len():
            val mapping = self.process_map.get(i)
            if mapping.origin_site == site:
                return Some(mapping.pid_id)
            i = i + 1
        nil

    me unmap_process(pid_id: i64):
        # Remove a process mapping (e.g., when renderer crashes or tab closes).
        var idx = -1
        var i = 0
        while i < self.process_map.len():
            if self.process_map.get(i).pid_id == pid_id:
                idx = i
            i = i + 1
        if idx >= 0:
            self.process_map.remove(idx)

    fn is_same_site(a: Origin, b: Origin) -> bool:
        a.to_site() == b.to_site()

    fn should_isolate(origin: Origin) -> bool:
        # All origins should be isolated in site-per-process model.
        # Could be relaxed for data: or about: URLs.
        val scheme = origin.scheme
        if scheme == "data":
            return false
        if scheme == "about":
            return false
        true

    # --- internal helpers ---

    me get_or_create_utility_pid() -> i64:
        # Non-isolatable origins share a single utility renderer.
        val utility_site = "__utility__"
        var i = 0
        while i < self.process_map.len():
            val mapping = self.process_map.get(i)
            if mapping.origin_site == utility_site:
                return mapping.pid_id
            i = i + 1
        val pid = self.next_pid_hint
        self.next_pid_hint = self.next_pid_hint + 1
        self.process_map.push(OriginMapping.create(utility_site, pid))
        pid
