# Process lifecycle management for the Simple Browser Platform.
# Manages spawning, killing, and IPC routing across browser processes.
# Each process gets a unique PID and runs in a sandbox with restricted capabilities.

use examples.browser.entity.ipc.process_types.{ProcessId, ProcessKind, ProcessState, ProcessInfo}
use examples.browser.entity.ipc.message_types.{BrowserIpcMsg}
use examples.browser.shared.logging.{Logger}
use examples.browser.shared.error.{BrowserError, ipc_error}

class ProcessMailbox:
    pid_id: i64
    messages: List<BrowserIpcMsg>

    static fn for_pid(pid_id: i64) -> ProcessMailbox:
        ProcessMailbox(pid_id: pid_id, messages: List<BrowserIpcMsg>())

class ProcessManager:
    logger: Logger
    processes: List<ProcessInfo>
    mailboxes: List<ProcessMailbox>
    next_pid: i64

    static fn create_manager(logger: Logger) -> ProcessManager:
        ProcessManager(
            logger: logger,
            processes: List<ProcessInfo>(),
            mailboxes: List<ProcessMailbox>(),
            next_pid: 1
        )

    me spawn(kind: ProcessKind) -> Result<ProcessId, BrowserError>:
        # Allocate a new PID and create a process entry
        val pid = ProcessId(id: self.next_pid, kind: kind)
        self.next_pid = self.next_pid + 1

        val info = ProcessInfo(pid: pid, state: ProcessState.Starting, memory_usage: 0)
        self.processes.push(info)
        self.mailboxes.push(ProcessMailbox.for_pid(pid.id))

        self.logger.info("Spawned process pid={pid.id} kind={kind}")

        # Transition to Running
        self.set_state(pid, ProcessState.Running)

        Ok(pid)

    me kill(pid: ProcessId) -> Result<(), BrowserError>:
        # Find process and transition to Terminated
        val found = self.find_index(pid)
        if found < 0:
            return Err(ipc_error("Process not found: pid={pid.id}"))
        self.set_state(pid, ProcessState.Terminated)
        self.logger.info("Killed process pid={pid.id}")
        Ok(())

    me send(msg: BrowserIpcMsg) -> Result<(), BrowserError>:
        # Route IPC message to destination process
        val dst_state = self.get_state(msg.dst)
        match dst_state:
            ProcessState.Running:
                self.logger.debug("IPC: pid={msg.src.id} -> pid={msg.dst.id}")
                self.enqueue(msg.dst.id, msg)?
                Ok(())
            _:
                Err(ipc_error("Cannot send to process pid={msg.dst.id}: not running"))

    me recv(pid: ProcessId) -> BrowserIpcMsg?:
        var i = 0
        while i < self.mailboxes.len():
            var mailbox = self.mailboxes.get(i)
            if mailbox.pid_id == pid.id:
                if mailbox.messages.len() == 0:
                    return nil
                val msg = mailbox.messages.get(0)
                mailbox.messages.remove(0)
                self.mailboxes.set(i, mailbox)
                return Some(msg)
            i = i + 1
        nil

    fn pending_messages() -> i64:
        var total = 0
        for mailbox in self.mailboxes:
            total = total + mailbox.messages.len()
        total

    fn get_state(pid: ProcessId) -> ProcessState:
        var i = 0
        while i < self.processes.len():
            val info = self.processes.get(i)
            if info.pid.id == pid.id:
                return info.state
            i = i + 1
        ProcessState.Terminated

    fn list_processes() -> List<ProcessInfo>:
        self.processes

    # --- internal helpers ---

    me set_state(pid: ProcessId, state: ProcessState):
        var i = 0
        while i < self.processes.len():
            val info = self.processes.get(i)
            if info.pid.id == pid.id:
                val updated = ProcessInfo(pid: pid, state: state, memory_usage: info.memory_usage)
                self.processes.set(i, updated)
                return
            i = i + 1

    fn find_index(pid: ProcessId) -> i64:
        var i = 0
        while i < self.processes.len():
            val info = self.processes.get(i)
            if info.pid.id == pid.id:
                return i
            i = i + 1
        -1

    me enqueue(pid_id: i64, msg: BrowserIpcMsg) -> Result<(), BrowserError>:
        var i = 0
        while i < self.mailboxes.len():
            var mailbox = self.mailboxes.get(i)
            if mailbox.pid_id == pid_id:
                mailbox.messages.push(msg)
                self.mailboxes.set(i, mailbox)
                return Ok(())
            i = i + 1
        Err(ipc_error("No mailbox for process pid={pid_id}"))
