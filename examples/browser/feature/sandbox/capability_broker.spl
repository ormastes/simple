# Capability-based sandboxing for the Simple Browser Platform.
# Follows the OpenBSD pledge/unveil model. Each process gets a SandboxPolicy
# loaded from sandbox.sdn profiles. The broker controls granting and revoking
# capabilities at runtime.

use std.io_runtime.{file_read}
use examples.browser.entity.ipc.process_types.{ProcessId}
use examples.browser.shared.logging.{Logger}
use examples.browser.shared.error.{BrowserError, sandbox_error}

class SandboxPolicy:
    capabilities: List<text>
    denied: List<text>
    pledge: bool
    unveil_paths: List<text>

    static fn from_profile(capabilities: List<text>, denied: List<text>, pledge: bool, unveil_paths: List<text>) -> SandboxPolicy:
        SandboxPolicy(capabilities: capabilities, denied: denied, pledge: pledge, unveil_paths: unveil_paths)

    static fn empty() -> SandboxPolicy:
        SandboxPolicy(capabilities: List<text>(), denied: List<text>(), pledge: false, unveil_paths: List<text>())

class PolicyEntry:
    pid_id: i64
    policy: SandboxPolicy

    static fn bind_policy(pid_id: i64, policy: SandboxPolicy) -> PolicyEntry:
        PolicyEntry(pid_id: pid_id, policy: policy)

class CapabilityBroker:
    logger: Logger
    policies: List<PolicyEntry>

    static fn create_broker(logger: Logger) -> CapabilityBroker:
        CapabilityBroker(logger: logger, policies: List<PolicyEntry>())

    me apply_sandbox(pid: ProcessId, profile: text) -> Result<(), BrowserError>:
        val policy = self.load_profile(profile)
        match policy:
            Ok(p):
                val entry = PolicyEntry.bind_policy(pid.id, p)
                self.policies.push(entry)
                self.logger.info("Applied sandbox profile '{profile}' to pid={pid.id}")
                Ok(())
            Err(e):
                Err(e)

    fn check_capability(pid: ProcessId, cap: text) -> bool:
        val policy = self.find_policy(pid)
        match policy:
            Some(p):
                # Check denied list first — denied always wins
                var i = 0
                while i < p.denied.len():
                    if p.denied.get(i) == cap:
                        return false
                    i = i + 1
                # Check capabilities list
                var j = 0
                while j < p.capabilities.len():
                    if p.capabilities.get(j) == cap:
                        return true
                    j = j + 1
                false
            nil:
                false

    me grant(pid: ProcessId, cap: text) -> Result<(), BrowserError>:
        var i = 0
        while i < self.policies.len():
            val entry = self.policies.get(i)
            if entry.pid_id == pid.id:
                entry.policy.capabilities.push(cap)
                self.logger.info("Granted '{cap}' to pid={pid.id}")
                return Ok(())
            i = i + 1
        Err(sandbox_error("No sandbox policy for pid={pid.id}"))

    me revoke(pid: ProcessId, cap: text) -> Result<(), BrowserError>:
        var i = 0
        while i < self.policies.len():
            val entry = self.policies.get(i)
            if entry.pid_id == pid.id:
                # Add to denied list to override any existing grant
                entry.policy.denied.push(cap)
                self.logger.info("Revoked '{cap}' from pid={pid.id}")
                return Ok(())
            i = i + 1
        Err(sandbox_error("No sandbox policy for pid={pid.id}"))

    # --- internal helpers ---

    fn find_policy(pid: ProcessId) -> Option<SandboxPolicy>:
        var i = 0
        while i < self.policies.len():
            val entry = self.policies.get(i)
            if entry.pid_id == pid.id:
                return Some(entry.policy)
            i = i + 1
        nil

    fn load_profile(profile: text) -> Result<SandboxPolicy, BrowserError>:
        val content = file_read("examples/browser/sandbox.sdn")
        if content.len() == 0:
            return Err(sandbox_error("Failed to read sandbox policy file"))

        var section = ""
        var collecting_key = ""
        var capabilities = List<text>()
        var denied = List<text>()
        var unveil_paths = List<text>()
        var pledge = false
        var saw_profile = false

        for raw_line in content.split("\n"):
            val trimmed = raw_line.trim()
            if trimmed == "" or trimmed.starts_with("#"):
                pass_do_nothing
            else if trimmed.ends_with(":") and not trimmed.contains(": "):
                if collecting_key.len() > 0 and section == profile:
                    collecting_key = ""
                section = trimmed.substring(0, trimmed.len() - 1)
                if section == profile:
                    saw_profile = true
            else if section == profile:
                if collecting_key.len() > 0:
                    if trimmed == "]":
                        collecting_key = ""
                    else:
                        val item = _normalize_item(trimmed)
                        if item.len() > 0:
                            _push_list_item(collecting_key, item, capabilities, denied, unveil_paths)
                else:
                    val colon_index = trimmed.index_of(":")
                    if colon_index < 0:
                        pass_do_nothing
                    else:
                        val key = trimmed.substring(0, colon_index).trim()
                        val value = trimmed.substring(colon_index + 1).trim()
                        if value == "[":
                            collecting_key = key
                        else if value.starts_with("[") and value.ends_with("]"):
                            _assign_inline_list(key, value, capabilities, denied, unveil_paths)
                        else if key == "pledge":
                            pledge = value == "true"

        if not saw_profile:
            return Err(sandbox_error("Sandbox profile not found: {profile}"))

        Ok(SandboxPolicy.from_profile(
            capabilities: capabilities,
            denied: denied,
            pledge: pledge,
            unveil_paths: unveil_paths
        ))

fn _assign_inline_list(key: text, value: text, capabilities: List<text>, denied: List<text>, unveil_paths: List<text>):
    val inner = value.substring(1, value.len() - 1).trim()
    if inner.len() == 0:
        return
    for piece in inner.split(","):
        val item = _normalize_item(piece)
        if item.len() > 0:
            _push_list_item(key, item, capabilities, denied, unveil_paths)

fn _push_list_item(key: text, item: text, capabilities: List<text>, denied: List<text>, unveil_paths: List<text>):
    if key == "capabilities":
        capabilities.push(item)
    else if key == "denied":
        denied.push(item)
    else if key == "unveil_paths":
        unveil_paths.push(item)

fn _normalize_item(raw: text) -> text:
    var item = raw.trim()
    if item.ends_with(","):
        item = item.substring(0, item.len() - 1).trim()
    if item.starts_with("\"") and item.ends_with("\"") and item.len() >= 2:
        item = item.substring(1, item.len() - 1)
    item
