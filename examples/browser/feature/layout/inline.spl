# Inline formatting context — text and inline element layout.
# Implements CSS inline layout: left-to-right fragment placement, line breaking
# when content overflows available width, baseline alignment, and text-align
# distribution within line boxes.

use examples.browser.entity.dom.box_types.(BoxKind, BoxModel, LayoutBox)
use examples.browser.entity.dom.css_types.(CSSValue)
use examples.browser.feature.style.computed.(ComputedStyle, extract_px)
use examples.browser.feature.layout.block.(LayoutContext, resolve_length, resolve_padding, resolve_border_width)
use examples.browser.shared.logging.(Logger, LogLevel)

# ---------------------------------------------------------------------------
# InlineFragment — a positioned piece of inline content within a line.
# ---------------------------------------------------------------------------

class InlineFragment:
    node_id: i64
    x: f64
    y: f64
    width: f64
    height: f64
    baseline: f64
    text_content: text
    is_text: bool

    static fn create_text(node_id: i64, content: text, w: f64, h: f64, bl: f64) -> InlineFragment:
        InlineFragment(
            node_id: node_id,
            x: 0.0, y: 0.0,
            width: w, height: h,
            baseline: bl,
            text_content: content,
            is_text: true
        )

    static fn create_box(node_id: i64, w: f64, h: f64, bl: f64) -> InlineFragment:
        InlineFragment(
            node_id: node_id,
            x: 0.0, y: 0.0,
            width: w, height: h,
            baseline: bl,
            text_content: "",
            is_text: false
        )

# ---------------------------------------------------------------------------
# LineBox — a horizontal line of inline content.
# ---------------------------------------------------------------------------

class LineBox:
    x: f64
    y: f64
    width: f64
    height: f64
    baseline: f64
    fragments: [InlineFragment]

    static fn create(x: f64, y: f64) -> LineBox:
        LineBox(
            x: x, y: y,
            width: 0.0, height: 0.0,
            baseline: 0.0,
            fragments: [InlineFragment]()
        )

# ---------------------------------------------------------------------------
# InlineFormatter — performs inline-level layout.
# ---------------------------------------------------------------------------

class InlineFormatter:
    logger: Logger

    static fn new(logger: Logger) -> InlineFormatter:
        InlineFormatter(logger: logger)

    # -------------------------------------------------------------------
    # Main entry: layout inline children into line boxes.
    # -------------------------------------------------------------------
    me layout_inline(children: [LayoutBox], styles: [ComputedStyle], ctx: LayoutContext) -> [LineBox]:
        self.logger.debug("layout_inline: {children.len()} children, available_w={ctx.containing_block_width}")

        val available_width = ctx.containing_block_width
        var lines = [LineBox]()
        var current_line = LineBox.create(ctx.current_x, ctx.current_y)
        var cursor_x = 0.0
        var line_y = ctx.current_y

        # Determine a default style for text measurement
        val default_style = if styles.len() > 0: styles[0] else: ComputedStyle.default_style()
        val font_size = extract_px(default_style.font_size)
        val font_family = default_style.font_family
        val text_align_val = default_style.text_align
        val line_height = get_line_height(default_style)

        var child_idx = 0
        for child in children:
            val child_style = if child_idx < styles.len(): styles[child_idx] else: default_style

            match child.kind:
                BoxKind.Inline:
                    # Inline box: treat as a single fragment
                    val frag_w = if child.width > 0.0: child.width else: 0.0
                    val frag_h = if child.height > 0.0: child.height else: line_height
                    val frag_bl = frag_h * 0.8

                    if should_wrap(cursor_x, frag_w, available_width) and cursor_x > 0.0:
                        # Finalize current line
                        current_line.width = cursor_x
                        current_line.height = calculate_line_height(current_line.fragments)
                        current_line.baseline = calculate_line_baseline(current_line.fragments)
                        current_line.fragments = baseline_align(current_line.fragments)
                        current_line = align_line(current_line, available_width, text_align_val)
                        lines.push(current_line)

                        # Start new line
                        line_y = line_y + current_line.height
                        current_line = LineBox.create(ctx.current_x, line_y)
                        cursor_x = 0.0

                    var frag = InlineFragment.create_box(child.node_id, frag_w, frag_h, frag_bl)
                    frag.x = cursor_x
                    frag.y = 0.0
                    current_line.fragments.push(frag)
                    cursor_x = cursor_x + frag_w

                _:
                    # Text node or other — extract text content and break into words
                    val text_content = extract_text_content(child)
                    val child_font_size = extract_px(child_style.font_size)
                    val child_font_family = child_style.font_family
                    val child_line_height = get_line_height(child_style)

                    if text_content.len() == 0:
                        child_idx = child_idx + 1
                        continue

                    val words = break_text_into_words(text_content)

                    for word in words:
                        val word_width = measure_text(word, child_font_size, child_font_family)
                        val word_height = child_line_height
                        val word_baseline = child_font_size * 0.8

                        # Add space before word if not at start of line
                        val space_width = if cursor_x > 0.0: measure_text(" ", child_font_size, child_font_family) else: 0.0

                        if should_wrap(cursor_x + space_width, word_width, available_width) and cursor_x > 0.0:
                            # Finalize current line
                            current_line.width = cursor_x
                            current_line.height = calculate_line_height(current_line.fragments)
                            current_line.baseline = calculate_line_baseline(current_line.fragments)
                            current_line.fragments = baseline_align(current_line.fragments)
                            current_line = align_line(current_line, available_width, text_align_val)
                            lines.push(current_line)

                            # Start new line
                            line_y = line_y + current_line.height
                            current_line = LineBox.create(ctx.current_x, line_y)
                            cursor_x = 0.0

                        # Add space fragment if needed
                        if cursor_x > 0.0 and space_width > 0.0:
                            cursor_x = cursor_x + space_width

                        # Add word fragment
                        var frag = InlineFragment.create_text(child.node_id, word, word_width, word_height, word_baseline)
                        frag.x = cursor_x
                        frag.y = 0.0
                        current_line.fragments.push(frag)
                        cursor_x = cursor_x + word_width

            child_idx = child_idx + 1

        # Finalize last line if it has fragments
        if current_line.fragments.len() > 0:
            current_line.width = cursor_x
            current_line.height = calculate_line_height(current_line.fragments)
            current_line.baseline = calculate_line_baseline(current_line.fragments)
            current_line.fragments = baseline_align(current_line.fragments)
            current_line = align_line(current_line, available_width, text_align_val)
            lines.push(current_line)

        self.logger.debug("layout_inline: produced {lines.len()} line boxes")
        lines

# ---------------------------------------------------------------------------
# Text breaking — split text into words on whitespace boundaries.
# ---------------------------------------------------------------------------

fn break_text_into_words(text_content: text) -> [text]:
    var words = [text]()
    var current_word = ""

    for ch in text_content:
        if ch == " " or ch == "\t" or ch == "\n" or ch == "\r":
            if current_word.len() > 0:
                words.push(current_word)
                current_word = ""
        else:
            current_word = current_word + ch

    if current_word.len() > 0:
        words.push(current_word)

    words

# ---------------------------------------------------------------------------
# Text measurement — approximate text width using a simple character model.
# Average character width is ~0.6 * font_size for proportional fonts.
# ---------------------------------------------------------------------------

fn measure_text(word: text, font_size: f64, font_family: text) -> f64:
    val char_count = word.len()
    val avg_char_width = font_size * 0.6

    # Adjust for monospace fonts
    val width_factor = if font_family == "monospace" or font_family == "courier":
        font_size * 0.6
    else if font_family == "serif" or font_family == "times":
        font_size * 0.55
    else:
        font_size * 0.6

    val result = char_count.to_f64() * width_factor
    result

# ---------------------------------------------------------------------------
# Line height — resolve from ComputedStyle.
# ---------------------------------------------------------------------------

fn get_line_height(style: ComputedStyle) -> f64:
    val font_size = extract_px(style.font_size)
    val lh_val = style.line_height
    match lh_val:
        CSSValue.Length(v, unit):
            if unit == "px":
                v
            else:
                v * font_size
        CSSValue.Number(v):
            # Unitless number: multiply by font-size
            v * font_size
        CSSValue.Percentage(v):
            (v / 100.0) * font_size
        CSSValue.Keyword(v):
            if v == "normal":
                font_size * 1.2
            else:
                font_size * 1.2
        _:
            font_size * 1.2

# ---------------------------------------------------------------------------
# Line alignment — apply text-align within the line box.
# ---------------------------------------------------------------------------

fn align_line(line: LineBox, available_width: f64, text_align: text) -> LineBox:
    var result = line
    val remaining = available_width - line.width

    if remaining <= 0.0:
        return result

    match text_align:
        "center":
            val offset = remaining / 2.0
            result.fragments = offset_fragments(result.fragments, offset)
            result
        "right":
            result.fragments = offset_fragments(result.fragments, remaining)
            result
        "end":
            result.fragments = offset_fragments(result.fragments, remaining)
            result
        "justify":
            # Distribute space between fragments (not for the last line typically)
            val frag_count = result.fragments.len()
            if frag_count > 1:
                val gap = remaining / (frag_count - 1).to_f64()
                var offset = 0.0
                var justified = [InlineFragment]()
                var i = 0
                for frag in result.fragments:
                    var f = frag
                    f.x = f.x + offset
                    justified.push(f)
                    offset = offset + gap
                    i = i + 1
                result.fragments = justified
            result
        _:
            # "left", "start", or default — no adjustment
            result

fn offset_fragments(fragments: [InlineFragment], offset: f64) -> [InlineFragment]:
    var result = [InlineFragment]()
    for frag in fragments:
        var f = frag
        f.x = f.x + offset
        result.push(f)
    result

# ---------------------------------------------------------------------------
# Baseline alignment — align fragments to a common baseline.
# ---------------------------------------------------------------------------

fn baseline_align(fragments: [InlineFragment]) -> [InlineFragment]:
    # Find the maximum baseline offset
    var max_baseline = 0.0
    for frag in fragments:
        if frag.baseline > max_baseline:
            max_baseline = frag.baseline

    # Shift each fragment so baselines align
    var result = [InlineFragment]()
    for frag in fragments:
        var f = frag
        val baseline_diff = max_baseline - f.baseline
        f.y = baseline_diff
        result.push(f)
    result

fn calculate_line_baseline(fragments: [InlineFragment]) -> f64:
    var max_baseline = 0.0
    for frag in fragments:
        if frag.baseline > max_baseline:
            max_baseline = frag.baseline
    max_baseline

# ---------------------------------------------------------------------------
# Line height calculation — maximum height among fragments.
# ---------------------------------------------------------------------------

fn calculate_line_height(fragments: [InlineFragment]) -> f64:
    var max_height = 0.0
    for frag in fragments:
        if frag.height > max_height:
            max_height = frag.height
    if max_height == 0.0:
        # Default minimum line height
        16.0 * 1.2
    else:
        max_height

# ---------------------------------------------------------------------------
# Wrap detection — should we start a new line?
# ---------------------------------------------------------------------------

fn should_wrap(current_x: f64, word_width: f64, available_width: f64) -> bool:
    (current_x + word_width) > available_width

# ---------------------------------------------------------------------------
# Helper — extract text content from a layout box (via node data or children).
# ---------------------------------------------------------------------------

fn extract_text_content(box_node: LayoutBox) -> text:
    # In a real browser, we'd look up the DOM node's text content.
    # For now, return empty — the caller provides text via the style/DOM layer.
    ""
