#![allow(REQC001)]
#![allow(REQC004)]
#![allow(unnamed_duplicate_typed_args)]
# Text shaping and line breaking for the layout engine.
# Provides glyph-level shaping (simplified), line-break opportunity detection,
# greedy and word-wrap line breaking, text measurement with font metrics,
# and white-space collapsing per CSS white-space property.

use examples.browser.entity.dom.css_types.{CSSValue}
use examples.browser.shared.logging.{Logger, LogLevel}

# ---------------------------------------------------------------------------
# BreakOpportunity — per-character break classification.
# ---------------------------------------------------------------------------

enum BreakOpportunity:
    Mandatory
    Allowed
    Prohibited

# ---------------------------------------------------------------------------
# TextRun — a contiguous run of text with uniform styling.
# ---------------------------------------------------------------------------

class TextRun:
    text_content: text
    font_size: f64
    font_family: text
    font_weight: i64
    font_style: text
    letter_spacing: f64
    word_spacing: f64

    static fn create(content: text, size: f64, family: text) -> TextRun:
        TextRun(
            text_content: content,
            font_size: size,
            font_family: family,
            font_weight: 400,
            font_style: "normal",
            letter_spacing: 0.0,
            word_spacing: 0.0
        )

    static fn create_full(content: text, size: f64, family: text, weight: i64, style_val: text, ls: f64, ws: f64) -> TextRun:
        TextRun(
            text_content: content,
            font_size: size,
            font_family: family,
            font_weight: weight,
            font_style: style_val,
            letter_spacing: ls,
            word_spacing: ws
        )

# ---------------------------------------------------------------------------
# ShapedGlyph — a positioned glyph after text shaping.
# ---------------------------------------------------------------------------

class ShapedGlyph:
    codepoint: i64
    x_advance: f64
    y_advance: f64
    x_offset: f64
    y_offset: f64

    static fn create(cp: i64, xa: f64) -> ShapedGlyph:
        ShapedGlyph(
            codepoint: cp,
            x_advance: xa,
            y_advance: 0.0,
            x_offset: 0.0,
            y_offset: 0.0
        )

# ---------------------------------------------------------------------------
# FontMetrics — vertical metrics for a font at a given size.
# ---------------------------------------------------------------------------

class FontMetrics:
    ascent: f64
    descent: f64
    line_gap: f64
    x_height: f64
    cap_height: f64
    em_size: f64

    static fn create(ascent: f64, descent: f64, line_gap: f64, x_height: f64, cap_height: f64, em_size: f64) -> FontMetrics:
        FontMetrics(
            ascent: ascent,
            descent: descent,
            line_gap: line_gap,
            x_height: x_height,
            cap_height: cap_height,
            em_size: em_size
        )

fn text_to_codepoints(s: text) -> [i64]:
    val bytes = s.bytes()
    var codepoints: [i64] = []
    var i = 0
    while i < bytes.len():
        val b0 = bytes[i].to_i64() & 0xFF
        if b0 < 0x80:
            codepoints.push(b0)
            i = i + 1
        else if (b0 & 0xE0) == 0xC0 and i + 1 < bytes.len():
            val b1 = bytes[i + 1].to_i64() & 0x3F
            codepoints.push(((b0 & 0x1F) << 6) | b1)
            i = i + 2
        else if (b0 & 0xF0) == 0xE0 and i + 2 < bytes.len():
            val b1 = bytes[i + 1].to_i64() & 0x3F
            val b2 = bytes[i + 2].to_i64() & 0x3F
            codepoints.push(((b0 & 0x0F) << 12) | (b1 << 6) | b2)
            i = i + 3
        else if (b0 & 0xF8) == 0xF0 and i + 3 < bytes.len():
            val b1 = bytes[i + 1].to_i64() & 0x3F
            val b2 = bytes[i + 2].to_i64() & 0x3F
            val b3 = bytes[i + 3].to_i64() & 0x3F
            codepoints.push(((b0 & 0x07) << 18) | (b1 << 12) | (b2 << 6) | b3)
            i = i + 4
        else:
            codepoints.push(0xFFFD)
            i = i + 1
    codepoints

# ---------------------------------------------------------------------------
# TextShaper — shapes text runs into positioned glyphs.
# ---------------------------------------------------------------------------

class TextShaper:
    logger: Logger

    static fn new(logger: Logger) -> TextShaper:
        TextShaper(logger: logger)

    # -------------------------------------------------------------------
    # Shape a text run into a list of positioned glyphs.
    # This is a simplified shaper — a real implementation would use
    # HarfBuzz or similar. We approximate with per-character advances.
    # -------------------------------------------------------------------
    me shape(run: TextRun) -> [ShapedGlyph]:
        self.logger.trace("shaping text run: len={run.text_content.len()} font_size={run.font_size}")
        var glyphs: [ShapedGlyph] = []
        val base_advance = measure_char_advance(run.font_size, run.font_family)

        val codepoints = text_to_codepoints(run.text_content)
        for cp in codepoints:
            var advance = base_advance + run.letter_spacing

            # Adjust advance for whitespace (word spacing)
            if cp == 32:
                advance = advance + run.word_spacing

            # Wider characters (CJK) get double advance
            if is_cjk_codepoint(cp):
                advance = advance * 2.0

            val glyph = ShapedGlyph.create(cp, advance)
            glyphs.push(glyph)

        glyphs

# ---------------------------------------------------------------------------
# Line breaking — find break opportunities per CSS line-breaking rules.
# ---------------------------------------------------------------------------

fn find_break_opportunities(text_content: text) -> [BreakOpportunity]:
    var result = [BreakOpportunity]()
    var prev_ch = ""
    var idx = 0

    val codepoints = text_to_codepoints(text_content)
    for cp in codepoints:
        if cp == 10:
            # Newline is a mandatory break
            result.push(BreakOpportunity.Mandatory)
        else if cp == 32 or cp == 9:
            # Whitespace allows a break after it
            result.push(BreakOpportunity.Allowed)
        else if cp == 45:
            # Hyphen allows a break after it
            result.push(BreakOpportunity.Allowed)
        else if is_cjk_codepoint(cp):
            # CJK characters allow breaks before and after
            result.push(BreakOpportunity.Allowed)
        else if is_breakable_whitespace(prev_ch):
            # Character after whitespace: break allowed here
            result.push(BreakOpportunity.Allowed)
        else:
            result.push(BreakOpportunity.Prohibited)

        prev_ch = if cp == 32: " " else: if cp == 9: "\t" else: if cp == 10: "\n" else: ""
        idx = idx + 1

    result

# ---------------------------------------------------------------------------
# Greedy line breaking — break text into lines that fit max_width.
# ---------------------------------------------------------------------------

fn break_into_lines(text_content: text, max_width: f64, font_size: f64) -> [text]:
    var lines = [text]()
    val words = split_on_whitespace(text_content)

    if words.len() == 0:
        return lines

    var current_line = ""
    var current_width = 0.0
    val space_width = measure_word(" ", font_size)

    for word in words:
        val word_width = measure_word(word, font_size)

        if current_line.len() == 0:
            # First word on the line — always add it even if it overflows
            current_line = word
            current_width = word_width
        else:
            val needed = current_width + space_width + word_width
            if needed <= max_width:
                current_line = current_line + " " + word
                current_width = needed
            else:
                # Line full — push and start new line
                lines.push(current_line)
                current_line = word
                current_width = word_width

    # Push the last line
    if current_line.len() > 0:
        lines.push(current_line)

    lines

# ---------------------------------------------------------------------------
# Word-level wrapping — group words into lines respecting max_width.
# Returns a list of word groups (one group per line).
# ---------------------------------------------------------------------------

fn word_wrap(words: [text], widths: [f64], max_width: f64) -> [[text]]:
    var lines = [[text]]()
    var current_line_words = [text]()
    var current_width = 0.0
    val space_width = max_width * 0.03  # approximate space as 3% of max_width

    var i = 0
    for word in words:
        val w = if i < widths.len(): widths[i] else: 0.0

        if current_line_words.len() == 0:
            current_line_words.push(word)
            current_width = w
        else:
            val needed = current_width + space_width + w
            if needed <= max_width:
                current_line_words.push(word)
                current_width = needed
            else:
                lines.push(current_line_words)
                current_line_words = [text]()
                current_line_words.push(word)
                current_width = w

        i = i + 1

    if current_line_words.len() > 0:
        lines.push(current_line_words)

    lines

# ---------------------------------------------------------------------------
# Text measurement functions.
# ---------------------------------------------------------------------------

fn measure_run(run: TextRun) -> f64:
    var total = 0.0
    val base_advance = measure_char_advance(run.font_size, run.font_family)

    val codepoints = text_to_codepoints(run.text_content)
    for cp in codepoints:
        var advance = base_advance + run.letter_spacing
        if cp == 32:
            advance = advance + run.word_spacing
        if is_cjk_codepoint(cp):
            advance = advance * 2.0
        total = total + advance

    total

fn measure_word(word: text, font_size: f64) -> f64:
    val char_count = word.len()
    char_count.to_f64() * font_size * 0.6

fn measure_char(c: text, font_size: f64) -> f64:
    if is_cjk_char(c):
        font_size * 1.0
    else:
        font_size * 0.6

fn measure_char_advance(font_size: f64, font_family: text) -> f64:
    # Approximate average character advance width by font family
    match font_family:
        "monospace": font_size * 0.6
        "courier": font_size * 0.6
        "Courier New": font_size * 0.6
        "serif": font_size * 0.55
        "Times New Roman": font_size * 0.55
        "sans-serif": font_size * 0.58
        "Arial": font_size * 0.58
        "Helvetica": font_size * 0.58
        _: font_size * 0.6

# ---------------------------------------------------------------------------
# Font metrics — approximate metrics for common font families.
# ---------------------------------------------------------------------------

fn get_font_metrics(font_size: f64, font_family: text) -> FontMetrics:
    # These are approximate ratios based on common fonts.
    # Real implementations would query the font file or system API.
    val ascent_ratio = match font_family:
        "serif": 0.85
        "Times New Roman": 0.85
        "sans-serif": 0.88
        "Arial": 0.88
        "Helvetica": 0.88
        "monospace": 0.80
        "courier": 0.80
        _: 0.85

    val descent_ratio = match font_family:
        "serif": 0.22
        "Times New Roman": 0.22
        "sans-serif": 0.24
        "Arial": 0.24
        "monospace": 0.20
        "courier": 0.20
        _: 0.22

    val x_height_ratio = match font_family:
        "serif": 0.45
        "sans-serif": 0.52
        "monospace": 0.50
        _: 0.48

    val cap_height_ratio = match font_family:
        "serif": 0.66
        "sans-serif": 0.72
        "monospace": 0.68
        _: 0.68

    FontMetrics.create(
        ascent: font_size * ascent_ratio,
        descent: font_size * descent_ratio,
        line_gap: font_size * 0.10,
        x_height: font_size * x_height_ratio,
        cap_height: font_size * cap_height_ratio,
        em_size: font_size
    )

# ---------------------------------------------------------------------------
# White-space handling — CSS white-space property collapsing.
# ---------------------------------------------------------------------------

fn collapse_whitespace(text_content: text, white_space: text) -> text:
    match white_space:
        "pre":
            # Preserve all whitespace and newlines
            text_content
        "pre-wrap":
            # Preserve whitespace, but allow wrapping
            text_content
        "pre-line":
            # Collapse spaces/tabs to single space, preserve newlines
            collapse_spaces_only(text_content)
        "nowrap":
            # Collapse whitespace, no wrapping (wrapping handled by layout)
            collapse_all_whitespace(text_content)
        _:
            # "normal" — collapse all whitespace sequences to single space
            collapse_all_whitespace(text_content)

fn collapse_all_whitespace(text_content: text) -> text:
    var result = ""
    var in_whitespace = false
    var leading = true

    for ch in text_content:
        if ch == " " or ch == "\t" or ch == "\n" or ch == "\r":
            if not in_whitespace and not leading:
                result = result + " "
                in_whitespace = true
        else:
            result = result + ch
            in_whitespace = false
            leading = false

    # Trim trailing space
    if result.len() > 0 and in_whitespace:
        result = trim_trailing_space(result)

    result

fn collapse_spaces_only(text_content: text) -> text:
    var result = ""
    var in_space_run = false

    for ch in text_content:
        if ch == " " or ch == "\t":
            if not in_space_run:
                result = result + " "
                in_space_run = true
        else:
            result = result + ch
            in_space_run = false

    result

fn trim_trailing_space(s: text) -> text:
    # Remove last character if it is a space
    if s.len() == 0:
        return s
    var result = ""
    var i = 0
    val last_idx = s.len() - 1
    for ch in s:
        if i < last_idx:
            result = result + ch
        else:
            if ch != " ":
                result = result + ch
        i = i + 1
    result

# ---------------------------------------------------------------------------
# Character classification helpers.
# ---------------------------------------------------------------------------

fn is_breakable_whitespace(c: text) -> bool:
    c == " " or c == "\t" or c == "\n" or c == "\r"

fn is_cjk_char(c: text) -> bool:
    val cp = char_to_codepoint(c)
    is_cjk_codepoint(cp)

fn is_cjk_codepoint(cp: i64) -> bool:
    (cp >= 0x4E00 and cp <= 0x9FFF) or (cp >= 0x3400 and cp <= 0x4DBF) or (cp >= 0x3000 and cp <= 0x303F) or (cp >= 0xFF00 and cp <= 0xFFEF) or (cp >= 0xAC00 and cp <= 0xD7AF)

# ---------------------------------------------------------------------------
# Utility — split text on whitespace.
# ---------------------------------------------------------------------------

fn split_on_whitespace(text_content: text) -> [text]:
    var words = [text]()
    var current = ""

    for ch in text_content:
        if ch == " " or ch == "\t" or ch == "\n" or ch == "\r":
            if current.len() > 0:
                words.push(current)
                current = ""
        else:
            current = current + ch

    if current.len() > 0:
        words.push(current)

    words

# ---------------------------------------------------------------------------
# Utility — decode a single UTF-8 character into a Unicode codepoint.
# ---------------------------------------------------------------------------

fn char_to_codepoint(c: text) -> i64:
    if c.len() == 0:
        return 0
    val bytes = c.bytes()
    if bytes.len() == 0:
        0
    else:
        val b0 = bytes[0].to_i64() & 0xFF
        if b0 < 0x80:
            b0
        else if (b0 & 0xE0) == 0xC0 and bytes.len() >= 2:
            val b1 = bytes[1].to_i64() & 0x3F
            ((b0 & 0x1F) << 6) | b1
        else if (b0 & 0xF0) == 0xE0 and bytes.len() >= 3:
            val b1 = bytes[1].to_i64() & 0x3F
            val b2 = bytes[2].to_i64() & 0x3F
            ((b0 & 0x0F) << 12) | (b1 << 6) | b2
        else if (b0 & 0xF8) == 0xF0 and bytes.len() >= 4:
            val b1 = bytes[1].to_i64() & 0x3F
            val b2 = bytes[2].to_i64() & 0x3F
            val b3 = bytes[3].to_i64() & 0x3F
            ((b0 & 0x07) << 18) | (b1 << 12) | (b2 << 6) | b3
        else:
            0xFFFD
