# SVG rendering subset — converts a tree of SVG nodes to PaintOps.
# Supports a basic subset: rect, circle, line, text, and path.
#
# SVG uses the software paint pipeline (PaintOp/FillRect scanline rasterization).
# GPU-accelerated path tessellation is not used at this layer.

use examples.browser.entity.dom.paint_types.(Color, PaintOp, from_rgb, from_rgba, black, white, transparent)
use std.common.color.convert.(from_hex, from_name)
use examples.browser.shared.logging.(Logger, LogLevel)

# ---------------------------------------------------------------------------
# SvgNode — a node in the SVG DOM tree.
# ---------------------------------------------------------------------------

class SvgNode:
    tag: text
    attrs: [Pair<text, text>]
    children: [SvgNode]

    static fn create(tag: text, attrs: [Pair<text, text>]) -> SvgNode:
        SvgNode(tag: tag, attrs: attrs, children: [SvgNode]())

    static fn with_children(tag: text, attrs: [Pair<text, text>], children: [SvgNode]) -> SvgNode:
        SvgNode(tag: tag, attrs: attrs, children: children)

# ---------------------------------------------------------------------------
# SvgRenderer
# ---------------------------------------------------------------------------

class SvgRenderer:
    logger: Logger

    static fn new(logger: Logger) -> SvgRenderer:
        SvgRenderer(logger: logger)

# ---------------------------------------------------------------------------
# SVG rendering functions
# ---------------------------------------------------------------------------

# Render an SVG tree into a list of PaintOps.
fn render(svg_tree: [SvgNode]) -> [PaintOp]:
    var ops = [PaintOp]()
    for node in svg_tree:
        val node_ops = render_node(node)
        for op in node_ops:
            ops.push(op)
    ops

# Render a single SVG node, dispatching by tag name.
fn render_node(node: SvgNode) -> [PaintOp]:
    var ops = [PaintOp]()

    match node.tag:
        "rect":
            val rect_ops = render_rect(node.attrs)
            for op in rect_ops:
                ops.push(op)
        "circle":
            val circle_ops = render_circle(node.attrs)
            for op in circle_ops:
                ops.push(op)
        "line":
            val line_ops = render_line(node.attrs)
            for op in line_ops:
                ops.push(op)
        "text":
            # Text content would come from a child text node
            val text_ops = render_text(node.attrs, "")
            for op in text_ops:
                ops.push(op)
        "path":
            val d = get_attr(node.attrs, "d")
            val path_ops = render_path(d)
            for op in path_ops:
                ops.push(op)
        "g":
            # Group element — render children
            pass_dn
        "svg":
            # Root SVG element — render children
            pass_dn
        _:
            pass_dn  # Unknown tag, skip

    # Recurse into children
    for child in node.children:
        val child_ops = render_node(child)
        for op in child_ops:
            ops.push(op)

    ops

# Render an SVG <rect> element.
fn render_rect(attrs: [Pair<text, text>]) -> [PaintOp]:
    var ops = [PaintOp]()
    val x = parse_svg_length(get_attr(attrs, "x"))
    val y = parse_svg_length(get_attr(attrs, "y"))
    val w = parse_svg_length(get_attr(attrs, "width"))
    val h = parse_svg_length(get_attr(attrs, "height"))
    val fill = parse_svg_color(get_attr(attrs, "fill"))

    if w > 0.0 and h > 0.0:
        ops.push(PaintOp.FillRect(x: x, y: y, w: w, h: h, color: fill))

    # Stroke if present
    val stroke_color_str = get_attr(attrs, "stroke")
    if stroke_color_str != "":
        val stroke_color = parse_svg_color(stroke_color_str)
        val stroke_w = parse_svg_length(get_attr(attrs, "stroke-width"))
        val sw = if stroke_w <= 0.0: 1.0 else: stroke_w
        # Top
        ops.push(PaintOp.FillRect(x: x, y: y, w: w, h: sw, color: stroke_color))
        # Bottom
        ops.push(PaintOp.FillRect(x: x, y: y + h - sw, w: w, h: sw, color: stroke_color))
        # Left
        ops.push(PaintOp.FillRect(x: x, y: y, w: sw, h: h, color: stroke_color))
        # Right
        ops.push(PaintOp.FillRect(x: x + w - sw, y: y, w: sw, h: h, color: stroke_color))

    ops

# Render an SVG <circle> element as an axis-aligned bounding box fill.
# True circle rasterization would require arc PaintOps.
fn render_circle(attrs: [Pair<text, text>]) -> [PaintOp]:
    var ops = [PaintOp]()
    val cx = parse_svg_length(get_attr(attrs, "cx"))
    val cy = parse_svg_length(get_attr(attrs, "cy"))
    val r = parse_svg_length(get_attr(attrs, "r"))
    val fill = parse_svg_color(get_attr(attrs, "fill"))

    if r > 0.0:
        # Approximate circle as bounding box
        ops.push(PaintOp.FillRect(x: cx - r, y: cy - r, w: r * 2.0, h: r * 2.0, color: fill))

    ops

# Render an SVG <line> element as a thin filled rectangle.
fn render_line(attrs: [Pair<text, text>]) -> [PaintOp]:
    var ops = [PaintOp]()
    val x1 = parse_svg_length(get_attr(attrs, "x1"))
    val y1 = parse_svg_length(get_attr(attrs, "y1"))
    val x2 = parse_svg_length(get_attr(attrs, "x2"))
    val y2 = parse_svg_length(get_attr(attrs, "y2"))
    val stroke = parse_svg_color(get_attr(attrs, "stroke"))
    val stroke_w = parse_svg_length(get_attr(attrs, "stroke-width"))
    val sw = if stroke_w <= 0.0: 1.0 else: stroke_w

    # Simplified — horizontal or vertical lines only as filled rects
    if y1 == y2:
        # Horizontal line
        val min_x = if x1 < x2: x1 else: x2
        val line_w = if x2 > x1: x2 - x1 else: x1 - x2
        ops.push(PaintOp.FillRect(x: min_x, y: y1 - sw / 2.0, w: line_w, h: sw, color: stroke))
    else if x1 == x2:
        # Vertical line
        val min_y = if y1 < y2: y1 else: y2
        val line_h = if y2 > y1: y2 - y1 else: y1 - y2
        ops.push(PaintOp.FillRect(x: x1 - sw / 2.0, y: min_y, w: sw, h: line_h, color: stroke))
    else:
        # Diagonal — approximate as horizontal rect from (x1,y1) to (x2,y2)
        val min_x = if x1 < x2: x1 else: x2
        val min_y = if y1 < y2: y1 else: y2
        val line_w = if x2 > x1: x2 - x1 else: x1 - x2
        val line_h = if y2 > y1: y2 - y1 else: y1 - y2
        ops.push(PaintOp.FillRect(x: min_x, y: min_y, w: line_w, h: line_h, color: stroke))

    ops

# Render SVG <text> element.
fn render_text(attrs: [Pair<text, text>], content: text) -> [PaintOp]:
    var ops = [PaintOp]()
    val x = parse_svg_length(get_attr(attrs, "x"))
    val y = parse_svg_length(get_attr(attrs, "y"))
    val fill = parse_svg_color(get_attr(attrs, "fill"))
    val font_size = parse_svg_length(get_attr(attrs, "font-size"))
    val fs = if font_size <= 0.0: 16.0 else: font_size

    if content.len() > 0:
        ops.push(PaintOp.DrawText(x: x, y: y, text_content: content, font_size: fs, color: fill))

    ops

# ---------------------------------------------------------------------------
# SVG Path command representation
# ---------------------------------------------------------------------------

enum PathCommand:
    MoveTo(x: f64, y: f64)
    LineTo(x: f64, y: f64)
    CubicTo(x1: f64, y1: f64, x2: f64, y2: f64, x: f64, y: f64)
    QuadTo(x1: f64, y1: f64, x: f64, y: f64)
    ClosePath

# A 2D point for path tessellation.
class PathPoint:
    x: f64
    y: f64

    static fn create(x: f64, y: f64) -> PathPoint:
        PathPoint(x: x, y: y)

# Render SVG <path> element with full path parsing and tessellation.
fn render_path(d: text) -> [PaintOp]:
    if d == "":
        return [PaintOp]()

    # Parse the d attribute into path commands
    val commands = parse_path_commands(d)

    # Tessellate curves into line segments
    val points = tessellate_path(commands)

    # Convert path outline to filled rectangles via scanline fill
    val fill_color = black()  # Default fill; caller can override via style
    val ops = scanline_fill(points, fill_color)
    ops

# ---------------------------------------------------------------------------
# SVG path d-attribute parser
# ---------------------------------------------------------------------------

# Parse an SVG path d-attribute string into a list of PathCommands.
fn parse_path_commands(d: text) -> [PathCommand]:
    var commands = [PathCommand]()
    var pos = 0
    val len = d.len()
    var cur_x = 0.0
    var cur_y = 0.0
    var start_x = 0.0
    var start_y = 0.0

    while pos < len:
        # Skip whitespace and commas
        pos = _skip_ws(d, pos)
        if pos >= len:
            return commands

        val ch = d.slice(pos, pos + 1)

        if ch == "M" or ch == "m":
            val is_rel = ch == "m"
            pos = pos + 1
            val xy = _parse_two_numbers(d, pos)
            pos = xy.second.second  # updated pos stored in second.second
            var x = xy.first.first
            var y = xy.first.second
            if is_rel:
                x = cur_x + x
                y = cur_y + y
            commands.push(PathCommand.MoveTo(x: x, y: y))
            cur_x = x
            cur_y = y
            start_x = x
            start_y = y
        else if ch == "L" or ch == "l":
            val is_rel = ch == "l"
            pos = pos + 1
            val xy = _parse_two_numbers(d, pos)
            pos = xy.second.second
            var x = xy.first.first
            var y = xy.first.second
            if is_rel:
                x = cur_x + x
                y = cur_y + y
            commands.push(PathCommand.LineTo(x: x, y: y))
            cur_x = x
            cur_y = y
        else if ch == "H" or ch == "h":
            val is_rel = ch == "h"
            pos = pos + 1
            val nr = _parse_number(d, pos)
            pos = nr.second
            var x = nr.first
            if is_rel:
                x = cur_x + x
            commands.push(PathCommand.LineTo(x: x, y: cur_y))
            cur_x = x
        else if ch == "V" or ch == "v":
            val is_rel = ch == "v"
            pos = pos + 1
            val nr = _parse_number(d, pos)
            pos = nr.second
            var y = nr.first
            if is_rel:
                y = cur_y + y
            commands.push(PathCommand.LineTo(x: cur_x, y: y))
            cur_y = y
        else if ch == "C" or ch == "c":
            val is_rel = ch == "c"
            pos = pos + 1
            val n1 = _parse_two_numbers(d, pos)
            pos = n1.second.second
            val n2 = _parse_two_numbers(d, pos)
            pos = n2.second.second
            val n3 = _parse_two_numbers(d, pos)
            pos = n3.second.second
            var x1 = n1.first.first
            var y1 = n1.first.second
            var x2 = n2.first.first
            var y2 = n2.first.second
            var x = n3.first.first
            var y = n3.first.second
            if is_rel:
                x1 = cur_x + x1
                y1 = cur_y + y1
                x2 = cur_x + x2
                y2 = cur_y + y2
                x = cur_x + x
                y = cur_y + y
            commands.push(PathCommand.CubicTo(x1: x1, y1: y1, x2: x2, y2: y2, x: x, y: y))
            cur_x = x
            cur_y = y
        else if ch == "Q" or ch == "q":
            val is_rel = ch == "q"
            pos = pos + 1
            val n1 = _parse_two_numbers(d, pos)
            pos = n1.second.second
            val n2 = _parse_two_numbers(d, pos)
            pos = n2.second.second
            var x1 = n1.first.first
            var y1 = n1.first.second
            var x = n2.first.first
            var y = n2.first.second
            if is_rel:
                x1 = cur_x + x1
                y1 = cur_y + y1
                x = cur_x + x
                y = cur_y + y
            commands.push(PathCommand.QuadTo(x1: x1, y1: y1, x: x, y: y))
            cur_x = x
            cur_y = y
        else if ch == "Z" or ch == "z":
            pos = pos + 1
            commands.push(PathCommand.ClosePath)
            cur_x = start_x
            cur_y = start_y
        else:
            # Skip unknown character
            pos = pos + 1

    commands

# ---------------------------------------------------------------------------
# Path tessellation — De Casteljau subdivision for Bezier curves
# ---------------------------------------------------------------------------

# Tessellate path commands into a list of line segment points.
fn tessellate_path(commands: [PathCommand]) -> [PathPoint]:
    var points = [PathPoint]()
    var cur_x = 0.0
    var cur_y = 0.0
    var start_x = 0.0
    var start_y = 0.0

    for cmd in commands:
        match cmd:
            PathCommand.MoveTo(x, y):
                points.push(PathPoint.create(x, y))
                cur_x = x
                cur_y = y
                start_x = x
                start_y = y
            PathCommand.LineTo(x, y):
                points.push(PathPoint.create(x, y))
                cur_x = x
                cur_y = y
            PathCommand.CubicTo(x1, y1, x2, y2, x, y):
                # Subdivide cubic Bezier using De Casteljau
                val subdivided = _subdivide_cubic(cur_x, cur_y, x1, y1, x2, y2, x, y, 8)
                for pt in subdivided:
                    points.push(pt)
                cur_x = x
                cur_y = y
            PathCommand.QuadTo(x1, y1, x, y):
                # Subdivide quadratic Bezier using De Casteljau
                val subdivided = _subdivide_quad(cur_x, cur_y, x1, y1, x, y, 8)
                for pt in subdivided:
                    points.push(pt)
                cur_x = x
                cur_y = y
            PathCommand.ClosePath:
                points.push(PathPoint.create(start_x, start_y))
                cur_x = start_x
                cur_y = start_y

    points

# Subdivide a cubic Bezier curve into line segments using De Casteljau.
fn _subdivide_cubic(x0: f64, y0: f64, x1: f64, y1: f64, x2: f64, y2: f64, x3: f64, y3: f64, steps: i64) -> [PathPoint]:
    var result = [PathPoint]()
    var i = 1
    while i <= steps:
        val t = i.to_f64() / steps.to_f64()
        val mt = 1.0 - t

        # De Casteljau: B(t) = (1-t)^3*P0 + 3*(1-t)^2*t*P1 + 3*(1-t)*t^2*P2 + t^3*P3
        val mt2 = mt * mt
        val mt3 = mt2 * mt
        val t2 = t * t
        val t3 = t2 * t

        val px = mt3 * x0 + 3.0 * mt2 * t * x1 + 3.0 * mt * t2 * x2 + t3 * x3
        val py = mt3 * y0 + 3.0 * mt2 * t * y1 + 3.0 * mt * t2 * y2 + t3 * y3
        result.push(PathPoint.create(px, py))
        i = i + 1
    result

# Subdivide a quadratic Bezier curve into line segments using De Casteljau.
fn _subdivide_quad(x0: f64, y0: f64, x1: f64, y1: f64, x2: f64, y2: f64, steps: i64) -> [PathPoint]:
    var result = [PathPoint]()
    var i = 1
    while i <= steps:
        val t = i.to_f64() / steps.to_f64()
        val mt = 1.0 - t

        # De Casteljau: B(t) = (1-t)^2*P0 + 2*(1-t)*t*P1 + t^2*P2
        val mt2 = mt * mt
        val t2 = t * t

        val px = mt2 * x0 + 2.0 * mt * t * x1 + t2 * x2
        val py = mt2 * y0 + 2.0 * mt * t * y1 + t2 * y2
        result.push(PathPoint.create(px, py))
        i = i + 1
    result

# ---------------------------------------------------------------------------
# Scanline fill — convert closed path outline to filled FillRect strips
# ---------------------------------------------------------------------------

# Fill a polygon defined by points using scanline rasterization.
fn scanline_fill(points: [PathPoint], fill_color: Color) -> [PaintOp]:
    var ops = [PaintOp]()

    if points.len() < 3:
        return ops

    # Find bounding box
    var min_x = points.get(0).x
    var max_x = min_x
    var min_y = points.get(0).y
    var max_y = min_y

    for pt in points:
        if pt.x < min_x: min_x = pt.x
        if pt.x > max_x: max_x = pt.x
        if pt.y < min_y: min_y = pt.y
        if pt.y > max_y: max_y = pt.y

    # Scanline from min_y to max_y in 1-pixel steps
    val num_edges = points.len()
    var scan_y = min_y
    while scan_y <= max_y:
        # Find all x-intersections of the scanline with polygon edges
        var intersections = [f64]()

        var edge_i = 0
        while edge_i < num_edges:
            val next_i = (edge_i + 1) % num_edges
            val p0 = points.get(edge_i)
            val p1 = points.get(next_i)

            val y0 = p0.y
            val y1 = p1.y

            # Check if scanline crosses this edge
            val crosses_down = y0 <= scan_y and y1 > scan_y
            val crosses_up = y1 <= scan_y and y0 > scan_y
            if crosses_down or crosses_up:
                val dy = y1 - y0
                if dy != 0.0:
                    val t = (scan_y - y0) / dy
                    val ix = p0.x + t * (p1.x - p0.x)
                    intersections.push(ix)

            edge_i = edge_i + 1

        # Sort intersections (simple insertion sort)
        var si = 1
        while si < intersections.len():
            var sj = si
            while sj > 0:
                val va = intersections.get(sj - 1)
                val vb = intersections.get(sj)
                if va > vb:
                    intersections.set(sj - 1, vb)
                    intersections.set(sj, va)
                sj = sj - 1
            si = si + 1

        # Fill between pairs of intersections (even-odd rule)
        var pair = 0
        while pair + 1 < intersections.len():
            val x_start = intersections.get(pair)
            val x_end = intersections.get(pair + 1)
            if x_end > x_start:
                ops.push(PaintOp.FillRect(x: x_start, y: scan_y, w: x_end - x_start, h: 1.0, color: fill_color))
            pair = pair + 2

        scan_y = scan_y + 1.0

    ops

# ---------------------------------------------------------------------------
# Path parsing helpers
# ---------------------------------------------------------------------------

# Skip whitespace and commas in the path string.
fn _skip_ws(s: text, pos: i64) -> i64:
    var p = pos
    val len = s.len()
    while p < len:
        val ch = s.slice(p, p + 1)
        if ch == " " or ch == "," or ch == "\n" or ch == "\t" or ch == "\r":
            p = p + 1
        else:
            return p
    p

# Parse a floating-point number from the path string.
# Returns (value, new_pos).
fn _parse_number(s: text, pos: i64) -> Pair<f64, i64>:
    var p = _skip_ws(s, pos)
    val len = s.len()
    val start = p

    # Optional sign
    if p < len:
        val ch = s.slice(p, p + 1)
        if ch == "-" or ch == "+":
            p = p + 1

    # Digits before decimal point
    while p < len:
        val ch = s.slice(p, p + 1)
        if _is_digit(ch):
            p = p + 1
        else:
            if ch == ".":
                p = p + 1
                # Digits after decimal point
                while p < len:
                    val d = s.slice(p, p + 1)
                    if _is_digit(d):
                        p = p + 1
                    else:
                        return _make_num_result(s, start, p)
                return _make_num_result(s, start, p)
            else:
                return _make_num_result(s, start, p)

    _make_num_result(s, start, p)

fn _make_num_result(s: text, start: i64, end: i64) -> Pair<f64, i64>:
    if end <= start:
        return Pair(first: 0.0, second: end)
    val num_str = s.slice(start, end)
    val parsed = num_str.to_f64()
    if val v = parsed:
        return Pair(first: v, second: end)
    Pair(first: 0.0, second: end)

# Parse two numbers separated by whitespace/comma.
# Returns ((x, y), (_, new_pos)) — second.second holds the updated position.
fn _parse_two_numbers(s: text, pos: i64) -> Pair<Pair<f64, f64>, Pair<i64, i64>>:
    val n1 = _parse_number(s, pos)
    val n2 = _parse_number(s, n1.second)
    Pair(
        first: Pair(first: n1.first, second: n2.first),
        second: Pair(first: 0, second: n2.second)
    )

fn _is_digit(ch: text) -> bool:
    if ch == "0": return true
    if ch == "1": return true
    if ch == "2": return true
    if ch == "3": return true
    if ch == "4": return true
    if ch == "5": return true
    if ch == "6": return true
    if ch == "7": return true
    if ch == "8": return true
    if ch == "9": return true
    false

# ---------------------------------------------------------------------------
# SVG attribute/value parsing helpers
# ---------------------------------------------------------------------------

# Get an attribute value by name, returning empty string if not found.
fn get_attr(attrs: [Pair<text, text>], name: text) -> text:
    for attr in attrs:
        if attr.first == name:
            return attr.second
    ""

# Parse an SVG color string into a Color.
# Supports: named colors, #RGB, #RGBA, #RRGGBB, #RRGGBBAA, rgb(r,g,b), and "none".
fn parse_svg_color(value: text) -> Color:
    if value == "" or value == "none":
        return transparent()

    # Hex color (#RGB, #RGBA, #RRGGBB, #RRGGBBAA)
    if value.starts_with("#"):
        return from_hex(value)

    # Named colors via stdlib
    val named = from_name(value)
    if named.a > 0 or value.to_lower() == "black":
        return named

    # Default fallback
    black()

# Parse an SVG length value (e.g., "100", "50.5", "10px") to f64.
fn parse_svg_length(value: text) -> f64:
    if value == "":
        return 0.0

    # Strip known unit suffixes
    var num_str = value
    if value.ends_with("px"):
        num_str = value.slice(0, value.len() - 2)
    else if value.ends_with("pt"):
        num_str = value.slice(0, value.len() - 2)
    else if value.ends_with("em"):
        num_str = value.slice(0, value.len() - 2)

    # Parse the numeric part
    val parsed = num_str.to_f64()
    if val v = parsed:
        return v
    0.0
