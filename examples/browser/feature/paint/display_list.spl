# Display list builder — converts layout tree to paint operations.
# Walks the layout tree depth-first, generating PaintOps for each box
# in correct CSS painting order: background, borders, content.
#
# DisplayListGpuEmitter translates PaintOp lists into stdlib RenderCommand
# buffers for GPU-accelerated rendering.

use examples.browser.entity.dom.paint_types.{Color, Gradient, GradientStop, PaintOp, DisplayList, DisplayItem, from_rgb, black, white, transparent}
use examples.browser.entity.dom.css_types.{CSSValue, CSSDeclaration}
use examples.browser.entity.dom.box_types.{LayoutBox, BoxModel, BoxKind}
use examples.browser.feature.style.computed.{ComputedStyle, extract_px}
use examples.browser.feature.style.transform.{parse_transform, transforms_to_matrix}
use examples.browser.feature.paint.shadow.{parse_box_shadow, generate_all_shadow_commands}
use examples.browser.shared.logging.{Logger, LogLevel}
use std.nogc_sync_mut.engine.render.command.{RenderCommand, RenderCommandBuffer}
use std.common.engine.color.{EngineColor}
use std.common.engine.rect.{Rect2}
use std.common.engine.ids.{TextureId, RawHandle}
use std.common.engine.units.{ZIndex}

# ---------------------------------------------------------------------------
# DisplayListBuilder — accumulates PaintOps for an entire layout tree.
# ---------------------------------------------------------------------------

class DisplayListBuilder:
    ops: [PaintOp]
    logger: Logger

    static fn new(logger: Logger) -> DisplayListBuilder:
        DisplayListBuilder(ops: [PaintOp](), logger: logger)

    # Walk the entire layout tree and produce a flat DisplayList of paint ops.
    me build(layout_root: LayoutBox, styles: [ComputedStyle]) -> DisplayList:
        self.ops = [PaintOp]()
        self.logger.debug("building display list from layout tree")
        self.walk_tree(layout_root, styles)
        self.logger.info("display list built: {self.ops.len()} ops")
        DisplayList(ops: self.ops)

    # Recursive tree walk — depth-first, paint parent then children.
    me walk_tree(box_node: LayoutBox, styles: [ComputedStyle]):
        # Look up style for this node
        val style = self.find_style(box_node.node_id, styles)
        if val s = style:
            if should_paint(s):
                self.paint_box(box_node, s)

        # Recurse into children
        for child in box_node.children:
            self.walk_tree(child, styles)

    # Paint a single box following CSS 2.1 painting order:
    # 1. Push clip if overflow hidden
    # 2. Paint background
    # 3. Paint borders
    # 4. Paint box-shadow
    # 5. Paint content (text or replaced element)
    # 6. Pop clip
    me paint_box(box_node: LayoutBox, style: ComputedStyle):
        self.logger.trace("painting box node_id={box_node.node_id}")

        val clip_needed = (style.overflow_x == "hidden" or style.overflow_y == "hidden"
            or style.overflow_x == "scroll" or style.overflow_y == "scroll"
            or style.overflow_x == "auto" or style.overflow_y == "auto")

        # 0. Push CSS transform if present
        val has_transform = style.transform != "none" and style.transform != ""
        if has_transform:
            val fns = parse_transform(style.transform)
            if fns.len() > 0:
                val matrix = transforms_to_matrix(fns)
                self.ops.push(PaintOp.PushTransform(matrix: matrix.data))

        # 1. Push clip if overflow hidden/scroll/auto
        if clip_needed:
            val clip_op = PaintOp.PushClip(
                x: box_node.x,
                y: box_node.y,
                w: box_node.width,
                h: box_node.height
            )
            self.ops.push(clip_op)

        # Push opacity layer if not fully opaque
        val needs_opacity = style.opacity < 1.0
        if needs_opacity:
            self.ops.push(PaintOp.PushOpacity(alpha: style.opacity))

        # 2. Paint box-shadow (before background, per CSS spec)
        self.paint_box_shadow_for(box_node, style)

        # 3. Paint background
        self.paint_background_for(box_node, style)

        # 4. Paint borders
        self.paint_borders_for(box_node, style)

        # 5. Paint content (text)
        self.paint_text_for(box_node, style)

        # Pop opacity layer
        if needs_opacity:
            self.ops.push(PaintOp.PopOpacity)

        # 6. Pop clip
        if clip_needed:
            self.ops.push(PaintOp.PopClip)

        # Pop transform
        if has_transform:
            self.ops.push(PaintOp.PopTransform)

    # Paint the background-color for a box. Background-image is handled separately.
    me paint_background_for(box_node: LayoutBox, style: ComputedStyle):
        val bg_color = get_background_color(style)
        # Only paint if not fully transparent
        if bg_color.a > 0:
            val op = PaintOp.FillRect(
                x: box_node.x,
                y: box_node.y,
                w: box_node.width,
                h: box_node.height,
                color: bg_color
            )
            self.ops.push(op)
            self.logger.trace("background fill at ({box_node.x}, {box_node.y})")

    # Paint all four borders. Uses DrawBorder with width/color arrays [top, right, bottom, left].
    me paint_borders_for(box_node: LayoutBox, style: ComputedStyle):
        val bm = box_node.box_model
        val has_borders = (bm.border_top > 0.0 or bm.border_right > 0.0
            or bm.border_bottom > 0.0 or bm.border_left > 0.0)
        if not has_borders:
            return

        # Check each side's style independently
        val top_visible = style.border_top_style != "none" and bm.border_top > 0.0
        val right_visible = style.border_right_style != "none" and bm.border_right > 0.0
        val bottom_visible = style.border_bottom_style != "none" and bm.border_bottom > 0.0
        val left_visible = style.border_left_style != "none" and bm.border_left > 0.0

        if not top_visible and not right_visible and not bottom_visible and not left_visible:
            return

        val top_color = css_color_to_color(style.border_top_color)
        val right_color = css_color_to_color(style.border_right_color)
        val bottom_color = css_color_to_color(style.border_bottom_color)
        val left_color = css_color_to_color(style.border_left_color)

        val widths = [
            if top_visible: bm.border_top else: 0.0,
            if right_visible: bm.border_right else: 0.0,
            if bottom_visible: bm.border_bottom else: 0.0,
            if left_visible: bm.border_left else: 0.0
        ]
        val colors = [top_color, right_color, bottom_color, left_color]

        val op = PaintOp.DrawBorder(
            x: box_node.x,
            y: box_node.y,
            w: box_node.width,
            h: box_node.height,
            widths: widths,
            colors: colors
        )
        self.ops.push(op)
        self.logger.trace("borders at ({box_node.x}, {box_node.y})")

    # Paint text content for a box. Generates DrawText ops with font size and color.
    me paint_text_for(box_node: LayoutBox, style: ComputedStyle):
        # Only inline and inline-block boxes render text directly
        match box_node.kind:
            BoxKind.Inline: pass_dn
            BoxKind.InlineBlock: pass_dn
            _: return

        val font_size = extract_px(style.font_size)
        val text_color = get_text_color(style)

        # Calculate text baseline position (top of box + font ascent approximation)
        val text_x = box_node.x + box_node.box_model.padding_left
        val text_y = box_node.y + box_node.box_model.padding_top + font_size * 0.8

        val op = PaintOp.DrawText(
            x: text_x,
            y: text_y,
            text_content: "",  # Actual text content resolved by text layout
            font_size: font_size,
            color: text_color
        )
        self.ops.push(op)
        self.logger.trace("text at ({text_x}, {text_y}) size={font_size}")

    # Paint box-shadow using the shadow module.
    # Parses the box-shadow CSS value and generates paint commands.
    me paint_box_shadow_for(box_node: LayoutBox, style: ComputedStyle):
        if style.box_shadow == "none" or style.box_shadow == "":
            return

        val shadows = parse_box_shadow(style.box_shadow)
        if shadows.len() == 0:
            return

        val shadow_ops = generate_all_shadow_commands(
            shadows,
            box_node.x, box_node.y,
            box_node.width, box_node.height
        )
        for op in shadow_ops:
            self.ops.push(op)

        self.logger.trace("box-shadow at ({box_node.x}, {box_node.y}) {shadows.len()} shadows")

    # Find the ComputedStyle for a given node_id from the style list.
    fn find_style(node_id: i64, styles: [ComputedStyle]) -> ComputedStyle?:
        if node_id >= 0 and node_id < styles.len():
            return styles.get(node_id)
        nil

# ---------------------------------------------------------------------------
# Utility functions
# ---------------------------------------------------------------------------

# Determine whether a box should be painted based on its computed style.
fn should_paint(style: ComputedStyle) -> bool:
    # display: none — do not paint at all
    if style.display == "none":
        return false
    # visibility: hidden — reserve space but do not paint content
    if style.visibility == "hidden":
        return false
    true

# Extract background-color from ComputedStyle as a Color.
fn get_background_color(style: ComputedStyle) -> Color:
    css_color_to_color(style.background_color)

# Extract foreground (text) color from ComputedStyle as a Color.
fn get_text_color(style: ComputedStyle) -> Color:
    css_color_to_color(style.color)

# Convert a CSSValue that is expected to be a Color variant into a Color.
# Falls back to transparent for non-color values.
fn css_color_to_color(value: CSSValue) -> Color:
    match value:
        CSSValue.Color(color):
            color
        CSSValue.Keyword(v):
            match v:
                "transparent": transparent()
                "black": black()
                "white": white()
                "red": from_rgb(255, 0, 0)
                "green": from_rgb(0, 128, 0)
                "blue": from_rgb(0, 0, 255)
                "yellow": from_rgb(255, 255, 0)
                "orange": from_rgb(255, 165, 0)
                "purple": from_rgb(128, 0, 128)
                "gray": from_rgb(128, 128, 128)
                "grey": from_rgb(128, 128, 128)
                _: transparent()
        _:
            transparent()

# ---------------------------------------------------------------------------
# DisplayListGpuEmitter — translates PaintOps to stdlib RenderCommands
# ---------------------------------------------------------------------------

class DisplayListGpuEmitter:
    buffer: RenderCommandBuffer
    scissor_stack: [Rect2]
    alpha_stack: [f64]
    current_alpha: f64
    z_counter: i64

    static fn create() -> DisplayListGpuEmitter:
        DisplayListGpuEmitter(
            buffer: RenderCommandBuffer.create(),
            scissor_stack: [Rect2](),
            alpha_stack: [f64](),
            current_alpha: 1.0,
            z_counter: 0
        )

    # Emit all PaintOps from a DisplayList into the RenderCommandBuffer.
    me emit(display_list: DisplayList) -> RenderCommandBuffer:
        self.buffer.clear()
        self.z_counter = 0
        self.current_alpha = 1.0
        self.scissor_stack = [Rect2]()
        self.alpha_stack = [f64]()

        for op in display_list.ops:
            self.emit_op(op)

        self.buffer

    # Emit a single PaintOp as one or more RenderCommands.
    me emit_op(op: PaintOp):
        match op:
            PaintOp.FillRect(x, y, w, h, color):
                val ec = _to_engine_color(color, self.current_alpha)
                val rect = Rect2(x: x, y: y, width: w, height: h)
                val z = ZIndex(value: self.z_counter)
                self.z_counter = self.z_counter + 1
                self.buffer.push(RenderCommand.DrawRect(rect: rect, color: ec, z_order: z))

            PaintOp.DrawText(x, y, text_content, font_size, color):
                # Glyph atlas not available — emit a placeholder rect
                val ec = _to_engine_color(color, self.current_alpha)
                val approx_width = text_content.len().to_f64() * font_size * 0.6
                val rect = Rect2(x: x, y: y - font_size, width: approx_width, height: font_size)
                val z = ZIndex(value: self.z_counter)
                self.z_counter = self.z_counter + 1
                self.buffer.push(RenderCommand.DrawRect(rect: rect, color: ec, z_order: z))

            PaintOp.DrawBorder(x, y, w, h, widths, colors):
                # Emit 4 DrawRect commands, one per border edge
                val z = ZIndex(value: self.z_counter)
                self.z_counter = self.z_counter + 1

                # Top border
                val top_w = _safe_get_f64(widths, 0)
                val top_c = _safe_get_color(colors, 0, self.current_alpha)
                val top_rect = Rect2(x: x, y: y, width: w, height: top_w)
                self.buffer.push(RenderCommand.DrawRect(rect: top_rect, color: top_c, z_order: z))

                # Right border
                val right_w = _safe_get_f64(widths, 1)
                val right_c = _safe_get_color(colors, 1, self.current_alpha)
                val right_rect = Rect2(x: x + w - right_w, y: y, width: right_w, height: h)
                self.buffer.push(RenderCommand.DrawRect(rect: right_rect, color: right_c, z_order: z))

                # Bottom border
                val bottom_w = _safe_get_f64(widths, 2)
                val bottom_c = _safe_get_color(colors, 2, self.current_alpha)
                val bottom_rect = Rect2(x: x, y: y + h - bottom_w, width: w, height: bottom_w)
                self.buffer.push(RenderCommand.DrawRect(rect: bottom_rect, color: bottom_c, z_order: z))

                # Left border
                val left_w = _safe_get_f64(widths, 3)
                val left_c = _safe_get_color(colors, 3, self.current_alpha)
                val left_rect = Rect2(x: x, y: y, width: left_w, height: h)
                self.buffer.push(RenderCommand.DrawRect(rect: left_rect, color: left_c, z_order: z))

            PaintOp.DrawImage(x, y, w, h, image_id):
                # Map to DrawSprite with a TextureId derived from image_id
                val tex_id = TextureId(raw: RawHandle.new(image_id, 1))
                val src_rect = Rect2(x: 0.0, y: 0.0, width: w, height: h)
                val dst_rect = Rect2(x: x, y: y, width: w, height: h)
                val tint = EngineColor.rgba(1.0, 1.0, 1.0, self.current_alpha)
                val z = ZIndex(value: self.z_counter)
                self.z_counter = self.z_counter + 1
                self.buffer.push(RenderCommand.DrawSprite(
                    texture_id: tex_id,
                    src_rect: src_rect,
                    dst_rect: dst_rect,
                    tint: tint,
                    z_order: z
                ))

            PaintOp.PushClip(x, y, w, h):
                val clip_rect = Rect2(x: x, y: y, width: w, height: h)
                self.scissor_stack.push(clip_rect)

            PaintOp.PopClip:
                if self.scissor_stack.len() > 0:
                    self.scissor_stack.pop()

            PaintOp.DrawGradient(x, y, w, h, gradient):
                # Approximate gradient as a series of filled rects
                val steps = 16
                val step_w = w / steps.to_f64()
                var step_i = 0
                while step_i < steps:
                    val t = step_i.to_f64() / steps.to_f64()
                    # Linear interpolation between first and last stop
                    val stops = gradient.stops
                    var color = from_rgb(0, 0, 0)
                    if stops.len() >= 2:
                        val c1 = stops[0].color
                        val c2 = stops[stops.len() - 1].color
                        val r = c1.r + ((c2.r - c1.r).to_f64() * t).to_i64()
                        val g = c1.g + ((c2.g - c1.g).to_f64() * t).to_i64()
                        val b = c1.b + ((c2.b - c1.b).to_f64() * t).to_i64()
                        color = from_rgb(r, g, b)
                    else if stops.len() == 1:
                        color = stops[0].color
                    val ec = _to_engine_color(color, self.current_alpha)
                    val rect = Rect2(x: x + step_i.to_f64() * step_w, y: y, width: step_w, height: h)
                    val z = ZIndex(value: self.z_counter)
                    self.buffer.push(RenderCommand.DrawRect(rect: rect, color: ec, z_order: z))
                    step_i = step_i + 1
                self.z_counter = self.z_counter + 1

            PaintOp.PushOpacity(alpha):
                self.alpha_stack.push(self.current_alpha)
                self.current_alpha = self.current_alpha * alpha

            PaintOp.PopOpacity:
                if self.alpha_stack.len() > 0:
                    val prev = self.alpha_stack.pop()
                    if val p = prev:
                        self.current_alpha = p
                    else:
                        self.current_alpha = 1.0
                else:
                    self.current_alpha = 1.0

            PaintOp.PushTransform(matrix):
                # Transform support: store matrix for future use
                # GPU backend would set a transform uniform here
                pass_dn

            PaintOp.PopTransform:
                pass_dn

            PaintOp.PushFilter(filter_type, amount):
                # Filter support: would set up a render target for post-processing
                pass_dn

            PaintOp.PopFilter:
                pass_dn

# Convert a browser Color (0-255 integer RGBA) to an EngineColor (0.0-1.0 float RGBA).
fn _to_engine_color(color: Color, alpha_mul: f64) -> EngineColor:
    val r = color.r.to_f64() / 255.0
    val g = color.g.to_f64() / 255.0
    val b = color.b.to_f64() / 255.0
    val a = (color.a.to_f64() / 255.0) * alpha_mul
    EngineColor.rgba(r, g, b, a)

# Safely get an f64 from a [f64] at an index.
fn _safe_get_f64(list: [f64], idx: i64) -> f64:
    if idx >= 0 and idx < list.len():
        val v = list.get(idx)
        if val f = v:
            return f
    0.0

# Safely get a Color from a [Color] at an index and convert to EngineColor.
fn _safe_get_color(list: [Color], idx: i64, alpha_mul: f64) -> EngineColor:
    if idx >= 0 and idx < list.len():
        val v = list.get(idx)
        if val c = v:
            return _to_engine_color(c, alpha_mul)
    EngineColor.transparent()
