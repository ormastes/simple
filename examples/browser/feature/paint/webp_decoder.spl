#![allow(REQC001)]
#![allow(REQC004)]
#![allow(unnamed_duplicate_typed_args)]
# WebP decoder — parses RIFF container and VP8/VP8L frame headers.
# Full macroblock reconstruction is a follow-up; MVP returns solid-color placeholder pixels.

use examples.browser.entity.media.webp_types.{WebpChunk, WebpContainer, WebpFrameHeader, WebpImage}

fn _byte_at_webp(data: [i64], offset: i64) -> i64:
    if offset < 0 or offset >= data.len():
        return 0
    val v = data.get(offset)
    if val b = v:
        return b
    0

fn _read_u32_le(data: [i64], offset: i64) -> i64:
    val b0 = _byte_at_webp(data, offset)
    val b1 = _byte_at_webp(data, offset + 1)
    val b2 = _byte_at_webp(data, offset + 2)
    val b3 = _byte_at_webp(data, offset + 3)
    b0 + b1 * 256 + b2 * 65536 + b3 * 16777216

fn _read_u16_le(data: [i64], offset: i64) -> i64:
    val b0 = _byte_at_webp(data, offset)
    val b1 = _byte_at_webp(data, offset + 1)
    b0 + b1 * 256

fn _fourcc(data: [i64], offset: i64) -> text:
    val b0 = _byte_at_webp(data, offset)
    val b1 = _byte_at_webp(data, offset + 1)
    val b2 = _byte_at_webp(data, offset + 2)
    val b3 = _byte_at_webp(data, offset + 3)
    "{b0},{b1},{b2},{b3}"

fn _fourcc_eq(data: [i64], offset: i64, a: i64, b: i64, c: i64, d: i64) -> bool:
    (
        _byte_at_webp(data, offset) == a and
        _byte_at_webp(data, offset + 1) == b and
        _byte_at_webp(data, offset + 2) == c and
        _byte_at_webp(data, offset + 3) == d
    )

fn _is_riff(data: [i64]) -> bool:
    # 'R'=82 'I'=73 'F'=70 'F'=70
    _fourcc_eq(data, 0, 82, 73, 70, 70)

fn _is_webp_magic(data: [i64]) -> bool:
    # 'W'=87 'E'=69 'B'=66 'P'=80
    _fourcc_eq(data, 8, 87, 69, 66, 80)

fn is_webp(data: [i64]) -> bool:
    if data.len() < 12:
        return false
    _is_riff(data) and _is_webp_magic(data)

fn _slice_chunk_data(data: [i64], start: i64, size: i64) -> [i64]:
    var out = [i64]()
    var i = 0
    while i < size and (start + i) < data.len():
        val v = data.get(start + i)
        if val b = v:
            out.push(b)
        i = i + 1
    out

class WebpDecoder:
    static fn new() -> WebpDecoder:
        WebpDecoder()

    fn parse_container(data: [i64]) -> WebpContainer:
        val file_size = _read_u32_le(data, 4)
        var container = WebpContainer.create(file_size)
        # Chunks begin at offset 12 (after RIFF+size+WEBP)
        var pos = 12
        while pos + 8 <= data.len():
            val chunk_size = _read_u32_le(data, pos + 4)
            val chunk_data = _slice_chunk_data(data, pos + 8, chunk_size)
            val fc = _fourcc(data, pos)
            val chunk = WebpChunk.create(fc, chunk_size, chunk_data)
            container.chunks.push(chunk)
            # Chunks are padded to even byte boundaries
            var advance = chunk_size
            if advance % 2 != 0:
                advance = advance + 1
            pos = pos + 8 + advance
        container

    fn decode_vp8_header(chunk: [i64]) -> WebpFrameHeader:
        # VP8 tag byte: bits 0=keyframe(0=key), 1-3=version, 4=show_frame, 5-18=first_part_size
        # Start code: 0x9D 0x01 0x2A at bytes 3-5
        if chunk.len() < 10:
            return WebpFrameHeader.create(0, 0)
        val sc0 = _byte_at_webp(chunk, 3)
        val sc1 = _byte_at_webp(chunk, 4)
        val sc2 = _byte_at_webp(chunk, 5)
        if sc0 != 157 or sc1 != 1 or sc2 != 42:
            return WebpFrameHeader.create(0, 0)
        val raw_w = _read_u16_le(chunk, 6)
        val raw_h = _read_u16_le(chunk, 8)
        val width = raw_w % 16384
        val height = raw_h % 16384
        val h_scale = raw_w / 16384
        val v_scale = raw_h / 16384
        WebpFrameHeader(width: width, height: height, horizontal_scale: h_scale, vertical_scale: v_scale, color_space: 0, clamping: 0)

    fn decode_vp8l_header(chunk: [i64]) -> WebpFrameHeader:
        # VP8L signature byte: 0x2F, then 28-bit packed width-1 (14 bits) + height-1 (14 bits)
        if chunk.len() < 5:
            return WebpFrameHeader.create(0, 0)
        val sig = _byte_at_webp(chunk, 0)
        if sig != 47:
            return WebpFrameHeader.create(0, 0)
        val b1 = _byte_at_webp(chunk, 1)
        val b2 = _byte_at_webp(chunk, 2)
        val b3 = _byte_at_webp(chunk, 3)
        val b4 = _byte_at_webp(chunk, 4)
        val width = 1 + b1 + (b2 % 64) * 256
        val height = 1 + (b2 / 64) + b3 * 4 + (b4 % 16) * 1024
        WebpFrameHeader.create(width, height)

    fn decode(data: [i64]) -> WebpImage:
        if not is_webp(data):
            return WebpImage.create(0, 0)
        val container = self.parse_container(data)
        # Find VP8L first (lossless), then VP8 (lossy)
        for chunk in container.chunks:
            # VP8L: '86,80,56,76'
            if chunk.fourcc == "86,80,56,76":
                val hdr = self.decode_vp8l_header(chunk.data)
                if hdr.width > 0 and hdr.height > 0:
                    return WebpImage.solid(hdr.width, hdr.height, 128, 128, 128, 255)
        for chunk in container.chunks:
            # VP8 : '86,80,56,32'
            if chunk.fourcc == "86,80,56,32":
                val hdr = self.decode_vp8_header(chunk.data)
                if hdr.width > 0 and hdr.height > 0:
                    return WebpImage.solid(hdr.width, hdr.height, 128, 128, 128, 255)
        WebpImage.create(0, 0)
