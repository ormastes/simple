#![allow(unnamed_duplicate_typed_args)]
# Pure f64 CSS filter pipeline.
# All channel operations use f64 internally.
# Conversion to u32 ARGB happens only at the final pack step.
# Pixel format: ARGB 0xAARRGGBB.
# Spec: https://www.w3.org/TR/filter-effects-1/

use examples.browser.feature.paint.filter.{FilterFunction}
use std.common.color.types.{Color, from_rgb, from_rgba}
use std.common.math.{MATH_PI, math_abs, math_max, math_min}
use std.common.math3d.math_util.{sin3d, cos3d}

# =========================================================================
# Per-pixel color filter application (pure f64)
# =========================================================================

fn apply_color_filter_float(pixel: u32, filters: [FilterFunction]) -> u32:
    """Apply a chain of color filters to an ARGB pixel.

    All channel math in f64. Only the final pack converts to u32.
    Uses exact BT.709 luminance coefficients (0.2126, 0.7152, 0.0722).
    Full f64 hue rotation matrix with sin()/cos().
    """
    var r = _extract_r_ff(pixel).to_f64()
    var g = _extract_g_ff(pixel).to_f64()
    var b = _extract_b_ff(pixel).to_f64()
    var a = _extract_a_ff(pixel).to_f64()

    for filter in filters:
        match filter:
            FilterFunction.Brightness(amount):
                r = r * amount
                g = g * amount
                b = b * amount

            FilterFunction.Contrast(amount):
                r = (r - 128.0) * amount + 128.0
                g = (g - 128.0) * amount + 128.0
                b = (b - 128.0) * amount + 128.0

            FilterFunction.Grayscale(amount):
                val clamped = math_min(1.0, math_max(0.0, amount))
                # Exact BT.709 luminance
                val lum = 0.2126 * r + 0.7152 * g + 0.0722 * b
                r = r + (lum - r) * clamped
                g = g + (lum - g) * clamped
                b = b + (lum - b) * clamped

            FilterFunction.HueRotate(angle):
                val rad = angle * MATH_PI / 180.0
                val c = cos3d(rad)
                val s = sin3d(rad)
                # Full f64 hue rotation matrix (preserving BT.709 luminance)
                val nr = r * (0.213 + 0.787 * c - 0.213 * s) + g * (0.715 - 0.715 * c - 0.715 * s) + b * (0.072 - 0.072 * c + 0.928 * s)
                val ng = r * (0.213 - 0.213 * c + 0.143 * s) + g * (0.715 + 0.285 * c + 0.140 * s) + b * (0.072 - 0.072 * c - 0.283 * s)
                val nb = r * (0.213 - 0.213 * c - 0.787 * s) + g * (0.715 - 0.715 * c + 0.715 * s) + b * (0.072 + 0.928 * c + 0.072 * s)
                r = nr
                g = ng
                b = nb

            FilterFunction.Invert(amount):
                val clamped = math_min(1.0, math_max(0.0, amount))
                r = r + (255.0 - 2.0 * r) * clamped
                g = g + (255.0 - 2.0 * g) * clamped
                b = b + (255.0 - 2.0 * b) * clamped

            FilterFunction.Opacity(amount):
                a = a * math_min(1.0, math_max(0.0, amount))

            FilterFunction.Saturate(amount):
                val lum = 0.2126 * r + 0.7152 * g + 0.0722 * b
                r = lum + (r - lum) * amount
                g = lum + (g - lum) * amount
                b = lum + (b - lum) * amount

            FilterFunction.Sepia(amount):
                val clamped = math_min(1.0, math_max(0.0, amount))
                # Sepia matrix (exact CSS spec coefficients)
                val sr = r * 0.393 + g * 0.769 + b * 0.189
                val sg = r * 0.349 + g * 0.686 + b * 0.168
                val sb = r * 0.272 + g * 0.534 + b * 0.131
                r = r + (sr - r) * clamped
                g = g + (sg - g) * clamped
                b = b + (sb - b) * clamped

            FilterFunction.Blur(_):
                # Spatial filter -- no-op at per-pixel level
                pass_dn

            FilterFunction.DropShadow(_, _, _, _):
                # Spatial filter -- no-op at per-pixel level
                pass_dn

    _pack_argb_ff(_clamp_byte_ff(a), _clamp_byte_ff(r), _clamp_byte_ff(g), _clamp_byte_ff(b))

fn apply_color_filter_float_to_color(color: Color, filters: [FilterFunction]) -> Color:
    """Convenience: apply f64 filters to a Color value."""
    val pixel = _color_to_argb_ff(color)
    val result = apply_color_filter_float(pixel, filters)
    _argb_to_color_ff(result)

# =========================================================================
# Multi-filter composition helpers
# =========================================================================

fn apply_brightness_float(pixel: u32, amount: f64) -> u32:
    """Apply brightness adjustment. amount=1.0 is no change."""
    val r = _extract_r_ff(pixel).to_f64() * amount
    val g = _extract_g_ff(pixel).to_f64() * amount
    val b = _extract_b_ff(pixel).to_f64() * amount
    val a = _extract_a_ff(pixel)
    _pack_argb_ff(a.to_i64(), _clamp_byte_ff(r), _clamp_byte_ff(g), _clamp_byte_ff(b))

fn apply_contrast_float(pixel: u32, amount: f64) -> u32:
    """Apply contrast adjustment. amount=1.0 is no change."""
    val r = (_extract_r_ff(pixel).to_f64() - 128.0) * amount + 128.0
    val g = (_extract_g_ff(pixel).to_f64() - 128.0) * amount + 128.0
    val b = (_extract_b_ff(pixel).to_f64() - 128.0) * amount + 128.0
    val a = _extract_a_ff(pixel)
    _pack_argb_ff(a.to_i64(), _clamp_byte_ff(r), _clamp_byte_ff(g), _clamp_byte_ff(b))

fn apply_grayscale_float(pixel: u32, amount: f64) -> u32:
    """Apply grayscale filter. amount=1.0 is fully gray."""
    val clamped = math_min(1.0, math_max(0.0, amount))
    val r = _extract_r_ff(pixel).to_f64()
    val g = _extract_g_ff(pixel).to_f64()
    val b = _extract_b_ff(pixel).to_f64()
    val a = _extract_a_ff(pixel)
    val lum = 0.2126 * r + 0.7152 * g + 0.0722 * b
    val nr = r + (lum - r) * clamped
    val ng = g + (lum - g) * clamped
    val nb = b + (lum - b) * clamped
    _pack_argb_ff(a.to_i64(), _clamp_byte_ff(nr), _clamp_byte_ff(ng), _clamp_byte_ff(nb))

fn apply_sepia_float(pixel: u32, amount: f64) -> u32:
    """Apply sepia filter. amount=1.0 is fully sepia-toned."""
    val clamped = math_min(1.0, math_max(0.0, amount))
    val r = _extract_r_ff(pixel).to_f64()
    val g = _extract_g_ff(pixel).to_f64()
    val b = _extract_b_ff(pixel).to_f64()
    val a = _extract_a_ff(pixel)
    val sr = r * 0.393 + g * 0.769 + b * 0.189
    val sg = r * 0.349 + g * 0.686 + b * 0.168
    val sb = r * 0.272 + g * 0.534 + b * 0.131
    val nr = r + (sr - r) * clamped
    val ng = g + (sg - g) * clamped
    val nb = b + (sb - b) * clamped
    _pack_argb_ff(a.to_i64(), _clamp_byte_ff(nr), _clamp_byte_ff(ng), _clamp_byte_ff(nb))

fn apply_hue_rotate_float(pixel: u32, angle_deg: f64) -> u32:
    """Apply hue rotation. Full f64 sin/cos matrix."""
    val rad = angle_deg * MATH_PI / 180.0
    val c = cos3d(rad)
    val s = sin3d(rad)

    val r = _extract_r_ff(pixel).to_f64()
    val g = _extract_g_ff(pixel).to_f64()
    val b = _extract_b_ff(pixel).to_f64()
    val a = _extract_a_ff(pixel)

    val nr = r * (0.213 + 0.787 * c - 0.213 * s) + g * (0.715 - 0.715 * c - 0.715 * s) + b * (0.072 - 0.072 * c + 0.928 * s)
    val ng = r * (0.213 - 0.213 * c + 0.143 * s) + g * (0.715 + 0.285 * c + 0.140 * s) + b * (0.072 - 0.072 * c - 0.283 * s)
    val nb = r * (0.213 - 0.213 * c - 0.787 * s) + g * (0.715 - 0.715 * c + 0.715 * s) + b * (0.072 + 0.928 * c + 0.072 * s)

    _pack_argb_ff(a.to_i64(), _clamp_byte_ff(nr), _clamp_byte_ff(ng), _clamp_byte_ff(nb))

fn apply_invert_float(pixel: u32, amount: f64) -> u32:
    """Apply inversion filter. amount=1.0 fully inverts."""
    val clamped = math_min(1.0, math_max(0.0, amount))
    val r = _extract_r_ff(pixel).to_f64()
    val g = _extract_g_ff(pixel).to_f64()
    val b = _extract_b_ff(pixel).to_f64()
    val a = _extract_a_ff(pixel)
    val nr = r + (255.0 - 2.0 * r) * clamped
    val ng = g + (255.0 - 2.0 * g) * clamped
    val nb = b + (255.0 - 2.0 * b) * clamped
    _pack_argb_ff(a.to_i64(), _clamp_byte_ff(nr), _clamp_byte_ff(ng), _clamp_byte_ff(nb))

fn apply_saturate_float(pixel: u32, amount: f64) -> u32:
    """Apply saturation adjustment. amount=1.0 is no change, 0.0 is grayscale."""
    val r = _extract_r_ff(pixel).to_f64()
    val g = _extract_g_ff(pixel).to_f64()
    val b = _extract_b_ff(pixel).to_f64()
    val a = _extract_a_ff(pixel)
    val lum = 0.2126 * r + 0.7152 * g + 0.0722 * b
    val nr = lum + (r - lum) * amount
    val ng = lum + (g - lum) * amount
    val nb = lum + (b - lum) * amount
    _pack_argb_ff(a.to_i64(), _clamp_byte_ff(nr), _clamp_byte_ff(ng), _clamp_byte_ff(nb))

# =========================================================================
# Pixel manipulation (ARGB: 0xAARRGGBB)
# =========================================================================

fn _extract_a_ff(pixel: u32) -> i64:
    ((pixel / 16777216) % 256).to_i64()

fn _extract_r_ff(pixel: u32) -> i64:
    ((pixel / 65536) % 256).to_i64()

fn _extract_g_ff(pixel: u32) -> i64:
    ((pixel / 256) % 256).to_i64()

fn _extract_b_ff(pixel: u32) -> i64:
    (pixel % 256).to_i64()

fn _pack_argb_ff(a: i64, r: i64, g: i64, b: i64) -> u32:
    val au = _clamp_i64_ff(a, 0, 255).to_u32()
    val ru = _clamp_i64_ff(r, 0, 255).to_u32()
    val gu = _clamp_i64_ff(g, 0, 255).to_u32()
    val bu = _clamp_i64_ff(b, 0, 255).to_u32()
    au * 16777216 + ru * 65536 + gu * 256 + bu

fn _clamp_byte_ff(v: f64) -> i64:
    """Clamp f64 to 0-255 and convert to i64. The only float-to-int conversion."""
    if v < 0.0:
        return 0
    if v > 255.0:
        return 255
    _f64_to_i64_ff(v)

fn _clamp_i64_ff(v: i64, lo: i64, hi: i64) -> i64:
    if v < lo:
        return lo
    if v > hi:
        return hi
    v

fn _color_to_argb_ff(color: Color) -> u32:
    _pack_argb_ff(color.a, color.r, color.g, color.b)

fn _argb_to_color_ff(pixel: u32) -> Color:
    from_rgba(
        _extract_r_ff(pixel),
        _extract_g_ff(pixel),
        _extract_b_ff(pixel),
        _extract_a_ff(pixel)
    )

fn _f64_to_i64_ff(v: f64) -> i64:
    if v >= 0.0:
        return _positive_f64_to_i64_ff(v)
    val pos = _positive_f64_to_i64_ff(-v)
    -pos

fn _positive_f64_to_i64_ff(v: f64) -> i64:
    if v <= 0.0:
        return 0
    if v >= 2147483647.0:
        return 2147483647
    var result = 0
    var remaining = v
    while remaining >= 1000.0:
        result = result + 1000
        remaining = remaining - 1000.0
    while remaining >= 1.0:
        result = result + 1
        remaining = remaining - 1.0
    result
