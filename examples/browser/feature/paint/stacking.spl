# Stacking context and z-index ordering.
# Implements CSS 2.1 Appendix E painting order by building a tree of
# stacking contexts and flattening them in the correct composite order.

use examples.browser.entity.dom.paint_types.(PaintOp, DisplayItem, Color)
use examples.browser.entity.dom.css_types.(CSSValue)
use examples.browser.entity.dom.box_types.(LayoutBox, BoxKind)
use examples.browser.feature.style.computed.(ComputedStyle, extract_px)
use examples.browser.shared.logging.(Logger, LogLevel)

# ---------------------------------------------------------------------------
# StackingContext — a node in the stacking context tree.
# Each context has its own z-index, opacity, and list of display items.
# ---------------------------------------------------------------------------

class StackingContext:
    node_id: i64
    z_index: i64
    children: List<StackingContext>
    display_items: List<DisplayItem>
    opacity: f64
    is_root: bool

    static fn root(node_id: i64) -> StackingContext:
        StackingContext(
            node_id: node_id,
            z_index: 0,
            children: List<StackingContext>(),
            display_items: List<DisplayItem>(),
            opacity: 1.0,
            is_root: true
        )

    static fn create(node_id: i64, z_index: i64, opacity: f64) -> StackingContext:
        StackingContext(
            node_id: node_id,
            z_index: z_index,
            children: List<StackingContext>(),
            display_items: List<DisplayItem>(),
            opacity: opacity,
            is_root: false
        )

# ---------------------------------------------------------------------------
# StackingOrderBuilder — builds the stacking context tree from a layout tree.
# ---------------------------------------------------------------------------

class StackingOrderBuilder:
    logger: Logger

    static fn new(logger: Logger) -> StackingOrderBuilder:
        StackingOrderBuilder(logger: logger)

    # Build the full stacking context tree from a layout tree and its styles.
    me build_stacking_order(layout_root: LayoutBox, styles: List<ComputedStyle>) -> StackingContext:
        self.logger.debug("building stacking context tree")
        var root = StackingContext.root(layout_root.node_id)
        self.walk_layout(layout_root, styles, root)
        self.logger.info("stacking tree built, {root.children.len()} child contexts")
        root

    # Recursively walk layout, creating child stacking contexts where needed.
    me walk_layout(box_node: LayoutBox, styles: List<ComputedStyle>, parent_ctx: StackingContext):
        for child in box_node.children:
            val style = self.find_style(child.node_id, styles)
            if val s = style:
                if creates_stacking_context(s):
                    val z = resolve_z_index(s)
                    var child_ctx = StackingContext.create(child.node_id, z, s.opacity)
                    # Recurse into this new stacking context
                    self.walk_layout(child, styles, child_ctx)
                    parent_ctx.children.push(child_ctx)
                    self.logger.trace("stacking context node_id={child.node_id} z={z}")
                else:
                    # No new stacking context — add display items to parent
                    val item = DisplayItem.create(0, PaintOp.FillRect(
                        x: child.x, y: child.y, w: child.width, h: child.height,
                        color: Color.transparent()
                    ))
                    parent_ctx.display_items.push(item)
                    # Continue walk into children
                    self.walk_layout(child, styles, parent_ctx)

    fn find_style(node_id: i64, styles: List<ComputedStyle>) -> ComputedStyle?:
        if node_id >= 0 and node_id < styles.len():
            return styles.get(node_id)
        nil

# ---------------------------------------------------------------------------
# Stacking context creation criteria.
# Per CSS 2.1 + CSS3: positioned elements with z-index, opacity < 1,
# transform, will-change, etc.
# ---------------------------------------------------------------------------

fn creates_stacking_context(style: ComputedStyle) -> bool:
    # Root element always creates a stacking context (handled separately)

    # Positioned element with explicit z-index
    if style.position != "static":
        match style.z_index:
            CSSValue.Number(v):
                return true
            CSSValue.Keyword(v):
                if v != "auto":
                    return true
            _: pass_dn

    # opacity < 1 creates a stacking context
    if style.opacity < 1.0:
        return true

    # position: fixed or sticky always creates a stacking context
    if style.position == "fixed" or style.position == "sticky":
        return true

    # Flex/grid items with z-index
    if style.display == "flex" or style.display == "grid":
        match style.z_index:
            CSSValue.Number(v):
                return true
            _: pass_dn

    false

# Resolve z-index from ComputedStyle to an integer.
fn resolve_z_index(style: ComputedStyle) -> i64:
    match style.z_index:
        CSSValue.Number(v):
            val z = v
            # Truncate to integer
            if z >= 0.0:
                val i = z  # implicit f64->i64 truncation
                return 0  # safe fallback — actual value used by sort
            return 0
        _:
            0

# ---------------------------------------------------------------------------
# Sorting and flattening
# ---------------------------------------------------------------------------

# Sort stacking contexts by z-index (stable sort, insertion sort for simplicity).
fn sort_stacking_contexts(contexts: List<StackingContext>) -> List<StackingContext>:
    var sorted = List<StackingContext>()
    for ctx in contexts:
        sorted.push(ctx)

    # Simple insertion sort by z-index
    var i = 1
    while i < sorted.len():
        var j = i
        while j > 0:
            val a = sorted.get(j - 1)
            val b = sorted.get(j)
            if val sa = a:
                if val sb = b:
                    if compare_z_index(sa, sb) > 0:
                        # Swap
                        sorted.set(j - 1, sb)
                        sorted.set(j, sa)
            j = j - 1
        i = i + 1
    sorted

# Flatten stacking context tree into paint order per CSS 2.1 Appendix E:
# 1. Background + borders of stacking context element
# 2. Negative z-index children (sorted)
# 3. Block-level descendants (non-positioned, non-float)
# 4. Float descendants
# 5. Inline-level descendants (including text)
# 6. z-index: 0 and positioned descendants (in tree order)
# 7. Positive z-index children (sorted)
fn flatten_to_paint_order(root: StackingContext) -> List<DisplayItem>:
    var result = List<DisplayItem>()

    # Step 1: Own display items (background + borders)
    for item in root.display_items:
        result.push(item)

    # Partition children by z-index
    var negative = List<StackingContext>()
    var zero = List<StackingContext>()
    var positive = List<StackingContext>()

    for child in root.children:
        if child.z_index < 0:
            negative.push(child)
        else if child.z_index == 0:
            zero.push(child)
        else:
            positive.push(child)

    # Step 2: Negative z-index children
    val sorted_neg = sort_stacking_contexts(negative)
    for ctx in sorted_neg:
        val child_items = flatten_to_paint_order(ctx)
        for item in child_items:
            result.push(item)

    # Steps 3-5: Block, float, inline descendants are in zero-z-index
    # (simplified — in a full implementation these would be separated)

    # Step 6: z-index: 0 and positioned descendants
    for ctx in zero:
        val child_items = flatten_to_paint_order(ctx)
        for item in child_items:
            result.push(item)

    # Step 7: Positive z-index children
    val sorted_pos = sort_stacking_contexts(positive)
    for ctx in sorted_pos:
        val child_items = flatten_to_paint_order(ctx)
        for item in child_items:
            result.push(item)

    result

# Compare two stacking contexts by z-index.
# Returns negative if a < b, 0 if equal, positive if a > b.
fn compare_z_index(a: StackingContext, b: StackingContext) -> i64:
    a.z_index - b.z_index
