#![allow(REQC001)]
#![allow(REQC004)]
#![allow(unnamed_duplicate_typed_args)]
# Image decoding pipeline — detects format, manages decoded image cache,
# and provides placeholder generation for loading states.

use examples.browser.entity.media.image_types.{ImageData, ImageFormat}
use examples.browser.shared.logging.{Logger, LogLevel}
use examples.browser.shared.error.{BrowserError, BrowserResult, paint_error}
use std.common.color.lab_xyz.{CieLab, cie_lab_d50_to_srgb_packed_argb}
use std.common.image.image_info.{detect_image_info, image_is_jpeg_xl, image_is_tiff, jpeg_xl_image_info, tiff_image_info}

# ---------------------------------------------------------------------------
# Image state tracking
# ---------------------------------------------------------------------------

enum ImageState:
    Pending
    Decoding
    Ready
    Error

# ---------------------------------------------------------------------------
# DecodedImage — cached result of decoding an image.
# ---------------------------------------------------------------------------

class DecodedImage:
    id: i64
    url: text
    data: ImageData
    state: ImageState

    static fn pending(id: i64, url: text) -> DecodedImage:
        DecodedImage(
            id: id,
            url: url,
            data: ImageData.create(0, 0, ImageFormat.Png),
            state: ImageState.Pending
        )

    static fn ready(id: i64, url: text, data: ImageData) -> DecodedImage:
        DecodedImage(id: id, url: url, data: data, state: ImageState.Ready)

    static fn error(id: i64, url: text) -> DecodedImage:
        DecodedImage(
            id: id,
            url: url,
            data: ImageData.create(0, 0, ImageFormat.Png),
            state: ImageState.Error
        )

# ---------------------------------------------------------------------------
# ImageDecoder — decodes raw image data and maintains a cache.
# ---------------------------------------------------------------------------

class ImageDecoder:
    cache: [DecodedImage]
    logger: Logger

    static fn new(logger: Logger) -> ImageDecoder:
        ImageDecoder(cache: [], logger: logger)

    # Decode raw image data into an ImageData structure.
    # Decodes raw image data into pixel arrays by format.
    me decode(image_id: i64, raw_data: text, format: ImageFormat) -> BrowserResult<ImageData>:
        self.logger.debug("decoding image id={image_id} format={format_name(format)}")

        # Check cache first
        val cached = self.get_decoded(image_id)
        if val c = cached:
            match c.state:
                ImageState.Ready:
                    self.logger.trace("cache hit for image {image_id}")
                    return Ok(c.data)
                ImageState.Error:
                    return Err(paint_error("image {image_id} previously failed to decode"))
                _: pass_dn

        # Mark as decoding
        val placeholder = DecodedImage(
            id: image_id,
            url: "",
            data: ImageData.create(0, 0, format),
            state: ImageState.Decoding
        )
        self.cache.push(placeholder)

        # Actual decoding — dispatch by format
        var decoded_data = ImageData.create(0, 0, format)
        match format:
            ImageFormat.Png:
                decoded_data = decode_png(raw_data)
            ImageFormat.Jpeg:
                decoded_data = decode_jpeg(raw_data)
            ImageFormat.Bmp:
                decoded_data = decode_bmp(raw_data)
            ImageFormat.Gif:
                decoded_data = decode_gif(raw_data)
            ImageFormat.Webp:
                decoded_data = decode_webp(raw_data)
            ImageFormat.Ico:
                decoded_data = decode_ico(raw_data)
            ImageFormat.Svg:
                decoded_data = decode_svg(raw_data)
            ImageFormat.Tiff:
                decoded_data = decode_tiff(raw_data)
            ImageFormat.JpegXl:
                decoded_data = decode_jpegxl(raw_data)
            _:
                decoded_data = create_placeholder(100, 100)
        val result = DecodedImage.ready(image_id, "", decoded_data)

        # Update cache — replace the decoding entry
        self.update_cache(image_id, result)
        self.logger.info("decoded image {image_id}")
        Ok(decoded_data)

    # Look up a decoded image by ID from the cache.
    me get_decoded(image_id: i64) -> DecodedImage?:
        for entry in self.cache:
            if entry.id == image_id:
                return entry
        nil

    # Update an existing cache entry.
    me update_cache(image_id: i64, updated: DecodedImage):
        var i = 0
        while i < self.cache.len():
            val entry = self.cache.get(i)
            if val e = entry:
                if e.id == image_id:
                    self.cache.set(i, updated)
                    return
            i = i + 1
        # Not found — just append
        self.cache.push(updated)

# ---------------------------------------------------------------------------
# Format detection
# ---------------------------------------------------------------------------

# Detect image format from raw data using magic bytes.
# PNG:  137 80 78 71 (0x89 P N G)
# JPEG: 255 216      (0xFF 0xD8)
# GIF:  71 73 70     (G I F)
# BMP:  66 77        (B M)
# WebP: RIFF....WEBP
# ICO:  00 00 01 00
# TIFF: II*\\0 or MM\\0*
# JXL:  FF 0A codestream or 00 00 00 0C JXL 20 0D 0A 87 0A container
# SVG:  <svg or XML text containing an <svg root
fn detect_format(data: text) -> ImageFormat:
    val len = data.len()
    if len < 2:
        return ImageFormat.Png  # Default fallback

    if _is_svg_data(data):
        return ImageFormat.Svg

    if image_is_tiff(data):
        return ImageFormat.Tiff

    if image_is_jpeg_xl(data):
        return ImageFormat.JpegXl

    # Check PNG signature
    if len >= 4:
        val b0 = _byte_at(data, 0)
        val b1 = _byte_at(data, 1)
        val b2 = _byte_at(data, 2)
        val b3 = _byte_at(data, 3)
        if b0 == 137 and b1 == 80 and b2 == 78 and b3 == 71:
            return ImageFormat.Png
        if b0 == 0 and b1 == 0 and b2 == 1 and b3 == 0:
            return ImageFormat.Ico

    if len >= 12:
        if data.starts_with("RIFF") and data.contains("WEBP"):
            return ImageFormat.Webp

    # Check JPEG signature
    val j0 = _byte_at(data, 0)
    val j1 = _byte_at(data, 1)
    if j0 == 255 and j1 == 216:
        return ImageFormat.Jpeg

    # Check GIF signature
    if len >= 3:
        val g0 = _byte_at(data, 0)
        val g1 = _byte_at(data, 1)
        val g2 = _byte_at(data, 2)
        if g0 == 71 and g1 == 73 and g2 == 70:
            return ImageFormat.Gif

    # Check BMP signature
    if j0 == 66 and j1 == 77:
        return ImageFormat.Bmp

    # Default
    ImageFormat.Png

# ---------------------------------------------------------------------------
# Image operations
# ---------------------------------------------------------------------------

# Scale an image to the target dimensions using bilinear interpolation.
fn scale_image(image: ImageData, target_width: i64, target_height: i64) -> ImageData:
    if target_width <= 0 or target_height <= 0:
        return ImageData.create(target_width, target_height, image.format)
    if image.width <= 0 or image.height <= 0:
        return ImageData.create(target_width, target_height, image.format)

    var data = []
    val src_w = image.width
    val src_h = image.height

    var ty = 0
    while ty < target_height:
        # Map target y back to source coordinate
        val sy_f = ty.to_f64() * (src_h.to_f64() - 1.0) / (target_height.to_f64() - 1.0 + 0.000001)
        val sy0 = _floor_i64(sy_f)
        val sy1 = if sy0 + 1 < src_h: sy0 + 1 else: sy0
        val fy = sy_f - sy0.to_f64()

        var tx = 0
        while tx < target_width:
            # Map target x back to source coordinate
            val sx_f = tx.to_f64() * (src_w.to_f64() - 1.0) / (target_width.to_f64() - 1.0 + 0.000001)
            val sx0 = _floor_i64(sx_f)
            val sx1 = if sx0 + 1 < src_w: sx0 + 1 else: sx0
            val fx = sx_f - sx0.to_f64()

            # Read the 4 source pixels (RGBA)
            val i00 = (sy0 * src_w + sx0) * 4
            val i10 = (sy0 * src_w + sx1) * 4
            val i01 = (sy1 * src_w + sx0) * 4
            val i11 = (sy1 * src_w + sx1) * 4

            # Bilinear interpolation per channel
            var ch = 0
            while ch < 4:
                val v00 = _safe_get(image.data, i00 + ch)
                val v10 = _safe_get(image.data, i10 + ch)
                val v01 = _safe_get(image.data, i01 + ch)
                val v11 = _safe_get(image.data, i11 + ch)

                # Blend: top = lerp(v00, v10, fx), bottom = lerp(v01, v11, fx), result = lerp(top, bottom, fy)
                val top = v00.to_f64() + (v10.to_f64() - v00.to_f64()) * fx
                val bottom = v01.to_f64() + (v11.to_f64() - v01.to_f64()) * fx
                val result = top + (bottom - top) * fy
                val clamped = _clamp_byte(result)
                data.push(clamped)
                ch = ch + 1

            tx = tx + 1
        ty = ty + 1

    ImageData(width: target_width, height: target_height, format: image.format, data: data)

# Create a gray placeholder image for loading states.
fn create_placeholder(width: i64, height: i64) -> ImageData:
    create_placeholder_format(width, height, ImageFormat.Png)

fn create_placeholder_format(width: i64, height: i64, format: ImageFormat) -> ImageData:
    var data = []
    # Fill with mid-gray RGBA (128, 128, 128, 255)
    var y = 0
    while y < height:
        var x = 0
        while x < width:
            data = data + [128, 128, 128, 255]
            x = x + 1
        y = y + 1
    ImageData(width: width, height: height, format: format, data: data)

# Helper — format name for logging.
fn format_name(format: ImageFormat) -> text:
    match format:
        ImageFormat.Png: "PNG"
        ImageFormat.Jpeg: "JPEG"
        ImageFormat.Gif: "GIF"
        ImageFormat.Webp: "WebP"
        ImageFormat.Svg: "SVG"
        ImageFormat.Bmp: "BMP"
        ImageFormat.Ico: "ICO"
        ImageFormat.Tiff: "TIFF"
        ImageFormat.JpegXl: "JPEG XL"

fn decode_tiff(raw_data: text) -> ImageData:
    val info = tiff_image_info(raw_data)
    val decoded = _decode_tiff_baseline_pixels(raw_data)
    match decoded:
        Some(image):
            return image
        nil:
            pass_dn
    if info.width > 0 and info.height > 0:
        return create_placeholder_format(info.width, info.height, ImageFormat.Tiff)
    create_placeholder_format(1, 1, ImageFormat.Tiff)

fn decode_jpegxl(raw_data: text) -> ImageData:
    val info = jpeg_xl_image_info(raw_data)
    if info.width > 0 and info.height > 0:
        return create_placeholder_format(info.width, info.height, ImageFormat.JpegXl)
    create_placeholder_format(1, 1, ImageFormat.JpegXl)

# ---------------------------------------------------------------------------
# PNG Decoder — parse chunks, decompress IDAT, reconstruct pixels
# ---------------------------------------------------------------------------

# Decode a PNG from raw binary data (as text of raw bytes).
fn decode_png(raw_data: text) -> ImageData:
    val data_len = raw_data.len()

    # Verify PNG signature: 137 80 78 71 13 10 26 10
    if data_len < 8:
        return create_placeholder(1, 1)
    val sig_ok = _check_png_signature(raw_data)
    if not sig_ok:
        return create_placeholder(1, 1)

    # Parse chunks
    var width = 0
    var height = 0
    var bit_depth = 8
    var color_type = 6  # default RGBA
    var compressed_data = []
    var palette: [i64] = []
    var palette_alpha: [i64] = []
    var offset = 8  # skip signature

    while offset + 12 <= data_len:
        # Chunk: 4-byte length, 4-byte type, data, 4-byte CRC
        val chunk_len = _read_u32_be(raw_data, offset)
        val chunk_type = _read_chunk_type(raw_data, offset + 4)

        if chunk_type == "IHDR":
            width = _read_u32_be(raw_data, offset + 8)
            height = _read_u32_be(raw_data, offset + 12)
            bit_depth = _byte_at(raw_data, offset + 16)
            color_type = _byte_at(raw_data, offset + 17)
        else if chunk_type == "IDAT":
            # Collect compressed data bytes
            var i = 0
            while i < chunk_len:
                compressed_data.push(_byte_at(raw_data, offset + 8 + i))
                i = i + 1
        else if chunk_type == "PLTE":
            var i = 0
            while i < chunk_len:
                palette.push(_byte_at(raw_data, offset + 8 + i))
                i = i + 1
        else if chunk_type == "tRNS":
            var i = 0
            while i < chunk_len:
                palette_alpha.push(_byte_at(raw_data, offset + 8 + i))
                i = i + 1
        else if chunk_type == "IEND":
            offset = data_len  # stop parsing

        offset = offset + 12 + chunk_len

    if width <= 0 or height <= 0:
        return create_placeholder(1, 1)

    # Determine bytes per pixel based on color_type
    val bpp = _bytes_per_pixel(color_type, bit_depth)

    # Decompress IDAT using DEFLATE (skip 2-byte zlib header)
    val decompressed = _inflate(compressed_data, 2)

    # Reconstruct scanlines with PNG filter undoing
    val stride = width * bpp
    val pixels = _reconstruct_scanlines(decompressed, width, height, bpp, stride)

    # Convert to RGBA if not already
    val rgba = _to_rgba(pixels, width, height, color_type, bpp, palette, palette_alpha)

    ImageData(width: width, height: height, format: ImageFormat.Png, data: rgba)

# Decode uncompressed Windows BMP data into RGBA pixels.
fn decode_bmp(raw_data: text) -> ImageData:
    val data_len = raw_data.len()
    if data_len < 54:
        return create_placeholder(1, 1)
    if _byte_at(raw_data, 0) != 66 or _byte_at(raw_data, 1) != 77:
        return create_placeholder(1, 1)

    val pixel_offset = _read_u32_le(raw_data, 10)
    val dib_size = _read_u32_le(raw_data, 14)
    if dib_size < 40:
        return create_placeholder(1, 1)

    val width = _read_i32_le(raw_data, 18)
    var height = _read_i32_le(raw_data, 22)
    val planes = _read_u16_le(raw_data, 26)
    val bits_per_pixel = _read_u16_le(raw_data, 28)
    val compression = _read_u32_le(raw_data, 30)

    if width <= 0 or height == 0 or planes != 1 or compression != 0:
        return create_placeholder(1, 1)
    if bits_per_pixel != 24 and bits_per_pixel != 32:
        return create_placeholder(1, 1)

    var top_down = false
    if height < 0:
        top_down = true
        height = 0 - height

    val bytes_per_pixel = bits_per_pixel / 8
    val row_stride = ((width * bytes_per_pixel + 3) / 4) * 4
    if pixel_offset + row_stride * height > data_len:
        return create_placeholder(1, 1)

    var rgba = []
    var y = 0
    while y < height:
        val source_y = if top_down: y else: height - 1 - y
        val row_offset = pixel_offset + source_y * row_stride
        var x = 0
        while x < width:
            val pixel = row_offset + x * bytes_per_pixel
            val b = _byte_at(raw_data, pixel)
            val g = _byte_at(raw_data, pixel + 1)
            val r = _byte_at(raw_data, pixel + 2)
            val a = if bits_per_pixel == 32: _byte_at(raw_data, pixel + 3) else: 255
            rgba.push(r)
            rgba.push(g)
            rgba.push(b)
            rgba.push(a)
            x = x + 1
        y = y + 1

    ImageData(width: width, height: height, format: ImageFormat.Bmp, data: rgba)

# Decode the first GIF image into RGBA pixels.
fn decode_gif(raw_data: text) -> ImageData:
    if raw_data.len() < 10:
        return create_placeholder_format(1, 1, ImageFormat.Gif)
    val signature = _byte_at(raw_data, 0) == 71 and _byte_at(raw_data, 1) == 73 and _byte_at(raw_data, 2) == 70
    val version = _byte_at(raw_data, 3) == 56 and (_byte_at(raw_data, 4) == 55 or _byte_at(raw_data, 4) == 57) and _byte_at(raw_data, 5) == 97
    if not signature or not version:
        return create_placeholder_format(1, 1, ImageFormat.Gif)
    val width = _read_u16_le(raw_data, 6)
    val height = _read_u16_le(raw_data, 8)
    if width <= 0 or height <= 0:
        return create_placeholder_format(1, 1, ImageFormat.Gif)

    val packed = _byte_at(raw_data, 10)
    val has_global_palette = (packed / 128) % 2 == 1
    val global_palette_size = _pow2((packed % 8) + 1)
    var offset = 13
    var palette: [i64] = []
    if has_global_palette:
        if offset + global_palette_size * 3 > raw_data.len():
            return create_placeholder_format(width, height, ImageFormat.Gif)
        palette = _read_gif_palette(raw_data, offset, global_palette_size)
        offset = offset + global_palette_size * 3

    var transparent_index = -1
    while offset < raw_data.len():
        val marker = _byte_at(raw_data, offset)
        if marker == 59:
            return create_placeholder_format(width, height, ImageFormat.Gif)
        if marker == 33:
            val label = _byte_at(raw_data, offset + 1)
            if label == 249 and offset + 7 < raw_data.len():
                val block_size = _byte_at(raw_data, offset + 2)
                if block_size == 4:
                    val gce_packed = _byte_at(raw_data, offset + 3)
                    if (gce_packed % 2) == 1:
                        transparent_index = _byte_at(raw_data, offset + 6)
                offset = offset + 3 + block_size + 1
            else:
                offset = _skip_gif_extension(raw_data, offset + 2)
        else if marker == 44:
            if offset + 9 >= raw_data.len():
                return create_placeholder_format(width, height, ImageFormat.Gif)
            val image_width = _read_u16_le(raw_data, offset + 5)
            val image_height = _read_u16_le(raw_data, offset + 7)
            val image_packed = _byte_at(raw_data, offset + 9)
            val has_local_palette = (image_packed / 128) % 2 == 1
            val interlaced = (image_packed / 64) % 2 == 1
            offset = offset + 10
            if has_local_palette:
                val local_palette_size = _pow2((image_packed % 8) + 1)
                if offset + local_palette_size * 3 > raw_data.len():
                    return create_placeholder_format(width, height, ImageFormat.Gif)
                palette = _read_gif_palette(raw_data, offset, local_palette_size)
                offset = offset + local_palette_size * 3
            if interlaced:
                return create_placeholder_format(width, height, ImageFormat.Gif)
            if offset >= raw_data.len() or palette.len() == 0:
                return create_placeholder_format(width, height, ImageFormat.Gif)
            val min_code_size = _byte_at(raw_data, offset)
            offset = offset + 1
            val image_data = _read_gif_sub_blocks(raw_data, offset)
            val indices = _gif_lzw_decode(image_data, min_code_size, image_width * image_height)
            if indices.len() < image_width * image_height:
                return create_placeholder_format(width, height, ImageFormat.Gif)
            val rgba = _gif_indices_to_rgba(indices, palette, image_width * image_height, transparent_index)
            return ImageData(width: image_width, height: image_height, format: ImageFormat.Gif, data: rgba)
        else:
            return create_placeholder_format(width, height, ImageFormat.Gif)

    create_placeholder_format(width, height, ImageFormat.Gif)

# Decode JPEG metadata and preserve intrinsic dimensions.
# Full entropy/DCT pixel decode is outside this pure-Simple path; dimensions are
# still required for layout, responsive sizing, and avoiding fixed placeholders.
fn decode_jpeg(raw_data: text) -> ImageData:
    if raw_data.len() < 4:
        return create_placeholder_format(1, 1, ImageFormat.Jpeg)
    if _byte_at(raw_data, 0) != 255 or _byte_at(raw_data, 1) != 216:
        return create_placeholder_format(1, 1, ImageFormat.Jpeg)

    var offset = 2
    while offset + 3 < raw_data.len():
        while offset < raw_data.len() and _byte_at(raw_data, offset) != 255:
            offset = offset + 1
        while offset < raw_data.len() and _byte_at(raw_data, offset) == 255:
            offset = offset + 1
        if offset >= raw_data.len():
            return create_placeholder_format(1, 1, ImageFormat.Jpeg)

        val marker = _byte_at(raw_data, offset)
        offset = offset + 1
        if marker == 217 or marker == 218:
            return create_placeholder_format(1, 1, ImageFormat.Jpeg)
        if _jpeg_marker_has_no_length(marker):
            pass_dn
        else:
            if offset + 1 >= raw_data.len():
                return create_placeholder_format(1, 1, ImageFormat.Jpeg)
            val segment_len = _read_u16_be(raw_data, offset)
            if segment_len < 2 or offset + segment_len > raw_data.len():
                return create_placeholder_format(1, 1, ImageFormat.Jpeg)
            if _jpeg_is_sof_marker(marker):
                if segment_len >= 7:
                    val height = _read_u16_be(raw_data, offset + 3)
                    val width = _read_u16_be(raw_data, offset + 5)
                    if width > 0 and height > 0:
                        return create_placeholder_format(width, height, ImageFormat.Jpeg)
                return create_placeholder_format(1, 1, ImageFormat.Jpeg)
            offset = offset + segment_len

    create_placeholder_format(1, 1, ImageFormat.Jpeg)

# Decode WebP container metadata into an intrinsic-size placeholder.
fn decode_webp(raw_data: text) -> ImageData:
    if raw_data.len() < 20:
        return create_placeholder_format(1, 1, ImageFormat.Webp)
    if not raw_data.starts_with("RIFF") or not raw_data.contains("WEBP"):
        return create_placeholder_format(1, 1, ImageFormat.Webp)

    val chunk_type = _read_chunk_type(raw_data, 12)
    if chunk_type == "VP8X" and raw_data.len() >= 30:
        val width = _read_u24_le(raw_data, 24) + 1
        val height = _read_u24_le(raw_data, 27) + 1
        if width > 0 and height > 0:
            return create_placeholder_format(width, height, ImageFormat.Webp)
    else if chunk_type == "VP8L" and raw_data.len() >= 25:
        if _byte_at(raw_data, 20) == 47:
            val b1 = _byte_at(raw_data, 21)
            val b2 = _byte_at(raw_data, 22)
            val b3 = _byte_at(raw_data, 23)
            val b4 = _byte_at(raw_data, 24)
            val width = 1 + b1 + (b2 % 64) * 256
            val height = 1 + (b2 / 64) + b3 * 4 + (b4 % 16) * 1024
            if width > 0 and height > 0:
                return create_placeholder_format(width, height, ImageFormat.Webp)
    else if chunk_type == "VP8 " and raw_data.len() >= 30:
        if _byte_at(raw_data, 23) == 157 and _byte_at(raw_data, 24) == 1 and _byte_at(raw_data, 25) == 42:
            val width = _read_u16_le(raw_data, 26) % 16384
            val height = _read_u16_le(raw_data, 28) % 16384
            if width > 0 and height > 0:
                return create_placeholder_format(width, height, ImageFormat.Webp)

    create_placeholder_format(1, 1, ImageFormat.Webp)

# Decode ICO directory metadata and BMP-backed icon pixels.
fn decode_ico(raw_data: text) -> ImageData:
    if raw_data.len() < 22:
        return create_placeholder_format(1, 1, ImageFormat.Ico)
    if _byte_at(raw_data, 0) != 0 or _byte_at(raw_data, 1) != 0:
        return create_placeholder_format(1, 1, ImageFormat.Ico)
    if _byte_at(raw_data, 2) != 1 or _byte_at(raw_data, 3) != 0:
        return create_placeholder_format(1, 1, ImageFormat.Ico)
    if _read_u16_le(raw_data, 4) <= 0:
        return create_placeholder_format(1, 1, ImageFormat.Ico)

    var width = _byte_at(raw_data, 6)
    var height = _byte_at(raw_data, 7)
    if width == 0:
        width = 256
    if height == 0:
        height = 256

    val bytes_in_resource = _read_u32_le(raw_data, 14)
    val image_offset = _read_u32_le(raw_data, 18)
    val decoded = _decode_ico_bmp(raw_data, image_offset, bytes_in_resource, width, height)
    match decoded:
        Some(image):
            image
        nil:
            create_placeholder_format(width, height, ImageFormat.Ico)

fn _decode_ico_bmp(raw_data: text, image_offset: i64, bytes_in_resource: i64, entry_width: i64, entry_height: i64) -> ImageData?:
    if image_offset <= 0:
        return nil
    if image_offset + 40 > raw_data.len():
        return nil
    if bytes_in_resource > 0 and image_offset + bytes_in_resource > raw_data.len():
        return nil

    val dib_size = _read_u32_le(raw_data, image_offset)
    if dib_size < 40:
        return nil
    val dib_width = _read_i32_le(raw_data, image_offset + 4)
    val dib_height_with_mask = _read_i32_le(raw_data, image_offset + 8)
    val planes = _read_u16_le(raw_data, image_offset + 12)
    val bits_per_pixel = _read_u16_le(raw_data, image_offset + 14)
    val compression = _read_u32_le(raw_data, image_offset + 16)
    if planes != 1 or compression != 0:
        return nil
    if bits_per_pixel != 32 and bits_per_pixel != 24:
        return nil

    var width = dib_width
    var height = dib_height_with_mask / 2
    if width <= 0:
        width = entry_width
    if height <= 0:
        height = entry_height
    if width <= 0 or height <= 0:
        return nil

    val bytes_per_pixel = bits_per_pixel / 8
    val xor_offset = image_offset + dib_size
    val xor_stride = ((width * bytes_per_pixel + 3) / 4) * 4
    val xor_bytes = xor_stride * height
    if xor_offset + xor_bytes > raw_data.len():
        return nil

    val mask_stride = ((width + 31) / 32) * 4
    val mask_offset = xor_offset + xor_bytes
    var rgba: [i64] = []
    var y = 0
    while y < height:
        val source_y = height - 1 - y
        val row_offset = xor_offset + source_y * xor_stride
        var x = 0
        while x < width:
            val pixel = row_offset + x * bytes_per_pixel
            val b = _byte_at(raw_data, pixel)
            val g = _byte_at(raw_data, pixel + 1)
            val r = _byte_at(raw_data, pixel + 2)
            var a = if bits_per_pixel == 32: _byte_at(raw_data, pixel + 3) else: 255
            if bits_per_pixel == 24 and mask_offset + mask_stride * height <= raw_data.len():
                val mask_row = mask_offset + source_y * mask_stride
                val mask_byte = _byte_at(raw_data, mask_row + x / 8)
                val mask_bit = (mask_byte / _pow2(7 - (x % 8))) % 2
                if mask_bit == 1:
                    a = 0
            rgba.push(r)
            rgba.push(g)
            rgba.push(b)
            rgba.push(a)
            x = x + 1
        y = y + 1

    Some(ImageData(width: width, height: height, format: ImageFormat.Ico, data: rgba))

# SVG is vector content; rasterization belongs to a later rendering stage.
fn decode_svg(raw_data: text) -> ImageData:
    if not _is_svg_data(raw_data):
        return create_placeholder_format(1, 1, ImageFormat.Svg)
    val width = _svg_dimension(raw_data, "width", 300)
    val height = _svg_dimension(raw_data, "height", 150)
    create_placeholder_format(width, height, ImageFormat.Svg)

fn _read_gif_palette(data: text, offset: i64, color_count: i64) -> [i64]:
    var palette: [i64] = []
    var i = 0
    while i < color_count:
        val base = offset + i * 3
        palette.push(_byte_at(data, base))
        palette.push(_byte_at(data, base + 1))
        palette.push(_byte_at(data, base + 2))
        i = i + 1
    palette

fn _skip_gif_extension(data: text, offset: i64) -> i64:
    var pos = offset
    while pos < data.len():
        val size = _byte_at(data, pos)
        pos = pos + 1
        if size == 0:
            return pos
        pos = pos + size
    pos

fn _read_gif_sub_blocks(data: text, offset: i64) -> [i64]:
    var out: [i64] = []
    var pos = offset
    while pos < data.len():
        val size = _byte_at(data, pos)
        pos = pos + 1
        if size == 0:
            return out
        var i = 0
        while i < size and pos + i < data.len():
            out.push(_byte_at(data, pos + i))
            i = i + 1
        pos = pos + size
    out

fn _gif_lzw_decode(data: [i64], min_code_size: i64, expected_pixels: i64) -> [i64]:
    if min_code_size < 2 or min_code_size > 8:
        return []

    val clear_code = _pow2(min_code_size)
    val end_code = clear_code + 1
    var code_size = min_code_size + 1
    var next_code = end_code + 1
    var dict = _gif_initial_dictionary(clear_code)
    var output: [i64] = []
    var previous: [i64] = []
    var bit_pos = 0
    val total_bits = data.len() * 8
    var done = false

    while not done and bit_pos + code_size <= total_bits and output.len() < expected_pixels:
        val code = _read_bits(data, bit_pos, code_size)
        bit_pos = bit_pos + code_size

        if code == clear_code:
            dict = _gif_initial_dictionary(clear_code)
            code_size = min_code_size + 1
            next_code = end_code + 1
            previous = []
        else if code == end_code:
            done = true
        else:
            var entry: [i64] = []
            if code < dict.len():
                entry = _gif_dict_get(dict, code)
            else if code == next_code and previous.len() > 0:
                entry = previous + [_safe_get_list(previous, 0)]
            else:
                return output

            var i = 0
            while i < entry.len() and output.len() < expected_pixels:
                output.push(_safe_get_list(entry, i))
                i = i + 1

            if previous.len() > 0 and entry.len() > 0:
                dict.push(previous + [_safe_get_list(entry, 0)])
                next_code = next_code + 1
                if next_code == _pow2(code_size) and code_size < 12:
                    code_size = code_size + 1
            previous = entry

    output

fn _gif_initial_dictionary(clear_code: i64) -> [[i64]]:
    var dict: [[i64]] = []
    var i = 0
    while i < clear_code:
        dict.push([i])
        i = i + 1
    dict.push([])
    dict.push([])
    dict

fn _gif_dict_get(dict: [[i64]], index: i64) -> [i64]:
    if index >= 0 and index < dict.len():
        val entry = dict.get(index)
        if val e = entry:
            return e
    []

fn _gif_indices_to_rgba(indices: [i64], palette: [i64], pixel_count: i64, transparent_index: i64) -> [i64]:
    var rgba: [i64] = []
    var i = 0
    while i < pixel_count:
        val index = _safe_get_list(indices, i)
        val base = index * 3
        if index == transparent_index:
            rgba.push(0)
            rgba.push(0)
            rgba.push(0)
            rgba.push(0)
        else if base + 2 < palette.len():
            rgba.push(_safe_get_list(palette, base))
            rgba.push(_safe_get_list(palette, base + 1))
            rgba.push(_safe_get_list(palette, base + 2))
            rgba.push(255)
        else:
            rgba.push(0)
            rgba.push(0)
            rgba.push(0)
            rgba.push(255)
        i = i + 1
    rgba

# Check the 8-byte PNG signature.
fn _check_png_signature(data: text) -> bool:
    val b0 = _byte_at(data, 0) == 137
    val b1 = _byte_at(data, 1) == 80
    val b2 = _byte_at(data, 2) == 78
    val b3 = _byte_at(data, 3) == 71
    val b4 = _byte_at(data, 4) == 13
    val b5 = _byte_at(data, 5) == 10
    val b6 = _byte_at(data, 6) == 26
    val b7 = _byte_at(data, 7) == 10
    val first_four = b0 and b1 and b2 and b3
    val last_four = b4 and b5 and b6 and b7
    first_four and last_four

fn _byte_at(data: text, offset: i64) -> i64:
    if offset < 0 or offset >= data.len():
        return 0
    data[offset:offset + 1].char_code_at(0)

# Read a 4-byte big-endian unsigned integer.
fn _read_u32_be(data: text, offset: i64) -> i64:
    val b0 = _byte_at(data, offset)
    val b1 = _byte_at(data, offset + 1)
    val b2 = _byte_at(data, offset + 2)
    val b3 = _byte_at(data, offset + 3)
    b0 * 16777216 + b1 * 65536 + b2 * 256 + b3

fn _read_u16_le(data: text, offset: i64) -> i64:
    val b0 = _byte_at(data, offset)
    val b1 = _byte_at(data, offset + 1)
    b0 + b1 * 256

fn _read_u16_be(data: text, offset: i64) -> i64:
    val b0 = _byte_at(data, offset)
    val b1 = _byte_at(data, offset + 1)
    b0 * 256 + b1

fn _read_u24_le(data: text, offset: i64) -> i64:
    val b0 = _byte_at(data, offset)
    val b1 = _byte_at(data, offset + 1)
    val b2 = _byte_at(data, offset + 2)
    b0 + b1 * 256 + b2 * 65536

fn _jpeg_marker_has_no_length(marker: i64) -> bool:
    marker == 1 or (marker >= 208 and marker <= 215)

fn _jpeg_is_sof_marker(marker: i64) -> bool:
    if marker == 192: return true
    if marker == 193: return true
    if marker == 194: return true
    if marker == 195: return true
    if marker == 197: return true
    if marker == 198: return true
    if marker == 199: return true
    if marker == 201: return true
    if marker == 202: return true
    if marker == 203: return true
    if marker == 205: return true
    if marker == 206: return true
    if marker == 207: return true
    false

fn _read_u32_le(data: text, offset: i64) -> i64:
    val b0 = _byte_at(data, offset)
    val b1 = _byte_at(data, offset + 1)
    val b2 = _byte_at(data, offset + 2)
    val b3 = _byte_at(data, offset + 3)
    b0 + b1 * 256 + b2 * 65536 + b3 * 16777216

fn _read_i32_le(data: text, offset: i64) -> i64:
    val unsigned = _read_u32_le(data, offset)
    if unsigned >= 2147483648:
        return unsigned - 4294967296
    unsigned

fn _read_u16(data: text, offset: i64, little: bool) -> i64:
    if little:
        return _read_u16_le(data, offset)
    _read_u16_be(data, offset)

fn _read_u32(data: text, offset: i64, little: bool) -> i64:
    if little:
        return _read_u32_le(data, offset)
    _read_u32_be(data, offset)

fn _decode_tiff_baseline_pixels(raw_data: text) -> ImageData?:
    if not image_is_tiff(raw_data):
        return nil
    val little = _byte_at(raw_data, 0) == 73
    val ifd = _read_u32(raw_data, 4, little)
    if ifd <= 0 or ifd + 2 > raw_data.len():
        return nil
    val count = _read_u16(raw_data, ifd, little)
    var width = 0
    var height = 0
    var compression = 1
    var photometric = 1
    var samples_per_pixel = 1
    var planar_config = 1
    var rows_per_strip = 0
    var strip_offset_entry = 0
    var strip_offset_count = 0
    var strip_byte_count_entry = 0
    var strip_byte_count_count = 0
    var tile_width = 0
    var tile_length = 0
    var tile_offset_entry = 0
    var tile_offset_count = 0
    var tile_byte_count_entry = 0
    var tile_byte_count_count = 0
    var bits_per_sample_count = 1
    var bits_per_sample_value = 8
    var bits_per_sample_offset = 0
    var color_map_entry = 0
    var color_map_count = 0

    var i = 0
    while i < count:
        val entry = ifd + 2 + i * 12
        if entry + 12 > raw_data.len():
            return nil
        val tag = _read_u16(raw_data, entry, little)
        val typ = _read_u16(raw_data, entry + 2, little)
        val value_count = _read_u32(raw_data, entry + 4, little)
        val first_value = _tiff_entry_first_value(raw_data, entry, little)
        if tag == 256:
            width = first_value
        else if tag == 257:
            height = first_value
        else if tag == 258:
            bits_per_sample_count = value_count
            if value_count == 1:
                bits_per_sample_value = first_value
            else:
                bits_per_sample_offset = _read_u32(raw_data, entry + 8, little)
        else if tag == 259:
            compression = first_value
        else if tag == 262:
            photometric = first_value
        else if tag == 273:
            strip_offset_entry = entry
            strip_offset_count = value_count
        else if tag == 277:
            samples_per_pixel = first_value
        else if tag == 278:
            rows_per_strip = first_value
        else if tag == 279:
            strip_byte_count_entry = entry
            strip_byte_count_count = value_count
        else if tag == 284:
            planar_config = first_value
        else if tag == 320:
            color_map_entry = entry
            color_map_count = value_count
        else if tag == 322:
            tile_width = first_value
        else if tag == 323:
            tile_length = first_value
        else if tag == 324:
            tile_offset_entry = entry
            tile_offset_count = value_count
        else if tag == 325:
            tile_byte_count_entry = entry
            tile_byte_count_count = value_count
        else:
            pass_dn
        i = i + 1

    if width <= 0 or height <= 0:
        return nil
    if compression != 1 and compression != 32773:
        return nil
    if planar_config != 1 and planar_config != 2:
        return nil
    if planar_config == 2 and (compression != 1 or photometric != 2 or samples_per_pixel != 3):
        return nil
    if samples_per_pixel != 1 and samples_per_pixel != 3 and samples_per_pixel != 4:
        return nil
    if photometric != 0 and photometric != 1 and photometric != 2 and photometric != 3 and photometric != 8:
        return nil
    if samples_per_pixel == 1 and photometric != 0 and photometric != 1 and photometric != 3:
        return nil
    if samples_per_pixel > 1 and photometric != 2 and photometric != 8:
        return nil
    if photometric == 8 and samples_per_pixel != 3:
        return nil
    if photometric == 3 and (samples_per_pixel != 1 or not _tiff_colormap_is_supported(raw_data, color_map_entry, color_map_count, little)):
        return nil
    val is_tiled = tile_offset_entry > 0
    if is_tiled and (compression != 1 or planar_config != 1 or tile_width <= 0 or tile_length <= 0 or tile_byte_count_entry <= 0):
        return nil
    val sample_bits = _tiff_sample_bits(raw_data, bits_per_sample_count, bits_per_sample_value, bits_per_sample_offset, little)
    if not _tiff_bits_are_supported(raw_data, bits_per_sample_count, bits_per_sample_value, bits_per_sample_offset, samples_per_pixel, compression, photometric, planar_config, little):
        return nil

    val bytes_per_sample = _tiff_bytes_per_sample(sample_bits)
    val bytes_per_pixel = samples_per_pixel * bytes_per_sample
    val decoded_pixel_bytes_needed = width * height * bytes_per_pixel
    if rows_per_strip <= 0:
        rows_per_strip = height
    val strip_count_needed = (height + rows_per_strip - 1) / rows_per_strip
    val tiles_across = if is_tiled: (width + tile_width - 1) / tile_width else: 0
    val tiles_down = if is_tiled: (height + tile_length - 1) / tile_length else: 0
    val tile_count_needed = tiles_across * tiles_down
    if is_tiled:
        if tile_offset_count != 1 and tile_offset_count < tile_count_needed:
            return nil
        if tile_byte_count_count != 1 and tile_byte_count_count < tile_count_needed:
            return nil
    else:
        if strip_offset_entry <= 0:
            return nil
        val strip_offset_count_needed = _tiff_strip_offset_count_needed(strip_count_needed, samples_per_pixel, planar_config)
        if strip_offset_count != 1 and strip_offset_count < strip_offset_count_needed:
            return nil
        if strip_byte_count_count != 0 and strip_byte_count_count != 1 and strip_byte_count_count < strip_offset_count_needed:
            return nil
    var packbits_pixels: [i64] = []
    if compression == 32773:
        if is_tiled:
            return nil
        if strip_byte_count_entry <= 0:
            return nil
        packbits_pixels = _tiff_decode_packbits_strips(
            raw_data,
            strip_offset_entry,
            strip_offset_count,
            strip_byte_count_entry,
            strip_byte_count_count,
            strip_count_needed,
            decoded_pixel_bytes_needed,
            little
        )
        if packbits_pixels.len() < decoded_pixel_bytes_needed:
            return nil

    var rgba = []
    var pixel_index = 0
    while pixel_index < width * height:
        var pixel_offset = pixel_index * bytes_per_pixel
        val row = pixel_index / width
        val col = pixel_index - row * width
        if is_tiled:
            val tile_x = col / tile_width
            val tile_y = row / tile_length
            val tile_index = tile_y * tiles_across + tile_x
            val tile_lookup_index = _tiff_strip_lookup_index(tile_index, tile_offset_count)
            val byte_count_lookup_index = _tiff_strip_lookup_index(tile_index, tile_byte_count_count)
            val tile_offset = _tiff_entry_value_at(raw_data, tile_offset_entry, tile_lookup_index, little)
            val tile_byte_count = _tiff_entry_value_at(raw_data, tile_byte_count_entry, byte_count_lookup_index, little)
            val local_x = col - tile_x * tile_width
            val local_y = row - tile_y * tile_length
            pixel_offset = tile_offset + (local_y * tile_width + local_x) * bytes_per_pixel
            if tile_offset <= 0 or pixel_offset + bytes_per_pixel > raw_data.len():
                return nil
            if tile_byte_count <= 0 or pixel_offset + bytes_per_pixel > tile_offset + tile_byte_count:
                return nil
        else if compression == 1 and planar_config == 1:
            val strip_index = row / rows_per_strip
            val row_in_strip = row - strip_index * rows_per_strip
            val strip_lookup_index = _tiff_strip_lookup_index(strip_index, strip_offset_count)
            val byte_count_lookup_index = _tiff_strip_lookup_index(strip_index, strip_byte_count_count)
            val strip_offset = _tiff_entry_value_at(raw_data, strip_offset_entry, strip_lookup_index, little)
            val strip_byte_count = _tiff_entry_value_at(raw_data, strip_byte_count_entry, byte_count_lookup_index, little)
            pixel_offset = strip_offset + (row_in_strip * width + col) * bytes_per_pixel
            if strip_offset <= 0 or pixel_offset + bytes_per_pixel > raw_data.len():
                return nil
            if strip_byte_count > 0 and pixel_offset + bytes_per_pixel > strip_offset + strip_byte_count:
                return nil
        if planar_config == 2:
            rgba.push(_tiff_planar_sample_byte(raw_data, strip_offset_entry, strip_offset_count, strip_byte_count_entry, strip_byte_count_count, row, col, width, rows_per_strip, strip_count_needed, 0, little))
            rgba.push(_tiff_planar_sample_byte(raw_data, strip_offset_entry, strip_offset_count, strip_byte_count_entry, strip_byte_count_count, row, col, width, rows_per_strip, strip_count_needed, 1, little))
            rgba.push(_tiff_planar_sample_byte(raw_data, strip_offset_entry, strip_offset_count, strip_byte_count_entry, strip_byte_count_count, row, col, width, rows_per_strip, strip_count_needed, 2, little))
            rgba.push(255)
        else if photometric == 3:
            val palette_index = _tiff_pixel_byte(raw_data, packbits_pixels, pixel_offset, compression == 32773)
            rgba.push(_tiff_colormap_byte(raw_data, color_map_entry, color_map_count, palette_index, 0, little))
            rgba.push(_tiff_colormap_byte(raw_data, color_map_entry, color_map_count, palette_index, 1, little))
            rgba.push(_tiff_colormap_byte(raw_data, color_map_entry, color_map_count, palette_index, 2, little))
            rgba.push(255)
        else if samples_per_pixel == 1:
            var gray = _tiff_gray_sample(raw_data, packbits_pixels, pixel_offset, sample_bits, compression == 32773, little)
            if photometric == 0:
                gray = 255 - gray
            rgba.push(gray)
            rgba.push(gray)
            rgba.push(gray)
            rgba.push(255)
        else if photometric == 8:
            val argb = _tiff_cielab_pixel_to_argb(
                _tiff_pixel_byte(raw_data, packbits_pixels, pixel_offset, compression == 32773),
                _tiff_pixel_byte(raw_data, packbits_pixels, pixel_offset + 1, compression == 32773),
                _tiff_pixel_byte(raw_data, packbits_pixels, pixel_offset + 2, compression == 32773)
            )
            rgba.push((argb / 65536) & 255)
            rgba.push((argb / 256) & 255)
            rgba.push(argb & 255)
            rgba.push(255)
        else:
            rgba.push(_tiff_color_sample(raw_data, packbits_pixels, pixel_offset, 0, sample_bits, compression == 32773, little))
            rgba.push(_tiff_color_sample(raw_data, packbits_pixels, pixel_offset, 1, sample_bits, compression == 32773, little))
            rgba.push(_tiff_color_sample(raw_data, packbits_pixels, pixel_offset, 2, sample_bits, compression == 32773, little))
            if samples_per_pixel == 4:
                rgba.push(_tiff_color_sample(raw_data, packbits_pixels, pixel_offset, 3, sample_bits, compression == 32773, little))
            else:
                rgba.push(255)
        pixel_index = pixel_index + 1

    Some(ImageData(width: width, height: height, format: ImageFormat.Tiff, data: rgba))

fn _tiff_strip_offset_count_needed(strip_count_needed: i64, samples_per_pixel: i64, planar_config: i64) -> i64:
    if planar_config == 2:
        return strip_count_needed * samples_per_pixel
    strip_count_needed

fn _tiff_planar_sample_byte(
    raw_data: text,
    strip_offset_entry: i64,
    strip_offset_count: i64,
    strip_byte_count_entry: i64,
    strip_byte_count_count: i64,
    row: i64,
    col: i64,
    width: i64,
    rows_per_strip: i64,
    strip_count_needed: i64,
    sample_plane: i64,
    little: bool
) -> i64:
    val strip_index = row / rows_per_strip
    val row_in_strip = row - strip_index * rows_per_strip
    val planar_strip_index = sample_plane * strip_count_needed + strip_index
    val strip_lookup_index = _tiff_strip_lookup_index(planar_strip_index, strip_offset_count)
    val byte_count_lookup_index = _tiff_strip_lookup_index(planar_strip_index, strip_byte_count_count)
    val strip_offset = _tiff_entry_value_at(raw_data, strip_offset_entry, strip_lookup_index, little)
    val strip_byte_count = _tiff_entry_value_at(raw_data, strip_byte_count_entry, byte_count_lookup_index, little)
    val sample_offset = strip_offset + row_in_strip * width + col
    if strip_offset <= 0 or sample_offset + 1 > raw_data.len():
        return 0
    if strip_byte_count > 0 and sample_offset + 1 > strip_offset + strip_byte_count:
        return 0
    _byte_at(raw_data, sample_offset)

fn _tiff_pixel_byte(raw_data: text, decoded_pixels: [i64], offset: i64, compressed: bool) -> i64:
    if compressed:
        return decoded_pixels[offset]
    _byte_at(raw_data, offset)

fn _tiff_gray_sample(raw_data: text, decoded_pixels: [i64], offset: i64, sample_bits: i64, compressed: bool, little: bool) -> i64:
    if sample_bits == 16:
        if compressed:
            val hi = decoded_pixels[offset + 1]
            val lo = decoded_pixels[offset]
            return (lo + hi * 256) / 257
        return _read_u16(raw_data, offset, little) / 257
    _tiff_pixel_byte(raw_data, decoded_pixels, offset, compressed)

fn _tiff_color_sample(raw_data: text, decoded_pixels: [i64], pixel_offset: i64, channel: i64, sample_bits: i64, compressed: bool, little: bool) -> i64:
    val channel_offset = pixel_offset + channel * _tiff_bytes_per_sample(sample_bits)
    if sample_bits == 16:
        if compressed:
            val hi = decoded_pixels[channel_offset + 1]
            val lo = decoded_pixels[channel_offset]
            return (lo + hi * 256) / 257
        return _read_u16(raw_data, channel_offset, little) / 257
    _tiff_pixel_byte(raw_data, decoded_pixels, channel_offset, compressed)

fn _tiff_decode_packbits_strips(
    data: text,
    strip_offset_entry: i64,
    strip_offset_count: i64,
    strip_byte_count_entry: i64,
    strip_byte_count_count: i64,
    strip_count_needed: i64,
    expected_len: i64,
    little: bool
) -> [i64]:
    var out: [i64] = []
    var strip_index = 0
    while strip_index < strip_count_needed and out.len() < expected_len:
        val strip_lookup_index = _tiff_strip_lookup_index(strip_index, strip_offset_count)
        val byte_count_lookup_index = _tiff_strip_lookup_index(strip_index, strip_byte_count_count)
        val strip_offset = _tiff_entry_value_at(data, strip_offset_entry, strip_lookup_index, little)
        val strip_byte_count = _tiff_entry_value_at(data, strip_byte_count_entry, byte_count_lookup_index, little)
        if strip_offset <= 0 or strip_byte_count <= 0 or strip_offset + strip_byte_count > data.len():
            return []
        val strip_end = strip_offset + strip_byte_count
        var pos = strip_offset
        while pos < strip_end and out.len() < expected_len:
            val header = _byte_at(data, pos)
            pos = pos + 1
            if header <= 127:
                val literal_count = header + 1
                if pos + literal_count > strip_end:
                    return []
                var i = 0
                while i < literal_count and out.len() < expected_len:
                    out.push(_byte_at(data, pos + i))
                    i = i + 1
                pos = pos + literal_count
            else if header == 128:
                pass_dn
            else:
                if pos >= strip_end:
                    return []
                val repeat_count = 257 - header
                val value = _byte_at(data, pos)
                pos = pos + 1
                var i = 0
                while i < repeat_count and out.len() < expected_len:
                    out.push(value)
                    i = i + 1
        strip_index = strip_index + 1
    out

fn _tiff_colormap_is_supported(data: text, entry: i64, value_count: i64, little: bool) -> bool:
    if entry <= 0 or value_count < 768:
        return false
    val typ = _read_u16(data, entry + 2, little)
    if typ != 3:
        return false
    val offset = _read_u32(data, entry + 8, little)
    offset > 0 and offset + value_count * 2 <= data.len()

fn _tiff_colormap_byte(data: text, entry: i64, value_count: i64, palette_index: i64, plane: i64, little: bool) -> i64:
    val entries_per_plane = value_count / 3
    if palette_index < 0 or palette_index >= entries_per_plane:
        return 0
    val offset = _read_u32(data, entry + 8, little)
    val value = _read_u16(data, offset + (plane * entries_per_plane + palette_index) * 2, little)
    value / 257

fn _tiff_strip_lookup_index(strip_index: i64, value_count: i64) -> i64:
    if value_count == 1:
        return 0
    strip_index

fn _tiff_cielab_pixel_to_argb(l_byte: i64, a_byte: i64, b_byte: i64) -> i64:
    val l = (l_byte as f64) * 100.0 / 255.0
    val a = (a_byte - 128) as f64
    val b = (b_byte - 128) as f64
    cie_lab_d50_to_srgb_packed_argb(CieLab(l: l, a: a, b: b, white_point: "D50"), 255)

fn _tiff_entry_first_value(data: text, entry: i64, little: bool) -> i64:
    _tiff_entry_value_at(data, entry, 0, little)

fn _tiff_entry_value_at(data: text, entry: i64, index: i64, little: bool) -> i64:
    val typ = _read_u16(data, entry + 2, little)
    val value_count = _read_u32(data, entry + 4, little)
    if value_count <= 0 or index < 0 or index >= value_count:
        return 0
    if typ == 3:
        if value_count <= 2:
            return _read_u16(data, entry + 8 + index * 2, little)
        val offset = _read_u32(data, entry + 8, little)
        if offset <= 0 or offset + (index + 1) * 2 > data.len():
            return 0
        return _read_u16(data, offset + index * 2, little)
    if typ == 4:
        if value_count == 1:
            return _read_u32(data, entry + 8, little)
        val offset = _read_u32(data, entry + 8, little)
        if offset <= 0 or offset + (index + 1) * 4 > data.len():
            return 0
        return _read_u32(data, offset + index * 4, little)
    0

fn _tiff_sample_bits(data: text, value_count: i64, inline_value: i64, offset: i64, little: bool) -> i64:
    if value_count == 1:
        return inline_value
    if offset <= 0 or offset + 2 > data.len():
        return 0
    _read_u16(data, offset, little)

fn _tiff_bytes_per_sample(sample_bits: i64) -> i64:
    if sample_bits == 16:
        return 2
    1

fn _tiff_bits_are_supported(data: text, value_count: i64, inline_value: i64, offset: i64, samples_per_pixel: i64, compression: i64, photometric: i64, planar_config: i64, little: bool) -> bool:
    val sample_bits = _tiff_sample_bits(data, value_count, inline_value, offset, little)
    if sample_bits == 16:
        if compression != 1 or planar_config != 1:
            return false
        if photometric != 0 and photometric != 1 and photometric != 2:
            return false
        if value_count == 1:
            return samples_per_pixel == 1
        return value_count == samples_per_pixel and _tiff_sample_bits_all_equal(data, value_count, offset, 16, little)
    if sample_bits != 8:
        return false
    if value_count == 1:
        return true
    if value_count != samples_per_pixel:
        return false
    if offset <= 0 or offset + value_count * 2 > data.len():
        return false
    var i = 0
    while i < value_count:
        if _read_u16(data, offset + i * 2, little) != 8:
            return false
        i = i + 1
    true

fn _tiff_sample_bits_all_equal(data: text, value_count: i64, offset: i64, expected: i64, little: bool) -> bool:
    if offset <= 0 or offset + value_count * 2 > data.len():
        return false
    var i = 0
    while i < value_count:
        if _read_u16(data, offset + i * 2, little) != expected:
            return false
        i = i + 1
    true

# Read a 4-byte ASCII chunk type.
fn _read_chunk_type(data: text, offset: i64) -> text:
    var result = ""
    var i = 0
    while i < 4:
        val ch = _byte_at(data, offset + i)
        result = result + _byte_to_char(ch)
        i = i + 1
    result

# Convert a byte value to a single ASCII character.
fn _byte_to_char(b: i64) -> text:
    # Use text.from_byte or equivalent
    if b >= 65 and b <= 90:
        # Uppercase A-Z
        val chars = "ABCDEFGHIJKLMNOPQRSTUVWXYZ"
        return chars.slice(b - 65, b - 65 + 1)
    if b >= 97 and b <= 122:
        # Lowercase a-z
        val chars = "abcdefghijklmnopqrstuvwxyz"
        return chars.slice(b - 97, b - 97 + 1)
    if b >= 48 and b <= 57:
        val chars = "0123456789"
        return chars.slice(b - 48, b - 48 + 1)
    if b == 32:
        return " "
    "?"

fn _has_ascii_at(data: text, offset: i64, expected: text) -> bool:
    if offset < 0 or offset + expected.len() > data.len():
        return false
    if expected.len() == 4:
        return _read_chunk_type(data, offset) == expected
    data.slice(offset, offset + expected.len()) == expected

fn _is_svg_data(data: text) -> bool:
    var start = 0
    while start < data.len() and _is_ascii_ws(_byte_at(data, start)):
        start = start + 1
    if start + 4 <= data.len() and data.slice(start, start + 4).to_lower() == "<svg":
        return true
    if start + 5 <= data.len() and data.slice(start, start + 5).to_lower() == "<?xml":
        val sample_end = if data.len() < 256: data.len() else: 256
        val sample = data.slice(start, sample_end).to_lower()
        return sample.contains("<svg")
    false

fn _is_ascii_ws(byte: i64) -> bool:
    byte == 32 or byte == 9 or byte == 10 or byte == 13

fn _svg_dimension(data: text, name: text, fallback: i64) -> i64:
    val lower = data.to_lower()
    val svg_pos = lower.index_of("<svg")
    if svg_pos < 0:
        return fallback
    val root_tail = lower.slice(svg_pos, lower.len())
    val root_end = root_tail.index_of(">")
    val search_end = if root_end >= 0: svg_pos + root_end else: data.len()
    val attr_pos = lower.index_of(name, svg_pos)
    if attr_pos < 0 or attr_pos > search_end:
        return fallback

    var pos = attr_pos + name.len()
    while pos < search_end and _is_ascii_ws(_byte_at(data, pos)):
        pos = pos + 1
    if pos >= search_end or _byte_at(data, pos) != 61:
        return fallback
    pos = pos + 1
    while pos < search_end and _is_ascii_ws(_byte_at(data, pos)):
        pos = pos + 1

    var quote = 0
    if pos < search_end:
        val q = _byte_at(data, pos)
        if q == 34 or q == 39:
            quote = q
            pos = pos + 1

    val number_start = pos
    while pos < search_end and _is_svg_number_byte(_byte_at(data, pos)):
        pos = pos + 1
    if pos <= number_start:
        return fallback
    val number_end = pos
    if quote != 0 and (pos >= search_end or _byte_at(data, pos) != quote):
        # Unit suffixes such as px are allowed before the closing quote.
        while pos < search_end and _byte_at(data, pos) != quote and not _is_ascii_ws(_byte_at(data, pos)):
            pos = pos + 1

    val number_text = data.slice(number_start, number_end)
    val parsed = number_text.to_f64()
    if parsed <= 0.0:
        return fallback
    parsed.to_i64()

fn _is_svg_number_byte(byte: i64) -> bool:
    (byte >= 48 and byte <= 57) or byte == 46

# Determine bytes per pixel from PNG color type and bit depth.
fn _bytes_per_pixel(color_type: i64, bit_depth: i64) -> i64:
    val bits_per_channel = bit_depth
    match color_type:
        0: 1  # Grayscale
        2: 3  # RGB
        3: 1  # Indexed (palette)
        4: 2  # Grayscale + Alpha
        6: 4  # RGBA
        _: 4

# ---------------------------------------------------------------------------
# DEFLATE Decompression (RFC 1951)
# ---------------------------------------------------------------------------

# Minimal DEFLATE inflater — handles uncompressed and fixed Huffman blocks.
# skip_bytes: number of header bytes to skip (e.g. 2 for zlib header).
fn _inflate(compressed: [i64], skip_bytes: i64) -> [i64]:
    var output = []
    var bit_pos = skip_bytes * 8  # current bit position
    val total_bits = compressed.len() * 8

    var done = false
    while not done:
        if bit_pos + 3 > total_bits:
            done = true
        else:
            val bfinal = _read_bits(compressed, bit_pos, 1)
            bit_pos = bit_pos + 1
            val btype = _read_bits(compressed, bit_pos, 2)
            bit_pos = bit_pos + 2

            if btype == 0:
                # Uncompressed block
                # Align to byte boundary
                val byte_aligned = ((bit_pos + 7) / 8) * 8
                bit_pos = byte_aligned
                val byte_off = bit_pos / 8
                val block_len = _get_byte(compressed, byte_off) + _get_byte(compressed, byte_off + 1) * 256
                bit_pos = bit_pos + 32  # skip LEN and NLEN
                var i = 0
                while i < block_len:
                    output.push(_get_byte(compressed, bit_pos / 8))
                    bit_pos = bit_pos + 8
                    i = i + 1
            else if btype == 1:
                # Fixed Huffman codes
                val inflate_result = _inflate_fixed_huffman(compressed, bit_pos, output)
                bit_pos = inflate_result.first
                output = inflate_result.second
            else if btype == 2:
                # Dynamic Huffman codes — fall back to fixed for simplicity
                val inflate_result = _inflate_fixed_huffman(compressed, bit_pos, output)
                bit_pos = inflate_result.first
                output = inflate_result.second
            else:
                done = true  # Invalid block type

            if bfinal == 1:
                done = true

    output

# Inflate a fixed Huffman block.
# Returns (new_bit_pos, output_data).
fn _inflate_fixed_huffman(data: [i64], start_bit: i64, output: [i64]) -> Pair<i64, [i64]>:
    var bit_pos = start_bit
    var out = output
    val total_bits = data.len() * 8

    var block_done = false
    while not block_done:
        if bit_pos + 7 > total_bits:
            block_done = true
        else:
            # Decode a fixed Huffman literal/length symbol
            val symbol_result = _decode_fixed_lit(data, bit_pos)
            val symbol = symbol_result.first
            bit_pos = symbol_result.second

            if symbol < 256:
                # Literal byte
                out.push(symbol)
            else if symbol == 256:
                # End of block
                block_done = true
            else:
                # Length-distance pair (LZ77 back-reference)
                val length = _decode_length(symbol, data, bit_pos)
                bit_pos = bit_pos + _length_extra_bits(symbol)

                # Decode distance (5-bit fixed code, reversed)
                val dist_code = _read_bits_rev(data, bit_pos, 5)
                bit_pos = bit_pos + 5
                val distance = _decode_distance(dist_code, data, bit_pos)
                bit_pos = bit_pos + _distance_extra_bits(dist_code)

                # Copy from sliding window
                var i = 0
                while i < length:
                    val src_idx = out.len() - distance
                    if src_idx >= 0 and src_idx < out.len():
                        out.push(out.get(src_idx))
                    else:
                        out.push(0)
                    i = i + 1

    Pair(first: bit_pos, second: out)

# Decode a fixed Huffman literal/length code.
# Returns (symbol, new_bit_pos).
fn _decode_fixed_lit(data: [i64], bit_pos: i64) -> Pair<i64, i64>:
    # Fixed Huffman code table:
    # 0-143: 8-bit codes 00110000-10111111 (values 48-191)
    # 144-255: 9-bit codes 110010000-111111111
    # 256-279: 7-bit codes 0000000-0010111
    # 280-287: 8-bit codes 11000000-11000111

    # Try 7-bit code first (256-279)
    val code7 = _read_bits_rev(data, bit_pos, 7)
    if code7 >= 0 and code7 <= 23:
        return Pair(first: 256 + code7, second: bit_pos + 7)

    # Try 8-bit code (0-143 or 280-287)
    val code8 = _read_bits_rev(data, bit_pos, 8)
    if code8 >= 48 and code8 <= 191:
        return Pair(first: code8 - 48, second: bit_pos + 8)
    if code8 >= 192 and code8 <= 199:
        return Pair(first: 280 + (code8 - 192), second: bit_pos + 8)

    # Try 9-bit code (144-255)
    val code9 = _read_bits_rev(data, bit_pos, 9)
    if code9 >= 400 and code9 <= 511:
        return Pair(first: 144 + (code9 - 400), second: bit_pos + 9)

    # Fallback: treat as end of block
    Pair(first: 256, second: bit_pos + 7)

# Read N bits from a byte array at a bit offset (LSB first).
fn _read_bits(data: [i64], bit_pos: i64, count: i64) -> i64:
    var result = 0
    var i = 0
    while i < count:
        val byte_idx = (bit_pos + i) / 8
        val bit_idx = (bit_pos + i) % 8
        val byte_val = _get_byte(data, byte_idx)
        val bit_val = (byte_val / _pow2(bit_idx)) % 2
        result = result + bit_val * _pow2(i)
        i = i + 1
    result

# Read N bits in reverse order (MSB first, for Huffman codes).
fn _read_bits_rev(data: [i64], bit_pos: i64, count: i64) -> i64:
    var result = 0
    var i = 0
    while i < count:
        val byte_idx = (bit_pos + i) / 8
        val bit_idx = (bit_pos + i) % 8
        val byte_val = _get_byte(data, byte_idx)
        val bit_val = (byte_val / _pow2(bit_idx)) % 2
        result = result * 2 + bit_val
        i = i + 1
    result

# Safely get a byte from a list, returning 0 for out-of-bounds.
fn _get_byte(data: [i64], idx: i64) -> i64:
    if idx >= 0 and idx < data.len():
        val v = data.get(idx)
        if val b = v:
            return b
    0

# Power of 2 lookup.
fn _pow2(n: i64) -> i64:
    if n <= 0: return 1
    if n == 1: return 2
    if n == 2: return 4
    if n == 3: return 8
    if n == 4: return 16
    if n == 5: return 32
    if n == 6: return 64
    if n == 7: return 128
    if n == 8: return 256
    if n == 9: return 512
    if n == 10: return 1024
    if n == 11: return 2048
    if n == 12: return 4096
    if n == 13: return 8192
    if n == 14: return 16384
    if n == 15: return 32768
    # For larger values, compute iteratively
    var result = 1
    var i = 0
    while i < n:
        result = result * 2
        i = i + 1
    result

# Decode length from a length code (257-285).
fn _decode_length(code: i64, data: [i64], bit_pos: i64) -> i64:
    if code <= 264: return code - 257 + 3
    if code == 285: return 258
    # Codes 265-284 have extra bits
    val group = (code - 261) / 4
    val extra = _length_extra_bits(code)
    val base_len = _length_base(code)
    val extra_val = _read_bits(data, bit_pos, extra)
    base_len + extra_val

# Get number of extra bits for a length code.
fn _length_extra_bits(code: i64) -> i64:
    if code <= 264: return 0
    if code == 285: return 0
    val group = (code - 265) / 4 + 1
    if group > 5: return 5
    group

# Get the base length for a length code.
fn _length_base(code: i64) -> i64:
    if code == 265: return 11
    if code == 266: return 13
    if code == 267: return 15
    if code == 268: return 17
    if code == 269: return 19
    if code == 270: return 23
    if code == 271: return 27
    if code == 272: return 31
    if code == 273: return 35
    if code == 274: return 43
    if code == 275: return 51
    if code == 276: return 59
    if code == 277: return 67
    if code == 278: return 83
    if code == 279: return 99
    if code == 280: return 115
    if code == 281: return 131
    if code == 282: return 163
    if code == 283: return 195
    if code == 284: return 227
    3

# Decode distance from a distance code (0-29).
fn _decode_distance(code: i64, data: [i64], bit_pos: i64) -> i64:
    if code <= 3: return code + 1
    val extra = _distance_extra_bits(code)
    val base_dist = _distance_base(code)
    val extra_val = _read_bits(data, bit_pos, extra)
    base_dist + extra_val

# Get number of extra bits for a distance code.
fn _distance_extra_bits(code: i64) -> i64:
    if code <= 3: return 0
    val group = (code - 4) / 2 + 1
    if group > 13: return 13
    group

# Get the base distance for a distance code.
fn _distance_base(code: i64) -> i64:
    if code == 4: return 5
    if code == 5: return 7
    if code == 6: return 9
    if code == 7: return 13
    if code == 8: return 17
    if code == 9: return 25
    if code == 10: return 33
    if code == 11: return 49
    if code == 12: return 65
    if code == 13: return 97
    if code == 14: return 129
    if code == 15: return 193
    if code == 16: return 257
    if code == 17: return 385
    if code == 18: return 513
    if code == 19: return 769
    if code == 20: return 1025
    if code == 21: return 1537
    if code == 22: return 2049
    if code == 23: return 3073
    if code == 24: return 4097
    if code == 25: return 6145
    if code == 26: return 8193
    if code == 27: return 12289
    if code == 28: return 16385
    if code == 29: return 24577
    1

# ---------------------------------------------------------------------------
# PNG Filter Reconstruction
# ---------------------------------------------------------------------------

# Reconstruct pixels from filtered scanlines.
# Each scanline is prefixed with a 1-byte filter type.
fn _reconstruct_scanlines(data: [i64], width: i64, height: i64, bpp: i64, stride: i64) -> [i64]:
    var pixels = []
    var prev_row = []
    # Initialize previous row to zeros
    var init = 0
    while init < stride:
        prev_row.push(0)
        init = init + 1

    var row = 0
    var data_pos = 0
    while row < height:
        # Read filter type byte
        val filter_type = _safe_get_list(data, data_pos)
        data_pos = data_pos + 1

        var current_row = []
        var col = 0
        while col < stride:
            val raw_byte = _safe_get_list(data, data_pos)
            data_pos = data_pos + 1

            var reconstructed = 0
            match filter_type:
                0:
                    # None
                    reconstructed = raw_byte
                1:
                    # Sub: Recon(x) = Filt(x) + Recon(a)
                    val a = if col >= bpp: _safe_get_list_from(current_row, col - bpp) else: 0
                    reconstructed = (raw_byte + a) % 256
                2:
                    # Up: Recon(x) = Filt(x) + Recon(b)
                    val b = _safe_get_list_from(prev_row, col)
                    reconstructed = (raw_byte + b) % 256
                3:
                    # Average: Recon(x) = Filt(x) + floor((Recon(a) + Recon(b)) / 2)
                    val a = if col >= bpp: _safe_get_list_from(current_row, col - bpp) else: 0
                    val b = _safe_get_list_from(prev_row, col)
                    reconstructed = (raw_byte + (a + b) / 2) % 256
                4:
                    # Paeth: Recon(x) = Filt(x) + PaethPredictor(a, b, c)
                    val a = if col >= bpp: _safe_get_list_from(current_row, col - bpp) else: 0
                    val b = _safe_get_list_from(prev_row, col)
                    val c = if col >= bpp: _safe_get_list_from(prev_row, col - bpp) else: 0
                    val paeth = _paeth_predictor(a, b, c)
                    reconstructed = (raw_byte + paeth) % 256
                _:
                    reconstructed = raw_byte

            current_row.push(reconstructed)
            pixels.push(reconstructed)
            col = col + 1

        prev_row = current_row
        row = row + 1

    pixels

# Paeth predictor function per PNG spec.
fn _paeth_predictor(a: i64, b: i64, c: i64) -> i64:
    val p = a + b - c
    val pa = _abs_i64(p - a)
    val pb = _abs_i64(p - b)
    val pc = _abs_i64(p - c)
    if pa <= pb and pa <= pc:
        return a
    if pb <= pc:
        return b
    c

# Convert decoded pixel data to RGBA format.
fn _to_rgba(pixels: [i64], width: i64, height: i64, color_type: i64, bpp: i64, palette: [i64], palette_alpha: [i64]) -> [i64]:
    var rgba = []
    val total = width * height
    var i = 0
    match color_type:
        0:
            # Grayscale -> RGBA
            while i < total:
                val g = _safe_get_list(pixels, i)
                rgba.push(g)
                rgba.push(g)
                rgba.push(g)
                rgba.push(255)
                i = i + 1
        2:
            # RGB -> RGBA
            while i < total:
                val idx = i * 3
                rgba.push(_safe_get_list(pixels, idx))
                rgba.push(_safe_get_list(pixels, idx + 1))
                rgba.push(_safe_get_list(pixels, idx + 2))
                rgba.push(255)
                i = i + 1
        3:
            # Indexed color -> RGBA using PLTE and optional tRNS alpha.
            while i < total:
                val palette_index = _safe_get_list(pixels, i)
                val palette_base = palette_index * 3
                if palette_base + 2 < palette.len():
                    rgba.push(_safe_get_list(palette, palette_base))
                    rgba.push(_safe_get_list(palette, palette_base + 1))
                    rgba.push(_safe_get_list(palette, palette_base + 2))
                    if palette_index < palette_alpha.len():
                        rgba.push(_safe_get_list(palette_alpha, palette_index))
                    else:
                        rgba.push(255)
                else:
                    rgba.push(0)
                    rgba.push(0)
                    rgba.push(0)
                    rgba.push(255)
                i = i + 1
        4:
            # Grayscale+Alpha -> RGBA
            while i < total:
                val idx = i * 2
                val g = _safe_get_list(pixels, idx)
                val a = _safe_get_list(pixels, idx + 1)
                rgba.push(g)
                rgba.push(g)
                rgba.push(g)
                rgba.push(a)
                i = i + 1
        6:
            # Already RGBA
            while i < total:
                val idx = i * 4
                rgba.push(_safe_get_list(pixels, idx))
                rgba.push(_safe_get_list(pixels, idx + 1))
                rgba.push(_safe_get_list(pixels, idx + 2))
                rgba.push(_safe_get_list(pixels, idx + 3))
                i = i + 1
        _:
            # Unknown — fill with gray
            while i < total:
                rgba.push(128)
                rgba.push(128)
                rgba.push(128)
                rgba.push(255)
                i = i + 1
    rgba

# ---------------------------------------------------------------------------
# Integer math helpers
# ---------------------------------------------------------------------------

fn _abs_i64(x: i64) -> i64:
    if x < 0: return -x
    x

fn _floor_i64(x: f64) -> i64:
    # Truncate toward zero (sufficient for positive values in scaling)
    val i = x
    i

fn _clamp_byte(x: f64) -> i64:
    if x < 0.0: return 0
    if x > 255.0: return 255
    val i = x + 0.5
    i

fn _safe_get(data: [i64], idx: i64) -> i64:
    if idx >= 0 and idx < data.len():
        val v = data.get(idx)
        if val b = v:
            return b
    0

fn _safe_get_list(data: [i64], idx: i64) -> i64:
    if idx >= 0 and idx < data.len():
        val v = data.get(idx)
        if val b = v:
            return b
    0

fn _safe_get_list_from(data: [i64], idx: i64) -> i64:
    if idx >= 0 and idx < data.len():
        val v = data.get(idx)
        if val b = v:
            return b
    0
