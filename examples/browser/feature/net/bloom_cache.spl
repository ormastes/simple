#![allow(REQC001)]
#![allow(REQC004)]

# Counting bloom filter for HTTP cache freshness validation.
# Uses double hashing (FNV-1a + DJB2) to generate k hash positions.
# Counting allows removal (decrement counters) unlike standard bloom filters.

class BloomBitArray:
    counters: [i64]
    capacity: i64

    static fn new(size: i64) -> BloomBitArray:
        var counters: [i64] = []
        var i = 0
        while i < size:
            counters.push(0)
            i = i + 1
        BloomBitArray(
            counters: counters,
            capacity: size
        )

    me set(index: i64) -> void:
        self.increment(index)

    me get(index: i64) -> bool:
        if index < 0 or index >= self.capacity:
            return false
        self.counters.get(index) > 0

    me increment(index: i64) -> void:
        if index < 0 or index >= self.capacity:
            return
        val cur = self.counters.get(index)
        self.counters.set(index, cur + 1)

    me decrement(index: i64) -> void:
        if index < 0 or index >= self.capacity:
            return
        val cur = self.counters.get(index)
        if cur > 0:
            self.counters.set(index, cur - 1)

    me clear() -> void:
        var i = 0
        while i < self.capacity:
            self.counters.set(i, 0)
            i = i + 1

    me size() -> i64:
        self.capacity


fn _fnv1a_hash(key: text) -> i64:
    var hash = 2166136261
    var i = 0
    while i < key.len():
        val b = key.char_at(i)
        hash = hash ^ b
        hash = hash * 16777619
        hash = hash % 4294967296
        i = i + 1
    hash

fn _djb2_hash(key: text) -> i64:
    var hash = 5381
    var i = 0
    while i < key.len():
        val b = key.char_at(i)
        hash = hash * 33 + b
        hash = hash % 4294967296
        i = i + 1
    hash

fn _double_hash_pos(h1: i64, h2: i64, iter: i64, m: i64) -> i64:
    (h1 + iter * h2) % m


class CacheFreshnessFilter:
    bits: BloomBitArray
    timestamps: [i64]
    num_bits: i64
    num_hashes: i64
    count: i64

    static fn new(expected_items: i64, false_positive_rate: f64) -> CacheFreshnessFilter:
        # m ≈ n * 10 for 1% FPR (integer approximation of -n*ln(p)/ln(2)^2)
        val m = expected_items * 10
        val k = 7
        var timestamps: [i64] = []
        var i = 0
        while i < m:
            timestamps.push(0)
            i = i + 1
        CacheFreshnessFilter(
            bits: BloomBitArray.new(m),
            timestamps: timestamps,
            num_bits: m,
            num_hashes: k,
            count: 0
        )

    me insert(url: text, etag: text, last_modified: i64) -> void:
        val key = url
        val h1 = _fnv1a_hash(key)
        val h2 = _djb2_hash(key)
        val now = last_modified
        var i = 0
        while i < self.num_hashes:
            val pos = _double_hash_pos(h1, h2, i, self.num_bits)
            self.bits.increment(pos)
            if i == 0:
                self.timestamps.set(pos, now)
            i = i + 1
        self.count = self.count + 1

    me query(url: text) -> bool:
        val key = url
        val h1 = _fnv1a_hash(key)
        val h2 = _djb2_hash(key)
        var i = 0
        while i < self.num_hashes:
            val pos = _double_hash_pos(h1, h2, i, self.num_bits)
            if not self.bits.get(pos):
                return false
            i = i + 1
        true

    me remove(url: text) -> void:
        val key = url
        val h1 = _fnv1a_hash(key)
        val h2 = _djb2_hash(key)
        var i = 0
        while i < self.num_hashes:
            val pos = _double_hash_pos(h1, h2, i, self.num_bits)
            self.bits.decrement(pos)
            i = i + 1
        if self.count > 0:
            self.count = self.count - 1

    me is_fresh(url: text, now: i64, max_age: i64) -> bool:
        if not self.query(url):
            return false
        val h1 = _fnv1a_hash(url)
        val h2 = _djb2_hash(url)
        val pos = _double_hash_pos(h1, h2, 0, self.num_bits)
        val stored_at = self.timestamps.get(pos)
        stored_at + max_age > now

    me clear() -> void:
        self.bits.clear()
        var i = 0
        while i < self.num_bits:
            self.timestamps.set(i, 0)
            i = i + 1
        self.count = 0

    me item_count() -> i64:
        self.count

    me bit_count() -> i64:
        self.num_bits

    me hash_count() -> i64:
        self.num_hashes

    me false_positive_rate() -> f64:
        0.01
