# DNS resolver with caching for the Simple Browser Platform.
# Provides hostname-to-address resolution with a TTL-based cache layer.
# Cache entries expire after a configurable TTL to ensure freshness.
# The actual system DNS lookup is stubbed for platform portability.

use examples.browser.shared.error {BrowserError, BrowserResult, network_error}
use examples.browser.shared.logging {Logger, LogLevel}
use std.io_runtime.{time_now_unix_micros}

# A single cached DNS entry: resolved addresses plus a timestamp and TTL.
class DnsCacheEntry:
    hostname: text
    addresses: [text]
    created_at: i64
    ttl: i64

    static fn create(hostname: text, addresses: [text], created_at: i64, ttl: i64) -> DnsCacheEntry:
        DnsCacheEntry(
            hostname: hostname,
            addresses: addresses,
            created_at: created_at,
            ttl: ttl
        )

    fn is_expired(now: i64) -> bool:
        now - self.created_at > self.ttl

# In-memory DNS cache keyed by hostname.
# Stores resolved addresses with per-entry TTL expiration.
class DnsCache:
    entries: [DnsCacheEntry]
    max_ttl: i64

    static fn create(max_ttl: i64) -> DnsCache:
        DnsCache(entries: [], max_ttl: max_ttl)

    # Look up a hostname in the cache. Returns nil if not found or expired.
    me lookup(hostname: text, now: i64) -> [text]?:
        val index = self.find_index(hostname)
        if index >= 0:
            val e = self.entries[index]
            if e.is_expired(now):
                self.remove_at(index)
                return nil
            return e.addresses
        nil

    # Store resolved addresses for a hostname with the given TTL.
    # The TTL is clamped to the cache-wide max_ttl.
    me store(hostname: text, addresses: [text], now: i64, ttl: i64):
        val effective_ttl = if ttl > self.max_ttl: self.max_ttl else: ttl
        val entry = DnsCacheEntry.create(hostname, addresses, now, effective_ttl)
        val index = self.find_index(hostname)
        if index >= 0:
            self.entries[index] = entry
        else:
            self.entries = self.entries + [entry]

    # Remove a specific hostname from the cache.
    me invalidate(hostname: text):
        val index = self.find_index(hostname)
        if index >= 0:
            self.remove_at(index)

    # Remove all entries from the cache.
    me flush():
        self.entries = []

    fn size() -> i64:
        self.entries.len()

    fn find_index(hostname: text) -> i64:
        var i = 0
        while i < self.entries.len():
            if self.entries[i].hostname == hostname:
                return i
            i = i + 1
        -1

    me remove_at(index: i64):
        var result: [DnsCacheEntry] = []
        var i = 0
        while i < self.entries.len():
            if i != index:
                result = result + [self.entries[i]]
            i = i + 1
        self.entries = result

# DNS resolver with an integrated TTL cache.
# Checks the cache before performing a system DNS lookup.
class DnsResolver:
    cache: DnsCache
    logger: Logger
    default_ttl: i64
    extra_hosts: [DnsCacheEntry]

    static fn new(logger: Logger, cache_ttl: i64) -> DnsResolver:
        DnsResolver(
            cache: DnsCache.create(cache_ttl),
            logger: logger,
            default_ttl: cache_ttl,
            extra_hosts: []
        )

    # Resolve a hostname to a list of IP address strings.
    # Returns cached addresses if available and not expired.
    # Falls back to a system DNS lookup and caches the result.
    me resolve(hostname: text) -> BrowserResult<[text]>:
        self.logger.debug("dns: resolving {hostname}")

        # Fast path: check the cache first
        val cached = self.cache_lookup(hostname)
        if cached.?:
            val addrs = cached.unwrap()
            self.logger.debug("dns: cache hit for {hostname} ({addrs.len()} addresses)")
            return Ok(addrs)

        # Slow path: perform system DNS lookup
        self.logger.info("dns: cache miss for {hostname}, performing lookup")
        val result = self.system_lookup(hostname)
        match result:
            Ok(addresses):
                if addresses.is_empty():
                    self.logger.warn("dns: lookup returned no addresses for {hostname}")
                    return Err(network_error("DNS resolution failed: no addresses for {hostname}"))
                self.logger.debug("dns: resolved {hostname} to {addresses.len()} addresses")
                val now = self.current_time()
                self.cache.store(hostname, addresses, now, self.default_ttl)
                Ok(addresses)
            Err(e):
                self.logger.error("dns: lookup failed for {hostname}: {e.message}")
                Err(e)

    # Check the cache for a hostname. Returns the address list or nil if expired/missing.
    me cache_lookup(hostname: text) -> [text]?:
        val now = self.current_time()
        self.cache.lookup(hostname, now)

    # Remove a single hostname from the cache, forcing re-resolution on next access.
    me invalidate(hostname: text):
        self.logger.debug("dns: invalidating cache for {hostname}")
        self.cache.invalidate(hostname)

    # Clear the entire DNS cache.
    me flush_cache():
        self.logger.info("dns: flushing entire cache ({self.cache.size()} entries)")
        self.cache.flush()

    # Perform the actual system DNS lookup.
    # This is the platform boundary; returns resolved IP addresses for a hostname.
    # Handles special cases (localhost, IP literals) directly.
    me system_lookup(hostname: text) -> BrowserResult<[text]>:
        # Handle localhost directly
        if hostname == "localhost":
            return Ok(["127.0.0.1"])

        # Handle IP address literals (no lookup needed)
        if self.is_ip_literal(hostname):
            return Ok([hostname])

        # Validate hostname before attempting lookup
        if not self.is_valid_hostname(hostname):
            return Err(network_error("Invalid hostname: {hostname}"))

            # No stdlib DNS module available — use a built-in well-known host table.
        # This covers common development and testing scenarios.
        val well_known = self.well_known_lookup(hostname)
        if well_known.?:
            val addrs = well_known.unwrap()
            self.logger.debug("dns: resolved {hostname} via well-known table ({addrs.len()} addresses)")
            return Ok(addrs)

        self.logger.warn("dns: no well-known entry for {hostname} — real DNS resolution requires stdlib net module")
        Err(network_error("DNS resolution for '{hostname}' unavailable: no stdlib net module. Add entry via dns.add_well_known() or use a known host."))

    # Look up a hostname in the built-in well-known host table.
    # Returns addresses for common hosts used in development and testing.
    fn well_known_lookup(hostname: text) -> [text]?:
        val h = hostname.to_lower()
        if h == "localhost":
            return ["127.0.0.1", "::1"]
        if h == "ip6-localhost" or h == "ip6-loopback":
            return ["::1"]
        if h == "broadcasthost":
            return ["255.255.255.255"]
        # Common well-known domains for testing
        if h == "example.com" or h == "www.example.com":
            return ["93.184.216.34"]
        if h == "example.org" or h == "www.example.org":
            return ["93.184.216.34"]
        if h == "example.net" or h == "www.example.net":
            return ["93.184.216.34"]
        # Check additional entries added at runtime
        var i = 0
        while i < self.extra_hosts.len():
            val entry = self.extra_hosts[i]
            if entry.hostname.to_lower() == h:
                return entry.addresses
            i = i + 1
        nil

    # Register an additional hostname-to-address mapping for the well-known table.
    # Use this to add custom entries for testing or development.
    me add_well_known(hostname: text, addresses: [text]):
        self.logger.debug("dns: adding well-known entry: {hostname} -> {addresses.len()} addresses")
        val entry = DnsCacheEntry.create(hostname, addresses, 0, 0)
        self.extra_hosts = self.extra_hosts + [entry]

    # Check whether a string looks like an IPv4 address literal.
    fn is_ip_literal(s: text) -> bool:
        val parts = s.split(".")
        if parts.len() != 4:
            return false
        var all_numeric = true
        for part in parts:
            if part.is_empty():
                all_numeric = false
            for ch in part.chars():
                if not ch.is_digit():
                    all_numeric = false
        all_numeric

    # Basic hostname validation: non-empty, no spaces, reasonable length.
    fn is_valid_hostname(hostname: text) -> bool:
        if hostname.is_empty():
            return false
        if hostname.len() > 253:
            return false
        if hostname.contains(" "):
            return false
        val labels = hostname.split(".")
        for label in labels:
            if label.is_empty():
                return false
            if label.len() > 63:
                return false
        true

    # Return the current monotonic time in seconds.
    # Used for cache expiration calculations.
    fn current_time() -> i64:
        # Use runtime wall clock seconds for cache expiration.
        time_now_unix_micros() / 1_000_000
