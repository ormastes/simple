# Cookie store with domain/path scoping for the Simple Browser Platform.
# Implements RFC 6265 cookie management: setting, retrieval with domain/path
# matching, expiration, and Set-Cookie header parsing.

use examples.browser.entity.net.cookie_types.(Cookie, CookieJar, SameSite)
use examples.browser.entity.net.url_types.Url
use examples.browser.shared.error.(BrowserResult, BrowserError, network_error, parse_error)
use examples.browser.shared.logging.Logger
use std.io_runtime.time

# Maximum cookies per domain (RFC 6265 recommends at least 50)
val MAX_COOKIES_PER_DOMAIN = 50

# Maximum total cookies
val MAX_TOTAL_COOKIES = 3000

# --- CookieStore ---

class CookieStore:
    cookies: List<Cookie>
    logger: Logger

    static fn new(logger: Logger) -> CookieStore:
        CookieStore(cookies: List<Cookie>(), logger: logger)

    me set_cookie(cookie: Cookie) -> BrowserResult<()>:
        # Add or update a cookie. If a cookie with the same name+domain+path
        # exists, replace it. Enforces per-domain and total limits.
        val name = cookie.name
        val domain = cookie.domain
        val path = cookie.path

        # Validate cookie name is non-empty
        if name.len() == 0:
            return Err(parse_error("Cookie name cannot be empty"))

        # Remove existing cookie with same name+domain+path
        self.remove_matching(name, domain, path)

        # Check per-domain limit
        val domain_count = self.count_for_domain(domain)
        if domain_count >= MAX_COOKIES_PER_DOMAIN:
            self.logger.warn("Per-domain cookie limit reached for {domain}, evicting oldest")
            self.evict_oldest_for_domain(domain)

        # Check total limit
        if self.cookies.len() >= MAX_TOTAL_COOKIES:
            self.logger.warn("Total cookie limit reached, evicting oldest")
            self.evict_oldest()

        self.cookies.push(cookie)
        self.logger.debug("Set cookie: {name} for domain={domain} path={path}")
        Ok(())

    me get_cookies(url: Url) -> List<Cookie>:
        # Return all cookies that match the given URL.
        # Checks domain, path, secure flag, and expiration.
        val now = time.now_seconds()
        val is_secure = url.scheme == "https"
        val request_domain = url.host
        val request_path = if url.path.len() > 0: url.path else: "/"

        var result = List<Cookie>()
        var i = 0
        while i < self.cookies.len():
            val cookie = self.cookies.get(i)
            if should_send(cookie, url, is_secure):
                # Also check expiration (0 means session cookie — always valid)
                if cookie.expires == 0 or cookie.expires > now:
                    result.push(cookie)
            i = i + 1
        result

    me remove_cookie(name: text, domain: text) -> bool:
        # Remove a specific cookie by name and domain.
        var i = 0
        while i < self.cookies.len():
            val cookie = self.cookies.get(i)
            if cookie.name == name and cookie.domain == domain:
                self.cookies.remove(i)
                self.logger.debug("Removed cookie: {name} for domain={domain}")
                return true
            i = i + 1
        false

    me clear_expired():
        # Remove all expired cookies. Session cookies (expires == 0) are kept.
        val now = time.now_seconds()
        var i = 0
        while i < self.cookies.len():
            val cookie = self.cookies.get(i)
            if cookie.expires > 0 and cookie.expires <= now:
                self.cookies.remove(i)
                self.logger.debug("Cleared expired cookie: {cookie.name}")
                # Don't increment i — list shifted
            else:
                i = i + 1

    me clear_for_domain(domain: text):
        # Remove all cookies for a specific domain.
        var i = 0
        while i < self.cookies.len():
            val cookie = self.cookies.get(i)
            if cookie.domain == domain:
                self.cookies.remove(i)
            else:
                i = i + 1
        self.logger.info("Cleared all cookies for domain={domain}")

    # --- internal mutation helpers ---

    me remove_matching(name: text, domain: text, path: text):
        # Remove a cookie with exact name+domain+path match.
        var i = 0
        while i < self.cookies.len():
            val cookie = self.cookies.get(i)
            if cookie.name == name and cookie.domain == domain and cookie.path == path:
                self.cookies.remove(i)
                return
            i = i + 1

    me count_for_domain(domain: text) -> i64:
        var count: i64 = 0
        var i = 0
        while i < self.cookies.len():
            if self.cookies.get(i).domain == domain:
                count = count + 1
            i = i + 1
        count

    me evict_oldest_for_domain(domain: text):
        # Remove the first (oldest) cookie for a domain.
        var i = 0
        while i < self.cookies.len():
            if self.cookies.get(i).domain == domain:
                self.cookies.remove(i)
                return
            i = i + 1

    me evict_oldest():
        # Remove the first (oldest) cookie overall.
        if self.cookies.len() > 0:
            self.cookies.remove(0)

# --- Set-Cookie header parsing ---

fn parse_set_cookie(header: text, request_url: Url) -> BrowserResult<Cookie>:
    # Parse a Set-Cookie header into a Cookie.
    # Format: name=value; attr1; attr2=val2; ...
    # Example: "session=abc123; Domain=example.com; Path=/; Secure; HttpOnly; SameSite=Lax; Max-Age=3600"
    val parts = header.split(";")
    if parts.len() == 0:
        return Err(parse_error("Empty Set-Cookie header"))

    # First part is name=value
    val name_value = parts.get(0).trim()
    val eq_idx = index_of(name_value, "=")
    if eq_idx < 0:
        return Err(parse_error("Invalid Set-Cookie: missing '=' in name=value"))

    val name = name_value.slice(0, eq_idx).trim()
    val value = name_value.slice(eq_idx + 1, name_value.len()).trim()

    if name.len() == 0:
        return Err(parse_error("Invalid Set-Cookie: empty cookie name"))

    # Defaults from request URL
    var domain = request_url.host
    var path = default_cookie_path(request_url.path)
    var expires: i64 = 0
    var secure = false
    var http_only = false
    var same_site = SameSite.Lax

    # Parse attributes
    var i = 1
    while i < parts.len():
        val attr = parts.get(i).trim()
        val attr_lower = attr.to_lower()

        if attr_lower.starts_with("domain="):
            val raw_domain = attr.slice(7, attr.len()).trim()
            # Strip leading dot per RFC 6265 section 5.2.3
            domain = if raw_domain.starts_with("."): raw_domain.slice(1, raw_domain.len()) else: raw_domain
        else if attr_lower.starts_with("path="):
            path = attr.slice(5, attr.len()).trim()
        else if attr_lower.starts_with("max-age="):
            val age_str = attr.slice(8, attr.len()).trim()
            val parsed = parse_i64_simple(age_str)
            match parsed:
                Some(seconds):
                    val now = time.now_seconds()
                    expires = now + seconds
                nil:
                    pass_dn  # Ignore malformed max-age
        else if attr_lower.starts_with("expires="):
            # HTTP date parsing is complex; simplified to epoch or skip
            pass_todo
        else if attr_lower == "secure":
            secure = true
        else if attr_lower == "httponly":
            http_only = true
        else if attr_lower.starts_with("samesite="):
            val ss_val = attr.slice(9, attr.len()).trim().to_lower()
            same_site = match ss_val:
                "strict": SameSite.Strict
                "lax": SameSite.Lax
                "none": SameSite.None
                _: SameSite.Lax  # Default to Lax per modern browser behavior
        # else: ignore unknown attributes

        i = i + 1

    Ok(Cookie(
        name: name,
        value: value,
        domain: domain,
        path: path,
        expires: expires,
        secure: secure,
        http_only: http_only,
        same_site: same_site
    ))

# --- RFC 6265 domain matching ---

fn domain_matches(cookie_domain: text, request_domain: text) -> bool:
    # RFC 6265 Section 5.1.3: Domain Matching.
    # A request domain matches a cookie domain if:
    #   1. The domains are identical (case-insensitive), OR
    #   2. The cookie domain is a suffix of the request domain,
    #      AND the character preceding the suffix in the request domain is '.'.
    #      AND the request domain is not an IP address.
    val cd = cookie_domain.to_lower()
    val rd = request_domain.to_lower()

    # Exact match
    if cd == rd:
        return true

    # Suffix match: request_domain ends with cookie_domain
    # and the preceding character is a dot
    if rd.len() > cd.len():
        val suffix_start = rd.len() - cd.len()
        val suffix = rd.slice(suffix_start, rd.len())
        if suffix == cd:
            val preceding = rd.get(suffix_start - 1)
            if preceding == ".":
                # Verify request domain is not an IP address (simple check)
                if not is_ip_address(rd):
                    return true
    false

fn path_matches(cookie_path: text, request_path: text) -> bool:
    # RFC 6265 Section 5.1.4: Path Matching.
    # A request path matches a cookie path if:
    #   1. The cookie path is identical to the request path.
    #   2. The cookie path is a prefix of the request path, AND
    #      either the cookie path ends with '/', or the character
    #      in the request path immediately following the prefix is '/'.
    val cp = cookie_path
    val rp = if request_path.len() > 0: request_path else: "/"

    # Exact match
    if cp == rp:
        return true

    # Prefix match
    if rp.starts_with(cp):
        # Cookie path ends with /
        if cp.ends_with("/"):
            return true
        # Character after prefix is /
        if rp.len() > cp.len() and rp.get(cp.len()) == "/":
            return true

    false

fn should_send(cookie: Cookie, url: Url, is_secure: bool) -> bool:
    # Determine if a cookie should be sent with a request to the given URL.
    # Checks: domain match, path match, secure flag, expiration.
    val request_domain = url.host
    val request_path = if url.path.len() > 0: url.path else: "/"

    # Domain matching
    if not domain_matches(cookie.domain, request_domain):
        return false

    # Path matching
    if not path_matches(cookie.path, request_path):
        return false

    # Secure cookies only over HTTPS
    if cookie.secure and not is_secure:
        return false

    # SameSite checks (simplified: Strict cookies only sent for same-site requests)
    # Full SameSite requires knowing the request's initiator origin,
    # which is beyond simple URL matching. For now, always allow.

    true

# --- Internal helpers ---

fn default_cookie_path(request_path: text) -> text:
    # RFC 6265 Section 5.1.4: Default path.
    # 1. If the URI path is empty or doesn't start with /, return "/".
    # 2. If the path contains no more than one /, return "/".
    # 3. Return the path up to (but not including) the last /.
    if request_path.len() == 0 or not request_path.starts_with("/"):
        return "/"
    val last_slash = last_index_of(request_path, "/")
    if last_slash <= 0:
        return "/"
    request_path.slice(0, last_slash)

fn is_ip_address(host: text) -> bool:
    # Simple heuristic: if the host consists only of digits and dots, it's an IPv4.
    # Also check for IPv6 bracket notation.
    if host.starts_with("["):
        return true  # IPv6
    var i = 0
    var has_alpha = false
    while i < host.len():
        val ch = host.get(i)
        if (ch >= "a" and ch <= "z") or (ch >= "A" and ch <= "Z"):
            has_alpha = true
        i = i + 1
    not has_alpha

fn index_of(s: text, needle: text) -> i64:
    # Find the first index of needle in s. Returns -1 if not found.
    var i = 0
    val nlen = needle.len()
    while i + nlen <= s.len():
        if s.slice(i, i + nlen) == needle:
            return i
        i = i + 1
    -1

fn last_index_of(s: text, needle: text) -> i64:
    # Find the last index of needle in s. Returns -1 if not found.
    val nlen = needle.len()
    var i = s.len() - nlen
    while i >= 0:
        if s.slice(i, i + nlen) == needle:
            return i
        i = i - 1
    -1

fn parse_i64_simple(s: text) -> Option<i64>:
    # Parse a text string as an i64.
    if s.len() == 0:
        return nil
    var result: i64 = 0
    var i = 0
    var negative = false
    if s.get(0) == "-":
        negative = true
        i = 1
    while i < s.len():
        val ch = s.get(i)
        if ch >= "0" and ch <= "9":
            val digit = ch.to_i64() - "0".to_i64()
            result = result * 10 + digit
        else:
            return nil
        i = i + 1
    if negative:
        Some(-result)
    else:
        Some(result)
