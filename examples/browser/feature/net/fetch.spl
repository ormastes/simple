# Fetch API implementation for the Simple Browser Platform.
# This is the main network entry point — all resource loading flows through fetch().
# Implements the Fetch specification's request lifecycle: CORS check, cache lookup,
# DNS resolution, HTTP request, redirect handling, cookie storage, and response caching.

use examples.browser.entity.net.request_types {FetchRequest, FetchResponse, HttpMethod, RequestMode, RequestCredentials}
use examples.browser.entity.net.url_types {Url, Origin}
use examples.browser.entity.net.cors_types {PreflightResult}
use examples.browser.shared.error {BrowserError, BrowserResult, network_error}
use examples.browser.shared.logging {Logger, LogLevel}
use examples.browser.feature.net.dns {DnsResolver}
use examples.browser.feature.net.cors {CorsChecker, is_simple_method, needs_preflight}
use examples.browser.feature.net.h1_client {H1Client}
use examples.browser.feature.net.tls {TlsManager, TlsConnection}
use examples.browser.entity.net.tls_types {TlsConfig, TlsVersion}

use examples.browser.feature.net.cache.{HttpCache}
use examples.browser.feature.net.cookie_store.{CookieStore}

# Default maximum number of HTTP redirects to follow before aborting.
val DEFAULT_MAX_REDIRECTS = 20

# Default DNS cache TTL in seconds.
val DEFAULT_DNS_TTL = 300

# The Fetch engine orchestrates the full request lifecycle.
# Each fetch() call runs through: CORS preflight (if needed), cache check,
# DNS resolution, HTTP transport, redirect following, cookie management,
# and response caching.
class FetchEngine:
    dns: DnsResolver
    cache: HttpCache
    cookie_store: CookieStore
    cors: CorsChecker
    logger: Logger
    max_redirects: i64

    static fn new(logger: Logger) -> FetchEngine:
        FetchEngine(
            dns: DnsResolver.new(logger, DEFAULT_DNS_TTL),
            cache: HttpCache.create(),
            cookie_store: CookieStore.create(),
            cors: CorsChecker.new(logger),
            logger: logger,
            max_redirects: DEFAULT_MAX_REDIRECTS
        )

    # The main fetch function. Implements the Fetch specification request lifecycle.
    # Steps: CORS check -> cache -> DNS -> HTTP -> redirects -> cookies -> cache store.
    me fetch(request: FetchRequest) -> BrowserResult<FetchResponse>:
        self.logger.info("fetch: {method_text(request.method)} {request.url.to_text()}")

        # Step 1: CORS preflight if the request mode is Cors
        match request.mode:
            RequestMode.Cors:
                val preflight_result = self.handle_cors_preflight(request)?
                if not preflight_result:
                    return Err(network_error("CORS preflight denied"))
            _:
                pass_do_nothing

        # Step 2: Check the HTTP cache
        val cached = self.cache.lookup(request)
        if val response = cached:
            self.logger.debug("fetch: cache hit for {request.url.to_text()}")
            return Ok(response)

        # Step 3: Execute the request with redirect support
        self.fetch_with_redirect(request, 0)

    # Internal fetch loop that follows redirects up to max_redirects.
    # Each redirect decrements the remaining count and constructs a new request
    # targeting the Location header URL.
    me fetch_with_redirect(request: FetchRequest, redirect_count: i64) -> BrowserResult<FetchResponse>:
        if redirect_count > self.max_redirects:
            self.logger.error("fetch: exceeded maximum redirects ({self.max_redirects})")
            return Err(network_error("Too many redirects (max: {self.max_redirects})"))

        # Step 3a: Resolve DNS for the target host
        val url = request.url
        val addresses = self.dns.resolve(url.host)?

        if addresses.is_empty():
            return Err(network_error("DNS resolution returned no addresses for {url.host}"))

        val target_addr = addresses.get(0).unwrap_or("127.0.0.1")
        self.logger.debug("fetch: resolved {url.host} -> {target_addr}")

        # Step 3b: Attach cookies to the request
        val request_with_cookies = self.attach_cookies(request)

        # Step 3c: Perform the actual HTTP request
        val response = self.execute_http(request_with_cookies, target_addr)?

        # Step 3d: CORS response validation (for Cors mode)
        match request.mode:
            RequestMode.Cors:
                self.cors.check(request, response.headers)?
            _:
                pass_do_nothing

        # Step 3e: Store cookies from Set-Cookie response headers
        self.cookie_store.store_from_headers(request.url, response.headers)

        # Step 3f: Handle redirects (301, 302, 303, 307, 308)
        if should_redirect(response.status):
            val location = self.get_header(response.headers, "location")
            if val loc = location:
                self.logger.info("fetch: redirect {response.status} -> {loc}")
                val redirect_url = self.resolve_redirect_url(request.url, loc)
                val redirect_request = self.create_redirect_request(request, redirect_url, response.status)
                return self.fetch_with_redirect(redirect_request, redirect_count + 1)
            else:
                self.logger.warn("fetch: redirect status {response.status} but no Location header")

        # Step 3g: Cache the response if eligible
        if is_cacheable(response):
            self.logger.debug("fetch: caching response for {request.url.to_text()}")
            self.cache.store(request, response)

        # Mark the response as redirected if we followed any redirects
        if redirect_count > 0:
            val redirected_response = FetchResponse(
                status: response.status,
                status_text: response.status_text,
                headers: response.headers,
                body: response.body,
                url: response.url,
                redirected: true
            )
            return Ok(redirected_response)

        Ok(response)

    # Execute the CORS preflight sequence if needed.
    # Returns true if the request is allowed, false if denied.
    me handle_cors_preflight(request: FetchRequest) -> BrowserResult<bool>:
        if not self.cors.needs_preflight(request):
            self.logger.debug("fetch: no preflight needed")
            return Ok(true)

        self.logger.info("fetch: sending CORS preflight for {request.url.to_text()}")
        val preflight_req = self.cors.create_preflight(request)

        # Resolve DNS for preflight (same host)
        val addresses = self.dns.resolve(request.url.host)?
        val target_addr = addresses.get(0).unwrap_or("127.0.0.1")

        # Send the OPTIONS preflight
        val preflight_response = self.execute_http(preflight_req, target_addr)?

        # Validate the preflight response
        val result = self.cors.validate_preflight(preflight_response, request)
        match result:
            PreflightResult.Allowed:
                self.logger.debug("fetch: CORS preflight allowed")
                Ok(true)
            PreflightResult.Denied(reason):
                self.logger.warn("fetch: CORS preflight denied: {reason}")
                Ok(false)

    # Attach stored cookies to the request as a Cookie header.
    fn attach_cookies(request: FetchRequest) -> FetchRequest:
        # Only attach cookies if credentials mode allows it
        val should_send = match request.credentials:
            RequestCredentials.Omit: false
            RequestCredentials.SameOrigin: true
            RequestCredentials.Include: true

        if not should_send:
            return request

        val cookies = self.cookie_store.get_cookies_for(request.url)
        if cookies.is_empty():
            return request

        # Build Cookie header value: name=value; name2=value2
        var parts = List<text>()
        for cookie in cookies:
            parts.push("{cookie.first}={cookie.second}")
        val cookie_header = parts.join("; ")

        # Append Cookie header to the request
        var new_headers = List<Pair<text, text>>()
        for h in request.headers:
            new_headers.push(h)
        new_headers.push(Pair("Cookie", cookie_header))

        FetchRequest(
            url: request.url,
            method: request.method,
            headers: new_headers,
            body: request.body,
            mode: request.mode,
            credentials: request.credentials
        )

    # Perform the actual HTTP request over the network.
    # Routes through the H1 client which supports mock registry and simulated responses.
    me execute_http(request: FetchRequest, target_addr: text) -> BrowserResult<FetchResponse>:
        self.logger.debug("fetch: HTTP {method_text(request.method)} to {target_addr} for {request.url.to_text()}")

        # Build a temporary H1 client to handle the request.
        # The H1 client checks the mock registry first, then falls back to
        # simulated responses when real socket I/O is unavailable.
        val tls_config = default_tls_config()
        var tls_mgr = TlsManager.new(self.logger, tls_config)
        var h1 = H1Client.new(self.logger, self.dns, tls_mgr)
        val response = h1.request(request)?
        Ok(response)

    # Resolve a redirect Location URL against the original request URL.
    # Handles both absolute URLs and relative paths.
    fn resolve_redirect_url(base: Url, location: text) -> Url:
        # Absolute URL (starts with scheme://)
        if location.contains("://"):
            return Url.parse(location)

        # Protocol-relative URL (starts with //)
        if location.starts_with("//"):
            return Url.parse("{base.scheme}:{location}")

        # Absolute path (starts with /)
        if location.starts_with("/"):
            return Url.create(base.scheme, base.host, base.port, location)

        # Relative path — resolve against the base path
        val base_dir = if base.path.contains("/"):
            val last_slash = base.path.last_index_of("/")
            base.path.substring(0, last_slash + 1)
        else:
            "/"
        val resolved_path = "{base_dir}{location}"
        Url.create(base.scheme, base.host, base.port, resolved_path)

    # Create a new request for a redirect, adjusting the method per HTTP semantics.
    # 303 always becomes GET; 301/302 become GET for POST; 307/308 preserve method.
    fn create_redirect_request(original: FetchRequest, new_url: Url, status: i64) -> FetchRequest:
        val redirect_method = if status == 303:
            # 303 See Other: always use GET
            HttpMethod.Get
        else if status == 301 or status == 302:
            # 301/302: POST becomes GET (historical browser behavior), others preserved
            match original.method:
                HttpMethod.Post: HttpMethod.Get
                _: original.method
        else:
            # 307/308: preserve original method
            original.method

        val redirect_body = match redirect_method:
            HttpMethod.Get: ""
            HttpMethod.Head: ""
            _: original.body

        # Strip sensitive headers on cross-origin redirect
        val original_origin = Origin.from_url(original.url)
        val new_origin = Origin.from_url(new_url)
        val is_cross_origin = (original_origin.to_text() != new_origin.to_text())

        var new_headers = List<Pair<text, text>>()
        for header in original.headers:
            val name = header.first.to_lowercase()
            # Strip Authorization and Cookie headers on cross-origin redirects
            if is_cross_origin and (name == "authorization" or name == "cookie"):
                pass_do_nothing
            else:
                new_headers.push(header)

        FetchRequest(
            url: new_url,
            method: redirect_method,
            headers: new_headers,
            body: redirect_body,
            mode: original.mode,
            credentials: original.credentials
        )

    # Extract a header value by name (case-insensitive) from a header list.
    fn get_header(headers: List<Pair<text, text>>, name: text) -> text?:
        val lower_name = name.to_lowercase()
        for header in headers:
            if header.first.to_lowercase() == lower_name:
                return header.second
        nil

# -- Module-level functions --

# Determine whether an HTTP status code indicates a redirect.
fn should_redirect(status: i64) -> bool:
    status == 301 or status == 302 or status == 303 or status == 307 or status == 308

# Determine whether a response is eligible for HTTP caching.
# Checks status code, Cache-Control, and Vary headers.
fn is_cacheable(response: FetchResponse) -> bool:
    # Only cache successful responses
    if response.status < 200 or response.status >= 300:
        return false

    # Check Cache-Control for no-store directive
    for header in response.headers:
        if header.first.to_lowercase() == "cache-control":
            val value = header.second.to_lowercase()
            if value.contains("no-store"):
                return false
            if value.contains("no-cache"):
                return false

    # Only cache GET/HEAD responses
    # (we cannot check the method from the response alone, so cache all
    # successful responses and let the cache layer handle method matching)
    true

# Convert an HttpMethod to its text representation.
# Create a default TLS configuration for use by the fetch transport.
fn default_tls_config() -> TlsConfig:
    TlsConfig(min_version: TlsVersion.Tls12)

fn method_text(method: HttpMethod) -> text:
    match method:
        HttpMethod.Get: "GET"
        HttpMethod.Post: "POST"
        HttpMethod.Put: "PUT"
        HttpMethod.Delete: "DELETE"
        HttpMethod.Head: "HEAD"
        HttpMethod.Options: "OPTIONS"
        HttpMethod.Patch: "PATCH"
