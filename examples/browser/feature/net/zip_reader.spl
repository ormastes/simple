#![allow(REQC001)]
#![allow(REQC004)]
#![allow(unnamed_duplicate_typed_args)]

# ZIP archive reader. Parses local headers and central directory,
# decompresses stored (method 0) and deflate (method 8) entries.

use std.nogc_sync_mut.compression.gzip.inflate.inflate
use std.nogc_sync_mut.compression.gzip.crc.{crc32_calculate, crc32_verify}
use examples.browser.entity.net.zip_types.{
    ZipLocalHeader, ZipCentralEntry, ZipEndRecord, Zip64EndRecord, ZipEntry
}

val LOCAL_SIG: i64 = 67324752       # 0x04034b50
val CENTRAL_SIG: i64 = 33639248     # 0x02014b50
val EOCD_SIG: i64 = 101010256       # 0x06054b50
val EOCD64_SIG: i64 = 101075792     # 0x06064b50
val EOCD64_LOCATOR_SIG: i64 = 117853008  # 0x07064b50
val ZIP64_MARKER: i64 = 4294967295  # 0xFFFFFFFF
val ZIP64_EXTRA_TAG: i64 = 1        # 0x0001
val LFH_FIXED_SIZE: i64 = 30
val CDH_FIXED_SIZE: i64 = 46
val EOCD_FIXED_SIZE: i64 = 22
val METHOD_STORED: i64 = 0
val METHOD_DEFLATE: i64 = 8

fn read_u16_le(data: [u8], offset: i64) -> i64:
    data[offset].to_i64() | (data[offset + 1].to_i64() << 8)

fn read_u32_le(data: [u8], offset: i64) -> i64:
    data[offset].to_i64()
        | (data[offset + 1].to_i64() << 8)
        | (data[offset + 2].to_i64() << 16)
        | (data[offset + 3].to_i64() << 24)

fn read_u64_le(data: [u8], offset: i64) -> i64:
    data[offset].to_i64()
        | (data[offset + 1].to_i64() << 8)
        | (data[offset + 2].to_i64() << 16)
        | (data[offset + 3].to_i64() << 24)
        | (data[offset + 4].to_i64() << 32)
        | (data[offset + 5].to_i64() << 40)
        | (data[offset + 6].to_i64() << 48)
        | (data[offset + 7].to_i64() << 56)

fn read_filename(data: [u8], offset: i64, length: i64) -> text:
    var chars: [u8] = []
    var i = 0
    loop:
        if i >= length:
            break
        chars.push(data[offset + i])
        i = i + 1
    chars.to_text()

class ZipReader:
    data: [u8]

    static fn new(data: [u8]) -> ZipReader:
        ZipReader(data: data)

    me read_local_header(offset: i64) -> ZipLocalHeader?:
        val d = self.data
        if offset + LFH_FIXED_SIZE > d.len():
            return nil

        val sig = read_u32_le(d, offset)
        if sig != LOCAL_SIG:
            return nil

        val version_needed   = read_u16_le(d, offset + 4)
        val flags            = read_u16_le(d, offset + 6)
        val method           = read_u16_le(d, offset + 8)
        val crc32            = read_u32_le(d, offset + 14)
        val compressed_size  = read_u32_le(d, offset + 18)
        val uncompressed_sz  = read_u32_le(d, offset + 22)
        val fname_len        = read_u16_le(d, offset + 26)
        val extra_len        = read_u16_le(d, offset + 28)
        val fname            = read_filename(d, offset + LFH_FIXED_SIZE, fname_len)

        return ZipLocalHeader.create(
            signature: sig,
            version_needed: version_needed,
            flags: flags,
            compression_method: method,
            crc32: crc32,
            compressed_size: compressed_size,
            uncompressed_size: uncompressed_sz,
            filename_length: fname_len,
            extra_length: extra_len,
            filename: fname
        )

    me find_end_record() -> ZipEndRecord?:
        val d = self.data
        val dlen = d.len()
        # Max ZIP comment is 65535 bytes; scan backwards from end.
        val max_comment = 65535
        var search_start = dlen - EOCD_FIXED_SIZE
        val search_limit = if dlen - max_comment - EOCD_FIXED_SIZE > 0:
            dlen - max_comment - EOCD_FIXED_SIZE
        else:
            0

        var pos = search_start
        loop:
            if pos < search_limit:
                break
            val sig = read_u32_le(d, pos)
            if sig == EOCD_SIG:
                val disk_number     = read_u16_le(d, pos + 4)
                val disk_with_cd    = read_u16_le(d, pos + 6)
                val entries_disk    = read_u16_le(d, pos + 8)
                val entries_total   = read_u16_le(d, pos + 10)
                val cd_size         = read_u32_le(d, pos + 12)
                val cd_offset       = read_u32_le(d, pos + 16)
                val comment_len     = read_u16_le(d, pos + 20)
                return ZipEndRecord.create(
                    signature: sig,
                    disk_number: disk_number,
                    disk_with_cd: disk_with_cd,
                    num_entries_disk: entries_disk,
                    num_entries_total: entries_total,
                    cd_size: cd_size,
                    cd_offset: cd_offset,
                    comment_length: comment_len
                )
            pos = pos - 1

        return nil

    me read_central_directory() -> [ZipCentralEntry]:
        var entries: [ZipCentralEntry] = []
        val eocd = self.find_end_record()
        if eocd == nil:
            return entries

        val d = self.data
        var offset = eocd.cd_offset
        val total  = eocd.num_entries_total

        var i = 0
        loop:
            if i >= total:
                break
            if offset + CDH_FIXED_SIZE > d.len():
                break

            val sig = read_u32_le(d, offset)
            if sig != CENTRAL_SIG:
                break

            val version_made    = read_u16_le(d, offset + 4)
            val version_needed  = read_u16_le(d, offset + 6)
            val flags           = read_u16_le(d, offset + 8)
            val method          = read_u16_le(d, offset + 10)
            val crc32           = read_u32_le(d, offset + 16)
            val comp_size       = read_u32_le(d, offset + 20)
            val uncomp_size     = read_u32_le(d, offset + 24)
            val fname_len       = read_u16_le(d, offset + 28)
            val extra_len       = read_u16_le(d, offset + 30)
            val comment_len     = read_u16_le(d, offset + 32)
            val disk_start      = read_u16_le(d, offset + 34)
            val internal_attrs  = read_u16_le(d, offset + 36)
            val external_attrs  = read_u32_le(d, offset + 38)
            val local_offset    = read_u32_le(d, offset + 42)
            val fname           = read_filename(d, offset + CDH_FIXED_SIZE, fname_len)

            entries.push(ZipCentralEntry.create(
                signature: sig,
                version_made: version_made,
                version_needed: version_needed,
                flags: flags,
                compression_method: method,
                crc32: crc32,
                compressed_size: comp_size,
                uncompressed_size: uncomp_size,
                filename_length: fname_len,
                extra_length: extra_len,
                comment_length: comment_len,
                disk_start: disk_start,
                internal_attrs: internal_attrs,
                external_attrs: external_attrs,
                local_offset: local_offset,
                filename: fname
            ))

            offset = offset + CDH_FIXED_SIZE + fname_len + extra_len + comment_len
            i = i + 1

        return entries

    me extract_entry(entry: ZipCentralEntry) -> [u8]?:
        val d = self.data
        val lh = self.read_local_header(entry.local_offset)
        if lh == nil:
            return nil

        val data_start = entry.local_offset + LFH_FIXED_SIZE + lh.filename_length + lh.extra_length
        val comp_size  = entry.compressed_size

        if data_start + comp_size > d.len():
            return nil

        var compressed: [u8] = []
        var i = 0
        loop:
            if i >= comp_size:
                break
            compressed.push(d[data_start + i])
            i = i + 1

        if entry.compression_method == METHOD_STORED:
            return compressed

        if entry.compression_method == METHOD_DEFLATE:
            return inflate(compressed)

        return nil

    me validate_crc32(data: [u8], expected: i64) -> bool:
        return crc32_verify(data, expected)

    me supports_zip64() -> bool:
        val d = self.data
        val dlen = d.len()
        # Look for zip64 EOCD locator just before the EOCD record.
        # Locator is 20 bytes; scan backwards.
        var pos = dlen - EOCD_FIXED_SIZE - 20
        loop:
            if pos < 0:
                break
            val sig = read_u32_le(d, pos)
            if sig == EOCD64_LOCATOR_SIG:
                return true
            pos = pos - 1
        return false

    me extract_all() -> [ZipEntry]:
        var result: [ZipEntry] = []
        val d = self.data
        var offset = 0

        loop:
            if offset + LFH_FIXED_SIZE > d.len():
                break

            val sig = read_u32_le(d, offset)
            if sig != LOCAL_SIG:
                break

            val lh = self.read_local_header(offset)
            if lh == nil:
                break

            val data_start = offset + LFH_FIXED_SIZE + lh.filename_length + lh.extra_length
            val comp_size  = lh.compressed_size

            if data_start + comp_size > d.len():
                break

            var compressed: [u8] = []
            var i = 0
            loop:
                if i >= comp_size:
                    break
                compressed.push(d[data_start + i])
                i = i + 1

            var decompressed: [u8]? = nil
            if lh.compression_method == METHOD_STORED:
                decompressed = compressed
            if lh.compression_method == METHOD_DEFLATE:
                decompressed = inflate(compressed)

            if decompressed != nil:
                result.push(ZipEntry.create(
                    name: lh.filename,
                    compressed_data: compressed,
                    uncompressed_size: lh.uncompressed_size,
                    crc32: lh.crc32,
                    method: lh.compression_method
                ))

            offset = data_start + comp_size

        return result
