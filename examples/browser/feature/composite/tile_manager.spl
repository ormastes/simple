# Tile-based rasterization — splits compositing layers into tiles that
# can be independently rasterized and uploaded as GPU textures.
# Dirty tracking ensures only changed tiles are re-rasterized.

use examples.browser.entity.dom.paint_types.(DisplayItem, PaintOp, Color)
use examples.browser.feature.composite.layer_tree.(CompositeLayer)
use examples.browser.shared.logging.(Logger, LogLevel)

# ---------------------------------------------------------------------------
# Tile — a fixed-size rasterization unit within a layer.
# ---------------------------------------------------------------------------

class Tile:
    id: i64
    layer_id: i64
    x: i64
    y: i64
    width: i64
    height: i64
    is_dirty: bool
    texture_id: i64

    static fn create(id: i64, layer_id: i64, x: i64, y: i64, width: i64, height: i64) -> Tile:
        Tile(
            id: id,
            layer_id: layer_id,
            x: x,
            y: y,
            width: width,
            height: height,
            is_dirty: true,
            texture_id: -1
        )

# ---------------------------------------------------------------------------
# TileManager — creates, tracks, and rasterizes tiles for layers.
# ---------------------------------------------------------------------------

class TileManager:
    tiles: List<Tile>
    tile_size: i64
    next_id: i64
    logger: Logger

    static fn new(tile_size: i64, logger: Logger) -> TileManager:
        TileManager(
            tiles: List<Tile>(),
            tile_size: tile_size,
            next_id: 0,
            logger: logger
        )

    # Create a grid of tiles covering a compositing layer.
    me create_tiles_for_layer(layer: CompositeLayer, tile_size: i64) -> List<Tile>:
        var new_tiles = List<Tile>()
        val layer_w = layer.bounds_w.to_i64()
        val layer_h = layer.bounds_h.to_i64()

        if layer_w <= 0 or layer_h <= 0:
            return new_tiles

        # Calculate tile grid dimensions
        val cols = (layer_w + tile_size - 1) / tile_size
        val rows = (layer_h + tile_size - 1) / tile_size

        self.logger.debug("creating {cols}x{rows} tiles for layer {layer.id}")

        var row = 0
        while row < rows:
            var col = 0
            while col < cols:
                val tile_x = col * tile_size
                val tile_y = row * tile_size

                # Clamp tile dimensions at layer boundary
                val tw = if tile_x + tile_size > layer_w: layer_w - tile_x else: tile_size
                val th = if tile_y + tile_size > layer_h: layer_h - tile_y else: tile_size

                val tile = Tile.create(self.next_id, layer.id, tile_x, tile_y, tw, th)
                self.next_id = self.next_id + 1
                new_tiles.push(tile)
                self.tiles.push(tile)
                col = col + 1
            row = row + 1

        self.logger.info("created {new_tiles.len()} tiles for layer {layer.id}")
        new_tiles

    # Mark a single tile as dirty (needs re-rasterization).
    me mark_dirty(tile_id: i64):
        for tile in self.tiles:
            if tile.id == tile_id:
                tile.is_dirty = true
                return

    # Mark all tiles that overlap a damaged region within a layer.
    me mark_dirty_region(layer_id: i64, x: f64, y: f64, w: f64, h: f64):
        var count = 0
        for tile in self.tiles:
            if tile.layer_id == layer_id:
                if tile_intersects(tile, x, y, w, h):
                    tile.is_dirty = true
                    count = count + 1
        self.logger.trace("marked {count} tiles dirty in layer {layer_id}")

    # Get all tiles that are marked dirty.
    fn get_dirty_tiles() -> List<Tile>:
        var dirty = List<Tile>()
        for tile in self.tiles:
            if tile.is_dirty:
                dirty.push(tile)
        dirty

    # Rasterize a tile by painting the display items that intersect it
    # into a software pixel buffer. Returns a texture_id for compositing.
    me rasterize_tile(tile: Tile, items: List<DisplayItem>) -> i64:
        self.logger.trace("rasterizing tile {tile.id} at ({tile.x}, {tile.y})")

        val tx = tile.x.to_f64()
        val ty = tile.y.to_f64()
        val tw = tile.width.to_f64()
        val th = tile.height.to_f64()

        # Filter display items to those intersecting this tile
        var relevant = List<DisplayItem>()
        for item in items:
            if _item_intersects_tile(item, tx, ty, tw, th):
                relevant.push(item)

        # Create pixel buffer for the tile (RGBA, 4 bytes per pixel)
        val buf_size = tile.width * tile.height * 4
        var pixel_buffer = List<i64>()
        var init_i = 0
        while init_i < buf_size:
            pixel_buffer.push(0)  # Initialize to transparent black
            init_i = init_i + 1

        # Rasterize each relevant display item into the pixel buffer
        for item in relevant:
            _rasterize_item(item, pixel_buffer, tile.x, tile.y, tile.width, tile.height)

        # Mark tile as clean and assign a texture ID
        tile.is_dirty = false
        val texture_id = tile.id  # Texture ID maps 1:1 with tile ID
        tile.texture_id = texture_id

        self.logger.trace("tile {tile.id} rasterized, texture={texture_id}, items={relevant.len()}")
        texture_id

# ---------------------------------------------------------------------------
# Tile query functions
# ---------------------------------------------------------------------------

# Get tiles for a specific layer that overlap the viewport.
fn tiles_for_viewport(tiles: List<Tile>, layer_id: i64, vp_x: f64, vp_y: f64, vp_w: f64, vp_h: f64) -> List<Tile>:
    var visible = List<Tile>()
    for tile in tiles:
        if tile.layer_id == layer_id:
            if tile_intersects(tile, vp_x, vp_y, vp_w, vp_h):
                visible.push(tile)
    visible

# Test whether a tile intersects a rectangular region.
fn tile_intersects(tile: Tile, x: f64, y: f64, w: f64, h: f64) -> bool:
    val tx = tile.x.to_f64()
    val ty = tile.y.to_f64()
    val tw = tile.width.to_f64()
    val th = tile.height.to_f64()

    # AABB intersection test
    if tx + tw <= x:
        return false
    if ty + th <= y:
        return false
    if x + w <= tx:
        return false
    if y + h <= ty:
        return false
    true

# ---------------------------------------------------------------------------
# Software rasterization helpers
# ---------------------------------------------------------------------------

# Check if a display item intersects a tile's bounding box.
fn _item_intersects_tile(item: DisplayItem, tx: f64, ty: f64, tw: f64, th: f64) -> bool:
    # Extract the bounding box from the item's PaintOp
    val bounds = _item_bounds(item)
    val ix = bounds.first.first
    val iy = bounds.first.second
    val iw = bounds.second.first
    val ih = bounds.second.second

    # AABB intersection
    if ix + iw <= tx: return false
    if iy + ih <= ty: return false
    if tx + tw <= ix: return false
    if ty + th <= iy: return false
    true

# Extract bounding box ((x, y), (w, h)) from a display item's PaintOp.
fn _item_bounds(item: DisplayItem) -> Pair<Pair<f64, f64>, Pair<f64, f64>>:
    match item.op:
        PaintOp.FillRect(x, y, w, h, color):
            Pair(first: Pair(first: x, second: y), second: Pair(first: w, second: h))
        PaintOp.DrawText(x, y, text_content, font_size, color):
            val approx_w = text_content.len().to_f64() * font_size * 0.6
            Pair(first: Pair(first: x, second: y - font_size), second: Pair(first: approx_w, second: font_size))
        PaintOp.DrawBorder(x, y, w, h, widths, colors):
            Pair(first: Pair(first: x, second: y), second: Pair(first: w, second: h))
        PaintOp.DrawImage(x, y, w, h, image_id):
            Pair(first: Pair(first: x, second: y), second: Pair(first: w, second: h))
        _:
            # Clips and opacity don't have spatial bounds
            Pair(first: Pair(first: 0.0, second: 0.0), second: Pair(first: 0.0, second: 0.0))

# Rasterize a single display item into the pixel buffer.
# tile_x/tile_y are the tile's world-space origin; pixel coords are relative.
fn _rasterize_item(item: DisplayItem, buffer: List<i64>, tile_x: i64, tile_y: i64, tile_w: i64, tile_h: i64):
    match item.op:
        PaintOp.FillRect(x, y, w, h, color):
            _fill_rect_pixels(buffer, tile_x, tile_y, tile_w, tile_h, x, y, w, h, color.r, color.g, color.b, color.a)
        PaintOp.DrawText(x, y, text_content, font_size, color):
            # Placeholder: draw a colored rectangle for text area
            val approx_w = text_content.len().to_f64() * font_size * 0.6
            _fill_rect_pixels(buffer, tile_x, tile_y, tile_w, tile_h, x, y - font_size, approx_w, font_size, color.r, color.g, color.b, color.a)
        PaintOp.DrawBorder(x, y, w, h, widths, colors):
            # Draw four border edges as filled rectangles
            val top_w = _get_width(widths, 0)
            val right_w = _get_width(widths, 1)
            val bottom_w = _get_width(widths, 2)
            val left_w = _get_width(widths, 3)
            val bc = _get_border_color(colors, 0)
            # Top
            _fill_rect_pixels(buffer, tile_x, tile_y, tile_w, tile_h, x, y, w, top_w, bc.r, bc.g, bc.b, bc.a)
            # Right
            _fill_rect_pixels(buffer, tile_x, tile_y, tile_w, tile_h, x + w - right_w, y, right_w, h, bc.r, bc.g, bc.b, bc.a)
            # Bottom
            _fill_rect_pixels(buffer, tile_x, tile_y, tile_w, tile_h, x, y + h - bottom_w, w, bottom_w, bc.r, bc.g, bc.b, bc.a)
            # Left
            _fill_rect_pixels(buffer, tile_x, tile_y, tile_w, tile_h, x, y, left_w, h, bc.r, bc.g, bc.b, bc.a)
        PaintOp.DrawImage(x, y, w, h, image_id):
            # Placeholder: fill with a light gray to indicate image area
            _fill_rect_pixels(buffer, tile_x, tile_y, tile_w, tile_h, x, y, w, h, 200, 200, 200, 255)
        _:
            pass_dn  # PushClip/PopClip/PushOpacity/PopOpacity handled at higher level

# Fill a rectangle region within the tile's pixel buffer.
# All coordinates are in world space; this function clips to tile bounds.
fn _fill_rect_pixels(buffer: List<i64>, tile_x: i64, tile_y: i64, tile_w: i64, tile_h: i64, rx: f64, ry: f64, rw: f64, rh: f64, r: i64, g: i64, b: i64, a: i64):
    # Convert world coords to tile-local pixel coords
    val local_x0 = _max_i64(_f64_to_i64(rx) - tile_x, 0)
    val local_y0 = _max_i64(_f64_to_i64(ry) - tile_y, 0)
    val local_x1 = _min_i64(_f64_to_i64(rx + rw) - tile_x, tile_w)
    val local_y1 = _min_i64(_f64_to_i64(ry + rh) - tile_y, tile_h)

    if local_x1 <= local_x0 or local_y1 <= local_y0:
        return

    var py = local_y0
    while py < local_y1:
        var px = local_x0
        while px < local_x1:
            val idx = (py * tile_w + px) * 4
            if idx + 3 < buffer.len():
                # Simple alpha-over compositing
                if a >= 255:
                    buffer.set(idx, r)
                    buffer.set(idx + 1, g)
                    buffer.set(idx + 2, b)
                    buffer.set(idx + 3, 255)
                else if a > 0:
                    val src_a = a.to_f64() / 255.0
                    val inv_a = 1.0 - src_a
                    val dst_r = buffer.get(idx)
                    val dst_g = buffer.get(idx + 1)
                    val dst_b = buffer.get(idx + 2)
                    if val dr = dst_r:
                        if val dg = dst_g:
                            if val db = dst_b:
                                val out_r = _f64_to_i64(r.to_f64() * src_a + dr.to_f64() * inv_a)
                                val out_g = _f64_to_i64(g.to_f64() * src_a + dg.to_f64() * inv_a)
                                val out_b = _f64_to_i64(b.to_f64() * src_a + db.to_f64() * inv_a)
                                buffer.set(idx, out_r)
                                buffer.set(idx + 1, out_g)
                                buffer.set(idx + 2, out_b)
                                buffer.set(idx + 3, 255)
            px = px + 1
        py = py + 1

fn _f64_to_i64(v: f64) -> i64:
    val i = v
    i

fn _max_i64(a: i64, b: i64) -> i64:
    if a > b: a else: b

fn _min_i64(a: i64, b: i64) -> i64:
    if a < b: a else: b

fn _get_width(widths: List<f64>, idx: i64) -> f64:
    if idx >= 0 and idx < widths.len():
        val v = widths.get(idx)
        if val f = v:
            return f
    0.0

fn _get_border_color(colors: List<Color>, idx: i64) -> Color:
    if idx >= 0 and idx < colors.len():
        val v = colors.get(idx)
        if val c = v:
            return c
    Color(r: 0, g: 0, b: 0, a: 255)
