# VSync and frame pacing — manages frame timing, requestAnimationFrame
# callbacks, and dropped frame detection for smooth rendering.

use examples.browser.shared.logging.(Logger, LogLevel)

# ---------------------------------------------------------------------------
# FrameState — the current phase of the frame pipeline.
# ---------------------------------------------------------------------------

enum FrameState:
    Idle
    AnimationCallbacks
    Layout
    Paint
    Composite
    Present

# ---------------------------------------------------------------------------
# FrameScheduler — controls frame production rate and budget.
# ---------------------------------------------------------------------------

class FrameScheduler:
    target_fps: i64
    frame_budget_ms: f64
    last_frame_time: f64
    frame_count: i64
    dropped_frames: i64
    state: FrameState
    pending_callbacks: [i64]
    logger: Logger
    first_frame_time: f64

    static fn new(target_fps: i64, logger: Logger) -> FrameScheduler:
        val budget = 1000.0 / target_fps.to_f64()
        FrameScheduler(
            target_fps: target_fps,
            frame_budget_ms: budget,
            last_frame_time: 0.0,
            frame_count: 0,
            dropped_frames: 0,
            state: FrameState.Idle,
            pending_callbacks: [i64](),
            logger: logger,
            first_frame_time: 0.0
        )

    # Determine whether a new frame should be produced at the given timestamp.
    # Returns true if enough time has elapsed since the last frame.
    me begin_frame(timestamp_ms: f64) -> bool:
        if self.frame_count == 0:
            # First frame — always produce
            self.first_frame_time = timestamp_ms
            self.last_frame_time = timestamp_ms
            self.state = FrameState.AnimationCallbacks
            self.frame_count = 1
            self.logger.debug("first frame at {timestamp_ms}ms")
            return true

        val elapsed = timestamp_ms - self.last_frame_time
        if elapsed < self.frame_budget_ms:
            # Not enough time elapsed — skip this frame request
            return false

        # Check if we dropped frames (elapsed > 2x budget)
        if elapsed > self.frame_budget_ms * 2.0:
            val dropped = (elapsed / self.frame_budget_ms).to_i64() - 1
            self.dropped_frames = self.dropped_frames + dropped
            self.logger.warn("dropped {dropped} frames (elapsed={elapsed}ms)")

        self.last_frame_time = timestamp_ms
        self.frame_count = self.frame_count + 1
        self.state = FrameState.AnimationCallbacks
        true

    # Record the end of a frame and transition to Idle.
    me end_frame(timestamp_ms: f64):
        val frame_duration = timestamp_ms - self.last_frame_time
        if frame_duration > self.frame_budget_ms:
            self.logger.warn("frame overbudget: {frame_duration}ms > {self.frame_budget_ms}ms")
        self.state = FrameState.Idle
        self.logger.trace("frame {self.frame_count} completed in {frame_duration}ms")

    # Schedule a requestAnimationFrame callback by ID.
    me request_animation_frame(callback_id: i64):
        self.pending_callbacks.push(callback_id)
        self.logger.trace("rAF scheduled: callback {callback_id}")

    # Consume and return all pending rAF callbacks for this frame.
    fn take_callbacks() -> [i64]:
        val callbacks = self.pending_callbacks
        self.pending_callbacks = [i64]()
        callbacks

    # Calculate remaining time in the current frame budget.
    fn frame_budget_remaining(start_ms: f64, now_ms: f64) -> f64:
        val elapsed = now_ms - start_ms
        val remaining = self.frame_budget_ms - elapsed
        if remaining < 0.0:
            return 0.0
        remaining

    # Check if the current frame is over budget.
    fn is_behind_schedule(start_ms: f64, now_ms: f64) -> bool:
        val elapsed = now_ms - start_ms
        elapsed > self.frame_budget_ms

    # Calculate current FPS based on total frames and elapsed time.
    fn fps() -> f64:
        if self.frame_count <= 1:
            return 0.0
        val elapsed = self.last_frame_time - self.first_frame_time
        if elapsed <= 0.0:
            return 0.0
        (self.frame_count.to_f64() - 1.0) / (elapsed / 1000.0)

    # Calculate the fraction of dropped frames over total expected frames.
    fn dropped_frame_rate() -> f64:
        val total = self.frame_count + self.dropped_frames
        if total <= 0:
            return 0.0
        self.dropped_frames.to_f64() / total.to_f64()

    # Advance the frame state to the next pipeline phase.
    me advance_state():
        match self.state:
            FrameState.Idle:
                self.state = FrameState.AnimationCallbacks
            FrameState.AnimationCallbacks:
                self.state = FrameState.Layout
            FrameState.Layout:
                self.state = FrameState.Paint
            FrameState.Paint:
                self.state = FrameState.Composite
            FrameState.Composite:
                self.state = FrameState.Present
            FrameState.Present:
                self.state = FrameState.Idle
