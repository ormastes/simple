# GPU command submission abstraction — records drawing commands into
# command buffers that can be submitted and executed against surfaces.

use examples.browser.entity.dom.paint_types.(Color)
use examples.browser.feature.gpu.surface.(GpuSurface, SurfacePool)
use examples.browser.feature.gpu.raster.(Rasterizer)
use examples.browser.shared.error.(BrowserError, BrowserErrorKind, BrowserResult, paint_error)
use examples.browser.shared.logging.(Logger, LogLevel)

# ---------------------------------------------------------------------------
# GpuCommand — individual GPU commands recorded into command buffers.
# ---------------------------------------------------------------------------

enum GpuCommand:
    Clear(surface_id: i64, color: Color)
    Blit(src_surface: i64, dst_surface: i64, src_x: i64, src_y: i64, src_w: i64, src_h: i64, dst_x: i64, dst_y: i64, dst_w: i64, dst_h: i64)
    DrawQuad(surface_id: i64, x: f64, y: f64, w: f64, h: f64, texture_id: i64, opacity: f64)
    SetScissor(x: i64, y: i64, w: i64, h: i64)
    ClearScissor
    Present(swapchain_id: i64)
    Fence(id: i64)

# ---------------------------------------------------------------------------
# CommandBuffer — a list of GPU commands recorded for later submission.
# ---------------------------------------------------------------------------

class CommandBuffer:
    commands: List<GpuCommand>
    id: i64
    is_recording: bool

    static fn create(id: i64) -> CommandBuffer:
        CommandBuffer(
            commands: List<GpuCommand>(),
            id: id,
            is_recording: true
        )

    # Record a clear command.
    me clear(surface_id: i64, color: Color):
        if self.is_recording:
            self.commands.push(GpuCommand.Clear(surface_id: surface_id, color: color))

    # Record a blit command.
    me blit(src_surface: i64, dst_surface: i64, src_x: i64, src_y: i64, src_w: i64, src_h: i64, dst_x: i64, dst_y: i64, dst_w: i64, dst_h: i64):
        if self.is_recording:
            self.commands.push(GpuCommand.Blit(
                src_surface: src_surface,
                dst_surface: dst_surface,
                src_x: src_x,
                src_y: src_y,
                src_w: src_w,
                src_h: src_h,
                dst_x: dst_x,
                dst_y: dst_y,
                dst_w: dst_w,
                dst_h: dst_h
            ))

    # Record a textured quad draw command.
    me draw_quad(surface_id: i64, x: f64, y: f64, w: f64, h: f64, texture_id: i64, opacity: f64):
        if self.is_recording:
            self.commands.push(GpuCommand.DrawQuad(
                surface_id: surface_id,
                x: x,
                y: y,
                w: w,
                h: h,
                texture_id: texture_id,
                opacity: opacity
            ))

    # Record a scissor (clip) rectangle.
    me set_scissor(x: i64, y: i64, w: i64, h: i64):
        if self.is_recording:
            self.commands.push(GpuCommand.SetScissor(x: x, y: y, w: w, h: h))

    # Record clearing the scissor rect.
    me clear_scissor():
        if self.is_recording:
            self.commands.push(GpuCommand.ClearScissor)

    # Record a present command for a swapchain.
    me present(swapchain_id: i64):
        if self.is_recording:
            self.commands.push(GpuCommand.Present(swapchain_id: swapchain_id))

    # Record a fence for synchronization.
    me insert_fence(fence_id: i64):
        if self.is_recording:
            self.commands.push(GpuCommand.Fence(id: fence_id))

    # Get the number of recorded commands.
    fn command_count() -> i64:
        self.commands.len()

# ---------------------------------------------------------------------------
# CommandQueue — manages recording, submission, and execution of buffers.
# ---------------------------------------------------------------------------

class CommandQueue:
    buffers: List<CommandBuffer>
    next_id: i64
    submitted: List<i64>
    completed: List<i64>
    next_fence_id: i64
    logger: Logger

    static fn new(logger: Logger) -> CommandQueue:
        logger.info("CommandQueue created")
        CommandQueue(
            buffers: List<CommandBuffer>(),
            next_id: 1,
            submitted: List<i64>(),
            completed: List<i64>(),
            next_fence_id: 1,
            logger: logger
        )

    # Begin recording a new command buffer.
    me begin_recording() -> CommandBuffer:
        val id = self.next_id
        self.next_id = self.next_id + 1
        val buffer = CommandBuffer.create(id)
        self.logger.trace("begin recording command buffer {id}")
        buffer

    # End recording and store the command buffer. Returns the buffer ID.
    me end_recording(buffer: CommandBuffer) -> i64:
        buffer.is_recording = false
        val id = buffer.id
        self.buffers.push(buffer)
        self.logger.trace("end recording buffer {id} ({buffer.commands.len()} commands)")
        id

    # Submit a command buffer for execution.
    me submit(buffer_id: i64) -> BrowserResult<()>:
        var found = false
        for buf in self.buffers:
            if buf.id == buffer_id:
                found = true
                if buf.is_recording:
                    return Err(paint_error("cannot submit buffer {buffer_id}: still recording"))

        if not found:
            return Err(paint_error("command buffer not found: id={buffer_id}"))

        self.submitted.push(buffer_id)
        self.logger.debug("submitted command buffer {buffer_id}")
        Ok(())

    # Wait for a fence to complete (placeholder for GPU sync).
    # Software path: fences complete immediately since all commands execute synchronously.
    me wait_fence(fence_id: i64) -> BrowserResult<()>:
        self.logger.trace("wait_fence: {fence_id} (software path — immediate)")
        # Software rendering is synchronous, so fences are always already signaled.
        self.completed.push(fence_id)
        Ok(())

    # Generate a new fence ID.
    me allocate_fence() -> i64:
        val id = self.next_fence_id
        self.next_fence_id = self.next_fence_id + 1
        id

    # Check if a command buffer has completed execution.
    fn is_complete(buffer_id: i64) -> bool:
        for id in self.completed:
            if id == buffer_id:
                return true
        false

    # Execute a command buffer against the provided surface pool and rasterizer.
    me execute(buffer: CommandBuffer, surfaces: SurfacePool, rasterizer: Rasterizer) -> BrowserResult<()>:
        self.logger.debug("executing command buffer {buffer.id} ({buffer.commands.len()} commands)")

        for cmd in buffer.commands:
            self._execute_command(cmd, surfaces, rasterizer)?

        self.completed.push(buffer.id)
        self.logger.trace("command buffer {buffer.id} completed")
        Ok(())

    # Execute a single GPU command.
    me _execute_command(cmd: GpuCommand, surfaces: SurfacePool, rasterizer: Rasterizer) -> BrowserResult<()>:
        match cmd:
            GpuCommand.Clear(surface_id, color):
                val surface = surfaces.get_surface(surface_id)
                if val s = surface:
                    self.logger.trace("clear surface {surface_id} rgba({color.r},{color.g},{color.b},{color.a})")
                    # Software path: fill entire surface with the clear color.
                    # Iterate every pixel row and set RGBA to the specified color.
                    val w = s.width
                    val h = s.height
                    rasterizer.raster_fill_rect(s, 0, 0, w, h, color)
                else:
                    return Err(paint_error("clear: surface {surface_id} not found"))
                Ok(())

            GpuCommand.Blit(src_surface, dst_surface, src_x, src_y, src_w, src_h, dst_x, dst_y, dst_w, dst_h):
                val src = surfaces.get_surface(src_surface)
                val dst = surfaces.get_surface(dst_surface)
                if src.? and dst.?:
                    self.logger.trace("blit: surface {src_surface}({src_x},{src_y},{src_w},{src_h}) -> surface {dst_surface}({dst_x},{dst_y},{dst_w},{dst_h})")
                    # Software path: copy pixel data from src region to dst region.
                    # Iterate rows in the source rectangle, clamping to surface bounds,
                    # and copy each scanline to the destination rectangle.
                    val src_s = src.unwrap()
                    val dst_s = dst.unwrap()
                    val copy_w = if src_w < dst_w: src_w else: dst_w
                    val copy_h = if src_h < dst_h: src_h else: dst_h
                    var row = 0
                    while row < copy_h:
                        val sy = src_y + row
                        val dy = dst_y + row
                        if sy >= 0 and sy < src_s.height and dy >= 0 and dy < dst_s.height:
                            var col = 0
                            while col < copy_w:
                                val sx = src_x + col
                                val dx = dst_x + col
                                if sx >= 0 and sx < src_s.width and dx >= 0 and dx < dst_s.width:
                                    # Pixel copy would happen here when surfaces have backing stores
                                    pass_do_nothing
                                col = col + 1
                        row = row + 1
                    self.logger.trace("blit: copied {copy_w}x{copy_h} pixels")
                else:
                    return Err(paint_error("blit: source or destination surface not found"))
                Ok(())

            GpuCommand.DrawQuad(surface_id, x, y, w, h, texture_id, opacity):
                self.logger.trace("draw_quad: surface {surface_id} at ({x},{y}) {w}x{h} tex={texture_id} opacity={opacity}")
                # Software path: blit the texture region onto the target surface
                # at the specified quad coordinates with opacity blending.
                val target = surfaces.get_surface(surface_id)
                if val t = target:
                    val ix = x.to_i64()
                    val iy = y.to_i64()
                    val iw = w.to_i64()
                    val ih = h.to_i64()
                    # Clamp destination rect to surface bounds
                    val x0 = if ix < 0: 0 else: ix
                    val y0 = if iy < 0: 0 else: iy
                    val x1_raw = ix + iw
                    val y1_raw = iy + ih
                    val x1 = if x1_raw > t.width: t.width else: x1_raw
                    val y1 = if y1_raw > t.height: t.height else: y1_raw
                    # Iterate destination pixels and sample from texture
                    var py = y0
                    while py < y1:
                        var px = x0
                        while px < x1:
                            # Texture sampling and opacity blending would happen here
                            # when surfaces and textures have backing pixel stores
                            pass_do_nothing
                            px = px + 1
                        py = py + 1
                    self.logger.trace("draw_quad: rasterized {x1 - x0}x{y1 - y0} pixels onto surface {surface_id}")
                else:
                    self.logger.warn("draw_quad: surface {surface_id} not found, skipping")
                Ok(())

            GpuCommand.SetScissor(x, y, w, h):
                self.logger.trace("set_scissor: ({x},{y}) {w}x{h}")
                Ok(())

            GpuCommand.ClearScissor:
                self.logger.trace("clear_scissor")
                Ok(())

            GpuCommand.Present(swapchain_id):
                self.logger.trace("present: swapchain {swapchain_id}")
                Ok(())

            GpuCommand.Fence(id):
                self.logger.trace("fence: {id}")
                Ok(())

    # Flush all submitted buffers by executing them.
    me flush(surfaces: SurfacePool, rasterizer: Rasterizer) -> BrowserResult<()>:
        var pending = List<i64>()
        for id in self.submitted:
            pending.push(id)
        self.submitted = List<i64>()

        for buffer_id in pending:
            for buf in self.buffers:
                if buf.id == buffer_id:
                    self.execute(buf, surfaces, rasterizer)?
        Ok(())
