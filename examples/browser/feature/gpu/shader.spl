#![allow(REQC001)]
#![allow(REQC004)]
#![allow(unnamed_duplicate_typed_args)]
# Shader management for the GPU compositor.
# Manages shader sources, compilation, and program linking for
# future GPU-accelerated rendering (Vulkan/WebGPU/OpenGL).

use examples.browser.shared.error.{BrowserError, BrowserErrorKind, BrowserResult, paint_error}
use examples.browser.shared.logging.{Logger, LogLevel}

# ---------------------------------------------------------------------------
# Shader enums
# ---------------------------------------------------------------------------

enum ShaderStage:
    Vertex
    Fragment
    Compute

enum ShaderLanguage:
    Glsl
    Spirv
    Wgsl

fn shader_stage_equals(a: ShaderStage, b: ShaderStage) -> bool:
    match a:
        ShaderStage.Vertex:
            match b:
                ShaderStage.Vertex: true
                _: false
        ShaderStage.Fragment:
            match b:
                ShaderStage.Fragment: true
                _: false
        ShaderStage.Compute:
            match b:
                ShaderStage.Compute: true
                _: false

fn validate_shader_source(stage: ShaderStage, source: text) -> BrowserResult<()>:
    val trimmed = source.trim()
    if trimmed.len() == 0:
        return Err(paint_error("shader source is empty"))
    if not trimmed.contains("void main"):
        return Err(paint_error("shader source missing main function"))
    if not _balanced_delimiters(trimmed, "(", ")"):
        return Err(paint_error("shader source has unbalanced parentheses"))
    if not _balanced_delimiters(trimmed, "{", "}"):
        return Err(paint_error("shader source has unbalanced braces"))

    if shader_stage_equals(stage, ShaderStage.Vertex):
        if not trimmed.contains("gl_Position"):
            return Err(paint_error("vertex shader must assign gl_Position"))
    else if shader_stage_equals(stage, ShaderStage.Fragment):
        if not (trimmed.contains("out vec4") or trimmed.contains("gl_FragColor")):
            return Err(paint_error("fragment shader must declare or write a color output"))
    else if shader_stage_equals(stage, ShaderStage.Compute):
        if not trimmed.contains("local_size"):
            return Err(paint_error("compute shader must declare a local_size layout"))
    Ok(())

fn _balanced_delimiters(source: text, open_ch: text, close_ch: text) -> bool:
    var depth = 0
    var i = 0
    while i < source.len():
        val ch = source.slice(i, i + 1)
        if ch == open_ch:
            depth = depth + 1
        else if ch == close_ch:
            depth = depth - 1
            if depth < 0:
                return false
        i = i + 1
    depth == 0

# ---------------------------------------------------------------------------
# ShaderUniform — a uniform variable binding in a shader program.
# ---------------------------------------------------------------------------

class ShaderUniform:
    name: text
    uniform_type: text
    location: i64

    static fn create(name: text, uniform_type: text, location: i64) -> ShaderUniform:
        ShaderUniform(name: name, uniform_type: uniform_type, location: location)

# ---------------------------------------------------------------------------
# ShaderSource — a single shader stage source.
# ---------------------------------------------------------------------------

class ShaderSource:
    id: i64
    stage: ShaderStage
    language: ShaderLanguage
    source: text
    name: text
    is_compiled: bool

    static fn create(id: i64, stage: ShaderStage, language: ShaderLanguage, source: text, name: text) -> ShaderSource:
        ShaderSource(id: id, stage: stage, language: language, source: source, name: name, is_compiled: false)

# ---------------------------------------------------------------------------
# ShaderProgram — a linked vertex + fragment shader pair.
# ---------------------------------------------------------------------------

class ShaderProgram:
    id: i64
    vertex_id: i64
    fragment_id: i64
    uniforms: [ShaderUniform]
    is_compiled: bool

    static fn create(id: i64, vertex_id: i64, fragment_id: i64) -> ShaderProgram:
        ShaderProgram(
            id: id,
            vertex_id: vertex_id,
            fragment_id: fragment_id,
            uniforms: [],
            is_compiled: false
        )

# ---------------------------------------------------------------------------
# Built-in shader sources
# ---------------------------------------------------------------------------

# Passthrough vertex shader for textured quads.
val QUAD_VERTEX_SHADER = """#version 450
layout(location = 0) in vec2 a_position;
layout(location = 1) in vec2 a_texcoord;
layout(location = 0) out vec2 v_texcoord;
layout(set = 0, binding = 0) uniform Uniforms {
    mat4 u_transform;
};
void main() {
    v_texcoord = a_texcoord;
    gl_Position = u_transform * vec4(a_position, 0.0, 1.0);
}"""

# Texture sampling fragment shader for textured quads.
val QUAD_FRAGMENT_SHADER = """#version 450
layout(location = 0) in vec2 v_texcoord;
layout(location = 0) out vec4 o_color;
layout(set = 0, binding = 1) uniform sampler2D u_texture;
layout(set = 0, binding = 2) uniform FragUniforms {
    float u_opacity;
};
void main() {
    vec4 tex_color = texture(u_texture, v_texcoord);
    o_color = tex_color * u_opacity;
}"""

# Solid color fragment shader (no texture sampling).
val SOLID_FRAGMENT_SHADER = """#version 450
layout(location = 0) out vec4 o_color;
layout(set = 0, binding = 0) uniform FragUniforms {
    vec4 u_color;
};
void main() {
    o_color = u_color;
}"""

# ---------------------------------------------------------------------------
# ShaderManager — creates and manages shader sources and programs.
# ---------------------------------------------------------------------------

class ShaderManager:
    shaders: [ShaderSource]
    programs: [ShaderProgram]
    next_id: i64
    logger: Logger

    static fn new(logger: Logger) -> ShaderManager:
        logger.info("ShaderManager created")
        ShaderManager(
            shaders: [],
            programs: [],
            next_id: 1,
            logger: logger
        )

    # Create a new shader source and return its ID.
    me create_shader(stage: ShaderStage, source: text, name: text) -> i64:
        val id = self.next_id
        self.next_id = self.next_id + 1

        val stage_name = match stage:
            ShaderStage.Vertex: "vertex"
            ShaderStage.Fragment: "fragment"
            ShaderStage.Compute: "compute"

        val shader = ShaderSource.create(id, stage, ShaderLanguage.Glsl, source, name)
        self.shaders.push(shader)
        self.logger.debug("created {stage_name} shader '{name}' id={id}")
        id

    # Create a shader program by linking a vertex and fragment shader.
    me create_program(vertex_id: i64, fragment_id: i64) -> BrowserResult<ShaderProgram>:
        val vs_idx = self._find_shader_index(vertex_id)
        if vs_idx < 0:
            return Err(paint_error("vertex shader not found: id={vertex_id}"))
        val vs_shader = self.shaders[vs_idx]
        if not shader_stage_equals(vs_shader.stage, ShaderStage.Vertex):
            return Err(paint_error("shader {vertex_id} is not a vertex shader"))
        self.logger.trace("create_program: found vertex shader '{vs_shader.name}' id={vertex_id}")

        val fs_idx = self._find_shader_index(fragment_id)
        if fs_idx < 0:
            return Err(paint_error("fragment shader not found: id={fragment_id}"))
        val fs_shader = self.shaders[fs_idx]
        if not shader_stage_equals(fs_shader.stage, ShaderStage.Fragment):
            return Err(paint_error("shader {fragment_id} is not a fragment shader"))
        self.logger.trace("create_program: found fragment shader '{fs_shader.name}' id={fragment_id}")

        val prog_id = self.next_id
        self.next_id = self.next_id + 1

        var program = ShaderProgram.create(prog_id, vertex_id, fragment_id)
        program.is_compiled = vs_shader.is_compiled and fs_shader.is_compiled
        self.programs.push(program)
        self.logger.debug("created program id={prog_id} (vs={vertex_id}, fs={fragment_id})")
        Ok(program)

    # Compile a shader for the software rendering path by validating the source.
    # This does not produce backend bytecode, but it rejects malformed sources
    # before a program can be considered renderable.
    me compile_shader(shader_id: i64) -> BrowserResult<()>:
        val shader_idx = self._find_shader_index(shader_id)
        if shader_idx < 0:
            return Err(paint_error("shader not found: id={shader_id}"))
        var shader = self.shaders[shader_idx]
        self.logger.debug("compiling shader '{shader.name}' id={shader_id}")
        validate_shader_source(shader.stage, shader.source)?
        shader.is_compiled = true
        self.shaders[shader_idx] = shader
        self._refresh_program_compile_state()
        self.logger.trace("shader '{shader.name}' validated and marked compiled")
        Ok(())

    # Look up a program by ID.
    fn get_program(program_id: i64) -> ShaderProgram?:
        for prog in self.programs:
            if prog.id == program_id:
                return prog
        nil

    # Look up a shader source by ID.
    fn _get_shader(shader_id: i64) -> ShaderSource?:
        for shader in self.shaders:
            if shader.id == shader_id:
                return shader
        nil

    fn _find_shader_index(shader_id: i64) -> i64:
        var idx = 0
        while idx < self.shaders.len():
            if self.shaders[idx].id == shader_id:
                return idx
            idx = idx + 1
        -1

    me _refresh_program_compile_state():
        var idx = 0
        while idx < self.programs.len():
            var program = self.programs[idx]
            val vs_idx = self._find_shader_index(program.vertex_id)
            val fs_idx = self._find_shader_index(program.fragment_id)
            if vs_idx >= 0 and fs_idx >= 0:
                program.is_compiled = self.shaders[vs_idx].is_compiled and self.shaders[fs_idx].is_compiled
                self.programs[idx] = program
            idx = idx + 1

    # Register built-in shaders and return a program for textured quads.
    me register_builtins() -> BrowserResult<ShaderProgram>:
        val vs_id = self.create_shader(ShaderStage.Vertex, QUAD_VERTEX_SHADER, "builtin_quad_vs")
        val fs_id = self.create_shader(ShaderStage.Fragment, QUAD_FRAGMENT_SHADER, "builtin_quad_fs")
        val program = self.create_program(vs_id, fs_id)?

        # Add standard uniforms
        program.uniforms.push(ShaderUniform.create("u_transform", "mat4", 0))
        program.uniforms.push(ShaderUniform.create("u_texture", "sampler2D", 1))
        program.uniforms.push(ShaderUniform.create("u_opacity", "float", 2))

        self.logger.info("registered builtin quad shader program id={program.id}")
        Ok(program)

    # Register a solid-color shader program.
    me register_solid_program() -> BrowserResult<ShaderProgram>:
        val vs_id = self.create_shader(ShaderStage.Vertex, QUAD_VERTEX_SHADER, "builtin_solid_vs")
        val fs_id = self.create_shader(ShaderStage.Fragment, SOLID_FRAGMENT_SHADER, "builtin_solid_fs")
        val program = self.create_program(vs_id, fs_id)?

        program.uniforms.push(ShaderUniform.create("u_transform", "mat4", 0))
        program.uniforms.push(ShaderUniform.create("u_color", "vec4", 1))

        self.logger.info("registered builtin solid shader program id={program.id}")
        Ok(program)
