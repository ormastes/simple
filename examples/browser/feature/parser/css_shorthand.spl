# CSS Shorthand Property Expansion
#
# Converts shorthand CSS declarations into their constituent longhand
# declarations. For example, `margin: 10px 20px` expands to four
# individual margin-top/right/bottom/left declarations.
#
# Spec: https://www.w3.org/TR/css-cascade-4/#shorthand

use examples.browser.entity.dom.css_types.{CSSValue, CSSDeclaration}
use examples.browser.feature.style.logical_properties.{map_logical_to_physical, is_logical_property, WritingContext}

# =========================================================================
# Public API
# =========================================================================

fn expand_shorthand(property: text, value: CSSValue) -> [CSSDeclaration]:
    """Expand a shorthand property into longhand declarations.
    Returns a single-element list for non-shorthand properties.
    Handles CSS logical properties by mapping to physical equivalents.
    """
    val lower = property.to_lower()

    # Map logical properties to physical (LTR default)
    if is_logical_property(lower):
        val ctx = WritingContext.default_ctx()
        val physical = map_logical_to_physical(lower, ctx)
        return [CSSDeclaration(property: physical, value: value, important: false)]

    # Logical shorthands
    if lower == "margin-inline":
        return expand_pair(value, "margin-left", "margin-right")
    if lower == "margin-block":
        return expand_pair(value, "margin-top", "margin-bottom")
    if lower == "padding-inline":
        return expand_pair(value, "padding-left", "padding-right")
    if lower == "padding-block":
        return expand_pair(value, "padding-top", "padding-bottom")
    if lower == "inset":
        return expand_box_shorthand(value, "top", "right", "bottom", "left")
    if lower == "inset-inline":
        return expand_pair(value, "left", "right")
    if lower == "inset-block":
        return expand_pair(value, "top", "bottom")

    if lower == "margin":
        return expand_box_shorthand(value, "margin-top", "margin-right", "margin-bottom", "margin-left")

    if lower == "padding":
        return expand_box_shorthand(value, "padding-top", "padding-right", "padding-bottom", "padding-left")

    if lower == "border-width":
        return expand_box_shorthand(value, "border-top-width", "border-right-width", "border-bottom-width", "border-left-width")

    if lower == "border-style":
        return expand_box_shorthand_kw(value, "border-top-style", "border-right-style", "border-bottom-style", "border-left-style")

    if lower == "border-color":
        return expand_box_shorthand(value, "border-top-color", "border-right-color", "border-bottom-color", "border-left-color")

    if lower == "border":
        return expand_border(value)

    if lower == "border-top" or lower == "border-right" or lower == "border-bottom" or lower == "border-left":
        return expand_border_side(lower, value)

    if lower == "border-radius":
        return expand_border_radius(value)

    if lower == "overflow":
        return expand_pair(value, "overflow-x", "overflow-y")

    if lower == "gap":
        return expand_pair(value, "row-gap", "column-gap")

    if lower == "outline":
        return expand_outline(value)

    if lower == "flex":
        return expand_flex(value)

    if lower == "flex-flow":
        return expand_flex_flow(value)

    if lower == "background":
        return expand_background(value)

    if lower == "font":
        return expand_font(value)

    if lower == "text-decoration":
        return [CSSDeclaration(property: "text-decoration", value: value, important: false)]

    if lower == "list-style":
        return [CSSDeclaration(property: "list-style-type", value: value, important: false)]

    # Not a shorthand — return as-is
    [CSSDeclaration(property: property, value: value, important: false)]

fn is_shorthand(property: text) -> bool:
    """Check if a property name is a shorthand or logical property."""
    val lower = property.to_lower()
    if is_logical_property(lower):
        return true
    val shorthands = [
        "margin", "padding", "border", "border-width", "border-style",
        "border-color", "border-top", "border-right", "border-bottom",
        "border-left", "border-radius", "overflow", "gap", "flex",
        "flex-flow", "background", "font",
        "margin-inline", "margin-block", "padding-inline", "padding-block",
        "inset", "inset-inline", "inset-block", "outline"
    ]
    for s in shorthands:
        if s == lower:
            return true
    false

# =========================================================================
# Box shorthand: 1-4 values → top/right/bottom/left
# =========================================================================

fn expand_box_shorthand(value: CSSValue, top: text, right: text, bottom: text, left: text) -> [CSSDeclaration]:
    # For a single value shorthand, apply to all four sides
    [
        CSSDeclaration(property: top, value: value, important: false),
        CSSDeclaration(property: right, value: value, important: false),
        CSSDeclaration(property: bottom, value: value, important: false),
        CSSDeclaration(property: left, value: value, important: false)
    ]

fn expand_box_shorthand_kw(value: CSSValue, top: text, right: text, bottom: text, left: text) -> [CSSDeclaration]:
    [
        CSSDeclaration(property: top, value: value, important: false),
        CSSDeclaration(property: right, value: value, important: false),
        CSSDeclaration(property: bottom, value: value, important: false),
        CSSDeclaration(property: left, value: value, important: false)
    ]

# =========================================================================
# Pair shorthand: 1-2 values → x/y or row/column
# =========================================================================

fn expand_pair(value: CSSValue, first: text, second: text) -> [CSSDeclaration]:
    [
        CSSDeclaration(property: first, value: value, important: false),
        CSSDeclaration(property: second, value: value, important: false)
    ]

# =========================================================================
# border shorthand → width + style + color for all 4 sides
# =========================================================================

fn expand_border(value: CSSValue) -> [CSSDeclaration]:
    # Simplified: treat the value as border-width and set defaults for style/color
    var result: [CSSDeclaration] = []
    # border: <width> <style> <color> — we store the primary value as width
    # For a keyword like "solid", store as style
    match value:
        CSSValue.Keyword(v):
            # Likely a style keyword
            val sides = ["top", "right", "bottom", "left"]
            for side in sides:
                result = result + [
                    CSSDeclaration(property: "border-{side}-style", value: value, important: false)
                ]
        CSSValue.Length(v: _, unit: _):
            val sides = ["top", "right", "bottom", "left"]
            for side in sides:
                result = result + [
                    CSSDeclaration(property: "border-{side}-width", value: value, important: false)
                ]
        CSSValue.Color(color: _):
            val sides = ["top", "right", "bottom", "left"]
            for side in sides:
                result = result + [
                    CSSDeclaration(property: "border-{side}-color", value: value, important: false)
                ]
        _:
            val sides = ["top", "right", "bottom", "left"]
            for side in sides:
                result = result + [
                    CSSDeclaration(property: "border-{side}-width", value: value, important: false)
                ]
    result

fn expand_border_side(prop: text, value: CSSValue) -> [CSSDeclaration]:
    # e.g. "border-top" → border-top-width, border-top-style, border-top-color
    val side = prop.slice(7, prop.len())  # extract "top"/"right"/"bottom"/"left"
    match value:
        CSSValue.Keyword(v):
            [CSSDeclaration(property: "border-{side}-style", value: value, important: false)]
        CSSValue.Length(v: _, unit: _):
            [CSSDeclaration(property: "border-{side}-width", value: value, important: false)]
        CSSValue.Color(color: _):
            [CSSDeclaration(property: "border-{side}-color", value: value, important: false)]
        _:
            [CSSDeclaration(property: "border-{side}-width", value: value, important: false)]

fn expand_border_radius(value: CSSValue) -> [CSSDeclaration]:
    [
        CSSDeclaration(property: "border-top-left-radius", value: value, important: false),
        CSSDeclaration(property: "border-top-right-radius", value: value, important: false),
        CSSDeclaration(property: "border-bottom-right-radius", value: value, important: false),
        CSSDeclaration(property: "border-bottom-left-radius", value: value, important: false)
    ]

# =========================================================================
# flex shorthand → flex-grow, flex-shrink, flex-basis
# =========================================================================

fn expand_flex(value: CSSValue) -> [CSSDeclaration]:
    match value:
        CSSValue.Number(v):
            # Single number → flex-grow
            [
                CSSDeclaration(property: "flex-grow", value: CSSValue.Number(v: v), important: false),
                CSSDeclaration(property: "flex-shrink", value: CSSValue.Number(v: 1.0), important: false),
                CSSDeclaration(property: "flex-basis", value: CSSValue.Length(v: 0.0, unit: "px"), important: false)
            ]
        CSSValue.Keyword(v):
            if v == "auto":
                [
                    CSSDeclaration(property: "flex-grow", value: CSSValue.Number(v: 1.0), important: false),
                    CSSDeclaration(property: "flex-shrink", value: CSSValue.Number(v: 1.0), important: false),
                    CSSDeclaration(property: "flex-basis", value: CSSValue.Keyword(v: "auto"), important: false)
                ]
            else if v == "none":
                [
                    CSSDeclaration(property: "flex-grow", value: CSSValue.Number(v: 0.0), important: false),
                    CSSDeclaration(property: "flex-shrink", value: CSSValue.Number(v: 0.0), important: false),
                    CSSDeclaration(property: "flex-basis", value: CSSValue.Keyword(v: "auto"), important: false)
                ]
            else:
                [CSSDeclaration(property: "flex-grow", value: value, important: false)]
        _:
            # Treat as flex-basis
            [
                CSSDeclaration(property: "flex-grow", value: CSSValue.Number(v: 1.0), important: false),
                CSSDeclaration(property: "flex-shrink", value: CSSValue.Number(v: 1.0), important: false),
                CSSDeclaration(property: "flex-basis", value: value, important: false)
            ]

fn expand_flex_flow(value: CSSValue) -> [CSSDeclaration]:
    match value:
        CSSValue.Keyword(v):
            if v == "row" or v == "column" or v == "row-reverse" or v == "column-reverse":
                [CSSDeclaration(property: "flex-direction", value: value, important: false)]
            else if v == "wrap" or v == "nowrap" or v == "wrap-reverse":
                [CSSDeclaration(property: "flex-wrap", value: value, important: false)]
            else:
                [CSSDeclaration(property: "flex-direction", value: value, important: false)]
        _:
            [CSSDeclaration(property: "flex-direction", value: value, important: false)]

# =========================================================================
# background shorthand (simplified — extracts color only)
# =========================================================================

fn expand_background(value: CSSValue) -> [CSSDeclaration]:
    match value:
        CSSValue.Color(color: _):
            [CSSDeclaration(property: "background-color", value: value, important: false)]
        CSSValue.Url(v: _):
            [CSSDeclaration(property: "background-image", value: value, important: false)]
        CSSValue.Keyword(v):
            if v == "none":
                [CSSDeclaration(property: "background-image", value: CSSValue.Keyword(v: "none"), important: false)]
            else:
                [CSSDeclaration(property: "background-color", value: value, important: false)]
        _:
            [CSSDeclaration(property: "background-color", value: value, important: false)]

# =========================================================================
# font shorthand (simplified — extracts size only)
# =========================================================================

fn expand_font(value: CSSValue) -> [CSSDeclaration]:
    match value:
        CSSValue.Length(v: _, unit: _):
            [CSSDeclaration(property: "font-size", value: value, important: false)]
        CSSValue.Keyword(v):
            [CSSDeclaration(property: "font-family", value: value, important: false)]
        _:
            [CSSDeclaration(property: "font-size", value: value, important: false)]

# =========================================================================
# outline shorthand → outline-width + outline-style + outline-color
# =========================================================================

fn expand_outline(value: CSSValue) -> [CSSDeclaration]:
    match value:
        CSSValue.Length(v: _, unit: _):
            [CSSDeclaration(property: "outline-width", value: value, important: false)]
        CSSValue.Color(color: _):
            [CSSDeclaration(property: "outline-color", value: value, important: false)]
        CSSValue.Keyword(v):
            if v == "none":
                [
                    CSSDeclaration(property: "outline-style", value: CSSValue.Keyword(v: "none"), important: false),
                    CSSDeclaration(property: "outline-width", value: CSSValue.Length(v: 0.0, unit: "px"), important: false)
                ]
            else:
                [CSSDeclaration(property: "outline-style", value: value, important: false)]
        CSSValue.Number(v):
            [CSSDeclaration(property: "outline-width", value: CSSValue.Length(v: v, unit: "px"), important: false)]
        _:
            [CSSDeclaration(property: "outline-style", value: value, important: false)]
