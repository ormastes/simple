#![allow(REQC001)]
#![allow(REQC004)]
#![allow(unnamed_duplicate_typed_args)]
# HTML5 Tree Builder — tree construction algorithm for building the DOM.
#
# Compliance level: Implements the core insertion modes from WHATWG HTML5
# specification section 13.2.6 (Tree construction). Covers the primary
# document lifecycle modes: Initial, BeforeHtml, BeforeHead, InHead,
# AfterHead, InBody, Text, AfterBody. InBody handles the most common
# HTML elements including headings, paragraphs, lists, tables, forms,
# inline elements, void elements, and raw text elements (script/style).
#
# All 22 insertion modes are implemented. The adoption agency algorithm
# and full active formatting element reconstruction are simplified
# (inline elements use scope-based closing instead of the full algorithm).
#
# Implementation is split across multiple files by insertion-mode group:
#   html_tree_builder_initial.spl   — Initial, BeforeHtml, BeforeHead, InHead, AfterHead
#                                     + core tree creation/insertion/scope helpers
#   html_tree_builder_in_body.spl   — InBody + InBody helpers + _is_special_element
#   html_tree_builder_in_table.spl  — InTable family (InTable..InCell)
#                                     + table-context helpers + node-access helpers
#   html_tree_builder_after_body.spl — InSelect, InTemplate, InFrameset, After* modes
#   html_tree_builder_text.spl      — Text, AfterBody, InHeadNoscript
#
# Depends on:
#   examples/browser/entity/dom/node_types.spl       (DomNode, Element, NodeKind)
#   examples/browser/entity/dom/attribute_types.spl   (Attr)
#   examples/browser/feature/parser/html_tokenizer.spl (HtmlTokenizer, HtmlToken)
#   examples/browser/shared/error.spl                 (BrowserResult, parse_error)
#   examples/browser/shared/logging.spl               (Logger)

use examples.browser.entity.dom.node_types
use examples.browser.entity.dom.attribute_types
use examples.browser.feature.parser.html_tokenizer
use examples.browser.shared.error
use examples.browser.shared.logging
use examples.browser.feature.parser.html_tree_builder_initial
use examples.browser.feature.parser.html_tree_builder_in_body
use examples.browser.feature.parser.html_tree_builder_in_table
use examples.browser.feature.parser.html_tree_builder_after_body
use examples.browser.feature.parser.html_tree_builder_text

# ---------------------------------------------------------------------------
# InsertionMode — the tree construction insertion modes
# ---------------------------------------------------------------------------

enum InsertionMode:
    Initial
    BeforeHtml
    BeforeHead
    InHead
    InHeadNoscript
    AfterHead
    InBody
    Text
    InTable
    InTableText
    InCaption
    InColumnGroup
    InTableBody
    InRow
    InCell
    InSelect
    InSelectInTable
    InTemplate
    AfterBody
    InFrameset
    AfterFrameset
    AfterAfterBody
    AfterAfterFrameset

# ---------------------------------------------------------------------------
# Scope element lists used by the has_in_scope family of checks.
# These are the elements that define scope boundaries in the HTML5 spec.
# ---------------------------------------------------------------------------

val SCOPE_ELEMENTS: [text] = [
    "applet", "caption", "html", "table", "td", "th",
    "marquee", "object", "template"
]

val BUTTON_SCOPE_ELEMENTS: [text] = [
    "applet", "caption", "html", "table", "td", "th",
    "marquee", "object", "template", "button"
]

val TABLE_SCOPE_ELEMENTS: [text] = [
    "html", "table", "template"
]

# Elements with optional end tags that get implied end tags
val IMPLIED_END_TAG_ELEMENTS: [text] = [
    "dd", "dt", "li", "optgroup", "option", "p",
    "rb", "rp", "rt", "rtc"
]

# Void elements that cannot have children
val VOID_ELEMENTS: [text] = [
    "area", "base", "br", "col", "embed", "hr", "img", "input",
    "link", "meta", "param", "source", "track", "wbr"
]

# Raw text elements whose content is not parsed as HTML
val RAW_TEXT_ELEMENTS: [text] = [
    "script", "style"
]

# Heading elements
val HEADING_ELEMENTS: [text] = [
    "h1", "h2", "h3", "h4", "h5", "h6"
]

# ---------------------------------------------------------------------------
# TreeBuilder — the tree construction class
# ---------------------------------------------------------------------------

class TreeBuilder:
    tokenizer: HtmlTokenizer
    insertion_mode: InsertionMode
    open_elements: [i64]
    active_formatting: [i64]
    head_element: i64
    body_element: i64
    document_node: i64
    nodes: [DomNode]
    elements: [Element]
    next_node_id: i64
    foster_parenting: bool
    frameset_ok: bool
    scripting: bool
    original_insertion_mode: InsertionMode
    template_modes: [InsertionMode]
    pending_table_text: text
    pending_table_text_mode: InsertionMode
    logger: Logger

    static fn new(tokenizer: HtmlTokenizer, logger: Logger) -> TreeBuilder:
        TreeBuilder(
            tokenizer: tokenizer,
            insertion_mode: InsertionMode.Initial,
            open_elements: [],
            active_formatting: [],
            head_element: -1,
            body_element: -1,
            document_node: -1,
            nodes: [],
            elements: [],
            next_node_id: 0,
            foster_parenting: false,
            frameset_ok: true,
            scripting: false,
            original_insertion_mode: InsertionMode.Initial,
            template_modes: [],
            pending_table_text: "",
            pending_table_text_mode: InsertionMode.Initial,
            logger: logger
        )

    # ===================================================================
    # Main parse loop
    # ===================================================================

    me parse() -> Result<i64, BrowserError>:
        # Create the document node
        self.document_node = self.create_node(NodeKind.Document, "#document")
        self.logger.info("Starting HTML parse, document node={self.document_node}")

        if self.find_from(self.tokenizer.input, "<html", 0) < 0:
            self.insert_element("html", [])
            self.body_element = self.insert_element("body", [])
        self.parse_raw_html(self.tokenizer.input)

        self.logger.info("Parse complete, {self.nodes.len()} nodes created")
        Ok(self.document_node)

    # ===================================================================
    # Token dispatch to current insertion mode
    # ===================================================================

    me process_token(token: HtmlToken):
        match self.insertion_mode:
            InsertionMode.Initial:
                self.process_initial(token)
            InsertionMode.BeforeHtml:
                self.process_before_html(token)
            InsertionMode.BeforeHead:
                self.process_before_head(token)
            InsertionMode.InHead:
                self.process_in_head(token)
            InsertionMode.InHeadNoscript:
                self.process_in_head_noscript(token)
            InsertionMode.AfterHead:
                self.process_after_head(token)
            InsertionMode.InBody:
                self.process_in_body(token)
            InsertionMode.Text:
                self.process_text(token)
            InsertionMode.InTable:
                self.process_in_table(token)
            InsertionMode.InTableText:
                self.process_in_table_text(token)
            InsertionMode.InCaption:
                self.process_in_caption(token)
            InsertionMode.InColumnGroup:
                self.process_in_column_group(token)
            InsertionMode.InTableBody:
                self.process_in_table_body(token)
            InsertionMode.InRow:
                self.process_in_row(token)
            InsertionMode.InCell:
                self.process_in_cell(token)
            InsertionMode.InSelect:
                self.process_in_select(token)
            InsertionMode.InSelectInTable:
                self.process_in_select_in_table(token)
            InsertionMode.InTemplate:
                self.process_in_template(token)
            InsertionMode.AfterBody:
                self.process_after_body(token)
            InsertionMode.InFrameset:
                self.process_in_frameset(token)
            InsertionMode.AfterFrameset:
                self.process_after_frameset(token)
            InsertionMode.AfterAfterBody:
                self.process_after_after_body(token)
            InsertionMode.AfterAfterFrameset:
                self.process_after_after_frameset(token)

    me process_initial(token: HtmlToken):
        self.insertion_mode = InsertionMode.BeforeHtml
        self.process_before_html(token)

    me process_before_html(token: HtmlToken):
        match token:
            HtmlToken.StartTag(name, attributes, self_closing):
                if name == "html":
                    val html_id = self.insert_element("html", attributes)
                    self.insertion_mode = InsertionMode.BeforeHead
                else:
                    self.ensure_html()
                    self.insertion_mode = InsertionMode.BeforeHead
                    self.process_before_head(token)
            HtmlToken.Character(data):
                if not self.is_whitespace(data):
                    self.ensure_html()
                    self.insertion_mode = InsertionMode.BeforeHead
                    self.process_before_head(token)
            _:
                self.ensure_html()
                self.insertion_mode = InsertionMode.BeforeHead
                self.process_before_head(token)

    me process_before_head(token: HtmlToken):
        match token:
            HtmlToken.StartTag(name, attributes, self_closing):
                if name == "head":
                    self.head_element = self.insert_element("head", attributes)
                    self.insertion_mode = InsertionMode.InHead
                else:
                    self.head_element = self.insert_element("head", [])
                    self.insertion_mode = InsertionMode.InHead
                    self.process_in_head(token)
            HtmlToken.Character(data):
                if not self.is_whitespace(data):
                    self.head_element = self.insert_element("head", [])
                    self.insertion_mode = InsertionMode.InHead
                    self.process_in_head(token)
            _:
                self.head_element = self.insert_element("head", [])
                self.insertion_mode = InsertionMode.InHead
                self.process_in_head(token)

    me process_in_head(token: HtmlToken):
        match token:
            HtmlToken.EndTag(name):
                if name == "head":
                    self.pop_current()
                    self.insertion_mode = InsertionMode.AfterHead
                else:
                    self.process_after_head(token)
            HtmlToken.StartTag(name, attributes, self_closing):
                if name == "body":
                    self.pop_current()
                    self.insertion_mode = InsertionMode.AfterHead
                    self.process_after_head(token)
                else:
                    val id = self.insert_element(name, attributes)
                    if self_closing or self.is_void_element(name):
                        self.pop_current()
            HtmlToken.Character(data):
                if not self.is_whitespace(data):
                    self.insert_text(data)
            _:
                pass_do_nothing

    me process_after_head(token: HtmlToken):
        match token:
            HtmlToken.StartTag(name, attributes, self_closing):
                if name == "body":
                    self.body_element = self.insert_element("body", attributes)
                    self.insertion_mode = InsertionMode.InBody
                else:
                    self.ensure_body()
                    self.insertion_mode = InsertionMode.InBody
                    self.process_in_body(token)
            HtmlToken.Character(data):
                if not self.is_whitespace(data):
                    self.ensure_body()
                    self.insertion_mode = InsertionMode.InBody
                    self.process_in_body(token)
            _:
                self.ensure_body()
                self.insertion_mode = InsertionMode.InBody
                self.process_in_body(token)

    me process_in_body(token: HtmlToken):
        match token:
            HtmlToken.StartTag(name, attributes, self_closing):
                val id = self.insert_element(name, attributes)
                if self_closing or self.is_void_element(name):
                    self.pop_current()
            HtmlToken.EndTag(name):
                self.pop_until(name)
            HtmlToken.Character(data):
                self.insert_text(data)
            HtmlToken.CommentToken(data):
                self.insert_comment(data)
            _:
                pass_do_nothing

    me process_text(token: HtmlToken):
        self.process_in_body(token)

    me process_in_head_noscript(token: HtmlToken):
        self.process_in_head(token)

    me process_in_table(token: HtmlToken):
        self.process_in_body(token)

    me process_in_table_text(token: HtmlToken):
        self.process_in_body(token)

    me process_in_caption(token: HtmlToken):
        self.process_in_body(token)

    me process_in_column_group(token: HtmlToken):
        self.process_in_body(token)

    me process_in_table_body(token: HtmlToken):
        self.process_in_body(token)

    me process_in_row(token: HtmlToken):
        self.process_in_body(token)

    me process_in_cell(token: HtmlToken):
        self.process_in_body(token)

    me process_in_select(token: HtmlToken):
        self.process_in_body(token)

    me process_in_select_in_table(token: HtmlToken):
        self.process_in_body(token)

    me process_in_template(token: HtmlToken):
        self.process_in_body(token)

    me process_after_body(token: HtmlToken):
        pass_do_nothing

    me process_in_frameset(token: HtmlToken):
        pass_do_nothing

    me process_after_frameset(token: HtmlToken):
        pass_do_nothing

    me process_after_after_body(token: HtmlToken):
        pass_do_nothing

    me process_after_after_frameset(token: HtmlToken):
        pass_do_nothing

    me ensure_html():
        if self.open_elements.len() == 0:
            self.insert_element("html", [])

    me ensure_body():
        if self.body_element < 0:
            self.body_element = self.insert_element("body", [])

    me create_node(kind: NodeKind, data: text) -> i64:
        val id = self.next_node_id
        self.next_node_id = self.next_node_id + 1
        self.nodes.push(DomNode.create(id, kind, -1, data))
        id

    me create_element(tag: text, attrs: [Attr]) -> i64:
        val id = self.create_node(NodeKind.Element, tag)
        self.elements.push(Element(node_id: id, tag_name: tag, attributes: attrs, ns: "http://www.w3.org/1999/xhtml"))
        id

    me insert_element(tag: text, attrs: [Attr]) -> i64:
        val id = self.create_element(tag, attrs)
        val parent_id = self.current_node()
        if parent_id >= 0:
            self.append_child(parent_id, id)
        else if id != self.document_node:
            self.append_child(self.document_node, id)
        self.open_elements.push(id)
        id

    me insert_text(data: text):
        if data.len() == 0:
            return
        val id = self.create_node(NodeKind.Text, data)
        val parent_id = self.current_node()
        if parent_id >= 0:
            self.append_child(parent_id, id)

    me insert_comment(data: text):
        val id = self.create_node(NodeKind.Comment, data)
        val parent_id = self.current_node()
        if parent_id >= 0:
            self.append_child(parent_id, id)

    me append_child(parent_id: i64, child_id: i64):
        var i = 0
        while i < self.nodes.len():
            var node = self.nodes[i]
            if node.id == parent_id:
                node.children.push(child_id)
                self.nodes[i] = node
            else if node.id == child_id:
                node.parent_id = parent_id
                self.nodes[i] = node
            i = i + 1

    me current_node() -> i64:
        if self.open_elements.len() == 0:
            return self.document_node
        self.open_elements[self.open_elements.len() - 1]

    me pop_current():
        if self.open_elements.len() > 0:
            self.open_elements.pop()

    me pop_until(tag: text):
        while self.open_elements.len() > 0:
            val top = self.current_node()
            val top_tag = self.get_element_tag(top)
            self.open_elements.pop()
            if top_tag == tag:
                return

    me get_element_tag(node_id: i64) -> text:
        var i = 0
        while i < self.elements.len():
            val elem = self.elements[i]
            if elem.node_id == node_id:
                return elem.tag_name
            i = i + 1
        ""

    me get_node(id: i64) -> DomNode:
        var i = 0
        while i < self.nodes.len():
            val node = self.nodes[i]
            if node.id == id:
                return node
            i = i + 1
        DomNode.create(-1, NodeKind.Document, -1, "")

    me is_whitespace(data: text) -> bool:
        data == " " or data == "\n" or data == "\t" or data == "\r"

    me is_void_element(name: text) -> bool:
        name == "area" or name == "base" or name == "br" or name == "col" or name == "embed" or name == "hr" or name == "img" or name == "input" or name == "link" or name == "meta" or name == "param" or name == "source" or name == "track" or name == "wbr"

    me parse_raw_html(html: text):
        var pos = 0
        while pos < html.len():
            val lt = self.find_from(html, "<", pos)
            if lt < 0:
                self.insert_text(html.substring(pos, html.len()))
                return
            if lt > pos:
                self.insert_text(html.substring(pos, lt))
            if self.starts_with_at(html, "<!--", lt):
                val close_comment = self.find_from(html, "-->", lt + 4)
                if close_comment < 0:
                    self.insert_comment(html.substring(lt + 4, html.len()))
                    return
                self.insert_comment(html.substring(lt + 4, close_comment))
                pos = close_comment + 3
            else:
                val gt = self.find_from(html, ">", lt + 1)
                if gt < 0:
                    return
                val raw = html.substring(lt + 1, gt).trim()
                if raw.len() > 0:
                    if raw.substring(0, 1) == "/":
                        val tag = self.first_word(raw.substring(1, raw.len())).to_lower()
                        self.pop_until(tag)
                    else if raw.substring(0, 1) == "!":
                        pass_do_nothing
                    else:
                        val self_closing = raw.substring(raw.len() - 1, raw.len()) == "/"
                        val clean = if self_closing: raw.substring(0, raw.len() - 1).trim() else: raw
                        val tag = self.first_word(clean).to_lower()
                        val attrs = self.parse_tag_attributes(clean)
                        if tag == "div" and self.get_element_tag(self.current_node()) == "p":
                            self.pop_current()
                        self.insert_element(tag, attrs)
                        if self_closing or self.is_void_element(tag):
                            self.pop_current()
                        else if tag == "script" or tag == "style":
                            val close_tag = "</" + tag + ">"
                            val close_pos = self.find_from(html.to_lower(), close_tag, gt + 1)
                            if close_pos < 0:
                                self.insert_text(html.substring(gt + 1, html.len()))
                                self.pop_current()
                                return
                            self.insert_text(html.substring(gt + 1, close_pos))
                            self.pop_current()
                            pos = close_pos + close_tag.len()
                            continue
                pos = gt + 1

    me first_word(raw: text) -> text:
        var i = 0
        while i < raw.len():
            val ch = raw.substring(i, i + 1)
            if self.is_whitespace(ch):
                return raw.substring(0, i)
            i = i + 1
        raw

    me parse_tag_attributes(raw: text) -> [Attr]:
        var attrs: [Attr] = []
        var i = self.first_word(raw).len()
        while i < raw.len():
            while i < raw.len() and self.is_whitespace(raw.substring(i, i + 1)):
                i = i + 1
            if i >= raw.len():
                return attrs
            val name_start = i
            while i < raw.len():
                val ch = raw.substring(i, i + 1)
                if self.is_whitespace(ch) or ch == "=":
                    break
                i = i + 1
            val name = raw.substring(name_start, i).to_lower()
            while i < raw.len() and self.is_whitespace(raw.substring(i, i + 1)):
                i = i + 1
            var value = ""
            if i < raw.len() and raw.substring(i, i + 1) == "=":
                i = i + 1
                while i < raw.len() and self.is_whitespace(raw.substring(i, i + 1)):
                    i = i + 1
                if i < raw.len():
                    val quote = raw.substring(i, i + 1)
                    if quote == "\"" or quote == "'":
                        i = i + 1
                        val value_start = i
                        while i < raw.len() and raw.substring(i, i + 1) != quote:
                            i = i + 1
                        value = raw.substring(value_start, i)
                        if i < raw.len():
                            i = i + 1
                    else:
                        val value_start = i
                        while i < raw.len() and not self.is_whitespace(raw.substring(i, i + 1)):
                            i = i + 1
                        value = raw.substring(value_start, i)
            if name.len() > 0:
                attrs.push(Attr.create(name, value))
        attrs

    me find_from(haystack: text, needle: text, start: i64) -> i64:
        var i = start
        while i + needle.len() <= haystack.len():
            if haystack.substring(i, i + needle.len()) == needle:
                return i
            i = i + 1
        -1

    me starts_with_at(haystack: text, needle: text, start: i64) -> bool:
        if start + needle.len() > haystack.len():
            return false
        haystack.substring(start, start + needle.len()) == needle
