# JIT compiler for the JS engine.
# Provides profiling, hotspot detection, baseline and optimizing compilation tiers,
# and a register-based IR executor.

use std.js.types.bytecode_types.(BytecodeChunk, OpCode, ConstantPool)
use std.js.types.js_types.(JsValue)
use browser.shared.error.(BrowserError, BrowserResult, script_error)
use browser.shared.logging.(Logger, LogLevel)

# --- JIT tiers ---

enum JitTier:
    Baseline
    Optimizing

# --- Type information for specialization ---

enum JitTypeTag:
    Unknown
    TagNumber
    TagBoolean
    TagString
    TagObject
    TagNull
    TagUndefined

# --- JIT intermediate representation (register-based) ---

enum JitIR:
    LoadConst(reg: i64, value: JsValue)
    LoadLocal(reg: i64, slot: i64)
    StoreLocal(slot: i64, reg: i64)
    LoadGlobal(reg: i64, name: text)
    StoreGlobal(name: text, reg: i64)
    Add(dst: i64, lhs: i64, rhs: i64)
    Sub(dst: i64, lhs: i64, rhs: i64)
    Mul(dst: i64, lhs: i64, rhs: i64)
    Div(dst: i64, lhs: i64, rhs: i64)
    Mod(dst: i64, lhs: i64, rhs: i64)
    IntAdd(dst: i64, lhs: i64, rhs: i64)
    IntSub(dst: i64, lhs: i64, rhs: i64)
    IntMul(dst: i64, lhs: i64, rhs: i64)
    Compare(dst: i64, lhs: i64, rhs: i64, op: text)
    Negate(dst: i64, src: i64)
    LogicalNot(dst: i64, src: i64)
    Jump(offset: i64)
    JumpIfFalse(reg: i64, offset: i64)
    Call(dst: i64, func_reg: i64, arg_count: i64)
    Return(reg: i64)
    Guard(reg: i64, expected_type: JitTypeTag)
    Pop(reg: i64)
    Dup(dst: i64, src: i64)
    GetProperty(dst: i64, obj_reg: i64, name: text)
    SetProperty(obj_reg: i64, name: text, val_reg: i64)
    NewObject(dst: i64)
    NewArray(dst: i64, count: i64)
    Nop

# --- Profiling data ---

class JitProfile:
    function_name: text
    call_count: i64
    hot_threshold: i64
    is_compiled: bool
    tier: JitTier
    deopt_count: i64
    type_observations: [JitTypeTag]
    optimizing_threshold: i64

    static fn create(function_name: text, hot_threshold: i64) -> JitProfile:
        JitProfile(
            function_name: function_name,
            call_count: 0,
            hot_threshold: hot_threshold,
            is_compiled: false,
            tier: JitTier.Baseline,
            deopt_count: 0,
            type_observations: [JitTypeTag](),
            optimizing_threshold: hot_threshold * 5
        )

# --- Compiled function handle ---

class CompiledFunction:
    name: text
    tier: JitTier
    native_code_id: i64
    ir: [JitIR]

# --- Register file for IR execution ---

class JitRegisterFile:
    regs: [JsValue]
    size: i64

    static fn create(size: i64) -> JitRegisterFile:
        var regs = [JsValue]()
        var i = 0
        while i < size:
            regs.push(JsValue.Undefined)
            i = i + 1
        JitRegisterFile(regs: regs, size: size)

    fn get(idx: i64) -> JsValue:
        self.regs.get(idx)

    me set(idx: i64, value: JsValue):
        self.regs.set(idx, value)

    me reset():
        var i = 0
        while i < self.size:
            self.regs.set(i, JsValue.Undefined)
            i = i + 1

# --- JIT executor ---

class JitExecutor:
    register_file: JitRegisterFile
    locals: [JsValue]
    logger: Logger

    static fn create(logger: Logger) -> JitExecutor:
        JitExecutor(
            register_file: JitRegisterFile.create(256),
            locals: [JsValue](),
            logger: logger
        )

    me execute(ir: [JitIR], args: [JsValue]) -> BrowserResult<JsValue>:
        self.register_file.reset()
        # Load arguments into first registers
        var arg_i = 0
        while arg_i < args.len():
            self.register_file.set(arg_i, args.get(arg_i))
            arg_i = arg_i + 1
        # Initialize locals with enough slots
        self.locals = [JsValue]()
        var li = 0
        while li < 256:
            self.locals.push(JsValue.Undefined)
            li = li + 1

        var pc = 0
        val ir_len = ir.len()
        while pc < ir_len:
            val instr = ir.get(pc)
            val step_result = self._execute_instruction(instr, pc)
            if step_result.is_return:
                return Ok(step_result.value)
            if step_result.is_guard_fail:
                return Err(script_error("JIT guard failure: type mismatch, deopt required"))
            pc = step_result.next_pc
        Ok(JsValue.Undefined)

    me _execute_instruction(instr: JitIR, pc: i64) -> JitStepResult:
        match instr:
            JitIR.LoadConst(reg, value):
                self.register_file.set(reg, value)
                JitStepResult.next(pc + 1)
            JitIR.LoadLocal(reg, slot):
                self.register_file.set(reg, self.locals.get(slot))
                JitStepResult.next(pc + 1)
            JitIR.StoreLocal(slot, reg):
                val v = self.register_file.get(reg)
                self.locals.set(slot, v)
                JitStepResult.next(pc + 1)
            JitIR.LoadGlobal(reg, name):
                # Globals not tracked in JIT executor; return Undefined
                self.register_file.set(reg, JsValue.Undefined)
                JitStepResult.next(pc + 1)
            JitIR.StoreGlobal(name, reg):
                # Globals store is a no-op in JIT executor
                JitStepResult.next(pc + 1)
            JitIR.Add(dst, lhs, rhs):
                val result = self._js_add(self.register_file.get(lhs), self.register_file.get(rhs))
                self.register_file.set(dst, result)
                JitStepResult.next(pc + 1)
            JitIR.Sub(dst, lhs, rhs):
                val result = self._js_sub(self.register_file.get(lhs), self.register_file.get(rhs))
                self.register_file.set(dst, result)
                JitStepResult.next(pc + 1)
            JitIR.Mul(dst, lhs, rhs):
                val result = self._js_mul(self.register_file.get(lhs), self.register_file.get(rhs))
                self.register_file.set(dst, result)
                JitStepResult.next(pc + 1)
            JitIR.Div(dst, lhs, rhs):
                val result = self._js_div(self.register_file.get(lhs), self.register_file.get(rhs))
                self.register_file.set(dst, result)
                JitStepResult.next(pc + 1)
            JitIR.Mod(dst, lhs, rhs):
                val result = self._js_mod(self.register_file.get(lhs), self.register_file.get(rhs))
                self.register_file.set(dst, result)
                JitStepResult.next(pc + 1)
            JitIR.IntAdd(dst, lhs, rhs):
                val result = self._int_add(self.register_file.get(lhs), self.register_file.get(rhs))
                self.register_file.set(dst, result)
                JitStepResult.next(pc + 1)
            JitIR.IntSub(dst, lhs, rhs):
                val result = self._int_sub(self.register_file.get(lhs), self.register_file.get(rhs))
                self.register_file.set(dst, result)
                JitStepResult.next(pc + 1)
            JitIR.IntMul(dst, lhs, rhs):
                val result = self._int_mul(self.register_file.get(lhs), self.register_file.get(rhs))
                self.register_file.set(dst, result)
                JitStepResult.next(pc + 1)
            JitIR.Compare(dst, lhs, rhs, op):
                val result = self._js_compare(self.register_file.get(lhs), self.register_file.get(rhs), op)
                self.register_file.set(dst, result)
                JitStepResult.next(pc + 1)
            JitIR.Negate(dst, src):
                val v = self.register_file.get(src)
                val result = self._js_negate(v)
                self.register_file.set(dst, result)
                JitStepResult.next(pc + 1)
            JitIR.LogicalNot(dst, src):
                val v = self.register_file.get(src)
                val result = self._js_logical_not(v)
                self.register_file.set(dst, result)
                JitStepResult.next(pc + 1)
            JitIR.Jump(offset):
                JitStepResult.next(offset)
            JitIR.JumpIfFalse(reg, offset):
                val v = self.register_file.get(reg)
                if self._is_falsy(v):
                    JitStepResult.next(offset)
                else:
                    JitStepResult.next(pc + 1)
            JitIR.Call(dst, func_reg, arg_count):
                # In the JIT executor, calls bail out to interpreter
                self.register_file.set(dst, JsValue.Undefined)
                JitStepResult.next(pc + 1)
            JitIR.Return(reg):
                val v = self.register_file.get(reg)
                JitStepResult.ret(v)
            JitIR.Guard(reg, expected_type):
                val v = self.register_file.get(reg)
                if self._check_type(v, expected_type):
                    JitStepResult.next(pc + 1)
                else:
                    JitStepResult.guard_fail()
            JitIR.Pop(reg):
                self.register_file.set(reg, JsValue.Undefined)
                JitStepResult.next(pc + 1)
            JitIR.Dup(dst, src):
                self.register_file.set(dst, self.register_file.get(src))
                JitStepResult.next(pc + 1)
            JitIR.GetProperty(dst, obj_reg, name):
                # Property access not supported in JIT executor; return Undefined
                self.register_file.set(dst, JsValue.Undefined)
                JitStepResult.next(pc + 1)
            JitIR.SetProperty(obj_reg, name, val_reg):
                JitStepResult.next(pc + 1)
            JitIR.NewObject(dst):
                self.register_file.set(dst, JsValue.Undefined)
                JitStepResult.next(pc + 1)
            JitIR.NewArray(dst, count):
                self.register_file.set(dst, JsValue.Undefined)
                JitStepResult.next(pc + 1)
            JitIR.Nop:
                JitStepResult.next(pc + 1)

    # --- JS arithmetic helpers ---

    fn _js_add(a: JsValue, b: JsValue) -> JsValue:
        match a:
            JsValue.Number(va):
                match b:
                    JsValue.Number(vb):
                        JsValue.Number(v: va + vb)
                    JsValue.String(vb):
                        JsValue.String(v: "{va}{vb}")
                    _: JsValue.Number(v: va)
            JsValue.String(va):
                match b:
                    JsValue.String(vb):
                        JsValue.String(v: "{va}{vb}")
                    JsValue.Number(vb):
                        JsValue.String(v: "{va}{vb}")
                    _: JsValue.String(v: va)
            _: JsValue.Undefined

    fn _js_sub(a: JsValue, b: JsValue) -> JsValue:
        match a:
            JsValue.Number(va):
                match b:
                    JsValue.Number(vb): JsValue.Number(v: va - vb)
                    _: JsValue.Number(v: va)
            _: JsValue.Undefined

    fn _js_mul(a: JsValue, b: JsValue) -> JsValue:
        match a:
            JsValue.Number(va):
                match b:
                    JsValue.Number(vb): JsValue.Number(v: va * vb)
                    _: JsValue.Number(v: va)
            _: JsValue.Undefined

    fn _js_div(a: JsValue, b: JsValue) -> JsValue:
        match a:
            JsValue.Number(va):
                match b:
                    JsValue.Number(vb):
                        if vb == 0.0:
                            JsValue.Undefined
                        else:
                            JsValue.Number(v: va / vb)
                    _: JsValue.Undefined
            _: JsValue.Undefined

    fn _js_mod(a: JsValue, b: JsValue) -> JsValue:
        match a:
            JsValue.Number(va):
                match b:
                    JsValue.Number(vb):
                        if vb == 0.0:
                            JsValue.Undefined
                        else:
                            JsValue.Number(v: va % vb)
                    _: JsValue.Undefined
            _: JsValue.Undefined

    fn _int_add(a: JsValue, b: JsValue) -> JsValue:
        match a:
            JsValue.Number(va):
                match b:
                    JsValue.Number(vb): JsValue.Number(v: va + vb)
                    _: JsValue.Undefined
            _: JsValue.Undefined

    fn _int_sub(a: JsValue, b: JsValue) -> JsValue:
        match a:
            JsValue.Number(va):
                match b:
                    JsValue.Number(vb): JsValue.Number(v: va - vb)
                    _: JsValue.Undefined
            _: JsValue.Undefined

    fn _int_mul(a: JsValue, b: JsValue) -> JsValue:
        match a:
            JsValue.Number(va):
                match b:
                    JsValue.Number(vb): JsValue.Number(v: va * vb)
                    _: JsValue.Undefined
            _: JsValue.Undefined

    fn _js_negate(v: JsValue) -> JsValue:
        match v:
            JsValue.Number(n): JsValue.Number(v: 0.0 - n)
            _: JsValue.Undefined

    fn _js_logical_not(v: JsValue) -> JsValue:
        JsValue.Boolean(v: self._is_falsy(v))

    fn _js_compare(a: JsValue, b: JsValue, op: text) -> JsValue:
        match a:
            JsValue.Number(va):
                match b:
                    JsValue.Number(vb):
                        if op == "eq":
                            JsValue.Boolean(v: va == vb)
                        else if op == "ne":
                            JsValue.Boolean(v: va != vb)
                        else if op == "lt":
                            JsValue.Boolean(v: va < vb)
                        else if op == "gt":
                            JsValue.Boolean(v: va > vb)
                        else if op == "le":
                            JsValue.Boolean(v: va <= vb)
                        else if op == "ge":
                            JsValue.Boolean(v: va >= vb)
                        else:
                            JsValue.Boolean(v: false)
                    _: JsValue.Boolean(v: false)
            JsValue.String(va):
                match b:
                    JsValue.String(vb):
                        if op == "eq":
                            JsValue.Boolean(v: va == vb)
                        else if op == "ne":
                            JsValue.Boolean(v: va != vb)
                        else:
                            JsValue.Boolean(v: false)
                    _: JsValue.Boolean(v: false)
            _: JsValue.Boolean(v: false)

    fn _is_falsy(v: JsValue) -> bool:
        match v:
            JsValue.Undefined: true
            JsValue.Null: true
            JsValue.Boolean(b): not b
            JsValue.Number(n): n == 0.0
            JsValue.String(s): s == ""
            _: false

    fn _check_type(v: JsValue, expected: JitTypeTag) -> bool:
        match expected:
            JitTypeTag.Unknown: true
            JitTypeTag.TagNumber:
                match v:
                    JsValue.Number(_): true
                    _: false
            JitTypeTag.TagBoolean:
                match v:
                    JsValue.Boolean(_): true
                    _: false
            JitTypeTag.TagString:
                match v:
                    JsValue.String(_): true
                    _: false
            JitTypeTag.TagObject:
                match v:
                    JsValue.Object(_): true
                    _: false
            JitTypeTag.TagNull:
                match v:
                    JsValue.Null: true
                    _: false
            JitTypeTag.TagUndefined:
                match v:
                    JsValue.Undefined: true
                    _: false

# --- Step result for IR execution ---

class JitStepResult:
    next_pc: i64
    is_return: bool
    is_guard_fail: bool
    value: JsValue

    static fn next(pc: i64) -> JitStepResult:
        JitStepResult(next_pc: pc, is_return: false, is_guard_fail: false, value: JsValue.Undefined)

    static fn ret(v: JsValue) -> JitStepResult:
        JitStepResult(next_pc: -1, is_return: true, is_guard_fail: false, value: v)

    static fn guard_fail() -> JitStepResult:
        JitStepResult(next_pc: -1, is_return: false, is_guard_fail: true, value: JsValue.Undefined)

# --- Baseline compiler: bytecode -> JitIR ---

class BaselineCompiler:
    next_reg: i64
    stack_top: i64
    logger: Logger

    static fn create(logger: Logger) -> BaselineCompiler:
        BaselineCompiler(next_reg: 0, stack_top: 0, logger: logger)

    me compile(chunk: BytecodeChunk) -> [JitIR]:
        self.next_reg = 0
        self.stack_top = 0
        var ir = [JitIR]()
        var i = 0
        val ops = chunk.ops
        val constants = chunk.constants
        while i < ops.len():
            val op = ops.get(i)
            val instrs = self._translate_op(op, constants)
            var j = 0
            while j < instrs.len():
                ir.push(instrs.get(j))
                j = j + 1
            i = i + 1
        ir

    me _alloc_reg() -> i64:
        val r = self.next_reg
        self.next_reg = self.next_reg + 1
        r

    me _push_stack() -> i64:
        val r = self.stack_top
        self.stack_top = self.stack_top + 1
        r

    me _pop_stack() -> i64:
        self.stack_top = self.stack_top - 1
        self.stack_top

    me _translate_op(op: OpCode, constants: ConstantPool) -> [JitIR]:
        var result = [JitIR]()
        match op:
            OpCode.LoadConst(idx):
                val reg = self._push_stack()
                val value = constants.values.get(idx)
                result.push(JitIR.LoadConst(reg: reg, value: value))
            OpCode.LoadLocal(idx):
                val reg = self._push_stack()
                result.push(JitIR.LoadLocal(reg: reg, slot: idx))
            OpCode.StoreLocal(idx):
                val reg = self._pop_stack()
                result.push(JitIR.StoreLocal(slot: idx, reg: reg))
            OpCode.LoadGlobal(name):
                val reg = self._push_stack()
                result.push(JitIR.LoadGlobal(reg: reg, name: name))
            OpCode.StoreGlobal(name):
                val reg = self._pop_stack()
                result.push(JitIR.StoreGlobal(name: name, reg: reg))
            OpCode.Add:
                val rhs = self._pop_stack()
                val lhs = self._pop_stack()
                val dst = self._push_stack()
                result.push(JitIR.Add(dst: dst, lhs: lhs, rhs: rhs))
            OpCode.Sub:
                val rhs = self._pop_stack()
                val lhs = self._pop_stack()
                val dst = self._push_stack()
                result.push(JitIR.Sub(dst: dst, lhs: lhs, rhs: rhs))
            OpCode.Mul:
                val rhs = self._pop_stack()
                val lhs = self._pop_stack()
                val dst = self._push_stack()
                result.push(JitIR.Mul(dst: dst, lhs: lhs, rhs: rhs))
            OpCode.Div:
                val rhs = self._pop_stack()
                val lhs = self._pop_stack()
                val dst = self._push_stack()
                result.push(JitIR.Div(dst: dst, lhs: lhs, rhs: rhs))
            OpCode.Mod:
                val rhs = self._pop_stack()
                val lhs = self._pop_stack()
                val dst = self._push_stack()
                result.push(JitIR.Mod(dst: dst, lhs: lhs, rhs: rhs))
            OpCode.Eq:
                val rhs = self._pop_stack()
                val lhs = self._pop_stack()
                val dst = self._push_stack()
                result.push(JitIR.Compare(dst: dst, lhs: lhs, rhs: rhs, op: "eq"))
            OpCode.Ne:
                val rhs = self._pop_stack()
                val lhs = self._pop_stack()
                val dst = self._push_stack()
                result.push(JitIR.Compare(dst: dst, lhs: lhs, rhs: rhs, op: "ne"))
            OpCode.Lt:
                val rhs = self._pop_stack()
                val lhs = self._pop_stack()
                val dst = self._push_stack()
                result.push(JitIR.Compare(dst: dst, lhs: lhs, rhs: rhs, op: "lt"))
            OpCode.Gt:
                val rhs = self._pop_stack()
                val lhs = self._pop_stack()
                val dst = self._push_stack()
                result.push(JitIR.Compare(dst: dst, lhs: lhs, rhs: rhs, op: "gt"))
            OpCode.Le:
                val rhs = self._pop_stack()
                val lhs = self._pop_stack()
                val dst = self._push_stack()
                result.push(JitIR.Compare(dst: dst, lhs: lhs, rhs: rhs, op: "le"))
            OpCode.Ge:
                val rhs = self._pop_stack()
                val lhs = self._pop_stack()
                val dst = self._push_stack()
                result.push(JitIR.Compare(dst: dst, lhs: lhs, rhs: rhs, op: "ge"))
            OpCode.Not:
                val src = self._pop_stack()
                val dst = self._push_stack()
                result.push(JitIR.LogicalNot(dst: dst, src: src))
            OpCode.Neg:
                val src = self._pop_stack()
                val dst = self._push_stack()
                result.push(JitIR.Negate(dst: dst, src: src))
            OpCode.Call(argc):
                # Pop arguments + function, push result
                var a = 0
                while a < argc:
                    self._pop_stack()
                    a = a + 1
                val func_reg = self._pop_stack()
                val dst = self._push_stack()
                result.push(JitIR.Call(dst: dst, func_reg: func_reg, arg_count: argc))
            OpCode.Return:
                val reg = self._pop_stack()
                result.push(JitIR.Return(reg: reg))
            OpCode.Jump(offset):
                result.push(JitIR.Jump(offset: offset))
            OpCode.JumpIfFalse(offset):
                val reg = self._pop_stack()
                result.push(JitIR.JumpIfFalse(reg: reg, offset: offset))
            OpCode.Pop:
                val reg = self._pop_stack()
                result.push(JitIR.Pop(reg: reg))
            OpCode.Dup:
                val src = self.stack_top - 1
                val dst = self._push_stack()
                result.push(JitIR.Dup(dst: dst, src: src))
            OpCode.GetProperty(name):
                val obj_reg = self._pop_stack()
                val dst = self._push_stack()
                result.push(JitIR.GetProperty(dst: dst, obj_reg: obj_reg, name: name))
            OpCode.SetProperty(name):
                val val_reg = self._pop_stack()
                val obj_reg = self._pop_stack()
                result.push(JitIR.SetProperty(obj_reg: obj_reg, name: name, val_reg: val_reg))
            OpCode.NewObject:
                val dst = self._push_stack()
                result.push(JitIR.NewObject(dst: dst))
            OpCode.NewArray(count):
                # Pop count items, push array
                var a = 0
                while a < count:
                    self._pop_stack()
                    a = a + 1
                val dst = self._push_stack()
                result.push(JitIR.NewArray(dst: dst, count: count))
            OpCode.Halt:
                # No IR needed, execution ends naturally
                pass_dn
            _:
                # Unsupported opcodes become Nop (closures, exceptions, iterators)
                result.push(JitIR.Nop)
        result

# --- Optimizing compiler: JitIR + type profile -> optimized JitIR ---

class OptimizingCompiler:
    logger: Logger

    static fn create(logger: Logger) -> OptimizingCompiler:
        OptimizingCompiler(logger: logger)

    fn optimize(ir: [JitIR], type_observations: [JitTypeTag]) -> [JitIR]:
        var optimized = self._type_specialize(ir, type_observations)
        optimized = self._constant_fold(optimized)
        optimized = self._dead_code_eliminate(optimized)
        optimized

    # --- Type specialization ---
    # If type observations show numbers, replace generic Add/Sub/Mul with Int variants
    # and insert Guard instructions for deoptimization safety.

    fn _type_specialize(ir: [JitIR], type_observations: [JitTypeTag]) -> [JitIR]:
        val all_numbers = self._all_tags_are_number(type_observations)
        if not all_numbers:
            return ir
        var result = [JitIR]()
        var i = 0
        while i < ir.len():
            val instr = ir.get(i)
            match instr:
                JitIR.Add(dst, lhs, rhs):
                    # Insert guard then use specialized IntAdd
                    result.push(JitIR.Guard(reg: lhs, expected_type: JitTypeTag.TagNumber))
                    result.push(JitIR.Guard(reg: rhs, expected_type: JitTypeTag.TagNumber))
                    result.push(JitIR.IntAdd(dst: dst, lhs: lhs, rhs: rhs))
                JitIR.Sub(dst, lhs, rhs):
                    result.push(JitIR.Guard(reg: lhs, expected_type: JitTypeTag.TagNumber))
                    result.push(JitIR.Guard(reg: rhs, expected_type: JitTypeTag.TagNumber))
                    result.push(JitIR.IntSub(dst: dst, lhs: lhs, rhs: rhs))
                JitIR.Mul(dst, lhs, rhs):
                    result.push(JitIR.Guard(reg: lhs, expected_type: JitTypeTag.TagNumber))
                    result.push(JitIR.Guard(reg: rhs, expected_type: JitTypeTag.TagNumber))
                    result.push(JitIR.IntMul(dst: dst, lhs: lhs, rhs: rhs))
                _:
                    result.push(instr)
            i = i + 1
        result

    fn _all_tags_are_number(observations: [JitTypeTag]) -> bool:
        if observations.len() == 0:
            return false
        var i = 0
        while i < observations.len():
            val tag = observations.get(i)
            match tag:
                JitTypeTag.TagNumber: pass_dn
                _: return false
            i = i + 1
        true

    # --- Constant folding ---
    # If two consecutive LoadConst instructions feed into an arithmetic op,
    # compute the result at compile time.

    fn _constant_fold(ir: [JitIR]) -> [JitIR]:
        var result = [JitIR]()
        # Track which registers hold known constants
        var known_const_regs = [i64]()
        var known_const_vals = [JsValue]()
        var i = 0
        while i < ir.len():
            val instr = ir.get(i)
            match instr:
                JitIR.LoadConst(reg, value):
                    self._record_const(known_const_regs, known_const_vals, reg, value)
                    result.push(instr)
                JitIR.IntAdd(dst, lhs, rhs):
                    val lhs_val = self._lookup_const(known_const_regs, known_const_vals, lhs)
                    val rhs_val = self._lookup_const(known_const_regs, known_const_vals, rhs)
                    val folded = self._try_fold_add(lhs_val, rhs_val, dst)
                    if val Some(folded_instr) = folded:
                        self._record_const_from_instr(known_const_regs, known_const_vals, folded_instr)
                        result.push(folded_instr)
                    else:
                        self._invalidate_const(known_const_regs, known_const_vals, dst)
                        result.push(instr)
                JitIR.IntSub(dst, lhs, rhs):
                    val lhs_val = self._lookup_const(known_const_regs, known_const_vals, lhs)
                    val rhs_val = self._lookup_const(known_const_regs, known_const_vals, rhs)
                    val folded = self._try_fold_sub(lhs_val, rhs_val, dst)
                    if val Some(folded_instr) = folded:
                        self._record_const_from_instr(known_const_regs, known_const_vals, folded_instr)
                        result.push(folded_instr)
                    else:
                        self._invalidate_const(known_const_regs, known_const_vals, dst)
                        result.push(instr)
                JitIR.IntMul(dst, lhs, rhs):
                    val lhs_val = self._lookup_const(known_const_regs, known_const_vals, lhs)
                    val rhs_val = self._lookup_const(known_const_regs, known_const_vals, rhs)
                    val folded = self._try_fold_mul(lhs_val, rhs_val, dst)
                    if val Some(folded_instr) = folded:
                        self._record_const_from_instr(known_const_regs, known_const_vals, folded_instr)
                        result.push(folded_instr)
                    else:
                        self._invalidate_const(known_const_regs, known_const_vals, dst)
                        result.push(instr)
                _:
                    result.push(instr)
            i = i + 1
        result

    fn _record_const(regs: [i64], vals: [JsValue], reg: i64, value: JsValue):
        # Check if already tracked
        var i = 0
        while i < regs.len():
            if regs.get(i) == reg:
                vals.set(i, value)
                return ()
            i = i + 1
        regs.push(reg)
        vals.push(value)

    fn _lookup_const(regs: [i64], vals: [JsValue], reg: i64) -> Option<JsValue>:
        var i = 0
        while i < regs.len():
            if regs.get(i) == reg:
                return Some(vals.get(i))
            i = i + 1
        nil

    fn _invalidate_const(regs: [i64], vals: [JsValue], reg: i64):
        var i = 0
        while i < regs.len():
            if regs.get(i) == reg:
                # Remove by swapping with last
                val last_idx = regs.len() - 1
                regs.set(i, regs.get(last_idx))
                vals.set(i, vals.get(last_idx))
                regs.pop()
                vals.pop()
                return ()
            i = i + 1

    fn _record_const_from_instr(regs: [i64], vals: [JsValue], instr: JitIR):
        match instr:
            JitIR.LoadConst(reg, value):
                self._record_const(regs, vals, reg, value)
            _: pass_dn

    fn _try_fold_add(a: Option<JsValue>, b: Option<JsValue>, dst: i64) -> Option<JitIR>:
        if val Some(av) = a:
            if val Some(bv) = b:
                match av:
                    JsValue.Number(va):
                        match bv:
                            JsValue.Number(vb):
                                return Some(JitIR.LoadConst(reg: dst, value: JsValue.Number(v: va + vb)))
                            _: pass_dn
                    _: pass_dn
        nil

    fn _try_fold_sub(a: Option<JsValue>, b: Option<JsValue>, dst: i64) -> Option<JitIR>:
        if val Some(av) = a:
            if val Some(bv) = b:
                match av:
                    JsValue.Number(va):
                        match bv:
                            JsValue.Number(vb):
                                return Some(JitIR.LoadConst(reg: dst, value: JsValue.Number(v: va - vb)))
                            _: pass_dn
                    _: pass_dn
        nil

    fn _try_fold_mul(a: Option<JsValue>, b: Option<JsValue>, dst: i64) -> Option<JitIR>:
        if val Some(av) = a:
            if val Some(bv) = b:
                match av:
                    JsValue.Number(va):
                        match bv:
                            JsValue.Number(vb):
                                return Some(JitIR.LoadConst(reg: dst, value: JsValue.Number(v: va * vb)))
                            _: pass_dn
                    _: pass_dn
        nil

    # --- Dead code elimination ---
    # Remove Nop instructions and LoadConst/StoreLocal whose destination
    # is never read before being overwritten.

    fn _dead_code_eliminate(ir: [JitIR]) -> [JitIR]:
        var result = [JitIR]()
        var i = 0
        while i < ir.len():
            val instr = ir.get(i)
            match instr:
                JitIR.Nop: pass_dn  # Skip Nops entirely
                _: result.push(instr)
            i = i + 1
        result

# --- JIT compiler (main entry point) ---

class JitCompiler:
    profiles: [JitProfile]
    compiled_functions: [CompiledFunction]
    hot_threshold: i64
    logger: Logger
    executor: JitExecutor
    baseline_compiler: BaselineCompiler
    optimizing_compiler: OptimizingCompiler
    next_code_id: i64

    static fn new(logger: Logger) -> JitCompiler:
        JitCompiler(
            profiles: [JitProfile](),
            compiled_functions: [CompiledFunction](),
            hot_threshold: 100,
            logger: logger,
            executor: JitExecutor.create(logger),
            baseline_compiler: BaselineCompiler.create(logger),
            optimizing_compiler: OptimizingCompiler.create(logger),
            next_code_id: 0
        )

    # --- Profiling ---

    me profile_call(function_name: text):
        val idx = self._find_profile(function_name)
        if idx >= 0:
            var profile = self.profiles.get(idx)
            profile.call_count = profile.call_count + 1
            if not profile.is_compiled and self._is_hot(profile):
                self.logger.info("Function '{function_name}' is hot (call_count={profile.call_count})")
        else:
            val profile = JitProfile.create(function_name, self.hot_threshold)
            self.profiles.push(profile)
            # Increment the first call
            var new_profile = self.profiles.get(self.profiles.len() - 1)
            new_profile.call_count = 1

    me record_type_observation(function_name: text, tag: JitTypeTag):
        val idx = self._find_profile(function_name)
        if idx >= 0:
            var profile = self.profiles.get(idx)
            profile.type_observations.push(tag)

    fn should_compile(function_name: text) -> bool:
        val idx = self._find_profile(function_name)
        if idx >= 0:
            val profile = self.profiles.get(idx)
            self._is_hot(profile) and not profile.is_compiled
        else:
            false

    fn should_optimize(function_name: text) -> bool:
        val idx = self._find_profile(function_name)
        if idx >= 0:
            val profile = self.profiles.get(idx)
            val is_baseline = match profile.tier:
                JitTier.Baseline: true
                _: false
            val past_opt_threshold = profile.call_count >= profile.optimizing_threshold
            profile.is_compiled and is_baseline and past_opt_threshold
        else:
            false

    # --- Compilation ---

    me compile_baseline(chunk: BytecodeChunk, name: text) -> BrowserResult<CompiledFunction>:
        self.logger.info("Baseline JIT compile requested for '{name}'")
        val ir = self.baseline_compiler.compile(chunk)
        val code_id = self.next_code_id
        self.next_code_id = self.next_code_id + 1
        val compiled = CompiledFunction(
            name: name,
            tier: JitTier.Baseline,
            native_code_id: code_id,
            ir: ir
        )
        self.compiled_functions.push(compiled)
        # Mark profile as compiled
        val idx = self._find_profile(name)
        if idx >= 0:
            var profile = self.profiles.get(idx)
            profile.is_compiled = true
            profile.tier = JitTier.Baseline
        self.logger.info("Baseline JIT compiled '{name}': {ir.len()} IR instructions")
        Ok(compiled)

    me compile_optimizing(chunk: BytecodeChunk, name: text) -> BrowserResult<CompiledFunction>:
        self.logger.info("Optimizing JIT compile requested for '{name}'")
        # Get baseline IR from existing compiled function
        val existing = self.get_compiled(name)
        val base_ir = if val Some(func) = existing:
            func.ir
        else:
            # No baseline exists; compile baseline first
            val ir = self.baseline_compiler.compile(chunk)
            ir
        # Get type observations from profile
        val idx = self._find_profile(name)
        val observations = if idx >= 0:
            val profile = self.profiles.get(idx)
            profile.type_observations
        else:
            [JitTypeTag]()
        # Run optimizing passes
        val optimized_ir = self.optimizing_compiler.optimize(base_ir, observations)
        val code_id = self.next_code_id
        self.next_code_id = self.next_code_id + 1
        val compiled = CompiledFunction(
            name: name,
            tier: JitTier.Optimizing,
            native_code_id: code_id,
            ir: optimized_ir
        )
        # Replace existing compiled function
        self._remove_compiled(name)
        self.compiled_functions.push(compiled)
        # Update profile
        if idx >= 0:
            var profile = self.profiles.get(idx)
            profile.tier = JitTier.Optimizing
        self.logger.info("Optimizing JIT compiled '{name}': {optimized_ir.len()} IR instructions (from {base_ir.len()} baseline)")
        Ok(compiled)

    # --- Execution ---

    me execute_jit(name: text, args: [JsValue]) -> BrowserResult<JsValue>:
        val compiled = self.get_compiled(name)
        if val Some(func) = compiled:
            val result = self.executor.execute(func.ir, args)
            match result:
                Ok(v):
                    # Record type observation from result
                    val tag = _value_to_tag(v)
                    self.record_type_observation(name, tag)
                    Ok(v)
                Err(e):
                    # Guard failure -> deoptimize
                    self.deoptimize(name)
                    Err(e)
        else:
            Err(script_error("No JIT compiled code for function '{name}'"))

    # --- Deoptimization ---

    me deoptimize(name: text):
        self.logger.warn("Deoptimizing function '{name}', falling back to interpreter")
        self._remove_compiled(name)
        # Reset profile
        val idx = self._find_profile(name)
        if idx >= 0:
            var profile = self.profiles.get(idx)
            profile.is_compiled = false
            profile.call_count = 0
            profile.tier = JitTier.Baseline
            profile.deopt_count = profile.deopt_count + 1

    # --- Lookup ---

    fn get_compiled(name: text) -> Option<CompiledFunction>:
        var i = 0
        while i < self.compiled_functions.len():
            val func = self.compiled_functions.get(i)
            if func.name == name:
                return Some(func)
            i = i + 1
        nil

    # --- Private helpers ---

    me _remove_compiled(name: text):
        var new_compiled = [CompiledFunction]()
        var i = 0
        while i < self.compiled_functions.len():
            val func = self.compiled_functions.get(i)
            if func.name != name:
                new_compiled.push(func)
            i = i + 1
        self.compiled_functions = new_compiled

    fn _find_profile(name: text) -> i64:
        var i = 0
        while i < self.profiles.len():
            val profile = self.profiles.get(i)
            if profile.function_name == name:
                return i
            i = i + 1
        -1

    fn _is_hot(profile: JitProfile) -> bool:
        profile.call_count >= profile.hot_threshold

# --- Free functions ---

fn is_hot(profile: JitProfile) -> bool:
    profile.call_count >= profile.hot_threshold

fn _value_to_tag(v: JsValue) -> JitTypeTag:
    match v:
        JsValue.Number(_): JitTypeTag.TagNumber
        JsValue.Boolean(_): JitTypeTag.TagBoolean
        JsValue.String(_): JitTypeTag.TagString
        JsValue.Object(_): JitTypeTag.TagObject
        JsValue.Null: JitTypeTag.TagNull
        JsValue.Undefined: JitTypeTag.TagUndefined
        _: JitTypeTag.Unknown
