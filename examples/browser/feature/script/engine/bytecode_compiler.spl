# Bytecode compiler for the JS engine.
# Compiles AST (Statement/Expression trees) into BytecodeChunk opcodes.

use browser.entity.script.bytecode_types.(OpCode, BytecodeChunk, ConstantPool)
use browser.entity.script.js_types.(JsValue, JsObject, JsProperty)
use browser.entity.script.ast_types.(Expression, Statement)
use browser.shared.error.(BrowserError, BrowserResult, script_error)
use browser.shared.logging.(Logger, LogLevel)

# --- Scope tracking ---

class CompilerScope:
    locals: List<Pair<text, i64>>
    depth: i64
    parent_scope: i64

    static fn create(depth: i64, parent_scope: i64) -> CompilerScope:
        CompilerScope(locals: List<Pair<text, i64>>(), depth: depth, parent_scope: parent_scope)

# --- Bytecode compiler ---

class BytecodeCompiler:
    chunk: BytecodeChunk
    constants: List<JsValue>
    scopes: List<CompilerScope>
    current_scope: i64
    next_scope_id: i64
    loop_starts: List<i64>
    loop_breaks: List<List<i64>>
    logger: Logger

    static fn new(logger: Logger) -> BytecodeCompiler:
        var scopes = List<CompilerScope>()
        val global_scope = CompilerScope.create(0, -1)
        scopes.push(global_scope)
        BytecodeCompiler(
            chunk: BytecodeChunk.create("main"),
            constants: List<JsValue>(),
            scopes: scopes,
            current_scope: 0,
            next_scope_id: 1,
            loop_starts: List<i64>(),
            loop_breaks: List<List<i64>>(),
            logger: logger
        )

    # --- Main entry ---

    me compile(program: List<Statement>) -> BrowserResult<BytecodeChunk>:
        self.logger.info("Compiling program with {program.len()} statements")
        var i = 0
        while i < program.len():
            val stmt = program.get(i)
            self.compile_statement(stmt)
            i = i + 1
        self.emit(OpCode.Halt)
        self.chunk.constants = ConstantPool(values: self.constants)
        self.logger.info("Compilation complete: {self.chunk.ops.len()} opcodes, {self.constants.len()} constants")
        Ok(self.chunk)

    # --- Statement compilation ---

    me compile_statement(stmt: Statement):
        match stmt:
            Statement.VarDecl(name, init):
                self.compile_var_decl(name, init)
            Statement.ExprStmt(expr):
                self.compile_expression(expr)
                self.emit(OpCode.Pop)
            Statement.Return(value):
                self.compile_return(value)
            Statement.If(cond, then_body, else_body):
                self.compile_if(cond, then_body, else_body)
            Statement.While(cond, body):
                self.compile_while(cond, body)
            Statement.For(init, cond, update, body):
                self.compile_for(init, cond, update, body)
            Statement.Block(stmts):
                self.compile_block(stmts)
            Statement.FnDecl(name, params, body):
                self.compile_function_decl(name, params, body)

    me compile_var_decl(name: text, init: Expression):
        self.logger.debug("Compiling var declaration: {name}")
        self.compile_expression(init)
        val slot = self.resolve_local(name)
        if slot >= 0:
            self.emit(OpCode.StoreLocal(idx: slot))
        else:
            self._declare_local(name)
            val new_slot = self.resolve_local(name)
            self.emit(OpCode.StoreLocal(idx: new_slot))

    me compile_function_decl(name: text, params: List<text>, body: List<Statement>):
        self.logger.debug("Compiling function: {name} with {params.len()} params")
        # Save current compilation state
        val parent_chunk = self.chunk
        val parent_constants = self.constants
        self.chunk = BytecodeChunk.create(name)
        self.constants = List<JsValue>()
        self.begin_scope()
        # Declare parameters as locals
        var p = 0
        while p < params.len():
            val param_name = params.get(p)
            self._declare_local(param_name)
            p = p + 1
        # Compile body
        var i = 0
        while i < body.len():
            self.compile_statement(body.get(i))
            i = i + 1
        # Ensure function returns undefined if no explicit return
        self.emit_constant(JsValue.Undefined)
        self.emit(OpCode.Return)
        self.end_scope()
        # Capture compiled chunk
        val fn_chunk = self.chunk
        fn_chunk.constants = ConstantPool(values: self.constants)
        # Restore parent state
        self.chunk = parent_chunk
        self.constants = parent_constants
        # Store function as a constant and bind to name
        val fn_id = self.constants.len()
        self.constants.push(JsValue.Function(id: fn_id))
        self.emit(OpCode.LoadConst(idx: fn_id))
        self.emit(OpCode.StoreGlobal(name: name))

    me compile_return(value: Expression):
        self.compile_expression(value)
        self.emit(OpCode.Return)

    me compile_if(cond: Expression, then_body: List<Statement>, else_body: List<Statement>):
        self.compile_expression(cond)
        val else_jump = self.emit_jump(OpCode.JumpIfFalse(offset: 0))
        # Then branch
        self.begin_scope()
        var i = 0
        while i < then_body.len():
            self.compile_statement(then_body.get(i))
            i = i + 1
        self.end_scope()
        val end_jump = self.emit_jump(OpCode.Jump(offset: 0))
        # Patch else jump to here
        self.patch_jump(else_jump)
        # Else branch
        if else_body.len() > 0:
            self.begin_scope()
            var j = 0
            while j < else_body.len():
                self.compile_statement(else_body.get(j))
                j = j + 1
            self.end_scope()
        # Patch end jump
        self.patch_jump(end_jump)

    me compile_while(cond: Expression, body: List<Statement>):
        val loop_start = self.current_offset()
        self.loop_starts.push(loop_start)
        self.loop_breaks.push(List<i64>())
        self.compile_expression(cond)
        val exit_jump = self.emit_jump(OpCode.JumpIfFalse(offset: 0))
        self.begin_scope()
        var i = 0
        while i < body.len():
            self.compile_statement(body.get(i))
            i = i + 1
        self.end_scope()
        # Loop back to condition
        self.emit(OpCode.Jump(offset: loop_start))
        self.patch_jump(exit_jump)
        # Patch break jumps
        val breaks = self.loop_breaks.pop()
        var b = 0
        while b < breaks.len():
            self.patch_jump(breaks.get(b))
            b = b + 1
        self.loop_starts.pop()

    me compile_for(init: Statement, cond: Expression, update: Expression, body: List<Statement>):
        self.begin_scope()
        # Init
        self.compile_statement(init)
        val loop_start = self.current_offset()
        self.loop_starts.push(loop_start)
        self.loop_breaks.push(List<i64>())
        # Condition
        self.compile_expression(cond)
        val exit_jump = self.emit_jump(OpCode.JumpIfFalse(offset: 0))
        # Body
        var i = 0
        while i < body.len():
            self.compile_statement(body.get(i))
            i = i + 1
        # Update
        self.compile_expression(update)
        self.emit(OpCode.Pop)
        # Loop back
        self.emit(OpCode.Jump(offset: loop_start))
        self.patch_jump(exit_jump)
        # Patch breaks
        val breaks = self.loop_breaks.pop()
        var b = 0
        while b < breaks.len():
            self.patch_jump(breaks.get(b))
            b = b + 1
        self.loop_starts.pop()
        self.end_scope()

    me compile_block(stmts: List<Statement>):
        self.begin_scope()
        var i = 0
        while i < stmts.len():
            self.compile_statement(stmts.get(i))
            i = i + 1
        self.end_scope()

    # --- Expression compilation ---

    me compile_expression(expr: Expression):
        match expr:
            Expression.Literal(value):
                self.compile_literal(value)
            Expression.Identifier(name):
                self.compile_identifier(name)
            Expression.Binary(op, left, right):
                self.compile_binary(op, left, right)
            Expression.Unary(op, operand):
                self.compile_unary(op, operand)
            Expression.Call(callee, args):
                self.compile_call(callee, args)
            Expression.Member(object, property):
                self.compile_member(object, property)
            Expression.Assignment(target, value):
                self.compile_assignment(target, value)
            Expression.Array(elements):
                self.compile_array(elements)
            Expression.ObjectExpr(properties):
                self.compile_object(properties)

    me compile_literal(value: JsValue):
        self.emit_constant(value)

    me compile_identifier(name: text):
        val slot = self.resolve_local(name)
        if slot >= 0:
            self.emit(OpCode.LoadLocal(idx: slot))
        else:
            self.emit(OpCode.LoadGlobal(name: name))

    me compile_binary(op: text, left: Expression, right: Expression):
        self.compile_expression(left)
        self.compile_expression(right)
        val opcode = op_for_binary(op)
        self.emit(opcode)

    me compile_unary(op: text, operand: Expression):
        self.compile_expression(operand)
        match op:
            "!": self.emit(OpCode.Not)
            "-": self.emit(OpCode.Neg)
            _: self.logger.warn("Unknown unary operator: {op}")

    me compile_call(callee: Expression, args: List<Expression>):
        self.compile_expression(callee)
        var i = 0
        while i < args.len():
            self.compile_expression(args.get(i))
            i = i + 1
        self.emit(OpCode.Call(argc: args.len()))

    me compile_member(object: Expression, property: text):
        self.compile_expression(object)
        self.emit(OpCode.GetProperty(name: property))

    me compile_assignment(target: Expression, value: Expression):
        self.compile_expression(value)
        match target:
            Expression.Identifier(name):
                val slot = self.resolve_local(name)
                if slot >= 0:
                    self.emit(OpCode.Dup)
                    self.emit(OpCode.StoreLocal(idx: slot))
                else:
                    self.emit(OpCode.Dup)
                    self.emit(OpCode.StoreGlobal(name: name))
            Expression.Member(object, property):
                self.compile_expression(object)
                self.emit(OpCode.SetProperty(name: property))
            _:
                self.logger.error("Invalid assignment target")

    me compile_array(elements: List<Expression>):
        var i = 0
        while i < elements.len():
            self.compile_expression(elements.get(i))
            i = i + 1
        self.emit(OpCode.NewArray(count: elements.len()))

    me compile_object(properties: List<Pair<text, Expression>>):
        self.emit(OpCode.NewObject)
        var i = 0
        while i < properties.len():
            val prop = properties.get(i)
            self.emit(OpCode.Dup)
            self.compile_expression(prop.second)
            self.emit(OpCode.SetProperty(name: prop.first))
            i = i + 1

    # --- Helpers ---

    me emit(op: OpCode):
        self.chunk.ops.push(op)

    me emit_constant(value: JsValue) -> i64:
        val idx = self.constants.len()
        self.constants.push(value)
        self.emit(OpCode.LoadConst(idx: idx))
        idx

    me emit_jump(op: OpCode) -> i64:
        val location = self.chunk.ops.len()
        self.emit(op)
        location

    me patch_jump(location: i64):
        val target = self.chunk.ops.len()
        val existing = self.chunk.ops.get(location)
        match existing:
            OpCode.JumpIfFalse(_):
                self.chunk.ops.set(location, OpCode.JumpIfFalse(offset: target))
            OpCode.Jump(_):
                self.chunk.ops.set(location, OpCode.Jump(offset: target))
            _:
                self.logger.error("Cannot patch non-jump opcode at {location}")

    fn current_offset() -> i64:
        self.chunk.ops.len()

    fn resolve_local(name: text) -> i64:
        val scope = self.scopes.get(self.current_scope)
        var i = scope.locals.len() - 1
        while i >= 0:
            val local = scope.locals.get(i)
            if local.first == name:
                return i
            i = i - 1
        -1

    me _declare_local(name: text):
        var scope = self.scopes.get(self.current_scope)
        val slot = scope.locals.len()
        scope.locals.push(Pair(first: name, second: slot))

    me begin_scope():
        val depth = self.scopes.get(self.current_scope).depth + 1
        val new_scope = CompilerScope.create(depth, self.current_scope)
        # Copy locals from parent scope
        val parent = self.scopes.get(self.current_scope)
        var i = 0
        while i < parent.locals.len():
            new_scope.locals.push(parent.locals.get(i))
            i = i + 1
        self.scopes.push(new_scope)
        self.current_scope = self.scopes.len() - 1
        self.next_scope_id = self.next_scope_id + 1
        self.logger.trace("Begin scope depth {depth}")

    me end_scope():
        val scope = self.scopes.get(self.current_scope)
        val parent_id = scope.parent_scope
        self.logger.trace("End scope depth {scope.depth}")
        self.current_scope = parent_id

# --- Free function: binary operator mapping ---

fn op_for_binary(op: text) -> OpCode:
    match op:
        "+": OpCode.Add
        "-": OpCode.Sub
        "*": OpCode.Mul
        "/": OpCode.Div
        "%": OpCode.Mod
        "==": OpCode.Eq
        "!=": OpCode.Ne
        "<": OpCode.Lt
        ">": OpCode.Gt
        "<=": OpCode.Le
        ">=": OpCode.Ge
        _: OpCode.Add  # fallback
