#![allow(REQC001)]
# Legacy parser module retained for old browser source paths.
#
# The browser runtime uses std.js.engine.parser.JsParser. Keeping this file as a
# small non-importing shim prevents grouped example builds from introducing a
# second parser surface and shadowing canonical lexer/parser symbols.

class BrowserLegacyJsParser:
    source: text

    static fn new(input: text, logger: any) -> BrowserLegacyJsParser:
        BrowserLegacyJsParser(source: input)
