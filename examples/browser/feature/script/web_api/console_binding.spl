# Console bindings — console.log, error, warn, info, debug, table, time, timeEnd.
# Provides formatted output, performance timers, and call counters for the JS engine.

use browser.shared.logging.Logger
use browser.shared.error.BrowserResult
use browser.shared.error.script_error
use browser.entity.script.js_types.JsValue
use browser.entity.script.js_types.JsObject
use browser.entity.script.js_types.JsProperty
use browser.feature.script.engine.runtime.JsRuntime
use browser.feature.script.engine.runtime.format_value
use browser.feature.script.engine.interpreter.to_string

# ── Native function IDs ──────────────────────────────────────────────────

val NATIVE_CONSOLE_LOG_BIND = -500
val NATIVE_CONSOLE_ERROR_BIND = -501
val NATIVE_CONSOLE_WARN_BIND = -502
val NATIVE_CONSOLE_INFO_BIND = -503
val NATIVE_CONSOLE_DEBUG_BIND = -504
val NATIVE_CONSOLE_TABLE_BIND = -505
val NATIVE_CONSOLE_TIME_BIND = -506
val NATIVE_CONSOLE_TIME_END_BIND = -507
val NATIVE_CONSOLE_COUNT_BIND = -508
val NATIVE_CONSOLE_CLEAR_BIND = -509

# ── ConsoleBinding ───────────────────────────────────────────────────────

class ConsoleBinding:
    timers: List<Pair<text, i64>>
    counters: List<Pair<text, i64>>
    logger: Logger

    static fn new(logger: Logger) -> ConsoleBinding:
        ConsoleBinding(
            timers: List<Pair<text, i64>>(),
            counters: List<Pair<text, i64>>(),
            logger: logger,
        )

    # Install console object methods on the JS runtime.
    me install(runtime: JsRuntime):
        self.logger.debug("Installing console bindings")

        # Create the console object
        val console_id = runtime.interpreter.object_store.create_object()

        runtime._define_method_on(console_id, "log", NATIVE_CONSOLE_LOG_BIND)
        runtime._define_method_on(console_id, "error", NATIVE_CONSOLE_ERROR_BIND)
        runtime._define_method_on(console_id, "warn", NATIVE_CONSOLE_WARN_BIND)
        runtime._define_method_on(console_id, "info", NATIVE_CONSOLE_INFO_BIND)
        runtime._define_method_on(console_id, "debug", NATIVE_CONSOLE_DEBUG_BIND)
        runtime._define_method_on(console_id, "table", NATIVE_CONSOLE_TABLE_BIND)
        runtime._define_method_on(console_id, "time", NATIVE_CONSOLE_TIME_BIND)
        runtime._define_method_on(console_id, "timeEnd", NATIVE_CONSOLE_TIME_END_BIND)
        runtime._define_method_on(console_id, "count", NATIVE_CONSOLE_COUNT_BIND)
        runtime._define_method_on(console_id, "clear", NATIVE_CONSOLE_CLEAR_BIND)

        # Bind console to global scope
        runtime.interpreter.env_stack.define_var(
            runtime.interpreter.global_env, "console", JsValue.Object(id: console_id))

        self.logger.debug("Console bindings installed")

# ── Console method implementations ───────────────────────────────────────

fn js_console_log(args: List<JsValue>) -> JsValue:
    val msg = format_args(args)
    print(msg)
    JsValue.Undefined

fn js_console_error(args: List<JsValue>) -> JsValue:
    val msg = format_args(args)
    print("[ERROR] " + msg)
    JsValue.Undefined

fn js_console_warn(args: List<JsValue>) -> JsValue:
    val msg = format_args(args)
    print("[WARN] " + msg)
    JsValue.Undefined

fn js_console_info(args: List<JsValue>) -> JsValue:
    val msg = format_args(args)
    print("[INFO] " + msg)
    JsValue.Undefined

fn js_console_debug(args: List<JsValue>) -> JsValue:
    val msg = format_args(args)
    print("[DEBUG] " + msg)
    JsValue.Undefined

fn js_console_table(args: List<JsValue>) -> JsValue:
    # Format tabular data. For arrays of objects, display as table.
    # Simplified: format each arg on its own line with index.
    if args.len() == 0:
        print("(empty table)")
        return JsValue.Undefined

    val first = args.get(0)
    match first:
        JsValue.Array(id):
            # Would iterate array elements and display as rows
            print("(index)  | Value")
            print("---------+------")
            print("  0      | [Array]")
        JsValue.Object(id):
            print("(index)  | Value")
            print("---------+------")
            print("  0      | [Object]")
        _:
            val formatted = format_value_pretty(first, 0)
            print(formatted)

    JsValue.Undefined

fn js_console_time(args: List<JsValue>) -> JsValue:
    # Start a named timer. Uses a stub timestamp for now.
    val label = _get_label(args)
    val now = _time_now_stub()
    # Store the timer start. Caller (ConsoleBinding) manages the list.
    # For a standalone function, we print a marker.
    print("timer '{label}' started")
    JsValue.Undefined

fn js_console_timeEnd(args: List<JsValue>) -> JsValue:
    # Stop a named timer and print elapsed time.
    val label = _get_label(args)
    # Full implementation looks up the start time and computes delta.
    print("{label}: 0ms (stub)")
    JsValue.Undefined

fn js_console_count(args: List<JsValue>) -> JsValue:
    # Increment and print a named counter.
    val label = _get_label(args)
    # Full implementation maintains per-label counters.
    print("{label}: 1")
    JsValue.Undefined

fn js_console_clear(args: List<JsValue>) -> JsValue:
    # Clear the console output.
    print("\x1b[2J\x1b[H")
    JsValue.Undefined

# ── Formatting ───────────────────────────────────────────────────────────

# Format all arguments into a single space-separated string.
fn format_args(args: List<JsValue>) -> text:
    var parts = List<text>()
    var i = 0
    val len = args.len()
    while i < len:
        val part = format_value_pretty(args.get(i), 0)
        parts.push(part)
        i = i + 1
    parts.join(" ")

# Recursively pretty-print a JsValue with depth control.
fn format_value_pretty(value: JsValue, depth: i64) -> text:
    if depth > 4:
        return "[...]"

    match value:
        JsValue.Undefined:
            "undefined"
        JsValue.Null:
            "null"
        JsValue.Boolean(v):
            if v: "true" else: "false"
        JsValue.Number(v):
            "{v}"
        JsValue.String(v):
            if depth == 0:
                v
            else:
                "'" + v + "'"
        JsValue.Object(id):
            if depth == 0:
                "[object Object]"
            else:
                "{ ... }"
        JsValue.Array(id):
            if depth == 0:
                "[]"
            else:
                "[ ... ]"
        JsValue.Function(id):
            "[Function]"
        JsValue.Symbol(id):
            "Symbol()"

# ── Internal helpers ─────────────────────────────────────────────────────

fn _get_label(args: List<JsValue>) -> text:
    if args.len() >= 1:
        return to_string(args.get(0))
    "default"

fn _time_now_stub() -> i64:
    # Stub — no real clock without FFI.
    0
