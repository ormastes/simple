#![allow(unnamed_duplicate_typed_args)]
# DOM bindings — bridge between JS engine and DOM tree.
# Exposes document/element methods to JavaScript: getElementById, querySelector,
# createElement, attribute manipulation, child management, and property accessors.

use browser.shared.logging.Logger
use browser.shared.error.BrowserResult
use browser.shared.error.BrowserError
use browser.shared.error.BrowserErrorKind
use browser.shared.error.script_error
use browser.shared.error.dom_error
use std.js.types.js_types.JsValue
use std.js.types.js_types.JsObject
use std.js.types.js_types.JsProperty
use browser.entity.dom.node_types.DomNode
use browser.entity.dom.node_types.NodeKind
use browser.entity.dom.node_types.Element
use browser.entity.dom.node_types.TextNode
use std.js.engine.runtime.JsRuntime
use std.js.engine.interpreter_types.to_string
use browser.feature.dom.document.Document
use browser.feature.dom.element.ElementOps
use browser.feature.dom.text.TextOps

# ── Native function IDs for DOM bindings ─────────────────────────────────

val NATIVE_GET_ELEMENT_BY_ID = -100
val NATIVE_GET_ELEMENTS_BY_TAG_NAME = -101
val NATIVE_GET_ELEMENTS_BY_CLASS_NAME = -102
val NATIVE_QUERY_SELECTOR = -103
val NATIVE_QUERY_SELECTOR_ALL = -104
val NATIVE_CREATE_ELEMENT = -105
val NATIVE_CREATE_TEXT_NODE = -106
val NATIVE_GET_ATTRIBUTE = -110
val NATIVE_SET_ATTRIBUTE = -111
val NATIVE_REMOVE_ATTRIBUTE = -112
val NATIVE_APPEND_CHILD = -113
val NATIVE_REMOVE_CHILD = -114
val NATIVE_INSERT_BEFORE = -115
val NATIVE_GET_INNER_HTML = -120
val NATIVE_SET_INNER_HTML = -121
val NATIVE_GET_TEXT_CONTENT = -122
val NATIVE_SET_TEXT_CONTENT = -123
val NATIVE_CLASS_LIST_ADD = -124
val NATIVE_CLASS_LIST_REMOVE = -125
val NATIVE_STYLE_SET = -126

# ── DomBindings ──────────────────────────────────────────────────────────

class DomBindings:
    document_ref: i64
    doc: Document
    logger: Logger

    static fn new(document_ref: i64, logger: Logger) -> DomBindings:
        DomBindings(document_ref: document_ref, doc: Document.new("", logger), logger: logger)

    static fn with_document(document_ref: i64, doc: Document, logger: Logger) -> DomBindings:
        DomBindings(document_ref: document_ref, doc: doc, logger: logger)

    # Install all DOM API bindings on the global JS runtime object.
    me install(runtime: JsRuntime):
        self.logger.debug("Installing DOM bindings")

        # Create the document object in the JS object store
        val doc_id = runtime.interpreter.object_store.create_object()

        # ── Document methods ────────────────────────────────────────
        runtime._define_method_on(doc_id, "getElementById", NATIVE_GET_ELEMENT_BY_ID)
        runtime._define_method_on(doc_id, "getElementsByTagName", NATIVE_GET_ELEMENTS_BY_TAG_NAME)
        runtime._define_method_on(doc_id, "getElementsByClassName", NATIVE_GET_ELEMENTS_BY_CLASS_NAME)
        runtime._define_method_on(doc_id, "querySelector", NATIVE_QUERY_SELECTOR)
        runtime._define_method_on(doc_id, "querySelectorAll", NATIVE_QUERY_SELECTOR_ALL)
        runtime._define_method_on(doc_id, "createElement", NATIVE_CREATE_ELEMENT)
        runtime._define_method_on(doc_id, "createTextNode", NATIVE_CREATE_TEXT_NODE)

        # Store document ref so DOM methods can resolve against the tree
        runtime.interpreter.object_store.set_property(
            doc_id, "__dom_ref__", JsValue.Number(v: self.document_ref.to_f64()))

        # Bind document to global scope
        runtime.interpreter.env_stack.define_var(
            runtime.interpreter.global_env, "document", JsValue.Object(id: doc_id))

        self.logger.debug("DOM bindings installed with document ref={self.document_ref}")

# ── Document query methods ───────────────────────────────────────────────

fn js_getElementById(args: [JsValue], doc: Document) -> BrowserResult<JsValue>:
    if args.len() < 1:
        return Err(script_error("getElementById requires 1 argument"))
    val id_str = to_string(args.get(0))
    if id_str.len() == 0:
        return Ok(JsValue.Null)
    val found = doc.getElementById(id_str)
    if val Some(node_id) = found:
        return Ok(wrap_node(node_id))
    Ok(JsValue.Null)

fn js_getElementsByTagName(args: [JsValue], doc: Document) -> BrowserResult<JsValue>:
    if args.len() < 1:
        return Err(script_error("getElementsByTagName requires 1 argument"))
    val tag = to_string(args.get(0))
    val ids = doc.getElementsByTagName(tag)
    Ok(_wrap_node_list(ids))

fn js_getElementsByClassName(args: [JsValue], doc: Document) -> BrowserResult<JsValue>:
    if args.len() < 1:
        return Err(script_error("getElementsByClassName requires 1 argument"))
    val class_name = to_string(args.get(0))
    val ids = doc.getElementsByClassName(class_name)
    Ok(_wrap_node_list(ids))

fn js_querySelector(args: [JsValue], doc: Document) -> BrowserResult<JsValue>:
    if args.len() < 1:
        return Err(script_error("querySelector requires 1 argument"))
    val selector = to_string(args.get(0))
    if selector.len() == 0:
        return Err(script_error("querySelector: empty selector"))
    val found = doc.querySelector(selector)
    if val Some(node_id) = found:
        return Ok(wrap_node(node_id))
    Ok(JsValue.Null)

fn js_querySelectorAll(args: [JsValue], doc: Document) -> BrowserResult<JsValue>:
    if args.len() < 1:
        return Err(script_error("querySelectorAll requires 1 argument"))
    val selector = to_string(args.get(0))
    if selector.len() == 0:
        return Err(script_error("querySelectorAll: empty selector"))
    val ids = doc.querySelectorAll(selector)
    Ok(_wrap_node_list(ids))

fn js_createElement(args: [JsValue], doc: Document) -> BrowserResult<JsValue>:
    if args.len() < 1:
        return Err(script_error("createElement requires 1 argument"))
    val tag_name = to_string(args.get(0))
    if tag_name.len() == 0:
        return Err(script_error("createElement: tag name cannot be empty"))
    val node_id = doc.createElement(tag_name)
    Ok(wrap_node(node_id))

fn js_createTextNode(args: [JsValue], doc: Document) -> BrowserResult<JsValue>:
    if args.len() < 1:
        return Err(script_error("createTextNode requires 1 argument"))
    val content = to_string(args.get(0))
    val node_id = doc.createTextNode(content)
    Ok(wrap_node(node_id))

# ── Element attribute methods ────────────────────────────────────────────

fn js_getAttribute(args: [JsValue], doc: Document) -> BrowserResult<JsValue>:
    if args.len() < 2:
        return Err(script_error("getAttribute requires element and attribute name"))
    val node_id = unwrap_node(args.get(0))
    if val Some(nid) = node_id:
        val attr_name = to_string(args.get(1))
        val attr_val = ElementOps.getAttribute(doc, nid, attr_name)
        if val Some(v) = attr_val:
            return Ok(JsValue.String(v: v))
        return Ok(JsValue.Null)
    Err(script_error("getAttribute: invalid node reference"))

fn js_setAttribute(args: [JsValue], doc: Document) -> BrowserResult<JsValue>:
    if args.len() < 3:
        return Err(script_error("setAttribute requires element, name, and value"))
    val node_id = unwrap_node(args.get(0))
    if val Some(nid) = node_id:
        val attr_name = to_string(args.get(1))
        val attr_value = to_string(args.get(2))
        ElementOps.setAttribute(doc, nid, attr_name, attr_value)
        return Ok(JsValue.Undefined)
    Err(script_error("setAttribute: invalid node reference"))

fn js_removeAttribute(args: [JsValue], doc: Document) -> BrowserResult<JsValue>:
    if args.len() < 2:
        return Err(script_error("removeAttribute requires element and attribute name"))
    val node_id = unwrap_node(args.get(0))
    if val Some(nid) = node_id:
        val attr_name = to_string(args.get(1))
        ElementOps.removeAttribute(doc, nid, attr_name)
        return Ok(JsValue.Undefined)
    Err(script_error("removeAttribute: invalid node reference"))

# ── Child node manipulation ──────────────────────────────────────────────

fn js_appendChild(args: [JsValue], doc: Document) -> BrowserResult<JsValue>:
    if args.len() < 2:
        return Err(script_error("appendChild requires parent and child nodes"))
    val parent_id = unwrap_node(args.get(0))
    val child_id = unwrap_node(args.get(1))
    if val Some(pid) = parent_id:
        if val Some(cid) = child_id:
            doc.appendChild(pid, cid)?
            return Ok(wrap_node(cid))
        return Err(script_error("appendChild: invalid child node"))
    Err(script_error("appendChild: invalid parent node"))

fn js_removeChild(args: [JsValue], doc: Document) -> BrowserResult<JsValue>:
    if args.len() < 2:
        return Err(script_error("removeChild requires parent and child nodes"))
    val parent_id = unwrap_node(args.get(0))
    val child_id = unwrap_node(args.get(1))
    if val Some(pid) = parent_id:
        if val Some(cid) = child_id:
            doc.removeChild(pid, cid)?
            return Ok(wrap_node(cid))
        return Err(script_error("removeChild: invalid child node"))
    Err(script_error("removeChild: invalid parent node"))

fn js_insertBefore(args: [JsValue], doc: Document) -> BrowserResult<JsValue>:
    if args.len() < 3:
        return Err(script_error("insertBefore requires parent, new child, and reference child"))
    val parent_id = unwrap_node(args.get(0))
    val new_child_id = unwrap_node(args.get(1))
    # Third arg can be null (insert at end)
    if val Some(pid) = parent_id:
        if val Some(ncid) = new_child_id:
            val ref_child = unwrap_node(args.get(2))
            if val Some(rcid) = ref_child:
                doc.insertBefore(pid, ncid, rcid)?
            else:
                # Null ref child = append at end
                doc.appendChild(pid, ncid)?
            return Ok(wrap_node(ncid))
        return Err(script_error("insertBefore: invalid new child node"))
    Err(script_error("insertBefore: invalid parent node"))

# ── Property accessors ───────────────────────────────────────────────────

fn js_innerHTML_get(node_id: i64, doc: Document) -> JsValue:
    val html = ElementOps.innerHTML(doc, node_id)
    JsValue.String(v: html)

fn js_innerHTML_set(node_id: i64, html: text, doc: Document) -> BrowserResult<()>:
    if node_id < 0:
        return Err(dom_error("innerHTML set: invalid node id"))
    # Remove existing children
    val node_opt = doc.node_store.get_node(node_id)
    if val Some(node) = node_opt:
        var children_copy = [i64]()
        var ci = 0
        while ci < node.children.len():
            children_copy.push(node.children.get(ci))
            ci = ci + 1
        var ri = 0
        while ri < children_copy.len():
            doc.removeChild(node_id, children_copy.get(ri))
            ri = ri + 1
    # Create a text node with the HTML content as placeholder
    # (full implementation would parse the HTML into a subtree)
    if html.len() > 0:
        val text_id = doc.createTextNode(html)
        doc.appendChild(node_id, text_id)
    Ok(())

fn js_textContent_get(node_id: i64, doc: Document) -> JsValue:
    val content = doc.get_inner_text(node_id)
    JsValue.String(v: content)

fn js_textContent_set(node_id: i64, content: text, doc: Document):
    # Remove all children
    val node_opt = doc.node_store.get_node(node_id)
    if val Some(node) = node_opt:
        var children_copy = [i64]()
        var ci = 0
        while ci < node.children.len():
            children_copy.push(node.children.get(ci))
            ci = ci + 1
        var ri = 0
        while ri < children_copy.len():
            doc.removeChild(node_id, children_copy.get(ri))
            ri = ri + 1
    # Create a single text node
    if content.len() > 0:
        val text_id = doc.createTextNode(content)
        doc.appendChild(node_id, text_id)

fn js_classList_add(node_id: i64, class_name: text, doc: Document):
    ElementOps.classList_add(doc, node_id, class_name)

fn js_classList_remove(node_id: i64, class_name: text, doc: Document):
    ElementOps.classList_remove(doc, node_id, class_name)

fn js_style_set(node_id: i64, property: text, value: text, doc: Document):
    val existing = ElementOps.getAttribute(doc, node_id, "style")
    if val Some(style_str) = existing:
        val new_style = _update_inline_style(style_str, property, value)
        ElementOps.setAttribute(doc, node_id, "style", new_style)
    else:
        ElementOps.setAttribute(doc, node_id, "style", "{property}: {value}")

# ── Node wrapping / unwrapping ───────────────────────────────────────────

# Create a JS object that represents a DOM node.
# The object carries a __node_id__ property for identification.
fn wrap_node(node_id: i64) -> JsValue:
    # We encode the node as a JS Object with a well-known property.
    # The object_store would normally allocate an id; here we use the node_id
    # directly as a stand-in since the full runtime manages allocation.
    JsValue.Object(id: node_id)

# Extract the node_id from a JS value that was created by wrap_node.
fn unwrap_node(value: JsValue) -> i64?:
    match value:
        JsValue.Object(id):
            Some(id)
        JsValue.Number(v):
            # Allow passing numeric node ids directly
            Some(v.to_i64())
        _:
            nil

# ── DOM dispatch ─────────────────────────────────────────────────────────

# Dispatch a DOM native function call by its ID.
fn dispatch_dom_native(fn_id: i64, args: [JsValue], doc: Document) -> BrowserResult<JsValue>:
    if fn_id == NATIVE_GET_ELEMENT_BY_ID:
        return js_getElementById(args, doc)
    if fn_id == NATIVE_GET_ELEMENTS_BY_TAG_NAME:
        return js_getElementsByTagName(args, doc)
    if fn_id == NATIVE_GET_ELEMENTS_BY_CLASS_NAME:
        return js_getElementsByClassName(args, doc)
    if fn_id == NATIVE_QUERY_SELECTOR:
        return js_querySelector(args, doc)
    if fn_id == NATIVE_QUERY_SELECTOR_ALL:
        return js_querySelectorAll(args, doc)
    if fn_id == NATIVE_CREATE_ELEMENT:
        return js_createElement(args, doc)
    if fn_id == NATIVE_CREATE_TEXT_NODE:
        return js_createTextNode(args, doc)
    if fn_id == NATIVE_GET_ATTRIBUTE:
        return js_getAttribute(args, doc)
    if fn_id == NATIVE_SET_ATTRIBUTE:
        return js_setAttribute(args, doc)
    if fn_id == NATIVE_REMOVE_ATTRIBUTE:
        return js_removeAttribute(args, doc)
    if fn_id == NATIVE_APPEND_CHILD:
        return js_appendChild(args, doc)
    if fn_id == NATIVE_REMOVE_CHILD:
        return js_removeChild(args, doc)
    if fn_id == NATIVE_INSERT_BEFORE:
        return js_insertBefore(args, doc)
    if fn_id == NATIVE_GET_INNER_HTML:
        val nid = _extract_node_id(args)
        return Ok(js_innerHTML_get(nid, doc))
    if fn_id == NATIVE_SET_INNER_HTML:
        val nid = _extract_node_id(args)
        val html = _extract_string_arg(args, 1)
        js_innerHTML_set(nid, html, doc)?
        return Ok(JsValue.Undefined)
    if fn_id == NATIVE_GET_TEXT_CONTENT:
        val nid = _extract_node_id(args)
        return Ok(js_textContent_get(nid, doc))
    if fn_id == NATIVE_SET_TEXT_CONTENT:
        val nid = _extract_node_id(args)
        val content = _extract_string_arg(args, 1)
        js_textContent_set(nid, content, doc)
        return Ok(JsValue.Undefined)
    if fn_id == NATIVE_CLASS_LIST_ADD:
        val nid = _extract_node_id(args)
        val cls = _extract_string_arg(args, 1)
        js_classList_add(nid, cls, doc)
        return Ok(JsValue.Undefined)
    if fn_id == NATIVE_CLASS_LIST_REMOVE:
        val nid = _extract_node_id(args)
        val cls = _extract_string_arg(args, 1)
        js_classList_remove(nid, cls, doc)
        return Ok(JsValue.Undefined)
    if fn_id == NATIVE_STYLE_SET:
        val nid = _extract_node_id(args)
        val prop = _extract_string_arg(args, 1)
        val v = _extract_string_arg(args, 2)
        js_style_set(nid, prop, v, doc)
        return Ok(JsValue.Undefined)
    Err(script_error("Unknown DOM native function id: {fn_id}"))

# Extract a node_id from the first argument.
fn _extract_node_id(args: [JsValue]) -> i64:
    if args.len() >= 1:
        val nid = unwrap_node(args.get(0))
        if val Some(id) = nid:
            return id
    -1

# Extract a string argument at the given index.
fn _extract_string_arg(args: [JsValue], index: i64) -> text:
    if args.len() > index:
        return to_string(args.get(index))
    ""

# Wrap a list of node IDs as a JsValue.Array placeholder.
fn _wrap_node_list(ids: [i64]) -> JsValue:
    if ids.len() == 0:
        return JsValue.Array(id: 0)
    JsValue.Array(id: ids.get(0))

# Update inline style string with a new property value.
fn _update_inline_style(style: text, property: text, value: text) -> text:
    val parts = style.split(";")
    var result = [text]()
    var found = false
    var i = 0
    while i < parts.len():
        val part = parts.get(i).trim()
        if part.len() > 0:
            val colon_idx = _find_colon_idx(part)
            if colon_idx >= 0:
                val prop_name = part.substring(0, colon_idx).trim()
                if prop_name == property:
                    result.push("{property}: {value}")
                    found = true
                else:
                    result.push(part)
            else:
                result.push(part)
        i = i + 1
    if not found:
        result.push("{property}: {value}")
    _join_style(result)

fn _find_colon_idx(s: text) -> i64:
    var i = 0
    while i < s.len():
        if s.substring(i, i + 1) == ":":
            return i
        i = i + 1
    -1

fn _join_style(parts: [text]) -> text:
    var result = ""
    var i = 0
    while i < parts.len():
        if i > 0:
            result = result + "; "
        result = result + parts.get(i)
        i = i + 1
    result

# ── Internal helpers ─────────────────────────────────────────────────────

# Simple hash to generate a deterministic node_id from a string identifier.
fn _hash_id(s: text) -> i64:
    var hash: i64 = 5381
    var i = 0
    val len = s.len()
    while i < len:
        val ch = s[i:i + 1]
        # djb2-style hash: hash * 33 + char_code
        hash = hash * 33 + _char_code(ch)
        i = i + 1
    # Keep positive
    if hash < 0:
        hash = 0 - hash
    hash

fn _char_code(ch: text) -> i64:
    if ch.len() == 0:
        return 0
    # Simplified char code — maps a-z to 97-122, A-Z to 65-90, 0-9 to 48-57
    if ch >= "a" and ch <= "z":
        return 97 + _alpha_offset(ch, "a")
    if ch >= "A" and ch <= "Z":
        return 65 + _alpha_offset(ch, "A")
    if ch >= "0" and ch <= "9":
        return 48 + _digit_value(ch)
    # Default for other characters
    95

fn _alpha_offset(ch: text, base: text) -> i64:
    # Count offset from base character
    val chars = "abcdefghijklmnopqrstuvwxyz"
    val lower = ch.to_lower()
    var i = 0
    while i < 26:
        if chars[i:i + 1] == lower:
            return i
        i = i + 1
    0

fn _digit_value(ch: text) -> i64:
    if ch == "0": return 0
    if ch == "1": return 1
    if ch == "2": return 2
    if ch == "3": return 3
    if ch == "4": return 4
    if ch == "5": return 5
    if ch == "6": return 6
    if ch == "7": return 7
    if ch == "8": return 8
    if ch == "9": return 9
    0
