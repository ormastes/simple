# Timer bindings — setTimeout, setInterval, requestAnimationFrame.
# Manages a list of scheduled timers with callback ids, delays, and cancellation.
# The event loop calls tick() each frame to collect and fire expired timers.

use browser.shared.logging.Logger
use browser.shared.error.BrowserResult
use browser.shared.error.script_error
use browser.entity.script.js_types.JsValue
use browser.feature.script.engine.runtime.JsRuntime
use browser.feature.script.engine.interpreter.to_number

# ── Native function IDs ──────────────────────────────────────────────────

val NATIVE_SET_TIMEOUT_BIND = -300
val NATIVE_SET_INTERVAL_BIND = -301
val NATIVE_CLEAR_TIMEOUT_BIND = -302
val NATIVE_CLEAR_INTERVAL_BIND = -303
val NATIVE_REQUEST_ANIMATION_FRAME = -304
val NATIVE_CANCEL_ANIMATION_FRAME = -305

# ── Timer data ───────────────────────────────────────────────────────────

class Timer:
    id: i64
    callback_id: i64
    delay_ms: i64
    is_interval: bool
    scheduled_at: i64
    is_cancelled: bool

    static fn one_shot(id: i64, callback_id: i64, delay_ms: i64, now: i64) -> Timer:
        Timer(
            id: id,
            callback_id: callback_id,
            delay_ms: delay_ms,
            is_interval: false,
            scheduled_at: now,
            is_cancelled: false,
        )

    static fn repeating(id: i64, callback_id: i64, delay_ms: i64, now: i64) -> Timer:
        Timer(
            id: id,
            callback_id: callback_id,
            delay_ms: delay_ms,
            is_interval: true,
            scheduled_at: now,
            is_cancelled: false,
        )

    fn is_due(current_time_ms: i64) -> bool:
        if self.is_cancelled:
            return false
        val fire_at = self.scheduled_at + self.delay_ms
        current_time_ms >= fire_at

# ── TimerBinding ─────────────────────────────────────────────────────────

class TimerBinding:
    timers: [Timer]
    next_id: i64
    logger: Logger

    static fn new(logger: Logger) -> TimerBinding:
        TimerBinding(timers: [Timer](), next_id: 1, logger: logger)

    # Install timer functions on the JS runtime global scope.
    me install(runtime: JsRuntime):
        self.logger.debug("Installing timer bindings")
        runtime._define_global_fn("setTimeout", NATIVE_SET_TIMEOUT_BIND)
        runtime._define_global_fn("setInterval", NATIVE_SET_INTERVAL_BIND)
        runtime._define_global_fn("clearTimeout", NATIVE_CLEAR_TIMEOUT_BIND)
        runtime._define_global_fn("clearInterval", NATIVE_CLEAR_INTERVAL_BIND)
        runtime._define_global_fn("requestAnimationFrame", NATIVE_REQUEST_ANIMATION_FRAME)
        runtime._define_global_fn("cancelAnimationFrame", NATIVE_CANCEL_ANIMATION_FRAME)
        self.logger.debug("Timer bindings installed")

    # ── Timer creation ──────────────────────────────────────────────

    me js_setTimeout(args: [JsValue]) -> JsValue:
        val callback_id = _extract_callback_id(args)
        val delay = _extract_delay(args)
        val timer_id = self.next_id
        self.next_id = self.next_id + 1
        val now = _current_time_stub()
        val timer = Timer.one_shot(timer_id, callback_id, delay, now)
        self.timers.push(timer)
        self.logger.debug("setTimeout: id={timer_id}, delay={delay}ms")
        JsValue.Number(v: timer_id.to_f64())

    me js_setInterval(args: [JsValue]) -> JsValue:
        val callback_id = _extract_callback_id(args)
        val delay = _extract_delay(args)
        val timer_id = self.next_id
        self.next_id = self.next_id + 1
        val now = _current_time_stub()
        val timer = Timer.repeating(timer_id, callback_id, delay, now)
        self.timers.push(timer)
        self.logger.debug("setInterval: id={timer_id}, delay={delay}ms")
        JsValue.Number(v: timer_id.to_f64())

    # ── Timer cancellation ──────────────────────────────────────────

    me js_clearTimeout(args: [JsValue]) -> JsValue:
        val timer_id = _extract_timer_id(args)
        self._cancel_timer(timer_id)
        self.logger.debug("clearTimeout: id={timer_id}")
        JsValue.Undefined

    me js_clearInterval(args: [JsValue]) -> JsValue:
        val timer_id = _extract_timer_id(args)
        self._cancel_timer(timer_id)
        self.logger.debug("clearInterval: id={timer_id}")
        JsValue.Undefined

    # ── requestAnimationFrame ───────────────────────────────────────

    me js_requestAnimationFrame(args: [JsValue]) -> JsValue:
        val callback_id = _extract_callback_id(args)
        val timer_id = self.next_id
        self.next_id = self.next_id + 1
        val now = _current_time_stub()
        # rAF fires before next paint, approximate as ~16ms (60fps)
        val timer = Timer.one_shot(timer_id, callback_id, 16, now)
        self.timers.push(timer)
        self.logger.debug("requestAnimationFrame: id={timer_id}")
        JsValue.Number(v: timer_id.to_f64())

    me js_cancelAnimationFrame(args: [JsValue]) -> JsValue:
        val timer_id = _extract_timer_id(args)
        self._cancel_timer(timer_id)
        self.logger.debug("cancelAnimationFrame: id={timer_id}")
        JsValue.Undefined

    # ── Event loop integration ──────────────────────────────────────

    # Returns callback ids of timers that are due at the given time.
    me tick(current_time_ms: i64) -> [i64]:
        var due_callbacks = [i64]()
        var i = 0
        val len = self.timers.len()
        while i < len:
            val timer = self.timers.get(i)
            if timer.is_due(current_time_ms):
                due_callbacks.push(timer.callback_id)
            i = i + 1
        due_callbacks

    # Collect and return all expired timers, marking one-shot timers as cancelled.
    me fire_timers(current_time_ms: i64) -> [Timer]:
        var fired = [Timer]()
        var i = 0
        val len = self.timers.len()
        while i < len:
            var timer = self.timers.get(i)
            if timer.is_due(current_time_ms):
                fired.push(timer)
                if not timer.is_interval:
                    timer.is_cancelled = true
            i = i + 1
        fired

    # Reschedule interval timers that have fired.
    me reschedule_intervals():
        var i = 0
        val len = self.timers.len()
        val now = _current_time_stub()
        while i < len:
            var timer = self.timers.get(i)
            if timer.is_interval and not timer.is_cancelled:
                val fire_at = timer.scheduled_at + timer.delay_ms
                if now >= fire_at:
                    timer.scheduled_at = now
            i = i + 1

    # ── Internal ────────────────────────────────────────────────────

    me _cancel_timer(timer_id: i64):
        var i = 0
        val len = self.timers.len()
        while i < len:
            var timer = self.timers.get(i)
            if timer.id == timer_id:
                timer.is_cancelled = true
                return
            i = i + 1

# ── Argument extraction helpers ──────────────────────────────────────────

fn _extract_callback_id(args: [JsValue]) -> i64:
    if args.len() >= 1:
        match args.get(0):
            JsValue.Function(id): return id
            JsValue.Number(v): return v.to_i64()
            _: pass_dn
    -1

fn _extract_delay(args: [JsValue]) -> i64:
    if args.len() >= 2:
        val delay_val = to_number(args.get(1))
        val delay_i = delay_val.to_i64()
        if delay_i < 0:
            return 0
        return delay_i
    0

fn _extract_timer_id(args: [JsValue]) -> i64:
    if args.len() >= 1:
        val id_val = to_number(args.get(0))
        return id_val.to_i64()
    -1

# Stub for current time — full implementation uses runtime clock.
fn _current_time_stub() -> i64:
    0
