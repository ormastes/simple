# ── UUID generation ──────────────────────────────────────────────────────

# Generate a UUID v4 string: xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx
# Uses a simple LCG for pseudo-random bytes. NOT cryptographically secure.
fn generate_uuid_v4() -> text:
    # Generate 16 pseudo-random hex nibbles per section.
    # Format: 8-4-4-4-12
    var result = ""

    # Section 1: 8 hex chars
    result = result + _hex_block(8)
    result = result + "-"

    # Section 2: 4 hex chars
    result = result + _hex_block(4)
    result = result + "-"

    # Section 3: 4xxx (version 4)
    result = result + "4"
    result = result + _hex_block(3)
    result = result + "-"

    # Section 4: yxxx (variant bits: 8, 9, a, or b)
    result = result + _variant_char()
    result = result + _hex_block(3)
    result = result + "-"

    # Section 5: 12 hex chars
    result = result + _hex_block(12)

    result

# ── Pseudo-random helpers ────────────────────────────────────────────────

# Simple LCG state — NOT cryptographically secure.
var _lcg_state: i64 = 12345

fn _lcg_next() -> i64:
    # LCG: state = (a * state + c) mod m
    _lcg_state = (_lcg_state * 1103515245 + 12345) % 2147483647
    if _lcg_state < 0:
        _lcg_state = 0 - _lcg_state
    _lcg_state

fn _hex_block(count: i64) -> text:
    val hex_chars = "0123456789abcdef"
    var result = ""
    var i = 0
    while i < count:
        val r = _lcg_next() % 16
        result = result + hex_chars[r:r + 1]
        i = i + 1
    result

fn _variant_char() -> text:
    # Variant must be 8, 9, a, or b
    val variants = "89ab"
    val r = _lcg_next() % 4
    variants[r:r + 1]
