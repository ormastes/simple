# Web Crypto API binding — crypto.getRandomValues, crypto.randomUUID,
# and SubtleCrypto stubs (digest, encrypt, decrypt, sign, verify).

use browser.shared.logging.Logger
use browser.shared.error.BrowserResult
use browser.shared.error.script_error
use browser.entity.script.js_types.JsValue
use browser.entity.script.js_types.JsObject
use browser.entity.script.js_types.JsProperty
use browser.feature.script.engine.runtime.JsRuntime
use browser.feature.script.engine.interpreter.to_string

# ── Native function IDs ──────────────────────────────────────────────────

val NATIVE_CRYPTO_GET_RANDOM_VALUES = -700
val NATIVE_CRYPTO_RANDOM_UUID = -701
val NATIVE_SUBTLE_DIGEST = -710
val NATIVE_SUBTLE_ENCRYPT = -711
val NATIVE_SUBTLE_DECRYPT = -712
val NATIVE_SUBTLE_SIGN = -713
val NATIVE_SUBTLE_VERIFY = -714

# ── CryptoBinding ────────────────────────────────────────────────────────

class CryptoBinding:
    logger: Logger
    seed: i64

    static fn new(logger: Logger) -> CryptoBinding:
        CryptoBinding(logger: logger, seed: 42)

    # Install crypto and crypto.subtle objects on the JS runtime.
    me install(runtime: JsRuntime):
        self.logger.debug("Installing crypto bindings")

        # Create the crypto object
        val crypto_id = runtime.interpreter.object_store.create_object()

        runtime._define_method_on(crypto_id, "getRandomValues", NATIVE_CRYPTO_GET_RANDOM_VALUES)
        runtime._define_method_on(crypto_id, "randomUUID", NATIVE_CRYPTO_RANDOM_UUID)

        # Create the subtle sub-object
        val subtle_id = runtime.interpreter.object_store.create_object()
        runtime._define_method_on(subtle_id, "digest", NATIVE_SUBTLE_DIGEST)
        runtime._define_method_on(subtle_id, "encrypt", NATIVE_SUBTLE_ENCRYPT)
        runtime._define_method_on(subtle_id, "decrypt", NATIVE_SUBTLE_DECRYPT)
        runtime._define_method_on(subtle_id, "sign", NATIVE_SUBTLE_SIGN)
        runtime._define_method_on(subtle_id, "verify", NATIVE_SUBTLE_VERIFY)

        # Attach subtle to crypto
        runtime.interpreter.object_store.set_property(
            crypto_id, "subtle", JsValue.Object(id: subtle_id))

        # Bind crypto to global scope
        runtime.interpreter.env_stack.define_var(
            runtime.interpreter.global_env, "crypto", JsValue.Object(id: crypto_id))

        self.logger.debug("Crypto bindings installed")

# ── crypto.getRandomValues ───────────────────────────────────────────────

fn js_crypto_getRandomValues(args: List<JsValue>) -> JsValue:
    # Fill a typed array with cryptographically strong random values.
    # Full implementation requires a CSPRNG; this is a stub with pseudo-random.
    if args.len() < 1:
        return JsValue.Undefined

    # The argument should be a TypedArray (Uint8Array, Uint16Array, etc.).
    # For now, return the input unchanged — actual RNG fill is pass_todo.
    val typed_array = args.get(0)
    pass_todo

fn js_crypto_randomUUID(args: List<JsValue>) -> JsValue:
    # Generate a v4 UUID: xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx
    val uuid = generate_uuid_v4()
    JsValue.String(v: uuid)

