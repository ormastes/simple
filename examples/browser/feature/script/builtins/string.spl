# String and RegExp built-ins for the JS engine.
# Operates on Simple text type (maps to JS string).

fn string_length(s: text) -> i64:
    s.len()

fn string_charAt(s: text, index: i64) -> text:
    val len = s.len()
    if index < 0 or index >= len:
        return ""
    s[index:index + 1]

fn string_charCodeAt(s: text, index: i64) -> i64:
    val ch = string_charAt(s, index)
    if ch == "":
        return -1
    # Return the byte value of the first character
    ch.byte_at(0)

fn string_indexOf(s: text, search: text) -> i64:
    val s_len = s.len()
    val search_len = search.len()
    if search_len == 0:
        return 0
    if search_len > s_len:
        return -1
    var i = 0
    val limit = s_len - search_len
    while i <= limit:
        val sub = s[i:i + search_len]
        if sub == search:
            return i
        i = i + 1
    -1

fn string_lastIndexOf(s: text, search: text) -> i64:
    val s_len = s.len()
    val search_len = search.len()
    if search_len == 0:
        return s_len
    if search_len > s_len:
        return -1
    var i = s_len - search_len
    while i >= 0:
        val sub = s[i:i + search_len]
        if sub == search:
            return i
        i = i - 1
    -1

fn string_includes(s: text, search: text) -> bool:
    string_indexOf(s, search) >= 0

fn string_startsWith(s: text, prefix: text) -> bool:
    val prefix_len = prefix.len()
    if prefix_len > s.len():
        return false
    s[0:prefix_len] == prefix

fn string_endsWith(s: text, suffix: text) -> bool:
    val s_len = s.len()
    val suffix_len = suffix.len()
    if suffix_len > s_len:
        return false
    s[s_len - suffix_len:s_len] == suffix

fn string_slice(s: text, start: i64, end_idx: i64) -> text:
    val len = s.len()
    var st = start
    var en = end_idx
    if st < 0:
        st = len + st
    if st < 0:
        st = 0
    if en < 0:
        en = len + en
    if en > len:
        en = len
    if st >= en:
        return ""
    s[st:en]

fn string_substring(s: text, start: i64, end_idx: i64) -> text:
    val len = s.len()
    var st = start
    var en = end_idx
    if st < 0:
        st = 0
    if en < 0:
        en = 0
    if st > len:
        st = len
    if en > len:
        en = len
    # substring swaps if start > end
    if st > en:
        val tmp = st
        st = en
        en = tmp
    s[st:en]

fn string_toUpperCase(s: text) -> text:
    s.to_upper()

fn string_toLowerCase(s: text) -> text:
    s.to_lower()

fn string_trim(s: text) -> text:
    s.trim()

fn string_trimStart(s: text) -> text:
    s.trim_start()

fn string_trimEnd(s: text) -> text:
    s.trim_end()

fn string_split(s: text, separator: text) -> [text]:
    if separator == "":
        # Split into individual characters
        var chars = [text]()
        var i = 0
        val len = s.len()
        while i < len:
            chars.push(s[i:i + 1])
            i = i + 1
        return chars
    s.split(separator)

fn string_replace(s: text, search: text, replacement: text) -> text:
    val idx = string_indexOf(s, search)
    if idx < 0:
        return s
    val before = s[0:idx]
    val after = s[idx + search.len():s.len()]
    before + replacement + after

fn string_repeat(s: text, count: i64) -> text:
    if count <= 0:
        return ""
    var result = ""
    var i = 0
    while i < count:
        result = result + s
        i = i + 1
    result

fn string_padStart(s: text, length: i64, pad: text) -> text:
    val s_len = s.len()
    if s_len >= length:
        return s
    val pad_len = pad.len()
    if pad_len == 0:
        return s
    var padding = ""
    val needed = length - s_len
    while padding.len() < needed:
        padding = padding + pad
    # Trim padding to exact needed length
    padding = padding[0:needed]
    padding + s

fn string_padEnd(s: text, length: i64, pad: text) -> text:
    val s_len = s.len()
    if s_len >= length:
        return s
    val pad_len = pad.len()
    if pad_len == 0:
        return s
    var padding = ""
    val needed = length - s_len
    while padding.len() < needed:
        padding = padding + pad
    padding = padding[0:needed]
    s + padding

fn string_replaceAll(s: text, search: text, replacement: text) -> text:
    if search == "":
        return s
    var result = ""
    var pos = 0
    val s_len = s.len()
    val search_len = search.len()
    while pos <= s_len - search_len:
        val sub = s[pos:pos + search_len]
        if sub == search:
            result = result + replacement
            pos = pos + search_len
        else:
            result = result + s[pos:pos + 1]
            pos = pos + 1
    # Append remaining characters
    if pos < s_len:
        result = result + s[pos:s_len]
    result

fn string_concat(a: text, b: text) -> text:
    a + b

fn string_fromCharCode(code: i64) -> text:
    # Convert a char code to a single-character string
    # Common ASCII range
    if code == 0: return "\0"
    if code == 9: return "\t"
    if code == 10: return "\n"
    if code == 13: return "\r"
    if code == 32: return " "
    if code == 33: return "!"
    if code == 34: return "\""
    if code == 35: return "#"
    if code == 36: return "$"
    if code == 37: return "%"
    if code == 38: return "&"
    if code == 39: return "'"
    if code == 40: return "("
    if code == 41: return ")"
    if code == 42: return "*"
    if code == 43: return "+"
    if code == 44: return ","
    if code == 45: return "-"
    if code == 46: return "."
    if code == 47: return "/"
    if code >= 48 and code <= 57:
        val digit = code - 48
        return "{digit}"
    if code == 58: return ":"
    if code == 59: return ";"
    if code == 60: return "<"
    if code == 61: return "="
    if code == 62: return ">"
    if code == 63: return "?"
    if code == 64: return "@"
    # Uppercase letters A-Z (65-90)
    if code >= 65 and code <= 90:
        val letters = "ABCDEFGHIJKLMNOPQRSTUVWXYZ"
        val idx = code - 65
        return letters[idx:idx + 1]
    if code == 91: return "["
    if code == 92: return "\\"
    if code == 93: return "]"
    if code == 94: return "^"
    if code == 95: return "_"
    if code == 96: return "`"
    # Lowercase letters a-z (97-122)
    if code >= 97 and code <= 122:
        val letters = "abcdefghijklmnopqrstuvwxyz"
        val idx = code - 97
        return letters[idx:idx + 1]
    if code == 123: return "{"
    if code == 124: return "|"
    if code == 125: return "}"
    if code == 126: return "~"
    # Outside printable ASCII range — return placeholder
    "?"
