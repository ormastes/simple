# JS Error types for the JS engine.
# Models Error, TypeError, ReferenceError, etc.

use browser.entity.script.js_types.*

enum JsErrorKind:
    Error
    TypeError
    ReferenceError
    SyntaxError
    RangeError
    URIError
    EvalError

class JsError:
    kind: JsErrorKind
    message: text
    stack: [text]

# --- Constructors ---

fn create_error(kind: JsErrorKind, message: text) -> JsError:
    JsError(kind: kind, message: message, stack: [text]())

fn create_type_error(message: text) -> JsError:
    JsError(kind: JsErrorKind.TypeError, message: message, stack: [text]())

fn create_reference_error(message: text) -> JsError:
    JsError(kind: JsErrorKind.ReferenceError, message: message, stack: [text]())

fn create_syntax_error(message: text) -> JsError:
    JsError(kind: JsErrorKind.SyntaxError, message: message, stack: [text]())

fn create_range_error(message: text) -> JsError:
    JsError(kind: JsErrorKind.RangeError, message: message, stack: [text]())

fn create_uri_error(message: text) -> JsError:
    JsError(kind: JsErrorKind.URIError, message: message, stack: [text]())

fn create_eval_error(message: text) -> JsError:
    JsError(kind: JsErrorKind.EvalError, message: message, stack: [text]())

# --- Stack trace ---

me push_stack_frame(error: JsError, frame: text):
    error.stack.push(frame)

fn format_stack_trace(error: JsError) -> text:
    val kind_name = _error_kind_name(error.kind)
    var result = "{kind_name}: {error.message}"
    var i = 0
    val len = error.stack.len()
    while i < len:
        val frame = error.stack.get(i)
        result = result + "\n    at {frame}"
        i = i + 1
    result

# --- Conversion ---

fn error_to_js_value(error: JsError) -> JsValue:
    # Convert error to a JsValue.Object that has message and stack properties.
    # The caller should allocate the object ID and populate the object store.
    # For now, return a string representation.
    JsValue.String(v: format_stack_trace(error))

fn error_message(error: JsError) -> text:
    error.message

fn error_kind(error: JsError) -> JsErrorKind:
    error.kind

fn error_stack_depth(error: JsError) -> i64:
    error.stack.len()

# --- Kind name ---

fn _error_kind_name(kind: JsErrorKind) -> text:
    match kind:
        JsErrorKind.Error: "Error"
        JsErrorKind.TypeError: "TypeError"
        JsErrorKind.ReferenceError: "ReferenceError"
        JsErrorKind.SyntaxError: "SyntaxError"
        JsErrorKind.RangeError: "RangeError"
        JsErrorKind.URIError: "URIError"
        JsErrorKind.EvalError: "EvalError"

# --- Predicate helpers ---

fn is_type_error(error: JsError) -> bool:
    match error.kind:
        JsErrorKind.TypeError: true
        _: false

fn is_reference_error(error: JsError) -> bool:
    match error.kind:
        JsErrorKind.ReferenceError: true
        _: false

fn is_syntax_error(error: JsError) -> bool:
    match error.kind:
        JsErrorKind.SyntaxError: true
        _: false

fn is_range_error(error: JsError) -> bool:
    match error.kind:
        JsErrorKind.RangeError: true
        _: false
