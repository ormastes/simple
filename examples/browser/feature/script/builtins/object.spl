#![allow(REQC001)]
#![allow(REQC004)]
#![allow(unnamed_duplicate_typed_args)]
# Object, Array, Map, Set, WeakMap, WeakSet built-ins.
# Operates on JsValue/JsObject types from js_types.spl.

use std.js.types.js_types.*

# --- Object methods ---

fn object_keys(obj: JsObject) -> JsValue:
    var keys = [JsValue]()
    var i = 0
    val props = obj.properties
    val len = props.len()
    while i < len:
        val prop = props.get(i)
        if prop.enumerable:
            keys.push(JsValue.String(v: prop.key))
        i = i + 1
    # Return as array JsValue — caller allocates the array id
    JsValue.Array(id: obj.id)

fn object_values(obj: JsObject) -> JsValue:
    var values = [JsValue]()
    var i = 0
    val props = obj.properties
    val len = props.len()
    while i < len:
        val prop = props.get(i)
        if prop.enumerable:
            values.push(prop.value)
        i = i + 1
    JsValue.Array(id: obj.id)

fn object_entries(obj: JsObject) -> JsValue:
    var entries = [JsValue]()
    var i = 0
    val props = obj.properties
    val len = props.len()
    while i < len:
        val prop = props.get(i)
        if prop.enumerable:
            # Each entry is conceptually [key, value]
            entries.push(JsValue.String(v: prop.key))
            entries.push(prop.value)
        i = i + 1
    JsValue.Array(id: obj.id)

fn object_assign(target: JsObject, sources: [JsObject]) -> JsObject:
    var result = target
    var si = 0
    val source_count = sources.len()
    while si < source_count:
        val source = sources.get(si)
        var pi = 0
        val prop_count = source.properties.len()
        while pi < prop_count:
            val prop = source.properties.get(pi)
            if prop.enumerable:
                var found = false
                var ti = 0
                val target_len = result.properties.len()
                while ti < target_len:
                    val existing = result.properties.get(ti)
                    if existing.key == prop.key:
                        if existing.writable:
                            result.properties.set(ti, JsProperty.data(key: prop.key, value: prop.value))
                        found = true
                    ti = ti + 1
                if not found:
                    result.properties.push(JsProperty.data(key: prop.key, value: prop.value))
            pi = pi + 1
        si = si + 1
    result

fn object_freeze(obj: JsObject) -> JsObject:
    var frozen = obj
    var i = 0
    val len = frozen.properties.len()
    while i < len:
        val prop = frozen.properties.get(i)
        val read_only = JsProperty(
            key: prop.key,
            value: prop.value,
            writable: false,
            enumerable: prop.enumerable,
            configurable: false
        )
        frozen.properties.set(i, read_only)
        i = i + 1
    frozen

fn object_has_own(obj: JsObject, key: text) -> bool:
    var i = 0
    val len = obj.properties.len()
    while i < len:
        val prop = obj.properties.get(i)
        if prop.key == key:
            return true
        i = i + 1
    false

# --- Array methods ---

fn array_push(arr: JsObject, value: JsValue) -> JsValue:
    arr.properties.push(JsProperty.data(key: "{arr.properties.len()}", value: value))
    val new_len = arr.properties.len()
    JsValue.Number(v: new_len.to_f64())

fn array_pop(arr: JsObject) -> JsValue:
    val len = arr.properties.len()
    if len == 0:
        return JsValue.Undefined
    val last = arr.properties.get(len - 1)
    arr.properties.remove(len - 1)
    last.value

fn array_shift(arr: JsObject) -> JsValue:
    val len = arr.properties.len()
    if len == 0:
        return JsValue.Undefined
    val first = arr.properties.get(0)
    arr.properties.remove(0)
    # Re-index remaining properties
    var i = 0
    val new_len = arr.properties.len()
    while i < new_len:
        val prop = arr.properties.get(i)
        arr.properties.set(i, JsProperty.data(key: "{i}", value: prop.value))
        i = i + 1
    first.value

fn array_unshift(arr: JsObject, value: JsValue) -> JsValue:
    arr.properties.insert(0, JsProperty.data(key: "0", value: value))
    # Re-index all properties
    var i = 0
    val len = arr.properties.len()
    while i < len:
        val prop = arr.properties.get(i)
        arr.properties.set(i, JsProperty.data(key: "{i}", value: prop.value))
        i = i + 1
    JsValue.Number(v: len.to_f64())

fn array_length(arr: JsObject) -> i64:
    arr.properties.len()

fn array_slice(arr: JsObject, start: i64, end_idx: i64) -> JsValue:
    var result = [JsProperty]()
    val len = arr.properties.len()
    var s = start
    var e = end_idx
    if s < 0:
        s = len + s
    if s < 0:
        s = 0
    if e < 0:
        e = len + e
    if e > len:
        e = len
    var i = s
    var idx = 0
    while i < e:
        val prop = arr.properties.get(i)
        result.push(JsProperty.data(key: "{idx}", value: prop.value))
        i = i + 1
        idx = idx + 1
    JsValue.Array(id: -1)

fn array_splice(arr: JsObject, start: i64, delete_count: i64, items: [JsValue]) -> JsValue:
    val len = arr.properties.len()
    var s = start
    if s < 0:
        s = len + s
    if s < 0:
        s = 0
    if s > len:
        s = len
    var dc = delete_count
    if dc < 0:
        dc = 0
    if s + dc > len:
        dc = len - s
    # Remove deleted elements
    var removed = [JsProperty]()
    var d = 0
    while d < dc:
        val prop = arr.properties.get(s)
        removed.push(prop)
        arr.properties.remove(s)
        d = d + 1
    # Insert new items
    var ii = 0
    val item_count = items.len()
    while ii < item_count:
        arr.properties.insert(s + ii, JsProperty.data(key: "{s + ii}", value: items.get(ii)))
        ii = ii + 1
    # Re-index
    var ri = 0
    val new_len = arr.properties.len()
    while ri < new_len:
        val prop = arr.properties.get(ri)
        arr.properties.set(ri, JsProperty.data(key: "{ri}", value: prop.value))
        ri = ri + 1
    JsValue.Array(id: -1)

fn array_indexOf(arr: JsObject, value: JsValue) -> i64:
    var i = 0
    val len = arr.properties.len()
    while i < len:
        val prop = arr.properties.get(i)
        if _js_value_equal(prop.value, value):
            return i
        i = i + 1
    -1

fn array_includes(arr: JsObject, value: JsValue) -> bool:
    array_indexOf(arr, value) >= 0

fn array_join(arr: JsObject, separator: text) -> text:
    var result = ""
    var i = 0
    val len = arr.properties.len()
    while i < len:
        if i > 0:
            result = result + separator
        val prop = arr.properties.get(i)
        result = result + _js_value_to_string(prop.value)
        i = i + 1
    result

fn array_reverse(arr: JsObject) -> JsObject:
    val len = arr.properties.len()
    var left = 0
    var right = len - 1
    while left < right:
        val l_prop = arr.properties.get(left)
        val r_prop = arr.properties.get(right)
        arr.properties.set(left, JsProperty.data(key: "{left}", value: r_prop.value))
        arr.properties.set(right, JsProperty.data(key: "{right}", value: l_prop.value))
        left = left + 1
        right = right - 1
    arr

fn array_concat(arr: JsObject, other: JsObject) -> JsValue:
    var idx = arr.properties.len()
    var i = 0
    val other_len = other.properties.len()
    while i < other_len:
        val prop = other.properties.get(i)
        arr.properties.push(JsProperty.data(key: "{idx}", value: prop.value))
        idx = idx + 1
        i = i + 1
    JsValue.Array(id: arr.id)

# --- Internal helpers ---

fn _js_value_equal(a: JsValue, b: JsValue) -> bool:
    match a:
        JsValue.Undefined:
            match b:
                JsValue.Undefined: true
                _: false
        JsValue.Null:
            match b:
                JsValue.Null: true
                _: false
        JsValue.Boolean(v):
            match b:
                JsValue.Boolean(v2): v == v2
                _: false
        JsValue.Number(v):
            match b:
                JsValue.Number(v2): v == v2
                _: false
        JsValue.String(v):
            match b:
                JsValue.String(v2): v == v2
                _: false
        _: false

fn _js_value_to_string(value: JsValue) -> text:
    match value:
        JsValue.Undefined: "undefined"
        JsValue.Null: "null"
        JsValue.Boolean(v):
            if v: "true" else: "false"
        JsValue.Number(v): "{v}"
        JsValue.String(v): v
        JsValue.Object(id): "[object Object]"
        JsValue.Array(id): "[object Array]"
        JsValue.Function(id): "[object Function]"
        JsValue.Symbol(id): "[object Symbol]"

# --- Map / Set / WeakMap / WeakSet stubs ---

# --- Object.seal ---

fn object_seal(obj: JsObject) -> JsObject:
    var sealed = obj
    var i = 0
    val len = sealed.properties.len()
    while i < len:
        val prop = sealed.properties.get(i)
        val non_config = JsProperty(
            key: prop.key,
            value: prop.value,
            writable: prop.writable,
            enumerable: prop.enumerable,
            configurable: false
        )
        sealed.properties.set(i, non_config)
        i = i + 1
    sealed

# --- Object.create ---

fn object_create(prototype_id: i64) -> JsObject:
    JsObject.with_prototype(-1, prototype_id)

# --- Object.defineProperty ---

fn object_defineProperty(obj: JsObject, key: text, writable: bool, enumerable: bool, configurable: bool, value: JsValue) -> JsObject:
    var found = false
    var i = 0
    val len = obj.properties.len()
    while i < len:
        val prop = obj.properties.get(i)
        if prop.key == key:
            obj.properties.set(i, JsProperty(key: key, value: value, writable: writable, enumerable: enumerable, configurable: configurable))
            found = true
        i = i + 1
    if not found:
        obj.properties.push(JsProperty(key: key, value: value, writable: writable, enumerable: enumerable, configurable: configurable))
    obj

# --- Object.getPrototypeOf ---

fn object_getPrototypeOf(obj: JsObject) -> i64:
    obj.prototype_id

# --- Object.getOwnPropertyDescriptor ---

fn object_getOwnPropertyDescriptor(obj: JsObject, key: text) -> Option<JsProperty>:
    var i = 0
    val len = obj.properties.len()
    while i < len:
        val prop = obj.properties.get(i)
        if prop.key == key:
            return Some(prop)
        i = i + 1
    None

# --- Object.getOwnPropertyNames ---

fn object_getOwnPropertyNames(obj: JsObject) -> [text]:
    var names = [text]()
    var i = 0
    val len = obj.properties.len()
    while i < len:
        val prop = obj.properties.get(i)
        names.push(prop.key)
        i = i + 1
    names

# --- Map methods ---
# Map is modeled as a JsObject with properties as key-value pairs.

fn map_set(obj: JsObject, key: text, value: JsValue) -> JsObject:
    var found = false
    var i = 0
    val len = obj.properties.len()
    while i < len:
        val prop = obj.properties.get(i)
        if prop.key == key:
            obj.properties.set(i, JsProperty.data(key: key, value: value))
            found = true
        i = i + 1
    if not found:
        obj.properties.push(JsProperty.data(key: key, value: value))
    obj

fn map_get(obj: JsObject, key: text) -> JsValue:
    var i = 0
    val len = obj.properties.len()
    while i < len:
        val prop = obj.properties.get(i)
        if prop.key == key:
            return prop.value
        i = i + 1
    JsValue.Undefined

fn map_has(obj: JsObject, key: text) -> bool:
    var i = 0
    val len = obj.properties.len()
    while i < len:
        val prop = obj.properties.get(i)
        if prop.key == key:
            return true
        i = i + 1
    false

fn map_delete(obj: JsObject, key: text) -> bool:
    var i = 0
    val len = obj.properties.len()
    while i < len:
        val prop = obj.properties.get(i)
        if prop.key == key:
            obj.properties.remove(i)
            return true
        i = i + 1
    false

# --- Set methods ---
# Set is modeled as a JsObject where each property key is the string representation of the value.

fn set_add(obj: JsObject, value: JsValue) -> JsObject:
    val key = _js_value_to_string(value)
    if not set_has(obj, value):
        obj.properties.push(JsProperty.data(key: key, value: value))
    obj

fn set_has(obj: JsObject, value: JsValue) -> bool:
    val key = _js_value_to_string(value)
    var i = 0
    val len = obj.properties.len()
    while i < len:
        val prop = obj.properties.get(i)
        if prop.key == key:
            return true
        i = i + 1
    false

fn set_delete(obj: JsObject, value: JsValue) -> bool:
    val key = _js_value_to_string(value)
    var i = 0
    val len = obj.properties.len()
    while i < len:
        val prop = obj.properties.get(i)
        if prop.key == key:
            obj.properties.remove(i)
            return true
        i = i + 1
    false

# --- WeakMap methods ---
# WeakMap uses integer key ids (object references). Modeled as properties with key = "{key_id}".

fn weakmap_set(obj: JsObject, key_id: i64, value: JsValue) -> JsObject:
    val key = "{key_id}"
    var found = false
    var i = 0
    val len = obj.properties.len()
    while i < len:
        val prop = obj.properties.get(i)
        if prop.key == key:
            obj.properties.set(i, JsProperty.data(key: key, value: value))
            found = true
        i = i + 1
    if not found:
        obj.properties.push(JsProperty.data(key: key, value: value))
    obj

fn weakmap_get(obj: JsObject, key_id: i64) -> JsValue:
    val key = "{key_id}"
    var i = 0
    val len = obj.properties.len()
    while i < len:
        val prop = obj.properties.get(i)
        if prop.key == key:
            return prop.value
        i = i + 1
    JsValue.Undefined

# --- WeakSet methods ---

fn weakset_add(obj: JsObject, value_id: i64) -> JsObject:
    val key = "{value_id}"
    var found = false
    var i = 0
    val len = obj.properties.len()
    while i < len:
        if obj.properties.get(i).key == key:
            found = true
        i = i + 1
    if not found:
        obj.properties.push(JsProperty.data(key: key, value: JsValue.Number(v: value_id.to_f64())))
    obj

fn weakset_has(obj: JsObject, value_id: i64) -> bool:
    val key = "{value_id}"
    var i = 0
    val len = obj.properties.len()
    while i < len:
        if obj.properties.get(i).key == key:
            return true
        i = i + 1
    false
