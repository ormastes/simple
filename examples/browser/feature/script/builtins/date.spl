# Date built-in for the JS engine.
# Models JS Date with timestamp-based decomposition.

class JsDate:
    timestamp_ms: i64

# --- Construction ---

fn date_now() -> i64:
    # Returns current timestamp in milliseconds since Unix epoch.
    # Requires runtime clock support.
    pass_todo

fn date_new(year: i64, month: i64, day: i64, hours: i64, minutes: i64, seconds: i64, ms: i64) -> JsDate:
    # Convert date components to milliseconds since epoch.
    # month is 0-based (0 = January) per JS convention.
    var total_days: i64 = 0
    # Days from epoch year (1970) to target year
    var y = 1970
    if year >= 1970:
        while y < year:
            if is_leap_year(y):
                total_days = total_days + 366
            else:
                total_days = total_days + 365
            y = y + 1
    else:
        y = 1969
        while y >= year:
            if is_leap_year(y):
                total_days = total_days - 366
            else:
                total_days = total_days - 365
            y = y - 1
    # Days from months in target year
    var m = 0
    while m < month:
        total_days = total_days + days_in_month(year, m)
        m = m + 1
    # Day of month (1-based)
    total_days = total_days + day - 1
    val total_ms = total_days * 86400000 + hours * 3600000 + minutes * 60000 + seconds * 1000 + ms
    JsDate(timestamp_ms: total_ms)

fn date_from_timestamp(ms: i64) -> JsDate:
    JsDate(timestamp_ms: ms)

# --- Getters ---

fn date_getTime(d: JsDate) -> i64:
    d.timestamp_ms

fn date_getFullYear(d: JsDate) -> i64:
    val parts = _decompose_timestamp(d.timestamp_ms)
    parts.year

fn date_getMonth(d: JsDate) -> i64:
    val parts = _decompose_timestamp(d.timestamp_ms)
    parts.month

fn date_getDate(d: JsDate) -> i64:
    val parts = _decompose_timestamp(d.timestamp_ms)
    parts.day

fn date_getDay(d: JsDate) -> i64:
    # Day of week: 0 = Sunday, 1 = Monday, ..., 6 = Saturday
    # Jan 1 1970 was a Thursday (4)
    var total_days = d.timestamp_ms / 86400000
    var dow = (total_days + 4) % 7
    if dow < 0:
        dow = dow + 7
    dow

fn date_getHours(d: JsDate) -> i64:
    val parts = _decompose_timestamp(d.timestamp_ms)
    parts.hours

fn date_getMinutes(d: JsDate) -> i64:
    val parts = _decompose_timestamp(d.timestamp_ms)
    parts.minutes

fn date_getSeconds(d: JsDate) -> i64:
    val parts = _decompose_timestamp(d.timestamp_ms)
    parts.seconds

fn date_getMilliseconds(d: JsDate) -> i64:
    val parts = _decompose_timestamp(d.timestamp_ms)
    parts.ms

# --- Formatting ---

fn date_toISOString(d: JsDate) -> text:
    val parts = _decompose_timestamp(d.timestamp_ms)
    val y_str = _pad_number(parts.year, 4)
    val m_str = _pad_number(parts.month + 1, 2)
    val d_str = _pad_number(parts.day, 2)
    val h_str = _pad_number(parts.hours, 2)
    val min_str = _pad_number(parts.minutes, 2)
    val s_str = _pad_number(parts.seconds, 2)
    val ms_str = _pad_number(parts.ms, 3)
    "{y_str}-{m_str}-{d_str}T{h_str}:{min_str}:{s_str}.{ms_str}Z"

fn date_toLocaleDateString(d: JsDate) -> text:
    val parts = _decompose_timestamp(d.timestamp_ms)
    "{parts.month + 1}/{parts.day}/{parts.year}"

# --- Helpers ---

fn days_in_month(year: i64, month: i64) -> i64:
    # month is 0-based
    if month == 0: return 31
    if month == 1:
        if is_leap_year(year):
            return 29
        return 28
    if month == 2: return 31
    if month == 3: return 30
    if month == 4: return 31
    if month == 5: return 30
    if month == 6: return 31
    if month == 7: return 31
    if month == 8: return 30
    if month == 9: return 31
    if month == 10: return 30
    if month == 11: return 31
    30

fn is_leap_year(year: i64) -> bool:
    if year % 400 == 0:
        return true
    if year % 100 == 0:
        return false
    year % 4 == 0

# --- Internal decomposition ---

class _DateParts:
    year: i64
    month: i64
    day: i64
    hours: i64
    minutes: i64
    seconds: i64
    ms: i64

fn _decompose_timestamp(timestamp_ms: i64) -> _DateParts:
    var remaining_ms = timestamp_ms
    val ms = remaining_ms % 1000
    remaining_ms = remaining_ms / 1000
    val seconds = remaining_ms % 60
    remaining_ms = remaining_ms / 60
    val minutes = remaining_ms % 60
    remaining_ms = remaining_ms / 60
    val hours = remaining_ms % 24
    var total_days = remaining_ms / 24

    # Compute year
    var year = 1970
    if total_days >= 0:
        while true:
            val year_days = _year_length(year)
            if total_days < year_days:
                break
            total_days = total_days - year_days
            year = year + 1
    else:
        while total_days < 0:
            year = year - 1
            total_days = total_days + _year_length(year)

    # Compute month and day
    var month = 0
    while month < 11:
        val m_days = days_in_month(year, month)
        if total_days < m_days:
            break
        total_days = total_days - m_days
        month = month + 1

    val day = total_days + 1  # 1-based

    _DateParts(
        year: year,
        month: month,
        day: day,
        hours: hours,
        minutes: minutes,
        seconds: seconds,
        ms: ms
    )

fn _year_length(year: i64) -> i64:
    if is_leap_year(year): 366 else: 365

fn _pad_number(n: i64, width: i64) -> text:
    var s = "{n}"
    while s.len() < width:
        s = "0" + s
    s
