#![allow(unnamed_duplicate_typed_args)]
# JSON.parse and JSON.stringify for the JS engine.
# Parses JSON text into JsValue tree and serializes back.

use std.js.types.js_types.*
use browser.shared.error.*

class Pair<A, B>:
    first: A
    second: B

# --- Public API ---

fn json_parse(input: text) -> BrowserResult<JsValue>:
    val trimmed_pos = skip_whitespace(input, 0)
    if trimmed_pos >= input.len():
        return Result.Err(parse_error("Unexpected end of JSON input"))
    val result = parse_value(input, trimmed_pos)
    Result.Ok(result.first)

fn json_stringify(value: JsValue, indent: i64) -> text:
    stringify_value(value, indent, 0)

# --- Internal parsing ---

fn parse_value(input: text, pos: i64) -> Pair<JsValue, i64>:
    val p = skip_whitespace(input, pos)
    if p >= input.len():
        return Pair(first: JsValue.Undefined, second: p)
    val ch = input[p:p + 1]
    if ch == "\"":
        val str_result = parse_string(input, p)
        return Pair(first: JsValue.String(v: str_result.first), second: str_result.second)
    if ch == "{":
        return parse_object(input, p)
    if ch == "[":
        return parse_array(input, p)
    if ch == "t":
        # true
        return Pair(first: JsValue.Boolean(v: true), second: p + 4)
    if ch == "f":
        # false
        return Pair(first: JsValue.Boolean(v: false), second: p + 5)
    if ch == "n":
        # null
        return Pair(first: JsValue.Null, second: p + 4)
    # Number
    val num_result = parse_number(input, p)
    Pair(first: JsValue.Number(v: num_result.first), second: num_result.second)

fn parse_string(input: text, pos: i64) -> Pair<text, i64>:
    # pos points to opening quote
    var i = pos + 1
    var result = ""
    val len = input.len()
    while i < len:
        val ch = input[i:i + 1]
        if ch == "\"":
            return Pair(first: result, second: i + 1)
        if ch == "\\":
            i = i + 1
            if i >= len:
                break
            val esc = input[i:i + 1]
            if esc == "\"":
                result = result + "\""
            else if esc == "\\":
                result = result + "\\"
            else if esc == "/":
                result = result + "/"
            else if esc == "n":
                result = result + "\n"
            else if esc == "t":
                result = result + "\t"
            else if esc == "r":
                result = result + "\r"
            else if esc == "b":
                result = result + "\b"
            else if esc == "f":
                result = result + "\f"
            else if esc == "u":
                # Unicode escape \uXXXX — simplified, skip 4 chars
                result = result + "?"
                i = i + 4
            else:
                result = result + esc
        else:
            result = result + ch
        i = i + 1
    Pair(first: result, second: i)

fn parse_number(input: text, pos: i64) -> Pair<f64, i64>:
    var i = pos
    val len = input.len()
    var num_str = ""
    # Optional negative sign
    if i < len:
        val ch = input[i:i + 1]
        if ch == "-":
            num_str = "-"
            i = i + 1
    # Integer part
    while i < len:
        val ch = input[i:i + 1]
        if ch >= "0" and ch <= "9":
            num_str = num_str + ch
            i = i + 1
        else:
            break
    # Decimal part
    if i < len:
        val dot = input[i:i + 1]
        if dot == ".":
            num_str = num_str + "."
            i = i + 1
            while i < len:
                val ch = input[i:i + 1]
                if ch >= "0" and ch <= "9":
                    num_str = num_str + ch
                    i = i + 1
                else:
                    break
    # Exponent part
    if i < len:
        val exp_ch = input[i:i + 1]
        if exp_ch == "e" or exp_ch == "E":
            num_str = num_str + exp_ch
            i = i + 1
            if i < len:
                val sign = input[i:i + 1]
                if sign == "+" or sign == "-":
                    num_str = num_str + sign
                    i = i + 1
            while i < len:
                val ch = input[i:i + 1]
                if ch >= "0" and ch <= "9":
                    num_str = num_str + ch
                    i = i + 1
                else:
                    break
    # Convert string to f64 — simplified
    val value = _simple_parse_f64(num_str)
    Pair(first: value, second: i)

fn parse_array(input: text, pos: i64) -> Pair<JsValue, i64>:
    # pos points to '['
    var i = pos + 1
    i = skip_whitespace(input, i)
    val len = input.len()
    if i < len:
        val ch = input[i:i + 1]
        if ch == "]":
            return Pair(first: JsValue.Array(id: -1), second: i + 1)
    # Parse elements
    var count = 0
    while i < len:
        val element = parse_value(input, i)
        count = count + 1
        i = skip_whitespace(input, element.second)
        if i >= len:
            break
        val next = input[i:i + 1]
        if next == "]":
            return Pair(first: JsValue.Array(id: -1), second: i + 1)
        if next == ",":
            i = i + 1
    Pair(first: JsValue.Array(id: -1), second: i)

fn parse_object(input: text, pos: i64) -> Pair<JsValue, i64>:
    # pos points to '{'
    var i = pos + 1
    i = skip_whitespace(input, i)
    val len = input.len()
    if i < len:
        val ch = input[i:i + 1]
        if ch == "}":
            return Pair(first: JsValue.Object(id: -1), second: i + 1)
    # Parse key-value pairs
    while i < len:
        i = skip_whitespace(input, i)
        # Parse key (must be string)
        val key = parse_string(input, i)
        i = skip_whitespace(input, key.second)
        # Skip colon
        if i < len:
            val colon = input[i:i + 1]
            if colon == ":":
                i = i + 1
        # Parse value
        val value = parse_value(input, i)
        i = skip_whitespace(input, value.second)
        if i >= len:
            break
        val next = input[i:i + 1]
        if next == "}":
            return Pair(first: JsValue.Object(id: -1), second: i + 1)
        if next == ",":
            i = i + 1
    Pair(first: JsValue.Object(id: -1), second: i)

fn skip_whitespace(input: text, pos: i64) -> i64:
    var i = pos
    val len = input.len()
    while i < len:
        val ch = input[i:i + 1]
        if ch == " " or ch == "\t" or ch == "\n" or ch == "\r":
            i = i + 1
        else:
            break
    i

# --- Stringify ---

fn stringify_value(value: JsValue, indent: i64, depth: i64) -> text:
    match value:
        JsValue.Undefined: "undefined"
        JsValue.Null: "null"
        JsValue.Boolean(v):
            if v: "true" else: "false"
        JsValue.Number(v): "{v}"
        JsValue.String(v):
            "\"" + escape_json_string(v) + "\""
        JsValue.Object(id):
            # Simplified — would need object store access for full impl
            "{}"
        JsValue.Array(id):
            "[]"
        JsValue.Function(id): "undefined"
        JsValue.Symbol(id): "undefined"

fn escape_json_string(s: text) -> text:
    var result = ""
    var i = 0
    val len = s.len()
    while i < len:
        val ch = s[i:i + 1]
        if ch == "\"":
            result = result + "\\\""
        else if ch == "\\":
            result = result + "\\\\"
        else if ch == "\n":
            result = result + "\\n"
        else if ch == "\r":
            result = result + "\\r"
        else if ch == "\t":
            result = result + "\\t"
        else:
            result = result + ch
        i = i + 1
    result

fn _make_indent(indent: i64, depth: i64) -> text:
    if indent <= 0:
        return ""
    val total = indent * depth
    var result = ""
    var i = 0
    while i < total:
        result = result + " "
        i = i + 1
    result

# --- Internal number parsing ---

fn _simple_parse_f64(s: text) -> f64:
    var result: f64 = 0.0
    var i = 0
    val len = s.len()
    var negative = false
    if len > 0:
        val first = s[0:1]
        if first == "-":
            negative = true
            i = 1
    # Integer part
    while i < len:
        val ch = s[i:i + 1]
        if ch == "." or ch == "e" or ch == "E":
            break
        val d = _char_digit(ch)
        if d < 0:
            break
        result = result * 10.0 + d.to_f64()
        i = i + 1
    # Decimal part
    if i < len:
        val dot = s[i:i + 1]
        if dot == ".":
            i = i + 1
            var frac: f64 = 0.0
            var divisor: f64 = 10.0
            while i < len:
                val ch = s[i:i + 1]
                if ch == "e" or ch == "E":
                    break
                val d = _char_digit(ch)
                if d < 0:
                    break
                frac = frac + d.to_f64() / divisor
                divisor = divisor * 10.0
                i = i + 1
            result = result + frac
    if negative:
        result = 0.0 - result
    result

fn _char_digit(ch: text) -> i64:
    if ch == "0": return 0
    if ch == "1": return 1
    if ch == "2": return 2
    if ch == "3": return 3
    if ch == "4": return 4
    if ch == "5": return 5
    if ch == "6": return 6
    if ch == "7": return 7
    if ch == "8": return 8
    if ch == "9": return 9
    -1
