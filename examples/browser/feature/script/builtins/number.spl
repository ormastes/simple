# Number and Math built-ins for the JS engine.
# Implements Number.* and Math.* methods.

val MATH_PI: f64 = 3.141592653589793
val MATH_E: f64 = 2.718281828459045
val MATH_LN2: f64 = 0.6931471805599453
val MATH_LN10: f64 = 2.302585092994046
val MATH_SQRT2: f64 = 1.4142135623730951
val NUMBER_MAX_SAFE_INTEGER: f64 = 9007199254740991.0
val NUMBER_MIN_SAFE_INTEGER: f64 = -9007199254740991.0
val NAN_MARKER: f64 = 0.0  # Placeholder — real NaN needs runtime support

# --- Number methods ---

fn number_isNaN(value: f64) -> bool:
    # NaN is the only value not equal to itself
    value != value

fn number_isFinite(value: f64) -> bool:
    val is_nan = number_isNaN(value)
    if is_nan:
        return false
    # Check for infinity by comparison with max bounds
    val abs_val = math_abs(value)
    abs_val < 1.7976931348623157e308

fn number_isInteger(value: f64) -> bool:
    if number_isNaN(value):
        return false
    if not number_isFinite(value):
        return false
    val truncated = math_trunc(value)
    value == truncated

fn number_parseInt(s: text, radix: i64) -> f64:
    if radix == 10 or radix == 0:
        # Simple decimal parsing
        var result: f64 = 0.0
        var i = 0
        val len = s.len()
        var negative = false
        if len > 0:
            val first = s[0:1]
            if first == "-":
                negative = true
                i = 1
            else if first == "+":
                i = 1
        var found_digit = false
        while i < len:
            val ch = s[i:i + 1]
            val digit = _char_to_digit(ch)
            if digit < 0 or digit >= 10:
                break
            found_digit = true
            result = result * 10.0 + digit.to_f64()
            i = i + 1
        if not found_digit:
            return NAN_MARKER
        if negative:
            return 0.0 - result
        result
    else:
        # Non-decimal radix parsing
        var result: f64 = 0.0
        var i = 0
        val len = s.len()
        var negative = false
        if len > 0:
            val first = s[0:1]
            if first == "-":
                negative = true
                i = 1
            else if first == "+":
                i = 1
        # Skip 0x prefix for hex
        if radix == 16 and i + 1 < len:
            val prefix = s[i:i + 2]
            if prefix == "0x" or prefix == "0X":
                i = i + 2
        var found_digit = false
        while i < len:
            val ch = s[i:i + 1]
            val digit = _char_to_digit_radix(ch, radix)
            if digit < 0:
                break
            found_digit = true
            result = result * radix.to_f64() + digit.to_f64()
            i = i + 1
        if not found_digit:
            return NAN_MARKER
        if negative:
            return 0.0 - result
        result

fn number_parseFloat(s: text) -> f64:
    # Simplified: delegate to parseInt for integer portion, then handle decimal
    var result: f64 = 0.0
    var i = 0
    val len = s.len()
    var negative = false
    # Skip leading whitespace
    while i < len:
        val ch = s[i:i + 1]
        if ch != " " and ch != "\t" and ch != "\n":
            break
        i = i + 1
    if i < len:
        val first = s[i:i + 1]
        if first == "-":
            negative = true
            i = i + 1
        else if first == "+":
            i = i + 1
    # Integer part
    var found_digit = false
    while i < len:
        val ch = s[i:i + 1]
        val digit = _char_to_digit(ch)
        if digit < 0:
            break
        found_digit = true
        result = result * 10.0 + digit.to_f64()
        i = i + 1
    # Fractional part
    if i < len:
        val dot = s[i:i + 1]
        if dot == ".":
            i = i + 1
            var frac: f64 = 0.0
            var frac_div: f64 = 10.0
            while i < len:
                val ch = s[i:i + 1]
                val digit = _char_to_digit(ch)
                if digit < 0:
                    break
                found_digit = true
                frac = frac + digit.to_f64() / frac_div
                frac_div = frac_div * 10.0
                i = i + 1
            result = result + frac
    if not found_digit:
        return NAN_MARKER
    if negative:
        return 0.0 - result
    result

fn number_toFixed(value: f64, digits: i64) -> text:
    # Simple fixed-point representation
    if digits <= 0:
        val rounded = math_round(value)
        return "{rounded.to_i64()}"
    val multiplier = math_pow(10.0, digits.to_f64())
    val rounded = math_round(value * multiplier)
    val int_part = (rounded / multiplier).to_i64()
    val frac_part_raw = math_abs(rounded - int_part.to_f64() * multiplier)
    var frac_str = "{frac_part_raw.to_i64()}"
    # Pad with leading zeros
    while frac_str.len() < digits:
        frac_str = "0" + frac_str
    "{int_part}.{frac_str}"

fn number_toString(value: f64, radix: i64) -> text:
    if radix == 10 or radix == 0:
        return "{value}"
    # Integer conversion to other radix
    val int_val = value.to_i64()
    var n = int_val
    var negative = false
    if n < 0:
        negative = true
        n = 0 - n
    if n == 0:
        return "0"
    var result = ""
    while n > 0:
        val remainder = n % radix
        result = _digit_to_char(remainder) + result
        n = n / radix
    if negative:
        result = "-" + result
    result

# --- Math methods ---

fn math_abs(x: f64) -> f64:
    if x < 0.0:
        return 0.0 - x
    x

fn math_floor(x: f64) -> f64:
    val i = x.to_i64()
    val f = i.to_f64()
    if f > x:
        return (i - 1).to_f64()
    f

fn math_ceil(x: f64) -> f64:
    val i = x.to_i64()
    val f = i.to_f64()
    if f < x:
        return (i + 1).to_f64()
    f

fn math_round(x: f64) -> f64:
    math_floor(x + 0.5)

fn math_max(a: f64, b: f64) -> f64:
    if a >= b: a else: b

fn math_min(a: f64, b: f64) -> f64:
    if a <= b: a else: b

fn math_pow(base: f64, exp: f64) -> f64:
    # Integer exponent fast path
    if number_isInteger(exp) and exp >= 0.0:
        var result: f64 = 1.0
        var e = exp.to_i64()
        var b = base
        while e > 0:
            if e % 2 == 1:
                result = result * b
            b = b * b
            e = e / 2
        return result
    # Negative integer exponent
    if number_isInteger(exp) and exp < 0.0:
        val pos_result = math_pow(base, 0.0 - exp)
        return 1.0 / pos_result
    # Non-integer exponents need runtime support
    pass_todo

fn math_sqrt(x: f64) -> f64:
    if x < 0.0:
        return NAN_MARKER
    if x == 0.0:
        return 0.0
    # Newton's method
    var guess = x / 2.0
    var i = 0
    while i < 50:
        val next = (guess + x / guess) / 2.0
        val diff = math_abs(next - guess)
        if diff < 0.0000000001:
            return next
        guess = next
        i = i + 1
    guess

fn math_random() -> f64:
    # Requires PRNG seed / runtime support
    pass_todo

fn math_sign(x: f64) -> f64:
    if x > 0.0:
        return 1.0
    if x < 0.0:
        return -1.0
    0.0

fn math_trunc(x: f64) -> f64:
    val i = x.to_i64()
    i.to_f64()

fn math_log(x: f64) -> f64:
    # Natural logarithm — needs runtime or series approximation
    pass_todo

fn math_clamp(x: f64, min_val: f64, max_val: f64) -> f64:
    if x < min_val:
        return min_val
    if x > max_val:
        return max_val
    x

fn math_hypot(a: f64, b: f64) -> f64:
    math_sqrt(a * a + b * b)

# --- Internal helpers ---

fn _char_to_digit(ch: text) -> i64:
    if ch == "0": return 0
    if ch == "1": return 1
    if ch == "2": return 2
    if ch == "3": return 3
    if ch == "4": return 4
    if ch == "5": return 5
    if ch == "6": return 6
    if ch == "7": return 7
    if ch == "8": return 8
    if ch == "9": return 9
    -1

fn _char_to_digit_radix(ch: text, radix: i64) -> i64:
    val d = _char_to_digit(ch)
    if d >= 0 and d < radix:
        return d
    # Hex letters
    val lower = ch.to_lower()
    if lower == "a" and radix > 10: return 10
    if lower == "b" and radix > 11: return 11
    if lower == "c" and radix > 12: return 12
    if lower == "d" and radix > 13: return 13
    if lower == "e" and radix > 14: return 14
    if lower == "f" and radix > 15: return 15
    -1

fn _digit_to_char(d: i64) -> text:
    if d == 0: return "0"
    if d == 1: return "1"
    if d == 2: return "2"
    if d == 3: return "3"
    if d == 4: return "4"
    if d == 5: return "5"
    if d == 6: return "6"
    if d == 7: return "7"
    if d == 8: return "8"
    if d == 9: return "9"
    if d == 10: return "a"
    if d == 11: return "b"
    if d == 12: return "c"
    if d == 13: return "d"
    if d == 14: return "e"
    if d == 15: return "f"
    "?"
