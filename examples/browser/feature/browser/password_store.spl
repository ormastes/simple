#![allow(REQC001)]
#![allow(REQC004)]
#![allow(unnamed_duplicate_typed_args)]
# Credential management for the Simple Browser Platform.
# Stores saved usernames and passwords per origin.
#
# Credentials stay in memory for this prototype. Stored secrets use a versioned,
# salted, iterated verifier so plaintext and legacy demo hashes are not retained.

use sbp.shared.logging.{Logger, LogLevel}

class SavedCredential:
    id: i64
    origin: text
    username: text
    salt: text
    password_hash: text
    active: bool
    created_at: i64
    last_used: i64

    static fn create(id: i64, origin: text, username: text, salt: text, password_hash: text) -> SavedCredential:
        SavedCredential.create_full(
            id: id, origin: origin, username: username, salt: salt,
            password_hash: password_hash, active: true, created_at: 0, last_used: 0
        )

    static fn create_full(id: i64, origin: text, username: text, salt: text, password_hash: text, active: bool, created_at: i64, last_used: i64) -> SavedCredential:
        SavedCredential(
            id: id, origin: origin, username: username,
            salt: salt,
            password_hash: password_hash,
            active: active,
            created_at: created_at, last_used: last_used
        )

class PasswordStore:
    credentials: [SavedCredential]
    next_id: i64
    logger: Logger

    static fn new(logger: Logger) -> PasswordStore:
        PasswordStore(
            credentials: [],
            next_id: 1,
            logger: logger
        )

    me save_credential(origin: text, username: text, password: text) -> i64:
        # Check if credential already exists for origin+username and update
        var i = self.credentials.len() - 1
        while i >= 0:
            if self.credentials[i].origin == origin and self.credentials[i].username == username:
                val existing = self.credentials[i]
                val updated_hash = hash_password_with_salt(password, existing.salt)
                self.credentials.push(SavedCredential.create_full(
                    id: existing.id, origin: origin, username: username, salt: existing.salt,
                    password_hash: updated_hash, active: true,
                    created_at: existing.created_at, last_used: existing.last_used
                ))
                self.logger.info("Credential updated for {origin} user={username}")
                return existing.id
            i = i - 1
        val id = self.next_id
        self.next_id = self.next_id + 1
        val salt = credential_salt(origin, username, id)
        val pw_hash = hash_password_with_salt(password, salt)
        val cred = SavedCredential.create(id: id, origin: origin, username: username, salt: salt, password_hash: pw_hash)
        self.credentials.push(cred)
        self.logger.info("Credential saved id={id} for {origin} user={username}")
        id

    fn get_credentials(origin: text) -> [SavedCredential]:
        var results = []
        for i in 0..self.credentials.len():
            val c = self.credentials[i]
            if c.origin == origin and c.active and self.is_latest_entry(i):
                results.push(c)
        results

    me remove_credential(id: i64):
        var i = self.credentials.len() - 1
        while i >= 0:
            if self.credentials[i].id == id:
                val existing = self.credentials[i]
                self.credentials.push(SavedCredential.create_full(
                    id: existing.id, origin: existing.origin, username: existing.username,
                    salt: existing.salt, password_hash: existing.password_hash,
                    active: false, created_at: existing.created_at, last_used: existing.last_used
                ))
                self.logger.info("Credential removed id={id}")
                return
            i = i - 1

    me update_last_used(id: i64):
        var i = self.credentials.len() - 1
        while i >= 0:
            if self.credentials[i].id == id:
                val existing = self.credentials[i]
                self.credentials.push(SavedCredential.create_full(
                    id: existing.id, origin: existing.origin, username: existing.username,
                    salt: existing.salt, password_hash: existing.password_hash,
                    active: existing.active, created_at: existing.created_at,
                    last_used: existing.last_used + 1
                ))
                self.logger.debug("Credential id={id} last_used updated")
                return
            i = i - 1

    fn has_credentials(origin: text) -> bool:
        for i in 0..self.credentials.len():
            val c = self.credentials[i]
            if c.origin == origin and c.active and self.is_latest_entry(i):
                return true
        false

    fn verify_credential(origin: text, username: text, password: text) -> bool:
        var i = self.credentials.len() - 1
        while i >= 0:
            val c = self.credentials[i]
            if c.origin == origin and c.username == username:
                if not c.active:
                    return false
                return constant_time_equal(
                    hash_password_with_salt(password, c.salt),
                    c.password_hash
                )
            i = i - 1
        false

    me clear_all():
        self.credentials = []
        self.next_id = 1
        self.logger.info("All credentials cleared")

    fn get_credential_count() -> i64:
        var total = 0
        for i in 0..self.credentials.len():
            if self.credentials[i].active and self.is_latest_entry(i):
                total = total + 1
        total

    me remove_credential_by_origin(origin: text, username: text):
        # Remove a specific credential identified by origin + username
        var i = self.credentials.len() - 1
        while i >= 0:
            if self.credentials[i].origin == origin and self.credentials[i].username == username:
                val existing = self.credentials[i]
                self.credentials.push(SavedCredential.create_full(
                    id: existing.id, origin: origin, username: username,
                    salt: existing.salt, password_hash: existing.password_hash,
                    active: false, created_at: existing.created_at, last_used: existing.last_used
                ))
                self.logger.info("Credential removed for {origin} user={username}")
                return
            i = i - 1

    me update_credential(origin: text, username: text, new_password: text):
        # Update the password for an existing credential
        var i = self.credentials.len() - 1
        while i >= 0:
            if self.credentials[i].origin == origin and self.credentials[i].username == username:
                val existing = self.credentials[i]
                self.credentials.push(SavedCredential.create_full(
                    id: existing.id, origin: origin, username: username, salt: existing.salt,
                    password_hash: hash_password_with_salt(new_password, existing.salt),
                    active: true, created_at: existing.created_at, last_used: existing.last_used
                ))
                self.logger.info("Credential password updated for {origin} user={username}")
                return
            i = i - 1
        # If no existing credential, save as new
        self.save_credential(origin: origin, username: username, password: new_password)

    fn get_all_origins() -> [text]:
        # Return a deduplicated list of all origins with stored credentials
        var origins = [text]()
        for i in 0..self.credentials.len():
            val c = self.credentials[i]
            if not c.active or not self.is_latest_entry(i):
                continue
            var found = false
            for o in origins:
                if o == c.origin:
                    found = true
            if found == false:
                origins.push(c.origin)
        origins

    fn is_latest_entry(index: i64) -> bool:
        val c = self.credentials[index]
        for i in index + 1..self.credentials.len():
            val later = self.credentials[i]
            if later.origin == c.origin and later.username == c.username:
                return false
        true

fn hash_password(password: text) -> text:
    hash_password_with_salt(password, "sbp-password-store-v1")

fn hash_password_with_salt(password: text, salt: text) -> text:
    val rounds = 512
    var h: i64 = 2166136261
    val material = salt + ":" + password + ":sbp-password-store-v1"
    for round in 0..rounds:
        h = mix_hash_round(h, material, round)
    "pbkdf-lite-v1:{rounds}:{salt}:{to_hex64(h)}"

fn credential_salt(origin: text, username: text, id: i64) -> text:
    val material = origin + "|" + username + "|" + id.to_text()
    "s1-" + to_hex64(mix_hash_round(16777619, material, id))

fn mix_hash_round(seed: i64, material: text, round: i64) -> i64:
    val modulo = 2147483647
    var h = positive_mod(seed + round * 1103515245, modulo)
    for i in 0..material.len():
        val c = material.char_code_at(i)
        h = positive_mod((h + c + i + 17) * 16777619, modulo)
        h = positive_mod(h + (h / 97) + round, modulo)
    h

fn positive_mod(value: i64, modulo: i64) -> i64:
    var r = value % modulo
    if r < 0:
        r = r + modulo
    r

fn constant_time_equal(a: text, b: text) -> bool:
    if a.len() != b.len():
        return false
    var diff = 0
    for i in 0..a.len():
        if a.char_at(i) != b.char_at(i):
            diff = diff + 1
    diff == 0

fn to_hex64(value: i64) -> text:
    var n = positive_mod(value, 2147483647)
    var out = ""
    for _ in 0..16:
        val digit = n % 16
        out = hex_digit(digit) + out
        n = n / 16
    out

fn hex_digit(value: i64) -> text:
    if value == 0: return "0"
    if value == 1: return "1"
    if value == 2: return "2"
    if value == 3: return "3"
    if value == 4: return "4"
    if value == 5: return "5"
    if value == 6: return "6"
    if value == 7: return "7"
    if value == 8: return "8"
    if value == 9: return "9"
    if value == 10: return "a"
    if value == 11: return "b"
    if value == 12: return "c"
    if value == 13: return "d"
    if value == 14: return "e"
    "f"
