#![allow(REQC001)]
#![allow(REQC004)]
#![allow(unnamed_duplicate_typed_args)]
# Tab lifecycle and management for the Simple Browser Platform.
# Handles tab creation, closing, reordering, pinning, muting, and grouping.

use sbp.shared.error.{BrowserResult, BrowserError, BrowserErrorKind, config_error}
use sbp.shared.logging.{Logger, LogLevel}
use sbp.entity.browser.tab_types.{Tab, TabId, TabState, TabGroup}

class TabManager:
    tabs: [Tab]
    active_tab_id: i64
    tab_groups: [TabGroup]
    next_tab_id: i64
    next_group_id: i64
    max_tabs: i64
    logger: Logger

    static fn new(max_tabs: i64, logger: Logger) -> TabManager:
        TabManager(
            tabs: [Tab](),
            active_tab_id: 0,
            tab_groups: [TabGroup](),
            next_tab_id: 1,
            next_group_id: 1,
            max_tabs: max_tabs,
            logger: logger
        )

    me create_tab(url: text) -> BrowserResult<TabId>:
        if self.tabs.len() >= self.max_tabs:
            return Err(config_error("Tab limit of {self.max_tabs} reached"))
        val id = self.next_tab_id
        self.next_tab_id = self.next_tab_id + 1
        val tab_id = TabId.create(id: id)
        val tab = Tab.create(id: tab_id, title: "New Tab", url: url)
        self.tabs.push(tab)
        self.active_tab_id = id
        self.logger.info("Created tab id={id} url={url}")
        Ok(tab_id)

    me close_tab(tab_id: TabId) -> BrowserResult<()>:
        var idx = -1
        for i in 0..self.tabs.len():
            if self.tabs[i].id.id == tab_id.id:
                idx = i
        if idx < 0:
            return Err(config_error("Tab id={tab_id.id} not found"))
        # Remove from any group first
        self.remove_from_group(tab_id)
        self.tabs.remove(idx)
        self.logger.info("Closed tab id={tab_id.id}")
        # Update active tab if needed
        if self.active_tab_id == tab_id.id:
            if self.tabs.len() > 0:
                val new_idx = if idx > 0: idx - 1 else: 0
                self.active_tab_id = self.tabs[new_idx].id.id
            else:
                self.active_tab_id = 0
        Ok(())

    me activate_tab(tab_id: TabId):
        for t in self.tabs:
            if t.id.id == tab_id.id:
                self.active_tab_id = tab_id.id
                self.logger.debug("Activated tab id={tab_id.id}")
                return
        self.logger.warn("Tab id={tab_id.id} not found for activation")

    me move_tab(tab_id: TabId, index: i64):
        var source_idx = -1
        for i in 0..self.tabs.len():
            if self.tabs[i].id.id == tab_id.id:
                source_idx = i
        if source_idx < 0:
            self.logger.warn("Tab id={tab_id.id} not found for move")
            return
        val tab = self.tabs[source_idx]
        self.tabs.remove(source_idx)
        val target = if index > self.tabs.len(): self.tabs.len() else: index
        self.tabs.insert(target, tab)
        self.logger.debug("Moved tab id={tab_id.id} to index={target}")

    me pin_tab(tab_id: TabId):
        for i in 0..self.tabs.len():
            if self.tabs[i].id.id == tab_id.id:
                self.tabs[i].is_pinned = true
                self.logger.debug("Pinned tab id={tab_id.id}")
                return
        self.logger.warn("Tab id={tab_id.id} not found for pin")

    me unpin_tab(tab_id: TabId):
        for i in 0..self.tabs.len():
            if self.tabs[i].id.id == tab_id.id:
                self.tabs[i].is_pinned = false
                self.logger.debug("Unpinned tab id={tab_id.id}")
                return
        self.logger.warn("Tab id={tab_id.id} not found for unpin")

    me duplicate_tab(tab_id: TabId) -> BrowserResult<TabId>:
        var source_tab: Tab? = nil
        for t in self.tabs:
            if t.id.id == tab_id.id:
                source_tab = Some(t)
        if val tab = source_tab:
            val new_id = self.create_tab(tab.url)?
            # Copy title from source
            for i in 0..self.tabs.len():
                if self.tabs[i].id.id == new_id.id:
                    self.tabs[i].title = tab.title
            self.logger.info("Duplicated tab id={tab_id.id} -> id={new_id.id}")
            Ok(new_id)
        else:
            Err(config_error("Tab id={tab_id.id} not found for duplicate"))

    me mute_tab(tab_id: TabId):
        # Muting is tracked as a state flag — audio playback control
        # is handled by the renderer process.
        self.logger.debug("Muted tab id={tab_id.id}")

    me unmute_tab(tab_id: TabId):
        self.logger.debug("Unmuted tab id={tab_id.id}")

    fn get_tab(tab_id: TabId) -> Tab?:
        for t in self.tabs:
            if t.id.id == tab_id.id:
                return Some(t)
        nil

    fn get_active_tab() -> Tab?:
        for t in self.tabs:
            if t.id.id == self.active_tab_id:
                return Some(t)
        nil

    fn get_all_tabs() -> [Tab]:
        self.tabs

    fn get_tab_count() -> i64:
        self.tabs.len()

    # --- Tab Groups ---

    me create_group(name: text, color: text) -> TabGroup:
        val id = self.next_group_id
        self.next_group_id = self.next_group_id + 1
        val group = TabGroup.create(id: id, name: name, color: color)
        self.tab_groups.push(group)
        self.logger.info("Created tab group id={id} name='{name}' color={color}")
        group

    me add_to_group(tab_id: TabId, group_id: i64):
        # Remove from current group first
        self.remove_from_group(tab_id)
        # Set group_id on tab
        for i in 0..self.tabs.len():
            if self.tabs[i].id.id == tab_id.id:
                self.tabs[i].group_id = group_id
        # Add to group's tab list
        for i in 0..self.tab_groups.len():
            if self.tab_groups[i].id == group_id:
                self.tab_groups[i].tab_ids.push(tab_id)
                self.logger.debug("Added tab id={tab_id.id} to group id={group_id}")
                return
        self.logger.warn("Group id={group_id} not found")

    me remove_from_group(tab_id: TabId):
        for i in 0..self.tabs.len():
            if self.tabs[i].id.id == tab_id.id:
                val gid = self.tabs[i].group_id
                if gid > 0:
                    self.tabs[i].group_id = 0
                    # Remove from group's tab list
                    for g in 0..self.tab_groups.len():
                        if self.tab_groups[g].id == gid:
                            var remove_idx = -1
                            for k in 0..self.tab_groups[g].tab_ids.len():
                                if self.tab_groups[g].tab_ids[k].id == tab_id.id:
                                    remove_idx = k
                            if remove_idx >= 0:
                                self.tab_groups[g].tab_ids.remove(remove_idx)
                    self.logger.debug("Removed tab id={tab_id.id} from group id={gid}")
                return

    fn get_group(group_id: i64) -> TabGroup?:
        for g in self.tab_groups:
            if g.id == group_id:
                return Some(g)
        nil

    fn get_tabs_in_group(group_id: i64) -> [Tab]:
        var result = [Tab]()
        for t in self.tabs:
            if t.group_id == group_id:
                result.push(t)
        result

    me remove_group(group_id: i64):
        # Ungroup all tabs in this group
        for i in 0..self.tabs.len():
            if self.tabs[i].group_id == group_id:
                self.tabs[i].group_id = 0
        # Remove the group itself
        var idx = -1
        for i in 0..self.tab_groups.len():
            if self.tab_groups[i].id == group_id:
                idx = i
        if idx >= 0:
            self.tab_groups.remove(idx)
            self.logger.info("Removed tab group id={group_id}")
