# Web storage manager for the Simple Browser Platform.
# Implements localStorage, sessionStorage, and IndexedDB stubs per origin.

use sbp.shared.error.{BrowserResult, BrowserError, BrowserErrorKind, config_error}
use sbp.shared.logging.{Logger, LogLevel}
use sbp.entity.browser.storage_types.{StorageArea, StorageKind, IndexedDbSchema}

class StorageManager:
    local_stores: [StorageArea]
    session_stores: [StorageArea]
    databases: [IndexedDbSchema]
    logger: Logger

    static fn new(logger: Logger) -> StorageManager:
        StorageManager(
            local_stores: [StorageArea](),
            session_stores: [StorageArea](),
            databases: [IndexedDbSchema](),
            logger: logger
        )

    # --- Internal helpers ---

    me get_or_create_local(origin: text) -> i64:
        for i in 0..self.local_stores.len():
            if self.local_stores[i].origin == origin:
                return i
        val store = StorageArea.create(kind: StorageKind.Local, origin: origin)
        self.local_stores.push(store)
        self.local_stores.len() - 1

    me get_or_create_session(origin: text) -> i64:
        for i in 0..self.session_stores.len():
            if self.session_stores[i].origin == origin:
                return i
        val store = StorageArea.create(kind: StorageKind.Session, origin: origin)
        self.session_stores.push(store)
        self.session_stores.len() - 1

    # --- localStorage ---

    me local_getItem(origin: text, key: text) -> text?:
        val idx = self.get_or_create_local(origin)
        for pair in self.local_stores[idx].entries:
            if pair.first == key:
                return Some(pair.second)
        nil

    me local_setItem(origin: text, key: text, value: text):
        val idx = self.get_or_create_local(origin)
        # Update existing key or append
        for i in 0..self.local_stores[idx].entries.len():
            if self.local_stores[idx].entries[i].first == key:
                self.local_stores[idx].entries[i] = Pair(first: key, second: value)
                return
        self.local_stores[idx].entries.push(Pair(first: key, second: value))
        self.logger.debug("localStorage set: {origin} [{key}]")

    me local_removeItem(origin: text, key: text):
        val idx = self.get_or_create_local(origin)
        var remove_idx = -1
        for i in 0..self.local_stores[idx].entries.len():
            if self.local_stores[idx].entries[i].first == key:
                remove_idx = i
        if remove_idx >= 0:
            self.local_stores[idx].entries.remove(remove_idx)
            self.logger.debug("localStorage removed: {origin} [{key}]")

    me local_clear(origin: text):
        val idx = self.get_or_create_local(origin)
        self.local_stores[idx].entries = [Pair<text, text>]()
        self.logger.debug("localStorage cleared: {origin}")

    fn local_length(origin: text) -> i64:
        for store in self.local_stores:
            if store.origin == origin:
                return store.entries.len()
        0

    # --- sessionStorage ---

    me session_getItem(origin: text, key: text) -> text?:
        val idx = self.get_or_create_session(origin)
        for pair in self.session_stores[idx].entries:
            if pair.first == key:
                return Some(pair.second)
        nil

    me session_setItem(origin: text, key: text, value: text):
        val idx = self.get_or_create_session(origin)
        for i in 0..self.session_stores[idx].entries.len():
            if self.session_stores[idx].entries[i].first == key:
                self.session_stores[idx].entries[i] = Pair(first: key, second: value)
                return
        self.session_stores[idx].entries.push(Pair(first: key, second: value))
        self.logger.debug("sessionStorage set: {origin} [{key}]")

    me session_removeItem(origin: text, key: text):
        val idx = self.get_or_create_session(origin)
        var remove_idx = -1
        for i in 0..self.session_stores[idx].entries.len():
            if self.session_stores[idx].entries[i].first == key:
                remove_idx = i
        if remove_idx >= 0:
            self.session_stores[idx].entries.remove(remove_idx)
            self.logger.debug("sessionStorage removed: {origin} [{key}]")

    me session_clear(origin: text):
        val idx = self.get_or_create_session(origin)
        self.session_stores[idx].entries = [Pair<text, text>]()
        self.logger.debug("sessionStorage cleared: {origin}")

    fn session_length(origin: text) -> i64:
        for store in self.session_stores:
            if store.origin == origin:
                return store.entries.len()
        0

    fn local_key(origin: text, index: i64) -> text?:
        for store in self.local_stores:
            if store.origin == origin:
                if index >= 0 and index < store.entries.len():
                    return Some(store.entries[index].first)
                return nil
        nil

    fn session_key(origin: text, index: i64) -> text?:
        for store in self.session_stores:
            if store.origin == origin:
                if index >= 0 and index < store.entries.len():
                    return Some(store.entries[index].first)
                return nil
        nil

    # --- IndexedDB ---

    me idb_open(origin: text, name: text, version: i64) -> BrowserResult<i64>:
        # Check if database already exists for this origin+name
        for i in 0..self.databases.len():
            if self.databases[i].name == name:
                if self.databases[i].version < version:
                    # Upgrade: replace with new version
                    self.databases[i] = IndexedDbSchema.create(name: name, version: version)
                    self.logger.debug("IndexedDB upgraded: {origin}/{name} v{version}")
                return Ok(i)
        # Create new database
        val schema = IndexedDbSchema.create(name: name, version: version)
        self.databases.push(schema)
        self.logger.debug("IndexedDB opened: {origin}/{name} v{version}")
        Ok(self.databases.len() - 1)

    # --- Cross-storage operations ---

    me clear_origin_data(origin: text):
        self.local_clear(origin)
        self.session_clear(origin)
        self.logger.info("All storage cleared for origin: {origin}")

    fn get_storage_usage(origin: text) -> i64:
        # Rough byte estimate: sum of key + value lengths
        var total = 0
        for store in self.local_stores:
            if store.origin == origin:
                for pair in store.entries:
                    total = total + pair.first.len() + pair.second.len()
        for store in self.session_stores:
            if store.origin == origin:
                for pair in store.entries:
                    total = total + pair.first.len() + pair.second.len()
        total
