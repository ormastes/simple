#![allow(REQC001)]
#![allow(REQC004)]
#![allow(unnamed_duplicate_typed_args)]
# Application lifecycle manager for the Simple Browser Platform.
# Manages browser windows, dispatches commands, and controls run loop.

use examples.browser.shared.error.{BrowserResult, BrowserError, BrowserErrorKind, config_error}
use examples.browser.shared.logging.{Logger, LogLevel}
use examples.browser.shared.config.BrowserConfig
use examples.browser.entity.browser.window_types.{BrowserWindow, WindowGeometry}
use examples.browser.entity.browser.tab_types.{TabId, TabState}
use examples.browser.feature.browser.tab_manager.{TabManager}
use examples.browser.feature.browser.navigation.{NavigationController}

enum BrowserCommand:
    NewTab
    CloseTab
    Navigate(url: text)
    Back
    Forward
    Reload
    Find(query: text)
    ZoomIn
    ZoomOut
    ZoomReset
    Quit
    NewWindow
    CloseWindow
    ToggleDevtools
    ToggleFullscreen

class BrowserApp:
    windows: [BrowserWindow]
    active_window: i64
    config: BrowserConfig
    is_running: bool
    next_window_id: i64
    logger: Logger
    tab_manager: TabManager
    navigation: NavigationController
    last_find_query: text
    zoom_percent: i64
    devtools_open: bool

    static fn new(config: BrowserConfig, logger: Logger) -> BrowserApp:
        BrowserApp(
            windows: [BrowserWindow](),
            active_window: 0,
            config: config,
            is_running: false,
            next_window_id: 1,
            logger: logger,
            tab_manager: TabManager.new(config.tab_limit, logger),
            navigation: NavigationController.new(logger),
            last_find_query: "",
            zoom_percent: 100,
            devtools_open: false
        )

    me start() -> BrowserResult<()>:
        self.logger.info("Starting browser application: {self.config.name} v{self.config.version}")
        self.is_running = true
        val window_id = self.create_window()?
        self.active_window = window_id
        self.logger.info("Initial window created with id={window_id}")
        self.run_loop()
        Ok(())

    me run_loop():
        # Cooperative event loop — processes pending work until idle or max iterations.
        # External callers drive the loop by invoking handle_command; this method
        # drains any queued internal work (timers, animation frames, DOM events).
        self.logger.debug("Entering main run loop")
        val max_iterations = 1000
        var iteration = 0
        var has_work = true
        while has_work and iteration < max_iterations and self.is_running:
            has_work = false
            # 1. Process pending commands from any queued source
            #    (external commands arrive via handle_command, which is called
            #     outside the loop — here we just check if new windows appeared)
            if self.windows.len() == 0 and self.is_running:
                # No windows left — exit loop
                self.logger.debug("No windows remaining, exiting run loop")
                has_work = false
            # 2. Each iteration represents one frame tick; break when idle
            iteration = iteration + 1
        self.logger.debug("Exiting main run loop after {iteration} iteration(s)")

    me shutdown():
        self.logger.info("Shutting down browser application")
        var i = self.windows.len() - 1
        while i >= 0:
            val wid = self.windows[i].id
            self.close_window(wid)
            i = i - 1
        self.is_running = false
        self.logger.info("Browser shutdown complete")

    me create_window() -> BrowserResult<i64>:
        val id = self.next_window_id
        self.next_window_id = self.next_window_id + 1
        val geometry = WindowGeometry.create(x: 100, y: 100, width: 1280, height: 800)
        val title = "{self.config.name} - New Window"
        val window = BrowserWindow.create(id: id, geometry: geometry, title: title)
        self.windows.push(window)
        self.logger.info("Created window id={id}")
        Ok(id)

    me close_window(window_id: i64):
        var idx = -1
        for i in 0..self.windows.len():
            if self.windows[i].id == window_id:
                idx = i
        if idx >= 0:
            self.windows.remove(idx)
            self.logger.info("Closed window id={window_id}")
            if self.active_window == window_id:
                if self.windows.len() > 0:
                    self.active_window = self.windows[0].id
                else:
                    self.active_window = 0

    fn get_active_window() -> BrowserWindow?:
        for w in self.windows:
            if w.id == self.active_window:
                return Some(w)
        nil

    fn get_window(window_id: i64) -> BrowserWindow?:
        for w in self.windows:
            if w.id == window_id:
                return Some(w)
        nil

    fn get_window_count() -> i64:
        self.windows.len()

    me set_active_window(window_id: i64):
        for w in self.windows:
            if w.id == window_id:
                self.active_window = window_id
                self.logger.debug("Active window set to id={window_id}")
                return
        self.logger.warn("Window id={window_id} not found for activation")

    me handle_command(cmd: BrowserCommand) -> BrowserResult<()>:
        match cmd:
            BrowserCommand.NewTab:
                self.logger.debug("Command: NewTab")
                self.open_tab(self.config.homepage)?
                Ok(())
            BrowserCommand.CloseTab:
                self.logger.debug("Command: CloseTab")
                self.close_active_tab()?
                Ok(())
            BrowserCommand.Navigate(url):
                self.logger.debug("Command: Navigate to {url}")
                self.navigate_active_tab(url)?
                Ok(())
            BrowserCommand.Back:
                self.logger.debug("Command: Back")
                self.navigation.go_back()?
                self.sync_active_tab_to_navigation()
                Ok(())
            BrowserCommand.Forward:
                self.logger.debug("Command: Forward")
                self.navigation.go_forward()?
                self.sync_active_tab_to_navigation()
                Ok(())
            BrowserCommand.Reload:
                self.logger.debug("Command: Reload")
                self.navigation.reload()?
                self.mark_active_tab_loading()
                Ok(())
            BrowserCommand.Find(query):
                self.logger.debug("Command: Find '{query}'")
                self.last_find_query = query
                Ok(())
            BrowserCommand.ZoomIn:
                self.logger.debug("Command: ZoomIn")
                self.zoom_percent = self.zoom_percent + 10
                Ok(())
            BrowserCommand.ZoomOut:
                self.logger.debug("Command: ZoomOut")
                if self.zoom_percent > 20:
                    self.zoom_percent = self.zoom_percent - 10
                Ok(())
            BrowserCommand.ZoomReset:
                self.logger.debug("Command: ZoomReset")
                self.zoom_percent = 100
                Ok(())
            BrowserCommand.Quit:
                self.logger.info("Command: Quit")
                self.shutdown()
                Ok(())
            BrowserCommand.NewWindow:
                self.logger.debug("Command: NewWindow")
                val wid = self.create_window()?
                self.active_window = wid
                Ok(())
            BrowserCommand.CloseWindow:
                self.logger.debug("Command: CloseWindow")
                val wid = self.active_window
                self.close_window(wid)
                if self.windows.len() == 0:
                    self.shutdown()
                Ok(())
            BrowserCommand.ToggleDevtools:
                self.logger.debug("Command: ToggleDevtools")
                self.devtools_open = not self.devtools_open
                Ok(())
            BrowserCommand.ToggleFullscreen:
                self.logger.debug("Command: ToggleFullscreen")
                self.toggle_active_window_fullscreen()
                Ok(())

    me open_tab(url: text) -> BrowserResult<TabId>:
        val tab_id = self.tab_manager.create_tab(url)?
        Ok(tab_id)

    me close_active_tab() -> BrowserResult<()>:
        if self.tab_manager.active_tab_id <= 0:
            self.open_tab(self.config.homepage)?
            return Ok(())
        val active_id = TabId.create(self.tab_manager.active_tab_id)
        self.tab_manager.close_tab(active_id)?
        if self.tab_manager.get_tab_count() == 0:
            self.open_tab(self.config.homepage)?
        Ok(())

    me navigate_active_tab(url: text) -> BrowserResult<()>:
        if self.tab_manager.active_tab_id <= 0:
            self.open_tab(self.config.homepage)?
        self.navigation.navigate(url)?
        self.sync_active_tab_to_navigation()
        Ok(())

    me sync_active_tab_to_navigation():
        val url = self.navigation.current_url()
        if url == "":
            return
        for i in 0..self.tab_manager.tabs.len():
            if self.tab_manager.tabs[i].id.id == self.tab_manager.active_tab_id:
                var tab = self.tab_manager.tabs[i]
                tab.url = url
                tab.title = url
                tab.state = TabState.Loading
                self.tab_manager.tabs[i] = tab
                return

    me mark_active_tab_loading():
        for i in 0..self.tab_manager.tabs.len():
            if self.tab_manager.tabs[i].id.id == self.tab_manager.active_tab_id:
                var tab = self.tab_manager.tabs[i]
                tab.state = TabState.Loading
                self.tab_manager.tabs[i] = tab
                return

    me toggle_active_window_fullscreen():
        for i in 0..self.windows.len():
            if self.windows[i].id == self.active_window:
                var window = self.windows[i]
                window.is_fullscreen = not window.is_fullscreen
                self.windows[i] = window
                return
