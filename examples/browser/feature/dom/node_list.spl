# Live and static node collections for DOM query results.
# NodeList wraps ordered node IDs; HTMLCollection wraps element IDs with filters.
# Live collections re-query the document on refresh().

use examples.browser.entity.dom.node_types
use examples.browser.entity.dom.attribute_types
use examples.browser.feature.dom.document
use examples.browser.feature.dom.element

# --- NodeList — ordered collection of node IDs -------------------------------

class NodeList:
    node_ids: List<i64>
    is_live: bool
    query: text
    root_id: i64

    static fn create_static(ids: List<i64>) -> NodeList:
        NodeList(node_ids: ids, is_live: false, query: "", root_id: -1)

    static fn create_live(ids: List<i64>, query: text, root_id: i64) -> NodeList:
        NodeList(node_ids: ids, is_live: true, query: query, root_id: root_id)

# Return the number of nodes in the list.
fn length(list: NodeList) -> i64:
    list.node_ids.len()

# Get a node id by index. Returns nil if out of bounds.
fn item(list: NodeList, index: i64) -> i64?:
    if index >= 0 and index < list.node_ids.len():
        return list.node_ids.get(index)
    nil

# Check whether the list contains a given node id.
fn contains(list: NodeList, node_id: i64) -> bool:
    var i = 0
    while i < list.node_ids.len():
        if list.node_ids.get(i) == node_id:
            return true
        i = i + 1
    false

# Return the index of a node id, or -1 if not present.
fn indexOf(list: NodeList, node_id: i64) -> i64:
    var i = 0
    while i < list.node_ids.len():
        if list.node_ids.get(i) == node_id:
            return i
        i = i + 1
    -1

# Re-query the document for live collections.
# Static collections are returned unchanged.
fn refresh(list: NodeList, doc: Document) -> NodeList:
    if not list.is_live:
        return list
    if list.query.len() == 0:
        return list
    val new_ids = doc.querySelectorAll(list.query)
    NodeList(node_ids: new_ids, is_live: true, query: list.query, root_id: list.root_id)

# Iterate over each node id, calling the callback.
fn forEach(list: NodeList, callback: fn(i64)):
    var i = 0
    while i < list.node_ids.len():
        callback(list.node_ids.get(i))
        i = i + 1

# --- HTMLCollection — live element collection with tag/class filters ----------

class HTMLCollection:
    element_ids: List<i64>
    is_live: bool
    tag_filter: text
    class_filter: text
    root_id: i64

    static fn create_by_tag(ids: List<i64>, tag: text, root_id: i64) -> HTMLCollection:
        HTMLCollection(
            element_ids: ids,
            is_live: true,
            tag_filter: tag,
            class_filter: "",
            root_id: root_id
        )

    static fn create_by_class(ids: List<i64>, cls: text, root_id: i64) -> HTMLCollection:
        HTMLCollection(
            element_ids: ids,
            is_live: false,
            tag_filter: "",
            class_filter: cls,
            root_id: root_id
        )

    static fn create_static(ids: List<i64>) -> HTMLCollection:
        HTMLCollection(
            element_ids: ids,
            is_live: false,
            tag_filter: "",
            class_filter: "",
            root_id: -1
        )

# Return the number of elements in the collection.
fn collection_length(collection: HTMLCollection) -> i64:
    collection.element_ids.len()

# Get an element id by index.
fn collection_item(collection: HTMLCollection, index: i64) -> i64?:
    if index >= 0 and index < collection.element_ids.len():
        return collection.element_ids.get(index)
    nil

# Find an element by its "id" or "name" attribute value.
fn namedItem(collection: HTMLCollection, name: text, doc: Document) -> i64?:
    var i = 0
    while i < collection.element_ids.len():
        val eid = collection.element_ids.get(i)
        # Check "id" attribute
        val id_val = ElementOps.getAttribute(doc, eid, "id")
        if val Some(iv) = id_val:
            if iv == name:
                return eid
        # Check "name" attribute
        val name_val = ElementOps.getAttribute(doc, eid, "name")
        if val Some(nv) = name_val:
            if nv == name:
                return eid
        i = i + 1
    nil

# Re-query the document for live collections.
fn refresh_collection(collection: HTMLCollection, doc: Document) -> HTMLCollection:
    if not collection.is_live:
        return collection
    if collection.tag_filter.len() > 0:
        val new_ids = doc.getElementsByTagName(collection.tag_filter)
        return HTMLCollection(
            element_ids: new_ids,
            is_live: true,
            tag_filter: collection.tag_filter,
            class_filter: collection.class_filter,
            root_id: collection.root_id
        )
    if collection.class_filter.len() > 0:
        val new_ids = doc.getElementsByClassName(collection.class_filter)
        return HTMLCollection(
            element_ids: new_ids,
            is_live: true,
            tag_filter: collection.tag_filter,
            class_filter: collection.class_filter,
            root_id: collection.root_id
        )
    collection
