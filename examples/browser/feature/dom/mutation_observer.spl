# MutationObserver API for monitoring DOM tree changes.
# Observers register interest in childList, attribute, or characterData changes
# on target nodes (optionally including subtrees). When mutations occur,
# MutationRecords are queued and delivered via callback.
#
# Depends on:
#   entity/dom/node_types.spl   — DomNode, NodeKind
#   shared/logging.spl          — Logger, LogLevel

# --- Mutation types ---

enum MutationType:
    ChildList
    Attributes
    CharacterData

# --- Mutation record ---

class MutationRecord:
    type_val: MutationType
    target_id: i64
    added_nodes: List<i64>
    removed_nodes: List<i64>
    previous_sibling: i64
    next_sibling: i64
    attribute_name: text
    attribute_namespace: text
    old_value: text

    static fn child_list(target_id: i64, added: List<i64>, removed: List<i64>, prev_sib: i64, next_sib: i64) -> MutationRecord:
        MutationRecord(
            type_val: MutationType.ChildList,
            target_id: target_id,
            added_nodes: added,
            removed_nodes: removed,
            previous_sibling: prev_sib,
            next_sibling: next_sib,
            attribute_name: "",
            attribute_namespace: "",
            old_value: ""
        )

    static fn attribute(target_id: i64, name: text, namespace: text, old_value: text) -> MutationRecord:
        MutationRecord(
            type_val: MutationType.Attributes,
            target_id: target_id,
            added_nodes: List<i64>(),
            removed_nodes: List<i64>(),
            previous_sibling: -1,
            next_sibling: -1,
            attribute_name: name,
            attribute_namespace: namespace,
            old_value: old_value
        )

    static fn character_data(target_id: i64, old_value: text) -> MutationRecord:
        MutationRecord(
            type_val: MutationType.CharacterData,
            target_id: target_id,
            added_nodes: List<i64>(),
            removed_nodes: List<i64>(),
            previous_sibling: -1,
            next_sibling: -1,
            attribute_name: "",
            attribute_namespace: "",
            old_value: old_value
        )

# --- Observer init options ---

class MutationObserverInit:
    child_list: bool
    attributes: bool
    character_data: bool
    subtree: bool
    attribute_old_value: bool
    character_data_old_value: bool
    attribute_filter: List<text>

    static fn default_init() -> MutationObserverInit:
        MutationObserverInit(
            child_list: false,
            attributes: false,
            character_data: false,
            subtree: false,
            attribute_old_value: false,
            character_data_old_value: false,
            attribute_filter: List<text>()
        )

    static fn child_list_only() -> MutationObserverInit:
        MutationObserverInit(
            child_list: true,
            attributes: false,
            character_data: false,
            subtree: false,
            attribute_old_value: false,
            character_data_old_value: false,
            attribute_filter: List<text>()
        )

    static fn attributes_only(old_value: bool) -> MutationObserverInit:
        MutationObserverInit(
            child_list: false,
            attributes: true,
            character_data: false,
            subtree: false,
            attribute_old_value: old_value,
            character_data_old_value: false,
            attribute_filter: List<text>()
        )

    static fn all_mutations() -> MutationObserverInit:
        MutationObserverInit(
            child_list: true,
            attributes: true,
            character_data: true,
            subtree: true,
            attribute_old_value: true,
            character_data_old_value: true,
            attribute_filter: List<text>()
        )

# --- Observed target ---

class ObservedTarget:
    node_id: i64
    options: MutationObserverInit

    static fn create(node_id: i64, options: MutationObserverInit) -> ObservedTarget:
        ObservedTarget(node_id: node_id, options: options)

# --- Mutation observer ---

class MutationObserver:
    id: i64
    callback_id: i64
    targets: List<ObservedTarget>
    pending_records: List<MutationRecord>

    static fn create(id: i64, callback_id: i64) -> MutationObserver:
        MutationObserver(
            id: id,
            callback_id: callback_id,
            targets: List<ObservedTarget>(),
            pending_records: List<MutationRecord>()
        )

# --- Observer registry ---

class MutationObserverRegistry:
    observers: List<MutationObserver>
    next_observer_id: i64
    logger: Logger

    static fn new(logger: Logger) -> MutationObserverRegistry:
        MutationObserverRegistry(
            observers: List<MutationObserver>(),
            next_observer_id: 1,
            logger: logger
        )

    # Create a new observer with the given callback ID. Returns the observer ID.
    me create_observer(callback_id: i64) -> i64:
        val id = self.next_observer_id
        self.next_observer_id = self.next_observer_id + 1
        val observer = MutationObserver.create(id, callback_id)
        self.observers.push(observer)
        self.logger.info("create_observer: id={id} callback={callback_id}")
        id

    # Start observing a target node with the given options.
    # If the observer is already observing this target, the options are replaced.
    me observe(observer_id: i64, target_id: i64, options: MutationObserverInit):
        var i = 0
        while i < self.observers.len():
            var observer = self.observers.get(i)
            if observer.id == observer_id:
                # Check if already observing this target
                var found = false
                var j = 0
                while j < observer.targets.len():
                    val target = observer.targets.get(j)
                    if target.node_id == target_id:
                        # Replace options for existing target
                        observer.targets.set(j, ObservedTarget.create(target_id, options))
                        found = true
                        j = observer.targets.len()  # break
                    j = j + 1

                if !found:
                    observer.targets.push(ObservedTarget.create(target_id, options))

                self.observers.set(i, observer)
                self.logger.debug("observe: observer={observer_id} target={target_id} childList={options.child_list} attributes={options.attributes} subtree={options.subtree}")
                return
            i = i + 1
        self.logger.warn("observe: observer {observer_id} not found")

    # Stop observing all targets for this observer.
    me disconnect(observer_id: i64):
        var i = 0
        while i < self.observers.len():
            var observer = self.observers.get(i)
            if observer.id == observer_id:
                observer.targets = List<ObservedTarget>()
                self.observers.set(i, observer)
                self.logger.debug("disconnect: observer={observer_id}")
                return
            i = i + 1
        self.logger.warn("disconnect: observer {observer_id} not found")

    # Take and return all pending records for an observer, clearing the queue.
    me take_records(observer_id: i64) -> List<MutationRecord>:
        var i = 0
        while i < self.observers.len():
            var observer = self.observers.get(i)
            if observer.id == observer_id:
                val records = observer.pending_records
                observer.pending_records = List<MutationRecord>()
                self.observers.set(i, observer)
                self.logger.debug("take_records: observer={observer_id} count={records.len()}")
                return records
            i = i + 1
        self.logger.warn("take_records: observer {observer_id} not found")
        List<MutationRecord>()

    # --- Notification methods (called by DOM manipulation code) ---

    # Notify observers about child list changes.
    me notify_child_list(parent_id: i64, added: List<i64>, removed: List<i64>, prev_sibling: i64, next_sibling: i64):
        self.logger.trace("notify_child_list: parent={parent_id} added={added.len()} removed={removed.len()}")
        val record = MutationRecord.child_list(parent_id, added, removed, prev_sibling, next_sibling)

        var i = 0
        while i < self.observers.len():
            var observer = self.observers.get(i)
            if should_notify(observer, parent_id, MutationType.ChildList, "", self.doc_nodes_ref()):
                observer.pending_records.push(record)
                self.observers.set(i, observer)
                self.logger.trace("notify_child_list: queued record for observer={observer.id}")
            i = i + 1

    # Notify observers about attribute changes.
    me notify_attribute(target_id: i64, name: text, namespace: text, old_value: text):
        self.logger.trace("notify_attribute: target={target_id} attr={name}")
        val record = MutationRecord.attribute(target_id, name, namespace, old_value)

        var i = 0
        while i < self.observers.len():
            var observer = self.observers.get(i)
            if should_notify(observer, target_id, MutationType.Attributes, name, self.doc_nodes_ref()):
                # Check attribute filter
                var pass_filter = true
                var j = 0
                while j < observer.targets.len():
                    val target = observer.targets.get(j)
                    if target.options.attributes and target.options.attribute_filter.len() > 0:
                        pass_filter = false
                        var k = 0
                        while k < target.options.attribute_filter.len():
                            if target.options.attribute_filter.get(k) == name:
                                pass_filter = true
                            k = k + 1
                    j = j + 1

                if pass_filter:
                    observer.pending_records.push(record)
                    self.observers.set(i, observer)
                    self.logger.trace("notify_attribute: queued record for observer={observer.id}")
            i = i + 1

    # Notify observers about character data changes.
    me notify_character_data(target_id: i64, old_value: text):
        self.logger.trace("notify_character_data: target={target_id}")
        val record = MutationRecord.character_data(target_id, old_value)

        var i = 0
        while i < self.observers.len():
            var observer = self.observers.get(i)
            if should_notify(observer, target_id, MutationType.CharacterData, "", self.doc_nodes_ref()):
                observer.pending_records.push(record)
                self.observers.set(i, observer)
                self.logger.trace("notify_character_data: queued record for observer={observer.id}")
            i = i + 1

    # Placeholder for doc_nodes reference — in production, this would reference the document.
    # Returns an empty list; callers that need subtree checking should pass doc_nodes explicitly.
    fn doc_nodes_ref() -> List<DomNode>:
        List<DomNode>()

    # Schedule microtask for callback delivery (not yet implemented).
    me queue_microtask():
        pass_todo

    # Get the count of pending records across all observers.
    fn total_pending_records() -> i64:
        var total = 0
        var i = 0
        while i < self.observers.len():
            total = total + self.observers.get(i).pending_records.len()
            i = i + 1
        total

    # Get the number of registered observers.
    fn observer_count() -> i64:
        self.observers.len()

    # Remove an observer entirely from the registry.
    me remove_observer(observer_id: i64):
        var i = 0
        while i < self.observers.len():
            if self.observers.get(i).id == observer_id:
                self.observers.remove(i)
                self.logger.debug("remove_observer: id={observer_id}")
                return
            i = i + 1
        self.logger.warn("remove_observer: observer {observer_id} not found")

# --- Internal helpers ---

# Check if an observer is interested in a mutation at the given target.
fn should_notify(observer: MutationObserver, target_id: i64, type_val: MutationType, attr_name: text, doc_nodes: List<DomNode>) -> bool:
    var i = 0
    while i < observer.targets.len():
        val observed = observer.targets.get(i)
        val options = observed.options

        # Check if the mutation type matches the observer's interest
        val type_match = match type_val:
            MutationType.ChildList: options.child_list
            MutationType.Attributes: options.attributes
            MutationType.CharacterData: options.character_data

        if type_match:
            # Direct target match
            if observed.node_id == target_id:
                # For attributes, check the filter
                if type_val == MutationType.Attributes and options.attribute_filter.len() > 0:
                    var k = 0
                    while k < options.attribute_filter.len():
                        if options.attribute_filter.get(k) == attr_name:
                            return true
                        k = k + 1
                else:
                    return true

            # Subtree match: target_id is a descendant of observed.node_id
            if options.subtree:
                if is_subtree_of(observed.node_id, target_id, doc_nodes):
                    if type_val == MutationType.Attributes and options.attribute_filter.len() > 0:
                        var k = 0
                        while k < options.attribute_filter.len():
                            if options.attribute_filter.get(k) == attr_name:
                                return true
                            k = k + 1
                    else:
                        return true

        i = i + 1

    false

# Check if node_id is a descendant of ancestor_id by walking the parent chain.
fn is_subtree_of(ancestor_id: i64, node_id: i64, doc_nodes: List<DomNode>) -> bool:
    if ancestor_id == node_id:
        return true

    var current = node_id
    var searching = true
    while searching:
        searching = false
        var i = 0
        while i < doc_nodes.len():
            val node = doc_nodes.get(i)
            if node.id == current:
                if node.parent_id == ancestor_id:
                    return true
                if node.parent_id >= 0 and node.parent_id != current:
                    current = node.parent_id
                    searching = true
                i = doc_nodes.len()  # break
            i = i + 1

    false

# Format mutation type as text (for logging).
fn mutation_type_name(type_val: MutationType) -> text:
    match type_val:
        MutationType.ChildList: "childList"
        MutationType.Attributes: "attributes"
        MutationType.CharacterData: "characterData"
