#![allow(REQC001)]
#![allow(REQC004)]
#![allow(unnamed_duplicate_typed_args)]
# CSS selector matching against DOM nodes.
# Implements matching for type, class, ID, attribute, and pseudo-class selectors,
# plus combinators (descendant, child, adjacent sibling, general sibling).
# Provides querySelector and querySelectorAll tree-search methods.
# Supports functional pseudo-classes: :nth-child(), :nth-last-child(),
# :nth-of-type(), :nth-last-of-type(), :not().
# Supports interaction pseudo-classes: :hover, :focus, :active.
#
# Depends on:
#   entity/dom/node_types.spl   — DomNode, NodeKind, Element
#   entity/dom/css_types.spl    — Selector, SelectorPart, FunctionalPseudo
#   shared/logging.spl          — Logger, LogLevel
#   feature/dom/generated_content.spl — InteractionState

# --- An+B formula for :nth-child and related selectors ---

class AnBFormula:
    a: i64
    b: i64

    static fn create(a: i64, b: i64) -> AnBFormula:
        AnBFormula(a: a, b: b)

    # Check if a 1-based position matches this An+B formula.
    fn matches_position(pos: i64) -> bool:
        if self.a == 0:
            # 0n+B means only position B matches
            return pos == self.b
        # An+B: pos = a*n + b for some non-negative integer n
        # => n = (pos - b) / a, and n must be >= 0 and integer
        val diff = pos - self.b
        # Check divisibility
        if diff % self.a != 0:
            return false
        val n = diff / self.a
        n >= 0

# Parse An+B syntax from a text argument.
# Handles: "odd", "even", "3", "2n+1", "-n+3", "n", "3n", "-2n-1", etc.
fn parse_an_b(expr: text) -> AnBFormula:
    val s = expr.trim().to_lower()

    # Keyword shortcuts
    if s == "odd":
        return AnBFormula.create(2, 1)
    if s == "even":
        return AnBFormula.create(2, 0)

    # Find position of 'n'
    val n_pos = s.find("n")

    if n_pos < 0:
        # No 'n': plain integer B (e.g., "3")
        val b = parse_int_safe(s)
        return AnBFormula.create(0, b)

    # Parse A (coefficient of n)
    var a = 1
    if n_pos == 0:
        # "n..." means a=1
        a = 1
    else:
        val a_part = s.substring(0, n_pos).trim()
        if a_part == "-":
            a = -1
        else if a_part == "+" or a_part == "":
            a = 1
        else:
            a = parse_int_safe(a_part)

    # Parse B (offset after n)
    var b = 0
    if n_pos + 1 < s.len():
        val rest = s.substring(n_pos + 1, s.len()).trim()
        if rest.len() > 0:
            # rest is like "+1", "-3", "+0"
            b = parse_int_safe(rest)

    AnBFormula.create(a, b)

# Parse an integer from text, handling optional leading + sign.
fn parse_int_safe(s: text) -> i64:
    val trimmed = s.trim()
    if trimmed.len() == 0:
        return 0
    # Strip leading +
    if trimmed.starts_with("+"):
        val rest = trimmed.substring(1, trimmed.len())
        return parse_int_safe(rest)
    # Handle negative
    if trimmed.starts_with("-"):
        val rest = trimmed.substring(1, trimmed.len())
        val abs_val = parse_int_safe(rest)
        return 0 - abs_val
    # Parse digits
    var result = 0
    var i = 0
    while i < trimmed.len():
        val ch = trimmed.substring(i, i + 1)
        if ch >= "0" and ch <= "9":
            val digit = char_to_digit(ch)
            result = result * 10 + digit
        else:
            # Non-digit encountered; stop
            return result
        i = i + 1
    result

# Convert a single digit character to its integer value.
fn char_to_digit(ch: text) -> i64:
    if ch == "0": return 0
    if ch == "1": return 1
    if ch == "2": return 2
    if ch == "3": return 3
    if ch == "4": return 4
    if ch == "5": return 5
    if ch == "6": return 6
    if ch == "7": return 7
    if ch == "8": return 8
    if ch == "9": return 9
    0

# --- Selector matcher ---

class SelectorMatcher:
    logger: Logger
    interaction: InteractionState

    static fn new(logger: Logger) -> SelectorMatcher:
        SelectorMatcher(logger: logger, interaction: InteractionState.none())

    static fn with_interaction(logger: Logger, interaction: InteractionState) -> SelectorMatcher:
        SelectorMatcher(logger: logger, interaction: interaction)

    # Does this selector match the given node?
    fn matches(selector: Selector, node_id: i64, doc_nodes: [DomNode], doc_elements: [Element]) -> bool:
        val parts = selector.parts

        # If there are no parts, nothing matches
        if parts.len() == 0:
            return false

        # Split parts and combinators for compound selector matching
        var selector_parts = [SelectorPart]()
        var combinators = [text]()

        var i = 0
        while i < parts.len():
            val part = parts.get(i)
            match part:
                SelectorPart.Combinator(kind):
                    combinators.push(kind)
                _:
                    selector_parts.push(part)
            i = i + 1

        # If there are combinators, use combinator matching
        if combinators.len() > 0:
            return self.matches_with_combinator(selector_parts, combinators, node_id, doc_nodes, doc_elements)

        # Simple selector: all parts must match the same node
        var j = 0
        while j < selector_parts.len():
            if !self.matches_part(selector_parts.get(j), node_id, doc_nodes, doc_elements):
                return false
            j = j + 1
        true

    # Match a single selector part against a node.
    fn matches_part(part: SelectorPart, node_id: i64, doc_nodes: [DomNode], doc_elements: [Element]) -> bool:
        match part:
            SelectorPart.Type(name):
                self.matches_type(name, node_id, doc_elements)
            SelectorPart.Class(name):
                self.matches_class(name, node_id, doc_elements)
            SelectorPart.Id(name):
                self.matches_id(name, node_id, doc_elements)
            SelectorPart.Universal:
                # Universal selector matches any element node
                val elem = get_element_for_node(node_id, doc_elements)
                match elem:
                    Some(_): true
                    nil: false
            SelectorPart.Attribute(name, op, value):
                self.matches_attribute(name, op, value, node_id, doc_elements)
            SelectorPart.PseudoClass(name):
                self.matches_pseudo_class(name, node_id, doc_nodes, doc_elements)
            SelectorPart.PseudoElement(_):
                # Pseudo-elements are handled at style application, not matching
                false
            SelectorPart.FunctionalPseudo(name, arg_text):
                self.matches_functional_pseudo(name, arg_text, node_id, doc_nodes, doc_elements)
            SelectorPart.Combinator(_):
                # Combinators are handled separately
                false

    # Find the first node in subtree matching the selector (depth-first).
    fn querySelector(selector: Selector, root_id: i64, doc_nodes: [DomNode], doc_elements: [Element]) -> i64?:
        val nodes_in_order = walk_subtree(root_id, doc_nodes)
        var i = 0
        while i < nodes_in_order.len():
            val nid = nodes_in_order.get(i)
            if self.matches(selector, nid, doc_nodes, doc_elements):
                self.logger.debug("querySelector: matched node={nid}")
                return nid
            i = i + 1
        self.logger.debug("querySelector: no match found under root={root_id}")
        nil

    # Find all nodes in subtree matching the selector (depth-first order).
    fn querySelectorAll(selector: Selector, root_id: i64, doc_nodes: [DomNode], doc_elements: [Element]) -> [i64]:
        var result = [i64]()
        val nodes_in_order = walk_subtree(root_id, doc_nodes)
        var i = 0
        while i < nodes_in_order.len():
            val nid = nodes_in_order.get(i)
            if self.matches(selector, nid, doc_nodes, doc_elements):
                result.push(nid)
            i = i + 1
        self.logger.debug("querySelectorAll: found {result.len()} matches under root={root_id}")
        result

    # --- Part matchers ---

    # Match element tag name (case-insensitive for HTML).
    fn matches_type(name: text, node_id: i64, elements: [Element]) -> bool:
        val elem = get_element_for_node(node_id, elements)
        match elem:
            Some(e):
                e.tag_name == name or e.tag_name == name.to_lower() or e.tag_name == name.to_upper()
            nil:
                false

    # Match class: element's "class" attribute contains the given class name.
    fn matches_class(name: text, node_id: i64, elements: [Element]) -> bool:
        val elem = get_element_for_node(node_id, elements)
        match elem:
            Some(e):
                val class_attr = get_attribute_value(e, "class")
                match class_attr:
                    Some(class_str):
                        # Split class string by spaces and check for exact match
                        val classes = class_str.split(" ")
                        var i = 0
                        while i < classes.len():
                            if classes.get(i) == name:
                                return true
                            i = i + 1
                        false
                    nil:
                        false
            nil:
                false

    # Match ID: element's "id" attribute equals the given name.
    fn matches_id(name: text, node_id: i64, elements: [Element]) -> bool:
        val elem = get_element_for_node(node_id, elements)
        match elem:
            Some(e):
                val id_attr = get_attribute_value(e, "id")
                match id_attr:
                    Some(id_val): id_val == name
                    nil: false
            nil:
                false

    # Match attribute selector with operator.
    # Operators: = (exact), ~= (space-separated word), |= (hyphen-separated prefix),
    #            ^= (starts with), $= (ends with), *= (contains)
    fn matches_attribute(name: text, op: text, value: text, node_id: i64, elements: [Element]) -> bool:
        val elem = get_element_for_node(node_id, elements)
        match elem:
            Some(e):
                val attr_val = get_attribute_value(e, name)
                match attr_val:
                    Some(av):
                        if op == "":
                            # [attr] — attribute exists
                            true
                        else if op == "=":
                            # [attr=value] — exact match
                            av == value
                        else if op == "~=":
                            # [attr~=value] — space-separated word
                            val words = av.split(" ")
                            var i = 0
                            var found = false
                            while i < words.len():
                                if words.get(i) == value:
                                    found = true
                                i = i + 1
                            found
                        else if op == "|=":
                            # [attr|=value] — exact or starts with value-
                            av == value or av.starts_with("{value}-")
                        else if op == "^=":
                            # [attr^=value] — starts with
                            av.starts_with(value)
                        else if op == "$=":
                            # [attr$=value] — ends with
                            av.ends_with(value)
                        else if op == "*=":
                            # [attr*=value] — contains substring
                            av.contains(value)
                        else:
                            false
                    nil:
                        # Attribute not present
                        if op == "":
                            # [attr] — existence check, attribute not found
                            false
                        else:
                            false
            nil:
                false

    # Match pseudo-class selectors.
    fn matches_pseudo_class(name: text, node_id: i64, doc_nodes: [DomNode], elements: [Element]) -> bool:
        if name == "root":
            # :root matches the document element (parent is document or -1)
            var i = 0
            while i < doc_nodes.len():
                val node = doc_nodes.get(i)
                if node.id == node_id:
                    return node.parent_id < 0 or node.parent_id == node_id
                i = i + 1
            return false

        if name == "first-child":
            val siblings = get_siblings(node_id, doc_nodes)
            if siblings.len() > 0:
                return siblings.get(0) == node_id
            return false

        if name == "last-child":
            val siblings = get_siblings(node_id, doc_nodes)
            if siblings.len() > 0:
                return siblings.get(siblings.len() - 1) == node_id
            return false

        if name == "only-child":
            val siblings = get_siblings(node_id, doc_nodes)
            return siblings.len() == 1 and siblings.get(0) == node_id

        if name == "empty":
            # :empty matches elements with no children
            var i = 0
            while i < doc_nodes.len():
                val node = doc_nodes.get(i)
                if node.id == node_id:
                    return node.children.len() == 0
                i = i + 1
            return false

        if name == "first-of-type":
            val elem = get_element_for_node(node_id, elements)
            match elem:
                Some(e):
                    val siblings = get_siblings(node_id, doc_nodes)
                    var j = 0
                    while j < siblings.len():
                        val sib_id = siblings.get(j)
                        val sib_elem = get_element_for_node(sib_id, elements)
                        match sib_elem:
                            Some(se):
                                if se.tag_name == e.tag_name:
                                    return sib_id == node_id
                            nil: pass_dn
                        j = j + 1
                    false
                nil: false

        if name == "last-of-type":
            val elem = get_element_for_node(node_id, elements)
            match elem:
                Some(e):
                    val siblings = get_siblings(node_id, doc_nodes)
                    var last_match = -1
                    var j = 0
                    while j < siblings.len():
                        val sib_id = siblings.get(j)
                        val sib_elem = get_element_for_node(sib_id, elements)
                        match sib_elem:
                            Some(se):
                                if se.tag_name == e.tag_name:
                                    last_match = sib_id
                            nil: pass_dn
                        j = j + 1
                    last_match == node_id
                nil: false

        if name == "only-of-type":
            val elem = get_element_for_node(node_id, elements)
            match elem:
                Some(e):
                    val siblings = get_siblings(node_id, doc_nodes)
                    var count = 0
                    var j = 0
                    while j < siblings.len():
                        val sib_id = siblings.get(j)
                        val sib_elem = get_element_for_node(sib_id, elements)
                        match sib_elem:
                            Some(se):
                                if se.tag_name == e.tag_name:
                                    count = count + 1
                            nil: pass_dn
                        j = j + 1
                    count == 1
                nil: false

        # Interaction pseudo-classes: check against InteractionState
        if name == "hover":
            return self.interaction.is_hovered(node_id)

        if name == "focus":
            return self.interaction.is_focused(node_id)

        if name == "active":
            return self.interaction.is_active(node_id)

        if name == "visited":
            # :visited is intentionally restricted for privacy
            return false

        if name == "link":
            # :link matches unvisited <a> with href
            val elem = get_element_for_node(node_id, elements)
            match elem:
                Some(e):
                    if e.tag_name == "a" or e.tag_name == "area":
                        val href = get_attribute_value(e, "href")
                        match href:
                            Some(_): return true
                            nil: return false
                    return false
                nil: return false

        if name == "enabled":
            val elem = get_element_for_node(node_id, elements)
            match elem:
                Some(e):
                    val disabled = get_attribute_value(e, "disabled")
                    match disabled:
                        Some(_): return false
                        nil: return true
                nil: return false

        if name == "disabled":
            val elem = get_element_for_node(node_id, elements)
            match elem:
                Some(e):
                    val disabled = get_attribute_value(e, "disabled")
                    match disabled:
                        Some(_): return true
                        nil: return false
                nil: return false

        if name == "checked":
            val elem = get_element_for_node(node_id, elements)
            match elem:
                Some(e):
                    val checked = get_attribute_value(e, "checked")
                    match checked:
                        Some(_): return true
                        nil: return false
                nil: return false

        # Unsupported pseudo-class
        self.logger.warn("matches_pseudo_class: unsupported pseudo-class :{name}")
        false

    # --- Functional pseudo-class matching ---

    # Match functional pseudo-classes: :nth-child(), :nth-last-child(),
    # :nth-of-type(), :nth-last-of-type(), :not()
    fn matches_functional_pseudo(name: text, arg_text: text, node_id: i64, doc_nodes: [DomNode], elements: [Element]) -> bool:
        if name == "nth-child":
            val formula = parse_an_b(arg_text)
            val siblings = get_element_siblings(node_id, doc_nodes, elements)
            val pos = get_position_in_list(node_id, siblings)
            if pos < 0:
                return false
            return formula.matches_position(pos + 1)  # 1-based

        if name == "nth-last-child":
            val formula = parse_an_b(arg_text)
            val siblings = get_element_siblings(node_id, doc_nodes, elements)
            val pos = get_position_in_list(node_id, siblings)
            if pos < 0:
                return false
            val reverse_pos = siblings.len() - pos  # 1-based from end
            return formula.matches_position(reverse_pos)

        if name == "nth-of-type":
            val formula = parse_an_b(arg_text)
            val elem = get_element_for_node(node_id, elements)
            match elem:
                Some(e):
                    val typed_siblings = get_typed_siblings(node_id, e.tag_name, doc_nodes, elements)
                    val pos = get_position_in_list(node_id, typed_siblings)
                    if pos < 0:
                        return false
                    return formula.matches_position(pos + 1)
                nil: return false

        if name == "nth-last-of-type":
            val formula = parse_an_b(arg_text)
            val elem = get_element_for_node(node_id, elements)
            match elem:
                Some(e):
                    val typed_siblings = get_typed_siblings(node_id, e.tag_name, doc_nodes, elements)
                    val pos = get_position_in_list(node_id, typed_siblings)
                    if pos < 0:
                        return false
                    val reverse_pos = typed_siblings.len() - pos
                    return formula.matches_position(reverse_pos)
                nil: return false

        if name == "not":
            # :not(simple-selector) — negate a single selector part
            val negated_part = parse_simple_selector(arg_text)
            match negated_part:
                Some(part):
                    # :not() matches if the inner selector does NOT match
                    return !self.matches_part(part, node_id, doc_nodes, elements)
                nil:
                    self.logger.warn("matches_functional_pseudo: could not parse :not({arg_text})")
                    return false

        if name == "is" or name == "where":
            # :is() / :where() — matches if any argument selector matches
            val parts = parse_selector_list_simple(arg_text)
            var i = 0
            while i < parts.len():
                if self.matches_part(parts.get(i), node_id, doc_nodes, elements):
                    return true
                i = i + 1
            return false

        if name == "has":
            # :has(selector) — matches if the element has a descendant matching selector
            val part = parse_simple_selector(arg_text)
            match part:
                Some(p):
                    val descendants = walk_subtree(node_id, doc_nodes)
                    var i = 0
                    while i < descendants.len():
                        if self.matches_part(p, descendants.get(i), doc_nodes, elements):
                            return true
                        i = i + 1
                    return false
                nil: return false

        self.logger.warn("matches_functional_pseudo: unsupported :{name}({arg_text})")
        false

    # --- Combinator matching ---

    # Match a compound selector with combinators.
    # selector_parts: the non-combinator parts, grouped per compound segment.
    # combinators: the combinators between segments.
    # We process from right to left: the rightmost segment matches the candidate node,
    # then each combinator constrains the relationship to the next segment left.
    fn matches_with_combinator(selector_parts: [SelectorPart], combinators: [text], node_id: i64, doc_nodes: [DomNode], elements: [Element]) -> bool:
        # Group parts into segments separated by combinators.
        # For a selector like "div > .foo .bar", parts = [Type("div"), Class("foo"), Class("bar")]
        # and combinators = [">", " "].
        # Segments (right-to-left): [Class("bar")], [Class("foo")], [Type("div")]
        # Combinators (right-to-left): " ", ">"

        # Simple approach: assume 1 part per segment (most common case).
        # The rightmost part must match the candidate node.
        if selector_parts.len() == 0:
            return false

        val rightmost = selector_parts.get(selector_parts.len() - 1)
        if !self.matches_part(rightmost, node_id, doc_nodes, elements):
            return false

        # Walk left through combinators
        var current_node = node_id
        var seg_idx = selector_parts.len() - 2  # next segment to the left
        var comb_idx = combinators.len() - 1     # corresponding combinator

        while seg_idx >= 0 and comb_idx >= 0:
            val part = selector_parts.get(seg_idx)
            val combinator = combinators.get(comb_idx)

            if combinator == " ":
                # Descendant combinator: any ancestor must match
                val matched = self.match_descendant(part, current_node, doc_nodes, elements)
                match matched:
                    Some(ancestor_id):
                        current_node = ancestor_id
                    nil:
                        return false
            else if combinator == ">":
                # Child combinator: direct parent must match
                val matched = self.match_child(part, current_node, doc_nodes, elements)
                match matched:
                    Some(parent_id):
                        current_node = parent_id
                    nil:
                        return false
            else if combinator == "+":
                # Adjacent sibling: immediately preceding sibling must match
                val matched = self.match_adjacent(part, current_node, doc_nodes, elements)
                match matched:
                    Some(sib_id):
                        current_node = sib_id
                    nil:
                        return false
            else if combinator == "~":
                # General sibling: any preceding sibling must match
                val matched = self.match_general_sibling(part, current_node, doc_nodes, elements)
                match matched:
                    Some(sib_id):
                        current_node = sib_id
                    nil:
                        return false
            else:
                self.logger.warn("matches_with_combinator: unknown combinator '{combinator}'")
                return false

            seg_idx = seg_idx - 1
            comb_idx = comb_idx - 1

        true

    # Descendant combinator: find any ancestor of node_id that matches part.
    fn match_descendant(part: SelectorPart, node_id: i64, doc_nodes: [DomNode], elements: [Element]) -> i64?:
        var parent = get_parent(node_id, doc_nodes)
        while true:
            match parent:
                Some(pid):
                    if self.matches_part(part, pid, doc_nodes, elements):
                        return pid
                    parent = get_parent(pid, doc_nodes)
                nil:
                    return nil
        nil

    # Child combinator: direct parent must match.
    fn match_child(part: SelectorPart, node_id: i64, doc_nodes: [DomNode], elements: [Element]) -> i64?:
        val parent = get_parent(node_id, doc_nodes)
        match parent:
            Some(pid):
                if self.matches_part(part, pid, doc_nodes, elements):
                    return pid
                nil
            nil:
                nil

    # Adjacent sibling: the immediately preceding sibling must match.
    fn match_adjacent(part: SelectorPart, node_id: i64, doc_nodes: [DomNode], elements: [Element]) -> i64?:
        val siblings = get_siblings(node_id, doc_nodes)
        val idx = get_child_index_in_list(node_id, siblings)
        if idx > 0:
            val prev_id = siblings.get(idx - 1)
            if self.matches_part(part, prev_id, doc_nodes, elements):
                return prev_id
        nil

    # General sibling: any preceding sibling must match.
    fn match_general_sibling(part: SelectorPart, node_id: i64, doc_nodes: [DomNode], elements: [Element]) -> i64?:
        val siblings = get_siblings(node_id, doc_nodes)
        val idx = get_child_index_in_list(node_id, siblings)
        var i = idx - 1
        while i >= 0:
            val sib_id = siblings.get(i)
            if self.matches_part(part, sib_id, doc_nodes, elements):
                return sib_id
            i = i - 1
        nil

# --- Traversal helpers ---

# Depth-first traversal of a subtree rooted at root_id.
# Returns node IDs in document order (excluding root itself).
fn walk_subtree(root_id: i64, doc_nodes: [DomNode]) -> [i64]:
    var result = [i64]()
    var stack = [i64]()
    stack.push(root_id)

    while stack.len() > 0:
        val current = stack.pop()
        # Skip root itself — querySelectorAll doesn't match root
        if current != root_id:
            result.push(current)

        # Find this node and push children in reverse order for correct traversal
        var i = 0
        while i < doc_nodes.len():
            val node = doc_nodes.get(i)
            if node.id == current:
                var ci = node.children.len() - 1
                while ci >= 0:
                    stack.push(node.children.get(ci))
                    ci = ci - 1
                i = doc_nodes.len()  # break
            i = i + 1

    result

# Get the parent node ID of a given node.
fn get_parent(node_id: i64, doc_nodes: [DomNode]) -> i64?:
    var i = 0
    while i < doc_nodes.len():
        val node = doc_nodes.get(i)
        if node.id == node_id:
            if node.parent_id >= 0 and node.parent_id != node_id:
                return node.parent_id
            return nil
        i = i + 1
    nil

# Get the sibling node IDs (children of the same parent).
fn get_siblings(node_id: i64, doc_nodes: [DomNode]) -> [i64]:
    val parent = get_parent(node_id, doc_nodes)
    match parent:
        Some(pid):
            var i = 0
            while i < doc_nodes.len():
                val node = doc_nodes.get(i)
                if node.id == pid:
                    return node.children
                i = i + 1
            [i64]()
        nil:
            [i64]()

# Get the index of a child within its parent's children list.
fn get_child_index(node_id: i64, doc_nodes: [DomNode]) -> i64:
    val siblings = get_siblings(node_id, doc_nodes)
    get_child_index_in_list(node_id, siblings)

# Get the index of a node ID within a list.
fn get_child_index_in_list(node_id: i64, siblings: [i64]) -> i64:
    var i = 0
    while i < siblings.len():
        if siblings.get(i) == node_id:
            return i
        i = i + 1
    -1

# Get the Element record for a given node ID.
fn get_element_for_node(node_id: i64, elements: [Element]) -> Element?:
    var i = 0
    while i < elements.len():
        val elem = elements.get(i)
        if elem.node_id == node_id:
            return elem
        i = i + 1
    nil

# Get an attribute value from an element by name.
fn get_attribute_value(elem: Element, name: text) -> text?:
    var i = 0
    while i < elem.attributes.len():
        val attr = elem.attributes.get(i)
        if attr.name == name:
            return attr.value
        i = i + 1
    nil

# --- Functional pseudo-class helpers ---

# Get element siblings (only element nodes) from the parent's children.
fn get_element_siblings(node_id: i64, doc_nodes: [DomNode], elements: [Element]) -> [i64]:
    val all_siblings = get_siblings(node_id, doc_nodes)
    var result = [i64]()
    var i = 0
    while i < all_siblings.len():
        val sid = all_siblings.get(i)
        val elem = get_element_for_node(sid, elements)
        match elem:
            Some(_): result.push(sid)
            nil: pass_dn
        i = i + 1
    result

# Get siblings of the same tag type (element nodes only).
fn get_typed_siblings(node_id: i64, tag_name: text, doc_nodes: [DomNode], elements: [Element]) -> [i64]:
    val all_siblings = get_siblings(node_id, doc_nodes)
    var result = [i64]()
    var i = 0
    while i < all_siblings.len():
        val sid = all_siblings.get(i)
        val elem = get_element_for_node(sid, elements)
        match elem:
            Some(e):
                if e.tag_name == tag_name:
                    result.push(sid)
            nil: pass_dn
        i = i + 1
    result

# Get the 0-based position of a node ID in a list. Returns -1 if not found.
fn get_position_in_list(node_id: i64, ids: [i64]) -> i64:
    var i = 0
    while i < ids.len():
        if ids.get(i) == node_id:
            return i
        i = i + 1
    -1

# Parse a simple selector argument (tag name, .class, #id, [attr], :pseudo).
# Used by :not() and :has() to parse their argument.
fn parse_simple_selector(arg: text) -> SelectorPart?:
    val s = arg.trim()
    if s.len() == 0:
        return nil

    val first = s.substring(0, 1)

    # .class
    if first == ".":
        val class_name = s.substring(1, s.len())
        return SelectorPart.Class(name: class_name)

    # #id
    if first == "#":
        val id_name = s.substring(1, s.len())
        return SelectorPart.Id(name: id_name)

    # :pseudo-class
    if first == ":":
        val pseudo_name = s.substring(1, s.len())
        return SelectorPart.PseudoClass(name: pseudo_name)

    # [attr] or [attr=value]
    if first == "[" and s.ends_with("]"):
        val inner = s.substring(1, s.len() - 1)
        return parse_attribute_selector(inner)

    # * universal
    if s == "*":
        return SelectorPart.Universal

    # Tag name
    SelectorPart.Type(name: s)

# Parse an attribute selector inner text (without brackets).
fn parse_attribute_selector(inner: text) -> SelectorPart:
    # Check for operators: *=, ^=, $=, ~=, |=, =
    var op_pos = -1
    var op = ""
    var i = 0
    while i < inner.len():
        val ch = inner.substring(i, i + 1)
        if ch == "=" and op_pos < 0:
            # Check for 2-char operator
            if i > 0:
                val prev = inner.substring(i - 1, i)
                if prev == "~" or prev == "|" or prev == "^" or prev == "$" or prev == "*":
                    op = inner.substring(i - 1, i + 1)
                    op_pos = i - 1
                else:
                    op = "="
                    op_pos = i
            else:
                op = "="
                op_pos = i
        i = i + 1

    if op_pos < 0:
        # No operator: existence check [attr]
        return SelectorPart.Attribute(name: inner.trim(), op: "", value: "")

    var attr_name = ""
    if op.len() == 2:
        attr_name = inner.substring(0, op_pos).trim()
    else:
        attr_name = inner.substring(0, op_pos).trim()

    val value_start = op_pos + op.len()
    var attr_value = inner.substring(value_start, inner.len()).trim()
    # Strip quotes from value if present
    if attr_value.len() >= 2:
        val vf = attr_value.substring(0, 1)
        val vl = attr_value.substring(attr_value.len() - 1, attr_value.len())
        if (vf == "\"" and vl == "\"") or (vf == "'" and vl == "'"):
            attr_value = attr_value.substring(1, attr_value.len() - 1)

    SelectorPart.Attribute(name: attr_name, op: op, value: attr_value)

# Parse a comma-separated list of simple selectors (for :is() / :where()).
fn parse_selector_list_simple(args: text) -> [SelectorPart]:
    var result = [SelectorPart]()
    val parts = args.split(",")
    var i = 0
    while i < parts.len():
        val part = parse_simple_selector(parts.get(i))
        match part:
            Some(p): result.push(p)
            nil: pass_dn
        i = i + 1
    result

# --- Specificity calculation ---

# Calculate specificity for a selector (ids, classes, elements).
fn calculate_specificity(selector: Selector) -> Specificity:
    var ids = 0
    var classes = 0
    var elements = 0

    var i = 0
    while i < selector.parts.len():
        val part = selector.parts.get(i)
        match part:
            SelectorPart.Id(_):
                ids = ids + 1
            SelectorPart.Class(_):
                classes = classes + 1
            SelectorPart.Attribute(_, _, _):
                classes = classes + 1
            SelectorPart.PseudoClass(_):
                classes = classes + 1
            SelectorPart.Type(_):
                elements = elements + 1
            SelectorPart.PseudoElement(_):
                elements = elements + 1
            SelectorPart.FunctionalPseudo(name, _):
                # :not() has specificity of its argument, :where() has zero
                if name == "where":
                    pass_dn
                else:
                    classes = classes + 1
            SelectorPart.Universal:
                pass_dn  # Universal selector has no specificity
            SelectorPart.Combinator(_):
                pass_dn  # Combinators have no specificity
        i = i + 1

    Specificity.create(ids, classes, elements)

# Compare two specificities. Returns positive if a > b, negative if a < b, 0 if equal.
fn compare_specificity(a: Specificity, b: Specificity) -> i64:
    if a.ids != b.ids:
        return a.ids - b.ids
    if a.classes != b.classes:
        return a.classes - b.classes
    a.elements - b.elements
