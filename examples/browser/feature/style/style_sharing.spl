# Style sharing cache — avoids redundant style computation for elements
# with identical styling inputs (same tag, classes, and parent style).
# Siblings with the same selector profile frequently share computed styles.

use examples.browser.feature.style.computed.(ComputedStyle, extract_px)
use examples.browser.entity.dom.css_types.(CSSValue)
use examples.browser.shared.logging.(Logger, LogLevel)

# ---------------------------------------------------------------------------
# StyleCacheKey — identifies a unique styling context.
# ---------------------------------------------------------------------------

class StyleCacheKey:
    tag_name: text
    class_names: List<text>
    parent_style_hash: i64

    static fn create(tag_name: text, class_names: List<text>, parent_style_hash: i64) -> StyleCacheKey:
        StyleCacheKey(tag_name: tag_name, class_names: class_names, parent_style_hash: parent_style_hash)

# ---------------------------------------------------------------------------
# StyleCacheEntry — a cached computed style with its key and hit count.
# ---------------------------------------------------------------------------

class StyleCacheEntry:
    key: StyleCacheKey
    computed: ComputedStyle
    hit_count: i64

    static fn create(key: StyleCacheKey, computed: ComputedStyle) -> StyleCacheEntry:
        StyleCacheEntry(key: key, computed: computed, hit_count: 0)

# ---------------------------------------------------------------------------
# StyleSharingCache — the LRU-evicting style cache.
# ---------------------------------------------------------------------------

class StyleSharingCache:
    entries: List<StyleCacheEntry>
    max_size: i64
    hits: i64
    misses: i64
    logger: Logger

    static fn new(max_size: i64, logger: Logger) -> StyleSharingCache:
        StyleSharingCache(
            entries: List<StyleCacheEntry>(),
            max_size: max_size,
            hits: 0,
            misses: 0,
            logger: logger
        )

    # Look up a cached computed style for the given key.
    # Returns the cached style if found, nil otherwise.
    me lookup(key: StyleCacheKey) -> ComputedStyle?:
        var idx = 0
        for entry in self.entries:
            if keys_match(entry.key, key):
                self.hits = self.hits + 1
                # Increment hit count on the entry
                var updated = entry
                updated.hit_count = updated.hit_count + 1
                self.entries.set(idx, updated)
                self.logger.trace("style cache hit for <{key.tag_name}>, total hits={self.hits}")
                return entry.computed
            idx = idx + 1
        self.misses = self.misses + 1
        self.logger.trace("style cache miss for <{key.tag_name}>, total misses={self.misses}")
        return nil

    # Store a computed style in the cache. If the cache is full, evict the
    # least recently used entry (lowest hit count).
    me store(key: StyleCacheKey, style: ComputedStyle):
        # Check if key already exists — update in place
        var idx = 0
        for entry in self.entries:
            if keys_match(entry.key, key):
                self.entries.set(idx, StyleCacheEntry(key: key, computed: style, hit_count: entry.hit_count))
                self.logger.trace("style cache updated for <{key.tag_name}>")
                return
            idx = idx + 1

        # Evict if at capacity
        if self.entries.len() >= self.max_size:
            self.evict_lru()

        self.entries.push(StyleCacheEntry.create(key, style))
        self.logger.trace("style cache stored for <{key.tag_name}>, size={self.entries.len()}")

    # Invalidate all entries that contain a given class name.
    me invalidate_for_class(class_name: text):
        var new_entries = List<StyleCacheEntry>()
        for entry in self.entries:
            var has_class = false
            for cn in entry.key.class_names:
                if cn == class_name:
                    has_class = true
            if not has_class:
                new_entries.push(entry)
        val removed = self.entries.len() - new_entries.len()
        self.entries = new_entries
        if removed > 0:
            self.logger.debug("style cache invalidated {removed} entries for class '{class_name}'")

    # Clear the entire cache.
    me clear():
        self.entries = List<StyleCacheEntry>()
        self.hits = 0
        self.misses = 0
        self.logger.debug("style cache cleared")

    # Cache hit rate as a fraction [0.0, 1.0].
    fn hit_rate() -> f64:
        val total = self.hits + self.misses
        if total == 0:
            return 0.0
        return self.hits.to_f64() / total.to_f64()

    # Evict the entry with the lowest hit count.
    me evict_lru():
        if self.entries.len() == 0:
            return
        var min_hits = self.entries.get(0).hit_count
        var min_idx = 0
        var idx = 1
        while idx < self.entries.len():
            val entry = self.entries.get(idx)
            if entry.hit_count < min_hits:
                min_hits = entry.hit_count
                min_idx = idx
            idx = idx + 1
        self.entries.remove(min_idx)

# ---------------------------------------------------------------------------
# Key creation and comparison.
# ---------------------------------------------------------------------------

fn create_key(tag: text, classes: List<text>, parent_hash: i64) -> StyleCacheKey:
    StyleCacheKey.create(tag, classes, parent_hash)

# Compare two cache keys for equality.
fn keys_match(a: StyleCacheKey, b: StyleCacheKey) -> bool:
    if a.tag_name != b.tag_name:
        return false
    if a.parent_style_hash != b.parent_style_hash:
        return false
    if a.class_names.len() != b.class_names.len():
        return false
    # Compare class names (order-sensitive for simplicity)
    var idx = 0
    while idx < a.class_names.len():
        if a.class_names.get(idx) != b.class_names.get(idx):
            return false
        idx = idx + 1
    return true

# ---------------------------------------------------------------------------
# Style hashing — simple hash for a ComputedStyle for cache key generation.
# ---------------------------------------------------------------------------

fn hash_style(style: ComputedStyle) -> i64:
    var h: i64 = 17
    # Mix in key property values
    h = h * 31 + hash_text(style.display)
    h = h * 31 + hash_text(style.position)
    h = h * 31 + hash_css_value(style.font_size)
    h = h * 31 + hash_css_value(style.color)
    h = h * 31 + hash_text(style.font_family)
    h = h * 31 + hash_css_value(style.font_weight)
    h = h * 31 + hash_text(style.visibility)
    h = h * 31 + hash_text(style.text_align)
    h = h * 31 + hash_css_value(style.line_height)
    h

# Simple text hash — DJB2 variant.
fn hash_text(s: text) -> i64:
    var h: i64 = 5381
    for ch in s.chars():
        h = h * 33 + ch.to_i64()
    h

# Hash a CSSValue into an i64.
fn hash_css_value(v: CSSValue) -> i64:
    match v:
        CSSValue.Length(val, unit):
            val.to_i64() * 1000 + hash_text(unit)
        CSSValue.Number(val):
            val.to_i64() * 1000 + 7
        CSSValue.Keyword(val):
            hash_text(val)
        CSSValue.Color(color):
            color.r * 16777216 + color.g * 65536 + color.b * 256 + color.a
        CSSValue.Percentage(val):
            val.to_i64() * 100 + 13
        _:
            0
