# CSS property inheritance logic.
# Handles inherited properties (color, font-*, text-*, etc.) that flow from
# parent to child unless explicitly overridden. Also provides font-size and
# font-weight keyword resolution.

use examples.browser.entity.dom.css_types.(CSSValue, CSSDeclaration)
use examples.browser.feature.style.computed.(ComputedStyle, get_property_from_style, set_property_on_style, extract_px)
use examples.browser.shared.logging.(Logger, LogLevel)

# ---------------------------------------------------------------------------
# InheritanceResolver — resolves inherited properties from parent to child.
# ---------------------------------------------------------------------------

class InheritanceResolver:
    inherited_properties: List<text>
    logger: Logger

    static fn new(logger: Logger) -> InheritanceResolver:
        val props = [
            "color", "font-family", "font-size", "font-weight", "font-style",
            "line-height", "text-align", "text-decoration", "text-indent",
            "text-transform", "letter-spacing", "word-spacing", "white-space",
            "visibility", "direction", "cursor", "list-style-type",
            "list-style-position", "quotes"
        ]
        InheritanceResolver(inherited_properties: props, logger: logger)

    # Fill in inherited values from parent for all inherited properties where
    # the child has no explicit cascaded value (i.e., still holds the initial).
    fn resolve_inheritance(computed: ComputedStyle, parent: ComputedStyle) -> ComputedStyle:
        var result = computed
        for prop in self.inherited_properties:
            val child_val = get_property_from_style(result, prop)
            # If the child value is the CSS 'inherit' keyword, use parent value
            match child_val:
                CSSValue.Inherit:
                    val parent_val = self.inherit_value(prop, parent)
                    result = set_property_on_style(result, prop, parent_val)
                _:
                    pass_dn
        self.logger.trace("inheritance resolved for {self.inherited_properties.len()} properties")
        result

    # Get the parent's value for a specific property.
    fn inherit_value(property: text, parent: ComputedStyle) -> CSSValue:
        get_property_from_style(parent, property)

    # Determine if a property should inherit its value.
    # Inherit if the cascaded value is the Inherit keyword, or if the property
    # is in the inherited list and no explicit cascaded value was set (nil).
    fn should_inherit(property: text, cascaded: CSSValue?) -> bool:
        if val cv = cascaded:
            match cv:
                CSSValue.Inherit: return true
                CSSValue.Unset: return self.is_inherited(property)
                _: return false
        # No cascaded value — inherit if property is inheritable
        return self.is_inherited(property)

    # Check if a property name is in the inherited properties list.
    fn is_inherited(property: text) -> bool:
        for p in self.inherited_properties:
            if p == property:
                return true
        return false

# ---------------------------------------------------------------------------
# Font size resolution — handles px, em, rem, %, and keyword sizes.
# ---------------------------------------------------------------------------

fn resolve_font_size(value: CSSValue, parent_font_size: f64) -> f64:
    match value:
        CSSValue.Length(v, unit):
            if unit == "px":
                v
            else if unit == "em":
                v * parent_font_size
            else if unit == "rem":
                # Root font size is conventionally 16px
                v * 16.0
            else if unit == "pt":
                v * (96.0 / 72.0)
            else:
                v
        CSSValue.Percentage(v):
            (v / 100.0) * parent_font_size
        CSSValue.Keyword(v):
            # Check for absolute size keywords
            val kw_size = keyword_font_size(v)
            if kw_size > 0.0:
                kw_size
            else:
                # Check for relative size keywords
                val rel_size = relative_font_size(v, parent_font_size)
                if rel_size > 0.0:
                    rel_size
                else:
                    parent_font_size
        CSSValue.Number(v):
            v
        _:
            parent_font_size

# Absolute size keyword → pixel value mapping.
# Based on CSS specification with medium = 16px.
fn keyword_font_size(keyword: text) -> f64:
    match keyword:
        "xx-small": 9.0
        "x-small": 10.0
        "small": 13.0
        "medium": 16.0
        "large": 18.0
        "x-large": 24.0
        "xx-large": 32.0
        "xxx-large": 48.0
        _: 0.0

# Relative size keywords — larger/smaller relative to parent.
fn relative_font_size(keyword: text, parent: f64) -> f64:
    match keyword:
        "larger":
            # Scale up by roughly 1.2x, snapping to nearest absolute keyword
            if parent < 10.0: 10.0
            else if parent < 13.0: 13.0
            else if parent < 16.0: 16.0
            else if parent < 18.0: 18.0
            else if parent < 24.0: 24.0
            else if parent < 32.0: 32.0
            else: 48.0
        "smaller":
            # Scale down by roughly 1.2x, snapping to nearest absolute keyword
            if parent > 32.0: 32.0
            else if parent > 24.0: 24.0
            else if parent > 18.0: 18.0
            else if parent > 16.0: 16.0
            else if parent > 13.0: 13.0
            else if parent > 10.0: 10.0
            else: 9.0
        _: 0.0

# ---------------------------------------------------------------------------
# Font weight resolution — normal, bold, bolder, lighter, and numeric.
# ---------------------------------------------------------------------------

fn resolve_font_weight(value: CSSValue, parent_weight: i64) -> i64:
    match value:
        CSSValue.Keyword(v):
            match v:
                "normal": 400
                "bold": 700
                "bolder": bolder(parent_weight)
                "lighter": lighter(parent_weight)
                _: 400
        CSSValue.Number(v):
            val weight = v.to_i64()
            # Clamp to valid range [1, 1000]
            if weight < 1:
                1
            else if weight > 1000:
                1000
            else:
                weight
        _:
            400

# Compute the bolder weight relative to the current weight.
# Per CSS spec: 100-349→400, 350-549→700, 550-899→900, 900+→900
fn bolder(current: i64) -> i64:
    if current < 350:
        400
    else if current < 550:
        700
    else:
        900

# Compute the lighter weight relative to the current weight.
# Per CSS spec: 100-549→100, 550-749→400, 750+→700
fn lighter(current: i64) -> i64:
    if current < 550:
        100
    else if current < 750:
        400
    else:
        700
