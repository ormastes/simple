#![allow(REQC001)]
#![allow(REQC004)]
#![allow(unnamed_duplicate_typed_args)]
# Browser Render Adapter
#
# Wires the browser example into the shared ui.render contract.
# Routes render requests by mode to produce different views of the
# browser state: tab overview, current page, network log, and devtools.
#
# adapter_name: "browser"
# Modes: "tabs", "page", "network", "devtools"

use app.ui.render.types.{RenderConfig, RenderResult}
use app.ui.render.html.{
    html_page, html_escape,
    html_flex_row, html_flex_col, html_section,
    html_card, html_card_with_status, html_metric_card,
    html_badge, html_status_dot, html_progress_bar,
    html_table, html_kv_table,
    css_reset, css_dark_theme, css_light_theme
}
use app.ui.render.css.{card_css, badge_css, table_css, grid_css, responsive_css}
use app.ui.render.fmt.{fmt_bytes, fmt_duration_ms, fmt_number, truncate, heading, separator, pad_right}

use examples.browser.ui_bridge.{BrowserSnapshot, render_browser_ui, render_cookies_html, render_headers_html}
use examples.browser.entity.browser.tab_types.{Tab, TabId, TabState, TabGroup}
use examples.browser.entity.dom.node_types.{DomNode, NodeKind}
use examples.browser.feature.browser.devtools.{NetworkEntry, ConsoleEntry}

# =========================================================================
# Adapter Entry Point
# =========================================================================

fn browser_render_adapter(config: RenderConfig, snapshot: BrowserSnapshot) -> RenderResult:
    """Main render adapter for the browser example.

    Routes by config.mode:
      "tabs"     - Tab overview with group summaries
      "page"     - Current page view (default)
      "network"  - Network request log
      "devtools" - DOM tree + CSS + console + network panels
    """
    match config.mode:
        "tabs":
            return _render_tabs_mode(config, snapshot)
        "network":
            return _render_network_mode(config, snapshot)
        "devtools":
            return _render_devtools_mode(config, snapshot)
        _:
            # Default: "page" mode — full browser chrome + page
            return render_browser_ui(config, snapshot)

# =========================================================================
# Tabs Mode — Tab Overview
# =========================================================================

fn _render_tabs_mode(config: RenderConfig, snap: BrowserSnapshot) -> RenderResult:
    """Render a tab overview showing all open tabs and groups."""
    val text_out = _tabs_text(config, snap)
    val html_out = _tabs_html(config, snap)

    match config.format:
        "html":
            return RenderResult(
                format: "html",
                text_output: text_out,
                html_output: html_out,
                metadata: _tabs_metadata(snap),
                warnings: []
            )
        "both":
            return RenderResult(
                format: "both",
                text_output: text_out,
                html_output: html_out,
                metadata: _tabs_metadata(snap),
                warnings: []
            )
        _:
            return RenderResult(
                format: "text",
                text_output: text_out,
                html_output: "",
                metadata: _tabs_metadata(snap),
                warnings: []
            )

fn _tabs_text(config: RenderConfig, snap: BrowserSnapshot) -> text:
    val width = config.width
    var lines: [text] = []

    lines.push(heading("Tab Overview", "=", width))
    lines.push("")
    lines.push("Open tabs: {snap.tabs.len()}")
    lines.push("Tab groups: {snap.tab_groups.len()}")
    lines.push("")

    # List tabs
    for tab in snap.tabs:
        val active = if tab.id.id == snap.active_tab_id: " * " else: "   "
        val pin = if tab.is_pinned: "[P]" else: "   "
        val state = _tab_state_label(tab.state)
        val title = truncate(tab.title, 30)
        val url = truncate(tab.url, 40)
        lines.push("{active}{pin} {title}")
        lines.push("       {url}  [{state}]")
    lines.push("")

    # Groups
    if snap.tab_groups.len() > 0:
        lines.push(heading("Groups", "-", width))
        for group in snap.tab_groups:
            val count = group.tab_ids.len()
            lines.push("  {group.name} ({group.color}) - {count} tabs")

    return _join_lines(lines)

fn _tabs_html(config: RenderConfig, snap: BrowserSnapshot) -> text:
    val theme_css = if config.theme == "light": css_light_theme() else: css_dark_theme()
    val all_css = "{css_reset()}\n{theme_css}\n{card_css()}\n{badge_css()}\n{grid_css()}\n{table_css()}\n{responsive_css()}"

    var body = ""
    body = "{body}<div class=\"container\">\n"
    body = "{body}<h1>Tab Overview</h1>\n"

    # Summary metrics
    val total_tabs = "{snap.tabs.len()}"
    val active_count = "1"
    val pinned = _count_pinned(snap.tabs)
    val groups = "{snap.tab_groups.len()}"

    var metrics: [text] = []
    metrics.push(html_metric_card("Open Tabs", total_tabs, ""))
    metrics.push(html_metric_card("Pinned", "{pinned}", ""))
    metrics.push(html_metric_card("Groups", groups, ""))
    body = "{body}<div class=\"card-grid\">{metrics.join(\"\")}</div>\n"

    # Tab cards
    body = "{body}<h2 style=\"margin-top:16px\">Tabs</h2>\n"
    for tab in snap.tabs:
        val is_active = tab.id.id == snap.active_tab_id
        val status = _tab_state_status(tab.state)
        val title = html_escape(tab.title)
        val url = html_escape(truncate(tab.url, 60))
        var card_body = "<div>{url}</div>"
        if tab.is_pinned:
            card_body = "{card_body} {html_badge(\"Pinned\", \"var(--blue, #58a6ff)\")}"
        if is_active:
            card_body = "{card_body} {html_badge(\"Active\", \"var(--green, #3fb950)\")}"
        body = "{body}{html_card_with_status(title, card_body, status)}\n"

    # Group section
    if snap.tab_groups.len() > 0:
        body = "{body}<h2 style=\"margin-top:16px\">Tab Groups</h2>\n"
        for group in snap.tab_groups:
            val count = group.tab_ids.len()
            val group_body = "{count} tabs"
            body = "{body}{html_card(html_escape(group.name), group_body)}\n"

    body = "{body}</div>\n"
    return html_page("Tab Overview - Simple Browser", all_css, body)

fn _tabs_metadata(snap: BrowserSnapshot) -> Dict<text, text>:
    var meta: Dict<text, text> = {}
    meta["adapter"] = "browser"
    meta["mode"] = "tabs"
    meta["tab_count"] = "{snap.tabs.len()}"
    meta["group_count"] = "{snap.tab_groups.len()}"
    meta["pinned_count"] = "{_count_pinned(snap.tabs)}"
    return meta

# =========================================================================
# Network Mode — Request Log
# =========================================================================

fn _render_network_mode(config: RenderConfig, snap: BrowserSnapshot) -> RenderResult:
    val text_out = _network_text(config, snap)
    val html_out = _network_html(config, snap)

    match config.format:
        "html":
            return RenderResult(
                format: "html",
                text_output: text_out,
                html_output: html_out,
                metadata: _network_metadata(snap),
                warnings: []
            )
        "both":
            return RenderResult(
                format: "both",
                text_output: text_out,
                html_output: html_out,
                metadata: _network_metadata(snap),
                warnings: []
            )
        _:
            return RenderResult(
                format: "text",
                text_output: text_out,
                html_output: "",
                metadata: _network_metadata(snap),
                warnings: []
            )

fn _network_text(config: RenderConfig, snap: BrowserSnapshot) -> text:
    val width = config.width
    var lines: [text] = []

    lines.push(heading("Network Log", "=", width))
    lines.push("")
    lines.push("Total requests: {snap.network_entries.len()}")
    lines.push("Bytes transferred: {fmt_bytes(snap.bytes_transferred)}")
    lines.push("Load time: {fmt_duration_ms(snap.load_time_ms)}")
    lines.push("")
    lines.push(separator("-", width))

    if snap.network_entries.len() == 0:
        lines.push("(no network requests)")
    else:
        # Request list
        lines.push(pad_right("Method", 8) + pad_right("Status", 8) + "URL")
        lines.push(separator("-", width))
        for entry in snap.network_entries:
            val method = pad_right(entry.method, 8)
            val status = pad_right("{entry.status_code}", 8)
            val url = truncate(entry.url, width - 16)
            lines.push("{method}{status}{url}")

    return _join_lines(lines)

fn _network_html(config: RenderConfig, snap: BrowserSnapshot) -> text:
    val theme_css = if config.theme == "light": css_light_theme() else: css_dark_theme()
    val all_css = "{css_reset()}\n{theme_css}\n{card_css()}\n{badge_css()}\n{table_css()}\n{grid_css()}\n{responsive_css()}"

    var body = ""
    body = "{body}<div class=\"container\">\n"
    body = "{body}<h1>Network Log</h1>\n"

    # Summary metrics
    var metrics: [text] = []
    metrics.push(html_metric_card("Requests", "{snap.network_entries.len()}", ""))
    metrics.push(html_metric_card("Transferred", fmt_bytes(snap.bytes_transferred), ""))
    metrics.push(html_metric_card("Load Time", fmt_duration_ms(snap.load_time_ms), ""))
    body = "{body}<div class=\"card-grid\">{metrics.join(\"\")}</div>\n"

    # Request table
    body = "{body}<div style=\"margin-top:16px\">\n"
    if snap.network_entries.len() == 0:
        body = "{body}{html_card(\"Network Requests\", \"(no requests)\")}\n"
    else:
        var rows: [[text]] = []
        for entry in snap.network_entries:
            val status_label = if entry.status_code == 0: "pending" else: "{entry.status_code}"
            rows.push([entry.method, status_label, entry.url, entry.request_id])
        body = "{body}{html_section(\"Requests\", html_table([\"Method\", \"Status\", \"URL\", \"Request ID\"], rows))}\n"
    body = "{body}</div>\n"

    # Cookies
    if snap.cookies.len() > 0:
        body = "{body}{html_section(\"Cookies\", render_cookies_html(snap.cookies))}\n"

    body = "{body}</div>\n"
    return html_page("Network Log - Simple Browser", all_css, body)

fn _network_metadata(snap: BrowserSnapshot) -> Dict<text, text>:
    var meta: Dict<text, text> = {}
    meta["adapter"] = "browser"
    meta["mode"] = "network"
    meta["request_count"] = "{snap.network_entries.len()}"
    meta["bytes_transferred"] = "{snap.bytes_transferred}"
    meta["load_time_ms"] = "{snap.load_time_ms}"
    return meta

# =========================================================================
# DevTools Mode — DOM + CSS + Console + Network
# =========================================================================

fn _render_devtools_mode(config: RenderConfig, snap: BrowserSnapshot) -> RenderResult:
    val text_out = _devtools_text(config, snap)
    val html_out = _devtools_html(config, snap)

    match config.format:
        "html":
            return RenderResult(
                format: "html",
                text_output: text_out,
                html_output: html_out,
                metadata: _devtools_metadata(snap),
                warnings: []
            )
        "both":
            return RenderResult(
                format: "both",
                text_output: text_out,
                html_output: html_out,
                metadata: _devtools_metadata(snap),
                warnings: []
            )
        _:
            return RenderResult(
                format: "text",
                text_output: text_out,
                html_output: "",
                metadata: _devtools_metadata(snap),
                warnings: []
            )

fn _devtools_text(config: RenderConfig, snap: BrowserSnapshot) -> text:
    val width = config.width
    var lines: [text] = []

    lines.push(heading("DevTools", "=", width))
    lines.push("")

    # DOM tree
    lines.push(heading("Elements", "-", width))
    if snap.dom_nodes.len() == 0:
        lines.push("  (no DOM nodes)")
    else:
        for node in snap.dom_nodes:
            val indent = _indent(1)
            val kind = _node_kind_label(node.kind)
            val data_display = if node.data != "": " \"{truncate(node.data, 40)}\"" else: ""
            lines.push("{indent}[{node.id}] {kind}{data_display}")
    lines.push("")

    # CSS computed styles
    lines.push(heading("Styles", "-", width))
    if snap.css_declarations.len() == 0:
        lines.push("  (no computed styles)")
    else:
        for decl in snap.css_declarations:
            val value_str = _css_value_text(decl.value)
            val important = if decl.important: " !important" else: ""
            lines.push("  {decl.property}: {value_str}{important}")
    lines.push("")

    # Console
    lines.push(heading("Console", "-", width))
    if snap.console_entries.len() == 0:
        lines.push("  (no console output)")
    else:
        for entry in snap.console_entries:
            val level = pad_right("[{entry.level}]", 8)
            lines.push("  {level} {truncate(entry.message, width - 12)}")
    lines.push("")

    # Network (summary)
    lines.push(heading("Network", "-", width))
    lines.push("  Requests: {snap.network_entries.len()}")
    lines.push("  Transferred: {fmt_bytes(snap.bytes_transferred)}")

    return _join_lines(lines)

fn _devtools_html(config: RenderConfig, snap: BrowserSnapshot) -> text:
    val theme_css = if config.theme == "light": css_light_theme() else: css_dark_theme()
    val all_css = "{css_reset()}\n{theme_css}\n{card_css()}\n{badge_css()}\n{table_css()}\n{grid_css()}\n{responsive_css()}"

    var body = ""
    body = "{body}<div class=\"container\">\n"
    body = "{body}<h1>DevTools</h1>\n"

    # Elements panel — DOM tree
    var dom_content = ""
    if snap.dom_nodes.len() == 0:
        dom_content = "<div style=\"color:var(--text-dim)\">(no DOM nodes)</div>"
    else:
        dom_content = "<div class=\"dom-tree\" style=\"font-family:monospace;font-size:13px\">"
        for node in snap.dom_nodes:
            val kind = _node_kind_label(node.kind)
            val data_display = if node.data != "": " \"{html_escape(truncate(node.data, 60))}\"" else: ""
            val node_color = _node_kind_color(node.kind)
            dom_content = "{dom_content}<div style=\"padding:2px 0;padding-left:16px\">"
            dom_content = "{dom_content}<span style=\"color:{node_color}\">{html_escape(kind)}</span>"
            dom_content = "{dom_content}<span style=\"color:var(--text-dim)\">[{node.id}]</span>"
            dom_content = "{dom_content}{html_escape(data_display)}"
            dom_content = "{dom_content}</div>"
        dom_content = "{dom_content}</div>"
    body = "{body}{html_card(\"Elements\", dom_content)}\n"

    # Styles panel — CSS declarations
    var style_content = ""
    if snap.css_declarations.len() == 0:
        style_content = "<div style=\"color:var(--text-dim)\">(no computed styles)</div>"
    else:
        var css_pairs: [(text, text)] = []
        for decl in snap.css_declarations:
            val value_str = _css_value_text(decl.value)
            val important = if decl.important: " !important" else: ""
            css_pairs.push((decl.property, "{value_str}{important}"))
        style_content = html_kv_table(css_pairs)
    body = "{body}{html_card(\"Styles\", style_content)}\n"

    # Console panel
    var console_content = ""
    if snap.console_entries.len() == 0:
        console_content = "<div style=\"color:var(--text-dim)\">(no console output)</div>"
    else:
        console_content = "<div style=\"font-family:monospace;font-size:13px;background:var(--bg,#0d1117);padding:8px;border-radius:4px\">"
        for entry in snap.console_entries:
            val level_color = _console_level_color(entry.level)
            console_content = "{console_content}<div style=\"padding:2px 0\">"
            console_content = "{console_content}<span style=\"color:{level_color};font-weight:600\">[{html_escape(entry.level)}]</span> "
            console_content = "{console_content}{html_escape(entry.message)}"
            console_content = "{console_content}</div>"
        console_content = "{console_content}</div>"
    body = "{body}{html_card(\"Console\", console_content)}\n"

    # Network summary panel
    var net_rows: [[text]] = []
    for entry in snap.network_entries:
        val status_label = if entry.status_code == 0: "pending" else: "{entry.status_code}"
        net_rows.push([entry.method, status_label, truncate(entry.url, 50)])
    val net_content = if net_rows.len() == 0:
        "<div style=\"color:var(--text-dim)\">(no requests)</div>"
    else:
        html_table(["Method", "Status", "URL"], net_rows)
    body = "{body}{html_card(\"Network ({snap.network_entries.len()} requests)\", net_content)}\n"

    body = "{body}</div>\n"
    return html_page("DevTools - Simple Browser", all_css, body)

fn _devtools_metadata(snap: BrowserSnapshot) -> Dict<text, text>:
    var meta: Dict<text, text> = {}
    meta["adapter"] = "browser"
    meta["mode"] = "devtools"
    meta["dom_nodes"] = "{snap.dom_nodes.len()}"
    meta["css_declarations"] = "{snap.css_declarations.len()}"
    meta["console_entries"] = "{snap.console_entries.len()}"
    meta["network_requests"] = "{snap.network_entries.len()}"
    return meta

# =========================================================================
# Helpers
# =========================================================================

fn _tab_state_label(state: TabState) -> text:
    match state:
        TabState.Loading: "loading"
        TabState.Complete: "complete"
        TabState.Error: "error"
        TabState.Crashed: "crashed"
        TabState.Frozen: "frozen"

fn _tab_state_status(state: TabState) -> text:
    """Map TabState to a status string for html_card_with_status."""
    match state:
        TabState.Loading: "in_progress"
        TabState.Complete: "ok"
        TabState.Error: "error"
        TabState.Crashed: "critical"
        TabState.Frozen: "warning"

fn _node_kind_label(kind: NodeKind) -> text:
    match kind:
        NodeKind.Document: "Document"
        NodeKind.Element: "Element"
        NodeKind.Text: "Text"
        NodeKind.Comment: "Comment"
        NodeKind.DocumentFragment: "Fragment"
        NodeKind.Attribute: "Attribute"

fn _node_kind_color(kind: NodeKind) -> text:
    match kind:
        NodeKind.Document: "var(--blue, #58a6ff)"
        NodeKind.Element: "var(--green, #3fb950)"
        NodeKind.Text: "var(--text, #c9d1d9)"
        NodeKind.Comment: "var(--gray, #8b949e)"
        NodeKind.DocumentFragment: "var(--yellow, #d29922)"
        NodeKind.Attribute: "var(--blue, #58a6ff)"

fn _css_value_text(value: CSSValue) -> text:
    match value:
        CSSValue.Keyword(v): v
        CSSValue.Length(v, unit): "{v}{unit}"
        CSSValue.Percentage(v): "{v}%"
        CSSValue.Color(color): "(color)"
        CSSValue.Number(v): "{v}"
        CSSValue.Url(v): "url({v})"
        CSSValue.Inherit: "inherit"
        CSSValue.Initial: "initial"
        CSSValue.Unset: "unset"

fn _console_level_color(level: text) -> text:
    match level:
        "error": "var(--red, #f85149)"
        "warn": "var(--yellow, #d29922)"
        "info": "var(--blue, #58a6ff)"
        "debug": "var(--gray, #8b949e)"
        _: "var(--text, #c9d1d9)"

fn _count_pinned(tabs: [Tab]) -> i64:
    var count = 0
    for tab in tabs:
        if tab.is_pinned:
            count = count + 1
    return count

fn _indent(depth: i32) -> text:
    var s = ""
    var i: i32 = 0
    while i < depth:
        s = "{s}  "
        i = i + 1
    return s

fn _join_lines(lines: [text]) -> text:
    var result = ""
    var first = true
    for line in lines:
        if not first:
            result = "{result}\n"
        result = "{result}{line}"
        first = false
    return result
