#![allow(REQC001)]
#![allow(REQC004)]
#![allow(unnamed_duplicate_typed_args)]
# Simple Browser Platform — Entry Point
#
# Chromium-class browser architecture written 100% in Simple.
# Multi-process model: browser (privileged), renderer (sandboxed),
# network service, GPU compositor.
#
# Architecture:
#   Layer 0: Network (DNS, TLS, HTTP, fetch, cache, cookies, CORS)
#   Layer 1: Parser (HTML5 tokenizer+tree builder, CSS parser)
#   Layer 2: DOM (document tree, events, mutation observers)
#   Layer 3: Style (cascade, computed values, inheritance, animations)
#   Layer 4: Layout (block, inline, flex, grid, text shaping)
#   Layer 5: Paint (display list, stacking, text/image/border paint)
#   Layer 6: Composite (layer tree, tiling, damage tracking)
#   Layer 7: GPU (surfaces, raster, textures, command buffers)
#   Layer 8: Script (JS lexer/parser/VM/GC, builtins, web APIs)
#   Layer 9: Browser (tabs, navigation, history, permissions, devtools)
#   Layer 10: Sandbox (process manager, capabilities, site isolation, CSP)
#
# Security: Capability-based (Capsicum + OpenBSD inspired)
# IPC: Typed enum messages, no stringly-typed protocols
#
# Bootstrap verification path in this checkout:
#   src/compiler_rust/target/bootstrap/simple native-build \
#     --entry examples/browser/mod.spl -o build/browser_example

use examples.browser.entity.ipc.message_types.{BrowserIpcMsg, BrowserIpcMethod, IpcFlag}
use examples.browser.entity.ipc.process_types.{ProcessId, ProcessKind}
use examples.browser.entity.browser.tab_types.{TabId}
use examples.browser.feature.sandbox.process_manager.{ProcessManager}
use examples.browser.feature.sandbox.capability_broker.{CapabilityBroker}
use examples.browser.shared.config.{BrowserConfig, load_config}
use examples.browser.shared.logging.{Logger, LogLevel}
use examples.browser.shared.error.{BrowserError}
use examples.browser.transform.pipeline.{RenderPipeline}

class PendingNavigation:
    renderer_pid_id: i64
    tab_id: i64
    url: text

    static fn for_renderer(renderer_pid_id: i64, tab_id: i64, url: text) -> PendingNavigation:
        PendingNavigation(renderer_pid_id: renderer_pid_id, tab_id: tab_id, url: url)

# Browser process — the privileged coordinator
class BrowserProcess:
    config: BrowserConfig
    logger: Logger
    process_manager: ProcessManager
    capability_broker: CapabilityBroker
    pipeline: RenderPipeline
    next_tab_id: i64
    gpu_pid_id: i64
    pending_navigations: [PendingNavigation]

    static fn boot(config: BrowserConfig) -> BrowserProcess:
        val logger = Logger(name: "browser")
        val pm = ProcessManager.create_manager(logger)
        val cb = CapabilityBroker.create_broker(logger)
        val pipeline = RenderPipeline.create_pipeline(logger)
        BrowserProcess(
            config: config,
            logger: logger,
            process_manager: pm,
            capability_broker: cb,
            pipeline: pipeline,
            next_tab_id: 1,
            gpu_pid_id: -1,
            pending_navigations: [PendingNavigation]()
        )

    me start() -> Result<(), BrowserError>:
        self.logger.info("Simple Browser Platform v{self.config.version} starting")

        # Spawn core service processes
        val network_pid = self.process_manager.spawn(ProcessKind.Network)?
        self.capability_broker.apply_sandbox(network_pid, "network_process")?
        self.logger.info("Network service started: pid={network_pid.id}")

        val gpu_pid = self.process_manager.spawn(ProcessKind.Gpu)?
        self.capability_broker.apply_sandbox(gpu_pid, "gpu_process")?
        self.gpu_pid_id = gpu_pid.id
        self.logger.info("GPU compositor started: pid={gpu_pid.id}")

        # Open initial tab
        self.open_tab(self.config.homepage)?

        # Enter main event loop
        self.run_event_loop()

    me open_tab(url: text) -> Result<TabId, BrowserError>:
        val tab_id = TabId(id: self.next_tab_id)
        self.next_tab_id = self.next_tab_id + 1

        # Spawn sandboxed renderer process for this tab
        val renderer_pid = self.process_manager.spawn(ProcessKind.Renderer)?
        self.capability_broker.apply_sandbox(renderer_pid, "renderer_process")?

        # Send navigation command to renderer
        val msg = BrowserIpcMsg(
            src: ProcessId(id: 0, kind: ProcessKind.Browser),
            dst: renderer_pid,
            method: BrowserIpcMethod.NavigateTo,
            flags: [IpcFlag.Async],
            request_id: 0
        )
        self.pending_navigations.push(PendingNavigation.for_renderer(renderer_pid.id, tab_id.id, url))
        self.process_manager.send(msg)?

        self.logger.info("Tab {tab_id.id} opened: {url}")
        Ok(tab_id)

    me run_event_loop() -> Result<(), BrowserError>:
        self.logger.info("Entering main event loop")
        var idle_cycles = 0
        while idle_cycles < 2:
            var progressed = false
            val processes = self.process_manager.list_processes()
            for info in processes:
                val msg = self.process_manager.recv(info.pid)
                if val Some(envelope) = msg:
                    progressed = true
                    self.handle_message(envelope)?
            if progressed:
                idle_cycles = 0
            else:
                idle_cycles = idle_cycles + 1
        self.logger.info("Event loop drained all pending IPC messages")
        Ok(())

    me handle_message(msg: BrowserIpcMsg) -> Result<(), BrowserError>:
        match msg.method:
            BrowserIpcMethod.NavigateTo:
                self.handle_navigation(msg.dst)
            BrowserIpcMethod.SubmitFrame:
                self.logger.info("GPU process accepted composited frame")
                Ok(())
            _:
                self.logger.debug("Ignoring IPC message {msg.method}")
                Ok(())

    me handle_navigation(renderer_pid: ProcessId) -> Result<(), BrowserError>:
        val pending = self.take_pending_navigation(renderer_pid.id)
        if not pending.?:
            self.logger.warn("Renderer pid={renderer_pid.id} received navigation without pending URL")
            return Ok(())
        val nav = pending.unwrap()
        self.logger.info("Renderer pid={renderer_pid.id} navigating tab={nav.tab_id} to {nav.url}")

        val html = self.sample_document_for(nav.url)
        val dom = self.pipeline.parse(html)?
        val styled = self.pipeline.resolve_styles(dom)?
        val layout = self.pipeline.compute_layout(styled)?
        val display_list = self.pipeline.paint(layout)?
        self.logger.info("Navigation complete for tab={nav.tab_id}: {display_list.ops.len()} paint ops")

        if self.gpu_pid_id > 0:
            val gpu_msg = BrowserIpcMsg(
                src: renderer_pid,
                dst: ProcessId(id: self.gpu_pid_id, kind: ProcessKind.Gpu),
                method: BrowserIpcMethod.SubmitFrame,
                flags: [IpcFlag.Async],
                request_id: nav.tab_id
            )
            self.process_manager.send(gpu_msg)?
        Ok(())

    me take_pending_navigation(renderer_pid_id: i64) -> PendingNavigation?:
        var i = 0
        while i < self.pending_navigations.len():
            val nav = self.pending_navigations.get(i)
            if nav.renderer_pid_id == renderer_pid_id:
                self.pending_navigations.remove(i)
                return Some(nav)
            i = i + 1
        nil

    fn sample_document_for(url: text) -> text:
        "<html><body><h1>Simple Browser</h1><p>Loaded {url}</p><div>pipeline ok</div></body></html>"

# Application entry point
fn main():
    val config = load_config("examples/browser/config.sdn")
    match config:
        Ok(cfg):
            var browser = BrowserProcess.boot(cfg)
            match browser.start():
                Ok(_): pass_do_nothing
                Err(e): print("Fatal: {e.message}")
        Err(e):
            print("Failed to load config: {e.message}")
