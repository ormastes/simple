use std.spec

# TODO: Replace DamageRect with std.common.engine.rect.Rect2 — near-duplicate
# (same fields: x/y/width/height as f64; Rect2 has right(), bottom(), contains_point(), intersects()).
# A rectangular damage region
class DamageRect:
    x: f64
    y: f64
    width: f64
    height: f64

    static fn create(x: f64, y: f64, w: f64, h: f64) -> DamageRect:
        DamageRect(x: x, y: y, width: w, height: h)

    fn area() -> f64:
        self.width * self.height

    fn right() -> f64:
        self.x + self.width

    fn bottom() -> f64:
        self.y + self.height

# Check if two rects overlap
fn rects_overlap(a: DamageRect, b: DamageRect) -> bool:
    if a.x >= b.right():
        return false
    if b.x >= a.right():
        return false
    if a.y >= b.bottom():
        return false
    if b.y >= a.bottom():
        return false
    true

# Compute union bounding box of two rects
fn union_rect(a: DamageRect, b: DamageRect) -> DamageRect:
    var min_x = a.x
    if b.x < min_x:
        min_x = b.x
    var min_y = a.y
    if b.y < min_y:
        min_y = b.y
    var max_right = a.right()
    if b.right() > max_right:
        max_right = b.right()
    var max_bottom = a.bottom()
    if b.bottom() > max_bottom:
        max_bottom = b.bottom()
    DamageRect.create(min_x, min_y, max_right - min_x, max_bottom - min_y)

# Damage tracker: collects damaged regions
class DamageTracker:
    regions: List<DamageRect>
    viewport_width: f64
    viewport_height: f64

    static fn create(vw: f64, vh: f64) -> DamageTracker:
        DamageTracker(regions: List<DamageRect>(), viewport_width: vw, viewport_height: vh)

    me add_damage(rect: DamageRect):
        # Try to merge with existing overlapping region
        var merged = false
        var i = 0
        while i < self.regions.len():
            if rects_overlap(self.regions[i], rect):
                self.regions[i] = union_rect(self.regions[i], rect)
                merged = true
                i = self.regions.len()  # break
            i = i + 1
        if not merged:
            self.regions.push(rect)

    me clear():
        self.regions = List<DamageRect>()

    fn total_damage_area() -> f64:
        var total = 0.0
        for r in self.regions:
            total = total + r.area()
        total

    fn is_full_repaint() -> bool:
        var viewport_area = self.viewport_width * self.viewport_height
        var damage = self.total_damage_area()
        damage >= viewport_area * 0.8

# Tile dirty marking
class Tile:
    x: i64
    y: i64
    dirty: bool

    static fn create(x: i64, y: i64) -> Tile:
        Tile(x: x, y: y, dirty: false)

fn mark_tiles_dirty(tiles: List<Tile>, damage: DamageRect, tile_size: f64) -> List<Tile>:
    var result = List<Tile>()
    for tile in tiles:
        var tile_x = tile.x.to_f64() * tile_size
        var tile_y = tile.y.to_f64() * tile_size
        var tile_rect = DamageRect.create(tile_x, tile_y, tile_size, tile_size)
        if rects_overlap(tile_rect, damage):
            var dirty_tile = Tile.create(tile.x, tile.y)
            dirty_tile.dirty = true
            result.push(dirty_tile)
        else:
            result.push(tile)
    result

describe "DamageTracking":
    describe "region management":
        it "add_damage records region":
            var tracker = DamageTracker.create(800.0, 600.0)
            tracker.add_damage(DamageRect.create(10.0, 20.0, 100.0, 50.0))
            expect(tracker.regions.len()).to_equal(1)
            expect(tracker.regions[0].x).to_equal(10.0)
            expect(tracker.regions[0].y).to_equal(20.0)

        it "clear removes all regions":
            var tracker = DamageTracker.create(800.0, 600.0)
            tracker.add_damage(DamageRect.create(0.0, 0.0, 50.0, 50.0))
            tracker.add_damage(DamageRect.create(200.0, 200.0, 50.0, 50.0))
            expect(tracker.regions.len()).to_equal(2)
            tracker.clear()
            expect(tracker.regions.len()).to_equal(0)

    describe "merging":
        it "overlapping rects merge":
            var tracker = DamageTracker.create(800.0, 600.0)
            tracker.add_damage(DamageRect.create(10.0, 10.0, 100.0, 100.0))
            tracker.add_damage(DamageRect.create(50.0, 50.0, 100.0, 100.0))
            # Should merge into one region
            expect(tracker.regions.len()).to_equal(1)

        it "non-overlapping rects stay separate":
            var tracker = DamageTracker.create(800.0, 600.0)
            tracker.add_damage(DamageRect.create(0.0, 0.0, 50.0, 50.0))
            tracker.add_damage(DamageRect.create(200.0, 200.0, 50.0, 50.0))
            expect(tracker.regions.len()).to_equal(2)

        it "merge produces union bounding box":
            var a = DamageRect.create(10.0, 10.0, 100.0, 100.0)
            var b = DamageRect.create(50.0, 50.0, 100.0, 100.0)
            var merged = union_rect(a, b)
            expect(merged.x).to_equal(10.0)
            expect(merged.y).to_equal(10.0)
            expect(merged.width).to_equal(140.0)
            expect(merged.height).to_equal(140.0)

    describe "area and repaint":
        it "total_damage_area sums all regions":
            var tracker = DamageTracker.create(800.0, 600.0)
            tracker.add_damage(DamageRect.create(0.0, 0.0, 100.0, 100.0))
            tracker.add_damage(DamageRect.create(500.0, 500.0, 50.0, 50.0))
            var total = tracker.total_damage_area()
            # 100*100 + 50*50 = 10000 + 2500 = 12500
            expect(total).to_equal(12500.0)

        it "is_full_repaint detects large damage":
            var tracker = DamageTracker.create(800.0, 600.0)
            # viewport area = 480000, 80% = 384000
            tracker.add_damage(DamageRect.create(0.0, 0.0, 800.0, 500.0))
            # damage area = 400000 > 384000
            expect(tracker.is_full_repaint()).to_equal(true)

    describe "tile integration":
        it "damage triggers tile dirty marking":
            var tiles = [
                Tile.create(0, 0),
                Tile.create(1, 0),
                Tile.create(2, 0),
                Tile.create(0, 1)
            ]
            var damage = DamageRect.create(10.0, 10.0, 50.0, 50.0)
            var result = mark_tiles_dirty(tiles, damage, 256.0)
            # Tile (0,0) covers 0..256 x 0..256, overlaps with damage at 10,10
            expect(result[0].dirty).to_equal(true)
            # Tile (1,0) covers 256..512 x 0..256, no overlap
            expect(result[1].dirty).to_equal(false)
            # Tile (2,0) covers 512..768 x 0..256, no overlap
            expect(result[2].dirty).to_equal(false)
            # Tile (0,1) covers 0..256 x 256..512, no overlap
            expect(result[3].dirty).to_equal(false)
