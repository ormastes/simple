fn _tiff_palette_colormap_red_green() -> text:
    var out = ""
    var i = 0
    while i < 256:
        if i == 0:
            out = out + _bytes([255, 255])
        else:
            out = out + _bytes([0, 0])
        i = i + 1
    i = 0
    while i < 256:
        if i == 1:
            out = out + _bytes([255, 255])
        else:
            out = out + _bytes([0, 0])
        i = i + 1
    i = 0
    while i < 256:
        out = out + _bytes([0, 0])
        i = i + 1
    out

fn _tiff_le_2x1_palette_red_green() -> text:
    _bytes([
        73, 73, 42, 0,
        8, 0, 0, 0,
        10, 0,
        0, 1, 4, 0, 1, 0, 0, 0, 2, 0, 0, 0,
        1, 1, 4, 0, 1, 0, 0, 0, 1, 0, 0, 0,
        2, 1, 3, 0, 1, 0, 0, 0, 8, 0, 0, 0,
        3, 1, 3, 0, 1, 0, 0, 0, 1, 0, 0, 0,
        6, 1, 3, 0, 1, 0, 0, 0, 3, 0, 0, 0,
        17, 1, 4, 0, 1, 0, 0, 0, 134, 6, 0, 0,
        21, 1, 3, 0, 1, 0, 0, 0, 1, 0, 0, 0,
        22, 1, 3, 0, 1, 0, 0, 0, 1, 0, 0, 0,
        23, 1, 4, 0, 1, 0, 0, 0, 2, 0, 0, 0,
        64, 1, 3, 0, 0, 3, 0, 0, 134, 0, 0, 0,
        0, 0, 0, 0
    ]) + _tiff_palette_colormap_red_green() + _bytes([0, 1])

