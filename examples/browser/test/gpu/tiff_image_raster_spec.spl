use examples.browser.shared.logging.{Logger}

fn _bytes(values: [i64]) -> text:
    var out = ""
    var i = 0
    while i < values.len():
        val item = values.get(i)
        if val b = item:
            out = out + _fixture_byte(b)
        i = i + 1
    out

fn _fixture_byte(value: i64) -> text:
    if value == 0:
        return "\0"
    if value == 1:
        return "\x01"
    if value == 2:
        return "\x02"
    if value == 3:
        return "\x03"
    if value == 4:
        return "\x04"
    if value == 5:
        return "\x05"
    if value == 6:
        return "\x06"
    if value == 7:
        return "\x07"
    if value == 8:
        return "\x08"
    if value == 9:
        return "\x09"
    if value == 10:
        return "\x0A"
    if value == 16:
        return "\x10"
    if value == 17:
        return "\x11"
    if value == 20:
        return "\x14"
    if value == 21:
        return "\x15"
    if value == 22:
        return "\x16"
    if value == 23:
        return "\x17"
    if value == 28:
        return "\x1C"
    if value == 30:
        return "\x1E"
    if value == 40:
        return "\x28"
    if value == 42:
        return "\x2A"
    if value == 50:
        return "\x32"
    if value == 60:
        return "\x3C"
    if value == 64:
        return "\x40"
    if value == 73:
        return "\x49"
    if value == 110:
        return "\x6E"
    if value == 116:
        return "\x74"
    if value == 120:
        return "\x78"
    if value == 122:
        return "\x7A"
    if value == 124:
        return "\x7C"
    if value == 126:
        return "\x7E"
    if value == 128:
        return "\x80"
    if value == 132:
        return "\x84"
    if value == 134:
        return "\x86"
    if value == 138:
        return "\x8A"
    if value == 140:
        return "\x8C"
    if value == 255:
        return "\xFF"
    char_from_code(value)

fn _tiff_le_2x1_rgb() -> text:
    _bytes([
        73, 73, 42, 0,
        8, 0, 0, 0,
        8, 0,
        0, 1, 4, 0, 1, 0, 0, 0, 2, 0, 0, 0,
        1, 1, 4, 0, 1, 0, 0, 0, 1, 0, 0, 0,
        2, 1, 3, 0, 3, 0, 0, 0, 110, 0, 0, 0,
        3, 1, 3, 0, 1, 0, 0, 0, 1, 0, 0, 0,
        6, 1, 3, 0, 1, 0, 0, 0, 2, 0, 0, 0,
        17, 1, 4, 0, 1, 0, 0, 0, 116, 0, 0, 0,
        21, 1, 3, 0, 1, 0, 0, 0, 3, 0, 0, 0,
        23, 1, 4, 0, 1, 0, 0, 0, 6, 0, 0, 0,
        0, 0, 0, 0,
        8, 0, 8, 0, 8, 0,
        10, 20, 30, 40, 50, 60
    ])

