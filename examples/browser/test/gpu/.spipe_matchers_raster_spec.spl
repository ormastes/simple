#![allow(REQC004)]
#![allow(unnamed_duplicate_typed_args)]

use std.spec
use examples.browser.entity.dom.paint_types.{Color, PaintOp, DisplayItem}
use examples.browser.entity.media.image_types.{ImageData, ImageFormat}
use examples.browser.feature.gpu.raster.{Rasterizer}
use examples.browser.feature.gpu.surface.{GpuSurface, SurfaceFormat}
use examples.browser.shared.logging.{Logger}

fn make_rasterizer() -> Rasterizer:
    Rasterizer.new(Logger(name: "raster-spec"))

fn two_by_two_image() -> ImageData:
    ImageData(
        width: 2,
        height: 2,
        format: ImageFormat.RGBA8,
        pixels: [
            255, 0, 0, 255,
            0, 255, 0, 255,
            0, 0, 255, 255,
            255, 255, 255, 255
        ]
    )

fn pixel(surface: GpuSurface, x: i64, y: i64) -> [i64]:
    val idx = (y * surface.width + x) * 4
    [surface.pixels[idx], surface.pixels[idx + 1], surface.pixels[idx + 2], surface.pixels[idx + 3]]

describe "Rasterizer":
    describe "DrawImage":
        it "rasterizes registered decoded images from display list items":
            var rasterizer = make_rasterizer()
            var surface = GpuSurface.create(1, 2, 2, SurfaceFormat.RGBA8)
            rasterizer.register_image(9, two_by_two_image())
            val item = DisplayItem.create(0, PaintOp.DrawImage(x: 0.0, y: 0.0, w: 2.0, h: 2.0, image_id: 9, src: "asset.bmp"))

            val result = rasterizer.rasterize([item], surface)
            expect result.? == true
            expect pixel(surface, 0, 0) == [255, 0, 0, 255]
            expect pixel(surface, 1, 0) == [0, 255, 0, 255]
            expect pixel(surface, 0, 1) == [0, 0, 255, 255]
            expect pixel(surface, 1, 1) == [255, 255, 255, 255]

        it "leaves target unchanged when image id is missing":
            var rasterizer = make_rasterizer()
            var surface = GpuSurface.create(1, 1, 1, SurfaceFormat.RGBA8)
            val item = DisplayItem.create(0, PaintOp.DrawImage(x: 0.0, y: 0.0, w: 1.0, h: 1.0, image_id: 404, src: "missing.bmp"))

            val result = rasterizer.rasterize([item], surface)
            expect result.? == true
            expect pixel(surface, 0, 0) == [0, 0, 0, 0]