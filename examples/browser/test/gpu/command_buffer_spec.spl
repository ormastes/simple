#![allow(REQC004)]
#![allow(unnamed_duplicate_typed_args)]

use std.spec
use examples.browser.entity.dom.paint_types.{Color}
use examples.browser.feature.gpu.command_buffer.{CommandQueue}
use examples.browser.feature.gpu.raster.{Rasterizer}
use examples.browser.feature.gpu.surface.{SurfaceFormat, SurfacePool}
use examples.browser.shared.logging.{Logger}

fn make_logger() -> Logger:
    Logger(name: "command-buffer-spec")

fn pixel(surface_pool: SurfacePool, x: i64, y: i64) -> [i64]:
    val surface = surface_pool.surfaces[0]
    val idx = (y * surface.width + x) * 4
    [surface.pixels[idx], surface.pixels[idx + 1], surface.pixels[idx + 2], surface.pixels[idx + 3]]

describe "CommandQueue":
    describe "fences":
        it "signals a fence only after the submitted buffer is flushed":
            val logger = make_logger()
            var queue = CommandQueue.new(logger)
            var surfaces = SurfacePool.new(4, logger)
            var rasterizer = Rasterizer.new(logger)
            val created = surfaces.create_surface(2, 2, SurfaceFormat.RGBA8)
            expect(created.?).to_equal(true)
            val surface = created.unwrap()

            var buffer = queue.begin_recording()
            val fence = queue.allocate_fence()
            buffer.clear(surface.id, Color(r: 7, g: 11, b: 13, a: 255))
            buffer.insert_fence(fence)
            val buffer_id = queue.end_recording(buffer)

            val before = queue.wait_fence(fence)
            expect(before.?).to_equal(false)
            expect(queue.is_fence_complete(fence)).to_equal(false)

            val submitted = queue.submit(buffer_id)
            expect(submitted.?).to_equal(true)
            val flushed = queue.flush(surfaces, rasterizer)
            expect(flushed.?).to_equal(true)

            val after = queue.wait_fence(fence)
            expect(after.?).to_equal(true)
            expect(queue.is_complete(buffer_id)).to_equal(true)
            expect(queue.is_fence_complete(fence)).to_equal(true)
            expect(pixel(surfaces, 1, 1)).to_equal([7, 11, 13, 255])
