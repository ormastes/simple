use std.spec.*
use app.ui.render.types.{RenderConfig}
use examples.browser.ui_bridge.{BrowserSnapshot, browser_snapshot_from_app, render_browser_ui}
use examples.browser.entity.browser.navigation_types.{NavigationState}
use examples.browser.feature.browser.app.{BrowserApp, BrowserCommand}
use examples.browser.shared.config.{BrowserConfig}
use examples.browser.shared.logging.{Logger}
use examples.browser.feature.browser.tab_manager.{TabManager}
use examples.browser.feature.browser.navigation.{NavigationController}
use examples.browser.feature.net.h1_client.{MockResponseRegistry, set_mock_registry}
use examples.browser.shared.error.{BrowserResult}

fn _html_config() -> RenderConfig:
    RenderConfig(
        mode: "render",
        backend: "auto",
        format: "html",
        width: 100,
        height: 30,
        theme: "dark",
        asset_path: "",
        output_path: "",
        adapter_name: "browser",
        use_default_demo: false
    )

fn _snapshot(url: text) -> BrowserSnapshot:
    BrowserSnapshot(
        tabs: [],
        active_tab_id: 0,
        tab_groups: [],
        current_url: url,
        page_title: "Example",
        page_text_content: "",
        nav_state: NavigationState.Idle,
        load_progress: 100,
        is_secure: true,
        cookies: [],
        network_entries: [],
        console_entries: [],
        dom_nodes: [],
        css_declarations: [],
        bytes_transferred: 0,
        load_time_ms: 0,
        window: nil
    )

fn _config() -> BrowserConfig:
    BrowserConfig(
        name: "simple-browser-platform",
        version: "0.1.0",
        homepage: "about:blank",
        user_agent: "SimpleBrowser/0.1",
        tab_limit: 8,
        process_model: "site-per-process",
        default_encoding: "utf-8",
        max_history_entries: 1000,
        max_connections_per_host: 6,
        max_total_connections: 64,
        dns_cache_ttl: 300,
        http_cache_size_mb: 256,
        cookie_policy: "same-site-lax",
        connect_timeout_ms: 30000,
        read_timeout_ms: 60000,
        gpu_compositing: true,
        hardware_acceleration: true,
        max_texture_size: 4096,
        tile_size: 256,
        target_fps: 60,
        csp_default: "default-src 'self'",
        mixed_content: "block"
    )

fn _app() -> BrowserApp:
    val logger = Logger(name: "ui-bridge-render-test")
    val config = _config()
    BrowserApp(
        windows: [],
        active_window: 0,
        config: config,
        is_running: false,
        next_window_id: 1,
        logger: logger,
        tab_manager: TabManager(
            tabs: [],
            active_tab_id: 0,
            tab_groups: [],
            next_tab_id: 1,
            next_group_id: 1,
            max_tabs: config.tab_limit,
            logger: logger
        ),
        navigation: NavigationController(
            entries: [],
            current_index: -1,
            is_loading: false,
            state: NavigationState.Idle,
            logger: logger
        ),
        last_find_query: "",
        zoom_percent: 100,
        devtools_open: false,
        page_title: "New Tab",
        page_text_content: "",
        page_html: ""
    )

fn _ok(result: BrowserResult<()>) -> bool:
    match result:
        Ok(_): true
        Err(_): false

describe "Browser UI bridge rendering":
    it "renders bindable browser chrome actions":
        val snap = _snapshot("https://example.com/?q=one&two=2")
        val result = render_browser_ui(_html_config(), snap)
        val html = result.html_output
        expect(html.contains("data-browser-action=\"back\"")).to_equal(true)
        expect(html.contains("data-browser-action=\"forward\"")).to_equal(true)
        expect(html.contains("data-browser-action=\"reload\"")).to_equal(true)
        expect(html.contains("data-browser-action=\"new-tab\"")).to_equal(true)
        expect(html.contains("data-browser-action=\"close-tab\"")).to_equal(true)
        expect(html.contains("data-browser-action=\"address-submit\"")).to_equal(true)
        expect(html.contains("data-browser-action=\"find\"")).to_equal(true)
        expect(html.contains("data-browser-action=\"zoom-out\"")).to_equal(true)
        expect(html.contains("data-browser-action=\"zoom-reset\"")).to_equal(true)
        expect(html.contains("data-browser-action=\"zoom-in\"")).to_equal(true)
        expect(html.contains("data-browser-action=\"toggle-devtools\"")).to_equal(true)
        expect(html.contains("data-browser-action=\"toggle-fullscreen\"")).to_equal(true)

    it "renders the address bar as editable escaped input":
        val snap = _snapshot("https://example.com/?q=one&two=2")
        val result = render_browser_ui(_html_config(), snap)
        val html = result.html_output
        expect(html.contains("name=\"url\"")).to_equal(true)
        expect(html.contains("readonly")).to_equal(false)
        expect(html.contains("value=\"https://example.com/?q=one&amp;two=2\"")).to_equal(true)

    it "renders browser chrome event glue for host dispatch":
        val snap = _snapshot("https://example.com")
        val result = render_browser_ui(_html_config(), snap)
        val html = result.html_output
        expect(html.contains("window.SimpleBrowserDispatch")).to_equal(true)
        expect(html.contains("simple-browser-action")).to_equal(true)
        expect(html.contains("emitBrowserAction(\"address-submit\"")).to_equal(true)
        expect(html.contains("data-browser-input=\\\"find\\\"")).to_equal(true)

    it "renders fetched BrowserApp page state through snapshot adapter":
        var registry = MockResponseRegistry.create()
        registry.register("snapshot.example", 200, "<html><body><h1>Snapshot Page</h1><p>visible text</p><div>ready</div></body></html>")
        set_mock_registry(registry)
        var app = _app()
        expect(_ok(app.handle_command(BrowserCommand.NewTab))).to_equal(true)
        expect(_ok(app.handle_command(BrowserCommand.Navigate("https://snapshot.example/page")))).to_equal(true)
        val snap = browser_snapshot_from_app(app)
        val result = render_browser_ui(_html_config(), snap)
        expect(snap.page_title).to_equal("Snapshot Page")
        expect(snap.page_text_content).to_contain("visible text")
        expect(snap.current_url).to_equal("https://snapshot.example/page")
        expect(result.html_output.contains("Snapshot Page")).to_equal(true)
        expect(result.html_output.contains("visible text")).to_equal(true)
