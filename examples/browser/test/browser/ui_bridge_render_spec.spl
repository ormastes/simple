use std.spec.*
use app.ui.render.types.{RenderConfig}
use examples.browser.ui_bridge.{BrowserSnapshot, render_browser_ui}
use examples.browser.entity.browser.navigation_types.{NavigationState}

fn _html_config() -> RenderConfig:
    RenderConfig(
        mode: "render",
        backend: "auto",
        format: "html",
        width: 100,
        height: 30,
        theme: "dark",
        asset_path: "",
        output_path: "",
        adapter_name: "browser",
        use_default_demo: false
    )

fn _snapshot(url: text) -> BrowserSnapshot:
    BrowserSnapshot(
        tabs: [],
        active_tab_id: 0,
        tab_groups: [],
        current_url: url,
        page_title: "Example",
        page_text_content: "",
        nav_state: NavigationState.Idle,
        load_progress: 100,
        is_secure: true,
        cookies: [],
        network_entries: [],
        console_entries: [],
        dom_nodes: [],
        css_declarations: [],
        bytes_transferred: 0,
        load_time_ms: 0,
        window: nil
    )

describe "Browser UI bridge rendering":
    it "renders bindable browser chrome actions":
        val snap = _snapshot("https://example.com/?q=one&two=2")
        val result = render_browser_ui(_html_config(), snap)
        val html = result.html_output
        expect(html.contains("data-browser-action=\"back\"")).to_equal(true)
        expect(html.contains("data-browser-action=\"forward\"")).to_equal(true)
        expect(html.contains("data-browser-action=\"reload\"")).to_equal(true)
        expect(html.contains("data-browser-action=\"new-tab\"")).to_equal(true)
        expect(html.contains("data-browser-action=\"close-tab\"")).to_equal(true)
        expect(html.contains("data-browser-action=\"address-submit\"")).to_equal(true)

    it "renders the address bar as editable escaped input":
        val snap = _snapshot("https://example.com/?q=one&two=2")
        val result = render_browser_ui(_html_config(), snap)
        val html = result.html_output
        expect(html.contains("name=\"url\"")).to_equal(true)
        expect(html.contains("readonly")).to_equal(false)
        expect(html.contains("value=\"https://example.com/?q=one&amp;two=2\"")).to_equal(true)
