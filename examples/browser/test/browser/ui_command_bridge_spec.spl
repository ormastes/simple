use std.spec.*
use examples.browser.transform.ui_to_dom.{
    BrowserChromeAction, UiBrowserCommandBridge,
    browser_chrome_action_from_host, browser_command_for_chrome_action
}
use examples.browser.feature.browser.app.{BrowserApp, BrowserCommand}
use examples.browser.shared.error.{BrowserResult}
use examples.browser.shared.config.{BrowserConfig}
use examples.browser.shared.logging.{Logger}
use examples.browser.entity.browser.tab_types.{TabState}
use examples.browser.entity.browser.navigation_types.{NavigationState}
use examples.browser.feature.browser.tab_manager.{TabManager}
use examples.browser.feature.browser.navigation.{NavigationController}

fn _config() -> BrowserConfig:
    BrowserConfig(
        name: "simple-browser-platform",
        version: "0.1.0",
        homepage: "about:blank",
        user_agent: "SimpleBrowser/0.1",
        tab_limit: 8,
        process_model: "site-per-process",
        default_encoding: "utf-8",
        max_history_entries: 1000,
        max_connections_per_host: 6,
        max_total_connections: 64,
        dns_cache_ttl: 300,
        http_cache_size_mb: 256,
        cookie_policy: "same-site-lax",
        connect_timeout_ms: 30000,
        read_timeout_ms: 60000,
        gpu_compositing: true,
        hardware_acceleration: true,
        max_texture_size: 4096,
        tile_size: 256,
        target_fps: 60,
        csp_default: "default-src 'self'",
        mixed_content: "block"
    )

fn _app() -> BrowserApp:
    val logger = Logger(name: "ui-command-bridge-test")
    val config = _config()
    BrowserApp(
        windows: [],
        active_window: 0,
        config: config,
        is_running: false,
        next_window_id: 1,
        logger: logger,
        tab_manager: TabManager(
            tabs: [],
            active_tab_id: 0,
            tab_groups: [],
            next_tab_id: 1,
            next_group_id: 1,
            max_tabs: config.tab_limit,
            logger: logger
        ),
        navigation: NavigationController(
            entries: [],
            current_index: -1,
            is_loading: false,
            state: NavigationState.Idle,
            logger: logger
        ),
        last_find_query: "",
        zoom_percent: 100,
        devtools_open: false
    )

fn _ok(result: BrowserResult<()>) -> bool:
    match result:
        Ok(_): true
        Err(_): false

fn _is_navigate_to(cmd: BrowserCommand, expected: text) -> bool:
    match cmd:
        BrowserCommand.Navigate(url):
            url == expected
        _:
            false

fn _host_action_ok(action_name: text, value: text) -> bool:
    match browser_chrome_action_from_host(action_name, value):
        Ok(_): true
        Err(_): false

describe "UI browser command bridge":
    it "maps address bar submissions to app navigation commands":
        val cmd = browser_command_for_chrome_action(BrowserChromeAction.AddressSubmit("example.com"))
        expect(_is_navigate_to(cmd, "example.com")).to_equal(true)

    it "decodes host browser action payloads":
        expect(_host_action_ok("address-submit", "example.com")).to_equal(true)
        expect(_host_action_ok("back", "")).to_equal(true)
        expect(_host_action_ok("new-tab", "")).to_equal(true)
        expect(_host_action_ok("unknown", "")).to_equal(false)

    it "dispatches address bar submissions through BrowserApp state":
        var app = _app()
        val bridge = UiBrowserCommandBridge.new(Logger(name: "ui-command-bridge-test"))
        expect(_ok(bridge.dispatch(app, BrowserChromeAction.NewTab))).to_equal(true)
        expect(_ok(bridge.dispatch(app, BrowserChromeAction.AddressSubmit("example.com")))).to_equal(true)
        expect(app.navigation.current_url()).to_equal("https://example.com")
        expect(app.tab_manager.get_active_tab().unwrap().url).to_equal("https://example.com")
        expect(app.tab_manager.get_active_tab().unwrap().state).to_equal(TabState.Loading)

    it "dispatches toolbar history and reload actions through BrowserApp":
        var app = _app()
        val bridge = UiBrowserCommandBridge.new(Logger(name: "ui-command-bridge-test"))
        expect(_ok(bridge.dispatch(app, BrowserChromeAction.NewTab))).to_equal(true)
        expect(_ok(bridge.dispatch(app, BrowserChromeAction.AddressSubmit("https://a.example")))).to_equal(true)
        expect(_ok(bridge.dispatch(app, BrowserChromeAction.AddressSubmit("https://b.example")))).to_equal(true)
        expect(_ok(bridge.dispatch(app, BrowserChromeAction.Back))).to_equal(true)
        expect(app.navigation.current_url()).to_equal("https://a.example")
        expect(_ok(bridge.dispatch(app, BrowserChromeAction.Forward))).to_equal(true)
        expect(app.navigation.current_url()).to_equal("https://b.example")
        expect(_ok(bridge.dispatch(app, BrowserChromeAction.Reload))).to_equal(true)
        expect(app.navigation.is_loading).to_equal(true)

    it "dispatches browser chrome state actions through BrowserApp":
        var app = _app()
        val bridge = UiBrowserCommandBridge.new(Logger(name: "ui-command-bridge-test"))
        val window_id = app.create_window().unwrap()
        app.active_window = window_id
        expect(_ok(bridge.dispatch(app, BrowserChromeAction.NewTab))).to_equal(true)
        expect(_ok(bridge.dispatch(app, BrowserChromeAction.NewTab))).to_equal(true)
        expect(app.tab_manager.get_tab_count()).to_equal(2)
        expect(_ok(bridge.dispatch(app, BrowserChromeAction.CloseTab))).to_equal(true)
        expect(app.tab_manager.get_tab_count()).to_equal(1)
        expect(_ok(bridge.dispatch(app, BrowserChromeAction.Find("needle")))).to_equal(true)
        expect(app.last_find_query).to_equal("needle")
        expect(_ok(bridge.dispatch(app, BrowserChromeAction.ZoomIn))).to_equal(true)
        expect(app.zoom_percent).to_equal(110)
        expect(_ok(bridge.dispatch(app, BrowserChromeAction.ZoomReset))).to_equal(true)
        expect(app.zoom_percent).to_equal(100)
        expect(_ok(bridge.dispatch(app, BrowserChromeAction.ToggleDevtools))).to_equal(true)
        expect(app.devtools_open).to_equal(true)
        expect(_ok(bridge.dispatch(app, BrowserChromeAction.ToggleFullscreen))).to_equal(true)
        expect(app.windows[0].is_fullscreen).to_equal(true)

    it "dispatches host browser action payloads through BrowserApp":
        var app = _app()
        val bridge = UiBrowserCommandBridge.new(Logger(name: "ui-command-bridge-test"))
        expect(_ok(bridge.dispatch_host_action(app, "new-tab", ""))).to_equal(true)
        expect(_ok(bridge.dispatch_host_action(app, "address-submit", "example.com"))).to_equal(true)
        expect(app.navigation.current_url()).to_equal("https://example.com")
        expect(_ok(bridge.dispatch_host_action(app, "find", "needle"))).to_equal(true)
        expect(app.last_find_query).to_equal("needle")
