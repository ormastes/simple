#![allow(REQC004)]
#![allow(unnamed_duplicate_typed_args)]

use examples.browser.feature.browser.storage.{StorageManager}
use examples.browser.shared.logging.{Logger, LogLevel}

fn make_storage() -> StorageManager:
    StorageManager.new(Logger.new("storage-spec", LogLevel.Error))

describe "StorageManager IndexedDB":
    it "opens databases per origin instead of sharing by name":
        var storage = make_storage()
        val a = storage.idb_open("https://a.test", "app", 1)
        val b = storage.idb_open("https://b.test", "app", 1)

        match a:
            Ok(a_id):
                match b:
                    Ok(b_id):
                        expect a_id == b_id == false
                        expect storage.databases[a_id].origin == "https://a.test"
                        expect storage.databases[b_id].origin == "https://b.test"
                    Err(e): expect(e.message).to_equal("ok")
            Err(e): expect(e.message).to_equal("ok")

    it "preserves object stores while upgrading the database version":
        var storage = make_storage()
        val opened = storage.idb_open("https://app.test", "app", 1)
        match opened:
            Ok(db_id):
                storage.idb_create_object_store(db_id, "items")
                storage.idb_put(db_id, "items", "a", "one")
                val upgraded = storage.idb_open("https://app.test", "app", 2)
                match upgraded:
                    Ok(upgraded_id):
                        expect upgraded_id == db_id
                        expect storage.databases[db_id].version == 2
                        match storage.idb_get(db_id, "items", "a"):
                            Ok(Some(value)): expect(value).to_equal("one")
                            Ok(nil): expect("missing").to_equal("value")
                            Err(e): expect(e.message).to_equal("ok")
                    Err(e): expect(e.message).to_equal("ok")
            Err(e): expect(e.message).to_equal("ok")

    it "puts updates deletes and clears records in object stores":
        var storage = make_storage()
        val opened = storage.idb_open("https://app.test", "app", 1)
        match opened:
            Ok(db_id):
                storage.idb_create_object_store(db_id, "items")
                storage.idb_put(db_id, "items", "a", "one")
                storage.idb_put(db_id, "items", "a", "two")
                match storage.idb_get(db_id, "items", "a"):
                    Ok(Some(value)): expect(value).to_equal("two")
                    Ok(nil): expect("missing").to_equal("value")
                    Err(e): expect(e.message).to_equal("ok")

                match storage.idb_delete(db_id, "items", "a"):
                    Ok(deleted): expect(deleted).to_equal(true)
                    Err(e): expect(e.message).to_equal("ok")
                expect storage.idb_get(db_id, "items", "a") == Ok(nil)

                storage.idb_put(db_id, "items", "b", "three")
                storage.idb_clear(db_id, "items")
                expect storage.idb_get(db_id, "items", "b") == Ok(nil)
            Err(e): expect(e.message).to_equal("ok")

    it "includes IndexedDB records in origin usage":
        var storage = make_storage()
        val opened = storage.idb_open("https://app.test", "app", 1)
        match opened:
            Ok(db_id):
                storage.idb_create_object_store(db_id, "items")
                storage.idb_put(db_id, "items", "abc", "value")

                expect storage.get_storage_usage("https://app.test") == 8
                expect storage.get_storage_usage("https://other.test") == 0
            Err(e): expect(e.message).to_equal("ok")