use examples.browser.feature.browser.password_store.{PasswordStore, hash_password}
use examples.browser.shared.logging.{Logger, LogLevel}

fn make_store() -> PasswordStore:
    PasswordStore.new(Logger.new("password-store-spec", LogLevel.Error))

describe "PasswordStore":
    it "stores versioned salted password verifiers instead of plaintext or legacy hashes":
        var store = make_store()
        val id = store.save_credential("https://example.test", "alice", "correct horse")
        val creds = store.get_credentials("https://example.test")
        val stored_hash = creds[0].password_hash

        expect id == 1
        expect creds.len() == 1
        expect stored_hash.starts_with("pbkdf-lite-v1:512:s1-") == true
        expect stored_hash == "correct horse" == false
        expect stored_hash.starts_with("hash:") == false

    it "verifies the current password and rejects wrong origins or passwords":
        var store = make_store()
        store.save_credential("https://example.test", "alice", "secret")

        expect store.verify_credential("https://example.test", "alice", "secret") == true
        expect store.verify_credential("https://example.test", "alice", "wrong") == false
        expect store.verify_credential("https://other.test", "alice", "secret") == false

    it "updates existing credentials without creating duplicates":
        var store = make_store()
        val first = store.save_credential("https://example.test", "alice", "old")
        val second = store.save_credential("https://example.test", "alice", "new")

        expect second == first
        expect store.get_credential_count() == 1
        expect store.verify_credential("https://example.test", "alice", "old") == false
        expect store.verify_credential("https://example.test", "alice", "new") == true

    it "keeps deterministic legacy hash helper versioned for compatibility callers":
        val hashed = hash_password("secret")

        expect hashed.starts_with("pbkdf-lite-v1:512:") == true
        expect hashed.starts_with("hash:") == false