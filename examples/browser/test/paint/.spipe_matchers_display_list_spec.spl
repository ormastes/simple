#![allow(spipe_placeholder_tests)]
#![allow(REQC001)]
#![allow(REQC004)]
#![allow(unnamed_duplicate_typed_args)]
"""
# Display List

Tests for display list functionality.
"""
#![allow(unnamed_duplicate_typed_args)]
use std.spec
use examples.browser.entity.dom.paint_types.{Color, PaintOp, DisplayList, DisplayItem, from_rgb, black, transparent}
use examples.browser.entity.dom.box_types.{LayoutBox, BoxKind, BoxModel}
use examples.browser.feature.paint.display_list.{DisplayListBuilder}
use examples.browser.feature.style.computed.{ComputedStyle}
use examples.browser.shared.logging.{Logger}
# Color is imported from paint_types (which already uses std.common.color.types).
# Computed style subset needed for painting
class PaintStyle:
    background_color: Color
    color: Color
    visibility: text
    display: text
    overflow: text
    opacity: f64

    static fn default() -> PaintStyle:
        PaintStyle(
            background_color: transparent(),
            color: black(),
            visibility: "visible",
            display: "block",
            overflow: "visible",
            opacity: 1.0
        )

# A paintable node combining layout box and style
class PaintNode:
    layout: LayoutBox
    style: PaintStyle
    text_content: text
    image_id: i64
    children: [PaintNode]

    static fn create(layout: LayoutBox, style: PaintStyle) -> PaintNode:
        PaintNode(
            layout: layout,
            style: style,
            text_content: "",
            image_id: -1,
            children: []
        )

fn zero_box_model() -> BoxModel:
    BoxModel(
        margin_top: 0.0, margin_right: 0.0, margin_bottom: 0.0, margin_left: 0.0,
        border_top: 0.0, border_right: 0.0, border_bottom: 0.0, border_left: 0.0,
        padding_top: 0.0, padding_right: 0.0, padding_bottom: 0.0, padding_left: 0.0
    )

fn make_paint_node(layout: LayoutBox, style: PaintStyle) -> PaintNode:
    PaintNode(
        layout: layout,
        style: style,
        text_content: "",
        image_id: -1,
        children: []
    )

# Build display list from a paint node tree
fn build_display_list(node: PaintNode) -> DisplayList:
    var dl = DisplayList(ops: [])
    if node.style.display == "none":
        return dl
    if node.style.visibility == "hidden":
        return dl

    # Push clip for overflow hidden
    if node.style.overflow == "hidden":
        var clip = PaintOp.PushClip(
            x: node.layout.x, y: node.layout.y,
            w: node.layout.width, h: node.layout.height
        )
        dl.ops.push(clip)

    # Push opacity if < 1
    if node.style.opacity < 1.0:
        dl.ops.push(PaintOp.PushOpacity(alpha: node.style.opacity))

    # Background color
    if node.style.background_color.a > 0:
        var fill = PaintOp.FillRect(
            x: node.layout.x, y: node.layout.y,
            w: node.layout.width, h: node.layout.height,
            color: node.style.background_color
        )
        dl.ops.push(fill)

    # Border
    var bm = node.layout.box_model
    if bm.border_top > 0.0 or bm.border_right > 0.0 or bm.border_bottom > 0.0 or bm.border_left > 0.0:
        var border = PaintOp.DrawBorder(
            x: node.layout.x, y: node.layout.y,
            w: node.layout.width, h: node.layout.height,
            widths: [bm.border_top, bm.border_right, bm.border_bottom, bm.border_left],
            colors: [black(), black(), black(), black()]
        )
        dl.ops.push(border)

    # Text
    if node.text_content != "":
        var text_op = PaintOp.DrawText(
            x: node.layout.x, y: node.layout.y,
            text_content: node.text_content,
            font_size: 16.0,
            color: node.style.color
        )
        dl.ops.push(text_op)

    # Image
    if node.image_id >= 0:
        var img = PaintOp.DrawImage(
            x: node.layout.x, y: node.layout.y,
            w: node.layout.width, h: node.layout.height,
            image_id: node.image_id,
            src_url: ""
        )
        dl.ops.push(img)

    # Children
    for child in node.children:
        var child_dl = build_display_list(child)
        for op in child_dl.ops:
            dl.ops.push(op)

    # Pop opacity
    if node.style.opacity < 1.0:
        dl.ops.push(PaintOp.PopOpacity)

    # Pop clip
    if node.style.overflow == "hidden":
        dl.ops.push(PaintOp.PopClip)

    dl

# Helper to make a simple layout box
fn make_box(x: f64, y: f64, w: f64, h: f64) -> LayoutBox:
    var box = LayoutBox(
        node_id: 0, kind: BoxKind.Block,
        x: 0.0, y: 0.0, width: 0.0, height: 0.0,
        box_model: zero_box_model(), text_content: "", children: []
    )
    box.x = x
    box.y = y
    box.width = w
    box.height = h
    box

fn make_box_with_border(x: f64, y: f64, w: f64, h: f64, bw: f64) -> LayoutBox:
    var box = make_box(x, y, w, h)
    box.box_model.border_top = bw
    box.box_model.border_right = bw
    box.box_model.border_bottom = bw
    box.box_model.border_left = bw
    box

fn count_ops_of_kind(dl: DisplayList, kind: text) -> i64:
    var count = 0
    for op in dl.ops:
        match op:
            FillRect(x, y, w, h, color):
                if kind == "FillRect":
                    count = count + 1
            DrawText(x, y, text_content, font_size, color):
                if kind == "DrawText":
                    count = count + 1
            DrawBorder(x, y, w, h, widths, colors):
                if kind == "DrawBorder":
                    count = count + 1
            DrawImage(x, y, w, h, image_id, src_url):
                if kind == "DrawImage":
                    count = count + 1
            PushClip(x, y, w, h):
                if kind == "PushClip":
                    count = count + 1
            PopClip:
                if kind == "PopClip":
                    count = count + 1
            PushOpacity(alpha):
                if kind == "PushOpacity":
                    count = count + 1
            PopOpacity:
                if kind == "PopOpacity":
                    count = count + 1
    count

describe "DisplayList":
    """
    ## Displaylist Tests

    Validates DisplayList functionality.
    """

    describe "basic painting":
        it "empty layout produces empty display list":
            var layout = make_box(0.0, 0.0, 0.0, 0.0)
            var style = PaintStyle.default()
            var node = make_paint_node(layout, style)
            var dl = build_display_list(node)
            expect dl.ops.len() == 0

        it "single box generates fill rect":
            var layout = make_box(10.0, 20.0, 100.0, 50.0)
            var style = PaintStyle.default()
            style.background_color = from_rgb(255, 0, 0)
            var node = make_paint_node(layout, style)
            var dl = build_display_list(node)
            expect count_ops_of_kind(dl, "FillRect") == 1

        it "box with text generates draw text":
            var layout = make_box(0.0, 0.0, 200.0, 30.0)
            var style = PaintStyle.default()
            var node = make_paint_node(layout, style)
            node.text_content = "Hello"
            var dl = build_display_list(node)
            expect count_ops_of_kind(dl, "DrawText") == 1

        it "real display list builder carries layout text into DrawText":
            var layout = LayoutBox.create(0, BoxKind.Inline)
            layout.x = 0.0
            layout.y = 0.0
            layout.width = 200.0
            layout.height = 30.0
            layout.text_content = "Hello"
            var style = ComputedStyle.default_style()
            style.display = "inline"
            var builder = DisplayListBuilder.new(Logger(name: "display-list-spec"))

            val dl = builder.build(layout, [style])

            var found_text = ""
            for op in dl.ops:
                match op:
                    DrawText(x, y, text_content, font_size, color):
                        found_text = text_content
                    _: pass_dn
            expect found_text == "Hello"

        it "background color generates fill rect with correct color":
            var layout = make_box(0.0, 0.0, 100.0, 100.0)
            var style = PaintStyle.default()
            style.background_color = from_rgb(0, 128, 255)
            var node = make_paint_node(layout, style)
            var dl = build_display_list(node)
            var fill_found = false
            for op in dl.ops:
                match op:
                    FillRect(x, y, w, h, color):
                        fill_found = true
                        expect color.r == 0
                        expect color.g == 128
                        expect color.b == 255
                    _: pass_dn
            expect fill_found == true

    describe "borders":
        it "border generates draw border op":
            var layout = make_box_with_border(0.0, 0.0, 100.0, 100.0, 2.0)
            var style = PaintStyle.default()
            var node = make_paint_node(layout, style)
            var dl = build_display_list(node)
            expect count_ops_of_kind(dl, "DrawBorder") == 1

    describe "visibility and display":
        it "hidden visibility skips painting":
            var layout = make_box(0.0, 0.0, 100.0, 100.0)
            var style = PaintStyle.default()
            style.visibility = "hidden"
            style.background_color = from_rgb(255, 0, 0)
            var node = make_paint_node(layout, style)
            var dl = build_display_list(node)
            expect dl.ops.len() == 0

        it "display none skips painting":
            var layout = make_box(0.0, 0.0, 100.0, 100.0)
            var style = PaintStyle.default()
            style.display = "none"
            style.background_color = from_rgb(255, 0, 0)
            var node = make_paint_node(layout, style)
            var dl = build_display_list(node)
            expect dl.ops.len() == 0

    describe "clipping and opacity":
        it "clip rect pushed for overflow hidden":
            var layout = make_box(10.0, 20.0, 200.0, 100.0)
            var style = PaintStyle.default()
            style.overflow = "hidden"
            style.background_color = from_rgb(200, 200, 200)
            var node = make_paint_node(layout, style)
            var dl = build_display_list(node)
            expect count_ops_of_kind(dl, "PushClip") == 1
            expect count_ops_of_kind(dl, "PopClip") == 1

        it "opacity pushes PushOpacity":
            var layout = make_box(0.0, 0.0, 100.0, 100.0)
            var style = PaintStyle.default()
            style.opacity = 0.5
            style.background_color = from_rgb(255, 0, 0)
            var node = make_paint_node(layout, style)
            var dl = build_display_list(node)
            expect count_ops_of_kind(dl, "PushOpacity") == 1
            expect count_ops_of_kind(dl, "PopOpacity") == 1

    describe "tree order and content types":
        it "nested boxes paint in tree order":
            var parent_layout = make_box(0.0, 0.0, 300.0, 200.0)
            var parent_style = PaintStyle.default()
            parent_style.background_color = from_rgb(200, 200, 200)
            var parent_node = make_paint_node(parent_layout, parent_style)

            var child_layout = make_box(10.0, 10.0, 100.0, 50.0)
            var child_style = PaintStyle.default()
            child_style.background_color = from_rgb(100, 100, 100)
            var child_node = make_paint_node(child_layout, child_style)

            parent_node.children = [child_node]
            var dl = build_display_list(parent_node)
            # Parent fill first, then child fill
            expect count_ops_of_kind(dl, "FillRect") == 2
            expect dl.ops.len() == 2

        it "text color uses computed color":
            var layout = make_box(0.0, 0.0, 200.0, 30.0)
            var style = PaintStyle.default()
            style.color = from_rgb(255, 0, 0)
            var node = make_paint_node(layout, style)
            node.text_content = "Red text"
            var dl = build_display_list(node)
            var found_text = false
            for op in dl.ops:
                match op:
                    DrawText(x, y, text_content, font_size, color):
                        found_text = true
                        expect color.r == 255
                        expect color.g == 0
                    _: pass_dn
            expect found_text == true

        it "image generates DrawImage op":
            var layout = make_box(0.0, 0.0, 200.0, 150.0)
            var style = PaintStyle.default()
            var node = make_paint_node(layout, style)
            node.image_id = 42
            var dl = build_display_list(node)
            expect count_ops_of_kind(dl, "DrawImage") == 1