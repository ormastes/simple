fn _tiff_palette_colormap_red_green() -> text:
    var out = ""
    var i = 0
    while i < 256:
        if i == 0:
            out = out + _bytes([255, 255])
        else:
            out = out + _bytes([0, 0])
        i = i + 1
    i = 0
    while i < 256:
        if i == 1:
            out = out + _bytes([255, 255])
        else:
            out = out + _bytes([0, 0])
        i = i + 1
    i = 0
    while i < 256:
        out = out + _bytes([0, 0])
        i = i + 1
    out

