fn _bytes(values: [i64]) -> text:
    var out = ""
    var i = 0
    while i < values.len():
        val item = values.get(i)
        if val b = item:
            out = out + _fixture_byte(b)
        i = i + 1
    out

fn _fixture_byte(value: i64) -> text:
    if value == 0:
        return "\0"
    if value == 1:
        return "\x01"
    if value == 2:
        return "\x02"
    if value == 3:
        return "\x03"
