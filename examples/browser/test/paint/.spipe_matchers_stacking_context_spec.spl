#![allow(REQC001)]
#![allow(REQC004)]
#![allow(unnamed_duplicate_typed_args)]
"""
# Stacking Context

Tests for stacking context functionality.
"""
#![allow(unnamed_duplicate_typed_args)]
use std.spec

# StackingContext.z_index uses i64 directly — this is intentional for simplicity at this layer.
# Stacking context entry
class StackingContext:
    node_id: i64
    z_index: i64
    opacity: f64
    is_positioned: bool
    children: [StackingContext]

    static fn create(node_id: i64, z_index: i64) -> StackingContext:
        StackingContext(
            node_id: node_id,
            z_index: z_index,
            opacity: 1.0,
            is_positioned: false,
            children: []
        )

    static fn positioned(node_id: i64, z_index: i64) -> StackingContext:
        StackingContext(
            node_id: node_id,
            z_index: z_index,
            opacity: 1.0,
            is_positioned: true,
            children: []
        )

# Check if an element creates a stacking context
fn creates_stacking_context(is_root: bool, is_positioned: bool, z_index: i64, opacity: f64) -> bool:
    if is_root:
        return true
    if is_positioned and z_index != 0:
        return true
    if opacity < 1.0:
        return true
    false

# Categorize children into negative z-index, zero, and positive z-index groups
class PaintOrder:
    negative: [StackingContext]
    zero: [StackingContext]
    positive: [StackingContext]

    static fn empty() -> PaintOrder:
        PaintOrder(
            negative: [],
            zero: [],
            positive: []
        )

fn categorize_children(children: [StackingContext]) -> PaintOrder:
    var order = PaintOrder(negative: [], zero: [], positive: [])
    for child in children:
        if child.z_index < 0:
            order.negative = order.negative + [child]
        else:
            if child.z_index == 0:
                order.zero = order.zero + [child]
            else:
                order.positive = order.positive + [child]
    order

# Sort stacking contexts by z-index (simple insertion sort)
fn sort_by_z_index(contexts: [StackingContext]) -> [StackingContext]:
    var sorted: [StackingContext] = []
    for ctx in contexts:
        sorted = sorted + [ctx]
    var n = sorted.len()
    var i = 1
    while i < n:
        var j = i
        while j > 0 and sorted[j - 1].z_index > sorted[j].z_index:
            var tmp = sorted[j - 1]
            sorted[j - 1] = sorted[j]
            sorted[j] = tmp
            j = j - 1
        i = i + 1
    sorted

# Flatten stacking contexts into paint order (node_id list)
fn flatten_paint_order(ctx: StackingContext) -> [i64]:
    var result: [i64] = []
    var order = categorize_children(ctx.children)
    # 1. Negative z-index children
    var neg_sorted = sort_by_z_index(order.negative)
    for c in neg_sorted:
        var sub = flatten_paint_order(c)
        for id in sub:
            result = result + [id]
    # 2. Current element
    result = result + [ctx.node_id]
    # 3. Zero z-index children (source order)
    for c in order.zero:
        var sub = flatten_paint_order(c)
        for id in sub:
            result = result + [id]
    # 4. Positive z-index children
    var pos_sorted = sort_by_z_index(order.positive)
    for c in pos_sorted:
        var sub = flatten_paint_order(c)
        for id in sub:
            result = result + [id]
    result

describe "StackingContext":
    """
    ## Stackingcontext Tests

    Validates StackingContext functionality.
    """

    describe "context creation":
        it "root element creates stacking context":
            var result = creates_stacking_context(true, false, 0, 1.0)
            expect result == true

        it "positioned element with z-index creates context":
            var result = creates_stacking_context(false, true, 5, 1.0)
            expect result == true

        it "opacity less than 1 creates context":
            var result = creates_stacking_context(false, false, 0, 0.5)
            expect result == true

        it "non-positioned elements don't create context":
            var result = creates_stacking_context(false, false, 0, 1.0)
            expect result == false

    describe "paint ordering":
        it "negative z-index paints before positive":
            var root = StackingContext(node_id: 0, z_index: 0, opacity: 1.0, is_positioned: false, children: [])
            var neg_child = StackingContext(node_id: 1, z_index: -1, opacity: 1.0, is_positioned: true, children: [])
            var pos_child = StackingContext(node_id: 2, z_index: 1, opacity: 1.0, is_positioned: true, children: [])
            root.children = [pos_child, neg_child]
            var order = flatten_paint_order(root)
            # negative(-1) first, then root(0), then positive(1)
            expect order[0] == 1
            expect order[1] == 0
            expect order[2] == 2

        it "z-index 0 paints between negative and positive":
            var root = StackingContext(node_id: 0, z_index: 0, opacity: 1.0, is_positioned: false, children: [])
            var neg = StackingContext(node_id: 1, z_index: -2, opacity: 1.0, is_positioned: true, children: [])
            var zero = StackingContext(node_id: 2, z_index: 0, opacity: 1.0, is_positioned: false, children: [])
            var pos = StackingContext(node_id: 3, z_index: 5, opacity: 1.0, is_positioned: true, children: [])
            root.children = [pos, neg, zero]
            var order = flatten_paint_order(root)
            expect order[0] == 1
            expect order[1] == 0
            expect order[2] == 2
            expect order[3] == 3

        it "same z-index preserves source order":
            var root = StackingContext(node_id: 0, z_index: 0, opacity: 1.0, is_positioned: false, children: [])
            var a = StackingContext(node_id: 1, z_index: 0, opacity: 1.0, is_positioned: false, children: [])
            var b = StackingContext(node_id: 2, z_index: 0, opacity: 1.0, is_positioned: false, children: [])
            var c = StackingContext(node_id: 3, z_index: 0, opacity: 1.0, is_positioned: false, children: [])
            root.children = [a, b, c]
            var order = flatten_paint_order(root)
            # root painted, then children in source order
            expect order[0] == 0
            expect order[1] == 1
            expect order[2] == 2
            expect order[3] == 3

        it "nested stacking contexts":
            var root = StackingContext(node_id: 0, z_index: 0, opacity: 1.0, is_positioned: false, children: [])
            var child = StackingContext(node_id: 1, z_index: 1, opacity: 1.0, is_positioned: true, children: [])
            var grandchild = StackingContext(node_id: 2, z_index: 2, opacity: 1.0, is_positioned: true, children: [])
            child.children = [grandchild]
            root.children = [child]
            var order = flatten_paint_order(root)
            expect order[0] == 0
            expect order[1] == 1
            expect order[2] == 2

    describe "special descendants":
        it "float descendants paint after block descendants":
            # Floats paint in layer 4 (after in-flow blocks in layer 3)
            var block_layer = 3
            var float_layer = 4
            expect float_layer > block_layer

        it "inline descendants paint after floats":
            # Inline/text content is in layer 5 (after floats in layer 4)
            var float_layer = 4
            var inline_layer = 5
            expect inline_layer > float_layer