#![allow(REQC001)]
#![allow(REQC004)]
#![allow(unnamed_duplicate_typed_args)]
"""
# Display List

Production-backed tests for converting layout boxes and computed styles into
paint operations.
"""

use std.spec
use examples.browser.entity.dom.box_types.{LayoutBox, BoxKind, BoxModel}
use examples.browser.entity.dom.css_types.{CSSValue}
use examples.browser.entity.dom.paint_types.{DisplayList, PaintOp, from_rgb}
use examples.browser.feature.paint.display_list.{DisplayListBuilder}
use examples.browser.feature.style.computed.{ComputedStyle}
use examples.browser.shared.logging.{Logger}

fn make_box(node_id: i64, kind: BoxKind, x: f64, y: f64, w: f64, h: f64) -> LayoutBox:
    var box = LayoutBox.create(node_id, kind)
    box.x = x
    box.y = y
    box.width = w
    box.height = h
    box

fn builder() -> DisplayListBuilder:
    DisplayListBuilder.new(Logger(name: "display-list-spec"))

fn transparent_style() -> ComputedStyle:
    ComputedStyle.default_style()

fn colored_style(r: i64, g: i64, b: i64) -> ComputedStyle:
    var style = ComputedStyle.default_style()
    style.display = "block"
    style.background_color = CSSValue.Color(color: from_rgb(r, g, b))
    style

fn styles_for_two(root: ComputedStyle, child: ComputedStyle) -> [ComputedStyle]:
    [root, child]

fn count_ops_of_kind(dl: DisplayList, kind: text) -> i64:
    var count = 0
    for op in dl.ops:
        match op:
            FillRect(x, y, w, h, color):
                if kind == "FillRect":
                    count = count + 1
            DrawText(x, y, text_content, font_size, color):
                if kind == "DrawText":
                    count = count + 1
            DrawBorder(x, y, w, h, widths, colors):
                if kind == "DrawBorder":
                    count = count + 1
            DrawImage(x, y, w, h, image_id, src_url):
                if kind == "DrawImage":
                    count = count + 1
            PushClip(x, y, w, h):
                if kind == "PushClip":
                    count = count + 1
            PopClip:
                if kind == "PopClip":
                    count = count + 1
            PushOpacity(alpha):
                if kind == "PushOpacity":
                    count = count + 1
            PopOpacity:
                if kind == "PopOpacity":
                    count = count + 1
            PushTransform(matrix):
                if kind == "PushTransform":
                    count = count + 1
            PopTransform:
                if kind == "PopTransform":
                    count = count + 1
            _: pass_dn
    count

describe "DisplayListBuilder":
    context "basic painting":
        it "transparent box produces no paint ops":
            val root = make_box(0, BoxKind.Block, 0.0, 0.0, 100.0, 50.0)
            val dl = builder().build(root, [transparent_style()])

            expect(dl.ops.len()).to_equal(0)

        it "background color generates a FillRect from computed style":
            val root = make_box(0, BoxKind.Block, 10.0, 20.0, 100.0, 50.0)
            val dl = builder().build(root, [colored_style(255, 0, 0)])

            expect(count_ops_of_kind(dl, "FillRect")).to_equal(1)
            match dl.ops[0]:
                FillRect(x, y, w, h, color):
                    expect(x).to_equal(10.0)
                    expect(y).to_equal(20.0)
                    expect(w).to_equal(100.0)
                    expect(h).to_equal(50.0)
                    expect(color.r).to_equal(255)
                _: expect(false).to_equal(true)

        it "inline text generates DrawText using computed color and font size":
            var root = make_box(0, BoxKind.Inline, 0.0, 0.0, 200.0, 30.0)
            root.text_content = "Hello"
            var style = transparent_style()
            style.display = "inline"
            style.color = CSSValue.Color(color: from_rgb(255, 0, 0))
            style.font_size = CSSValue.Length(v: 20.0, unit: "px")

            val dl = builder().build(root, [style])

            expect(count_ops_of_kind(dl, "DrawText")).to_equal(1)
            match dl.ops[0]:
                DrawText(x, y, text_content, font_size, color):
                    expect(text_content).to_equal("Hello")
                    expect(font_size).to_equal(20.0)
                    expect(color.r).to_equal(255)
                _: expect(false).to_equal(true)

    context "borders and effects":
        it "visible box borders generate DrawBorder":
            var root = make_box(0, BoxKind.Block, 0.0, 0.0, 100.0, 100.0)
            root.box_model = BoxModel(
                margin_top: 0.0, margin_right: 0.0, margin_bottom: 0.0, margin_left: 0.0,
                border_top: 2.0, border_right: 2.0, border_bottom: 2.0, border_left: 2.0,
                padding_top: 0.0, padding_right: 0.0, padding_bottom: 0.0, padding_left: 0.0
            )
            var style = transparent_style()
            style.display = "block"
            style.border_top_style = "solid"
            style.border_right_style = "solid"
            style.border_bottom_style = "solid"
            style.border_left_style = "solid"

            val dl = builder().build(root, [style])

            expect(count_ops_of_kind(dl, "DrawBorder")).to_equal(1)

        it "overflow hidden wraps painted content in clip ops":
            val root = make_box(0, BoxKind.Block, 5.0, 10.0, 200.0, 100.0)
            var style = colored_style(200, 200, 200)
            style.overflow_x = "hidden"
            style.overflow_y = "hidden"

            val dl = builder().build(root, [style])

            expect(count_ops_of_kind(dl, "PushClip")).to_equal(1)
            expect(count_ops_of_kind(dl, "PopClip")).to_equal(1)

        it "opacity wraps painted content in opacity ops":
            val root = make_box(0, BoxKind.Block, 0.0, 0.0, 100.0, 100.0)
            var style = colored_style(0, 128, 255)
            style.opacity = 0.5

            val dl = builder().build(root, [style])

            expect(count_ops_of_kind(dl, "PushOpacity")).to_equal(1)
            expect(count_ops_of_kind(dl, "PopOpacity")).to_equal(1)

    context "visibility and tree order":
        it "display none and hidden visibility skip paint":
            val root = make_box(0, BoxKind.Block, 0.0, 0.0, 100.0, 100.0)
            var none_style = colored_style(255, 0, 0)
            none_style.display = "none"
            var hidden_style = colored_style(255, 0, 0)
            hidden_style.visibility = "hidden"

            expect(builder().build(root, [none_style]).ops.len()).to_equal(0)
            expect(builder().build(root, [hidden_style]).ops.len()).to_equal(0)

        it "paints parent before child in layout tree order":
            var root = make_box(0, BoxKind.Block, 0.0, 0.0, 300.0, 200.0)
            val child = make_box(1, BoxKind.Block, 10.0, 10.0, 100.0, 50.0)
            root.children = [child]

            val dl = builder().build(
                root,
                styles_for_two(colored_style(200, 200, 200), colored_style(100, 100, 100))
            )

            expect(count_ops_of_kind(dl, "FillRect")).to_equal(2)
            match dl.ops[0]:
                FillRect(x, y, w, h, color):
                    expect(color.r).to_equal(200)
                _: expect(false).to_equal(true)
            match dl.ops[1]:
                FillRect(x, y, w, h, color):
                    expect(color.r).to_equal(100)
                _: expect(false).to_equal(true)
