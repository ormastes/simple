#![allow(REQC004)]
#![allow(unnamed_duplicate_typed_args)]

use std.spec
use examples.browser.feature.parser.html_tokenizer.{HtmlTokenizer}
use examples.browser.shared.logging.{Logger, LogLevel}

fn token_count(input: text) -> i64:
    var tokenizer = HtmlTokenizer.new(input, Logger.new("html-tokenizer-spec", LogLevel.Error))
    var count = 0
    var guard = 0
    while tokenizer.pos < input.len() and guard < 1000:
        guard = guard + 1
        tokenizer.next_token()
        count = count + 1
    count

describe "HtmlTokenizer":
    context "basic tokenization":
        it "tokenizes simple text":
            expect(token_count("Hello, world!")).to_equal(1)

        it "tokenizes start and end tags":
            expect(token_count("<p>Hello</p>")).to_be_greater_than(0)

        it "tokenizes self-closing tags":
            expect(token_count("<br/>")).to_equal(1)

        it "tokenizes attributes without crashing":
            expect(token_count("<a href=\"https://example.com\" title=\"Example\">")).to_equal(1)

        it "tokenizes comments and doctypes":
            expect(token_count("<!-- a comment --><!DOCTYPE html>")).to_be_greater_than(0)

        it "handles empty and partial input":
            expect(token_count("")).to_equal(0)
            expect(token_count("<div")).to_be_greater_than(-1)
