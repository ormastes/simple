#![allow(REQC001)]
#![allow(REQC004)]
#![allow(unnamed_duplicate_typed_args)]
"""
# Html Tokenizer

Tests for html tokenizer functionality.
"""
# HTML Tokenizer Tests
#
# Category: Browser Platform Parser
# Status: Active
#
# Validates the HTML tokenizer: conversion of raw HTML text into a sequence
# of tokens (start tags, end tags, self-closing tags, text, comments, doctype).
# Each test feeds an HTML string to the tokenizer and verifies the resulting
# token sequence (token type, tag name, attributes, text content).
#
# Run with: bin/simple test examples/browser/test/parser/html_tokenizer_spec.spl

use std.spec
use examples.browser.feature.parser.html_tokenizer.{HtmlTokenizer, HtmlToken}
use examples.browser.entity.dom.attribute_types.{Attr}
use examples.browser.shared.logging.{Logger, LogLevel}

# ============================================================================
# Helpers
# ============================================================================

fn tokenize(input: text) -> [HtmlToken]:
    var tokenizer = HtmlTokenizer.new(input, Logger.new("html-tokenizer-spec", LogLevel.Error))
    var tokens: [HtmlToken] = []
    var done = false
    while not done:
        val token = tokenizer.next_token()
        match token:
            HtmlToken.Eof:
                done = true
            _:
                tokens.push(token)
    tokens

fn token_kind(tok: HtmlToken) -> text:
    match tok:
        HtmlToken.StartTag(name, attributes, self_closing):
            if self_closing: "self_closing" else: "start_tag"
        HtmlToken.EndTag(name): "end_tag"
        HtmlToken.Character(data): "text"
        HtmlToken.CommentToken(data): "comment"
        HtmlToken.Doctype(name, public_id, system_id, force_quirks): "doctype"
        HtmlToken.Eof: "eof"

fn token_tag(tok: HtmlToken) -> text:
    match tok:
        HtmlToken.StartTag(name, attributes, self_closing): name
        HtmlToken.EndTag(name): name
        _: ""

fn token_text(tok: HtmlToken) -> text:
    match tok:
        HtmlToken.Character(data): data
        HtmlToken.CommentToken(data): data
        HtmlToken.Doctype(name, public_id, system_id, force_quirks): name
        _: ""

fn token_attrs(tok: HtmlToken) -> [Attr]:
    match tok:
        HtmlToken.StartTag(name, attributes, self_closing): attributes
        _: []

# ============================================================================
# Basic tokenization
# ============================================================================

describe "HtmlTokenizer":
    """
    ## Htmltokenizer Tests

    Validates HtmlTokenizer functionality.
    """

    context "text nodes":
        it "tokenizes simple text":
            val tokens = tokenize("Hello, world!")
            expect tokens.len() == 1
            expect token_kind(tokens[0]) == "text"
            expect token_text(tokens[0]) == "Hello, world!"

    context "start tags":
        it "tokenizes start tag":
            val tokens = tokenize("<div>")
            expect tokens.len() == 1
            expect token_kind(tokens[0]) == "start_tag"
            expect token_tag(tokens[0]) == "div"

    context "end tags":
        it "tokenizes end tag":
            val tokens = tokenize("</div>")
            expect tokens.len() == 1
            expect token_kind(tokens[0]) == "end_tag"
            expect token_tag(tokens[0]) == "div"

    context "self-closing tags":
        it "tokenizes self-closing tag":
            val tokens = tokenize("<br/>")
            expect tokens.len() == 1
            expect token_kind(tokens[0]) == "self_closing"
            expect token_tag(tokens[0]) == "br"

    context "attributes":
        it "tokenizes tag with attributes":
            val tokens = tokenize("<div class=main>")
            expect tokens.len() == 1
            expect token_kind(tokens[0]) == "start_tag"
            expect token_tag(tokens[0]) == "div"
            val attrs = token_attrs(tokens[0])
            expect attrs.len() == 1
            expect attrs[0].name == "class"
            expect attrs[0].value == "main"

        it "tokenizes tag with quoted attribute values":
            val tokens = tokenize("<a href=\"https://example.com\" title=\"Example\">")
            expect tokens.len() == 1
            expect token_tag(tokens[0]) == "a"
            val attrs = token_attrs(tokens[0])
            expect attrs.len() == 2
            expect attrs[0].name == "href"
            expect attrs[0].value == "https://example.com"
            expect attrs[1].name == "title"
            expect attrs[1].value == "Example"

    context "comments":
        it "tokenizes comment":
            val tokens = tokenize("<!-- a comment -->")
            expect tokens.len() == 1
            expect token_kind(tokens[0]) == "comment"
            expect token_text(tokens[0]) == " a comment "

    context "doctype":
        it "tokenizes doctype":
            val tokens = tokenize("<!DOCTYPE html>")
            expect tokens.len() == 1
            expect token_kind(tokens[0]) == "doctype"
            expect token_text(tokens[0]) == "html"

    context "multiple elements":
        it "tokenizes multiple elements":
            val tokens = tokenize("<p>Hello</p>")
            expect tokens.len() == 3
            expect token_kind(tokens[0]) == "start_tag"
            expect token_tag(tokens[0]) == "p"
            expect token_kind(tokens[1]) == "text"
            expect token_text(tokens[1]) == "Hello"
            expect token_kind(tokens[2]) == "end_tag"
            expect token_tag(tokens[2]) == "p"

    context "whitespace handling":
        it "handles whitespace in tags":
            val tokens = tokenize("<  div  class = \"main\"  >")
            expect tokens.len() == 1
            expect token_kind(tokens[0]) == "start_tag"
            expect token_tag(tokens[0]) == "div"
            val attrs = token_attrs(tokens[0])
            expect attrs.len() == 1
            expect attrs[0].name == "class"
            expect attrs[0].value == "main"

    context "character references":
        it "decodes basic character references":
            val tokens = tokenize("&amp; &lt; &gt; &quot;")
            expect tokens.len() == 1
            expect token_kind(tokens[0]) == "text"
            expect token_text(tokens[0]) == "& < > \""

    context "raw text elements":
        it "tokenizes script content as raw text":
            val tokens = tokenize("<script>var x = 1 < 2;</script>")
            expect tokens.len() == 3
            expect token_kind(tokens[0]) == "start_tag"
            expect token_tag(tokens[0]) == "script"
            expect token_kind(tokens[1]) == "text"
            expect token_text(tokens[1]) == "var x = 1 < 2;"
            expect token_kind(tokens[2]) == "end_tag"
            expect token_tag(tokens[2]) == "script"

        it "tokenizes style content as raw text":
            val tokens = tokenize("<style>body { color: red; }</style>")
            expect tokens.len() == 3
            expect token_kind(tokens[0]) == "start_tag"
            expect token_tag(tokens[0]) == "style"
            expect token_kind(tokens[1]) == "text"
            expect token_text(tokens[1]) == "body { color: red; }"
            expect token_kind(tokens[2]) == "end_tag"
            expect token_tag(tokens[2]) == "style"

    context "edge cases":
        it "handles empty document":
            val tokens = tokenize("")
            expect tokens.len() == 0

        it "handles unclosed tag gracefully":
            val tokens = tokenize("<div")
            # Tokenizer should produce at least something (possibly an error token
            # or a partial start tag). The key is it does not crash.
            val count = tokens.len()
            val has_tokens = count >= 0
            expect has_tokens == true