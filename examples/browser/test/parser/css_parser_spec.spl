#![allow(REQC001)]
#![allow(REQC004)]
#![allow(unnamed_duplicate_typed_args)]
"""
# Css Parser

Tests for css parser functionality.
"""
# CSS Parser Tests
#
# Category: Browser Platform Parser
# Status: Active
#
# Validates the CSS tokenizer and parser: tokenization of CSS values,
# selector parsing, declaration blocks, specificity calculations, and
# value types (colors, lengths, percentages, !important).
#
# Run with: bin/simple test examples/browser/test/parser/css_parser_spec.spl

use std.spec
use examples.browser.feature.parser.css_tokenizer.{css_tokenize, CssToken}
use examples.browser.feature.parser.css_parser.{parse_selector_text, parse_declarations_text, calculate_specificity}
use examples.browser.feature.parser.css_parser_selectors
use examples.browser.feature.parser.css_parser_declarations
use examples.browser.feature.parser.css_parser_media
use examples.browser.entity.dom.css_types.{CSSValue, CSSDeclaration, SelectorPart, Selector, Specificity}
use examples.browser.shared.logging.{Logger, LogLevel}

# ============================================================================
# Helpers
# ============================================================================

fn css_logger() -> Logger:
    Logger(name: "css-parser-test")

fn tokenize_css(input: text) -> [CssToken]:
    css_tokenize(input, css_logger())

fn parse_selector(input: text) -> Selector:
    parse_selector_text(input, css_logger())

fn parse_declarations(input: text) -> [CSSDeclaration]:
    parse_declarations_text(input, css_logger())

fn tok_kind(tok: CssToken) -> text:
    match tok:
        CssToken.Ident(_): "ident"
        CssToken.Number(_, _): "number"
        CssToken.Dimension(_, _): "dimension"
        CssToken.Percentage(_): "percentage"
        CssToken.Hash(_, _): "hash"
        CssToken.String(_): "string"
        CssToken.Whitespace: "whitespace"
        CssToken.Colon: "colon"
        CssToken.Semicolon: "semicolon"
        CssToken.OpenBrace: "left_brace"
        CssToken.CloseBrace: "right_brace"
        CssToken.Delim(v):
            if v == ".":
                "dot"
            else:
                "delim"
        CssToken.Comma: "comma"
        _: "other"

fn tok_value(tok: CssToken) -> text:
    match tok:
        CssToken.Ident(v): v
        CssToken.Number(v, _): "{v}"
        CssToken.Dimension(v, unit): "{v}{unit}"
        CssToken.Percentage(v): "{v}"
        CssToken.Hash(v, _): v
        CssToken.String(v): v
        CssToken.Delim(v): v
        _: ""

fn selector_part_kind(part: SelectorPart) -> text:
    match part:
        SelectorPart.Type(_): "type"
        SelectorPart.Class(_): "class"
        SelectorPart.Id(_): "id"
        SelectorPart.Universal: "universal"
        SelectorPart.Attribute(_, _, _): "attribute"
        SelectorPart.PseudoClass(_): "pseudo_class"
        SelectorPart.PseudoElement(_): "pseudo_element"
        SelectorPart.Combinator(_): "combinator"

fn selector_part_name(part: SelectorPart) -> text:
    match part:
        SelectorPart.Type(name): name
        SelectorPart.Class(name): name
        SelectorPart.Id(name): name
        SelectorPart.Universal: "*"
        SelectorPart.Attribute(name, _, _): name
        SelectorPart.PseudoClass(name): name
        SelectorPart.PseudoElement(name): name
        SelectorPart.Combinator(kind): kind

# ============================================================================
# CSS Tokenizer
# ============================================================================

describe "CSSTokenizer":
    """
    ## Csstokenizer Tests

    Validates CSSTokenizer functionality.
    """

    context "basic tokens":
        it "tokenizes ident":
            val tokens = tokenize_css("color")
            # Filter out whitespace tokens for simpler assertions
            var idents: [CssToken] = []
            var i = 0
            while i < tokens.len():
                if tok_kind(tokens.get(i)) == "ident":
                    idents = idents + [tokens.get(i)]
                i = i + 1
            expect(idents.len()).to_be_greater_than(0)

        it "tokenizes number":
            val tokens = tokenize_css("42")
            var nums: [CssToken] = []
            var i = 0
            while i < tokens.len():
                if tok_kind(tokens.get(i)) == "number":
                    nums = nums + [tokens.get(i)]
                i = i + 1
            expect(nums.len()).to_be_greater_than(0)

        it "tokenizes dimension (px, em, rem)":
            val tokens = tokenize_css("16px")
            expect(tokens.len()).to_be_greater_than(0)

        it "tokenizes percentage":
            val tokens = tokenize_css("50%")
            expect(tokens.len()).to_be_greater_than(0)

        it "tokenizes hash":
            val tokens = tokenize_css("#ff0000")
            var hashes: [CssToken] = []
            var i = 0
            while i < tokens.len():
                if tok_kind(tokens.get(i)) == "hash":
                    hashes = hashes + [tokens.get(i)]
                i = i + 1
            expect(hashes.len()).to_be_greater_than(0)

        it "tokenizes string":
            val tokens = tokenize_css("\"hello world\"")
            var strs: [CssToken] = []
            var i = 0
            while i < tokens.len():
                if tok_kind(tokens.get(i)) == "string":
                    strs = strs + [tokens.get(i)]
                i = i + 1
            expect(strs.len()).to_be_greater_than(0)

        it "tokenizes whitespace":
            val tokens = tokenize_css("a  b")
            expect(tokens.len()).to_be_greater_than(0)

# ============================================================================
# CSS Selector Parsing
# ============================================================================

describe "CSS Selector Parser":
    context "simple selectors":
        it "parses simple type selector":
            val sel = parse_selector("div")
            expect(sel.parts.len()).to_equal(1)
            expect(selector_part_kind(sel.parts.get(0))).to_equal("type")
            expect(selector_part_name(sel.parts.get(0))).to_equal("div")

        it "parses class selector":
            val sel = parse_selector(".main")
            expect(sel.parts.len()).to_equal(1)
            expect(selector_part_kind(sel.parts.get(0))).to_equal("class")
            expect(selector_part_name(sel.parts.get(0))).to_equal("main")

        it "parses ID selector":
            val sel = parse_selector("#header")
            expect(sel.parts.len()).to_equal(1)
            expect(selector_part_kind(sel.parts.get(0))).to_equal("id")
            expect(selector_part_name(sel.parts.get(0))).to_equal("header")

    context "compound selectors":
        it "parses compound selector":
            val sel = parse_selector("div.main#content")
            expect(sel.parts.len()).to_equal(3)
            expect(selector_part_kind(sel.parts.get(0))).to_equal("type")
            expect(selector_part_name(sel.parts.get(0))).to_equal("div")
            expect(selector_part_kind(sel.parts.get(1))).to_equal("class")
            expect(selector_part_name(sel.parts.get(1))).to_equal("main")
            expect(selector_part_kind(sel.parts.get(2))).to_equal("id")
            expect(selector_part_name(sel.parts.get(2))).to_equal("content")

    context "combinators":
        it "parses descendant combinator":
            val sel = parse_selector("div p")
            # Should produce: Type("div"), Combinator(" "), Type("p")
            expect(sel.parts.len()).to_equal(3)
            expect(selector_part_kind(sel.parts.get(0))).to_equal("type")
            expect(selector_part_name(sel.parts.get(0))).to_equal("div")
            expect(selector_part_kind(sel.parts.get(1))).to_equal("combinator")
            expect(selector_part_kind(sel.parts.get(2))).to_equal("type")
            expect(selector_part_name(sel.parts.get(2))).to_equal("p")

# ============================================================================
# CSS Declaration Parsing
# ============================================================================

describe "CSS Declaration Parser":
    it "parses declaration block":
        val decls = parse_declarations("color: red; font-size: 16px;")
        expect(decls.len()).to_equal(2)
        expect(decls.get(0).property).to_equal("color")
        expect(decls.get(1).property).to_equal("font-size")

    it "parses color value (#hex)":
        val decls = parse_declarations("color: #ff0000;")
        expect(decls.len()).to_equal(1)
        expect(decls.get(0).property).to_equal("color")
        val is_color = match decls.get(0).value:
            CSSValue.Color(_): true
            _: false
        expect(is_color).to_equal(true)

    it "parses length value":
        val decls = parse_declarations("width: 100px;")
        expect(decls.len()).to_equal(1)
        expect(decls.get(0).property).to_equal("width")
        val is_length = match decls.get(0).value:
            CSSValue.Length(v, unit): unit == "px"
            _: false
        expect(is_length).to_equal(true)

    it "parses !important flag":
        val decls = parse_declarations("color: red !important;")
        expect(decls.len()).to_equal(1)
        expect(decls.get(0).important).to_equal(true)

# ============================================================================
# Specificity Calculation
# ============================================================================

describe "CSS Specificity":
    it "calculates specificity for type selector":
        val sel = parse_selector("div")
        val spec = calculate_specificity(sel)
        expect(spec.ids).to_equal(0)
        expect(spec.classes).to_equal(0)
        expect(spec.elements).to_equal(1)

    it "calculates specificity for class selector":
        val sel = parse_selector(".main")
        val spec = calculate_specificity(sel)
        expect(spec.ids).to_equal(0)
        expect(spec.classes).to_equal(1)
        expect(spec.elements).to_equal(0)

    it "calculates specificity for ID selector":
        val sel = parse_selector("#header")
        val spec = calculate_specificity(sel)
        expect(spec.ids).to_equal(1)
        expect(spec.classes).to_equal(0)
        expect(spec.elements).to_equal(0)

    it "calculates specificity for compound selector":
        # div.main#content => (1 id, 1 class, 1 element)
        val sel = parse_selector("div.main#content")
        val spec = calculate_specificity(sel)
        expect(spec.ids).to_equal(1)
        expect(spec.classes).to_equal(1)
        expect(spec.elements).to_equal(1)
