#![allow(REQC001)]
#![allow(REQC004)]
"""
# CSS @supports Specification

Tests for eval_supports_query() feature detection logic.
Pure string matching — no rendering required.

Run with: bin/simple test examples/browser/test/style/css_supports_spec.spl
"""

use std.spec
use examples.browser.feature.style.supports.{eval_supports_query, known_properties}

# ============================================================================
# Helpers
# ============================================================================

fn known_prop_count() -> i64:
    known_properties().len()

# ============================================================================
# Spec
# ============================================================================

describe "CSS @supports Query Evaluation":
    """
    Validates eval_supports_query() for (property: value) feature detection.
    Tests only string-match logic — no style resolution or layout involved.
    """

    context "known properties — positive":
        it "display: flex is supported":
            expect(eval_supports_query("(display: flex)")).to_equal(true)

        it "color: red is supported":
            expect(eval_supports_query("(color: red)")).to_equal(true)

        it "background-color: blue is supported":
            expect(eval_supports_query("(background-color: blue)")).to_equal(true)

        it "opacity: 0.5 is supported":
            expect(eval_supports_query("(opacity: 0.5)")).to_equal(true)

        it "position: sticky is supported":
            expect(eval_supports_query("(position: sticky)")).to_equal(true)

        it "transform: rotate(0) is supported":
            expect(eval_supports_query("(transform: rotate(0))")).to_equal(true)

        it "transition: all 0s is supported":
            expect(eval_supports_query("(transition: all 0s)")).to_equal(true)

        it "animation: none is supported":
            expect(eval_supports_query("(animation: none)")).to_equal(true)

        it "object-fit: cover is supported":
            expect(eval_supports_query("(object-fit: cover)")).to_equal(true)

        it "overflow: auto is supported":
            expect(eval_supports_query("(overflow: auto)")).to_equal(true)

    context "unknown / unsupported properties — negative":
        it "grid-template: none returns false (not yet implemented)":
            expect(eval_supports_query("(grid-template: none)")).to_equal(false)

        it "completely unknown property returns false":
            expect(eval_supports_query("(xyzzy-foo: bar)")).to_equal(false)

        it "empty query returns false":
            expect(eval_supports_query("")).to_equal(false)

    context "not() negation":
        it "not(unknown property) returns true":
            expect(eval_supports_query("not (xyzzy-foo: bar)")).to_equal(true)

        it "not(display: flex) returns false":
            expect(eval_supports_query("not (display: flex)")).to_equal(false)

    context "and() conjunction":
        it "display:flex and color:red — both known — returns true":
            expect(eval_supports_query("(display: flex) and (color: red)")).to_equal(true)

        it "display:flex and unknown — returns false":
            expect(eval_supports_query("(display: flex) and (xyzzy: bar)")).to_equal(false)

    context "or() disjunction":
        it "unknown or display:flex — returns true":
            expect(eval_supports_query("(xyzzy: bar) or (display: flex)")).to_equal(true)

        it "unknown or unknown — returns false":
            expect(eval_supports_query("(xyzzy: bar) or (zork: baz)")).to_equal(false)

    context "known_properties list":
        it "known_properties returns non-empty list":
            expect(known_prop_count() > 0).to_equal(true)

        it "known_properties contains display":
            val props = known_properties()
            var found = false
            for p in props:
                if p == "display":
                    found = true
            expect(found).to_equal(true)

        it "known_properties contains transform":
            val props = known_properties()
            var found = false
            for p in props:
                if p == "transform":
                    found = true
            expect(found).to_equal(true)

        it "known_properties contains custom-property support marker":
            # --var: value style queries evaluate as supported
            expect(eval_supports_query("(--my-var: 1)")).to_equal(true)
