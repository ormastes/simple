use std.spec
use examples.browser.feature.style.transform.{TransformFunction, parse_transform, tf_arg_at}

fn check_via_accessor() -> bool:
    val fns = parse_transform("translate(10px, 20px)")
    var arg0 = 0.0
    var fn_found = false
    for f in fns:
        if not fn_found:
            arg0 = tf_arg_at(f, 0)
            fn_found = true
    arg0 > 9.0 and arg0 < 11.0

describe "minimal":
    it "accessor works":
        expect(check_via_accessor()).to_equal(true)
