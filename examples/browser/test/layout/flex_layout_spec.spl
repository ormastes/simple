use std.spec

# Helper: create a flex container
fn make_flex_container(id: i64, w: f64, h: f64, direction: text) -> LayoutBox:
    var box = LayoutBox.create(id, BoxKind.Flex)
    box.width = w
    box.height = h
    box

# Helper: create a flex item with basis, grow, shrink
class FlexProps:
    grow: f64
    shrink: f64
    basis: f64
    order: i64

    static fn default() -> FlexProps:
        FlexProps(grow: 0.0, shrink: 1.0, basis: 0.0, order: 0)

fn make_flex_item(id: i64, basis: f64, grow: f64, shrink: f64) -> LayoutBox:
    var box = LayoutBox.create(id, BoxKind.Block)
    box.width = basis
    box.height = 50.0
    box

# Distribute free space among items based on flex-grow
fn distribute_grow(container_width: f64, items: List<f64>, grows: List<f64>) -> List<f64>:
    var total_basis = 0.0
    for b in items:
        total_basis = total_basis + b
    var free_space = container_width - total_basis
    if free_space < 0.0:
        free_space = 0.0
    var total_grow = 0.0
    for g in grows:
        total_grow = total_grow + g
    var result = List<f64>()
    var i = 0
    for b in items:
        if total_grow > 0.0:
            result.push(b + free_space * grows[i] / total_grow)
        else:
            result.push(b)
        i = i + 1
    result

# Shrink items proportionally when they overflow
fn distribute_shrink(container_width: f64, items: List<f64>, shrinks: List<f64>) -> List<f64>:
    var total_basis = 0.0
    for b in items:
        total_basis = total_basis + b
    var overflow = total_basis - container_width
    if overflow < 0.0:
        overflow = 0.0
    var total_shrink = 0.0
    for s in shrinks:
        total_shrink = total_shrink + s
    var result = List<f64>()
    var i = 0
    for b in items:
        if total_shrink > 0.0:
            result.push(b - overflow * shrinks[i] / total_shrink)
        else:
            result.push(b)
        i = i + 1
    result

# Layout items in row direction, returning x positions
fn layout_row(container_x: f64, widths: List<f64>) -> List<f64>:
    var positions = List<f64>()
    var cursor = container_x
    for w in widths:
        positions.push(cursor)
        cursor = cursor + w
    positions

# Layout items in column direction, returning y positions
fn layout_column(container_y: f64, heights: List<f64>) -> List<f64>:
    var positions = List<f64>()
    var cursor = container_y
    for h in heights:
        positions.push(cursor)
        cursor = cursor + h
    positions

# Justify content: space-between distribution
fn justify_space_between(container_width: f64, item_widths: List<f64>) -> List<f64>:
    var total_items_w = 0.0
    for w in item_widths:
        total_items_w = total_items_w + w
    var count = item_widths.len()
    var gap = 0.0
    if count > 1:
        gap = (container_width - total_items_w) / (count - 1).to_f64()
    var positions = List<f64>()
    var cursor = 0.0
    for w in item_widths:
        positions.push(cursor)
        cursor = cursor + w + gap
    positions

# Justify content: center
fn justify_center(container_width: f64, item_widths: List<f64>) -> List<f64>:
    var total_items_w = 0.0
    for w in item_widths:
        total_items_w = total_items_w + w
    var start = (container_width - total_items_w) / 2.0
    var positions = List<f64>()
    var cursor = start
    for w in item_widths:
        positions.push(cursor)
        cursor = cursor + w
    positions

# Align items center on cross axis
fn align_center_cross(container_height: f64, item_height: f64) -> f64:
    (container_height - item_height) / 2.0

# Flex wrap: split items into lines
fn flex_wrap_lines(container_width: f64, item_widths: List<f64>) -> List<List<f64>>:
    var lines = List<List<f64>>()
    var current_line = List<f64>()
    var line_width = 0.0
    for w in item_widths:
        if line_width + w > container_width and current_line.len() > 0:
            lines.push(current_line)
            current_line = List<f64>()
            line_width = 0.0
        current_line.push(w)
        line_width = line_width + w
    if current_line.len() > 0:
        lines.push(current_line)
    lines

describe "FlexLayout":
    describe "direction":
        it "row direction lays items horizontally":
            var widths = [100.0, 150.0, 50.0]
            var positions = layout_row(0.0, widths)
            expect(positions[0]).to_equal(0.0)
            expect(positions[1]).to_equal(100.0)
            expect(positions[2]).to_equal(250.0)

        it "column direction lays items vertically":
            var heights = [40.0, 60.0, 30.0]
            var positions = layout_column(0.0, heights)
            expect(positions[0]).to_equal(0.0)
            expect(positions[1]).to_equal(40.0)
            expect(positions[2]).to_equal(100.0)

        it "row-reverse reverses direction":
            var widths = [100.0, 150.0, 50.0]
            var positions = layout_row(0.0, widths)
            # In row-reverse, last item is at x=0, first at the end
            var reversed = List<f64>()
            var container_w = 300.0
            var cursor = container_w
            for w in widths:
                cursor = cursor - w
                reversed.push(cursor)
            expect(reversed[0]).to_equal(200.0)
            expect(reversed[1]).to_equal(50.0)
            expect(reversed[2]).to_equal(0.0)

    describe "flex grow and shrink":
        it "flex-grow distributes free space":
            var bases = [100.0, 100.0]
            var grows = [1.0, 1.0]
            var result = distribute_grow(400.0, bases, grows)
            expect(result[0]).to_equal(200.0)
            expect(result[1]).to_equal(200.0)

        it "flex-shrink reduces items proportionally":
            var bases = [200.0, 200.0]
            var shrinks = [1.0, 1.0]
            var result = distribute_shrink(300.0, bases, shrinks)
            expect(result[0]).to_equal(150.0)
            expect(result[1]).to_equal(150.0)

        it "flex-basis sets initial size":
            var bases = [150.0, 50.0]
            var grows = [0.0, 0.0]
            var result = distribute_grow(400.0, bases, grows)
            # No grow, so sizes stay at basis
            expect(result[0]).to_equal(150.0)
            expect(result[1]).to_equal(50.0)

        it "flex-grow 0 keeps natural size":
            var bases = [80.0, 120.0]
            var grows = [0.0, 0.0]
            var result = distribute_grow(500.0, bases, grows)
            expect(result[0]).to_equal(80.0)
            expect(result[1]).to_equal(120.0)

        it "mixed grow factors distribute proportionally":
            var bases = [100.0, 100.0]
            var grows = [1.0, 3.0]
            var result = distribute_grow(500.0, bases, grows)
            # free space = 300, item0 gets 75, item1 gets 225
            expect(result[0]).to_equal(175.0)
            expect(result[1]).to_equal(325.0)

    describe "wrapping":
        it "flex-wrap creates new lines":
            var widths = [200.0, 200.0, 200.0]
            var lines = flex_wrap_lines(350.0, widths)
            expect(lines.len()).to_equal(2)
            expect(lines[0].len()).to_equal(1)
            expect(lines[1].len()).to_equal(2)

    describe "justify content":
        it "justify-content space-between":
            var widths = [50.0, 50.0, 50.0]
            var positions = justify_space_between(300.0, widths)
            expect(positions[0]).to_equal(0.0)
            expect(positions[1]).to_equal(125.0)
            expect(positions[2]).to_equal(250.0)

        it "justify-content center":
            var widths = [50.0, 50.0]
            var positions = justify_center(300.0, widths)
            expect(positions[0]).to_equal(100.0)
            expect(positions[1]).to_equal(150.0)

    describe "align items":
        it "align-items center":
            var container_h = 200.0
            var item_h = 50.0
            var offset = align_center_cross(container_h, item_h)
            expect(offset).to_equal(75.0)

        it "align-items stretch fills cross axis":
            var container_h = 200.0
            # stretch means item height = container height
            var item_h = container_h
            expect(item_h).to_equal(200.0)

    describe "order":
        it "order property reorders items":
            var orders = [2, 0, 1]
            # Sort indices by order: index 1 (order 0), index 2 (order 1), index 0 (order 2)
            var sorted_indices = [1, 2, 0]
            expect(sorted_indices[0]).to_equal(1)
            expect(sorted_indices[1]).to_equal(2)
            expect(sorted_indices[2]).to_equal(0)

    describe "auto margins":
        it "auto margins push items apart":
            # Item with auto left margin gets pushed to the right
            var container_w = 400.0
            var item_w = 100.0
            var auto_margin_left = container_w - item_w
            expect(auto_margin_left).to_equal(300.0)
