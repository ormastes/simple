#![allow(REQC004)]
#![allow(unnamed_duplicate_typed_args)]

use std.spec
use examples.browser.feature.layout.text_shape.{TextRun, TextShaper, char_to_codepoint, is_cjk_char, measure_char, text_to_codepoints}
use examples.browser.shared.logging.{Logger}

describe "TextShape":
    describe "codepoint decoding":
        it "returns ASCII codepoints":
            expect char_to_codepoint("A") == 65

        it "decodes multibyte UTF-8 codepoints":
            expect char_to_codepoint("é") == 0x00E9
            expect char_to_codepoint("界") == 0x754C
            expect char_to_codepoint("😀") == 0x1F600

        it "splits text into decoded codepoints":
            val cps = text_to_codepoints("A界")
            expect cps.len() == 2
            expect cps[0] == 65
            expect cps[1] == 0x754C

        it "detects CJK characters from decoded codepoints":
            expect is_cjk_char("界") == true
            expect is_cjk_char("A") == false

    describe "glyph shaping":
        it "records decoded glyph codepoints":
            val shaper = TextShaper.new(Logger(name: "text-shape-spec"))
            val glyphs = shaper.shape(TextRun.create("A界", 10.0, "sans-serif"))
            expect glyphs.len() == 2
            expect glyphs[0].codepoint == 65
            expect glyphs[1].codepoint == 0x754C

        it "measures CJK glyphs at full em width":
            expect measure_char("界", 12.0) == 12.0