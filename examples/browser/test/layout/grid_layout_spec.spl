use std.spec

# Grid track definition
enum TrackSize:
    Fixed(px: f64)
    Fr(value: f64)
    Auto
    MinMax(min_px: f64, max_px: f64)

# Resolve grid tracks into concrete pixel sizes
fn resolve_tracks(tracks: [TrackSize], container_size: f64, gap: f64) -> [f64]:
    var total_gap = gap * (tracks.len() - 1).to_f64()
    var available = container_size - total_gap
    # First pass: fixed and auto
    var remaining = available
    var total_fr = 0.0
    var sizes = [f64]()
    for track in tracks:
        match track:
            Fixed(px):
                sizes.push(px)
                remaining = remaining - px
            Fr(v):
                sizes.push(0.0)
                total_fr = total_fr + v
            Auto:
                # Auto: allocate 0 initially, size to content later
                sizes.push(0.0)
            MinMax(min_px, max_px):
                sizes.push(min_px)
                remaining = remaining - min_px
    # Second pass: distribute fr units
    if total_fr > 0.0:
        var i = 0
        for track in tracks:
            match track:
                Fr(v):
                    sizes[i] = remaining * v / total_fr
                _: pass_dn
            i = i + 1
    sizes

# Compute positions from sizes and gap
fn track_positions(sizes: [f64], gap: f64, start: f64) -> [f64]:
    var positions = [f64]()
    var cursor = start
    for s in sizes:
        positions.push(cursor)
        cursor = cursor + s + gap
    positions

# Place an item that spans multiple tracks
fn span_size(sizes: [f64], start_track: i64, span: i64, gap: f64) -> f64:
    var total = 0.0
    var i = 0
    while i < span:
        total = total + sizes[start_track + i]
        if i < span - 1:
            total = total + gap
        i = i + 1
    total

# Auto placement: assign items to next available cell
fn auto_place(num_items: i64, num_cols: i64) -> [[i64]]:
    var placements = [[i64]]()
    var i = 0
    while i < num_items:
        var row = i / num_cols
        var col = i % num_cols
        placements.push([row, col])
        i = i + 1
    placements

describe "GridLayout":
    describe "track sizing":
        it "fixed track sizes respected":
            var tracks = [TrackSize.Fixed(px: 100.0), TrackSize.Fixed(px: 200.0)]
            var sizes = resolve_tracks(tracks, 400.0, 0.0)
            expect(sizes[0]).to_equal(100.0)
            expect(sizes[1]).to_equal(200.0)

        it "fr unit distributes remaining space":
            var tracks = [TrackSize.Fr(value: 1.0), TrackSize.Fr(value: 1.0)]
            var sizes = resolve_tracks(tracks, 400.0, 0.0)
            expect(sizes[0]).to_equal(200.0)
            expect(sizes[1]).to_equal(200.0)

        it "mixed fixed and fr tracks":
            var tracks = [TrackSize.Fixed(px: 100.0), TrackSize.Fr(value: 1.0)]
            var sizes = resolve_tracks(tracks, 400.0, 0.0)
            expect(sizes[0]).to_equal(100.0)
            expect(sizes[1]).to_equal(300.0)

        it "minmax track respects min and max":
            var tracks = [TrackSize.MinMax(min_px: 50.0, max_px: 200.0)]
            var sizes = resolve_tracks(tracks, 400.0, 0.0)
            # MinMax initially gets min; for a single track with no fr, stays at min
            expect(sizes[0]).to_be_greater_than(49.0)
            expect(sizes[0]).to_be_less_than(201.0)

        it "auto track sizes to content":
            var tracks = [TrackSize.Auto]
            var sizes = resolve_tracks(tracks, 400.0, 0.0)
            # Auto starts at 0, would be sized to content in full impl
            expect(sizes[0]).to_equal(0.0)

    describe "gaps":
        it "column gap adds space between tracks":
            var tracks = [TrackSize.Fr(value: 1.0), TrackSize.Fr(value: 1.0)]
            var sizes = resolve_tracks(tracks, 400.0, 20.0)
            # available = 400 - 20 = 380, each gets 190
            expect(sizes[0]).to_equal(190.0)
            expect(sizes[1]).to_equal(190.0)
            var positions = track_positions(sizes, 20.0, 0.0)
            expect(positions[0]).to_equal(0.0)
            expect(positions[1]).to_equal(210.0)

        it "row gap adds space between rows":
            var row_tracks = [TrackSize.Fixed(px: 50.0), TrackSize.Fixed(px: 50.0)]
            var sizes = resolve_tracks(row_tracks, 120.0, 10.0)
            var positions = track_positions(sizes, 10.0, 0.0)
            expect(positions[0]).to_equal(0.0)
            expect(positions[1]).to_equal(60.0)

    describe "spanning":
        it "item spans multiple columns":
            var col_sizes = [100.0, 100.0, 100.0]
            var span_w = span_size(col_sizes, 0, 2, 10.0)
            # 100 + 100 + 10 (one gap) = 210
            expect(span_w).to_equal(210.0)

        it "item spans multiple rows":
            var row_sizes = [50.0, 50.0, 50.0]
            var span_h = span_size(row_sizes, 0, 3, 5.0)
            # 50 + 50 + 50 + 5 + 5 (two gaps) = 160
            expect(span_h).to_equal(160.0)

    describe "auto placement":
        it "auto placement fills grid":
            var placements = auto_place(6, 3)
            expect(placements.len()).to_equal(6)
            # First row: (0,0), (0,1), (0,2)
            expect(placements[0][0]).to_equal(0)
            expect(placements[0][1]).to_equal(0)
            expect(placements[2][1]).to_equal(2)
            # Second row: (1,0), (1,1), (1,2)
            expect(placements[3][0]).to_equal(1)
            expect(placements[3][1]).to_equal(0)
            expect(placements[5][0]).to_equal(1)
            expect(placements[5][1]).to_equal(2)
