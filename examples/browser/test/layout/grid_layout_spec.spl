#![allow(REQC001)]
#![allow(REQC004)]
#![allow(unnamed_duplicate_typed_args)]
"""
# Grid Layout

Production-backed tests for CSS Grid parsing, track sizing, auto placement,
and child positioning.
"""

use std.spec
use examples.browser.entity.dom.box_types.{LayoutBox, BoxKind}
use examples.browser.feature.layout.block.{LayoutContext}
use examples.browser.feature.layout.grid_layout.{
    GridFormatter, GridItem, GridTrack, GridTrackDef,
    auto_place_items, distribute_fr_space, expand_repeat,
    get_track_position, get_track_span_size, parse_track_list,
    resolve_track_sizes
}
use examples.browser.feature.style.computed.{ComputedStyle}
use examples.browser.shared.logging.{Logger, LogLevel}

fn logger() -> Logger:
    Logger.new("grid-layout-spec", LogLevel.Error)

fn make_box(node_id: i64, width: f64, height: f64) -> LayoutBox:
    var box = LayoutBox.create(node_id, BoxKind.Block)
    box.width = width
    box.height = height
    box

fn make_container(width: f64, height: f64, children: [LayoutBox]) -> LayoutBox:
    var box = LayoutBox.create(1, BoxKind.Grid)
    box.width = width
    box.height = height
    box.children = children
    box

fn grid_style(cols: text, rows: text) -> ComputedStyle:
    var style = ComputedStyle.default_style()
    style.display = "grid"
    style.grid_template_columns = cols
    style.grid_template_rows = rows
    style

describe "Grid layout":
    context "track parsing":
        it "parses fixed fraction auto and minmax tracks":
            val defs = parse_track_list("100px 1fr auto minmax(50px, 200px)")

            expect(defs.len()).to_equal(4)
            match defs[0]:
                GridTrackDef.Fixed(size): expect(size).to_equal(100.0)
                _: expect(false).to_equal(true)
            match defs[1]:
                GridTrackDef.Fraction(fr): expect(fr).to_equal(1.0)
                _: expect(false).to_equal(true)
            match defs[2]:
                GridTrackDef.Auto: expect(true).to_equal(true)
                _: expect(false).to_equal(true)
            match defs[3]:
                GridTrackDef.MinMax(min_val, max_val):
                    expect(min_val).to_equal(50.0)
                    expect(max_val).to_equal(200.0)
                _: expect(false).to_equal(true)

        it "expands repeat definitions":
            val expanded = expand_repeat(GridTrackDef.Repeat(
                count: 3,
                tracks: [GridTrackDef.Fraction(fr: 1.0)]
            ))

            expect(expanded.len()).to_equal(3)
            match expanded[2]:
                GridTrackDef.Fraction(fr): expect(fr).to_equal(1.0)
                _: expect(false).to_equal(true)

    context "track sizing":
        it "resolves fixed tracks without growing past their fixed limit":
            val tracks = [
                GridTrack.from_def(0, GridTrackDef.Fixed(size: 100.0)),
                GridTrack.from_def(1, GridTrackDef.Fixed(size: 200.0))
            ]
            val resolved = resolve_track_sizes(tracks, 500.0)

            expect(resolved[0].base_size).to_equal(100.0)
            expect(resolved[1].base_size).to_equal(200.0)

        it "distributes free space across fr tracks by flex factor":
            val tracks = [
                GridTrack.from_def(0, GridTrackDef.Fraction(fr: 1.0)),
                GridTrack.from_def(1, GridTrackDef.Fraction(fr: 3.0))
            ]
            val resolved = distribute_fr_space(tracks, 400.0)

            expect(resolved[0].base_size).to_equal(100.0)
            expect(resolved[1].base_size).to_equal(300.0)

        it "computes track positions and span sizes with gaps":
            val tracks = [
                GridTrack.from_def(0, GridTrackDef.Fixed(size: 100.0)),
                GridTrack.from_def(1, GridTrackDef.Fixed(size: 100.0)),
                GridTrack.from_def(2, GridTrackDef.Fixed(size: 100.0))
            ]

            expect(get_track_position(2, tracks, 10.0)).to_equal(220.0)
            expect(get_track_span_size(0, 2, tracks, 10.0)).to_equal(210.0)

    context "auto placement":
        it "places unpositioned items row major":
            val items = [
                GridItem.from_box(make_box(10, 0.0, 0.0)),
                GridItem.from_box(make_box(11, 0.0, 0.0)),
                GridItem.from_box(make_box(12, 0.0, 0.0)),
                GridItem.from_box(make_box(13, 0.0, 0.0))
            ]

            val placed = auto_place_items(items, 3, 2)

            expect(placed[0].area.row_start).to_equal(0)
            expect(placed[0].area.col_start).to_equal(0)
            expect(placed[2].area.col_start).to_equal(2)
            expect(placed[3].area.row_start).to_equal(1)
            expect(placed[3].area.col_start).to_equal(0)

    context "formatter integration":
        it "positions children using production grid tracks":
            val children = [
                make_box(10, 0.0, 0.0),
                make_box(11, 0.0, 0.0),
                make_box(12, 0.0, 0.0)
            ]
            val container = make_container(400.0, 100.0, children)
            val style = grid_style("100px 1fr", "50px 50px")
            val ctx = LayoutContext.create(400.0, 100.0, logger())
            val formatter = GridFormatter.new(logger())

            val laid_out = formatter.layout_grid(container, style, ctx)

            expect(laid_out.children.len()).to_equal(3)
            expect(laid_out.children[0].x).to_equal(0.0)
            expect(laid_out.children[0].y).to_equal(0.0)
            expect(laid_out.children[0].width).to_equal(100.0)
            expect(laid_out.children[0].height).to_equal(50.0)
            expect(laid_out.children[1].x).to_equal(100.0)
            expect(laid_out.children[1].width).to_equal(300.0)
            expect(laid_out.children[2].x).to_equal(0.0)
            expect(laid_out.children[2].y).to_equal(50.0)
