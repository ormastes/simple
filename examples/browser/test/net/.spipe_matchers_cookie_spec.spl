#![allow(REQC001)]
#![allow(REQC004)]
#![allow(unnamed_duplicate_typed_args)]
"""
# Cookie

Production-backed tests for cookie storage, Set-Cookie parsing, scoping,
security flags, and lifecycle behavior.
"""

use std.spec
use examples.browser.feature.net.cookie_store.{CookieStore, parse_set_cookie}
use examples.browser.entity.net.cookie_types.{Cookie, SameSite}
use examples.browser.entity.net.url_types.Url
use examples.browser.shared.logging.{Logger, LogLevel}

fn https_url(host: text, path: text) -> Url:
    Url(scheme: "https", host: host, port: 443, path: path, query: "", fragment: "", raw: "")

fn http_url(host: text, path: text) -> Url:
    Url(scheme: "http", host: host, port: 80, path: path, query: "", fragment: "", raw: "")

fn new_store() -> CookieStore:
    CookieStore.new(Logger.new("cookie-spec", LogLevel.Error))

fn cookie(name: text, value: text, domain: text, path: text, secure: bool) -> Cookie:
    Cookie(
        name: name,
        value: value,
        domain: domain,
        path: path,
        expires: 0,
        secure: secure,
        http_only: false,
        same_site: SameSite.Lax
    )

fn parse_ok(header: text, url: Url) -> Cookie:
    val result = parse_set_cookie(header, url)
    match result:
        Ok(parsed): parsed
        Err(_): cookie("", "", "", "/", false)

fn parse_failed(header: text, url: Url) -> bool:
    val result = parse_set_cookie(header, url)
    match result:
        Err(_): true
        Ok(_): false

describe "CookieStore":
    context "storage and replacement":
        it "stores cookies in the production store":
            var store = new_store()
            store.set_cookie(cookie("session", "abc123", "example.com", "/", false))

            val found = store.get_cookies(https_url("example.com", "/"))
            expect found.len() == 1
            expect found[0].name == "session"
            expect found[0].value == "abc123"

        it "replaces an existing cookie with the same name domain and path":
            var store = new_store()
            store.set_cookie(cookie("session", "old", "example.com", "/", false))
            store.set_cookie(cookie("session", "new", "example.com", "/", false))

            val found = store.get_cookies(https_url("example.com", "/"))
            expect found.len() == 1
            expect found[0].value == "new"

    context "domain and path scope":
        it "returns only cookies matching the request domain":
            var store = new_store()
            store.set_cookie(cookie("session", "abc", "example.com", "/", false))
            store.set_cookie(cookie("token", "xyz", "other.com", "/", false))

            val found = store.get_cookies(https_url("example.com", "/"))
            expect found.len() == 1
            expect found[0].name == "session"

        it "sends domain cookies to subdomains":
            var store = new_store()
            store.set_cookie(cookie("session", "abc", "example.com", "/", false))

            val found = store.get_cookies(https_url("sub.example.com", "/"))
            expect found.len() == 1
            expect found[0].name == "session"

        it "matches cookie paths on directory boundaries":
            var store = new_store()
            store.set_cookie(cookie("api", "1", "example.com", "/api", false))
            store.set_cookie(cookie("web", "1", "example.com", "/web", false))

            val api = store.get_cookies(https_url("example.com", "/api/users"))
            val similar = store.get_cookies(https_url("example.com", "/apix"))

            expect api.len() == 1
            expect api[0].name == "api"
            expect similar.len() == 0

    context "Set-Cookie parsing":
        it "parses name value domain path and flags":
            val parsed = parse_ok(
                "id=42; Domain=.example.com; Path=/api; Secure; HttpOnly; SameSite=Strict",
                https_url("example.com", "/account/login")
            )

            val is_strict = match parsed.same_site:
                SameSite.Strict: true
                _: false

            expect parsed.name == "id"
            expect parsed.value == "42"
            expect parsed.domain == "example.com"
            expect parsed.path == "/api"
            expect parsed.secure == true
            expect parsed.http_only == true
            expect is_strict == true

        it "uses request host and default directory path when attributes are absent":
            val parsed = parse_ok("sid=abc", https_url("example.com", "/account/login"))

            expect parsed.domain == "example.com"
            expect parsed.path == "/account"

        it "rejects invalid Set-Cookie domain attributes":
            val url = https_url("example.com", "/")

            expect parse_failed("sid=1; Domain=evil.com", url) == true
            expect parse_failed("sid=1; Domain=.com", url) == true

    context "security and lifecycle":
        it "does not send Secure cookies over HTTP":
            var store = new_store()
            store.set_cookie(cookie("sid", "secure", "example.com", "/", true))
            store.set_cookie(cookie("theme", "dark", "example.com", "/", false))

            val https_cookies = store.get_cookies(https_url("example.com", "/"))
            val http_cookies = store.get_cookies(http_url("example.com", "/"))

            expect https_cookies.len() == 2
            expect http_cookies.len() == 1
            expect http_cookies[0].name == "theme"

        it "rejects SameSite None without Secure":
            val url = https_url("example.com", "/")

            expect parse_failed("sid=1; SameSite=None", url) == true
            expect parse_failed("sid=1; SameSite=None; Secure", url) == false

        it "rejects Secure cookies set from non HTTPS origins":
            expect parse_failed("sid=1; Secure", http_url("example.com", "/")) == true

        it "clears and removes cookies through the production store":
            var store = new_store()
            store.set_cookie(cookie("a", "1", "example.com", "/", false))
            store.set_cookie(cookie("b", "2", "example.com", "/", false))
            store.set_cookie(cookie("c", "3", "other.com", "/", false))

            expect store.remove_cookie("a", "example.com") == true
            expect store.get_cookies(https_url("example.com", "/")).len() == 1

            store.clear_for_domain("example.com")
            expect store.get_cookies(https_url("example.com", "/")).len() == 0
            expect store.get_cookies(https_url("other.com", "/")).len() == 1