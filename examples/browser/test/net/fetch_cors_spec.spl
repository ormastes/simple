#![allow(REQC004)]
#![allow(unnamed_duplicate_typed_args)]
#![allow(REQC001, REQC004, unnamed_duplicate_typed_args)]
"""
# Fetch Cors

Tests for fetch cors functionality.
"""
# Fetch + CORS Tests
#
# Category: Browser Platform Networking
# Status: Active
#
# Validates CORS simple-request classification, preflight necessity,
# preflight validation, origin parsing, redirect detection, and cacheability.
# Exercises the production CORS checker rather than local mirror helpers.
#
# Run with: bin/simple test examples/browser/test/net/fetch_cors_spec.spl

use std.spec
use examples.browser.entity.net.request_types.{FetchRequest, FetchResponse, HttpMethod, RequestMode, RequestCredentials}
use examples.browser.entity.net.cors_types.{PreflightResult}
use examples.browser.entity.net.url_types.{Url}
use examples.browser.feature.net.cors.{CorsChecker, is_simple_method, is_simple_header, parse_allow_origin}
use examples.browser.feature.net.fetch.{should_redirect, is_cacheable}
use examples.browser.shared.error.{BrowserResult}
use examples.browser.shared.logging.{Logger, LogLevel}

fn cors_checker() -> CorsChecker:
    CorsChecker.new(Logger.new("fetch-cors-spec", LogLevel.Error))

fn request(method: HttpMethod, headers: [Pair<text, text>]) -> FetchRequest:
    FetchRequest(
        url: Url.parse("https://api.example.com/data"),
        method: method,
        headers: headers,
        body: "",
        mode: RequestMode.Cors,
        credentials: RequestCredentials.SameOrigin
    )

fn response(status: i64, headers: [Pair<text, text>]) -> FetchResponse:
    FetchResponse(
        status: status,
        status_text: "OK",
        headers: headers,
        body: "",
        url: Url.parse("https://api.example.com/data"),
        redirected: false
    )

fn result_is_ok(result: BrowserResult<()>) -> bool:
    match result:
        Ok(_): true
        Err(_): false

# ============================================================================
# CORS Simple Request Classification
# ============================================================================

describe "CORS Simple Request Classification":
    """
    ## Cors Simple Request Classification Tests

    Validates CORS Simple Request Classification functionality.
    """

    context "is_simple_method":
        it "is_simple_method returns true for GET":
            expect(is_simple_method(HttpMethod.Get)).to_equal(true)

        it "is_simple_method returns true for HEAD":
            expect(is_simple_method(HttpMethod.Head)).to_equal(true)

        it "is_simple_method returns true for POST":
            expect(is_simple_method(HttpMethod.Post)).to_equal(true)

        it "is_simple_method returns false for PUT":
            expect(is_simple_method(HttpMethod.Put)).to_equal(false)

    context "is_simple_header":
        it "is_simple_header returns true for Accept":
            expect(is_simple_header("Accept")).to_equal(true)

        it "is_simple_header returns false for Authorization":
            expect(is_simple_header("Authorization")).to_equal(false)

# ============================================================================
# Preflight Determination
# ============================================================================

describe "CORS Preflight Determination":
    context "needs_preflight":
        it "needs_preflight returns false for simple GET":
            val headers = [Pair("Origin", "https://app.example.com"), Pair("Accept", "text/html")]
            expect(cors_checker().needs_preflight(request(HttpMethod.Get, headers))).to_equal(false)

        it "needs_preflight returns true for PUT request":
            val headers = [Pair("Origin", "https://app.example.com"), Pair("Accept", "text/html")]
            expect(cors_checker().needs_preflight(request(HttpMethod.Put, headers))).to_equal(true)

    context "needs_preflight with non-simple headers":
        it "needs_preflight returns true for non-simple header":
            val headers = [Pair("Origin", "https://app.example.com"), Pair("Authorization", "Bearer x")]
            expect(cors_checker().needs_preflight(request(HttpMethod.Get, headers))).to_equal(true)

        it "needs_preflight returns true for JSON content-type":
            val headers = [Pair("Origin", "https://app.example.com"), Pair("Content-Type", "application/json")]
            expect(cors_checker().needs_preflight(request(HttpMethod.Post, headers))).to_equal(true)

# ============================================================================
# Preflight Validation
# ============================================================================

describe "CORS Preflight Validation":
    context "validate_preflight":
        it "validate_preflight allows matching request Origin header":
            val original = request(
                HttpMethod.Put,
                [Pair("Origin", "https://app.example.com"), Pair("Authorization", "Bearer x")]
            )
            val preflight = response(204, [
                Pair("Access-Control-Allow-Origin", "https://app.example.com"),
                Pair("Access-Control-Allow-Methods", "PUT"),
                Pair("Access-Control-Allow-Headers", "Authorization")
            ])
            val result = cors_checker().validate_preflight(preflight, original)
            match result:
                PreflightResult.Allowed:
                    expect(true).to_equal(true)
                PreflightResult.Denied(reason):
                    expect("should be allowed").to_equal("")

        it "validate_preflight denies mismatched request Origin header":
            val original = request(
                HttpMethod.Put,
                [Pair("Origin", "https://app.example.com"), Pair("Authorization", "Bearer x")]
            )
            val preflight = response(204, [
                Pair("Access-Control-Allow-Origin", "https://other.example.com"),
                Pair("Access-Control-Allow-Methods", "PUT"),
                Pair("Access-Control-Allow-Headers", "Authorization")
            ])
            val result = cors_checker().validate_preflight(preflight, original)
            match result:
                PreflightResult.Allowed:
                    expect("should be denied").to_equal("")
                PreflightResult.Denied(reason):
                    expect(reason).to_contain("not allowed by preflight")

        it "create_preflight preserves the caller Origin header":
            val original = request(
                HttpMethod.Put,
                [Pair("Origin", "https://app.example.com"), Pair("Authorization", "Bearer x")]
            )
            val preflight = cors_checker().create_preflight(original)
            expect(preflight.headers[0].first).to_equal("Origin")
            expect(preflight.headers[0].second).to_equal("https://app.example.com")

describe "CORS Response Validation":
    context "check":
        it "allows response when allow-origin matches caller Origin header":
            val req = request(HttpMethod.Get, [Pair("Origin", "https://app.example.com")])
            val headers = [Pair("Access-Control-Allow-Origin", "https://app.example.com")]
            expect(result_is_ok(cors_checker().check(req, headers))).to_equal(true)

        it "denies response when allow-origin matches target but not caller":
            val req = request(HttpMethod.Get, [Pair("Origin", "https://app.example.com")])
            val headers = [Pair("Access-Control-Allow-Origin", "https://api.example.com")]
            expect(result_is_ok(cors_checker().check(req, headers))).to_equal(false)

# ============================================================================
# Allow-Origin Parsing
# ============================================================================

describe "CORS Allow-Origin Parsing":
    context "parse_allow_origin":
        it "parse_allow_origin handles wildcard":
            expect(parse_allow_origin("*")[0]).to_equal("*")

        it "parse_allow_origin handles specific origin":
            expect(parse_allow_origin("https://example.com")[0]).to_equal("https://example.com")

# ============================================================================
# Redirect Detection
# ============================================================================

describe "Fetch Redirect Detection":
    context "should_redirect":
        it "should_redirect returns true for 301":
            expect(should_redirect(301)).to_equal(true)

        it "should_redirect returns true for 302":
            expect(should_redirect(302)).to_equal(true)

        it "should_redirect returns false for 200":
            expect(should_redirect(200)).to_equal(false)

# ============================================================================
# Response Cacheability
# ============================================================================

describe "Fetch Response Cacheability":
    context "is_cacheable":
        it "is_cacheable returns true for 200 response":
            expect(is_cacheable(response(200, []))).to_equal(true)

        it "is_cacheable returns false for 404 response":
            expect(is_cacheable(response(404, []))).to_equal(false)
