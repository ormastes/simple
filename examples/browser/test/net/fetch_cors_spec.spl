"""
# Fetch Cors

Tests for fetch cors functionality.
"""
# Fetch + CORS Tests
#
# Category: Browser Platform Networking
# Status: Active
#
# Validates CORS simple-request classification, preflight necessity,
# preflight validation, origin parsing, redirect detection, and cacheability.
# Helper functions are defined inline since the feature layer is not yet
# implemented; they mirror the logic the feature layer will provide.
#
# Run with: bin/simple test examples/browser/test/net/fetch_cors_spec.spl

use std.spec
use sbp.entity.net.url_types.{Url, Origin}
use sbp.entity.net.request_types.{HttpMethod, FetchRequest, FetchResponse, RequestMode}
use sbp.entity.net.cors_types.{CorsPolicy, CorsRequest, PreflightResult}

# ============================================================================
# Helpers — CORS classification functions
# ============================================================================

# A simple method is GET, HEAD, or POST per the Fetch specification.
fn is_simple_method(method: text) -> bool:
    method == "GET" or method == "HEAD" or method == "POST"

# A simple header is one of the CORS-safelisted request headers.
fn is_simple_header(name: text) -> bool:
    val lower = name.to_lower()
    lower == "accept" or lower == "accept-language" or lower == "content-language" or lower == "content-type"

# A preflight is needed when the request uses a non-simple method or
# includes non-simple headers.
fn needs_preflight(method: text, headers: [text]) -> bool:
    if not is_simple_method(method):
        return true
    for h in headers:
        if not is_simple_header(h):
            return true
    false

# Validate a preflight response: check that the request origin appears in
# the policy's allowed_origins list (or that the list is empty, meaning
# permissive/wildcard).
fn validate_preflight(policy: CorsPolicy, request_origin: text) -> PreflightResult:
    if policy.allowed_origins.is_empty():
        return PreflightResult.Allowed
    for origin in policy.allowed_origins:
        if origin == request_origin:
            return PreflightResult.Allowed
    PreflightResult.Denied(reason: "Origin {request_origin} not allowed")

# Parse the Access-Control-Allow-Origin header value.
# Returns the origin string or "*" for wildcard.
fn parse_allow_origin(header_value: text) -> text:
    val trimmed = header_value.trim()
    if trimmed == "*":
        return "*"
    trimmed

# HTTP redirect status codes.
fn should_redirect(status: i64) -> bool:
    status == 301 or status == 302 or status == 303 or status == 307 or status == 308

# A response is cacheable if it has a 200, 203, 204, 206, 300, or 301 status.
fn is_cacheable(status: i64) -> bool:
    status == 200 or status == 203 or status == 204 or status == 206 or status == 300 or status == 301

# ============================================================================
# CORS Simple Request Classification
# ============================================================================

describe "CORS Simple Request Classification":
    """
    ## Cors Simple Request Classification Tests

    Validates CORS Simple Request Classification functionality.
    """

    context "is_simple_method":
        it "is_simple_method returns true for GET":
            expect(is_simple_method("GET")).to_equal(true)

        it "is_simple_method returns true for HEAD":
            expect(is_simple_method("HEAD")).to_equal(true)

        it "is_simple_method returns true for POST":
            expect(is_simple_method("POST")).to_equal(true)

        it "is_simple_method returns false for PUT":
            expect(is_simple_method("PUT")).to_equal(false)

    context "is_simple_header":
        it "is_simple_header returns true for Accept":
            expect(is_simple_header("Accept")).to_equal(true)

        it "is_simple_header returns false for Authorization":
            expect(is_simple_header("Authorization")).to_equal(false)

# ============================================================================
# Preflight Determination
# ============================================================================

describe "CORS Preflight Determination":
    context "needs_preflight":
        it "needs_preflight returns false for simple GET":
            val headers: [text] = ["Accept", "Content-Type"]
            expect(needs_preflight("GET", headers)).to_equal(false)

        it "needs_preflight returns true for PUT request":
            val headers: [text] = ["Accept"]
            expect(needs_preflight("PUT", headers)).to_equal(true)

    context "needs_preflight with non-simple headers":
        it "needs_preflight returns true for non-simple header":
            val headers: [text] = ["Authorization"]
            expect(needs_preflight("GET", headers)).to_equal(true)

# ============================================================================
# Preflight Validation
# ============================================================================

describe "CORS Preflight Validation":
    context "validate_preflight":
        it "validate_preflight allows matching origin":
            val policy = CorsPolicy.create(
                allowed_origins: ["https://example.com", "https://app.example.com"],
                allowed_methods: ["GET", "POST"],
                allowed_headers: ["Accept"],
                max_age: 3600,
                allow_credentials: false
            )
            val result = validate_preflight(policy, "https://example.com")
            match result:
                PreflightResult.Allowed:
                    expect(true).to_equal(true)
                PreflightResult.Denied(reason):
                    expect("should be allowed").to_equal("")

        it "validate_preflight denies mismatched origin":
            val policy = CorsPolicy.create(
                allowed_origins: ["https://example.com"],
                allowed_methods: ["GET"],
                allowed_headers: ["Accept"],
                max_age: 3600,
                allow_credentials: false
            )
            val result = validate_preflight(policy, "https://evil.com")
            match result:
                PreflightResult.Allowed:
                    expect("should be denied").to_equal("")
                PreflightResult.Denied(reason):
                    expect(reason).to_contain("not allowed")

# ============================================================================
# Allow-Origin Parsing
# ============================================================================

describe "CORS Allow-Origin Parsing":
    context "parse_allow_origin":
        it "parse_allow_origin handles wildcard":
            expect(parse_allow_origin("*")).to_equal("*")

        it "parse_allow_origin handles specific origin":
            expect(parse_allow_origin("https://example.com")).to_equal("https://example.com")

# ============================================================================
# Redirect Detection
# ============================================================================

describe "Fetch Redirect Detection":
    context "should_redirect":
        it "should_redirect returns true for 301":
            expect(should_redirect(301)).to_equal(true)

        it "should_redirect returns true for 302":
            expect(should_redirect(302)).to_equal(true)

        it "should_redirect returns false for 200":
            expect(should_redirect(200)).to_equal(false)

# ============================================================================
# Response Cacheability
# ============================================================================

describe "Fetch Response Cacheability":
    context "is_cacheable":
        it "is_cacheable returns true for 200 response":
            expect(is_cacheable(200)).to_equal(true)

        it "is_cacheable returns false for 404 response":
            expect(is_cacheable(404)).to_equal(false)
