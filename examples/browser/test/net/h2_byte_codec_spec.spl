#![allow(unnamed_duplicate_typed_args)]

use std.spec
use examples.browser.feature.net.h2_client.{decode_byte, encode_byte}

describe "HTTP/2 byte codec":
    it "round trips ASCII control bytes without question mark placeholders":
        expect(decode_byte(encode_byte(1), 0)).to_equal(1)
        expect(decode_byte(encode_byte(2), 0)).to_equal(2)
        expect(decode_byte(encode_byte(8), 0)).to_equal(8)
        expect(decode_byte(encode_byte(31), 0)).to_equal(31)

    it "keeps existing printable and named control byte behavior":
        expect(decode_byte(encode_byte(0), 0)).to_equal(0)
        expect(decode_byte(encode_byte(9), 0)).to_equal(9)
        expect(decode_byte(encode_byte(10), 0)).to_equal(10)
        expect(decode_byte(encode_byte(13), 0)).to_equal(13)
        expect(decode_byte(encode_byte(65), 0)).to_equal(65)
        expect(decode_byte(encode_byte(126), 0)).to_equal(126)
