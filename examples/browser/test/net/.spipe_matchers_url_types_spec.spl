"""
# URL Types

Tests for URL parsing and origin serialization used by fetch, CORS, cookies,
redirects, and site isolation.
"""

use std.spec
use examples.browser.entity.net.url_types.{Url, Origin, is_same_origin}

describe "Url.parse":
    it "parses absolute HTTPS URLs into structured fields":
        val url = Url.parse("https://api.example.com/data/items?q=one#top")
        expect url.scheme == "https"
        expect url.host == "api.example.com"
        expect url.port == 443
        expect url.path == "/data/items"
        expect url.query == "q=one"
        expect url.fragment == "top"
        expect url.to_text() == "https://api.example.com/data/items?q=one#top"

    it "parses explicit non-default ports":
        val url = Url.parse("http://localhost:8080/app")
        expect url.scheme == "http"
        expect url.host == "localhost"
        expect url.port == 8080
        expect url.path == "/app"
        expect url.to_text() == "http://localhost:8080/app"

    it "keeps slash path when URL has only authority":
        val url = Url.parse("https://example.com")
        expect url.path == "/"
        expect url.to_text() == "https://example.com/"

    it "strips userinfo before host matching":
        val url = Url.parse("https://user:pass@example.com/private")
        expect url.host == "example.com"
        expect url.path == "/private"

describe "Origin":
    it "serializes parsed default ports without explicit port text":
        val origin = Origin.from_url(Url.parse("https://example.com/index.html"))
        expect origin.to_text() == "https://example.com"

    it "serializes non-default ports":
        val origin = Origin.from_url(Url.parse("https://example.com:8443/index.html"))
        expect origin.to_text() == "https://example.com:8443"

    it "compares default and explicit default ports as same origin":
        val a = Origin.from_url(Url.parse("https://example.com/a"))
        val b = Origin.from_url(Url.parse("https://example.com:443/b"))
        expect is_same_origin(a, b) == true

    it "rejects different schemes as different origins":
        val a = Origin.from_url(Url.parse("https://example.com/a"))
        val b = Origin.from_url(Url.parse("http://example.com/a"))
        expect is_same_origin(a, b) == false