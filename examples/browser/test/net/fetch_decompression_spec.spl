#![allow(unnamed_duplicate_typed_args)]
# Fetch decompression integration tests.
#
# Category: Browser Platform Networking
# Status: Active
#
# Validates Content-Encoding decompression in the fetch pipeline:
# Accept-Encoding header injection, zstd/lz4 body decompression, fail-closed
# for unsupported codecs, and no-op for missing/identity encodings.
#
# Run with: bin/simple test examples/browser/test/net/fetch_decompression_spec.spl

use std.spec
use std.common.compress.{CompressionCodec, CompressionError, CompressionOptions, try_compress_bytes, decompress_bytes, default_compression_options}

extern fn string_to_bytes(text: text) -> [u8]
extern fn bytes_to_string(bytes: [u8]) -> text

# ============================================================================
# Helpers
# ============================================================================

fn _payload() -> [u8]:
    # 64 bytes of repeated 'A' — compresses well, exercises codec paths
    val t = "AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA"
    string_to_bytes(t)

# ============================================================================
# Round-trip guard — this MUST pass before any decompression test is trusted
# ============================================================================

describe "bytes_to_string / string_to_bytes round-trip":
    it "round-trips arbitrary bytes through text without corruption":
        val original = _payload()
        val compressed = try_compress_bytes(original, default_compression_options(CompressionCodec.zstd)).unwrap()
        val as_text = bytes_to_string(compressed)
        val recovered = string_to_bytes(as_text)
        expect(recovered.len()).to_equal(compressed.len())
