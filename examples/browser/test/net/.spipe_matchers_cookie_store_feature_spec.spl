use examples.browser.feature.net.cookie_store.{CookieStore, parse_set_cookie}
use examples.browser.entity.net.cookie_types.{Cookie, SameSite}
use examples.browser.entity.net.url_types.Url
use examples.browser.shared.logging.{Logger, LogLevel}

fn https_url(host: text, path: text) -> Url:
    Url(scheme: "https", host: host, port: 443, path: path, query: "", fragment: "", raw: "")

fn http_url(host: text, path: text) -> Url:
    Url(scheme: "http", host: host, port: 80, path: path, query: "", fragment: "", raw: "")

fn result_is_err(header: text, url: Url) -> bool:
    val result = parse_set_cookie(header, url)
    match result:
        Err(_): true
        Ok(_): false

fn result_domain(header: text, url: Url) -> text:
    val result = parse_set_cookie(header, url)
    match result:
        Ok(cookie): cookie.domain
        Err(_): ""

describe "CookieStore feature":
    it "rejects Set-Cookie Domain attributes outside the request host":
        val url = https_url("example.com", "/account/login")

        expect result_is_err("sid=1; Domain=evil.com; Path=/", url) == true
        expect result_domain("sid=1; Domain=.example.com; Path=/", url) == "example.com"

    it "requires Secure for SameSite=None cookies":
        val url = https_url("example.com", "/")

        expect result_is_err("sid=1; SameSite=None", url) == true
        expect result_is_err("sid=1; SameSite=None; Secure", url) == false

    it "rejects Secure cookies set from non-HTTPS origins":
        expect result_is_err("sid=1; Secure", http_url("example.com", "/")) == true

    it "filters Secure cookies from HTTP requests in the production store":
        var store = CookieStore.new(Logger.new("cookie-store-feature-spec", LogLevel.Error))
        val secure_cookie = Cookie(
            name: "sid", value: "secure", domain: "example.com",
            path: "/", expires: 0, secure: true,
            http_only: true, same_site: SameSite.Lax
        )
        val plain_cookie = Cookie(
            name: "theme", value: "dark", domain: "example.com",
            path: "/", expires: 0, secure: false,
            http_only: false, same_site: SameSite.Lax
        )
        store.set_cookie(secure_cookie)
        store.set_cookie(plain_cookie)
        val https_cookies = store.get_cookies(https_url("example.com", "/"))
        val http_cookies = store.get_cookies(http_url("example.com", "/"))

        expect https_cookies.len() == 2
        expect http_cookies.len() == 1