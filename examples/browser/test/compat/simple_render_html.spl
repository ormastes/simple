extern fn rt_cli_get_args() -> [text]

use std.io.{file_read}
use std.gc_async_mut.gpu.browser_engine.browser_renderer.{render_html_to_pixels_with_viewport}
use examples.browser.test.compat.image_export.{export_ppm}

fn main() -> i64:
    val argv = rt_cli_get_args()
    if argv.len() < 6:
        return 1

    val input_path = argv[2]
    val output_path = argv[3]
    val width = argv[4].parse_i32() ?? 800
    val height = argv[5].parse_i32() ?? 600

    val html = file_read(input_path)
    if html.len() == 0:
        return 2

    val rendered = render_html_to_pixels_with_viewport(html, width, height)
    if rendered.pixel_data.len() == 0:
        return 3

    if not export_ppm(output_path, rendered.pixel_data, rendered.width, rendered.height):
        return 4
    0
