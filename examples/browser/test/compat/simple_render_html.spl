#![allow(REQC001)]
#![allow(REQC004)]
#![allow(unnamed_duplicate_typed_args)]
extern fn rt_cli_get_args() -> [text]
extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_write_text(path: text, content: text) -> bool
use std.gc_async_mut.gpu.browser_engine.simple_web_html_renderer.{simple_web_render_html_to_pixels}

fn export_ppm_text(pixels: [u32], width: i32, height: i32) -> text:
    var ppm = "P3\n{width} {height}\n255\n"
    var col = 0
    for pixel in pixels:
        val r = (pixel >> 16) & 0xFF
        val g = (pixel >> 8) & 0xFF
        val b = pixel & 0xFF
        ppm = "{ppm}{r} {g} {b} "
        col = col + 1
        if col >= width:
            ppm = "{ppm}\n"
            col = 0
    ppm

fn main() -> i64:
    val argv = rt_cli_get_args()
    if argv.len() < 6:
        return 1

    val input_path = argv[2]
    val output_path = argv[3]
    val width = argv[4].parse_i32() ?? 800
    val height = argv[5].parse_i32() ?? 600

    val html = rt_file_read_text(input_path) ?? ""
    if html.len() == 0:
        return 2

    val pixels = simple_web_render_html_to_pixels(html, width, height)
    if pixels.len() == 0:
        return 3

    val ppm = export_ppm_text(pixels, width, height)
    if not rt_file_write_text(output_path, ppm):
        return 4
    0
