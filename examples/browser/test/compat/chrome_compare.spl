# Chrome Rendering Comparison Suite
#
# Renders test HTML pages through both the Simple browser engine and
# Chrome (via headless screenshot), then compares pixel output.
#
# Workflow:
#   1. Render HTML with Simple's BrowserRenderer → pixel buffer
#   2. Export as PPM/PNG
#   3. Take Chrome screenshot of same HTML (external tool)
#   4. Load Chrome screenshot
#   5. Compare pixel buffers
#
# External dependencies (for Chrome comparison):
#   - Chrome/Chromium installed
#   - Node.js + Puppeteer, OR
#   - chrome --headless --screenshot
#
# Usage:
#   val suite = ChromeCompare.new(800, 600, logger)
#   val results = suite.run_all_tests()
#   print results.report()

use examples.browser.test.compat.image_export.{ComparisonMetrics, compare_pixel_buffers,
    export_ppm_text, generate_comparison_report}
use examples.browser.test.compat.test_manifest.{TestManifest, TestEntry}
use examples.browser.shared.logging.{Logger, LogLevel}
use std.gc_async_mut.gpu.browser_engine.browser_renderer.{BrowserRenderer}

extern fn rt_file_read_text(path: text) -> text
extern fn rt_fs_list_dir(path: text) -> [text]
extern fn rt_fs_is_dir(path: text) -> bool

# =========================================================================
# Test Page Definitions
# =========================================================================

class TestPage:
    name: text
    html: text
    category: text
    description: text

fn build_test_pages() -> [TestPage]:
    """Build the comprehensive set of HTML test pages for Chrome comparison."""
    var pages: [TestPage] = []

    # ---- Box Model ----
    pages = pages + [TestPage(
        name: "box-model-basic",
        category: "box-model",
        description: "Basic box model with margin, padding, border",
        html: "<html><body style='margin:0;padding:0'><div style='margin:20px;padding:15px;border:2px solid #333;width:200px;height:100px;background:#e0e0e0'>Box Model</div></body></html>"
    )]

    pages = pages + [TestPage(
        name: "box-model-centering",
        category: "box-model",
        description: "Auto margin centering",
        html: "<html><body style='margin:0;padding:0'><div style='width:300px;margin:20px auto;height:80px;background:#4CAF50;color:white;text-align:center;line-height:80px'>Centered</div></body></html>"
    )]

    # ---- Flexbox ----
    pages = pages + [TestPage(
        name: "flex-row",
        category: "flexbox",
        description: "Flex row with gap and alignment",
        html: "<html><body style='margin:0;padding:0'><div style='display:flex;gap:10px;padding:20px;background:#f5f5f5'><div style='width:100px;height:60px;background:#F44336'></div><div style='width:100px;height:80px;background:#2196F3'></div><div style='width:100px;height:40px;background:#4CAF50'></div></div></body></html>"
    )]

    pages = pages + [TestPage(
        name: "flex-center",
        category: "flexbox",
        description: "Flex centering (both axes)",
        html: "<html><body style='margin:0;padding:0'><div style='display:flex;justify-content:center;align-items:center;width:400px;height:200px;background:#E8EAF6'><div style='width:120px;height:60px;background:#3F51B5;border-radius:8px'></div></div></body></html>"
    )]

    pages = pages + [TestPage(
        name: "flex-column",
        category: "flexbox",
        description: "Flex column layout",
        html: "<html><body style='margin:0;padding:0'><div style='display:flex;flex-direction:column;gap:8px;width:200px;padding:16px;background:#FFF3E0'><div style='height:40px;background:#FF9800'></div><div style='height:40px;background:#FF5722'></div><div style='height:40px;background:#795548'></div></div></body></html>"
    )]

    # ---- Positioning ----
    pages = pages + [TestPage(
        name: "position-absolute",
        category: "positioning",
        description: "Absolute positioning within relative parent",
        html: "<html><body style='margin:0;padding:0'><div style='position:relative;width:300px;height:200px;background:#E3F2FD;margin:20px'><div style='position:absolute;top:20px;left:30px;width:80px;height:80px;background:#1976D2'></div><div style='position:absolute;bottom:20px;right:30px;width:60px;height:60px;background:#D32F2F'></div></div></body></html>"
    )]

    # ---- Colors ----
    pages = pages + [TestPage(
        name: "color-palette",
        category: "colors",
        description: "Named colors and hex values",
        html: "<html><body style='margin:0;padding:0;display:flex;flex-wrap:wrap'><div style='width:60px;height:60px;background:red'></div><div style='width:60px;height:60px;background:green'></div><div style='width:60px;height:60px;background:blue'></div><div style='width:60px;height:60px;background:yellow'></div><div style='width:60px;height:60px;background:purple'></div><div style='width:60px;height:60px;background:orange'></div><div style='width:60px;height:60px;background:cyan'></div><div style='width:60px;height:60px;background:pink'></div><div style='width:60px;height:60px;background:navy'></div><div style='width:60px;height:60px;background:teal'></div><div style='width:60px;height:60px;background:coral'></div><div style='width:60px;height:60px;background:rebeccapurple'></div></div></body></html>"
    )]

    # ---- Typography ----
    pages = pages + [TestPage(
        name: "text-styles",
        category: "typography",
        description: "Text decoration, alignment, sizing",
        html: "<html><body style='margin:0;padding:20px;font-family:sans-serif'><h1 style='font-size:32px;color:#333'>Heading 1</h1><p style='font-size:16px;color:#666;line-height:1.5'>Normal paragraph with <span style='font-weight:bold'>bold</span> and <span style='text-decoration:underline'>underline</span> text.</p><p style='text-align:center;color:red'>Centered red text</p><p style='text-align:right;color:blue'>Right-aligned blue text</p></body></html>"
    )]

    # ---- Borders ----
    pages = pages + [TestPage(
        name: "borders-multi",
        category: "borders",
        description: "Different border styles per side",
        html: "<html><body style='margin:0;padding:20px'><div style='width:200px;height:100px;border-top:3px solid red;border-right:3px solid green;border-bottom:3px solid blue;border-left:3px solid orange;padding:10px;background:#f9f9f9'>Multi borders</div></body></html>"
    )]

    # ---- Opacity and Visual ----
    pages = pages + [TestPage(
        name: "opacity-layers",
        category: "visual",
        description: "Overlapping elements with opacity",
        html: "<html><body style='margin:0;padding:0'><div style='position:relative;width:300px;height:200px'><div style='position:absolute;top:0;left:0;width:150px;height:150px;background:red;opacity:0.5'></div><div style='position:absolute;top:50px;left:50px;width:150px;height:150px;background:blue;opacity:0.5'></div></div></body></html>"
    )]

    # ---- Z-Index ----
    pages = pages + [TestPage(
        name: "z-index",
        category: "stacking",
        description: "Z-index stacking order",
        html: "<html><body style='margin:0;padding:20px'><div style='position:relative;width:250px;height:180px'><div style='position:absolute;z-index:1;top:0;left:0;width:120px;height:120px;background:#F44336'></div><div style='position:absolute;z-index:3;top:30px;left:30px;width:120px;height:120px;background:#4CAF50'></div><div style='position:absolute;z-index:2;top:60px;left:60px;width:120px;height:120px;background:#2196F3'></div></div></body></html>"
    )]

    # ---- Overflow ----
    pages = pages + [TestPage(
        name: "overflow-hidden",
        category: "overflow",
        description: "Overflow hidden clips content",
        html: "<html><body style='margin:0;padding:20px'><div style='width:150px;height:80px;overflow:hidden;background:#E8EAF6;border:1px solid #3F51B5'><div style='width:300px;height:200px;background:linear-gradient(red,blue)'>This text overflows and should be clipped</div></div></body></html>"
    )]

    pages

# =========================================================================
# ChromeCompare Runner
# =========================================================================

class ChromeCompareResult:
    test_name: text
    category: text
    metrics: ComparisonMetrics
    simple_ppm: text
    verdict: text

class ChromeCompareSuite:
    results: [ChromeCompareResult]
    total: i64
    pass_count: i64
    fail_count: i64

    static fn empty() -> ChromeCompareSuite:
        ChromeCompareSuite(results: [], total: 0, pass_count: 0, fail_count: 0)

    me add(result: ChromeCompareResult):
        self.results = self.results + [result]
        self.total = self.total + 1
        if result.metrics.match_percentage >= 90.0:
            self.pass_count = self.pass_count + 1
        else:
            self.fail_count = self.fail_count + 1

    fn overall_match_pct() -> f64:
        if self.results.len() == 0:
            return 0.0
        var total_pct = 0.0
        for r in self.results:
            total_pct = total_pct + r.metrics.match_percentage
        total_pct / self.results.len().to_f64()

    fn report() -> text:
        var r = "# Chrome Rendering Comparison Report\n\n"
        r = "{r}## Summary\n"
        r = "{r}- Tests: {self.total}\n"
        r = "{r}- Pass (>=90%): {self.pass_count}\n"
        r = "{r}- Fail (<90%): {self.fail_count}\n"
        r = "{r}- Overall match: {self.overall_match_pct()}%\n\n"

        r = "{r}## Per-Test Results\n\n"
        r = "{r}| Test | Category | Match % | RMSE | Verdict |\n"
        r = "{r}|------|----------|---------|------|--------|\n"
        for result in self.results:
            r = "{r}| {result.test_name} | {result.category} | {result.metrics.match_percentage}% | {result.metrics.rmse} | {result.verdict} |\n"

        r = "{r}\n## Category Breakdown\n\n"
        # Group by category
        var categories: [text] = []
        var cat_totals: [f64] = []
        var cat_counts: [i64] = []
        for result in self.results:
            var found = false
            var idx = 0
            for cat in categories:
                if cat == result.category:
                    cat_totals[idx] = cat_totals[idx] + result.metrics.match_percentage
                    cat_counts[idx] = cat_counts[idx] + 1
                    found = true
                idx = idx + 1
            if not found:
                categories = categories + [result.category]
                cat_totals = cat_totals + [result.metrics.match_percentage]
                cat_counts = cat_counts + [1]

        var ci = 0
        while ci < categories.len():
            val avg = cat_totals[ci] / cat_counts[ci].to_f64()
            r = "{r}- **{categories[ci]}**: {avg}% avg match ({cat_counts[ci]} tests)\n"
            ci = ci + 1

        r

class ChromeCompare:
    viewport_width: i32
    viewport_height: i32
    logger: Logger

    static fn new(width: i32, height: i32, logger: Logger) -> ChromeCompare:
        ChromeCompare(
            viewport_width: width,
            viewport_height: height,
            logger: logger
        )

    fn get_test_pages() -> [TestPage]:
        build_test_pages()

    fn test_count() -> i64:
        build_test_pages().len().to_i64()

    me run_simple_only(render_fn: fn(text, i32, i32) -> [u32]) -> ChromeCompareSuite:
        """Run all test pages through Simple renderer only.
        Use this when Chrome screenshots are not available.
        Generates PPM output files for manual comparison.
        """
        var suite = ChromeCompareSuite.empty()
        val pages = build_test_pages()

        for page in pages:
            self.logger.info("rendering: {page.name}")
            val pixels = render_fn(page.html, self.viewport_width, self.viewport_height)
            val ppm = export_ppm_text("", pixels, self.viewport_width, self.viewport_height)

            # Self-compare (always 100% match) — real comparison needs Chrome pixels
            val metrics = compare_pixel_buffers(pixels, pixels,
                                               self.viewport_width, self.viewport_height)

            val result = ChromeCompareResult(
                test_name: page.name,
                category: page.category,
                metrics: metrics,
                simple_ppm: ppm,
                verdict: "RENDERED (no Chrome reference)"
            )
            suite.add(result)
            self.logger.info("  {page.name}: rendered {pixels.len()} pixels")

        self.logger.info(suite.report())
        suite

    me run_comparison(render_fn: fn(text, i32, i32) -> [u32],
                      chrome_fn: fn(text, i32, i32) -> [u32]) -> ChromeCompareSuite:
        """Run comparison between Simple and Chrome renderers.
        Both render_fn and chrome_fn take (html, width, height) and return [u32] pixel buffers.
        """
        var suite = ChromeCompareSuite.empty()
        val pages = build_test_pages()

        for page in pages:
            self.logger.info("comparing: {page.name}")
            val simple_pixels = render_fn(page.html, self.viewport_width, self.viewport_height)
            val chrome_pixels = chrome_fn(page.html, self.viewport_width, self.viewport_height)

            val metrics = compare_pixel_buffers(simple_pixels, chrome_pixels,
                                               self.viewport_width, self.viewport_height)

            var verdict = "POOR"
            if metrics.match_percentage >= 99.0:
                verdict = "EXCELLENT"
            else if metrics.match_percentage >= 95.0:
                verdict = "GOOD"
            else if metrics.match_percentage >= 85.0:
                verdict = "FAIR"
            else if metrics.match_percentage >= 70.0:
                verdict = "PARTIAL"

            val ppm = export_ppm_text("", simple_pixels, self.viewport_width, self.viewport_height)

            val result = ChromeCompareResult(
                test_name: page.name,
                category: page.category,
                metrics: metrics,
                simple_ppm: ppm,
                verdict: verdict
            )
            suite.add(result)
            self.logger.info("  {page.name}: {metrics.match_percentage}% match — {verdict}")

        self.logger.info(suite.report())
        suite

# =========================================================================
# Directory-based Test Loading
# =========================================================================

fn build_test_pages_from_directory(dir: text) -> [TestPage]:
    """Load HTML test files from a directory and convert them to TestPage objects.
    Reads each .html file's content and extracts category/description from meta tags.
    """
    val manifest = TestManifest.from_directory(dir)
    var pages: [TestPage] = []

    for entry in manifest.all_tests():
        val html_content = rt_file_read_text(entry.path)
        val page = TestPage(
            name: entry.name,
            html: html_content,
            category: entry.category,
            description: "{entry.feature} test from {entry.category} suite"
        )
        pages = pages + [page]

    pages

fn render_simple_test(html: text, w: i32, h: i32) -> [u32]:
    """Render HTML through Simple's BrowserRenderer and return pixel buffer.
    Returns an ARGB u32 pixel array of size w*h.
    Falls back to a blank white canvas if rendering fails.
    """
    val renderer = BrowserRenderer.create(w, h)
    val rendered = renderer.render_html_to_pixels(html)
    if rendered.pixel_data.len() > 0:
        return rendered.pixel_data

    var pixels: [u32] = []
    val total = w * h
    var i = 0
    while i < total:
        pixels = pixels + [0xFFFFFFFF]
        i = i + 1
    pixels
