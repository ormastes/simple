#!/bin/sh
# Chrome vs Simple Comparison Runner
#
# Takes Chrome screenshots and compares them against Simple renderer output.
# Simplified version of pixel_suite_runner.shs for quick comparison.
#
# Usage:
#   ./chrome_vs_simple_runner.shs [html_dir] [output_dir]
#
# Output:
#   output_dir/report.md — Comparison report with per-test RMSE
#
# Dependencies:
#   - Chrome/Chromium
#   - ImageMagick (convert + compare commands)

HTML_DIR="${1:-$(cd "$(dirname "$0")" && pwd)/html}"
OUTPUT_DIR="${2:-/tmp/chrome_vs_simple}"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
CHROME_SCRIPT="$SCRIPT_DIR/chrome_screenshot.shs"
COMPARE_HELPER="$SCRIPT_DIR/compare_render_pair.spl"

WIDTH=800
HEIGHT=600

echo "=== Chrome vs Simple Runner ==="
echo "HTML dir: $HTML_DIR"
echo "Output:   $OUTPUT_DIR"
echo ""

mkdir -p "$OUTPUT_DIR/chrome" "$OUTPUT_DIR/simple" "$OUTPUT_DIR/diff"

COMPARE_BINARY="$OUTPUT_DIR/compare_render_pair.smf"
if [ ! -f "$COMPARE_BINARY" ]; then
    ./bin/simple compile "$COMPARE_HELPER" -o "$COMPARE_BINARY" >/dev/null 2>&1
fi
if [ ! -f "$COMPARE_BINARY" ]; then
    echo "Render comparison helper compile failed"
    exit 1
fi

COMPARE_SELFTEST_A="$OUTPUT_DIR/.compare_selftest_a.ppm"
COMPARE_SELFTEST_B="$OUTPUT_DIR/.compare_selftest_b.ppm"
COMPARE_SELFTEST_METRICS="$OUTPUT_DIR/.compare_selftest.txt"
COMPARE_SELFTEST_DIFF="$OUTPUT_DIR/.compare_selftest_diff.ppm"
cat >"$COMPARE_SELFTEST_A" <<'EOF'
P3
1 1
255
255 255 255
EOF
cp "$COMPARE_SELFTEST_A" "$COMPARE_SELFTEST_B"
if ! ./bin/simple "$COMPARE_BINARY" \
    "$COMPARE_SELFTEST_A" \
    "$COMPARE_SELFTEST_B" \
    1 1 \
    "$COMPARE_SELFTEST_METRICS" \
    "$COMPARE_SELFTEST_DIFF" \
    >/dev/null 2>&1; then
    echo "Simple standalone runtime cannot execute compat helpers yet (_rt_interp_call unresolved)"
    echo "Chrome screenshots still work via chrome_screenshot.shs, but full pixel diff needs the runtime loader fixed first."
    exit 1
fi

render_with_simple_test() {
    html_file="$1"
    output_ppm="$2"
    temp_spec="$OUTPUT_DIR/render_one_spec.spl"
    cat >"$temp_spec" <<EOF
use std.spec.*
use std.io.{file_write}
use examples.browser.test.compat.chrome_compare.{render_simple_test}
use examples.browser.test.compat.image_export.{export_ppm_text}
extern fn rt_file_read_text(path: text) -> text

describe "render one":
    it "renders html fixture to ppm":
        val html = rt_file_read_text("$html_file")
        val pixels = render_simple_test(html, $WIDTH, $HEIGHT)
        expect(pixels.len()).to_equal($((WIDTH * HEIGHT)))
        expect(file_write("$output_ppm", export_ppm_text("", pixels, $WIDTH, $HEIGHT))).to_equal(true)
EOF
    ./bin/simple test "$temp_spec" >/dev/null 2>&1
}

TOTAL=0
COMPARED=0
SUM_RMSE=0

for category_dir in "$HTML_DIR"/*/; do
    category="$(basename "$category_dir")"
    for html_file in "$category_dir"*.html; do
        [ -f "$html_file" ] || continue
        test_name="$(basename "$html_file" .html)"
        TOTAL=$((TOTAL + 1))

        # Chrome screenshot
        chrome_png="$OUTPUT_DIR/chrome/${test_name}.png"
        sh "$CHROME_SCRIPT" "$html_file" "$chrome_png" "$WIDTH" "$HEIGHT" 2>/dev/null

        if [ ! -f "$chrome_png" ]; then
            echo "SKIP $category/$test_name (no Chrome)"
            continue
        fi

        chrome_bmp="$OUTPUT_DIR/chrome/${test_name}.bmp"
        if ! /usr/bin/sips -s format bmp "$chrome_png" --out "$chrome_bmp" >/dev/null 2>&1; then
            echo "SKIP $category/$test_name (chrome conversion failed)"
            continue
        fi

        simple_ppm="$OUTPUT_DIR/simple/${test_name}.ppm"
        render_with_simple_test "$html_file" "$simple_ppm"
        if [ ! -f "$simple_ppm" ]; then
            echo "SKIP $category/$test_name (simple render failed)"
            continue
        fi

        metrics_txt="$OUTPUT_DIR/diff/${test_name}.txt"
        diff_ppm="$OUTPUT_DIR/diff/${test_name}.ppm"
        ./bin/simple "$COMPARE_BINARY" "$chrome_bmp" "$simple_ppm" "$WIDTH" "$HEIGHT" "$metrics_txt" "$diff_ppm" >/dev/null 2>&1

        if [ -f "$metrics_txt" ]; then
            match_pct=$(awk -F= '/^match_percentage=/{print $2}' "$metrics_txt")
            rmse=$(awk -F= '/^rmse=/{print $2}' "$metrics_txt")
            echo "$category/$test_name: match=${match_pct}% rmse=$rmse"
            COMPARED=$((COMPARED + 1))
        fi
    done
done

echo ""
echo "=== Results: $COMPARED/$TOTAL compared ==="
echo "Chrome:  $OUTPUT_DIR/chrome/"
echo "Simple:  $OUTPUT_DIR/simple/"
echo "Diff:    $OUTPUT_DIR/diff/"
