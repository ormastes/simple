# CSS Property Compatibility Tracker
#
# Tracks implementation status of CSS properties against the full
# CSS property index. Generates compatibility percentages and reports
# for measuring Chrome parity progress.

# =========================================================================
# Property Status
# =========================================================================

enum PropStatus:
    Implemented
    Partial
    Missing

class PropertyEntry:
    name: text
    status: PropStatus
    category: text
    notes: text

    static fn implemented(name: text, category: text) -> PropertyEntry:
        PropertyEntry(name: name, status: PropStatus.Implemented, category: category, notes: "")

    static fn partial(name: text, category: text, notes: text) -> PropertyEntry:
        PropertyEntry(name: name, status: PropStatus.Partial, category: category, notes: notes)

    static fn missing(name: text, category: text) -> PropertyEntry:
        PropertyEntry(name: name, status: PropStatus.Missing, category: category, notes: "")

# =========================================================================
# Compatibility Tracker
# =========================================================================

class CompatTracker:
    properties: [PropertyEntry]

    static fn new() -> CompatTracker:
        CompatTracker(properties: build_property_index())

    fn total() -> i64:
        self.properties.len().to_i64()

    fn implemented_count() -> i64:
        var count = 0
        for p in self.properties:
            match p.status:
                PropStatus.Implemented: count = count + 1
                _: pass_dn
        count

    fn partial_count() -> i64:
        var count = 0
        for p in self.properties:
            match p.status:
                PropStatus.Partial: count = count + 1
                _: pass_dn
        count

    fn missing_count() -> i64:
        var count = 0
        for p in self.properties:
            match p.status:
                PropStatus.Missing: count = count + 1
                _: pass_dn
        count

    fn parity_percentage() -> f64:
        """Chrome parity: implemented + 0.5*partial / total * 100."""
        val total = self.total().to_f64()
        if total == 0.0:
            return 0.0
        val impl = self.implemented_count().to_f64()
        val part = self.partial_count().to_f64()
        ((impl + part * 0.5) / total) * 100.0

    fn report() -> text:
        var lines = "CSS Property Compatibility Report\n"
        lines = "{lines}================================\n"
        lines = "{lines}Total properties: {self.total()}\n"
        lines = "{lines}Implemented: {self.implemented_count()}\n"
        lines = "{lines}Partial: {self.partial_count()}\n"
        lines = "{lines}Missing: {self.missing_count()}\n"
        lines = "{lines}Chrome parity: {self.parity_percentage()}%\n\n"

        # Group by category
        val categories = ["box-model", "display", "positioning", "sizing",
                         "typography", "color", "flexbox", "grid", "visual",
                         "overflow", "transform", "animation", "filter",
                         "selector", "at-rule", "misc"]
        for cat in categories:
            var cat_impl = 0
            var cat_total = 0
            for p in self.properties:
                if p.category == cat:
                    cat_total = cat_total + 1
                    match p.status:
                        PropStatus.Implemented: cat_impl = cat_impl + 1
                        _: pass_dn
            if cat_total > 0:
                lines = "{lines}{cat}: {cat_impl}/{cat_total}\n"

        lines = "{lines}\nMissing properties:\n"
        for p in self.properties:
            match p.status:
                PropStatus.Missing:
                    lines = "{lines}  - {p.name} ({p.category})\n"
                _: pass_dn

        lines

# =========================================================================
# Property Index — all tracked CSS properties with status
# =========================================================================

fn build_property_index() -> [PropertyEntry]:
    var props: [PropertyEntry] = []

    # Box Model — implemented
    props = props + [PropertyEntry.implemented("margin-top", "box-model")]
    props = props + [PropertyEntry.implemented("margin-right", "box-model")]
    props = props + [PropertyEntry.implemented("margin-bottom", "box-model")]
    props = props + [PropertyEntry.implemented("margin-left", "box-model")]
    props = props + [PropertyEntry.implemented("padding-top", "box-model")]
    props = props + [PropertyEntry.implemented("padding-right", "box-model")]
    props = props + [PropertyEntry.implemented("padding-bottom", "box-model")]
    props = props + [PropertyEntry.implemented("padding-left", "box-model")]
    props = props + [PropertyEntry.implemented("border-top-width", "box-model")]
    props = props + [PropertyEntry.implemented("border-right-width", "box-model")]
    props = props + [PropertyEntry.implemented("border-bottom-width", "box-model")]
    props = props + [PropertyEntry.implemented("border-left-width", "box-model")]
    props = props + [PropertyEntry.implemented("border-top-color", "box-model")]
    props = props + [PropertyEntry.implemented("border-right-color", "box-model")]
    props = props + [PropertyEntry.implemented("border-bottom-color", "box-model")]
    props = props + [PropertyEntry.implemented("border-left-color", "box-model")]
    props = props + [PropertyEntry.implemented("border-top-style", "box-model")]
    props = props + [PropertyEntry.implemented("border-right-style", "box-model")]
    props = props + [PropertyEntry.implemented("border-bottom-style", "box-model")]
    props = props + [PropertyEntry.implemented("border-left-style", "box-model")]
    props = props + [PropertyEntry.implemented("border-top-left-radius", "box-model")]
    props = props + [PropertyEntry.implemented("border-top-right-radius", "box-model")]
    props = props + [PropertyEntry.implemented("border-bottom-right-radius", "box-model")]
    props = props + [PropertyEntry.implemented("border-bottom-left-radius", "box-model")]

    # Display
    props = props + [PropertyEntry.implemented("display", "display")]

    # Positioning
    props = props + [PropertyEntry.implemented("position", "positioning")]
    props = props + [PropertyEntry.implemented("top", "positioning")]
    props = props + [PropertyEntry.implemented("right", "positioning")]
    props = props + [PropertyEntry.implemented("bottom", "positioning")]
    props = props + [PropertyEntry.implemented("left", "positioning")]
    props = props + [PropertyEntry.implemented("float", "positioning")]
    props = props + [PropertyEntry.implemented("z-index", "positioning")]
    props = props + [PropertyEntry.implemented("clear", "positioning")]

    # Sizing
    props = props + [PropertyEntry.implemented("width", "sizing")]
    props = props + [PropertyEntry.implemented("height", "sizing")]
    props = props + [PropertyEntry.implemented("min-width", "sizing")]
    props = props + [PropertyEntry.implemented("max-width", "sizing")]
    props = props + [PropertyEntry.implemented("min-height", "sizing")]
    props = props + [PropertyEntry.implemented("max-height", "sizing")]
    props = props + [PropertyEntry.implemented("aspect-ratio", "sizing")]

    # Typography
    props = props + [PropertyEntry.implemented("color", "typography")]
    props = props + [PropertyEntry.implemented("font-family", "typography")]
    props = props + [PropertyEntry.implemented("font-size", "typography")]
    props = props + [PropertyEntry.implemented("font-weight", "typography")]
    props = props + [PropertyEntry.implemented("font-style", "typography")]
    props = props + [PropertyEntry.implemented("line-height", "typography")]
    props = props + [PropertyEntry.implemented("text-align", "typography")]
    props = props + [PropertyEntry.implemented("text-decoration", "typography")]
    props = props + [PropertyEntry.implemented("text-indent", "typography")]
    props = props + [PropertyEntry.implemented("text-transform", "typography")]
    props = props + [PropertyEntry.implemented("letter-spacing", "typography")]
    props = props + [PropertyEntry.implemented("word-spacing", "typography")]
    props = props + [PropertyEntry.implemented("white-space", "typography")]
    props = props + [PropertyEntry.implemented("text-overflow", "typography")]
    props = props + [PropertyEntry.implemented("word-break", "typography")]
    props = props + [PropertyEntry.implemented("overflow-wrap", "typography")]
    props = props + [PropertyEntry.implemented("text-shadow", "typography")]
    props = props + [PropertyEntry.implemented("vertical-align", "typography")]

    # Color/Background
    props = props + [PropertyEntry.implemented("background-color", "color")]
    props = props + [PropertyEntry.implemented("background-image", "color")]
    props = props + [PropertyEntry.implemented("opacity", "color")]
    props = props + [PropertyEntry.implemented("background-position", "color")]
    props = props + [PropertyEntry.implemented("background-size", "color")]
    props = props + [PropertyEntry.implemented("background-repeat", "color")]
    props = props + [PropertyEntry.missing("background-attachment", "color")]
    props = props + [PropertyEntry.missing("background-clip", "color")]
    props = props + [PropertyEntry.missing("background-origin", "color")]

    # Flexbox
    props = props + [PropertyEntry.implemented("flex-direction", "flexbox")]
    props = props + [PropertyEntry.implemented("flex-wrap", "flexbox")]
    props = props + [PropertyEntry.implemented("justify-content", "flexbox")]
    props = props + [PropertyEntry.implemented("align-items", "flexbox")]
    props = props + [PropertyEntry.implemented("align-content", "flexbox")]
    props = props + [PropertyEntry.implemented("flex-grow", "flexbox")]
    props = props + [PropertyEntry.implemented("flex-shrink", "flexbox")]
    props = props + [PropertyEntry.implemented("flex-basis", "flexbox")]
    props = props + [PropertyEntry.implemented("row-gap", "flexbox")]
    props = props + [PropertyEntry.implemented("column-gap", "flexbox")]
    props = props + [PropertyEntry.implemented("align-self", "flexbox")]
    props = props + [PropertyEntry.implemented("order", "flexbox")]

    # Grid
    props = props + [PropertyEntry.implemented("grid-template-columns", "grid")]
    props = props + [PropertyEntry.implemented("grid-template-rows", "grid")]
    props = props + [PropertyEntry.implemented("grid-column", "grid")]
    props = props + [PropertyEntry.implemented("grid-row", "grid")]
    props = props + [PropertyEntry.partial("grid-area", "grid", "shorthand not expanded")]
    props = props + [PropertyEntry.implemented("grid-auto-flow", "grid")]
    props = props + [PropertyEntry.implemented("grid-auto-columns", "grid")]
    props = props + [PropertyEntry.implemented("grid-auto-rows", "grid")]

    # Visual
    props = props + [PropertyEntry.implemented("visibility", "visual")]
    props = props + [PropertyEntry.implemented("box-shadow", "visual")]
    props = props + [PropertyEntry.implemented("outline", "visual")]
    props = props + [PropertyEntry.implemented("cursor", "visual")]
    props = props + [PropertyEntry.implemented("pointer-events", "visual")]
    props = props + [PropertyEntry.implemented("user-select", "visual")]

    # Overflow
    props = props + [PropertyEntry.implemented("overflow-x", "overflow")]
    props = props + [PropertyEntry.implemented("overflow-y", "overflow")]
    props = props + [PropertyEntry.missing("scroll-behavior", "overflow")]

    # Transform
    props = props + [PropertyEntry.implemented("transform", "transform")]
    props = props + [PropertyEntry.implemented("transform-origin", "transform")]
    props = props + [PropertyEntry.partial("perspective", "transform", "property tracked, 3D transform not rendered")]
    props = props + [PropertyEntry.partial("perspective-origin", "transform", "property tracked")]

    # Animation
    props = props + [PropertyEntry.implemented("transition-property", "animation")]
    props = props + [PropertyEntry.implemented("transition-duration", "animation")]
    props = props + [PropertyEntry.partial("animation-name", "animation", "engine exists, controller wired")]
    props = props + [PropertyEntry.partial("animation-duration", "animation", "engine exists")]
    props = props + [PropertyEntry.implemented("transition-timing-function", "animation")]
    props = props + [PropertyEntry.implemented("transition-delay", "animation")]
    props = props + [PropertyEntry.implemented("animation-timing-function", "animation")]
    props = props + [PropertyEntry.implemented("animation-delay", "animation")]
    props = props + [PropertyEntry.implemented("animation-iteration-count", "animation")]
    props = props + [PropertyEntry.implemented("animation-direction", "animation")]
    props = props + [PropertyEntry.implemented("animation-fill-mode", "animation")]

    # Filter
    props = props + [PropertyEntry.implemented("filter", "filter")]
    props = props + [PropertyEntry.implemented("backdrop-filter", "filter")]
    props = props + [PropertyEntry.missing("mix-blend-mode", "filter")]
    props = props + [PropertyEntry.missing("isolation", "filter")]

    # At-rules
    props = props + [PropertyEntry.implemented("@media", "at-rule")]
    props = props + [PropertyEntry.partial("@keyframes", "at-rule", "parsed but not fully executed")]
    props = props + [PropertyEntry.partial("@font-face", "at-rule", "parsed but font loading not wired")]
    props = props + [PropertyEntry.implemented("@container", "at-rule")]
    props = props + [PropertyEntry.implemented("@supports", "at-rule")]
    props = props + [PropertyEntry.implemented("@layer", "at-rule")]

    # CSS Functions
    props = props + [PropertyEntry.implemented("calc()", "misc")]
    props = props + [PropertyEntry.implemented("min()", "misc")]
    props = props + [PropertyEntry.implemented("max()", "misc")]
    props = props + [PropertyEntry.implemented("clamp()", "misc")]
    props = props + [PropertyEntry.implemented("var()", "misc")]
    props = props + [PropertyEntry.missing("env()", "misc")]
    props = props + [PropertyEntry.missing("attr()", "misc")]

    # Misc
    props = props + [PropertyEntry.implemented("content", "misc")]
    props = props + [PropertyEntry.implemented("contain", "misc")]
    props = props + [PropertyEntry.implemented("container-type", "misc")]
    props = props + [PropertyEntry.implemented("container-name", "misc")]
    props = props + [PropertyEntry.implemented("writing-mode", "misc")]
    props = props + [PropertyEntry.implemented("direction", "misc")]

    props
