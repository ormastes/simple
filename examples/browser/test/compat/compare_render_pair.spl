extern fn rt_cli_get_args() -> [text]

use std.io.{file_write}

use examples.browser.test.compat.image_export.{compare_pixel_buffers, export_ppm,
    generate_diff_image, load_pixels_from_image}

fn main() -> i64:
    val argv = rt_cli_get_args()
    if argv.len() < 8:
        return 1

    val baseline_path = argv[2]
    val candidate_path = argv[3]
    val width = argv[4].parse_i32() ?? 800
    val height = argv[5].parse_i32() ?? 600
    val metrics_path = argv[6]
    val diff_path = argv[7]

    val baseline_pixels = load_pixels_from_image(baseline_path)
    val candidate_pixels = load_pixels_from_image(candidate_path)
    if baseline_pixels.len() == 0 or candidate_pixels.len() == 0:
        return 2

    val metrics = compare_pixel_buffers(baseline_pixels, candidate_pixels, width, height)
    val diff_pixels = generate_diff_image(baseline_pixels, candidate_pixels, width, height)
    if not export_ppm(diff_path, diff_pixels, width, height):
        return 3

    val metrics_text = "match_percentage={metrics.match_percentage}\nrmse={metrics.rmse}\nmatching_pixels={metrics.matching_pixels}\ndifferent_pixels={metrics.different_pixels}\nmax_channel_diff={metrics.max_channel_diff}\navg_channel_diff={metrics.avg_channel_diff}\n"
    if not file_write(metrics_path, metrics_text):
        return 4
    0
