extern fn rt_cli_get_args() -> [text]

use std.io.{file_read}
use std.gc_async_mut.gpu.browser_engine.widget_to_dom.{html_string_to_dom,
    parse_tag, split_tag_parts}
use std.gc_async_mut.gpu.browser_engine.browser_renderer.{render_html_to_pixels_with_viewport}

fn main() -> i64:
    val argv = rt_cli_get_args()
    val mode = if argv.len() > 2: argv[2] else: "file"

    if mode == "file":
        val html = file_read("../../examples/browser/test/compat/html/flexbox/flex-row.html")
        if html.len() > 0:
            return 10
        return 11

    if mode == "parse-div":
        val dom = html_string_to_dom("<div></div>")
        if dom.tag == "div":
            return 20
        return 21

    if mode == "parse-open-div":
        val dom = html_string_to_dom("<div>")
        if dom.tag == "div":
            return 26
        return 27

    if mode == "parse-text-div":
        val dom = html_string_to_dom("<div>x</div>")
        if dom.tag == "div":
            return 28
        return 29

    if mode == "split-tag":
        val parts = split_tag_parts("div")
        if parts.len() == 1:
            return 22
        return 23

    if mode == "parse-tag":
        val dom = parse_tag("div")
        if dom.tag == "div":
            return 24
        return 25

    if mode == "parse-doctype":
        val dom = html_string_to_dom("<!DOCTYPE html><html></html>")
        if dom.tag == "div":
            return 30
        return 31

    if mode == "parse-file":
        val html = file_read("../../examples/browser/test/compat/html/flexbox/flex-row.html")
        val dom = html_string_to_dom(html)
        if dom.tag == "div":
            return 40
        return 41

    if mode == "render-div":
        val rendered = render_html_to_pixels_with_viewport("<div></div>", 32, 32)
        if rendered.width == 32 and rendered.height == 32:
            return 50
        return 51

    if mode == "render-file":
        val html = file_read("../../examples/browser/test/compat/html/flexbox/flex-row.html")
        val rendered = render_html_to_pixels_with_viewport(html, 32, 32)
        if rendered.width == 32 and rendered.height == 32:
            return 60
        return 61

    99
