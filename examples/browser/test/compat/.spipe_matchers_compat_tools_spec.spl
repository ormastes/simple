"""
# Compat Tools

Tests for compat tools functionality.
"""
use std.spec.*

use examples.browser.test.compat.test_manifest.{TestManifest}
use examples.browser.test.compat.chrome_compare.{ChromeCompare, render_simple_test}
use examples.browser.shared.logging.{Logger, LogLevel}

fn solid_render(_html: text, w: i32, h: i32) -> [u32]:
    var pixels: [u32] = []
    val total = w * h
    var i = 0
    while i < total:
        pixels = pixels + [0xFFFFFFFF]
        i = i + 1
    pixels

describe "browser compat tools":
    """
    ## Browser Compat Tools Tests

    Validates browser compat tools functionality.
    """


    it "scans compatibility html manifest recursively":
        val manifest = TestManifest.from_directory("examples/browser/test/compat/html")
        expect manifest.test_count() > 20
        expect manifest.categories().contains("flexbox") == true
        expect manifest.categories().contains("grid") == true

    it "renders html to non-empty pixel buffer":
        val html = "<html><body style='margin:0'><div style='width:64px;height:64px;background:#ff0000'></div></body></html>"
        val pixels = render_simple_test(html, 128, 128)
        expect pixels.len() == 128 * 128

        var non_white = false
        for pixel in pixels:
            if pixel != 0xFFFFFFFF:
                non_white = true
        expect non_white == true

    it "does not count simple-only renders as Chrome parity passes":
        val suite = ChromeCompare.new(8, 8, Logger.new("compat-tools-spec", LogLevel.Error)).run_simple_only(solid_render)
        expect suite.total > 0
        expect suite.pass_count == 0
        expect suite.fail_count == 0
        expect suite.unverified_count == suite.total
        expect suite.results[0].has_chrome_reference == false
        expect (suite.results[0].verdict).contains("UNVERIFIED")