#!/bin/sh
# Pixel Suite Runner — Full pixel comparison pipeline
#
# 1. Takes Chrome screenshots of all HTML test files
# 2. Converts PNG to PPM for pixel comparison
# 3. Runs Simple renderer on same files (placeholder — generates white canvas)
# 4. Compares pixels
# 5. Generates markdown report
#
# Usage:
#   ./pixel_suite_runner.shs [output_dir]
#
# Output:
#   output_dir/chrome/   — Chrome screenshots (PNG + PPM)
#   output_dir/simple/   — Simple renderer output (PPM)
#   output_dir/diff/     — Visual diff images (PPM)
#   output_dir/report.md — Comparison report
#
# Dependencies:
#   - Chrome/Chromium
#   - ImageMagick (convert command for PNG→PPM)

OUTPUT_DIR="${1:-/tmp/pixel_suite}"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
HTML_DIR="$SCRIPT_DIR/html"
CHROME_SCRIPT="$SCRIPT_DIR/chrome_screenshot.shs"
COMPARE_HELPER="$SCRIPT_DIR/compare_render_pair.spl"

WIDTH=800
HEIGHT=600

echo "=== Pixel Suite Runner ==="
echo "HTML dir: $HTML_DIR"
echo "Output:   $OUTPUT_DIR"
echo "Viewport: ${WIDTH}x${HEIGHT}"
echo ""

mkdir -p "$OUTPUT_DIR/chrome" "$OUTPUT_DIR/simple" "$OUTPUT_DIR/diff"

COMPARE_BINARY="$OUTPUT_DIR/compare_render_pair.smf"
if [ ! -f "$COMPARE_BINARY" ]; then
    ./bin/simple compile "$COMPARE_HELPER" -o "$COMPARE_BINARY" >/dev/null 2>&1
fi
if [ ! -f "$COMPARE_BINARY" ]; then
    echo "Error: failed to compile comparison helper"
    exit 1
fi

render_with_simple_test() {
    html_file="$1"
    output_ppm="$2"
    temp_spec="$OUTPUT_DIR/render_one_spec.spl"
    cat >"$temp_spec" <<EOF
use std.spec.*
use std.io.{file_write}
use examples.browser.test.compat.chrome_compare.{render_simple_test}
use examples.browser.test.compat.image_export.{export_ppm_text}
extern fn rt_file_read_text(path: text) -> text

describe "render one":
    it "renders html fixture to ppm":
        val html = rt_file_read_text("$html_file")
        val pixels = render_simple_test(html, $WIDTH, $HEIGHT)
        expect(pixels.len()).to_equal($((WIDTH * HEIGHT)))
        expect(file_write("$output_ppm", export_ppm_text("", pixels, $WIDTH, $HEIGHT))).to_equal(true)
EOF
    ./bin/simple test "$temp_spec" >/dev/null 2>&1
}

# Check dependencies
if ! sh "$CHROME_SCRIPT" --help >/dev/null 2>&1; then
    echo "Warning: Chrome may not be available"
fi

# Collect all HTML test files
TOTAL=0
PASS=0
FAIL=0
SKIP=0

REPORT="$OUTPUT_DIR/report.md"
echo "# Pixel Suite Report" > "$REPORT"
echo "" >> "$REPORT"
echo "Viewport: ${WIDTH}x${HEIGHT}" >> "$REPORT"
echo "Date: $(date -u +%Y-%m-%dT%H:%M:%SZ)" >> "$REPORT"
echo "" >> "$REPORT"
echo "| Test | Category | Chrome | Simple | Status |" >> "$REPORT"
echo "|------|----------|--------|--------|--------|" >> "$REPORT"

# Walk the html/ directory
for category_dir in "$HTML_DIR"/*/; do
    category="$(basename "$category_dir")"
    for html_file in "$category_dir"*.html; do
        [ -f "$html_file" ] || continue
        test_name="$(basename "$html_file" .html)"
        TOTAL=$((TOTAL + 1))

        echo "--- [$category] $test_name ---"

        # Step 1: Chrome screenshot
        chrome_png="$OUTPUT_DIR/chrome/${test_name}.png"
        sh "$CHROME_SCRIPT" "$html_file" "$chrome_png" "$WIDTH" "$HEIGHT" 2>/dev/null

        chrome_ok="NO"
        if [ -f "$chrome_png" ]; then
            chrome_ok="YES"
            echo "  Chrome: OK"
            /usr/bin/sips -s format bmp "$chrome_png" --out "$OUTPUT_DIR/chrome/${test_name}.bmp" >/dev/null 2>&1
        else
            echo "  Chrome: FAILED"
        fi

        # Step 2: Simple renderer
        simple_ppm="$OUTPUT_DIR/simple/${test_name}.ppm"
        render_with_simple_test "$html_file" "$simple_ppm"
        if [ ! -f "$simple_ppm" ]; then
            echo "  Simple: FAILED"
            SKIP=$((SKIP + 1))
            echo "| $test_name | $category | $chrome_ok | NO | simple render failed |" >> "$REPORT"
            continue
        fi
        echo "  Simple: OK"

        # Step 3: Compare with the built-in Simple helper.
        chrome_bmp="$OUTPUT_DIR/chrome/${test_name}.bmp"
        metrics_txt="$OUTPUT_DIR/diff/${test_name}.txt"
        diff_ppm="$OUTPUT_DIR/diff/${test_name}.ppm"
        if [ "$chrome_ok" = "YES" ] && [ -f "$chrome_bmp" ]; then
            ./bin/simple "$COMPARE_BINARY" "$chrome_bmp" "$simple_ppm" "$WIDTH" "$HEIGHT" "$metrics_txt" "$diff_ppm" >/dev/null 2>&1
            if [ -f "$metrics_txt" ]; then
                match_pct=$(awk -F= '/^match_percentage=/{print $2}' "$metrics_txt")
                rmse=$(awk -F= '/^rmse=/{print $2}' "$metrics_txt")
                echo "  Diff match: ${match_pct}%"
                echo "| $test_name | $category | $chrome_ok | YES | match ${match_pct}% rmse ${rmse} |" >> "$REPORT"
            else
                FAIL=$((FAIL + 1))
                echo "| $test_name | $category | $chrome_ok | YES | compare failed |" >> "$REPORT"
            fi
        else
            SKIP=$((SKIP + 1))
            echo "| $test_name | $category | $chrome_ok | YES | skipped |" >> "$REPORT"
        fi
    done
done

echo "" >> "$REPORT"
echo "## Summary" >> "$REPORT"
echo "- Total: $TOTAL" >> "$REPORT"
echo "- Failed: $FAIL" >> "$REPORT"
echo "- Skipped: $SKIP" >> "$REPORT"

echo ""
echo "=== Done: $TOTAL tests ==="
echo "Report: $REPORT"
echo "Chrome screenshots: $OUTPUT_DIR/chrome/"
echo "Simple output:      $OUTPUT_DIR/simple/"
echo "Diff images:        $OUTPUT_DIR/diff/"
