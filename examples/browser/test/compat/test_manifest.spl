#![allow(REQC001)]
#![allow(REQC004)]
#![allow(unnamed_duplicate_typed_args)]
# Test Manifest — Scan HTML test directory and build structured test list
#
# Recursively scans a directory for .html test files, parses meta tags
# (test-category, test-feature), and builds a structured manifest.
#
# Usage:
#   val manifest = TestManifest.from_directory("examples/browser/test/compat/html")
#   for entry in manifest.all_tests():
#       print "{entry.category}/{entry.name}: {entry.path}"

extern fn rt_file_read_text(path: text) -> text
extern fn rt_fs_list_dir(path: text) -> [text]
extern fn rt_fs_is_dir(path: text) -> bool

# =========================================================================
# TestEntry — one HTML test file
# =========================================================================

class TestEntry:
    name: text
    category: text
    feature: text
    path: text

    fn display() -> text:
        "{self.category}/{self.name} ({self.feature})"

# =========================================================================
# TestManifest — collection of test entries
# =========================================================================

class TestManifest:
    entries: [TestEntry]

    static fn empty() -> TestManifest:
        TestManifest(entries: [])

    static fn from_directory(dir: text) -> TestManifest:
        """Scan `dir` recursively for .html files and build a manifest."""
        val entries = scan_directory(dir)
        TestManifest(entries: entries)

    fn all_tests() -> [TestEntry]:
        self.entries

    fn tests_for_category(category: text) -> [TestEntry]:
        var filtered: [TestEntry] = []
        for entry in self.entries:
            if entry.category == category:
                filtered = filtered + [entry]
        filtered

    fn test_count() -> i32:
        self.entries.len().to_i32()

    fn categories() -> [text]:
        """Return unique category names."""
        var cats: [text] = []
        for entry in self.entries:
            var found = false
            for c in cats:
                if c == entry.category:
                    found = true
            if not found:
                cats = cats + [entry.category]
        cats

    fn summary() -> text:
        var s = "TestManifest: {self.test_count()} tests\n"
        for cat in self.categories():
            val cat_tests = self.tests_for_category(cat)
            s = "{s}  {cat}: {cat_tests.len()} tests\n"
        s

# =========================================================================
# Directory Scanner
# =========================================================================

fn scan_directory(dir: text) -> [TestEntry]:
    """Recursively scan directory for .html files and return discovered entries."""
    var entries: [TestEntry] = []
    val items = rt_fs_list_dir(dir)
    for item in items:
        val full_path = "{dir}/{item}"
        if rt_fs_is_dir(full_path):
            entries = entries + scan_directory(full_path)
        else if item.ends_with(".html"):
            val entry = parse_html_test_file(full_path, item)
            entries = entries + [entry]
    entries

# =========================================================================
# HTML Meta Tag Parser
# =========================================================================

fn parse_html_test_file(path: text, filename: text) -> TestEntry:
    """Parse an HTML test file and extract meta tag values."""
    val content = rt_file_read_text(path)
    val category = extract_meta_content(content, "test-category")
    val feature = extract_meta_content(content, "test-feature")
    val name = strip_html_extension(filename)

    TestEntry(
        name: name,
        category: if category != "": category else: "uncategorized",
        feature: if feature != "": feature else: name,
        path: path
    )

fn extract_meta_content(html: text, meta_name: text) -> text:
    """Extract the content attribute from <meta name="meta_name" content="...">."""
    # Search for: <meta name="meta_name" content="VALUE">
    val search_prefix = "name=\"{meta_name}\" content=\""
    val idx = text_find(html, search_prefix)
    if idx < 0:
        return ""
    val start = idx + search_prefix.len()
    val rest = text_substring(html, start, html.len())
    val end_quote = text_find(rest, "\"")
    if end_quote < 0:
        return ""
    text_substring(rest, 0, end_quote)

fn strip_html_extension(filename: text) -> text:
    """Remove .html extension from filename."""
    if filename.ends_with(".html"):
        return text_substring(filename, 0, filename.len() - 5)
    filename

# =========================================================================
# Text Helpers
# =========================================================================

fn text_find(haystack: text, needle: text) -> i64:
    """Find first occurrence of needle in haystack. Returns -1 if not found."""
    val hlen = haystack.len()
    val nlen = needle.len()
    if nlen > hlen:
        return -1
    var i = 0
    while i <= hlen - nlen:
        val slice = text_substring(haystack, i, i + nlen)
        if slice == needle:
            return i.to_i64()
        i = i + 1
    -1

fn text_substring(s: text, start: i64, end: i64) -> text:
    """Extract substring from start to end (exclusive)."""
    var result = ""
    var i = start
    while i < end:
        if i >= 0 and i < s.len():
            result = "{result}{s[i]}"
        i = i + 1
    result
