# WPT Low-Level Compat Check — uses direct DOM/layout/paint pipeline
#
# Avoids BrowserRenderer to minimize dependency surface.
# Pipeline: DOM build -> style blocks -> layout -> paint -> scene -> buffer

extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_write_text(path: text, content: text) -> bool

use std.gc_async_mut.gpu.browser_engine.dom.{BeDomNode}
use std.gc_async_mut.gpu.browser_engine.layout.{layout_tree}
use std.gc_async_mut.gpu.browser_engine.paint.{generate_paint_list,
    paint_commands_to_scene}
use std.gc_async_mut.gpu.browser_engine.style_block.{process_style_blocks}
use std.gc_async_mut.gpu.browser_engine.browser_renderer.{
    browser_renderer_html_string_to_dom}
use common.render_scene.executor.{execute_scene_to_buffer}

val W: i32 = 200
val H: i32 = 200

fn main() -> i64:
    print "=========================================="
    print "  Browser Compat Check (low-level)"
    print "=========================================="

    var passed = 0
    var failed = 0
    var total = 0

    # Test 1: Inline style
    total = total + 1
    if render_and_check("inline-style", "<div style=\"width: 100px; height: 100px; background-color: red;\"></div>"):
        passed = passed + 1
    else:
        failed = failed + 1

    # Test 2: <style> tag selector
    total = total + 1
    if render_and_check("style-tag-selector", "<style>div { background-color: blue; width: 100px; height: 100px; }</style><div></div>"):
        passed = passed + 1
    else:
        failed = failed + 1

    # Test 3: <style> class selector
    total = total + 1
    if render_and_check("style-class-selector", "<style>.box { background-color: green; width: 80px; height: 80px; }</style><div class=\"box\"></div>"):
        passed = passed + 1
    else:
        failed = failed + 1

    # Test 4: <style> ID selector
    total = total + 1
    if render_and_check("style-id-selector", "<style>#main { background-color: yellow; width: 120px; height: 60px; }</style><div id=\"main\"></div>"):
        passed = passed + 1
    else:
        failed = failed + 1

    # Test 5: Flexbox display
    total = total + 1
    if render_and_check("flexbox-display", "<style>div { display: flex; width: 200px; height: 50px; background-color: black; }</style><div></div>"):
        passed = passed + 1
    else:
        failed = failed + 1

    # Test 6: Named colors
    total = total + 1
    if render_and_check("named-color", "<style>div { background-color: navy; width: 100px; height: 100px; }</style><div></div>"):
        passed = passed + 1
    else:
        failed = failed + 1

    # Test 7: Hex color
    total = total + 1
    if render_and_check("hex-color", "<style>div { background-color: #FF6600; width: 100px; height: 100px; }</style><div></div>"):
        passed = passed + 1
    else:
        failed = failed + 1

    # Test 8: RGB color
    total = total + 1
    if render_and_check("rgb-color", "<style>div { background-color: rgb(128, 0, 255); width: 100px; height: 100px; }</style><div></div>"):
        passed = passed + 1
    else:
        failed = failed + 1

    # Test 9: Border
    total = total + 1
    if render_and_check("border", "<style>div { border: 2px solid red; width: 100px; height: 100px; }</style><div></div>"):
        passed = passed + 1
    else:
        failed = failed + 1

    # Test 10: Margin + padding
    total = total + 1
    if render_and_check("margin-padding", "<style>div { margin: 10px; padding: 10px; background: green; width: 80px; height: 80px; }</style><div></div>"):
        passed = passed + 1
    else:
        failed = failed + 1

    # Test 11: Display none
    total = total + 1
    val r11 = render_to_pixels("<style>.hidden { display: none; background: red; width: 100px; height: 100px; }</style><div class=\"hidden\"></div>")
    val nw11 = count_nonwhite(r11)
    if nw11 == 0:
        print "  PASS display-none"
        passed = passed + 1
    else:
        print "  FAIL display-none: {nw11} non-white pixels"
        failed = failed + 1

    # Test 12: flex-direction column
    total = total + 1
    if render_and_check("flex-column", "<style>.col { display: flex; flex-direction: column; width: 100px; } .item { background: blue; height: 30px; width: 100px; }</style><div class=\"col\"><div class=\"item\"></div><div class=\"item\"></div></div>"):
        passed = passed + 1
    else:
        failed = failed + 1

    # Test 13: justify-content center
    total = total + 1
    if render_and_check("justify-center", "<style>.f { display: flex; justify-content: center; width: 200px; height: 50px; background: gray; } .i { width: 50px; height: 50px; background: red; }</style><div class=\"f\"><div class=\"i\"></div></div>"):
        passed = passed + 1
    else:
        failed = failed + 1

    # Test 14: align-items center
    total = total + 1
    if render_and_check("align-center", "<style>.f { display: flex; align-items: center; width: 200px; height: 100px; background: gray; } .i { width: 50px; height: 30px; background: blue; }</style><div class=\"f\"><div class=\"i\"></div></div>"):
        passed = passed + 1
    else:
        failed = failed + 1

    # Test 15: Comma selectors
    total = total + 1
    if render_and_check("comma-selectors", "<style>p, span { background-color: red; width: 50px; height: 50px; display: block; }</style><p></p><span></span>"):
        passed = passed + 1
    else:
        failed = failed + 1

    # Test 16: Flex shorthand
    total = total + 1
    if render_and_check("flex-shorthand", "<style>.c { display: flex; width: 200px; height: 50px; } .i { flex: 1 0 0%; background: blue; height: 50px; }</style><div class=\"c\"><div class=\"i\"></div><div class=\"i\"></div></div>"):
        passed = passed + 1
    else:
        failed = failed + 1

    # Test 17: Background shorthand
    total = total + 1
    if render_and_check("background-shorthand", "<style>div { background: blue; width: 100px; height: 100px; }</style><div></div>"):
        passed = passed + 1
    else:
        failed = failed + 1

    # Test 18: Flex wrap
    total = total + 1
    if render_and_check("flex-wrap", "<style>.w { display: flex; flex-wrap: wrap; width: 100px; } .i { width: 60px; height: 30px; background: blue; }</style><div class=\"w\"><div class=\"i\"></div><div class=\"i\"></div></div>"):
        passed = passed + 1
    else:
        failed = failed + 1

    # Test 19: Gap
    total = total + 1
    if render_and_check("flex-gap", "<style>.g { display: flex; gap: 10px; width: 200px; } .i { width: 50px; height: 50px; background: red; }</style><div class=\"g\"><div class=\"i\"></div><div class=\"i\"></div></div>"):
        passed = passed + 1
    else:
        failed = failed + 1

    # Test 20: Position relative
    total = total + 1
    if render_and_check("position-relative", "<style>div { position: relative; top: 20px; left: 20px; background: green; width: 80px; height: 80px; }</style><div></div>"):
        passed = passed + 1
    else:
        failed = failed + 1

    # --- WPT reftest pairs ---
    print "\n--- WPT Reftest Pairs ---"
    val wpt_base = "examples/browser/test/compat/external/wpt"

    val flex_tests = ["flexbox_margin", "flexbox_inline", "flexbox_display",
        "flexbox_direction-column", "flexbox_direction-row-reverse",
        "flexbox_justifycontent-center", "flexbox_justifycontent-spacebetween",
        "flexbox_align-items-center", "flexbox_align-items-stretch",
        "flexbox_align-items-flexstart", "flexbox_flex-1-1-0", "flexbox_flex-none",
        "flexbox_wrap", "flexbox_flow-row-wrap",
        "flexbox_align-self-center", "flexbox_align-self-stretch"]

    for name in flex_tests:
        total = total + 1
        if run_reftest(wpt_base, "flexbox", name):
            passed = passed + 1
        else:
            failed = failed + 1

    val color_tests = ["background-color-rgb-001", "background-color-rgb-002",
        "background-color-rgb-003", "background-color-hsl-001",
        "background-color-hsl-002", "hex-003", "t424-hsl-values-b-1"]

    for name in color_tests:
        total = total + 1
        if run_reftest(wpt_base, "colors", name):
            passed = passed + 1
        else:
            failed = failed + 1

    # --- Acid tests ---
    print "\n--- Acid Tests ---"
    val acid_base = "examples/browser/test/compat/external"

    val acid1_html = rt_file_read_text("{acid_base}/acid1.html") ?? ""
    if acid1_html.len() > 0:
        total = total + 1
        val a1_pixels = render_to_pixels(acid1_html)
        val nw_a1 = count_nonwhite(a1_pixels)
        if nw_a1 > 1000:
            print "  PASS acid1: {nw_a1} colored pixels"
            passed = passed + 1
        else:
            print "  FAIL acid1: only {nw_a1} colored pixels"
            failed = failed + 1

    val acid2_html = rt_file_read_text("{acid_base}/acid2.html") ?? ""
    if acid2_html.len() > 0:
        total = total + 1
        val a2_pixels = render_to_pixels(acid2_html)
        val nw_a2 = count_nonwhite(a2_pixels)
        if nw_a2 > 100:
            print "  PASS acid2: {nw_a2} colored pixels"
            passed = passed + 1
        else:
            print "  FAIL acid2: only {nw_a2} colored pixels"
            failed = failed + 1

    # Summary
    print "\n=========================================="
    val rate = if total > 0: (passed.to_f64() / total.to_f64()) * 100.0 else: 0.0
    print "Total: {total}  Passed: {passed}  Failed: {failed}"
    print "Pass rate: {rate}%"
    print "=========================================="
    0

# =========================================================================
# Pipeline
# =========================================================================

fn render_to_pixels(html: text) -> [u32]:
    val dom = browser_renderer_html_string_to_dom(html)
    val layout = layout_tree(dom, W, H)
    val commands = generate_paint_list(layout)
    val scene = paint_commands_to_scene(commands, W, H)
    var buffer = init_buffer(W, H)
    execute_scene_to_buffer(scene, buffer, W, H)
    buffer

fn render_to_pixels_large(html: text) -> [u32]:
    val dom = browser_renderer_html_string_to_dom(html)
    val layout = layout_tree(dom, 800, 600)
    val commands = generate_paint_list(layout)
    val scene = paint_commands_to_scene(commands, 800, 600)
    var buffer = init_buffer(800, 600)
    execute_scene_to_buffer(scene, buffer, 800, 600)
    buffer

fn init_buffer(w: i32, h: i32) -> [u32]:
    var buffer: [u32] = []
    var i = 0
    val total = w * h
    while i < total:
        buffer = buffer + [0xFFFFFFFF]
        i = i + 1
    buffer

fn render_and_check(name: text, html: text) -> bool:
    val pixels = render_to_pixels(html)
    val nw = count_nonwhite(pixels)
    if nw > 100:
        print "  PASS {name}: {nw} non-white pixels"
        return true
    print "  FAIL {name}: only {nw} non-white pixels"
    false

fn count_nonwhite(pixels: [u32]) -> i64:
    var count = 0
    for px in pixels:
        if px != 0xFFFFFFFF:
            count = count + 1
    count

fn run_reftest(base: text, category: text, name: text) -> bool:
    val test_html = rt_file_read_text("{base}/{category}/{name}.html") ?? ""
    val ref_html = rt_file_read_text("{base}/{category}/{name}-ref.html") ?? ""
    if test_html.len() == 0 or ref_html.len() == 0:
        print "  SKIP {category}/{name}: files not found"
        return false

    val test_pixels = render_to_pixels_large(test_html)
    val ref_pixels = render_to_pixels_large(ref_html)

    var matching = 0
    val total = 800 * 600
    var i = 0
    while i < total:
        if i < test_pixels.len() and i < ref_pixels.len():
            if test_pixels[i] == ref_pixels[i]:
                matching = matching + 1
        i = i + 1
    val pct = if total > 0: (matching.to_f64() / total.to_f64()) * 100.0 else: 0.0
    if pct >= 95.0:
        print "  PASS {category}/{name}: {pct}%"
        return true
    print "  FAIL {category}/{name}: {pct}%"
    false
