#!/bin/sh
# Browser Rendering Comparison Runner
#
# Renders all test pages through both Simple and Chrome, then compares.
#
# Usage:
#   ./run_comparison.shs [output_dir]
#
# Output:
#   output_dir/simple/  — Simple renderer output (PPM/PNG)
#   output_dir/chrome/  — Chrome screenshots (PNG)
#   output_dir/diff/    — Difference images
#   output_dir/report.md — Comparison report
#
# Dependencies:
#   - Chrome/Chromium
#   - ImageMagick (convert, compare commands)
#   - Simple compiler (bin/simple)

OUTPUT_DIR="${1:-/tmp/browser_compare}"

mkdir -p "$OUTPUT_DIR/simple" "$OUTPUT_DIR/chrome" "$OUTPUT_DIR/diff" "$OUTPUT_DIR/html"

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/../../../.." && pwd)"

echo "=== Browser Rendering Comparison ==="
echo "Output: $OUTPUT_DIR"
echo ""

# Test pages — HTML content inline
declare -a TESTS=(
    "box-model-basic:<div style='margin:20px;padding:15px;border:2px solid #333;width:200px;height:100px;background:#e0e0e0'>Box Model</div>"
    "flex-row:<div style='display:flex;gap:10px;padding:20px;background:#f5f5f5'><div style='width:100px;height:60px;background:#F44336'></div><div style='width:100px;height:80px;background:#2196F3'></div><div style='width:100px;height:40px;background:#4CAF50'></div></div>"
    "flex-center:<div style='display:flex;justify-content:center;align-items:center;width:400px;height:200px;background:#E8EAF6'><div style='width:120px;height:60px;background:#3F51B5;border-radius:8px'></div></div>"
    "position-absolute:<div style='position:relative;width:300px;height:200px;background:#E3F2FD;margin:20px'><div style='position:absolute;top:20px;left:30px;width:80px;height:80px;background:#1976D2'></div><div style='position:absolute;bottom:20px;right:30px;width:60px;height:60px;background:#D32F2F'></div></div>"
    "color-palette:<div style='display:flex;flex-wrap:wrap'><div style='width:60px;height:60px;background:red'></div><div style='width:60px;height:60px;background:green'></div><div style='width:60px;height:60px;background:blue'></div><div style='width:60px;height:60px;background:yellow'></div><div style='width:60px;height:60px;background:purple'></div><div style='width:60px;height:60px;background:orange'></div></div>"
    "opacity-overlap:<div style='position:relative;width:300px;height:200px'><div style='position:absolute;top:0;left:0;width:150px;height:150px;background:red;opacity:0.5'></div><div style='position:absolute;top:50px;left:50px;width:150px;height:150px;background:blue;opacity:0.5'></div></div>"
    "z-index:<div style='position:relative;width:250px;height:180px'><div style='position:absolute;z-index:1;top:0;left:0;width:120px;height:120px;background:#F44336'></div><div style='position:absolute;z-index:3;top:30px;left:30px;width:120px;height:120px;background:#4CAF50'></div><div style='position:absolute;z-index:2;top:60px;left:60px;width:120px;height:120px;background:#2196F3'></div></div>"
    "borders-multi:<div style='width:200px;height:100px;border-top:3px solid red;border-right:3px solid green;border-bottom:3px solid blue;border-left:3px solid orange;padding:10px;background:#f9f9f9'>Borders</div>"
)

TOTAL=0
PASS=0

for test_entry in "${TESTS[@]}"; do
    NAME="${test_entry%%:*}"
    HTML="${test_entry#*:}"

    echo "--- $NAME ---"

    # Write HTML file
    cat > "$OUTPUT_DIR/html/$NAME.html" << EOF
<!DOCTYPE html>
<html>
<head><meta charset="utf-8"><style>*{margin:0;padding:0;box-sizing:border-box}</style></head>
<body style="margin:0;padding:0">
$HTML
</body>
</html>
EOF

    # Chrome screenshot
    sh "$SCRIPT_DIR/chrome_screenshot.shs" \
        "$OUTPUT_DIR/html/$NAME.html" \
        "$OUTPUT_DIR/chrome/$NAME.png" \
        800 600 2>/dev/null

    if [ ! -f "$OUTPUT_DIR/chrome/$NAME.png" ]; then
        echo "  Chrome: FAILED"
        continue
    fi
    echo "  Chrome: OK"

    # Compare (if Simple output exists)
    if [ -f "$OUTPUT_DIR/simple/$NAME.png" ]; then
        if command -v compare >/dev/null 2>&1; then
            METRIC=$(compare -metric RMSE \
                "$OUTPUT_DIR/simple/$NAME.png" \
                "$OUTPUT_DIR/chrome/$NAME.png" \
                "$OUTPUT_DIR/diff/$NAME.png" 2>&1 | head -1)
            echo "  Diff RMSE: $METRIC"
        fi
    else
        echo "  Simple: no output yet (run Simple renderer first)"
    fi

    TOTAL=$((TOTAL + 1))
done

echo ""
echo "=== Done: $TOTAL test pages ==="
echo "Chrome screenshots: $OUTPUT_DIR/chrome/"
echo "To compare: render same HTML with Simple renderer, save to $OUTPUT_DIR/simple/"
echo "Then run: compare -metric RMSE simple.png chrome.png diff.png"
