#![allow(REQC001)]
#![allow(REQC004)]
#![allow(unnamed_duplicate_typed_args)]
# ============================================================================
# Integration: Content Security Policy Tests
# Category: Browser Platform Integration
# Status: Active
#
# Validates the CSP enforcement engine: header parsing, directive extraction,
# source matching for scripts/styles/images, default-src fallback, special
# tokens ('none', 'unsafe-inline', 'unsafe-eval', 'self'), and report-uri
# extraction.
#
# Run with: bin/simple test examples/browser/test/integration/csp_spec.spl
# ============================================================================

use std.spec
use examples.browser.feature.sandbox.csp.{
    CspDirective, CspPolicy, parse_csp, parse_csp_with_origin,
    check_source, check_script, check_style, check_image
}
use examples.browser.entity.dom.node_types.{Element}
use examples.browser.feature.parser.html_tokenizer.{HtmlTokenizer}
use examples.browser.feature.parser.html_tree_builder.{TreeBuilder}
use examples.browser.transform.csp_from_dom.{extract_meta_csp, script_element_allowed, script_element_allowed_by_meta}
use examples.browser.shared.logging.{Logger, LogLevel}

# ============================================================================
# Helpers
# ============================================================================

fn make_logger() -> Logger:
    Logger.new("csp_test", LogLevel.Debug)

fn make_directive(name: text, sources: [text]) -> CspDirective:
    CspDirective.create(name, sources)

fn make_policy(directives: [CspDirective]) -> CspPolicy:
    CspPolicy.create(directives, "")

fn make_policy_with_report(directives: [CspDirective], report_uri: text) -> CspPolicy:
    CspPolicy.create(directives, report_uri)

fn single_directive_policy(name: text, sources: [text]) -> CspPolicy:
    var directives: [CspDirective] = []
    directives = directives + [make_directive(name, sources)]
    make_policy(directives)

fn build_tree(html: text) -> TreeBuilder:
    val logger = make_logger()
    val tokenizer = HtmlTokenizer.new(html, logger)
    TreeBuilder.new(tokenizer, logger)

fn first_element(builder: TreeBuilder, tag: text) -> Element?:
    var i = 0
    while i < builder.elements.len():
        val elem = builder.elements[i]
        if elem.tag_name == tag:
            return Some(elem)
        i = i + 1
    None

# ============================================================================
# Tests
# ============================================================================

describe "Content Security Policy Integration":

    # ========================================================================
    # CSP parsing
    # ========================================================================

    context "parse_csp":
        it "parse_csp extracts default-src directive":
            val policy = parse_csp("default-src 'self'")
            expect policy.directives.len() == 1
            expect policy.directives[0].name == "default-src"
            expect policy.directives[0].sources[0] == "'self'"

        it "parse_csp extracts script-src directive":
            val policy = parse_csp("script-src 'self' https://cdn.example.com")
            expect policy.directives.len() == 1
            expect policy.directives[0].name == "script-src"
            expect policy.directives[0].sources.len() == 2
            expect policy.directives[0].sources[1] == "https://cdn.example.com"
            expect policy.report_uri == ""

        it "parse_csp handles multiple directives":
            val policy = parse_csp("default-src 'none'; script-src 'self'; style-src 'self'")
            expect policy.directives.len() == 3

        it "parse_csp extracts report-uri separately":
            val policy = parse_csp("default-src 'self'; report-uri https://report.example.com/csp")
            expect policy.directives.len() == 1
            expect policy.report_uri == "https://report.example.com/csp"

    # ========================================================================
    # Source checking — scripts
    # ========================================================================

    context "script source checking":
        it "check_script allows whitelisted source":
            val sources = ["https://cdn.example.com", "https://api.example.com"]
            val policy = single_directive_policy("script-src", sources)
            val allowed = check_script(policy, "https://cdn.example.com")
            expect allowed == true

        it "check_script blocks non-whitelisted source":
            val sources = ["https://cdn.example.com"]
            val policy = single_directive_policy("script-src", sources)
            val allowed = check_script(policy, "https://evil.example.com")
            expect allowed == false

        it "host sources match only URL host boundaries":
            val sources = ["cdn.example.com"]
            val policy = single_directive_policy("script-src", sources)
            expect check_script(policy, "https://cdn.example.com/app.js") == true
            expect check_script(policy, "https://evil.example/path://cdn.example.com/app.js") == false

        it "full URL sources do not overmatch same-prefix attacker hosts":
            val sources = ["https://cdn.example.com"]
            val policy = single_directive_policy("script-src", sources)
            expect check_script(policy, "https://cdn.example.com/app.js") == true
            expect check_script(policy, "https://cdn.example.com.evil/app.js") == false

        it "wildcard host sources match subdomains but not suffix attackers":
            val sources = ["*.example.com"]
            val policy = single_directive_policy("script-src", sources)
            expect check_script(policy, "https://cdn.example.com/app.js") == true
            expect check_script(policy, "https://example.com/app.js") == false
            expect check_script(policy, "https://cdn.example.com.evil/app.js") == false

    # ========================================================================
    # Source checking — styles
    # ========================================================================

    context "style source checking":
        it "check_style allows 'self'":
            """'self' is treated as a literal token match in the current
            implementation. The source must exactly equal \"'self'\"."""
            val sources = ["'self'"]
            val policy = single_directive_policy("style-src", sources)
            val allowed = check_style(policy, "'self'")
            expect allowed == true

    # ========================================================================
    # Source checking — images
    # ========================================================================

    context "image source checking":
        it "check_image allows data: URI":
            val sources = ["data:", "https://img.example.com"]
            val policy = single_directive_policy("img-src", sources)
            val allowed = check_image(policy, "data:")
            expect allowed == true

    # ========================================================================
    # default-src fallback
    # ========================================================================

    context "default-src fallback":
        it "empty policy allows sources when no CSP was delivered":
            val policy = CspPolicy.empty()
            expect check_script(policy, "https://any.example.com/app.js") == true
            expect check_style(policy, "inline") == true

        it "default-src applies when specific directive missing":
            """When script-src is not present, check_script falls back
            to default-src."""
            val sources = ["https://allowed.example.com"]
            val policy = single_directive_policy("default-src", sources)
            # No script-src directive — should fall back to default-src
            val allowed = check_script(policy, "https://allowed.example.com")
            expect allowed == true
            val blocked = check_script(policy, "https://blocked.example.com")
            expect blocked == false

        it "script-src-elem falls back to script-src before default-src":
            val policy = parse_csp("default-src 'none'; script-src https://cdn.example.com")
            expect check_source(policy, "script-src-elem", "https://cdn.example.com/app.js") == true
            expect check_source(policy, "script-src-elem", "https://evil.example.com/app.js") == false

        it "style-src-attr falls back to style-src before default-src":
            val policy = parse_csp("default-src 'none'; style-src 'unsafe-inline'")
            expect check_source(policy, "style-src-attr", "inline") == true
            expect check_source(policy, "style-src-attr", "https://evil.example.com/style.css") == false

    # ========================================================================
    # Special tokens
    # ========================================================================

    context "special CSP tokens":
        it "'none' blocks all sources":
            val sources = ["'none'"]
            val policy = single_directive_policy("script-src", sources)
            val allowed = check_script(policy, "https://any.example.com")
            expect allowed == false

        it "'unsafe-inline' allows inline scripts":
            val sources = ["'unsafe-inline'"]
            val policy = single_directive_policy("script-src", sources)
            val allowed = check_script(policy, "inline")
            expect allowed == true

        it "'unsafe-inline' is not treated as a literal URL source":
            val sources = ["'unsafe-inline'"]
            val policy = single_directive_policy("script-src", sources)
            val allowed = check_script(policy, "'unsafe-inline'")
            expect allowed == false

        it "'unsafe-eval' allows eval()":
            val sources = ["'unsafe-eval'"]
            val policy = single_directive_policy("script-src", sources)
            val allowed = check_script(policy, "eval")
            expect allowed == true

        it "'unsafe-eval' is not treated as a literal URL source":
            val sources = ["'unsafe-eval'"]
            val policy = single_directive_policy("script-src", sources)
            val allowed = check_script(policy, "'unsafe-eval'")
            expect allowed == false

        it "'self' does not overmatch same-prefix attacker origins":
            val policy = parse_csp_with_origin("script-src 'self'", "https://example.com")
            expect check_script(policy, "https://example.com/app.js") == true
            expect check_script(policy, "https://example.com.evil/app.js") == false

    # ========================================================================
    # Report URI
    # ========================================================================

    context "report-uri":
        it "report-uri is extracted from policy":
            val directives = [make_directive("default-src", ["'self'"])]
            val policy = make_policy_with_report(directives, "https://report.example.com/csp")
            expect policy.report_uri == "https://report.example.com/csp"

    # ========================================================================
    # DOM integration
    # ========================================================================

    context "DOM integration":
        it "extracts meta CSP from parsed HTML":
            var builder = build_tree("<html><head><meta http-equiv=\"Content-Security-Policy\" content=\"script-src 'none'\"></head><body></body></html>")
            val result = builder.parse()
            match result:
                Ok(doc_id):
                    val policy = extract_meta_csp(builder.elements)
                    expect policy.directives.len() == 1
                    expect policy.directives[0].name == "script-src"
                Err(e):
                    expect "parse should succeed" == ""

        it "blocks inline script elements from meta CSP":
            var builder = build_tree("<html><head><meta http-equiv=\"Content-Security-Policy\" content=\"script-src 'none'\"></head><body><script>window.x = 1;</script></body></html>")
            val result = builder.parse()
            match result:
                Ok(doc_id):
                    val policy = extract_meta_csp(builder.elements)
                    val script = first_element(builder, "script")
                    if val Some(elem) = script:
                        expect script_element_allowed(policy, elem) == false
                    else:
                        expect "script element should exist" == ""
                Err(e):
                    expect "parse should succeed" == ""

        it "allows whitelisted external script elements from meta CSP":
            var builder = build_tree("<html><head><meta http-equiv=\"Content-Security-Policy\" content=\"default-src 'none'; script-src https://cdn.example.com\"></head><body><script src=\"https://cdn.example.com/app.js\"></script></body></html>")
            val result = builder.parse()
            match result:
                Ok(doc_id):
                    val policy = extract_meta_csp(builder.elements)
                    val script = first_element(builder, "script")
                    if val Some(elem) = script:
                        expect script_element_allowed(policy, elem) == true
                    else:
                        expect "script element should exist" == ""
                Err(e):
                    expect "parse should succeed" == ""

        it "applies multiple meta CSP policies cumulatively to script elements":
            var builder = build_tree("<html><head><meta http-equiv=\"Content-Security-Policy\" content=\"script-src 'unsafe-inline'\"><meta http-equiv=\"Content-Security-Policy\" content=\"script-src 'none'\"></head><body><script>window.x = 1;</script></body></html>")
            val result = builder.parse()
            match result:
                Ok(doc_id):
                    val script = first_element(builder, "script")
                    if val Some(elem) = script:
                        expect script_element_allowed_by_meta(builder.elements, elem) == false
                    else:
                        expect "script element should exist" == ""
                Err(e):
                    expect "parse should succeed" == ""

        it "allows scripts when no meta CSP policy is present":
            var builder = build_tree("<html><body><script>window.x = 1;</script></body></html>")
            val result = builder.parse()
            match result:
                Ok(doc_id):
                    val script = first_element(builder, "script")
                    if val Some(elem) = script:
                        expect script_element_allowed_by_meta(builder.elements, elem) == true
                    else:
                        expect "script element should exist" == ""
                Err(e):
                    expect "parse should succeed" == ""