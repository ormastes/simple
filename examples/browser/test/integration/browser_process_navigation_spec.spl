use std.spec.*
use examples.browser.transform.navigation_loader.{load_navigation_document}
use examples.browser.feature.net.h1_client.{MockResponseRegistry, set_mock_registry}
use examples.browser.shared.logging.{Logger}

describe "Browser process navigation loading":
    it "loads navigation documents through fetch responses":
        var registry = MockResponseRegistry.create()
        registry.register("offline.invalid/page", 200, "<html><body><h1>Fetched</h1><p>from mock fetch</p><div>ok</div></body></html>")
        set_mock_registry(registry)
        val html = load_navigation_document("https://offline.invalid/page", Logger(name: "browser-process-navigation-test"))
        expect(html.contains("<h1>Fetched</h1>")).to_equal(true)
        expect(html.contains("from mock fetch")).to_equal(true)

    it "creates deterministic error documents for failed navigation":
        var registry = MockResponseRegistry.create()
        registry.register("offline.invalid/missing", 404, "missing")
        set_mock_registry(registry)
        val html = load_navigation_document("https://offline.invalid/missing", Logger(name: "browser-process-navigation-test"))
        expect(html.contains("<h1>Navigation Error</h1>")).to_equal(true)
        expect(html.contains("HTTP 404")).to_equal(true)
