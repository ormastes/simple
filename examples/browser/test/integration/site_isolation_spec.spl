# ============================================================================
# Integration: Site Isolation and Process Model Tests
# Category: Browser Platform Integration
# Status: Active
#
# Validates the site isolation policy: same-origin pages sharing a process,
# cross-origin pages getting separate processes, is_same_site comparisons,
# renderer/network/browser capability restrictions, crashed-renderer
# containment, process-origin tracking, and sandbox enforcement.
#
# Run with: bin/simple test examples/browser/test/integration/site_isolation_spec.spl
# ============================================================================

use std.spec
use examples.browser.entity.ipc.process_types.{ProcessId, ProcessKind, ProcessState, ProcessInfo}
use examples.browser.feature.sandbox.site_isolation.{Origin, SiteIsolationPolicy, OriginMapping}
use examples.browser.feature.sandbox.process_manager.{ProcessManager}
use examples.browser.feature.sandbox.capability_broker.{CapabilityBroker, SandboxPolicy, PolicyEntry}
use examples.browser.shared.logging.{Logger, LogLevel}
use examples.browser.shared.error.{BrowserResult}

# ============================================================================
# Helpers
# ============================================================================

fn make_logger() -> Logger:
    Logger.new("site_isolation_test", LogLevel.Debug)

fn make_origin(scheme: text, host: text, port: i64) -> Origin:
    Origin.create(scheme, host, port)

fn make_policy() -> SiteIsolationPolicy:
    SiteIsolationPolicy.new()

fn make_process_manager() -> ProcessManager:
    ProcessManager.new(make_logger())

fn make_capability_broker() -> CapabilityBroker:
    CapabilityBroker.new(make_logger())

fn make_sandbox_policy(caps: List<text>, denied: List<text>) -> SandboxPolicy:
    SandboxPolicy.create(caps, denied, true, List<text>())

# ============================================================================
# Tests
# ============================================================================

describe "Site Isolation Integration":

    # ========================================================================
    # Same-site / cross-site determination
    # ========================================================================

    context "site comparison":
        it "is_same_site returns true for same domain":
            var policy = make_policy()
            val a = make_origin("https", "example.com", 443)
            val b = make_origin("https", "example.com", 443)
            expect(policy.is_same_site(a, b)).to_equal(true)

        it "is_same_site returns false for different domains":
            var policy = make_policy()
            val a = make_origin("https", "example.com", 443)
            val b = make_origin("https", "other.com", 443)
            expect(policy.is_same_site(a, b)).to_equal(false)

    # ========================================================================
    # Process assignment by origin
    # ========================================================================

    context "process assignment":
        it "same-origin pages share process":
            var policy = make_policy()
            val origin_a = make_origin("https", "example.com", 443)
            val origin_b = make_origin("https", "example.com", 443)
            val pid_a = policy.get_process_for_origin(origin_a)
            val pid_b = policy.get_process_for_origin(origin_b)
            expect(pid_a.id).to_equal(pid_b.id)

        it "different-origin pages get separate processes":
            var policy = make_policy()
            val origin_a = make_origin("https", "example.com", 443)
            val origin_b = make_origin("https", "other.com", 443)
            val pid_a = policy.get_process_for_origin(origin_a)
            val pid_b = policy.get_process_for_origin(origin_b)
            # Different origins get different PID hints
            expect(pid_a.id).to_be_less_than(pid_b.id)

        it "process assignment tracks by origin":
            """Multiple calls for the same origin should return the same PID."""
            var policy = make_policy()
            val origin = make_origin("https", "tracked.example.com", 443)
            val first = policy.get_process_for_origin(origin)
            val second = policy.get_process_for_origin(origin)
            val third = policy.get_process_for_origin(origin)
            expect(first.id).to_equal(second.id)
            expect(second.id).to_equal(third.id)

    # ========================================================================
    # Process capability restrictions
    # ========================================================================

    context "capability restrictions":
        it "renderer process has restricted capabilities":
            """A renderer sandbox policy should have limited capabilities
            and specific denials."""
            var broker = make_capability_broker()
            var pm = make_process_manager()
            val renderer_pid_result = pm.spawn(ProcessKind.Renderer)
            match renderer_pid_result:
                Ok(pid):
                    # Renderer processes run in strict sandbox
                    expect(pid.kind).to_equal(ProcessKind.Renderer)
                    expect(pid.id).to_be_greater_than(0)
                Err(e):
                    expect("spawn should succeed").to_equal("")

        it "network process can access cache path":
            """Network process is spawned with Network kind."""
            var pm = make_process_manager()
            val net_pid_result = pm.spawn(ProcessKind.Network)
            match net_pid_result:
                Ok(pid):
                    expect(pid.kind).to_equal(ProcessKind.Network)
                    expect(pid.id).to_be_greater_than(0)
                Err(e):
                    expect("spawn should succeed").to_equal("")

        it "browser process has full capabilities":
            """The browser (main) process is the privileged coordinator."""
            val browser_pid = ProcessId.create(0, ProcessKind.Browser)
            expect(browser_pid.kind).to_equal(ProcessKind.Browser)
            expect(browser_pid.id).to_equal(0)

    # ========================================================================
    # Crash containment
    # ========================================================================

    context "crash containment":
        it "crashed renderer doesn't crash browser":
            """When a renderer crashes, the browser process continues.
            The crashed renderer is marked Terminated."""
            var pm = make_process_manager()
            val r1_result = pm.spawn(ProcessKind.Renderer)
            val r2_result = pm.spawn(ProcessKind.Renderer)
            match r1_result:
                Ok(r1_pid):
                    match r2_result:
                        Ok(r2_pid):
                            # Kill renderer 1 (simulate crash)
                            val kill_result = pm.kill(r1_pid)
                            match kill_result:
                                Ok(_):
                                    # Renderer 1 is now terminated
                                    val state1 = pm.get_state(r1_pid)
                                    expect(state1).to_equal(ProcessState.Terminated)
                                    # Renderer 2 is still running
                                    val state2 = pm.get_state(r2_pid)
                                    expect(state2).to_equal(ProcessState.Running)
                                Err(e):
                                    expect("kill should succeed").to_equal("")
                        Err(e):
                            expect("spawn r2 should succeed").to_equal("")
                Err(e):
                    expect("spawn r1 should succeed").to_equal("")

    # ========================================================================
    # Sandbox policy enforcement
    # ========================================================================

    context "sandbox policy enforcement":
        it "capability check enforces sandbox policy":
            """A manually constructed SandboxPolicy with specific caps and
            denials can be checked via the CapabilityBroker."""
            var broker = make_capability_broker()
            val pid = ProcessId.create(42, ProcessKind.Renderer)
            # Manually register a policy for this PID
            var caps = List<text>()
            caps.push("dom")
            caps.push("wasm")
            var denied = List<text>()
            denied.push("filesystem")
            denied.push("network")
            val policy = make_sandbox_policy(caps, denied)
            val entry = PolicyEntry.create(42, policy)
            broker.policies.push(entry)
            # Check allowed capability
            val dom_allowed = broker.check_capability(pid, "dom")
            expect(dom_allowed).to_equal(true)
            # Check denied capability
            val fs_allowed = broker.check_capability(pid, "filesystem")
            expect(fs_allowed).to_equal(false)
