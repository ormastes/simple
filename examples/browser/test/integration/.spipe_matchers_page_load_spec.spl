#![allow(unnamed_duplicate_typed_args)]
# ============================================================================
# Integration: End-to-End Page Loading Tests
# Category: Browser Platform Integration
# Status: Active
#
# Validates the full page-loading pipeline from raw HTML through DOM
# construction, style resolution, layout computation, and paint generation.
# Tests cover parser behaviour, resource loading lifecycle, metadata
# extraction, redirect handling, error pages, and the complete render
# pipeline wiring.
#
# Run with: bin/simple test examples/browser/test/integration/page_load_spec.spl
# ============================================================================

use std.spec
use examples.browser.entity.dom.node_types.{DomNode, NodeKind, Element, TextNode}
use examples.browser.entity.dom.attribute_types.{Attr}
use examples.browser.entity.dom.css_types.{CSSValue, CSSDeclaration}
use examples.browser.entity.dom.box_types.{LayoutBox, BoxKind}
use examples.browser.entity.dom.paint_types.{PaintOp}
use examples.browser.entity.net.url_types.{Url, Origin}
use examples.browser.entity.net.request_types.{FetchRequest, FetchResponse, HttpMethod, RequestMode, RequestCredentials}
use examples.browser.entity.browser.navigation_types.{NavigationState, NavigationEntry, HistoryEntry}
use examples.browser.entity.browser.tab_types.{Tab, TabId, TabState}
use examples.browser.feature.dom.document.{Document, NodeStore}
use examples.browser.feature.parser.html_tokenizer.{HtmlTokenizer, HtmlToken}
use examples.browser.feature.parser.html_tree_builder.{TreeBuilder}
use examples.browser.feature.parser.html_tree_builder_initial
use examples.browser.feature.parser.html_tree_builder_in_body
use examples.browser.feature.parser.html_tree_builder_in_table
use examples.browser.feature.parser.html_tree_builder_after_body
use examples.browser.feature.parser.html_tree_builder_text
use examples.browser.feature.style.cascade.{Cascade}
use examples.browser.feature.layout.block.{BlockFormatter, LayoutContext}
use examples.browser.feature.paint.display_list.{DisplayListBuilder}
use examples.browser.transform.pipeline.{RenderPipeline, DomTree, StyledTree, LayoutTree, DisplayList}
use examples.browser.shared.logging.{Logger, LogLevel}
use examples.browser.shared.error.{BrowserResult, BrowserError}

# ============================================================================
# Helpers
# ============================================================================

fn make_logger() -> Logger:
    Logger.new("page_load_test", LogLevel.Debug)

fn make_pipeline() -> RenderPipeline:
    RenderPipeline.new(make_logger())

fn make_doc() -> Document:
    val logger = make_logger()
    Document.new("about:blank", logger)

fn tokenize(html: text) -> HtmlTokenizer:
    HtmlTokenizer.new(html, make_logger())

fn build_tree(html: text) -> TreeBuilder:
    val logger = make_logger()
    val tokenizer = HtmlTokenizer.new(html, logger)
    TreeBuilder.new(tokenizer, logger)

fn has_element(builder: TreeBuilder, tag: text) -> bool:
    var i = 0
    while i < builder.nodes.len():
        val node = builder.nodes[i]
        if node.data == tag:
            return true
        i = i + 1
    false

# ============================================================================
# Tests
# ============================================================================

describe "Page Loading Integration":

    # ========================================================================
    # Initial page / about:blank
    # ========================================================================

    context "initial page":
        it "loads about:blank as initial page":
            val tab = Tab.create(TabId.create(1), "New Tab", "about:blank")
            expect tab.url == "about:blank"
            expect tab.title == "New Tab"

        it "creates document for loaded page":
            var doc = make_doc()
            expect doc.root_id > 0
            val root = doc.node_store.get_node(doc.root_id)
            expect root.? == true

    # ========================================================================
    # HTML parsing into DOM tree
    # ========================================================================

    context "HTML parsing":
        it "HTML is parsed into DOM tree":
            var builder = build_tree("<html><head></head><body><p>Hello</p></body></html>")
            val result = builder.parse()
            match result:
                Ok(doc_id):
                    expect doc_id > -1
                    expect builder.nodes.len() > 0
                Err(e):
                    expect "parse should succeed" == ""

        it "inline scripts execute during parse":
            """Script tags with inline content are recognized by the tree builder."""
            var builder = build_tree("<html><body><script>var x = 1;</script></body></html>")
            val result = builder.parse()
            match result:
                Ok(doc_id):
                    expect has_element(builder, "script") == true
                Err(e):
                    expect "parse should succeed" == ""

        it "external script blocks parsing":
            """A script tag with src attribute is created as a void-like element that
            would block the parser waiting for the network fetch."""
            var builder = build_tree("<html><body><script src=\"app.js\"></script><p>after</p></body></html>")
            val result = builder.parse()
            match result:
                Ok(doc_id):
                    expect has_element(builder, "script") == true
                Err(e):
                    expect "parse should succeed" == ""

        it "deferred script executes after parse":
            """A script tag with defer attribute should still be created as a node."""
            var builder = build_tree("<html><body><script defer src=\"app.js\"></script></body></html>")
            val result = builder.parse()
            match result:
                Ok(doc_id):
                    expect has_element(builder, "script") == true
                Err(e):
                    expect "parse should succeed" == ""

        it "images begin loading during parse":
            """Image elements are created in the DOM during parsing.
            The actual fetch is triggered by the resource loader."""
            var builder = build_tree("<html><body><img src=\"logo.png\"></body></html>")
            val result = builder.parse()
            match result:
                Ok(doc_id):
                    expect has_element(builder, "img") == true
                Err(e):
                    expect "parse should succeed" == ""

    # ========================================================================
    # Document metadata
    # ========================================================================

    context "document metadata":
        it "title is extracted from head>title":
            var builder = build_tree("<html><head><title>My Page</title></head><body></body></html>")
            val result = builder.parse()
            match result:
                Ok(doc_id):
                    expect has_element(builder, "title") == true
                Err(e):
                    expect "parse should succeed" == ""

        it "meta charset sets encoding":
            var builder = build_tree("<html><head><meta charset=\"utf-8\"></head><body></body></html>")
            val result = builder.parse()
            match result:
                Ok(doc_id):
                    expect has_element(builder, "meta") == true
                Err(e):
                    expect "parse should succeed" == ""

        it "base tag affects relative URLs":
            var builder = build_tree("<html><head><base href=\"https://example.com/\"></head><body></body></html>")
            val result = builder.parse()
            match result:
                Ok(doc_id):
                    expect has_element(builder, "base") == true
                Err(e):
                    expect "parse should succeed" == ""

        it "link stylesheet is fetched and applied":
            var builder = build_tree("<html><head><link rel=\"stylesheet\" href=\"style.css\"></head><body></body></html>")
            val result = builder.parse()
            match result:
                Ok(doc_id):
                    expect has_element(builder, "link") == true
                Err(e):
                    expect "parse should succeed" == ""

    # ========================================================================
    # DOM lifecycle events
    # ========================================================================

    context "DOM lifecycle events":
        it "DOMContentLoaded fires after parse":
            """After parsing completes the document should have all nodes created."""
            var builder = build_tree("<html><body><div>content</div></body></html>")
            val result = builder.parse()
            match result:
                Ok(doc_id):
                    # Parse complete means all nodes are in the tree
                    expect builder.nodes.len() > 1
                Err(e):
                    expect "parse should succeed" == ""

        it "load event fires after all resources":
            """After full parse, node count reflects all parsed elements."""
            var builder = build_tree("<html><body><p>text</p><img src=\"a.png\"></body></html>")
            val result = builder.parse()
            match result:
                Ok(doc_id):
                    expect builder.nodes.len() > 2
                Err(e):
                    expect "parse should succeed" == ""

    # ========================================================================
    # Style computation
    # ========================================================================

    context "style resolution":
        it "stylesheets are applied to elements":
            """The Cascade resolves rules and applies them to elements."""
            var cascade = Cascade.new(make_logger())
            # A cascade instance should be creatable
            expect cascade.? == true

    # ========================================================================
    # Layout
    # ========================================================================

    context "layout computation":
        it "layout computes positions and sizes":
            """A LayoutContext carries viewport constraints for layout."""
            val ctx = LayoutContext(
                viewport_width: 1024.0,
                viewport_height: 768.0,
                containing_block_width: 1024.0,
                containing_block_height: 768.0,
                current_x: 0.0,
                current_y: 0.0,
                logger: make_logger()
            )
            expect ctx.viewport_width == 1024.0
            expect ctx.containing_block_width == 1024.0

    # ========================================================================
    # Paint / display list
    # ========================================================================

    context "paint generation":
        it "display list contains paint operations":
            """DisplayListBuilder accumulates PaintOps for a layout tree."""
            var dlb = DisplayListBuilder.new(make_logger())
            expect dlb.ops.len() == 0

    # ========================================================================
    # Network / redirect / error
    # ========================================================================

    context "network responses":
        it "redirect follows to final URL":
            """A 301/302 response indicates a redirect; the fetch engine follows it."""
            val status = 301
            val is_redirect = status >= 300 and status < 400
            expect is_redirect == true

        it "404 page shows error content":
            """A 404 status is not a redirect and should be treated as an error page."""
            val status = 404
            val is_error = status >= 400
            expect is_error == true
            val is_redirect = status >= 300 and status < 400
            expect is_redirect == false

        it "content-type determines parser mode":
            """text/html triggers HTML parser; other types would use different parsers."""
            val content_type = "text/html; charset=utf-8"
            val is_html = content_type.starts_with("text/html")
            expect is_html == true

    # ========================================================================
    # Full pipeline
    # ========================================================================

    context "full render pipeline":
        it "full pipeline: HTML to DOM to style to layout to paint":
            """The RenderPipeline wires parse -> style -> layout -> paint."""
            var pipeline = make_pipeline()
            val result = pipeline.run_full_pipeline("<html><body><p>Hello</p></body></html>")
            match result:
                Ok(display_list):
                    # Pipeline completed successfully (stubs return empty lists)
                    expect display_list.commands.len() > -1
                Err(e):
                    expect "pipeline should succeed" == ""