use std.spec
use std.js.types.js_types.{JsValue}
use examples.browser.feature.script.engine.vm.{ObjectStore}

describe "Browser ObjectStore":
    it "persists newly assigned properties":
        var store = ObjectStore(objects: [], next_id: 0)
        val obj_id = store.create_object()

        store.set_property(obj_id, "name", JsValue.String(v: "Alice"))

        expect(store.get_property(obj_id, "name")).to_equal(JsValue.String(v: "Alice"))

    it "persists replacement properties":
        var store = ObjectStore(objects: [], next_id: 0)
        val obj_id = store.create_object()

        store.set_property(obj_id, "count", JsValue.Number(v: 1.0))
        store.set_property(obj_id, "count", JsValue.Number(v: 2.0))

        expect(store.get_property(obj_id, "count")).to_equal(JsValue.Number(v: 2.0))
