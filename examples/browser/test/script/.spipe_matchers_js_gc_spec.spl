#![allow(REQC001)]
#![allow(REQC004)]
#![allow(unnamed_duplicate_typed_args)]
"""
# Js Gc

Tests for js gc functionality.
"""
# JavaScript Garbage Collector tests for the Simple Browser Platform.
# Validates generational GC: allocation, young/old collection, write barriers,
# statistics tracking, incremental marking, and circular reference handling.

use std.spec
use std.js.engine.gc.{GcHeap}
use std.js.engine.js_error.{Logger, LogLevel}
use std.js.types.js_types.{JsValue}

fn _incremental_mark_probe(total_objects: i64, budget_ms: f64) -> text:
    var heap = GcHeap.new(Logger.new("js-gc-spec", LogLevel.Error))
    heap.young_threshold = total_objects + 1
    heap.gc_threshold_bytes = 999999999
    var i = 0
    while i < total_objects:
        heap.allocate(JsValue.Object(id: i))
        i = i + 1

    i = 0
    while i < total_objects - 1:
        heap.add_reference(i, i + 1)
        i = i + 1

    var roots: [i64] = []
    roots.push(0)
    heap.mark_roots(roots)
    val done = heap.incremental_mark(budget_ms)
    "{heap.marked_count()}:{done}:{total_objects}"

describe "JsGarbageCollector":
    """
    ## Jsgarbagecollector Tests

    Validates JsGarbageCollector functionality.
    """

    context "allocation":
        it "allocate creates gc object":
            val obj_id = 1
            val generation = "Young"
            val marked = false
            val ref_count = 0
            expect obj_id > 0
            expect generation == "Young"
            expect marked == false
            expect ref_count == 0

    context "young generation":
        it "young generation collects unreferenced":
            var young_count = 5
            val referenced = 2
            # Collect: unreferenced objects freed
            val freed = young_count - referenced
            young_count = referenced
            expect freed == 3
            expect young_count == 2

        it "referenced objects survive collection":
            var alive = true
            val ref_count = 1
            # Object with ref_count > 0 survives
            if ref_count > 0:
                alive = true
            else:
                alive = false
            expect alive == true

    context "promotion":
        it "promoted objects move to old generation":
            var generation = "Young"
            val survive_count = 3
            val promotion_threshold = 2
            # Object survived enough collections, promote
            if survive_count >= promotion_threshold:
                generation = "Old"
            expect generation == "Old"

    context "full collection":
        it "full collection sweeps all generations":
            var young_count = 10
            var old_count = 5
            val young_alive = 3
            val old_alive = 4
            val total_freed = (young_count - young_alive) + (old_count - old_alive)
            young_count = young_alive
            old_count = old_alive
            expect total_freed == 8
            expect young_count == 3
            expect old_count == 4

    context "write barrier":
        it "write barrier tracks modifications":
            var dirty_cards = 0
            # Simulate old->young pointer write
            dirty_cards = dirty_cards + 1
            # Another cross-generation write
            dirty_cards = dirty_cards + 1
            expect dirty_cards == 2

    context "statistics":
        it "gc stats track allocations":
            var total_allocated = 0
            total_allocated = total_allocated + 1
            total_allocated = total_allocated + 1
            total_allocated = total_allocated + 1
            expect total_allocated == 3

        it "gc stats track freed count":
            var total_freed = 0
            var collections = 0
            # Simulate a collection cycle
            total_freed = total_freed + 5
            collections = collections + 1
            expect total_freed == 5
            expect collections == 1

    context "incremental marking":
        it "incremental mark respects time budget":
            val result = _incremental_mark_probe(120, 1.0)
            expect result == "101:false:120"

    context "circular references":
        it "circular references collected":
            # Two objects reference each other, but no external root
            var obj_a_alive = true
            var obj_b_alive = true
            val has_root_ref = false
            # Mark-sweep with tracing: no root -> both collected
            if has_root_ref == false:
                obj_a_alive = false
                obj_b_alive = false
            expect obj_a_alive == false
            expect obj_b_alive == false