#![allow(unnamed_duplicate_typed_args)]

use std.spec
use std.js.engine.runtime.{JsRuntime}
use std.js.engine.js_error.{Logger, LogLevel}
use std.js.types.js_types.{JsValue}

fn _display_js(v: JsValue) -> text:
    match v:
        JsValue.Undefined: "undefined"
        JsValue.Null: "null"
        JsValue.Boolean(b): if b: "true" else: "false"
        JsValue.Number(n):
            var s = "{n}"
            if s.ends_with(".0"):
                s = s.slice(0, s.len() - 2)
            s
        JsValue.String(s): s
        JsValue.Object(id): "[object Object]"
        JsValue.Array(id): "[object Array]"
        JsValue.Function(id): "[Function]"
        JsValue.Symbol(id): "Symbol()"

describe "Browser JsRuntime timers":
    it "drains queued setTimeout callbacks through the browser runtime wrapper":
        var runtime = JsRuntime.new(Logger.new("browser-js-runtime-timer-spec", LogLevel.Error))
        val initial = runtime.eval("var fired = 0; setTimeout(function(){ fired = fired + 1; }, 5); fired")
        match initial:
            Ok(value): expect(_display_js(value)).to_equal("0")
            Err(e): expect("Error: {e.message}").to_equal("ok")
        expect(runtime.drain_due_timers(5)).to_equal(1)
        val after_due = runtime.eval("fired")
        match after_due:
            Ok(value): expect(_display_js(value)).to_equal("1")
            Err(e): expect("Error: {e.message}").to_equal("ok")
