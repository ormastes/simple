#![allow(unnamed_duplicate_typed_args)]

use std.spec
use std.js.types.js_types.{JsObject, JsValue}
use examples.browser.feature.script.builtins.object.{
    map_delete, map_get, map_has, map_set,
    set_add, set_delete, set_has,
    weakmap_get, weakmap_set,
    weakset_add, weakset_delete, weakset_has
}

describe "Object collection builtins":
    describe "Map":
        it "reads the latest value after setting an existing key":
            var map = JsObject.create(1)
            map = map_set(map, "answer", JsValue.Number(v: 1.0))
            map = map_set(map, "answer", JsValue.Number(v: 2.0))

            expect map_has(map, "answer") == true
            expect map_get(map, "answer") == JsValue.Number(v: 2.0)

        it "deletes an updated key without leaving stale entries":
            var map = JsObject.create(1)
            map = map_set(map, "answer", JsValue.Number(v: 1.0))
            map = map_set(map, "answer", JsValue.Number(v: 2.0))

            map = map_delete(map, "answer")
            expect map_has(map, "answer") == false
            expect map_get(map, "answer") == JsValue.Undefined

    describe "Set":
        it "adds, checks, and reports deletion for primitive values":
            var set = JsObject.create(2)
            set = set_add(set, JsValue.String(v: "a"))

            expect set_has(set, JsValue.String(v: "a")) == true
            set = set_delete(set, JsValue.String(v: "a"))
            expect set_has(set, JsValue.String(v: "a")) == false
            set = set_delete(set, JsValue.String(v: "missing"))
            expect set_has(set, JsValue.String(v: "missing")) == false

    describe "WeakMap":
        it "reads the latest value for object reference keys":
            var map = JsObject.create(3)
            map = weakmap_set(map, 42, JsValue.String(v: "old"))
            map = weakmap_set(map, 42, JsValue.String(v: "new"))

            expect weakmap_get(map, 42) == JsValue.String(v: "new")

    describe "WeakSet":
        it "adds checks and deletes object reference ids":
            var set = JsObject.create(4)
            set = weakset_add(set, 42)
            set = weakset_add(set, 42)

            expect weakset_has(set, 42) == true
            set = weakset_delete(set, 42)
            expect weakset_has(set, 42) == false
            set = weakset_delete(set, 42)
            expect weakset_has(set, 42) == false