#![allow(unnamed_duplicate_typed_args)]

use std.spec
use std.js.types.js_types.{JsValue}
use std.js.engine.js_error.{Logger}
use examples.browser.feature.script.web_api.console_binding.{ConsoleBinding, format_args}

fn _binding() -> ConsoleBinding:
    ConsoleBinding.new(Logger(name: "console-binding-spec"))

describe "ConsoleBinding":
    describe "format_args":
        it "joins primitive console arguments":
            val formatted = format_args([JsValue.String(v: "count:"), JsValue.Number(v: 42.0), JsValue.Boolean(v: true)])
            expect (formatted).contains("count:")
            expect (formatted).contains("42")
            expect (formatted).contains("true")

    describe "time":
        it "records runtime timestamps for labels":
            var binding = _binding()
            binding.time([JsValue.String(v: "load")])

            expect binding.timers.len() == 1
            expect binding.timers[0].first == "load"
            expect binding.timers[0].second > 0

        it "removes matching timers when ended":
            var binding = _binding()
            binding.time([JsValue.String(v: "load")])
            binding.timeEnd([JsValue.String(v: "load")])

            expect binding.timers.len() == 0

    describe "count":
        it "increments named counters":
            var binding = _binding()
            binding.count([JsValue.String(v: "paint")])
            binding.count([JsValue.String(v: "paint")])

            expect binding.counters.len() == 1
            expect binding.counters[0].first == "paint"
            expect binding.counters[0].second == 2