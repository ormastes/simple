#![allow(unnamed_duplicate_typed_args)]

use std.spec
use examples.browser.feature.script.builtins.date.{date_now, date_new, date_from_timestamp, date_getTime, date_getFullYear, date_getMonth, date_getDate, date_getDay, date_getHours, date_getMinutes, date_getSeconds, date_getMilliseconds, date_toISOString}

describe "Date built-in":
    it "returns current runtime time instead of epoch zero":
        val now = date_now()
        expect(now).to_be_greater_than(0)

    it "constructs timestamps from JavaScript date fields":
        val d = date_new(1970, 0, 2, 3, 4, 5, 6)
        expect(date_getTime(d)).to_equal(97445006)

    it "decomposes timestamps into UTC date parts":
        val d = date_from_timestamp(97445006)
        expect(date_getFullYear(d)).to_equal(1970)
        expect(date_getMonth(d)).to_equal(0)
        expect(date_getDate(d)).to_equal(2)
        expect(date_getDay(d)).to_equal(5)
        expect(date_getHours(d)).to_equal(3)
        expect(date_getMinutes(d)).to_equal(4)
        expect(date_getSeconds(d)).to_equal(5)
        expect(date_getMilliseconds(d)).to_equal(6)

    it "formats ISO strings with zero padding":
        val d = date_new(2024, 1, 29, 7, 8, 9, 10)
        expect(date_toISOString(d)).to_equal("2024-02-29T07:08:09.010Z")
