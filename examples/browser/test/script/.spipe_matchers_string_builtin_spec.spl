use std.spec
use examples.browser.feature.script.builtins.string.{string_charCodeAt, string_fromCharCode}

describe "String builtins":
    describe "fromCharCode":
        it "returns ASCII controls and punctuation without placeholders":
            expect string_fromCharCode(9) == "\t"
            expect string_fromCharCode(10) == "\n"
            expect string_fromCharCode(60) == "<"
            expect string_fromCharCode(126) == "~"

        it "returns non ASCII code units instead of question mark":
            expect string_fromCharCode(233) == "é"
            expect string_fromCharCode(30028) == "界"

        it "normalizes to unsigned 16 bit JavaScript code units":
            expect string_fromCharCode(65536 + 65) == "A"
            expect string_fromCharCode(0xD800) == "\uFFFD"

    describe "charCodeAt":
        it "returns character code points instead of UTF-8 bytes":
            expect string_charCodeAt("é", 0) == 233
            expect string_charCodeAt("Aé", 1) == 233
            expect string_charCodeAt("界", 0) == 30028