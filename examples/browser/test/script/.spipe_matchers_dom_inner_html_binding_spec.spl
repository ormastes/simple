use examples.browser.feature.dom.document.{Document}
use examples.browser.feature.dom.element.{ElementOps}
use examples.browser.shared.logging.{Logger, LogLevel}
use examples.browser.shared.error.{BrowserResult}

fn make_doc() -> Document:
    Document.new("about:blank", Logger.new("dom-inner-html-binding-spec", LogLevel.Error))

describe "DOM innerHTML":
    it "parses nested elements into the production DOM tree":
        var doc = make_doc()
        val host = doc.createElement("div")
        doc.appendChild(doc.body_id, host)

        val set_result = doc.set_inner_html(host, "<span>Hello <b>world</b></span>")
        expect _result_message(set_result) == "ok"

        val html = ElementOps.innerHTML(doc, host)
        val bolds = doc.getElementsByTagName("b")

        expect html == "<span>Hello <b>world</b></span>"
        expect bolds.len() == 1

    it "decodes text entities and serializes them safely":
        var doc = make_doc()
        val host = doc.createElement("div")
        doc.appendChild(doc.body_id, host)

        val set_result = doc.set_inner_html(host, "<p>Tom &amp; &lt;Jerry&gt;</p>")
        expect _result_message(set_result) == "ok"

        expect doc.get_inner_text(host) == "Tom & <Jerry>"
        expect ElementOps.innerHTML(doc, host) == "<p>Tom &amp; &lt;Jerry&gt;</p>"

    it "preserves comments in the parsed fragment":
        var doc = make_doc()
        val host = doc.createElement("div")
        doc.appendChild(doc.body_id, host)

        val set_result = doc.set_inner_html(host, "<p>a</p><!--note--><p>b</p>")
        expect _result_message(set_result) == "ok"

        expect ElementOps.innerHTML(doc, host) == "<p>a</p><!--note--><p>b</p>"

fn _result_message(result: BrowserResult<()>) -> text:
    match result:
        Ok(_): "ok"
        Err(e): e.message