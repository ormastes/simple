#![allow(REQC001)]
#![allow(REQC004)]
#![allow(unnamed_duplicate_typed_args)]
"""
# Js Interpreter

Tests for JavaScript runtime evaluation in the Simple Browser Platform.
"""

use std.spec
use std.js.engine.runtime.{JsRuntime}
use std.js.engine.js_error.{Logger, LogLevel}
use std.js.types.js_types.{JsValue}
use std.js.types.ast_types.{JsExpression, JsStatement, JsAstFactory}
use std.js.engine.interpreter_types.{EnvironmentStack, JsFunction, to_number, js_to_string, to_boolean, is_truthy, typeof_value, strict_equals, abstract_equals, RETURN_SIGNAL, _is_array_method, _is_string_method, _get_obj_id, _get_fn_id, f64_to_i64, _digit_val}

fn _run_js(source: text) -> text:
    val runtime = JsRuntime.new(Logger.new("browser-js-interpreter-spec", LogLevel.Error))
    val result = runtime.eval(source)
    match result:
        Ok(value):
            return _display_js(value)
        Err(e):
            return "Error: {e.message}"

fn _display_js(v: JsValue) -> text:
    match v:
        JsValue.Undefined: "undefined"
        JsValue.Null: "null"
        JsValue.Boolean(b): if b: "true" else: "false"
        JsValue.Number(n):
            var s = "{n}"
            if s.ends_with(".0"):
                s = s.slice(0, s.len() - 2)
            s
        JsValue.String(s): s
        JsValue.Object(id): "[object Object]"
        JsValue.Array(id): "[object Array]"
        JsValue.Function(id): "[Function]"
        JsValue.Symbol(id): "Symbol()"

describe "JsInterpreter":
    context "literals":
        it "evaluates number literal":
            expect(_run_js("42")).to_equal("42")

        it "evaluates string literal":
            expect(_run_js("\"hello\"")).to_equal("hello")

    context "arithmetic":
        it "evaluates addition":
            expect(_run_js("10 + 32")).to_equal("42")

        it "evaluates string concatenation":
            expect(_run_js("\"hello\" + \" \" + \"world\"")).to_equal("hello world")

    context "variables":
        it "evaluates variable declaration and access":
            expect(_run_js("var x = 10; x + 5")).to_equal("15")

    context "control flow":
        it "evaluates if/else":
            expect(_run_js("var x = 10; if (x > 5) { 'big'; } else { 'small'; }")).to_equal("big")

        it "evaluates while loop":
            expect(_run_js("var i = 0; var sum = 0; while (i < 5) { sum = sum + i; i = i + 1; } sum")).to_equal("10")

    context "functions":
        it "evaluates function declaration and call":
            expect(_run_js("function double(x) { return x * 2; } double(21)")).to_equal("42")

        it "evaluates recursive function":
            expect(_run_js("function fact(n) { if (n <= 1) return 1; return n * fact(n - 1); } fact(5)")).to_equal("120")

        it "evaluates nested function scope":
            expect(_run_js("function outer() { var x = 10; function inner() { return x; } return inner(); } outer()")).to_equal("10")

    context "comparison operators":
        it "evaluates comparison operators":
            expect(_run_js("(3 < 5) + ':' + (5 > 3) + ':' + (42 == 42) + ':' + (42 != 0)")).to_equal("true:true:true:true")

        it "evaluates logical operators":
            expect(_run_js("(true && false) + ':' + (true || false)")).to_equal("false:true")

    context "objects and arrays":
        it "evaluates object property access":
            expect(_run_js("var obj = { name: 'Alice', age: 30 }; obj.name + ':' + obj.age")).to_equal("Alice:30")

        it "evaluates array operations":
            expect(_run_js("var arr = [10, 20, 30]; arr.length + ':' + arr[1]")).to_equal("3:20")

        it "prevents writes to frozen object properties":
            expect(_run_js("var obj = { a: 1 }; Object.freeze(obj); obj.a = 2; obj.a")).to_equal("1")

        it "prevents adding properties to frozen objects":
            expect(_run_js("var obj = { a: 1 }; Object.freeze(obj); obj.b = 2; obj.b")).to_equal("undefined")

        it "reports frozen object state":
            expect(_run_js("var obj = { a: 1 }; Object.freeze(obj); Object.isFrozen(obj) + ':' + Object.isFrozen({ b: 2 })")).to_equal("true:false")

        it "keeps frozen bookkeeping out of enumerable object keys":
            expect(_run_js("var obj = { a: 1 }; Object.freeze(obj); Object.keys(obj).length")).to_equal("1")

    context "typeof":
        it "typeof returns correct type string":
            expect(_run_js("typeof 1 + ':' + typeof 'x' + ':' + typeof true + ':' + typeof missing + ':' + typeof {}")).to_equal("number:string:boolean:undefined:object")

    context "Math":
        it "Math.random returns changing in-range values":
            expect(_run_js("var a = Math.random(); var b = Math.random(); (a < 1) + ':' + (b < 1) + ':' + (a != b)")).to_equal("true:true:true")

    context "Timers":
        it "setTimeout and setInterval return unique positive handles":
            expect(_run_js("var a = setTimeout(function(){}, 10); var b = setInterval(function(){}, 10); (a > 0) + ':' + (b > 0) + ':' + (a != b)")).to_equal("true:true:true")

        it "setTimeout callback runs only when due":
            var runtime = JsRuntime.new(Logger.new("browser-js-timer-timeout-spec", LogLevel.Error))
            val initial = runtime.eval("var fired = 0; setTimeout(function(){ fired = fired + 1; }, 50); fired")
            match initial:
                Ok(value): expect(_display_js(value)).to_equal("0")
                Err(e): expect("Error: {e.message}").to_equal("ok")
            expect(runtime.drain_due_timers(49)).to_equal(0)
            val before_due = runtime.eval("fired")
            match before_due:
                Ok(value): expect(_display_js(value)).to_equal("0")
                Err(e): expect("Error: {e.message}").to_equal("ok")
            expect(runtime.drain_due_timers(50)).to_equal(1)
            val after_due = runtime.eval("fired")
            match after_due:
                Ok(value): expect(_display_js(value)).to_equal("1")
                Err(e): expect("Error: {e.message}").to_equal("ok")

        it "clearTimeout cancels pending callback":
            var runtime = JsRuntime.new(Logger.new("browser-js-timer-clear-spec", LogLevel.Error))
            val initial = runtime.eval("var fired = 0; var id = setTimeout(function(){ fired = fired + 1; }, 10); clearTimeout(id); fired")
            match initial:
                Ok(value): expect(_display_js(value)).to_equal("0")
                Err(e): expect("Error: {e.message}").to_equal("ok")
            expect(runtime.drain_due_timers(10)).to_equal(0)
            val after_due = runtime.eval("fired")
            match after_due:
                Ok(value): expect(_display_js(value)).to_equal("0")
                Err(e): expect("Error: {e.message}").to_equal("ok")

        it "setInterval callback repeats on each interval":
            var runtime = JsRuntime.new(Logger.new("browser-js-timer-interval-spec", LogLevel.Error))
            val initial = runtime.eval("var fired = 0; setInterval(function(){ fired = fired + 1; }, 20); fired")
            match initial:
                Ok(value): expect(_display_js(value)).to_equal("0")
                Err(e): expect("Error: {e.message}").to_equal("ok")
            expect(runtime.drain_due_timers(20)).to_equal(1)
            val first = runtime.eval("fired")
            match first:
                Ok(value): expect(_display_js(value)).to_equal("1")
                Err(e): expect("Error: {e.message}").to_equal("ok")
            expect(runtime.drain_due_timers(39)).to_equal(0)
            expect(runtime.drain_due_timers(40)).to_equal(1)
            val second = runtime.eval("fired")
            match second:
                Ok(value): expect(_display_js(value)).to_equal("2")
                Err(e): expect("Error: {e.message}").to_equal("ok")

    context "JSON":
        it "JSON.parse decodes quoted strings instead of echoing source":
            expect(_run_js("JSON.parse('\"hello\"')")).to_equal("hello")

        it "JSON.parse returns structured object and array values":
            expect(_run_js("JSON.parse('{\"name\":\"Alice\"}')")).to_equal("[object Object]")
            expect(_run_js("JSON.parse('[1,2,3]')")).to_equal("[object Array]")

        it "JSON.parse allocates object and array properties":
            expect(_run_js("var data = JSON.parse('{\"name\":\"Alice\",\"scores\":[10,20]}'); data.name + ':' + data.scores[1]")).to_equal("Alice:20")

        it "JSON.parse rejects trailing JavaScript after valid JSON":
            expect(_run_js("JSON.parse('true; Math.random()')")).to_contain("Error:")

        it "JSON.parse rejects partial JSON literal names":
            expect(_run_js("JSON.parse('trol')")).to_contain("Error:")
