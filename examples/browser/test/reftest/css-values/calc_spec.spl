#![allow(unnamed_duplicate_typed_args)]
"""
# CSS calc() / min() / max() / clamp() Reference Tests

Verifies that CSS math functions compute correct values.
"""
"""
## Test Coverage

Rendering comparison for CSS math function expressions.
"""

use examples.browser.test.reftest.reftest_runner.{RefTestCase}

fn calc_test_cases() -> [RefTestCase]:
    var cases: [RefTestCase] = []

    # Test 1: calc(100% - 20px) should be equivalent to explicit px
    val test1 = RefTestCase(
        name: "calc-subtraction",
        test_html: "<div style='width: 800px'><div style='width: calc(100% - 20px); height: 50px; background: red'></div></div>",
        ref_html: "<div style='width: 800px'><div style='width: 780px; height: 50px; background: red'></div></div>",
        comparison: "==",
        tolerance: 2,
        category: "css-values"
    )
    cases = cases + [test1]

    # Test 2: min() takes the smaller value
    val test2 = RefTestCase(
        name: "min-function",
        test_html: "<div style='width: min(200px, 300px); height: 50px; background: green'></div>",
        ref_html: "<div style='width: 200px; height: 50px; background: green'></div>",
        comparison: "==",
        tolerance: 0,
        category: "css-values"
    )
    cases = cases + [test2]

    # Test 3: max() takes the larger value
    val test3 = RefTestCase(
        name: "max-function",
        test_html: "<div style='width: max(200px, 300px); height: 50px; background: blue'></div>",
        ref_html: "<div style='width: 300px; height: 50px; background: blue'></div>",
        comparison: "==",
        tolerance: 0,
        category: "css-values"
    )
    cases = cases + [test3]

    # Test 4: clamp(min, preferred, max) — preferred within range
    val test4 = RefTestCase(
        name: "clamp-within-range",
        test_html: "<div style='width: clamp(100px, 200px, 300px); height: 50px; background: orange'></div>",
        ref_html: "<div style='width: 200px; height: 50px; background: orange'></div>",
        comparison: "==",
        tolerance: 0,
        category: "css-values"
    )
    cases = cases + [test4]

    # Test 5: clamp — preferred below min
    val test5 = RefTestCase(
        name: "clamp-below-min",
        test_html: "<div style='width: clamp(200px, 100px, 300px); height: 50px; background: purple'></div>",
        ref_html: "<div style='width: 200px; height: 50px; background: purple'></div>",
        comparison: "==",
        tolerance: 0,
        category: "css-values"
    )
    cases = cases + [test5]

    # Test 6: clamp — preferred above max
    val test6 = RefTestCase(
        name: "clamp-above-max",
        test_html: "<div style='width: clamp(100px, 400px, 300px); height: 50px; background: teal'></div>",
        ref_html: "<div style='width: 300px; height: 50px; background: teal'></div>",
        comparison: "==",
        tolerance: 0,
        category: "css-values"
    )
    cases = cases + [test6]

    cases
