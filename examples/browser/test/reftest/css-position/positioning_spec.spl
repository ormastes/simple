"""
# CSS Positioned Layout Reference Tests

Tests position: relative, absolute, fixed, and sticky behavior.
"""
"""
## Test Coverage

Rendering comparison for each CSS position mode.
"""

use examples.browser.test.reftest.reftest_runner.{RefTestCase}

fn positioning_test_cases() -> [RefTestCase]:
    var cases: [RefTestCase] = []

    # Test 1: position: relative with top/left offsets
    val test1 = RefTestCase(
        name: "position-relative-offset",
        test_html: "<div style='position: relative; top: 10px; left: 20px; width: 50px; height: 50px; background: red'></div>",
        ref_html: "<div style='margin-top: 10px; margin-left: 20px; width: 50px; height: 50px; background: red'></div>",
        comparison: "==",
        tolerance: 2,
        category: "css-position"
    )
    cases = cases + [test1]

    # Test 2: position: absolute within positioned parent
    val test2 = RefTestCase(
        name: "position-absolute-in-relative",
        test_html: "<div style='position: relative; width: 200px; height: 200px; background: #eee'><div style='position: absolute; top: 50px; left: 50px; width: 50px; height: 50px; background: red'></div></div>",
        ref_html: "<div style='width: 200px; height: 200px; background: #eee'><div style='margin-top: 50px; margin-left: 50px; width: 50px; height: 50px; background: red'></div></div>",
        comparison: "==",
        tolerance: 2,
        category: "css-position"
    )
    cases = cases + [test2]

    # Test 3: position: absolute with right/bottom
    val test3 = RefTestCase(
        name: "position-absolute-right-bottom",
        test_html: "<div style='position: relative; width: 200px; height: 200px; background: #eee'><div style='position: absolute; right: 10px; bottom: 10px; width: 50px; height: 50px; background: blue'></div></div>",
        ref_html: "<div style='position: relative; width: 200px; height: 200px; background: #eee'><div style='position: absolute; left: 140px; top: 140px; width: 50px; height: 50px; background: blue'></div></div>",
        comparison: "==",
        tolerance: 2,
        category: "css-position"
    )
    cases = cases + [test3]

    # Test 4: z-index ordering
    val test4 = RefTestCase(
        name: "z-index-ordering",
        test_html: "<div style='position: relative; width: 200px; height: 200px'><div style='position: absolute; z-index: 1; top: 0; left: 0; width: 100px; height: 100px; background: red'></div><div style='position: absolute; z-index: 2; top: 25px; left: 25px; width: 100px; height: 100px; background: blue'></div></div>",
        ref_html: "<div style='position: relative; width: 200px; height: 200px'><div style='position: absolute; z-index: 1; top: 0; left: 0; width: 100px; height: 100px; background: red'></div><div style='position: absolute; z-index: 2; top: 25px; left: 25px; width: 100px; height: 100px; background: blue'></div></div>",
        comparison: "==",
        tolerance: 0,
        category: "css-position"
    )
    cases = cases + [test4]

    cases
