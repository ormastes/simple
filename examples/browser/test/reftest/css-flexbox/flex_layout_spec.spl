"""
# CSS Flexbox Layout Reference Tests

Tests flexbox container behavior: direction, wrapping, alignment, and gap.
"""
"""
## Test Coverage

Rendering comparison for flexbox container configurations.
"""

use examples.browser.test.reftest.reftest_runner.{RefTestCase}

fn flex_layout_test_cases() -> [RefTestCase]:
    var cases: [RefTestCase] = []

    # Test 1: flex-direction: row — children side by side
    val test1 = RefTestCase(
        name: "flex-direction-row",
        test_html: "<div style='display: flex; flex-direction: row; width: 300px'><div style='width: 100px; height: 50px; background: red'></div><div style='width: 100px; height: 50px; background: green'></div><div style='width: 100px; height: 50px; background: blue'></div></div>",
        ref_html: "<div style='width: 300px'><div style='float: left; width: 100px; height: 50px; background: red'></div><div style='float: left; width: 100px; height: 50px; background: green'></div><div style='float: left; width: 100px; height: 50px; background: blue'></div></div>",
        comparison: "==",
        tolerance: 2,
        category: "css-flexbox"
    )
    cases = cases + [test1]

    # Test 2: flex-direction: column — children stacked vertically
    val test2 = RefTestCase(
        name: "flex-direction-column",
        test_html: "<div style='display: flex; flex-direction: column; width: 100px'><div style='height: 50px; background: red'></div><div style='height: 50px; background: green'></div><div style='height: 50px; background: blue'></div></div>",
        ref_html: "<div style='width: 100px'><div style='height: 50px; background: red'></div><div style='height: 50px; background: green'></div><div style='height: 50px; background: blue'></div></div>",
        comparison: "==",
        tolerance: 2,
        category: "css-flexbox"
    )
    cases = cases + [test2]

    # Test 3: gap property
    val test3 = RefTestCase(
        name: "flex-gap",
        test_html: "<div style='display: flex; gap: 10px; width: 220px'><div style='width: 100px; height: 50px; background: red'></div><div style='width: 100px; height: 50px; background: blue'></div></div>",
        ref_html: "<div style='width: 220px'><div style='float: left; width: 100px; height: 50px; background: red'></div><div style='float: left; margin-left: 10px; width: 100px; height: 50px; background: blue'></div></div>",
        comparison: "==",
        tolerance: 2,
        category: "css-flexbox"
    )
    cases = cases + [test3]

    # Test 4: justify-content: center
    val test4 = RefTestCase(
        name: "flex-justify-center",
        test_html: "<div style='display: flex; justify-content: center; width: 300px; background: #eee'><div style='width: 100px; height: 50px; background: red'></div></div>",
        ref_html: "<div style='width: 300px; background: #eee'><div style='width: 100px; height: 50px; margin: 0 auto; background: red'></div></div>",
        comparison: "==",
        tolerance: 2,
        category: "css-flexbox"
    )
    cases = cases + [test4]

    # Test 5: flex-wrap: wrap
    val test5 = RefTestCase(
        name: "flex-wrap",
        test_html: "<div style='display: flex; flex-wrap: wrap; width: 200px'><div style='width: 120px; height: 50px; background: red'></div><div style='width: 120px; height: 50px; background: blue'></div></div>",
        ref_html: "<div style='width: 200px'><div style='width: 120px; height: 50px; background: red'></div><div style='width: 120px; height: 50px; background: blue'></div></div>",
        comparison: "==",
        tolerance: 2,
        category: "css-flexbox"
    )
    cases = cases + [test5]

    cases
