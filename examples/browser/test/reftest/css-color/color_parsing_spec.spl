"""
# CSS Color Parsing Reference Tests

Verifies that all color formats render identically: hex, rgb(), rgba(),
named colors, transparent.
"""
"""
## Test Coverage

Render-level comparison for each CSS color format.
"""

use examples.browser.test.reftest.reftest_runner.{RefTestCase}

fn color_parsing_test_cases() -> [RefTestCase]:
    var cases: [RefTestCase] = []

    # Test 1: Hex #RRGGBB == rgb(r,g,b)
    val test1 = RefTestCase(
        name: "hex-rgb-equivalence",
        test_html: "<div style='width: 100px; height: 100px; background-color: #FF0000'></div>",
        ref_html: "<div style='width: 100px; height: 100px; background-color: rgb(255, 0, 0)'></div>",
        comparison: "==",
        tolerance: 0,
        category: "css-color"
    )
    cases = cases + [test1]

    # Test 2: Short hex #RGB == full hex #RRGGBB
    val test2 = RefTestCase(
        name: "short-hex-expansion",
        test_html: "<div style='width: 100px; height: 100px; background-color: #F00'></div>",
        ref_html: "<div style='width: 100px; height: 100px; background-color: #FF0000'></div>",
        comparison: "==",
        tolerance: 0,
        category: "css-color"
    )
    cases = cases + [test2]

    # Test 3: Named color == hex
    val test3 = RefTestCase(
        name: "named-color-rebeccapurple",
        test_html: "<div style='width: 100px; height: 100px; background-color: rebeccapurple'></div>",
        ref_html: "<div style='width: 100px; height: 100px; background-color: #663399'></div>",
        comparison: "==",
        tolerance: 0,
        category: "css-color"
    )
    cases = cases + [test3]

    # Test 4: rgba with alpha
    val test4 = RefTestCase(
        name: "rgba-alpha-50pct",
        test_html: "<div style='width: 100px; height: 100px; background-color: rgba(255, 0, 0, 0.5)'></div>",
        ref_html: "<div style='width: 100px; height: 100px; background-color: #FF000080'></div>",
        comparison: "==",
        tolerance: 2,
        category: "css-color"
    )
    cases = cases + [test4]

    # Test 5: transparent == rgba(0,0,0,0)
    val test5 = RefTestCase(
        name: "transparent-equivalence",
        test_html: "<div style='width: 100px; height: 100px; background-color: transparent'></div>",
        ref_html: "<div style='width: 100px; height: 100px; background-color: rgba(0, 0, 0, 0)'></div>",
        comparison: "==",
        tolerance: 0,
        category: "css-color"
    )
    cases = cases + [test5]

    # Test 6: All 17 basic CSS colors
    val test6 = RefTestCase(
        name: "named-color-navy",
        test_html: "<div style='width: 100px; height: 100px; background-color: navy'></div>",
        ref_html: "<div style='width: 100px; height: 100px; background-color: #000080'></div>",
        comparison: "==",
        tolerance: 0,
        category: "css-color"
    )
    cases = cases + [test6]

    # Test 7: Extended named color
    val test7 = RefTestCase(
        name: "named-color-cornflowerblue",
        test_html: "<div style='width: 100px; height: 100px; background-color: cornflowerblue'></div>",
        ref_html: "<div style='width: 100px; height: 100px; background-color: #6495ED'></div>",
        comparison: "==",
        tolerance: 0,
        category: "css-color"
    )
    cases = cases + [test7]

    cases
