# CSS Ref Test Harness — runs all ref test suites
#
# Collects tests from all CSS feature categories and runs them
# through the browser renderer, comparing pixel output.
#
# Usage:
#   val harness = TestHarness.new(800, 600, logger)
#   val suite = harness.run_all(render_fn)
#   print suite.summary()

use examples.browser.test.reftest.reftest_runner.{RefTestCase, RefTestRunner, RefTestSuiteResult}
use examples.browser.test.reftest.css_box.margin_collapse_spec.{margin_collapse_test_cases}
use examples.browser.test.reftest.css_flexbox.flex_layout_spec.{flex_layout_test_cases}
use examples.browser.test.reftest.css_position.positioning_spec.{positioning_test_cases}
use examples.browser.test.reftest.css_color.color_parsing_spec.{color_parsing_test_cases}
use examples.browser.test.reftest.css_values.calc_spec.{calc_test_cases}
use examples.browser.shared.logging.{Logger}

class TestHarness:
    viewport_width: i32
    viewport_height: i32
    logger: Logger

    static fn new(vw: i32, vh: i32, logger: Logger) -> TestHarness:
        TestHarness(
            viewport_width: vw,
            viewport_height: vh,
            logger: logger
        )

    fn collect_all_tests() -> [RefTestCase]:
        """Collect test cases from all CSS feature test suites."""
        var all: [RefTestCase] = []

        # Box model tests
        val box_tests = margin_collapse_test_cases()
        for t in box_tests:
            all = all + [t]

        # Flexbox tests
        val flex_tests = flex_layout_test_cases()
        for t in flex_tests:
            all = all + [t]

        # Positioning tests
        val pos_tests = positioning_test_cases()
        for t in pos_tests:
            all = all + [t]

        # Color tests
        val color_tests = color_parsing_test_cases()
        for t in color_tests:
            all = all + [t]

        # CSS function tests
        val calc_tests = calc_test_cases()
        for t in calc_tests:
            all = all + [t]

        all

    fn test_count() -> i64:
        self.collect_all_tests().len().to_i64()

    me run_all(render_fn: fn(text) -> [u32]) -> RefTestSuiteResult:
        """Run all ref tests using the provided render function.
        render_fn takes an HTML string and returns a pixel buffer.
        """
        val runner = RefTestRunner.new(self.viewport_width, self.viewport_height, self.logger)
        val tests = self.collect_all_tests()
        self.logger.info("running {tests.len()} ref tests across all categories")
        val suite = runner.run_suite(tests, render_fn)

        self.logger.info("=== RESULTS ===")
        self.logger.info(suite.summary())
        self.logger.info(suite.summary_by_category())
        suite
