# Ref tests for CSS box model — margin collapsing
#
# Each test verifies a CSS box model behavior by rendering two HTML
# documents and comparing them pixel-by-pixel.

use examples.browser.test.reftest.reftest_runner.{RefTestCase, RefTestRunner, RefTestSuiteResult}
use examples.browser.test.reftest.pixel_compare.{CompareResult}
use examples.browser.shared.logging.{Logger}

fn margin_collapse_test_cases() -> [RefTestCase]:
    var cases: [RefTestCase] = []

    # Test 1: Adjacent sibling margin collapse — two 20px margins should collapse to 20px gap
    val test1 = RefTestCase(
        name: "margin-collapse-adjacent-siblings",
        test_html: "<div style='margin-bottom: 20px; height: 50px; background: red'></div><div style='margin-top: 20px; height: 50px; background: blue'></div>",
        ref_html: "<div style='height: 50px; background: red'></div><div style='margin-top: 20px; height: 50px; background: blue'></div>",
        comparison: "==",
        tolerance: 0,
        category: "css-box"
    )
    cases = cases + [test1]

    # Test 2: Auto margin centering — margin: 0 auto should center a block
    val test2 = RefTestCase(
        name: "margin-auto-centering",
        test_html: "<div style='width: 200px; margin: 0 auto; height: 50px; background: green'></div>",
        ref_html: "<div style='width: 200px; margin-left: 300px; height: 50px; background: green'></div>",
        comparison: "==",
        tolerance: 2,
        category: "css-box"
    )
    cases = cases + [test2]

    # Test 3: Padding does not collapse
    val test3 = RefTestCase(
        name: "padding-no-collapse",
        test_html: "<div style='padding: 10px; height: 30px; background: yellow; box-sizing: border-box'></div>",
        ref_html: "<div style='padding: 10px; height: 30px; background: yellow; box-sizing: border-box'></div>",
        comparison: "==",
        tolerance: 0,
        category: "css-box"
    )
    cases = cases + [test3]

    # Test 4: Border-box sizing
    val test4 = RefTestCase(
        name: "box-sizing-border-box",
        test_html: "<div style='width: 100px; height: 100px; padding: 10px; border: 5px solid black; box-sizing: border-box; background: red'></div>",
        ref_html: "<div style='width: 70px; height: 70px; padding: 10px; border: 5px solid black; background: red'></div>",
        comparison: "==",
        tolerance: 0,
        category: "css-box"
    )
    cases = cases + [test4]

    cases
