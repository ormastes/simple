#![allow(spipe_placeholder_tests)]
#![allow(REQC001)]
#![allow(REQC004)]
#![allow(unnamed_duplicate_typed_args)]
# Architecture: MDSOC Capsule Isolation Tests
# Category: Browser Platform Architecture
# Status: Active
#
# Validates that the Simple Browser Platform capsule.sdn enforces correct
# isolation between dimensions and layers. Entity capsules must be pure types
# with no feature dependencies, feature layers must respect ordering, and
# the transform dimension must bridge entity and feature explicitly.
#
# Run with: bin/simple test examples/browser/test/architecture/capsule_isolation_spec.spl

use std.spec
use std.io_runtime.{file_read}

val CAPSULE_PATH = "examples/browser/capsule.sdn"

val LAYER_ORDER = [
    "net", "parser", "dom", "style", "layout",
    "paint", "composite", "gpu", "script", "browser", "sandbox"
]

fn get_layer_level(layer: text) -> i64:
    var i: i64 = 0
    for l in LAYER_ORDER:
        if l == layer:
            return i
        i = i + 1
    -1

# Helper: check if a dependency name starts with a given prefix
fn dep_starts_with(dep: text, prefix: text) -> bool:
    dep.starts_with(prefix)

fn capsule_section(content: text, name: text) -> text:
    val header = "[capsule {name}]"
    val start = content.index_of(header)
    if start < 0:
        return ""
    val tail = content.slice(start, content.len())
    val rest = tail.slice(header.len(), tail.len())
    val next = rest.index_of("\n[")
    if next < 0:
        return tail
    tail.slice(0, header.len() + next)

# ============================================================================
# Entity dimension isolation
# ============================================================================

describe "Browser capsule isolation":
    context "entity dimension":
        it "entity dimension has no feature dependencies":
            """All entity capsules (sbp.types.*) only depend on other sbp.types.* capsules."""
            val content = file_read(CAPSULE_PATH)
            # Entity capsules in capsule.sdn: sbp.types.dom, sbp.types.net,
            # sbp.types.script, sbp.types.browser, sbp.types.ipc, sbp.types.media
            # None of them declare dependencies (they are pure types).
            # Verify by checking the file does not contain entity capsules with
            # non-types dependencies.
            val entity_names = [
                "sbp.types.dom", "sbp.types.net", "sbp.types.script",
                "sbp.types.browser", "sbp.types.ipc", "sbp.types.media"
            ]
            var all_clean = true
            for name in entity_names:
                val section = capsule_section(content, name)
                if section == "" or section.contains("dependencies ="):
                    all_clean = false
            expect(all_clean).to_equal(true)

    context "feature dimension dependencies":
        it "script engine only talks to DOM and types":
            """sbp.script dependencies are only sbp.dom and sbp.types.* capsules."""
            val content = file_read(CAPSULE_PATH)
            val section = capsule_section(content, "sbp.script")
            val deps_valid = (
                section.contains("dependencies = [\"sbp.dom\", \"sbp.types.script\", \"sbp.types.dom\"]")
            )
            expect(deps_valid).to_equal(true)

        it "network layer has no DOM access":
            """sbp.net dependencies do not include sbp.dom."""
            val content = file_read(CAPSULE_PATH)
            val section = capsule_section(content, "sbp.net")
            expect(section.contains("\"sbp.dom\"")).to_equal(false)

    context "layer ordering":
        it "no reverse layer dependencies":
            """For each feature capsule, verify deps are at lower or equal layers."""
            val content = file_read(CAPSULE_PATH)
            # Map of capsule name to layer extracted from capsule.sdn
            val cap_names = [
                "sbp.net", "sbp.parser", "sbp.dom", "sbp.style",
                "sbp.layout", "sbp.paint", "sbp.composite", "sbp.gpu",
                "sbp.script", "sbp.browser", "sbp.sandbox"
            ]
            val cap_layers = [
                "net", "parser", "dom", "style", "layout",
                "paint", "composite", "gpu", "script", "browser", "sandbox"
            ]
            var all_valid = true
            var i = 0
            while i < cap_names.len():
                val cap_name = cap_names.get(i)
                val cap_layer = cap_layers.get(i)
                val cap_level = get_layer_level(cap_layer)
                # Known dependencies from capsule.sdn (hardcoded for architecture test)
                val deps = _get_feature_deps(cap_name)
                for dep in deps:
                    # Only check feature deps (skip sbp.types.*)
                    if not dep.starts_with("sbp.types."):
                        val dep_layer = _capsule_to_layer(dep)
                        val dep_level = get_layer_level(dep_layer)
                        if dep_level > cap_level:
                            all_valid = false
                i = i + 1
            expect(all_valid).to_equal(true)

        it "layer order is enforced":
            """layer_order list has correct sequence from capsule.sdn."""
            val expected = [
                "net", "parser", "dom", "style", "layout",
                "paint", "composite", "gpu", "script", "browser", "sandbox"
            ]
            var i: i64 = 0
            for layer in expected:
                expect(LAYER_ORDER[i]).to_equal(layer)
                i = i + 1
            expect(i).to_equal(11)

    context "transform dimension":
        it "transform bridges connect dimensions":
            """sbp.transform.pipeline has deps in both entity and feature dimensions."""
            val content = file_read(CAPSULE_PATH)
            # The transform pipeline depends on both entity (sbp.types.*) and
            # feature (sbp.net, sbp.parser, sbp.dom, etc.) capsules.
            val section = capsule_section(content, "sbp.transform.pipeline")
            val has_entity_dep = section.contains("\"sbp.types.dom\"")
            val has_feature_dep = (
                section.contains("\"sbp.net\"") and
                section.contains("\"sbp.dom\"") and
                section.contains("\"sbp.parser\"") and
                section.contains("\"sbp.browser\"")
            )
            expect(has_entity_dep).to_equal(true)
            expect(has_feature_dep).to_equal(true)

    context "rules":
        it "cycles are rejected":
            """reject_cycles rule is true in capsule.sdn."""
            val content = file_read(CAPSULE_PATH)
            expect(content.contains("[rules]")).to_equal(true)
            expect(content.contains("reject_cycles = true")).to_equal(true)

# ============================================================================
# Helpers: hardcoded dependency map from capsule.sdn for layer validation
# ============================================================================

fn _get_feature_deps(capsule_name: text) -> [text]:
    """Return known dependencies for a feature capsule."""
    match capsule_name:
        "sbp.net": ["sbp.types.net", "sbp.types.ipc"]
        "sbp.parser": ["sbp.net", "sbp.types.dom"]
        "sbp.dom": ["sbp.parser", "sbp.types.dom"]
        "sbp.style": ["sbp.dom", "sbp.types.dom"]
        "sbp.layout": ["sbp.style", "sbp.types.dom", "sbp.types.media"]
        "sbp.paint": ["sbp.layout", "sbp.types.dom", "sbp.types.media"]
        "sbp.composite": ["sbp.paint", "sbp.types.dom"]
        "sbp.gpu": ["sbp.composite", "sbp.types.media"]
        "sbp.script": ["sbp.dom", "sbp.types.script", "sbp.types.dom"]
        "sbp.browser": ["sbp.net", "sbp.dom", "sbp.script", "sbp.composite", "sbp.types.browser", "sbp.types.ipc"]
        "sbp.sandbox": ["sbp.browser", "sbp.types.ipc"]
        _: []

fn _capsule_to_layer(capsule_name: text) -> text:
    """Map a feature capsule name to its layer."""
    match capsule_name:
        "sbp.net": "net"
        "sbp.parser": "parser"
        "sbp.dom": "dom"
        "sbp.style": "style"
        "sbp.layout": "layout"
        "sbp.paint": "paint"
        "sbp.composite": "composite"
        "sbp.gpu": "gpu"
        "sbp.script": "script"
        "sbp.browser": "browser"
        "sbp.sandbox": "sandbox"
        _: ""
