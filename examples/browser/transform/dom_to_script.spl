# DOM-to-Script bridge for the Simple Browser Platform.
# Dispatches DOM events and notifications to the JavaScript runtime so that
# registered event listeners, mutation observers, and lifecycle callbacks
# are invoked at the correct time.

use sbp.shared.logging.{Logger, LogLevel}
use sbp.shared.error.{BrowserResult, script_error}
use sbp.entity.dom.event_types.{DomEvent, EventPhase}
use sbp.entity.script.js_types.{JsValue, JsObject, JsProperty}
use sbp.feature.script.engine.runtime.{JsRuntime}
use sbp.feature.dom.mutation_observer.{MutationRecord, MutationType}

# ---------------------------------------------------------------------------
# DomToScriptBridge
# ---------------------------------------------------------------------------
class DomToScriptBridge:
    logger: Logger

    static fn new(logger: Logger) -> DomToScriptBridge:
        DomToScriptBridge(logger: logger)

    # --- Event dispatch ------------------------------------------------------

    # Dispatch a DOM event to the JS runtime.
    # Finds all registered listeners for the event type on the target node,
    # wraps the DomEvent as a JS object, and invokes each callback.
    fn dispatch_event_to_js(event: DomEvent, runtime: JsRuntime) -> BrowserResult<()>:
        self.logger.debug("DomToScript: dispatching '{event.type_name}' to node {event.target_id}")

        # Convert the DomEvent to a JsValue the script can inspect
        val js_event = wrap_dom_event(event)

        # TODO: look up registered listeners on runtime and invoke callbacks
        # For now, log and succeed
        pass_todo
        self.logger.debug("DomToScript: dispatch complete for '{event.type_name}'")
        Ok(())

    # --- Mutation observer notifications -------------------------------------

    # Deliver a MutationRecord to any observing JS callbacks.
    fn notify_mutation(record: MutationRecord, runtime: JsRuntime):
        self.logger.debug("DomToScript: mutation notification target={record.target_id}")
        # TODO: walk observer list, check filter, invoke callback
        pass_todo

    # --- Window / document lifecycle events ----------------------------------

    # Notify JS that the viewport was resized.
    fn notify_resize(width: i64, height: i64, runtime: JsRuntime):
        self.logger.debug("DomToScript: resize {width}x{height}")
        # TODO: create ResizeEvent, dispatch to window listeners
        pass_todo

    # Notify JS of a scroll position change.
    fn notify_scroll(scroll_x: f64, scroll_y: f64, runtime: JsRuntime):
        self.logger.debug("DomToScript: scroll ({scroll_x}, {scroll_y})")
        # TODO: create ScrollEvent, dispatch
        pass_todo

    # Fire the `load` event (window.onload).
    fn notify_load(runtime: JsRuntime):
        self.logger.info("DomToScript: load event")
        # TODO: dispatch 'load' event to window
        pass_todo

    # Fire the `DOMContentLoaded` event.
    fn notify_dom_content_loaded(runtime: JsRuntime):
        self.logger.info("DomToScript: DOMContentLoaded event")
        # TODO: dispatch 'DOMContentLoaded' to document
        pass_todo

# ---------------------------------------------------------------------------
# Pure helpers
# ---------------------------------------------------------------------------

# Convert a DomEvent into a JsValue.Object that JS code can read.
# Properties: type, target, currentTarget, bubbles, cancelable, timeStamp.
fn wrap_dom_event(event: DomEvent) -> JsValue:
    # We represent the event as an integer object ID.  The actual property
    # storage would be handled by the JS object store in a real implementation.
    # For now, return a placeholder object reference.
    #
    # In a full implementation this would:
    #   1. Allocate a JsObject in the runtime's object store
    #   2. Set .type = event.type_name
    #   3. Set .target = node reference for event.target_id
    #   4. Set .currentTarget = node reference for event.current_target_id
    #   5. Set .bubbles = event.init.bubbles
    #   6. Set .cancelable = event.init.cancelable
    #   7. Set .timeStamp = event.timestamp
    pass_todo
    JsValue.Object(id: -1)

# Convert an EventPhase enum to its DOM Level 2 integer constant.
fn event_phase_to_int(phase: EventPhase) -> i64:
    match phase:
        EventPhase.None: 0
        EventPhase.Capturing: 1
        EventPhase.AtTarget: 2
        EventPhase.Bubbling: 3
