# UI-to-DOM bridge for the Simple Browser Platform.
# Translates chrome/UI actions (URL bar submission, back/forward,
# reload, find-in-page, zoom, etc.) into navigation or DOM interaction
# commands that the browser engine processes.
# Also handles UI events (click, scroll, input, resize, focus) by
# dispatching corresponding DOM mutations.

use sbp.shared.logging.{Logger, LogLevel}
use sbp.shared.error.{BrowserResult, dom_error}

# ---------------------------------------------------------------------------
# NavigationAction — what the UI intends to do after classifying input.
# ---------------------------------------------------------------------------
enum NavigationAction:
    Navigate(url: text)
    Search(query: text)
    InternalPage(page: text)

# ---------------------------------------------------------------------------
# UiEvent — UI-level events that map to DOM mutations
# ---------------------------------------------------------------------------
enum UiEvent:
    Click(x: f64, y: f64)
    Input(element_id: i64, value: text)
    Scroll(dx: f64, dy: f64)
    Resize(width: f64, height: f64)
    Focus(element_id: i64)
    Blur(element_id: i64)

# ---------------------------------------------------------------------------
# DomMutation — the DOM-side effect of a UI action
# ---------------------------------------------------------------------------
enum DomMutation:
    DispatchClickEvent(element_id: i64, x: f64, y: f64)
    UpdateInputValue(element_id: i64, value: text)
    DispatchInputEvent(element_id: i64)
    UpdateScrollPosition(dx: f64, dy: f64)
    DispatchScrollEvent
    UpdateViewport(width: f64, height: f64)
    DispatchResizeEvent
    SetFocusedElement(element_id: i64)
    DispatchFocusEvent(element_id: i64)
    DispatchBlurEvent(element_id: i64)

# ---------------------------------------------------------------------------
# NavigationHistory — simple back/forward history stack
# ---------------------------------------------------------------------------
class NavigationHistory:
    back_stack: List<text>
    forward_stack: List<text>
    current_url: text

    static fn create() -> NavigationHistory:
        NavigationHistory(
            back_stack: List<text>(),
            forward_stack: List<text>(),
            current_url: "about:blank"
        )

    me navigate_to(url: text):
        if self.current_url.len() > 0:
            self.back_stack.push(self.current_url)
        self.current_url = url
        # Clear forward stack on new navigation
        self.forward_stack = List<text>()

    me go_back() -> text?:
        if self.back_stack.len() == 0:
            return nil
        # Pop from back stack
        val prev = self.back_stack.get(self.back_stack.len() - 1)
        var new_back = List<text>()
        var i = 0
        while i < self.back_stack.len() - 1:
            new_back.push(self.back_stack.get(i))
            i = i + 1
        self.back_stack = new_back
        # Push current to forward stack
        self.forward_stack.push(self.current_url)
        self.current_url = prev
        prev

    me go_forward() -> text?:
        if self.forward_stack.len() == 0:
            return nil
        # Pop from forward stack
        val next = self.forward_stack.get(self.forward_stack.len() - 1)
        var new_fwd = List<text>()
        var i = 0
        while i < self.forward_stack.len() - 1:
            new_fwd.push(self.forward_stack.get(i))
            i = i + 1
        self.forward_stack = new_fwd
        # Push current to back stack
        self.back_stack.push(self.current_url)
        self.current_url = next
        next

# ---------------------------------------------------------------------------
# ViewportState — tracks current viewport dimensions, scroll, zoom, focus
# ---------------------------------------------------------------------------
class ViewportState:
    width: f64
    height: f64
    scroll_x: f64
    scroll_y: f64
    zoom_factor: f64
    focused_element_id: i64

    static fn create(width: f64, height: f64) -> ViewportState:
        ViewportState(
            width: width,
            height: height,
            scroll_x: 0.0,
            scroll_y: 0.0,
            zoom_factor: 1.0,
            focused_element_id: -1
        )

# ---------------------------------------------------------------------------
# UiToDomBridge
# ---------------------------------------------------------------------------
class UiToDomBridge:
    logger: Logger
    history: NavigationHistory
    viewport: ViewportState
    is_loading: bool

    static fn new(logger: Logger) -> UiToDomBridge:
        UiToDomBridge(
            logger: logger,
            history: NavigationHistory.create(),
            viewport: ViewportState.create(1280.0, 720.0),
            is_loading: false
        )

    # --- URL bar -------------------------------------------------------------

    # User pressed Enter in the URL bar.
    # Classify the input and return the appropriate action.
    fn handle_url_submit(url: text) -> BrowserResult<NavigationAction>:
        self.logger.info("UiToDom: URL submitted: '{url}'")
        val action = classify_input(url)
        Ok(action)

    # --- Navigation buttons --------------------------------------------------

    me handle_back() -> BrowserResult<text>:
        self.logger.info("UiToDom: back")
        val prev = self.history.go_back()
        if val url = prev:
            self.logger.debug("UiToDom: navigating back to {url}")
            return Ok(url)
        self.logger.debug("UiToDom: no back history available")
        Err(dom_error("No back history available"))

    me handle_forward() -> BrowserResult<text>:
        self.logger.info("UiToDom: forward")
        val next = self.history.go_forward()
        if val url = next:
            self.logger.debug("UiToDom: navigating forward to {url}")
            return Ok(url)
        self.logger.debug("UiToDom: no forward history available")
        Err(dom_error("No forward history available"))

    me handle_reload() -> BrowserResult<text>:
        self.logger.info("UiToDom: reload")
        val current = self.history.current_url
        if current.len() == 0 or current == "about:blank":
            return Err(dom_error("No page to reload"))
        self.logger.debug("UiToDom: reloading {current}")
        Ok(current)

    me handle_stop() -> BrowserResult<()>:
        self.logger.info("UiToDom: stop loading")
        self.is_loading = false
        self.logger.debug("UiToDom: loading stopped")
        Ok(())

    # Record a navigation in history (call after successful page load).
    me record_navigation(url: text):
        self.logger.debug("UiToDom: recording navigation to {url}")
        self.history.navigate_to(url)

    # --- UI event dispatch ---------------------------------------------------

    # Process a UI event and return the list of DOM mutations to apply.
    me handle_event(event: UiEvent) -> List<DomMutation>:
        var mutations = List<DomMutation>()
        match event:
            UiEvent.Click(x, y):
                self.logger.debug("UiToDom: click at ({x}, {y})")
                # In a full implementation, hit-test the layout tree to find element_id.
                # For now, use focused element or -1 as placeholder.
                val target_id = self.viewport.focused_element_id
                mutations.push(DomMutation.DispatchClickEvent(element_id: target_id, x: x, y: y))
            UiEvent.Input(element_id, value):
                self.logger.debug("UiToDom: input on element {element_id}: '{value}'")
                mutations.push(DomMutation.UpdateInputValue(element_id: element_id, value: value))
                mutations.push(DomMutation.DispatchInputEvent(element_id: element_id))
            UiEvent.Scroll(dx, dy):
                self.logger.debug("UiToDom: scroll ({dx}, {dy})")
                self.viewport.scroll_x = self.viewport.scroll_x + dx
                self.viewport.scroll_y = self.viewport.scroll_y + dy
                # Clamp scroll_y to >= 0
                if self.viewport.scroll_y < 0.0:
                    self.viewport.scroll_y = 0.0
                mutations.push(DomMutation.UpdateScrollPosition(dx: dx, dy: dy))
                mutations.push(DomMutation.DispatchScrollEvent)
            UiEvent.Resize(width, height):
                self.logger.debug("UiToDom: resize to ({width}, {height})")
                self.viewport.width = width
                self.viewport.height = height
                mutations.push(DomMutation.UpdateViewport(width: width, height: height))
                mutations.push(DomMutation.DispatchResizeEvent)
            UiEvent.Focus(element_id):
                self.logger.debug("UiToDom: focus on element {element_id}")
                val prev_focused = self.viewport.focused_element_id
                if prev_focused >= 0 and prev_focused != element_id:
                    mutations.push(DomMutation.DispatchBlurEvent(element_id: prev_focused))
                self.viewport.focused_element_id = element_id
                mutations.push(DomMutation.SetFocusedElement(element_id: element_id))
                mutations.push(DomMutation.DispatchFocusEvent(element_id: element_id))
            UiEvent.Blur(element_id):
                self.logger.debug("UiToDom: blur on element {element_id}")
                if self.viewport.focused_element_id == element_id:
                    self.viewport.focused_element_id = -1
                mutations.push(DomMutation.DispatchBlurEvent(element_id: element_id))
        mutations

    # --- Page interaction ----------------------------------------------------

    # Find-in-page: search text nodes for `query` and return matching node IDs.
    # In a full implementation, this would walk the DOM text nodes.
    # Here we do a simple linear scan of the provided node_ids to simulate matching.
    fn handle_find_in_page(query: text, node_ids: List<i64>) -> List<i64>:
        self.logger.debug("UiToDom: find in page '{query}' across {node_ids.len()} nodes")
        # Without DOM text content access, return all provided node IDs as
        # potential matches. The caller can filter further with actual text content.
        if query.len() == 0:
            return List<i64>()
        # Return node_ids as candidates (simulated match)
        self.logger.warn("UiToDom: find-in-page returns all {node_ids.len()} nodes as candidates (no DOM text access)")
        node_ids

    # Zoom the page by the given factor (e.g. 1.1 = 110%).
    me handle_zoom(factor: f64) -> BrowserResult<()>:
        self.logger.info("UiToDom: zoom factor={factor}")
        if factor <= 0.0:
            return Err(dom_error("Zoom factor must be positive"))
        if factor < 0.25 or factor > 5.0:
            return Err(dom_error("Zoom factor out of range (0.25 - 5.0)"))
        self.viewport.zoom_factor = factor
        self.logger.debug("UiToDom: zoom set to {factor}")
        Ok(())

    # Print the current page.
    fn handle_print() -> BrowserResult<()>:
        self.logger.info("UiToDom: print requested")
        # Print requires platform integration (OS print dialog).
        # Log the intent and return success — the caller is responsible
        # for routing to the platform print subsystem.
        self.logger.warn("UiToDom: print routed to caller — platform print dialog integration required")
        Ok(())

# ---------------------------------------------------------------------------
# Input classification
# ---------------------------------------------------------------------------

# Classify raw URL-bar input as a navigation URL, search query, or
# internal page reference.
fn classify_input(input: text) -> NavigationAction:
    val trimmed = input.trim()

    # 1. Internal pages (about:blank, about:settings, etc.)
    if trimmed.starts_with("about:"):
        val page = trimmed.substring(6, trimmed.len())
        return NavigationAction.InternalPage(page: page)

    # 2. Explicit protocol — treat as URL
    if trimmed.starts_with("http://") or trimmed.starts_with("https://"):
        return NavigationAction.Navigate(url: trimmed)

    # 3. Looks like a domain (contains a dot, no spaces)
    if trimmed.contains(".") and not trimmed.contains(" "):
        return NavigationAction.Navigate(url: "https://{trimmed}")

    # 4. Localhost with optional port
    if trimmed.starts_with("localhost"):
        return NavigationAction.Navigate(url: "http://{trimmed}")

    # 5. Otherwise treat as search query
    NavigationAction.Search(query: trimmed)
