# Composite-to-GPU bridge for the Simple Browser Platform.
# Translates compositing layers into GpuCommands that can be submitted
# to the GPU command buffer for rasterization and final presentation.
#
# Each layer is rasterized independently, then the layers are composited
# back-to-front with appropriate transforms and opacity.

use sbp.shared.logging.{Logger, LogLevel}
use sbp.entity.dom.paint_types.{PaintOp, DisplayItem, Color, white}
use sbp.feature.composite.layer_tree.{CompositeLayer}
use sbp.feature.gpu.command_buffer.{GpuCommand}

# ---------------------------------------------------------------------------
# CompositeToGpuBridge
# ---------------------------------------------------------------------------
class CompositeToGpuBridge:
    logger: Logger

    static fn new(logger: Logger) -> CompositeToGpuBridge:
        CompositeToGpuBridge(logger: logger)

    # Generate the full set of GPU commands for one frame.
    # `layers` is the composited layer tree; `frame` is the frame counter
    # used for fence synchronization.
    fn generate_gpu_commands(layers: List<CompositeLayer>, frame: i64) -> List<GpuCommand>:
        self.logger.info("CompositeToGpu: generating GPU commands for frame {frame}")
        var cmds = List<GpuCommand>()

        # 1. Clear the back buffer
        cmds.push(GpuCommand.Clear(
            surface_id: 0,
            color: white(),
        ))

        # 2. Rasterize each layer
        for layer in layers:
            val layer_cmds = rasterize_layer(layer)
            for cmd in layer_cmds:
                cmds.push(cmd)

        # 3. Composite layers back-to-front
        val comp_cmds = composite_layers(layers)
        for cmd in comp_cmds:
            cmds.push(cmd)

        # 4. Present
        val present = present_frame(0)
        cmds.push(present)

        # 5. Fence for frame synchronization
        cmds.push(GpuCommand.Fence(id: frame))

        self.logger.info("CompositeToGpu: {cmds.len()} GPU commands")
        cmds

# ---------------------------------------------------------------------------
# Pure helpers
# ---------------------------------------------------------------------------

# Rasterize a single layer into GPU commands.
# Each DisplayItem's PaintOp is translated to the appropriate GPU draw call.
fn rasterize_layer(layer: CompositeLayer) -> List<GpuCommand>:
    var cmds = List<GpuCommand>()

    # Apply layer transform
    val transform_cmds = apply_layer_transform(layer)
    for cmd in transform_cmds:
        cmds.push(cmd)

    # Set scissor rect for layer bounds
    if layer.clips_children:
        cmds.push(GpuCommand.SetScissor(
            x: layer.bounds_x.to_i64(),
            y: layer.bounds_y.to_i64(),
            w: layer.bounds_w.to_i64(),
            h: layer.bounds_h.to_i64(),
        ))

    # Translate each display item to a GPU draw quad
    for item in layer.display_items:
        match item.op:
            PaintOp.FillRect(x, y, w, h, color):
                # Use a solid-color quad (texture_id = -1 means untextured)
                cmds.push(GpuCommand.DrawQuad(
                    surface_id: 0,
                    x: x, y: y, w: w, h: h,
                    texture_id: -1,
                    opacity: layer.opacity,
                ))
            PaintOp.DrawImage(x, y, w, h, image_id):
                cmds.push(GpuCommand.DrawQuad(
                    surface_id: 0,
                    x: x, y: y, w: w, h: h,
                    texture_id: image_id,
                    opacity: layer.opacity,
                ))
            _: pass_do_nothing

    # Clear scissor if it was set
    if layer.clips_children:
        cmds.push(GpuCommand.ClearScissor)

    cmds

# Composite layers in back-to-front order by blitting each layer's
# rasterized surface onto the final surface.
fn composite_layers(layers: List<CompositeLayer>) -> List<GpuCommand>:
    var cmds = List<GpuCommand>()
    var layer_idx = 0
    for layer in layers:
        if layer_idx > 0:
            # Blit this layer onto surface 0 (the back buffer)
            cmds.push(GpuCommand.Blit(
                src_surface: layer.id,
                dst_surface: 0,
                src_x: 0, src_y: 0,
                src_w: layer.bounds_w.to_i64(), src_h: layer.bounds_h.to_i64(),
                dst_x: layer.bounds_x.to_i64(), dst_y: layer.bounds_y.to_i64(),
                dst_w: layer.bounds_w.to_i64(), dst_h: layer.bounds_h.to_i64(),
            ))
        layer_idx = layer_idx + 1
    cmds

# Apply the layer's CSS transform (stored as a flattened 4x4 matrix).
# Decomposes the transform into translation and scale components and
# emits DrawQuad commands that represent the transformation.
# A 4x4 identity matrix has 1.0 on the diagonal and 0.0 elsewhere.
fn apply_layer_transform(layer: CompositeLayer) -> List<GpuCommand>:
    var cmds = List<GpuCommand>()
    val t = layer.transform

    # Only process if we have a full 4x4 matrix (16 elements)
    if t.len() < 16:
        return cmds

    # Check if this is the identity matrix — skip if so
    val is_identity = _is_identity_matrix(t)
    if is_identity:
        return cmds

    # Extract translation from matrix elements [12], [13] (tx, ty)
    val tx = t.get(12)
    val ty = t.get(13)

    # Extract scale from diagonal elements [0] (sx) and [5] (sy)
    val sx = t.get(0)
    val sy = t.get(5)

    # Compute transformed bounds
    val new_x = layer.bounds_x * sx + tx
    val new_y = layer.bounds_y * sy + ty
    val new_w = layer.bounds_w * sx
    val new_h = layer.bounds_h * sy

    # Emit a DrawQuad with the transformed coordinates on the layer surface
    cmds.push(GpuCommand.DrawQuad(
        surface_id: layer.id,
        x: new_x,
        y: new_y,
        w: new_w,
        h: new_h,
        texture_id: -1,
        opacity: layer.opacity
    ))

    cmds

# Check if a flattened 4x4 matrix is the identity matrix.
fn _is_identity_matrix(m: List<f64>) -> bool:
    if m.len() < 16:
        return false
    # Diagonal must be 1.0, all others 0.0
    var i = 0
    while i < 16:
        val row = i / 4
        val col = i % 4
        val expected = if row == col: 1.0 else: 0.0
        val diff = m.get(i) - expected
        val abs_diff = if diff < 0.0: 0.0 - diff else: diff
        if abs_diff > 0.0001:
            return false
        i = i + 1
    true

# Issue a present/swap command for the given swapchain.
fn present_frame(swapchain_id: i64) -> GpuCommand:
    GpuCommand.Present(swapchain_id: swapchain_id)
