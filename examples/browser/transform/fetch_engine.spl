use examples.browser.entity.net.quic_types.{QuicConfig}
use examples.browser.entity.media.webp_types.{WebpConfig, WebpImage}
use examples.browser.feature.net.quic_transport.{QuicConnection}
use examples.browser.feature.net.h3_client.{H3Client, H3Header}
use examples.browser.feature.net.h2_parallel.{H2ParallelFetch, H2Request, H2Header}
use examples.browser.feature.net.zip_reader.{ZipReader}
use examples.browser.feature.net.bundle_tracker.{BundleGraph, SharedChunkResolver}
use examples.browser.feature.net.bloom_cache.{CacheFreshnessFilter}
use examples.browser.feature.paint.webp_decoder.{WebpDecoder}
use examples.browser.feature.paint.webp_encoder.{WebpEncoder}

val PROTOCOL_H1: i64 = 1
val PROTOCOL_H2: i64 = 2
val PROTOCOL_H3: i64 = 3

val CT_ZIP: text = "application/zip"
val CT_ZIP_ALT: text = "application/x-zip-compressed"
val CT_JS: text = "application/javascript"
val CT_CSS: text = "text/css"
val CT_IMAGE_PREFIX: text = "image/"
val CT_WEBP: text = "image/webp"

class AltSvcEntry:
    host: text
    port: i64
    protocol: i64

    static fn new(host: text, port: i64, protocol: i64) -> AltSvcEntry:
        AltSvcEntry(host: host, port: port, protocol: protocol)

class FetchHeader:
    name: text
    value: text

    static fn new(name: text, value: text) -> FetchHeader:
        FetchHeader(name: name, value: value)

class FetchResult:
    url: text
    status: i64
    headers: [FetchHeader]
    body: [u8]
    protocol: text

    static fn new(url: text, status: i64, headers: [FetchHeader], body: [u8], protocol: text) -> FetchResult:
        FetchResult(url: url, status: status, headers: headers, body: body, protocol: protocol)

class FetchEngineConfig:
    h3_enabled: bool
    bloom_expected_items: i64
    bundle_tracking: bool
    webp_auto_convert: bool
    zip_auto_extract: bool

    static fn new() -> FetchEngineConfig:
        FetchEngineConfig(
            h3_enabled: false,
            bloom_expected_items: 1000,
            bundle_tracking: false,
            webp_auto_convert: false,
            zip_auto_extract: false
        )

    fn with_h3_enabled(enabled: bool) -> FetchEngineConfig:
        FetchEngineConfig(
            h3_enabled: enabled,
            bloom_expected_items: self.bloom_expected_items,
            bundle_tracking: self.bundle_tracking,
            webp_auto_convert: self.webp_auto_convert,
            zip_auto_extract: self.zip_auto_extract
        )

    fn with_bloom_filter(expected_items: i64) -> FetchEngineConfig:
        FetchEngineConfig(
            h3_enabled: self.h3_enabled,
            bloom_expected_items: expected_items,
            bundle_tracking: self.bundle_tracking,
            webp_auto_convert: self.webp_auto_convert,
            zip_auto_extract: self.zip_auto_extract
        )

    fn with_bundle_tracking(enabled: bool) -> FetchEngineConfig:
        FetchEngineConfig(
            h3_enabled: self.h3_enabled,
            bloom_expected_items: self.bloom_expected_items,
            bundle_tracking: enabled,
            webp_auto_convert: self.webp_auto_convert,
            zip_auto_extract: self.zip_auto_extract
        )

    fn with_webp_auto_convert(enabled: bool) -> FetchEngineConfig:
        FetchEngineConfig(
            h3_enabled: self.h3_enabled,
            bloom_expected_items: self.bloom_expected_items,
            bundle_tracking: self.bundle_tracking,
            webp_auto_convert: enabled,
            zip_auto_extract: self.zip_auto_extract
        )

    fn with_zip_auto_extract(enabled: bool) -> FetchEngineConfig:
        FetchEngineConfig(
            h3_enabled: self.h3_enabled,
            bloom_expected_items: self.bloom_expected_items,
            bundle_tracking: self.bundle_tracking,
            webp_auto_convert: self.webp_auto_convert,
            zip_auto_extract: enabled
        )

fn _header_value(headers: [FetchHeader], name: text) -> text:
    var i = 0
    while i < headers.len():
        if headers[i].name == name:
            return headers[i].value
        i = i + 1
    ""

fn _host_of(url: text) -> text:
    var start = 0
    if url.starts_with("https://"):
        start = 8
    elif url.starts_with("http://"):
        start = 7
    var end = start
    while end < url.len():
        val c = url.char_at(end)
        if c == 47 or c == 58:
            break
        end = end + 1
    url.slice(start, end)

fn _has_altsvc(entries: [AltSvcEntry], host: text, protocol: i64) -> bool:
    var i = 0
    while i < entries.len():
        if entries[i].host == host and entries[i].protocol == protocol:
            return true
        i = i + 1
    false

fn _make_stub_response(url: text, protocol: text) -> FetchResult:
    var empty_headers: [FetchHeader] = []
    var empty_body: [u8] = []
    FetchResult.new(url, 200, empty_headers, empty_body, protocol)

class FetchEngine:
    config: FetchEngineConfig
    bloom: CacheFreshnessFilter
    alt_svc: [AltSvcEntry]
    h2_fetcher: H2ParallelFetch
    bundle_graph: BundleGraph
    chunk_resolver: SharedChunkResolver

    static fn new(config: FetchEngineConfig) -> FetchEngine:
        FetchEngine(
            config: config,
            bloom: CacheFreshnessFilter.new(config.bloom_expected_items, 0.01),
            alt_svc: [AltSvcEntry](),
            h2_fetcher: H2ParallelFetch.new(100),
            bundle_graph: BundleGraph.new(),
            chunk_resolver: SharedChunkResolver.new(2)
        )

    fn select_protocol(url: text) -> i64:
        val host = _host_of(url)
        if self.config.h3_enabled and _has_altsvc(self.alt_svc, host, PROTOCOL_H3):
            return PROTOCOL_H3
        if _has_altsvc(self.alt_svc, host, PROTOCOL_H2):
            return PROTOCOL_H2
        PROTOCOL_H1

    fn _fetch_h1(url: text, headers: [FetchHeader]) -> FetchResult:
        _make_stub_response(url, "h1")

    me _fetch_h2(url: text, headers: [FetchHeader]) -> FetchResult:
        var h2_headers: [H2Header] = []
        var i = 0
        while i < headers.len():
            h2_headers.push(H2Header.new(headers[i].name, headers[i].value))
            i = i + 1
        var requests: [H2Request] = []
        requests.push(H2Request.new("GET", url, h2_headers))
        val responses = self.h2_fetcher.fetch_parallel(requests)
        if responses.len() == 0:
            return _make_stub_response(url, "h2")
        val r = responses[0]
        var out_headers: [FetchHeader] = []
        var j = 0
        while j < r.headers.len():
            out_headers.push(FetchHeader.new(r.headers[j].name, r.headers[j].value))
            j = j + 1
        FetchResult.new(url, r.status, out_headers, r.body, "h2")

    fn _fetch_h3(url: text, headers: [FetchHeader]) -> FetchResult:
        val quic_config = QuicConfig.default()
        val quic = QuicConnection.new(quic_config)
        val host = _host_of(url)
        quic.connect(host, 443)
        var client = H3Client.new(quic)
        var h3_headers: [H3Header] = []
        var i = 0
        while i < headers.len():
            h3_headers.push(H3Header.new(headers[i].name, headers[i].value))
            i = i + 1
        val resp = client.request("GET", url, h3_headers)
        var out_headers: [FetchHeader] = []
        var j = 0
        while j < resp.headers.len():
            out_headers.push(FetchHeader.new(resp.headers[j].name, resp.headers[j].value))
            j = j + 1
        FetchResult.new(url, resp.status, out_headers, resp.body, "h3")

    me _network_fetch(url: text, headers: [FetchHeader], protocol: i64) -> FetchResult:
        if protocol == PROTOCOL_H3:
            return self._fetch_h3(url, headers)
        if protocol == PROTOCOL_H2:
            return self._fetch_h2(url, headers)
        self._fetch_h1(url, headers)

    me _cache_store(result: FetchResult):
        val etag = _header_value(result.headers, "etag")
        self.bloom.insert(result.url, etag, 0)

    me _update_altsvc(result: FetchResult):
        val altsvc = _header_value(result.headers, "alt-svc")
        if altsvc.starts_with("h3"):
            val host = _host_of(result.url)
            if not _has_altsvc(self.alt_svc, host, PROTOCOL_H3):
                self.alt_svc.push(AltSvcEntry.new(host, 443, PROTOCOL_H3))

    me process_response(response: FetchResult) -> FetchResult:
        val ct = _header_value(response.headers, "content-type")
        var body = response.body

        if self.config.zip_auto_extract and (ct == CT_ZIP or ct == CT_ZIP_ALT):
            val reader = ZipReader.new(body)
            val entries = reader.extract_all()
            if entries.len() > 0:
                val decompressed = reader.decompress(entries[0])
                if not (decompressed == nil):
                    body = decompressed

        if self.config.webp_auto_convert and ct.starts_with(CT_IMAGE_PREFIX):
            if ct == CT_WEBP:
                val decoder = WebpDecoder.new()
                var as_i64: [i64] = []
                var bi = 0
                while bi < body.len():
                    as_i64.push(body[bi].to_i64())
                    bi = bi + 1
                decoder.parse_container(as_i64)
            else:
                val encoder = WebpEncoder.new(WebpConfig.default())
                val img = WebpImage.create(0, 0)
                encoder.encode(img)

        if self.config.bundle_tracking and (ct == CT_JS or ct == CT_CSS):
            self.bundle_graph.build_from_source(response.url, "")
            var entries_list: [text] = []
            entries_list.push(response.url)
            self.chunk_resolver.find_shared_modules(self.bundle_graph, entries_list)

        FetchResult.new(response.url, response.status, response.headers, body, response.protocol)

    me fetch(url: text, headers: [FetchHeader]) -> FetchResult:
        if self.bloom.is_fresh(url, 0, 300):
            return _make_stub_response(url, "cache")

        val protocol = self.select_protocol(url)
        val raw = self._network_fetch(url, headers, protocol)
        self._update_altsvc(raw)
        val processed = self.process_response(raw)
        self._cache_store(processed)
        processed

    me fetch_batch(urls: [text]) -> [FetchResult]:
        var results: [FetchResult] = []
        var empty_headers: [FetchHeader] = []

        var i = 0
        while i < urls.len():
            val url = urls[i]
            val host = _host_of(url)
            val protocol = self.select_protocol(url)

            if protocol == PROTOCOL_H3:
                results.push(self.fetch(url, empty_headers))
            elif protocol == PROTOCOL_H2:
                var h2_headers: [H2Header] = []
                var requests: [H2Request] = []
                requests.push(H2Request.new("GET", url, h2_headers))
                val responses = self.h2_fetcher.fetch_parallel(requests)
                if responses.len() > 0:
                    val r = responses[0]
                    var out_headers: [FetchHeader] = []
                    var j = 0
                    while j < r.headers.len():
                        out_headers.push(FetchHeader.new(r.headers[j].name, r.headers[j].value))
                        j = j + 1
                    val raw = FetchResult.new(url, r.status, out_headers, r.body, "h2")
                    self._update_altsvc(raw)
                    val processed = self.process_response(raw)
                    self._cache_store(processed)
                    results.push(processed)
                else:
                    results.push(_make_stub_response(url, "h2"))
            else:
                results.push(self.fetch(url, empty_headers))
            i = i + 1
        results

    fn shutdown() -> void:
        pass_do_nothing
