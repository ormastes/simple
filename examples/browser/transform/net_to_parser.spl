# Net-to-Parser bridge for the Simple Browser Platform.
# Converts a FetchResponse from the network layer into a ParserInput
# that the HTML/CSS/JS parsers can consume, handling content-type
# detection, character encoding sniffing, and resource classification.

use sbp.shared.logging.{Logger, LogLevel}
use sbp.entity.net.request_types.{FetchResponse}

# ---------------------------------------------------------------------------
# ParserInput — the parsed-and-decoded payload ready for a parser.
# ---------------------------------------------------------------------------
class ParserInput:
    url: text
    content: text
    content_type: text
    encoding: text
    is_complete: bool

    static fn create(url: text, content: text, content_type: text, encoding: text) -> ParserInput:
        ParserInput(
            url: url,
            content: content,
            content_type: content_type,
            encoding: encoding,
            is_complete: true,
        )

    static fn partial(url: text, content: text, content_type: text, encoding: text) -> ParserInput:
        ParserInput(
            url: url,
            content: content,
            content_type: content_type,
            encoding: encoding,
            is_complete: false,
        )

# ---------------------------------------------------------------------------
# NetToParserBridge
# ---------------------------------------------------------------------------
class NetToParserBridge:
    logger: Logger

    static fn new(logger: Logger) -> NetToParserBridge:
        NetToParserBridge(logger: logger)

    # Convert a complete FetchResponse into a ParserInput.
    fn feed_response(response: FetchResponse) -> ParserInput:
        val url_str = response.url.href
        val ct = detect_content_type(response.headers, url_str)
        val enc = detect_encoding(response.headers, response.body)
        val decoded = decode_content(response.body, enc)

        self.logger.debug("NetToParser: url={url_str} type={ct} enc={enc} len={decoded.len()}")
        ParserInput.create(url_str, decoded, ct, enc)

# ---------------------------------------------------------------------------
# Content-type detection
# ---------------------------------------------------------------------------

# Determine content type from headers first, then fall back to URL extension.
fn detect_content_type(headers: List<Pair<text, text>>, url: text) -> text:
    # 1. Check Content-Type header
    for pair in headers:
        if pair.first.to_lower() == "content-type":
            # Strip parameters (e.g. "text/html; charset=utf-8" -> "text/html")
            val value = pair.second
            val semi = value.index_of(";")
            if semi >= 0:
                return value.substring(0, semi).trim()
            return value.trim()

    # 2. Fall back to URL extension
    if url.ends_with(".html") or url.ends_with(".htm"):
        return "text/html"
    if url.ends_with(".css"):
        return "text/css"
    if url.ends_with(".js") or url.ends_with(".mjs"):
        return "application/javascript"
    if url.ends_with(".json"):
        return "application/json"
    if url.ends_with(".png"):
        return "image/png"
    if url.ends_with(".jpg") or url.ends_with(".jpeg"):
        return "image/jpeg"
    if url.ends_with(".gif"):
        return "image/gif"
    if url.ends_with(".svg"):
        return "image/svg+xml"
    if url.ends_with(".woff2"):
        return "font/woff2"
    if url.ends_with(".woff"):
        return "font/woff"

    # Default
    "application/octet-stream"

# ---------------------------------------------------------------------------
# Encoding detection
# ---------------------------------------------------------------------------

# Detect character encoding from Content-Type charset parameter or BOM.
fn detect_encoding(headers: List<Pair<text, text>>, content: text) -> text:
    # 1. Check Content-Type charset parameter
    for pair in headers:
        if pair.first.to_lower() == "content-type":
            val value = pair.second.to_lower()
            val charset_idx = value.index_of("charset=")
            if charset_idx >= 0:
                val start = charset_idx + 8
                val rest = value.substring(start, value.len())
                # Strip trailing parameters or whitespace
                val semi = rest.index_of(";")
                if semi >= 0:
                    return rest.substring(0, semi).trim()
                return rest.trim()

    # 2. Check for UTF-8 BOM (EF BB BF)
    if content.len() >= 3:
        if content.starts_with("\xEF\xBB\xBF"):
            return "utf-8"

    # 3. Check for UTF-16 BOM
    if content.len() >= 2:
        if content.starts_with("\xFF\xFE"):
            return "utf-16le"
        if content.starts_with("\xFE\xFF"):
            return "utf-16be"

    # Default to UTF-8 per the HTML spec
    "utf-8"

# ---------------------------------------------------------------------------
# Resource classification helpers
# ---------------------------------------------------------------------------

fn is_html_content(content_type: text) -> bool:
    content_type == "text/html" or content_type == "application/xhtml+xml"

fn is_css_content(content_type: text) -> bool:
    content_type == "text/css"

fn is_javascript_content(content_type: text) -> bool:
    (content_type == "application/javascript" or
     content_type == "text/javascript" or
     content_type == "application/x-javascript")

fn is_image_content(content_type: text) -> bool:
    content_type.starts_with("image/")

fn is_font_content(content_type: text) -> bool:
    content_type.starts_with("font/")

# ---------------------------------------------------------------------------
# Decode raw bytes using the detected encoding.
# Currently a pass-through — real implementation would handle charset
# conversion for non-UTF-8 encodings.
# ---------------------------------------------------------------------------
fn decode_content(raw: text, encoding: text) -> text:
    # TODO: actual charset decode for non-UTF-8 encodings
    pass_todo
    raw
