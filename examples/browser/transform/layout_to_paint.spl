# Layout-to-Paint bridge for the Simple Browser Platform.
# Walks the layout tree and generates a DisplayList of PaintOps that
# describe how to render the page to a surface.
#
# Paint order follows the CSS specification (backgrounds, borders, content,
# outlines) and respects stacking context z-index ordering.

use sbp.shared.logging.{Logger, LogLevel}
use sbp.entity.dom.box_types.{LayoutBox, BoxKind}
use sbp.entity.dom.paint_types.{PaintOp, DisplayList, DisplayItem, Color, from_rgba, transparent}
use sbp.entity.dom.css_types.{CSSValue}
use sbp.feature.style.computed.{ComputedStyle}

# ---------------------------------------------------------------------------
# LayoutToPaintBridge
# ---------------------------------------------------------------------------
class LayoutToPaintBridge:
    logger: Logger

    static fn new(logger: Logger) -> LayoutToPaintBridge:
        LayoutToPaintBridge(logger: logger)

    # Walk the entire layout tree starting at `layout_root` and produce
    # a flat DisplayList of PaintOps ready for the compositor.
    fn generate_display_list(layout_root: LayoutBox, styles: List<ComputedStyle>) -> DisplayList:
        self.logger.info("LayoutToPaint: generating display list")
        var items = List<DisplayItem>()
        self.collect_items(layout_root, styles, items, 0)

        # Sort by paint order (z-index)
        val sorted = paint_order_sort(items)

        # Flatten into ops list
        var ops = List<PaintOp>()
        for item in sorted:
            ops.push(item.op)

        self.logger.info("LayoutToPaint: {ops.len()} paint ops generated")
        DisplayList(ops: ops)

    # Recursively collect DisplayItems from a layout box and its children.
    fn collect_items(box_node: LayoutBox, styles: List<ComputedStyle>, items: List<DisplayItem>, depth: i64):
        val style = self.style_for_box(box_node, styles)

        if not should_paint_box(style):
            return

        # Collect paint ops for this box
        val ops = collect_paint_ops(box_node, style)
        for op in ops:
            val z = self.compute_z_index(style, depth)
            items.push(DisplayItem.create(z_index: z, op: op))

        # Handle overflow clipping
        val clip_op = create_clip_for_overflow(box_node, style.overflow_x)
        if val clip = clip_op:
            items.push(DisplayItem.create(z_index: depth, op: clip))

        # Recurse into children
        for child in box_node.children:
            self.collect_items(child, styles, items, depth + 1)

        # Pop clip if we pushed one
        if val _clip = clip_op:
            items.push(DisplayItem.create(z_index: depth, op: PaintOp.PopClip))

    # Look up computed style for a layout box by node_id.
    fn style_for_box(box_node: LayoutBox, styles: List<ComputedStyle>) -> ComputedStyle:
        if box_node.node_id >= 0 and box_node.node_id < styles.len():
            styles.get(box_node.node_id)
        else:
            ComputedStyle.default_style()

    # Compute effective z-index from style and nesting depth.
    fn compute_z_index(style: ComputedStyle, depth: i64) -> i64:
        match style.z_index:
            CSSValue.Number(v): v.to_i64() + depth
            _: depth

# ---------------------------------------------------------------------------
# Pure helpers
# ---------------------------------------------------------------------------

# Generate paint operations for a single layout box.
fn collect_paint_ops(box_node: LayoutBox, style: ComputedStyle) -> List<PaintOp>:
    var ops = List<PaintOp>()

    # 1. Background
    val bg = extract_color(style.background_color)
    if bg.a > 0:
        ops.push(PaintOp.FillRect(
            x: box_node.x, y: box_node.y,
            w: box_node.width, h: box_node.height,
            color: bg,
        ))

    # 2. Borders (simplified — uniform color/width)
    val border_w = extract_length(style.border_top_width)
    if border_w > 0.0:
        val border_color = extract_color(style.border_top_color)
        val widths = [border_w, border_w, border_w, border_w]
        val colors = [border_color, border_color, border_color, border_color]
        ops.push(PaintOp.DrawBorder(
            x: box_node.x, y: box_node.y,
            w: box_node.width, h: box_node.height,
            widths: widths, colors: colors,
        ))

    # 3. Opacity wrapper
    if style.opacity < 1.0:
        ops.push(PaintOp.PushOpacity(alpha: style.opacity))

    ops

# Sort display items by z_index (ascending) for correct paint order.
fn paint_order_sort(items: List<DisplayItem>) -> List<DisplayItem>:
    # Simple insertion sort — display lists are typically small per frame.
    var sorted = List<DisplayItem>()
    for item in items:
        sorted.push(item)
    var i = 1
    while i < sorted.len():
        var j = i
        while j > 0 and sorted.get(j - 1).z_index > sorted.get(j).z_index:
            val tmp = sorted.get(j - 1)
            sorted.set(j - 1, sorted.get(j))
            sorted.set(j, tmp)
            j = j - 1
        i = i + 1
    sorted

# A box should be painted if it is visible.
fn should_paint_box(style: ComputedStyle) -> bool:
    style.visibility != "hidden" and style.display != "none"

# Create a PushClip op if the box has non-visible overflow.
fn create_clip_for_overflow(box_node: LayoutBox, overflow: text) -> PaintOp?:
    if overflow == "hidden" or overflow == "scroll" or overflow == "auto":
        Some(PaintOp.PushClip(
            x: box_node.x, y: box_node.y,
            w: box_node.width, h: box_node.height,
        ))
    else:
        nil

# Extract a Color from a CSSValue, defaulting to transparent.
fn extract_color(value: CSSValue) -> Color:
    match value:
        CSSValue.Color(color): color
        _: transparent()

# Extract a length in px from a CSSValue, defaulting to 0.
fn extract_length(value: CSSValue) -> f64:
    match value:
        CSSValue.Length(v, unit): v
        CSSValue.Number(v): v
        _: 0.0
