# E2E broker loop tests

fn _setup_broker():
    BK_AGENT_IDS = []
    BK_AGENT_CAPS = []
    BK_AGENT_MAX_CONCURRENT = []
    BK_AGENT_PRIORITIES = []
    BK_AGENT_LOADS = []
    BK_AGENT_STATUSES = []
    BK_AGENT_COUNT = 0
    BK_TASK_IDS = []
    BK_TASK_CONTENTS = []
    BK_TASK_CAPS = []
    BK_TASK_URGENCIES = []
    BK_TASK_STATUSES = []
    BK_TASK_AGENTS = []
    BK_TASK_RESULTS = []
    BK_TASK_ERRORS = []
    BK_TASK_COUNT = 0
    BK_NEXT_TASK_ID = 1
    BK_COMPLETED = 0

describe "Broker E2E":
    it "submits and processes a task":
        _setup_broker()
        worker_register("coder", "code,test", 3, 10)

        # Submit task via CLI handler
        val result = _handle_submit("Review code", "code")
        expect(result).to_contain("task-1")

        # Process pending
        val process_result = broker_run_pending()
        expect(process_result).to_contain("coder")
        expect(BK_TASK_STATUSES[0]).to_equal("assigned")

    it "shows agent list":
        _setup_broker()
        worker_register("coder", "code", 3, 10)
        worker_register("reviewer", "review", 2, 8)
        val result = worker_list_text()
        expect(result).to_contain("coder")
        expect(result).to_contain("reviewer")

    it "shows status dashboard":
        _setup_broker()
        worker_register("coder", "code", 3, 10)
        val result = dashboard_status()
        expect(result).to_contain("Mate Broker Dashboard")
        expect(result).to_contain("Agents: 1")
