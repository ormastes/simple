# mate-broker — Multi-Agent Task Broker
#
# A broker receives tasks, solicits bids from specialist agents,
# scores bids, awards tasks, and monitors completion.
#
# MDSOC Architecture: entity/ feature/ transform/ shared/
# This file is self-contained for interpreter mode.

use std.ui.{column, row, panel, label, text_widget, table_widget,
             progress, statusbar, divider, build_tree_with_title, UITree,
             input, button, text_field}
use common.ui.widget.{UIState, UIEvent}
use common.ui.state.{init_state, update_state, update_tree}
use app.ui.tui.backend.{TuiBackend}
use app.ui.render.widgets.{render_html_tree}
use app.ui.web.html.{generate_css}
use app.ui.tauri.ipc.{parse_ipc_message, build_ipc_render}
use std.nogc_sync_mut.io.tcp.{TcpListener, TcpStream}

extern fn rt_cli_get_args() -> [text]
extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_dir_create_all(path: text) -> bool
extern fn rt_stdin_read_line() -> text?

# ============================================================================
# Broker state (parallel arrays + manual counters)
# ============================================================================

# Agent pool
var BK_AGENT_IDS: [text] = []
var BK_AGENT_CAPS: [text] = []           # comma-separated
var BK_AGENT_MAX_CONCURRENT: [i64] = []
var BK_AGENT_PRIORITIES: [i64] = []
var BK_AGENT_LOADS: [i64] = []
var BK_AGENT_STATUSES: [text] = []
var BK_AGENT_COUNT = 0

# Task queue
var BK_TASK_IDS: [text] = []
var BK_TASK_CONTENTS: [text] = []
var BK_TASK_CAPS: [text] = []            # comma-separated required caps
var BK_TASK_URGENCIES: [i64] = []
var BK_TASK_STATUSES: [text] = []
var BK_TASK_AGENTS: [text] = []
var BK_TASK_RESULTS: [text] = []
var BK_TASK_ERRORS: [text] = []
var BK_TASK_COUNT = 0
var BK_NEXT_TASK_ID = 1

# Stats
var BK_COMPLETED = 0
var BK_STRATEGY = "capability"

var MAIN_EXECUTED = false

# Interactive dashboard state
var INPUT_TASK_CONTENT = ""
var INPUT_TASK_CAPS = "code"
var INPUT_AGENT_ID = ""
var INPUT_AGENT_CAPS = ""
var STATUS_MSG = ""

# === entity/agent_profile.spl ===

struct AgentProfile:
    id: text
    capabilities: [text]
    max_concurrent: i64
    priority: i64
    current_load: i64
    status: text         # "idle", "busy", "offline"

fn agent_profile(id: text, capabilities: [text]) -> AgentProfile:
    AgentProfile(
        id: id,
        capabilities: capabilities,
        max_concurrent: 3,
        priority: 5,
        current_load: 0,
        status: "idle"
    )

fn agent_profile_full(id: text, capabilities: [text],
                      max_concurrent: i64, priority: i64) -> AgentProfile:
    AgentProfile(
        id: id,
        capabilities: capabilities,
        max_concurrent: max_concurrent,
        priority: priority,
        current_load: 0,
        status: "idle"
    )

impl AgentProfile:
    fn has_capability(cap: text) -> bool:
        for c in self.capabilities:
            if c == cap:
                return true
        false

    fn is_available() -> bool:
        self.status != "offline" and self.current_load < self.max_concurrent

    fn load_ratio() -> i64:
        if self.max_concurrent == 0:
            return 100
        (self.current_load * 100) / self.max_concurrent

    fn to_text() -> text:
        "Agent(" + self.id + ", load=" + self.current_load.to_text() + "/" + self.max_concurrent.to_text() + ", " + self.status + ")"

# === entity/task_request.spl ===

struct TaskRequest:
    id: text
    content: text
    required_caps: [text]
    urgency: i64         # 1-10, higher = more urgent
    status: text         # "pending", "bidding", "assigned", "running", "completed", "failed"
    assigned_agent: text
    result: text
    error: text

fn task_request(id: text, content: text, required_caps: [text]) -> TaskRequest:
    TaskRequest(
        id: id,
        content: content,
        required_caps: required_caps,
        urgency: 5,
        status: "pending",
        assigned_agent: "",
        result: "",
        error: ""
    )

fn task_request_urgent(id: text, content: text, required_caps: [text],
                       urgency: i64) -> TaskRequest:
    TaskRequest(
        id: id,
        content: content,
        required_caps: required_caps,
        urgency: urgency,
        status: "pending",
        assigned_agent: "",
        result: "",
        error: ""
    )

impl TaskRequest:
    fn is_pending() -> bool:
        self.status == "pending"

    fn is_completed() -> bool:
        self.status == "completed"

    fn to_text() -> text:
        "Task(" + self.id + ", urgency=" + self.urgency.to_text() + ", " + self.status + ")"

# === entity/bid.spl ===

struct Bid:
    agent_id: text
    task_id: text
    score: i64           # 0-100 composite score
    cap_overlap: i64     # capability match score (0-100)
    load_score: i64      # inverse load score (0-100)
    priority_score: i64  # agent priority score (0-100)
    accepted: bool

fn bid(agent_id: text, task_id: text, cap_overlap: i64,
       load_score: i64, priority_score: i64) -> Bid:
    # Weighted composite: cap_overlap*0.4 + load*0.3 + priority*0.3
    val score = (cap_overlap * 40 + load_score * 30 + priority_score * 30) / 100
    Bid(
        agent_id: agent_id,
        task_id: task_id,
        score: score,
        cap_overlap: cap_overlap,
        load_score: load_score,
        priority_score: priority_score,
        accepted: false
    )

impl Bid:
    fn to_text() -> text:
        "Bid(" + self.agent_id + " -> " + self.task_id + ", score=" + self.score.to_text() + ")"

# === feature/broker/matching.spl ===

fn broker_solicit_bids(task_id: text, required_caps: [text]) -> [Bid]:
    var bids: [Bid] = []
    var i = 0
    while i < BK_AGENT_COUNT:
        val agent_id = BK_AGENT_IDS[i]
        val agent_status = BK_AGENT_STATUSES[i]
        val agent_load = BK_AGENT_LOADS[i]
        val agent_max = BK_AGENT_MAX_CONCURRENT[i]
        val agent_priority = BK_AGENT_PRIORITIES[i]
        val agent_caps_str = BK_AGENT_CAPS[i]

        # Skip offline or at-capacity agents
        if agent_status == "offline":
            i = i + 1
            continue
        if agent_load >= agent_max:
            i = i + 1
            continue

        # Calculate capability overlap
        val agent_caps = agent_caps_str.split(",")
        var overlap_count = 0
        var total_required = 0
        for req in required_caps:
            val trimmed_req = req.trim()
            if trimmed_req != "":
                total_required = total_required + 1
                for ac in agent_caps:
                    if ac.trim() == trimmed_req:
                        overlap_count = overlap_count + 1
                        break

        if overlap_count == 0:
            i = i + 1
            continue

        # Scores (0-100 scale)
        var cap_score = 0
        if total_required > 0:
            cap_score = (overlap_count * 100) / total_required

        var load_score = 100
        if agent_max > 0:
            load_score = ((agent_max - agent_load) * 100) / agent_max

        val priority_score = agent_priority * 10
        val b = bid(agent_id, task_id, cap_score, load_score, priority_score)
        bids.push(b)
        i = i + 1
    bids

fn broker_select_best_bid(bids: [Bid]) -> Bid:
    var best_idx = 0
    var best_score = -1
    var i = 0
    while i < bids.len():
        if bids[i].score > best_score:
            best_score = bids[i].score
            best_idx = i
        i = i + 1
    bids[best_idx]

# === feature/broker/loop.spl ===

fn broker_process_task(task_idx: i64) -> text:
    # 1. Get task info
    val task_id = BK_TASK_IDS[task_idx]
    val content = BK_TASK_CONTENTS[task_idx]
    val caps_str = BK_TASK_CAPS[task_idx]

    # 2. Solicit bids
    BK_TASK_STATUSES[task_idx] = "bidding"
    val required_caps = _split_caps(caps_str)
    val bids = broker_solicit_bids(task_id, required_caps)

    if bids.len() == 0:
        BK_TASK_STATUSES[task_idx] = "failed"
        BK_TASK_ERRORS[task_idx] = "No capable agents available"
        return "Task " + task_id + ": no agents available"

    # 3. Award to best bid
    val best = broker_select_best_bid(bids)
    BK_TASK_STATUSES[task_idx] = "assigned"
    BK_TASK_AGENTS[task_idx] = best.agent_id
    BK_COMPLETED = BK_COMPLETED + 1

    "Task " + task_id + " awarded to " + best.agent_id + " (score=" + best.score.to_text() + ")"

fn broker_run_pending() -> text:
    var results: [text] = []
    var i = 0
    while i < BK_TASK_COUNT:
        if BK_TASK_STATUSES[i] == "pending":
            val r = broker_process_task(i)
            results.push(r)
        i = i + 1
    if results.len() == 0:
        return "No pending tasks."
    results.join("\n")

fn _split_caps(caps_str: text) -> [text]:
    if caps_str == "":
        return []
    caps_str.split(",")

# === feature/broker/coordination.spl ===

fn broker_coordinate_sequential(task_ids: [text]) -> text:
    # Process tasks one at a time in order
    var results: [text] = []
    for task_id in task_ids:
        val idx = _find_task_index(task_id)
        if idx >= 0:
            val r = broker_process_task(idx)
            results.push(r)
    results.join("\n")

fn broker_coordinate_parallel(task_ids: [text]) -> text:
    # Award all tasks simultaneously (best-effort)
    var results: [text] = []
    for task_id in task_ids:
        val idx = _find_task_index(task_id)
        if idx >= 0:
            val r = broker_process_task(idx)
            results.push(r)
    results.join("\n")

fn broker_coordinate_pipeline(task_ids: [text]) -> text:
    # Pipeline: output of task N feeds into task N+1
    var results: [text] = []
    var prev_result = ""
    for task_id in task_ids:
        val idx = _find_task_index(task_id)
        if idx >= 0:
            if prev_result != "":
                BK_TASK_CONTENTS[idx] = BK_TASK_CONTENTS[idx] + "\n\nContext from previous step:\n" + prev_result
            val r = broker_process_task(idx)
            prev_result = r
            results.push(r)
    results.join("\n")

fn _find_task_index(task_id: text) -> i64:
    var i = 0
    while i < BK_TASK_COUNT:
        if BK_TASK_IDS[i] == task_id:
            return i
        i = i + 1
    -1

# === feature/worker/worker.spl ===

fn worker_register(id: text, capabilities: text, max_concurrent: i64, priority: i64):
    BK_AGENT_IDS = BK_AGENT_IDS + [id]
    BK_AGENT_CAPS = BK_AGENT_CAPS + [capabilities]
    BK_AGENT_MAX_CONCURRENT = BK_AGENT_MAX_CONCURRENT + [max_concurrent]
    BK_AGENT_PRIORITIES = BK_AGENT_PRIORITIES + [priority]
    BK_AGENT_LOADS = BK_AGENT_LOADS + [0]
    BK_AGENT_STATUSES = BK_AGENT_STATUSES + ["idle"]
    BK_AGENT_COUNT = BK_AGENT_COUNT + 1

fn worker_set_status(agent_id: text, status: text):
    var i = 0
    while i < BK_AGENT_COUNT:
        if BK_AGENT_IDS[i] == agent_id:
            BK_AGENT_STATUSES[i] = status
            return
        i = i + 1

fn worker_increment_load(agent_id: text):
    var i = 0
    while i < BK_AGENT_COUNT:
        if BK_AGENT_IDS[i] == agent_id:
            BK_AGENT_LOADS[i] = BK_AGENT_LOADS[i] + 1
            if BK_AGENT_LOADS[i] >= BK_AGENT_MAX_CONCURRENT[i]:
                BK_AGENT_STATUSES[i] = "busy"
            return
        i = i + 1

fn worker_decrement_load(agent_id: text):
    var i = 0
    while i < BK_AGENT_COUNT:
        if BK_AGENT_IDS[i] == agent_id:
            if BK_AGENT_LOADS[i] > 0:
                BK_AGENT_LOADS[i] = BK_AGENT_LOADS[i] - 1
            if BK_AGENT_LOADS[i] < BK_AGENT_MAX_CONCURRENT[i]:
                BK_AGENT_STATUSES[i] = "idle"
            return
        i = i + 1

fn worker_list_text() -> text:
    if BK_AGENT_COUNT == 0:
        return "  (no agents registered)"
    var parts: [text] = []
    var i = 0
    while i < BK_AGENT_COUNT:
        var tmp_ld = BK_AGENT_LOADS[i]
        var tmp_mx = BK_AGENT_MAX_CONCURRENT[i]
        val line = "  " + BK_AGENT_IDS[i] + " [" + BK_AGENT_STATUSES[i] + "] load=" + tmp_ld.to_text() + "/" + tmp_mx.to_text() + " caps=[" + BK_AGENT_CAPS[i] + "]"
        parts.push(line)
        i = i + 1
    parts.join("\n")

# === feature/monitor/dashboard.spl ===

fn dashboard_status() -> text:
    var parts: [text] = []
    parts.push("=== Mate Broker Dashboard ===")
    parts.push("")
    var tmp_ac = BK_AGENT_COUNT
    var tmp_tc = BK_TASK_COUNT
    var tmp_cc = BK_COMPLETED
    parts.push("Agents: " + tmp_ac.to_text())
    parts.push("Tasks: " + tmp_tc.to_text())
    parts.push("Completed: " + tmp_cc.to_text())
    parts.push("")

    # Agent summary
    parts.push("Agent Pool:")
    var i = 0
    while i < BK_AGENT_COUNT:
        var tmp_ld2 = BK_AGENT_LOADS[i]
        var tmp_mx2 = BK_AGENT_MAX_CONCURRENT[i]
        val line = "  " + BK_AGENT_IDS[i] + " [" + BK_AGENT_STATUSES[i] + "] " + tmp_ld2.to_text() + "/" + tmp_mx2.to_text()
        parts.push(line)
        i = i + 1

    parts.push("")
    parts.push("Task Queue:")
    if BK_TASK_COUNT == 0:
        parts.push("  (empty)")
    else:
        var j = 0
        while j < BK_TASK_COUNT:
            var task_line = "  " + BK_TASK_IDS[j] + " [" + BK_TASK_STATUSES[j] + "]"
            val agent = BK_TASK_AGENTS[j]
            if agent != "":
                task_line = task_line + " -> " + agent
            task_line = task_line + " " + BK_TASK_CONTENTS[j]
            parts.push(task_line)
            j = j + 1

    parts.join("\n")

fn dashboard_ui() -> UITree:
    var agent_count_text = BK_AGENT_COUNT.to_text()
    var task_count_text = BK_TASK_COUNT.to_text()
    var completed_text = BK_COMPLETED.to_text()

    val stats = row("stats", [
        label("stat_agents", "Agents: " + agent_count_text),
        label("stat_tasks", "Tasks: " + task_count_text),
        label("stat_done", "Completed: " + completed_text)
    ])

    var agent_rows: [[text]] = []
    var ai = 0
    while ai < BK_AGENT_COUNT:
        var ld = BK_AGENT_LOADS[ai]
        var mx = BK_AGENT_MAX_CONCURRENT[ai]
        agent_rows = agent_rows + [[
            BK_AGENT_IDS[ai],
            BK_AGENT_STATUSES[ai],
            ld.to_text() + "/" + mx.to_text(),
            BK_AGENT_CAPS[ai]
        ]]
        ai = ai + 1

    val agents_table = table_widget("agents_table",
        ["ID", "Status", "Load", "Capabilities"],
        agent_rows
    )

    var task_rows: [[text]] = []
    var tj = 0
    while tj < BK_TASK_COUNT:
        val agent = BK_TASK_AGENTS[tj]
        var agent_col = if agent != "": agent else: "-"
        task_rows = task_rows + [[
            BK_TASK_IDS[tj],
            BK_TASK_STATUSES[tj],
            agent_col,
            BK_TASK_CONTENTS[tj]
        ]]
        tj = tj + 1

    val tasks_table = table_widget("tasks_table",
        ["ID", "Status", "Agent", "Content"],
        task_rows
    )

    val root = column("dashboard", [
        stats,
        divider("div1"),
        panel("agents_panel", "Agent Pool", [agents_table]),
        divider("div2"),
        panel("tasks_panel", "Task Queue", [tasks_table]),
        statusbar("status_bar", "mate-broker", "strategy: " + BK_STRATEGY)
    ])

    build_tree_with_title(root, "Mate Broker Dashboard", "dark")

# === Interactive Dashboard UI ===

fn dashboard_interactive_ui() -> UITree:
    var agent_count_text = BK_AGENT_COUNT.to_text()
    var task_count_text = BK_TASK_COUNT.to_text()
    var completed_text = BK_COMPLETED.to_text()

    val stats = row("stats", [
        label("stat_agents", "Agents: " + agent_count_text),
        label("stat_tasks", "Tasks: " + task_count_text),
        label("stat_done", "Completed: " + completed_text)
    ])

    var agent_rows: [[text]] = []
    var ai = 0
    while ai < BK_AGENT_COUNT:
        var ld = BK_AGENT_LOADS[ai]
        var mx = BK_AGENT_MAX_CONCURRENT[ai]
        agent_rows = agent_rows + [[
            BK_AGENT_IDS[ai],
            BK_AGENT_STATUSES[ai],
            ld.to_text() + "/" + mx.to_text(),
            BK_AGENT_CAPS[ai]
        ]]
        ai = ai + 1

    val agents_table = table_widget("agents_table",
        ["ID", "Status", "Load", "Capabilities"],
        agent_rows
    )

    var task_rows: [[text]] = []
    var tj = 0
    while tj < BK_TASK_COUNT:
        val agent = BK_TASK_AGENTS[tj]
        var agent_col = if agent != "": agent else: "-"
        task_rows = task_rows + [[
            BK_TASK_IDS[tj],
            BK_TASK_STATUSES[tj],
            agent_col,
            BK_TASK_CONTENTS[tj]
        ]]
        tj = tj + 1

    val tasks_table = table_widget("tasks_table",
        ["ID", "Status", "Agent", "Content"],
        task_rows
    )

    val task_form = panel("task_form", "Submit Task", [
        row("task_inputs", [
            text_field("task_content_input", INPUT_TASK_CONTENT, "Task description"),
            text_field("task_caps_input", INPUT_TASK_CAPS, "Capabilities"),
            button("submit_task_btn", "Submit", "submit_task")
        ])
    ])

    val agent_form = panel("agent_form", "Register Agent", [
        row("agent_inputs", [
            text_field("agent_id_input", INPUT_AGENT_ID, "Agent ID"),
            text_field("agent_caps_input", INPUT_AGENT_CAPS, "Capabilities"),
            button("register_btn", "Register", "register_agent")
        ])
    ])

    val actions = row("action_buttons", [
        button("process_btn", "Process Pending", "process_pending"),
        button("refresh_btn", "Refresh", "refresh")
    ])

    val status_text = if STATUS_MSG != "": STATUS_MSG else: "Ready"

    val root = column("dashboard", [
        stats,
        divider("div1"),
        task_form,
        agent_form,
        actions,
        divider("div2"),
        panel("agents_panel", "Agent Pool", [agents_table]),
        divider("div3"),
        panel("tasks_panel", "Task Queue", [tasks_table]),
        statusbar("status_bar", "mate-broker", status_text)
    ])

    build_tree_with_title(root, "Mate Broker Dashboard", "dark")

fn _read_input_value(state: UIState, widget_id: text) -> text:
    val widget = state.tree.find_widget(widget_id)
    if widget != nil:
        return widget.get_prop("value")
    ""

fn _handle_ui_action(state: UIState, name: text):
    if name == "submit_task":
        val content = _read_input_value(state, "task_content_input")
        val caps = _read_input_value(state, "task_caps_input")
        if content != "":
            STATUS_MSG = broker_submit_task(content, caps)
            INPUT_TASK_CONTENT = ""
            INPUT_TASK_CAPS = "code"
        else:
            STATUS_MSG = "Error: Task content cannot be empty"
    elif name == "process_pending":
        STATUS_MSG = broker_run_pending()
    elif name == "register_agent":
        val agent_id = _read_input_value(state, "agent_id_input")
        val agent_caps = _read_input_value(state, "agent_caps_input")
        if agent_id != "":
            STATUS_MSG = broker_register_agent(agent_id, agent_caps)
            INPUT_AGENT_ID = ""
            INPUT_AGENT_CAPS = ""
        else:
            STATUS_MSG = "Error: Agent ID cannot be empty"
    elif name == "refresh":
        STATUS_MSG = "Dashboard refreshed"

# === TUI Backend ===

fn _run_tui_dashboard():
    broker_init()
    var state = init_state(dashboard_interactive_ui())
    var backend = TuiBackend.new()
    backend.init()
    backend.render(state)

    var running = true
    while running:
        val event = backend.poll_event(100)
        if event != nil:
            match event:
                UIEvent.Quit:
                    running = false
                UIEvent.Action(name):
                    _handle_ui_action(state, name)
                    val new_tree = dashboard_interactive_ui()
                    state = update_tree(state, new_tree)
                    backend.render(state)
                _:
                    state = update_state(state, event)
                    backend.render(state)

    backend.shutdown()

# === Web Backend ===

fn _run_web_dashboard(port: i64):
    broker_init()
    var port_str = port.to_text()
    print("Mate Broker Web Dashboard")
    print("  URL: http://localhost:" + port_str)
    print("Press Ctrl+C to stop")
    print("")

    match TcpListener.bind("0.0.0.0:" + port_str):
        Err(e):
            print("Error: Failed to bind to port " + port_str + ": " + e)
            return
        Ok(listener):
            loop:
                match listener.accept():
                    Ok(stream):
                        _handle_web_connection(stream)
                    Err(e):
                        print("Accept error: " + e)

fn _handle_web_connection(stream: TcpStream):
    match stream.read_line():
        Err(e):
            return
        Ok(request_line):
            val parts = request_line.split(" ")
            if parts.len() < 2:
                return
            val method = parts[0]
            val path = parts[1]

            var content_length = 0
            loop:
                match stream.read_line():
                    Ok(header_line):
                        if header_line.trim() == "":
                            break
                        if header_line.starts_with("Content-Length:"):
                            val len_str = header_line[15:]
                            content_length = len_str.trim().to_int()
                    Err(_):
                        break

            var body = ""
            if method == "POST" and content_length > 0:
                match stream.read_bytes(content_length):
                    Ok(data):
                        body = data
                    Err(_):
                        pass_dn

            if method == "GET" and path == "/":
                val html = _generate_web_page()
                val response = _web_response(200, "text/html", html)
                stream.write_all(response)
            elif method == "POST" and path == "/submit":
                val content = _form_field(body, "content")
                val caps = _form_field(body, "caps")
                if content != "":
                    STATUS_MSG = broker_submit_task(content, caps)
                val html = _generate_web_page()
                val response = _web_response(200, "text/html", html)
                stream.write_all(response)
            elif method == "POST" and path == "/process":
                STATUS_MSG = broker_run_pending()
                val html = _generate_web_page()
                val response = _web_response(200, "text/html", html)
                stream.write_all(response)
            elif method == "POST" and path == "/register":
                val id = _form_field(body, "agent_id")
                val caps = _form_field(body, "agent_caps")
                if id != "":
                    STATUS_MSG = broker_register_agent(id, caps)
                val html = _generate_web_page()
                val response = _web_response(200, "text/html", html)
                stream.write_all(response)
            else:
                val response = _web_response(404, "text/plain", "Not Found")
                stream.write_all(response)

fn _generate_web_page() -> text:
    val tree = dashboard_interactive_ui()
    val state = init_state(tree)
    val body_html = render_html_tree(state.tree.root_node(), state)
    val css = generate_css("dark")

    var html = "<!DOCTYPE html><html><head>"
    html = html + "<meta charset=\"utf-8\"><title>Mate Broker</title>"
    html = html + "<style>" + css + "</style>"
    html = html + "<style>body{font-family:monospace;background:#1a1a2e;color:#e0e0e0;margin:20px;}"
    html = html + "form{display:inline-block;margin:5px;}"
    html = html + "input{background:#16213e;color:#e0e0e0;border:1px solid #0f3460;padding:8px;margin:4px;}"
    html = html + "button{background:#0f3460;color:#e0e0e0;border:none;padding:8px 16px;cursor:pointer;margin:4px;}"
    html = html + "button:hover{background:#1a4080;}"
    html = html + ".status{background:#0f3460;padding:10px;margin-top:15px;border-radius:4px;}</style>"
    html = html + "</head><body>"
    html = html + "<h1>Mate Broker Dashboard</h1>"
    html = html + body_html
    html = html + "<hr>"
    html = html + "<h3>Submit Task</h3>"
    html = html + "<form method=\"POST\" action=\"/submit\">"
    html = html + "<input name=\"content\" placeholder=\"Task description\" required> "
    html = html + "<input name=\"caps\" value=\"code\" placeholder=\"Capabilities\"> "
    html = html + "<button type=\"submit\">Submit Task</button></form>"
    html = html + "<h3>Register Agent</h3>"
    html = html + "<form method=\"POST\" action=\"/register\">"
    html = html + "<input name=\"agent_id\" placeholder=\"Agent ID\" required> "
    html = html + "<input name=\"agent_caps\" placeholder=\"Capabilities\"> "
    html = html + "<button type=\"submit\">Register</button></form>"
    html = html + "<br><form method=\"POST\" action=\"/process\">"
    html = html + "<button type=\"submit\">Process Pending Tasks</button></form>"
    if STATUS_MSG != "":
        html = html + "<div class=\"status\">" + STATUS_MSG + "</div>"
    html = html + "</body></html>"
    html

fn _web_response(status: i64, content_type: text, body: text) -> text:
    val status_text = if status == 200: "OK" else: "Not Found"
    var st = status
    var bl = body.len()
    var response = "HTTP/1.1 " + st.to_text() + " " + status_text + "\r\n"
    response = response + "Content-Type: " + content_type + "\r\n"
    response = response + "Content-Length: " + bl.to_text() + "\r\n"
    response = response + "Connection: close\r\n\r\n"
    response = response + body
    response

fn _form_field(body: text, field: text) -> text:
    val parts = body.split("&")
    for part in parts:
        val kv = part.split("=")
        if kv.len() >= 2 and kv[0] == field:
            return kv[1].replace("+", " ").replace("%20", " ").replace("%2C", ",")
    ""

# === Tauri Backend (Desktop + Mobile) ===

fn _run_tauri_dashboard(port: i64):
    broker_init()
    var state = init_state(dashboard_interactive_ui())

    _send_tauri_html(state)

    var running = true
    while running:
        val line = rt_stdin_read_line()
        if line == nil:
            continue
        if line == "":
            continue
        val event = parse_ipc_message(line)
        if event != nil:
            match event:
                UIEvent.Quit:
                    running = false
                UIEvent.Action(name):
                    _handle_ui_action(state, name)
                    val new_tree = dashboard_interactive_ui()
                    state = update_tree(state, new_tree)
                    _send_tauri_html(state)
                _:
                    state = update_state(state, event)
                    _send_tauri_html(state)

fn _send_tauri_html(state: UIState):
    val theme = state.tree.theme_name()
    val css = generate_css(theme)
    val body_html = render_html_tree(state.tree.root_node(), state)
    val html = "<html><head><style>" + css + "</style></head><body><div id=\"app\">" + body_html + "</div></body></html>"
    val ipc_msg = build_ipc_render(html)
    print(ipc_msg)

# === transform/dispatch/pool_view.spl ===

fn pool_available_agents() -> [text]:
    var available: [text] = []
    var i = 0
    while i < BK_AGENT_COUNT:
        if BK_AGENT_STATUSES[i] != "offline" and BK_AGENT_LOADS[i] < BK_AGENT_MAX_CONCURRENT[i]:
            available.push(BK_AGENT_IDS[i])
        i = i + 1
    available

fn pool_agents_with_capability(cap: text) -> [text]:
    var matches: [text] = []
    var i = 0
    while i < BK_AGENT_COUNT:
        val caps = BK_AGENT_CAPS[i].split(",")
        for c in caps:
            if c.trim() == cap:
                matches.push(BK_AGENT_IDS[i])
                break
        i = i + 1
    matches

fn pool_total_capacity() -> i64:
    var total = 0
    var i = 0
    while i < BK_AGENT_COUNT:
        total = total + BK_AGENT_MAX_CONCURRENT[i] - BK_AGENT_LOADS[i]
        i = i + 1
    total

# === transform/dispatch/queue_view.spl ===

fn queue_pending_tasks() -> [text]:
    var pending: [text] = []
    var i = 0
    while i < BK_TASK_COUNT:
        if BK_TASK_STATUSES[i] == "pending":
            pending.push(BK_TASK_IDS[i])
        i = i + 1
    pending

fn queue_assigned_tasks() -> [text]:
    var assigned: [text] = []
    var i = 0
    while i < BK_TASK_COUNT:
        if BK_TASK_STATUSES[i] == "assigned" or BK_TASK_STATUSES[i] == "running":
            assigned.push(BK_TASK_IDS[i])
        i = i + 1
    assigned

fn queue_completed_count() -> i64:
    var count = 0
    var i = 0
    while i < BK_TASK_COUNT:
        if BK_TASK_STATUSES[i] == "completed":
            count = count + 1
        i = i + 1
    count

fn queue_failed_count() -> i64:
    var count = 0
    var i = 0
    while i < BK_TASK_COUNT:
        if BK_TASK_STATUSES[i] == "failed":
            count = count + 1
        i = i + 1
    count

# === shared/state.spl ===

val STATE_DIR = ".build/mate_broker"

fn state_init():
    rt_dir_create_all(STATE_DIR)

fn state_save_agents() -> bool:
    var lines: [text] = []
    var tmp_ac2 = BK_AGENT_COUNT
    lines.push("agent_count: " + tmp_ac2.to_text())
    var i = 0
    while i < BK_AGENT_COUNT:
        lines.push("")
        lines.push("agent_" + i.to_text() + ":")
        lines.push("  id: " + BK_AGENT_IDS[i])
        lines.push("  caps: " + BK_AGENT_CAPS[i])
        var tmp_mx3 = BK_AGENT_MAX_CONCURRENT[i]
        var tmp_pr = BK_AGENT_PRIORITIES[i]
        var tmp_ld3 = BK_AGENT_LOADS[i]
        lines.push("  max: " + tmp_mx3.to_text())
        lines.push("  priority: " + tmp_pr.to_text())
        lines.push("  load: " + tmp_ld3.to_text())
        lines.push("  status: " + BK_AGENT_STATUSES[i])
        i = i + 1
    rt_file_write_text(STATE_DIR + "/agents.sdn", lines.join("\n") + "\n")

fn state_save_tasks() -> bool:
    var lines: [text] = []
    var tmp_tc2 = BK_TASK_COUNT
    var tmp_nid = BK_NEXT_TASK_ID
    lines.push("task_count: " + tmp_tc2.to_text())
    lines.push("next_id: " + tmp_nid.to_text())
    var i = 0
    while i < BK_TASK_COUNT:
        lines.push("")
        lines.push("task_" + i.to_text() + ":")
        lines.push("  id: " + BK_TASK_IDS[i])
        lines.push("  content: " + BK_TASK_CONTENTS[i])
        lines.push("  caps: " + BK_TASK_CAPS[i])
        var tmp_urg = BK_TASK_URGENCIES[i]
        lines.push("  urgency: " + tmp_urg.to_text())
        lines.push("  status: " + BK_TASK_STATUSES[i])
        lines.push("  agent: " + BK_TASK_AGENTS[i])
        i = i + 1
    rt_file_write_text(STATE_DIR + "/tasks.sdn", lines.join("\n") + "\n")

# === shared/protocol.spl ===

val MSG_REGISTER = "register"
val MSG_BID_REQUEST = "bid_request"
val MSG_BID_RESPONSE = "bid_response"
val MSG_AWARD = "award"
val MSG_COMPLETE = "complete"
val MSG_STATUS = "status"

fn protocol_format_register(agent_id: text, capabilities: text) -> text:
    "type: " + MSG_REGISTER + "\nagent_id: " + agent_id + "\ncapabilities: " + capabilities

fn protocol_format_bid_request(task_id: text, required_caps: text) -> text:
    "type: " + MSG_BID_REQUEST + "\ntask_id: " + task_id + "\nrequired_caps: " + required_caps

fn protocol_format_award(task_id: text, agent_id: text) -> text:
    "type: " + MSG_AWARD + "\ntask_id: " + task_id + "\nagent_id: " + agent_id

fn protocol_format_complete(task_id: text, agent_id: text, result: text) -> text:
    "type: " + MSG_COMPLETE + "\ntask_id: " + task_id + "\nagent_id: " + agent_id + "\nresult: " + result

fn protocol_parse_type(message: text) -> text:
    val lines = message.split("\n")
    for line in lines:
        val trimmed = line.trim()
        if trimmed.starts_with("type:"):
            val tlen = trimmed.len()
            return trimmed[5:tlen].trim()
    ""

# ============================================================================
# CLI command handlers
# ============================================================================

fn _handle_submit(content: text, caps: text) -> text:
    var tmp_nid2 = BK_NEXT_TASK_ID
    val id = "task-" + tmp_nid2.to_text()
    BK_NEXT_TASK_ID = BK_NEXT_TASK_ID + 1
    BK_TASK_IDS = BK_TASK_IDS + [id]
    BK_TASK_CONTENTS = BK_TASK_CONTENTS + [content]
    BK_TASK_CAPS = BK_TASK_CAPS + [caps]
    BK_TASK_URGENCIES = BK_TASK_URGENCIES + [5]
    BK_TASK_STATUSES = BK_TASK_STATUSES + ["pending"]
    BK_TASK_AGENTS = BK_TASK_AGENTS + [""]
    BK_TASK_RESULTS = BK_TASK_RESULTS + [""]
    BK_TASK_ERRORS = BK_TASK_ERRORS + [""]
    BK_TASK_COUNT = BK_TASK_COUNT + 1
    "Submitted: " + id + " (" + content + ") caps=[" + caps + "]"

fn _load_default_agents():
    worker_register("coder", "code,refactor,test", 3, 10)
    worker_register("reviewer", "review,security,docs", 2, 8)
    worker_register("researcher", "research,analysis,docs", 2, 5)
    worker_register("tester", "test,integration,benchmark", 4, 7)

fn broker_init():
    _load_default_agents()

fn broker_submit_task(content: text, caps: text) -> text:
    val result = _handle_submit(content, caps)
    val process = broker_run_pending()
    result + "\n" + process

fn broker_register_agent(id: text, caps: text) -> text:
    worker_register(id, caps, 3, 5)
    "Registered agent: " + id

fn _show_broker_help() -> text:
    var parts: [text] = []
    parts.push("mate-broker — Multi-Agent Task Broker")
    parts.push("")
    parts.push("Usage: mate-broker <command> [args]")
    parts.push("")
    parts.push("Commands:")
    parts.push("  start                    Start broker (load default agents)")
    parts.push("  submit <task> [--caps c] Submit task request")
    parts.push("  status                   Show broker status")
    parts.push("  agents                   List agent pool")
    parts.push("  register <id> <caps>     Register new agent")
    parts.push("  process                  Process pending tasks")
    parts.push("  tui                      Interactive TUI dashboard")
    parts.push("  web [port]               Web dashboard (default: 8080)")
    parts.push("  tauri [port]             Tauri desktop/mobile UI (default: 3000)")
    parts.push("  help                     Show this help")
    parts.join("\n")

# ============================================================================
# Main
# ============================================================================

fn main():
    if MAIN_EXECUTED:
        return
    MAIN_EXECUTED = true

    # Strip runtime args
    val raw_args = rt_cli_get_args()
    var args: [text] = []
    var found_script = false
    for a in raw_args:
        if found_script:
            args.push(a)
        elif a.ends_with(".spl"):
            found_script = true

    if args.len() == 0:
        print(_show_broker_help())
        return

    val cmd = args[0]

    if cmd == "help":
        print(_show_broker_help())
    elif cmd == "start":
        _load_default_agents()
        var tmp_ac3 = BK_AGENT_COUNT
        print("Broker started with " + tmp_ac3.to_text() + " agents")
        print(worker_list_text())
    elif cmd == "agents":
        _load_default_agents()
        print("Agent Pool:")
        print(worker_list_text())
    elif cmd == "submit":
        _load_default_agents()
        if args.len() < 2:
            print("Usage: mate-broker submit <task> [--caps capabilities]")
            return
        var content_parts: [text] = []
        var caps = "code"
        var i = 1
        while i < args.len():
            if args[i] == "--caps" and i + 1 < args.len():
                i = i + 1
                caps = args[i]
            else:
                content_parts.push(args[i])
            i = i + 1
        val content = content_parts.join(" ")
        print(_handle_submit(content, caps))
        val process_result = broker_run_pending()
        print(process_result)
    elif cmd == "status":
        _load_default_agents()
        print(dashboard_status())
        val ui = dashboard_ui()
        print("\n[UI Tree: " + ui.title() + ", theme=" + ui.theme() + "]")
    elif cmd == "register":
        if args.len() < 3:
            print("Usage: mate-broker register <id> <capabilities>")
            return
        worker_register(args[1], args[2], 3, 5)
        print("Registered agent: " + args[1])
    elif cmd == "process":
        _load_default_agents()
        val result = broker_run_pending()
        print(result)
    elif cmd == "tui":
        _run_tui_dashboard()
    elif cmd == "web":
        var web_port = 8080
        if args.len() > 1:
            web_port = args[1].to_int()
        _run_web_dashboard(web_port)
    elif cmd == "tauri":
        var tauri_port = 3000
        if args.len() > 1:
            tauri_port = args[1].to_int()
        _run_tauri_dashboard(tauri_port)
    else:
        print("Unknown command: " + cmd)
        print(_show_broker_help())

main()
