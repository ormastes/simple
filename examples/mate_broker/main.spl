# mate-broker — Multi-Agent Task Broker
#
# A broker receives tasks, solicits bids from specialist agents,
# scores bids, awards tasks, and monitors completion.
#
# MDSOC Architecture: entity/ feature/ transform/ shared/
# This file is self-contained for interpreter mode.

extern fn rt_cli_get_args() -> [text]
extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_dir_create_all(path: text) -> bool

# ============================================================================
# Broker state (parallel arrays + manual counters)
# ============================================================================

# Agent pool
var BK_AGENT_IDS: [text] = []
var BK_AGENT_CAPS: [text] = []           # comma-separated
var BK_AGENT_MAX_CONCURRENT: [i64] = []
var BK_AGENT_PRIORITIES: [i64] = []
var BK_AGENT_LOADS: [i64] = []
var BK_AGENT_STATUSES: [text] = []
var BK_AGENT_COUNT = 0

# Task queue
var BK_TASK_IDS: [text] = []
var BK_TASK_CONTENTS: [text] = []
var BK_TASK_CAPS: [text] = []            # comma-separated required caps
var BK_TASK_URGENCIES: [i64] = []
var BK_TASK_STATUSES: [text] = []
var BK_TASK_AGENTS: [text] = []
var BK_TASK_RESULTS: [text] = []
var BK_TASK_ERRORS: [text] = []
var BK_TASK_COUNT = 0
var BK_NEXT_TASK_ID = 1

# Stats
var BK_COMPLETED = 0
var BK_STRATEGY = "capability"

var MAIN_EXECUTED = false

# === entity/agent_profile.spl ===

struct AgentProfile:
    id: text
    capabilities: [text]
    max_concurrent: i64
    priority: i64
    current_load: i64
    status: text         # "idle", "busy", "offline"

fn agent_profile(id: text, capabilities: [text]) -> AgentProfile:
    AgentProfile(
        id: id,
        capabilities: capabilities,
        max_concurrent: 3,
        priority: 5,
        current_load: 0,
        status: "idle"
    )

fn agent_profile_full(id: text, capabilities: [text],
                      max_concurrent: i64, priority: i64) -> AgentProfile:
    AgentProfile(
        id: id,
        capabilities: capabilities,
        max_concurrent: max_concurrent,
        priority: priority,
        current_load: 0,
        status: "idle"
    )

impl AgentProfile:
    fn has_capability(cap: text) -> bool:
        for c in self.capabilities:
            if c == cap:
                return true
        false

    fn is_available() -> bool:
        self.status != "offline" and self.current_load < self.max_concurrent

    fn load_ratio() -> i64:
        if self.max_concurrent == 0:
            return 100
        (self.current_load * 100) / self.max_concurrent

    fn to_text() -> text:
        "Agent(" + self.id + ", load=" + self.current_load.to_text() + "/" + self.max_concurrent.to_text() + ", " + self.status + ")"

# === entity/task_request.spl ===

struct TaskRequest:
    id: text
    content: text
    required_caps: [text]
    urgency: i64         # 1-10, higher = more urgent
    status: text         # "pending", "bidding", "assigned", "running", "completed", "failed"
    assigned_agent: text
    result: text
    error: text

fn task_request(id: text, content: text, required_caps: [text]) -> TaskRequest:
    TaskRequest(
        id: id,
        content: content,
        required_caps: required_caps,
        urgency: 5,
        status: "pending",
        assigned_agent: "",
        result: "",
        error: ""
    )

fn task_request_urgent(id: text, content: text, required_caps: [text],
                       urgency: i64) -> TaskRequest:
    TaskRequest(
        id: id,
        content: content,
        required_caps: required_caps,
        urgency: urgency,
        status: "pending",
        assigned_agent: "",
        result: "",
        error: ""
    )

impl TaskRequest:
    fn is_pending() -> bool:
        self.status == "pending"

    fn is_completed() -> bool:
        self.status == "completed"

    fn to_text() -> text:
        "Task(" + self.id + ", urgency=" + self.urgency.to_text() + ", " + self.status + ")"

# === entity/bid.spl ===

struct Bid:
    agent_id: text
    task_id: text
    score: i64           # 0-100 composite score
    cap_overlap: i64     # capability match score (0-100)
    load_score: i64      # inverse load score (0-100)
    priority_score: i64  # agent priority score (0-100)
    accepted: bool

fn bid(agent_id: text, task_id: text, cap_overlap: i64,
       load_score: i64, priority_score: i64) -> Bid:
    # Weighted composite: cap_overlap*0.4 + load*0.3 + priority*0.3
    val score = (cap_overlap * 40 + load_score * 30 + priority_score * 30) / 100
    Bid(
        agent_id: agent_id,
        task_id: task_id,
        score: score,
        cap_overlap: cap_overlap,
        load_score: load_score,
        priority_score: priority_score,
        accepted: false
    )

impl Bid:
    fn to_text() -> text:
        "Bid(" + self.agent_id + " -> " + self.task_id + ", score=" + self.score.to_text() + ")"

# === feature/broker/matching.spl ===

fn broker_solicit_bids(task_id: text, required_caps: [text]) -> [Bid]:
    var bids: [Bid] = []
    var i = 0
    while i < BK_AGENT_COUNT:
        val agent_id = BK_AGENT_IDS[i]
        val agent_status = BK_AGENT_STATUSES[i]
        val agent_load = BK_AGENT_LOADS[i]
        val agent_max = BK_AGENT_MAX_CONCURRENT[i]
        val agent_priority = BK_AGENT_PRIORITIES[i]
        val agent_caps_str = BK_AGENT_CAPS[i]

        # Skip offline or at-capacity agents
        if agent_status == "offline":
            i = i + 1
            continue
        if agent_load >= agent_max:
            i = i + 1
            continue

        # Calculate capability overlap
        val agent_caps = agent_caps_str.split(",")
        var overlap_count = 0
        var total_required = 0
        for req in required_caps:
            val trimmed_req = req.trim()
            if trimmed_req != "":
                total_required = total_required + 1
                for ac in agent_caps:
                    if ac.trim() == trimmed_req:
                        overlap_count = overlap_count + 1
                        break

        if overlap_count == 0:
            i = i + 1
            continue

        # Scores (0-100 scale)
        var cap_score = 0
        if total_required > 0:
            cap_score = (overlap_count * 100) / total_required

        var load_score = 100
        if agent_max > 0:
            load_score = ((agent_max - agent_load) * 100) / agent_max

        val priority_score = agent_priority * 10
        val b = bid(agent_id, task_id, cap_score, load_score, priority_score)
        bids.push(b)
        i = i + 1
    bids

fn broker_select_best_bid(bids: [Bid]) -> Bid:
    var best_idx = 0
    var best_score = -1
    var i = 0
    while i < bids.len():
        if bids[i].score > best_score:
            best_score = bids[i].score
            best_idx = i
        i = i + 1
    bids[best_idx]

# === feature/broker/loop.spl ===

fn broker_process_task(task_idx: i64) -> text:
    # 1. Get task info
    val task_id = BK_TASK_IDS[task_idx]
    val content = BK_TASK_CONTENTS[task_idx]
    val caps_str = BK_TASK_CAPS[task_idx]

    # 2. Solicit bids
    BK_TASK_STATUSES[task_idx] = "bidding"
    val required_caps = _split_caps(caps_str)
    val bids = broker_solicit_bids(task_id, required_caps)

    if bids.len() == 0:
        BK_TASK_STATUSES[task_idx] = "failed"
        BK_TASK_ERRORS[task_idx] = "No capable agents available"
        return "Task " + task_id + ": no agents available"

    # 3. Award to best bid
    val best = broker_select_best_bid(bids)
    BK_TASK_STATUSES[task_idx] = "assigned"
    BK_TASK_AGENTS[task_idx] = best.agent_id
    BK_COMPLETED = BK_COMPLETED + 1

    "Task " + task_id + " awarded to " + best.agent_id + " (score=" + best.score.to_text() + ")"

fn broker_run_pending() -> text:
    var results: [text] = []
    var i = 0
    while i < BK_TASK_COUNT:
        if BK_TASK_STATUSES[i] == "pending":
            val r = broker_process_task(i)
            results.push(r)
        i = i + 1
    if results.len() == 0:
        return "No pending tasks."
    results.join("\n")

fn _split_caps(caps_str: text) -> [text]:
    if caps_str == "":
        return []
    caps_str.split(",")

# === feature/broker/coordination.spl ===

fn broker_coordinate_sequential(task_ids: [text]) -> text:
    # Process tasks one at a time in order
    var results: [text] = []
    for task_id in task_ids:
        val idx = _find_task_index(task_id)
        if idx >= 0:
            val r = broker_process_task(idx)
            results.push(r)
    results.join("\n")

fn broker_coordinate_parallel(task_ids: [text]) -> text:
    # Award all tasks simultaneously (best-effort)
    var results: [text] = []
    for task_id in task_ids:
        val idx = _find_task_index(task_id)
        if idx >= 0:
            val r = broker_process_task(idx)
            results.push(r)
    results.join("\n")

fn broker_coordinate_pipeline(task_ids: [text]) -> text:
    # Pipeline: output of task N feeds into task N+1
    var results: [text] = []
    var prev_result = ""
    for task_id in task_ids:
        val idx = _find_task_index(task_id)
        if idx >= 0:
            if prev_result != "":
                BK_TASK_CONTENTS[idx] = BK_TASK_CONTENTS[idx] + "\n\nContext from previous step:\n" + prev_result
            val r = broker_process_task(idx)
            prev_result = r
            results.push(r)
    results.join("\n")

fn _find_task_index(task_id: text) -> i64:
    var i = 0
    while i < BK_TASK_COUNT:
        if BK_TASK_IDS[i] == task_id:
            return i
        i = i + 1
    -1

# === feature/worker/worker.spl ===

fn worker_register(id: text, capabilities: text, max_concurrent: i64, priority: i64):
    BK_AGENT_IDS = BK_AGENT_IDS + [id]
    BK_AGENT_CAPS = BK_AGENT_CAPS + [capabilities]
    BK_AGENT_MAX_CONCURRENT = BK_AGENT_MAX_CONCURRENT + [max_concurrent]
    BK_AGENT_PRIORITIES = BK_AGENT_PRIORITIES + [priority]
    BK_AGENT_LOADS = BK_AGENT_LOADS + [0]
    BK_AGENT_STATUSES = BK_AGENT_STATUSES + ["idle"]
    BK_AGENT_COUNT = BK_AGENT_COUNT + 1

fn worker_set_status(agent_id: text, status: text):
    var i = 0
    while i < BK_AGENT_COUNT:
        if BK_AGENT_IDS[i] == agent_id:
            BK_AGENT_STATUSES[i] = status
            return
        i = i + 1

fn worker_increment_load(agent_id: text):
    var i = 0
    while i < BK_AGENT_COUNT:
        if BK_AGENT_IDS[i] == agent_id:
            BK_AGENT_LOADS[i] = BK_AGENT_LOADS[i] + 1
            if BK_AGENT_LOADS[i] >= BK_AGENT_MAX_CONCURRENT[i]:
                BK_AGENT_STATUSES[i] = "busy"
            return
        i = i + 1

fn worker_decrement_load(agent_id: text):
    var i = 0
    while i < BK_AGENT_COUNT:
        if BK_AGENT_IDS[i] == agent_id:
            if BK_AGENT_LOADS[i] > 0:
                BK_AGENT_LOADS[i] = BK_AGENT_LOADS[i] - 1
            if BK_AGENT_LOADS[i] < BK_AGENT_MAX_CONCURRENT[i]:
                BK_AGENT_STATUSES[i] = "idle"
            return
        i = i + 1

fn worker_list_text() -> text:
    if BK_AGENT_COUNT == 0:
        return "  (no agents registered)"
    var parts: [text] = []
    var i = 0
    while i < BK_AGENT_COUNT:
        var tmp_ld = BK_AGENT_LOADS[i]
        var tmp_mx = BK_AGENT_MAX_CONCURRENT[i]
        val line = "  " + BK_AGENT_IDS[i] + " [" + BK_AGENT_STATUSES[i] + "] load=" + tmp_ld.to_text() + "/" + tmp_mx.to_text() + " caps=[" + BK_AGENT_CAPS[i] + "]"
        parts.push(line)
        i = i + 1
    parts.join("\n")

# === feature/monitor/dashboard.spl ===

fn dashboard_status() -> text:
    var parts: [text] = []
    parts.push("=== Mate Broker Dashboard ===")
    parts.push("")
    var tmp_ac = BK_AGENT_COUNT
    var tmp_tc = BK_TASK_COUNT
    var tmp_cc = BK_COMPLETED
    parts.push("Agents: " + tmp_ac.to_text())
    parts.push("Tasks: " + tmp_tc.to_text())
    parts.push("Completed: " + tmp_cc.to_text())
    parts.push("")

    # Agent summary
    parts.push("Agent Pool:")
    var i = 0
    while i < BK_AGENT_COUNT:
        var tmp_ld2 = BK_AGENT_LOADS[i]
        var tmp_mx2 = BK_AGENT_MAX_CONCURRENT[i]
        val line = "  " + BK_AGENT_IDS[i] + " [" + BK_AGENT_STATUSES[i] + "] " + tmp_ld2.to_text() + "/" + tmp_mx2.to_text()
        parts.push(line)
        i = i + 1

    parts.push("")
    parts.push("Task Queue:")
    if BK_TASK_COUNT == 0:
        parts.push("  (empty)")
    else:
        var j = 0
        while j < BK_TASK_COUNT:
            var task_line = "  " + BK_TASK_IDS[j] + " [" + BK_TASK_STATUSES[j] + "]"
            val agent = BK_TASK_AGENTS[j]
            if agent != "":
                task_line = task_line + " -> " + agent
            task_line = task_line + " " + BK_TASK_CONTENTS[j]
            parts.push(task_line)
            j = j + 1

    parts.join("\n")

# === transform/dispatch/pool_view.spl ===

fn pool_available_agents() -> [text]:
    var available: [text] = []
    var i = 0
    while i < BK_AGENT_COUNT:
        if BK_AGENT_STATUSES[i] != "offline" and BK_AGENT_LOADS[i] < BK_AGENT_MAX_CONCURRENT[i]:
            available.push(BK_AGENT_IDS[i])
        i = i + 1
    available

fn pool_agents_with_capability(cap: text) -> [text]:
    var matches: [text] = []
    var i = 0
    while i < BK_AGENT_COUNT:
        val caps = BK_AGENT_CAPS[i].split(",")
        for c in caps:
            if c.trim() == cap:
                matches.push(BK_AGENT_IDS[i])
                break
        i = i + 1
    matches

fn pool_total_capacity() -> i64:
    var total = 0
    var i = 0
    while i < BK_AGENT_COUNT:
        total = total + BK_AGENT_MAX_CONCURRENT[i] - BK_AGENT_LOADS[i]
        i = i + 1
    total

# === transform/dispatch/queue_view.spl ===

fn queue_pending_tasks() -> [text]:
    var pending: [text] = []
    var i = 0
    while i < BK_TASK_COUNT:
        if BK_TASK_STATUSES[i] == "pending":
            pending.push(BK_TASK_IDS[i])
        i = i + 1
    pending

fn queue_assigned_tasks() -> [text]:
    var assigned: [text] = []
    var i = 0
    while i < BK_TASK_COUNT:
        if BK_TASK_STATUSES[i] == "assigned" or BK_TASK_STATUSES[i] == "running":
            assigned.push(BK_TASK_IDS[i])
        i = i + 1
    assigned

fn queue_completed_count() -> i64:
    var count = 0
    var i = 0
    while i < BK_TASK_COUNT:
        if BK_TASK_STATUSES[i] == "completed":
            count = count + 1
        i = i + 1
    count

fn queue_failed_count() -> i64:
    var count = 0
    var i = 0
    while i < BK_TASK_COUNT:
        if BK_TASK_STATUSES[i] == "failed":
            count = count + 1
        i = i + 1
    count

# === shared/state.spl ===

val STATE_DIR = ".build/mate_broker"

fn state_init():
    rt_dir_create_all(STATE_DIR)

fn state_save_agents() -> bool:
    var lines: [text] = []
    var tmp_ac2 = BK_AGENT_COUNT
    lines.push("agent_count: " + tmp_ac2.to_text())
    var i = 0
    while i < BK_AGENT_COUNT:
        lines.push("")
        lines.push("agent_" + i.to_text() + ":")
        lines.push("  id: " + BK_AGENT_IDS[i])
        lines.push("  caps: " + BK_AGENT_CAPS[i])
        var tmp_mx3 = BK_AGENT_MAX_CONCURRENT[i]
        var tmp_pr = BK_AGENT_PRIORITIES[i]
        var tmp_ld3 = BK_AGENT_LOADS[i]
        lines.push("  max: " + tmp_mx3.to_text())
        lines.push("  priority: " + tmp_pr.to_text())
        lines.push("  load: " + tmp_ld3.to_text())
        lines.push("  status: " + BK_AGENT_STATUSES[i])
        i = i + 1
    rt_file_write_text(STATE_DIR + "/agents.sdn", lines.join("\n") + "\n")

fn state_save_tasks() -> bool:
    var lines: [text] = []
    var tmp_tc2 = BK_TASK_COUNT
    var tmp_nid = BK_NEXT_TASK_ID
    lines.push("task_count: " + tmp_tc2.to_text())
    lines.push("next_id: " + tmp_nid.to_text())
    var i = 0
    while i < BK_TASK_COUNT:
        lines.push("")
        lines.push("task_" + i.to_text() + ":")
        lines.push("  id: " + BK_TASK_IDS[i])
        lines.push("  content: " + BK_TASK_CONTENTS[i])
        lines.push("  caps: " + BK_TASK_CAPS[i])
        var tmp_urg = BK_TASK_URGENCIES[i]
        lines.push("  urgency: " + tmp_urg.to_text())
        lines.push("  status: " + BK_TASK_STATUSES[i])
        lines.push("  agent: " + BK_TASK_AGENTS[i])
        i = i + 1
    rt_file_write_text(STATE_DIR + "/tasks.sdn", lines.join("\n") + "\n")

# === shared/protocol.spl ===

val MSG_REGISTER = "register"
val MSG_BID_REQUEST = "bid_request"
val MSG_BID_RESPONSE = "bid_response"
val MSG_AWARD = "award"
val MSG_COMPLETE = "complete"
val MSG_STATUS = "status"

fn protocol_format_register(agent_id: text, capabilities: text) -> text:
    "type: " + MSG_REGISTER + "\nagent_id: " + agent_id + "\ncapabilities: " + capabilities

fn protocol_format_bid_request(task_id: text, required_caps: text) -> text:
    "type: " + MSG_BID_REQUEST + "\ntask_id: " + task_id + "\nrequired_caps: " + required_caps

fn protocol_format_award(task_id: text, agent_id: text) -> text:
    "type: " + MSG_AWARD + "\ntask_id: " + task_id + "\nagent_id: " + agent_id

fn protocol_format_complete(task_id: text, agent_id: text, result: text) -> text:
    "type: " + MSG_COMPLETE + "\ntask_id: " + task_id + "\nagent_id: " + agent_id + "\nresult: " + result

fn protocol_parse_type(message: text) -> text:
    val lines = message.split("\n")
    for line in lines:
        val trimmed = line.trim()
        if trimmed.starts_with("type:"):
            val tlen = trimmed.len()
            return trimmed[5:tlen].trim()
    ""

# ============================================================================
# CLI command handlers
# ============================================================================

fn _handle_submit(content: text, caps: text) -> text:
    var tmp_nid2 = BK_NEXT_TASK_ID
    val id = "task-" + tmp_nid2.to_text()
    BK_NEXT_TASK_ID = BK_NEXT_TASK_ID + 1
    BK_TASK_IDS = BK_TASK_IDS + [id]
    BK_TASK_CONTENTS = BK_TASK_CONTENTS + [content]
    BK_TASK_CAPS = BK_TASK_CAPS + [caps]
    BK_TASK_URGENCIES = BK_TASK_URGENCIES + [5]
    BK_TASK_STATUSES = BK_TASK_STATUSES + ["pending"]
    BK_TASK_AGENTS = BK_TASK_AGENTS + [""]
    BK_TASK_RESULTS = BK_TASK_RESULTS + [""]
    BK_TASK_ERRORS = BK_TASK_ERRORS + [""]
    BK_TASK_COUNT = BK_TASK_COUNT + 1
    "Submitted: " + id + " (" + content + ") caps=[" + caps + "]"

fn _load_default_agents():
    worker_register("coder", "code,refactor,test", 3, 10)
    worker_register("reviewer", "review,security,docs", 2, 8)
    worker_register("researcher", "research,analysis,docs", 2, 5)
    worker_register("tester", "test,integration,benchmark", 4, 7)

fn _show_broker_help() -> text:
    var parts: [text] = []
    parts.push("mate-broker — Multi-Agent Task Broker")
    parts.push("")
    parts.push("Usage: mate-broker <command> [args]")
    parts.push("")
    parts.push("Commands:")
    parts.push("  start                    Start broker (load default agents)")
    parts.push("  submit <task> [--caps c] Submit task request")
    parts.push("  status                   Show broker status")
    parts.push("  agents                   List agent pool")
    parts.push("  register <id> <caps>     Register new agent")
    parts.push("  process                  Process pending tasks")
    parts.push("  help                     Show this help")
    parts.join("\n")

# ============================================================================
# Main
# ============================================================================

fn main():
    if MAIN_EXECUTED:
        return
    MAIN_EXECUTED = true

    # Strip runtime args
    val raw_args = rt_cli_get_args()
    var args: [text] = []
    var found_script = false
    for a in raw_args:
        if found_script:
            args.push(a)
        elif a.ends_with(".spl"):
            found_script = true

    if args.len() == 0:
        print(_show_broker_help())
        return

    val cmd = args[0]

    if cmd == "help":
        print(_show_broker_help())
    elif cmd == "start":
        _load_default_agents()
        var tmp_ac3 = BK_AGENT_COUNT
        print("Broker started with " + tmp_ac3.to_text() + " agents")
        print(worker_list_text())
    elif cmd == "agents":
        _load_default_agents()
        print("Agent Pool:")
        print(worker_list_text())
    elif cmd == "submit":
        _load_default_agents()
        if args.len() < 2:
            print("Usage: mate-broker submit <task> [--caps capabilities]")
            return
        var content_parts: [text] = []
        var caps = "code"
        var i = 1
        while i < args.len():
            if args[i] == "--caps" and i + 1 < args.len():
                i = i + 1
                caps = args[i]
            else:
                content_parts.push(args[i])
            i = i + 1
        val content = content_parts.join(" ")
        print(_handle_submit(content, caps))
        val process_result = broker_run_pending()
        print(process_result)
    elif cmd == "status":
        _load_default_agents()
        print(dashboard_status())
    elif cmd == "register":
        if args.len() < 3:
            print("Usage: mate-broker register <id> <capabilities>")
            return
        worker_register(args[1], args[2], 3, 5)
        print("Registered agent: " + args[1])
    elif cmd == "process":
        _load_default_agents()
        val result = broker_run_pending()
        print(result)
    else:
        print("Unknown command: " + cmd)
        print(_show_broker_help())

main()
