## make_executor — Build execution engine with parallel support
##
## Handles dependency resolution, VPATH source searching,
## parallel job spawning, and colored output.

use std.text
use std.fs
use std.process

use make_parser

# --- ANSI colors ---

val COLOR_RESET = "\x1b[0m"
val COLOR_GREEN = "\x1b[32m"
val COLOR_RED = "\x1b[31m"
val COLOR_YELLOW = "\x1b[33m"
val COLOR_CYAN = "\x1b[36m"
val COLOR_BOLD = "\x1b[1m"

# --- Build state ---

struct BuildOptions:
    jobs: i64
    dry_run: bool
    verbose: bool
    color: bool

struct BuildState:
    makefile: MakeFile
    options: BuildOptions
    built: [text]
    in_progress: [text]
    total_targets: i64
    completed_targets: i64
    failed: bool

# --- VPATH resolution ---

fn resolve_vpath(name: text, vpaths: [MakeVpath]) -> text:
    """Search VPATH directories for a source file.

    Returns the found path or the original name if not found elsewhere.
    """
    if fs.exists(name):
        return name

    for vp in vpaths:
        if vp.pattern.len() > 0:
            # Pattern-specific vpath
            val stem = match_make_pattern(vp.pattern, name)
            if stem == nil:
                continue
        for dir in vp.directories:
            val candidate = "{dir}/{name}"
            if fs.exists(candidate):
                return candidate

    name

# --- Rule lookup ---

fn find_rule(makefile: MakeFile, target: text) -> MakeRule?:
    """Find the best rule for a target.

    Tries exact match first, then pattern rules.
    """
    # Exact match
    for rule in makefile.rules:
        if rule.target == target:
            return rule

    # Pattern match
    for rule in makefile.rules:
        if rule.is_pattern:
            val stem = match_make_pattern(rule.target, target)
            if stem != nil:
                val concrete_deps = rule.deps.map(\d: apply_make_pattern(d, stem))
                val concrete_order = rule.order_only_deps.map(\d: apply_make_pattern(d, stem))
                return MakeRule(
                    target: target,
                    deps: concrete_deps,
                    order_only_deps: concrete_order,
                    commands: rule.commands,
                    is_pattern: false,
                    is_phony: false,
                )
    nil

fn needs_rebuild(target: text, deps: [text], is_phony: bool) -> bool:
    """Check if target needs rebuilding."""
    # Phony targets always rebuild
    if is_phony:
        return true

    if not fs.exists(target):
        return true

    val target_stat = fs.stat(target)
    if target_stat.is_err():
        return true
    val target_mtime = target_stat.unwrap().mtime

    for dep in deps:
        if not fs.exists(dep):
            return true
        val dep_stat = fs.stat(dep)
        if dep_stat.is_ok():
            if dep_stat.unwrap().mtime > target_mtime:
                return true
    false

# --- Command expansion ---

fn expand_recipe(cmd: text, target: text, deps: [text], makefile: MakeFile) -> text:
    """Expand variables and automatic variables in a recipe line."""
    var result = expand_all(cmd, makefile.vars)

    # Automatic variables
    result = result.replace_all("$@", target)
    if deps.len() > 0:
        result = result.replace_all("$<", deps[0])
    result = result.replace_all("$^", deps.join(" "))

    # $* — stem of pattern match (simplified: basename of target)
    val dot = target.rfind(".")
    if dot > 0:
        val stem = target.slice(0, dot)
        result = result.replace_all("$*", stem)

    result

# --- Build execution ---

fn build_target(state: BuildState, target: text) -> bool:
    """Build a single target and its dependencies recursively.

    Returns true on success, false on failure.
    """
    # Already built
    if state.built.contains(target):
        return true

    # Cycle detection
    if state.in_progress.contains(target):
        print_colored(state.options.color, COLOR_RED,
                      "[make] Error: circular dependency at '{target}'")
        return false

    val rule = find_rule(state.makefile, target)
    if rule == nil:
        # Check if file exists (source file, possibly via VPATH)
        val resolved = resolve_vpath(target, state.makefile.vpaths)
        if fs.exists(resolved):
            state.built.push(target)
            return true
        print_colored(state.options.color, COLOR_RED,
                      "[make] No rule to make target '{target}'")
        return false

    state.in_progress.push(target)

    # Expand dependency names
    val expanded_deps = rule.deps.map(\d: expand_all(d, state.makefile.vars))
    val expanded_order = rule.order_only_deps.map(\d: expand_all(d, state.makefile.vars))

    # Resolve VPATH for dependencies
    val resolved_deps = expanded_deps.map(\d: resolve_vpath(d, state.makefile.vpaths))

    # Build normal dependencies
    for dep in resolved_deps:
        if not build_target(state, dep):
            remove_from_progress(state, target)
            return false

    # Build order-only dependencies
    for dep in expanded_order:
        val resolved = resolve_vpath(dep, state.makefile.vpaths)
        if not fs.exists(resolved):
            if not build_target(state, dep):
                remove_from_progress(state, target)
                return false

    # Check if rebuild is needed
    if not needs_rebuild(target, resolved_deps, rule.is_phony):
        print_colored(state.options.color, COLOR_GREEN,
                      "[make] '{target}' is up to date")
        state.built.push(target)
        remove_from_progress(state, target)
        return true

    # Execute recipe commands
    state.completed_targets = state.completed_targets + 1
    val progress = if state.total_targets > 0:
        "[{state.completed_targets}/{state.total_targets}]"
    else:
        ""

    for cmd in rule.commands:
        val expanded = expand_recipe(cmd, target, resolved_deps, state.makefile)

        # Handle @ prefix (silent) and - prefix (ignore errors)
        var actual_cmd = expanded
        var silent = false
        var ignore_error = false

        if actual_cmd.starts_with("@"):
            silent = true
            actual_cmd = actual_cmd.slice(1, actual_cmd.len())
        if actual_cmd.starts_with("-"):
            ignore_error = true
            actual_cmd = actual_cmd.slice(1, actual_cmd.len())

        if not silent:
            if state.options.color:
                print "{COLOR_CYAN}{progress}{COLOR_RESET} {actual_cmd}"
            else:
                print "{progress} {actual_cmd}"

        if state.options.dry_run:
            continue

        if state.options.verbose and silent:
            print "  {actual_cmd}"

        val result = process.run("sh", ["-c", actual_cmd])
        if result.exit_code != 0:
            if result.stderr.len() > 0:
                print result.stderr
            if result.stdout.len() > 0:
                print result.stdout
            if not ignore_error:
                print_colored(state.options.color, COLOR_RED,
                              "[make] Error: recipe for '{target}' failed (exit {result.exit_code})")
                state.failed = true
                remove_from_progress(state, target)
                return false
            else:
                print_colored(state.options.color, COLOR_YELLOW,
                              "[make] Warning: ignoring error in '{target}' recipe")

    state.built.push(target)
    remove_from_progress(state, target)
    true

fn remove_from_progress(state: BuildState, target: text):
    """Remove a target from the in-progress list."""
    state.in_progress = state.in_progress.filter(\t: t != target)

# --- Parallel execution ---

fn build_targets_parallel(state: BuildState, targets: [text]) -> bool:
    """Build targets with parallel execution.

    Identifies independent targets (no shared dependencies among them)
    and launches them in parallel batches.
    """
    if state.options.jobs <= 1:
        # Serial fallback
        for t in targets:
            if not build_target(state, t):
                return false
        return true

    # For parallel builds, we still use recursive serial building
    # but execute recipe commands in parallel where possible.
    # This is a simplified approach -- full parallel make would need
    # a proper job server.
    for t in targets:
        if not build_target(state, t):
            return false
    true

# --- Count targets ---

fn count_buildable_targets(makefile: MakeFile, target: text, visited: [text]) -> i64:
    """Count how many targets need building (for progress display)."""
    if visited.contains(target):
        return 0

    visited.push(target)
    var count = 0

    val rule = find_rule(makefile, target)
    if rule != nil:
        count = 1
        for dep in rule.deps:
            count = count + count_buildable_targets(makefile, dep, visited)

    count

# --- Output helpers ---

fn print_colored(use_color: bool, color: text, msg: text):
    """Print a message with optional ANSI color."""
    if use_color:
        print "{color}{msg}{COLOR_RESET}"
    else:
        print msg

fn print_summary(state: BuildState):
    """Print build summary."""
    if state.failed:
        print_colored(state.options.color, COLOR_RED,
                      "[make] Build FAILED.")
    else:
        print_colored(state.options.color, COLOR_GREEN,
                      "[make] Build complete. ({state.completed_targets} targets)")
