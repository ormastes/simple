# Unit tests for stdio protocol header parsing.

use src.util.protocol_headers.{is_ascii_digits, parse_content_length_header}

describe "Protocol Headers":
    """Crash-prevention guards for malformed Content-Length headers"""

    context "is_ascii_digits":
        it "accepts digit-only strings":
            expect(is_ascii_digits("123")).to_equal(true)

        it "rejects empty strings":
            expect(is_ascii_digits("")).to_equal(false)

        it "rejects whitespace and signs":
            expect(is_ascii_digits(" 12")).to_equal(false)
            expect(is_ascii_digits("-12")).to_equal(false)

        it "rejects non-digit characters":
            expect(is_ascii_digits("12x")).to_equal(false)

    context "parse_content_length_header":
        it "parses valid Content-Length headers":
            expect(parse_content_length_header("Content-Length: 42")).to_equal(42)

        it "trims surrounding whitespace":
            expect(parse_content_length_header("Content-Length:   7  ")).to_equal(7)

        it "rejects empty Content-Length values":
            expect(parse_content_length_header("Content-Length:")).to_equal(-1)

        it "rejects non-numeric Content-Length values":
            expect(parse_content_length_header("Content-Length: abc")).to_equal(-1)

        it "rejects negative Content-Length values":
            expect(parse_content_length_header("Content-Length: -1")).to_equal(-1)

        it "rejects unrelated headers":
            expect(parse_content_length_header("Content-Type: application/json")).to_equal(-1)
