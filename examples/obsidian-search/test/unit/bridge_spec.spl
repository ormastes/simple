# Unit tests for LSP-MCP bridge handlers

use src.lsp_mcp.bridge_handlers.{handle_bridge_tool}

describe "LSP-MCP Bridge":
    """Tests for bridge tool responses"""

    context "obsidian_semantic_health":
        """Semantic/embedding health check tool"""

        it "returns structured health status":
            val result = handle_bridge_tool("1", "obsidian_semantic_health", "{}", "")
            expect(result).to_contain("status")
            expect(result).to_contain("not_configured")

    context "obsidian_complete_wikilink":
        """Wikilink completion via MCP bridge"""

        it "returns completions array":
            val body = "{\"arguments\":{\"prefix\":\"test\"}}"
            val result = handle_bridge_tool("1", "obsidian_complete_wikilink", body, "")
            expect(result).to_contain("completions")

    context "obsidian_complete_tag":
        """Tag completion via MCP bridge"""

        it "returns tags array":
            val body = "{\"arguments\":{\"prefix\":\"proj\"}}"
            val result = handle_bridge_tool("1", "obsidian_complete_tag", body, "")
            expect(result).to_contain("tags")

    context "obsidian_resolve_link":
        """Link resolution via MCP bridge"""

        it "returns resolution result":
            val body = "{\"arguments\":{\"target\":\"nonexistent\"}}"
            val result = handle_bridge_tool("1", "obsidian_resolve_link", body, "")
            expect(result).to_contain("resolved")
