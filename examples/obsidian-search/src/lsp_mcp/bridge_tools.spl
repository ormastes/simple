#![allow(unnamed_duplicate_typed_args)]
# LSP-MCP Bridge Tool Schemas — 7 LSP-exposed MCP tools
#
# Defines tool schemas for the LSP-MCP bridge tools/list response.
# All tools are read-only LSP-oriented operations:
# diagnostics, completions, hover, link resolution, semantic health.

use src.util.json_helpers.{js, jp, jo1, jo2, jo3, ja, jo, make_json_result, SB_L, SB_R, LB, RB}

# --- Tool schema builder ---

fn make_string_prop(description: text) -> text:
    jo2(jp("type", js("string")), jp("description", js(description)))

fn make_int_prop(description: text) -> text:
    jo2(jp("type", js("integer")), jp("description", js(description)))

fn make_tool(name: text, description: text, props: text, required: text) -> text:
    val schema = jo3(
        jp("type", js("object")),
        jp("properties", props),
        jp("required", required)
    )
    val annotations = jo3(
        jp("readOnlyHint", "true"),
        jp("destructiveHint", "false"),
        jp("idempotentHint", "true")
    )
    var tool_obj = LB()
    tool_obj = tool_obj + jp("name", js(name))
    tool_obj = tool_obj + "," + jp("description", js(description))
    tool_obj = tool_obj + "," + jp("inputSchema", schema)
    tool_obj = tool_obj + "," + jp("annotations", annotations)
    tool_obj = tool_obj + RB()
    tool_obj

# --- All 7 bridge tool schemas ---

fn make_bridge_tools_list(id: text) -> text:
    var tool_parts: [text] = []

    # 1. obsidian_diagnostics
    var diag_props = LB()
    diag_props = diag_props + jp("path", make_string_prop("Relative path to the note in the vault"))
    diag_props = diag_props + RB()
    tool_parts.push(make_tool(
        "obsidian_diagnostics",
        "Run diagnostics on a single Obsidian note. Reports broken wikilinks, missing tags, and structural issues.",
        diag_props,
        ja([js("path")])
    ))

    # 2. obsidian_vault_diagnostics
    var vdiag_props = LB()
    vdiag_props = vdiag_props + jp("limit", make_int_prop("Maximum number of diagnostic items to return (default 50)"))
    vdiag_props = vdiag_props + RB()
    tool_parts.push(make_tool(
        "obsidian_vault_diagnostics",
        "Run vault-wide diagnostics. Finds broken wikilinks, orphan notes, and reports embedding health across all files.",
        vdiag_props,
        ja([])
    ))

    # 3. obsidian_complete_wikilink
    var cwl_props = LB()
    cwl_props = cwl_props + jp("prefix", make_string_prop("Wikilink prefix to complete (case-insensitive)"))
    cwl_props = cwl_props + RB()
    tool_parts.push(make_tool(
        "obsidian_complete_wikilink",
        "Get wikilink completions for a given prefix. Returns matching vault note names.",
        cwl_props,
        ja([js("prefix")])
    ))

    # 4. obsidian_complete_tag
    var ct_props = LB()
    ct_props = ct_props + jp("prefix", make_string_prop("Tag prefix to complete (without # symbol, case-insensitive)"))
    ct_props = ct_props + RB()
    tool_parts.push(make_tool(
        "obsidian_complete_tag",
        "Get tag completions for a given prefix. Scans all vault notes for matching tags.",
        ct_props,
        ja([js("prefix")])
    ))

    # 5. obsidian_hover
    var hover_props = LB()
    hover_props = hover_props + jp("target", make_string_prop("Wikilink target to get hover info for"))
    hover_props = hover_props + RB()
    tool_parts.push(make_tool(
        "obsidian_hover",
        "Get hover information for a wikilink target. Returns frontmatter preview as markdown.",
        hover_props,
        ja([js("target")])
    ))

    # 6. obsidian_resolve_link
    var rl_props = LB()
    rl_props = rl_props + jp("target", make_string_prop("Wikilink target to resolve to a file path"))
    rl_props = rl_props + RB()
    tool_parts.push(make_tool(
        "obsidian_resolve_link",
        "Resolve a wikilink target to its file path. Returns the path or close suggestions if not found.",
        rl_props,
        ja([js("target")])
    ))

    # 7. obsidian_semantic_health
    var sh_props = LB()
    sh_props = sh_props + RB()
    tool_parts.push(make_tool(
        "obsidian_semantic_health",
        "Get embedding and semantic search status. Reports availability, alternatives, and configuration.",
        sh_props,
        ja([])
    ))

    val tools = SB_L() + tool_parts.join(",") + SB_R()
    val result = jo1(jp("tools", tools))
    make_json_result(id, result)
