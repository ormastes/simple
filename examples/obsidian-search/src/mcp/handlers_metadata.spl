# MCP Handlers for metadata management tools (Phase B)
#
# Routes manage_frontmatter, add_tags, remove_tags, rename_tag,
# batch_read_notes, and list_files tool calls.

use src.util.json_helpers.{js, jp, jo, jo1, jo2, jo3, ja, ji, jb, make_json_result, make_error, tool_text_result, extract_field, extract_nested, extract_arg, safe_substr, LB, RB, SB_L, SB_R}
use src.core.frontmatter_manager.{get_frontmatter_field, set_frontmatter_field, delete_frontmatter_field, get_all_frontmatter}
use src.core.tag_manager.{add_tag_to_note, remove_tag_from_note, rename_tag_in_vault, list_all_tags}
use src.core.vault_scanner.{scan_vault, relative_path, invalidate_scan_vault_cache}
use src.core.note_parser.{parse_frontmatter}

extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_write_text(path: text, content: text) -> bool

# --- Path helper ---

fn obs_full_path(vault_path: text, rel_path: text) -> text:
    var full_path = vault_path
    if full_path != "" and not full_path.ends_with("/"):
        full_path = full_path + "/"
    full_path + rel_path

# --- Main dispatch ---

/**
Handle a metadata management tool call.
Dispatches to the appropriate handler based on tool_name.
*/
fn handle_metadata_tool(id: text, tool_name: text, body: text, vault_path: text) -> text:

    if tool_name == "manage_frontmatter":
        return handle_manage_frontmatter(id, body, vault_path)

    elif tool_name == "add_tags":
        return handle_add_tags(id, body, vault_path)

    elif tool_name == "remove_tags":
        return handle_remove_tags(id, body, vault_path)

    elif tool_name == "rename_tag":
        return handle_rename_tag(id, body, vault_path)

    elif tool_name == "batch_read_notes":
        return handle_batch_read_notes(id, body, vault_path)

    elif tool_name == "list_files":
        return handle_list_files(id, body, vault_path)

    make_error(id, -32602, "Unknown metadata tool: " + tool_name)

# --- manage_frontmatter ---

fn handle_manage_frontmatter(id: text, body: text, vault_path: text) -> text:
    val path = extract_arg(body, "path")
    val operation = extract_arg(body, "operation")
    val field = extract_arg(body, "field")
    val value = extract_arg(body, "value")

    if path == "":
        return make_error(id, -32602, "Missing required parameter: path")
    if operation == "":
        return make_error(id, -32602, "Missing required parameter: operation")

    val full_path = obs_full_path(vault_path, path)
    val content = rt_file_read_text(full_path) ?? ""

    if operation == "get":
        if field == "":
            return make_error(id, -32602, "Missing required parameter: field (for get)")
        val result = get_frontmatter_field(content, field)
        val output = jo2(jp("field", js(field)), jp("value", js(result)))
        return tool_text_result(id, output)

    elif operation == "get_all":
        val fm_json = get_all_frontmatter(content)
        val output = jo2(jp("path", js(path)), jp("frontmatter", fm_json))
        return tool_text_result(id, output)

    elif operation == "set":
        if field == "":
            return make_error(id, -32602, "Missing required parameter: field (for set)")
        if value == "":
            return make_error(id, -32602, "Missing required parameter: value (for set)")
        val new_content = set_frontmatter_field(content, field, value)
        val ok = rt_file_write_text(full_path, new_content)
        if ok:
            invalidate_scan_vault_cache(vault_path)
        val output = jo3(jp("path", js(path)), jp("field", js(field)), jp("success", jb(ok)))
        return tool_text_result(id, output)

    elif operation == "delete":
        if field == "":
            return make_error(id, -32602, "Missing required parameter: field (for delete)")
        val new_content = delete_frontmatter_field(content, field)
        val ok = rt_file_write_text(full_path, new_content)
        if ok:
            invalidate_scan_vault_cache(vault_path)
        val output = jo3(jp("path", js(path)), jp("field", js(field)), jp("success", jb(ok)))
        return tool_text_result(id, output)

    make_error(id, -32602, "Invalid operation: " + operation + ". Use get, set, delete, or get_all.")

# --- add_tags ---

fn handle_add_tags(id: text, body: text, vault_path: text) -> text:
    val path = extract_arg(body, "path")
    val tags_str = extract_arg(body, "tags")

    if path == "":
        return make_error(id, -32602, "Missing required parameter: path")
    if tags_str == "":
        return make_error(id, -32602, "Missing required parameter: tags")

    val tags = split_comma_list(tags_str)
    var added: [text] = []
    for tag in tags:
        val ok = add_tag_to_note(vault_path, path, tag)
        if ok:
            added.push(tag)
    if added.len() > 0:
        invalidate_scan_vault_cache(vault_path)

    var added_js: [text] = []
    for a in added:
        added_js.push(js(a))
    val output = jo3(
        jp("path", js(path)),
        jp("added", ja(added_js)),
        jp("count", ji(added.len()))
    )
    tool_text_result(id, output)

# --- remove_tags ---

fn handle_remove_tags(id: text, body: text, vault_path: text) -> text:
    val path = extract_arg(body, "path")
    val tags_str = extract_arg(body, "tags")

    if path == "":
        return make_error(id, -32602, "Missing required parameter: path")
    if tags_str == "":
        return make_error(id, -32602, "Missing required parameter: tags")

    val tags = split_comma_list(tags_str)
    var removed: [text] = []
    for tag in tags:
        val ok = remove_tag_from_note(vault_path, path, tag)
        if ok:
            removed.push(tag)
    if removed.len() > 0:
        invalidate_scan_vault_cache(vault_path)

    var removed_js: [text] = []
    for r in removed:
        removed_js.push(js(r))
    val output = jo3(
        jp("path", js(path)),
        jp("removed", ja(removed_js)),
        jp("count", ji(removed.len()))
    )
    tool_text_result(id, output)

# --- rename_tag ---

fn handle_rename_tag(id: text, body: text, vault_path: text) -> text:
    val old_tag = extract_arg(body, "old_tag")
    val new_tag = extract_arg(body, "new_tag")

    if old_tag == "":
        return make_error(id, -32602, "Missing required parameter: old_tag")
    if new_tag == "":
        return make_error(id, -32602, "Missing required parameter: new_tag")

    val count = rename_tag_in_vault(vault_path, old_tag, new_tag)
    if count > 0:
        invalidate_scan_vault_cache(vault_path)
    val output = jo3(
        jp("old_tag", js(old_tag)),
        jp("new_tag", js(new_tag)),
        jp("modified_files", ji(count))
    )
    tool_text_result(id, output)

# --- batch_read_notes ---

fn handle_batch_read_notes(id: text, body: text, vault_path: text) -> text:
    val paths_str = extract_arg(body, "paths")

    if paths_str == "":
        return make_error(id, -32602, "Missing required parameter: paths")

    val paths = split_comma_list(paths_str)
    val max_notes = 50
    if paths.len() > max_notes:
        return make_error(id, -32602, "Too many paths: " + paths.len().to_text() + ". Maximum is " + max_notes.to_text())
    var items: [text] = []

    for path in paths:
        val full_path = obs_full_path(vault_path, path)
        val content = rt_file_read_text(full_path) ?? ""
        val meta = parse_frontmatter(content)
        var meta_pairs: [text] = []
        meta_pairs.push(jp("title", js(meta.title)))
        var tags_js: [text] = []
        for t in meta.tags:
            tags_js.push(js(t))
        meta_pairs.push(jp("tags", ja(tags_js)))
        var aliases_js: [text] = []
        for a in meta.aliases:
            aliases_js.push(js(a))
        meta_pairs.push(jp("aliases", ja(aliases_js)))
        val meta_json = jo(meta_pairs)

        var note_pairs: [text] = []
        note_pairs.push(jp("path", js(path)))
        note_pairs.push(jp("content", js(content)))
        note_pairs.push(jp("metadata", meta_json))
        items.push(jo(note_pairs))

    val output = jo2(jp("notes", ja(items)), jp("count", ji(items.len())))
    tool_text_result(id, output)

# --- list_files ---

fn handle_list_files(id: text, body: text, vault_path: text) -> text:
    val directory = extract_arg(body, "directory")
    val pattern = extract_arg(body, "pattern")
    val limit_str = extract_arg(body, "limit")
    var limit = if limit_str != "": int(limit_str) ?? 200 else: 200
    if limit <= 0:
        limit = 200
    if limit > 1000:
        limit = 1000

    val effective_pattern = if pattern != "": pattern else: "*.md"
    val files = scan_vault(vault_path)
    var items: [text] = []

    for file in files:
        if items.len() >= limit:
            break
        val rel = relative_path(file, vault_path)

        if directory != "":
            if not rel.starts_with(directory):
                continue

        if not matches_glob(rel, effective_pattern):
            continue

        var file_pairs: [text] = []
        file_pairs.push(jp("path", js(rel)))
        items.push(jo(file_pairs))

    var truncated = items.len() >= limit
    val output = jo3(jp("files", ja(items)), jp("count", ji(items.len())), jp("truncated", jb(truncated)))
    tool_text_result(id, output)

# --- Internal helpers ---

fn split_comma_list(s: text) -> [text]:
    var result: [text] = []
    val parts = s.split(",")
    for part in parts:
        val trimmed = part.trim()
        if trimmed != "":
            result.push(trimmed)
    result

fn matches_glob(path: text, pattern: text) -> bool:
    # Simple glob matching: supports *.ext pattern
    if pattern == "*":
        return true
    if pattern.starts_with("*."):
        val ext = safe_substr(pattern, 1, pattern.len())
        return path.ends_with(ext)
    # Exact substring match fallback
    path.contains(pattern)
