# MCP Handlers — write tool dispatch (Phase A)
#
# Routes write tool/call requests to note_writer functions
# and formats results as MCP tool responses.

use src.util.json_helpers.{js, jp, jo, jo1, jo2, jo3, ja, ji, jb, make_error, tool_text_result, extract_arg, LB, RB}
use src.core.note_writer.{create_note, edit_note, delete_note, move_note}
use src.core.md_diagnostics.{check_markdown_diagnostics, format_md_diagnostics_block, md_diagnostics_to_json, MdDiagnostic}

extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_read_text(path: text) -> text

# --- Frontmatter builder ---

fn build_frontmatter_yaml(fm_json: text) -> text:
    # Simple JSON-to-YAML frontmatter conversion
    # Expects flat JSON like {"title":"X","tags":["a","b"]}
    # Produces YAML frontmatter block
    if fm_json == "" or fm_json == "{}":
        return ""
    # For now, embed the raw JSON as a comment and produce minimal YAML
    # A full JSON parser is not available; use the raw string
    "---\n" + fm_json + "\n---\n"

fn prepend_frontmatter(content: text, frontmatter: text) -> text:
    if frontmatter == "":
        return content
    val yaml_block = build_frontmatter_yaml(frontmatter)
    if yaml_block == "":
        return content
    yaml_block + "\n" + content

# --- Main write handler dispatch ---

fn handle_write_tool(id: text, tool_name: text, body: text, vault_path: text) -> text:

    if tool_name == "create_note":
        val path = extract_arg(body, "path")
        val content = extract_arg(body, "content")
        val frontmatter = extract_arg(body, "frontmatter")
        if path == "":
            return make_error(id, -32602, "Missing required parameter: path")
        if content == "":
            return make_error(id, -32602, "Missing required parameter: content")
        val final_content = prepend_frontmatter(content, frontmatter)
        val ok = create_note(vault_path, path, final_content)
        if ok:
            val md_diags = check_markdown_diagnostics(path, final_content, vault_path)
            val diag_block = format_md_diagnostics_block(path, md_diags)
            if md_diags.len() > 0:
                val diag_json = md_diagnostics_to_json(md_diags)
                val output = jo3(jp("success", "true"), jp("path", js(path)), jp("_diagnostics", diag_json))
                return tool_text_result(id, output + "\n" + diag_block)
            val output = jo2(jp("success", "true"), jp("path", js(path)))
            return tool_text_result(id, output)
        else:
            val output = jo2(jp("success", "false"), jp("error", js("Failed to create note. File may already exist or directory creation failed.")))
            return tool_text_result(id, output)

    elif tool_name == "edit_note":
        val path = extract_arg(body, "path")
        val content = extract_arg(body, "content")
        var mode = extract_arg(body, "mode")
        if path == "":
            return make_error(id, -32602, "Missing required parameter: path")
        if content == "":
            return make_error(id, -32602, "Missing required parameter: content")
        if mode == "":
            mode = "append"
        if mode != "append" and mode != "prepend" and mode != "overwrite" and mode != "insert_after_heading":
            return make_error(id, -32602, "Invalid mode: " + mode + ". Must be append, prepend, overwrite, or insert_after_heading.")
        val ok = edit_note(vault_path, path, content, mode)
        if ok:
            val full_path_for_diag = vault_path + "/" + path
            val edited = rt_file_read_text(full_path_for_diag) ?? ""
            val md_diags = check_markdown_diagnostics(path, edited, vault_path)
            val diag_block = format_md_diagnostics_block(path, md_diags)
            if md_diags.len() > 0:
                val diag_json = md_diagnostics_to_json(md_diags)
                val output = jo3(jp("success", "true"), jp("path", js(path)), jp("_diagnostics", diag_json))
                return tool_text_result(id, output + "\n" + diag_block)
            val output = jo3(jp("success", "true"), jp("path", js(path)), jp("mode", js(mode)))
            return tool_text_result(id, output)
        else:
            val output = jo2(jp("success", "false"), jp("error", js("Failed to edit note. File may not exist.")))
            return tool_text_result(id, output)

    elif tool_name == "delete_note":
        val path = extract_arg(body, "path")
        val confirm = extract_arg(body, "confirm")
        if path == "":
            return make_error(id, -32602, "Missing required parameter: path")
        if confirm != "yes":
            return make_error(id, -32602, "Deletion requires confirm='yes' for safety.")
        val ok = delete_note(vault_path, path)
        if ok:
            val output = jo2(jp("success", "true"), jp("path", js(path)))
            return tool_text_result(id, output)
        else:
            val output = jo2(jp("success", "false"), jp("error", js("Failed to delete note. File may not exist.")))
            return tool_text_result(id, output)

    elif tool_name == "move_note":
        val old_path = extract_arg(body, "old_path")
        val new_path = extract_arg(body, "new_path")
        if old_path == "":
            return make_error(id, -32602, "Missing required parameter: old_path")
        if new_path == "":
            return make_error(id, -32602, "Missing required parameter: new_path")
        val updated_count = move_note(vault_path, old_path, new_path)
        if updated_count >= 0:
            val output = jo3(jp("success", "true"), jp("new_path", js(new_path)), jp("updated_links", ji(updated_count)))
            return tool_text_result(id, output)
        elif updated_count == -1:
            val output = jo2(jp("success", "false"), jp("error", js("Source note not found: " + old_path)))
            return tool_text_result(id, output)
        elif updated_count == -2:
            val output = jo2(jp("success", "false"), jp("error", js("Destination already exists: " + new_path)))
            return tool_text_result(id, output)
        else:
            val output = jo2(jp("success", "false"), jp("error", js("Failed to move note.")))
            return tool_text_result(id, output)

    make_error(id, -32602, "Unknown write tool: " + tool_name)
