# Protocol header parsing helpers shared by Obsidian MCP stdio servers.

fn is_ascii_digits(s: text) -> bool:
    if s == "":
        return false
    var i = 0
    while i < s.len():
        val ch = s.substring(i, i + 1)
        if ch < "0" or ch > "9":
            return false
        i = i + 1
    true

fn parse_content_length_header(line: text) -> i64:
    if not line.starts_with("Content-Length:"):
        return -1
    var len_str = line.replace("Content-Length:", "")
    len_str = len_str.trim()
    if not is_ascii_digits(len_str):
        return -1
    int(len_str) ?? -1
