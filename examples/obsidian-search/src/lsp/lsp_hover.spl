# Obsidian LSP — Hover Provider
# Shows frontmatter preview when hovering over [[wikilinks]].
#
# On hover over a [[wikilink]], reads the target note's frontmatter
# and displays title, tags, and aliases as a markdown hover.

export handle_hover

use src.util.json_helpers.{js, jp, jo, jo1, jo2, ja, ji, jnull, safe_substr}
use src.lsp.lsp_json.{extract_position_line, extract_position_char, extract_td_uri}
use src.lsp.lsp_document.{doc_store_get_content, get_line_content, get_wikilink_at_position}
use src.lsp.lsp_document.{vault_note_exists, vault_get_note_path_by_name}
use src.core.note_parser.{parse_frontmatter, NoteMeta}

extern fn rt_file_read_text(path: text) -> text

# ---------------------------------------------------------------------------
# Hover handler
# ---------------------------------------------------------------------------

fn handle_hover(params: text) -> text:
    val uri = extract_td_uri(params)
    val line = extract_position_line(params)
    val character = extract_position_char(params)

    val content = doc_store_get_content(uri)
    if content == "":
        return jnull()

    # Check if cursor is on a wikilink
    val link_target = get_wikilink_at_position(content, line, character)
    if link_target == "":
        return jnull()

    # Look up the target note
    if not vault_note_exists(link_target):
        # Show "note not found" hover
        val markdown = "**[[{link_target}]]** -- Note not found in vault"
        return make_hover(markdown)

    # Read target note and extract frontmatter
    val target_path = vault_get_note_path_by_name(link_target)
    if target_path == "":
        return jnull()

    val target_content = rt_file_read_text(target_path) ?? ""
    if target_content == "":
        val markdown = "**[[{link_target}]]** -- Empty note"
        return make_hover(markdown)

    val meta = parse_frontmatter(target_content)

    # Build hover markdown
    var parts: [text] = []
    parts.push("**[[{link_target}]]**")
    parts.push("")

    if meta.title != "":
        parts.push("**Title:** {meta.title}")

    if meta.tags.len() > 0:
        val tags_str = meta.tags.join(", ")
        parts.push("**Tags:** {tags_str}")

    if meta.aliases.len() > 0:
        val aliases_str = meta.aliases.join(", ")
        parts.push("**Aliases:** {aliases_str}")

    if meta.frontmatter_raw != "":
        parts.push("")
        parts.push("---")
        parts.push("```yaml")
        parts.push(meta.frontmatter_raw)
        parts.push("```")

    # Add first few lines of content preview
    val preview = get_content_preview(target_content, 5)
    if preview != "":
        parts.push("")
        parts.push("---")
        parts.push(preview)

    val markdown = parts.join("\n")
    make_hover(markdown)

# ---------------------------------------------------------------------------
# Hover result builder
# ---------------------------------------------------------------------------

fn make_hover(markdown: text) -> text:
    val contents = jo2(
        jp("kind", js("markdown")),
        jp("value", js(markdown))
    )
    jo1(jp("contents", contents))

# ---------------------------------------------------------------------------
# Content preview helper
# ---------------------------------------------------------------------------

fn get_content_preview(content: text, max_lines: i64) -> text:
    val lines = content.split("\n")
    var preview_lines: [text] = []
    var count = 0
    var past_frontmatter = false
    var in_frontmatter = false

    for line in lines:
        val trimmed = line.trim()
        if count == 0 and trimmed == "---":
            in_frontmatter = true
            count = count + 1
            continue
        if in_frontmatter and trimmed == "---":
            in_frontmatter = false
            past_frontmatter = true
            count = count + 1
            continue
        if in_frontmatter:
            count = count + 1
            continue

        # Skip empty lines at the start of content
        if preview_lines.len() == 0 and trimmed == "":
            count = count + 1
            continue

        preview_lines.push(line)
        if preview_lines.len() >= max_lines:
            break
        count = count + 1

    if preview_lines.len() > 0:
        return preview_lines.join("\n")
    ""
