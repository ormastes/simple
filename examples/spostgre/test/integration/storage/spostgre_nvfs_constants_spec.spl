# spostgre + NVFS constants integration coverage for FR-SPOSTGRE-M2-002.

use std.spipe.*
use examples.nvfs.src.core.constants.{STORAGE_CLASS_DB_WAL, STORAGE_CLASS_META_DURABLE,
                                      STORAGE_CLASS_DB_TEMP, DURABILITY_DATA_DURABLE}
use engine.nvfs_shim.{shim_arena_create, shim_arena_class_for_test}
use engine.tier_cache.{tier_cache_new}

describe "spostgre NVFS shared constants":
    it "exports the canonical ordinals requested by FR-SPOSTGRE-M2-002":
        expect(STORAGE_CLASS_DB_WAL).to_equal(1)
        expect(STORAGE_CLASS_META_DURABLE).to_equal(2)
        expect(STORAGE_CLASS_DB_TEMP).to_equal(3)
        expect(DURABILITY_DATA_DURABLE).to_equal(1)

    it "uses imported class constants when creating shim and tier-cache arenas":
        val wal = shim_arena_create(STORAGE_CLASS_DB_WAL, 0)
        expect(shim_arena_class_for_test(wal)).to_equal(STORAGE_CLASS_DB_WAL)

        val cache = tier_cache_new()
        expect(shim_arena_class_for_test(cache.arena_handle)).to_equal(STORAGE_CLASS_DB_TEMP)
