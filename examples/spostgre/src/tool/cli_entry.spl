# spostgre CLI entry — minimal skeleton.
#
# Phase 5 ships "version + exit" only. Real subcommands (init, wal-replay,
# vacuum, checkpoint-now, dump-catalog) arrive post-skeleton.

fn spostgre_version() -> text:
    """Compile-time version string."""
    "spostgre 0.0.0 (skeleton)"

fn spostgre_run(argv: [text]) -> i32:
    """Parse argv, print version on `--version`, else print usage."""
    if argv.len() >= 2 and argv[1] == "--version":
        print spostgre_version()
        return 0
    print "usage: spostgre [--version]"
    0
