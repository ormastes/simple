# spostgre engine — shared-accel-backed tuple scan helpers.
#
# Phase 1 keeps spostgre's planner/storage contracts unchanged. BRIN remains the
# coarse filter; this module adds the tuple-level refinement step using the new
# shared `std.db.accel` scan, bitmap, token, and trigram helpers.

use std.db.accel.{
    DB_ACCEL_DEFAULT_BATCH_SIZE, RowBitmap, ScanPredicate, FilterStats,
    accel_capability_report, collect_text_row_indices, row_bitmap_indices, scan_text_values,
    text_contains_token, text_equals_span,
    trigram_extract, trigram_overlap_count
}
use std.db.accel.{ScanPredicateKind}
use engine.brin.{BrinIndex, BrinValue, brin_scan_range}

struct SpostgreScanResult:
    matched_rows: [i64]
    matched_ranges: [u32]
    filter_stats: FilterStats
    batch_count: i64
    used_brin: bool

fn spostgre_scan_text(values: [text], predicate: ScanPredicate) -> SpostgreScanResult:
    if not accel_capability_report().simd_active:
        return spostgre_scan_text_scalar(values, predicate)
    val (bitmap, stats) = scan_text_values(values, predicate)
    SpostgreScanResult(
        matched_rows: row_bitmap_indices(bitmap),
        matched_ranges: [],
        filter_stats: stats,
        batch_count: batch_count_for(values.len()),
        used_brin: false
    )

fn spostgre_scan_text_with_brin(range_ids: [u32], values: [text],
                                idx: BrinIndex,
                                pred_min: BrinValue,
                                pred_max: BrinValue,
                                predicate: ScanPredicate) -> SpostgreScanResult:
    val coarse_ranges = brin_scan_range(idx, pred_min, pred_max)
    val allowed_ranges = range_bitmap_for(range_ids, coarse_ranges)
    if not accel_capability_report().simd_active:
        return spostgre_scan_text_with_brin_scalar(range_ids, values, coarse_ranges, allowed_ranges, predicate)
    var candidate_values: [text] = []
    var candidate_rows: [i64] = []
    var row_idx = 0
    while row_idx < values.len():
        if allowed_ranges.get(range_ids[row_idx] as i64):
            candidate_values.push(values[row_idx])
            candidate_rows.push(row_idx)
        row_idx = row_idx + 1

    val (bitmap, stats) = scan_text_values(candidate_values, predicate)
    var refined = RowBitmap.empty(values.len())
    var candidate_idx = 0
    while candidate_idx < candidate_rows.len():
        if bitmap.get(candidate_idx):
            refined.set(candidate_rows[candidate_idx])
        candidate_idx = candidate_idx + 1
    SpostgreScanResult(
        matched_rows: row_bitmap_indices(refined),
        matched_ranges: coarse_ranges,
        filter_stats: FilterStats(
            rows_scanned: stats.rows_scanned,
            candidates_kept: refined.count(),
            bitmap_density: refined.density(),
            fallback_count: stats.fallback_count
        ),
        batch_count: batch_count_for(values.len()),
        used_brin: true
    )

fn spostgre_text_search(values: [text], query: text) -> [i64]:
    val query_trigrams = trigram_extract(query)
    val can_use_substring_fast_path = query.len() >= 3
    var result: [i64] = []
    var idx = 0
    while idx < values.len():
        val doc = values[idx]
        val keep = if can_use_substring_fast_path and doc.contains(query):
            true
        else:
            if text_contains_token(doc, query):
                true
            else:
                text_has_query_trigram(doc, query, query_trigrams)
        if keep:
            result.push(idx)
        idx = idx + 1
    result

fn range_bitmap_for(range_ids: [u32], ranges: [u32]) -> RowBitmap:
    var max_range_id = -1
    for range_id in range_ids:
        val range_idx = range_id as i64
        if range_idx > max_range_id:
            max_range_id = range_idx
    for range_id in ranges:
        val range_idx = range_id as i64
        if range_idx > max_range_id:
            max_range_id = range_idx
    var bitmap = RowBitmap.empty(max_range_id + 1)
    for range_id in ranges:
        bitmap.set(range_id as i64)
    bitmap

fn batch_count_for(row_count: i64) -> i64:
    if row_count == 0:
        0
    else:
        (row_count + DB_ACCEL_DEFAULT_BATCH_SIZE - 1) / DB_ACCEL_DEFAULT_BATCH_SIZE

fn spostgre_scan_text_scalar(values: [text], predicate: ScanPredicate) -> SpostgreScanResult:
    val (matched_rows, stats) = collect_text_row_indices(values, predicate)
    SpostgreScanResult(
        matched_rows: matched_rows,
        matched_ranges: [],
        filter_stats: stats,
        batch_count: batch_count_for(values.len()),
        used_brin: false
    )

fn spostgre_scan_text_with_brin_scalar(range_ids: [u32], values: [text],
                                       coarse_ranges: [u32],
                                       allowed_ranges: RowBitmap,
                                       predicate: ScanPredicate) -> SpostgreScanResult:
    var matched_rows: [i64] = []
    var scanned = 0
    if predicate.kind == ScanPredicateKind.Contains and range_ids_are_monotonic(range_ids):
        val kept = collect_brin_contains_rows_monotonic(range_ids, values, coarse_ranges, predicate.text_value, matched_rows)
        matched_rows = kept.rows
        scanned = kept.scanned
    else:
        match predicate.kind:
            case ScanPredicateKind.Eq:
                val kept = collect_brin_equal_rows(range_ids, values, allowed_ranges, predicate.text_value, matched_rows)
                matched_rows = kept.rows
                scanned = kept.scanned
            case ScanPredicateKind.Ne:
                val kept = collect_brin_not_equal_rows(range_ids, values, allowed_ranges, predicate.text_value, matched_rows)
                matched_rows = kept.rows
                scanned = kept.scanned
            case ScanPredicateKind.StartsWith:
                val kept = collect_brin_starts_with_rows(range_ids, values, allowed_ranges, predicate.text_value, matched_rows)
                matched_rows = kept.rows
                scanned = kept.scanned
            case ScanPredicateKind.EndsWith:
                val kept = collect_brin_ends_with_rows(range_ids, values, allowed_ranges, predicate.text_value, matched_rows)
                matched_rows = kept.rows
                scanned = kept.scanned
            case ScanPredicateKind.Contains:
                val kept = collect_brin_contains_rows(range_ids, values, allowed_ranges, predicate.text_value, matched_rows)
                matched_rows = kept.rows
                scanned = kept.scanned
            case ScanPredicateKind.ContainsToken:
                val kept = collect_brin_contains_token_rows(range_ids, values, allowed_ranges, predicate.text_value, matched_rows)
                matched_rows = kept.rows
                scanned = kept.scanned
            case ScanPredicateKind.Lt:
                val kept = collect_brin_lt_rows(range_ids, values, allowed_ranges, predicate.text_value, matched_rows)
                matched_rows = kept.rows
                scanned = kept.scanned
            case ScanPredicateKind.Le:
                val kept = collect_brin_le_rows(range_ids, values, allowed_ranges, predicate.text_value, matched_rows)
                matched_rows = kept.rows
                scanned = kept.scanned
            case ScanPredicateKind.Gt:
                val kept = collect_brin_gt_rows(range_ids, values, allowed_ranges, predicate.text_value, matched_rows)
                matched_rows = kept.rows
                scanned = kept.scanned
            case ScanPredicateKind.Ge:
                val kept = collect_brin_ge_rows(range_ids, values, allowed_ranges, predicate.text_value, matched_rows)
                matched_rows = kept.rows
                scanned = kept.scanned
    SpostgreScanResult(
        matched_rows: matched_rows,
        matched_ranges: coarse_ranges,
        filter_stats: make_filter_stats(scanned, matched_rows.len(), 0),
        batch_count: batch_count_for(values.len()),
        used_brin: true
    )

fn make_filter_stats(rows_scanned: i64, candidates_kept: i64, fallback_count: i64) -> FilterStats:
    FilterStats(
        rows_scanned: rows_scanned,
        candidates_kept: candidates_kept,
        bitmap_density: if rows_scanned == 0: 0.0 else: candidates_kept.to_float() / rows_scanned.to_float(),
        fallback_count: fallback_count
    )

struct BrinCollectResult:
    rows: [i64]
    scanned: i64

struct RangeSpan:
    start: i64
    end: i64

fn range_ids_are_monotonic(range_ids: [u32]) -> bool:
    var idx = 1
    while idx < range_ids.len():
        if range_ids[idx] < range_ids[idx - 1]:
            return false
        idx = idx + 1
    true

fn find_range_span_monotonic(range_ids: [u32], target: u32, start_hint: i64) -> RangeSpan?:
    var idx = start_hint
    while idx < range_ids.len():
        val current = range_ids[idx]
        if current >= target:
            break
        idx = idx + 1
    if idx >= range_ids.len():
        return None
    val current = range_ids[idx]
    if current != target:
        return None
    val start = idx
    while idx < range_ids.len():
        val span_value = range_ids[idx]
        if span_value != target:
            break
        idx = idx + 1
    Some(RangeSpan(start: start, end: idx))

fn text_has_query_trigram(doc: text, query: text, query_trigrams: [text]) -> bool:
    if query_trigrams.len() == 0:
        return false
    if query.len() < 3:
        return trigram_overlap_count(doc, query) > 0
    for trigram in query_trigrams:
        if doc.contains(trigram):
            return true
    false

fn collect_brin_equal_rows(range_ids: [u32], values: [text], allowed_ranges: RowBitmap,
                           needle: text, matched_rows: [i64]) -> BrinCollectResult:
    var rows = matched_rows
    var scanned = 0
    var row_idx = 0
    while row_idx < values.len():
        if allowed_ranges.get(range_ids[row_idx] as i64):
            scanned = scanned + 1
            if text_equals_span(values[row_idx], needle):
                rows.push(row_idx)
        row_idx = row_idx + 1
    BrinCollectResult(rows: rows, scanned: scanned)

fn collect_brin_not_equal_rows(range_ids: [u32], values: [text], allowed_ranges: RowBitmap,
                               needle: text, matched_rows: [i64]) -> BrinCollectResult:
    var rows = matched_rows
    var scanned = 0
    var row_idx = 0
    while row_idx < values.len():
        if allowed_ranges.get(range_ids[row_idx] as i64):
            scanned = scanned + 1
            if not text_equals_span(values[row_idx], needle):
                rows.push(row_idx)
        row_idx = row_idx + 1
    BrinCollectResult(rows: rows, scanned: scanned)

fn collect_brin_starts_with_rows(range_ids: [u32], values: [text], allowed_ranges: RowBitmap,
                                 needle: text, matched_rows: [i64]) -> BrinCollectResult:
    var rows = matched_rows
    var scanned = 0
    var row_idx = 0
    while row_idx < values.len():
        if allowed_ranges.get(range_ids[row_idx] as i64):
            scanned = scanned + 1
            if values[row_idx].starts_with(needle):
                rows.push(row_idx)
        row_idx = row_idx + 1
    BrinCollectResult(rows: rows, scanned: scanned)

fn collect_brin_ends_with_rows(range_ids: [u32], values: [text], allowed_ranges: RowBitmap,
                               needle: text, matched_rows: [i64]) -> BrinCollectResult:
    var rows = matched_rows
    var scanned = 0
    var row_idx = 0
    while row_idx < values.len():
        if allowed_ranges.get(range_ids[row_idx] as i64):
            scanned = scanned + 1
            if values[row_idx].ends_with(needle):
                rows.push(row_idx)
        row_idx = row_idx + 1
    BrinCollectResult(rows: rows, scanned: scanned)

fn collect_brin_contains_rows(range_ids: [u32], values: [text], allowed_ranges: RowBitmap,
                              needle: text, matched_rows: [i64]) -> BrinCollectResult:
    var rows = matched_rows
    var scanned = 0
    var cached_range_id = 0u32
    var cached_allowed = false
    var has_cached_range = false
    var row_idx = 0
    while row_idx < values.len():
        val range_id = range_ids[row_idx]
        if not has_cached_range or range_id != cached_range_id:
            cached_range_id = range_id
            cached_allowed = allowed_ranges.get(range_id as i64)
            has_cached_range = true
        if cached_allowed:
            scanned = scanned + 1
            if values[row_idx].contains(needle):
                rows.push(row_idx)
        row_idx = row_idx + 1
    BrinCollectResult(rows: rows, scanned: scanned)

fn collect_brin_contains_rows_monotonic(range_ids: [u32], values: [text], coarse_ranges: [u32],
                                        needle: text, matched_rows: [i64]) -> BrinCollectResult:
    var rows = matched_rows
    var scanned = 0
    var search_start = 0
    for range_id in coarse_ranges:
        if val Some(span) = find_range_span_monotonic(range_ids, range_id, search_start):
            search_start = span.end
            var row_idx = span.start
            while row_idx < span.end:
                scanned = scanned + 1
                if values[row_idx].contains(needle):
                    rows.push(row_idx)
                row_idx = row_idx + 1
    BrinCollectResult(rows: rows, scanned: scanned)

fn collect_brin_contains_token_rows(range_ids: [u32], values: [text], allowed_ranges: RowBitmap,
                                    needle: text, matched_rows: [i64]) -> BrinCollectResult:
    var rows = matched_rows
    var scanned = 0
    var row_idx = 0
    while row_idx < values.len():
        if allowed_ranges.get(range_ids[row_idx] as i64):
            scanned = scanned + 1
            if text_contains_token(values[row_idx], needle):
                rows.push(row_idx)
        row_idx = row_idx + 1
    BrinCollectResult(rows: rows, scanned: scanned)

fn collect_brin_lt_rows(range_ids: [u32], values: [text], allowed_ranges: RowBitmap,
                        needle: text, matched_rows: [i64]) -> BrinCollectResult:
    var rows = matched_rows
    var scanned = 0
    var row_idx = 0
    while row_idx < values.len():
        if allowed_ranges.get(range_ids[row_idx] as i64):
            scanned = scanned + 1
            if values[row_idx] < needle:
                rows.push(row_idx)
        row_idx = row_idx + 1
    BrinCollectResult(rows: rows, scanned: scanned)

fn collect_brin_le_rows(range_ids: [u32], values: [text], allowed_ranges: RowBitmap,
                        needle: text, matched_rows: [i64]) -> BrinCollectResult:
    var rows = matched_rows
    var scanned = 0
    var row_idx = 0
    while row_idx < values.len():
        if allowed_ranges.get(range_ids[row_idx] as i64):
            scanned = scanned + 1
            if values[row_idx] <= needle:
                rows.push(row_idx)
        row_idx = row_idx + 1
    BrinCollectResult(rows: rows, scanned: scanned)

fn collect_brin_gt_rows(range_ids: [u32], values: [text], allowed_ranges: RowBitmap,
                        needle: text, matched_rows: [i64]) -> BrinCollectResult:
    var rows = matched_rows
    var scanned = 0
    var row_idx = 0
    while row_idx < values.len():
        if allowed_ranges.get(range_ids[row_idx] as i64):
            scanned = scanned + 1
            if values[row_idx] > needle:
                rows.push(row_idx)
        row_idx = row_idx + 1
    BrinCollectResult(rows: rows, scanned: scanned)

fn collect_brin_ge_rows(range_ids: [u32], values: [text], allowed_ranges: RowBitmap,
                        needle: text, matched_rows: [i64]) -> BrinCollectResult:
    var rows = matched_rows
    var scanned = 0
    var row_idx = 0
    while row_idx < values.len():
        if allowed_ranges.get(range_ids[row_idx] as i64):
            scanned = scanned + 1
            if values[row_idx] >= needle:
                rows.push(row_idx)
        row_idx = row_idx + 1
    BrinCollectResult(rows: rows, scanned: scanned)
