# spostgre engine — checkpointer.
#
# Writes a checkpoint record to the WAL, waits for it to become durable,
# then publishes the new checkpoint superblock entry.

use std.spostgre_if.types.{Lsn}

struct CheckpointState:
    """Current checkpoint in flight."""
    started_at: i64
    target_lsn: i64
    committed: bool

fn checkpoint_begin() -> Lsn:
    """Start a checkpoint; returns the LSN that must be made durable first."""
