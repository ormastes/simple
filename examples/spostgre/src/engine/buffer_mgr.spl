# spostgre engine — buffer pool / BufferManager impl.
#
# Pins pages in memory; tracks dirty state; evicts via clock-sweep.
# Concrete impl of std.spostgre_if.storage_api.BufferManager.
# M4: TierCache (L2 NVMe) wired at eviction and fault paths.

use std.spostgre_if.types.{Rel, BlkNo}
use std.spostgre_if.storage_api.{PageBuf}
use engine.page.{PageHeader}
use engine.tier_cache.{TierCache, tier_cache_new, tier_cache_put,
                        tier_cache_get, tier_cache_invalidate}

# ---------------------------------------------------------------------------
# Free-space accounting helpers (FR-HOT-001).
# ---------------------------------------------------------------------------

# Size of one ItemIdData / line-pointer entry (4 bytes, standard PG layout).
val LINE_POINTER_SIZE: i32 = 4

fn page_slack(hdr: PageHeader) -> i32:
    """Return the free bytes on a page: upper - lower.

    upper = start of tuple heap (byte offset, grows down).
    lower = end of line-pointer array (byte offset, grows up).
    Free space is the gap between them.
    @coverage: spostgre_design.md §4.2
    """
    hdr.upper - hdr.lower

struct BufferSlot:
    """One frame in the buffer pool."""
    rel_id: i64
    blk: i64
    pin_count: i32
    dirty: bool
    generation: i64

struct BufferPool:
    """Fixed-size frame table.

    M4 additions:
      tier  — L2 NVMe cache (DB_TEMP arena, ephemeral).
      disk_reads — count of falls-through to durable storage; useful in tests.
    """
    slots:      [BufferSlot]
    capacity:   i32
    tier:       TierCache
    disk_reads: i64

    static fn new(capacity: i32) -> BufferPool:
        BufferPool(slots: [], capacity: capacity,
                   tier: tier_cache_new(), disk_reads: 0)

fn buf_get(pool: BufferPool, rel: Rel, blk: BlkNo) -> PageBuf:
    """Pin (rel, blk); load from arena if missing.

    Fault path (M4 hook):
      1. Check L2 TierCache — if hit, serve from NVMe cache (no disk I/O).
      2. Otherwise fall through to durable storage (disk_reads counter bumped).
    """
    # M4 fault hook — L2 check before durable read.
    val cached = tier_cache_get(pool.tier, rel.id, blk.n)
    if cached.len() > 0:
        return PageBuf(
            arena_id: pool.tier.arena_handle,
            offset: 0,
            length: cached.len() as i64,
            generation: 0)
    # L2 miss: no durable page store is wired into this example buffer pool yet.
    # disk_reads increment omitted because pool is immutable here;
    # a real impl would return (PageBuf, BufferPool) or use interior mutability.
    PageBuf(arena_id: -1, offset: 0, length: 0, generation: 0)

fn buf_evict(pool: BufferPool, slot: BufferSlot) -> BufferPool:
    """Evict a clean slot to L2 NVMe cache (M4 eviction hook).

    Dirty pages must be flushed to WAL / durable storage first; this function
    is only called for clean (unmodified) slots. The page bytes are written to
    the TierCache so a subsequent fault can be served from L2.
    """
    if slot.dirty:
        # Dirty: caller must write-back to durable storage then call
        # tier_cache_invalidate. Do not cache here.
        return pool
    # Clean eviction — write to L2.
    # Byte content is not yet available (buf_get is pass_todo); placeholder.
    val placeholder: [u8] = []
    val new_tier = tier_cache_put(pool.tier, slot.rel_id, slot.blk, placeholder)
    BufferPool(slots: pool.slots, capacity: pool.capacity,
               tier: new_tier, disk_reads: pool.disk_reads)

fn buf_prefetch(pool: BufferPool, rel: Rel, blk: BlkNo) -> bool:
    """Fire-and-forget prefetch."""
    val cached = tier_cache_get(pool.tier, rel.id, blk.n)
    cached.len() > 0
