# spostgre engine — page-indirection map (blk -> PhysPtr).
#
# Publishes new page versions atomically. Uses capability-gated
# CompareAndWrite path when available (see storage.capability), plain
# write-once-new-entry otherwise.

use std.spostgre_if.types.{Rel, BlkNo, PhysPtr, Lsn}

struct PmapEntry:
    """One pmap row: (rel, blk) -> physptr at generation."""
    rel_id: i64
    blk: i64
    arena_id: i64
    offset: i64
    generation: i64

fn pmap_lookup(rel: Rel, blk: BlkNo) -> PhysPtr:
    """Look up the current physical pointer for (rel, blk)."""
    pass_todo

fn pmap_publish(rel: Rel, blk: BlkNo, phys: PhysPtr, wal_lsn: Lsn) -> bool:
    """Atomically bind (rel, blk) -> phys. Must be ordered after WAL flush."""
    # @coverage: spostgre_design.md §6.5 (WAL-before-publish invariant)
    pass_todo
