# spostgre engine — transaction manager.
#
# Mints TxnIds, tracks active set, drives commit / abort.

use std.spostgre_if.types.{TxnId, Lsn}

struct TxnRecord:
    """One in-memory transaction."""
    id: i64
    start_lsn: i64
    commit_lsn: i64
    committed: bool

struct TxnManager:
    """Active transaction table."""
    next_id: i64
    active: [TxnRecord]

    static fn new() -> TxnManager:
        TxnManager(next_id: 1, active: [])

fn txn_begin(mgr: TxnManager) -> TxnId:
    """Allocate a new TxnId and record start_lsn."""
    pass_todo

fn txn_commit(mgr: TxnManager, txn: TxnId, commit_lsn: Lsn) -> bool:
    """Mark txn committed once WAL flush has reached commit_lsn."""
    pass_todo

fn txn_abort(mgr: TxnManager, txn: TxnId) -> bool:
    """Drop any pending intent records for txn."""
    pass_todo

pub fn oldest_running_xmin(mgr: TxnManager) -> i64:
    """Return the minimum xid of all currently-active transactions.

    If no transactions are active, returns mgr.next_id (i.e. the next xid
    that will be minted, meaning all committed work is visible to vacuum).
    @coverage: spostgre_design.md §vacuum (M5)
    """
    val n = mgr.active.len()
    if n == 0:
        return mgr.next_id
    var min_xid = mgr.active[0].id
    var i = 1
    while i < n:
        val xid = mgr.active[i].id
        if xid < min_xid:
            min_xid = xid
        i = i + 1
    min_xid
