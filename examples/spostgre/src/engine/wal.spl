# spostgre engine — WAL writer.
#
# Writes to a DB_WAL-class arena. The WalWriter trait contract lives in
# std.spostgre_if.storage_api; this file provides the concrete impl stubs.

use std.spostgre_if.types.{Lsn, TxnId}

struct WalState:
    """In-memory WAL writer state."""
    arena_id: i64
    next_lsn: i64
    durable_lsn: i64

    static fn new(arena_id: i64) -> WalState:
        WalState(arena_id: arena_id, next_lsn: 1, durable_lsn: 0)

fn wal_append(state: WalState, txn: TxnId, payload: [u8]) -> Lsn:
    """Append a WAL record; return its assigned LSN."""
    # @coverage: spostgre_design.md §6.3
    pass_todo

fn wal_flush_to(state: WalState, target: Lsn) -> bool:
    """Force-flush WAL such that durable_lsn >= target."""
