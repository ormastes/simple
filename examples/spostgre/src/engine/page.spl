# spostgre engine — page header + slot directory.
#
# On-disk page format follows spostgre_design.md §4 (logical-page scope).
# Real encoder / decoder arrives in Phase 6+.

struct PageHeader:
    """Fixed-size page header.

    Fields:
      lsn                 — LSN of the WAL record that last modified this page.
      checksum            — CRC32C over page body.
      flags               — bit field (see flag constants below).
      lower               — free-space low-water (end of slot directory).
      upper               — free-space high-water (start of tuple area).
      special             — page-type-specific tail offset.
      generation          — CoW generation, bumped per page_rewrite.
    """
    lsn: i64
    checksum: i32
    flags: i32
    lower: i32
    upper: i32
    special: i32
    generation: i64

struct SlotPointer:
    """One row in the slot directory."""
    offset: i32
    length: i32

fn page_init(buf: [u8]) -> PageHeader:
