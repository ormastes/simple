    # @coverage: spostgre_design.md §4
    pass_todo

fn page_decode_header(buf: [u8]) -> PageHeader:
    """Decode the header from a page buffer."""
    pass_todo

fn page_encode_header(buf: [u8], hdr: PageHeader) -> bool:
    """Encode a header back into the page buffer."""
    pass_todo
