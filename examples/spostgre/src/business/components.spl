# spostgre business — 11 POD components.
#
# Per spostgre_design.md §3.1. Each component is a plain-data struct
# attached to an ECS entity by std.ecs.ComponentStore<T>.

struct Relation:
    """A logical relation; one ECS entity per open relation."""
    rel_id: i64
    name_off: i32
    name_len: i32
    namespace_id: i64

struct PageDescriptor:
    """A loaded page frame; attaches to the owning relation entity."""
    rel_id: i64
    blk: i64
    generation: i64
    dirty: bool

struct Tuple:
    """A tuple / row row-header inside a page."""
    rel_id: i64
    blk: i64
    slot: i32
    xmin: i64
    xmax: i64

struct WalRecord:
    """An unpublished WAL record in flight."""
    txn_id: i64
    lsn: i64
    payload_off: i64
    payload_len: i64

struct Txn:
    """An active transaction."""
    txn_id: i64
    start_lsn: i64
    commit_lsn: i64
    committed: bool

struct Checkpoint:
    """A checkpoint in flight or just committed."""
    started_at: i64
    target_lsn: i64
    committed: bool

struct VacuumTask:
    """A vacuum task queued or running."""
    rel_id: i64
    lo_blk: i64
    hi_blk: i64
    bytes_freed: i64

struct BufferFrame:
    """A buffer-pool frame component, attached per-frame entity."""
    rel_id: i64
    blk: i64
    pin_count: i32
    last_used_tick: i64

struct PmapBinding:
    """An atomically-publishable (rel, blk) -> PhysPtr row."""
    rel_id: i64
    blk: i64
    arena_id: i64
    offset: i64
    generation: i64

struct BlobRef:
    """A reference to a large-value blob in MODEL_IMMUTABLE / GENERAL_MUTABLE."""
    rel_id: i64
    arena_id: i64
    offset: i64
    length: i64

struct CapabilityView:
    """A cached snapshot of the CapabilityProbe result at mount."""
    has_zns: bool
    has_fdp: bool
    has_cmb: bool
    has_pmr: bool
    has_flush: bool
    has_fua: bool
    has_cmp_and_write: bool
    has_multi_atomicity: bool
    has_copy_offload: bool
    has_dataset_mgmt: bool
