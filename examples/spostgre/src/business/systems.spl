# spostgre business — 8 systems.
#
# Per spostgre_design.md §3.1. Each system is a free function the scheduler
# calls on each tick. Bodies are stubs — real logic arrives post-Phase-5.
#
# System order matters: sys_wal_flush MUST run before sys_pmap_publish
# within the same commit (see spostgre_design.md §6.5).

fn sys_commit(ctx_ptr: u64, tick: i64):
    """Drive pending Txn entities to committed state (wal flush + pmap publish)."""
