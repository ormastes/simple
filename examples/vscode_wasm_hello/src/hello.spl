# Hello World - Simple to WASM example
#
# Exports functions callable from JavaScript via WebAssembly.
# Compiled with: bin/simple build --target wasm32-standalone

# Exported: returns a greeting message length (WASM can't return strings directly)
fn hello() -> Int:
    return 42

# Exported: simple addition
fn add(a: Int, b: Int) -> Int:
    return a + b

# Exported: factorial computation
fn factorial(n: Int) -> Int:
    if n <= 1:
        return 1
    var result = 1
    var i = 2
    while i <= n:
        result = result * i
        i = i + 1
    return result
