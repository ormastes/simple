# WASM Hello World - Build Configuration
#
# Compile Simple source to standalone WASM for VSCode webview.

project:
    name: "vscode_wasm_hello"
    version: "0.1.0"
    description: "Hello World: Simple compiled to WASM running in VSCode webview"

target:
    preset: "wasm32-standalone"
    output: "extension/wasm/hello.wasm"

source:
    entry: "src/hello.spl"
    include:
        - "src/"

exports:
    - "hello"
    - "add"
    - "factorial"
