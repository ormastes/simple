#!/bin/sh
# Run VSCode extension tests headlessly using xvfb
# Usage: sh scripts/run_tests.shs
# In devcontainer, Xvfb is already running on :99

set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
EXT_DIR="$PROJECT_DIR/extension"

echo "=== Building extension ==="
cd "$EXT_DIR"
npm run compile

echo "=== Running tests ==="
if [ -n "$DISPLAY" ]; then
    # Display already available (devcontainer or desktop)
    npm test
else
    # Headless: use xvfb-run
    xvfb-run -a npm test
fi

echo "=== Tests complete ==="
