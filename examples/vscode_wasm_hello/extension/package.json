{
  "name": "simple-wasm-hello",
  "displayName": "Simple WASM Hello World",
  "description": "Minimal example: Simple language compiled to WASM running in a VSCode webview",
  "version": "0.1.0",
  "publisher": "simple-lang",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "simpleWasmHello.showPanel",
        "title": "Simple WASM Hello: Show Panel"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "vscode-test",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/vscode": "^1.80.0",
    "@types/node": "^20.10.0",
    "@vscode/test-cli": "^0.0.4",
    "@vscode/test-electron": "^2.5.2",
    "mocha": "^10.8.2",
    "typescript": "^5.3.3"
  }
}
