# shared/web_security — Common web security library
#
# Provides: user auth, session management, rate limiting,
# CSRF protection, input sanitization, content safety filter,
# and security event logging.

# ============================================================================
# User Storage (parallel arrays + manual counter)
# ============================================================================

var WS_USER_IDS: [text] = []
var WS_USER_NAMES: [text] = []
var WS_USER_HASHES: [text] = []
var WS_USER_ROLES: [text] = []
var WS_USER_ACTIVE: [bool] = []
var WS_USER_COUNT = 0

fn ws_init():
    WS_USER_IDS = []
    WS_USER_NAMES = []
    WS_USER_HASHES = []
    WS_USER_ROLES = []
    WS_USER_ACTIVE = []
    WS_USER_COUNT = 0
    WS_SESSION_IDS = []
    WS_SESSION_USERS = []
    WS_SESSION_EXPIRES = []
    WS_SESSION_COUNT = 0
    WS_RATE_IPS = []
    WS_RATE_COUNTS = []
    WS_RATE_WINDOWS = []
    WS_RATE_COUNT = 0
    WS_CSRF_TOKENS = []
    WS_CSRF_COUNT = 0
    WS_LOG_ENTRIES = []
    WS_LOG_COUNT = 0

# ============================================================================
# Password Hashing (simple hash for demo — production would use bcrypt via FFI)
# ============================================================================

fn _simple_hash(password: text) -> text:
    # Simple string-based hash for demonstration
    # In production, use rt_process_run to call bcrypt/argon2
    var hash_val = 5381
    var i = 0
    while i < password.len():
        val ch = password[i:i + 1]
        # Simple DJB2-like hash using char position
        hash_val = hash_val * 33 + i + password.len()
        i = i + 1
    var tmp = hash_val
    "hash_" + tmp.to_text() + "_" + password.len().to_text()

fn _verify_hash(password: text, hash: text) -> bool:
    val computed = _simple_hash(password)
    computed == hash

# ============================================================================
# Auth: Register + Login
# ============================================================================

fn auth_register(username: text, password: text) -> (bool, text):
    # Check if username already exists
    var i = 0
    while i < WS_USER_COUNT:
        if WS_USER_NAMES[i] == username:
            return (false, "username_exists")
        i = i + 1
    # Validate
    if username.len() < 3:
        return (false, "username_too_short")
    if password.len() < 6:
        return (false, "password_too_short")
    # Register
    var tmp_count = WS_USER_COUNT
    val user_id = "user_" + tmp_count.to_text()
    val hash = _simple_hash(password)
    WS_USER_IDS = WS_USER_IDS + [user_id]
    WS_USER_NAMES = WS_USER_NAMES + [username]
    WS_USER_HASHES = WS_USER_HASHES + [hash]
    WS_USER_ROLES = WS_USER_ROLES + ["user"]
    WS_USER_ACTIVE = WS_USER_ACTIVE + [true]
    WS_USER_COUNT = WS_USER_COUNT + 1
    ws_log("register", username, "", "User registered")
    (true, user_id)

fn auth_login(username: text, password: text) -> (bool, text):
    var i = 0
    while i < WS_USER_COUNT:
        if WS_USER_NAMES[i] == username:
            if not WS_USER_ACTIVE[i]:
                ws_log("failed_login", username, "", "Account disabled")
                return (false, "account_disabled")
            if _verify_hash(password, WS_USER_HASHES[i]):
                # Create session
                val session_id = _generate_token(username)
                _session_create(session_id, username)
                ws_log("login", username, "", "Login successful")
                return (true, session_id)
            ws_log("failed_login", username, "", "Wrong password")
            return (false, "wrong_password")
        i = i + 1
    ws_log("failed_login", username, "", "User not found")
    (false, "user_not_found")

fn auth_find_user(username: text) -> i64:
    var i = 0
    while i < WS_USER_COUNT:
        if WS_USER_NAMES[i] == username:
            return i
        i = i + 1
    -1

# ============================================================================
# Session Management
# ============================================================================

var WS_SESSION_IDS: [text] = []
var WS_SESSION_USERS: [text] = []
var WS_SESSION_EXPIRES: [i64] = []
var WS_SESSION_COUNT = 0

fn _generate_token(seed: text) -> text:
    var hash = 7919
    var i = 0
    while i < seed.len():
        hash = hash * 31 + i
        i = i + 1
    var tmp_count = WS_SESSION_COUNT
    var tmp_hash = hash
    "sess_" + tmp_hash.to_text() + "_" + tmp_count.to_text()

fn _session_create(session_id: text, username: text):
    WS_SESSION_IDS = WS_SESSION_IDS + [session_id]
    WS_SESSION_USERS = WS_SESSION_USERS + [username]
    WS_SESSION_EXPIRES = WS_SESSION_EXPIRES + [0]  # 0 = no expiry for demo
    WS_SESSION_COUNT = WS_SESSION_COUNT + 1

fn session_validate(session_id: text) -> (bool, text):
    # Returns (valid, username)
    var i = 0
    while i < WS_SESSION_COUNT:
        if WS_SESSION_IDS[i] == session_id:
            return (true, WS_SESSION_USERS[i])
        i = i + 1
    (false, "")

fn session_destroy(session_id: text) -> bool:
    var i = 0
    while i < WS_SESSION_COUNT:
        if WS_SESSION_IDS[i] == session_id:
            val user = WS_SESSION_USERS[i]
            WS_SESSION_IDS[i] = ""
            WS_SESSION_USERS[i] = ""
            ws_log("logout", user, "", "Session destroyed")
            return true
        i = i + 1
    false

fn session_get_cookie(session_id: text) -> text:
    "session_id=" + session_id + "; Path=/; HttpOnly; SameSite=Strict; Max-Age=86400"

# ============================================================================
# Rate Limiter (sliding window counter)
# ============================================================================

var WS_RATE_IPS: [text] = []
var WS_RATE_COUNTS: [i64] = []
var WS_RATE_WINDOWS: [i64] = []
var WS_RATE_COUNT = 0

fn rate_check(ip: text, max_requests: i64) -> bool:
    # Returns true if request is allowed
    var i = 0
    while i < WS_RATE_COUNT:
        if WS_RATE_IPS[i] == ip:
            if WS_RATE_COUNTS[i] >= max_requests:
                ws_log("rate_limited", "", ip, "Rate limit exceeded")
                return false
            WS_RATE_COUNTS[i] = WS_RATE_COUNTS[i] + 1
            return true
        i = i + 1
    # New IP
    WS_RATE_IPS = WS_RATE_IPS + [ip]
    WS_RATE_COUNTS = WS_RATE_COUNTS + [1]
    WS_RATE_WINDOWS = WS_RATE_WINDOWS + [0]
    WS_RATE_COUNT = WS_RATE_COUNT + 1
    true

fn rate_reset(ip: text):
    var i = 0
    while i < WS_RATE_COUNT:
        if WS_RATE_IPS[i] == ip:
            WS_RATE_COUNTS[i] = 0
            return
        i = i + 1

fn rate_reset_all():
    var i = 0
    while i < WS_RATE_COUNT:
        WS_RATE_COUNTS[i] = 0
        i = i + 1

# ============================================================================
# CSRF Protection
# ============================================================================

var WS_CSRF_TOKENS: [text] = []
var WS_CSRF_COUNT = 0

fn csrf_generate(session_id: text) -> text:
    var hash = 1337
    var i = 0
    while i < session_id.len():
        hash = hash * 37 + i
        i = i + 1
    var tmp_count = WS_CSRF_COUNT
    var tmp_hash = hash
    val token = "csrf_" + tmp_hash.to_text() + "_" + tmp_count.to_text()
    WS_CSRF_TOKENS = WS_CSRF_TOKENS + [token]
    WS_CSRF_COUNT = WS_CSRF_COUNT + 1
    token

fn csrf_validate(token: text) -> bool:
    var i = 0
    while i < WS_CSRF_COUNT:
        if WS_CSRF_TOKENS[i] == token:
            # One-time use: invalidate after validation
            WS_CSRF_TOKENS[i] = ""
            return true
        i = i + 1
    false

# ============================================================================
# Input Sanitizer (XSS Prevention)
# ============================================================================

fn sanitize_html(input: text) -> text:
    # Escape HTML special characters
    var result: [text] = []
    var i = 0
    while i < input.len():
        val ch = input[i:i + 1]
        if ch == "<":
            result.push("&lt;")
        elif ch == ">":
            result.push("&gt;")
        elif ch == "&":
            result.push("&amp;")
        elif ch == "\"":
            result.push("&quot;")
        elif ch == "'":
            result.push("&#39;")
        else:
            result.push(ch)
        i = i + 1
    result.join("")

fn sanitize_filename(input: text) -> text:
    # Remove path traversal and dangerous chars
    var result: [text] = []
    var i = 0
    while i < input.len():
        val ch = input[i:i + 1]
        val is_dangerous = (ch == "/" or ch == "\\" or ch == "." or ch == "~" or ch == "<" or ch == ">" or ch == "|" or ch == ":" or ch == "*" or ch == "?")
        if not is_dangerous:
            result.push(ch)
        i = i + 1
    val sanitized = result.join("")
    if sanitized == "":
        return "unnamed"
    sanitized

# ============================================================================
# AI Content Safety Filter
# ============================================================================

var BLOCKED_TERMS: [text] = []
var BLOCKED_COUNT = 0

fn content_filter_init():
    BLOCKED_TERMS = []
    BLOCKED_COUNT = 0
    # Add blocked terms/patterns for AI image generation abuse prevention
    _add_blocked("nude")
    _add_blocked("naked")
    _add_blocked("nsfw")
    _add_blocked("explicit")
    _add_blocked("violence")
    _add_blocked("weapon")
    _add_blocked("drug")
    _add_blocked("child")
    _add_blocked("minor")
    _add_blocked("deepfake")
    _add_blocked("fake id")
    _add_blocked("passport")
    _add_blocked("without consent")

fn _add_blocked(term: text):
    BLOCKED_TERMS = BLOCKED_TERMS + [term]
    BLOCKED_COUNT = BLOCKED_COUNT + 1

fn content_is_safe(prompt: text) -> (bool, text):
    # Check prompt against blocked terms
    val lower_prompt = prompt.to_lower()
    var i = 0
    while i < BLOCKED_COUNT:
        val term = BLOCKED_TERMS[i]
        if lower_prompt.contains(term):
            ws_log("content_blocked", "", "", "Blocked term: " + term)
            return (false, term)
        i = i + 1
    (true, "")

fn content_check_image_request(face_path: text, options: text) -> (bool, text):
    # Validate image generation request
    if face_path == "":
        return (false, "missing_face_image")
    val safe = content_is_safe(options)
    if not safe.0:
        return (false, "blocked_content")
    (true, "")

# ============================================================================
# Security Event Logger
# ============================================================================

var WS_LOG_ENTRIES: [text] = []
var WS_LOG_COUNT = 0

fn ws_log(event_type: text, username: text, ip: text, details: text):
    val entry = "[" + event_type + "] user=" + username + " ip=" + ip + " " + details
    WS_LOG_ENTRIES = WS_LOG_ENTRIES + [entry]
    WS_LOG_COUNT = WS_LOG_COUNT + 1

fn ws_log_text() -> text:
    if WS_LOG_COUNT == 0:
        return "  (no security events)"
    var parts: [text] = []
    var i = 0
    while i < WS_LOG_COUNT:
        parts.push("  " + WS_LOG_ENTRIES[i])
        i = i + 1
    parts.join("\n")

# ============================================================================
# Security Error Messages (i18n)
# ============================================================================

fn security_error_msg(code: text, lang: text) -> text:
    if lang == "ko":
        if code == "username_exists":
            return "이미 사용 중인 사용자 이름입니다."
        elif code == "username_too_short":
            return "사용자 이름은 3자 이상이어야 합니다."
        elif code == "password_too_short":
            return "비밀번호는 6자 이상이어야 합니다."
        elif code == "wrong_password":
            return "비밀번호가 올바르지 않습니다."
        elif code == "user_not_found":
            return "사용자를 찾을 수 없습니다."
        elif code == "account_disabled":
            return "계정이 비활성화되었습니다."
        elif code == "rate_limited":
            return "요청이 너무 많습니다. 잠시 후 다시 시도해주세요."
        elif code == "csrf_invalid":
            return "보안 토큰이 유효하지 않습니다."
        elif code == "unauthorized":
            return "로그인이 필요합니다."
        elif code == "blocked_content":
            return "부적절한 콘텐츠가 감지되었습니다."
        elif code == "missing_face_image":
            return "얼굴 사진이 필요합니다."
        return "알 수 없는 오류가 발생했습니다."
    elif lang == "ja":
        if code == "username_exists":
            return "このユーザー名は既に使用されています。"
        elif code == "username_too_short":
            return "ユーザー名は3文字以上である必要があります。"
        elif code == "password_too_short":
            return "パスワードは6文字以上である必要があります。"
        elif code == "wrong_password":
            return "パスワードが正しくありません。"
        elif code == "user_not_found":
            return "ユーザーが見つかりません。"
        elif code == "account_disabled":
            return "アカウントが無効化されています。"
        elif code == "rate_limited":
            return "リクエストが多すぎます。しばらくしてから再試行してください。"
        elif code == "csrf_invalid":
            return "セキュリティトークンが無効です。"
        elif code == "unauthorized":
            return "ログインが必要です。"
        elif code == "blocked_content":
            return "不適切なコンテンツが検出されました。"
        elif code == "missing_face_image":
            return "顔写真が必要です。"
        return "不明なエラーが発生しました。"
    # English (default)
    if code == "username_exists":
        return "Username already taken."
    elif code == "username_too_short":
        return "Username must be at least 3 characters."
    elif code == "password_too_short":
        return "Password must be at least 6 characters."
    elif code == "wrong_password":
        return "Incorrect password."
    elif code == "user_not_found":
        return "User not found."
    elif code == "account_disabled":
        return "Account is disabled."
    elif code == "rate_limited":
        return "Too many requests. Please try again later."
    elif code == "csrf_invalid":
        return "Invalid security token."
    elif code == "unauthorized":
        return "Login required."
    elif code == "blocked_content":
        return "Inappropriate content detected."
    elif code == "missing_face_image":
        return "Face photo is required."
    "An unknown error occurred."
