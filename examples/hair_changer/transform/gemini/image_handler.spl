# transform/gemini/image_handler — Call Gemini CLI with images

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_file_exists(path: text) -> bool

var GEMINI_MODEL = "gemini-2.5-flash-preview-image-generation"
var GEMINI_CLI_PATH = "gemini"

fn gemini_set_model(model: text):
    GEMINI_MODEL = model

fn gemini_set_cli(path: text):
    GEMINI_CLI_PATH = path

fn gemini_generate_hair(face_path: text, hair_ref_path: text,
                        prompt: text, output_path: text) -> (bool, text):
    # Call gemini CLI with images
    if not rt_file_exists(face_path):
        return (false, "Face image not found: " + face_path)
    if not rt_file_exists(hair_ref_path):
        return (false, "Hair reference image not found: " + hair_ref_path)

    var cmd = GEMINI_CLI_PATH
    var args: [text] = []
    args = args + ["--sandbox", "off"]
    args = args + ["-p", prompt]
    args = args + ["--model", GEMINI_MODEL]

    # Pass image files as arguments
    args = args + ["--file", face_path]
    args = args + ["--file", hair_ref_path]

    val result = rt_process_run(cmd, args)
    val stdout = result.0 ?? ""
    val stderr = result.1 ?? ""
    val exit_code = result.2

    if exit_code != 0:
        var err = "Gemini CLI error (code " + exit_code.to_text() + ")"
        if stderr != "":
            err = err + ": " + stderr
        return (false, err)

    # The output should contain the generated image data or path
    (true, stdout)
