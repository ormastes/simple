# feature/gallery/presets — Load and list gallery presets

var GALLERY_IDS: [text] = []
var GALLERY_NAMES_KO: [text] = []
var GALLERY_NAMES_EN: [text] = []
var GALLERY_NAMES_JA: [text] = []
var GALLERY_CATEGORIES: [text] = []
var GALLERY_THUMBNAILS: [text] = []
var GALLERY_OPTIONS: [text] = []
var GALLERY_COUNT = 0

fn gallery_init():
    GALLERY_IDS = []
    GALLERY_NAMES_KO = []
    GALLERY_NAMES_EN = []
    GALLERY_NAMES_JA = []
    GALLERY_CATEGORIES = []
    GALLERY_THUMBNAILS = []
    GALLERY_OPTIONS = []
    GALLERY_COUNT = 0

fn gallery_add(id: text, name_ko: text, name_en: text, name_ja: text,
               category: text, thumbnail: text, options: text):
    GALLERY_IDS = GALLERY_IDS + [id]
    GALLERY_NAMES_KO = GALLERY_NAMES_KO + [name_ko]
    GALLERY_NAMES_EN = GALLERY_NAMES_EN + [name_en]
    GALLERY_NAMES_JA = GALLERY_NAMES_JA + [name_ja]
    GALLERY_CATEGORIES = GALLERY_CATEGORIES + [category]
    GALLERY_THUMBNAILS = GALLERY_THUMBNAILS + [thumbnail]
    GALLERY_OPTIONS = GALLERY_OPTIONS + [options]
    GALLERY_COUNT = GALLERY_COUNT + 1

fn gallery_load_defaults():
    gallery_init()
    gallery_add("short_bob", "단발 보브", "Short Bob", "ショートボブ", "short", "gallery/short_bob.jpg", "target_length=short,hair_type=straight,bangs=none")
    gallery_add("korean_bangs", "커튼뱅", "Curtain Bangs", "カーテンバング", "medium", "gallery/korean_bangs.jpg", "target_length=medium,hair_type=straight,bangs=curtain")
    gallery_add("long_waves", "롱 웨이브", "Long Waves", "ロングウェーブ", "long", "gallery/long_waves.jpg", "target_length=long,hair_type=wavy,bangs=none")
    gallery_add("pixie_cut", "픽시컷", "Pixie Cut", "ピクシーカット", "short", "gallery/pixie_cut.jpg", "target_length=short,hair_type=straight,volume=thin")
    gallery_add("layered_medium", "레이어드 미디엄", "Layered Medium", "レイヤードミディアム", "medium", "gallery/layered_medium.jpg", "target_length=medium,hair_type=straight,volume=thick")
    gallery_add("curtain_bangs_long", "롱 커튼뱅", "Long Curtain Bangs", "ロングカーテンバング", "long", "gallery/curtain_bangs_long.jpg", "target_length=long,bangs=curtain")
    gallery_add("platinum_blonde", "플래티넘 블론드", "Platinum Blonde", "プラチナブロンド", "color", "gallery/platinum_blonde.jpg", "color=platinum,dye=true")
    gallery_add("ash_brown", "애쉬 브라운", "Ash Brown", "アッシュブラウン", "color", "gallery/ash_brown.jpg", "color=ash_brown,dye=true")
    gallery_add("red_highlights", "레드 하이라이트", "Red Highlights", "レッドハイライト", "color", "gallery/red_highlights.jpg", "color=red,treatment=highlights,dye=true")
    gallery_add("natural_perm", "내추럴 펌", "Natural Perm", "ナチュラルパーマ", "perm", "gallery/natural_perm.jpg", "hair_type=wavy,perm=true")
    gallery_add("digital_perm", "디지털 펌", "Digital Perm", "デジタルパーマ", "perm", "gallery/digital_perm.jpg", "hair_type=curly,perm=true,volume=thick")
    gallery_add("two_block", "투블럭", "Two Block", "ツーブロック", "short", "gallery/two_block.jpg", "target_length=short,volume=thick")

fn gallery_to_json(lang: text) -> text:
    var q = "\""
    var items: [text] = []
    var i = 0
    while i < GALLERY_COUNT:
        var name = GALLERY_NAMES_EN[i]
        if lang == "ko":
            name = GALLERY_NAMES_KO[i]
        elif lang == "ja":
            name = GALLERY_NAMES_JA[i]
        val item = "{" + q + "id" + q + ":" + q + GALLERY_IDS[i] + q + "," + q + "name" + q + ":" + q + name + q + "," + q + "category" + q + ":" + q + GALLERY_CATEGORIES[i] + q + "," + q + "thumbnail" + q + ":" + q + GALLERY_THUMBNAILS[i] + q + "," + q + "options" + q + ":" + q + GALLERY_OPTIONS[i] + q + "}"
        items.push(item)
        i = i + 1
    "[" + items.join(",") + "]"
