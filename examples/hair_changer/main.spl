# hair-changer — AI Hair Style Try-On
#
# Beautiful web UI with Korean-first multi-language support.
# Uses Gemini 2.5 Flash Image for hair style transfer.
#
# MDSOC Architecture: entity/ feature/ transform/ shared/
# This file is self-contained for interpreter mode.

extern fn rt_cli_get_args() -> [text]
extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_dir_create_all(path: text) -> bool
extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_http_request(method: text, url: text, headers: text, body: text) -> (i64, text, text)

# === entity/hair_options.spl ===

struct HairOptions:
    current_length: text
    target_length: text
    hair_type: text
    color: text
    dye: bool
    treatment: text
    bangs: text
    volume: text
    perm: bool

fn hair_options_default() -> HairOptions:
    HairOptions(
        current_length: "medium",
        target_length: "medium",
        hair_type: "straight",
        color: "natural",
        dye: false,
        treatment: "none",
        bangs: "none",
        volume: "normal",
        perm: false
    )

# === entity/generation_request.spl ===

struct GenerationRequest:
    face_image_path: text
    hair_ref_path: text
    options_json: text
    output_path: text
    lang: text

fn generation_request(face: text, hair: text, opts: text, out: text) -> GenerationRequest:
    GenerationRequest(
        face_image_path: face,
        hair_ref_path: hair,
        options_json: opts,
        output_path: out,
        lang: "ko"
    )

# === entity/style_preset.spl ===

struct StylePreset:
    id: text
    name_ko: text
    name_en: text
    name_ja: text
    category: text
    thumbnail: text
    default_options: text

# === shared/config_loader.spl ===

var HC_PORT = 8080
var HC_GEMINI_MODEL = "gemini-2.5-flash-preview-image-generation"
var HC_GEMINI_CLI = "gemini"
var HC_UPLOAD_DIR = ".build/hair_changer/uploads"
var HC_RESULT_DIR = ".build/hair_changer/results"
var HC_DEFAULT_LANG = "ko"

fn hc_load_config(path: text) -> bool:
    if not rt_file_exists(path):
        return false
    val content = rt_file_read_text(path) ?? ""
    if content == "":
        return false
    var current_section = ""
    val lines = content.split("\n")
    for line in lines:
        val trimmed = line.trim()
        if trimmed == "" or trimmed.starts_with("#"):
            continue
        if not trimmed.contains(":"):
            continue
        val colon_pos = trimmed.index_of(":") ?? 0
        val key = trimmed[0:colon_pos].trim()
        var value = ""
        val tlen = trimmed.len()
        if colon_pos + 1 < tlen:
            value = trimmed[colon_pos + 1:tlen].trim()
        # Detect indent
        var indent = 0
        var k = 0
        while k < line.len():
            if line[k:k + 1] == " ":
                indent = indent + 1
            else:
                break
            k = k + 1
        if indent == 0:
            current_section = key
            continue
        if current_section == "server":
            if key == "port":
                HC_PORT = int(value)
            elif key == "default_lang":
                HC_DEFAULT_LANG = value
        elif current_section == "gemini":
            if key == "model":
                HC_GEMINI_MODEL = value
            elif key == "cli_path":
                HC_GEMINI_CLI = value
        elif current_section == "storage":
            if key == "upload_dir":
                HC_UPLOAD_DIR = value
            elif key == "result_dir":
                HC_RESULT_DIR = value
    true

# === shared/file_utils.spl ===

fn ensure_dirs():
    rt_dir_create_all(HC_UPLOAD_DIR)
    rt_dir_create_all(HC_RESULT_DIR)

fn is_valid_image_ext(filename: text) -> bool:
    if filename.ends_with(".jpg") or filename.ends_with(".jpeg"):
        return true
    if filename.ends_with(".png"):
        return true
    if filename.ends_with(".webp"):
        return true
    false

fn generate_result_path(request_id: text) -> text:
    HC_RESULT_DIR + "/" + request_id + ".png"

