# entity/generation_request — Image generation request

struct GenerationRequest:
    face_image_path: text
    hair_ref_path: text
    options_json: text
    output_path: text
    lang: text

fn generation_request(face: text, hair: text, opts: text, out: text) -> GenerationRequest:
    GenerationRequest(
        face_image_path: face,
        hair_ref_path: hair,
        options_json: opts,
        output_path: out,
        lang: "ko"
    )
