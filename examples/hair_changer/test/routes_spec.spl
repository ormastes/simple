# API route tests

# Inline JSON helper
fn _extract_json_string(json: text, key: text) -> text:
    val q = "\""
    val search = q + key + q + ":"
    val idx_opt = json.index_of(search)
    if not idx_opt.?:
        return ""
    val idx = idx_opt.unwrap()
    val start = idx + search.len()
    val jlen = json.len()
    val after = json[start:jlen].trim()
    if not after.starts_with(q):
        return ""
    val rest = after[1:after.len()]
    var end = 0
    var escaped = false
    while end < rest.len():
        val ch = rest[end:end + 1]
        if escaped:
            escaped = false
        elif ch == "\\":
            escaped = true
        elif ch == "\"":
            return rest[0:end]
        end = end + 1
    ""

fn _extract_option(options: text, key: text) -> text:
    val search = key + "="
    val idx_opt = options.index_of(search)
    if not idx_opt.?:
        return ""
    val idx = idx_opt.unwrap()
    val start = idx + search.len()
    val olen = options.len()
    val rest = options[start:olen]
    val comma_opt = rest.index_of(",")
    if comma_opt.?:
        val cp = comma_opt.unwrap()
        return rest[0:cp]
    rest

fn handle_api_health() -> text:
    "{\"status\":\"ok\",\"service\":\"hair-changer\"}"

describe "API Routes":
    it "health check returns ok":
        val response = handle_api_health()
        val status = _extract_json_string(response, "status")
        expect(status).to_equal("ok")
        val service = _extract_json_string(response, "service")
        expect(service).to_equal("hair-changer")

    it "extracts JSON string values":
        val json = "{\"name\":\"test\",\"value\":\"hello\"}"
        expect(_extract_json_string(json, "name")).to_equal("test")
        expect(_extract_json_string(json, "value")).to_equal("hello")

    it "extracts option values":
        val opts = "target_length=short,hair_type=wavy,color=red"
        expect(_extract_option(opts, "target_length")).to_equal("short")
        expect(_extract_option(opts, "hair_type")).to_equal("wavy")
        expect(_extract_option(opts, "color")).to_equal("red")

    it "handles missing option":
        val opts = "target_length=short"
        expect(_extract_option(opts, "color")).to_equal("")
