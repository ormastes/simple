# Prompt builder tests

fn build_hair_prompt(options_json: text, lang: text) -> text:
    var parts: [text] = []
    parts.push("Apply the hairstyle from the second reference image to the person in the first image.")
    parts.push("Keep the person's face, skin tone, and facial features completely identical.")
    parts.push("Only change the hairstyle.")
    if options_json.contains("target_length=short"):
        parts.push("The target hairstyle should be short length.")
    elif options_json.contains("target_length=medium"):
        parts.push("The target hairstyle should be medium length.")
    elif options_json.contains("target_length=long"):
        parts.push("The target hairstyle should be long length.")
    if options_json.contains("hair_type=straight"):
        parts.push("The hair should be straight.")
    elif options_json.contains("hair_type=wavy"):
        parts.push("The hair should have gentle waves.")
    elif options_json.contains("hair_type=curly"):
        parts.push("The hair should be curly.")
    if options_json.contains("dye=true"):
        if options_json.contains("color=platinum"):
            parts.push("Change the hair color to platinum blonde.")
        elif options_json.contains("color=ash_brown"):
            parts.push("Change the hair color to ash brown.")
        elif options_json.contains("color=red"):
            parts.push("Change the hair color to red.")
    if options_json.contains("bangs=curtain"):
        parts.push("Add Korean-style curtain bangs.")
    elif options_json.contains("bangs=blunt"):
        parts.push("Add blunt-cut straight bangs.")
    if options_json.contains("perm=true"):
        parts.push("The hair should have a natural perm texture.")
    parts.push("Produce a photorealistic result with natural lighting.")
    parts.join(" ")

describe "Prompt Builder":
    it "builds basic prompt":
        val prompt = build_hair_prompt("", "ko")
        expect(prompt).to_contain("Apply the hairstyle")
        expect(prompt).to_contain("photorealistic")

    it "includes length option":
        val prompt = build_hair_prompt("target_length=short", "ko")
        expect(prompt).to_contain("short length")

    it "includes hair type":
        val prompt = build_hair_prompt("hair_type=wavy", "ko")
        expect(prompt).to_contain("gentle waves")

    it "includes color with dye":
        val prompt = build_hair_prompt("color=platinum,dye=true", "ko")
        expect(prompt).to_contain("platinum blonde")

    it "includes curtain bangs":
        val prompt = build_hair_prompt("bangs=curtain", "ko")
        expect(prompt).to_contain("curtain bangs")

    it "includes perm":
        val prompt = build_hair_prompt("perm=true", "ko")
        expect(prompt).to_contain("perm texture")

    it "combines multiple options":
        val prompt = build_hair_prompt("target_length=long,hair_type=curly,bangs=curtain,perm=true", "ko")
        expect(prompt).to_contain("long length")
        expect(prompt).to_contain("curly")
        expect(prompt).to_contain("curtain bangs")
        expect(prompt).to_contain("perm texture")
