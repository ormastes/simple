# Feasibility checker tests

fn _length_rank(length: text) -> i64:
    if length == "shaved":
        return 0
    elif length == "short":
        return 1
    elif length == "medium":
        return 2
    elif length == "long":
        return 3
    1

fn check_feasibility(current: text, target: text) -> text:
    val current_rank = _length_rank(current)
    val target_rank = _length_rank(target)
    if target_rank <= current_rank:
        return "ok"
    val diff = target_rank - current_rank
    if diff == 1:
        return "ok"
    elif diff == 2:
        return "warning"
    "impossible"

fn feasibility_message(status: text, lang: text) -> text:
    if status == "ok":
        return ""
    if lang == "ko":
        if status == "warning":
            return "현재 머리 길이로는 이 스타일이 다소 어려울 수 있습니다. 익스텐션을 고려해보세요."
        return "현재 머리 길이로는 이 스타일이 어렵습니다. 가발이나 익스텐션이 필요합니다."
    elif lang == "ja":
        if status == "warning":
            return "現在の髪の長さでは、このスタイルは難しいかもしれません。エクステンションをご検討ください。"
        return "現在の髪の長さでは、このスタイルは困難です。ウィッグまたはエクステンションが必要です。"
    if status == "warning":
        return "This style may be difficult with your current hair length. Consider extensions."
    "This style is not achievable with your current hair length. A wig or extensions are needed."

describe "Feasibility Checker":
    it "allows same or shorter target":
        expect(check_feasibility("long", "short")).to_equal("ok")
        expect(check_feasibility("medium", "medium")).to_equal("ok")
        expect(check_feasibility("long", "medium")).to_equal("ok")

    it "allows one step up":
        expect(check_feasibility("short", "medium")).to_equal("ok")
        expect(check_feasibility("medium", "long")).to_equal("ok")

    it "warns for two steps up":
        expect(check_feasibility("short", "long")).to_equal("warning")

    it "impossible for shaved to long":
        expect(check_feasibility("shaved", "long")).to_equal("impossible")

    it "returns Korean warning message":
        val msg = feasibility_message("warning", "ko")
        expect(msg).to_contain("익스텐션")

    it "returns English warning message":
        val msg = feasibility_message("warning", "en")
        expect(msg).to_contain("extensions")

    it "returns Japanese warning message":
        val msg = feasibility_message("warning", "ja")
        expect(msg).to_contain("エクステンション")

    it "returns empty for ok status":
        val msg = feasibility_message("ok", "ko")
        expect(msg).to_equal("")
