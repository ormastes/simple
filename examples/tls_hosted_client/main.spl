#!/usr/bin/env simple
@allow(primitive_api)

extern fn rt_file_read_bytes(path: text) -> [u8]
extern fn rt_env_get(key: text) -> text

use std.nogc_sync_mut.io.tcp.{TcpStream}
use os.tls13.mod.{
    load_tls_test_server_config, tls13_connect_host_stream_with_config, tls13_default_client_config,
    tls13_recv, tls13_send, tls13_close, Tls13ConnectResult
}

fn _read_bytes(path: text) -> [u8]:
    val raw = rt_file_read_bytes(path)
    if val bytes = raw:
        bytes
    else:
        []

fn _bytes_contains(haystack: [u8], needle: text) -> bool:
    var needle_bytes: [u8] = []
    var i: u64 = 0
    while i < needle.len():
        needle_bytes.push(needle.char_code_at(i).to_u8())
        i = i + 1
    if needle_bytes.len() == 0:
        return true
    if haystack.len() < needle_bytes.len():
        return false

    var hi: u64 = 0
    while hi + needle_bytes.len() <= haystack.len():
        var matched = true
        var ni: u64 = 0
        while ni < needle_bytes.len():
            if haystack[hi + ni] != needle_bytes[ni]:
                matched = false
            ni = ni + 1
        if matched:
            return true
        hi = hi + 1
    false

fn main() -> i64:
    var config_path = rt_env_get("TLS_TEST_SERVER_CONFIG")
    if config_path == nil or config_path == "":
        config_path = "tools/tls_test_server/server.sdn"

    val config_result = load_tls_test_server_config(config_path)
    if val Err(err) = config_result:
        print "[simple-client] config error: {err}"
        return 1

    val config = match config_result:
        case Ok(cfg): cfg
        case _:
            print "[simple-client] config error"
            return 1

    if config.listen == "":
        print "[simple-client] invalid listen addr: {config.listen}"
        return 1
    val stream_result = TcpStream.connect(config.listen)
    if stream_result.err.?:
        print "[simple-client] connect failed: {stream_result.err.unwrap()}"
        return 1
    val stream = stream_result.unwrap()

    var tls_config = tls13_default_client_config()
    tls_config.root_store = [_read_bytes(config.fixture_dir + "/ca.der")]
    if config.require_client_auth:
        tls_config.client_cert_chain = [_read_bytes(config.fixture_dir + "/client.der")]
        tls_config.client_pkcs8 = _read_bytes(config.fixture_dir + "/client.key.der")
        tls_config.client_sig_scheme = 0x0807

    val tls_result = tls13_connect_host_stream_with_config(stream, "localhost", tls_config)
    if val Tls13ConnectResult.Failed(reason) = tls_result:
        print "[simple-client] handshake failed: {reason}"
        return 1

    val ctx = if val Tls13ConnectResult.Connected(ctx0) = tls_result:
        ctx0
    else:
        print "[simple-client] connect result mismatch"
        return 1

    val recv_result = tls13_recv(ctx)
    if not _bytes_contains(recv_result.data, config.greeting):
        print "[simple-client] greeting mismatch"
        tls13_close(recv_result.ctx)
        return 1

    val send_ctx = tls13_send(recv_result.ctx, [0x70u8, 0x69, 0x6E, 0x67])
    val ack_result = tls13_recv(send_ctx)
    if not _bytes_contains(ack_result.data, "server_ack"):
        print "[simple-client] ack missing"
        tls13_close(ack_result.ctx)
        return 1

    tls13_close(ack_result.ctx)
    print "[simple-client] handshake ok"
    0
