# Minimal reusable IDE render example.

fn main() -> i64:
    val body = "<div class=\"editor-area gui-editor-source\" data-language=\"markdown\"><div class=\"line\"><span class=\"content\"># Embedded IDE</span></div></div>"
    print "target=pure_simple"
    print "has_editor_source={body.contains(\"gui-editor-source\")}"
    print "has_markdown_language={body.contains(\"data-language=\\\"markdown\\\"\")}"
    0
