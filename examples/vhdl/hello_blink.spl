# Hello Blink - Minimal VHDL Example
#
# A simple LED blink counter that toggles an output at a configurable rate.
# Compiles through VhdlBackend to synthesizable VHDL-2008.
#
# @hardware

use compiler.backend.vhdl.vhdl_builder.VhdlBuilder

fn generate_blink_vhdl(clock_freq_mhz: i64, blink_rate_hz: i64) -> text:
    """Generate VHDL for a blink counter entity."""
    val count_max = (clock_freq_mhz * 1000000) / (blink_rate_hz * 2)

    var b = VhdlBuilder.create("blink")
    b.emit_library_header()

    # Entity: clk, rst inputs; led output
    b.emit_entity_begin("blink")
    b.emit_port_begin()
    b.emit_port("clk", "in", "std_logic", false)
    b.emit_port("rst", "in", "std_logic", false)
    b.emit_port("led", "out", "std_logic", true)
    b.emit_port_end()
    b.emit_entity_end("blink")

    # Architecture
    b.emit_architecture_begin("blink", "rtl")
    b.emit_signal_decl("counter", "unsigned(31 downto 0)", Some("(others => '0')"))
    b.emit_signal_decl("led_reg", "std_logic", Some("'0'"))
    b.emit_constant_decl("COUNT_MAX", "unsigned(31 downto 0)", "to_unsigned({count_max}, 32)")
    b.emit_architecture_body_begin()

    # Counter process
    b.emit_clocked_process_begin(Some("counter_proc"), "clk", Some("rst"))
    b.emit_process_body_begin()
    b.emit_if_begin("rst = '1'")
    b.emit_signal_assign("counter", "(others => '0')")
    b.emit_signal_assign("led_reg", "'0'")
    b.emit_elsif("rising_edge(clk)")
    b.emit_if_begin("counter = COUNT_MAX")
    b.emit_signal_assign("counter", "(others => '0')")
    b.emit_signal_assign("led_reg", "not led_reg")
    b.emit_else()
    b.emit_signal_assign("counter", "counter + 1")
    b.emit_if_end()
    b.emit_if_end()
    b.emit_process_end(Some("counter_proc"))
    b.emit_raw("")

    # Output assignment
    b.emit_signal_assign("led", "led_reg")

    b.emit_architecture_end("rtl")
    b.build()

fn blink_ports() -> [(text, text, text)]:
    """Port list for the blink entity."""
    [
        ("clk", "in", "std_logic"),
        ("rst", "in", "std_logic"),
        ("led", "out", "std_logic")
    ]
