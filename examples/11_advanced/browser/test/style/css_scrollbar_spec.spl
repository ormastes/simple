#![allow(REQC001)]
#![allow(REQC004)]
"""
# CSS Scrollbar Rendering Specification

Tests for scrollbar paint command generation:
track rect, thumb positioning, proportional sizing.
Pure paint-command math — no rendering required.

Run with: bin/simple test examples/browser/test/style/css_scrollbar_spec.spl
"""

use std.spec
use std.gc_async_mut.gpu.browser_engine.paint.{paint_scrollbar, PaintCommand}

fn approx(a: f64, b: f64) -> bool:
    val diff = a - b
    val abs_diff = if diff < 0.0: -diff else: diff
    abs_diff < 1.0

fn cmd_at(cmds: [PaintCommand], idx: i64) -> PaintCommand:
    var result = PaintCommand.rect(0, 0, 0, 0, 0)
    var i = 0
    for c in cmds:
        if i == idx:
            result = c
        i = i + 1
    result

describe "Scrollbar track rendering":
    it "returns at least 1 command (track) for any dimensions":
        val cmds = paint_scrollbar(0.0, 0.0, 200.0, 400.0, 800.0, 0.0)
        expect(cmds.len() >= 1).to_equal(true)

    it "track command is 8px wide":
        val cmds = paint_scrollbar(0.0, 0.0, 200.0, 400.0, 800.0, 0.0)
        val track = cmd_at(cmds, 0)
        expect(track.width).to_equal(8)

    it "track x is at right edge minus bar width":
        val cmds = paint_scrollbar(10.0, 20.0, 200.0, 400.0, 800.0, 0.0)
        val track = cmd_at(cmds, 0)
        expect(track.x).to_equal(202)

    it "track y matches container y":
        val cmds = paint_scrollbar(10.0, 20.0, 200.0, 400.0, 800.0, 0.0)
        val track = cmd_at(cmds, 0)
        expect(track.y).to_equal(20)

    it "track height matches container height":
        val cmds = paint_scrollbar(0.0, 0.0, 200.0, 300.0, 600.0, 0.0)
        val track = cmd_at(cmds, 0)
        expect(track.height).to_equal(300)

describe "Scrollbar thumb rendering":
    it "produces 2 commands when content overflows":
        val cmds = paint_scrollbar(0.0, 0.0, 200.0, 400.0, 800.0, 0.0)
        expect(cmds.len()).to_equal(2)

    it "thumb is at top when scroll_y is 0":
        val cmds = paint_scrollbar(0.0, 0.0, 200.0, 400.0, 800.0, 0.0)
        val thumb = cmd_at(cmds, 1)
        expect(thumb.y).to_equal(0)

    it "thumb is proportional to visible ratio":
        val cmds = paint_scrollbar(0.0, 0.0, 200.0, 400.0, 800.0, 0.0)
        val thumb = cmd_at(cmds, 1)
        expect(thumb.height).to_equal(200)

    it "thumb moves down when scrolled":
        val cmds = paint_scrollbar(0.0, 0.0, 200.0, 400.0, 800.0, 200.0)
        val thumb = cmd_at(cmds, 1)
        expect(thumb.y > 0).to_equal(true)

    it "thumb at max scroll is near bottom":
        val cmds = paint_scrollbar(0.0, 0.0, 200.0, 400.0, 800.0, 400.0)
        val thumb = cmd_at(cmds, 1)
        val thumb_bottom = thumb.y + thumb.height
        expect(thumb_bottom).to_equal(400)

    it "no thumb when content fits":
        val cmds = paint_scrollbar(0.0, 0.0, 200.0, 400.0, 300.0, 0.0)
        expect(cmds.len()).to_equal(1)

    it "minimum thumb height is 16px":
        val cmds = paint_scrollbar(0.0, 0.0, 200.0, 400.0, 100000.0, 0.0)
        val thumb = cmd_at(cmds, 1)
        expect(thumb.height >= 16).to_equal(true)

describe "Scrollbar edge cases":
    it "zero content height produces track only":
        val cmds = paint_scrollbar(0.0, 0.0, 200.0, 400.0, 0.0, 0.0)
        expect(cmds.len()).to_equal(1)

    it "equal content and container produces track only":
        val cmds = paint_scrollbar(0.0, 0.0, 200.0, 400.0, 400.0, 0.0)
        expect(cmds.len()).to_equal(1)
