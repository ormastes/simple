#![allow(REQC001)]
#![allow(REQC004)]
#![allow(unnamed_duplicate_typed_args)]
"""WebGPU API Types — Chrome WebGPU Surface Model

Mirrors the Chrome WebGPU API types: GPUAdapterInfo, GPUDeviceLimits,
GPUDeviceDescriptor, GPURequestAdapterOptions, GPUCanvasConfiguration.

Usage:
    use examples.browser.entity.media.webgpu_types.{GPUAdapterInfo, GPUDeviceLimits}
"""

# ============================================================================
# GPU Adapter Info
# ============================================================================

class GPUAdapterInfo:
    vendor: text
    architecture: text
    device: text
    description: text

    static fn create(vendor: text, architecture: text, device: text, description: text) -> GPUAdapterInfo:
        GPUAdapterInfo(vendor: vendor, architecture: architecture, device: device, description: description)

    static fn unknown() -> GPUAdapterInfo:
        GPUAdapterInfo(vendor: "unknown", architecture: "unknown", device: "unknown", description: "Software fallback adapter")

# ============================================================================
# GPU Device Limits
# ============================================================================

class GPUDeviceLimits:
    max_texture_dimension_1d: i32
    max_texture_dimension_2d: i32
    max_texture_dimension_3d: i32
    max_texture_array_layers: i32
    max_bind_groups: i32
    max_storage_buffers_per_shader_stage: i32
    max_compute_workgroup_size_x: i32
    max_compute_workgroup_size_y: i32
    max_compute_workgroup_size_z: i32
    max_compute_invocations_per_workgroup: i32
    max_buffer_size: i64
    max_vertex_buffers: i32
    max_vertex_attributes: i32

    static fn defaults() -> GPUDeviceLimits:
        GPUDeviceLimits(
            max_texture_dimension_1d: 8192,
            max_texture_dimension_2d: 8192,
            max_texture_dimension_3d: 2048,
            max_texture_array_layers: 256,
            max_bind_groups: 4,
            max_storage_buffers_per_shader_stage: 8,
            max_compute_workgroup_size_x: 256,
            max_compute_workgroup_size_y: 256,
            max_compute_workgroup_size_z: 64,
            max_compute_invocations_per_workgroup: 256,
            max_buffer_size: 268435456,
            max_vertex_buffers: 8,
            max_vertex_attributes: 16
        )

# ============================================================================
# GPU Feature Names (Chrome WebGPU shipping features)
# ============================================================================

val GPU_FEATURE_DEPTH_CLIP_CONTROL: text = "depth-clip-control"
val GPU_FEATURE_DEPTH32FLOAT_STENCIL8: text = "depth32float-stencil8"
val GPU_FEATURE_TEXTURE_COMPRESSION_BC: text = "texture-compression-bc"
val GPU_FEATURE_TEXTURE_COMPRESSION_ETC2: text = "texture-compression-etc2"
val GPU_FEATURE_TEXTURE_COMPRESSION_ASTC: text = "texture-compression-astc"
val GPU_FEATURE_INDIRECT_FIRST_INSTANCE: text = "indirect-first-instance"
val GPU_FEATURE_SHADER_F16: text = "shader-f16"
val GPU_FEATURE_FLOAT32_FILTERABLE: text = "float32-filterable"
val GPU_FEATURE_FLOAT32_BLENDABLE: text = "float32-blendable"
val GPU_FEATURE_CLIP_DISTANCES: text = "clip-distances"
val GPU_FEATURE_DUAL_SOURCE_BLENDING: text = "dual-source-blending"
val GPU_FEATURE_SUBGROUPS: text = "subgroups"

# ============================================================================
# GPU Power Preference
# ============================================================================

val GPU_POWER_LOW: i32 = 0
val GPU_POWER_HIGH: i32 = 1

# ============================================================================
# GPU Request Adapter Options
# ============================================================================

class GPURequestAdapterOptions:
    power_preference: i32
    force_fallback_adapter: bool

    static fn default_options() -> GPURequestAdapterOptions:
        GPURequestAdapterOptions(power_preference: GPU_POWER_HIGH, force_fallback_adapter: false)

    static fn low_power() -> GPURequestAdapterOptions:
        GPURequestAdapterOptions(power_preference: GPU_POWER_LOW, force_fallback_adapter: false)

    static fn fallback() -> GPURequestAdapterOptions:
        GPURequestAdapterOptions(power_preference: GPU_POWER_LOW, force_fallback_adapter: true)

# ============================================================================
# GPU Device Descriptor
# ============================================================================

class GPUDeviceDescriptor:
    required_features: [text]
    limits: GPUDeviceLimits
    label: text

    static fn create() -> GPUDeviceDescriptor:
        GPUDeviceDescriptor(
            required_features: [],
            limits: GPUDeviceLimits.defaults(),
            label: ""
        )

    static fn with_features(features: [text]) -> GPUDeviceDescriptor:
        GPUDeviceDescriptor(
            required_features: features,
            limits: GPUDeviceLimits.defaults(),
            label: ""
        )

# ============================================================================
# GPU Canvas Configuration
# ============================================================================

class GPUCanvasConfiguration:
    device_id: i32
    format: i32
    alpha_mode: text
    width: i32
    height: i32

    static fn create(device_id: i32, format: i32, width: i32, height: i32) -> GPUCanvasConfiguration:
        GPUCanvasConfiguration(
            device_id: device_id,
            format: format,
            alpha_mode: "opaque",
            width: width,
            height: height
        )
