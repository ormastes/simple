#![allow(REQC001)]
#![allow(REQC004)]
#![allow(unnamed_duplicate_typed_args)]
# WebP container and frame types for the browser WebP codec.

class WebpChunk:
    fourcc: text
    size: i64
    data: [i64]

    static fn create(fourcc: text, size: i64, data: [i64]) -> WebpChunk:
        WebpChunk(fourcc: fourcc, size: size, data: data)

class WebpContainer:
    riff_magic: text
    file_size: i64
    webp_magic: text
    chunks: [WebpChunk]

    static fn create(file_size: i64) -> WebpContainer:
        WebpContainer(riff_magic: "RIFF", file_size: file_size, webp_magic: "WEBP", chunks: [])

class WebpFrameHeader:
    width: i64
    height: i64
    horizontal_scale: i64
    vertical_scale: i64
    color_space: i64
    clamping: i64

    static fn create(width: i64, height: i64) -> WebpFrameHeader:
        WebpFrameHeader(width: width, height: height, horizontal_scale: 0, vertical_scale: 0, color_space: 0, clamping: 0)

class WebpConfig:
    quality: i64
    method: i64

    static fn create(quality: i64, method: i64) -> WebpConfig:
        WebpConfig(quality: quality, method: method)

    static fn default() -> WebpConfig:
        WebpConfig(quality: 85, method: 0)

class WebpImage:
    width: i64
    height: i64
    pixels: [i64]

    static fn create(width: i64, height: i64) -> WebpImage:
        WebpImage(width: width, height: height, pixels: [i64]())

    static fn solid(width: i64, height: i64, r: i64, g: i64, b: i64, a: i64) -> WebpImage:
        var pixels = [i64]()
        var i = 0
        val total = width * height
        while i < total:
            pixels.push(r)
            pixels.push(g)
            pixels.push(b)
            pixels.push(a)
            i = i + 1
        WebpImage(width: width, height: height, pixels: pixels)
