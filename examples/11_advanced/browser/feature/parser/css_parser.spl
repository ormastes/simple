#![allow(REQC001)]
#![allow(REQC004)]
#![allow(unnamed_duplicate_typed_args)]
# CSS Parser producing CSSOM from a CssToken stream.
# Implements CSS Syntax Level 3 (W3C CR) section 5 "Parsing" plus
# Selectors Level 4 for selector grammar.
#
# Produces CSSRule values referencing types from css_types.spl:
#   CSSRule, CSSDeclaration, CSSValue, Selector, SelectorPart, Specificity.
#
# Supports: rule lists, compound selectors with combinators,
# attribute selectors, pseudo-classes/elements, declaration blocks
# with !important, color values (hex, rgb/rgba, named), lengths,
# percentages, functions, keyword values, and specificity calculation.
#
# Implementation is split across multiple files:
#   css_parser_selectors.spl    — selector parsing (parse_selector_list..._is_selector_start)
#   css_parser_declarations.spl — declaration block parsing (parse_declaration_block..parse_declaration)
#   css_parser_media.spl        — value/function parsing (parse_value..._collect_var_name)
#
# Spec references:
#   https://www.w3.org/TR/css-syntax-3/#parsing
#   https://www.w3.org/TR/selectors-4/

use std.common.color.types.{Color, from_rgba, from_rgb}
use examples.browser.entity.dom.css_types.CSSValue
use examples.browser.entity.dom.css_types.CSSDeclaration
use examples.browser.entity.dom.css_types.CSSRule
use examples.browser.entity.dom.css_types.Selector
use examples.browser.entity.dom.css_types.SelectorPart
use examples.browser.entity.dom.css_types.Specificity
use examples.browser.shared.error.BrowserResult
use examples.browser.shared.error.BrowserError
use examples.browser.shared.error.BrowserErrorKind
use examples.browser.shared.error.parse_error
use examples.browser.shared.logging.Logger
use examples.browser.feature.parser.css_tokenizer.CssToken
use examples.browser.feature.parser.css_tokenizer.CssTokenizer
use examples.browser.shared.named_colors.named_color_lookup
use examples.browser.feature.parser.css_shorthand.{expand_shorthand, is_shorthand}
use examples.browser.feature.parser.css_parser_selectors
use examples.browser.feature.parser.css_parser_declarations
use examples.browser.feature.parser.css_parser_media

# ---------- Named color map ----------

fn named_color_to_rgb(name: text) -> CSSValue?:
    val color = named_color_lookup(name)
    if val Some(c) = color:
        return CSSValue.Color(color: c)
    nil

# ---------- Hex color helpers ----------

fn hex_char_value(c: text) -> i64:
    val code = c.char_code_at(0)
    if code >= 48 and code <= 57:
        return code - 48
    if code >= 65 and code <= 70:
        return code - 55
    if code >= 97 and code <= 102:
        return code - 87
    0

fn parse_hex_color(hex: text) -> CSSValue?:
    val len = hex.len()
    if len == 3:
        val r = hex_char_value(hex.char_at(0))
        val g = hex_char_value(hex.char_at(1))
        val b = hex_char_value(hex.char_at(2))
        return CSSValue.Color(color: from_rgb(r * 17, g * 17, b * 17))
    if len == 4:
        val r = hex_char_value(hex.char_at(0))
        val g = hex_char_value(hex.char_at(1))
        val b = hex_char_value(hex.char_at(2))
        val a = hex_char_value(hex.char_at(3))
        return CSSValue.Color(color: from_rgba(r * 17, g * 17, b * 17, a * 17))
    if len == 6:
        val r = hex_char_value(hex.char_at(0)) * 16 + hex_char_value(hex.char_at(1))
        val g = hex_char_value(hex.char_at(2)) * 16 + hex_char_value(hex.char_at(3))
        val b = hex_char_value(hex.char_at(4)) * 16 + hex_char_value(hex.char_at(5))
        return CSSValue.Color(color: from_rgb(r, g, b))
    if len == 8:
        val r = hex_char_value(hex.char_at(0)) * 16 + hex_char_value(hex.char_at(1))
        val g = hex_char_value(hex.char_at(2)) * 16 + hex_char_value(hex.char_at(3))
        val b = hex_char_value(hex.char_at(4)) * 16 + hex_char_value(hex.char_at(5))
        val a = hex_char_value(hex.char_at(6)) * 16 + hex_char_value(hex.char_at(7))
        return CSSValue.Color(color: from_rgba(r, g, b, a))
    nil

# ---------- Specificity ----------

fn calculate_specificity(selector: Selector) -> Specificity:
    var ids = 0
    var classes = 0
    var elements = 0
    for part in selector.parts:
        match part:
            SelectorPart.Id(_):
                ids = ids + 1
            SelectorPart.Class(_):
                classes = classes + 1
            SelectorPart.Attribute(_, _, _):
                classes = classes + 1
            SelectorPart.PseudoClass(_):
                classes = classes + 1
            SelectorPart.FunctionalPseudo(name, _):
                if name != "where":
                    classes = classes + 1
            SelectorPart.Type(_):
                elements = elements + 1
            SelectorPart.PseudoElement(_):
                elements = elements + 1
            SelectorPart.Universal:
                pass_dn
            SelectorPart.Combinator(_):
                pass_dn
    Specificity.create(ids, classes, elements)

fn parse_selector_text(input: text, logger: Logger) -> Selector:
    val _logger = logger
    var parts: [SelectorPart] = []
    var i = 0
    var saw_space = false
    while i < input.len():
        val c = input.char_at(i)
        if c == " " or c == "\t" or c == "\n":
            saw_space = true
            i = i + 1
        else:
            if saw_space and parts.len() > 0:
                parts = parts + [SelectorPart.Combinator(kind: " ")]
                saw_space = false
            if c == ".":
                i = i + 1
                val name_end = _selector_name_end(input, i)
                parts = parts + [SelectorPart.Class(name: input.slice(i, name_end))]
                i = name_end
            else if c == "#":
                i = i + 1
                val name_end = _selector_name_end(input, i)
                parts = parts + [SelectorPart.Id(name: input.slice(i, name_end))]
                i = name_end
            else if c == "*":
                parts = parts + [SelectorPart.Universal]
                i = i + 1
            else if c == ":":
                i = i + 1
                var is_element = false
                if i < input.len() and input.char_at(i) == ":":
                    is_element = true
                    i = i + 1
                val name_end = _selector_name_end(input, i)
                val pseudo_name = input.slice(i, name_end)
                i = name_end
                if !is_element and i < input.len() and input.char_at(i) == "(":
                    val arg_start = i + 1
                    var depth = 1
                    i = i + 1
                    while i < input.len() and depth > 0:
                        val pc = input.char_at(i)
                        if pc == "(":
                            depth = depth + 1
                        else if pc == ")":
                            depth = depth - 1
                            if depth == 0:
                                break
                        i = i + 1
                    val arg_text = input.slice(arg_start, i).trim()
                    if i < input.len() and input.char_at(i) == ")":
                        i = i + 1
                    parts = parts + [SelectorPart.FunctionalPseudo(name: pseudo_name, arg_text: arg_text)]
                else if is_element:
                    parts = parts + [SelectorPart.PseudoElement(name: pseudo_name)]
                else:
                    parts = parts + [SelectorPart.PseudoClass(name: pseudo_name)]
            else:
                val name_end = _selector_name_end(input, i)
                if name_end > i:
                    parts = parts + [SelectorPart.Type(name: input.slice(i, name_end))]
                    i = name_end
                else:
                    i = i + 1
    Selector(parts: parts)

fn parse_declarations_text(input: text, logger: Logger) -> [CSSDeclaration]:
    val _logger = logger
    var declarations: [CSSDeclaration] = []
    val pieces = input.split(";")
    var i = 0
    while i < pieces.len():
        val piece = pieces[i].trim()
        val colon = piece.index_of(":")
        if colon >= 0:
            val property = piece.slice(0, colon).trim()
            var raw_value = piece.slice(colon + 1, piece.len()).trim()
            var important = false
            if raw_value.ends_with("!important"):
                important = true
                raw_value = raw_value.slice(0, raw_value.len() - 10).trim()
            val value = parse_css_value_text(raw_value)
            declarations = declarations + [CSSDeclaration(property: property, value: value, important: important)]
        i = i + 1
    declarations

fn _selector_name_end(input: text, start: i64) -> i64:
    var i = start
    while i < input.len():
        val c = input.char_at(i)
        if is_letter(c) or is_digit(c) or c == "-" or c == "_":
            i = i + 1
        else:
            return i
    i

fn parse_css_value_text(raw: text) -> CSSValue:
    val value = raw.trim()
    if value.starts_with("#"):
        val parsed = parse_hex_color(value.slice(1, value.len()))
        match parsed:
            Some(v):
                return v
            nil:
                return CSSValue.Keyword(v: value)
    if value.ends_with("px"):
        val number_text = value.slice(0, value.len() - 2)
        return CSSValue.Length(v: number_text.to_f64(), unit: "px")
    val named = named_color_to_rgb(value)
    match named:
        Some(v):
            return v
        nil:
            CSSValue.Keyword(v: value)

# ---------- Parser class ----------

class CssParser:
    tokenizer: CssTokenizer
    current: CssToken
    logger: Logger

    static fn new(input: text, logger: Logger) -> CssParser:
        var tok = CssTokenizer.new(input, logger)
        val first = tok.next_token()
        CssParser(tokenizer: tok, current: first, logger: logger)

    me advance() -> CssToken:
        val prev = self.current
        self.current = self.tokenizer.next_token()
        prev

    me skip_whitespace():
        while true:
            match self.current:
                CssToken.Whitespace:
                    self.advance()
                _:
                    break

    me expect(token_type: text) -> BrowserResult<CssToken>:
        val tok = self.current
        val matches = self._token_matches(tok, token_type)
        if matches:
            self.advance()
            return Ok(tok)
        val msg = "Expected {token_type}, got unexpected token"
        self.logger.warn(msg)
        Err(parse_error(msg))

    fn _token_matches(tok: CssToken, token_type: text) -> bool:
        match tok:
            CssToken.OpenBrace:
                return token_type == "{"
            CssToken.CloseBrace:
                return token_type == "}"
            CssToken.OpenParen:
                return token_type == "("
            CssToken.CloseParen:
                return token_type == ")"
            CssToken.OpenBracket:
                return token_type == "["
            CssToken.CloseBracket:
                return token_type == "]"
            CssToken.Colon:
                return token_type == ":"
            CssToken.Semicolon:
                return token_type == ";"
            CssToken.Comma:
                return token_type == ","
            _:
                return false

    # ---------- Stylesheet parsing ----------

    me parse_stylesheet() -> [CSSRule]:
        var rules: [CSSRule] = []
        self.skip_whitespace()
        while true:
            match self.current:
                CssToken.Eof:
                    break
                CssToken.AtKeyword(at_name):
                    val lower_at = at_name.to_lower()
                    if lower_at == "media":
                        val inner_rules = self._parse_media_rule()
                        for r in inner_rules:
                            rules.push(r)
                    else if lower_at == "supports":
                        val inner_rules = self._parse_supports_rule()
                        for r in inner_rules:
                            rules.push(r)
                    else if lower_at == "container":
                        # @container: container queries — parse inner rules
                        # Condition evaluation deferred to layout pass
                        val inner_rules = self._parse_conditional_rule()
                        for r in inner_rules:
                            rules.push(r)
                    else if lower_at == "layer":
                        # @layer: cascade layers — parse inner rules
                        val inner_rules = self._parse_conditional_rule()
                        for r in inner_rules:
                            rules.push(r)
                    else if lower_at == "keyframes":
                        self._skip_at_rule()
                    else if lower_at == "font-face":
                        # @font-face: skip for now (font loading not yet wired)
                        self._skip_at_rule()
                    else:
                        self._skip_at_rule()
                CssToken.CdoToken:
                    self.advance()
                CssToken.CdcToken:
                    self.advance()
                _:
                    val rule = self.parse_rule()
                    if val Some(r) = rule:
                        rules.push(r)
            self.skip_whitespace()
        rules

    me _parse_media_rule() -> [CSSRule]:
        """Parse @media rule and include inner rules only when the default
        browsing context matches the media query.
        """
        self.advance()  # skip @media keyword
        var condition_text = ""
        while true:
            match self.current:
                CssToken.OpenBrace:
                    break
                CssToken.Eof:
                    return []
                _:
                    condition_text = condition_text + self._media_condition_token_text(self.current)
                    self.advance()

        # Parse inner rules (same as stylesheet but stop at matching close brace)
        self.advance()  # consume open brace
        var inner_rules: [CSSRule] = []
        while true:
            self.skip_whitespace()
            match self.current:
                CssToken.CloseBrace:
                    self.advance()
                    break
                CssToken.Eof:
                    break
                CssToken.AtKeyword(_):
                    self._skip_at_rule()
                _:
                    val rule = self.parse_rule()
                    if val Some(r) = rule:
                        inner_rules.push(r)
        if self._media_query_matches(condition_text):
            return inner_rules
        []

    me _media_query_matches(query_text: text) -> bool:
        var remaining = query_text.trim()
        while remaining.len() > 0:
            val comma_pos = remaining.find(",")
            var part = remaining
            if comma_pos >= 0:
                part = remaining.slice(0, comma_pos)
                remaining = remaining.slice(comma_pos + 1, remaining.len()).trim()
            else:
                remaining = ""
            if self._single_media_query_matches(part.trim()):
                return true
        false

    me _single_media_query_matches(query_text: text) -> bool:
        var query = query_text.trim().to_lower()
        var negate = false
        if query.starts_with("not "):
            negate = true
            query = query.slice(4, query.len()).trim()

        val result = self._single_media_query_matches_positive(query)
        if negate:
            return not result
        result

    me _single_media_query_matches_positive(query_text: text) -> bool:
        var query = query_text.trim()
        if query == "" or query == "all":
            return true
        if query == "screen":
            return true
        if query == "print":
            return false
        if query.starts_with("screen and "):
            query = query.slice(11, query.len()).trim()
        else if query.starts_with("all and "):
            query = query.slice(8, query.len()).trim()
        else if query.starts_with("print and "):
            return false
        self._media_expression_group_matches(query)

    me _media_expression_group_matches(query: text) -> bool:
        if query.contains(" or "):
            var remaining = query
            while remaining.len() > 0:
                val or_pos = remaining.find(" or ")
                var part = remaining
                if or_pos >= 0:
                    part = remaining.slice(0, or_pos)
                    remaining = remaining.slice(or_pos + 4, remaining.len()).trim()
                else:
                    remaining = ""
                if self._media_expression_group_matches(part.trim()):
                    return true
            return false

        var remaining = query
        while remaining.len() > 0:
            val and_pos = remaining.find(" and ")
            var part = remaining
            if and_pos >= 0:
                part = remaining.slice(0, and_pos)
                remaining = remaining.slice(and_pos + 5, remaining.len()).trim()
            else:
                remaining = ""
            if not self._media_expression_matches(part.trim()):
                return false
        true

    me _media_expression_matches(raw: text) -> bool:
        var expr = raw.trim()
        if expr.starts_with("(") and expr.ends_with(")"):
            expr = expr.slice(1, expr.len() - 1).trim()
        val colon_pos = expr.find(":")
        if colon_pos < 0:
            return self._media_boolean_feature_matches(expr)

        val feature = expr.slice(0, colon_pos).trim()
        val value = expr.slice(colon_pos + 1, expr.len()).trim()
        if feature == "min-width":
            return 1280.0 >= self._media_numeric_value(value)
        if feature == "max-width":
            return 1280.0 <= self._media_numeric_value(value)
        if feature == "width":
            return self._media_number_equals(1280.0, self._media_numeric_value(value))
        if feature == "min-height":
            return 720.0 >= self._media_numeric_value(value)
        if feature == "max-height":
            return 720.0 <= self._media_numeric_value(value)
        if feature == "height":
            return self._media_number_equals(720.0, self._media_numeric_value(value))
        if feature == "min-device-pixel-ratio":
            return 1.0 >= self._media_numeric_value(value)
        if feature == "max-device-pixel-ratio":
            return 1.0 <= self._media_numeric_value(value)
        if feature == "device-pixel-ratio":
            return self._media_number_equals(1.0, self._media_numeric_value(value))
        if feature == "orientation":
            return value == "landscape"
        if feature == "prefers-color-scheme":
            return value == "light"
        if feature == "prefers-reduced-motion":
            return value == "no-preference"
        if feature == "hover" or feature == "any-hover":
            return value == "hover"
        if feature == "pointer" or feature == "any-pointer":
            return value == "fine"
        false

    me _media_boolean_feature_matches(feature: text) -> bool:
        if feature == "hover" or feature == "any-hover":
            return true
        if feature == "pointer" or feature == "any-pointer":
            return true
        false

    me _media_numeric_value(raw: text) -> f64:
        var value = raw.trim()
        if value.ends_with("dppx"):
            value = value.slice(0, value.len() - 4).trim()
        else if value.ends_with("px"):
            value = value.slice(0, value.len() - 2).trim()
        value.to_f64()

    me _media_number_equals(left: f64, right: f64) -> bool:
        val diff = left - right
        val abs_diff = if diff < 0.0: 0.0 - diff else: diff
        abs_diff < 0.001

    me _media_condition_token_text(tok: CssToken) -> text:
        match tok:
            CssToken.Ident(v):
                v
            CssToken.Function(name):
                name + "("
            CssToken.Dimension(v, unit):
                self._format_media_number(v) + unit
            CssToken.Number(v, _):
                self._format_media_number(v)
            CssToken.Percentage(v):
                self._format_media_number(v) + "%"
            CssToken.String(v):
                "\"" + v + "\""
            CssToken.Delim(v):
                v
            CssToken.Colon:
                ":"
            CssToken.Comma:
                ","
            CssToken.OpenParen:
                "("
            CssToken.CloseParen:
                ")"
            CssToken.Whitespace:
                " "
            _:
                ""

    me _format_media_number(value: f64) -> text:
        val whole = value.to_i64()
        if whole.to_f64() == value:
            return "{whole}"
        "{value}"

    me _parse_conditional_rule() -> [CSSRule]:
        """Parse a conditional at-rule (@supports, @container, @layer).
        Skips the condition and parses the inner rule block.
        """
        self.advance()  # skip the at-keyword
        # Skip condition until open brace
        while true:
            match self.current:
                CssToken.OpenBrace:
                    break
                CssToken.Eof:
                    return []
                _:
                    self.advance()
        # Parse inner rules
        self.advance()  # consume open brace
        var inner_rules: [CSSRule] = []
        while true:
            self.skip_whitespace()
            match self.current:
                CssToken.CloseBrace:
                    self.advance()
                    break
                CssToken.Eof:
                    break
                CssToken.AtKeyword(_):
                    self._skip_at_rule()
                _:
                    val rule = self.parse_rule()
                    if val Some(r) = rule:
                        inner_rules.push(r)
        inner_rules

    me _parse_supports_rule() -> [CSSRule]:
        """Parse @supports and include inner rules only for matched feature
        queries. This intentionally covers declaration-based supports queries
        first; unsupported or unknown feature probes must not leak rules into
        the stylesheet.
        """
        self.advance()  # skip @supports keyword
        var condition_text = ""
        while true:
            match self.current:
                CssToken.OpenBrace:
                    break
                CssToken.Eof:
                    return []
                _:
                    condition_text = condition_text + self._stylesheet_token_text(self.current)
                    self.advance()

        self.advance()  # consume open brace
        var inner_rules: [CSSRule] = []
        while true:
            self.skip_whitespace()
            match self.current:
                CssToken.CloseBrace:
                    self.advance()
                    break
                CssToken.Eof:
                    break
                CssToken.AtKeyword(_):
                    self._skip_at_rule()
                _:
                    val rule = self.parse_rule()
                    if val Some(r) = rule:
                        inner_rules.push(r)

        if self._supports_condition_matches(condition_text):
            return inner_rules
        []

    me _supports_condition_matches(condition_text: text) -> bool:
        var condition = condition_text.trim().to_lower()
        if condition == "":
            return false
        if condition.starts_with("not "):
            return not self._supports_condition_matches(condition.slice(4, condition.len()).trim())
        condition = self._strip_wrapping_parens(condition)
        if condition.contains(" or "):
            var remaining = condition
            while remaining.len() > 0:
                val or_pos = remaining.find(" or ")
                var part = remaining
                if or_pos >= 0:
                    part = remaining.slice(0, or_pos)
                    remaining = remaining.slice(or_pos + 4, remaining.len()).trim()
                else:
                    remaining = ""
                if self._supports_condition_matches(part.trim()):
                    return true
            return false
        if condition.contains(" and "):
            var remaining = condition
            while remaining.len() > 0:
                val and_pos = remaining.find(" and ")
                var part = remaining
                if and_pos >= 0:
                    part = remaining.slice(0, and_pos)
                    remaining = remaining.slice(and_pos + 5, remaining.len()).trim()
                else:
                    remaining = ""
                if not self._supports_condition_matches(part.trim()):
                    return false
            return true
        self._supports_declaration_matches(condition)

    me _strip_wrapping_parens(value: text) -> text:
        var result = value.trim()
        while result.starts_with("(") and result.ends_with(")") and self._outer_parens_wrap_all(result):
            result = result.slice(1, result.len() - 1).trim()
        result

    me _outer_parens_wrap_all(value: text) -> bool:
        var depth = 0
        var index = 0
        while index < value.len():
            val ch = value.char_at(index)
            if ch == "(":
                depth = depth + 1
            else if ch == ")":
                depth = depth - 1
                if depth == 0 and index < value.len() - 1:
                    return false
            if depth < 0:
                return false
            index = index + 1
        depth == 0

    me _supports_declaration_matches(condition: text) -> bool:
        val colon_pos = condition.find(":")
        if colon_pos < 0:
            return false
        val property = condition.slice(0, colon_pos).trim()
        val value_text = condition.slice(colon_pos + 1, condition.len()).trim()
        if property == "" or value_text == "":
            return false
        if not self._supports_property_known(property):
            return false
        val declarations = parse_declarations_text(property + ": " + value_text + ";", self.logger)
        if declarations.len() == 0:
            return false
        self._supports_value_known(property, declarations.get(0).value)

    me _supports_property_known(property: text) -> bool:
        if property.starts_with("--"):
            return true
        val known = [
            "display", "position", "float", "top", "right", "bottom", "left",
            "width", "height", "min-width", "max-width", "min-height", "max-height",
            "margin", "margin-top", "margin-right", "margin-bottom", "margin-left",
            "padding", "padding-top", "padding-right", "padding-bottom", "padding-left",
            "border", "border-top-width", "border-right-width", "border-bottom-width", "border-left-width",
            "border-top-color", "border-right-color", "border-bottom-color", "border-left-color",
            "border-top-style", "border-right-style", "border-bottom-style", "border-left-style",
            "border-radius", "border-top-left-radius", "border-top-right-radius",
            "border-bottom-right-radius", "border-bottom-left-radius",
            "color", "background", "background-color", "background-image",
            "font-family", "font-size", "font-weight", "font-style",
            "line-height", "text-align", "text-decoration",
            "text-indent", "text-transform", "letter-spacing", "word-spacing", "white-space",
            "overflow", "overflow-x", "overflow-y", "scroll-behavior",
            "opacity", "visibility", "z-index",
            "flex-direction", "flex-wrap", "justify-content", "align-items", "align-content",
            "flex-grow", "flex-shrink", "flex-basis", "row-gap", "column-gap",
            "grid-template-columns", "grid-template-rows",
            "grid-column", "grid-row", "grid-auto-flow", "grid-auto-columns", "grid-auto-rows",
            "animation-name", "animation-duration", "animation-timing-function",
            "animation-delay", "animation-iteration-count", "animation-direction", "animation-fill-mode",
            "content", "transform", "transform-origin", "perspective", "perspective-origin",
            "box-shadow", "text-shadow", "filter", "backdrop-filter", "mix-blend-mode", "isolation",
            "transition-property", "transition-duration", "transition-timing-function", "transition-delay",
            "aspect-ratio", "clear", "text-overflow", "word-break", "overflow-wrap", "vertical-align",
            "background-position", "background-size", "background-repeat",
            "background-attachment", "background-clip", "background-origin",
            "align-self", "order", "outline-width", "outline-style", "outline-color", "outline-offset",
            "contain", "container-type", "container-name", "writing-mode", "direction",
            "cursor", "pointer-events", "user-select"
        ]
        for p in known:
            if p == property:
                return true
        false

    me _supports_value_known(property: text, value: CSSValue) -> bool:
        match value:
            CSSValue.Keyword(v):
                val lower = v.to_lower()
                if lower == "unknown":
                    return false
                if property == "display":
                    return self._supports_display_value(lower)
                if property == "color" or property == "background-color" or property.ends_with("-color"):
                    return lower == "currentcolor" or lower == "transparent"
                return true
            _:
                true

    me _supports_display_value(value: text) -> bool:
        val supported = [
            "none", "block", "inline", "inline-block", "list-item",
            "table", "table-row", "table-cell", "flex", "inline-flex",
            "grid", "inline-grid", "contents", "flow-root"
        ]
        for v in supported:
            if v == value:
                return true
        false

    me _skip_at_rule():
        self.advance()  # skip the at-keyword
        while true:
            match self.current:
                CssToken.Eof:
                    break
                CssToken.Semicolon:
                    self.advance()
                    break
                CssToken.OpenBrace:
                    self._skip_block()
                    break
                _:
                    self.advance()

    me _skip_block():
        self.advance()  # skip open brace
        var depth = 1
        while depth > 0:
            match self.current:
                CssToken.Eof:
                    break
                CssToken.OpenBrace:
                    depth = depth + 1
                    self.advance()
                CssToken.CloseBrace:
                    depth = depth - 1
                    self.advance()
                _:
                    self.advance()

    me parse_rule() -> CSSRule?:
        var selector_text = ""
        while true:
            match self.current:
                CssToken.OpenBrace:
                    break
                CssToken.Eof:
                    return nil
                CssToken.CloseBrace:
                    return nil
                _:
                    selector_text = selector_text + self._stylesheet_token_text(self.current)
                    self.advance()

        if selector_text.trim().len() == 0:
            self._skip_to_next_rule()
            return nil

        self.advance()  # consume open brace
        var declaration_text = ""
        while true:
            match self.current:
                CssToken.CloseBrace:
                    self.advance()
                    break
                CssToken.Eof:
                    break
                _:
                    declaration_text = declaration_text + self._stylesheet_token_text(self.current)
                    self.advance()

        val selector = parse_selector_text(selector_text.trim(), self.logger)
        val declarations = parse_declarations_text(declaration_text, self.logger)
        Some(CSSRule.create(selector, declarations))

    me _stylesheet_token_text(tok: CssToken) -> text:
        match tok:
            CssToken.Ident(v):
                v
            CssToken.Function(name):
                name + "("
            CssToken.AtKeyword(v):
                "@" + v
            CssToken.Hash(v, _):
                "#" + v
            CssToken.String(v):
                "\"" + v + "\""
            CssToken.Url(v):
                "url(" + v + ")"
            CssToken.Dimension(v, unit):
                self._format_media_number(v) + unit
            CssToken.Number(v, _):
                self._format_media_number(v)
            CssToken.Percentage(v):
                self._format_media_number(v) + "%"
            CssToken.Delim(v):
                v
            CssToken.Colon:
                ":"
            CssToken.Semicolon:
                ";"
            CssToken.Comma:
                ","
            CssToken.OpenParen:
                "("
            CssToken.CloseParen:
                ")"
            CssToken.OpenBracket:
                "["
            CssToken.CloseBracket:
                "]"
            CssToken.Whitespace:
                " "
            _:
                ""

    me _skip_to_next_rule():
        while true:
            match self.current:
                CssToken.Eof:
                    break
                CssToken.CloseBrace:
                    self.advance()
                    break
                CssToken.OpenBrace:
                    self._skip_block()
                    break
                _:
                    self.advance()
