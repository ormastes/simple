# 3D Sphere Smoke Demo — visual verification of PhysicsWorld3D
# Renders a 2D projection of a sphere falling under 3D gravity.
use std.nogc_sync_mut.game2d.app.run.{run}
use std.nogc_sync_mut.game2d.render.canvas.{Canvas}
use std.nogc_sync_mut.game2d.math.{DrawMode}
use std.common.engine.color.{EngineColor}
use std.common.engine.math2d.{Vec2}
use std.common.engine.rect.{Rect2}
use std.common.engine.ids.{NodeId}
use std.nogc_sync_mut.engine.physics.config.{default_physics_config_3d, Vec3}
use std.nogc_sync_mut.engine.physics.world3d.{PhysicsWorld3D}

fn make_node(idx: i64) -> NodeId:
    NodeId(raw: idx)

class Game:
    world: PhysicsWorld3D
    frame: i64

    fn load(self):
        pass_do_nothing

    fn update(self, dt: f32):
        val _ = dt

    me fixed_update(self, step: f32):
        self.world.step(0.016)
        self.frame = self.frame + 1

    fn draw(self, ctx: Canvas):
        ctx.clear(EngineColor(r: 0.1, g: 0.1, b: 0.2, a: 1.0))
        val floor_rect = Rect2(x: 100.0, y: 450.0, width: 600.0, height: 20.0)
        ctx.rect(DrawMode.Fill, floor_rect, EngineColor(r: 0.4, g: 0.4, b: 0.4, a: 1.0))
        val pos = self.world.get_position(make_node(0))
        val sx = 400.0 + pos.x * 50.0
        val sy = 440.0 - pos.y * 50.0
        ctx.circle(DrawMode.Fill, Vec2(x: sx, y: sy), 25.0, EngineColor(r: 1.0, g: 0.3, b: 0.3, a: 1.0))
        ctx.text("3D Sphere Smoke", Vec2(x: 10.0, y: 20.0), EngineColor(r: 1.0, g: 1.0, b: 1.0, a: 1.0))

fn main():
    var config = default_physics_config_3d()
    var world = PhysicsWorld3D.create(config)
    world.add_dynamic_body(make_node(0), 0.0, 5.0, 0.0, 1.0)
    world.add_sphere_collider(make_node(0), 0.5)
    world.add_static_body(make_node(1), 0.0, 0.0, 0.0)
    world.add_box_collider(make_node(1), 10.0, 0.5, 10.0)
    run(Game(world: world, frame: 0), "3D Sphere Smoke", 800, 600)
