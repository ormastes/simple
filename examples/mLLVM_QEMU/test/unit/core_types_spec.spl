"""
IR_TC Core Types Specification

Tests for IrTcTypeKind, IrTcValue, and GuestArch.
Validates type classification, bit/byte widths, and text representation.
"""

use std.spec.{describe, it, expect}
use core.types.{IrTcTypeKind, IrTcValue, GuestArch}

# ============================================================================
# IrTcTypeKind — Integer classification
# ============================================================================

describe "IrTcTypeKind.is_integer":
    it "returns true for I1":
        expect(IrTcTypeKind.I1.is_integer()).to_equal(true)

    it "returns true for I8":
        expect(IrTcTypeKind.I8.is_integer()).to_equal(true)

    it "returns true for I16":
        expect(IrTcTypeKind.I16.is_integer()).to_equal(true)

    it "returns true for I32":
        expect(IrTcTypeKind.I32.is_integer()).to_equal(true)

    it "returns true for I64":
        expect(IrTcTypeKind.I64.is_integer()).to_equal(true)

    it "returns false for F32":
        expect(IrTcTypeKind.F32.is_integer()).to_equal(false)

    it "returns false for Ptr":
        expect(IrTcTypeKind.Ptr(addr_space: 0).is_integer()).to_equal(false)

    it "returns false for Void":
        expect(IrTcTypeKind.Void.is_integer()).to_equal(false)

# ============================================================================
# IrTcTypeKind — Bit width
# ============================================================================

describe "IrTcTypeKind.bit_width":
    it "returns 1 for I1":
        expect(IrTcTypeKind.I1.bit_width()).to_equal(1)

    it "returns 8 for I8":
        expect(IrTcTypeKind.I8.bit_width()).to_equal(8)

    it "returns 16 for I16":
        expect(IrTcTypeKind.I16.bit_width()).to_equal(16)

    it "returns 32 for I32":
        expect(IrTcTypeKind.I32.bit_width()).to_equal(32)

    it "returns 64 for I64":
        expect(IrTcTypeKind.I64.bit_width()).to_equal(64)

    it "returns 32 for F32":
        expect(IrTcTypeKind.F32.bit_width()).to_equal(32)

    it "returns 64 for F64":
        expect(IrTcTypeKind.F64.bit_width()).to_equal(64)

    it "returns 8 for Flag":
        expect(IrTcTypeKind.Flag.bit_width()).to_equal(8)

    it "returns 0 for Void":
        expect(IrTcTypeKind.Void.bit_width()).to_equal(0)

# ============================================================================
# IrTcTypeKind — Byte width
# ============================================================================

describe "IrTcTypeKind.byte_width":
    it "rounds up I1 to 1 byte":
        expect(IrTcTypeKind.I1.byte_width()).to_equal(1)

    it "returns 1 for I8":
        expect(IrTcTypeKind.I8.byte_width()).to_equal(1)

    it "returns 2 for I16":
        expect(IrTcTypeKind.I16.byte_width()).to_equal(2)

    it "returns 4 for I32":
        expect(IrTcTypeKind.I32.byte_width()).to_equal(4)

    it "returns 8 for I64":
        expect(IrTcTypeKind.I64.byte_width()).to_equal(8)

    it "returns 0 for Void":
        expect(IrTcTypeKind.Void.byte_width()).to_equal(0)

# ============================================================================
# IrTcTypeKind — Text representation
# ============================================================================

describe "IrTcTypeKind.to_text":
    it "formats I1 as 'i1'":
        expect(IrTcTypeKind.I1.to_text()).to_equal("i1")

    it "formats I32 as 'i32'":
        expect(IrTcTypeKind.I32.to_text()).to_equal("i32")

    it "formats F32 as 'f32'":
        expect(IrTcTypeKind.F32.to_text()).to_equal("f32")

    it "formats Void as 'void'":
        expect(IrTcTypeKind.Void.to_text()).to_equal("void")

    it "formats Flag as 'flag'":
        expect(IrTcTypeKind.Flag.to_text()).to_equal("flag")

    it "formats Ptr with address space":
        expect(IrTcTypeKind.Ptr(addr_space: 1).to_text()).to_equal("ptr.1")

# ============================================================================
# IrTcValue — Text representation
# ============================================================================

describe "IrTcValue.to_text":
    it "formats as %id:type":
        val v = IrTcValue.new(3, IrTcTypeKind.I32)
        expect(v.to_text()).to_equal("%3:i32")

    it "formats void value":
        val v = IrTcValue.new(0, IrTcTypeKind.Void)
        expect(v.to_text()).to_equal("%0:void")

# ============================================================================
# GuestArch — Word size
# ============================================================================

describe "GuestArch.word_size":
    it "returns 8 for Avr":
        expect(GuestArch.Avr.word_size()).to_equal(8)

    it "returns 16 for I8086":
        expect(GuestArch.I8086.word_size()).to_equal(16)

    it "returns 32 for Arm":
        expect(GuestArch.Arm.word_size()).to_equal(32)

    it "returns 32 for Riscv32":
        expect(GuestArch.Riscv32.word_size()).to_equal(32)

    it "returns 64 for X86_64":
        expect(GuestArch.X86_64.word_size()).to_equal(64)

    it "returns 64 for AArch64":
        expect(GuestArch.AArch64.word_size()).to_equal(64)
