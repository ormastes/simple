# AVR ELF Writer
#
# Generates ELF32 executables for AVR 8-bit targets.
# Supports:
#   - ELF32 with AVR-specific sections (.text in Flash, .data in SRAM)
#   - Intel HEX output format for flash programmers
#
# Memory layout (ATmega328P-like):
#   Flash (program):  0x000000 – 0x007FFF (32KB)
#   SRAM (data):      0x000060 – 0x0008FF  (0x800000 offset in ELF LMA)
#   I/O registers:    0x000020 – 0x00005F

use format.irtc_binary.{encode_u16_le, encode_u32_le}
use linker.linker.{
    LinkerConfig, LinkerError, LinkResult,
    MergedSection, ResolvedSymbol, OutputFormat
}

# ============================================================================
# ELF Constants
# ============================================================================

# ELF identification
val ELF_MAGIC_0: i64 = 0x7F         # 0x7F
val ELF_MAGIC_1: i64 = 0x45         # 'E'
val ELF_MAGIC_2: i64 = 0x4C         # 'L'
val ELF_MAGIC_3: i64 = 0x46         # 'F'

val ELFCLASS32: i64 = 1              # 32-bit ELF
val ELFDATA2LSB: i64 = 1             # Little-endian
val EV_CURRENT: i64 = 1              # Current ELF version
val ELFOSABI_NONE: i64 = 0           # No OS/ABI specific extensions

# ELF type
val ET_EXEC: i64 = 2                 # Executable file

# ELF machine
val EM_AVR: i64 = 0x53               # Atmel AVR 8-bit

# ELF version
val EV_CURRENT_32: i64 = 1

# ELF header sizes
val ELF32_EHDR_SIZE: i64 = 52        # ELF32 header size
val ELF32_PHDR_SIZE: i64 = 32        # ELF32 program header size
val ELF32_SHDR_SIZE: i64 = 40        # ELF32 section header size

# Program header types
val PT_NULL: i64 = 0
val PT_LOAD: i64 = 1                 # Loadable segment

# Program header flags
val PF_X: i64 = 1                    # Execute
val PF_W: i64 = 2                    # Write
val PF_R: i64 = 4                    # Read

# Section header types
val SHT_NULL: i64 = 0
val SHT_PROGBITS: i64 = 1            # Program data
val SHT_SYMTAB: i64 = 2              # Symbol table
val SHT_STRTAB: i64 = 3              # String table
val SHT_NOBITS: i64 = 8              # BSS (no file data)

# Section header flags
val SHF_WRITE: i64 = 1               # Writable
val SHF_ALLOC: i64 = 2               # Occupies memory
val SHF_EXECINSTR: i64 = 4           # Executable

# AVR-specific: Data in SRAM has LMA offset 0x800000
val AVR_SRAM_LMA_OFFSET: i64 = 0x800000

# ============================================================================
# ELF32 Writer for AVR
# ============================================================================

fn write_avr_elf(result: LinkResult, config: LinkerConfig) -> Result<[i64], LinkerError>:
    """Generate an ELF32 executable for AVR targets.

    Sections:
      .text     — Flash (program memory), starting at 0x0000
      .data     — SRAM, LMA with 0x800000 offset (initialized data)
      .bss      — SRAM, zero-initialized
      .vectors  — Interrupt vector table at 0x0000 (merged into .text)
    """
    var output: [i64] = []

    # Classify sections
    var text_sections: [MergedSection] = []
    var data_sections: [MergedSection] = []
    var bss_sections: [MergedSection] = []

    for sect in result.sections:
        if sect.name == ".bss":
            bss_sections.push(sect)
        else if sect.is_writable():
            data_sections.push(sect)
        else:
            text_sections.push(sect)

    # Calculate total sizes
    var text_size: i64 = 0
    for s in text_sections:
        text_size = text_size + s.size()
    var data_size: i64 = 0
    for s in data_sections:
        data_size = data_size + s.size()
    var bss_size: i64 = 0
    for s in bss_sections:
        bss_size = bss_size + s.size()

    # Number of program headers: Flash segment + optional SRAM segment
    var phdr_count: i64 = 1       # Always have Flash/text
    if data_size > 0 or bss_size > 0:
        phdr_count = 2

    # Section header string table
    var shstrtab = _build_shstrtab(text_sections, data_sections, bss_sections)

    # Number of section headers: null + sections + .shstrtab
    val section_count = 1 + text_sections.len() + data_sections.len() + bss_sections.len() + 1

    # Layout computation
    val phdr_offset = ELF32_EHDR_SIZE
    val sections_start = phdr_offset + phdr_count * ELF32_PHDR_SIZE

    # Text sections start right after program headers
    var text_file_offset = sections_start
    var data_file_offset = text_file_offset + text_size
    var shstrtab_file_offset = data_file_offset + data_size
    var shdr_offset = shstrtab_file_offset + shstrtab.len()
    # Align section headers to 4 bytes
    if shdr_offset % 4 != 0:
        shdr_offset = shdr_offset + (4 - shdr_offset % 4)

    # --- ELF Header (52 bytes) ---
    # e_ident[16]
    output.push(ELF_MAGIC_0)
    output.push(ELF_MAGIC_1)
    output.push(ELF_MAGIC_2)
    output.push(ELF_MAGIC_3)
    output.push(ELFCLASS32)          # EI_CLASS
    output.push(ELFDATA2LSB)         # EI_DATA
    output.push(EV_CURRENT)          # EI_VERSION
    output.push(ELFOSABI_NONE)       # EI_OSABI
    for _ in 0..8:
        output.push(0)              # EI_ABIVERSION + padding

    _push_u16_le(output, ET_EXEC)             # e_type
    _push_u16_le(output, EM_AVR)              # e_machine
    _push_u32_le(output, EV_CURRENT_32)       # e_version
    _push_u32_le(output, result.entry_address) # e_entry
    _push_u32_le(output, phdr_offset)         # e_phoff
    _push_u32_le(output, shdr_offset)         # e_shoff
    _push_u32_le(output, 0)                   # e_flags (AVR-specific flags)
    _push_u16_le(output, ELF32_EHDR_SIZE)     # e_ehsize
    _push_u16_le(output, ELF32_PHDR_SIZE)     # e_phentsize
    _push_u16_le(output, phdr_count)          # e_phnum
    _push_u16_le(output, ELF32_SHDR_SIZE)     # e_shentsize
    _push_u16_le(output, section_count)       # e_shnum
    _push_u16_le(output, section_count - 1)   # e_shstrndx (last section)

    # --- Program Headers ---
    # LOAD segment for Flash (.text + .vectors + .rodata)
    val text_base = if text_sections.len() > 0: text_sections[0].addr else: 0
    _push_u32_le(output, PT_LOAD)                 # p_type
    _push_u32_le(output, text_file_offset)         # p_offset
    _push_u32_le(output, text_base)                # p_vaddr
    _push_u32_le(output, text_base)                # p_paddr (same for Flash)
    _push_u32_le(output, text_size)                # p_filesz
    _push_u32_le(output, text_size)                # p_memsz
    _push_u32_le(output, PF_R + PF_X)             # p_flags
    _push_u32_le(output, 2)                        # p_align (word aligned)

    # LOAD segment for SRAM (.data + .bss) if present
    if phdr_count > 1:
        val data_base = if data_sections.len() > 0: data_sections[0].addr else: 0x0060
        val data_lma = data_base + AVR_SRAM_LMA_OFFSET
        val mem_size = data_size + bss_size
        _push_u32_le(output, PT_LOAD)             # p_type
        _push_u32_le(output, data_file_offset)     # p_offset
        _push_u32_le(output, data_base)            # p_vaddr (SRAM VMA)
        _push_u32_le(output, data_lma)             # p_paddr (LMA with offset)
        _push_u32_le(output, data_size)            # p_filesz
        _push_u32_le(output, mem_size)             # p_memsz (includes BSS)
        _push_u32_le(output, PF_R + PF_W)         # p_flags
        _push_u32_le(output, 1)                    # p_align

    # --- Section Data ---
    # .text sections data
    for sect in text_sections:
        for b in sect.data:
            output.push(b)

    # .data sections data
    for sect in data_sections:
        for b in sect.data:
            output.push(b)

    # .shstrtab data
    val shstrtab_actual_offset = output.len()
    for b in shstrtab:
        output.push(b)

    # Padding to align section headers
    while output.len() % 4 != 0:
        output.push(0)

    val actual_shdr_offset = output.len()

    # --- Section Headers ---
    # SHT_NULL (index 0)
    _write_shdr(output, 0, SHT_NULL, 0, 0, 0, 0, 0, 0, 0, 0)

    # Text sections
    var strtab_pos: i64 = 1   # Skip leading null
    var file_off = text_file_offset
    for sect in text_sections:
        val sh_flags = SHF_ALLOC + SHF_EXECINSTR
        _write_shdr(output, strtab_pos, SHT_PROGBITS, sh_flags,
                    sect.addr, file_off, sect.size(), 0, 0, 1, 0)
        strtab_pos = strtab_pos + sect.name.len() + 1
        file_off = file_off + sect.size()

    # Data sections
    for sect in data_sections:
        val sh_flags = SHF_ALLOC + SHF_WRITE
        _write_shdr(output, strtab_pos, SHT_PROGBITS, sh_flags,
                    sect.addr, file_off, sect.size(), 0, 0, 1, 0)
        strtab_pos = strtab_pos + sect.name.len() + 1
        file_off = file_off + sect.size()

    # BSS sections
    for sect in bss_sections:
        val sh_flags = SHF_ALLOC + SHF_WRITE
        _write_shdr(output, strtab_pos, SHT_NOBITS, sh_flags,
                    sect.addr, 0, sect.size(), 0, 0, 1, 0)
        strtab_pos = strtab_pos + sect.name.len() + 1

    # .shstrtab
    _write_shdr(output, strtab_pos, SHT_STRTAB, 0,
                0, shstrtab_actual_offset, shstrtab.len(), 0, 0, 1, 0)

    # Patch e_shoff with actual value if it differs
    # (We already computed it correctly above, but let's be safe)
    var shoff_bytes = encode_u32_le(actual_shdr_offset)
    output[32] = shoff_bytes[0]
    output[33] = shoff_bytes[1]
    output[34] = shoff_bytes[2]
    output[35] = shoff_bytes[3]

    Ok(output)

# ============================================================================
# Intel HEX Writer
# ============================================================================

fn write_intel_hex(result: LinkResult, config: LinkerConfig) -> Result<[i64], LinkerError>:
    """Generate Intel HEX output for AVR flash programmers.

    Format: :LLAAAATT[DD...]CC
      LL = byte count
      AAAA = 16-bit address
      TT = record type (00=data, 01=EOF, 02=ext segment addr)
      DD = data bytes
      CC = checksum (two's complement of sum)
    """
    var output: [i64] = []

    # Collect all loadable data (Flash sections only)
    var flash_data: [i64] = []
    var flash_base: i64 = 0

    for sect in result.sections:
        if sect.is_executable() or (not sect.is_writable() and sect.data.len() > 0):
            if flash_data.len() == 0:
                flash_base = sect.addr
            # Pad gap if needed
            val expected_offset = sect.addr - flash_base
            while flash_data.len() < expected_offset:
                flash_data.push(0xFF)
            for b in sect.data:
                flash_data.push(b)

    # Write data records (16 bytes per record)
    val record_size: i64 = 16
    var addr = flash_base
    var pos: i64 = 0

    while pos < flash_data.len():
        var count = record_size
        if pos + count > flash_data.len():
            count = flash_data.len() - pos

        # If address exceeds 16-bit, emit Extended Segment Address record
        if addr > 0xFFFF:
            val seg = (addr / 16) / 4096
            _write_hex_record(output, 0, 0, 0x02, [seg / 256, seg % 256])
            addr = addr % 0x10000

        # Data record
        var data: [i64] = []
        for i in 0..count:
            data.push(flash_data[pos + i])
        _write_hex_record(output, count, addr, 0x00, data)

        addr = addr + count
        pos = pos + count

    # EOF record
    _write_hex_record(output, 0, 0, 0x01, [])

    Ok(output)

# ============================================================================
# Intel HEX Helpers
# ============================================================================

fn _write_hex_record(output: [i64], count: i64, addr: i64, rec_type: i64, data: [i64]):
    """Write one Intel HEX record as ASCII bytes."""
    # ':' start code
    output.push(0x3A)

    # LL — byte count
    _push_hex_byte(output, count)

    # AAAA — address (big-endian)
    _push_hex_byte(output, (addr / 256) % 256)
    _push_hex_byte(output, addr % 256)

    # TT — record type
    _push_hex_byte(output, rec_type)

    # DD — data bytes
    var checksum = count + (addr / 256) % 256 + addr % 256 + rec_type
    for b in data:
        _push_hex_byte(output, b)
        checksum = checksum + b

    # CC — checksum (two's complement of sum of all bytes)
    val cs = (256 - checksum % 256) % 256
    _push_hex_byte(output, cs)

    # Line ending (CRLF for HEX files)
    output.push(0x0D)
    output.push(0x0A)

fn _push_hex_byte(output: [i64], byte: i64):
    """Push a byte as two ASCII hex characters."""
    val high = (byte / 16) % 16
    val low = byte % 16
    output.push(_hex_digit(high))
    output.push(_hex_digit(low))

fn _hex_digit(nibble: i64) -> i64:
    """Convert 0-15 to ASCII hex digit."""
    if nibble < 10:
        0x30 + nibble    # '0' + n
    else:
        0x41 + nibble - 10   # 'A' + (n-10)

# ============================================================================
# Section Header String Table Builder
# ============================================================================

fn _build_shstrtab(text_sects: [MergedSection], data_sects: [MergedSection], bss_sects: [MergedSection]) -> [i64]:
    """Build the .shstrtab section containing all section names."""
    var table: [i64] = []
    table.push(0)    # Leading null byte

    for s in text_sects:
        _push_string(table, s.name)
    for s in data_sects:
        _push_string(table, s.name)
    for s in bss_sects:
        _push_string(table, s.name)
    _push_string(table, ".shstrtab")

    table

fn _push_string(table: [i64], s: text):
    """Push a null-terminated ASCII string into the table."""
    for i in 0..s.len():
        val ch = s[i:i + 1]
        table.push(_ascii_char(ch))
    table.push(0)

fn _ascii_char(ch: text) -> i64:
    """Map a single character to ASCII byte value."""
    if ch == ".": return 46
    if ch == "_": return 95
    if ch == "a": return 97
    if ch == "b": return 98
    if ch == "c": return 99
    if ch == "d": return 100
    if ch == "e": return 101
    if ch == "f": return 102
    if ch == "g": return 103
    if ch == "h": return 104
    if ch == "i": return 105
    if ch == "j": return 106
    if ch == "k": return 107
    if ch == "l": return 108
    if ch == "m": return 109
    if ch == "n": return 110
    if ch == "o": return 111
    if ch == "p": return 112
    if ch == "q": return 113
    if ch == "r": return 114
    if ch == "s": return 115
    if ch == "t": return 116
    if ch == "u": return 117
    if ch == "v": return 118
    if ch == "w": return 119
    if ch == "x": return 120
    if ch == "y": return 121
    if ch == "z": return 122
    if ch == "0": return 48
    if ch == "1": return 49
    if ch == "2": return 50
    if ch == "3": return 51
    if ch == "4": return 52
    if ch == "5": return 53
    if ch == "6": return 54
    if ch == "7": return 55
    if ch == "8": return 56
    if ch == "9": return 57
    63   # '?' fallback

# ============================================================================
# ELF Section Header Writer
# ============================================================================

fn _write_shdr(output: [i64], name: i64, type_: i64, flags: i64,
               addr: i64, offset: i64, size: i64, link: i64,
               info: i64, addralign: i64, entsize: i64):
    """Write one ELF32 section header entry (40 bytes)."""
    _push_u32_le(output, name)        # sh_name
    _push_u32_le(output, type_)       # sh_type
    _push_u32_le(output, flags)       # sh_flags
    _push_u32_le(output, addr)        # sh_addr
    _push_u32_le(output, offset)      # sh_offset
    _push_u32_le(output, size)        # sh_size
    _push_u32_le(output, link)        # sh_link
    _push_u32_le(output, info)        # sh_info
    _push_u32_le(output, addralign)   # sh_addralign
    _push_u32_le(output, entsize)     # sh_entsize

# ============================================================================
# Byte Encoding Helpers (mutable output list)
# ============================================================================

fn _push_u16_le(output: [i64], value: i64):
    """Append a 16-bit little-endian value to the output."""
    output.push(value % 256)
    output.push((value / 256) % 256)

fn _push_u32_le(output: [i64], value: i64):
    """Append a 32-bit little-endian value to the output."""
    output.push(value % 256)
    output.push((value / 256) % 256)
    output.push((value / 65536) % 256)
    output.push((value / 16777216) % 256)
