# Smoke test for console module — delete after verification
use app.console.console_log.*
use app.console.ansi_strip.*
use app.console.console_render.*

fn main():
    # Test 1: ESC detection via slice
    val sample = "\x1b[31mhi\x1b[0m"
    val first_char = sample[0:1]
    if first_char == "\x1b":
        print("ESC-SLICE-OK")
    else:
        print("ESC-SLICE-FAIL")

    # Test 2: strip_ansi
    val stripped = strip_ansi(sample)
    print("stripped={stripped}")

    # Test 3: parse_ansi_segments
    val segs = parse_ansi_segments(sample)
    val seg_count = segs.len()
    print("segs={seg_count}")
    if seg_count > 0:
        val seg0 = segs[0]
        print("seg0.content={seg0.content}")
        print("seg0.fg={seg0.fg_color}")

    # Test 4: ring buffer overflow
    var buf = log_buffer_new(2)
    buf = log_buffer_push(buf, log_entry_new(1000000, "error", "sys", "boom"))
    buf = log_buffer_push(buf, log_entry_new(2000000, "info", "net", "ok"))
    buf = log_buffer_push(buf, log_entry_new(3000000, "warn", "net", "slow"))
    val blen = log_buffer_len(buf)
    print("buf_len={blen}")

    # Test 5: tail ordering
    val tail = log_buffer_tail(buf, 2)
    if tail.len() == 2:
        print("tail0={tail[0].message}")
        print("tail1={tail[1].message}")

    # Test 6: render
    val rendered = render_console(buf, 80, 3, 0)
    print("render_ok")
