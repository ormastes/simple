# ANSI Escape Code Handling
#
# Strip or parse ANSI SGR sequences from terminal output so the console
# panel can display clean text or re-apply styles selectively.
#
# Uses `for ch in s:` iteration with `ch == "\x1b"` to detect ESC bytes.
# This is the proven pattern used across the codebase (main_lazy_diag_tools,
# test_runner_files, etc.).

use std.text.{to_int_or}

# ============================================================================
# Data Types
# ============================================================================

struct AnsiSegment:
    content: text
    fg_color: text
    bg_color: text
    bold: bool
    dim: bool

struct AnsiStyle:
    fg: text
    bg: text
    bold: bool
    dim: bool

# ============================================================================
# Strip
# ============================================================================

fn strip_ansi(input: text) -> text:
    """
    Remove all ANSI CSI escape sequences from the input string.
    Uses the for-ch-in iterator pattern proven in the codebase.
    """
    var parts: [text] = []
    var in_escape = false
    for ch in input:
        if in_escape:
            if ch == "m":
                in_escape = false
            continue
        if ch == "\x1b":
            in_escape = true
            continue
        parts.push(ch)
    parts.join("")

# ============================================================================
# Parse into styled segments
# ============================================================================

fn parse_ansi_segments(input: text) -> [AnsiSegment]:
    """
    Split input into segments, each carrying its current style state.
    Handles SGR codes: reset (0), bold (1), dim (2),
    foreground 30-37 / 90-97, background 40-47 / 100-107.

    Uses a three-state machine over `for ch in input:`:
      state 0 = normal text
      state 1 = just saw ESC
      state 2 = inside CSI params (after ESC[)
    """
    var segments: [AnsiSegment] = []
    var style = AnsiStyle(fg: "", bg: "", bold: false, dim: false)
    var buf = ""
    var state = 0
    var param = ""

    for ch in input:
        if state == 0:
            # Normal text
            if ch == "\x1b":
                state = 1
            else:
                buf = buf + ch
        elif state == 1:
            # Just saw ESC
            if ch == "[":
                # Flush accumulated text before entering CSI
                if buf != "":
                    segments.push(AnsiSegment(
                        content: buf,
                        fg_color: style.fg,
                        bg_color: style.bg,
                        bold: style.bold,
                        dim: style.dim
                    ))
                    buf = ""
                param = ""
                state = 2
            else:
                # Not a CSI sequence, treat ESC as invisible and keep ch
                buf = buf + ch
                state = 0
        elif state == 2:
            # Inside CSI params — collect until letter terminator
            if (ch >= "A" and ch <= "Z") or (ch >= "a" and ch <= "z"):
                # Final byte of CSI
                if ch == "m":
                    style = _apply_sgr(param, style)
                state = 0
            else:
                param = param + ch

    # Flush remaining text
    if buf != "":
        segments.push(AnsiSegment(
            content: buf,
            fg_color: style.fg,
            bg_color: style.bg,
            bold: style.bold,
            dim: style.dim
        ))

    segments

# ============================================================================
# SGR parameter application (returns new style — avoids value-copy bug)
# ============================================================================

fn _apply_sgr(param: text, prev: AnsiStyle) -> AnsiStyle:
    """Parse semicolon-separated SGR codes and return updated style."""
    var fg = prev.fg
    var bg = prev.bg
    var is_bold = prev.bold
    var is_dim = prev.dim

    val sgr_parts = param.split(";")
    var pi = 0
    while pi < sgr_parts.len():
        val code = to_int_or(sgr_parts[pi].trim(), 0)

        if code == 0:
            # Reset all
            fg = ""
            bg = ""
            is_bold = false
            is_dim = false
        elif code == 1:
            is_bold = true
        elif code == 2:
            is_dim = true
        elif code >= 30 and code <= 37:
            fg = _sgr_color_name(code - 30, false)
        elif code >= 90 and code <= 97:
            fg = _sgr_color_name(code - 90, true)
        elif code >= 40 and code <= 47:
            bg = _sgr_color_name(code - 40, false)
        elif code >= 100 and code <= 107:
            bg = _sgr_color_name(code - 100, true)

        pi = pi + 1

    AnsiStyle(fg: fg, bg: bg, bold: is_bold, dim: is_dim)

fn _sgr_color_name(index: i64, bright: bool) -> text:
    """Map SGR color index (0-7) to a human-readable name."""
    val prefix = if bright then "bright_" else: ""
    if index == 0:
        return prefix + "black"
    if index == 1:
        return prefix + "red"
    if index == 2:
        return prefix + "green"
    if index == 3:
        return prefix + "yellow"
    if index == 4:
        return prefix + "blue"
    if index == 5:
        return prefix + "magenta"
    if index == 6:
        return prefix + "cyan"
    if index == 7:
        return prefix + "white"
    ""
