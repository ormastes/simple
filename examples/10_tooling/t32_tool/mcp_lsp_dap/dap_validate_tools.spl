# T32 Tool — MCP LSP/DAP: DAP validation tool
# Tool: cmm_validate_before_run — lint CMM before DO execution

export handle_cmm_validate_before_run

use shared.mcp_json_base.{t32_js, t32_jp, t32_LB, t32_RB, t32_SB_L, t32_SB_R, t32_extract_field, t32_make_tool_result, t32_make_tool_error}
use cmm.cmm_parser.{parse_cmm_file, parse_cmm_source}
use cmm.cmm_ast.{CmmProgram}
use cmm.cmm_analyzer.{analyze_program}
use cmm.cmm_diagnostics.{format_diagnostic, CmmDiagnosticKind}

extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_exists(path: text) -> bool

# Validate a CMM script before running it via DO command.
# Returns parse errors and diagnostics. If errors > 0, recommends NOT running.
fn handle_cmm_validate_before_run(id: text, body: text) -> text:
    val path = t32_extract_field(body, "path")
    val source = t32_extract_field(body, "source")

    var program_source = ""
    var file_label = "(inline)"

    if path != "":
        if not rt_file_exists(path):
            return t32_make_tool_error(id, -32602, "File not found: " + path)
        program_source = rt_file_read_text(path) ?? ""
        file_label = path
    elif source != "":
        program_source = source
    else:
        return t32_make_tool_error(id, -32602, "Provide 'path' or 'source' for validation")

    val program = parse_cmm_source(program_source)
    val result = analyze_program(program)

    # Count by severity
    var error_count = 0
    var warn_count = 0
    var i = 0
    while i < result.diagnostics.len():
        match result.diagnostics[i].kind:
            case CmmDiagnosticKind.Error: error_count = error_count + 1
            case CmmDiagnosticKind.Warning: warn_count = warn_count + 1
            case _: ()
        i = i + 1

    val total_errors = program.errors.len() + error_count
    var safe_to_run = "true"
    if total_errors > 0:
        safe_to_run = "false"

    # Build issues array (max 20)
    var issues = t32_SB_L()
    var first = true
    i = 0
    while i < program.errors.len() and i < 10:
        if not first:
            issues = issues + ","
        first = false
        issues = issues + t32_LB() + t32_jp("severity", t32_js("error")) + "," + t32_jp("message", t32_js(program.errors[i])) + t32_RB()
        i = i + 1
    i = 0
    while i < result.diagnostics.len() and i < 10:
        if not first:
            issues = issues + ","
        first = false
        issues = issues + t32_LB() + t32_jp("severity", t32_js("diagnostic")) + "," + t32_jp("message", t32_js(format_diagnostic(result.diagnostics[i]))) + t32_RB()
        i = i + 1
    issues = issues + t32_SB_R()

    var r = t32_LB()
    r = r + t32_jp("file", t32_js(file_label))
    r = r + "," + t32_jp("safe_to_run", safe_to_run)
    r = r + "," + t32_jp("parse_errors", str(program.errors.len()))
    r = r + "," + t32_jp("analysis_errors", str(error_count))
    r = r + "," + t32_jp("warnings", str(warn_count))
    r = r + "," + t32_jp("statements", str(program.statements.len()))
    r = r + "," + t32_jp("issues", issues)
    r = r + t32_RB()
    t32_make_tool_result(id, r)
