# T32 Tool — MCP LSP/DAP: CMM LSP tool handlers
# Tools: cmm_parse, cmm_lint, cmm_hover, cmm_complete, cmm_goto_def, cmm_symbols

export handle_cmm_parse, handle_cmm_lint, handle_cmm_hover
export handle_cmm_complete, handle_cmm_goto_def, handle_cmm_symbols

use shared.mcp_json_base.{t32_js, t32_jp, t32_jo1, t32_jo2, t32_LB, t32_RB, t32_SB_L, t32_SB_R, t32_extract_field, t32_make_tool_result, t32_make_tool_error}
use cmm.cmm_parser.{parse_cmm_file, parse_cmm_source}
use cmm.cmm_ast.{CmmProgram, CmmStmt}
use cmm.cmm_analyzer.{analyze_program, CmmAnalysisResult, CmmSymbolTable, CmmSymbolKind}
use cmm.cmm_diagnostics.{format_diagnostic, CmmDiagnosticKind}
use cmm.cmm_commands.{build_command_db, lookup_command, get_completions}
use cmm.cmm_functions.{build_function_db, lookup_function, get_function_completions}

extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_exists(path: text) -> bool

# --- cmm_parse: Parse a CMM file and return AST summary ---

fn handle_cmm_parse(id: text, body: text) -> text:
    val path = t32_extract_field(body, "path")
    val source = t32_extract_field(body, "source")

    var program = CmmProgram(statements: [], file_path: "", errors: [])
    if path != "":
        if not rt_file_exists(path):
            return t32_make_tool_error(id, -32602, "File not found: " + path)
        program = parse_cmm_file(path)
    elif source != "":
        program = parse_cmm_source(source)
    else:
        return t32_make_tool_error(id, -32602, "Provide either 'path' or 'source'")

    var r = t32_LB()
    r = r + t32_jp("statements", str(program.statements.len()))
    r = r + "," + t32_jp("errors", str(program.errors.len()))
    if program.errors.len() > 0:
        var err_arr = t32_SB_L()
        var first = true
        var i = 0
        while i < program.errors.len() and i < 10:
            if not first:
                err_arr = err_arr + ","
            first = false
            err_arr = err_arr + t32_js(program.errors[i])
            i = i + 1
        err_arr = err_arr + t32_SB_R()
        r = r + "," + t32_jp("error_details", err_arr)
    r = r + t32_RB()
    t32_make_tool_result(id, r)

# --- cmm_lint: Parse and analyze, return diagnostics ---

fn handle_cmm_lint(id: text, body: text) -> text:
    val path = t32_extract_field(body, "path")
    val source = t32_extract_field(body, "source")

    var program = CmmProgram(statements: [], file_path: "", errors: [])
    if path != "":
        if not rt_file_exists(path):
            return t32_make_tool_error(id, -32602, "File not found: " + path)
        program = parse_cmm_file(path)
    elif source != "":
        program = parse_cmm_source(source)
    else:
        return t32_make_tool_error(id, -32602, "Provide either 'path' or 'source'")

    val result = analyze_program(program)

    var diag_arr = t32_SB_L()
    var first = true
    var i = 0
    while i < result.diagnostics.len() and i < 50:
        if not first:
            diag_arr = diag_arr + ","
        first = false
        diag_arr = diag_arr + t32_js(format_diagnostic(result.diagnostics[i]))
        i = i + 1
    diag_arr = diag_arr + t32_SB_R()

    var r = t32_LB()
    r = r + t32_jp("parse_errors", str(program.errors.len()))
    r = r + "," + t32_jp("diagnostics_count", str(result.diagnostics.len()))
    r = r + "," + t32_jp("diagnostics", diag_arr)
    r = r + t32_RB()
    t32_make_tool_result(id, r)

# --- cmm_hover: Get hover info for a command or function name ---

fn handle_cmm_hover(id: text, body: text) -> text:
    val name = t32_extract_field(body, "name")
    if name == "":
        return t32_make_tool_error(id, -32602, "Missing required parameter: name")

    val cmd_db = build_command_db()
    val func_db = build_function_db()

    # Try command lookup
    val cmd_info = lookup_command(cmd_db, name)
    match cmd_info:
        Some(cmd):
            var r = t32_LB()
            r = r + t32_jp("kind", t32_js("command"))
            r = r + "," + t32_jp("name", t32_js(cmd.full_name))
            r = r + "," + t32_jp("short_name", t32_js(cmd.short_name))
            r = r + "," + t32_jp("group", t32_js(cmd.group))
            r = r + "," + t32_jp("description", t32_js(cmd.description))
            r = r + t32_RB()
            return t32_make_tool_result(id, r)
        nil: ()

    # Try function lookup
    val func_info = lookup_function(func_db, name)
    match func_info:
        Some(func):
            var r = t32_LB()
            r = r + t32_jp("kind", t32_js("function"))
            r = r + "," + t32_jp("name", t32_js(func.full_name))
            r = r + "," + t32_jp("return_type", t32_js(func.return_type))
            r = r + "," + t32_jp("description", t32_js(func.description))
            r = r + t32_RB()
            return t32_make_tool_result(id, r)
        nil: ()

    var r = t32_LB()
    r = r + t32_jp("kind", t32_js("unknown"))
    r = r + "," + t32_jp("name", t32_js(name))
    r = r + "," + t32_jp("description", t32_js("No documentation found for '" + name + "'"))
    r = r + t32_RB()
    t32_make_tool_result(id, r)

# --- cmm_complete: Get completions for a prefix ---

fn handle_cmm_complete(id: text, body: text) -> text:
    val prefix = t32_extract_field(body, "prefix")
    if prefix == "":
        return t32_make_tool_error(id, -32602, "Missing required parameter: prefix")

    val cmd_db = build_command_db()
    val func_db = build_function_db()

    val cmd_completions = get_completions(cmd_db, prefix)
    val func_completions = get_function_completions(func_db, prefix)

    var arr = t32_SB_L()
    var first = true

    var i = 0
    while i < cmd_completions.len() and i < 20:
        if not first:
            arr = arr + ","
        first = false
        arr = arr + t32_LB() + t32_jp("name", t32_js(cmd_completions[i].full_name)) + "," + t32_jp("kind", t32_js("command")) + "," + t32_jp("description", t32_js(cmd_completions[i].description)) + t32_RB()
        i = i + 1

    i = 0
    while i < func_completions.len() and i < 20:
        if not first:
            arr = arr + ","
        first = false
        arr = arr + t32_LB() + t32_jp("name", t32_js(func_completions[i].full_name)) + "," + t32_jp("kind", t32_js("function")) + "," + t32_jp("description", t32_js(func_completions[i].description)) + t32_RB()
        i = i + 1

    arr = arr + t32_SB_R()

    var r = t32_LB()
    r = r + t32_jp("prefix", t32_js(prefix))
    r = r + "," + t32_jp("completions", arr)
    r = r + t32_RB()
    t32_make_tool_result(id, r)

# --- cmm_goto_def: Find definition of a label or macro ---

fn handle_cmm_goto_def(id: text, body: text) -> text:
    val name = t32_extract_field(body, "name")
    val path = t32_extract_field(body, "path")
    val source = t32_extract_field(body, "source")
    if name == "":
        return t32_make_tool_error(id, -32602, "Missing required parameter: name")

    var program = CmmProgram(statements: [], file_path: "", errors: [])
    if path != "":
        if not rt_file_exists(path):
            return t32_make_tool_error(id, -32602, "File not found: " + path)
        program = parse_cmm_file(path)
    elif source != "":
        program = parse_cmm_source(source)
    else:
        return t32_make_tool_error(id, -32602, "Provide 'path' or 'source' for goto_def context")

    val result = analyze_program(program)
    val symbols = result.symbols

    # Search labels
    val labels = symbols.labels()
    var i = 0
    while i < labels.len():
        if labels[i].name == name:
            var r = t32_LB()
            r = r + t32_jp("found", t32_js("true"))
            r = r + "," + t32_jp("kind", t32_js("label"))
            r = r + "," + t32_jp("name", t32_js(name))
            r = r + "," + t32_jp("line", str(labels[i].def_line))
            r = r + t32_RB()
            return t32_make_tool_result(id, r)
        i = i + 1

    # Search macros
    val macros = symbols.macros()
    i = 0
    while i < macros.len():
        if macros[i].name == name:
            var r = t32_LB()
            r = r + t32_jp("found", t32_js("true"))
            r = r + "," + t32_jp("kind", t32_js("macro"))
            r = r + "," + t32_jp("name", t32_js(name))
            r = r + "," + t32_jp("scope", t32_js(macros[i].scope))
            r = r + "," + t32_jp("line", str(macros[i].def_line))
            r = r + t32_RB()
            return t32_make_tool_result(id, r)
        i = i + 1

    var r = t32_LB()
    r = r + t32_jp("found", t32_js("false"))
    r = r + "," + t32_jp("name", t32_js(name))
    r = r + t32_RB()
    t32_make_tool_result(id, r)

# --- cmm_symbols: List all symbols in a CMM file ---

fn handle_cmm_symbols(id: text, body: text) -> text:
    val path = t32_extract_field(body, "path")
    val source = t32_extract_field(body, "source")

    var program = CmmProgram(statements: [], file_path: "", errors: [])
    if path != "":
        if not rt_file_exists(path):
            return t32_make_tool_error(id, -32602, "File not found: " + path)
        program = parse_cmm_file(path)
    elif source != "":
        program = parse_cmm_source(source)
    else:
        return t32_make_tool_error(id, -32602, "Provide either 'path' or 'source'")

    val result = analyze_program(program)
    val symbols = result.symbols
    val labels = symbols.labels()
    val macros = symbols.macros()

    var label_arr = t32_SB_L()
    var first = true
    var i = 0
    while i < labels.len():
        if not first:
            label_arr = label_arr + ","
        first = false
        label_arr = label_arr + t32_LB() + t32_jp("name", t32_js(labels[i].name)) + "," + t32_jp("line", str(labels[i].def_line)) + t32_RB()
        i = i + 1
    label_arr = label_arr + t32_SB_R()

    var macro_arr = t32_SB_L()
    first = true
    i = 0
    while i < macros.len():
        if not first:
            macro_arr = macro_arr + ","
        first = false
        macro_arr = macro_arr + t32_LB() + t32_jp("name", t32_js(macros[i].name)) + "," + t32_jp("scope", t32_js(macros[i].scope)) + "," + t32_jp("line", str(macros[i].def_line)) + t32_RB()
        i = i + 1
    macro_arr = macro_arr + t32_SB_R()

    var r = t32_LB()
    r = r + t32_jp("labels", label_arr)
    r = r + "," + t32_jp("macros", macro_arr)
    r = r + "," + t32_jp("label_count", str(labels.len()))
    r = r + "," + t32_jp("macro_count", str(macros.len()))
    r = r + t32_RB()
    t32_make_tool_result(id, r)
