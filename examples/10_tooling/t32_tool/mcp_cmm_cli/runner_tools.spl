# T32 Tool — MCP CMM CLI: Runner tool handlers
# Tools: cmm_run_converted, cmm_diff_original

export handle_cmm_run_converted, handle_cmm_diff_original

use shared.mcp_json_base.{t32_js, t32_jp, t32_LB, t32_RB, t32_extract_field, t32_make_tool_result, t32_make_tool_error, t32_shell_cmd}
use shared.session_types.{McpT32Session}
use shared.t32rem_wrapper.{t32_find_t32rem, t32_run_remote}
use cmm.cmm_parser.{parse_cmm_file}
use converter.converter.{convert_program, emit_cmm}

extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_write_text(path: text, content: text) -> bool

fn handle_cmm_run_converted(id: text, body: text) -> text:
    val path = t32_extract_field(body, "path")
    if path == "":
        return t32_make_tool_error(id, -32602, "Missing required parameter: path")
    if not rt_file_exists(path):
        return t32_make_tool_error(id, -32602, "File not found: " + path)

    # Convert the file
    val program = parse_cmm_file(path)
    val result = convert_program(program)
    val output = emit_cmm(result)

    # Write to temp file
    val tmp_path = "/tmp/cmm_converted_" + str(path.len()) + ".cmm"
    rt_file_write_text(tmp_path, output) ?? false

    # Report conversion (actual execution requires a T32 session)
    var r = t32_LB()
    r = r + t32_jp("original", t32_js(path))
    r = r + "," + t32_jp("converted_path", t32_js(tmp_path))
    r = r + "," + t32_jp("stripped", str(result.stripped_count))
    r = r + "," + t32_jp("transformed", str(result.transformed_count))
    r = r + "," + t32_jp("status", t32_js("converted"))
    r = r + "," + t32_jp("note", t32_js("Use t32_cmm_run with this path to execute on a TRACE32 session"))
    r = r + t32_RB()
    t32_make_tool_result(id, r)

fn handle_cmm_diff_original(id: text, body: text) -> text:
    val path = t32_extract_field(body, "path")
    if path == "":
        return t32_make_tool_error(id, -32602, "Missing required parameter: path")
    if not rt_file_exists(path):
        return t32_make_tool_error(id, -32602, "File not found: " + path)

    val original = rt_file_read_text(path) ?? ""
    val program = parse_cmm_file(path)
    val result = convert_program(program)
    val converted = emit_cmm(result)

    # Simple line-by-line diff
    val orig_lines = original.split("\n")
    val conv_lines = converted.split("\n")
    var diff_lines: [text] = []
    var max_lines = orig_lines.len()
    if conv_lines.len() > max_lines:
        max_lines = conv_lines.len()

    var i = 0
    while i < max_lines:
        var orig_line = ""
        var conv_line = ""
        if i < orig_lines.len():
            orig_line = orig_lines[i]
        if i < conv_lines.len():
            conv_line = conv_lines[i]
        if orig_line != conv_line:
            diff_lines.push("L" + str(i + 1) + ":")
            diff_lines.push("  - " + orig_line)
            diff_lines.push("  + " + conv_line)
        i = i + 1

    var r = t32_LB()
    r = r + t32_jp("path", t32_js(path))
    r = r + "," + t32_jp("original_lines", str(orig_lines.len()))
    r = r + "," + t32_jp("converted_lines", str(conv_lines.len()))
    r = r + "," + t32_jp("diff_count", str(diff_lines.len() / 3))
    r = r + "," + t32_jp("diff", t32_js(diff_lines.join("\n")))
    r = r + t32_RB()
    t32_make_tool_result(id, r)
