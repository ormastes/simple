# T32 Tool — MCP CMM CLI: Converter tool handlers
# Tools: cmm_convert_file, cmm_convert_dir, cmm_preview

export handle_cmm_convert_file, handle_cmm_convert_dir, handle_cmm_preview

use shared.mcp_json_base.{t32_js, t32_jp, t32_jo1, t32_jo2, t32_LB, t32_RB, t32_extract_field, t32_make_tool_result, t32_make_tool_error}
use cmm.cmm_parser.{parse_cmm_file, parse_cmm_source}
use converter.converter.{convert_program, emit_cmm}
use converter.converter_bulk.{convert_directory}

extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_write_text(path: text, content: text) -> bool

fn handle_cmm_convert_file(id: text, body: text) -> text:
    val path = t32_extract_field(body, "path")
    if path == "":
        return t32_make_tool_error(id, -32602, "Missing required parameter: path")
    if not rt_file_exists(path):
        return t32_make_tool_error(id, -32602, "File not found: " + path)

    val program = parse_cmm_file(path)
    val result = convert_program(program)
    val output = emit_cmm(result)

    # Write converted file alongside original with .cli.cmm extension
    val out_path = path.replace(".cmm", ".cli.cmm")
    rt_file_write_text(out_path, output) ?? false

    var r = t32_LB()
    r = r + t32_jp("input", t32_js(path))
    r = r + "," + t32_jp("output", t32_js(out_path))
    r = r + "," + t32_jp("stripped", str(result.stripped_count))
    r = r + "," + t32_jp("transformed", str(result.transformed_count))
    r = r + "," + t32_jp("dialogs", str(result.dialog_count))
    r = r + "," + t32_jp("kept", str(result.kept_count))
    r = r + t32_RB()
    t32_make_tool_result(id, r)

fn handle_cmm_convert_dir(id: text, body: text) -> text:
    val input_dir = t32_extract_field(body, "input_dir")
    if input_dir == "":
        return t32_make_tool_error(id, -32602, "Missing required parameter: input_dir")

    val output_dir = t32_extract_field(body, "output_dir")
    val result = convert_directory(input_dir, output_dir, false)

    var r = t32_LB()
    r = r + t32_jp("input_dir", t32_js(input_dir))
    r = r + "," + t32_jp("total_files", str(result.total_files))
    r = r + "," + t32_jp("converted", str(result.converted_files))
    r = r + "," + t32_jp("files_with_gui", str(result.files_with_gui))
    r = r + "," + t32_jp("stripped", str(result.total_stripped))
    r = r + "," + t32_jp("transformed", str(result.total_transformed))
    r = r + "," + t32_jp("dialogs", str(result.total_dialogs))
    r = r + t32_RB()
    t32_make_tool_result(id, r)

fn handle_cmm_preview(id: text, body: text) -> text:
    val path = t32_extract_field(body, "path")
    if path == "":
        return t32_make_tool_error(id, -32602, "Missing required parameter: path")
    if not rt_file_exists(path):
        return t32_make_tool_error(id, -32602, "File not found: " + path)

    val program = parse_cmm_file(path)
    val result = convert_program(program)
    val output = emit_cmm(result)

    var r = t32_LB()
    r = r + t32_jp("path", t32_js(path))
    r = r + "," + t32_jp("preview", t32_js(output))
    r = r + "," + t32_jp("stripped", str(result.stripped_count))
    r = r + "," + t32_jp("transformed", str(result.transformed_count))
    r = r + "," + t32_jp("dialogs", str(result.dialog_count))
    r = r + t32_RB()
    t32_make_tool_result(id, r)
