# T32 Tool — Shared MCP protocol I/O
# Extracted from mcp_t32/protocol.spl for reuse across MCP servers.

export mcp_read_stdin_message, mcp_write_stdout_message

use shared.mcp_json_base.{t32_LB, t32_text_byte_len}

# Protocol auto-detection state
var MCP_USE_JSON_LINES = false
val MCP_NL = "\n"

# Read a single MCP message from stdin.
# Auto-detects Content-Length framing vs JSON-Lines.
fn mcp_read_stdin_message() -> text:
    var line = input()
    if line == "":
        return ""
    if line.ends_with("\r"):
        line = line.substring(0, line.len() - 1)
    if line.starts_with(t32_LB()):
        MCP_USE_JSON_LINES = true
        return line
    if line.starts_with("Content-Length:"):
        var len_str = line.replace("Content-Length:", "")
        len_str = len_str.trim()
        val content_length = int(len_str)
        if content_length == 0:
            return ""
        input()
        var body = input()
        return body
    ""

# Write a single MCP message to stdout.
fn mcp_write_stdout_message(body: text):
    if MCP_USE_JSON_LINES:
        print_raw(body + MCP_NL)
    else:
        val byte_count = t32_text_byte_len(body)
        var header = "Content-Length: " + str(byte_count) + "\r" + MCP_NL + "\r" + MCP_NL
        print_raw(header)
        print_raw(body)
