# T32 Tool — Shared session types
# Extracted from mcp_t32/main.spl for reuse across MCP servers and CLI.

export McpT32Session, McpT32Core, McpT32HistoryItem

class McpT32Session:
    id: text
    host: text
    port: i64
    intercom_name: text
    architecture: text
    connected: bool
    cores: [McpT32Core]

class McpT32Core:
    core_id: text
    label: text
    instance_binding: text

class McpT32HistoryItem:
    command: text
    result: text
    session_id: text
    core_id: text
