# T32 Tool — GUI command classification for CLI conversion
# Classifies TRACE32 commands as GUI-only (strip), transformable, or keep.

export is_gui_only, gui_replacement, is_gui_transform, is_gui_keep

# Check if a command is GUI-only and should be stripped entirely.
# These commands have no CLI equivalent.
fn is_gui_only(cmd: text) -> bool:
    val lower = to_lower(cmd)
    # Window positioning and management
    if lower == "winpos" or lower.starts_with("winpos "):
        return true
    if lower.starts_with("winpage."):
        return true
    if lower == "winclear" or lower.starts_with("winclear "):
        return true
    if lower == "wintabs" or lower.starts_with("wintabs "):
        return true
    if lower == "framepos" or lower.starts_with("framepos "):
        return true
    # Screen control
    if lower == "screen.on" or lower == "screen.off":
        return true
    if lower == "screen.always" or lower == "screen.wait":
        return true
    if lower == "screen.dump" or lower == "screen.display":
        return true
    if lower.starts_with("screen.on ") or lower.starts_with("screen.off "):
        return true
    if lower.starts_with("screen.always ") or lower.starts_with("screen.wait "):
        return true
    # UI chrome
    if lower == "toolbar" or lower.starts_with("toolbar "):
        return true
    if lower == "statusbar" or lower.starts_with("statusbar "):
        return true
    if lower == "header" or lower.starts_with("header "):
        return true
    if lower == "footer" or lower.starts_with("footer "):
        return true
    # Menu programming
    if lower == "menu.reprogram" or lower.starts_with("menu.reprogram "):
        return true
    if lower == "menu.rp" or lower.starts_with("menu.rp "):
        return true
    # Dialog end
    if lower == "dialog.end":
        return true
    false

# Get replacement text for a transformable GUI command.
# Returns nil if the command should not be transformed.
fn gui_replacement(cmd: text, params_text: text) -> text?:
    val lower = to_lower(cmd)
    # DIALOG.OK "message" -> PRINT "message"
    if lower == "dialog.ok":
        return Some("PRINT " + params_text)
    # DIALOG.YESNO "question" -> default Yes for headless
    if lower == "dialog.yesno":
        return Some("; [GUI-to-CLI] DIALOG.YESNO replaced with default YES\n; Original: DIALOG.YESNO " + params_text)
    nil

# Check if a command is a GUI transform target (not strip, has replacement).
fn is_gui_transform(cmd: text) -> bool:
    val lower = to_lower(cmd)
    if lower == "dialog.ok" or lower == "dialog.yesno":
        return true
    false

# Check if a command should be kept as-is even though it looks GUI-related.
# WinPrint.* IS the CLI capture mechanism and must be preserved.
fn is_gui_keep(cmd: text) -> bool:
    val lower = to_lower(cmd)
    if lower.starts_with("winprint.") or lower.starts_with("winprint "):
        return true
    if lower.starts_with("printer.file") or lower.starts_with("printer.file "):
        return true
    false

# Simple lowercase conversion for ASCII.
fn to_lower(s: text) -> text:
    var result = ""
    var i = 0
    while i < s.len():
        val ch = s[i:i + 1]
        if ch >= "A" and ch <= "Z":
            result = result + ch.to_lower()
        else:
            result = result + ch
        i = i + 1
    result
