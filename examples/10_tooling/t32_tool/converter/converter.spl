# T32 Tool — GUI-to-CLI CMM Converter
# Walks a CmmProgram AST and transforms GUI commands for headless execution.

export convert_program, emit_cmm, ConvertResult

use cmm.cmm_ast.{CmmProgram, CmmStmt, CmmExpr, CmmSpan, CmmDialogItem, span}
use cmm.cmm_parser.{parse_cmm_source, parse_cmm_file}
use converter.gui_commands.{is_gui_only, gui_replacement, is_gui_keep, is_gui_transform}

extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_exists(path: text) -> bool
extern fn sys_get_args() -> [text]

struct ConvertResult:
    output: text
    stripped_count: i64
    transformed_count: i64
    kept_count: i64
    dialog_count: i64
    total_stmts: i64

# Convert a CmmProgram by transforming GUI statements for CLI mode.
fn convert_program(program: CmmProgram) -> ConvertResult:
    var stripped = 0
    var transformed = 0
    var kept = 0
    var dialog_count = 0
    var output_lines: [text] = []

    var i = 0
    while i < program.statements.len():
        val stmt = program.statements[i]
        val result = convert_stmt(stmt)
        if result.action == "strip":
            stripped = stripped + 1
            output_lines.push("; [stripped] " + result.original)
        elif result.action == "transform":
            transformed = transformed + 1
            output_lines.push(result.replacement)
        elif result.action == "dialog":
            dialog_count = dialog_count + 1
            output_lines.push(result.replacement)
        else:
            kept = kept + 1
            output_lines.push(result.original)
        i = i + 1

    ConvertResult(
        output: output_lines.join("\n"),
        stripped_count: stripped,
        transformed_count: transformed,
        kept_count: kept,
        dialog_count: dialog_count,
        total_stmts: program.statements.len()
    )

# Per-statement conversion result
struct StmtConvertResult:
    action: text
    original: text
    replacement: text

fn convert_stmt(stmt: CmmStmt) -> StmtConvertResult:
    match stmt:
        case CmmStmt.Command(cmd, params, s):
            # Check if this is a GUI-keep command (WinPrint, PRinTer.FILE)
            if is_gui_keep(cmd):
                return StmtConvertResult(action: "keep", original: cmd + params_to_text(params), replacement: "")
            # Check if GUI-only (strip)
            if is_gui_only(cmd):
                return StmtConvertResult(action: "strip", original: cmd + params_to_text(params), replacement: "")
            # Check if transformable
            if is_gui_transform(cmd):
                val params_str = params_to_text(params)
                val replacement = gui_replacement(cmd, params_str) ?? cmd + params_str
                return StmtConvertResult(action: "transform", original: cmd + params_str, replacement: replacement)
            # Default: keep
            return StmtConvertResult(action: "keep", original: cmd + params_to_text(params), replacement: "")
        case CmmStmt.DialogBlock(items, s):
            # Convert DIALOG block: extract EDIT defaults as LOCAL vars
            val replacement = convert_dialog(items)
            return StmtConvertResult(action: "dialog", original: "DIALOG (...)", replacement: replacement)
        case CmmStmt.Block(stmts, s):
            # Recursively convert block contents
            var lines: [text] = ["("]
            var si = 0
            while si < stmts.len():
                val sub = convert_stmt(stmts[si])
                if sub.action == "strip":
                    lines.push("  ; [stripped] " + sub.original)
                elif sub.action == "transform" or sub.action == "dialog":
                    lines.push("  " + sub.replacement)
                else:
                    lines.push("  " + sub.original)
                si = si + 1
            lines.push(")")
            return StmtConvertResult(action: "keep", original: "(block)", replacement: lines.join("\n"))
        case CmmStmt.IfElse(cond, then_body, else_body, s):
            return StmtConvertResult(action: "keep", original: "IF ...", replacement: "")
        case CmmStmt.CommentLine(text_val, s):
            return StmtConvertResult(action: "keep", original: "; " + text_val, replacement: "")
        case CmmStmt.EmptyLine(s):
            return StmtConvertResult(action: "keep", original: "", replacement: "")
        case CmmStmt.LabelDef(name, s):
            return StmtConvertResult(action: "keep", original: name + ":", replacement: "")
        case CmmStmt.MacroAssign(name, expr, s):
            return StmtConvertResult(action: "keep", original: "&" + name + "=...", replacement: "")
        case CmmStmt.LocalDecl(names, s):
            return StmtConvertResult(action: "keep", original: "LOCAL " + names.join(" "), replacement: "")
        case CmmStmt.GlobalDecl(names, s):
            return StmtConvertResult(action: "keep", original: "GLOBAL " + names.join(" "), replacement: "")
        case _:
            return StmtConvertResult(action: "keep", original: "(other)", replacement: "")

# Convert DIALOG block items to LOCAL variable declarations.
fn convert_dialog(items: [CmmDialogItem]) -> text:
    var lines: [text] = ["; [GUI-to-CLI] DIALOG block converted to LOCAL variables"]
    var i = 0
    while i < items.len():
        match items[i]:
            case CmmDialogItem.DlgEdit(name, default_val, callback):
                if name != "" and default_val != "":
                    lines.push("LOCAL &" + name)
                    lines.push("&" + name + "=" + default_val)
                elif name != "":
                    lines.push("LOCAL &" + name)
            case CmmDialogItem.DlgHeader(title):
                lines.push("; Dialog: " + title)
            case CmmDialogItem.DlgText(label):
                lines.push("; " + label)
            case _:
                i = i + 1
                continue
        i = i + 1
    lines.join("\n")

# Convert expression list to text representation.
fn params_to_text(params: [CmmExpr]) -> text:
    if params.len() == 0:
        return ""
    var parts: [text] = []
    var i = 0
    while i < params.len():
        parts.push(expr_to_text(params[i]))
        i = i + 1
    " " + parts.join(" ")

# Simple expression-to-text conversion.
fn expr_to_text(expr: CmmExpr) -> text:
    match expr:
        case CmmExpr.Lit(lit): return "(lit)"
        case CmmExpr.MacroRef(name): return "&" + name
        case CmmExpr.Ident(name): return name
        case CmmExpr.DotPath(path): return path
        case CmmExpr.OptionFlag(flag): return "/" + flag
        case CmmExpr.FunctionCall(name, args): return name + "(...)"
        case _: return "..."

# Emit CMM source from converted output (simple pass-through).
fn emit_cmm(converted: ConvertResult) -> text:
    converted.output

# --- CLI entry point ---

fn converter_main():
    val args = sys_get_args()
    if args.len() < 2:
        print "Usage: converter.spl <file.cmm>"
        print "Converts GUI-oriented CMM scripts to CLI-compatible form."
        return
    val path = args[1]
    if not rt_file_exists(path):
        print "Error: file not found: {path}"
        return
    val program = parse_cmm_file(path)
    val result = convert_program(program)
    print result.output
    print ""
    print "; === Conversion Summary ==="
    print "; Total statements: {result.total_stmts}"
    print "; Stripped (GUI-only): {result.stripped_count}"
    print "; Transformed: {result.transformed_count}"
    print "; Dialog blocks: {result.dialog_count}"
    print "; Kept as-is: {result.kept_count}"

converter_main()
