# T32 Tool — Conversion Report Generator
# Generates detailed statistics about GUI command usage in CMM files.

export generate_report, GuiCommandStats, GuiReport

use cmm.cmm_parser.{parse_cmm_source}
use cmm.cmm_ast.{CmmStmt, CmmProgram}
use converter.gui_commands.{is_gui_only, is_gui_transform, is_gui_keep}

extern fn rt_file_read_text(path: text) -> text
extern fn rt_dir_list(path: text) -> [text]
extern fn sys_get_args() -> [text]

struct GuiCommandStats:
    command: text
    count: i64

struct GuiReport:
    total_files: i64
    total_gui_commands: i64
    command_stats: [GuiCommandStats]
    top_gui_files: [text]

# Generate a report about GUI command usage in a directory.
fn generate_report(dir: text) -> GuiReport:
    var total_files = 0
    var total_gui = 0
    var cmd_counts: [text] = []
    var cmd_values: [i64] = []
    var gui_files: [text] = []

    val files = collect_cmm_files_report(dir)
    var i = 0
    while i < files.len():
        val path = files[i]
        total_files = total_files + 1

        val content = rt_file_read_text(path) ?? ""
        if content.starts_with("trace32 encrypted cmm file"):
            i = i + 1
            continue

        val program = parse_cmm_source(content)
        var file_gui_count = 0

        var si = 0
        while si < program.statements.len():
            val cmd_name = get_command_name(program.statements[si])
            if cmd_name != "" and is_gui_only(cmd_name):
                file_gui_count = file_gui_count + 1
                total_gui = total_gui + 1
                # Track command frequency
                var found = false
                var ci = 0
                while ci < cmd_counts.len():
                    if cmd_counts[ci] == cmd_name.to_lower():
                        cmd_values[ci] = cmd_values[ci] + 1
                        found = true
                    ci = ci + 1
                if not found:
                    cmd_counts.push(cmd_name.to_lower())
                    cmd_values.push(1)
            si = si + 1

        if file_gui_count > 0 and gui_files.len() < 20:
            gui_files.push("{path} ({file_gui_count} GUI commands)")

        if total_files % 200 == 0:
            print "  ... scanned {total_files} files"

        i = i + 1

    # Build stats array
    var stats: [GuiCommandStats] = []
    var ci = 0
    while ci < cmd_counts.len():
        stats.push(GuiCommandStats(command: cmd_counts[ci], count: cmd_values[ci]))
        ci = ci + 1

    GuiReport(
        total_files: total_files,
        total_gui_commands: total_gui,
        command_stats: stats,
        top_gui_files: gui_files
    )

# Extract command name from a statement.
fn get_command_name(stmt: CmmStmt) -> text:
    match stmt:
        case CmmStmt.Command(cmd, params, s): return cmd
        case CmmStmt.DeviceCommand(dev, cmd, params, s): return cmd
        case _: return ""

fn collect_cmm_files_report(dir: text) -> [text]:
    var results: [text] = []
    val entries = rt_dir_list(dir)
    var i = 0
    while i < entries.len():
        val entry = entries[i]
        if entry == "." or entry == "..":
            i = i + 1
            continue
        val full_path = dir + "/" + entry
        if entry.len() >= 5 and entry[entry.len() - 4:entry.len()].to_lower() == ".cmm":
            results.push(full_path)
        elif not entry.contains("."):
            val sub = collect_cmm_files_report(full_path)
            var si = 0
            while si < sub.len():
                results.push(sub[si])
                si = si + 1
        i = i + 1
    results

# --- CLI entry point ---

fn report_main():
    val args = sys_get_args()
    var dir = "/opt/t32/demo"
    if args.len() >= 2:
        dir = args[1]

    print "T32 Tool — GUI Command Report"
    print "Scanning: {dir}"
    print ""

    val report = generate_report(dir)

    print ""
    print "=== GUI Command Usage Report ==="
    print "Total CMM files scanned: {report.total_files}"
    print "Total GUI commands found: {report.total_gui_commands}"
    print ""

    if report.command_stats.len() > 0:
        print "--- Command Frequency ---"
        var i = 0
        while i < report.command_stats.len():
            print "  {report.command_stats[i].command}: {report.command_stats[i].count}"
            i = i + 1
        print ""

    if report.top_gui_files.len() > 0:
        print "--- Top Files with GUI Commands (max 20) ---"
        var fi = 0
        while fi < report.top_gui_files.len():
            print "  {report.top_gui_files[fi]}"
            fi = fi + 1

report_main()
