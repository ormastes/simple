# T32 Tool — Bulk GUI-to-CLI CMM Converter
# Converts all CMM files in a directory tree (e.g. /opt/t32/demo).

export convert_directory, BulkConvertResult

use cmm.cmm_parser.{parse_cmm_source}
use converter.converter.{convert_program, ConvertResult}

extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_dir_list(path: text) -> [text]
extern fn sys_get_args() -> [text]

struct BulkConvertResult:
    total_files: i64
    converted_files: i64
    skipped_encrypted: i64
    total_stripped: i64
    total_transformed: i64
    total_dialogs: i64
    files_with_gui: i64
    error_files: i64

# Convert all .cmm files in a directory tree.
fn convert_directory(input_dir: text, output_dir: text, report_only: bool) -> BulkConvertResult:
    var result = BulkConvertResult(
        total_files: 0, converted_files: 0, skipped_encrypted: 0,
        total_stripped: 0, total_transformed: 0, total_dialogs: 0,
        files_with_gui: 0, error_files: 0
    )

    val files = collect_cmm_files(input_dir)
    var i = 0
    while i < files.len():
        val path = files[i]
        result.total_files = result.total_files + 1

        val content = rt_file_read_text(path) ?? ""
        if content.starts_with("trace32 encrypted cmm file"):
            result.skipped_encrypted = result.skipped_encrypted + 1
            i = i + 1
            continue

        val program = parse_cmm_source(content)
        if program.errors.len() > 0:
            result.error_files = result.error_files + 1
            i = i + 1
            continue

        val conv = convert_program(program)
        result.total_stripped = result.total_stripped + conv.stripped_count
        result.total_transformed = result.total_transformed + conv.transformed_count
        result.total_dialogs = result.total_dialogs + conv.dialog_count

        if conv.stripped_count > 0 or conv.transformed_count > 0 or conv.dialog_count > 0:
            result.files_with_gui = result.files_with_gui + 1

        if not report_only and output_dir != "":
            # Write converted file to output directory
            val rel_path = path.replace(input_dir, "")
            val out_path = output_dir + rel_path
            rt_file_write_text(out_path, conv.output) ?? false

        result.converted_files = result.converted_files + 1

        if result.total_files % 100 == 0:
            print "  ... processed {result.total_files} files"

        i = i + 1

    result

# Recursively collect .cmm files.
fn collect_cmm_files(dir: text) -> [text]:
    var results: [text] = []
    val entries = rt_dir_list(dir)
    var i = 0
    while i < entries.len():
        val entry = entries[i]
        if entry == "." or entry == "..":
            i = i + 1
            continue
        val full_path = dir + "/" + entry
        if entry.len() >= 5 and entry[entry.len() - 4:entry.len()].to_lower() == ".cmm":
            results.push(full_path)
        elif not entry.contains("."):
            val sub = collect_cmm_files(full_path)
            var si = 0
            while si < sub.len():
                results.push(sub[si])
                si = si + 1
        i = i + 1
    results

# --- CLI entry point ---

fn bulk_main():
    val args = sys_get_args()
    var input_dir = "/opt/t32/demo"
    var output_dir = ""
    var report_only = false

    var ai = 1
    while ai < args.len():
        if args[ai] == "--report-only":
            report_only = true
        elif args[ai] == "--output" and ai + 1 < args.len():
            output_dir = args[ai + 1]
            ai = ai + 1
        else:
            input_dir = args[ai]
        ai = ai + 1

    print "T32 Tool — Bulk GUI-to-CLI Converter"
    print "Input: {input_dir}"
    if report_only:
        print "Mode: report only (no files written)"
    elif output_dir != "":
        print "Output: {output_dir}"
    print ""

    val result = convert_directory(input_dir, output_dir, report_only)

    print ""
    print "=== Bulk Conversion Summary ==="
    print "Total CMM files:     {result.total_files}"
    print "Converted:           {result.converted_files}"
    print "Parse errors:        {result.error_files}"
    print "Encrypted (skipped): {result.skipped_encrypted}"
    print ""
    print "Files with GUI commands: {result.files_with_gui}"
    print "GUI commands stripped:   {result.total_stripped}"
    print "Commands transformed:    {result.total_transformed}"
    print "Dialog blocks converted: {result.total_dialogs}"

    if result.total_files > 0:
        val gui_pct = result.files_with_gui * 100 / result.total_files
        print ""
        print "GUI usage rate: {gui_pct}% of files contain GUI commands"

bulk_main()
