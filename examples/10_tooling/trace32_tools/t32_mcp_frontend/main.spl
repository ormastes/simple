# T32 MCP Server — TRACE32 debug session control via MCP protocol
#
# Tools: 36 tools for session management, window capture, action invocation,
#        headless setup, AREA buffer, command database, CMM validation, async jobs,
#        and dialog interaction
# Protocol: MCP 2025-06-18 (Content-Length framing + JSON-Lines auto-detect)
#
# Architecture: Zero stdlib imports — all JSON helpers and transport inlined.
#   Avoids loading the entire src/lib/ module tree via mcp_sdk (8GB+ RSS OOM).
#
# Split into multiple files:
#   - json_helpers.spl    — Inlined JSON building/parsing/extraction (zero imports)
#   - protocol.spl        — Protocol I/O, initialize, tools list, schemas, T32-specific wrappers
#   - session_tools.spl   — Session/core/command tool handlers
#   - window_tools.spl    — Window tool handlers
#   - action_tools.spl    — Action/field/history/resource handlers + dispatcher
#   - gap_tools.spl       — Gap closure tools: session_info, action_list, status_snapshot, cmm_validate
#   - job_manager.spl     — Async job manager: create, get, list, cancel, cleanup
#   - snapshot_store.spl  — Window snapshot store: hash, diff (structured/table/text), capture-with-diff
#   - headless_tools.spl  — Headless setup, AREA read, CMM command database
#   - tool_common.spl     — Shared leaf helpers used across families
#   - action_tools.spl    — Action/field/history/resource handlers + dispatcher

extern fn rt_file_read_text(path: text) -> text
extern fn rt_dir_list(path: text) -> [text]
extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_env_get(name: text) -> text
extern fn rt_env_cwd() -> text
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_delete(path: text) -> bool
extern fn rt_file_exists(path: text) -> bool
extern fn rt_time_now_unix_micros() -> i64
extern fn stderr_write(data: text) -> i64
extern fn stderr_flush() -> i64

use t32_mcp_frontend.startup_protocol.{t32_read_stdin_message, t32_write_stdout_message, t32_make_json_result, t32_make_error, t32_make_init_response, t32_startup_extract_field, t32_startup_extract_id}
use t32_mcp_shared.state
use t32_mcp_frontend.startup_router.{t32_startup_dispatch_tool, t32_startup_make_resources_list, t32_startup_make_tools_list, t32_startup_handle_resource_read}

fn t32_startup_diag(message: text):
    stderr_write("[t32-mcp] " + message + "\n")
    stderr_flush()

fn t32_server_name() -> text:
    return "simple-mcp-t32"

fn t32_server_version() -> text:
    return "0.1.2"

fn t32_nl() -> text:
    return "\n"

fn t32_debug_enabled() -> bool:
    return (rt_env_get("T32_MCP_DEBUG") ?? "") != ""

fn t32_debug_diag(message: text):
    if t32_debug_enabled():
        t32_startup_diag("debug: " + message)

fn t32_debug_file_path() -> text:
    rt_env_get("T32_MCP_DEBUG_FILE") ?? ""

fn t32_debug_file_write(message: text):
    val path = t32_debug_file_path()
    if path != "":
        rt_file_write_text(path, message)

fn t32_debug_trace(message: text):
    t32_debug_diag(message)
    t32_debug_file_write(message)

fn t32_value_after_prefix(line: text, prefix: text) -> text:
    if line.len() <= prefix.len():
        return ""
    return line.substring(prefix.len()).trim()

fn t32_parse_i64(s: text) -> i64:
    if s == "":
        return 0
    var i = 0
    var sign = 1
    if s.starts_with("-"):
        sign = -1
        i = 1
    var value = 0
    while i < s.len():
        val ch = s.substring(i, i + 1)
        if ch < "0" or ch > "9":
            break
        value = value * 10 + (ch.to_int() - "0".to_int())
        i = i + 1
    return value * sign

fn t32_make_resource_templates_list(id: text) -> text:
    return t32_make_json_result(id, "{\"resourceTemplates\":[]}")

var T32_TOOL_DAEMON_DIR = ""
var T32_TOOL_DAEMON_PID = -1
var T32_TOOL_DAEMON_SEQ = 0
var T32_TOOL_DAEMON_ERROR = ""

fn t32_apply_config_file(config_path: text):
    if not rt_file_exists(config_path):
        t32_startup_diag("startup warning: config file not found: " + config_path)
        return
    val content = rt_file_read_text(config_path) ?? ""
    if content == "":
        return
    val lines = content.split("\n")
    for line in lines:
        val trimmed = line.trim()
        if trimmed.starts_with("default_port:"):
            val port_str = t32_value_after_prefix(trimmed, "default_port:")
            T32_DEFAULT_PORT = t32_parse_i64(port_str)
        if trimmed.starts_with("default_host:"):
            T32_DEFAULT_HOST = t32_value_after_prefix(trimmed, "default_host:")
        if trimmed.starts_with("rcl_port:"):
            val port_str = t32_value_after_prefix(trimmed, "rcl_port:")
            T32_RCL_PORT = t32_parse_i64(port_str)
        if trimmed.starts_with("rcl_host:"):
            T32_RCL_HOST = t32_value_after_prefix(trimmed, "rcl_host:")
        if trimmed.starts_with("backend_preference:"):
            T32_BACKEND_PREFERENCE = t32_value_after_prefix(trimmed, "backend_preference:")
        if trimmed.starts_with("python_binary:"):
            T32_PYTHON_BINARY = t32_value_after_prefix(trimmed, "python_binary:")
        if trimmed.starts_with("python_bridge:"):
            T32_PYTHON_BRIDGE_PATH = t32_value_after_prefix(trimmed, "python_bridge:")
        if trimmed.starts_with("api_lib_path:"):
            T32_API_LIB_PATH = t32_value_after_prefix(trimmed, "api_lib_path:")

fn t32_load_default_config(config_path: text):
    # Config file loading is opt-in to keep native startup small and predictable.
    if config_path != "":
        t32_apply_config_file(config_path)
    # Environment variables override defaults/config file.
    val env_port = rt_env_get("T32_DEFAULT_PORT") ?? ""
    if env_port != "":
        T32_DEFAULT_PORT = t32_parse_i64(env_port)
    val env_host = rt_env_get("T32_DEFAULT_HOST") ?? ""
    if env_host != "":
        T32_DEFAULT_HOST = env_host
    val env_rcl_port = rt_env_get("T32_RCL_PORT") ?? ""
    if env_rcl_port != "":
        T32_RCL_PORT = t32_parse_i64(env_rcl_port)
    val env_rcl_host = rt_env_get("T32_RCL_HOST") ?? ""
    if env_rcl_host != "":
        T32_RCL_HOST = env_rcl_host
    val env_backend = rt_env_get("T32_BACKEND_PREFERENCE") ?? ""
    if env_backend != "":
        T32_BACKEND_PREFERENCE = env_backend
    val env_python = rt_env_get("T32_PYTHON") ?? ""
    if env_python != "":
        T32_PYTHON_BINARY = env_python
    val env_api_lib = rt_env_get("T32_API_LIB") ?? ""
    if env_api_lib != "":
        T32_API_LIB_PATH = env_api_lib
    val env_bridge = rt_env_get("T32_PYTHON_BRIDGE") ?? ""
    if env_bridge != "":
        T32_PYTHON_BRIDGE_PATH = env_bridge
    if T32_DEFAULT_HOST == "":
        T32_DEFAULT_HOST = T32_RCL_HOST
    if T32_DEFAULT_PORT == 0:
        T32_DEFAULT_PORT = T32_RCL_PORT

fn t32_shell_quote(value: text) -> text:
    if value == "":
        return "''"
    var parts: [text] = []
    parts.push("'")
    var i = 0
    while i < value.len():
        val ch = value.substring(i, i + 1)
        if ch == "'":
            parts.push("'\\''")
        else:
            parts.push(ch)
        i = i + 1
    parts.push("'")
    return parts.join("")

fn t32_shell_dquote(value: text) -> text:
    return "\"" + value.replace("\"", "\\\"") + "\""

fn t32_sanitize_path_segment(value: text) -> text:
    if value == "":
        return "empty"
    var parts: [text] = []
    var i = 0
    while i < value.len():
        val ch = value.substring(i, i + 1)
        if (ch >= "a" and ch <= "z") or (ch >= "A" and ch <= "Z") or (ch >= "0" and ch <= "9") or ch == "_" or ch == "-":
            parts.push(ch)
        else:
            parts.push("_")
        i = i + 1
    val sanitized = parts.join("")
    if sanitized == "":
        return "empty"
    return sanitized

fn t32_shell_bin_path() -> text:
    val env_shell = rt_env_get("T32_MCP_SHELL_BIN") ?? ""
    if env_shell != "":
        return env_shell
    if rt_file_exists("/usr/bin/sh"):
        return "/usr/bin/sh"
    return "/bin/sh"

fn t32_tool_runtime_path() -> text:
    val env_runtime = rt_env_get("SIMPLE_RUNTIME") ?? ""
    if env_runtime != "":
        return env_runtime
    if rt_file_exists("src/compiler_rust/target/release/simple"):
        return "src/compiler_rust/target/release/simple"
    if rt_file_exists("bin/simple"):
        return "bin/simple"
    if rt_file_exists("bin/release/simple"):
        return "bin/release/simple"
    if rt_file_exists("bin/release/linux-x86_64/simple"):
        return "bin/release/linux-x86_64/simple"
    if rt_file_exists("bin/release/simple.exe"):
        return "bin/release/simple.exe"
    return "bin/release/simple"

fn t32_tool_daemon_path() -> text:
    val env_daemon = rt_env_get("T32_MCP_TOOL_DAEMON") ?? ""
    if env_daemon != "":
        return env_daemon
    return "src/app/t32_mcp_worker_light/main.spl"

fn t32_tool_daemon_dir() -> text:
    if T32_TOOL_DAEMON_DIR != "":
        return T32_TOOL_DAEMON_DIR
    val env_dir = rt_env_get("T32_MCP_TOOL_DAEMON_DIR") ?? ""
    if env_dir != "":
        T32_TOOL_DAEMON_DIR = env_dir
        return T32_TOOL_DAEMON_DIR
    val cwd = rt_env_cwd()
    var suffix = "workspace"
    if cwd != "":
        suffix = t32_sanitize_path_segment(cwd)
    T32_TOOL_DAEMON_DIR = "/tmp/t32_mcp_shared_" + suffix
    return T32_TOOL_DAEMON_DIR

fn t32_next_tool_request_key(id: text) -> text:
    T32_TOOL_DAEMON_SEQ = T32_TOOL_DAEMON_SEQ + 1
    return "req_" + str(T32_TOOL_DAEMON_SEQ) + "_" + t32_sanitize_path_segment(id) + "_" + str(rt_time_now_unix_micros())

fn t32_tool_daemon_is_alive(daemon_dir: text) -> bool:
    val match_text = t32_tool_daemon_path() + " " + daemon_dir
    val cmd = "ps -ef | grep -F -- " + t32_shell_dquote(match_text) + " | grep -Fv grep >/dev/null 2>&1"
    val (_stdout, _stderr, code) = rt_process_run(t32_shell_bin_path(), ["-c", cmd])
    return code == 0

fn t32_mkdir_p(path: text) -> bool:
    var stdout = ""
    var stderr = ""
    var code: i64 = 0
    (stdout, stderr, code) = rt_process_run("/bin/mkdir", ["-p", path])
    return code == 0

fn t32_wait_for_daemon_ready(daemon_dir: text, timeout_ms: i64) -> bool:
    val started = rt_time_now_unix_micros()
    val ready_path = daemon_dir + "/ready"
    while true:
        if rt_file_exists(ready_path) and t32_tool_daemon_is_alive(daemon_dir):
            return true
        val elapsed_ms = (rt_time_now_unix_micros() - started) / 1000
        if elapsed_ms >= timeout_ms:
            return false
        rt_process_run(t32_shell_bin_path(), ["-c", "sleep 0.05"])

fn t32_reset_tool_daemon_state(daemon_dir: text):
    val entries = rt_dir_list(daemon_dir) ?? []
    var i = 0
    while i < entries.len():
        val name = entries[i]
        if name == "ready" or name.ends_with(".req") or name.ends_with(".body.json") or name.ends_with(".response.json"):
            rt_file_delete(daemon_dir + "/" + name)
        i = i + 1
    T32_TOOL_DAEMON_PID = -1

fn t32_start_tool_daemon() -> bool:
    val daemon_dir = t32_tool_daemon_dir()
    T32_TOOL_DAEMON_ERROR = ""
    if not t32_mkdir_p(daemon_dir):
        T32_TOOL_DAEMON_ERROR = "Failed to create T32 tool daemon dir: " + daemon_dir
        return false
    if t32_tool_daemon_is_alive(daemon_dir):
        if t32_wait_for_daemon_ready(daemon_dir, 1500):
            T32_TOOL_DAEMON_PID = 1
            return true
        T32_TOOL_DAEMON_ERROR = "T32 tool daemon is running but never became ready"
        return false
    if rt_file_exists(daemon_dir + "/ready") or T32_TOOL_DAEMON_PID > 0:
        t32_reset_tool_daemon_state(daemon_dir)
    val runtime = t32_tool_runtime_path()
    val daemon_entry = t32_tool_daemon_path()
    val daemon_log = daemon_dir + "/daemon.log"
    val launch_cmd = "nohup " + t32_shell_dquote(runtime) + " " + t32_shell_dquote(daemon_entry) + " " + t32_shell_dquote(daemon_dir) + " >" + t32_shell_dquote(daemon_log) + " 2>&1 < /dev/null &"
    val (stdout, stderr, code) = rt_process_run(t32_shell_bin_path(), ["-c", launch_cmd])
    if code != 0:
        T32_TOOL_DAEMON_ERROR = "Failed to launch T32 tool daemon: " + t32_trim_error_text(stderr, stdout)
        return false
    T32_TOOL_DAEMON_PID = 1
    if t32_wait_for_daemon_ready(daemon_dir, 5000):
        return true
    T32_TOOL_DAEMON_ERROR = "T32 tool daemon failed to become ready"
    return false

fn t32_wait_for_tool_response(path: text, timeout_ms: i64) -> text:
    val started = rt_time_now_unix_micros()
    val daemon_dir = t32_tool_daemon_dir()
    while true:
        if rt_file_exists(path):
            return (rt_file_read_text(path) ?? "").trim()
        if not t32_tool_daemon_is_alive(daemon_dir):
            return ""
        val elapsed_ms = (rt_time_now_unix_micros() - started) / 1000
        if elapsed_ms >= timeout_ms:
            return ""
        rt_process_run(t32_shell_bin_path(), ["-c", "sleep 0.05"])

fn t32_trim_error_text(stderr: text, stdout: text) -> text:
    var raw = stderr.trim()
    if raw == "":
        raw = stdout.trim()
    if raw == "":
        return "unknown error"
    if raw.len() > 240:
        return raw[0:240]
    return raw

fn t32_dispatch_via_daemon(id: text, method: text, body: text) -> text:
    if not t32_start_tool_daemon():
        return ""
    val daemon_dir = t32_tool_daemon_dir()
    val base = daemon_dir + "/" + t32_next_tool_request_key(id)
    val body_path = base + ".body.json"
    val req_path = base + ".req"
    val response_path = base + ".response.json"
    if not rt_file_write_text(body_path, body):
        return ""
    val request_body = method + t32_nl() + id + t32_nl() + body_path + t32_nl() + response_path + t32_nl()
    if not rt_file_write_text(req_path, request_body):
        rt_file_delete(body_path)
        return ""
    val response = t32_wait_for_tool_response(response_path, 1000)
    rt_file_delete(req_path)
    rt_file_delete(body_path)
    rt_file_delete(response_path)
    if response == "":
        T32_TOOL_DAEMON_PID = -1
        return ""
    return response

# --- Entry point ---

fn main():
    # Keep startup minimal. Session/backend configuration is resolved lazily
    # in the tool paths that actually need it.
    t32_start_server()

fn t32_start_server():
    while true:
        var msg = t32_read_stdin_message()
        t32_debug_trace("read message bytes=" + str(msg.len()))
        if msg == "":
            if not T32_SEEN_FIRST_MESSAGE:
                t32_startup_diag("startup error: no MCP request received on stdin")
            return
        else:
            T32_SEEN_FIRST_MESSAGE = true
            var method = t32_startup_extract_field(msg, "method")
            var id = t32_startup_extract_id(msg)
            var response = ""
            t32_debug_trace("parsed method=<" + method + "> id=<" + id + ">")
            if method == "initialize":
                t32_startup_diag("initialize received; server version " + t32_server_version())
                response = t32_make_init_response(id)
            elif method == "initialized" or method == "notifications/initialized":
                response = ""
            elif method == "shutdown":
                response = t32_make_json_result(id, "null")
            elif method == "tools/list":
                response = t32_startup_make_tools_list(id)
            elif method == "tools/call":
                val tool_name = t32_startup_extract_field(msg, "name")
                if tool_name == "t32_sessions_list" or tool_name == "t32_resources_list" or tool_name == "t32_session_resume" or tool_name == "t32_session_close":
                    response = t32_startup_dispatch_tool(id, msg)
                else:
                    response = t32_dispatch_via_daemon(id, method, msg)
                    if response == "":
                        response = t32_startup_dispatch_tool(id, msg)
            elif method == "resources/list":
                response = t32_startup_make_resources_list(id)
            elif method == "resources/templates/list":
                response = t32_make_resource_templates_list(id)
            elif method == "resources/read":
                response = t32_startup_handle_resource_read(id, msg)
            elif method == "prompts/list":
                response = t32_make_json_result(id, "{\"prompts\":[]}")
            elif method == "roots/list":
                response = t32_make_json_result(id, "{\"roots\":[]}")
            elif method == "logging/setLevel" or method == "logging/setlevel":
                response = t32_make_json_result(id, "null")
            elif method == "ping":
                response = t32_make_json_result(id, "{}")
            elif method == "notifications/cancelled" or method == "notifications/roots/list_changed":
                response = ""
            else:
                if method == "":
                    t32_startup_diag("protocol error: request missing method field: " + msg)
                if id != "" and id != "null":
                    response = t32_make_error(id, -32601, "Method not found: " + method)
            t32_debug_trace("response bytes=" + str(response.len()))
            if response != "":
                t32_debug_trace("writing response")
                t32_write_stdout_message(response)
