# T32 CLI — command-line interface for TRACE32 sessions
# All commands route through bridge.spl (shared execution) + render.spl (formatting).

use app.t32_cli.types.{T32BridgeResult}
use app.t32_cli.bridge.{bridge_sessions_list, bridge_session_open, bridge_session_resume, bridge_session_close, bridge_session_info, bridge_core_list, bridge_core_select, bridge_cmd_run, bridge_cmm_run, bridge_eval, bridge_window_list, bridge_window_open, bridge_window_capture, bridge_window_describe, bridge_screenshot, bridge_action_invoke_with_request, t32_action_request_id, bridge_action_list, bridge_field_get, bridge_field_set, bridge_history_tail, bridge_resources_list, bridge_resource_read, bridge_setup_headless, bridge_area_read, bridge_cmm_commands, bridge_cmm_validate, bridge_status_snapshot, bridge_error_check, bridge_job_list, bridge_job_get, bridge_job_cancel, bridge_job_result, bridge_dialog_parse, bridge_dialog_get, bridge_dialog_set, bridge_dialog_click}
use app.t32_cli.render.{render_result, render_error}
use app.t32_cli.commands.{all_top_level_names, subcmds_for, find_shared_access_command}
use app.t32_cli.cli_shell.{start_t32_shell}
use app.t32_cli.error_codes.{t32_err_unknown_cmd, t32_err_unknown_subcmd, t32_err_missing_args}
export use app.t32_cli.access_error.{t32_map_access_error}
use common.ui.access_cli_grammar.{AccessRequest, AccessError, access_validate_request, access_render_json, access_error_to_json, ACCESS_OPERATION_SURFACE, ACCESS_OPERATION_ACT, ACCESS_OUTPUT_HUMAN, ACCESS_OUTPUT_JSON}
use app.io.mod.{eprint}
use app.mcp_t32.session_state.{MCP_T32_CURRENT_SESSION, MCP_T32_CURRENT_CORE}
use app.mcp_t32.session_tools.{t32_add_history_with_request}

extern fn sys_get_args() -> [text]

var t32_access_operation = ""
var t32_access_output_mode = ACCESS_OUTPUT_HUMAN
var t32_access_exit_code: i32 = 0
var t32_access_request_id = ""
var t32_access_timeout_ms: i64 = 5000
var t32_access_confirmed = false

pub fn t32_cli_main(args: [text]) -> i32:
    t32_access_exit_code = 0
    if args.len() == 0:
        print_usage()
        return 0

    val dispatch_args = match prepare_access_args(args):
        Err(access_error):
            record_t32_access_failure(access_error)
            print_typed_access_error(access_error, true)
            return t32_access_exit_code
        Ok(prepared): prepared
    val cmd = dispatch_args[0]
    var rest: [text] = []
    var i = 1
    while i < dispatch_args.len():
        rest.push(dispatch_args[i])
        i = i + 1

    match cmd:
        "sessions": cmd_sessions(rest)
        "cores": cmd_cores(rest)
        "windows": cmd_windows(rest)
        "window": cmd_window(rest)
        "field": cmd_field(rest)
        "action": cmd_action(rest)
        "screenshot": cmd_screenshot(rest)
        "cmm": cmd_cmm(rest)
        "cmd": cmd_cmd(rest)
        "eval": cmd_eval(rest)
        "status": cmd_status(rest)
        "history": cmd_history(rest)
        "resources": cmd_resources(rest)
        "resource": cmd_resource(rest)
        "headless": cmd_headless(rest)
        "area": cmd_area(rest)
        "cmm-commands": cmd_cmm_commands(rest)
        "cmm-validate": cmd_cmm_validate(rest)
        "jobs": cmd_jobs(rest)
        "dialog": cmd_dialog(rest)
        "error-check": cmd_error_check(rest)
        "shell": cmd_shell(rest)
        "help": print_usage()
        "--help": print_usage()
        _:
            print t32_err_unknown_cmd(cmd)
            t32_access_exit_code = 2
    t32_access_exit_code

fn main() -> i32:
    val raw_args = sys_get_args()
    var args = raw_args
    if args.len() >= 2 and not args[0].ends_with(".spl") and args[1].ends_with(".spl"):
        args = args[2:args.len()]
    elif args.len() >= 1 and (args[0].ends_with(".spl") or args[0].ends_with("t32-cli") or args[0].ends_with("t32_cli")):
        args = args[1:args.len()]
    t32_cli_main(args)

# --- Helper: print bridge result or error ---

fn print_bridge(result: Result<T32BridgeResult, text>):
    match result:
        Ok(r):
            var normalized = r
            if t32_access_operation != "":
                normalized.operation = t32_access_operation
                normalized.source_id = "t32"
                normalized.correlation_id = t32_access_request_id
            if t32_access_output_mode == ACCESS_OUTPUT_JSON and t32_access_operation != "":
                print access_render_json(normalized)
            else:
                print render_result(normalized)
        Err(e): print_access_error(e, true)

fn print_access_error(message: text, decorate_human: bool):
    print_typed_access_error(t32_map_access_error(message), decorate_human)

fn print_typed_access_error(access_error: AccessError, decorate_human: bool):
    t32_access_exit_code = 1
    if t32_access_output_mode == ACCESS_OUTPUT_JSON and t32_access_operation != "":
        print access_error_to_json(t32_access_operation, t32_access_request_id, access_error)
    elif decorate_human:
        eprint render_error(access_error.message)
    else:
        eprint access_error.message

fn record_t32_access_failure(access_error: AccessError):
    if t32_access_operation != ACCESS_OPERATION_ACT or t32_access_request_id == "":
        return
    t32_add_history_with_request("access_request action", "request", MCP_T32_CURRENT_SESSION, MCP_T32_CURRENT_CORE, t32_access_request_id)
    t32_add_history_with_request("access_result action", "code=" + access_error.code, MCP_T32_CURRENT_SESSION, MCP_T32_CURRENT_CORE, t32_access_request_id)

fn prepare_access_args(args: [text]) -> Result<[text], AccessError>:
    t32_access_operation = ""
    t32_access_output_mode = ACCESS_OUTPUT_HUMAN
    t32_access_request_id = ""
    t32_access_timeout_ms = 5000
    t32_access_confirmed = false
    val name = args[0]
    var subcmd = ""
    if (name == "window" or name == "action") and args.len() > 1:
        subcmd = args[1]
    if has_flag(args, "--json") and ((name == "window" and subcmd != "open") or name == "action"):
        t32_access_output_mode = ACCESS_OUTPUT_JSON
        t32_access_operation = if name == "window": ACCESS_OPERATION_SURFACE else: ACCESS_OPERATION_ACT
    match find_shared_access_command(name, subcmd):
        Some(descriptor):
            t32_access_operation = descriptor.operation
            t32_access_timeout_ms = descriptor.safety.timeout_ms
            if descriptor.operation == ACCESS_OPERATION_ACT:
                t32_access_request_id = t32_action_request_id()
            var prepared = args
            if has_flag(args, "--json"):
                t32_access_output_mode = ACCESS_OUTPUT_JSON
                prepared = without_flag(args, "--json")
            val confirmed = has_flag(args, "--confirm")
            t32_access_confirmed = confirmed
            if descriptor.operation == ACCESS_OPERATION_ACT and confirmed:
                prepared = without_flag(prepared, "--confirm")
            val first_arg = if descriptor.subcommand == "": 1 else: 2
            var request_args: [text] = []
            var i = first_arg
            while i < prepared.len():
                request_args.push(prepared[i])
                i = i + 1
            val request = AccessRequest.create(descriptor, t32_access_output_mode, "t32", "", t32_access_request_id, request_args, descriptor.safety.timeout_ms, confirmed)
            access_validate_request(request)?
            if request_args.len().to_i64() > t32_access_max_args(descriptor.handler_key):
                return Err(AccessError.detailed("invalid_argument", "too many arguments", "", "Usage: " + descriptor.usage, false, false))
            if descriptor.handler_key == "t32_history_tail" and request_args.len() == 1 and not t32_positive_decimal(request_args[0]):
                return Err(AccessError.detailed("invalid_argument", "history count must be a positive integer", "", "Usage: " + descriptor.usage, false, false))
            return Ok(prepared)
        nil: ()
    if t32_access_operation != "":
        return Ok(without_flag(args, "--json"))
    Ok(args)

fn t32_access_max_args(handler_key: text) -> i64:
    match handler_key:
        "t32_window_list": 0
        "t32_window_capture": 1
        "t32_window_describe": 1
        "t32_action_list": 1
        "t32_action_invoke": 2
        "t32_history_tail": 1
        _: 0

fn t32_positive_decimal(value: text) -> bool:
    if value == "": return false
    for ch in value:
        if not "0123456789".contains(ch): return false
    parse_int(value) > 0

fn without_flag(args: [text], flag: text) -> [text]:
    var filtered: [text] = []
    for arg in args:
        if arg != flag:
            filtered.push(arg)
    filtered

# --- Help ---

fn print_usage():
    print "Usage: simple t32 <command> [args...]"
    print ""
    print "Session Commands:"
    print "  sessions                    List all sessions"
    print "  sessions open <host> <port> <name> <arch>"
    print "  sessions close <id>         Close a session"
    print "  sessions use <id>           Switch active session"
    print "  sessions info <id>          Show session details"
    print "  cores                       List cores in current session"
    print "  cores select <core_id>      Select active core"
    print ""
    print "Execution Commands:"
    print "  cmd run <command> [--force]  Run raw PRACTICE command"
    print "  cmm <script> [--wait] [--timeout=<ms>] [--capture-area] [--force]"
    print "  eval <expression>           Evaluate TRACE32 expression"
    print ""
    print "Window Commands:"
    print "  windows [--json]            List available windows"
    print "  window show <key> [--json]  Capture window content"
    print "  window open <key>           Open a TRACE32 window"
    print "  window describe <key> [--json]  Describe window actions/fields"
    print "  screenshot <key> [path]     Save window screenshot"
    print ""
    print "Field/Action Commands:"
    print "  field get <key>             Get field value"
    print "  field set <key> <value>     Set field value"
    print "  action do <key> [args] --confirm [--json]  Execute an action"
    print "  action list [window_key] [--json]  List actions"
    print ""
    print "Observability Commands:"
    print "  status                      Show CPU run state"
    print "  history [count] [--json]    Show command history"
    print "  resources list              List MCP resources"
    print "  resource read <uri>         Read resource by URI"
    print "  error-check                 Check TRACE32 error state"
    print ""
    print "Headless/CMM Commands:"
    print "  headless setup [options]    One-shot headless setup"
    print "  area read [name] [--clear]  Read AREA buffer"
    print "  cmm-commands [--group=G] [--search=S]  Query command database"
    print "  cmm-validate <source>       Validate CMM for headless safety"
    print ""
    print "Job Commands:"
    print "  jobs list [--session=<id>]  List async jobs"
    print "  jobs get <job_id>           Get job status"
    print "  jobs cancel <job_id>        Cancel a job"
    print "  jobs result <job_id>        Get job result"
    print ""
    print "Dialog Commands:"
    print "  dialog parse <source>       Parse CMM for dialog elements"
    print "  dialog get <label>          Read dialog element state"
    print "  dialog set <label> [value]  Set dialog element"
    print "  dialog click <label>        Click dialog button"
    print ""
    print "Other:"
    print "  shell                       Start interactive shell"
    print "  help                        Show this help"

# --- Session Commands ---

fn cmd_sessions(args: [text]):
    if args.len() == 0:
        print_bridge(bridge_sessions_list())
        return

    val sub = args[0]
    match sub:
        "open":
            if args.len() < 5:
                print t32_err_missing_args("sessions open", "sessions open <host> <port> <name> <arch>", "sessions open localhost 20000 T32_ARM ARM")
                return
            val host = args[1]
            val port = parse_int(args[2])
            val name = args[3]
            val arch = args[4]
            print_bridge(bridge_session_open(host, port, name, arch))
        "close":
            if args.len() < 2:
                print t32_err_missing_args("sessions close", "sessions close <id>", "sessions close s1")
                return
            print_bridge(bridge_session_close(args[1]))
        "use":
            if args.len() < 2:
                print t32_err_missing_args("sessions use", "sessions use <id>", "sessions use s1")
                return
            print_bridge(bridge_session_resume(args[1]))
        "info":
            if args.len() < 2:
                print t32_err_missing_args("sessions info", "sessions info <id>", "sessions info s1")
                return
            print_bridge(bridge_session_info(args[1]))
        _: print t32_err_unknown_subcmd("sessions", sub, subcmds_for("sessions"))

fn cmd_cores(args: [text]):
    if args.len() == 0:
        print_bridge(bridge_core_list(""))
        return

    val sub = args[0]
    match sub:
        "select":
            if args.len() < 2:
                print t32_err_missing_args("cores select", "cores select <core_id>", "cores select c0")
                return
            print_bridge(bridge_core_select(args[1]))
        _: print t32_err_unknown_subcmd("cores", sub, subcmds_for("cores"))

# --- Execution Commands ---

fn cmd_cmd(args: [text]):
    if args.len() == 0:
        print t32_err_missing_args("cmd", "cmd run <command> [--force]", "cmd run \"Break.Set main\"")
        return

    val sub = args[0]
    match sub:
        "run":
            if args.len() < 2:
                print t32_err_missing_args("cmd run", "cmd run <command> [--force]", "cmd run \"Break.Set main\"")
                return
            val command = args[1]
            val force = has_flag(args, "--force")
            print_bridge(bridge_cmd_run(command, force))
        _: print t32_err_unknown_subcmd("cmd", sub, subcmds_for("cmd"))

fn cmd_cmm(args: [text]):
    if args.len() == 0:
        print t32_err_missing_args("cmm", "cmm <script_path> [--wait] [--timeout=<ms>] [--capture-area] [--force]", "cmm startup.cmm --wait")
        return

    val script = args[0]
    val wait = has_flag(args, "--wait")
    val capture_area = has_flag(args, "--capture-area")
    val force = has_flag(args, "--force")
    val timeout_ms = get_flag_value(args, "--timeout", "0")
    val timeout = parse_int(timeout_ms)
    print_bridge(bridge_cmm_run(script, wait, timeout, capture_area, force))

fn cmd_eval(args: [text]):
    if args.len() == 0:
        print t32_err_missing_args("eval", "eval <expression>", "eval Register.PP(PC)")
        return
    # Join all args as the expression (allows unquoted multi-word)
    val expr = join_args(args)
    print_bridge(bridge_eval(expr))

# --- Window Commands ---

fn cmd_windows(args: [text]):
    print_bridge(bridge_window_list())

fn cmd_window(args: [text]):
    if args.len() < 2:
        print_access_error(t32_err_missing_args("window", "window <show|open|describe> <key>", "window show register_view"), false)
        return

    val sub = args[0]
    val key = args[1]

    match sub:
        "show": print_bridge(bridge_window_capture(key))
        "open": print_bridge(bridge_window_open(key))
        "describe": print_bridge(bridge_window_describe(key))
        _: print_access_error(t32_err_unknown_subcmd("window", sub, subcmds_for("window")), false)

fn cmd_screenshot(args: [text]):
    if args.len() == 0:
        print t32_err_missing_args("screenshot", "screenshot <window_key> [output_path]", "screenshot register_view reg.png")
        return

    val window_key = args[0]
    var output_path = "{window_key}.png"
    if args.len() > 1:
        output_path = args[1]
    print_bridge(bridge_screenshot(window_key, output_path))

# --- Field/Action Commands ---

fn cmd_field(args: [text]):
    if args.len() < 2:
        print t32_err_missing_args("field", "field <get|set> <key> [value]", "field get pc")
        return

    val sub = args[0]
    val key = args[1]

    match sub:
        "get": print_bridge(bridge_field_get(key))
        "set":
            if args.len() < 3:
                print t32_err_missing_args("field set", "field set <key> <value>", "field set symbol main")
                return
            print_bridge(bridge_field_set(key, args[2]))
        _: print t32_err_unknown_subcmd("field", sub, subcmds_for("field"))

fn cmd_action(args: [text]):
    if args.len() == 0:
        print_access_error(t32_err_missing_args("action", "action <do|list> [key]", "action do step --confirm"), false)
        return

    val sub = args[0]
    match sub:
        "do":
            if args.len() < 2:
                print_access_error(t32_err_missing_args("action do", "action do <key> [args] --confirm", "action do step --confirm"), false)
                return
            val extra_args = if args.len() > 2: args[2] else: ""
            print_bridge(bridge_action_invoke_with_request(args[1], extra_args, t32_access_request_id, t32_access_timeout_ms, t32_access_confirmed))
        "list":
            val window_filter = if args.len() > 1: args[1] else: ""
            print_bridge(bridge_action_list(window_filter))
        _: print_access_error(t32_err_unknown_subcmd("action", sub, subcmds_for("action")), false)

# --- Observability Commands ---

fn cmd_status(args: [text]):
    print_bridge(bridge_status_snapshot())

fn cmd_history(args: [text]):
    val count = if args.len() > 0: parse_int(args[0]) else: 20
    print_bridge(bridge_history_tail(count))

fn cmd_resources(args: [text]):
    if args.len() == 0 or args[0] == "list":
        print_bridge(bridge_resources_list())
        return
    print t32_err_unknown_subcmd("resources", args[0], subcmds_for("resources"))

fn cmd_resource(args: [text]):
    if args.len() < 2:
        print t32_err_missing_args("resource", "resource read <uri>", "resource read t32:///sessions")
        return
    val sub = args[0]
    match sub:
        "read": print_bridge(bridge_resource_read(args[1]))
        _: print t32_err_unknown_subcmd("resource", sub, subcmds_for("resource"))

fn cmd_error_check(args: [text]):
    print_bridge(bridge_error_check())

# --- Headless/CMM Commands ---

fn cmd_headless(args: [text]):
    if args.len() == 0:
        print t32_err_missing_args("headless", "headless setup [options]", "headless setup")
        return
    val sub = args[0]
    match sub:
        "setup":
            val area_name = get_flag_value(args, "--area", "A000")
            val semihost = not has_flag(args, "--no-semihost")
            val error_handler = not has_flag(args, "--no-error-handler")
            print_bridge(bridge_setup_headless(area_name, semihost, error_handler))
        _: print t32_err_unknown_subcmd("headless", sub, subcmds_for("headless"))

fn cmd_area(args: [text]):
    if args.len() == 0:
        print t32_err_missing_args("area", "area read [name] [--clear]", "area read A000")
        return
    val sub = args[0]
    match sub:
        "read":
            val name = if args.len() > 1 and not args[1].starts_with("--"): args[1] else: "A000"
            val clear = has_flag(args, "--clear")
            print_bridge(bridge_area_read(name, clear))
        _: print t32_err_unknown_subcmd("area", sub, subcmds_for("area"))

fn cmd_cmm_commands(args: [text]):
    val group = get_flag_value(args, "--group", "")
    val search = get_flag_value(args, "--search", "")
    print_bridge(bridge_cmm_commands(group, search))

fn cmd_cmm_validate(args: [text]):
    if args.len() == 0:
        print t32_err_missing_args("cmm-validate", "cmm-validate <source> [--mode=<headless|interactive>]", "cmm-validate script.cmm")
        return
    val source = args[0]
    val mode = get_flag_value(args, "--mode", "headless")
    print_bridge(bridge_cmm_validate(source, mode))

# --- Job Commands ---

fn cmd_jobs(args: [text]):
    if args.len() == 0 or args[0] == "list":
        val session_filter = get_flag_value(args, "--session", "")
        print_bridge(bridge_job_list(session_filter))
        return

    val sub = args[0]
    match sub:
        "get":
            if args.len() < 2:
                print t32_err_missing_args("jobs get", "jobs get <job_id>", "jobs get j1")
                return
            print_bridge(bridge_job_get(args[1]))
        "cancel":
            if args.len() < 2:
                print t32_err_missing_args("jobs cancel", "jobs cancel <job_id>", "jobs cancel j1")
                return
            print_bridge(bridge_job_cancel(args[1]))
        "result":
            if args.len() < 2:
                print t32_err_missing_args("jobs result", "jobs result <job_id>", "jobs result j1")
                return
            print_bridge(bridge_job_result(args[1]))
        _: print t32_err_unknown_subcmd("jobs", sub, subcmds_for("jobs"))

# --- Dialog Commands ---

fn cmd_dialog(args: [text]):
    if args.len() == 0:
        print t32_err_missing_args("dialog", "dialog <parse|get|set|click> <args>", "dialog parse my_dialog.cmm")
        return

    val sub = args[0]
    match sub:
        "parse":
            if args.len() < 2:
                print t32_err_missing_args("dialog parse", "dialog parse <source>", "dialog parse my_dialog.cmm")
                return
            print_bridge(bridge_dialog_parse(args[1]))
        "get":
            if args.len() < 2:
                print t32_err_missing_args("dialog get", "dialog get <label> [--type=<bool|string|value>]", "dialog get MyCheckbox")
                return
            val query_type = get_flag_value(args, "--type", "string")
            print_bridge(bridge_dialog_get(args[1], query_type))
        "set":
            if args.len() < 2:
                print t32_err_missing_args("dialog set", "dialog set <label> [value] [--action=<set|select|deselect|disable|enable>]", "dialog set MyEdit \"hello\"")
                return
            val value = if args.len() > 2 and not args[2].starts_with("--"): args[2] else: ""
            val action = get_flag_value(args, "--action", "set")
            print_bridge(bridge_dialog_set(args[1], action, value))
        "click":
            if args.len() < 2:
                print t32_err_missing_args("dialog click", "dialog click <label>", "dialog click MyButton")
                return
            val capture_area = has_flag(args, "--capture-area")
            val timeout = parse_int(get_flag_value(args, "--timeout", "0"))
            print_bridge(bridge_dialog_click(args[1], capture_area, timeout))
        _: print t32_err_unknown_subcmd("dialog", sub, subcmds_for("dialog"))

# --- Shell ---

fn cmd_shell(args: [text]):
    start_t32_shell()

# --- Argument Parsing Helpers ---

fn parse_int(s: text) -> i64:
    var result: i64 = 0
    var i = 0
    while i < s.len():
        val ch = s[i]
        var digit = ch.to_int() - 48
        if digit >= 0 and digit <= 9:
            result = result * 10 + digit
        i = i + 1
    result

fn has_flag(args: [text], flag: text) -> bool:
    for a in args:
        if a == flag:
            return true
    false

fn get_flag_value(args: [text], prefix: text, default_val: text) -> text:
    val eq_prefix = prefix + "="
    for a in args:
        if a.starts_with(eq_prefix):
            return a.slice(eq_prefix.len(), a.len())
    default_val

fn join_args(args: [text]) -> text:
    if args.len() == 0:
        return ""
    var result = args[0]
    var i = 1
    while i < args.len():
        result = result + " " + args[i]
        i = i + 1
    result
