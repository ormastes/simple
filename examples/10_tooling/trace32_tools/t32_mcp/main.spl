# T32 MCP Server — TRACE32 debug session control via MCP protocol
#
# Tools: 36 tools for session management, window capture, action invocation,
#        headless setup, AREA buffer, command database, CMM validation, async jobs,
#        and dialog interaction
# Protocol: MCP 2025-06-18 (Content-Length framing + JSON-Lines auto-detect)
#
# Architecture: Zero stdlib imports — all JSON helpers and transport inlined.
#   Avoids loading the entire src/lib/ module tree via mcp_sdk (8GB+ RSS OOM).
#
# Split into multiple files:
#   - json_helpers.spl    — Inlined JSON building/parsing/extraction (zero imports)
#   - protocol.spl        — Protocol I/O, initialize, tools list, schemas, T32-specific wrappers
#   - session_tools.spl   — Session/core/command tool handlers
#   - window_tools.spl    — Window tool handlers
#   - action_tools.spl    — Action/field/history/resource handlers + dispatcher
#   - gap_tools.spl       — Gap closure tools: session_info, action_list, status_snapshot, cmm_validate
#   - job_manager.spl     — Async job manager: create, get, list, cancel, cleanup
#   - snapshot_store.spl  — Window snapshot store: hash, diff (structured/table/text), capture-with-diff
#   - headless_tools.spl  — Headless setup, AREA read, CMM command database
#   - tool_common.spl     — Shared leaf helpers used across families
#   - action_tools.spl    — Action/field/history/resource handlers + dispatcher

export main, t32_bootstrap_debug_logs, t32_start_server

extern fn rt_file_read_text(path: text) -> text
extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_env_get(name: text) -> text
extern fn rt_env_cwd() -> text
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_append_text(path: text, content: text) -> bool
extern fn rt_file_exists(path: text) -> bool
extern fn stderr_write(data: text) -> i64
extern fn stderr_flush() -> i64

use t32_mcp.json_helpers.{t32_extract_field, t32_extract_id, t32_extract_nested, t32_LB, t32_RB}
use t32_mcp.protocol.{t32_read_stdin_message, t32_write_stdout_message, t32_make_json_result, t32_make_error, t32_make_init_response, t32_make_tools_list}
use t32_mcp.tool_router.{t32_dispatch_tool, t32_make_resources_list, t32_handle_resource_read}
use t32_mcp.session_list_tools.{handle_t32_sessions_list}
use t32_mcp.job_manager.{t32_job_list, t32_job_get, t32_job_cancel, t32_job_to_json}
use t32_mcp.dialog_tools.{handle_t32_dialog_parse, handle_t32_dialog_get, handle_t32_dialog_set, handle_t32_dialog_click}

# Protocol auto-detection
var T32_USE_JSON_LINES = false

# Caches
var T32_TOOLS_CACHE = ""
var T32_INIT_CACHE = ""

# --- Module state for T32 sessions ---

class McpT32Session:
    id: text
    host: text
    port: i64
    intercom_name: text
    proxy_core: text
    architecture: text
    connected: bool
    cores: [McpT32Core]

class McpT32Core:
    core_id: text
    label: text
    instance_binding: text

class McpT32HistoryItem:
    command: text
    result: text
    session_id: text
    core_id: text

var MCP_T32_SESSIONS: [McpT32Session] = []
var MCP_T32_CURRENT_SESSION = ""
var MCP_T32_CURRENT_CORE = ""
var MCP_T32_HISTORY: [McpT32HistoryItem] = []
var MCP_T32_FIELD_STATE_KEYS: [text] = []
var MCP_T32_FIELD_STATE_VALUES: [text] = []
var MCP_T32_AREA_READY = false
var MCP_T32_AREA_NAME = ""
var T32_SEEN_FIRST_MESSAGE = false
var MCP_T32_LAST_ERROR = ""
var T32_DEBUG_LOG_ROOT = ""

# --- Default connection config ---
var T32_DEFAULT_PORT: i64 = 20000
var T32_DEFAULT_HOST = "localhost"
var T32_RCL_PORT: i64 = 20000
var T32_RCL_HOST = "localhost"
var T32_RCL_PROTOCOL = "NETTCP"    # NETTCP (TCP, firewall-friendly) or UDP
var T32_BACKEND_PREFERENCE = ""
var T32_PYTHON_BINARY = "python3"
var T32_API_LIB_PATH = ""
var T32_PYTHON_BRIDGE_PATH = ""

fn t32_startup_diag(message: text):
    if not t32_debug_enabled():
        return
    stderr_write("[t32-mcp] " + message + "\n")
    stderr_flush()

fn t32_server_name() -> text:
    return "simple-mcp-t32"

fn t32_server_version() -> text:
    return "0.1.2"

fn t32_nl() -> text:
    return "\n"

fn t32_debug_enabled() -> bool:
    val raw = rt_env_get("T32_MCP_DEBUG_LOG") ?? ""
    if raw == "":
        return true
    val lower = raw.to_lower()
    if lower == "0" or lower == "false" or lower == "off":
        return false
    true

fn t32_sanitize_path_segment(value: text) -> text:
    if value == "":
        return "workspace"
    var result = ""
    var i = 0
    while i < value.len():
        val ch = value.substring(i, i + 1)
        if (ch >= "a" and ch <= "z") or (ch >= "A" and ch <= "Z") or (ch >= "0" and ch <= "9"):
            result = result + ch
        elif ch == "." or ch == "-" or ch == "_":
            result = result + ch
        else:
            result = result + "_"
        i = i + 1
    if result == "":
        return "workspace"
    result

fn t32_debug_root_dir() -> text:
    if T32_DEBUG_LOG_ROOT != "":
        return T32_DEBUG_LOG_ROOT
    val cwd = rt_env_cwd()
    if cwd == "":
        cwd = rt_env_get("PWD") ?? ""
    if cwd == "":
        cwd = "workspace"
    T32_DEBUG_LOG_ROOT = "/tmp/t32_mcp_debug_" + t32_sanitize_path_segment(cwd)
    if t32_debug_enabled():
        rt_process_run("/bin/sh", ["-c", "mkdir -p " + T32_DEBUG_LOG_ROOT])
    T32_DEBUG_LOG_ROOT

fn t32_debug_log_path(name: text) -> text:
    t32_debug_root_dir() + "/" + name

fn t32_debug_append(name: text, message: text):
    if not t32_debug_enabled():
        return
    var line = message
    if not line.ends_with("\n"):
        line = line + "\n"
    rt_file_append_text(t32_debug_log_path(name), line)

fn t32_debug_trace(message: text):
    if t32_debug_enabled():
        t32_startup_diag("debug: " + message)
        t32_debug_append("frontend.log", message)

fn t32_debug_request(method: text, id: text, tool: text, raw: text):
    t32_debug_append("requests.log", "method=" + method + " id=" + id + " tool=" + tool + " bytes=" + str(raw.len()))

fn t32_debug_response(method: text, id: text, tool: text, response: text):
    t32_debug_append("wrapper.log", "method=" + method + " id=" + id + " tool=" + tool + " response_bytes=" + str(response.len()))

fn t32_debug_error(message: text):
    MCP_T32_LAST_ERROR = message
    t32_debug_append("errors.log", message)
    t32_startup_diag("error: " + message)

fn t32_bootstrap_debug_logs():
    if not t32_debug_enabled():
        return
    val root = t32_debug_root_dir()
    t32_debug_append("wrapper.log", "startup root=" + root + " server=" + t32_server_name() + " version=" + t32_server_version())
    t32_debug_append("frontend.log", "startup cwd=" + rt_env_cwd())

fn t32_json_bool(value: bool) -> text:
    if value:
        return "true"
    "false"

fn t32_count_sessions() -> i64:
    var count: i64 = 0
    for _s in MCP_T32_SESSIONS:
        count = count + 1
    count

fn t32_history_count() -> i64:
    var count: i64 = 0
    for _h in MCP_T32_HISTORY:
        count = count + 1
    count

fn t32_field_state_get(session_id: text, field_key: text) -> text:
    val lookup = session_id + ":" + field_key
    var idx = 0
    for key in MCP_T32_FIELD_STATE_KEYS:
        if key == lookup:
            return MCP_T32_FIELD_STATE_VALUES[idx]
        idx = idx + 1
    ""

fn t32_field_state_set(session_id: text, field_key: text, value: text):
    val lookup = session_id + ":" + field_key
    var idx = 0
    for key in MCP_T32_FIELD_STATE_KEYS:
        if key == lookup:
            MCP_T32_FIELD_STATE_VALUES[idx] = value
            return
        idx = idx + 1
    MCP_T32_FIELD_STATE_KEYS = MCP_T32_FIELD_STATE_KEYS + [lookup]
    MCP_T32_FIELD_STATE_VALUES = MCP_T32_FIELD_STATE_VALUES + [value]

fn t32_add_history(command: text, result: text, session_id: text, core_id: text):
    val entry = McpT32HistoryItem(command: command, result: result, session_id: session_id, core_id: core_id)
    MCP_T32_HISTORY = MCP_T32_HISTORY + [entry]
    if t32_history_count() > 500:
        MCP_T32_HISTORY = MCP_T32_HISTORY[250..]

fn t32_value_after_prefix(line: text, prefix: text) -> text:
    if line.len() <= prefix.len():
        return ""
    var tmp_sub = line.substring(prefix.len())
    return tmp_sub.trim()

fn t32_apply_config_file(config_path: text):
    if not rt_file_exists(config_path):
        t32_startup_diag("startup warning: config file not found: " + config_path)
        return
    val content = rt_file_read_text(config_path) ?? ""
    if content == "":
        return
    val lines = content.split("\n")
    for line in lines:
        val trimmed = line.trim()
        if trimmed.starts_with("default_port:"):
            val port_str = t32_value_after_prefix(trimmed, "default_port:")
            T32_DEFAULT_PORT = int(port_str)
        if trimmed.starts_with("default_host:"):
            T32_DEFAULT_HOST = t32_value_after_prefix(trimmed, "default_host:")
        if trimmed.starts_with("rcl_port:"):
            val port_str = t32_value_after_prefix(trimmed, "rcl_port:")
            T32_RCL_PORT = int(port_str)
        if trimmed.starts_with("rcl_host:"):
            T32_RCL_HOST = t32_value_after_prefix(trimmed, "rcl_host:")
        if trimmed.starts_with("rcl_protocol:"):
            T32_RCL_PROTOCOL = t32_value_after_prefix(trimmed, "rcl_protocol:")
        if trimmed.starts_with("backend_preference:"):
            T32_BACKEND_PREFERENCE = t32_value_after_prefix(trimmed, "backend_preference:")
        if trimmed.starts_with("python_binary:"):
            T32_PYTHON_BINARY = t32_value_after_prefix(trimmed, "python_binary:")
        if trimmed.starts_with("python_bridge:"):
            T32_PYTHON_BRIDGE_PATH = t32_value_after_prefix(trimmed, "python_bridge:")
        if trimmed.starts_with("api_lib_path:"):
            T32_API_LIB_PATH = t32_value_after_prefix(trimmed, "api_lib_path:")

fn t32_load_default_config(config_path: text):
    # Config file loading is opt-in to keep native startup small and predictable.
    if config_path != "":
        t32_apply_config_file(config_path)
    # Environment variables override defaults/config file.
    val env_port = rt_env_get("T32_DEFAULT_PORT") ?? ""
    if env_port != "":
        T32_DEFAULT_PORT = int(env_port)
    val env_host = rt_env_get("T32_DEFAULT_HOST") ?? ""
    if env_host != "":
        T32_DEFAULT_HOST = env_host
    val env_rcl_port = rt_env_get("T32_RCL_PORT") ?? ""
    if env_rcl_port != "":
        T32_RCL_PORT = int(env_rcl_port)
    val env_rcl_host = rt_env_get("T32_RCL_HOST") ?? ""
    if env_rcl_host != "":
        T32_RCL_HOST = env_rcl_host
    val env_rcl_protocol = rt_env_get("T32_RCL_PROTOCOL") ?? ""
    if env_rcl_protocol != "":
        T32_RCL_PROTOCOL = env_rcl_protocol
    val env_backend = rt_env_get("T32_BACKEND_PREFERENCE") ?? ""
    if env_backend != "":
        T32_BACKEND_PREFERENCE = env_backend
    val env_python = rt_env_get("T32_PYTHON") ?? ""
    if env_python != "":
        T32_PYTHON_BINARY = env_python
    val env_api_lib = rt_env_get("T32_API_LIB") ?? ""
    if env_api_lib != "":
        T32_API_LIB_PATH = env_api_lib
    val env_bridge = rt_env_get("T32_PYTHON_BRIDGE") ?? ""
    if env_bridge != "":
        T32_PYTHON_BRIDGE_PATH = env_bridge
    if T32_DEFAULT_HOST == "":
        T32_DEFAULT_HOST = T32_RCL_HOST
    if T32_DEFAULT_PORT == 0:
        T32_DEFAULT_PORT = T32_RCL_PORT

fn t32_make_resources_list(id: text) -> text:
    var sessions = t32_LB()
    sessions = sessions + t32_jp("uri", t32_js("t32:///sessions"))
    sessions = sessions + "," + t32_jp("name", t32_js("T32 Session Manifest"))
    sessions = sessions + "," + t32_jp("description", t32_js("List of all TRACE32 sessions and their state"))
    sessions = sessions + "," + t32_jp("mimeType", t32_js("application/json"))
    sessions = sessions + t32_RB()

    var history = t32_LB()
    history = history + t32_jp("uri", t32_js("t32:///history"))
    history = history + "," + t32_jp("name", t32_js("T32 Command History"))
    history = history + "," + t32_jp("description", t32_js("Recent TRACE32 command history"))
    history = history + "," + t32_jp("mimeType", t32_js("application/json"))
    history = history + t32_RB()

    var windows = t32_LB()
    windows = windows + t32_jp("uri", t32_js("t32:///windows"))
    windows = windows + "," + t32_jp("name", t32_js("T32 Window Catalog"))
    windows = windows + "," + t32_jp("description", t32_js("Available TRACE32 windows and their metadata"))
    windows = windows + "," + t32_jp("mimeType", t32_js("application/json"))
    windows = windows + t32_RB()

    val resources = t32_SB_L() + sessions + "," + history + "," + windows + t32_SB_R()
    t32_make_json_result(id, t32_jo1(t32_jp("resources", resources)))

fn t32_make_resource_templates_list(id: text) -> text:
    t32_make_json_result(id, t32_jo1(t32_jp("resourceTemplates", t32_SB_L() + t32_SB_R())))

fn t32_handle_resource_read(id: text, body: text) -> text:
    val uri = t32_extract_nested(body, "uri")
    if uri == "":
        return t32_make_error(id, -32602, "Missing required parameter: uri")
    if uri == "t32:///sessions":
        var arr = t32_SB_L()
        var first = true
        for s in MCP_T32_SESSIONS:
            if not first:
                arr = arr + ","
            first = false
            var obj = t32_LB()
            obj = obj + t32_jp("id", t32_js(s.id))
            obj = obj + "," + t32_jp("host", t32_js(s.host))
            obj = obj + "," + t32_jp("port", str(s.port))
            obj = obj + "," + t32_jp("intercom_name", t32_js(s.intercom_name))
            obj = obj + "," + t32_jp("architecture", t32_js(s.architecture))
            obj = obj + "," + t32_jp("connected", t32_json_bool(s.connected))
            obj = obj + t32_RB()
            arr = arr + obj
        arr = arr + t32_SB_R()
        val content = t32_LB() + t32_jp("uri", t32_js(uri)) + "," + t32_jp("mimeType", t32_js("application/json")) + "," + t32_jp("text", t32_js(t32_escape_json(arr))) + t32_RB()
        return t32_make_json_result(id, t32_jo1(t32_jp("contents", t32_SB_L() + content + t32_SB_R())))
    if uri == "t32:///history":
        return t32_handle_history_read(id)
    if uri == "t32:///windows":
        val content = t32_LB() + t32_jp("uri", t32_js(uri)) + "," + t32_jp("mimeType", t32_js("application/json")) + "," + t32_jp("text", t32_js("[]")) + t32_RB()
        return t32_make_json_result(id, t32_jo1(t32_jp("contents", t32_SB_L() + content + t32_SB_R())))
    t32_make_error(id, -32002, "Resource not found: " + uri)

fn t32_handle_history_read(id: text) -> text:
    var arr = t32_SB_L()
    var first = true
    for h in MCP_T32_HISTORY:
        if not first:
            arr = arr + ","
        first = false
        var obj = t32_LB()
        obj = obj + t32_jp("command", t32_js(h.command))
        obj = obj + "," + t32_jp("result", t32_js(h.result))
        obj = obj + "," + t32_jp("session_id", t32_js(h.session_id))
        obj = obj + "," + t32_jp("core_id", t32_js(h.core_id))
        obj = obj + t32_RB()
        arr = arr + obj
    arr = arr + t32_SB_R()
    val content = t32_LB() + t32_jp("uri", t32_js("t32:///history")) + "," + t32_jp("mimeType", t32_js("application/json")) + "," + t32_jp("text", t32_js(t32_escape_json(arr))) + t32_RB()
    t32_make_json_result(id, t32_jo1(t32_jp("contents", t32_SB_L() + content + t32_SB_R())))

fn t32_cmm_commands_db() -> [text]:
    var cmds: [text] = []
    cmds = cmds + ["Data.dump|D.D|Data|Display hex dump of memory"]
    cmds = cmds + ["Data.List|D.L|Data|Display disassembly listing"]
    cmds = cmds + ["Data.LOAD|D.LOAD|Data|Load program file"]
    cmds = cmds + ["Data.Set|D.S|Data|Set memory values"]
    cmds = cmds + ["Data.Compare|D.Compare|Data|Compare memory ranges"]
    cmds = cmds + ["Data.Print|D.Print|Data|Print memory to file"]
    cmds = cmds + ["SYStem.Up|SYS.Up|SYStem|Start debug session"]
    cmds = cmds + ["SYStem.Down|SYS.Down|SYStem|Stop debug session"]
    cmds = cmds + ["SYStem.RESet|SYS.RESet|SYStem|Reset system"]
    cmds = cmds + ["SYStem.Option|SYS.Option|SYStem|Set system option"]
    cmds = cmds + ["Break.Set|B.S|Break|Set breakpoint"]
    cmds = cmds + ["Break.Delete|B.D|Break|Delete breakpoint"]
    cmds = cmds + ["Break.List|B.L|Break|List breakpoints"]
    cmds = cmds + ["Register.Set|R.S|Register|Set register value"]
    cmds = cmds + ["Register.view|R|Register|View registers"]
    cmds = cmds + ["Var.View|V.V|Var|View variable"]
    cmds = cmds + ["Var.AddWatch|V.AddWatch|Var|Add watch expression"]
    cmds = cmds + ["Trace.List|T.L|Trace|List trace records"]
    cmds = cmds + ["AREA.Create|AREA.Create|AREA|Create AREA window"]
    cmds = cmds + ["AREA.Select|AREA.Select|AREA|Select AREA for I/O"]
    cmds = cmds + ["AREA.view|AREA.view|AREA|Open AREA window"]
    cmds = cmds + ["SCREEN.OFF|SCREEN.OFF|Screen|Disable screen updates"]
    cmds = cmds + ["SCREEN.ON|SCREEN.ON|Screen|Enable screen updates"]
    cmds = cmds + ["WINPOS|WINPOS|Window|Set window position and size"]
    cmds = cmds + ["EVAL|EVAL|Misc|Evaluate expression"]
    cmds = cmds + ["PRINT|PRINT|IO|Print to output area"]
    cmds = cmds + ["ON|ON|Event|Set event handler"]
    cmds = cmds + ["GLOBALON|GLOBALON|Event|Set global event handler"]
    cmds = cmds + ["DO|DO|Control|Call CMM script"]
    cmds = cmds + ["ENDDO|ENDDO|Control|End script / return value"]
    cmds = cmds + ["WAIT|WAIT|Control|Wait for condition or time"]
    cmds = cmds + ["STOP|STOP|Control|Halt execution"]
    cmds

fn t32_handle_cmm_commands(id: text, body: text) -> text:
    val group = t32_extract_field(body, "group")
    val search = t32_extract_field(body, "search")
    val db = t32_cmm_commands_db()
    var filtered: [text] = []
    for cmd in db:
        val parts = cmd.split("|")
        var cmd_name = ""
        var cmd_short = ""
        var cmd_group = ""
        var cmd_desc = ""
        if parts.len() > 0:
            cmd_name = parts[0]
        if parts.len() > 1:
            cmd_short = parts[1]
        if parts.len() > 2:
            cmd_group = parts[2]
        if parts.len() > 3:
            cmd_desc = parts[3]
        if group != "" and cmd_group.to_lower() != group.to_lower():
            continue
        if search != "":
            val lower_search = search.to_lower()
            var cmd_name_lower = cmd_name.to_lower()
            var cmd_desc_lower = cmd_desc.to_lower()
            if not cmd_name_lower.contains(lower_search) and not cmd_desc_lower.contains(lower_search):
                continue
        var obj = t32_LB()
        obj = obj + t32_jp("name", t32_js(cmd_name))
        obj = obj + "," + t32_jp("short_name", t32_js(cmd_short))
        obj = obj + "," + t32_jp("group", t32_js(cmd_group))
        obj = obj + "," + t32_jp("description", t32_js(cmd_desc))
        obj = obj + t32_RB()
        filtered = filtered + [obj]
    val arr = t32_SB_L() + filtered.join(",") + t32_SB_R()
    var r = t32_LB()
    r = r + t32_jp("count", str(filtered.len()))
    r = r + "," + t32_jp("commands", arr)
    r = r + t32_RB()
    t32_add_history("t32_cmm_commands", group + " " + search, MCP_T32_CURRENT_SESSION, MCP_T32_CURRENT_CORE)
    t32_make_tool_result(id, r)

fn t32_handle_field_get(id: text, body: text) -> text:
    val field_key = t32_extract_field(body, "field_key")
    if field_key == "":
        return t32_make_tool_error(id, -32602, "Missing required parameter: field_key")
    val session_id = MCP_T32_CURRENT_SESSION
    var value = t32_field_state_get(session_id, field_key)
    if value == "":
        if field_key == "pc" or field_key == "sp" or field_key == "lr" or field_key == "cpsr" or field_key == "r0" or field_key == "r1" or field_key == "r2" or field_key == "r3":
            value = "0x0"
        elif field_key.starts_with("status."):
            value = "unknown"
    t32_field_state_set(session_id, field_key, value)
    t32_add_history("field_get:" + field_key, value, session_id, MCP_T32_CURRENT_CORE)
    var r = t32_LB()
    r = r + t32_jp("field_key", t32_js(field_key))
    r = r + "," + t32_jp("value", t32_js(value))
    r = r + "," + t32_jp("session_id", t32_js(session_id))
    r = r + t32_RB()
    t32_make_tool_result(id, r)

fn t32_handle_field_set(id: text, body: text) -> text:
    val field_key = t32_extract_field(body, "field_key")
    val value = t32_extract_field(body, "value")
    if field_key == "" or value == "":
        return t32_make_tool_error(id, -32602, "Missing required parameter: field_key, value")
    val session_id = MCP_T32_CURRENT_SESSION
    t32_field_state_set(session_id, field_key, value)
    t32_add_history("field_set:" + field_key + "=" + value, "ok", session_id, MCP_T32_CURRENT_CORE)
    var r = t32_LB()
    r = r + t32_jp("field_key", t32_js(field_key))
    r = r + "," + t32_jp("value", t32_js(value))
    r = r + "," + t32_jp("session_id", t32_js(session_id))
    r = r + "," + t32_jp("status", t32_js("ok"))
    r = r + t32_RB()
    t32_make_tool_result(id, r)

fn t32_handle_history_tail(id: text, body: text) -> text:
    val count_str = t32_extract_field(body, "count")
    var count: i64 = 20
    if count_str != "":
        count = int(count_str)
        if count < 1:
            count = 20
    var total: i64 = 0
    for _h in MCP_T32_HISTORY:
        total = total + 1
    var start_idx: i64 = 0
    if total > count:
        start_idx = total - count
    var arr = t32_SB_L()
    var first = true
    var idx: i64 = 0
    for h in MCP_T32_HISTORY:
        if idx >= start_idx:
            if not first:
                arr = arr + ","
            first = false
            var obj = t32_LB()
            obj = obj + t32_jp("command", t32_js(h.command))
            obj = obj + "," + t32_jp("result", t32_js(h.result))
            obj = obj + "," + t32_jp("session_id", t32_js(h.session_id))
            obj = obj + "," + t32_jp("core_id", t32_js(h.core_id))
            obj = obj + t32_RB()
            arr = arr + obj
        idx = idx + 1
    arr = arr + t32_SB_R()
    t32_make_tool_result(id, arr)

fn t32_handle_error_check(id: text, body: text) -> text:
    var has_error = "false"
    var msg_type = "info"
    if MCP_T32_LAST_ERROR != "":
        has_error = "true"
        msg_type = "error"
    var r = t32_LB()
    r = r + t32_jp("message", t32_js(MCP_T32_LAST_ERROR))
    r = r + "," + t32_jp("type", t32_js(msg_type))
    r = r + "," + t32_jp("stderr", t32_js(""))
    r = r + "," + t32_jp("practice_state", "-1")
    r = r + "," + t32_jp("has_error", has_error)
    r = r + t32_RB()
    t32_make_tool_result(id, r)

# --- Entry point ---

fn main():
    # Keep startup minimal. Session/backend configuration is resolved lazily
    # in the tool paths that actually need it.
    t32_bootstrap_debug_logs()
    t32_start_server()

fn t32_start_server():
    while true:
        var msg = t32_read_stdin_message()
        t32_debug_trace("read message bytes=" + str(msg.len()))
        if msg == "":
            if not T32_SEEN_FIRST_MESSAGE:
                t32_startup_diag("startup error: no MCP request received on stdin")
            return
        else:
            T32_SEEN_FIRST_MESSAGE = true
            var method = t32_extract_field(msg, "method")
            var id = t32_extract_id(msg)
            var response = ""
            var tool_name = ""
            t32_debug_trace("parsed method=<" + method + "> id=<" + id + ">")
            if method == "tools/call":
                tool_name = t32_extract_nested(msg, "name")
                t32_debug_request(method, id, tool_name, msg)
            else:
                t32_debug_request(method, id, "", msg)
            if method == "initialize":
                t32_startup_diag("initialize received; server version " + t32_server_version())
                response = t32_make_init_response(id)
            elif method == "initialized" or method == "notifications/initialized":
                response = ""
            elif method == "shutdown":
                response = t32_make_json_result(id, "null")
            elif method == "tools/list":
                response = t32_make_tools_list(id)
            elif method == "tools/call":
                response = t32_dispatch_tool(id, msg)
            elif method == "resources/list":
                response = t32_make_resources_list(id)
            elif method == "resources/templates/list":
                response = t32_make_resource_templates_list(id)
            elif method == "resources/read":
                response = t32_handle_resource_read(id, msg)
            elif method == "prompts/list":
                response = t32_make_json_result(id, "{\"prompts\":[]}")
            elif method == "roots/list":
                response = t32_make_json_result(id, "{\"roots\":[]}")
            elif method == "logging/setLevel" or method == "logging/setlevel":
                response = t32_make_json_result(id, "null")
            elif method == "ping":
                response = t32_make_json_result(id, t32_LB() + t32_RB())
            elif method == "notifications/cancelled" or method == "notifications/roots/list_changed":
                response = ""
            else:
                if method == "":
                    t32_startup_diag("protocol error: request missing method field: " + msg)
                if id != "" and id != "null":
                    response = t32_make_error(id, -32601, "Method not found: " + method)
            t32_debug_trace("response bytes=" + str(response.len()))
            if response != "":
                t32_debug_trace("writing response")
                t32_debug_response(method, id, tool_name, response)
                t32_write_stdout_message(response)

fn t32_dispatch_low_cost_tool(id: text, body: text, tool_name: text) -> text:
    val args_raw = t32_extract_field_raw(body, "arguments")
    if tool_name == "t32_sessions_list":
        return handle_t32_sessions_list(id, body)
    if tool_name == "t32_job_list":
        val session_filter = t32_extract_field(args_raw, "session_id")
        var jobs = t32_job_list(session_filter)
        var parts: [text] = []
        for job in jobs:
            parts = parts + [t32_job_to_json(job)]
        return t32_make_tool_result(id, t32_SB_L() + parts.join(",") + t32_SB_R())
    if tool_name == "t32_job_get":
        val job_id = t32_extract_field(args_raw, "job_id")
        val job = t32_job_get(job_id)
        if job.status == "not_found":
            return t32_make_tool_error(id, -32602, "Job not found: " + job_id)
        return t32_make_tool_result(id, t32_job_to_json(job))
    if tool_name == "t32_job_cancel":
        val job_id = t32_extract_field(args_raw, "job_id")
        val ok = t32_job_cancel(job_id)
        if ok:
            return t32_make_tool_result(id, t32_LB() + t32_jp("cancelled", "true") + t32_RB())
        return t32_make_tool_error(id, -32602, "Cannot cancel job: " + job_id)
    if tool_name == "t32_job_result":
        val job_id = t32_extract_field(args_raw, "job_id")
        val job = t32_job_get(job_id)
        if job.status == "not_found":
            return t32_make_tool_error(id, -32602, "Job not found: " + job_id)
        if job.status == "completed":
            return t32_make_tool_result(id, t32_LB() + t32_jp("job_id", t32_js(job_id)) + "," + t32_jp("result", job.result) + t32_RB())
        if job.status == "failed":
            return t32_make_tool_error(id, -32602, "Job failed: " + job.error)
        return t32_make_tool_error(id, -32602, "Job not yet complete (status: " + job.status + ")")
    if tool_name == "t32_cmm_commands":
        return t32_handle_cmm_commands(id, args_raw)
    if tool_name == "t32_field_get":
        return t32_handle_field_get(id, args_raw)
    if tool_name == "t32_field_set":
        return t32_handle_field_set(id, args_raw)
    if tool_name == "t32_history_tail":
        return t32_handle_history_tail(id, args_raw)
    if tool_name == "t32_dialog_parse":
        return handle_t32_dialog_parse(id, args_raw)
    if tool_name == "t32_dialog_get":
        return handle_t32_dialog_get(id, args_raw)
    if tool_name == "t32_dialog_set":
        return handle_t32_dialog_set(id, args_raw)
    if tool_name == "t32_dialog_click":
        return handle_t32_dialog_click(id, args_raw)
    if tool_name == "t32_error_check":
        return t32_handle_error_check(id, args_raw)
    t32_debug_error("unknown low-cost tool: " + tool_name)
    t32_make_tool_error(id, -32601, "Method not found: " + tool_name)
