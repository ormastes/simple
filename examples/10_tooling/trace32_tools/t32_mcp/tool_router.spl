@allow(unnamed_duplicate_typed_args)
# T32 MCP — Tool dispatch and resource handling

use t32_cli.error_codes.{t32_err_unknown_tool, t32_err_missing_tool_name, t32_err_resource_not_found}
use t32_mcp.json_helpers.{t32_extract_field, t32_extract_field_raw, t32_extract_nested, t32_escape_json, t32_LB, t32_RB, t32_SB_L, t32_SB_R, t32_jp, t32_js, t32_jo1}
use t32_mcp.protocol.{t32_make_json_result, t32_make_error, t32_make_tool_result, t32_make_tool_error}
use t32_mcp.session_list_tools.{handle_t32_sessions_list}
use t32_mcp.session_state_tools.{handle_t32_session_resume, handle_t32_session_close}
use t32_mcp.session_tools.{handle_t32_session_open, handle_t32_core_list, handle_t32_core_select, handle_t32_window_open, handle_t32_window_capture, handle_t32_cmd_run, handle_t32_cmm_run, handle_t32_eval, handle_t32_error_check}
use t32_mcp.window_tools.{handle_t32_window_list, handle_t32_window_describe, t32_get_window_catalog, t32_parse_catalog_entry_with_meta}
use t32_mcp.headless_tools.{handle_t32_setup_headless, handle_t32_area_read, handle_t32_cmm_commands}
use t32_mcp.gap_tools.{handle_t32_session_info, handle_t32_action_list, handle_t32_status_snapshot, handle_t32_cmm_validate}
use t32_mcp.action_tools.{handle_t32_action_invoke, handle_t32_field_get, handle_t32_field_set, handle_t32_screenshot, handle_t32_history_tail}
use t32_mcp.dialog_tools.{handle_t32_dialog_parse, handle_t32_dialog_get, handle_t32_dialog_set, handle_t32_dialog_click}
use t32_mcp.job_manager.{t32_job_list, t32_job_get, t32_job_cancel, t32_job_to_json}

fn t32_make_resources_list(id: text) -> text:
    var r1 = t32_LB()
    r1 = r1 + t32_jp("uri", t32_js("t32:///sessions"))
    r1 = r1 + "," + t32_jp("name", t32_js("T32 Session Manifest"))
    r1 = r1 + "," + t32_jp("description", t32_js("List of all TRACE32 sessions and their state"))
    r1 = r1 + "," + t32_jp("mimeType", t32_js("application/json"))
    r1 = r1 + t32_RB()
    var r2 = t32_LB()
    r2 = r2 + t32_jp("uri", t32_js("t32:///windows"))
    r2 = r2 + "," + t32_jp("name", t32_js("T32 Window Catalog"))
    r2 = r2 + "," + t32_jp("description", t32_js("Available TRACE32 windows and their metadata"))
    r2 = r2 + "," + t32_jp("mimeType", t32_js("application/json"))
    r2 = r2 + t32_RB()
    var r3 = t32_LB()
    r3 = r3 + t32_jp("uri", t32_js("t32:///history"))
    r3 = r3 + "," + t32_jp("name", t32_js("T32 Command History"))
    r3 = r3 + "," + t32_jp("description", t32_js("Recent TRACE32 command history"))
    r3 = r3 + "," + t32_jp("mimeType", t32_js("application/json"))
    r3 = r3 + t32_RB()
    val resources = t32_SB_L() + r1 + "," + r2 + "," + r3 + t32_SB_R()
    t32_make_json_result(id, t32_jo1(t32_jp("resources", resources)))

fn t32_handle_resource_read(id: text, body: text) -> text:
    val uri = t32_extract_nested(body, "uri")
    if uri == "":
        return t32_make_error(id, -32602, "Missing required parameter: uri")
    if uri == "t32:///sessions":
        var arr = t32_SB_L()
        var first = true
        for s in MCP_T32_SESSIONS:
            if not first:
                arr = arr + ","
            first = false
            var obj = t32_LB()
            obj = obj + t32_jp("id", t32_js(s.id))
            obj = obj + "," + t32_jp("host", t32_js(s.host))
            obj = obj + "," + t32_jp("port", str(s.port))
            obj = obj + "," + t32_jp("architecture", t32_js(s.architecture))
            var conn_str = "false"
            if s.connected:
                conn_str = "true"
            obj = obj + "," + t32_jp("connected", conn_str)
            obj = obj + t32_RB()
            arr = arr + obj
        arr = arr + t32_SB_R()
        val content = t32_LB() + t32_jp("uri", t32_js(uri)) + "," + t32_jp("mimeType", t32_js("application/json")) + "," + t32_jp("text", t32_js(t32_escape_json(arr))) + t32_RB()
        return t32_make_json_result(id, t32_jo1(t32_jp("contents", t32_SB_L() + content + t32_SB_R())))
    if uri == "t32:///windows":
        val catalog = t32_get_window_catalog()
        var arr = t32_SB_L()
        var first = true
        for entry in catalog:
            var key = ""
            var title = ""
            var kind = ""
            var open_cmd = ""
            var capture_cmd = ""
            var capture_mode = ""
            var arch = ""
            var notes = ""
            (key, title, kind, open_cmd, capture_cmd, capture_mode, arch, notes) = t32_parse_catalog_entry_with_meta(entry)
            if not first:
                arr = arr + ","
            first = false
            var obj = t32_LB()
            obj = obj + t32_jp("window_key", t32_js(key))
            obj = obj + "," + t32_jp("title", t32_js(title))
            obj = obj + "," + t32_jp("kind", t32_js(kind))
            if capture_mode != "":
                obj = obj + "," + t32_jp("capture_mode", t32_js(capture_mode))
            if arch != "":
                obj = obj + "," + t32_jp("arch", t32_js(arch))
            if notes != "":
                obj = obj + "," + t32_jp("notes", t32_js(notes))
            obj = obj + t32_RB()
            arr = arr + obj
        arr = arr + t32_SB_R()
        val content = t32_LB() + t32_jp("uri", t32_js(uri)) + "," + t32_jp("mimeType", t32_js("application/json")) + "," + t32_jp("text", t32_js(t32_escape_json(arr))) + t32_RB()
        return t32_make_json_result(id, t32_jo1(t32_jp("contents", t32_SB_L() + content + t32_SB_R())))
    if uri == "t32:///history":
        return handle_t32_history_tail(id, body)
    t32_make_error(id, -32002, t32_err_resource_not_found(uri))

fn t32_dispatch_tool(id: text, body: text) -> text:
    val tool_name = t32_extract_nested(body, "name")
    val args_raw = t32_extract_field_raw(body, "arguments")
    if tool_name == "":
        return t32_make_error(id, -32602, t32_err_missing_tool_name())
    if tool_name == "t32_sessions_list":
        return handle_t32_sessions_list(id, args_raw)
    elif tool_name == "t32_session_open":
        return handle_t32_session_open(id, args_raw)
    elif tool_name == "t32_session_resume":
        return handle_t32_session_resume(id, args_raw)
    elif tool_name == "t32_session_close":
        return handle_t32_session_close(id, args_raw)
    elif tool_name == "t32_core_list":
        return handle_t32_core_list(id, args_raw)
    elif tool_name == "t32_core_select":
        return handle_t32_core_select(id, args_raw)
    elif tool_name == "t32_cmd_run":
        return handle_t32_cmd_run(id, args_raw)
    elif tool_name == "t32_cmm_run":
        return handle_t32_cmm_run(id, args_raw)
    elif tool_name == "t32_eval":
        return handle_t32_eval(id, args_raw)
    elif tool_name == "t32_window_list":
        return handle_t32_window_list(id, args_raw)
    elif tool_name == "t32_window_open":
        return handle_t32_window_open(id, args_raw)
    elif tool_name == "t32_window_capture":
        return handle_t32_window_capture(id, args_raw)
    elif tool_name == "t32_window_describe":
        return handle_t32_window_describe(id, args_raw)
    elif tool_name == "t32_screenshot":
        return handle_t32_screenshot(id, args_raw)
    elif tool_name == "t32_action_invoke":
        return handle_t32_action_invoke(id, args_raw)
    elif tool_name == "t32_field_get":
        return handle_t32_field_get(id, args_raw)
    elif tool_name == "t32_field_set":
        return handle_t32_field_set(id, args_raw)
    elif tool_name == "t32_history_tail":
        return handle_t32_history_tail(id, args_raw)
    elif tool_name == "t32_resources_list":
        return t32_make_resources_list(id)
    elif tool_name == "t32_resource_read":
        return t32_handle_resource_read(id, body)
    elif tool_name == "t32_setup_headless":
        return handle_t32_setup_headless(id, args_raw)
    elif tool_name == "t32_area_read":
        return handle_t32_area_read(id, args_raw)
    elif tool_name == "t32_cmm_commands":
        return handle_t32_cmm_commands(id, args_raw)
    elif tool_name == "t32_session_info":
        return handle_t32_session_info(id, args_raw)
    elif tool_name == "t32_action_list":
        return handle_t32_action_list(id, args_raw)
    elif tool_name == "t32_status_snapshot":
        return handle_t32_status_snapshot(id, args_raw)
    elif tool_name == "t32_cmm_validate":
        return handle_t32_cmm_validate(id, args_raw)
    elif tool_name == "t32_job_list":
        val session_filter = t32_extract_field(args_raw, "session_id")
        val jobs = t32_job_list(session_filter)
        var parts: [text] = []
        for job in jobs:
            parts.push(t32_job_to_json(job))
        return t32_make_tool_result(id, t32_SB_L() + parts.join(",") + t32_SB_R())
    elif tool_name == "t32_job_get":
        val job_id = t32_extract_field(args_raw, "job_id")
        val job = t32_job_get(job_id)
        if job.status == "not_found":
            return t32_make_tool_error(id, -32602, "Job not found: " + job_id)
        return t32_make_tool_result(id, t32_job_to_json(job))
    elif tool_name == "t32_job_cancel":
        val job_id = t32_extract_field(args_raw, "job_id")
        val ok = t32_job_cancel(job_id)
        if ok:
            return t32_make_tool_result(id, t32_LB() + t32_jp("cancelled", "true") + t32_RB())
        return t32_make_tool_error(id, -32602, "Cannot cancel job: " + job_id + " (not found or already terminal)")
    elif tool_name == "t32_job_result":
        val job_id = t32_extract_field(args_raw, "job_id")
        val job = t32_job_get(job_id)
        if job.status == "not_found":
            return t32_make_tool_error(id, -32602, "Job not found: " + job_id)
        if job.status == "completed":
            return t32_make_tool_result(id, t32_LB() + t32_jp("job_id", t32_js(job_id)) + "," + t32_jp("result", job.result) + t32_RB())
        if job.status == "failed":
            return t32_make_tool_error(id, -32602, "Job failed: " + job.error)
        return t32_make_tool_error(id, -32602, "Job not yet complete (status: " + job.status + ")")
    elif tool_name == "t32_dialog_parse":
        return handle_t32_dialog_parse(id, args_raw)
    elif tool_name == "t32_dialog_get":
        return handle_t32_dialog_get(id, args_raw)
    elif tool_name == "t32_dialog_set":
        return handle_t32_dialog_set(id, args_raw)
    elif tool_name == "t32_dialog_click":
        return handle_t32_dialog_click(id, args_raw)
    elif tool_name == "t32_error_check":
        return handle_t32_error_check(id, args_raw)
    t32_make_error(id, -32602, t32_err_unknown_tool(tool_name))
