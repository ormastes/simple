#![allow(unnamed_duplicate_typed_args)]
# T32 MCP — Dialog tool handlers
# Handles: dialog_parse, dialog_get, dialog_set, dialog_click
#
# REQ-F5-001: dialog_parse — parse CMM source for dialog elements
# REQ-F5-002: dialog_get — read dialog element state by label
# REQ-F5-003: dialog_set — set/disable/enable dialog element
# REQ-F5-004: dialog_click — check existence then execute button handler

use cmm_lsp.cmm_parser.{parse_cmm_source}
use cmm_lsp.cmm_ast.{CmmProgram, CmmStmt, CmmDialogItem, CmmSpan}
use app.t32_cli.error_codes.{T4100, T4101, T4102, T4103, t32_err_dialog_not_found, t32_err_no_dialog, t32_err_invalid_dialog_action, t32_err_dialog_parse_failed, t32_err_missing_param, t32_err_no_session_mcp}

# ============================================================================
# Tool 1: handle_t32_dialog_parse (REQ-F5-001)
# Parse CMM source for dialog elements with labels, types, titles
# ============================================================================

fn handle_t32_dialog_parse(id: text, body: text) -> text:
    val source = t32_extract_field(body, "source")
    if source == "":
        return t32_make_tool_error(id, -32602, t32_err_missing_param("source", "t32_dialog_parse", "t32_dialog_parse(source: \"<cmm source or path>\")", "t32_dialog_parse(source: \"config.cmm\")"))
    # If source looks like a file path, read it
    var cmm_source = source
    if not source.contains("\n") and not source.contains(";"):
        val file_content = rt_file_read_text(source) ?? ""
        if file_content != "":
            cmm_source = file_content
    val program = parse_cmm_source(cmm_source)
    # Walk statements for DialogBlock nodes
    var elements: [text] = []
    var labels: [text] = []
    var dialog_count: i64 = 0
    t32_collect_dialogs(program.statements, elements, labels, dialog_count)
    # Build errors array
    var errors_arr = t32_SB_L()
    var ei = 0
    while ei < program.errors.len():
        if ei > 0:
            errors_arr = errors_arr + ","
        errors_arr = errors_arr + t32_js(program.errors[ei])
        ei = ei + 1
    errors_arr = errors_arr + t32_SB_R()
    # Build labels array
    var labels_arr = t32_SB_L()
    var li = 0
    while li < labels.len():
        if li > 0:
            labels_arr = labels_arr + ","
        labels_arr = labels_arr + t32_js(labels[li])
        li = li + 1
    labels_arr = labels_arr + t32_SB_R()
    # Build elements array
    var elements_arr = t32_SB_L() + elements.join(",") + t32_SB_R()
    var r = t32_LB()
    r = r + t32_jp("dialog_count", str(dialog_count))
    r = r + "," + t32_jp("element_count", str(elements.len()))
    r = r + "," + t32_jp("elements", elements_arr)
    r = r + "," + t32_jp("labels", labels_arr)
    r = r + "," + t32_jp("errors", errors_arr)
    r = r + t32_RB()
    t32_make_tool_result(id, r)

# Walk statements recursively to find DialogBlock nodes
fn t32_collect_dialogs(stmts: [CmmStmt], elements: [text], labels: [text], dialog_count: i64):
    for stmt in stmts:
        match stmt:
            CmmStmt.DialogBlock(items, sp):
                dialog_count = dialog_count + 1
                for item in items:
                    val json = t32_dialog_item_to_json(item)
                    elements.push(json)
                    val label = t32_dialog_item_label(item)
                    if label != "":
                        labels.push(label)
            CmmStmt.IfElse(cond, then_body, else_body, sp):
                t32_collect_dialogs([then_body], elements, labels, dialog_count)
                match else_body:
                    Some(eb): t32_collect_dialogs([eb], elements, labels, dialog_count)
                    nil: pass_do_nothing
            CmmStmt.WhileLoop(cond, body, sp):
                t32_collect_dialogs([body], elements, labels, dialog_count)
            CmmStmt.RepeatLoop(count, body, sp):
                t32_collect_dialogs([body], elements, labels, dialog_count)
            CmmStmt.Block(inner_stmts, sp):
                t32_collect_dialogs(inner_stmts, elements, labels, dialog_count)
            _: pass_do_nothing

# Convert a CmmDialogItem to a JSON object string
fn t32_dialog_item_to_json(item: CmmDialogItem) -> text:
    match item:
        CmmDialogItem.DlgHeader(title):
            t32_jo2(t32_jp("type", t32_js("header")), t32_jp("title", t32_js(title)))
        CmmDialogItem.DlgPos(x, y, w):
            t32_jo1(t32_jp("type", t32_js("pos")))
        CmmDialogItem.DlgText(label_text):
            t32_jo2(t32_jp("type", t32_js("text")), t32_jp("text", t32_js(label_text)))
        CmmDialogItem.DlgEdit(name, default_val, callback):
            t32_jo4(t32_jp("type", t32_js("edit")), t32_jp("label", t32_js(name)), t32_jp("default", t32_js(default_val)), t32_jp("callback", t32_js(callback)))
        CmmDialogItem.DlgButton(name, btn_text, callback):
            t32_jo4(t32_jp("type", t32_js("button")), t32_jp("label", t32_js(name)), t32_jp("text", t32_js(btn_text)), t32_jp("callback", t32_js(callback)))
        CmmDialogItem.DlgDefButton(name, btn_text, callback):
            t32_jo4(t32_jp("type", t32_js("defbutton")), t32_jp("label", t32_js(name)), t32_jp("text", t32_js(btn_text)), t32_jp("callback", t32_js(callback)))
        CmmDialogItem.DlgCheckbox(name, cb_text, callback):
            t32_jo4(t32_jp("type", t32_js("checkbox")), t32_jp("label", t32_js(name)), t32_jp("text", t32_js(cb_text)), t32_jp("callback", t32_js(callback)))
        CmmDialogItem.DlgChoosebox(cb_text, callback):
            t32_jo3(t32_jp("type", t32_js("choosebox")), t32_jp("text", t32_js(cb_text)), t32_jp("callback", t32_js(callback)))
        CmmDialogItem.DlgPulldown(options, callback):
            t32_jo3(t32_jp("type", t32_js("pulldown")), t32_jp("options", t32_js(options)), t32_jp("callback", t32_js(callback)))
        CmmDialogItem.DlgLine(group_label):
            t32_jo2(t32_jp("type", t32_js("line")), t32_jp("text", t32_js(group_label)))
        CmmDialogItem.DlgClose(callback):
            t32_jo2(t32_jp("type", t32_js("close")), t32_jp("callback", t32_js(callback)))

# Extract the label name from a dialog item (empty for unlabeled items)
fn t32_dialog_item_label(item: CmmDialogItem) -> text:
    match item:
        CmmDialogItem.DlgEdit(name, _, _): name
        CmmDialogItem.DlgButton(name, _, _): name
        CmmDialogItem.DlgDefButton(name, _, _): name
        CmmDialogItem.DlgCheckbox(name, _, _): name
        _: ""

# ============================================================================
# Tool 2: handle_t32_dialog_get (REQ-F5-002)
# Read dialog element state by label via T32 EVAL
# ============================================================================

fn handle_t32_dialog_get(id: text, body: text) -> text:
    val label = t32_extract_field(body, "label")
    if label == "":
        return t32_make_tool_error(id, -32602, t32_err_missing_param("label", "t32_dialog_get", "t32_dialog_get(label: \"<name>\")", "t32_dialog_get(label: \"mycheck\")"))
    if not t32_validate_identifier(label):
        return t32_make_tool_error(id, -32602, "Invalid label: contains disallowed characters")
    var query_type = t32_extract_field(body, "type")
    val session_opt = t32_find_current_session()
    match session_opt:
        nil: return t32_make_tool_error(id, -32602, t32_err_no_session_mcp())
        Some(session):
            var value = ""
            var detected_type = query_type
            if query_type == "boolean":
                var stdout = ""
                var rc: i64 = 0
                (stdout, rc) = t32_run_remote(session, "EVAL DIALOG.BOOLEAN(" + label + ")")
                if rc != 0:
                    return t32_make_tool_error(id, -32000, t32_err_no_dialog())
                value = stdout.trim()
            elif query_type == "string":
                var stdout = ""
                var rc: i64 = 0
                (stdout, rc) = t32_run_remote(session, "EVAL DIALOG.STRING(" + label + ")")
                if rc != 0:
                    return t32_make_tool_error(id, -32000, t32_err_no_dialog())
                value = stdout.trim()
            elif query_type == "value":
                var stdout = ""
                var rc: i64 = 0
                (stdout, rc) = t32_run_remote(session, "EVAL DIALOG.VALUE(" + label + ")")
                if rc != 0:
                    return t32_make_tool_error(id, -32000, t32_err_no_dialog())
                value = stdout.trim()
            else:
                # Auto-detect: try STRING first (broadest), then BOOLEAN, then VALUE
                var s_out = ""
                var s_rc: i64 = 0
                (s_out, s_rc) = t32_run_remote(session, "EVAL DIALOG.STRING(" + label + ")")
                if s_rc == 0:
                    value = s_out.trim()
                    detected_type = "string"
                else:
                    var b_out = ""
                    var b_rc: i64 = 0
                    (b_out, b_rc) = t32_run_remote(session, "EVAL DIALOG.BOOLEAN(" + label + ")")
                    if b_rc == 0:
                        value = b_out.trim()
                        detected_type = "boolean"
                    else:
                        var v_out = ""
                        var v_rc: i64 = 0
                        (v_out, v_rc) = t32_run_remote(session, "EVAL DIALOG.VALUE(" + label + ")")
                        if v_rc == 0:
                            value = v_out.trim()
                            detected_type = "value"
                        else:
                            return t32_make_tool_error(id, -32000, t32_err_dialog_not_found(label))
            t32_add_history("EVAL DIALOG." + detected_type.to_upper() + "(" + label + ")", value, session.id, MCP_T32_CURRENT_CORE)
            var r = t32_LB()
            r = r + t32_jp("label", t32_js(label))
            r = r + "," + t32_jp("type", t32_js(detected_type))
            r = r + "," + t32_jp("value", t32_js(value))
            r = r + "," + t32_jp("session_id", t32_js(session.id))
            r = t32_append_status_bar_json(r, session)
            r = r + t32_RB()
            return t32_make_tool_result(id, r)

# ============================================================================
# Tool 3: handle_t32_dialog_set (REQ-F5-003)
# Select/deselect/disable/enable dialog element
# ============================================================================

fn handle_t32_dialog_set(id: text, body: text) -> text:
    val label = t32_extract_field(body, "label")
    if label == "":
        return t32_make_tool_error(id, -32602, t32_err_missing_param("label", "t32_dialog_set", "t32_dialog_set(label: \"<name>\")", "t32_dialog_set(label: \"mycheck\", action: \"set\")"))
    if not t32_validate_identifier(label):
        return t32_make_tool_error(id, -32602, "Invalid label: contains disallowed characters")
    var action = t32_extract_field(body, "action")
    if action == "":
        action = "set"
    # Map action to T32 command
    var cmd = ""
    if action == "set":
        cmd = "DIALOG.Set " + label
    elif action == "disable":
        cmd = "DIALOG.Disable " + label
    elif action == "enable":
        cmd = "DIALOG.Enable " + label
    else:
        return t32_make_tool_error(id, -32602, t32_err_invalid_dialog_action(action))
    val session_opt = t32_find_current_session()
    match session_opt:
        nil: return t32_make_tool_error(id, -32602, t32_err_no_session_mcp())
        Some(session):
            var stdout = ""
            var rc: i64 = 0
            (stdout, rc) = t32_run_remote(session, cmd)
            t32_add_history(cmd, stdout.trim(), session.id, MCP_T32_CURRENT_CORE)
            if rc != 0 and rc != -1:
                return t32_make_tool_error(id, -32000, "DIALOG action failed (exit " + str(rc) + "): " + stdout.trim())
            if rc == -1:
                return t32_make_tool_error(id, -32000, stdout.trim())
            var r = t32_LB()
            r = r + t32_jp("label", t32_js(label))
            r = r + "," + t32_jp("action", t32_js(action))
            r = r + "," + t32_jp("command", t32_js(cmd))
            r = r + "," + t32_jp("status", t32_js("ok"))
            r = r + "," + t32_jp("session_id", t32_js(session.id))
            r = t32_append_status_bar_json(r, session)
            r = r + t32_RB()
            return t32_make_tool_result(id, r)

# ============================================================================
# Tool 4: handle_t32_dialog_click (REQ-F5-004)
# Check DIALOG.EXIST then DIALOG.EXECUTE, return handler output
# ============================================================================

fn handle_t32_dialog_click(id: text, body: text) -> text:
    val label = t32_extract_field(body, "label")
    if label == "":
        return t32_make_tool_error(id, -32602, t32_err_missing_param("label", "t32_dialog_click", "t32_dialog_click(label: \"<button_label>\")", "t32_dialog_click(label: \"ok_btn\")"))
    if not t32_validate_identifier(label):
        return t32_make_tool_error(id, -32602, "Invalid label: contains disallowed characters")
    val capture_area_str = t32_extract_field(body, "capture_area")
    var capture_area = false
    if capture_area_str == "true":
        capture_area = true
    val session_opt = t32_find_current_session()
    match session_opt:
        nil: return t32_make_tool_error(id, -32602, t32_err_no_session_mcp())
        Some(session):
            # Step 1: Check existence
            var exist_out = ""
            var exist_rc: i64 = 0
            (exist_out, exist_rc) = t32_run_remote(session, "EVAL DIALOG.EXIST(" + label + ")")
            if exist_rc != 0:
                return t32_make_tool_error(id, -32000, t32_err_no_dialog())
            val exist_trimmed = exist_out.trim().to_lower()
            if exist_trimmed != "true" and exist_trimmed != "true." and exist_trimmed != "1":
                return t32_make_tool_error(id, -32000, t32_err_dialog_not_found(label))
            # Step 2: Execute button handler
            val exec_cmd = "DIALOG.EXECUTE " + label
            var exec_out = ""
            var exec_rc: i64 = 0
            (exec_out, exec_rc) = t32_run_remote(session, exec_cmd)
            t32_add_history(exec_cmd, exec_out.trim(), session.id, MCP_T32_CURRENT_CORE)
            if exec_rc != 0 and exec_rc != -1:
                return t32_make_tool_error(id, -32000, "DIALOG.EXECUTE failed (exit " + str(exec_rc) + "): " + exec_out.trim())
            if exec_rc == -1:
                return t32_make_tool_error(id, -32000, exec_out.trim())
            # Step 3: Capture AREA buffer if requested
            var area_output = ""
            if capture_area and MCP_T32_AREA_READY:
                var area_name = MCP_T32_AREA_NAME
                if area_name == "":
                    area_name = "MCP_OUT"
                var area_stdout = ""
                var area_rc: i64 = 0
                (area_stdout, area_rc) = t32_run_remote(session, "WinPrint.AREA " + area_name)
                if area_rc == 0:
                    area_output = area_stdout.trim()
            var r = t32_LB()
            r = r + t32_jp("label", t32_js(label))
            r = r + "," + t32_jp("exists", "true")
            r = r + "," + t32_jp("command", t32_js(exec_cmd))
            r = r + "," + t32_jp("output", t32_js(exec_out.trim()))
            r = r + "," + t32_jp("status", t32_js("ok"))
            r = r + "," + t32_jp("session_id", t32_js(session.id))
            if area_output != "":
                r = r + "," + t32_jp("area_output", t32_js(area_output))
            r = t32_append_status_bar_json(r, session)
            r = r + t32_RB()
            return t32_make_tool_result(id, r)
