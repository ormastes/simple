@allow(unnamed_duplicate_typed_args)
# T32 MCP — Dialog tool handlers
#
# Delegates to main.spl's inline dialog handlers which use string-based
# line parsing. The original AST-based implementation (cmm_lsp.cmm_parser)
# is in examples/ and not resolvable from the MCP server's module path.

use t32_mcp.main.{t32_handle_dialog_parse, t32_handle_dialog_get, t32_handle_dialog_set, t32_handle_dialog_click}

fn handle_t32_dialog_parse(id: text, body: text) -> text:
    t32_handle_dialog_parse(id, body)

fn handle_t32_dialog_get(id: text, body: text) -> text:
    t32_handle_dialog_get(id, body)

fn handle_t32_dialog_set(id: text, body: text) -> text:
    t32_handle_dialog_set(id, body)

fn handle_t32_dialog_click(id: text, body: text) -> text:
    t32_handle_dialog_click(id, body)
