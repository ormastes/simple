@allow(unnamed_duplicate_typed_args)
# T32 MCP — Shared package state and configuration

# Protocol auto-detection
var T32_USE_JSON_LINES = false

# Response caches
var T32_TOOLS_CACHE = ""
var T32_INIT_CACHE = ""

class McpT32Session:
    id: text
    host: text
    port: i64
    intercom_name: text
    architecture: text
    connected: bool
    cores: [McpT32Core]

class McpT32Core:
    core_id: text
    label: text
    instance_binding: text

class McpT32HistoryItem:
    command: text
    result: text
    session_id: text
    core_id: text

var MCP_T32_SESSIONS: [McpT32Session] = []
var MCP_T32_CURRENT_SESSION = ""
var MCP_T32_CURRENT_CORE = ""
var MCP_T32_HISTORY: [McpT32HistoryItem] = []
var MCP_T32_AREA_READY = false
var MCP_T32_AREA_NAME = ""
var T32_SEEN_FIRST_MESSAGE = false

# Default connection config
var T32_DEFAULT_PORT: i64 = 20000
var T32_DEFAULT_HOST = "localhost"
var T32_RCL_PORT: i64 = 20000
var T32_RCL_HOST = "localhost"
var T32_BACKEND_PREFERENCE = ""
var T32_PYTHON_BINARY = "python3"
var T32_API_LIB_PATH = ""
var T32_PYTHON_BRIDGE_PATH = ""
