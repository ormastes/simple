@allow(unnamed_duplicate_typed_args)
# T32 MCP — Startup-only protocol helpers
#
# Keep the source-hosted front-end on a minimal protocol surface so it can
# answer initialize and the startup-safe subset without importing the full
# schema-heavy protocol module.

extern fn stdin_read_char() -> text
extern fn stderr_write(data: text) -> i64
extern fn stderr_flush() -> i64
extern fn rt_env_get(name: text) -> text
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_append_text(path: text, content: text) -> bool

use t32_mcp.state

fn t32_nl() -> text:
    return "\n"

fn Q() -> text:
    return "\""

fn LB() -> text:
    return "{"

fn RB() -> text:
    return "}"

fn SB_L() -> text:
    return "["

fn SB_R() -> text:
    return "]"

fn escape_json(s: text) -> text:
    var out = s
    out = out.replace("\\", "\\\\")
    out = out.replace("\"", "\\\"")
    out = out.replace("\n", "\\n")
    out = out.replace("\r", "\\r")
    out = out.replace("\t", "\\t")
    return out

fn js(value: text) -> text:
    return Q() + escape_json(value) + Q()

fn jp(key: text, value: text) -> text:
    return Q() + key + Q() + ":" + value

fn jo1(p1: text) -> text:
    return LB() + p1 + RB()

fn jo2(p1: text, p2: text) -> text:
    return LB() + p1 + "," + p2 + RB()

fn jo3(p1: text, p2: text, p3: text) -> text:
    return LB() + p1 + "," + p2 + "," + p3 + RB()

fn jsonrpc_result(id: text, result: text) -> text:
    return jo3(jp("jsonrpc", js("2.0")), jp("id", id), jp("result", result))

fn jsonrpc_error(id: text, code: i64, message: text) -> text:
    val err = jo2(jp("code", str(code)), jp("message", js(escape_json(message))))
    return jo3(jp("jsonrpc", js("2.0")), jp("id", id), jp("error", err))

fn t32_stderr(message: text):
    stderr_write("[t32-mcp] " + message + "\n")
    stderr_flush()

fn t32_protocol_debug_enabled() -> bool:
    return (rt_env_get("T32_MCP_DEBUG") ?? "") != ""

fn t32_protocol_debug(message: text):
    if t32_protocol_debug_enabled():
        t32_stderr("proto: " + message)

fn t32_protocol_trace(message: text):
    val debug_path = rt_env_get("T32_MCP_DEBUG_FILE") ?? ""
    if debug_path != "":
        rt_file_write_text(debug_path, "startup_protocol: " + message)

fn t32_strip_last(s: text) -> text:
    if s.len() <= 1:
        return ""
    return s.substring(0, s.len() - 1)

fn t32_parse_i64(s: text) -> i64:
    if s == "":
        return 0
    var i = 0
    var sign = 1
    if s.starts_with("-"):
        sign = -1
        i = 1
    var value = 0
    while i < s.len():
        val ch = s.substring(i, i + 1)
        if ch < "0" or ch > "9":
            break
        value = value * 10 + (ch.to_int() - "0".to_int())
        i = i + 1
    return value * sign

fn t32_startup_find_value_start(json: text, key: text) -> i64:
    val search = "\"" + key + "\":"
    val idx_opt = json.index_of(search)
    match idx_opt:
        Some(idx):
            var start = idx + search.len()
            while start < json.len():
                val ch = json.substring(start, start + 1)
                if ch == " " or ch == "\n" or ch == "\r" or ch == "\t":
                    start = start + 1
                else:
                    break
            return start
        nil:
            return -1

fn t32_startup_extract_field(json: text, key: text) -> text:
    val marker = "\"" + key + "\":"
    if not json.contains(marker):
        return ""
    val parts = json.split(marker)
    if parts.len() < 2:
        return ""
    var rest = parts[1].trim()
    if rest == "":
        return ""
    if rest.starts_with("\""):
        val quote_parts = rest.split("\"")
        if quote_parts.len() < 2:
            return ""
        return quote_parts[1]
    var end = 0
    while end < rest.len():
        val ch = rest.substring(end, end + 1)
        if ch == "," or ch == "}" or ch == "]" or ch == " " or ch == "\n" or ch == "\r" or ch == "\t":
            break
        end = end + 1
    return rest.substring(0, end)

fn t32_startup_extract_field_raw(json: text, key: text) -> text:
    val marker = "\"" + key + "\":"
    if not json.contains(marker):
        return "null"
    val parts = json.split(marker)
    if parts.len() < 2:
        return "null"
    var rest = parts[1].trim()
    if rest == "":
        return "null"
    val first = rest.substring(0, 1)
    if first == "\"":
        val quote_parts = rest.split("\"")
        if quote_parts.len() < 2:
            return "null"
        return "\"" + quote_parts[1] + "\""
    if first == "{" or first == "[":
        var depth = 0
        var i = 0
        while i < rest.len():
            val ch = rest.substring(i, i + 1)
            if ch == "{" or ch == "[":
                depth = depth + 1
            elif ch == "}" or ch == "]":
                depth = depth - 1
                if depth == 0:
                    return rest.substring(0, i + 1)
            i = i + 1
        return "null"
    var end = 0
    while end < rest.len():
        val ch = rest.substring(end, end + 1)
        if ch == "," or ch == "}" or ch == "]" or ch == " " or ch == "\n" or ch == "\r" or ch == "\t":
            break
        end = end + 1
    if end <= 0:
        return "null"
    return rest.substring(0, end)

fn t32_startup_extract_id(json: text) -> text:
    return t32_startup_extract_field_raw(json, "id")

fn t32_mcp_read_line() -> text:
    var line = ""
    while true:
        val ch = stdin_read_char()
        if ch == "":
            return line
        line = line + ch
        if ch == "\n":
            return line

fn t32_mcp_read_chars(count: i64) -> text:
    var result = ""
    var i = 0
    while i < count:
        val ch = stdin_read_char()
        if ch == "":
            break
        result = result + ch
        i = i + 1
    return result

fn t32_read_stdin_message() -> text:
    var content_length = 0
    while true:
        var line = t32_mcp_read_line()
        if line == "":
            if content_length > 0:
                break
            return ""
        if line == "\r\n" or line == "\r" or line == "\n":
            if content_length > 0:
                break
            continue
        if line.ends_with("\r\n"):
            line = t32_strip_last(t32_strip_last(line))
        elif line.ends_with("\n"):
            line = t32_strip_last(line)
        elif line.ends_with("\r"):
            line = t32_strip_last(line)
        if line.starts_with("{"):
            T32_USE_JSON_LINES = true
            return line
        if line.starts_with("Content-Length:"):
            var len_str = line.replace("Content-Length:", "")
            len_str = len_str.trim()
            content_length = t32_parse_i64(len_str)
    if content_length <= 0:
        return ""
    return t32_mcp_read_chars(content_length)

fn t32_text_byte_len(s: text) -> i64:
    return s.len()

fn t32_write_stdout_message(body: text):
    t32_protocol_trace("write_stdout_message body_bytes=" + str(body.len()))
    if T32_USE_JSON_LINES:
        print_raw(body + t32_nl())
        return
    val byte_count = t32_text_byte_len(body)
    val header = "Content-Length: " + str(byte_count) + "\r" + t32_nl() + "\r" + t32_nl()
    print_raw(header)
    print_raw(body)

fn t32_make_json_result(id: text, result: text) -> text:
    return jsonrpc_result(id, result)

fn t32_make_error(id: text, code: i64, message: text) -> text:
    return jsonrpc_error(id, code, message)

fn t32_tool_output_has_key(output: text, key: text) -> bool:
    return output.contains(Q() + key + Q() + ":")

fn t32_unknown_gui_status_json() -> text:
    var gui = LB()
    gui = gui + jp("message_line", js(""))
    gui = gui + "," + jp("message_type", js("info"))
    gui = gui + "," + jp("cursor", js(""))
    gui = gui + "," + jp("debug", js(""))
    gui = gui + "," + jp("debugger_activity", js(""))
    gui = gui + "," + jp("trace", js(""))
    gui = gui + "," + jp("mode", js(""))
    gui = gui + "," + jp("system", js(""))
    gui = gui + "," + jp("task", js(""))
    gui = gui + "," + jp("cores", js(""))
    gui = gui + "," + jp("target", js(""))
    gui = gui + "," + jp("monitor", js(""))
    gui = gui + "," + jp("target_state", js("unknown"))
    gui = gui + RB()
    return gui

fn t32_normalize_tool_output(output: text) -> text:
    val trimmed = output.trim()
    var normalized = trimmed
    if trimmed.starts_with(LB()) and trimmed.ends_with(RB()):
        normalized = trimmed
    elif trimmed.starts_with(SB_L()) and trimmed.ends_with(SB_R()):
        normalized = jo1(jp("items", trimmed))
    else:
        normalized = jo1(jp("value", js(trimmed)))
    if t32_tool_output_has_key(normalized, "gui_status"):
        return normalized
    var body = normalized
    if body.starts_with(LB()) and body.ends_with(RB()):
        body = body.substring(1, body.len() - 1)
    var parts: [text] = []
    if body != "":
        parts.push(body)
    parts.push(jp("gui_status", t32_unknown_gui_status_json()))
    parts.push(jp("status_bar", jo2(jp("message", js("")), jp("type", js("info")))))
    parts.push(jp("target_state", js("unknown")))
    return LB() + parts.join(",") + RB()

fn t32_make_tool_result(id: text, output: text) -> text:
    val normalized = t32_normalize_tool_output(output)
    val text_obj = jo2(jp("type", js("text")), jp("text", js(normalized)))
    return jsonrpc_result(id, jo1(jp("content", SB_L() + text_obj + SB_R())))

fn t32_make_tool_error(id: text, code: i64, msg: text) -> text:
    val err = "ERROR " + str(code) + ": " + msg
    val text_obj = jo2(jp("type", js("text")), jp("text", js(err)))
    var result = LB()
    result = result + jp("content", SB_L() + text_obj + SB_R())
    result = result + "," + jp("isError", "true")
    result = result + RB()
    return jsonrpc_result(id, result)

fn t32_server_name() -> text:
    return "simple-mcp-t32"

fn t32_server_version() -> text:
    return "0.1.2"

fn t32_make_init_response(id: text) -> text:
    if T32_INIT_CACHE != "":
        return jsonrpc_result(id, T32_INIT_CACHE)
    val tools_cap = jo1(jp("listChanged", "true"))
    val resources_cap = jo2(jp("subscribe", "false"), jp("listChanged", "true"))
    val caps = jo2(jp("tools", tools_cap), jp("resources", resources_cap))
    val server_info = jo3(
        jp("name", js(t32_server_name())),
        jp("version", js(t32_server_version())),
        jp("instructions", js("TRACE32 debug session control via MCP protocol. 35 tools for session management, window capture, action invocation, field manipulation, headless setup, command database, CMM validation, async jobs, and dialog interaction."))
    )
    val result = jo3(
        jp("protocolVersion", js("2025-06-18")),
        jp("capabilities", caps),
        jp("serverInfo", server_info)
    )
    T32_INIT_CACHE = result
    return jsonrpc_result(id, result)
