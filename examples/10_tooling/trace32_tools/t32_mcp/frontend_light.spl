@allow(unnamed_duplicate_typed_args)
# T32 MCP - lightweight frontend for low-cost wrapper-visible tools.

extern fn stdin_read_char() -> text
extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_env_get(name: text) -> text
extern fn rt_env_cwd() -> text
extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_append_text(path: text, content: text) -> bool
extern fn rt_file_exists(path: text) -> bool
extern fn stderr_write(data: text) -> i64
extern fn stderr_flush() -> i64

use t32_mcp.json_helpers.{t32_extract_field, t32_extract_field_raw, t32_extract_id, t32_extract_nested, t32_LB, t32_RB, t32_SB_L, t32_SB_R, t32_jp, t32_js, t32_jo1}
use t32_mcp.protocol.{t32_make_json_result, t32_make_error, t32_make_init_response, t32_make_tools_list, t32_make_tool_result, t32_make_tool_error, t32_read_stdin_message, t32_write_stdout_message}
use t32_mcp.job_manager.{t32_job_list, t32_job_get, t32_job_cancel, t32_job_to_json}

class McpT32Session:
    id: text
    host: text
    port: i64
    intercom_name: text
    architecture: text
    connected: bool

class McpT32HistoryItem:
    command: text
    result: text
    session_id: text
    core_id: text

class McpT32Dialog:
    session_id: text
    label: text
    declared_label: text
    generated_label: bool
    widget_type: text
    queryable: bool
    clickable: bool
    settable: bool
    query_type: text
    runtime_access: text
    supported_actions: text
    value: text

var MCP_T32_SESSIONS: [McpT32Session] = []
var MCP_T32_CURRENT_SESSION = ""
var MCP_T32_CURRENT_CORE = ""
var MCP_T32_HISTORY: [McpT32HistoryItem] = []
var MCP_T32_DIALOGS: [McpT32Dialog] = []
var MCP_T32_FIELD_KEYS: [text] = []
var MCP_T32_FIELD_VALUES: [text] = []
var MCP_T32_LAST_ERROR = ""
var T32_USE_JSON_LINES = false
var T32_SEEN_FIRST_MESSAGE = false
var T32_DEBUG_ROOT = ""

fn t32_nl() -> text:
    "\n"

fn t32_debug_enabled() -> bool:
    val raw = rt_env_get("T32_MCP_DEBUG_LOG") ?? ""
    if raw == "":
        return true
    val lower = raw.to_lower()
    not (lower == "0" or lower == "false" or lower == "off")

fn t32_sanitize_segment(value: text) -> text:
    if value == "":
        return "workspace"
    var out = ""
    var i = 0
    while i < value.len():
        val ch = value.substring(i, i + 1)
        if (ch >= "a" and ch <= "z") or (ch >= "A" and ch <= "Z") or (ch >= "0" and ch <= "9") or ch == "." or ch == "-" or ch == "_":
            out = out + ch
        else:
            out = out + "_"
        i = i + 1
    if out == "":
        return "workspace"
    out

fn t32_debug_root_dir() -> text:
    if T32_DEBUG_ROOT != "":
        return T32_DEBUG_ROOT
    var cwd = rt_env_cwd()
    if cwd == "":
        cwd = rt_env_get("PWD") ?? ""
    if cwd == "":
        cwd = "workspace"
    T32_DEBUG_ROOT = "/tmp/t32_mcp_debug_" + t32_sanitize_segment(cwd)
    if t32_debug_enabled():
        rt_process_run("/bin/sh", ["-c", "mkdir -p " + T32_DEBUG_ROOT])
    T32_DEBUG_ROOT

fn t32_debug_append(file: text, line: text):
    if not t32_debug_enabled():
        return
    val path = t32_debug_root_dir() + "/" + file
    var content = line
    if not content.ends_with("\n"):
        content = content + "\n"
    rt_file_append_text(path, content)

fn t32_debug_bootstrap():
    if not t32_debug_enabled():
        return
    t32_debug_append("wrapper.log", "startup cwd=" + rt_env_cwd())
    t32_debug_append("wrapper.log", "entry=examples/10_tooling/trace32_tools/t32_mcp/frontend_light.spl")
    t32_debug_append("frontend.log", "startup")

fn t32_debug_request(method: text, id: text, tool: text, raw: text):
    t32_debug_append("requests.log", "method=" + method + " id=" + id + " tool=" + tool + " bytes=" + str(raw.len()))

fn t32_debug_response(method: text, id: text, tool: text, response: text):
    t32_debug_append("wrapper.log", "method=" + method + " id=" + id + " tool=" + tool + " response_bytes=" + str(response.len()))

fn t32_debug_error(message: text):
    MCP_T32_LAST_ERROR = message
    t32_debug_append("errors.log", message)
    stderr_write("[t32-mcp] " + message + "\n")
    stderr_flush()

fn t32_bool_json(value: bool) -> text:
    if value:
        return "true"
    "false"

fn t32_add_history(command: text, result: text, session_id: text, core_id: text):
    MCP_T32_HISTORY = MCP_T32_HISTORY + [McpT32HistoryItem(command: command, result: result, session_id: session_id, core_id: core_id)]
    var count = 0
    for _h in MCP_T32_HISTORY:
        count = count + 1
    if count > 500:
        MCP_T32_HISTORY = MCP_T32_HISTORY[250..]

fn t32_field_state_get(session_id: text, field_key: text) -> text:
    val lookup = session_id + ":" + field_key
    var idx = 0
    for key in MCP_T32_FIELD_KEYS:
        if key == lookup:
            return MCP_T32_FIELD_VALUES[idx]
        idx = idx + 1
    ""

fn t32_field_state_set(session_id: text, field_key: text, value: text):
    val lookup = session_id + ":" + field_key
    var idx = 0
    for key in MCP_T32_FIELD_KEYS:
        if key == lookup:
            MCP_T32_FIELD_VALUES[idx] = value
            return
        idx = idx + 1
    MCP_T32_FIELD_KEYS = MCP_T32_FIELD_KEYS + [lookup]
    MCP_T32_FIELD_VALUES = MCP_T32_FIELD_VALUES + [value]

fn t32_dialog_valid_label(label: text) -> bool:
    if label == "":
        return false
    var i = 0
    while i < label.len():
        val ch = label.substring(i, i + 1)
        if ch == " " or ch == "\t" or ch == ";" or ch == "|" or ch == "&" or ch == "`" or ch == "'" or ch == "\"":
            return false
        i = i + 1
    true

fn t32_dialog_supported_actions(widget_type: text) -> text:
    var items: [text] = []
    if widget_type == "checkbox":
        items = ["set", "select", "deselect", "disable", "enable"]
    elif widget_type == "string" or widget_type == "edit" or widget_type == "choice":
        items = ["set", "disable", "enable"]
    elif widget_type == "button" or widget_type == "defbutton" or widget_type == "view":
        items = ["click"]
    else:
        items = ["set"]
    var arr = t32_SB_L()
    var first = true
    for item in items:
        if not first:
            arr = arr + ","
        first = false
        arr = arr + t32_js(item)
    arr + t32_SB_R()

fn t32_dialog_widget_type(keyword: text) -> text:
    val lower = keyword.to_lower()
    if lower == "ok" or lower == "yesno" or lower == "button":
        return "button"
    if lower == "defbutton":
        return "defbutton"
    if lower == "check" or lower == "checkbox":
        return "checkbox"
    if lower == "choosebox" or lower == "pulldown":
        return "choice"
    if lower == "string" or lower == "edit" or lower == "file" or lower == "dir":
        return "string"
    if lower == "view":
        return "view"
    "value"

fn t32_dialog_query_type(widget_type: text) -> text:
    if widget_type == "checkbox":
        return "boolean"
    if widget_type == "choice":
        return "value"
    if widget_type == "string":
        return "string"
    ""

fn t32_dialog_runtime_access(generated_label: bool) -> text:
    if generated_label:
        return "parse_only"
    "label"

fn t32_dialog_trim_token(token: text) -> text:
    var out = token.trim()
    if out.starts_with("\"") and out.ends_with("\"") and out.len() >= 2:
        out = out.substring(1, out.len() - 1)
    out

fn t32_dialog_first_token(text_value: text) -> text:
    var i = 0
    while i < text_value.len():
        val ch = text_value.substring(i, i + 1)
        if ch == " " or ch == "\t" or ch == "," or ch == "(" or ch == ")" or ch == ":":
            break
        i = i + 1
    t32_dialog_trim_token(text_value.substring(0, i))

fn t32_dialog_extract_label(rest: text) -> text:
    var token = t32_dialog_first_token(rest)
    if token.starts_with("label="):
        token = token.substring(6, token.len())
    if token.starts_with("label:"):
        token = token.substring(6, token.len())
    t32_dialog_trim_token(token)

fn t32_dialog_to_json(dialog: McpT32Dialog) -> text:
    var r = t32_LB()
    r = r + t32_jp("label", t32_js(dialog.label))
    r = r + "," + t32_jp("declared_label", t32_js(dialog.declared_label))
    r = r + "," + t32_jp("generated_label", t32_bool_json(dialog.generated_label))
    r = r + "," + t32_jp("widget_type", t32_js(dialog.widget_type))
    r = r + "," + t32_jp("queryable", t32_bool_json(dialog.queryable))
    r = r + "," + t32_jp("clickable", t32_bool_json(dialog.clickable))
    r = r + "," + t32_jp("settable", t32_bool_json(dialog.settable))
    r = r + "," + t32_jp("query_type", t32_js(dialog.query_type))
    r = r + "," + t32_jp("supported_actions", dialog.supported_actions)
    r = r + "," + t32_jp("runtime_access", t32_js(dialog.runtime_access))
    r = r + "," + t32_jp("value", t32_js(dialog.value))
    r = r + t32_RB()
    r

fn t32_dialog_find_index(label: text) -> i64:
    var idx: i64 = 0
    for dialog in MCP_T32_DIALOGS:
        if dialog.label == label:
            return idx
        idx = idx + 1
    -1

fn t32_dialog_find(label: text) -> McpT32Dialog:
    var idx = t32_dialog_find_index(label)
    if idx >= 0:
        return MCP_T32_DIALOGS[idx]
    McpT32Dialog(session_id: "", label: "", declared_label: "", generated_label: true, widget_type: "", queryable: false, clickable: false, settable: false, query_type: "", runtime_access: "parse_only", supported_actions: "[]", value: "")

fn t32_dialog_store(dialog: McpT32Dialog):
    val idx = t32_dialog_find_index(dialog.label)
    if idx >= 0:
        MCP_T32_DIALOGS[idx] = dialog
        return
    MCP_T32_DIALOGS = MCP_T32_DIALOGS + [dialog]

fn t32_dialog_clear():
    MCP_T32_DIALOGS = []

fn t32_dialog_parse_line(session_id: text, line: text, index: i64) -> McpT32Dialog:
    val trimmed = line.trim()
    val after = trimmed.substring(7, trimmed.len()).trim()
    val keyword = t32_dialog_first_token(after)
    var declared_label = t32_dialog_extract_label(after.substring(keyword.len(), after.len()).trim())
    if declared_label != "" and not t32_dialog_valid_label(declared_label):
        declared_label = ""
    var generated_label = false
    var label = declared_label
    if label == "":
        generated_label = true
        label = "dialog_" + str(index + 1)
    var widget_type = t32_dialog_widget_type(keyword)
    var queryable = false
    var clickable = false
    var settable = false
    if widget_type == "checkbox" or widget_type == "choice" or widget_type == "string" or widget_type == "value":
        queryable = true
        settable = true
    if widget_type == "button" or widget_type == "defbutton" or widget_type == "view":
        clickable = true
    var query_type = t32_dialog_query_type(widget_type)
    var runtime_access = t32_dialog_runtime_access(generated_label)
    var value = ""
    if widget_type == "checkbox":
        value = "false"
    McpT32Dialog(
        session_id: session_id,
        label: label,
        declared_label: declared_label,
        generated_label: generated_label,
        widget_type: widget_type,
        queryable: queryable,
        clickable: clickable,
        settable: settable,
        query_type: query_type,
        runtime_access: runtime_access,
        supported_actions: t32_dialog_supported_actions(widget_type),
        value: value
    )

fn t32_dialog_parse_source(session_id: text, source: text) -> [McpT32Dialog]:
    var parsed: [McpT32Dialog] = []
    var idx: i64 = 0
    for line in source.split("\n"):
        val trimmed = line.trim()
        if trimmed == "":
            idx = idx + 1
            continue
        if trimmed.to_lower().starts_with("dialog."):
            parsed = parsed + [t32_dialog_parse_line(session_id, trimmed, idx)]
        idx = idx + 1
    parsed

fn t32_sessions_list_json() -> text:
    var arr = t32_SB_L()
    var first = true
    for s in MCP_T32_SESSIONS:
        if not first:
            arr = arr + ","
        first = false
        var obj = t32_LB()
        obj = obj + t32_jp("id", t32_js(s.id))
        obj = obj + "," + t32_jp("host", t32_js(s.host))
        obj = obj + "," + t32_jp("port", str(s.port))
        obj = obj + "," + t32_jp("intercom_name", t32_js(s.intercom_name))
        obj = obj + "," + t32_jp("architecture", t32_js(s.architecture))
        obj = obj + "," + t32_jp("connected", t32_bool_json(s.connected))
        obj = obj + t32_RB()
        arr = arr + obj
    arr = arr + t32_SB_R()
    t32_make_tool_result("0", t32_LB() + t32_jp("sessions", arr) + t32_RB())

fn t32_make_resources_list(id: text) -> text:
    var sessions = t32_LB()
    sessions = sessions + t32_jp("uri", t32_js("t32:///sessions"))
    sessions = sessions + "," + t32_jp("name", t32_js("T32 Session Manifest"))
    sessions = sessions + "," + t32_jp("description", t32_js("List of all TRACE32 sessions and their state"))
    sessions = sessions + "," + t32_jp("mimeType", t32_js("application/json"))
    sessions = sessions + t32_RB()
    var history = t32_LB()
    history = history + t32_jp("uri", t32_js("t32:///history"))
    history = history + "," + t32_jp("name", t32_js("T32 Command History"))
    history = history + "," + t32_jp("description", t32_js("Recent TRACE32 command history"))
    history = history + "," + t32_jp("mimeType", t32_js("application/json"))
    history = history + t32_RB()
    var resources = t32_SB_L() + sessions + "," + history + t32_SB_R()
    t32_make_json_result(id, t32_jo1(t32_jp("resources", resources)))

fn t32_handle_resource_read(id: text, body: text) -> text:
    val uri = t32_extract_nested(body, "uri")
    if uri == "":
        return t32_make_error(id, -32602, "Missing required parameter: uri")
    if uri == "t32:///sessions":
        var arr = t32_SB_L()
        var first = true
        for s in MCP_T32_SESSIONS:
            if not first:
                arr = arr + ","
            first = false
            var obj = t32_LB()
            obj = obj + t32_jp("id", t32_js(s.id))
            obj = obj + "," + t32_jp("host", t32_js(s.host))
            obj = obj + "," + t32_jp("port", str(s.port))
            obj = obj + "," + t32_jp("intercom_name", t32_js(s.intercom_name))
            obj = obj + "," + t32_jp("architecture", t32_js(s.architecture))
            obj = obj + "," + t32_jp("connected", t32_bool_json(s.connected))
            obj = obj + t32_RB()
            arr = arr + obj
        arr = arr + t32_SB_R()
        val content = t32_LB() + t32_jp("uri", t32_js(uri)) + "," + t32_jp("mimeType", t32_js("application/json")) + "," + t32_jp("text", t32_js(t32_escape_json(arr))) + t32_RB()
        return t32_make_json_result(id, t32_jo1(t32_jp("contents", t32_SB_L() + content + t32_SB_R())))
    if uri == "t32:///history":
        var arr = t32_SB_L()
        var first = true
        for h in MCP_T32_HISTORY:
            if not first:
                arr = arr + ","
            first = false
            var obj = t32_LB()
            obj = obj + t32_jp("command", t32_js(h.command))
            obj = obj + "," + t32_jp("result", t32_js(h.result))
            obj = obj + "," + t32_jp("session_id", t32_js(h.session_id))
            obj = obj + "," + t32_jp("core_id", t32_js(h.core_id))
            obj = obj + t32_RB()
            arr = arr + obj
        arr = arr + t32_SB_R()
        val content = t32_LB() + t32_jp("uri", t32_js(uri)) + "," + t32_jp("mimeType", t32_js("application/json")) + "," + t32_jp("text", t32_js(t32_escape_json(arr))) + t32_RB()
        return t32_make_json_result(id, t32_jo1(t32_jp("contents", t32_SB_L() + content + t32_SB_R())))
    t32_make_error(id, -32002, "Resource not found: " + uri)

fn t32_handle_cmm_commands(id: text, body: text) -> text:
    val group = t32_extract_field(body, "group")
    val search = t32_extract_field(body, "search")
    var db: [text] = []
    db = db + ["Data.dump|D.D|Data|Display hex dump of memory"]
    db = db + ["Data.List|D.L|Data|Display disassembly listing"]
    db = db + ["Data.LOAD|D.LOAD|Data|Load program file"]
    db = db + ["Data.Set|D.S|Data|Set memory values"]
    db = db + ["SYStem.Up|SYS.Up|SYStem|Start debug session"]
    db = db + ["SYStem.Down|SYS.Down|SYStem|Stop debug session"]
    db = db + ["Break.Set|B.S|Break|Set breakpoint"]
    db = db + ["Break.Delete|B.D|Break|Delete breakpoint"]
    db = db + ["Register.Set|R.S|Register|Set register value"]
    db = db + ["Register.view|R|Register|View registers"]
    db = db + ["Var.View|V.V|Var|View variable"]
    db = db + ["Var.AddWatch|V.AddWatch|Var|Add watch expression"]
    db = db + ["Trace.List|T.L|Trace|List trace records"]
    db = db + ["AREA.Create|AREA.Create|AREA|Create AREA window"]
    db = db + ["AREA.Select|AREA.Select|AREA|Select AREA for I/O"]
    db = db + ["SCREEN.OFF|SCREEN.OFF|Screen|Disable screen updates"]
    db = db + ["SCREEN.ON|SCREEN.ON|Screen|Enable screen updates"]
    db = db + ["WINPOS|WINPOS|Window|Set window position and size"]
    db = db + ["EVAL|EVAL|Misc|Evaluate expression"]
    db = db + ["PRINT|PRINT|IO|Print to output area"]
    db = db + ["ON|ON|Event|Set event handler"]
    db = db + ["GLOBALON|GLOBALON|Event|Set global event handler"]
    db = db + ["DO|DO|Control|Call CMM script"]
    db = db + ["ENDDO|ENDDO|Control|End script / return value"]
    var filtered: [text] = []
    for cmd in db:
        val parts = cmd.split("|")
        var cmd_name = ""
        var cmd_short = ""
        var cmd_group = ""
        var cmd_desc = ""
        if parts.len() > 0:
            cmd_name = parts[0]
        if parts.len() > 1:
            cmd_short = parts[1]
        if parts.len() > 2:
            cmd_group = parts[2]
        if parts.len() > 3:
            cmd_desc = parts[3]
        if group != "" and cmd_group.to_lower() != group.to_lower():
            continue
        if search != "":
            val lower_search = search.to_lower()
            if not cmd_name.to_lower().contains(lower_search) and not cmd_desc.to_lower().contains(lower_search):
                continue
        var obj = t32_LB()
        obj = obj + t32_jp("name", t32_js(cmd_name))
        obj = obj + "," + t32_jp("short_name", t32_js(cmd_short))
        obj = obj + "," + t32_jp("group", t32_js(cmd_group))
        obj = obj + "," + t32_jp("description", t32_js(cmd_desc))
        obj = obj + t32_RB()
        filtered = filtered + [obj]
    var arr = t32_SB_L()
    var first = true
    for item in filtered:
        if not first:
            arr = arr + ","
        first = false
        arr = arr + item
    arr = arr + t32_SB_R()
    var r = t32_LB()
    r = r + t32_jp("count", str(filtered.len()))
    r = r + "," + t32_jp("commands", arr)
    r = r + t32_RB()
    t32_add_history("t32_cmm_commands", group + " " + search, MCP_T32_CURRENT_SESSION, MCP_T32_CURRENT_CORE)
    t32_make_tool_result(id, r)

fn t32_handle_field_get(id: text, body: text) -> text:
    val field_key = t32_extract_field(body, "field_key")
    if field_key == "":
        return t32_make_tool_error(id, -32602, "Missing required parameter: field_key")
    val session_id = MCP_T32_CURRENT_SESSION
    var value = t32_field_state_get(session_id, field_key)
    if value == "":
        if field_key == "pc" or field_key == "sp" or field_key == "lr" or field_key == "cpsr" or field_key == "r0" or field_key == "r1" or field_key == "r2" or field_key == "r3":
            value = "0x0"
        elif field_key.starts_with("status."):
            value = "unknown"
    t32_field_state_set(session_id, field_key, value)
    t32_add_history("field_get:" + field_key, value, session_id, MCP_T32_CURRENT_CORE)
    var r = t32_LB()
    r = r + t32_jp("field_key", t32_js(field_key))
    r = r + "," + t32_jp("value", t32_js(value))
    r = r + "," + t32_jp("session_id", t32_js(session_id))
    r = r + t32_RB()
    t32_make_tool_result(id, r)

fn t32_handle_field_set(id: text, body: text) -> text:
    val field_key = t32_extract_field(body, "field_key")
    val value = t32_extract_field(body, "value")
    if field_key == "" or value == "":
        return t32_make_tool_error(id, -32602, "Missing required parameter: field_key, value")
    val session_id = MCP_T32_CURRENT_SESSION
    t32_field_state_set(session_id, field_key, value)
    t32_add_history("field_set:" + field_key + "=" + value, "ok", session_id, MCP_T32_CURRENT_CORE)
    var r = t32_LB()
    r = r + t32_jp("field_key", t32_js(field_key))
    r = r + "," + t32_jp("value", t32_js(value))
    r = r + "," + t32_jp("session_id", t32_js(session_id))
    r = r + "," + t32_jp("status", t32_js("ok"))
    r = r + t32_RB()
    t32_make_tool_result(id, r)

fn t32_handle_history_tail(id: text, body: text) -> text:
    val count_str = t32_extract_field(body, "count")
    var count: i64 = 20
    if count_str != "":
        count = int(count_str)
        if count < 1:
            count = 20
    var total: i64 = 0
    for _h in MCP_T32_HISTORY:
        total = total + 1
    var start_idx: i64 = 0
    if total > count:
        start_idx = total - count
    var arr = t32_SB_L()
    var first = true
    var idx: i64 = 0
    for h in MCP_T32_HISTORY:
        if idx >= start_idx:
            if not first:
                arr = arr + ","
            first = false
            var obj = t32_LB()
            obj = obj + t32_jp("command", t32_js(h.command))
            obj = obj + "," + t32_jp("result", t32_js(h.result))
            obj = obj + "," + t32_jp("session_id", t32_js(h.session_id))
            obj = obj + "," + t32_jp("core_id", t32_js(h.core_id))
            obj = obj + t32_RB()
            arr = arr + obj
        idx = idx + 1
    arr = arr + t32_SB_R()
    t32_make_tool_result(id, arr)

fn t32_handle_dialog_parse(id: text, body: text) -> text:
    val source = t32_extract_field(body, "source")
    if source == "":
        return t32_make_tool_error(id, -32602, "Missing required parameter: source")
    var cmm_source = source
    if not source.contains("\n") and not source.contains(";"):
        val file_content = rt_file_read_text(source) ?? ""
        if file_content != "":
            cmm_source = file_content
    t32_dialog_clear()
    val parsed = t32_dialog_parse_source(MCP_T32_CURRENT_SESSION, cmm_source)
    for dialog in parsed:
        t32_dialog_store(dialog)
    var arr = t32_SB_L()
    var first = true
    for dialog in parsed:
        if not first:
            arr = arr + ","
        first = false
        arr = arr + t32_dialog_to_json(dialog)
    arr = arr + t32_SB_R()
    var r = t32_LB()
    r = r + t32_jp("count", str(parsed.len()))
    r = r + "," + t32_jp("dialogs", arr)
    r = r + t32_RB()
    t32_add_history("dialog_parse", source, MCP_T32_CURRENT_SESSION, MCP_T32_CURRENT_CORE)
    t32_make_tool_result(id, r)

fn t32_handle_dialog_get(id: text, body: text) -> text:
    val label = t32_extract_field(body, "label")
    val query_type = t32_extract_field(body, "type")
    if label == "":
        return t32_make_tool_error(id, -32602, "Missing required parameter: label")
    val dialog = t32_dialog_find(label)
    if dialog.label == "":
        return t32_make_tool_error(id, -32602, "Dialog element not found: " + label)
    if not dialog.queryable:
        return t32_make_tool_error(id, -32602, "Dialog element is not queryable: " + label)
    if dialog.runtime_access != "label":
        return t32_make_tool_error(id, -32602, "Dialog element uses a generated label and cannot be queried at runtime: " + label)
    if query_type != "" and query_type != dialog.query_type:
        return t32_make_tool_error(id, -32602, "Dialog element expects type " + dialog.query_type + ", not " + query_type)
    t32_field_state_set(MCP_T32_CURRENT_SESSION, "dialog:" + label, dialog.value)
    var r = t32_LB()
    r = r + t32_jp("label", t32_js(dialog.label))
    r = r + "," + t32_jp("declared_label", t32_js(dialog.declared_label))
    r = r + "," + t32_jp("generated_label", t32_bool_json(dialog.generated_label))
    r = r + "," + t32_jp("widget_type", t32_js(dialog.widget_type))
    r = r + "," + t32_jp("query_type", t32_js(dialog.query_type))
    r = r + "," + t32_jp("value", t32_js(dialog.value))
    r = r + "," + t32_jp("queryable", t32_bool_json(dialog.queryable))
    r = r + "," + t32_jp("settable", t32_bool_json(dialog.settable))
    r = r + "," + t32_jp("clickable", t32_bool_json(dialog.clickable))
    r = r + "," + t32_jp("runtime_access", t32_js(dialog.runtime_access))
    r = r + t32_RB()
    t32_make_tool_result(id, r)

fn t32_handle_dialog_set(id: text, body: text) -> text:
    val label = t32_extract_field(body, "label")
    var action = t32_extract_field(body, "action")
    val value = t32_extract_field(body, "value")
    if label == "":
        return t32_make_tool_error(id, -32602, "Missing required parameter: label")
    if action == "":
        action = "set"
    val dialog = t32_dialog_find(label)
    if dialog.label == "":
        return t32_make_tool_error(id, -32602, "Dialog element not found: " + label)
    if not dialog.settable:
        return t32_make_tool_error(id, -32602, "Dialog element is not settable: " + label)
    if dialog.runtime_access != "label":
        return t32_make_tool_error(id, -32602, "Dialog element uses a generated label and cannot be set at runtime: " + label)
    var new_value = value
    if action == "disable" or action == "deselect":
        new_value = "false"
    elif action == "enable" or action == "select":
        new_value = "true"
    if new_value == "" and action == "set":
        new_value = "true"
    var updated = dialog
    updated.value = new_value
    t32_dialog_store(updated)
    t32_field_state_set(MCP_T32_CURRENT_SESSION, "dialog:" + label, new_value)
    t32_add_history("dialog_set:" + label + ":" + action, new_value, MCP_T32_CURRENT_SESSION, MCP_T32_CURRENT_CORE)
    var r = t32_LB()
    r = r + t32_jp("label", t32_js(label))
    r = r + "," + t32_jp("action", t32_js(action))
    r = r + "," + t32_jp("value", t32_js(new_value))
    r = r + "," + t32_jp("status", t32_js("ok"))
    r = r + t32_RB()
    t32_make_tool_result(id, r)

fn t32_handle_dialog_click(id: text, body: text) -> text:
    val label = t32_extract_field(body, "label")
    if label == "":
        return t32_make_tool_error(id, -32602, "Missing required parameter: label")
    val dialog = t32_dialog_find(label)
    if dialog.label == "":
        return t32_make_tool_error(id, -32602, "Dialog element not found: " + label)
    if not dialog.clickable:
        return t32_make_tool_error(id, -32602, "Dialog element is not clickable: " + label)
    var updated = dialog
    updated.value = "clicked"
    t32_dialog_store(updated)
    t32_add_history("dialog_click:" + label, "clicked", MCP_T32_CURRENT_SESSION, MCP_T32_CURRENT_CORE)
    var r = t32_LB()
    r = r + t32_jp("label", t32_js(label))
    r = r + "," + t32_jp("status", t32_js("ok"))
    r = r + t32_RB()
    t32_make_tool_result(id, r)

fn t32_handle_error_check(id: text, body: text) -> text:
    var r = t32_LB()
    r = r + t32_jp("message", t32_js(MCP_T32_LAST_ERROR))
    r = r + "," + t32_jp("type", t32_js(if MCP_T32_LAST_ERROR == "": "info" else: "error"))
    r = r + "," + t32_jp("stderr", t32_js(""))
    r = r + "," + t32_jp("practice_state", "-1")
    r = r + "," + t32_jp("has_error", t32_bool_json(MCP_T32_LAST_ERROR != ""))
    r = r + t32_RB()
    t32_make_tool_result(id, r)

fn t32_dispatch_low_cost_tool(id: text, body: text, tool_name: text) -> text:
    val args_raw = t32_extract_field_raw(body, "arguments")
    if tool_name == "t32_sessions_list":
        return t32_make_tool_result(id, t32_LB() + t32_jp("sessions", t32_SB_L() + t32_SB_R()) + t32_RB())
    elif tool_name == "t32_job_list":
        val session_filter = t32_extract_field(args_raw, "session_id")
        var jobs = t32_job_list(session_filter)
        var parts: [text] = []
        for job in jobs:
            parts = parts + [t32_job_to_json(job)]
        return t32_make_tool_result(id, t32_SB_L() + parts.join(",") + t32_SB_R())
    elif tool_name == "t32_job_get":
        val job_id = t32_extract_field(args_raw, "job_id")
        val job = t32_job_get(job_id)
        if job.status == "not_found":
            return t32_make_tool_error(id, -32602, "Job not found: " + job_id)
        return t32_make_tool_result(id, t32_job_to_json(job))
    elif tool_name == "t32_job_cancel":
        val job_id = t32_extract_field(args_raw, "job_id")
        val ok = t32_job_cancel(job_id)
        if ok:
            return t32_make_tool_result(id, t32_LB() + t32_jp("cancelled", "true") + t32_RB())
        return t32_make_tool_error(id, -32602, "Cannot cancel job: " + job_id)
    elif tool_name == "t32_job_result":
        val job_id = t32_extract_field(args_raw, "job_id")
        val job = t32_job_get(job_id)
        if job.status == "not_found":
            return t32_make_tool_error(id, -32602, "Job not found: " + job_id)
        if job.status == "completed":
            return t32_make_tool_result(id, t32_LB() + t32_jp("job_id", t32_js(job_id)) + "," + t32_jp("result", job.result) + t32_RB())
        if job.status == "failed":
            return t32_make_tool_error(id, -32602, "Job failed: " + job.error)
        return t32_make_tool_error(id, -32602, "Job not yet complete (status: " + job.status + ")")
    elif tool_name == "t32_cmm_commands":
        return t32_handle_cmm_commands(id, args_raw)
    elif tool_name == "t32_field_get":
        return t32_handle_field_get(id, args_raw)
    elif tool_name == "t32_field_set":
        return t32_handle_field_set(id, args_raw)
    elif tool_name == "t32_history_tail":
        return t32_handle_history_tail(id, args_raw)
    elif tool_name == "t32_dialog_parse":
        return t32_handle_dialog_parse(id, args_raw)
    elif tool_name == "t32_dialog_get":
        return t32_handle_dialog_get(id, args_raw)
    elif tool_name == "t32_dialog_set":
        return t32_handle_dialog_set(id, args_raw)
    elif tool_name == "t32_dialog_click":
        return t32_handle_dialog_click(id, args_raw)
    elif tool_name == "t32_error_check":
        return t32_handle_error_check(id, args_raw)
    return t32_make_tool_error(id, -32601, "Method not found: " + tool_name)

fn main():
    t32_debug_bootstrap()
    while true:
        var msg = t32_read_stdin_message()
        if msg == "":
            if not T32_SEEN_FIRST_MESSAGE:
                t32_debug_error("startup error: no MCP request received on stdin")
            return
        T32_SEEN_FIRST_MESSAGE = true
        val method = t32_extract_field(msg, "method")
        val id = t32_extract_id(msg)
        var response = ""
        var tool_name = ""
        if method == "tools/call":
            tool_name = t32_extract_nested(msg, "name")
        t32_debug_request(method, id, tool_name, msg)
        if method == "initialize":
            response = t32_make_init_response(id)
        elif method == "initialized" or method == "notifications/initialized":
            response = ""
        elif method == "shutdown":
            response = t32_make_json_result(id, "null")
        elif method == "tools/list":
            response = t32_make_tools_list(id)
        elif method == "tools/call":
            response = t32_dispatch_low_cost_tool(id, msg, tool_name)
        elif method == "resources/list":
            response = t32_make_resources_list(id)
        elif method == "resources/templates/list":
            response = t32_make_json_result(id, t32_jo1(t32_jp("resourceTemplates", t32_SB_L() + t32_SB_R())))
        elif method == "resources/read":
            response = t32_handle_resource_read(id, msg)
        elif method == "prompts/list":
            response = t32_make_json_result(id, "{\"prompts\":[]}")
        elif method == "roots/list":
            response = t32_make_json_result(id, "{\"roots\":[]}")
        elif method == "logging/setLevel" or method == "logging/setlevel":
            response = t32_make_json_result(id, "null")
        elif method == "ping":
            response = t32_make_json_result(id, t32_LB() + t32_RB())
        elif method == "notifications/cancelled" or method == "notifications/roots/list_changed":
            response = ""
        else:
            if id != "" and id != "null":
                response = t32_make_error(id, -32601, "Method not found: " + method)
        if response != "":
            t32_debug_response(method, id, tool_name, response)
            t32_write_stdout_message(response)
