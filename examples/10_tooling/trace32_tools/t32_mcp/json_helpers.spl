@allow(unnamed_duplicate_typed_args)
# T32 MCP Server — JSON helpers (inlined, zero stdlib imports)
#
# Provides all JSON building/parsing functions used by T32 MCP tool files.
# Both t32_-prefixed versions (used by session_tools, window_tools, etc.)
# and bare versions (used by protocol.spl) are defined here.
#
# Pattern copied from src/app/mcp/main_lazy_json.spl to avoid loading
# the entire src/lib/ module tree via mcp_sdk imports (which causes 8GB+ RSS).

# --- Safe string helpers ---

fn t32_strip_last(s: text) -> text:
    var parts: [text] = []
    var count = 0
    val limit = s.length() - 1
    for ch in s:
        if count >= limit:
            break
        parts.push(ch)
        count = count + 1
    parts.join("")

fn strip_last(s: text) -> text:
    t32_strip_last(s)

fn t32_strip_first_last(s: text) -> text:
    t32_strip_last(s.substring(1))

fn strip_first_last(s: text) -> text:
    t32_strip_first_last(s)

# --- JSON building primitives ---

fn t32_Q() -> text:
    "\""

fn t32_LB() -> text:
    "{"

fn t32_RB() -> text:
    "}"

fn t32_SB_L() -> text:
    "["

fn t32_SB_R() -> text:
    "]"

fn Q() -> text:
    "\""

fn LB() -> text:
    "{"

fn RB() -> text:
    "}"

fn SB_L() -> text:
    "["

fn SB_R() -> text:
    "]"

# --- JSON escape ---

fn t32_escape_json(s: text) -> text:
    var result = s
    result = result.replace(r"\", r"\\")
    result = result.replace(t32_Q(), r"\" + t32_Q())
    result = result.replace("\n", r"\n")
    result = result.replace("\r", r"\r")
    result = result.replace("\t", r"\t")
    result

fn escape_json(s: text) -> text:
    t32_escape_json(s)

# --- JSON string/pair/object builders ---

fn t32_js(s: text) -> text:
    t32_Q() + t32_escape_json(s) + t32_Q()

fn t32_jp(key: text, value: text) -> text:
    t32_Q() + key + t32_Q() + ":" + value

fn t32_jo1(p1: text) -> text:
    t32_LB() + p1 + t32_RB()

fn t32_jo2(p1: text, p2: text) -> text:
    t32_LB() + p1 + "," + p2 + t32_RB()

fn t32_jo3(p1: text, p2: text, p3: text) -> text:
    t32_LB() + p1 + "," + p2 + "," + p3 + t32_RB()

fn t32_jo4(p1: text, p2: text, p3: text, p4: text) -> text:
    t32_LB() + p1 + "," + p2 + "," + p3 + "," + p4 + t32_RB()

fn js(s: text) -> text:
    t32_js(s)

fn jp(key: text, value: text) -> text:
    t32_jp(key, value)

fn jo1(p1: text) -> text:
    t32_jo1(p1)

fn jo2(p1: text, p2: text) -> text:
    t32_jo2(p1, p2)

fn jo3(p1: text, p2: text, p3: text) -> text:
    t32_jo3(p1, p2, p3)

fn jo4(p1: text, p2: text, p3: text, p4: text) -> text:
    t32_jo4(p1, p2, p3, p4)

# --- JSON field extraction ---

fn t32_extract_field(json: text, key: text) -> text:
    val search = t32_Q() + key + t32_Q() + ":"
    val idx_result = json.index_of(search)
    var idx = -1
    match idx_result:
        Some(i): idx = i
        nil: return ""
    if idx < 0:
        return ""
    val start = idx + search.len()
    val after = json.substring(start)
    val trimmed = after.trim()
    if trimmed.starts_with(t32_Q()):
        val after_quote = trimmed.substring(1)
        var parts: [text] = []
        for ch in after_quote:
            if ch == t32_Q():
                break
            parts.push(ch)
        return parts.join("")
    else:
        var parts: [text] = []
        for ch in trimmed:
            if ch == "," or ch == t32_RB() or ch == t32_SB_R() or ch == " " or ch == "\n":
                break
            parts.push(ch)
        return parts.join("")

fn extract_field(json: text, key: text) -> text:
    t32_extract_field(json, key)

fn t32_extract_field_raw(json: text, key: text) -> text:
    val search = t32_Q() + key + t32_Q() + ":"
    val idx_result = json.index_of(search)
    var idx = -1
    match idx_result:
        Some(i): idx = i
        nil: return "null"
    if idx < 0:
        return "null"
    var start = idx + search.len()
    if start >= json.len():
        return "null"
    var rest = json.substring(start)
    rest = rest.trim()
    if rest == "":
        return "null"
    if rest.starts_with(t32_Q()):
        var out: [text] = [t32_Q()]
        var escaped = false
        var first = true
        for ch in rest:
            if first:
                first = false
                continue
            out.push(ch)
            if escaped:
                escaped = false
            elif ch == "\\":
                escaped = true
            elif ch == t32_Q():
                break
        return out.join("")
    var parts: [text] = []
    for ch in rest:
        if ch == "," or ch == t32_RB() or ch == t32_SB_R() or ch == " " or ch == "\n":
            break
        parts.push(ch)
    val raw = parts.join("")
    if raw == "":
        return "null"
    raw

fn extract_field_raw(json: text, key: text) -> text:
    t32_extract_field_raw(json, key)

fn t32_extract_id(json: text) -> text:
    t32_extract_field_raw(json, "id")

fn extract_id(json: text) -> text:
    t32_extract_id(json)

fn t32_extract_nested(json: text, key: text) -> text:
    val params_search = t32_Q() + "params" + t32_Q() + ":"
    val params_idx_result = json.index_of(params_search)
    var params_idx = -1
    match params_idx_result:
        Some(i): params_idx = i
        nil: return ""
    if params_idx < 0:
        return ""
    val params_start = params_idx + params_search.len()
    val params = json.substring(params_start)
    t32_extract_field(params, key)

fn extract_nested(json: text, key: text) -> text:
    t32_extract_nested(json, key)

# --- JSON-RPC helpers ---

fn jsonrpc_result(id: text, result: text) -> text:
    t32_jo3(t32_jp("jsonrpc", t32_js("2.0")), t32_jp("id", id), t32_jp("result", result))

fn jsonrpc_error(id: text, code: i64, message: text) -> text:
    val err = t32_jo2(t32_jp("code", str(code)), t32_jp("message", t32_js(message)))
    t32_jo3(t32_jp("jsonrpc", t32_js("2.0")), t32_jp("id", id), t32_jp("error", err))
