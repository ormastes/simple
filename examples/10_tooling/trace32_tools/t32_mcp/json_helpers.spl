@allow(unnamed_duplicate_typed_args)
# T32 MCP Server — JSON helpers
#
# Delegates to the canonical implementations in t32_lsp_mcp/json_helpers.spl.
# Provides t32_-prefixed wrappers and bare aliases consumed by T32 MCP tool files.

use t32_lsp_mcp.json_helpers.{
    Q, LB, RB, SB_L, SB_R,
    escape_json, js, jp, jo1, jo2, jo3, jo4,
    extract_field, extract_field_raw, extract_id,
    extract_nested, unescape_json_string,
    jsonrpc_result, jsonrpc_error
}

# --- Safe string helpers (local to t32_mcp) ---

fn t32_strip_last(s: text) -> text:
    if s.len() <= 1:
        return ""
    s.substring(0, s.len() - 1)

fn strip_last(s: text) -> text:
    t32_strip_last(s)

fn t32_strip_first_last(s: text) -> text:
    if s.len() <= 2:
        return ""
    s.substring(1, s.len() - 1)

fn strip_first_last(s: text) -> text:
    t32_strip_first_last(s)

# --- t32_-prefixed wrappers (delegating to canonical implementations) ---

fn t32_Q() -> text: Q()
fn t32_LB() -> text: LB()
fn t32_RB() -> text: RB()
fn t32_SB_L() -> text: SB_L()
fn t32_SB_R() -> text: SB_R()
fn t32_escape_json(s: text) -> text: escape_json(s)
fn t32_js(s: text) -> text: js(s)
fn t32_jp(key: text, value: text) -> text: jp(key, value)
fn t32_jo1(p1: text) -> text: jo1(p1)
fn t32_jo2(p1: text, p2: text) -> text: jo2(p1, p2)
fn t32_jo3(p1: text, p2: text, p3: text) -> text: jo3(p1, p2, p3)
fn t32_jo4(p1: text, p2: text, p3: text, p4: text) -> text: jo4(p1, p2, p3, p4)
fn t32_extract_field(json: text, key: text) -> text: extract_field(json, key)
fn t32_extract_field_raw(json: text, key: text) -> text: extract_field_raw(json, key)
fn t32_extract_id(json: text) -> text: extract_id(json)
fn t32_extract_nested(json: text, key: text) -> text: extract_nested(json, key)
