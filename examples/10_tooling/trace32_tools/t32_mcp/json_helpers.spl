@allow(unnamed_duplicate_typed_args)
# T32 MCP Server — JSON helpers
#
# Inlined implementations (zero cross-package imports).
# Provides t32_-prefixed wrappers and bare aliases consumed by T32 MCP tool files.

# --- JSON building helpers ---

fn Q() -> text:
    return "\""

fn LB() -> text:
    return "{"

fn RB() -> text:
    return "}"

fn SB_L() -> text:
    return "["

fn SB_R() -> text:
    return "]"

fn escape_json(s: text) -> text:
    var out = s
    out = out.replace("\\", "\\\\")
    out = out.replace("\"", "\\\"")
    out = out.replace("\n", "\\n")
    out = out.replace("\r", "\\r")
    out = out.replace("\t", "\\t")
    return out

fn js(value: text) -> text:
    return Q() + escape_json(value) + Q()

fn jp(key: text, value: text) -> text:
    return Q() + key + Q() + ":" + value

fn jo1(p1: text) -> text:
    return LB() + p1 + RB()

fn jo2(p1: text, p2: text) -> text:
    return LB() + p1 + "," + p2 + RB()

fn jo3(p1: text, p2: text, p3: text) -> text:
    return LB() + p1 + "," + p2 + "," + p3 + RB()

fn jo4(p1: text, p2: text, p3: text, p4: text) -> text:
    return LB() + p1 + "," + p2 + "," + p3 + "," + p4 + RB()

# --- JSON parsing helpers ---

fn _char_at(s: text, i: i64) -> text:
    return s.substring(i, i + 1)

fn _is_ws(ch: text) -> bool:
    return ch == " " or ch == "\n" or ch == "\r" or ch == "\t"

fn _find_json_value_start(json: text, key: text) -> i64:
    val search = Q() + key + Q()
    var offset = 0
    while offset + search.len() <= json.len():
        if json.substring(offset, offset + search.len()) != search:
            offset = offset + 1
            continue
        var j = offset + search.len()
        while j < json.len() and _is_ws(_char_at(json, j)):
            j = j + 1
        if j < json.len() and _char_at(json, j) == ":":
            j = j + 1
            while j < json.len() and _is_ws(_char_at(json, j)):
                j = j + 1
            return j
        offset = offset + search.len()
    return -1

fn extract_field(json: text, key: text) -> text:
    val start = _find_json_value_start(json, key)
    if start < 0 or start >= json.len():
        return ""
    val first = _char_at(json, start)
    if first == Q():
        var i = start + 1
        var escaped = false
        while i < json.len():
            val ch = _char_at(json, i)
            if escaped:
                escaped = false
            elif ch == "\\":
                escaped = true
            elif ch == Q():
                return json.substring(start + 1, i)
            i = i + 1
        return ""
    var end = start
    while end < json.len():
        val ch = _char_at(json, end)
        if ch == "," or ch == RB() or ch == "]" or _is_ws(ch):
            break
        end = end + 1
    return json.substring(start, end)

fn extract_field_raw(json: text, key: text) -> text:
    val start = _find_json_value_start(json, key)
    if start < 0 or start >= json.len():
        return "null"
    val first = _char_at(json, start)
    if first == Q():
        var i2 = start + 1
        var escaped = false
        while i2 < json.len():
            val ch = _char_at(json, i2)
            if escaped:
                escaped = false
            elif ch == "\\":
                escaped = true
            elif ch == Q():
                return json.substring(start, i2 + 1)
            i2 = i2 + 1
        return "null"
    if first == LB() or first == "[":
        var depth = 0
        var i3 = start
        var in_str = false
        var esc = false
        while i3 < json.len():
            val ch = _char_at(json, i3)
            if in_str:
                if esc:
                    esc = false
                elif ch == "\\":
                    esc = true
                elif ch == Q():
                    in_str = false
            else:
                if ch == Q():
                    in_str = true
                elif ch == LB() or ch == "[":
                    depth = depth + 1
                elif ch == RB() or ch == "]":
                    depth = depth - 1
                    if depth == 0:
                        return json.substring(start, i3 + 1)
            i3 = i3 + 1
        return "null"
    var end = start
    while end < json.len():
        val ch = _char_at(json, end)
        if ch == "," or ch == RB() or ch == "]" or _is_ws(ch):
            break
        end = end + 1
    val raw = json.substring(start, end)
    if raw == "":
        return "null"
    return raw

fn extract_id(json: text) -> text:
    return extract_field_raw(json, "id")

fn unescape_json_string(s: text) -> text:
    var parts: [text] = []
    var i = 0
    while i < s.len():
        val ch = s.substring(i, i + 1)
        if ch != "\\":
            parts.push(ch)
            i = i + 1
            continue
        if i + 1 >= s.len():
            parts.push(ch)
            i = i + 1
            continue
        val next = s.substring(i + 1, i + 2)
        if next == "n":
            parts.push("\n")
        elif next == "r":
            parts.push("\r")
        elif next == "t":
            parts.push("\t")
        elif next == "\"":
            parts.push("\"")
        elif next == "\\":
            parts.push("\\")
        else:
            parts.push(next)
        i = i + 2
    return parts.join("")

fn extract_nested(json: text, key: text) -> text:
    val params = extract_field_raw(json, "params")
    if params == "null":
        return ""
    return extract_field(params, key)

# --- JSON-RPC builders ---

fn jsonrpc_result(id: text, result: text) -> text:
    return jo3(jp("jsonrpc", js("2.0")), jp("id", id), jp("result", result))

fn jsonrpc_error(id: text, code: i64, message: text) -> text:
    val err = jo2(jp("code", code.to_string()), jp("message", js(escape_json(message))))
    return jo3(jp("jsonrpc", js("2.0")), jp("id", id), jp("error", err))

# --- Safe string helpers (local to t32_mcp) ---

fn t32_strip_last(s: text) -> text:
    if s.len() <= 1:
        return ""
    s.substring(0, s.len() - 1)

fn strip_last(s: text) -> text:
    t32_strip_last(s)

fn t32_strip_first_last(s: text) -> text:
    if s.len() <= 2:
        return ""
    s.substring(1, s.len() - 1)

fn strip_first_last(s: text) -> text:
    t32_strip_first_last(s)

# --- t32_-prefixed wrappers (delegating to canonical implementations) ---

fn t32_Q() -> text: Q()
fn t32_LB() -> text: LB()
fn t32_RB() -> text: RB()
fn t32_SB_L() -> text: SB_L()
fn t32_SB_R() -> text: SB_R()
fn t32_escape_json(s: text) -> text: escape_json(s)
fn t32_js(s: text) -> text: js(s)
fn t32_jp(key: text, value: text) -> text: jp(key, value)
fn t32_jo1(p1: text) -> text: jo1(p1)
fn t32_jo2(p1: text, p2: text) -> text: jo2(p1, p2)
fn t32_jo3(p1: text, p2: text, p3: text) -> text: jo3(p1, p2, p3)
fn t32_jo4(p1: text, p2: text, p3: text, p4: text) -> text: jo4(p1, p2, p3, p4)
fn t32_extract_field(json: text, key: text) -> text: extract_field(json, key)
fn t32_extract_field_raw(json: text, key: text) -> text: extract_field_raw(json, key)
fn t32_extract_id(json: text) -> text: extract_id(json)
fn t32_extract_nested(json: text, key: text) -> text: extract_nested(json, key)
