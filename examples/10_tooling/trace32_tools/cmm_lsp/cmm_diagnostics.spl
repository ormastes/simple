# CMM (PRACTICE Script) Diagnostics — Formatting and Collection
# Diagnostic utilities for the CMM Language Server.
#
# Provides:
#   - CmmDiagnostic / CmmDiagnosticKind — diagnostic value types
#   - DiagnosticCollector — mutable collector with convenience add_* methods
#   - format_diagnostic / severity_text — rendering helpers
#
# These types are shared by the analyzer (cmm_analyzer.spl) and the
# LSP diagnostic publisher (lsp_diagnostics.spl).

export CmmDiagnostic, CmmDiagnosticKind, DiagnosticCollector
export format_diagnostic, severity_text, make_diagnostic

# ---------------------------------------------------------------------------
# Diagnostic severity
# ---------------------------------------------------------------------------

enum CmmDiagnosticKind:
    Error
    Warning
    Info
    Hint

# ---------------------------------------------------------------------------
# Diagnostic value
# ---------------------------------------------------------------------------

struct CmmDiagnostic:
    kind: CmmDiagnosticKind
    message: text
    line: i64
    column: i64
    end_line: i64
    end_column: i64

# ---------------------------------------------------------------------------
# Formatting helpers
# ---------------------------------------------------------------------------

# Format a diagnostic as a human-readable single-line string.
#
# Example output:  12:4: error: Undefined label 'cleanup'
fn format_diagnostic(d: CmmDiagnostic) -> text:
    val sev = severity_text(d.kind)
    "{d.line}:{d.column}: {sev}: {d.message}"

# Convert a severity kind to its lowercase name.
fn severity_text(kind: CmmDiagnosticKind) -> text:
    match kind:
        case CmmDiagnosticKind.Error: "error"
        case CmmDiagnosticKind.Warning: "warning"
        case CmmDiagnosticKind.Info: "info"
        case CmmDiagnosticKind.Hint: "hint"

# Shorthand constructor for a single-position diagnostic.
fn make_diagnostic(kind: CmmDiagnosticKind, msg: text, line: i64, col: i64) -> CmmDiagnostic:
    CmmDiagnostic(
        kind: kind,
        message: msg,
        line: line,
        column: col,
        end_line: line,
        end_column: col
    )

# ---------------------------------------------------------------------------
# DiagnosticCollector — mutable accumulator
# ---------------------------------------------------------------------------

class DiagnosticCollector:
    diagnostics: [CmmDiagnostic]

    # Add an error diagnostic at a single position.
    me add_error(msg: text, line: i64, col: i64):
        self.diagnostics.push(CmmDiagnostic(
            kind: CmmDiagnosticKind.Error,
            message: msg,
            line: line,
            column: col,
            end_line: line,
            end_column: col
        ))

    # Add an error diagnostic spanning a range of positions.
    me add_error_range(msg: text, line: i64, col: i64, end_line: i64, end_col: i64):
        self.diagnostics.push(CmmDiagnostic(
            kind: CmmDiagnosticKind.Error,
            message: msg,
            line: line,
            column: col,
            end_line: end_line,
            end_column: end_col
        ))

    # Add a warning diagnostic at a single position.
    me add_warning(msg: text, line: i64, col: i64):
        self.diagnostics.push(CmmDiagnostic(
            kind: CmmDiagnosticKind.Warning,
            message: msg,
            line: line,
            column: col,
            end_line: line,
            end_column: col
        ))

    # Add a warning diagnostic spanning a range of positions.
    me add_warning_range(msg: text, line: i64, col: i64, end_line: i64, end_col: i64):
        self.diagnostics.push(CmmDiagnostic(
            kind: CmmDiagnosticKind.Warning,
            message: msg,
            line: line,
            column: col,
            end_line: end_line,
            end_column: end_col
        ))

    # Add an info diagnostic at a single position.
    me add_info(msg: text, line: i64, col: i64):
        self.diagnostics.push(CmmDiagnostic(
            kind: CmmDiagnosticKind.Info,
            message: msg,
            line: line,
            column: col,
            end_line: line,
            end_column: col
        ))

    # Add a hint diagnostic at a single position.
    me add_hint(msg: text, line: i64, col: i64):
        self.diagnostics.push(CmmDiagnostic(
            kind: CmmDiagnosticKind.Hint,
            message: msg,
            line: line,
            column: col,
            end_line: line,
            end_column: col
        ))

    # Return the total number of diagnostics collected.
    fn count() -> i64:
        self.diagnostics.len()

    # Return only error-level diagnostics.
    fn errors() -> [CmmDiagnostic]:
        var result: [CmmDiagnostic] = []
        var i = 0
        while i < self.diagnostics.len():
            val d = self.diagnostics[i]
            match d.kind:
                case CmmDiagnosticKind.Error:
                    result.push(d)
                case _: ()
            i = i + 1
        result

    # Return only warning-level diagnostics.
    fn warnings() -> [CmmDiagnostic]:
        var result: [CmmDiagnostic] = []
        var i = 0
        while i < self.diagnostics.len():
            val d = self.diagnostics[i]
            match d.kind:
                case CmmDiagnosticKind.Warning:
                    result.push(d)
                case _: ()
            i = i + 1
        result

    # Return true if any error-level diagnostic has been collected.
    fn has_errors() -> bool:
        var i = 0
        while i < self.diagnostics.len():
            match self.diagnostics[i].kind:
                case CmmDiagnosticKind.Error: return true
                case _: ()
            i = i + 1
        false

    # Format all diagnostics as newline-separated text.
    # Uses array collection to avoid O(n²) concatenation.
    fn format_all() -> text:
        val n = self.diagnostics.len()
        if n == 0: return ""
        if n == 1: return format_diagnostic(self.diagnostics[0])
        var parts: [text] = []
        var i = 0
        while i < n:
            if i > 0:
                parts.push("\n")
            parts.push(format_diagnostic(self.diagnostics[i]))
            i = i + 1
        diag_join_parts(parts)

# Join text parts efficiently using batch concatenation.
fn diag_join_parts(parts: [text]) -> text:
    val n = parts.len()
    if n == 0: return ""
    if n == 1: return parts[0]
    if n == 2: return parts[0] + parts[1]
    if n == 3: return parts[0] + parts[1] + parts[2]
    if n == 4: return parts[0] + parts[1] + parts[2] + parts[3]
    var merged: [text] = []
    var i = 0
    while i + 7 < n:
        merged.push(parts[i] + parts[i+1] + parts[i+2] + parts[i+3] + parts[i+4] + parts[i+5] + parts[i+6] + parts[i+7])
        i = i + 8
    var tail = ""
    while i < n:
        tail = tail + parts[i]
        i = i + 1
    if tail.len() > 0:
        merged.push(tail)
    diag_join_parts(merged)
