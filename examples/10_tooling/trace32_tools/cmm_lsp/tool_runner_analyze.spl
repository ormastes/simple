@allow(unnamed_duplicate_typed_args)
# CMM direct runner - analyzer-backed tools

use t32_lsp_mcp.json_helpers
use t32_lsp_mcp.tool_runner_common.{runner_arg0_is_executable_path, debug_args, is_ident_char, line_text_for_position, extract_word_from_lines, parse_i64}
use cmm_parser_runtime.{parse_cmm_source}
use cmm_analyzer.{analyze_program, CmmSymbol, CmmSymbolKind}
use cmm_diagnostics.{severity_text}

extern fn sys_get_args() -> [text]
extern fn sys_exit(code: i64)
extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_exists(path: text) -> bool

fn analyze_json_is_ws(ch: text) -> bool:
    ch == " " or ch == "\n" or ch == "\r" or ch == "\t"

fn analyze_find_key_start(args: text, key: text) -> i64:
    val needle = "\"" + key + "\""
    var i = 0
    while i + needle.len() <= args.len():
        var matches = true
        var j = 0
        while j < needle.len():
            if args.substring(i + j, i + j + 1) != needle.substring(j, j + 1):
                matches = false
                break
            j = j + 1
        if matches:
            return i
        i = i + 1
    -1

fn analyze_source_arg(args: text) -> text:
    val key_start = analyze_find_key_start(args, "source")
    if key_start < 0:
        return ""
    var start = key_start + 8
    while start < args.len() and analyze_json_is_ws(args.substring(start, start + 1)):
        start = start + 1
    if start >= args.len() or args.substring(start, start + 1) != ":":
        return ""
    start = start + 1
    while start < args.len() and analyze_json_is_ws(args.substring(start, start + 1)):
        start = start + 1
    if start >= args.len() or args.substring(start, start + 1) != "\"":
        return ""
    var i = start + 1
    var escaped = false
    while i < args.len():
        val ch = args.substring(i, i + 1)
        if escaped:
            escaped = false
        elif ch == "\\":
            escaped = true
        elif ch == "\"":
            return lsp_unescape_json_string(args.substring(start + 1, i))
        i = i + 1
    ""

fn analyze_number_arg(args: text, key: text) -> i64:
    val key_start = analyze_find_key_start(args, key)
    if key_start < 0:
        return 0
    var start = key_start + key.len() + 2
    while start < args.len() and analyze_json_is_ws(args.substring(start, start + 1)):
        start = start + 1
    if start >= args.len() or args.substring(start, start + 1) != ":":
        return 0
    start = start + 1
    while start < args.len() and analyze_json_is_ws(args.substring(start, start + 1)):
        start = start + 1
    var end = start
    while end < args.len():
        val ch = args.substring(end, end + 1)
        if (ch < "0" or ch > "9") and not (end == start and ch == "-"):
            break
        end = end + 1
    if end <= start:
        return 0
    parse_i64(args.substring(start, end))

fn symbol_kind_str(kind: CmmSymbolKind) -> text:
    match kind:
        case CmmSymbolKind.LabelSym: "label"
        case CmmSymbolKind.MacroSym: "macro"
        case CmmSymbolKind.SubroutineSym: "subroutine"
        case CmmSymbolKind.FileRefSym: "file"
        case _: "symbol"

fn handle_cmm_diagnostics(id: text, args: text) -> text:
    val source = analyze_source_arg(args)
    if source == "":
        return lsp_make_tool_error(id, -32602, "Missing required parameter: source")
    val analysis = analyze_program(parse_cmm_source(source))
    var arr = lsp_SB_L()
    var di = 0
    while di < analysis.diagnostics.len():
        if di > 0:
            arr = arr + ","
        val d = analysis.diagnostics[di]
        arr = arr + lsp_jo4(
            lsp_jp("severity", lsp_js(severity_text(d.kind))),
            lsp_jp("message", lsp_js(d.message)),
            lsp_jp("line", str(d.line)),
            lsp_jp("column", str(d.column))
        )
        di = di + 1
    arr = arr + lsp_SB_R()
    lsp_make_tool_result(id, lsp_jo2(lsp_jp("count", str(analysis.diagnostics.len())), lsp_jp("diagnostics", arr)))

fn handle_cmm_symbols(id: text, args: text) -> text:
    val source = analyze_source_arg(args)
    if source == "":
        return lsp_make_tool_error(id, -32602, "Missing required parameter: source")
    val analysis = analyze_program(parse_cmm_source(source))
    val labels = analysis.symbols.labels()
    val macros = analysis.symbols.macros()
    var syms: [CmmSymbol] = []
    var i = 0
    while i < labels.len():
        syms.push(labels[i])
        i = i + 1
    i = 0
    while i < macros.len():
        syms.push(macros[i])
        i = i + 1
    var arr = lsp_SB_L()
    i = 0
    while i < syms.len():
        if i > 0:
            arr = arr + ","
        val sym = syms[i]
        arr = arr + lsp_jo4(
            lsp_jp("name", lsp_js(sym.name)),
            lsp_jp("kind", lsp_js(symbol_kind_str(sym.kind))),
            lsp_jp("scope", lsp_js(sym.scope)),
            lsp_jp("line", str(sym.def_line))
        )
        i = i + 1
    arr = arr + lsp_SB_R()
    lsp_make_tool_result(id, lsp_jo2(lsp_jp("count", str(syms.len())), lsp_jp("symbols", arr)))

fn handle_cmm_definition(id: text, args: text) -> text:
    val source = analyze_source_arg(args)
    if source == "":
        return lsp_make_tool_error(id, -32602, "Missing required parameter: source")
    val target_line = analyze_number_arg(args, "line")
    val target_char = analyze_number_arg(args, "character")
    val program = parse_cmm_source(source)
    val analysis = analyze_program(program)
    val word = extract_word_from_lines(source.split("\n"), target_line, target_char)
    if word == "":
        return lsp_make_tool_result(id, lsp_jo1(lsp_jp("found", "false")))
    var lookup_name = word
    if word.starts_with("&"):
        lookup_name = word.substring(1)
    val all_labels = analysis.symbols.labels()
    var li = 0
    while li < all_labels.len():
        if all_labels[li].name == lookup_name or all_labels[li].name == word:
            return lsp_make_tool_result(id, lsp_jo4(
                lsp_jp("found", "true"),
                lsp_jp("symbol", lsp_js(all_labels[li].name)),
                lsp_jp("line", str(all_labels[li].def_line)),
                lsp_jp("column", str(all_labels[li].def_column))
            ))
        li = li + 1
    val all_macros = analysis.symbols.macros()
    var mi = 0
    while mi < all_macros.len():
        if all_macros[mi].name == lookup_name:
            return lsp_make_tool_result(id, lsp_jo4(
                lsp_jp("found", "true"),
                lsp_jp("symbol", lsp_js(all_macros[mi].name)),
                lsp_jp("line", str(all_macros[mi].def_line)),
                lsp_jp("column", str(all_macros[mi].def_column))
            ))
        mi = mi + 1
    lsp_make_tool_result(id, lsp_jo1(lsp_jp("found", "false")))

fn dispatch_tool(id: text, tool_name: text, args: text) -> text:
    if tool_name == "cmm_diagnostics":
        return handle_cmm_diagnostics(id, args)
    if tool_name == "cmm_symbols":
        return handle_cmm_symbols(id, args)
    if tool_name == "cmm_definition":
        return handle_cmm_definition(id, args)
    lsp_make_tool_error(id, -32601, "Unknown tool: " + tool_name)

fn main():
    val raw_args = sys_get_args()
    var args = raw_args
    if args.len() >= 2 and not args[0].ends_with(".spl") and args[1].ends_with(".spl"):
        args = args[2:args.len()]
    elif args.len() >= 1 and args[0].ends_with(".spl"):
        args = args[1:args.len()]
    elif args.len() >= 4 and runner_arg0_is_executable_path(args[0]):
        args = args[1:args.len()]
    if args.len() < 3:
        print "tool_runner_analyze argument error: " + debug_args(args)
        sys_exit(2)
    val id = args[0]
    val tool_name = args[1]
    val args_path = args[2]
    val args_raw = rt_file_read_text(args_path) ?? "null"
    print_raw(dispatch_tool(id, tool_name, args_raw))
