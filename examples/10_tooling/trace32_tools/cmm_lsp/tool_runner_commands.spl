@allow(unnamed_duplicate_typed_args)
# CMM direct runner - command database tools

use t32_lsp_mcp.json_helpers
use cmm_commands.{build_command_db, get_completions}

extern fn sys_get_args() -> [text]
extern fn sys_exit(code: i64)
extern fn rt_file_read_text(path: text) -> text

fn runner_arg0_is_executable_path(arg0: text) -> bool:
    arg0.contains("/") or arg0.contains("\\") or arg0.ends_with(".exe") or arg0.ends_with("t32_lsp_mcp_tool_runner")

fn debug_args(args: [text]) -> text:
    var out = "argc=" + str(args.len())
    var i = 0
    while i < args.len():
        out = out + " argv[" + str(i) + "]=" + args[i]
        i = i + 1
    out

fn line_text_for_position(lines: [text], target_line: i64) -> text:
    if target_line >= 0 and target_line < lines.len():
        return lines[target_line]
    if target_line >= 1 and target_line <= lines.len():
        return lines[target_line - 1]
    ""

fn extract_word_from_lines(lines: [text], target_line: i64, target_char: i64) -> text:
    val line = line_text_for_position(lines, target_line)
    if line == "":
        return ""
    var idx = target_char
    if idx < 0:
        idx = 0
    if idx > line.len():
        idx = line.len()
    var start = idx
    while start > 0 and is_ident_char(line.substring(start - 1, start)):
        start = start - 1
    var end = idx
    while end < line.len() and is_ident_char(line.substring(end, end + 1)):
        end = end + 1
    if end <= start:
        return ""
    line.substring(start, end)

fn is_ident_char(ch: text) -> bool:
    if ch == "_":
        return true
    val upper = ch.to_upper()
    val lower = ch.to_lower()
    if upper != lower:
        return true
    ch >= "0" and ch <= "9"

fn parse_i64(s: text) -> i64:
    if s == "":
        return 0
    var i = 0
    var sign = 1
    if s.starts_with("-"):
        sign = -1
        i = 1
    var value = 0
    while i < s.len():
        val ch = s.substring(i, i + 1)
        if ch < "0" or ch > "9":
            break
        value = value * 10 + int(ch)
        i = i + 1
    value * sign

fn lookup_hover_text(db, word: text) -> text:
    val matches = get_completions(db, word)
    var i = 0
    while i < matches.len():
        val cmd = matches[i]
        if cmd.full_name.to_lower() == word.to_lower():
            return cmd.description
        i = i + 1
    ""

fn handle_cmm_complete(id: text, args: text) -> text:
    val source = lsp_extract_field(args, "source")
    if source == "":
        return lsp_make_tool_error(id, -32602, "Missing required parameter: source")
    val target_line = parse_i64(lsp_extract_field(args, "line"))
    val target_char = parse_i64(lsp_extract_field(args, "character"))
    val prefix = extract_word_from_lines(source.split("\n"), target_line, target_char)
    val matches = get_completions(build_command_db(), prefix)
    var arr = lsp_SB_L()
    var ci = 0
    while ci < matches.len():
        if ci > 0:
            arr = arr + ","
        val cmd = matches[ci]
        arr = arr + lsp_jo3(
            lsp_jp("label", lsp_js(cmd.full_name)),
            lsp_jp("kind", lsp_js("command")),
            lsp_jp("description", lsp_js(cmd.description))
        )
        ci = ci + 1
    arr = arr + lsp_SB_R()
    lsp_make_tool_result(id, lsp_jo2(lsp_jp("count", str(matches.len())), lsp_jp("completions", arr)))

fn handle_cmm_hover(id: text, args: text) -> text:
    val source = lsp_extract_field(args, "source")
    if source == "":
        return lsp_make_tool_error(id, -32602, "Missing required parameter: source")
    val target_line = parse_i64(lsp_extract_field(args, "line"))
    val target_char = parse_i64(lsp_extract_field(args, "character"))
    val word = extract_word_from_lines(source.split("\n"), target_line, target_char)
    if word == "":
        return lsp_make_tool_result(id, lsp_jo1(lsp_jp("hover", lsp_js(""))))
    val hover_text = lookup_hover_text(build_command_db(), word)
    lsp_make_tool_result(id, lsp_jo2(lsp_jp("word", lsp_js(word)), lsp_jp("hover", lsp_js(hover_text))))

fn dispatch_tool(id: text, tool_name: text, args: text) -> text:
    if tool_name == "cmm_complete":
        return handle_cmm_complete(id, args)
    if tool_name == "cmm_hover":
        return handle_cmm_hover(id, args)
    lsp_make_tool_error(id, -32601, "Unknown tool: " + tool_name)

fn main():
    val raw_args = sys_get_args()
    var args = raw_args
    if args.len() >= 2 and not args[0].ends_with(".spl") and args[1].ends_with(".spl"):
        args = args[2:args.len()]
    elif args.len() >= 1 and args[0].ends_with(".spl"):
        args = args[1:args.len()]
    elif args.len() >= 4 and runner_arg0_is_executable_path(args[0]):
        args = args[1:args.len()]
    if args.len() < 3:
        print "tool_runner_commands argument error: " + debug_args(args)
        sys_exit(2)
    val id = args[0]
    val tool_name = args[1]
    val args_path = args[2]
    val args_raw = rt_file_read_text(args_path) ?? "null"
    print_raw(dispatch_tool(id, tool_name, args_raw))
