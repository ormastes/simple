# Tests for dialog label collection and completion integration.

use cmm_analyzer.{analyze_program}
use cmm_parser_runtime.{parse_cmm_source}

use std.spec.{describe, it, expect}

# ---------------------------------------------------------------------------
# Dialog label collection tests
# ---------------------------------------------------------------------------

describe "Dialog label collection":
    it "collects labels from DIALOG block":
        val source = """
DIALOG.Create "Test Dialog"
(
  myEdit: EDIT "" ""
  myCheck: CHECKBOX "Enable" ""
  myBtn: DEFBUTTON "OK" "GOSUB handle_ok"
)
DIALOG.Open
STOP
DIALOG.Close
ENDDO
handle_ok:
  ENDDO
"""
        val program = parse_cmm_source(source, "<test>")
        val analysis = analyze_program(program)
        expect(analysis.dialog_labels.len() > 0).to_equal(true)

    it "returns empty dialog_labels when no DIALOG block":
        val source = "PRINT \"hello\"\nENDDO"
        val program = parse_cmm_source(source, "<test>")
        val analysis = analyze_program(program)
        expect(analysis.dialog_labels.len()).to_equal(0)

    it "collects multiple dialog labels":
        val source = """
DIALOG.Create "Multi"
(
  nameField: EDIT "" ""
  ageField: EDIT "" ""
  okBtn: DEFBUTTON "OK" ""
  cancelBtn: DEFBUTTON "Cancel" ""
)
DIALOG.Open
STOP
DIALOG.Close
ENDDO
"""
        val program = parse_cmm_source(source, "<test>")
        val analysis = analyze_program(program)
        # Should have at least 4 labels
        expect(analysis.dialog_labels.len() >= 4).to_equal(true)
