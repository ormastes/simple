# CMM (PRACTICE Script) Parser — Shared Core
#
# Shared parser state and ASCII case-folding helpers extracted to break the
# import cycle between `cmm_parser.spl`, `cmm_parser_expr.spl`, and
# `cmm_parser_stmts.spl`.

use cmm_tokens.{CmmTokenKind, CmmToken}

export CmmParser, CmmParseError, to_upper_cmm

# Parse error with source location
struct CmmParseError:
    message: text
    line: i64
    column: i64

# Main parser state. Methods are distributed across multiple files via impl
# blocks that all import this shared core.
class CmmParser:
    tokens: [CmmToken]
    current: i64
    errors: [text]

# --- Case-insensitive helpers ---

fn to_upper_cmm(s: text) -> text:
    var needs_conversion = false
    var i = 0
    while i < s.len():
        val ch = s[i:i + 1]
        if ch >= "a" and ch <= "z":
            needs_conversion = true
            break
        i = i + 1
    if not needs_conversion:
        return s
    var parts: [text] = []
    i = 0
    while i < s.len():
        val ch = s[i:i + 1]
        parts.push(char_to_upper(ch))
        i = i + 1
    parts.join("")

fn char_to_upper(ch: text) -> text:
    if ch == "a": return "A"
    if ch == "b": return "B"
    if ch == "c": return "C"
    if ch == "d": return "D"
    if ch == "e": return "E"
    if ch == "f": return "F"
    if ch == "g": return "G"
    if ch == "h": return "H"
    if ch == "i": return "I"
    if ch == "j": return "J"
    if ch == "k": return "K"
    if ch == "l": return "L"
    if ch == "m": return "M"
    if ch == "n": return "N"
    if ch == "o": return "O"
    if ch == "p": return "P"
    if ch == "q": return "Q"
    if ch == "r": return "R"
    if ch == "s": return "S"
    if ch == "t": return "T"
    if ch == "u": return "U"
    if ch == "v": return "V"
    if ch == "w": return "W"
    if ch == "x": return "X"
    if ch == "y": return "Y"
    if ch == "z": return "Z"
    ch
