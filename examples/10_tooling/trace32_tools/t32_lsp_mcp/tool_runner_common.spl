@allow(unnamed_duplicate_typed_args)
# T32 LSP MCP - Shared tool runner helpers
#
# Common utility functions used by tool_runner, tool_runner_parse,
# tool_runner_validate, and cmm_lsp/tool_runner_analyze and tool_runner_commands.

use t32_lsp_mcp.json_helpers

fn arg_char_at(s: text, i: i64) -> text:
    return s.substring(i, i + 1)

fn arg_is_ws(ch: text) -> bool:
    return ch == " " or ch == "\n" or ch == "\r" or ch == "\t"

fn arg_find_json_value_start(json: text, key: text) -> i64:
    val search = "\"" + key + "\""
    var i = 0
    while i + search.len() <= json.len():
        if json.substring(i).starts_with(search):
            var j = i + search.len()
            while j < json.len() and arg_is_ws(arg_char_at(json, j)):
                j = j + 1
            if j < json.len() and arg_char_at(json, j) == ":":
                j = j + 1
                while j < json.len() and arg_is_ws(arg_char_at(json, j)):
                    j = j + 1
                return j
        i = i + 1
    return -1

fn arg_extract_string(json: text, key: text) -> text:
    val start = arg_find_json_value_start(json, key)
    if start < 0 or start >= json.len():
        return ""
    if arg_char_at(json, start) != "\"":
        return ""
    var i = start + 1
    var escaped = false
    while i < json.len():
        val ch = arg_char_at(json, i)
        if escaped:
            escaped = false
        elif ch == "\\":
            escaped = true
        elif ch == "\"":
            return lsp_unescape_json_string(json.substring(start + 1, i))
        i = i + 1
    return ""

fn arg_extract_object_raw(json: text, key: text) -> text:
    val start = arg_find_json_value_start(json, key)
    if start < 0 or start >= json.len():
        return ""
    val first = arg_char_at(json, start)
    if first != "{" and first != "[":
        return ""
    var depth = 0
    var i = start
    var in_str = false
    var escaped = false
    while i < json.len():
        val ch = arg_char_at(json, i)
        if in_str:
            if escaped:
                escaped = false
            elif ch == "\\":
                escaped = true
            elif ch == "\"":
                in_str = false
        else:
            if ch == "\"":
                in_str = true
            elif ch == "{" or ch == "[":
                depth = depth + 1
            elif ch == "}" or ch == "]":
                depth = depth - 1
                if depth == 0:
                    return json.substring(start, i + 1)
        i = i + 1
    return ""

fn arg_field(args: text, key: text) -> text:
    val marker1 = "\"" + key + "\":"
    val marker2 = "\"" + key + "\": "
    var marker = ""
    if args.contains(marker1):
        marker = marker1
    elif args.contains(marker2):
        marker = marker2
    else:
        return ""
    val parts = args.split(marker)
    if parts.len() < 2:
        return ""
    var rest = parts[1].trim()
    if rest == "":
        return ""
    if rest.starts_with("\""):
        var i = 1
        var escaped = false
        while i < rest.len():
            val ch = rest.substring(i, i + 1)
            if escaped:
                escaped = false
            elif ch == "\\":
                escaped = true
            elif ch == "\"":
                return lsp_unescape_json_string(rest.substring(1, i))
            i = i + 1
        return ""
    var end = 0
    while end < rest.len():
        val ch = rest.substring(end, end + 1)
        if ch == "," or ch == "}" or ch == "]" or ch == " " or ch == "\n" or ch == "\r" or ch == "\t":
            break
        end = end + 1
    if end <= 0:
        return ""
    return rest.substring(0, end)

fn runner_arg0_is_executable_path(arg0: text) -> bool:
    arg0.contains("/") or arg0.contains("\\") or arg0.ends_with(".exe") or arg0.ends_with("t32_lsp_mcp_tool_runner")

fn debug_args(args: [text]) -> text:
    var out = "argc=" + str(args.len())
    var i = 0
    while i < args.len():
        out = out + " argv[" + str(i) + "]=" + args[i]
        i = i + 1
    out

fn is_ident_char(ch: text) -> bool:
    if ch == "_":
        return true
    val upper = ch.to_upper()
    val lower = ch.to_lower()
    if upper != lower:
        return true
    ch >= "0" and ch <= "9"

fn line_text_for_position(lines: [text], target_line: i64) -> text:
    if target_line >= 0 and target_line < lines.len():
        return lines[target_line]
    if target_line >= 1 and target_line <= lines.len():
        return lines[target_line - 1]
    ""

fn extract_word_from_lines(lines: [text], target_line: i64, target_char: i64) -> text:
    val line = line_text_for_position(lines, target_line)
    if line == "":
        return ""
    var idx = target_char
    if idx < 0:
        idx = 0
    if idx > line.len():
        idx = line.len()
    var start = idx
    while start > 0 and is_ident_char(line.substring(start - 1, start)):
        start = start - 1
    var end = idx
    while end < line.len() and is_ident_char(line.substring(end, end + 1)):
        end = end + 1
    if end <= start:
        return ""
    line.substring(start, end)

fn parse_i64(s: text) -> i64:
    if s == "":
        return 0
    var i = 0
    var sign = 1
    if s.starts_with("-"):
        sign = -1
        i = 1
    var value = 0
    while i < s.len():
        val ch = s.substring(i, i + 1)
        if ch < "0" or ch > "9":
            break
        value = value * 10 + int(ch)
        i = i + 1
    value * sign

fn check_gui_keywords(source: text) -> [text]:
    val lower = source.to_lower()
    val keywords = ["dialog.", "menu.", "screen.wait", "inkey", "enter "]
    var found: [text] = []
    var i = 0
    while i < keywords.len():
        if lower.contains(keywords[i]):
            found.push(keywords[i])
        i = i + 1
    found

fn check_has_command(source: text, cmd: text) -> bool:
    val lower_source = source.to_lower()
    val lower_cmd = cmd.to_lower()
    lower_source.contains(lower_cmd)
