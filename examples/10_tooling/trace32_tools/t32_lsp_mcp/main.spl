@allow(unnamed_duplicate_typed_args)
# T32 LSP MCP Server — CMM language intelligence via MCP protocol
#
# Tools: 9 tools for parsing, AST inspection, dialog extraction, diagnostics, completions, hover, symbols, definition, CLI validation
# Protocol: MCP 2025-06-18 (Content-Length framing + JSON-Lines auto-detect)
#
# Architecture: Uses shared mcp_sdk for transport, JSON, and JSON-RPC.
#               Domain logic in cmm_lsp module.
#
# Files:
#   - protocol.spl     — Protocol I/O, initialize, tools list, schemas
#   - tools.spl        — Tool handler implementations

use t32_lsp_mcp.debug_log.{lsp_debug_append, lsp_debug_enabled, lsp_debug_root, lsp_debug_bootstrap}
use t32_lsp_mcp.json_helpers.{read_stdin_message, write_stdout_message, LB, RB, Q, SB_L, SB_R, jp, js, jo1, jo2, jo3, extract_field, extract_field_raw, extract_nested, extract_nested_raw, escape_json, jsonrpc_result, jsonrpc_error, has_method}
use t32_lsp_mcp.protocol

extern fn stderr_write(data: text) -> i64
extern fn stderr_flush() -> i64
extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_dir_list(path: text) -> [text]
extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_append_text(path: text, content: text) -> bool
extern fn rt_file_delete(path: text) -> bool
extern fn rt_file_exists(path: text) -> bool
extern fn rt_time_now_unix_micros() -> i64
extern fn rt_env_get(name: text) -> text
extern fn rt_env_cwd() -> text

val LSP_SERVER_NAME = "simple-mcp-t32-lsp"
val LSP_SERVER_VERSION = "0.1.2"
val LSP_NL = "\n"

# Protocol auto-detection
var LSP_USE_JSON_LINES = false

# Caches
var LSP_TOOLS_CACHE = ""
var LSP_INIT_CACHE = ""
var LSP_TOOL_DAEMON_DIR = ""
var LSP_TOOL_DAEMON_PID = -1
var LSP_TOOL_DAEMON_SEQ = 0
var LSP_TOOL_DAEMON_ERROR = ""

# --- Entry point ---

fn main():
    lsp_start_server()

fn lsp_log_message(file: text, message: text):
    if lsp_debug_enabled():
        lsp_debug_append(file, message)

fn lsp_json_char_at(s: text, i: i64) -> text:
    s.substring(i, i + 1)

fn lsp_json_is_ws(ch: text) -> bool:
    ch == " " or ch == "\n" or ch == "\r" or ch == "\t"

fn lsp_json_find_value_start(json: text, key: text) -> i64:
    val search = "\"" + key + "\""
    var offset = 0
    while offset + search.len() <= json.len():
        if json.substring(offset, offset + search.len()) != search:
            offset = offset + 1
            continue
        var j = offset + search.len()
        while j < json.len() and lsp_json_is_ws(lsp_json_char_at(json, j)):
            j = j + 1
        if j < json.len() and lsp_json_char_at(json, j) == ":":
            j = j + 1
            while j < json.len() and lsp_json_is_ws(lsp_json_char_at(json, j)):
                j = j + 1
            return j
        offset = offset + search.len()
    return -1

fn lsp_request_json_raw_field(json: text, key: text) -> text:
    val start = lsp_json_find_value_start(json, key)
    if start < 0 or start >= json.len():
        return "null"
    val first = lsp_json_char_at(json, start)
    if first == "\"":
        var i = start + 1
        var escaped = false
        while i < json.len():
            val ch = lsp_json_char_at(json, i)
            if escaped:
                escaped = false
            elif ch == "\\":
                escaped = true
            elif ch == "\"":
                return json.substring(start, i + 1)
            i = i + 1
        return "null"
    if first == "{" or first == "[":
        var depth = 0
        var i2 = start
        var in_str = false
        var esc = false
        while i2 < json.len():
            val ch = lsp_json_char_at(json, i2)
            if in_str:
                if esc:
                    esc = false
                elif ch == "\\":
                    esc = true
                elif ch == "\"":
                    in_str = false
            else:
                if ch == "\"":
                    in_str = true
                elif ch == "{" or ch == "[":
                    depth = depth + 1
                elif ch == "}" or ch == "]":
                    depth = depth - 1
                    if depth == 0:
                        return json.substring(start, i2 + 1)
            i2 = i2 + 1
        return "null"
    var end = start
    while end < json.len():
        val ch = lsp_json_char_at(json, end)
        if ch == "," or ch == "}" or ch == "]" or lsp_json_is_ws(ch):
            break
        end = end + 1
    val raw = json.substring(start, end)
    if raw == "":
        return "null"
    raw

fn lsp_request_json_text_field(json: text, key: text) -> text:
    val raw = lsp_request_json_raw_field(json, key)
    if raw == "null":
        return ""
    if raw.starts_with("\"") and raw.ends_with("\"") and raw.len() >= 2:
        return raw.substring(1, raw.len() - 1)
    raw

fn lsp_request_arguments_json(body: text) -> text:
    val args = extract_nested_raw(body, "arguments")
    if args == "null" or args == "":
        return body
    args

fn lsp_request_id_text(body: text) -> text:
    val candidates = [
        "\"id\": ",
        "\"id\":",
        "\\\"id\\\": ",
        "\\\"id\\\":"
    ]
    var ci = 0
    while ci < candidates.len():
        val marker = candidates[ci]
        var idx = body.index_of(marker).unwrap_or(-1)
        if idx >= 0:
            var start = idx + marker.len()
            while start < body.len() and lsp_json_is_ws(lsp_json_char_at(body, start)):
                start = start + 1
            if start >= body.len():
                return "null"
            val first = lsp_json_char_at(body, start)
            if first == "\"":
                var end = start + 1
                var escaped = false
                while end < body.len():
                    val ch = lsp_json_char_at(body, end)
                    if escaped:
                        escaped = false
                    elif ch == "\\":
                        escaped = true
                    elif ch == "\"":
                        return body.substring(start, end + 1)
                    end = end + 1
                return "null"
            var end2 = start
            while end2 < body.len():
                val ch = lsp_json_char_at(body, end2)
                if ch == "," or ch == "}" or ch == "]" or lsp_json_is_ws(ch):
                    break
                end2 = end2 + 1
            if end2 <= start:
                return "null"
            return body.substring(start, end2)
        ci = ci + 1
    "null"

fn lsp_start_server():
    lsp_debug_bootstrap()
    lsp_log_message("wrapper.log", "startup root=" + lsp_debug_root())
    lsp_log_message("frontend.log", "frontend start")
    while true:
        var msg = read_stdin_message()
        if msg == "":
            lsp_log_message("errors.log", "stdin closed before request")
            return
        else:
            var method = lsp_detect_method(msg)
            var id = lsp_request_id_text(msg)
            var response = ""
            lsp_log_message("requests.log", "method=" + method + " id=" + id)
            lsp_log_message("frontend.log", "recv method=" + method + " id=" + id + " bytes=" + str(msg.len()))
            if method == "initialize":
                response = lsp_make_init_response(id)
            elif method == "initialized" or method == "notifications/initialized":
                response = ""
            elif method == "shutdown":
                response = jsonrpc_result(id, "null")
            elif method == "tools/list":
                response = lsp_make_tools_list(id)
            elif method == "tools/call":
                response = lsp_dispatch_tool(id, msg)
            elif method == "resources/list":
                response = lsp_make_resources_list(id)
            elif method == "resources/templates/list":
                response = lsp_make_resource_templates_list(id)
            elif method == "prompts/list":
                response = lsp_make_prompts_list(id)
            elif method == "roots/list":
                response = lsp_make_roots_list(id)
            elif method == "logging/setLevel" or method == "logging/setlevel":
                response = jsonrpc_result(id, "null")
            elif method == "ping":
                response = jsonrpc_result(id, LB() + RB())
            elif method == "notifications/cancelled" or method == "notifications/roots/list_changed":
                response = ""
            else:
                if id != "" and id != "null":
                    response = jsonrpc_error(id, -32601, "Method not found: " + method)
            if response != "":
                lsp_log_message("frontend.log", "send method=" + method + " id=" + id + " bytes=" + str(response.len()))
                write_stdout_message(response)

# --- Tool dispatcher ---

fn lsp_dispatch_tool(id: text, body: text) -> text:
    val tool_name = lsp_detect_tool_name(body)
    if tool_name == "":
        return jsonrpc_error(id, -32602, "Missing tool name in tools/call request")
    val args_raw = lsp_request_arguments_json(body)
    if tool_name == "cmm_parse" or tool_name == "cmm_ast" or tool_name == "cmm_dialog_ast":
        return lsp_run_tool_direct_with_path(id, tool_name, args_raw, lsp_tool_runner_path_for_tool(tool_name))
    return lsp_run_tool_direct(id, tool_name, args_raw)

fn lsp_run_tool_direct(id: text, tool_name: text, args_raw: text) -> text:
    lsp_run_tool_direct_with_path(id, tool_name, args_raw, lsp_tool_runner_path_for_tool(tool_name))

fn lsp_run_tool_direct_with_path(id: text, tool_name: text, args_raw: text, runner: text) -> text:
    val args_path = lsp_tool_daemon_dir() + "/" + lsp_next_tool_request_key(id) + ".args.json"
    if not rt_file_write_text(args_path, args_raw):
        lsp_log_message("errors.log", "failed write args tool=" + tool_name + " id=" + id)
        return jsonrpc_error(id, -32002, "Failed to write tool arguments")
    val runner_bin = lsp_tool_runner_bin_path()
    val timeout_bin = lsp_timeout_bin_path()
    val (stdout, stderr, code) =
        if runner_bin != "":
            if timeout_bin != "":
                rt_process_run(timeout_bin, [lsp_tool_timeout_secs(), runner_bin, id, tool_name, args_path])
            else:
                rt_process_run(runner_bin, [id, tool_name, args_path])
        else:
            val runtime = lsp_tool_runtime_path()
            if timeout_bin != "":
                rt_process_run(timeout_bin, [lsp_tool_timeout_secs(), runtime, runner, id, tool_name, args_path])
            else:
                rt_process_run(runtime, [runner, id, tool_name, args_path])
    rt_file_delete(args_path)
    if code == 124:
        return jsonrpc_error(id, -32002, "Tool backend timed out" + lsp_tool_daemon_log_hint())
    if code != 0:
        val err_text = lsp_trim_error_text(stderr, stdout)
        return jsonrpc_error(id, -32002, "Tool backend failed: " + err_text)
    val response = stdout.trim()
    if response == "":
        return jsonrpc_error(id, -32002, "Tool backend returned no response")
    response

fn lsp_dispatch_tool_via_daemon(id: text, tool_name: text, body: text) -> text:
    if not lsp_start_tool_daemon():
        return ""
    val ready_path = lsp_tool_daemon_dir() + "/ready"
    if not rt_file_exists(ready_path):
        return ""
    val args_raw = lsp_request_arguments_json(body)
    val base = lsp_tool_daemon_dir() + "/" + lsp_next_tool_request_key(id)
    val args_path = base + ".args.json"
    val req_path = base + ".req"
    val response_path = base + ".response.json"
    if not rt_file_write_text(args_path, args_raw):
        lsp_log_message("errors.log", "failed write daemon args tool=" + tool_name + " id=" + id)
        return jsonrpc_error(id, -32002, "Failed to write tool arguments")
    val request_body = id + LSP_NL + tool_name + LSP_NL + args_path + LSP_NL + response_path + LSP_NL
    if not rt_file_write_text(req_path, request_body):
        rt_file_delete(args_path)
        return jsonrpc_error(id, -32002, "Failed to enqueue tool request")
    val response = lsp_wait_for_tool_response(response_path, 60000)
    rt_file_delete(req_path)
    rt_file_delete(args_path)
    rt_file_delete(response_path)
    if response == "":
        LSP_TOOL_DAEMON_PID = -1
        lsp_log_message("errors.log", "daemon timeout tool=" + tool_name + " id=" + id)
        return ""
    response


fn lsp_start_tool_daemon() -> bool:
    val daemon_dir = lsp_tool_daemon_dir()
    LSP_TOOL_DAEMON_ERROR = ""
    lsp_log_message("wrapper.log", "ensure daemon dir=" + daemon_dir)
    rt_process_run(lsp_shell_bin_path(), ["-c", "mkdir -p " + lsp_shell_quote(daemon_dir)])
    if lsp_tool_daemon_is_alive(daemon_dir):
        if lsp_wait_for_daemon_ready(daemon_dir, 1500):
            LSP_TOOL_DAEMON_PID = 1
            lsp_log_message("daemon.log", "reuse daemon dir=" + daemon_dir)
            return true
        LSP_TOOL_DAEMON_ERROR = "CMM tool daemon is running but never became ready" + lsp_tool_daemon_log_hint()
        lsp_log_message("errors.log", LSP_TOOL_DAEMON_ERROR)
        return false
    if rt_file_exists(daemon_dir + "/ready") or LSP_TOOL_DAEMON_PID > 0:
        lsp_reset_tool_daemon_state(daemon_dir)
    val runtime = lsp_tool_runtime_path()
    val daemon_entry = lsp_tool_daemon_path()
    val daemon_log = daemon_dir + "/daemon.log"
    val launch_cmd = "nohup " + lsp_shell_quote(runtime) + " " + lsp_shell_quote(daemon_entry) + " " + lsp_shell_quote(daemon_dir) + " >" + lsp_shell_quote(daemon_log) + " 2>&1 < /dev/null &"
    lsp_log_message("wrapper.log", "launch daemon runtime=" + runtime + " entry=" + daemon_entry + " dir=" + daemon_dir)
    val (stdout, stderr, code) = rt_process_run(lsp_shell_bin_path(), ["-c", launch_cmd])
    if code != 0:
        LSP_TOOL_DAEMON_ERROR = "Failed to launch CMM tool daemon: " + lsp_trim_error_text(stderr, stdout)
        lsp_log_message("errors.log", LSP_TOOL_DAEMON_ERROR)
        return false
    LSP_TOOL_DAEMON_PID = 1
    if lsp_wait_for_daemon_ready(daemon_dir, 3000):
        lsp_log_message("daemon.log", "daemon ready dir=" + daemon_dir)
        return true
    LSP_TOOL_DAEMON_ERROR = "CMM tool daemon failed to become ready" + lsp_tool_daemon_log_hint()
    lsp_log_message("errors.log", LSP_TOOL_DAEMON_ERROR)
    false

fn lsp_shell_quote(value: text) -> text:
    "'" + value.replace("'", "'\\''") + "'"

fn lsp_tool_daemon_is_alive(daemon_dir: text) -> bool:
    val match_text = lsp_tool_daemon_path() + " " + daemon_dir
    val cmd = "ps -ef | grep -F -- " + lsp_shell_quote(match_text) + " | grep -Fv grep >/dev/null 2>&1"
    val (_stdout, _stderr, code) = rt_process_run(lsp_shell_bin_path(), ["-c", cmd])
    code == 0

fn lsp_wait_for_daemon_ready(daemon_dir: text, timeout_ms: i64) -> bool:
    val started = rt_time_now_unix_micros()
    val ready_path = daemon_dir + "/ready"
    while true:
        if rt_file_exists(ready_path) and lsp_tool_daemon_is_alive(daemon_dir):
            return true
        val elapsed_ms = (rt_time_now_unix_micros() - started) / 1000
        if elapsed_ms >= timeout_ms:
            return false
        rt_process_run(lsp_shell_bin_path(), ["-c", "sleep 0.05"])

fn lsp_reset_tool_daemon_state(daemon_dir: text):
    val entries = rt_dir_list(daemon_dir) ?? []
    var i = 0
    while i < entries.len():
        val name = entries[i]
        if name == "ready" or name.ends_with(".req") or name.ends_with(".args.json") or name.ends_with(".response.json"):
            rt_file_delete(daemon_dir + "/" + name)
        i = i + 1
    LSP_TOOL_DAEMON_PID = -1

fn lsp_tool_daemon_log_hint() -> text:
    val daemon_log = lsp_tool_daemon_dir() + "/daemon.log"
    val raw = (rt_file_read_text(daemon_log) ?? "").trim()
    if raw == "":
        return ""
    var compact = raw.replace("\r", " ")
    compact = compact.replace("\n", " ")
    if compact.len() > 200:
        compact = compact[0:200]
    " (daemon.log: " + compact + ")"

fn lsp_tool_daemon_error_text() -> text:
    if LSP_TOOL_DAEMON_ERROR != "":
        return LSP_TOOL_DAEMON_ERROR
    "CMM tool daemon is unavailable"

fn lsp_tool_timeout_secs() -> text:
    "8s"

fn lsp_normalize_daemon_dir(candidate: text) -> text:
    val trimmed = candidate.trim()
    if trimmed == "" or trimmed == "/" or trimmed == "." or trimmed == "..":
        return ""
    if not trimmed.starts_with("/"):
        return ""
    trimmed

fn lsp_tool_daemon_dir() -> text:
    if LSP_TOOL_DAEMON_DIR != "":
        return LSP_TOOL_DAEMON_DIR
    val env_dir = lsp_normalize_daemon_dir(rt_env_get("T32_LSP_MCP_TOOL_DAEMON_DIR") ?? "")
    if env_dir != "":
        LSP_TOOL_DAEMON_DIR = env_dir
        return LSP_TOOL_DAEMON_DIR
    val cwd = rt_env_cwd()
    var suffix = "workspace"
    if cwd != "":
        suffix = lsp_sanitize_path_segment(cwd)
    LSP_TOOL_DAEMON_DIR = lsp_normalize_daemon_dir("/tmp/t32_lsp_mcp_shared_" + suffix)
    if LSP_TOOL_DAEMON_DIR == "":
        LSP_TOOL_DAEMON_DIR = "/tmp/t32_lsp_mcp_shared_workspace"
    LSP_TOOL_DAEMON_DIR

fn lsp_tool_daemon_path() -> text:
    val env_daemon = rt_env_get("T32_LSP_MCP_TOOL_DAEMON") ?? ""
    if env_daemon != "":
        return env_daemon
    "examples/10_tooling/trace32_tools/cmm_lsp/mcp_daemon.spl"

fn lsp_next_tool_request_key(id: text) -> text:
    LSP_TOOL_DAEMON_SEQ = LSP_TOOL_DAEMON_SEQ + 1
    "req_" + str(LSP_TOOL_DAEMON_SEQ) + "_" + lsp_sanitize_path_segment(id) + "_" + str(rt_time_now_unix_micros())

fn lsp_sanitize_path_segment(value: text) -> text:
    if value == "":
        return "empty"
    var parts: [text] = []
    var i = 0
    while i < value.len():
        val ch = value.substring(i, i + 1)
        if (ch >= "a" and ch <= "z") or (ch >= "A" and ch <= "Z") or (ch >= "0" and ch <= "9") or ch == "_" or ch == "-":
            parts.push(ch)
        else:
            parts.push("_")
        i = i + 1
    val sanitized = parts.join("")
    if sanitized == "":
        return "empty"
    sanitized

fn lsp_shell_bin_path() -> text:
    val env_shell = rt_env_get("T32_LSP_MCP_SHELL_BIN") ?? ""
    if env_shell != "":
        return env_shell
    if rt_file_exists("/bin/sh"):
        return "/bin/sh"
    if rt_file_exists("/usr/bin/sh"):
        return "/usr/bin/sh"
    "sh"

fn lsp_wait_for_tool_response(path: text, timeout_ms: i64) -> text:
    val started = rt_time_now_unix_micros()
    while true:
        if rt_file_exists(path):
            return (rt_file_read_text(path) ?? "").trim()
        val elapsed_ms = (rt_time_now_unix_micros() - started) / 1000
        if elapsed_ms >= timeout_ms:
            return ""
        rt_process_run(lsp_shell_bin_path(), ["-c", "sleep 0.05"])

fn lsp_has_method(msg: text, name: text) -> bool:
    has_method(msg, name)

fn lsp_detect_method(msg: text) -> text:
    if lsp_has_method(msg, "initialize"):
        return "initialize"
    if lsp_has_method(msg, "initialized") or lsp_has_method(msg, "notifications/initialized"):
        return "initialized"
    if lsp_has_method(msg, "notifications/cancelled"):
        return "notifications/cancelled"
    if lsp_has_method(msg, "notifications/roots/list_changed"):
        return "notifications/roots/list_changed"
    if lsp_has_method(msg, "shutdown"):
        return "shutdown"
    if lsp_has_method(msg, "tools/list"):
        return "tools/list"
    if lsp_has_method(msg, "tools/call"):
        return "tools/call"
    if lsp_has_method(msg, "resources/list"):
        return "resources/list"
    if lsp_has_method(msg, "resources/templates/list"):
        return "resources/templates/list"
    if lsp_has_method(msg, "prompts/list"):
        return "prompts/list"
    if lsp_has_method(msg, "roots/list"):
        return "roots/list"
    if lsp_has_method(msg, "logging/setLevel") or lsp_has_method(msg, "logging/setlevel"):
        return "logging/setLevel"
    if lsp_has_method(msg, "ping"):
        return "ping"
    extract_field(msg, "method")

fn lsp_detect_tool_name(body: text) -> text:
    if body.contains("\"name\":\"cmm_parse\"") or body.contains("\"name\": \"cmm_parse\""):
        return "cmm_parse"
    if body.contains("\"name\":\"cmm_diagnostics\"") or body.contains("\"name\": \"cmm_diagnostics\""):
        return "cmm_diagnostics"
    if body.contains("\"name\":\"cmm_complete\"") or body.contains("\"name\": \"cmm_complete\""):
        return "cmm_complete"
    if body.contains("\"name\":\"cmm_hover\"") or body.contains("\"name\": \"cmm_hover\""):
        return "cmm_hover"
    if body.contains("\"name\":\"cmm_symbols\"") or body.contains("\"name\": \"cmm_symbols\""):
        return "cmm_symbols"
    if body.contains("\"name\":\"cmm_definition\"") or body.contains("\"name\": \"cmm_definition\""):
        return "cmm_definition"
    if body.contains("\"name\":\"cmm_validate_cli\"") or body.contains("\"name\": \"cmm_validate_cli\""):
        return "cmm_validate_cli"
    if body.contains("\"name\":\"cmm_ast\"") or body.contains("\"name\": \"cmm_ast\""):
        return "cmm_ast"
    if body.contains("\"name\":\"cmm_dialog_ast\"") or body.contains("\"name\": \"cmm_dialog_ast\""):
        return "cmm_dialog_ast"
    extract_nested(body, "name")

fn lsp_tool_runtime_path() -> text:
    val env_runtime = rt_env_get("SIMPLE_RUNTIME") ?? ""
    if env_runtime != "":
        return env_runtime
    if rt_file_exists("bin/release/simple"):
        return "bin/release/simple"
    if rt_file_exists("bin/release/linux-x86_64/simple"):
        return "bin/release/linux-x86_64/simple"
    if rt_file_exists("bin/release/simple.exe"):
        return "bin/release/simple.exe"
    "bin/release/simple"

fn lsp_timeout_bin_path() -> text:
    val env_timeout = rt_env_get("T32_LSP_MCP_TIMEOUT_BIN") ?? ""
    if env_timeout != "":
        return env_timeout
    if rt_file_exists("/usr/bin/timeout"):
        return "/usr/bin/timeout"
    if rt_file_exists("/bin/timeout"):
        return "/bin/timeout"
    ""

fn lsp_tool_runner_path() -> text:
    val env_runner = rt_env_get("T32_LSP_MCP_TOOL_RUNNER") ?? ""
    if env_runner != "":
        return env_runner
    "examples/10_tooling/trace32_tools/t32_lsp_mcp/tool_runner.spl"

fn lsp_tool_runner_path_for_tool(tool_name: text) -> text:
    if tool_name == "cmm_parse":
        return lsp_parse_tool_runner_path()
    if tool_name == "cmm_validate_cli":
        return lsp_validate_tool_runner_path()
    if tool_name == "cmm_complete" or tool_name == "cmm_hover":
        return lsp_commands_tool_runner_path()
    if tool_name == "cmm_diagnostics" or tool_name == "cmm_symbols" or tool_name == "cmm_definition":
        return lsp_analyze_tool_runner_path()
    if tool_name == "cmm_ast" or tool_name == "cmm_dialog_ast":
        return lsp_ast_tool_runner_path()
    lsp_tool_runner_path()

fn lsp_parse_tool_runner_path() -> text:
    val env_runner = rt_env_get("T32_LSP_MCP_PARSE_RUNNER") ?? ""
    if env_runner != "":
        return env_runner
    "examples/10_tooling/trace32_tools/t32_lsp_mcp/tool_runner_parse.spl"

fn lsp_validate_tool_runner_path() -> text:
    val env_runner = rt_env_get("T32_LSP_MCP_VALIDATE_RUNNER") ?? ""
    if env_runner != "":
        return env_runner
    "examples/10_tooling/trace32_tools/t32_lsp_mcp/tool_runner_validate.spl"

fn lsp_commands_tool_runner_path() -> text:
    val env_runner = rt_env_get("T32_LSP_MCP_COMMANDS_RUNNER") ?? ""
    if env_runner != "":
        return env_runner
    "examples/10_tooling/trace32_tools/t32_lsp_mcp/tool_runner_commands.spl"

fn lsp_analyze_tool_runner_path() -> text:
    val env_runner = rt_env_get("T32_LSP_MCP_ANALYZE_RUNNER") ?? ""
    if env_runner != "":
        return env_runner
    "examples/10_tooling/trace32_tools/t32_lsp_mcp/tool_runner_analyze.spl"

fn lsp_ast_tool_runner_path() -> text:
    val env_runner = rt_env_get("T32_LSP_MCP_AST_RUNNER") ?? ""
    if env_runner != "":
        return env_runner
    "examples/10_tooling/trace32_tools/t32_lsp_mcp/tool_runner_ast.spl"

fn lsp_tool_runner_bin_path() -> text:
    rt_env_get("T32_LSP_MCP_TOOL_RUNNER_BIN") ?? ""

fn lsp_trim_error_text(stderr: text, stdout: text) -> text:
    var raw = stderr.trim()
    if raw == "":
        raw = stdout.trim()
    if raw == "":
        return "unknown error"
    if raw.len() > 240:
        return raw[0:240]
    raw
