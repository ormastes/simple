#![allow(unnamed_duplicate_typed_args)]
# T32 LSP MCP Server — CMM language intelligence via MCP protocol
#
# Tools: 6 tools for parsing, diagnostics, completions, hover, symbols, CLI validation
# Protocol: MCP 2025-06-18 (Content-Length framing + JSON-Lines auto-detect)
#
# Architecture: Imports CMM parser/analyzer from cmm_lsp module, inline JSON helpers
#
# Files:
#   - json_helpers.spl — JSON helpers, tool result helpers
#   - protocol.spl     — Protocol I/O, initialize, tools list, schemas
#   - tools.spl        — Tool handler implementations

use t32_lsp_mcp.json_helpers
use t32_lsp_mcp.protocol

val LSP_SERVER_NAME = "simple-mcp-t32-lsp"
val LSP_SERVER_VERSION = "0.1.2"
val LSP_NL = "\n"

# Protocol auto-detection
var LSP_USE_JSON_LINES = false

# Caches
var LSP_TOOLS_CACHE = ""
var LSP_INIT_CACHE = ""

# --- Entry point ---

fn main():
    lsp_start_server()

fn lsp_start_server():
    while true:
        var msg = lsp_read_stdin_message()
        if msg == "":
            return
        else:
            var method = lsp_detect_method(msg)
            var id = lsp_extract_id(msg)
            var response = ""
            if method == "initialize":
                response = lsp_make_init_response(id)
            elif method == "initialized" or method == "notifications/initialized":
                response = ""
            elif method == "shutdown":
                response = lsp_result_ok(id, "null")
            elif method == "tools/list":
                response = lsp_make_tools_list(id)
            elif method == "tools/call":
                response = lsp_dispatch_tool(id, msg)
            elif method == "ping":
                response = lsp_result_ok(id, lsp_LB() + lsp_RB())
            elif method == "notifications/cancelled" or method == "notifications/roots/list_changed":
                response = ""
            else:
                if id != "" and id != "null":
                    response = lsp_result_error(id, -32601, "Method not found: " + method)
            if response != "":
                lsp_write_stdout_message(response)

# --- Tool dispatcher ---

fn lsp_dispatch_tool(id: text, body: text) -> text:
    val tool_name = lsp_detect_tool_name(body)
    if tool_name == "":
        return lsp_result_error(id, -32602, "Missing tool name in tools/call request")
    lsp_result_error(id, -32001, "Tool execution is unavailable in the fast-start path")

fn lsp_has_method(msg: text, name: text) -> bool:
    msg.contains("\"method\":\"" + name + "\"") or msg.contains("\"method\": \"" + name + "\"")

fn lsp_detect_method(msg: text) -> text:
    if lsp_has_method(msg, "initialize"):
        return "initialize"
    if lsp_has_method(msg, "initialized") or lsp_has_method(msg, "notifications/initialized"):
        return "initialized"
    if lsp_has_method(msg, "notifications/cancelled"):
        return "notifications/cancelled"
    if lsp_has_method(msg, "notifications/roots/list_changed"):
        return "notifications/roots/list_changed"
    if lsp_has_method(msg, "shutdown"):
        return "shutdown"
    if lsp_has_method(msg, "tools/list"):
        return "tools/list"
    if lsp_has_method(msg, "tools/call"):
        return "tools/call"
    if lsp_has_method(msg, "ping"):
        return "ping"
    lsp_extract_field(msg, "method")

fn lsp_detect_tool_name(body: text) -> text:
    if body.contains("\"name\":\"cmm_parse\"") or body.contains("\"name\": \"cmm_parse\""):
        return "cmm_parse"
    if body.contains("\"name\":\"cmm_diagnostics\"") or body.contains("\"name\": \"cmm_diagnostics\""):
        return "cmm_diagnostics"
    if body.contains("\"name\":\"cmm_complete\"") or body.contains("\"name\": \"cmm_complete\""):
        return "cmm_complete"
    if body.contains("\"name\":\"cmm_hover\"") or body.contains("\"name\": \"cmm_hover\""):
        return "cmm_hover"
    if body.contains("\"name\":\"cmm_symbols\"") or body.contains("\"name\": \"cmm_symbols\""):
        return "cmm_symbols"
    if body.contains("\"name\":\"cmm_validate_cli\"") or body.contains("\"name\": \"cmm_validate_cli\""):
        return "cmm_validate_cli"
    lsp_extract_nested(body, "name")
