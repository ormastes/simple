@allow(unnamed_duplicate_typed_args)
# T32 LSP MCP - Parse-only backend
#
# Keep cmm_parse isolated from the heavier analysis/completion modules so
# parser requests do not hang during module initialization.

use t32_lsp_mcp.json_helpers
use t32_lsp_mcp.debug_log.{lsp_debug_append, lsp_debug_enabled}
use t32_lsp_mcp.tool_runner_common.{runner_arg0_is_executable_path, debug_args}
use cmm_lsp.cmm_parser_runtime.{parse_cmm_source}

extern fn sys_get_args() -> [text]
extern fn sys_exit(code: i64)
extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_exists(path: text) -> bool

fn parse_json_char_at(s: text, i: i64) -> text:
    s.substring(i, i + 1)

fn parse_json_is_ws(ch: text) -> bool:
    ch == " " or ch == "\n" or ch == "\r" or ch == "\t"

fn parse_json_find_value_start(json: text, key: text) -> i64:
    val search = "\"" + key + "\""
    var offset = 0
    while offset + search.len() <= json.len():
        if json.substring(offset, offset + search.len()) != search:
            offset = offset + 1
            continue
        var j = offset + search.len()
        while j < json.len() and parse_json_is_ws(parse_json_char_at(json, j)):
            j = j + 1
        if j < json.len() and parse_json_char_at(json, j) == ":":
            j = j + 1
            while j < json.len() and parse_json_is_ws(parse_json_char_at(json, j)):
                j = j + 1
            return j
        offset = offset + search.len()
    return -1

fn parse_json_raw_field(json: text, key: text) -> text:
    val start = parse_json_find_value_start(json, key)
    if start < 0 or start >= json.len():
        return "null"
    val first = parse_json_char_at(json, start)
    if first == "\"":
        var i = start + 1
        var escaped = false
        while i < json.len():
            val ch = parse_json_char_at(json, i)
            if escaped:
                escaped = false
            elif ch == "\\":
                escaped = true
            elif ch == "\"":
                return json.substring(start, i + 1)
            i = i + 1
        return "null"
    if first == "{" or first == "[":
        var depth = 0
        var i2 = start
        var in_str = false
        var esc = false
        while i2 < json.len():
            val ch = parse_json_char_at(json, i2)
            if in_str:
                if esc:
                    esc = false
                elif ch == "\\":
                    esc = true
                elif ch == "\"":
                    in_str = false
            else:
                if ch == "\"":
                    in_str = true
                elif ch == "{" or ch == "[":
                    depth = depth + 1
                elif ch == "}" or ch == "]":
                    depth = depth - 1
                    if depth == 0:
                        return json.substring(start, i2 + 1)
            i2 = i2 + 1
        return "null"
    var end = start
    while end < json.len():
        val ch = parse_json_char_at(json, end)
        if ch == "," or ch == "}" or ch == "]" or parse_json_is_ws(ch):
            break
        end = end + 1
    val raw = json.substring(start, end)
    if raw == "":
        return "null"
    raw

fn parse_json_text_field(json: text, key: text) -> text:
    val raw = parse_json_raw_field(json, key)
    if raw == "null":
        return ""
    if raw.starts_with("\"") and raw.ends_with("\"") and raw.len() >= 2:
        return lsp_unescape_json_string(raw.substring(1, raw.len() - 1))
    raw

fn parse_source_arg(args: text) -> text:
    val candidates = [
        "\\\"source\\\":\\\"",
        "\\\"source\\\": \\\"",
        "\"source\":\"",
        "\"source\": \""
    ]
    var ci = 0
    while ci < candidates.len():
        val marker = candidates[ci]
        var i = 0
        while i + marker.len() <= args.len():
            if args.substring(i, i + marker.len()) == marker:
                var start = i + marker.len()
                var j = start
                var escaped = false
                while j < args.len():
                    val ch = args.substring(j, j + 1)
                    if escaped:
                        escaped = false
                    elif ch == "\\":
                        escaped = true
                    elif ch == "\"":
                        return lsp_unescape_json_string(args.substring(start, j))
                    j = j + 1
                return ""
            i = i + 1
        ci = ci + 1
    ""

fn handle_cmm_parse(id: text, args: text) -> text:
    val source = parse_source_arg(args)
    if lsp_debug_enabled():
        lsp_debug_append("requests.log", "parse id=" + id + " args=" + args + " source_len=" + str(source.len()))
    if source == "":
        if lsp_debug_enabled():
            val preview = if args.len() > 120: args.substring(0, 120) else: args
            return lsp_make_tool_error(id, -32602, "Missing required parameter: source args=" + preview)
        return lsp_make_tool_error(id, -32602, "Missing required parameter: source")
    val program = parse_cmm_source(source)
    val node_count = program.statements.len()
    val error_count = program.errors.len()

    var errors_arr = lsp_SB_L()
    var ei = 0
    while ei < program.errors.len():
        if ei > 0:
            errors_arr = errors_arr + ","
        errors_arr = errors_arr + lsp_js(program.errors[ei])
        ei = ei + 1
    errors_arr = errors_arr + lsp_SB_R()

    val result = lsp_jo3(
        lsp_jp("node_count", str(node_count)),
        lsp_jp("error_count", str(error_count)),
        lsp_jp("errors", errors_arr)
    )
    lsp_make_tool_result(id, result)

fn main():
    val raw_args = sys_get_args()
    var args = raw_args
    if args.len() >= 2 and not args[0].ends_with(".spl") and args[1].ends_with(".spl"):
        args = args[2:args.len()]
    elif args.len() >= 1 and args[0].ends_with(".spl"):
        args = args[1:args.len()]
    elif args.len() >= 4 and runner_arg0_is_executable_path(args[0]):
        args = args[1:args.len()]

    if args.len() < 3:
        print "tool_runner_parse argument error: " + debug_args(args)
        sys_exit(2)

    val id = args[0]
    val args_path = args[2]
    val args_raw = rt_file_read_text(args_path) ?? "null"
    if lsp_debug_enabled():
        lsp_debug_append("requests.log", "parse runner id=" + id + " raw=" + args_raw)
    print_raw(handle_cmm_parse(id, args_raw))
