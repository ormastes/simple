@allow(unnamed_duplicate_typed_args)
# T32 LSP MCP - Tool execution backend
#
# Keep this runner aligned with the direct cmm_lsp imports used by the daemon.
# The old t32_lsp_mcp.tools wrapper module can hang during startup in direct mode.

use t32_lsp_mcp.json_helpers
use cmm_lsp.cmm_parser_runtime.{parse_cmm_source}
use cmm_lsp.cmm_analyzer.{analyze_program, CmmSymbol, CmmSymbolKind}
use cmm_lsp.cmm_commands.{build_command_db, get_completions}
use cmm_lsp.cmm_diagnostics.{severity_text}

extern fn sys_get_args() -> [text]
extern fn sys_exit(code: i64)
extern fn rt_file_read_text(path: text) -> text

fn arg_field(args: text, key: text) -> text:
    val value = lsp_extract_field(args, key)
    if value != "":
        return value
    val nested = lsp_extract_field_raw(args, key)
    if nested == "null":
        return ""
    if nested.starts_with(lsp_Q()) and nested.ends_with(lsp_Q()) and nested.len() >= 2:
        return lsp_unescape_json_string(nested.substring(1, nested.len() - 1))
    nested

fn runner_arg0_is_executable_path(arg0: text) -> bool:
    arg0.contains("/") or arg0.contains("\\") or arg0.ends_with(".exe") or arg0.ends_with("t32_lsp_mcp_tool_runner")

fn debug_args(args: [text]) -> text:
    var out = "argc=" + str(args.len())
    var i = 0
    while i < args.len():
        out = out + " argv[" + str(i) + "]=" + args[i]
        i = i + 1
    out

fn dispatch_tool(id: text, tool_name: text, args: text) -> text:
    if tool_name == "cmm_parse":
        return handle_cmm_parse(id, args)
    if tool_name == "cmm_diagnostics":
        return handle_cmm_diagnostics(id, args)
    if tool_name == "cmm_complete":
        return handle_cmm_complete(id, args)
    if tool_name == "cmm_hover":
        return handle_cmm_hover(id, args)
    if tool_name == "cmm_symbols":
        return handle_cmm_symbols(id, args)
    if tool_name == "cmm_validate_cli":
        return handle_cmm_validate_cli(id, args)
    lsp_make_tool_error(id, -32601, "Unknown tool: " + tool_name)

fn handle_cmm_parse(id: text, args: text) -> text:
    val source = arg_field(args, "source")
    if source == "":
        return lsp_make_tool_error(id, -32602, "Missing required parameter: source")
    val program = parse_cmm_source(source)
    var errors_arr = lsp_SB_L()
    var ei = 0
    while ei < program.errors.len():
        if ei > 0:
            errors_arr = errors_arr + ","
        errors_arr = errors_arr + lsp_js(program.errors[ei])
        ei = ei + 1
    errors_arr = errors_arr + lsp_SB_R()
    val result = lsp_jo3(
        lsp_jp("node_count", str(program.statements.len())),
        lsp_jp("error_count", str(program.errors.len())),
        lsp_jp("errors", errors_arr)
    )
    lsp_make_tool_result(id, result)

fn handle_cmm_diagnostics(id: text, args: text) -> text:
    val source = arg_field(args, "source")
    if source == "":
        return lsp_make_tool_error(id, -32602, "Missing required parameter: source")
    val analysis = analyze_program(parse_cmm_source(source))
    var arr = lsp_SB_L()
    var di = 0
    while di < analysis.diagnostics.len():
        if di > 0:
            arr = arr + ","
        val d = analysis.diagnostics[di]
        arr = arr + lsp_jo4(
            lsp_jp("severity", lsp_js(severity_text(d.kind))),
            lsp_jp("message", lsp_js(d.message)),
            lsp_jp("line", str(d.line)),
            lsp_jp("column", str(d.column))
        )
        di = di + 1
    arr = arr + lsp_SB_R()
    lsp_make_tool_result(id, lsp_jo2(lsp_jp("count", str(analysis.diagnostics.len())), lsp_jp("diagnostics", arr)))

fn handle_cmm_complete(id: text, args: text) -> text:
    val source = arg_field(args, "source")
    if source == "":
        return lsp_make_tool_error(id, -32602, "Missing required parameter: source")
    val target_line = parse_i64(arg_field(args, "line"))
    val target_char = parse_i64(arg_field(args, "character"))
    val prefix = extract_word_from_lines(source.split("\n"), target_line, target_char)
    val matches = get_completions(build_command_db(), prefix)
    var arr = lsp_SB_L()
    var ci = 0
    while ci < matches.len():
        if ci > 0:
            arr = arr + ","
        val cmd = matches[ci]
        arr = arr + lsp_jo3(
            lsp_jp("label", lsp_js(cmd.full_name)),
            lsp_jp("kind", lsp_js("command")),
            lsp_jp("description", lsp_js(cmd.description))
        )
        ci = ci + 1
    arr = arr + lsp_SB_R()
    lsp_make_tool_result(id, lsp_jo2(lsp_jp("count", str(matches.len())), lsp_jp("completions", arr)))

fn handle_cmm_hover(id: text, args: text) -> text:
    val source = arg_field(args, "source")
    if source == "":
        return lsp_make_tool_error(id, -32602, "Missing required parameter: source")
    val target_line = parse_i64(arg_field(args, "line"))
    val target_char = parse_i64(arg_field(args, "character"))
    val word = extract_word_from_lines(source.split("\n"), target_line, target_char)
    if word == "":
        return lsp_make_tool_result(id, lsp_jo1(lsp_jp("hover", lsp_js(""))))
    val hover_text = lookup_hover_text(build_command_db(), word)
    lsp_make_tool_result(id, lsp_jo2(lsp_jp("word", lsp_js(word)), lsp_jp("hover", lsp_js(hover_text))))

fn handle_cmm_symbols(id: text, args: text) -> text:
    val source = arg_field(args, "source")
    if source == "":
        return lsp_make_tool_error(id, -32602, "Missing required parameter: source")
    val analysis = analyze_program(parse_cmm_source(source))
    val labels = analysis.symbols.labels()
    val macros = analysis.symbols.macros()
    var syms: [CmmSymbol] = []
    var i = 0
    while i < labels.len():
        syms.push(labels[i])
        i = i + 1
    i = 0
    while i < macros.len():
        syms.push(macros[i])
        i = i + 1
    var arr = lsp_SB_L()
    i = 0
    while i < syms.len():
        if i > 0:
            arr = arr + ","
        val sym = syms[i]
        arr = arr + lsp_jo4(
            lsp_jp("name", lsp_js(sym.name)),
            lsp_jp("kind", lsp_js(symbol_kind_str(sym.kind))),
            lsp_jp("scope", lsp_js(sym.scope)),
            lsp_jp("line", str(sym.def_line))
        )
        i = i + 1
    arr = arr + lsp_SB_R()
    lsp_make_tool_result(id, lsp_jo2(lsp_jp("count", str(syms.len())), lsp_jp("symbols", arr)))

fn handle_cmm_validate_cli(id: text, args: text) -> text:
    val source = arg_field(args, "source")
    if source == "":
        return lsp_make_tool_error(id, -32602, "Missing required parameter: source")
    var issues: [text] = []
    val lower_source = source.to_lower()
    val gui_violations = check_gui_keywords(source)
    var i = 0
    while i < gui_violations.len():
        issues.push("GUI keyword found: " + gui_violations[i])
        i = i + 1
    if not check_has_command(source, "screen.off"):
        issues.push("Missing SCREEN.OFF command")
    if not lower_source.contains("area.create") or not lower_source.contains("area.select"):
        issues.push("Missing AREA.Create/Select setup")
    if not (lower_source.contains("on error") or lower_source.contains("on.error") or lower_source.contains("globalon error")):
        issues.push("Missing ON ERROR handler")
    if not source.contains("@target:"):
        issues.push("Missing @target: metadata header")
    if not source.contains("@purpose:"):
        issues.push("Missing @purpose: metadata header")
    if not source.contains("ENDDO TRUE()") and not source.contains("ENDDO FALSE()"):
        issues.push("Missing ENDDO TRUE()/FALSE() return value")
    val program = parse_cmm_source(source)
    if program.errors.len() > 0:
        issues.push("Parse error: " + program.errors[0])
    var issues_arr = lsp_SB_L()
    i = 0
    while i < issues.len():
        if i > 0:
            issues_arr = issues_arr + ","
        issues_arr = issues_arr + lsp_js(issues[i])
        i = i + 1
    issues_arr = issues_arr + lsp_SB_R()
    val valid = if issues.len() == 0: "true" else: "false"
    lsp_make_tool_result(id, lsp_jo3(lsp_jp("valid", valid), lsp_jp("issue_count", str(issues.len())), lsp_jp("issues", issues_arr)))

fn line_text_for_position(lines: [text], target_line: i64) -> text:
    if target_line >= 0 and target_line < lines.len():
        return lines[target_line]
    if target_line >= 1 and target_line <= lines.len():
        return lines[target_line - 1]
    ""

fn extract_word_from_lines(lines: [text], target_line: i64, target_char: i64) -> text:
    val line = line_text_for_position(lines, target_line)
    if line == "":
        return ""
    var idx = target_char
    if idx < 0:
        idx = 0
    if idx > line.len():
        idx = line.len()
    var start = idx
    while start > 0 and is_ident_char(line.substring(start - 1, start)):
        start = start - 1
    var end = idx
    while end < line.len() and is_ident_char(line.substring(end, end + 1)):
        end = end + 1
    if end <= start:
        return ""
    line.substring(start, end)

fn is_ident_char(ch: text) -> bool:
    if ch == "_":
        return true
    val upper = ch.to_upper()
    val lower = ch.to_lower()
    if upper != lower:
        return true
    ch >= "0" and ch <= "9"

fn lookup_hover_text(db, word: text) -> text:
    val matches = get_completions(db, word)
    var i = 0
    while i < matches.len():
        val cmd = matches[i]
        if cmd.full_name.to_lower() == word.to_lower():
            return cmd.description
        i = i + 1
    ""

fn symbol_kind_str(kind: CmmSymbolKind) -> text:
    match kind:
        case CmmSymbolKind.LabelSym: "label"
        case CmmSymbolKind.MacroSym: "macro"
        case CmmSymbolKind.SubroutineSym: "subroutine"
        case CmmSymbolKind.FileRefSym: "file"
        case _: "symbol"

fn check_gui_keywords(source: text) -> [text]:
    val lower = source.to_lower()
    val keywords = ["dialog.", "menu.", "screen.wait", "inkey", "enter "]
    var found: [text] = []
    var i = 0
    while i < keywords.len():
        if lower.contains(keywords[i]):
            found.push(keywords[i])
        i = i + 1
    found

fn check_has_command(source: text, cmd: text) -> bool:
    val lower_source = source.to_lower()
    val lower_cmd = cmd.to_lower()
    lower_source.contains(lower_cmd)

fn parse_i64(s: text) -> i64:
    if s == "":
        return 0
    var i = 0
    var sign = 1
    if s.starts_with("-"):
        sign = -1
        i = 1
    var value = 0
    while i < s.len():
        val ch = s.substring(i, i + 1)
        if ch < "0" or ch > "9":
            break
        value = value * 10 + int(ch)
        i = i + 1
    value * sign

fn main():
    val raw_args = sys_get_args()
    var args = raw_args
    if args.len() >= 2 and not args[0].ends_with(".spl") and args[1].ends_with(".spl"):
        args = args[2:args.len()]
    elif args.len() >= 1 and args[0].ends_with(".spl"):
        args = args[1:args.len()]
    elif args.len() >= 4 and runner_arg0_is_executable_path(args[0]):
        args = args[1:args.len()]

    if args.len() < 3:
        print "tool_runner argument error: " + debug_args(args)
        sys_exit(2)

    val id = args[0]
    val tool_name = args[1]
    val args_path = args[2]
    val args_raw = rt_file_read_text(args_path) ?? "null"
    print_raw(dispatch_tool(id, tool_name, args_raw))
