#![allow(unnamed_duplicate_typed_args)]
@allow(unnamed_duplicate_typed_args)
# Lightweight direct runner for command-db backed tools.

use t32_lsp_mcp.json_helpers
use t32_lsp_mcp.tool_runner_common.{runner_arg0_is_executable_path, debug_args, extract_word_from_lines, parse_i64, scan_symbols_lite, LiteSymbol, is_cmm_keyword, cmm_keyword_description, get_cmm_keywords}
use cmm_lsp.cmm_commands.{build_command_db, get_completions}

extern fn sys_get_args() -> [text]
extern fn sys_exit(code: i64)
extern fn rt_file_read_text(path: text) -> text

fn json_string_field(body: text, key: text) -> text:
    val pieces = body.split("\"" + key + "\":")
    if pieces.len() < 2:
        return ""
    val tail = pieces[1].trim_start()
    if tail == "" or not tail.starts_with("\""):
        return ""
    var i = 1
    var escaped = false
    while i < tail.len():
        val ch = tail[i:i + 1]
        if escaped:
            escaped = false
        elif ch == "\\":
            escaped = true
        elif ch == "\"":
            return lsp_unescape_json_string(tail.substring(1, i))
        i = i + 1
    ""

fn json_scalar_field(body: text, key: text) -> text:
    val pieces = body.split("\"" + key + "\":")
    if pieces.len() < 2:
        return ""
    val tail = pieces[1].trim_start()
    if tail == "":
        return ""
    var end = 0
    while end < tail.len():
        val ch = tail[end:end + 1]
        if ch == "," or ch == "}" or ch == "]" or ch == " " or ch == "\n" or ch == "\r" or ch == "\t":
            break
        end = end + 1
    if end <= 0:
        return ""
    tail.substring(0, end)

fn lookup_hover_text(db, word: text) -> text:
    val lower_word = word.to_lower()
    val matches = get_completions(db, word)
    var i = 0
    while i < matches.len():
        val cmd = matches[i]
        if cmd.full_name.to_lower() == lower_word or cmd.short_name.to_lower() == lower_word:
            var hover_text = cmd.full_name
            if cmd.description != "":
                hover_text = hover_text + " - " + cmd.description
            if cmd.short_name != "":
                hover_text = hover_text + " (" + cmd.short_name + ")"
            if cmd.group != "":
                hover_text = hover_text + " [" + cmd.group + "]"
            return hover_text
        i = i + 1
    ""

fn first_word(text_value: text) -> text:
    val trimmed = text_value.trim()
    if trimmed == "":
        return ""
    var end = 0
    while end < trimmed.len():
        val ch = trimmed[end:end + 1]
        if ch == " " or ch == "\n" or ch == "\r" or ch == "\t":
            break
        end = end + 1
    if end <= 0:
        return trimmed
    trimmed.substring(0, end)

fn handle_cmm_complete(id: text, args: text) -> text:
    val source = json_string_field(args, "source")
    if source == "":
        return lsp_make_tool_error(id, -32602, "Missing required parameter: source")
    val target_line = parse_i64(json_scalar_field(args, "line"))
    val target_char = parse_i64(json_scalar_field(args, "character"))
    var prefix = extract_word_from_lines(source.split("\n"), target_line, target_char)
    if prefix == "":
        prefix = first_word(source)
    val limit = 32
    var arr = lsp_SB_L()
    var total = 0
    # Phase 5: macro completions (highest priority)
    if prefix.starts_with("&"):
        val macro_prefix = prefix.substring(1).to_lower()
        val syms = scan_symbols_lite(source)
        var si = 0
        while si < syms.len() and total < limit:
            if syms[si].kind == "macro" and syms[si].name.to_lower().starts_with(macro_prefix):
                if total > 0:
                    arr = arr + ","
                arr = arr + lsp_jo3(
                    lsp_jp("label", lsp_js("&" + syms[si].name)),
                    lsp_jp("kind", lsp_js("macro")),
                    lsp_jp("description", lsp_js(syms[si].scope + " macro"))
                )
                total = total + 1
            si = si + 1
    # Phase 5: keyword completions
    val prefix_lower = prefix.to_lower()
    val kws = get_cmm_keywords()
    var ki = 0
    while ki < kws.len() and total < limit:
        if kws[ki].to_lower().starts_with(prefix_lower):
            if total > 0:
                arr = arr + ","
            val kw_desc = cmm_keyword_description(kws[ki].to_upper())
            arr = arr + lsp_jo3(
                lsp_jp("label", lsp_js(kws[ki])),
                lsp_jp("kind", lsp_js("keyword")),
                lsp_jp("description", lsp_js(kw_desc))
            )
            total = total + 1
        ki = ki + 1
    # Phase 5: label completions
    val lbl_syms = scan_symbols_lite(source)
    var lbi = 0
    while lbi < lbl_syms.len() and total < limit:
        if lbl_syms[lbi].kind == "label" and lbl_syms[lbi].name.to_lower().starts_with(prefix_lower):
            if total > 0:
                arr = arr + ","
            arr = arr + lsp_jo3(
                lsp_jp("label", lsp_js(lbl_syms[lbi].name)),
                lsp_jp("kind", lsp_js("label")),
                lsp_jp("description", lsp_js("label at line " + str(lbl_syms[lbi].line)))
            )
            total = total + 1
        lbi = lbi + 1
    # Command DB completions (lowest priority)
    val matches = get_completions(build_command_db(), prefix)
    var ci = 0
    while ci < matches.len() and total < limit:
        if total > 0:
            arr = arr + ","
        val cmd = matches[ci]
        arr = arr + lsp_jo3(
            lsp_jp("label", lsp_js(cmd.full_name)),
            lsp_jp("kind", lsp_js("command")),
            lsp_jp("description", lsp_js(cmd.description))
        )
        total = total + 1
        ci = ci + 1
    arr = arr + lsp_SB_R()
    lsp_make_tool_result(id, lsp_jo2(lsp_jp("count", str(total)), lsp_jp("completions", arr)))

fn handle_cmm_hover(id: text, args: text) -> text:
    val source = json_string_field(args, "source")
    if source == "":
        return lsp_make_tool_error(id, -32602, "Missing required parameter: source")
    val target_line = parse_i64(json_scalar_field(args, "line"))
    val target_char = parse_i64(json_scalar_field(args, "character"))
    var word = extract_word_from_lines(source.split("\n"), target_line, target_char)
    val fallback_word = first_word(source)
    if word == "" or (word.len() < 2 and fallback_word.len() > word.len()):
        word = fallback_word
    if word == "":
        return lsp_make_tool_result(id, lsp_jo1(lsp_jp("hover", lsp_js(""))))
    # Phase 5: macro hover
    if word.starts_with("&"):
        val macro_name = word.substring(1)
        val syms = scan_symbols_lite(source)
        var si = 0
        while si < syms.len():
            if syms[si].kind == "macro" and syms[si].name == macro_name:
                val hover_m = "&" + syms[si].name + " — " + syms[si].scope + " macro, declared at line " + str(syms[si].line)
                return lsp_make_tool_result(id, lsp_jo2(lsp_jp("word", lsp_js(word)), lsp_jp("hover", lsp_js(hover_m))))
            si = si + 1
    # Phase 5: label hover
    val label_syms = scan_symbols_lite(source)
    var li2 = 0
    while li2 < label_syms.len():
        if label_syms[li2].kind == "label" and label_syms[li2].name == word:
            val hover_l = word + ": — label, defined at line " + str(label_syms[li2].line)
            return lsp_make_tool_result(id, lsp_jo2(lsp_jp("word", lsp_js(word)), lsp_jp("hover", lsp_js(hover_l))))
        li2 = li2 + 1
    # Phase 5: keyword hover
    if is_cmm_keyword(word.to_upper()):
        val kw_desc = cmm_keyword_description(word.to_upper())
        if kw_desc != "":
            return lsp_make_tool_result(id, lsp_jo2(lsp_jp("word", lsp_js(word)), lsp_jp("hover", lsp_js(word.to_upper() + " — " + kw_desc))))
    val hover_text = lookup_hover_text(build_command_db(), word)
    lsp_make_tool_result(id, lsp_jo2(lsp_jp("word", lsp_js(word)), lsp_jp("hover", lsp_js(hover_text))))

fn dispatch_tool(id: text, tool_name: text, args: text) -> text:
    if tool_name == "cmm_complete":
        return handle_cmm_complete(id, args)
    if tool_name == "cmm_hover":
        return handle_cmm_hover(id, args)
    lsp_make_tool_error(id, -32601, "Unknown tool: " + tool_name)

fn main():
    val raw_args = sys_get_args()
    var args = raw_args
    if args.len() >= 2 and not args[0].ends_with(".spl") and args[1].ends_with(".spl"):
        args = args[2:args.len()]
    elif args.len() >= 1 and args[0].ends_with(".spl"):
        args = args[1:args.len()]
    elif args.len() >= 4 and runner_arg0_is_executable_path(args[0]):
        args = args[1:args.len()]
    if args.len() < 3:
        print "tool_runner_commands argument error: " + debug_args(args)
        sys_exit(2)
    val id = args[0]
    val tool_name = args[1]
    val args_path = args[2]
    val args_raw = rt_file_read_text(args_path) ?? "null"
    print_raw(dispatch_tool(id, tool_name, args_raw))
