@allow(unnamed_duplicate_typed_args)
# Lightweight analyzer runner that avoids the heavy semantic analyzer on MCP paths.

use t32_lsp_mcp.json_helpers
use t32_lsp_mcp.tool_runner_common.{runner_arg0_is_executable_path, debug_args, extract_word_from_lines, parse_i64, LiteSymbol, scan_symbols_lite}
use cmm_lsp.cmm_parser_runtime.{parse_cmm_source}

extern fn sys_get_args() -> [text]
extern fn sys_exit(code: i64)
extern fn rt_file_read_text(path: text) -> text

fn json_string_field(body: text, key: text) -> text:
    val pieces = body.split("\"" + key + "\":")
    if pieces.len() < 2:
        return ""
    val tail = pieces[1].trim_start()
    if tail == "" or not tail.starts_with("\""):
        return ""
    var i = 1
    var escaped = false
    while i < tail.len():
        val ch = tail[i:i + 1]
        if escaped:
            escaped = false
        elif ch == "\\":
            escaped = true
        elif ch == "\"":
            return lsp_unescape_json_string(tail.substring(1, i))
        i = i + 1
    ""

fn json_scalar_field(body: text, key: text) -> text:
    val pieces = body.split("\"" + key + "\":")
    if pieces.len() < 2:
        return ""
    val tail = pieces[1].trim_start()
    if tail == "":
        return ""
    var end = 0
    while end < tail.len():
        val ch = tail[end:end + 1]
        if ch == "," or ch == "}" or ch == "]" or ch == " " or ch == "\n" or ch == "\r" or ch == "\t":
            break
        end = end + 1
    if end <= 0:
        return ""
    tail.substring(0, end)

fn handle_cmm_diagnostics(id: text, args: text) -> text:
    val source = json_string_field(args, "source")
    if source == "":
        return lsp_make_tool_error(id, -32602, "Missing required parameter: source")
    val program = parse_cmm_source(source)
    var arr = lsp_SB_L()
    var di = 0
    while di < program.errors.len():
        if di > 0:
            arr = arr + ","
        arr = arr + lsp_jo4(
            lsp_jp("severity", lsp_js("error")),
            lsp_jp("message", lsp_js(program.errors[di])),
            lsp_jp("line", "0"),
            lsp_jp("column", "0")
        )
        di = di + 1
    arr = arr + lsp_SB_R()
    lsp_make_tool_result(id, lsp_jo2(lsp_jp("count", str(program.errors.len())), lsp_jp("diagnostics", arr)))

fn handle_cmm_symbols(id: text, args: text) -> text:
    val source = json_string_field(args, "source")
    if source == "":
        return lsp_make_tool_error(id, -32602, "Missing required parameter: source")
    val syms = scan_symbols_lite(source)
    var arr = lsp_SB_L()
    var i = 0
    while i < syms.len():
        if i > 0:
            arr = arr + ","
        val sym = syms[i]
        arr = arr + lsp_jo4(
            lsp_jp("name", lsp_js(sym.name)),
            lsp_jp("kind", lsp_js(sym.kind)),
            lsp_jp("scope", lsp_js(sym.scope)),
            lsp_jp("line", str(sym.line))
        )
        i = i + 1
    arr = arr + lsp_SB_R()
    lsp_make_tool_result(id, lsp_jo2(lsp_jp("count", str(syms.len())), lsp_jp("symbols", arr)))

fn handle_cmm_definition(id: text, args: text) -> text:
    val source = json_string_field(args, "source")
    if source == "":
        return lsp_make_tool_error(id, -32602, "Missing required parameter: source")
    val target_line = parse_i64(json_scalar_field(args, "line"))
    val target_char = parse_i64(json_scalar_field(args, "character"))
    val word = extract_word_from_lines(source.split("\n"), target_line, target_char)
    if word == "":
        return lsp_make_tool_result(id, lsp_jo1(lsp_jp("found", "false")))
    var lookup = word
    if lookup.starts_with("&"):
        lookup = lookup.substring(1)
    val syms = scan_symbols_lite(source)
    var i = 0
    while i < syms.len():
        if syms[i].name == lookup or syms[i].name == word:
            return lsp_make_tool_result(id, lsp_jo4(
                lsp_jp("found", "true"),
                lsp_jp("symbol", lsp_js(syms[i].name)),
                lsp_jp("line", str(syms[i].line)),
                lsp_jp("column", str(syms[i].column))
            ))
        i = i + 1
    lsp_make_tool_result(id, lsp_jo1(lsp_jp("found", "false")))

fn dispatch_tool(id: text, tool_name: text, args: text) -> text:
    if tool_name == "cmm_diagnostics":
        return handle_cmm_diagnostics(id, args)
    if tool_name == "cmm_symbols":
        return handle_cmm_symbols(id, args)
    if tool_name == "cmm_definition":
        return handle_cmm_definition(id, args)
    lsp_make_tool_error(id, -32601, "Unknown tool: " + tool_name)

fn main():
    val raw_args = sys_get_args()
    var args = raw_args
    if args.len() >= 2 and not args[0].ends_with(".spl") and args[1].ends_with(".spl"):
        args = args[2:args.len()]
    elif args.len() >= 1 and args[0].ends_with(".spl"):
        args = args[1:args.len()]
    elif args.len() >= 4 and runner_arg0_is_executable_path(args[0]):
        args = args[1:args.len()]
    if args.len() < 3:
        print "tool_runner_analyze argument error: " + debug_args(args)
        sys_exit(2)
    val id = args[0]
    val tool_name = args[1]
    val args_path = args[2]
    val args_raw = rt_file_read_text(args_path) ?? "null"
    print_raw(dispatch_tool(id, tool_name, args_raw))
