@allow(unnamed_duplicate_typed_args)
# T32 LSP MCP Server — JSON, protocol, and transport helpers
#
# Inlined implementations that work in interpreter mode.
# The std.mcp_sdk.* imports hang in interpreter mode because the
# std/common/lib module loader blocks during resolution.
# This file provides equivalent functions using only inline code
# and extern fn declarations.

extern fn stdin_read_char() -> text

# --- JSON building helpers ---

fn Q() -> text:
    "\""

fn LB() -> text:
    (123 as char).to_string()

fn RB() -> text:
    (125 as char).to_string()

fn SB_L() -> text:
    "["

fn SB_R() -> text:
    "]"

fn escape_json(s: text) -> text:
    var out = s
    out = out.replace("\\", "\\\\")
    out = out.replace("\"", "\\\"")
    out = out.replace("\n", "\\n")
    out = out.replace("\r", "\\r")
    out = out.replace("\t", "\\t")
    out

fn js(value: text) -> text:
    Q() + escape_json(value) + Q()

fn jp(key: text, value: text) -> text:
    Q() + key + Q() + ":" + value

fn jo1(p1: text) -> text:
    LB() + p1 + RB()

fn jo2(p1: text, p2: text) -> text:
    LB() + p1 + "," + p2 + RB()

fn jo3(p1: text, p2: text, p3: text) -> text:
    LB() + p1 + "," + p2 + "," + p3 + RB()

fn jo4(p1: text, p2: text, p3: text, p4: text) -> text:
    LB() + p1 + "," + p2 + "," + p3 + "," + p4 + RB()

# --- JSON parsing helpers ---

fn extract_field(json: text, key: text) -> text:
    val search = Q() + key + Q() + ":"
    val idx_opt = json.index_of(search)
    var idx = -1
    match idx_opt:
        Some(i): idx = i
        nil: return ""
    val start = idx + search.len()
    val after = json.substring(start).trim()
    if after.starts_with(Q()):
        val rest = after.substring(1)
        val end_opt = rest.index_of(Q())
        var end_idx = -1
        match end_opt:
            Some(i): end_idx = i
            nil: return ""
        if end_idx >= 0:
            return rest.substring(0, end_idx)
    # Non-string values
    var parts: [text] = []
    for ch in after:
        if ch == "," or ch == RB() or ch == "]" or ch == " " or ch == "\n" or ch == "\r":
            break
        parts.push(ch)
    parts.join("")

fn extract_field_raw(json: text, key: text) -> text:
    val search = Q() + key + Q() + ":"
    val idx_opt = json.index_of(search)
    var idx = -1
    match idx_opt:
        Some(i): idx = i
        nil: return "null"
    val start = idx + search.len()
    val after = json.substring(start).trim()
    if after.starts_with(Q()):
        # String value: find closing quote (skip escaped)
        var i2 = 1
        var escaped = false
        while i2 < after.len():
            val ch = after.substring(i2, i2 + 1)
            if escaped:
                escaped = false
            elif ch == "\\":
                escaped = true
            elif ch == Q():
                return after.substring(0, i2 + 1)
            i2 = i2 + 1
        return "null"
    if after.starts_with(LB()) or after.starts_with("["):
        # Nested object or array: find matching close
        var depth = 0
        var i3 = 0
        var in_str = false
        var esc = false
        while i3 < after.len():
            val ch = after.substring(i3, i3 + 1)
            if in_str:
                if esc:
                    esc = false
                elif ch == "\\":
                    esc = true
                elif ch == Q():
                    in_str = false
            else:
                if ch == Q():
                    in_str = true
                elif ch == LB() or ch == "[":
                    depth = depth + 1
                elif ch == RB() or ch == "]":
                    depth = depth - 1
                    if depth == 0:
                        return after.substring(0, i3 + 1)
            i3 = i3 + 1
        return "null"
    # Bare value (number, bool, null)
    var parts: [text] = []
    for ch in after:
        if ch == "," or ch == RB() or ch == "]" or ch == " " or ch == "\n" or ch == "\r" or ch == "\t":
            break
        parts.push(ch)
    val raw = parts.join("")
    if raw == "":
        return "null"
    raw

fn extract_id(json: text) -> text:
    extract_field_raw(json, "id")

fn extract_nested(json: text, key: text) -> text:
    val params = extract_field_raw(json, "params")
    if params == "null":
        return ""
    extract_field(params, key)

fn extract_nested_raw(json: text, key: text) -> text:
    val params = extract_field_raw(json, "params")
    if params == "null":
        return "null"
    extract_field_raw(params, key)

# --- JSON-RPC builders ---

fn jsonrpc_result(id: text, result: text) -> text:
    jo3(jp("jsonrpc", js("2.0")), jp("id", id), jp("result", result))

fn jsonrpc_error(id: text, code: i64, message: text) -> text:
    val err = jo2(jp("code", code.to_string()), jp("message", js(escape_json(message))))
    jo3(jp("jsonrpc", js("2.0")), jp("id", id), jp("error", err))

# --- Tool result helpers ---

fn make_tool_result(id: text, content: text) -> text:
    val text_obj = jo2(jp("type", js("text")), jp("text", js(escape_json(content))))
    val result = jo1(jp("content", "[" + text_obj + "]"))
    jo3(jp("jsonrpc", js("2.0")), jp("id", id), jp("result", result))

fn make_tool_error(id: text, message: text) -> text:
    val text_obj = jo2(jp("type", js("text")), jp("text", js(escape_json(message))))
    var result = LB()
    result = result + jp("content", "[" + text_obj + "]")
    result = result + "," + jp("isError", "true")
    result = result + RB()
    jo3(jp("jsonrpc", js("2.0")), jp("id", id), jp("result", result))

# --- Method detection ---

fn has_method(msg: text, name: text) -> bool:
    msg.contains("\"method\":\"" + name + "\"") or msg.contains("\"method\": \"" + name + "\"")

# --- Stdio transport ---

# Protocol auto-detection
var _USE_JSON_LINES = false

fn _read_line() -> text:
    var result = ""
    while true:
        val ch = stdin_read_char()
        if ch == "":
            if result == "":
                return ""
            return result
        result = result + ch
        if ch == "\n":
            return result

fn _read_chars(count: i64) -> text:
    var result = ""
    var i = 0
    while i < count:
        val ch = stdin_read_char()
        if ch == "":
            break
        result = result + ch
        i = i + 1
    result

fn _strip_line_end(line: text) -> text:
    if line.ends_with("\r\n"):
        return line.substring(0, line.len() - 2)
    if line.ends_with("\n"):
        return line.substring(0, line.len() - 1)
    if line.ends_with("\r"):
        return line.substring(0, line.len() - 1)
    line

fn read_stdin_message() -> text:
    var content_length = 0
    while true:
        var line = _read_line()
        if line == "":
            if content_length > 0:
                break
            return ""
        if line == "\r\n" or line == "\r" or line == "\n":
            if content_length > 0:
                break
            continue
        line = _strip_line_end(line)
        if line.starts_with(LB()):
            _USE_JSON_LINES = true
            return line
        if line.starts_with("Content-Length:"):
            var len_str = line.replace("Content-Length:", "")
            len_str = len_str.trim()
            content_length = int(len_str)
    if content_length <= 0:
        return ""
    _read_chars(content_length)

fn write_stdout_message(body: text):
    val nl = "\n"
    if _USE_JSON_LINES:
        print_raw(body + nl)
    else:
        var header = "Content-Length: " + str(body.len()) + "\r" + nl + "\r" + nl
        print_raw(header)
        print_raw(body)
