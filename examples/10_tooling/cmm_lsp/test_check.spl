# Test: replicate the parser dispatch pattern matching
use cmm_lexer.{lex_cmm_source}
use cmm_tokens.{CmmTokenKind, CmmToken}

val tokens = lex_cmm_source("  &count=0\n")
val tok = tokens[0]

# Test 1: match MacroRef
match tok.kind:
    case CmmTokenKind.MacroRef(name):
        print "1: Matched MacroRef name={name}"
    case _:
        print "1: Did NOT match MacroRef"

# Test 2: nested match (same structure as parser)
match tok.kind:
    case CmmTokenKind.MacroRef(name):
        print "2a: outer matched MacroRef"
        match tokens[1].kind:
            case CmmTokenKind.Assign:
                print "2b: inner matched Assign - SHOULD RETURN HERE"
            case _:
                print "2b: inner did NOT match Assign"
    case _:
        print "2a: outer did NOT match MacroRef"

# Test 3: match on peek_ahead equivalent
val tok1 = tokens[1]
match tok1.kind:
    case CmmTokenKind.Assign:
        print "3: token[1] is Assign"
    case _:
        print "3: token[1] is NOT Assign"

# Test 4: try the exact parser pattern with return
fn test_dispatch(toks: [CmmToken]) -> text:
    val tok = toks[0]
    match tok.kind:
        case CmmTokenKind.MacroRef(name):
            match toks[1].kind:
                case CmmTokenKind.Assign:
                    return "macro_assign:{name}"
                case _: ()
        case _: ()
    "generic_command"

val result = test_dispatch(tokens)
print "4: dispatch result = {result}"
