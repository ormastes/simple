    cmds.push(CmmCommandInfo(full_name: "CLOSE", short_name: "CLOSE", group: "IO", description: "Close file channel", min_version: "all"))
    cmds.push(CmmCommandInfo(full_name: "READ", short_name: "READ", group: "IO", description: "Read from file channel", min_version: "all"))
    cmds.push(CmmCommandInfo(full_name: "WRITE", short_name: "WRITE", group: "IO", description: "Write to file channel", min_version: "all"))
    cmds.push(CmmCommandInfo(full_name: "WRITEB", short_name: "WRITEB", group: "IO", description: "Write binary to file channel", min_version: "2013"))
    cmds.push(CmmCommandInfo(full_name: "APPEND", short_name: "APPEND", group: "IO", description: "Append to file", min_version: "all"))
    cmds.push(CmmCommandInfo(full_name: "PRINT", short_name: "PRINT", group: "IO", description: "Print to output area", min_version: "all"))

    # --- Encryption commands ---
    cmds.push(CmmCommandInfo(full_name: "ENCRYPTPER", short_name: "ENCRYPTPER", group: "Misc", description: "Encrypt PER file", min_version: "2013"))

    # --- Screen commands ---
    cmds.push(CmmCommandInfo(full_name: "SCREEN.display", short_name: "SCREEN", group: "Screen", description: "Control screen update", min_version: "all"))
    cmds.push(CmmCommandInfo(full_name: "SCREEN.ON", short_name: "SCREEN.ON", group: "Screen", description: "Enable screen updates", min_version: "all"))
    cmds.push(CmmCommandInfo(full_name: "SCREEN.OFF", short_name: "SCREEN.OFF", group: "Screen", description: "Disable screen updates", min_version: "all"))

    CmmCommandDB(commands: cmds)

# ---------------------------------------------------------------------------
# Lookup helpers
# ---------------------------------------------------------------------------

# Convert text to lower case for case-insensitive comparison.
# Simple implementation covering ASCII A-Z.
fn to_lower(s: text) -> text:
    var result = ""
    var i = 0
    while i < s.len():
        val ch = s[i:i + 1]
        if ch >= "A" and ch <= "Z":
            result = result + ch.to_lower()
        else:
            result = result + ch
        i = i + 1
    result

# Look up a command by full_name or short_name (case-insensitive).
#
# Returns the first matching CmmCommandInfo, or nil if not found.
fn lookup_command(db: CmmCommandDB, name: text) -> CmmCommandInfo?:
    val lower_name = to_lower(name)
    var i = 0
    while i < db.commands.len():
        val cmd = db.commands[i]
        if to_lower(cmd.full_name) == lower_name:
            return cmd
        if to_lower(cmd.short_name) == lower_name:
            return cmd
        i = i + 1
    nil

# Return all commands whose full_name or short_name starts with prefix
# (case-insensitive).  Used for auto-completion.
fn get_completions(db: CmmCommandDB, prefix: text) -> [CmmCommandInfo]:
    val lower_prefix = to_lower(prefix)
    var results: [CmmCommandInfo] = []
    var i = 0
    while i < db.commands.len():
        val cmd = db.commands[i]
        val lower_full = to_lower(cmd.full_name)
        val lower_short = to_lower(cmd.short_name)
        if starts_with(lower_full, lower_prefix) or starts_with(lower_short, lower_prefix):
            results.push(cmd)
        i = i + 1
    results

# Return all commands belonging to a given group (case-insensitive).
fn get_group_commands(db: CmmCommandDB, group: text) -> [CmmCommandInfo]:
    val lower_group = to_lower(group)
    var results: [CmmCommandInfo] = []
    var i = 0
    while i < db.commands.len():
        val cmd = db.commands[i]
        if to_lower(cmd.group) == lower_group:
            results.push(cmd)
        i = i + 1
    results

# ---------------------------------------------------------------------------
# Internal helpers
# ---------------------------------------------------------------------------

# Check if text starts with a given prefix
fn starts_with(haystack: text, prefix: text) -> bool:
    if prefix.len() > haystack.len():
        return false
    haystack.slice(0, prefix.len()) == prefix
