    cmds.push(CmmCommandInfo(full_name: "PRIVATE", short_name: "PRIVATE", group: "Declaration", description: "Declare private macro", min_version: "2012"))
    cmds.push(CmmCommandInfo(full_name: "ENTRY", short_name: "ENTRY", group: "Declaration", description: "Bind subroutine parameters", min_version: "all"))

    # --- Event commands ---
