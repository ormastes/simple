    cmds.push(CmmCommandInfo(full_name: "SYStem.Up", short_name: "SYS.Up", group: "SYStem", description: "Start debug session", min_version: "all"))
    cmds.push(CmmCommandInfo(full_name: "SYStem.Down", short_name: "SYS.Down", group: "SYStem", description: "Stop debug session", min_version: "all"))
    cmds.push(CmmCommandInfo(full_name: "SYStem.RESet", short_name: "SYS.RESet", group: "SYStem", description: "Reset system", min_version: "all"))
    cmds.push(CmmCommandInfo(full_name: "SYStem.state", short_name: "SYS", group: "SYStem", description: "Show system state window", min_version: "all"))
    cmds.push(CmmCommandInfo(full_name: "SYStem.Option", short_name: "SYS.Option", group: "SYStem", description: "Set system option", min_version: "all"))
    cmds.push(CmmCommandInfo(full_name: "SYStem.MemAccess", short_name: "SYS.MA", group: "SYStem", description: "Set memory access mode", min_version: "all"))

    # --- FLASH commands ---
    cmds.push(CmmCommandInfo(full_name: "FLASH.RESet", short_name: "FLASH.RESet", group: "FLASH", description: "Reset flash configuration", min_version: "all"))
    cmds.push(CmmCommandInfo(full_name: "FLASH.Create", short_name: "FLASH.Create", group: "FLASH", description: "Declare flash area", min_version: "all"))
    cmds.push(CmmCommandInfo(full_name: "FLASH.AUTO", short_name: "FLASH.AUTO", group: "FLASH", description: "Auto program flash", min_version: "all"))
    cmds.push(CmmCommandInfo(full_name: "FLASH.Erase", short_name: "FLASH.Erase", group: "FLASH", description: "Erase flash area", min_version: "all"))
    cmds.push(CmmCommandInfo(full_name: "FLASH.Program", short_name: "FLASH.Program", group: "FLASH", description: "Program flash", min_version: "all"))
    cmds.push(CmmCommandInfo(full_name: "FLASH.ReProgram", short_name: "FLASH.ReProgram", group: "FLASH", description: "Reprogram flash", min_version: "all"))
    cmds.push(CmmCommandInfo(full_name: "FLASH.CLocK", short_name: "FLASH.CLocK", group: "FLASH", description: "Set flash clock", min_version: "all"))

    # --- Break commands ---
    cmds.push(CmmCommandInfo(full_name: "Break.Set", short_name: "B.S", group: "Break", description: "Set breakpoint", min_version: "all"))
    cmds.push(CmmCommandInfo(full_name: "Break.Delete", short_name: "B.D", group: "Break", description: "Delete breakpoint", min_version: "all"))
    cmds.push(CmmCommandInfo(full_name: "Break.List", short_name: "B.L", group: "Break", description: "List breakpoints", min_version: "all"))
    cmds.push(CmmCommandInfo(full_name: "Break.RESet", short_name: "B.RESet", group: "Break", description: "Reset all breakpoints", min_version: "all"))

