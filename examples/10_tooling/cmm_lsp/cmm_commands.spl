    cmds.push(CmmCommandInfo(full_name: "Var.AddWatch", short_name: "V.AddWatch", group: "Var", description: "Add watch expression", min_version: "all"))
    cmds.push(CmmCommandInfo(full_name: "Var.WRITE", short_name: "V.WRITE", group: "Var", description: "Write variable to file", min_version: "all"))

    # --- Trace commands ---
    cmds.push(CmmCommandInfo(full_name: "Trace.LOAD", short_name: "T.LOAD", group: "Trace", description: "Load trace data", min_version: "all"))
