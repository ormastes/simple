    cmds.push(CmmCommandInfo(full_name: "HELP.Index", short_name: "HELP.Index", group: "Misc", description: "Open help index", min_version: "all"))
    cmds.push(CmmCommandInfo(full_name: "RADIX.Classic", short_name: "RADIX.Classic", group: "Misc", description: "Set classic radix mode", min_version: "all"))

    # --- Control flow keywords (treated as commands) ---
    cmds.push(CmmCommandInfo(full_name: "IF", short_name: "IF", group: "Control", description: "Conditional branch", min_version: "all"))
