    cmds.push(CmmCommandInfo(full_name: "WinCLEAR", short_name: "WinCLEAR", group: "Window", description: "Clear window", min_version: "all"))
    cmds.push(CmmCommandInfo(full_name: "WINTABS", short_name: "WINTABS", group: "Window", description: "Set window tab stops", min_version: "all"))

    # --- Mode commands ---
