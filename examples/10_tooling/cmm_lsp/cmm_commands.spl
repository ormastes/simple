# CMM (PRACTICE Script) Command Database
# Command group database for validation and completion in the CMM Language Server.
#
# T32 commands are dot-separated hierarchical tokens with case-insensitive
# matching.  UPPER case letters in a name indicate the minimum abbreviation
# (short form).  Example: SYStem.CPU -> short form SYS.CPU.
#
# Reference: doc/research/cmm_grammar_research_2026-03-10.md (Section 5)

export CmmCommandInfo, CmmCommandDB
export build_command_db, lookup_command, get_completions, get_group_commands

# ---------------------------------------------------------------------------
# Types
# ---------------------------------------------------------------------------

struct CmmCommandInfo:
    full_name: text          # e.g. "Data.dump"
    short_name: text         # e.g. "D.D"
    group: text              # e.g. "Data"
    description: text        # brief description
    min_version: text        # "2012", "2013", "all"

struct CmmCommandDB:
    commands: [CmmCommandInfo]

# ---------------------------------------------------------------------------
# Database builder
# ---------------------------------------------------------------------------

# Build the built-in command database covering the major T32 command groups.
fn build_command_db() -> CmmCommandDB:
    var cmds: [CmmCommandInfo] = []

    # --- Data commands ---
    cmds.push(CmmCommandInfo(full_name: "Data.dump", short_name: "D.D", group: "Data", description: "Display hex dump of memory", min_version: "all"))
    cmds.push(CmmCommandInfo(full_name: "Data.List", short_name: "D.L", group: "Data", description: "Display disassembly listing", min_version: "all"))
    cmds.push(CmmCommandInfo(full_name: "Data.LOAD", short_name: "D.LOAD", group: "Data", description: "Load program file", min_version: "all"))
    cmds.push(CmmCommandInfo(full_name: "Data.LOAD.auto", short_name: "D.LOAD.auto", group: "Data", description: "Auto-detect format and load", min_version: "all"))
    cmds.push(CmmCommandInfo(full_name: "Data.SAVE.Binary", short_name: "D.SAVE.B", group: "Data", description: "Save memory as binary file", min_version: "all"))
    cmds.push(CmmCommandInfo(full_name: "Data.Set", short_name: "D.S", group: "Data", description: "Set memory values", min_version: "all"))
    cmds.push(CmmCommandInfo(full_name: "Data.Test", short_name: "D.Test", group: "Data", description: "Test memory range", min_version: "all"))
    cmds.push(CmmCommandInfo(full_name: "Data.Print", short_name: "D.Print", group: "Data", description: "Print memory to file", min_version: "all"))
