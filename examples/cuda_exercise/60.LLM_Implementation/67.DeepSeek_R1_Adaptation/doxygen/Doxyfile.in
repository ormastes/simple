# Doxyfile for Module 67: DeepSeek R1 Adaptation

PROJECT_NAME           = "Module 67: DeepSeek R1 Adaptation"
PROJECT_NUMBER         = 67
PROJECT_BRIEF          = "GQA, RoPE, and SwiGLU components for DeepSeek R1 architecture"
OUTPUT_DIRECTORY       = @CMAKE_CURRENT_BINARY_DIR@/doxygen
INPUT                  = @CMAKE_CURRENT_SOURCE_DIR@/src
RECURSIVE              = YES
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = YES
EXTRACT_STATIC         = YES
GENERATE_HTML          = YES
GENERATE_LATEX         = NO
HTML_OUTPUT            = html
USE_MDFILE_AS_MAINPAGE = @CMAKE_CURRENT_SOURCE_DIR@/../doxygen/mainpage.md

# Enable markdown support
MARKDOWN_SUPPORT       = YES

# File patterns
FILE_PATTERNS          = *.cpp *.cu *.h *.cuh *.md

# Source browser
SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO

# Graph generation
HAVE_DOT               = YES
CALL_GRAPH             = YES
CALLER_GRAPH           = YES

# Other settings
QUIET                  = NO
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
