PROJECT_NAME           = "@MODULE@"
OUTPUT_DIRECTORY       = "@CMAKE_CURRENT_BINARY_DIR@/docs"
STRIP_FROM_PATH        = "@CMAKE_CURRENT_SOURCE_DIR@"
INPUT                  = "@CMAKE_CURRENT_SOURCE_DIR@/src" "@CMAKE_CURRENT_SOURCE_DIR@/doxygen/mainpage.md"
FILE_PATTERNS          = *.h *.cpp *.cu *.md
RECURSIVE              = YES
GENERATE_HTML          = YES
GENERATE_LATEX         = NO
QUIET                  = YES
EXTRACT_ALL            = YES
MARKDOWN_SUPPORT       = YES
