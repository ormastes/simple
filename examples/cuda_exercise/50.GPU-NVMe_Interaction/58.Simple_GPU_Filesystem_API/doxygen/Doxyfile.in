# Doxyfile for Module 58: Simple Filesystem Layer
PROJECT_NAME           = "Module 58: Simple Filesystem Layer"
PROJECT_BRIEF          = "Node-based LBA filesystem with file operations and C API"
OUTPUT_DIRECTORY       = @CMAKE_CURRENT_BINARY_DIR@/doxygen
INPUT                  = @CMAKE_CURRENT_SOURCE_DIR@/src @CMAKE_CURRENT_SOURCE_DIR@/../doxygen/mainpage.md
RECURSIVE              = YES
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = YES
EXTRACT_STATIC         = YES
GENERATE_HTML          = YES
GENERATE_LATEX         = NO
HTML_OUTPUT            = html
USE_MDFILE_AS_MAINPAGE = @CMAKE_CURRENT_SOURCE_DIR@/../doxygen/mainpage.md
FILE_PATTERNS          = *.h *.hpp *.cpp *.cu *.cuh *.md
EXCLUDE_PATTERNS       = */build/* */test/*
ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = YES
EXPAND_ONLY_PREDEF     = NO
STRIP_CODE_COMMENTS    = NO
SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES
CALL_GRAPH             = YES
CALLER_GRAPH           = YES
HAVE_DOT               = YES
DOT_NUM_THREADS        = 4
EXTRACT_ANON_NSPACES   = YES
