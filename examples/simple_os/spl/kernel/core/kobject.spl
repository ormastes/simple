# Kernel Object - Tagged union of all kernel-managed objects
#
# Every resource managed by the microkernel (endpoints, threads, memory
# frames, page tables, etc.) is represented as a KObject.  Capabilities
# point to KObjects; the reference count tracks how many capabilities
# reference a given object so that the kernel knows when it is safe to
# reclaim the underlying memory.
#
# KObjects are created from untyped memory regions.  The `parent_ptr`
# field records which untyped region was consumed so that retyping
# (memory reclamation) can walk the derivation tree.

use kernel.core.capability_types.{CapType}

# ---------------------------------------------------------------------------
# Kernel object type enum
# ---------------------------------------------------------------------------
enum KObjectType:
    Untyped         # Raw untyped memory — the root of the retyping tree
    Endpoint        # Synchronous IPC endpoint
    Notification    # Asynchronous notification word
    CNode           # Capability node (CSpace tree node)
    Tcb             # Thread control block
    Frame           # Physical memory frame
    PageTable       # Second-level page table
    PageDir         # First-level page directory
    SchedContext    # MCS scheduling context

# ---------------------------------------------------------------------------
# KObject header — stored for every kernel object
# ---------------------------------------------------------------------------
struct KObject:
    obj_type: KObjectType   # Discriminant for the object kind
    ref_count: u32          # Number of capabilities pointing here
    size_bits: u32          # log2 of the object size in bytes
    parent_ptr: u32         # Address of the parent untyped region (0 = root)
    addr: u32               # Base address of this object in physical memory
    is_alive: bool          # False once the object has been destroyed

# ---------------------------------------------------------------------------
# Maximum number of kernel objects tracked globally.
# In a real kernel this would be bounded by available untyped memory; here
# we use a fixed pool for simplicity.
# ---------------------------------------------------------------------------
val KOBJECT_POOL_SIZE: u32 = 1024

# ---------------------------------------------------------------------------
# Global kernel object pool
# ---------------------------------------------------------------------------
struct KObjectPool:
    objects: [KObject; 1024]
    count: u32

# ---------------------------------------------------------------------------
# Create a single kernel object descriptor.
# Starts with ref_count = 1 (the creating capability holds the first ref).
# ---------------------------------------------------------------------------
fn kobject_create(obj_type: KObjectType, addr: u32, size_bits: u32) -> KObject:
    KObject(
        obj_type: obj_type,
        ref_count: 1,
        size_bits: size_bits,
        parent_ptr: 0,
        addr: addr,
        is_alive: true
    )

# ---------------------------------------------------------------------------
# Create a kernel object that was retyped from a parent untyped region.
# ---------------------------------------------------------------------------
fn kobject_create_from(obj_type: KObjectType, addr: u32, size_bits: u32, parent_ptr: u32) -> KObject:
    KObject(
        obj_type: obj_type,
        ref_count: 1,
        size_bits: size_bits,
        parent_ptr: parent_ptr,
        addr: addr,
        is_alive: true
    )

# ---------------------------------------------------------------------------
# Increment the reference count (a new capability was created for this object).
# ---------------------------------------------------------------------------
fn kobject_retain(obj: var KObject):
    obj.ref_count = obj.ref_count + 1

# ---------------------------------------------------------------------------
# Decrement the reference count.  Returns true when the count reaches zero,
# meaning the object can be safely destroyed / reclaimed.
# ---------------------------------------------------------------------------
fn kobject_release(obj: var KObject) -> bool:
    if obj.ref_count == 0:
        return true
    obj.ref_count = obj.ref_count - 1
    if obj.ref_count == 0:
        obj.is_alive = false
        return true
    false

# ---------------------------------------------------------------------------
# Compute the size of the object in bytes from its size_bits.
# ---------------------------------------------------------------------------
fn kobject_size(obj: KObject) -> u32:
    1 as u32 << obj.size_bits

# ---------------------------------------------------------------------------
# Create an empty kernel object pool.
# ---------------------------------------------------------------------------
fn kobject_pool_create() -> KObjectPool:
    var default_obj = KObject(
        obj_type: KObjectType.Untyped,
        ref_count: 0,
        size_bits: 0,
        parent_ptr: 0,
        addr: 0,
        is_alive: false
    )
    KObjectPool(
        objects: [default_obj; 1024],
        count: 0
    )

# ---------------------------------------------------------------------------
# Allocate a new kernel object in the pool.
# Returns the pool index, or None if the pool is full.
# ---------------------------------------------------------------------------
fn kobject_pool_alloc(pool: var KObjectPool, obj_type: KObjectType, addr: u32, size_bits: u32) -> Option<u32>:
    if pool.count >= KOBJECT_POOL_SIZE:
        return Option<u32>.None

    # Find a dead slot (ref_count == 0 and not alive) or use the next index
    for i in 0..KOBJECT_POOL_SIZE:
        if !pool.objects[i].is_alive and pool.objects[i].ref_count == 0:
            pool.objects[i] = kobject_create(obj_type, addr, size_bits)
            pool.count = pool.count + 1
            return Option<u32>.Some(i)

    Option<u32>.None

# ---------------------------------------------------------------------------
# Look up a kernel object by its pool index.
# Returns None if the index is out of range or the object is dead.
# ---------------------------------------------------------------------------
fn kobject_pool_get(pool: KObjectPool, index: u32) -> Option<KObject>:
    if index >= KOBJECT_POOL_SIZE:
        return Option<KObject>.None
    if !pool.objects[index].is_alive:
        return Option<KObject>.None
    Option<KObject>.Some(pool.objects[index])

# ---------------------------------------------------------------------------
# Release a kernel object from the pool (decrement refcount; reclaim if zero).
# Returns true if the object was fully released.
# ---------------------------------------------------------------------------
fn kobject_pool_release(pool: var KObjectPool, index: u32) -> bool:
    if index >= KOBJECT_POOL_SIZE:
        return false
    if !pool.objects[index].is_alive:
        return false
    val freed = kobject_release(pool.objects[index])
    if freed:
        pool.count = pool.count - 1
    freed

# ---------------------------------------------------------------------------
# Map KObjectType to the corresponding CapType for capability creation.
# ---------------------------------------------------------------------------
fn kobject_to_cap_type(obj_type: KObjectType) -> CapType:
    if obj_type == KObjectType.Untyped:
        return CapType.Untyped
    if obj_type == KObjectType.Endpoint:
        return CapType.Endpoint
    if obj_type == KObjectType.Notification:
        return CapType.Notification
    if obj_type == KObjectType.CNode:
        return CapType.CNode
    if obj_type == KObjectType.Tcb:
        return CapType.Tcb
    if obj_type == KObjectType.Frame:
        return CapType.Frame
    if obj_type == KObjectType.PageTable:
        return CapType.PageTable
    if obj_type == KObjectType.PageDir:
        return CapType.PageDir
    if obj_type == KObjectType.SchedContext:
        return CapType.SchedContext
    # Fallback — should not be reached
    CapType.Null
