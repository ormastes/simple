# Kernel Boot - Entry Point
# Called from architecture-specific startup assembly.
# Initializes all kernel subsystems and prints [BOOT OK].

use kernel.core.log.{log_init, log_info}

# kernel_main - Entry point called from assembly startup code
fn kernel_main():
    # Initialize serial output first (via log system)
    log_init()

    # Signal successful boot
    log_info("[BOOT OK]")

    # TODO: Initialize remaining subsystems:
    # - GDT/IDT (x86)
    # - Frame allocator
    # - Paging
    # - Capability system
    # - Scheduler
    # - Root task

    log_info("[BOOT] Init complete, entering idle loop")

    # Idle loop
    while true:
        unsafe:
            asm """
            hlt
            """
