# Syscall Dispatch
# Routes system call numbers to kernel operations.
# Syscalls 0-99 are kernel-level; 100+ are delegated to the POSIX layer.

use kernel.core.log.{log_info}

# Syscall numbers
val SYS_SEND: u32 = 0
val SYS_RECV: u32 = 1
val SYS_CALL: u32 = 2
val SYS_REPLY: u32 = 3
val SYS_YIELD: u32 = 4
val SYS_NBSEND: u32 = 5
val SYS_NBRECV: u32 = 6
val SYS_DEBUG_PRINT: u32 = 7
val SYS_RETYPE: u32 = 8
val SYS_CNODE_COPY: u32 = 9
val SYS_CNODE_MINT: u32 = 10
val SYS_TCB_CONFIGURE: u32 = 11
val SYS_TCB_RESUME: u32 = 12
val SYS_TCB_SET_PRIORITY: u32 = 13
val SYS_IRQ_SET_HANDLER: u32 = 14
val SYS_IRQ_ACK: u32 = 15

# POSIX syscalls start at 100
val SYS_POSIX_BASE: u32 = 100

fn syscall_dispatch(num: u32, a0: u32, a1: u32, a2: u32, a3: u32, a4: u32) -> u32:
    # Delegate POSIX syscalls (100+) to the POSIX layer
    if num >= SYS_POSIX_BASE:
        # POSIX dispatch is handled by posix.posix_syscall.posix_dispatch()
        # The caller (trap handler) should route to posix_dispatch with the
        # current process's PID and scheduler reference.
        return 0

    # Kernel syscall routing
    if num == SYS_YIELD:
        return 0
    if num == SYS_DEBUG_PRINT:
        return 0

    # TODO: implement remaining kernel syscall routing
    0
