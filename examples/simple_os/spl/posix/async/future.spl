# Async Future Primitives
# Defines PollResult, PollValue, and Waker for the async reactor.

# ---------------------------------------------------------------------------
# Poll result enumeration
# ---------------------------------------------------------------------------
enum PollResult:
    Ready       # Operation completed
    Pending     # Operation not yet complete

# ---------------------------------------------------------------------------
# Poll value — combines poll result with optional value and error
# ---------------------------------------------------------------------------
struct PollValue:
    status: PollResult
    value: u32      # The result value (bytes read, etc.), valid when Ready
    error: u32      # errno code if error, 0 for success

# ---------------------------------------------------------------------------
# Waker — mechanism to wake a blocked task
# ---------------------------------------------------------------------------
struct Waker:
    thread_id: u32          # Thread to wake
    notification_bits: u32  # Bits to signal on the notification
    is_valid: bool          # Whether this waker is active

# ---------------------------------------------------------------------------
# Constants
# ---------------------------------------------------------------------------
val WAKER_NONE: u32 = 0xFFFFFFFF

# ---------------------------------------------------------------------------
# Create a Ready result with a successful value.
# ---------------------------------------------------------------------------
fn poll_ready(value: u32) -> PollValue:
    PollValue(
        status: PollResult.Ready,
        value: value,
        error: 0
    )

# ---------------------------------------------------------------------------
# Create a Ready result with an error code.
# ---------------------------------------------------------------------------
fn poll_ready_err(error: u32) -> PollValue:
    PollValue(
        status: PollResult.Ready,
        value: 0,
        error: error
    )

# ---------------------------------------------------------------------------
# Create a Pending result.
# ---------------------------------------------------------------------------
fn poll_pending() -> PollValue:
    PollValue(
        status: PollResult.Pending,
        value: 0,
        error: 0
    )

# ---------------------------------------------------------------------------
# Check if a PollValue is Ready.
# ---------------------------------------------------------------------------
fn poll_is_ready(pv: PollValue) -> bool:
    pv.status == PollResult.Ready

# ---------------------------------------------------------------------------
# Check if a PollValue is Pending.
# ---------------------------------------------------------------------------
fn poll_is_pending(pv: PollValue) -> bool:
    pv.status == PollResult.Pending

# ---------------------------------------------------------------------------
# Create a waker for a given thread and notification bits.
# ---------------------------------------------------------------------------
fn waker_create(thread_id: u32, bits: u32) -> Waker:
    Waker(
        thread_id: thread_id,
        notification_bits: bits,
        is_valid: true
    )

# ---------------------------------------------------------------------------
# Create an invalid/empty waker.
# ---------------------------------------------------------------------------
fn waker_none() -> Waker:
    Waker(
        thread_id: WAKER_NONE,
        notification_bits: 0,
        is_valid: false
    )

# ---------------------------------------------------------------------------
# Check if a waker is valid and active.
# ---------------------------------------------------------------------------
fn waker_is_valid(w: Waker) -> bool:
    w.is_valid
