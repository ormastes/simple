# Open File Description

use posix.vfs.inode.{InodeType}
use posix.errno.{EBADF}

enum OpenFlags:
    ReadOnly
    WriteOnly
    ReadWrite

val O_RDONLY: u32 = 0
val O_WRONLY: u32 = 1
val O_RDWR: u32 = 2
val O_CREAT: u32 = 64
val O_TRUNC: u32 = 512
val O_APPEND: u32 = 1024

struct OpenFile:
    inode_id: u32          # Index into VFS inode table
    fs_id: u32             # Which filesystem owns this inode
    offset: u32            # Current read/write position
    flags: u32             # Open flags (O_RDONLY, etc.)
    is_open: bool          # Whether this slot is in use
    is_directory: bool     # Whether this is an opendir() descriptor
    ref_count: u32         # Reference count for dup()

fn open_file_create(inode_id: u32, fs_id: u32, flags: u32) -> OpenFile:
    OpenFile(
        inode_id: inode_id,
        fs_id: fs_id,
        offset: 0,
        flags: flags,
        is_open: true,
        is_directory: false,
        ref_count: 1
    )

fn open_file_empty() -> OpenFile:
    OpenFile(
        inode_id: 0,
        fs_id: 0,
        offset: 0,
        flags: 0,
        is_open: false,
        is_directory: false,
        ref_count: 0
    )

fn open_file_is_readable(f: OpenFile) -> bool:
    val mode = f.flags & 3
    mode == O_RDONLY or mode == O_RDWR

fn open_file_is_writable(f: OpenFile) -> bool:
    val mode = f.flags & 3
    mode == O_WRONLY or mode == O_RDWR
