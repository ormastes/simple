# Standard I/O Wiring
# Connects file descriptors 0 (stdin), 1 (stdout), 2 (stderr) to /dev/serial.
# Called during POSIX init to set up the standard streams for each process.

use posix.io.fd_table.{FdTable, fd_alloc, fd_alloc_at, MAX_FDS}
use posix.io.file.{OpenFile, open_file_create, O_RDONLY, O_WRONLY}
use posix.vfs.inode.{InodeRef, FS_DEVFS}
use posix.errno.{EBADF}

# ---------------------------------------------------------------------------
# Standard file descriptor numbers
# ---------------------------------------------------------------------------
val STDIN_FD: u32 = 0
val STDOUT_FD: u32 = 1
val STDERR_FD: u32 = 2

# ---------------------------------------------------------------------------
# Wire stdin/stdout/stderr to a device inode.
# Typically called with the /dev/serial or /dev/console device.
# ---------------------------------------------------------------------------
fn stdio_init(fd_table: var FdTable, serial_inode_id: u32):
    # fd 0 = stdin (read-only from serial)
    val stdin_file = open_file_create(serial_inode_id, FS_DEVFS, O_RDONLY)
    fd_alloc_at(fd_table, STDIN_FD, stdin_file)

    # fd 1 = stdout (write-only to serial)
    val stdout_file = open_file_create(serial_inode_id, FS_DEVFS, O_WRONLY)
    fd_alloc_at(fd_table, STDOUT_FD, stdout_file)

    # fd 2 = stderr (write-only to serial)
    val stderr_file = open_file_create(serial_inode_id, FS_DEVFS, O_WRONLY)
    fd_alloc_at(fd_table, STDERR_FD, stderr_file)

# ---------------------------------------------------------------------------
# Check if a file descriptor is one of the standard streams.
# ---------------------------------------------------------------------------
fn is_stdio_fd(fd: u32) -> bool:
    fd == STDIN_FD or fd == STDOUT_FD or fd == STDERR_FD
