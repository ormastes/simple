# POSIX Clock

use posix.errno.{EINVAL}

# ---------------------------------------------------------------------------
# Constants
# ---------------------------------------------------------------------------
val CLOCK_REALTIME: u32 = 0
val CLOCK_MONOTONIC: u32 = 1
val TICKS_PER_SECOND: u32 = 1000    # Assume 1ms per tick

# ---------------------------------------------------------------------------
# Timespec — seconds + nanoseconds pair
# ---------------------------------------------------------------------------
struct Timespec:
    tv_sec: u32
    tv_nsec: u32

# ---------------------------------------------------------------------------
# ClockState — tracks boot time and realtime offset
# ---------------------------------------------------------------------------
struct ClockState:
    boot_ticks: u64            # Ticks at boot time
    realtime_offset: u64       # Offset to convert monotonic to realtime

# ---------------------------------------------------------------------------
# Create a zero-valued timespec.
# ---------------------------------------------------------------------------
fn timespec_zero() -> Timespec:
    Timespec(tv_sec: 0, tv_nsec: 0)

# ---------------------------------------------------------------------------
# Create a timespec with the given seconds and nanoseconds.
# ---------------------------------------------------------------------------
fn timespec_create(sec: u32, nsec: u32) -> Timespec:
    Timespec(tv_sec: sec, tv_nsec: nsec)

# ---------------------------------------------------------------------------
# Convert a timespec to kernel ticks.
# Each tick is 1ms (TICKS_PER_SECOND = 1000).
# nsec is in nanoseconds, so divide by 1_000_000 to get milliseconds.
# ---------------------------------------------------------------------------
fn timespec_to_ticks(ts: Timespec) -> u64:
    val sec_ticks = ts.tv_sec as u64 * TICKS_PER_SECOND as u64
    val nsec_ticks = ts.tv_nsec as u64 / 1000000
    sec_ticks + nsec_ticks

# ---------------------------------------------------------------------------
# Convert kernel ticks to a timespec.
# ---------------------------------------------------------------------------
fn ticks_to_timespec(ticks: u64) -> Timespec:
    val sec = (ticks / TICKS_PER_SECOND as u64) as u32
    val remaining = (ticks % TICKS_PER_SECOND as u64) as u32
    val nsec = remaining * 1000000
    Timespec(tv_sec: sec, tv_nsec: nsec)

# ---------------------------------------------------------------------------
# Create a default clock state (boot at tick 0, no realtime offset).
# ---------------------------------------------------------------------------
fn clock_state_create() -> ClockState:
    ClockState(boot_ticks: 0, realtime_offset: 0)

# ---------------------------------------------------------------------------
# Get the current time for the given clock_id.
# current_ticks is the raw tick count from the kernel timer.
# Returns EINVAL for unknown clock ids.
# ---------------------------------------------------------------------------
fn clock_gettime(state: ClockState, clock_id: u32, current_ticks: u64) -> Result<Timespec, u32>:
    if clock_id == CLOCK_MONOTONIC:
        val elapsed = current_ticks - state.boot_ticks
        val ts = ticks_to_timespec(elapsed)
        return Result<Timespec, u32>.Ok(ts)

    if clock_id == CLOCK_REALTIME:
        val elapsed = current_ticks - state.boot_ticks
        val realtime_ticks = elapsed + state.realtime_offset
        val ts = ticks_to_timespec(realtime_ticks)
        return Result<Timespec, u32>.Ok(ts)

    Result<Timespec, u32>.Err(EINVAL)

# ---------------------------------------------------------------------------
# Get the resolution for the given clock_id.
# All clocks have 1ms resolution (1 tick = 1ms = 1_000_000 ns).
# ---------------------------------------------------------------------------
fn clock_getres(clock_id: u32) -> Result<Timespec, u32>:
    if clock_id == CLOCK_REALTIME:
        return Result<Timespec, u32>.Ok(Timespec(tv_sec: 0, tv_nsec: 1000000))

    if clock_id == CLOCK_MONOTONIC:
        return Result<Timespec, u32>.Ok(Timespec(tv_sec: 0, tv_nsec: 1000000))

    Result<Timespec, u32>.Err(EINVAL)
