# POSIX Process

use posix.io.fd_table.{FdTable, fd_table_create, MAX_FDS}
use posix.errno.{ESRCH}

val MAX_SIGNALS: u32 = 32

enum ProcessState:
    Created
    Running
    Sleeping
    Stopped
    Zombie

struct Process:
    pid: u32
    ppid: u32                  # Parent PID
    tcb_id: u32                # Kernel thread id
    state: ProcessState
    exit_code: u32
    fd_table: FdTable
    signal_mask: u32           # Bitmask of blocked signals
    signal_pending: u32        # Bitmask of pending signals
    signal_handlers: [u32; 32] # Handler addresses per signal
    heap_start: u32            # Start of heap region
    heap_current: u32          # Current brk position
    name: text
    cwd: text                  # Current working directory

fn process_create(pid: u32, ppid: u32, tcb_id: u32, name: text) -> Process:
    Process(
        pid: pid,
        ppid: ppid,
        tcb_id: tcb_id,
        state: ProcessState.Created,
        exit_code: 0,
        fd_table: fd_table_create(),
        signal_mask: 0,
        signal_pending: 0,
        signal_handlers: [0 as u32; 32],
        heap_start: 0,
        heap_current: 0,
        name: name,
        cwd: "/"
    )

fn process_set_heap(proc: var Process, start: u32):
    proc.heap_start = start
    proc.heap_current = start

fn process_is_alive(proc: Process) -> bool:
    proc.state != ProcessState.Zombie and proc.state != ProcessState.Stopped
