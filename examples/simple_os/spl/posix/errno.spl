# POSIX Error Codes

# Standard POSIX errno constants
val EPERM: u32 = 1
val ENOENT: u32 = 2
val ESRCH: u32 = 3
val EINTR: u32 = 4
val EIO: u32 = 5
val ENXIO: u32 = 6
val E2BIG: u32 = 7
val ENOEXEC: u32 = 8
val EBADF: u32 = 9
val ECHILD: u32 = 10
val EAGAIN: u32 = 11
val ENOMEM: u32 = 12
val EACCES: u32 = 13
val EFAULT: u32 = 14
val EBUSY: u32 = 16
val EEXIST: u32 = 17
val EXDEV: u32 = 18
val ENODEV: u32 = 19
val ENOTDIR: u32 = 20
val EISDIR: u32 = 21
val EINVAL: u32 = 22
val ENFILE: u32 = 23
val EMFILE: u32 = 24
val ENOTTY: u32 = 25
val EFBIG: u32 = 27
val ENOSPC: u32 = 28
val ESPIPE: u32 = 29
val EROFS: u32 = 30
val EPIPE: u32 = 32
val ERANGE: u32 = 34
val ENAMETOOLONG: u32 = 36
val ENOSYS: u32 = 38
val ENOTEMPTY: u32 = 39
val ELOOP: u32 = 40
val EOVERFLOW: u32 = 75
val EBADFD: u32 = 77
val ENOTSUP: u32 = 95

# Returns the name string for a given POSIX error code.
fn errno_name(code: u32) -> text:
    if code == EPERM:
        return "EPERM"
    if code == ENOENT:
        return "ENOENT"
    if code == ESRCH:
        return "ESRCH"
    if code == EINTR:
        return "EINTR"
    if code == EIO:
        return "EIO"
    if code == ENXIO:
        return "ENXIO"
    if code == E2BIG:
        return "E2BIG"
    if code == ENOEXEC:
        return "ENOEXEC"
    if code == EBADF:
        return "EBADF"
    if code == ECHILD:
        return "ECHILD"
    if code == EAGAIN:
        return "EAGAIN"
    if code == ENOMEM:
        return "ENOMEM"
    if code == EACCES:
        return "EACCES"
    if code == EFAULT:
        return "EFAULT"
    if code == EBUSY:
        return "EBUSY"
    if code == EEXIST:
        return "EEXIST"
    if code == EXDEV:
        return "EXDEV"
    if code == ENODEV:
        return "ENODEV"
    if code == ENOTDIR:
        return "ENOTDIR"
    if code == EISDIR:
        return "EISDIR"
    if code == EINVAL:
        return "EINVAL"
    if code == ENFILE:
        return "ENFILE"
    if code == EMFILE:
        return "EMFILE"
    if code == ENOTTY:
        return "ENOTTY"
    if code == EFBIG:
        return "EFBIG"
    if code == ENOSPC:
        return "ENOSPC"
    if code == ESPIPE:
        return "ESPIPE"
    if code == EROFS:
        return "EROFS"
    if code == EPIPE:
        return "EPIPE"
    if code == ERANGE:
        return "ERANGE"
    if code == ENAMETOOLONG:
        return "ENAMETOOLONG"
    if code == ENOSYS:
        return "ENOSYS"
    if code == ENOTEMPTY:
        return "ENOTEMPTY"
    if code == ELOOP:
        return "ELOOP"
    if code == EOVERFLOW:
        return "EOVERFLOW"
    if code == EBADFD:
        return "EBADFD"
    if code == ENOTSUP:
        return "ENOTSUP"
    return "EUNKNOWN"

# Returns a short human-readable description for a given POSIX error code.
fn errno_message(code: u32) -> text:
    if code == EPERM:
        return "Operation not permitted"
    if code == ENOENT:
        return "No such file or directory"
    if code == ESRCH:
        return "No such process"
    if code == EINTR:
        return "Interrupted system call"
    if code == EIO:
        return "Input/output error"
    if code == ENXIO:
        return "No such device or address"
    if code == E2BIG:
        return "Argument list too long"
    if code == ENOEXEC:
        return "Exec format error"
    if code == EBADF:
        return "Bad file descriptor"
    if code == ECHILD:
        return "No child processes"
    if code == EAGAIN:
        return "Resource temporarily unavailable"
    if code == ENOMEM:
        return "Cannot allocate memory"
    if code == EACCES:
        return "Permission denied"
    if code == EFAULT:
        return "Bad address"
    if code == EBUSY:
        return "Device or resource busy"
    if code == EEXIST:
        return "File exists"
    if code == EXDEV:
        return "Invalid cross-device link"
    if code == ENODEV:
        return "No such device"
    if code == ENOTDIR:
        return "Not a directory"
    if code == EISDIR:
        return "Is a directory"
    if code == EINVAL:
        return "Invalid argument"
    if code == ENFILE:
        return "Too many open files in system"
    if code == EMFILE:
        return "Too many open files"
    if code == ENOTTY:
        return "Inappropriate ioctl for device"
    if code == EFBIG:
        return "File too large"
    if code == ENOSPC:
        return "No space left on device"
    if code == ESPIPE:
        return "Illegal seek"
    if code == EROFS:
        return "Read-only file system"
    if code == EPIPE:
        return "Broken pipe"
    if code == ERANGE:
        return "Numerical result out of range"
    if code == ENAMETOOLONG:
        return "File name too long"
    if code == ENOSYS:
        return "Function not implemented"
    if code == ENOTEMPTY:
        return "Directory not empty"
    if code == ELOOP:
        return "Too many levels of symbolic links"
    if code == EOVERFLOW:
        return "Value too large for defined data type"
    if code == EBADFD:
        return "File descriptor in bad state"
    if code == ENOTSUP:
        return "Operation not supported"
    return "Unknown error"
