# Hello World - Simplest User Task
#
# The most minimal user-space process: prints a greeting via the kernel
# debug console and then idles forever. Demonstrates that a user task
# can be created, scheduled, and communicate with the kernel.
#
# This task does not use any IPC endpoints. It only exercises the
# sys_debug_print syscall (which bypasses the serial driver and writes
# directly to the kernel's serial output for debugging purposes).

use user.libos.syscall.{sys_debug_print, sys_yield}

# ---------------------------------------------------------------------------
# Main entry point
# ---------------------------------------------------------------------------
fn main():
    sys_debug_print("[HELLO] Hello from user space!")
    sys_debug_print("[HELLO] This is the simplest possible user task")
    sys_debug_print("[HELLO] Running on the simple_os microkernel")

    # Print some system information
    sys_debug_print("[HELLO] Task started successfully")
    sys_debug_print("[HELLO] Using sys_debug_print for kernel console output")

    # Count a few iterations to prove the scheduler is working
    var count = 0
    while count < 5:
        sys_debug_print("[HELLO] Heartbeat {count}")
        count = count + 1
        # Yield to let other tasks run between heartbeats
        sys_yield()

    sys_debug_print("[HELLO] Heartbeat complete, entering idle loop")

    # Idle forever - the task stays alive but consumes no CPU
    # (sys_yield gives up the timeslice to other runnable tasks)
    while true:
        sys_yield()
