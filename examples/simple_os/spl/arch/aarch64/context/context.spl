# AArch64 CPU Register State / Thread Context
#
# Defines the saved register state for context switching between threads.
# Used by the context switch assembly (switch.S) and the scheduler.

# ---------- SPSR_EL1 mode values ----------

val SPSR_EL1H: u64 = 0x05     # EL1h: kernel mode, SP_EL1
val SPSR_EL0T: u64 = 0x00     # EL0t: user mode, SP_EL0

# DAIF mask bits
val SPSR_D: u64 = 0x200       # Debug mask
val SPSR_A: u64 = 0x100       # SError mask
val SPSR_I: u64 = 0x080       # IRQ mask
val SPSR_F: u64 = 0x040       # FIQ mask

# ---------- register state ----------

# Full saved register set for context switch.
@repr(C)
struct RegisterState:
    # General-purpose registers
    x0: u64
    x1: u64
    x2: u64
    x3: u64
    x4: u64
    x5: u64
    x6: u64
    x7: u64
    x8: u64
    x9: u64
    x10: u64
    x11: u64
    x12: u64
    x13: u64
    x14: u64
    x15: u64
    x16: u64
    x17: u64
    x18: u64
    x19: u64
    x20: u64
    x21: u64
    x22: u64
    x23: u64
    x24: u64
    x25: u64
    x26: u64
    x27: u64
    x28: u64
    x29: u64    # frame pointer
    x30: u64    # link register

    # Stack pointer
    sp: u64

    # Exception return state
    elr_el1: u64
    spsr_el1: u64

# ---------- public API ----------

# Create initial state for a kernel-mode thread (EL1h)
fn context_create_kernel(entry_point: u64, stack_top: u64) -> RegisterState:
    RegisterState(
        x0: 0, x1: 0, x2: 0, x3: 0, x4: 0, x5: 0, x6: 0, x7: 0,
        x8: 0, x9: 0, x10: 0, x11: 0, x12: 0, x13: 0, x14: 0, x15: 0,
        x16: 0, x17: 0, x18: 0, x19: 0, x20: 0, x21: 0, x22: 0, x23: 0,
        x24: 0, x25: 0, x26: 0, x27: 0, x28: 0,
        x29: stack_top,
        x30: entry_point,
        sp: stack_top,
        elr_el1: entry_point,
        spsr_el1: SPSR_EL1H
    )

# Create initial state for a user-mode thread (EL0t)
fn context_create_user(entry_point: u64, stack_top: u64) -> RegisterState:
    RegisterState(
        x0: 0, x1: 0, x2: 0, x3: 0, x4: 0, x5: 0, x6: 0, x7: 0,
        x8: 0, x9: 0, x10: 0, x11: 0, x12: 0, x13: 0, x14: 0, x15: 0,
        x16: 0, x17: 0, x18: 0, x19: 0, x20: 0, x21: 0, x22: 0, x23: 0,
        x24: 0, x25: 0, x26: 0, x27: 0, x28: 0,
        x29: stack_top,
        x30: entry_point,
        sp: stack_top,
        elr_el1: entry_point,
        spsr_el1: SPSR_EL0T
    )

# Create a register state for either kernel or user mode
fn context_create(entry_point: u64, stack_top: u64, is_user: bool) -> RegisterState:
    if is_user:
        return context_create_user(entry_point, stack_top)
    context_create_kernel(entry_point, stack_top)

# Set the first argument (x0)
fn context_set_arg(regs: RegisterState, arg: u64) -> RegisterState:
    RegisterState(
        x0: arg, x1: regs.x1, x2: regs.x2, x3: regs.x3,
        x4: regs.x4, x5: regs.x5, x6: regs.x6, x7: regs.x7,
        x8: regs.x8, x9: regs.x9, x10: regs.x10, x11: regs.x11,
        x12: regs.x12, x13: regs.x13, x14: regs.x14, x15: regs.x15,
        x16: regs.x16, x17: regs.x17, x18: regs.x18, x19: regs.x19,
        x20: regs.x20, x21: regs.x21, x22: regs.x22, x23: regs.x23,
        x24: regs.x24, x25: regs.x25, x26: regs.x26, x27: regs.x27,
        x28: regs.x28, x29: regs.x29, x30: regs.x30,
        sp: regs.sp, elr_el1: regs.elr_el1, spsr_el1: regs.spsr_el1
    )

# Set the program counter (ELR_EL1)
fn context_set_pc(regs: RegisterState, pc: u64) -> RegisterState:
    RegisterState(
        x0: regs.x0, x1: regs.x1, x2: regs.x2, x3: regs.x3,
        x4: regs.x4, x5: regs.x5, x6: regs.x6, x7: regs.x7,
        x8: regs.x8, x9: regs.x9, x10: regs.x10, x11: regs.x11,
        x12: regs.x12, x13: regs.x13, x14: regs.x14, x15: regs.x15,
        x16: regs.x16, x17: regs.x17, x18: regs.x18, x19: regs.x19,
        x20: regs.x20, x21: regs.x21, x22: regs.x22, x23: regs.x23,
        x24: regs.x24, x25: regs.x25, x26: regs.x26, x27: regs.x27,
        x28: regs.x28, x29: regs.x29, x30: regs.x30,
        sp: regs.sp, elr_el1: pc, spsr_el1: regs.spsr_el1
    )

# Set the stack pointer
fn context_set_sp(regs: RegisterState, new_sp: u64) -> RegisterState:
    RegisterState(
        x0: regs.x0, x1: regs.x1, x2: regs.x2, x3: regs.x3,
        x4: regs.x4, x5: regs.x5, x6: regs.x6, x7: regs.x7,
        x8: regs.x8, x9: regs.x9, x10: regs.x10, x11: regs.x11,
        x12: regs.x12, x13: regs.x13, x14: regs.x14, x15: regs.x15,
        x16: regs.x16, x17: regs.x17, x18: regs.x18, x19: regs.x19,
        x20: regs.x20, x21: regs.x21, x22: regs.x22, x23: regs.x23,
        x24: regs.x24, x25: regs.x25, x26: regs.x26, x27: regs.x27,
        x28: regs.x28, x29: regs.x29, x30: regs.x30,
        sp: new_sp, elr_el1: regs.elr_el1, spsr_el1: regs.spsr_el1
    )

# Set multiple argument registers (x0, x1, x2) for IPC
fn context_set_args(regs: RegisterState, arg0: u64, arg1: u64, arg2: u64) -> RegisterState:
    RegisterState(
        x0: arg0, x1: arg1, x2: arg2, x3: regs.x3,
        x4: regs.x4, x5: regs.x5, x6: regs.x6, x7: regs.x7,
        x8: regs.x8, x9: regs.x9, x10: regs.x10, x11: regs.x11,
        x12: regs.x12, x13: regs.x13, x14: regs.x14, x15: regs.x15,
        x16: regs.x16, x17: regs.x17, x18: regs.x18, x19: regs.x19,
        x20: regs.x20, x21: regs.x21, x22: regs.x22, x23: regs.x23,
        x24: regs.x24, x25: regs.x25, x26: regs.x26, x27: regs.x27,
        x28: regs.x28, x29: regs.x29, x30: regs.x30,
        sp: regs.sp, elr_el1: regs.elr_el1, spsr_el1: regs.spsr_el1
    )

# Check if context is user mode
fn context_is_user(regs: RegisterState) -> bool:
    (regs.spsr_el1 & 0x0F) == 0   # EL0t = M[3:0] = 0000
