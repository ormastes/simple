# AArch64 HAL Implementation
#
# Maps the generic Hal trait to AArch64-specific drivers:
#   serial  -> PL011 UART (MMIO at 0x09000000)
#   timer   -> AArch64 Generic Timer (CNTP_CTL_EL0)
#   mmu     -> 4-level AArch64 page tables
#   irq     -> msr daifclr/daifset instructions

use arch.hal.Hal
use arch.aarch64.io.uart.{uart_init, uart_putc, uart_print}
use arch.aarch64.boot.timer.{timer_init, timer_get_ticks, timer_get_ms}
use arch.aarch64.mm.mmu.{mmu_init}
use arch.aarch64.mm.paging.{paging_init, paging_map, paging_unmap}
use arch.aarch64.context.context.{RegisterState}

# ---------- HAL trait implementation ----------

struct Aarch64Hal:
    pass

impl Hal for Aarch64Hal:
    fn serial_init():
        uart_init()

    fn serial_putc(c: u8):
        uart_putc(c as u32)

    fn serial_write(s: String):
        uart_print(s)

    fn timer_init(freq_hz: u32):
        timer_init()

    fn timer_ticks() -> u64:
        timer_get_ticks()

    fn irq_enable():
        asm """
            msr daifclr, #0xf
        """

    fn irq_disable():
        asm """
            msr daifset, #0xf
        """

    fn context_switch(old: var RegisterState, new_ctx: RegisterState):
        # Delegated to assembly in switch.S
        pass

    fn mmu_map(virt: u32, phys: u32, size: u32, flags: u32):
        paging_map(virt as u64, phys as u64, flags as u64)

    fn mmu_unmap(virt: u32, size: u32):
        paging_unmap(virt as u64)

    fn halt():
        asm """
            wfe
        """
