# Hardware Abstraction Layer Trait
# Each architecture implements this trait to provide platform-specific operations.

trait Hal:
    fn serial_init()
    fn serial_putc(c: u8)
    fn serial_write(s: String)
    fn timer_init(freq_hz: u32)
    fn timer_ticks() -> u64
    fn irq_enable()
    fn irq_disable()
    fn context_switch(old: var RegisterState, new_ctx: RegisterState)
    fn mmu_map(virt: u32, phys: u32, size: u32, flags: u32)
    fn mmu_unmap(virt: u32, size: u32)
    fn halt()
