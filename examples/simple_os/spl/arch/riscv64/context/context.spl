# RISC-V 64-bit CPU Register State / Thread Context
#
# Defines the saved register state for context switching between threads.
# Used by the context switch assembly (switch.S) and the scheduler.
#
# RISC-V calling convention:
#   Callee-saved: s0-s11, sp, ra
#   Caller-saved: t0-t6, a0-a7
#   Special: zero(x0), gp(x3), tp(x4)

# ---------- mstatus.MPP field values ----------

val MPP_U: u64 = 0x0000       # User mode (MPP = 00)
val MPP_S: u64 = 0x0800       # Supervisor mode (MPP = 01)
val MPP_M: u64 = 0x1800       # Machine mode (MPP = 11)
val MPP_MASK: u64 = 0x1800

# mstatus bits
val MSTATUS_MPIE: u64 = 0x0080   # Previous Machine Interrupt Enable
val MSTATUS_MIE: u64 = 0x0008    # Machine Interrupt Enable

# ---------- register state ----------

# Full saved register set for a thread / context switch.
# Layout matches context_switch in switch.S.
@repr(C)
struct RegisterState:
    # Return address / program counter
    ra: u64        # x1
    # Stack pointer
    sp: u64        # x2
    # Callee-saved registers
    s0: u64        # x8  / fp
    s1: u64        # x9
    s2: u64        # x18
    s3: u64        # x19
    s4: u64        # x20
    s5: u64        # x21
    s6: u64        # x22
    s7: u64        # x23
    s8: u64        # x24
    s9: u64        # x25
    s10: u64       # x26
    s11: u64       # x27
    # Argument / return registers
    a0: u64        # x10
    a1: u64        # x11
    a2: u64        # x12
    a3: u64        # x13
    a4: u64        # x14
    a5: u64        # x15
    a6: u64        # x16
    a7: u64        # x17
    # Thread pointer / global pointer
    tp: u64        # x4
    gp: u64        # x3
    # Status and program counter CSRs
    mstatus: u64
    mepc: u64

# ---------- public API ----------

# Create an initial register state for a new kernel (M-mode) thread.
# entry_point: address of the function to start executing
# stack_top:   top of the thread's kernel stack
fn context_create_kernel(entry_point: u64, stack_top: u64) -> RegisterState:
    RegisterState(
        ra: entry_point,
        sp: stack_top,
        s0: stack_top,
        s1: 0,
        s2: 0,
        s3: 0,
        s4: 0,
        s5: 0,
        s6: 0,
        s7: 0,
        s8: 0,
        s9: 0,
        s10: 0,
        s11: 0,
        a0: 0,
        a1: 0,
        a2: 0,
        a3: 0,
        a4: 0,
        a5: 0,
        a6: 0,
        a7: 0,
        tp: 0,
        gp: 0,
        mstatus: MSTATUS_MPIE | MPP_M,
        mepc: entry_point
    )

# Create an initial register state for a new user (U-mode) thread.
# entry_point: user-space entry address
# stack_top:   top of the user-space stack
fn context_create_user(entry_point: u64, stack_top: u64) -> RegisterState:
    RegisterState(
        ra: entry_point,
        sp: stack_top,
        s0: stack_top,
        s1: 0,
        s2: 0,
        s3: 0,
        s4: 0,
        s5: 0,
        s6: 0,
        s7: 0,
        s8: 0,
        s9: 0,
        s10: 0,
        s11: 0,
        a0: 0,
        a1: 0,
        a2: 0,
        a3: 0,
        a4: 0,
        a5: 0,
        a6: 0,
        a7: 0,
        tp: 0,
        gp: 0,
        mstatus: MSTATUS_MPIE | MPP_U,
        mepc: entry_point
    )

# Create a register state for either kernel or user mode
fn context_create(entry_point: u64, stack_top: u64, is_user: bool) -> RegisterState:
    if is_user:
        return context_create_user(entry_point, stack_top)
    context_create_kernel(entry_point, stack_top)

# Set argument registers (a0, a1, a2) for passing data to a new context
fn context_set_args(regs: RegisterState, arg0: u64, arg1: u64, arg2: u64) -> RegisterState:
    RegisterState(
        ra: regs.ra,
        sp: regs.sp,
        s0: regs.s0,
        s1: regs.s1,
        s2: regs.s2,
        s3: regs.s3,
        s4: regs.s4,
        s5: regs.s5,
        s6: regs.s6,
        s7: regs.s7,
        s8: regs.s8,
        s9: regs.s9,
        s10: regs.s10,
        s11: regs.s11,
        a0: arg0,
        a1: arg1,
        a2: arg2,
        a3: regs.a3,
        a4: regs.a4,
        a5: regs.a5,
        a6: regs.a6,
        a7: regs.a7,
        tp: regs.tp,
        gp: regs.gp,
        mstatus: regs.mstatus,
        mepc: regs.mepc
    )

# Set the program counter (mepc) in a register state
fn context_set_pc(regs: RegisterState, pc: u64) -> RegisterState:
    RegisterState(
        ra: pc,
        sp: regs.sp,
        s0: regs.s0,
        s1: regs.s1,
        s2: regs.s2,
        s3: regs.s3,
        s4: regs.s4,
        s5: regs.s5,
        s6: regs.s6,
        s7: regs.s7,
        s8: regs.s8,
        s9: regs.s9,
        s10: regs.s10,
        s11: regs.s11,
        a0: regs.a0,
        a1: regs.a1,
        a2: regs.a2,
        a3: regs.a3,
        a4: regs.a4,
        a5: regs.a5,
        a6: regs.a6,
        a7: regs.a7,
        tp: regs.tp,
        gp: regs.gp,
        mstatus: regs.mstatus,
        mepc: pc
    )

# Set the stack pointer in a register state
fn context_set_sp(regs: RegisterState, sp: u64) -> RegisterState:
    RegisterState(
        ra: regs.ra,
        sp: sp,
        s0: regs.s0,
        s1: regs.s1,
        s2: regs.s2,
        s3: regs.s3,
        s4: regs.s4,
        s5: regs.s5,
        s6: regs.s6,
        s7: regs.s7,
        s8: regs.s8,
        s9: regs.s9,
        s10: regs.s10,
        s11: regs.s11,
        a0: regs.a0,
        a1: regs.a1,
        a2: regs.a2,
        a3: regs.a3,
        a4: regs.a4,
        a5: regs.a5,
        a6: regs.a6,
        a7: regs.a7,
        tp: regs.tp,
        gp: regs.gp,
        mstatus: regs.mstatus,
        mepc: regs.mepc
    )

# Check if a register state is for user mode (MPP == 0)
fn context_is_user(regs: RegisterState) -> bool:
    (regs.mstatus & MPP_MASK) == 0
