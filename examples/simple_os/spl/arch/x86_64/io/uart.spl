# x86_64 UART (COM1) Serial Driver
#
# Full COM1 serial port driver for kernel debug output.
# 115200 baud, 8N1 configuration.
# Identical to x86 version - UART is I/O-port based, no 64-bit changes needed.
#
# Usage:
#   serial_init()
#   serial_println("Hello from simple_os x86_64!")

# ---------- local port I/O helpers ----------

fn outb(port: i32, value: i32):
    asm """
        mov dx, {port}
        mov al, {value}
        out dx, al
    """

fn inb(port: i32) -> i32:
    var result = 0
    asm """
        mov dx, {port}
        in al, dx
        movzx eax, al
        mov {result}, eax
    """
    result

fn io_wait():
    outb(0x80, 0)

# ---------- constants ----------

# COM port base addresses
val COM1: i32 = 0x3F8
val COM2: i32 = 0x2F8

# UART register offsets
val UART_DATA: i32 = 0
val UART_IER: i32 = 1
val UART_FCR: i32 = 2
val UART_LCR: i32 = 3
val UART_MCR: i32 = 4
val UART_LSR: i32 = 5
val UART_MSR: i32 = 6
val UART_SCRATCH: i32 = 7

# Divisor latch (when DLAB set)
val UART_DLL: i32 = 0
val UART_DLH: i32 = 1

# Line Status Register bits
val LSR_DATA_READY: i32 = 0x01
val LSR_OVERRUN: i32 = 0x02
val LSR_PARITY_ERR: i32 = 0x04
val LSR_FRAMING_ERR: i32 = 0x08
val LSR_BREAK: i32 = 0x10
val LSR_THRE: i32 = 0x20
val LSR_TEMT: i32 = 0x40

# Line Control Register
val LCR_DLAB: i32 = 0x80
val LCR_8N1: i32 = 0x03

# Baud rate divisors (base clock 115200)
val BAUD_115200: i32 = 1
val BAUD_57600: i32 = 2
val BAUD_38400: i32 = 3
val BAUD_9600: i32 = 12

# ---------- global state ----------

var g_port: i32 = COM1
var g_initialized: bool = false

# ---------- public API ----------

# Initialize COM1 at 115200 baud, 8N1
fn serial_init():
    if g_initialized:
        return
    serial_init_port(COM1, BAUD_115200)

# Initialize a specific port with a given baud divisor
fn serial_init_port(port: i32, baud_divisor: i32):
    g_port = port

    # Disable all interrupts
    outb(port + UART_IER, 0x00)

    # Enable DLAB to set baud rate
    outb(port + UART_LCR, LCR_DLAB)

    # Set divisor (low / high bytes)
    outb(port + UART_DLL, baud_divisor & 0xFF)
    outb(port + UART_DLH, (baud_divisor >> 8) & 0xFF)

    # 8 data bits, no parity, 1 stop bit  --  clears DLAB
    outb(port + UART_LCR, LCR_8N1)

    # Enable FIFO, clear TX/RX, 14-byte threshold
    outb(port + UART_FCR, 0xC7)

    # RTS/DSR set, IRQs enabled via MCR
    outb(port + UART_MCR, 0x0B)

    # Loopback self-test
    outb(port + UART_MCR, 0x1E)
    outb(port + UART_DATA, 0xAE)
    val echo = inb(port + UART_DATA)
    # If echo != 0xAE the chip is faulty, but QEMU always passes

    # Back to normal operation
    outb(port + UART_MCR, 0x0F)

    g_initialized = true

# Check if transmit holding register is empty
fn serial_is_tx_empty() -> bool:
    (inb(g_port + UART_LSR) & LSR_THRE) != 0

# Spin until TX buffer is ready
fn serial_wait_tx():
    while not serial_is_tx_empty():
        pass

# Check whether received data is available
fn serial_has_data() -> bool:
    (inb(g_port + UART_LSR) & LSR_DATA_READY) != 0

# Write a single byte to serial
fn serial_write(byte: i32):
    if not g_initialized:
        serial_init()
    serial_wait_tx()
    outb(g_port + UART_DATA, byte)

# Read a single byte (blocks until data available)
fn serial_read() -> i32:
    if not g_initialized:
        serial_init()
    while not serial_has_data():
        pass
    inb(g_port + UART_DATA)

# Print a string
fn serial_print(s: text):
    if not g_initialized:
        serial_init()
    for i in 0..s.len():
        val ch = s.char_at(i)
        serial_write(ch)

# Print a string followed by CR+LF
fn serial_println(s: text):
    serial_print(s)
    serial_write(0x0D)
    serial_write(0x0A)
