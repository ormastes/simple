# ARM32 MMU Control (CP15 SCTLR, TTBR, DACR, TLB)
#
# Functions for configuring the ARMv7 MMU via CP15 coprocessor registers:
#   c1 (SCTLR)  - System Control (M bit = MMU enable)
#   c2 (TTBR0)  - Translation Table Base Register 0
#   c2 (TTBR1)  - Translation Table Base Register 1
#   c2 (TTBCR)  - Translation Table Base Control
#   c3 (DACR)   - Domain Access Control
#   c8          - TLB maintenance

# ---------- SCTLR bits ----------

val SCTLR_M: u32 = 0x00000001    # MMU enable
val SCTLR_A: u32 = 0x00000002    # Alignment fault enable
val SCTLR_C: u32 = 0x00000004    # Data cache enable
val SCTLR_Z: u32 = 0x00000800    # Branch prediction enable
val SCTLR_I: u32 = 0x00001000    # Instruction cache enable

# ---------- TTBR0 ----------

# Set TTBR0 (first-level page table base address)
fn mmu_set_ttbr0(table_phys: u32):
    # Set with inner/outer write-back write-allocate cacheable
    var ttbr = table_phys | 0x6B
    asm """
        ldr r0, {ttbr}
        mcr p15, 0, r0, c2, c0, 0
    """

# Read TTBR0
fn mmu_get_ttbr0() -> u32:
    var result: u32 = 0
    asm """
        mrc p15, 0, r0, c2, c0, 0
        str r0, {result}
    """
    result & 0xFFFFC000

# ---------- TTBR1 ----------

fn mmu_set_ttbr1(table_phys: u32):
    var ttbr = table_phys | 0x6B
    asm """
        ldr r0, {ttbr}
        mcr p15, 0, r0, c2, c0, 1
    """

# ---------- TTBCR ----------

fn mmu_set_ttbcr(value: u32):
    asm """
        ldr r0, {value}
        mcr p15, 0, r0, c2, c0, 2
    """

# ---------- DACR (Domain Access Control Register) ----------

fn mmu_set_dacr(value: u32):
    asm """
        ldr r0, {value}
        mcr p15, 0, r0, c3, c0, 0
    """

# ---------- TLB management ----------

# Invalidate entire unified TLB
fn mmu_flush_tlb():
    asm """
        dsb
        mov r0, #0
        mcr p15, 0, r0, c8, c7, 0
        dsb
        isb
    """

# Invalidate TLB entry for a specific virtual address
fn mmu_invalidate_tlb_entry(vaddr: u32):
    var aligned = vaddr & 0xFFFFF000
    asm """
        dsb
        ldr r0, {aligned}
        mcr p15, 0, r0, c8, c7, 1
        dsb
        isb
    """

# ---------- Cache maintenance ----------

# Invalidate entire instruction cache
fn mmu_invalidate_icache():
    asm """
        mov r0, #0
        mcr p15, 0, r0, c7, c5, 0
        isb
    """

# Clean entire data cache
fn mmu_clean_dcache():
    asm """
        mov r0, #0
        mcr p15, 0, r0, c7, c10, 0
        dsb
    """

# ---------- Barriers ----------

fn mmu_dsb():
    asm """
        dsb
    """

fn mmu_isb():
    asm """
        isb
    """

# ---------- SCTLR (System Control Register) ----------

# Read SCTLR
fn mmu_read_sctlr() -> u32:
    var result: u32 = 0
    asm """
        mrc p15, 0, r0, c1, c0, 0
        str r0, {result}
    """
    result

# Write SCTLR
fn mmu_write_sctlr(value: u32):
    asm """
        ldr r0, {value}
        mcr p15, 0, r0, c1, c0, 0
    """

# ---------- Enable / Disable MMU ----------

# Enable the MMU
fn mmu_enable():
    var sctlr = mmu_read_sctlr()
    sctlr = sctlr | SCTLR_M
    mmu_dsb()
    mmu_write_sctlr(sctlr)
    mmu_isb()

# Disable the MMU
fn mmu_disable():
    var sctlr = mmu_read_sctlr()
    sctlr = sctlr & ~SCTLR_M
    mmu_write_sctlr(sctlr)
    mmu_dsb()
    mmu_isb()

# ---------- Full MMU setup ----------

# Initialize MMU: set TTBCR, DACR, flush TLB
fn mmu_init():
    # Use TTBR0 only (N=0)
    mmu_set_ttbcr(0)
    # Set all 16 domains to client mode
    mmu_set_dacr(0x55555555)
    # Flush TLB
    mmu_flush_tlb()

# ---------- VBAR ----------

# Set the Vector Base Address Register
fn mmu_set_vbar(addr: u32):
    asm """
        ldr r0, {addr}
        mcr p15, 0, r0, c12, c0, 0
        isb
    """
