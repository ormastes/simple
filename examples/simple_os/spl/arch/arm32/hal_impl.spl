# ARM32 HAL Implementation
#
# Maps the generic Hal trait to ARM32-specific drivers:
#   serial  -> PL011 UART (MMIO at 0x09000000)
#   timer   -> ARMv7 Generic Timer (CNTP via CP15)
#   mmu     -> ARMv7 2-level page tables
#   irq     -> cpsie/cpsid instructions

use arch.hal.Hal
use arch.arm32.io.uart.{uart_init, uart_putc, uart_print}
use arch.arm32.boot.timer.{timer_init, timer_get_ticks, timer_get_ms}
use arch.arm32.mm.mmu.{mmu_init}
use arch.arm32.mm.paging.{paging_init, paging_map, paging_unmap}
use arch.arm32.context.context.{RegisterState}

# ---------- HAL trait implementation ----------

struct Arm32Hal:
    pass

impl Hal for Arm32Hal:
    fn serial_init():
        uart_init()

    fn serial_putc(c: u8):
        uart_putc(c as u32)

    fn serial_write(s: String):
        uart_print(s)

    fn timer_init(freq_hz: u32):
        timer_init(freq_hz)

    fn timer_ticks() -> u64:
        timer_get_ticks()

    fn irq_enable():
        asm """
            cpsie i
        """

    fn irq_disable():
        asm """
            cpsid i
        """

    fn context_switch(old: var RegisterState, new_ctx: RegisterState):
        # Delegated to assembly in switch.S
        pass

    fn mmu_map(virt: u32, phys: u32, size: u32, flags: u32):
        paging_map(virt, phys, flags)

    fn mmu_unmap(virt: u32, size: u32):
        paging_unmap(virt)

    fn halt():
        asm """
            wfi
        """
