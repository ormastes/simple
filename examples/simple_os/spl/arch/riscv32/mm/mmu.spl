# RISC-V32 Sv32 MMU Control (satp CSR, TLB)
#
# Functions for setting the root page table, flushing the TLB,
# and enabling/disabling Sv32 paging via the satp CSR.
#
# satp format (RV32):
#   Bit 31:    MODE (0=Bare, 1=Sv32)
#   Bits 30-22: ASID (9 bits)
#   Bits 21-0:  PPN (22 bits — physical page number of root table)

# ---------- constants ----------

val SATP_MODE_BARE: u32 = 0x00000000
val SATP_MODE_SV32: u32 = 0x80000000

# ---------- satp helpers ----------

# Build a satp value from mode, ASID, and PPN
fn make_satp(mode: u32, asid: u32, ppn: u32) -> u32:
    mode | ((asid & 0x1FF) << 22) | (ppn & 0x003FFFFF)

# ---------- public API ----------

# Full MMU setup: set page table and enable Sv32
fn mmu_init(root_page_table_phys: u32):
    mmu_enable(root_page_table_phys)

# Enable Sv32 paging with the given root page table physical address
fn mmu_enable(root_page_table_phys: u32):
    val ppn = root_page_table_phys >> 12
    val satp = make_satp(SATP_MODE_SV32, 0, ppn)
    asm """
        csrw satp, {satp}
    """
    mmu_flush_tlb()

# Disable paging (bare mode)
fn mmu_disable():
    asm """
        csrw satp, zero
    """
    mmu_flush_tlb()

# Set root page table with ASID
fn mmu_set_page_table(root_phys: u32, asid: u32):
    val ppn = root_phys >> 12
    val satp = make_satp(SATP_MODE_SV32, asid, ppn)
    asm """
        csrw satp, {satp}
    """
    mmu_flush_tlb()

# Flush the entire TLB
fn mmu_flush_tlb():
    asm """
        sfence.vma zero, zero
    """

# Flush a single TLB entry for a virtual address
fn mmu_flush_tlb_page(vaddr: u32):
    asm """
        sfence.vma {vaddr}, zero
    """

# Read the current satp CSR
fn mmu_read_satp() -> u32:
    var result: u32 = 0
    asm """
        csrr {result}, satp
    """
    result
