# x86 MMU Control (CR0, CR3, TLB)
#
# Functions for loading page directories, flushing the TLB,
# and enabling/disabling paging via CR0.

# ---------- CR3 (page directory base register) ----------

# Load a page directory physical address into CR3
fn mmu_load_page_dir(phys_addr: u32):
    asm """
        mov eax, {phys_addr}
        mov cr3, eax
    """

# Read the current CR3 value
fn mmu_get_page_dir() -> u32:
    var result: u32 = 0
    asm """
        mov eax, cr3
        mov {result}, eax
    """
    result

# ---------- TLB management ----------

# Full TLB flush by reloading CR3
fn mmu_flush_tlb():
    asm """
        mov eax, cr3
        mov cr3, eax
    """

# Invalidate a single page in the TLB (invlpg instruction)
fn mmu_invalidate_page(vaddr: u32):
    asm """
        mov eax, {vaddr}
        invlpg [eax]
    """

# ---------- CR0 paging control ----------

# Enable paging: set PG bit (bit 31) in CR0
fn mmu_enable_paging():
    asm """
        mov eax, cr0
        or eax, 0x80000000
        mov cr0, eax
    """

# Disable paging: clear PG bit (bit 31) in CR0
fn mmu_disable_paging():
    asm """
        mov eax, cr0
        and eax, 0x7FFFFFFF
        mov cr0, eax
    """

# ---------- CR0 helpers ----------

# Enable protected mode: set PE bit (bit 0) in CR0
fn mmu_enable_protected_mode():
    asm """
        mov eax, cr0
        or eax, 0x00000001
        mov cr0, eax
    """

# Enable write-protect: set WP bit (bit 16) in CR0
# This makes read-only pages enforced even in ring 0
fn mmu_enable_write_protect():
    asm """
        mov eax, cr0
        or eax, 0x00010000
        mov cr0, eax
    """

# Disable write-protect
fn mmu_disable_write_protect():
    asm """
        mov eax, cr0
        and eax, 0xFFFEFFFF
        mov cr0, eax
    """

# ---------- CR4 helpers ----------

# Enable PSE (Page Size Extensions) for 4MB pages
fn mmu_enable_pse():
    asm """
        mov eax, cr4
        or eax, 0x00000010
        mov cr4, eax
    """

# Enable PGE (Page Global Enable) for global pages
fn mmu_enable_pge():
    asm """
        mov eax, cr4
        or eax, 0x00000080
        mov cr4, eax
    """

# ---------- combined setup ----------

# Full MMU setup: load page directory, enable write-protect, enable paging
fn mmu_init(page_dir_phys: u32):
    mmu_load_page_dir(page_dir_phys)
    mmu_enable_write_protect()
    mmu_enable_paging()

# Read CR0 for diagnostics
fn mmu_read_cr0() -> u32:
    var result: u32 = 0
    asm """
        mov eax, cr0
        mov {result}, eax
    """
    result

# Read CR2 (page fault linear address)
fn mmu_read_cr2() -> u32:
    var result: u32 = 0
    asm """
        mov eax, cr2
        mov {result}, eax
    """
    result

# Read CR4
fn mmu_read_cr4() -> u32:
    var result: u32 = 0
    asm """
        mov eax, cr4
        mov {result}, eax
    """
    result
