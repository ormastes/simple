# hosted_main.spl — SimpleOS Desktop in a macOS Window
#
# Run with: SIMPLE_GUI=1 bin/simple examples/simple_os/hosted/hosted_main.spl

extern fn rt_winit_event_loop_new() -> i64
extern fn rt_winit_window_new(el: i64, w: i64, h: i64, title: text) -> i64
extern fn rt_winit_event_loop_poll_events(el: i64, max: i64) -> i64
extern fn rt_winit_event_get_type(ev: i64) -> i64
extern fn rt_winit_event_keyboard_input(ev: i64) -> (i64, i64, bool)
extern fn rt_winit_event_mouse_moved(ev: i64) -> (i64, i64)
extern fn rt_winit_event_mouse_button(ev: i64) -> (i64, bool)
extern fn rt_winit_event_free(ev: i64)
extern fn rt_winit_window_present_rgba(win: i64, w: i64, h: i64, pixels: [i64])
extern fn rt_winit_window_free(win: i64)
extern fn rt_winit_event_loop_free(el: i64)
extern fn rt_sleep_ms(ms: i64)

val SW: i64 = 1024
val SH: i64 = 768

# ============================================================================
# Pixel Buffer Helpers
# ============================================================================

fn make_pixel(r: i64, g: i64, b: i64) -> i64:
    (255 << 24) | (r << 16) | (g << 8) | b

fn fill_rect(pixels: [i64], x: i64, y: i64, w: i64, h: i64, color: i64) -> [i64]:
    var buf = pixels
    var row = 0
    while row < h:
        val py = y + row
        if py >= 0 and py < SH:
            var col = 0
            while col < w:
                val px = x + col
                if px >= 0 and px < SW:
                    val idx = py * SW + px
                    buf = buf.set(idx, color)
                col = col + 1
        row = row + 1
    buf

fn put_pixel(pixels: [i64], x: i64, y: i64, color: i64) -> [i64]:
    if x >= 0 and x < SW and y >= 0 and y < SH:
        return pixels.set(y * SW + x, color)
    pixels

# ============================================================================
# Desktop Scene
# ============================================================================

fn render_desktop(pixels: [i64]) -> [i64]:
    var buf = pixels
    val bg = make_pixel(30, 30, 46)
    var i = 0
    while i < SW * SH:
        buf = buf.set(i, bg)
        i = i + 1

    # Title bar (top)
    buf = fill_rect(buf, 0, 0, SW, 28, make_pixel(24, 24, 37))

    # Hello World window
    buf = fill_rect(buf, 200, 100, 400, 24, make_pixel(0, 122, 204))
    buf = fill_rect(buf, 580, 104, 16, 16, make_pixel(231, 76, 60))
    buf = fill_rect(buf, 200, 124, 400, 200, make_pixel(255, 255, 255))

    # RGB blocks
    buf = fill_rect(buf, 220, 220, 80, 30, make_pixel(255, 68, 68))
    buf = fill_rect(buf, 310, 220, 80, 30, make_pixel(68, 204, 68))
    buf = fill_rect(buf, 400, 220, 80, 30, make_pixel(68, 136, 255))

    # Status bar
    buf = fill_rect(buf, 200, 300, 400, 24, make_pixel(224, 224, 224))

    # Taskbar (bottom)
    buf = fill_rect(buf, 0, 736, SW, 32, make_pixel(24, 24, 37))
    buf = fill_rect(buf, 10, 742, 20, 20, make_pixel(52, 152, 219))
    buf = fill_rect(buf, 36, 742, 20, 20, make_pixel(39, 174, 96))
    buf = fill_rect(buf, 62, 742, 20, 20, make_pixel(231, 76, 60))
    buf = fill_rect(buf, 88, 742, 20, 20, make_pixel(243, 156, 18))
    buf = fill_rect(buf, 114, 742, 20, 20, make_pixel(155, 89, 182))
    buf

fn render_cursor(pixels: [i64], mx: i64, my: i64) -> [i64]:
    var buf = pixels
    var cy = 0
    while cy < 10:
        var cx = 0
        val cw = 10 - cy
        while cx < cw:
            if cx == 0 or cy == 0 or cx == cw - 1:
                buf = put_pixel(buf, mx + cx, my + cy, make_pixel(0, 0, 0))
            else:
                buf = put_pixel(buf, mx + cx, my + cy, make_pixel(255, 255, 255))
            cx = cx + 1
        cy = cy + 1
    buf

# ============================================================================
# Main Loop
# ============================================================================

fn main() -> i64:
    print "SimpleOS Hosted Desktop"

    val el = rt_winit_event_loop_new()
    val win = rt_winit_window_new(el, SW, SH, "SimpleOS Desktop")
    if win == 0:
        print "ERROR: Window creation failed"
        return 1
    print "Window ready"

    # Pixel buffer
    var pixels: [i64] = []
    var idx = 0
    while idx < SW * SH:
        pixels = pixels.push(0)
        idx = idx + 1

    # Initial render
    pixels = render_desktop(pixels)
    rt_winit_window_present_rgba(win, SW, SH, pixels)
    print "First frame presented"

    # Event loop
    var running = true
    var mouse_x: i64 = 512
    var mouse_y: i64 = 384
    var frame = 0

    while running:
        var ev = rt_winit_event_loop_poll_events(el, 100)
        while ev != 0:
            val etype = rt_winit_event_get_type(ev)
            if etype == 3:
                running = false
            else if etype == 10:
                val (sc, kc, pressed) = rt_winit_event_keyboard_input(ev)
                if pressed and kc == 9:
                    running = false
            else if etype == 21:
                val (mx, my) = rt_winit_event_mouse_moved(ev)
                mouse_x = mx
                mouse_y = my
            rt_winit_event_free(ev)
            ev = rt_winit_event_loop_poll_events(el, 100)

        var fbuf = render_desktop(pixels)
        fbuf = render_cursor(fbuf, mouse_x, mouse_y)
        rt_winit_window_present_rgba(win, SW, SH, fbuf)

        frame = frame + 1
        rt_sleep_ms(33)

    print "Closed after {frame} frames"
    rt_winit_window_free(win)
    rt_winit_event_loop_free(el)
    return 0
