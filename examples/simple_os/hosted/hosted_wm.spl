# hosted_wm.spl — SimpleOS Hosted Window Manager (1024x768, 3 windows)
#
# A full desktop window manager running natively on macOS via winit/softbuffer.
# Ports the multi-window composition from wm_entry.spl (baremetal) to hosted mode.
#
# Features:
#   - 1024x768 native window
#   - System bar (top) + Taskbar with dock icons (bottom)
#   - 3 app windows: Terminal, Hello World, File Manager
#   - Z-order management (focused window drawn on top)
#   - Keyboard: Tab=cycle, 1/2/3=focus window, S=screenshot, Escape=quit
#
# Run with:
#   SIMPLE_GUI=1 bin/simple examples/simple_os/hosted/hosted_wm.spl

# ============================================================================
# FFI Declarations
# ============================================================================

extern fn rt_winit_event_loop_new() -> i64
extern fn rt_winit_window_new(el: i64, w: i64, h: i64, title: text) -> i64
extern fn rt_winit_event_loop_poll_events(el: i64, max: i64) -> i64
extern fn rt_winit_event_get_type(ev: i64) -> i64
extern fn rt_winit_event_keyboard_input(ev: i64) -> (i64, i64, bool)
extern fn rt_winit_event_mouse_moved(ev: i64) -> (i64, i64)
extern fn rt_winit_event_free(ev: i64)
extern fn rt_winit_window_present_rgba(win: i64, w: i64, h: i64, pixels: [i64])
extern fn rt_winit_window_free(win: i64)
extern fn rt_winit_event_loop_free(el: i64)
extern fn rt_winit_save_pixels_bmp(path: text, w: i64, h: i64, pixels: [i64]) -> bool
extern fn rt_thread_sleep(ms: i64)

# ============================================================================
# Constants
# ============================================================================

val SCREEN_W: i64 = 1024
val SCREEN_H: i64 = 768

# Event types
val EVT_CLOSE: i64 = 3
val EVT_KEYBOARD: i64 = 10
val EVT_MOUSE_MOVED: i64 = 21

# Keycodes
val KEY_TAB: i64 = 9
val KEY_ESCAPE: i64 = 27
val KEY_1: i64 = 49
val KEY_2: i64 = 50
val KEY_3: i64 = 51
val KEY_S: i64 = 83
val KEY_Q: i64 = 81

# ============================================================================
# Color Palette (Dark theme — matches wm_entry.spl)
# ============================================================================

fn make_pixel(r: i64, g: i64, b: i64) -> i64:
    (255 << 24) | (r << 16) | (g << 8) | b

val BG_COLOR: i64        = make_pixel(26, 27, 38)
val TITLEBAR_COLOR: i64  = make_pixel(30, 30, 46)
val TASKBAR_COLOR: i64   = make_pixel(30, 30, 46)
val WIN_TITLE_ACTIVE: i64 = make_pixel(0, 122, 204)
val WIN_TITLE_INACTIVE: i64 = make_pixel(80, 80, 112)
val WIN_BODY_BG: i64     = make_pixel(255, 255, 255)
val WIN_BORDER: i64      = make_pixel(64, 64, 96)
val CLOSE_BTN: i64       = make_pixel(231, 76, 60)
val MIN_BTN: i64         = make_pixel(243, 156, 18)
val MAX_BTN: i64         = make_pixel(46, 204, 113)
val STATUS_BAR: i64      = make_pixel(224, 224, 224)
val ACCENT: i64          = make_pixel(187, 134, 252)
val CLOCK_BG: i64        = make_pixel(44, 44, 62)
val TEXT_LIGHT: i64      = make_pixel(204, 204, 204)
val DOCK_TERM: i64       = make_pixel(52, 152, 219)
val DOCK_FILES: i64      = make_pixel(39, 174, 96)
val DOCK_CALC: i64       = make_pixel(231, 76, 60)
val DOCK_CLOCK: i64      = make_pixel(243, 156, 18)
val DOCK_SETTINGS: i64   = make_pixel(155, 89, 182)

# ============================================================================
# Pixel Buffer Helpers
# ============================================================================

fn fill_rect(pixels: [i64], x: i64, y: i64, w: i64, h: i64, color: i64):
    var row = 0
    while row < h:
        val py = y + row
        if py >= 0 and py < SCREEN_H:
            var col = 0
            while col < w:
                val px = x + col
                if px >= 0 and px < SCREEN_W:
                    pixels[py * SCREEN_W + px] = color
                col = col + 1
        row = row + 1

# ============================================================================
# Desktop Components
# ============================================================================

fn draw_system_bar(pixels: [i64]):
    fill_rect(pixels, 0, 0, SCREEN_W, 24, TITLEBAR_COLOR)
    # "SimpleOS" label area
    fill_rect(pixels, 6, 4, 60, 16, ACCENT)
    # Clock area
    fill_rect(pixels, SCREEN_W - 80, 4, 74, 16, CLOCK_BG)

fn draw_taskbar(pixels: [i64]):
    val bar_h: i64 = 40
    val bar_y = SCREEN_H - bar_h
    fill_rect(pixels, 0, bar_y, SCREEN_W, bar_h, TASKBAR_COLOR)

    # Dock icons
    val icon_size: i64 = 28
    val icon_y = bar_y + 6
    val gap: i64 = 8
    var ix: i64 = 12

    fill_rect(pixels, ix, icon_y, icon_size, icon_size, DOCK_TERM)
    ix = ix + icon_size + gap
    fill_rect(pixels, ix, icon_y, icon_size, icon_size, DOCK_FILES)
    ix = ix + icon_size + gap
    fill_rect(pixels, ix, icon_y, icon_size, icon_size, DOCK_CALC)
    ix = ix + icon_size + gap
    fill_rect(pixels, ix, icon_y, icon_size, icon_size, DOCK_CLOCK)
    ix = ix + icon_size + gap
    fill_rect(pixels, ix, icon_y, icon_size, icon_size, DOCK_SETTINGS)

    # Running indicators
    fill_rect(pixels, 24, bar_y + 36, 4, 3, TEXT_LIGHT)
    fill_rect(pixels, 24 + icon_size + gap, bar_y + 36, 4, 3, TEXT_LIGHT)

# ============================================================================
# Window Drawing
# ============================================================================

fn draw_window(pixels: [i64], x: i64, y: i64, w: i64, h: i64, is_active: bool):
    val title_h: i64 = 28
    val btn_size: i64 = 14
    val btn_y = y + 7
    val body_y = y + title_h
    val body_h = h - title_h

    # Border
    fill_rect(pixels, x - 1, y - 1, w + 2, h + 2, WIN_BORDER)

    # Title bar
    if is_active:
        fill_rect(pixels, x, y, w, title_h, WIN_TITLE_ACTIVE)
    else:
        fill_rect(pixels, x, y, w, title_h, WIN_TITLE_INACTIVE)

    # Window control buttons
    fill_rect(pixels, x + w - 22, btn_y, btn_size, btn_size, CLOSE_BTN)
    fill_rect(pixels, x + w - 40, btn_y, btn_size, btn_size, MAX_BTN)
    fill_rect(pixels, x + w - 58, btn_y, btn_size, btn_size, MIN_BTN)

    # Body
    fill_rect(pixels, x, body_y, w, body_h, WIN_BODY_BG)

fn draw_hello_app(pixels: [i64], x: i64, y: i64, is_active: bool):
    val w: i64 = 360
    val h: i64 = 240
    draw_window(pixels, x, y, w, h, is_active)

    val content_y = y + 28
    val pad: i64 = 16

    # Greeting banner
    fill_rect(pixels, x + pad, content_y + pad, w - pad * 2, 40, make_pixel(240, 244, 255))
    fill_rect(pixels, x + pad, content_y + pad, 4, 40, ACCENT)

    # Color blocks
    val block_y = content_y + pad + 56
    fill_rect(pixels, x + pad, block_y, 80, 32, make_pixel(255, 107, 107))
    fill_rect(pixels, x + pad + 90, block_y, 80, 32, make_pixel(81, 207, 102))
    fill_rect(pixels, x + pad + 180, block_y, 80, 32, make_pixel(91, 155, 213))

    # Status bar
    fill_rect(pixels, x, y + h - 24, w, 24, STATUS_BAR)

fn draw_terminal(pixels: [i64], x: i64, y: i64, is_active: bool):
    val w: i64 = 400
    val h: i64 = 280
    draw_window(pixels, x, y, w, h, is_active)

    val body_y = y + 28
    val body_h = h - 28
    fill_rect(pixels, x, body_y, w, body_h, make_pixel(26, 27, 38))

    # Cursor
    fill_rect(pixels, x + 12, body_y + 12, 8, 16, make_pixel(68, 255, 68))

    # Text lines
    fill_rect(pixels, x + 24, body_y + 12, 120, 2, make_pixel(68, 255, 68))
    fill_rect(pixels, x + 12, body_y + 32, 200, 2, make_pixel(170, 170, 170))
    fill_rect(pixels, x + 12, body_y + 48, 160, 2, make_pixel(170, 170, 170))
    fill_rect(pixels, x + 12, body_y + 64, 240, 2, make_pixel(85, 136, 204))
    fill_rect(pixels, x + 12, body_y + 80, 100, 2, make_pixel(170, 170, 170))
    fill_rect(pixels, x + 12, body_y + 96, 180, 2, make_pixel(68, 255, 68))

fn draw_file_manager(pixels: [i64], x: i64, y: i64, is_active: bool):
    val w: i64 = 320
    val h: i64 = 200
    draw_window(pixels, x, y, w, h, is_active)

    val body_y = y + 28

    # Sidebar
    fill_rect(pixels, x, body_y, 80, h - 28, make_pixel(240, 240, 240))
    fill_rect(pixels, x + 8, body_y + 8, 64, 16, make_pixel(224, 224, 224))
    fill_rect(pixels, x + 8, body_y + 28, 64, 16, make_pixel(224, 224, 224))
    fill_rect(pixels, x + 8, body_y + 48, 64, 16, make_pixel(208, 232, 255))

    # File grid
    var row: i64 = 0
    while row < 3:
        var col: i64 = 0
        while col < 3:
            val fx = x + 92 + col * 72
            val fy = body_y + 8 + row * 52
            fill_rect(pixels, fx, fy, 48, 36, make_pixel(232, 232, 232))
            fill_rect(pixels, fx, fy, 48, 4, make_pixel(91, 155, 213))
            col = col + 1
        row = row + 1

# ============================================================================
# Desktop Composition (Z-order)
# ============================================================================

fn redraw_desktop(pixels: [i64], active: i64):
    # Clear work area
    fill_rect(pixels, 0, 24, SCREEN_W, SCREEN_H - 64, BG_COLOR)

    # System bar + taskbar
    draw_system_bar(pixels)
    draw_taskbar(pixels)

    # Draw windows: active window drawn last (on top)
    if active == 0:
        draw_file_manager(pixels, 520, 320, false)
        draw_hello_app(pixels, 320, 140, false)
        draw_terminal(pixels, 60, 80, true)
    else if active == 1:
        draw_file_manager(pixels, 520, 320, false)
        draw_terminal(pixels, 60, 80, false)
        draw_hello_app(pixels, 320, 140, true)
    else:
        draw_terminal(pixels, 60, 80, false)
        draw_hello_app(pixels, 320, 140, false)
        draw_file_manager(pixels, 520, 320, true)

# ============================================================================
# Main
# ============================================================================

fn main() -> i64:
    print "SimpleOS Window Manager — Hosted ({SCREEN_W}x{SCREEN_H})"
    print "Controls: Tab=cycle, 1/2/3=focus, S=screenshot, Escape=quit"
    print ""

    val el = rt_winit_event_loop_new()
    val win = rt_winit_window_new(el, SCREEN_W, SCREEN_H, "SimpleOS Window Manager")
    if win == 0:
        print "ERROR: Window creation failed (is SIMPLE_GUI=1 set?)"
        return 1
    print "Window created: {SCREEN_W}x{SCREEN_H}"

    # Initialize pixel buffer
    print "Initializing pixel buffer..."
    var pixels = [for _i in 0..(SCREEN_W * SCREEN_H): BG_COLOR]
    print "Pixel buffer ready ({pixels.len()} pixels)"

    # Initial render
    var active_win: i64 = 1
    print "Rendering desktop..."
    redraw_desktop(pixels, active_win)
    rt_winit_window_present_rgba(win, SCREEN_W, SCREEN_H, pixels)
    print "First frame presented"

    # Save initial screenshot
    val saved = rt_winit_save_pixels_bmp("/tmp/simpleos_wm.bmp", SCREEN_W, SCREEN_H, pixels)
    if saved:
        print "Screenshot saved: /tmp/simpleos_wm.bmp"
    else:
        print "Warning: screenshot save failed"

    # Event loop
    var running = true
    var frame: i64 = 0
    var screenshot_count: i64 = 1

    print "Entering event loop..."

    while running:
        var ev = rt_winit_event_loop_poll_events(el, 100)
        while ev != 0:
            val etype = rt_winit_event_get_type(ev)

            if etype == EVT_CLOSE:
                print "Window close requested"
                running = false

            else if etype == EVT_KEYBOARD:
                val (scancode, keycode, pressed) = rt_winit_event_keyboard_input(ev)
                if pressed:
                    if keycode == KEY_TAB:
                        active_win = (active_win + 1) % 3
                        redraw_desktop(pixels, active_win)
                        rt_winit_window_present_rgba(win, SCREEN_W, SCREEN_H, pixels)
                        val names = ["Terminal", "Hello World", "File Manager"]
                        print "Focus: {names[active_win]}"

                    else if keycode == KEY_1:
                        active_win = 0
                        redraw_desktop(pixels, active_win)
                        rt_winit_window_present_rgba(win, SCREEN_W, SCREEN_H, pixels)
                        print "Focus: Terminal"

                    else if keycode == KEY_2:
                        active_win = 1
                        redraw_desktop(pixels, active_win)
                        rt_winit_window_present_rgba(win, SCREEN_W, SCREEN_H, pixels)
                        print "Focus: Hello World"

                    else if keycode == KEY_3:
                        active_win = 2
                        redraw_desktop(pixels, active_win)
                        rt_winit_window_present_rgba(win, SCREEN_W, SCREEN_H, pixels)
                        print "Focus: File Manager"

                    else if keycode == KEY_S:
                        screenshot_count = screenshot_count + 1
                        val path = "/tmp/simpleos_wm_{screenshot_count}.bmp"
                        val ok = rt_winit_save_pixels_bmp(path, SCREEN_W, SCREEN_H, pixels)
                        if ok:
                            print "Screenshot saved: {path}"
                        else:
                            print "Screenshot save failed"

                    else if keycode == KEY_ESCAPE or keycode == KEY_Q:
                        print "Quit requested"
                        running = false

            rt_winit_event_free(ev)
            ev = rt_winit_event_loop_poll_events(el, 100)

        frame = frame + 1
        rt_thread_sleep(33)

    print ""
    print "Desktop closed after {frame} frames"
    rt_winit_window_free(win)
    rt_winit_event_loop_free(el)
    return 0
