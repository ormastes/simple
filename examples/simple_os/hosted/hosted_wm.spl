# hosted_wm.spl — SimpleOS Hosted Window Manager (1024x768)
#
# Runs SimpleOS desktop with app windows on macOS via winit.
# Uses the compositor module — same rendering path as baremetal.
#
# Run with:
#   SIMPLE_GUI=1 bin/simple examples/simple_os/hosted/hosted_wm.spl

extern fn rt_winit_event_loop_new() -> i64
extern fn rt_winit_window_new(el: i64, w: i64, h: i64, title: text) -> i64
extern fn rt_winit_window_free(win: i64)
extern fn rt_winit_event_loop_free(el: i64)

use os.compositor.hosted_backend.{HostedCompositorBackend}
use os.compositor.hosted_input_backend.{HostedInputBackend}
use os.compositor.compositor.{Compositor}

val SCREEN_W: i64 = 1024
val SCREEN_H: i64 = 768
val BG_COLOR: u32 = 0xFF1A1B26

fn main() -> i64:
    print "SimpleOS Window Manager — Hosted ({SCREEN_W}x{SCREEN_H})"
    print "Alt+Tab=cycle, Escape=quit"

    val el = rt_winit_event_loop_new()
    val win = rt_winit_window_new(el, SCREEN_W, SCREEN_H, "SimpleOS Window Manager")
    if win == 0:
        print "ERROR: Window creation failed (is SIMPLE_GUI=1 set?)"
        return 1

    val w32: i32 = 1024
    val h32: i32 = 768
    var backend = HostedCompositorBackend.create(win, w32, h32, BG_COLOR)
    var input = HostedInputBackend.create(el)
    var compositor = Compositor.with_backends(backend, input, w32, h32)

    compositor.create_window("File Manager", 40, 60, 480, 340)
    compositor.create_window("Terminal", 300, 180, 420, 300)
    compositor.create_window("Calculator", 560, 100, 240, 320)

    print "Desktop ready! 3 windows launched."
    compositor.run_loop()

    print "Desktop closed"
    backend.free()
    rt_winit_window_free(win)
    rt_winit_event_loop_free(el)
    return 0
