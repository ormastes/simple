# ARM32 filesystem executable acceptance entry.

extern fn serial_println(msg: text)
extern fn rt_qemu_exit_success()
extern fn arm_fs_exec_trace(id: u64)

use os.services.vfs.arm_fs_exec_vfs.{arm_fs_exec_vfs_boot_init}
use os.kernel.scheduler.scheduler.{Scheduler}
use os.kernel.log.klog.{KernelLog}
use os.kernel.loader.arm_fs_exec_spawn.{arm_fs_exec_spawn_hello_world_smf}

fn spl_start():
    arm_fs_exec_trace(1)
    serial_println("")
    serial_println("=== SimpleOS ARM32 FS exec boot ===")

    arm_fs_exec_trace(2)
    if not arm_fs_exec_vfs_boot_init():
        arm_fs_exec_trace(90)
        serial_println("[arm-fs-exec] vfs:fail")
        serial_println("TEST FAILED")
        rt_qemu_exit_success()
        return

    arm_fs_exec_trace(3)
    var scheduler = Scheduler.new_bootstrap()
    arm_fs_exec_trace(4)
    val pid = arm_fs_exec_spawn_hello_world_smf(2, scheduler, KernelLog.new(64))
    arm_fs_exec_trace(5)
    if pid <= 0:
        arm_fs_exec_trace(91)
        serial_println("[arm-fs-exec] spawn:fail")
        serial_println("TEST FAILED")
        rt_qemu_exit_success()
        return

    serial_println("[arm-fs-exec] vfs:ok")
    serial_println("[arm-fs-exec] smf:/sys/apps/hello_world.smf")
    serial_println("[arm-fs-exec] user-process pid={pid}")
    serial_println("TEST PASSED")
    rt_qemu_exit_success()
