# SimpleOS Glass Window Manager — ARM64 (AArch64) QEMU virt
#
# Self-contained entry with frosted glass UI effects on ARM64:
# 1. Framebuffer via QEMU ramfb device (fw_cfg at 0x09020000)
# 2. PL011 UART serial input for keyboard control
# 3. Gradient desktop background (midnight -> purple)
# 4. Frosted glass windows with blur + alpha blend + shadows
# 5. Glass system bar and dock with backdrop blur
# 6. macOS-style traffic light buttons (close/min/max)
# 7. Dark Glass / White Glass theme toggle (T key)
# 8. Focus ring effect on active window
# 9. UART keyboard input for window management
#
# Architecture differences from x86_64:
#   - No port I/O (no BGA, no PS/2) -- ARM64 uses MMIO exclusively
#   - Framebuffer via ramfb (fw_cfg) instead of BGA + PCI BAR scan
#   - Keyboard via PL011 UART (0x09000000) instead of PS/2 scancodes
#   - No mouse support (UART is character-based, not PS/2 packets)
#
# QEMU launch example:
#   qemu-system-aarch64 -machine virt -cpu cortex-a72 -m 512M \
#     -device ramfb -kernel wm.elf -nographic -serial mon:stdio

# === Extern FFI declarations ===
extern fn serial_println(msg: text)

# MMIO read/write (ARM64 native -- no port I/O on AArch64)
extern fn rt_mmio_read_u8(addr: u64) -> u64
extern fn rt_mmio_read_u16(addr: u64) -> u64
extern fn rt_mmio_read_u32(addr: u64) -> u64
