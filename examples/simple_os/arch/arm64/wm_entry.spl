# ===========================================================================
# PL011 UART Constants (ARM64 QEMU virt)
# ===========================================================================
val PL011_BASE: u64 = 0x09000000
val PL011_DR: u64 = 0x000       # Data Register
val PL011_FR: u64 = 0x018       # Flag Register
val PL011_FR_RXFE: u64 = 0x10   # Receive FIFO empty (bit 4)

# ===========================================================================
# QEMU fw_cfg Constants (for ramfb device configuration)
# ===========================================================================
val FW_CFG_BASE: u64 = 0x09020000   # fw_cfg MMIO on QEMU virt
val FW_CFG_DATA: u64 = 0x000        # Data port (8-bit)
val FW_CFG_SEL: u64  = 0x008        # Selector port (16-bit BE)
val FW_CFG_DMA: u64  = 0x010        # DMA address port (64-bit BE)

