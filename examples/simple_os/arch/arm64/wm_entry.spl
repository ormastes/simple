#![allow(unnamed_duplicate_typed_args)]
# SimpleOS Glass Window Manager — ARM64 (AArch64) QEMU virt
#
# Entry point and stateful window management for ARM64:
# 1. Framebuffer via QEMU ramfb device (fw_cfg at 0x09020000)
# 2. PL011 UART serial input for keyboard control
# 3. Window position state + animation state
# 4. Main loop: input dispatch, animation tick, desktop redraw
#
# Architecture differences from x86_64:
#   - No port I/O (no BGA, no PS/2) -- ARM64 uses MMIO exclusively
#   - Framebuffer via ramfb (fw_cfg) instead of BGA + PCI BAR scan
#   - Keyboard via PL011 UART (0x09000000) instead of PS/2 scancodes
#   - No mouse support (UART is character-based, not PS/2 packets)
#
# Extracted modules:
#   wm_entry_io.spl    — externs, UART, ramfb, render primitives, theme, constants
#   wm_entry_glass.spl — stateless glass draw fns (window, bar, dock, content)

# === Extern FFI declarations (only what spl_start uses directly) ===
extern fn serial_println(msg: text)
extern fn rt_gui_set_fb(addr: u64, width: u64)
extern fn rt_gui_begin_frame(width: u64, height: u64, unused1: u64, unused2: u64)
extern fn rt_gui_present(unused1: u64, unused2: u64, unused3: u64, unused4: u64)
extern fn rt_gui_draw_wallpaper(wh: u64, style: u64, unused1: u64, unused2: u64)
extern fn rt_alloc(size: u64) -> u64

use examples.simple_os.arch.arm64.wm_entry_io.{
    pack, pack8, blend, blur, rrect_aa, grad_h,
    draw_label, draw_label_shadow, draw_label_vector,
    bounce_offset, ease_in_cubic, ease_out_cubic, lerp,
    accent, accent2,
    surface, surface_a, elevated, elevated_a, border_c, border_a,
    shadow_a, text_c, text_sec,
    line,
    setup_ramfb,
    uart_data_ready, uart_read_char, uart_char_to_action
}

use examples.simple_os.arch.arm64.wm_entry_glass.{
    draw_glass_window,
    draw_glass_system_bar,
    draw_glass_dock,
    draw_hello_content,
    draw_terminal_content,
    draw_files_content
}

# ===========================================================================
# Window positions
# ===========================================================================
fn win0_x() -> u64: 60
fn win0_y() -> u64: 60
fn win1_x() -> u64: 300
fn win1_y() -> u64: 160
fn win2_x() -> u64: 540
fn win2_y() -> u64: 300

# ===========================================================================
# Window Title Drawing
# ===========================================================================

fn draw_window_title(x: u64, y: u64, w: u64, title_chars: u64, title_len: u64, theme: u64):
    val title_pixel_w = title_len * 10
    val text_x = x + (w - title_pixel_w) / 2
    val text_y = y + 14
    draw_label_vector(text_x + 1, text_y + 2, 0x00000000, 12, title_chars, title_len, 18)
    draw_label_vector(text_x + 1, text_y + 1, 0x00000000, 45, title_chars, title_len, 18)
    draw_label_vector(text_x, text_y, text_c(theme), 240, title_chars, title_len, 18)

# ===========================================================================
# Animation Helpers
# ===========================================================================

fn dock_icon_x(win_idx: u64) -> u64:
    val num_icons: u64 = 7
    val pill_w = 48
    val icon_gap = 16
    val dock_pad = 20
    val separator_w: u64 = 2
    val separator_gap: u64 = 10
    val num_util_icons: u64 = 2
    val dock_w = num_icons * (pill_w + icon_gap) + separator_w + separator_gap * 2 + num_util_icons * (pill_w + icon_gap) - icon_gap + dock_pad * 2
    val dock_x = (1024 - dock_w) / 2
    if win_idx == 0:
        dock_x + dock_pad + pill_w / 2
    else:
        if win_idx == 1:
            dock_x + dock_pad + 6 * (pill_w + icon_gap) + pill_w / 2
        else:
            dock_x + dock_pad + 1 * (pill_w + icon_gap) + pill_w / 2

fn dock_icon_y() -> u64:
    768 - 58 - 10 + 8

fn draw_animated_window(
    src_x: u64, src_y: u64, src_w: u64, src_h: u64,
    dst_x: u64, dst_y: u64, dst_w: u64, dst_h: u64,
    progress: u64, theme: u64):
    val eased = ease_out_cubic(progress)
    val ax = lerp(src_x, dst_x, eased)
    val ay = lerp(src_y, dst_y, eased)
    val aw = lerp(src_w, dst_w, eased)
    val ah = lerp(src_h, dst_h, eased)
    if aw > 20 and ah > 20:
        draw_glass_window(ax, ay, aw, ah, 1, theme)

# ===========================================================================
# Full Desktop Rendering
# ===========================================================================

fn draw_win0_normal(boff: u64, is_active: u64, theme: u64):
    val x = win0_x()
    val by = win0_y() - boff
    draw_glass_window(x, by, 420, 260, is_active, theme)
    draw_terminal_content(x, by, 420, 260, theme)
    draw_window_title(x, by, 420, pack8(84, 101, 114, 109, 105, 110, 97, 108), 8, theme)

fn draw_win1_normal(boff: u64, is_active: u64, theme: u64):
    val x = win1_x()
    val by = win1_y() - boff
    draw_glass_window(x, by, 480, 300, is_active, theme)
    draw_hello_content(x, by, 480, 300, theme)
    draw_window_title(x, by, 480, pack8(69, 100, 105, 116, 111, 114, 0, 0), 6, theme)

fn draw_win2_normal(boff: u64, is_active: u64, theme: u64):
    val x = win2_x()
    val by = win2_y() - boff
    draw_glass_window(x, by, 360, 240, is_active, theme)
    draw_files_content(x, by, 360, 240, theme)
    draw_window_title(x, by, 360, pack8(70, 105, 110, 100, 101, 114, 0, 0), 6, theme)

fn draw_close_animated(wx: u64, wy: u64, ww: u64, wh: u64, close_progress: u64, theme: u64):
    val eased = ease_in_cubic(close_progress)
    val shrink = eased * 15 / 100
    val cx = wx + shrink * ww / 200
    val cy = wy + shrink * wh / 200
    val cw = ww - shrink * ww / 100
    val ch = wh - shrink * wh / 100
    if cw > 30 and ch > 30:
        draw_glass_window(cx, cy, cw, ch, 1, theme)

fn draw_single_window(
    win: u64, boff: u64, is_active: u64, theme: u64,
    minimize_active: u64, minimize_progress: u64, minimize_win: u64,
    minimize_states: u64, close_active: u64, close_progress: u64,
    close_win: u64):
    val minimized_bit = (minimize_states >> win) & 1
    if minimize_active == 1 and minimize_win == win:
        if win == 0:
            draw_animated_window(win0_x(), win0_y(), 420, 260, dock_icon_x(0), dock_icon_y(), 48, 48, minimize_progress, theme)
        else:
            if win == 1:
                draw_animated_window(win1_x(), win1_y(), 480, 300, dock_icon_x(1), dock_icon_y(), 48, 48, minimize_progress, theme)
            else:
                draw_animated_window(win2_x(), win2_y(), 360, 240, dock_icon_x(2), dock_icon_y(), 48, 48, minimize_progress, theme)
    else:
        if close_active == 1 and close_win == win:
            if win == 0:
                draw_close_animated(win0_x(), win0_y(), 420, 260, close_progress, theme)
            else:
                if win == 1:
                    draw_close_animated(win1_x(), win1_y(), 480, 300, close_progress, theme)
                else:
                    draw_close_animated(win2_x(), win2_y(), 360, 240, close_progress, theme)
        else:
            if minimized_bit == 0:
                if win == 0:
                    draw_win0_normal(boff, is_active, theme)
                else:
                    if win == 1:
                        draw_win1_normal(boff, is_active, theme)
                    else:
                        draw_win2_normal(boff, is_active, theme)

fn draw_desktop(
    active: u64, theme: u64, anim_progress: u64,
    minimize_active: u64, minimize_progress: u64, minimize_win: u64,
    minimize_states: u64, close_active: u64, close_progress: u64,
    close_win: u64):
    rt_gui_begin_frame(1024, 768, 0, 0)

    # Procedural wallpaper
    rt_gui_draw_wallpaper(pack(1024, 768), theme, 0, 0)

    # Vignette
    blend(0, 0, 100, 80, 0x00000000, 20)
    blend(1024 - 100, 0, 100, 80, 0x00000000, 20)
    blend(0, 768 - 80, 100, 80, 0x00000000, 20)
    blend(1024 - 100, 768 - 80, 100, 80, 0x00000000, 20)

    grad_h(0, 0, 1024, 1, accent(theme), accent2(theme))

    # Tech grid (dark theme only)
    if theme == 0:
        var gy: u64 = 100
        while gy < 768 - 100:
            blend(0, gy, 1024, 1, 0x00FFFFFF, 2)
            gy = gy + 80
        var gx: u64 = 100
        while gx < 1024 - 100:
            blend(gx, 100, 1, 768 - 200, 0x00FFFFFF, 2)
            gx = gx + 80

    # Shooting stars
    if theme == 0:
        line(180, 80, 220, 95, 0x00FFFFFF, 2, 200)
        line(220, 95, 230, 98, 0x00FFFFFF, 2, 110)
        blend(178, 79, 5, 5, 0x00FFFFFF, 140)
        line(700, 120, 760, 150, 0x00FFFFFF, 2, 170)

    if theme == 0:
        blend(150, 120, 4, 4, 0x00FFFFFF, 160)
        blend(700, 200, 4, 4, 0x00FFFFFF, 140)
        blend(850, 350, 4, 4, 0x00FFFFFF, 120)
        blend(400, 500, 4, 4, 0x00FFFFFF, 100)
        blend(950, 100, 4, 4, 0x00FFFFFF, 150)

    if theme == 1:
        blend(0, 768 / 2, 1024, 768 / 2, 0x00E8D0F0, 6)

    blend(0, 768 * 2 / 3, 1024, 768 / 3, 0x00201008, 6)

    val boff = bounce_offset(anim_progress)

    # Windows in z-order
    if active == 0:
        draw_single_window(2, 0, 0, theme, minimize_active, minimize_progress, minimize_win, minimize_states, close_active, close_progress, close_win)
        draw_single_window(1, 0, 0, theme, minimize_active, minimize_progress, minimize_win, minimize_states, close_active, close_progress, close_win)
        draw_single_window(0, boff, 1, theme, minimize_active, minimize_progress, minimize_win, minimize_states, close_active, close_progress, close_win)
    else:
        if active == 1:
            draw_single_window(2, 0, 0, theme, minimize_active, minimize_progress, minimize_win, minimize_states, close_active, close_progress, close_win)
            draw_single_window(0, 0, 0, theme, minimize_active, minimize_progress, minimize_win, minimize_states, close_active, close_progress, close_win)
            draw_single_window(1, boff, 1, theme, minimize_active, minimize_progress, minimize_win, minimize_states, close_active, close_progress, close_win)
        else:
            draw_single_window(0, 0, 0, theme, minimize_active, minimize_progress, minimize_win, minimize_states, close_active, close_progress, close_win)
            draw_single_window(1, 0, 0, theme, minimize_active, minimize_progress, minimize_win, minimize_states, close_active, close_progress, close_win)
            draw_single_window(2, boff, 1, theme, minimize_active, minimize_progress, minimize_win, minimize_states, close_active, close_progress, close_win)

    # ARM64 verification path: direct bar/dock primitives avoid the layout
    # engine while still exercising the framebuffer-backed window manager.
    blend(0, 0, 1024, 28, 0x001E1E23, 160)
    blend(0, 27, 1024, 1, 0x00FFFFFF, 80)
    draw_label_shadow(16, 8, 0x00F5F5F7, 220, pack8(83, 105, 109, 112, 108, 101, 79, 83), 8, 40)
    draw_label_shadow(890, 8, 0x00EBEBF5, 180, pack8(65, 82, 77, 54, 52, 32, 87, 77), 8, 40)

    val dock_x: u64 = 292
    val dock_y: u64 = 700
    val dock_w: u64 = 440
    val dock_h: u64 = 56
    rrect_aa(dock_x, dock_y, dock_w, dock_h, 0x001E1E23, 24, 180)
    rrect_aa(dock_x, dock_y, dock_w, dock_h, 0x00FFFFFF, 24, 55)
    var icon_x: u64 = dock_x + 20
    var icon_i: u64 = 0
    while icon_i < 7:
        rrect_aa(icon_x, dock_y + 8, 40, 40, 0x000A84FF + icon_i * 0x00101008, 10, 230)
        blend(icon_x + 4, dock_y + 12, 32, 8, 0x00FFFFFF, 30)
        icon_x = icon_x + 58
        icon_i = icon_i + 1

    blend(0, 768 - 2, 1024, 2, 0x00000000, 20)
    blend(1024 / 2 - 200, 0, 400, 20, 0x00FFFFFF, 3)
    blend(0, 0, 1024, 768, 0x000A84FF, 2)

    rt_gui_present(0, 0, 0, 0)

# ===========================================================================
# Entry Point — ARM64 QEMU virt
# ===========================================================================

fn spl_start():
    serial_println("[WM] SimpleOS Glass Window Manager (ARM64) starting...")

    # 1. Allocate framebuffer in RAM
    serial_println("[WM] Allocating framebuffer (1024x768x32 = 3MB)...")
    val fb_addr = rt_alloc(3145728)
    if fb_addr == 0:
        serial_println("[WM] FATAL: Failed to allocate framebuffer")
        return

    # Tell glass_render.c where the framebuffer is
    rt_gui_set_fb(fb_addr, 1024)
    serial_println("[WM] Framebuffer allocated and registered")

    # 2. Configure QEMU ramfb to display from our buffer
    val ramfb_ok = setup_ramfb(fb_addr)
    if ramfb_ok == 0:
        serial_println("[WM] NOTE: No ramfb device -- rendering to shadow buffer only")
        serial_println("[WM] Add '-device ramfb' to QEMU command line for display")

    # 3. Boot splash screen
    serial_println("[WM] Showing boot splash...")
    rt_gui_begin_frame(1024, 768, 0, 0)

    rt_gui_draw_wallpaper(pack(1024, 768), 0, 0, 0)

    val splash_w: u64 = 300
    val splash_h: u64 = 140
    val splash_x = (1024 - splash_w) / 2
    val splash_y = (768 - splash_h) / 2 - 40

    blur(splash_x, splash_y, splash_w, splash_h, 24)
    rrect_aa(splash_x, splash_y, splash_w, splash_h, 0x001E1E23, 28, 140)
    blend(splash_x + 4, splash_y + 1, splash_w - 8, 1, 0x00FFFFFF, 40)
    blend(splash_x + 6, splash_y + 2, splash_w - 12, 1, 0x00FFFFFF, 20)
    rrect_aa(splash_x, splash_y, splash_w, splash_h, 0x00FFFFFF, 28, 25)

    # "SimpleOS" in vector font at 40px
    draw_label_vector(splash_x + 70, splash_y + 16, 0x00F5F5F7, 240, pack8(83, 105, 109, 112, 108, 101, 79, 83), 8, 40)

    # "v1.0"
    draw_label_shadow(splash_x + 130, splash_y + 60, 0x00EBEBF5, 160, pack8(118, 49, 46, 48, 0, 0, 0, 0), 4, 40)

    # Loading bar
    val bar_y = splash_y + 90
    rrect_aa(splash_x + 40, bar_y, splash_w - 80, 8, 0x00FFFFFF, 4, 30)
    grad_h(splash_x + 40, bar_y + 1, (splash_w - 80) * 2 / 3, 6, 0x000A84FF, 0x00BB86FC)
    rrect_aa(splash_x + 40, bar_y, (splash_w - 80) * 2 / 3, 8, 0x00FFFFFF, 4, 20)

    # "Starting..." + "ARM64" platform tag
    draw_label_shadow((1024 - 72) / 2, splash_y + splash_h + 20, 0x00EBEBF5, 120, pack8(83, 116, 97, 114, 116, 105, 110, 103), 8, 40)
    draw_label(splash_x + 56, splash_y + splash_h + 40, 0x00EBEBF5, 60, pack8(65, 82, 77, 54, 52, 32, 32, 32), 5)

    rt_gui_present(0, 0, 0, 0)

    # Brief pause for splash
    var splash_wait: u64 = 0
    while splash_wait < 2000000:
        splash_wait = splash_wait + 1

    # 4. Initial render
    var theme: u64 = 0
    var active_win: u64 = 1
    var anim_progress: u64 = 100
    var minimize_active: u64 = 0
    var minimize_progress: u64 = 0
    var minimize_win: u64 = 0
    var minimize_states: u64 = 0
    var close_active: u64 = 0
    var close_progress: u64 = 0
    var close_win: u64 = 0

    var anim_frame: u64 = 0
    var anim_start: u64 = 0
    var anim_duration: u64 = 12
    var animating: u64 = 0
    var needs_redraw: u64 = 1
    var idle_count: u64 = 0

    serial_println("[WM] Rendering glass desktop (dark theme)...")
    draw_desktop(active_win, theme, anim_progress, minimize_active, minimize_progress, minimize_win, minimize_states, close_active, close_progress, close_win)

    serial_println("[WM] Glass desktop rendered!")
    serial_println("[WM] Controls (UART): Tab=cycle, 1/2/3=focus, t=theme, m=minimize, r=restore, q=quit")

    # 5. Main loop -- UART input
    var running: u64 = 1
    while running == 1:
        # Poll PL011 UART for keyboard input
        if uart_data_ready() == 1:
            val ch = uart_read_char()
            val action = uart_char_to_action(ch)

            # CycleFocus (action 1)
            if action == 1:
                active_win = (active_win + 1) % 3
                animating = 1
                anim_start = anim_frame
                anim_progress = 0
                needs_redraw = 1
                serial_println("[WM] Focus cycled")

            # FocusWindow(0) (action 10)
            if action == 10:
                active_win = 0
                animating = 1
                anim_start = anim_frame
                anim_progress = 0
                needs_redraw = 1
                serial_println("[WM] Focus: Terminal")

            # FocusWindow(1) (action 11)
            if action == 11:
                active_win = 1
                animating = 1
                anim_start = anim_frame
                anim_progress = 0
                needs_redraw = 1
                serial_println("[WM] Focus: Editor")

            # FocusWindow(2) (action 12)
            if action == 12:
                active_win = 2
                animating = 1
                anim_start = anim_frame
                anim_progress = 0
                needs_redraw = 1
                serial_println("[WM] Focus: Finder")

            # ToggleTheme (action 2)
            if action == 2:
                theme = (theme + 1) % 2
                animating = 1
                anim_start = anim_frame
                anim_progress = 0
                needs_redraw = 1
                if theme == 0:
                    serial_println("[WM] Theme: Dark Glass")
                else:
                    serial_println("[WM] Theme: White Glass")

            # Quit (action 3)
            if action == 3:
                running = 0
                serial_println("[WM] Quit requested")

            # Minimize (action 4)
            if action == 4:
                val already_minimized = (minimize_states >> active_win) & 1
                if minimize_active == 0 and already_minimized == 0:
                    minimize_active = 1
                    minimize_progress = 0
                    minimize_win = active_win
                    needs_redraw = 1
                    serial_println("[WM] Minimizing window")

            # Close (action 5)
            if action == 5:
                if close_active == 0:
                    close_active = 1
                    close_progress = 0
                    close_win = active_win
                    needs_redraw = 1
                    serial_println("[WM] Closing window")

            # Restore (action 6)
            if action == 6:
                if minimize_states != 0:
                    minimize_states = 0
                    needs_redraw = 1
                    serial_println("[WM] Restored all windows")

        # Update focus animation
        if animating == 1:
            val elapsed = anim_frame - anim_start
            if elapsed >= anim_duration:
                animating = 0
                anim_progress = 100
            else:
                anim_progress = (elapsed * 100) / anim_duration
            needs_redraw = 1

        # Minimize animation tick
        if minimize_active == 1:
            minimize_progress = minimize_progress + 12
            if minimize_progress >= 100:
                minimize_progress = 100
                minimize_active = 0
                minimize_states = minimize_states | (1 << minimize_win)
                var next_win: u64 = (active_win + 1) % 3
                var search: u64 = 0
                while search < 3:
                    val next_min = (minimize_states >> next_win) & 1
                    if next_min == 0:
                        search = 3
                    else:
                        next_win = (next_win + 1) % 3
                    search = search + 1
                active_win = next_win
                serial_println("[WM] Window minimized to dock")
            needs_redraw = 1

        # Close animation tick
        if close_active == 1:
            close_progress = close_progress + 16
            if close_progress >= 100:
                close_progress = 100
                close_active = 0
                minimize_states = minimize_states | (1 << close_win)
                active_win = (active_win + 1) % 3
            needs_redraw = 1

        # Redraw if needed
        if needs_redraw == 1:
            draw_desktop(active_win, theme, anim_progress, minimize_active, minimize_progress, minimize_win, minimize_states, close_active, close_progress, close_win)
            needs_redraw = 0
            idle_count = 0

        anim_frame = anim_frame + 1

        # Throttle when idle
        if animating == 0 and minimize_active == 0 and close_active == 0:
            idle_count = idle_count + 1
            var spin: u64 = 0
            while spin < 50000:
                spin = spin + 1

    serial_println("[WM] Window Manager shutting down")
