# ARM64 filesystem executable acceptance entry.

use os.kernel.arch.hal.{hal_console_init, hal_console_writeln}
use os.services.vfs.vfs_init.{vfs_boot_init}
use os.kernel.scheduler.scheduler.{Scheduler}
use os.kernel.log.klog.{KernelLog}
use os.kernel.ipc.syscall.{dispatch_spawn_binary_direct}

fn qemu_exit_success():
    asm """
        mov x0, #0x18
        hlt #0xF000
    """

fn spl_start():
    hal_console_init()
    hal_console_writeln("")
    hal_console_writeln("=== SimpleOS ARM64 FS exec boot ===")

    if not vfs_boot_init():
        hal_console_writeln("[arm-fs-exec] vfs:fail")
        hal_console_writeln("TEST FAILED")
        qemu_exit_success()
        return

    var scheduler = Scheduler.new_bootstrap()
    val pid = dispatch_spawn_binary_direct(103, 0, 2, scheduler, KernelLog.new(64))
    if pid <= 0:
        hal_console_writeln("[arm-fs-exec] spawn:fail")
        hal_console_writeln("TEST FAILED")
        qemu_exit_success()
        return

    hal_console_writeln("[arm-fs-exec] vfs:ok")
    hal_console_writeln("[arm-fs-exec] smf:/sys/apps/hello_world.smf")
    hal_console_writeln("[arm-fs-exec] user-process pid={pid}")
    hal_console_writeln("TEST PASSED")
    qemu_exit_success()
