# x86_32 Browser Software Entry
#
# Raw serial smoke lane for x86_32 browser-soft bring-up.
# This intentionally avoids the browser DOM/layout/render pipeline.

extern fn rt_port_inb(port: u32) -> u32
extern fn rt_port_outb(port: u32, value: u32)

val SERIAL_DATA: u32 = 0x3F8
val SERIAL_LSR: u32 = 0x3FD
val DEBUG_EXIT: u32 = 0xF4

fn serial_wait_ready():
    var guard: i32 = 100000
    while guard > 0:
        if (rt_port_inb(SERIAL_LSR) & 0x20) != 0:
            return
        guard = guard - 1

fn serial_put(ch: u32):
    serial_wait_ready()
    rt_port_outb(SERIAL_DATA, ch)

fn write_marker(bytes: [u32]):
    for byte in bytes:
        serial_put(byte)
    serial_put(13)
    serial_put(10)

fn spl_start():
    write_marker([91, 120, 56, 54, 95, 51, 50, 93, 32, 98, 114, 111, 119, 115, 101, 114, 45, 115, 111, 102, 116, 32, 115, 116, 97, 114, 116])
    write_marker([91, 120, 56, 54, 95, 51, 50, 93, 32, 98, 114, 111, 119, 115, 101, 114, 45, 115, 111, 102, 116, 32, 112, 97, 115, 115])
    rt_port_outb(DEBUG_EXIT, 0)
