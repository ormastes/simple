#![allow(unknown_attribute)]
#![allow(unnamed_duplicate_typed_args)]

use os.kernel.arch.riscv64.boot_info.{
    rv64_boot_dtb_address, rv64_boot_dtb_valid, rv64_boot_hart_id,
    rv64_boot_parse_boot_info, rv64_boot_ram_base, rv64_boot_ram_size,
    rv64_boot_save_boot_args, rv64_boot_uart_base
}
use examples.simple_os.arch.riscv64.ghdl_boot_info_proof_layout.{
    proof_emit_marker, proof_store_bool, proof_store_u64
}

val KERNEL_LOAD_BASE: u64 = 0x80200000
val KERNEL_LOAD_SIZE: u64 = 0x00200000
val MEMORY_MAP_LEN: u64 = 3
val REGION_KIND_USABLE: u64 = 1
val REGION_KIND_RESERVED: u64 = 2
val REGION_KIND_KERNEL: u64 = 8

@section(".text.entry")
@naked
fn _start():
    asm volatile:
        "mv      s0, a0"
        "mv      s1, a1"
        "la      sp, _stack_top"
        "mv      a0, s0"
        "mv      a1, s1"
        "call    ghdl_boot_info_entry__boot_main"
        "j       ghdl_boot_info_entry___halt"

fn _halt():
    asm volatile:
        "ebreak"
        ".Lghdl_boot_info_halt:"
        "wfi"
        "j .Lghdl_boot_info_halt"

fn _record_boot_regions():
    val ram_base = rv64_boot_ram_base()
    val ram_size = rv64_boot_ram_size()
    val usable_base = KERNEL_LOAD_BASE + KERNEL_LOAD_SIZE
    val usable_size = (ram_base + ram_size) - usable_base
    val serial_mmio: bool = true
    val memory_map_len = MEMORY_MAP_LEN
    val region0_base = ram_base
    val region0_size = KERNEL_LOAD_BASE - ram_base
    val region0_kind = REGION_KIND_RESERVED
    val region1_base = KERNEL_LOAD_BASE
    val region1_size = KERNEL_LOAD_SIZE
    val region1_kind = REGION_KIND_KERNEL
    val region2_base = usable_base
    val region2_size = usable_size
    val region2_kind = REGION_KIND_USABLE

    proof_store_u64(7, rv64_boot_uart_base())
    proof_store_bool(8, serial_mmio)
    proof_store_u64(9, memory_map_len)

    proof_store_u64(10, region0_base)
    proof_store_u64(11, region0_size)
    proof_store_u64(12, region0_kind)

    proof_store_u64(13, region1_base)
    proof_store_u64(14, region1_size)
    proof_store_u64(15, region1_kind)

    proof_store_u64(16, region2_base)
    proof_store_u64(17, region2_size)
    proof_store_u64(18, region2_kind)

fn boot_main(hart_id: u64, dtb_addr: u64):
    val proof_magic: u64 = 0x42494F50524F4F46
    val done_clear: u64 = 0
    val done_set: u64 = 1
    proof_store_u64(0, proof_magic)
    proof_store_u64(1, done_clear)
    rv64_boot_save_boot_args(hart_id, dtb_addr)
    val _boot_info = rv64_boot_parse_boot_info()
    proof_store_u64(2, rv64_boot_hart_id())
    proof_store_u64(3, rv64_boot_dtb_address())
    proof_store_bool(4, rv64_boot_dtb_valid())
    proof_store_u64(5, rv64_boot_ram_base())
    proof_store_u64(6, rv64_boot_ram_size())
    _record_boot_regions()
    proof_emit_marker()
    proof_store_u64(1, done_set)
    _halt()
