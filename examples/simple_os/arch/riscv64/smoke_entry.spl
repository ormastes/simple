extern fn serial_println(msg: text)
extern fn rt_qemu_exit_success()
extern fn rt_riscv_nvfs_probe() -> i64
extern fn rt_riscv_smf_cli_probe() -> i64
extern fn rt_riscv_smf_gui_probe() -> i64

fn spl_start():
    serial_println("")
    serial_println("=== SimpleOS RV64 smoke boot ===")
    serial_println("SimpleOS RV64 boot OK")
    if rt_riscv_nvfs_probe() == 1:
        serial_println("[riscv-nvfs] image read ok")
    else:
        serial_println("[riscv-nvfs] image read failed")
        serial_println("TEST FAILED")
        rt_qemu_exit_success()
        return
    if rt_riscv_smf_cli_probe() == 1:
        serial_println("FS_MOUNT_OK")
        serial_println("SMF_DISCOVERY_OK")
        serial_println("SMF_CLI_LAUNCH_OK app=/sys/apps/hello_world.smf")
    else:
        serial_println("[riscv-smf] cli launch probe failed")
        serial_println("TEST FAILED")
        rt_qemu_exit_success()
        return
    if rt_riscv_smf_gui_probe() == 1:
        serial_println("SMF_WM_GUI_LAUNCH_OK app=/sys/apps/browser_demo.smf wm=manifest")
    else:
        serial_println("[riscv-smf] wm gui launch probe failed")
        serial_println("TEST FAILED")
        rt_qemu_exit_success()
        return
    serial_println("SIMPLEOS_RISCV_SMF_FS_PASS")
    serial_println("TEST PASSED")
    rt_qemu_exit_success()
