extern fn serial_println(msg: text)
extern fn rt_riscv_nvfs_probe() -> i64
extern fn rt_riscv_smf_cli_probe() -> i64
extern fn rt_riscv_smf_cli_load() -> i64
extern fn rt_riscv_smf_gui_probe() -> i64
extern fn rt_riscv_native_gui_process_render() -> i64

fn spl_start():
    serial_println("")
    serial_println("=== SimpleOS RV64 hosted preflight ===")
    serial_println("SimpleOS RV64 boot OK")

    if rt_riscv_nvfs_probe() != 1:
        serial_println("[hosted] storage: unreadable")
        serial_println("HOSTED_PREFLIGHT_FAILED stage=storage")
        serial_println("TEST FAILED")
        return

    if rt_riscv_smf_cli_probe() != 1:
        serial_println("[hosted] cli package probe failed")
        serial_println("HOSTED_PREFLIGHT_FAILED stage=cli-discovery")
        serial_println("TEST FAILED")
        return

    if rt_riscv_smf_cli_load() != 1:
        serial_println("[hosted] cli package load failed")
        serial_println("HOSTED_PREFLIGHT_FAILED stage=cli-load")
        serial_println("TEST FAILED")
        return

    if rt_riscv_smf_gui_probe() != 1:
        serial_println("[hosted] gui package probe failed")
        serial_println("HOSTED_PREFLIGHT_FAILED stage=gui-discovery")
        serial_println("TEST FAILED")
        return

    if rt_riscv_native_gui_process_render() != 1:
        serial_println("[hosted] gui render probe failed")
        serial_println("HOSTED_PREFLIGHT_FAILED stage=gui-render")
        serial_println("TEST FAILED")
        return

    serial_println("FS_MOUNT_OK")
    serial_println("SMF_DISCOVERY_OK")
    serial_println("ELF_LOAD_OK arch=riscv64 app=/sys/apps/hello_world.smf")
    serial_println("SMF_CLI_LAUNCH_OK app=/sys/apps/hello_world.smf")
    serial_println("SMF_WM_GUI_LAUNCH_OK app=/sys/apps/browser_demo.smf pid=1002 wm=x86_64_desktop_shell_contract")
    serial_println("NATIVE_GUI_PROCESS_RENDER_OK app=/sys/apps/browser_demo.smf pid=1002")
    serial_println("HOSTED_PREFLIGHT_READY")
    serial_println("HOSTED_NETWORK_UNAVAILABLE arch=riscv64 reason=guest-network-runtime-missing")
    serial_println("HOSTED_SSH_UNAVAILABLE arch=riscv64 reason=guest-network-runtime-missing")
    serial_println("HOSTED_HTTP_UNAVAILABLE arch=riscv64 reason=guest-network-runtime-missing")
    serial_println("HOSTED_PROOF_PENDING reason=smoke-media-only-rv64-ssh-http-not-yet-real")

    while true:
        continue
