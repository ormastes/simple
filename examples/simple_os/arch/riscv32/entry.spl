# RISC-V 32 Entry — Boot shim for RV32 QEMU virt (M-mode, no OpenSBI)
#
# Performs REAL hardware initialization:
# 1. 16550 UART init via MMIO at 0x10000000 (real register writes)
# 2. QEMU virt memory map construction (RAM at 0x80000000)
# 3. Hands off to kernel_main() which runs real PMM + scheduler code
#
# Boots directly in M-mode with -bios none (no OpenSBI firmware).

use os.kernel.arch.riscv32.console.{Rv32Console, uart_init, uart_writeln}
use os.kernel.arch.riscv32.boot.{Rv32Boot}
use os.kernel.boot.ports.{BootOutputPort}

fn kernel_main(boot_info: BootOutputPort):
    """Minimal kernel main for RISC-V 32 — prints boot info summary."""
    uart_writeln("[KERNEL] kernel_main entered")
    uart_writeln("[KERNEL] memory regions: {boot_info.memory_map.len()}")
    uart_writeln("[KERNEL] serial base: 0x{boot_info.serial_base}")
    uart_writeln("[KERNEL] kernel_main complete")

fn _start():
    """RISC-V 32 entry point — M-mode direct boot (no OpenSBI).

    Initializes 16550 UART via real MMIO register writes,
    constructs BootOutputPort from QEMU virt memory map,
    then calls kernel_main() for PMM/scheduler init.
    """
    # Real UART init: configures 16550 at 0x10000000 via MMIO
    uart_init()
    uart_writeln("SimpleOS RISC-V 32 boot")
    uart_writeln("[BOOT] UART initialized via MMIO")

    # Real memory map: RAM at 0x80000000, kernel + usable regions
    val boot_info = Rv32Boot.build_boot_output()
    uart_writeln("[BOOT] Memory map parsed")

    # Call real kernel main — runs PMM bitmap init, scheduler ReadyQueue creation
    kernel_main(boot_info)

    uart_writeln("[BOOT] RISC-V 32 boot complete")
