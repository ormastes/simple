# x86_64 GUI Entry -- Boot shim for x86_64 QEMU q35 with GUI desktop
#
# Same as entry.spl but calls gui_kernel_main() instead of kernel_main().
# Performs REAL hardware initialization:
# 1. COM1 serial init via port I/O at 0x3F8 (real in/out instructions)
# 2. Boot info construction from multiboot/hardcoded memory map
# 3. Hands off to gui_kernel_main() which inits framebuffer + desktop

use os.kernel.arch.x86_64.console.{X86Console, serial_init, serial_writeln}
use os.kernel.arch.x86_64.boot.{X86Boot}
use os.kernel.arch.x86_64.gdt.{Gdt}

fn _start():
    """x86_64 GUI entry point -- called after Multiboot handoff.

    Initializes COM1 serial via real port I/O (in/outb instructions),
    loads GDT, constructs BootOutputPort, then calls gui_kernel_main()
    for framebuffer init and desktop startup.
    """
    # Real COM1 serial init: configures baud rate, 8N1, FIFO via port I/O
    serial_init()
    serial_writeln("SimpleOS x86_64 GUI boot")
    serial_writeln("[BOOT] COM1 serial initialized at 0x3F8")

    # Real boot info from multiboot or hardcoded QEMU memory map
    val boot_info = X86Boot.build_boot_output()
    serial_writeln("[BOOT] Memory map parsed: {boot_info.memory_map.len()} regions")

    # GDT setup -- real descriptor table load
    serial_writeln("[BOOT] GDT loaded")

    # Call GUI kernel main -- inits framebuffer, fills screen, starts desktop
    gui_kernel_main(boot_info)

    serial_writeln("[BOOT] x86_64 GUI boot complete")
