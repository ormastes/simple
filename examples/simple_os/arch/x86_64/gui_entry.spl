# x86_64 GUI Entry -- Boot shim for x86_64 QEMU q35 with GUI desktop
#
# BGA-based boot (no Limine bootloader needed):
# 1. COM1 serial init via port I/O at 0x3F8
# 2. BGA framebuffer init via I/O ports (programs Bochs VGA directly)
# 3. Manual BootOutputPort construction with BGA framebuffer info
# 4. Hands off to gui_kernel_main() which inits compositor + desktop shell

use os.kernel.arch.x86_64.console.{serial_init, serial_writeln}
use os.drivers.framebuffer.bga_init.{bga_init_framebuffer}
use os.kernel.boot.ports.{BootOutputPort, BootMemoryRegion, MemoryRegionKind}
use os.kernel.types.memory_types.{PhysAddr, VirtAddr}
use os.kernel.arch.arch_context.{Architecture}

fn spl_start():
    """x86_64 GUI entry point -- called after Multiboot handoff from crt0.s.

    Initializes COM1 serial, programs BGA framebuffer via I/O ports,
    constructs BootOutputPort manually, then calls gui_kernel_main()
    which creates the compositor, desktop shell, and enters the event loop.
    """
    # Real COM1 serial init: configures baud rate, 8N1, FIFO via port I/O
    serial_init()
    serial_writeln("SimpleOS x86_64 GUI boot (BGA mode)")
    serial_writeln("[BOOT] COM1 serial initialized at 0x3F8")

    # Init BGA framebuffer -- programs Bochs VGA via I/O ports
    serial_writeln("[BOOT] Initializing BGA framebuffer (1024x768x32)...")
    val fb_info = bga_init_framebuffer(1024, 768, 32)
    serial_writeln("[BOOT] BGA framebuffer ready: {fb_info.width}x{fb_info.height} at 0x{fb_info.addr.addr}")

    # Build boot info manually (no Limine needed)
    # Memory: 128MB QEMU RAM, kernel at 1MB, usable region above kernel
    val boot_info = BootOutputPort(
        memory_map: [
            BootMemoryRegion(
                base: PhysAddr(addr: 0x200000),
                size: 0x7E00000,
                kind: MemoryRegionKind.Usable
            )
        ],
        framebuffer: fb_info,
        rsdp_addr: nil,
        kernel_phys_base: PhysAddr(addr: 0x100000),
        kernel_virt_base: VirtAddr(addr: 0x100000),
        kernel_size: 0x100000,
        serial_base: 0x3F8,
        serial_is_mmio: false,
        arch: Architecture.X86_64,
        hhdm_offset: 0
    )

    serial_writeln("[BOOT] Handing off to GUI kernel main...")
    gui_kernel_main(boot_info)

    serial_writeln("[BOOT] x86_64 GUI boot complete")
