# x86_64 Tools Test Entry — uses os_main.spl for all tool tests
#
# Build: PATH="/opt/homebrew/opt/llvm/bin:$PATH" bin/simple native-build \
#          --entry examples/simple_os/arch/x86_64/tools_test_entry.spl \
#          --source src/os --source src/lib \
#          --target x86_64-unknown-none \
#          -o build/os/simpleos_tools_test_x86_64.elf \
#          --linker-script examples/simple_os/arch/x86_64/linker.ld
#
# Run: qemu-system-x86_64 -machine q35 -cpu qemu64 -m 512M -serial stdio \
#        -display none -no-reboot \
#        -drive file=build/os/fat32.img,if=none,id=nvm,format=raw \
#        -device nvme,serial=deadbeef,drive=nvm \
#        -device isa-debug-exit,iobase=0xf4,iosize=0x04 \
#        -kernel build/os/simpleos_tools_test_x86_64.elf

extern fn serial_println(msg: text)
extern fn rt_port_outb(port: u16, value: u8)

# os_main runs all tool tests (lives in src/os/ where imports resolve)
use os.kernel.boot.os_main.{os_main}

fn _start():
    os_main()

    # Exit via isa-debug-exit
    rt_port_outb(0xf4, 0)
