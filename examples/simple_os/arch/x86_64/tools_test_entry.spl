# x86_64 Tools Test Entry — Exercise all shell tools on QEMU
#
# Boots SimpleOS, wires VFS + tool registry to the shell, then
# programmatically runs every built-in and external tool.
# Reports pass/fail via serial. Exits via isa-debug-exit.
#
# Build: bin/simple native-build --entry examples/simple_os/arch/x86_64/tools_test_entry.spl \
#          --target x86_64-unknown-none -o build/os/simpleos_tools_test_x86_64.elf \
#          --linker-script examples/simple_os/arch/x86_64/linker.ld
# Run:   qemu-system-x86_64 -machine q35 -cpu qemu64 -m 256M -serial stdio -display none \
#          -no-reboot -drive file=build/os/fat32.img,if=none,id=nvm,format=raw \
#          -device nvme,serial=deadbeef,drive=nvm \
#          -device isa-debug-exit,iobase=0xf4,iosize=0x04 \
#          -kernel build/os/simpleos_tools_test_x86_64.elf

extern fn serial_println(msg: text)
extern fn rt_port_outb(port: u16, value: u8)

# POSIX init
use os.posix.fd_table.{fd_table_init}
use os.posix.async_io.{async_io_init}
use os.posix.signal_compat.{signal_init}

# Services
use os.kernel.boot.init_services.{init_all_services, services_storage_ready}
use os.services.vfs.vfs_init.{vfs_get_manager}

# Shell
use os.apps.shell.shell_app.{ShellApp}

# Tool registry
use os.tools.tool_registry.{ToolRegistry, ToolEntry}

# External tools — proc
use os.tools.proc.ps_tool.{run_ps}
use os.tools.proc.kill_tool.{run_kill}
use os.tools.proc.nice_tool.{run_nice}
use os.tools.proc.top_tool.{run_top}

# External tools — dev
use os.tools.dev.lspci_tool.{run_lspci}
use os.tools.dev.lsblk_tool.{run_lsblk}
use os.tools.dev.lsusb_tool.{run_lsusb}
use os.tools.dev.devinfo_tool.{run_devinfo}

# External tools — net
use os.tools.net.ping_tool.{run_ping}
use os.tools.net.ifconfig_tool.{run_ifconfig}
use os.tools.net.netstat_tool.{run_netstat}
use os.tools.net.wget_tool.{run_wget}
use os.tools.net.dhcp_client.{run_dhcp}
use os.tools.net.dns_tool.{run_dns}

# External tools — archive
use os.tools.archive.tar_tool.{run_tar}
use os.tools.archive.gzip_tool.{run_gzip}
use os.tools.archive.zip_tool.{run_zip}

# External tools — boot
use os.tools.boot.boot_manager.{run_bootctl}
use os.tools.boot.boot_recovery.{run_boot_recovery}

# External tools — log
use os.tools.log.log_viewer.{run_log}

# External tools — pkg
use os.tools.pkg.pkg_manager.{run_pkg}

# ===========================================================================
# Test Harness
# ===========================================================================

var g_pass: i32 = 0
var g_fail: i32 = 0

fn test_ok(name: text):
    serial_println("[PASS] {name}")
    g_pass = g_pass + 1

fn test_fail(name: text):
    serial_println("[FAIL] {name}")
    g_fail = g_fail + 1

fn test_exit_code(code: i32, name: text):
    """Test that a tool returns exit code 0."""
    if code == 0:
        test_ok(name)
    else:
        serial_println("[FAIL] {name} (exit code {code})")
        g_fail = g_fail + 1

fn test_exit_code_any(code: i32, name: text):
    """Test that a tool runs without crashing (any exit code is ok)."""
    test_ok(name)

# ===========================================================================
# Tool Registration
# ===========================================================================

fn register_all_tools() -> ToolRegistry:
    var registry = ToolRegistry.new()

    # Process tools
    registry.register(ToolEntry(name: "ps", description: "List processes", category: "proc", run_fn: run_ps, capabilities: []))
    registry.register(ToolEntry(name: "kill", description: "Send signal", category: "proc", run_fn: run_kill, capabilities: []))
    registry.register(ToolEntry(name: "nice", description: "Set priority", category: "proc", run_fn: run_nice, capabilities: []))
    registry.register(ToolEntry(name: "top", description: "Process monitor", category: "proc", run_fn: run_top, capabilities: []))

    # Device tools
    registry.register(ToolEntry(name: "lspci", description: "List PCI devices", category: "dev", run_fn: run_lspci, capabilities: []))
    registry.register(ToolEntry(name: "lsblk", description: "List block devices", category: "dev", run_fn: run_lsblk, capabilities: []))
    registry.register(ToolEntry(name: "lsusb", description: "List USB devices", category: "dev", run_fn: run_lsusb, capabilities: []))
    registry.register(ToolEntry(name: "devinfo", description: "Device info", category: "dev", run_fn: run_devinfo, capabilities: []))

    # Network tools
    registry.register(ToolEntry(name: "ping", description: "ICMP ping", category: "net", run_fn: run_ping, capabilities: []))
    registry.register(ToolEntry(name: "ifconfig", description: "Network interfaces", category: "net", run_fn: run_ifconfig, capabilities: []))
    registry.register(ToolEntry(name: "netstat", description: "Network stats", category: "net", run_fn: run_netstat, capabilities: []))
    registry.register(ToolEntry(name: "wget", description: "HTTP download", category: "net", run_fn: run_wget, capabilities: []))
    registry.register(ToolEntry(name: "dhcp", description: "DHCP client", category: "net", run_fn: run_dhcp, capabilities: []))
    registry.register(ToolEntry(name: "dns", description: "DNS lookup", category: "net", run_fn: run_dns, capabilities: []))

    # Archive tools
    registry.register(ToolEntry(name: "tar", description: "Archive tool", category: "archive", run_fn: run_tar, capabilities: []))
    registry.register(ToolEntry(name: "gzip", description: "Compression", category: "archive", run_fn: run_gzip, capabilities: []))
    registry.register(ToolEntry(name: "zip", description: "ZIP archive", category: "archive", run_fn: run_zip, capabilities: []))

    # Boot tools
    registry.register(ToolEntry(name: "bootctl", description: "Boot manager", category: "boot", run_fn: run_bootctl, capabilities: []))
    registry.register(ToolEntry(name: "boot-recovery", description: "Boot recovery", category: "boot", run_fn: run_boot_recovery, capabilities: []))

    # Log tools
    registry.register(ToolEntry(name: "log", description: "Log viewer", category: "log", run_fn: run_log, capabilities: []))

    # Package tools
    registry.register(ToolEntry(name: "pkg", description: "Package manager", category: "pkg", run_fn: run_pkg, capabilities: []))

    registry

# ===========================================================================
# Filesystem Tool Tests (via shell.execute)
# ===========================================================================

fn test_filesystem_tools(shell: ShellApp):
    serial_println("")
    serial_println("=== Filesystem Tools ===")
    serial_println("")

    # pwd
    serial_println("[test] pwd")
    shell.execute("pwd")
    test_ok("pwd")

    # ls /
    serial_println("[test] ls /")
    shell.execute("ls /")
    test_ok("ls /")

    # mkdir /tooltest
    serial_println("[test] mkdir /tooltest")
    shell.execute("mkdir /tooltest")
    test_ok("mkdir /tooltest")

    # ls / (should show tooltest now)
    serial_println("[test] ls / (after mkdir)")
    shell.execute("ls /")
    test_ok("ls / after mkdir")

    # cat /hello.txt
    serial_println("[test] cat /hello.txt")
    shell.execute("cat /hello.txt")
    test_ok("cat /hello.txt")

    # echo
    serial_println("[test] echo hello world")
    shell.execute("echo hello world")
    test_ok("echo")

    # find /
    serial_println("[test] find /")
    shell.execute("find /")
    test_ok("find /")

    # grep Hello /hello.txt
    serial_println("[test] grep Hello /hello.txt")
    shell.execute("grep Hello /hello.txt")
    test_ok("grep")

    # help
    serial_println("[test] help")
    shell.execute("help")
    test_ok("help")

    # env
    serial_println("[test] env")
    shell.execute("env")
    test_ok("env")

    # history
    serial_println("[test] history")
    shell.execute("history")
    test_ok("history")

    # hostname
    serial_println("[test] hostname")
    shell.execute("hostname")
    test_ok("hostname")

    # uptime
    serial_println("[test] uptime")
    shell.execute("uptime")
    test_ok("uptime")

    # dmesg
    serial_println("[test] dmesg")
    shell.execute("dmesg")
    test_ok("dmesg")

    # ps (built-in)
    serial_println("[test] ps (built-in)")
    shell.execute("ps")
    test_ok("ps (built-in)")

# ===========================================================================
# External Tool Tests (direct run_fn calls)
# ===========================================================================

fn test_dev_tools():
    serial_println("")
    serial_println("=== Device Tools ===")
    serial_println("")

    serial_println("[test] lspci")
    val r1 = run_lspci([])
    test_exit_code_any(r1, "lspci")

    serial_println("[test] lspci -v")
    val r2 = run_lspci(["-v"])
    test_exit_code_any(r2, "lspci -v")

    serial_println("[test] lsblk")
    val r3 = run_lsblk([])
    test_exit_code_any(r3, "lsblk")

    serial_println("[test] lsusb")
    val r4 = run_lsusb([])
    test_exit_code_any(r4, "lsusb")

    serial_println("[test] devinfo")
    val r5 = run_devinfo([])
    test_exit_code_any(r5, "devinfo")

fn test_proc_tools():
    serial_println("")
    serial_println("=== Process Tools ===")
    serial_println("")

    serial_println("[test] ps")
    val r1 = run_ps([])
    test_exit_code_any(r1, "ps tool")

    serial_println("[test] ps -l")
    val r2 = run_ps(["-l"])
    test_exit_code_any(r2, "ps -l")

    serial_println("[test] kill (no args)")
    val r3 = run_kill([])
    test_exit_code_any(r3, "kill (no args)")

    serial_println("[test] nice (no args)")
    val r4 = run_nice([])
    test_exit_code_any(r4, "nice (no args)")

    # NOTE: top with -n 1 runs one iteration then exits
    serial_println("[test] top -n 1")
    val r5 = run_top(["-n", "1"])
    test_exit_code_any(r5, "top -n 1")

fn test_net_tools():
    serial_println("")
    serial_println("=== Network Tools (help-only, no NIC) ===")
    serial_println("")

    serial_println("[test] ifconfig")
    val r1 = run_ifconfig([])
    test_exit_code_any(r1, "ifconfig")

    serial_println("[test] netstat")
    val r2 = run_netstat([])
    test_exit_code_any(r2, "netstat")

    serial_println("[test] ping -h")
    val r3 = run_ping(["-h"])
    test_exit_code_any(r3, "ping -h")

    serial_println("[test] wget -h")
    val r4 = run_wget(["-h"])
    test_exit_code_any(r4, "wget -h")

    serial_println("[test] dhcp -h")
    val r5 = run_dhcp(["-h"])
    test_exit_code_any(r5, "dhcp -h")

    serial_println("[test] dns -h")
    val r6 = run_dns(["-h"])
    test_exit_code_any(r6, "dns -h")

fn test_archive_tools():
    serial_println("")
    serial_println("=== Archive Tools ===")
    serial_println("")

    serial_println("[test] tar -h")
    val r1 = run_tar(["-h"])
    test_exit_code_any(r1, "tar -h")

    serial_println("[test] gzip (no args)")
    val r2 = run_gzip([])
    test_exit_code_any(r2, "gzip (no args)")

    serial_println("[test] zip (no args)")
    val r3 = run_zip([])
    test_exit_code_any(r3, "zip (no args)")

fn test_boot_tools():
    serial_println("")
    serial_println("=== Boot Tools ===")
    serial_println("")

    serial_println("[test] bootctl")
    val r1 = run_bootctl([])
    test_exit_code_any(r1, "bootctl")

    serial_println("[test] boot-recovery -h")
    val r2 = run_boot_recovery(["-h"])
    test_exit_code_any(r2, "boot-recovery -h")

fn test_log_tools():
    serial_println("")
    serial_println("=== Log Tools ===")
    serial_println("")

    serial_println("[test] log")
    val r1 = run_log([])
    test_exit_code_any(r1, "log")

    serial_println("[test] log -n 5")
    val r2 = run_log(["-n", "5"])
    test_exit_code_any(r2, "log -n 5")

fn test_pkg_tools():
    serial_println("")
    serial_println("=== Package Tools ===")
    serial_println("")

    serial_println("[test] pkg list")
    val r1 = run_pkg(["list"])
    test_exit_code_any(r1, "pkg list")

    serial_println("[test] pkg (no args)")
    val r2 = run_pkg([])
    test_exit_code_any(r2, "pkg (no args)")

# ===========================================================================
# Entry Point
# ===========================================================================

fn _start():
    serial_println("")
    serial_println("========================================")
    serial_println("  SimpleOS Tools Test — x86_64 QEMU")
    serial_println("========================================")
    serial_println("")

    # POSIX layer init
    fd_table_init()
    async_io_init()
    signal_init()
    serial_println("[boot] POSIX layer initialized")

    # Services
    init_all_services()

    val storage_ok = services_storage_ready()
    serial_println("[boot] Storage ready: {storage_ok}")

    # Register all external tools
    var registry = register_all_tools()
    serial_println("[boot] Tool registry: {registry.names().len()} tools registered")

    # Create shell with VFS
    var shell = ShellApp.new()
    if storage_ok:
        shell.vfs = vfs_get_manager()
        serial_println("[boot] Shell connected to VFS")
    shell.tool_registry = registry
    serial_println("[boot] Shell connected to tool registry")

    serial_println("")
    serial_println("========================================")
    serial_println("  Running Tool Tests")
    serial_println("========================================")

    # Phase 1: Filesystem tools first
    test_filesystem_tools(shell)

    # Phase 2: External tools by category
    test_dev_tools()
    test_proc_tools()
    test_net_tools()
    test_archive_tools()
    test_boot_tools()
    test_log_tools()
    test_pkg_tools()

    # Summary
    serial_println("")
    serial_println("========================================")
    serial_println("  Results: {g_pass} passed, {g_fail} failed")
    serial_println("========================================")
    serial_println("")
    if g_fail == 0:
        serial_println("ALL TESTS PASSED")
    else:
        serial_println("SOME TESTS FAILED")

    serial_println("TEST COMPLETE")

    # Exit via isa-debug-exit (write 0 → QEMU exits with (0<<1)|1 = 1 = success)
    rt_port_outb(0xf4, 0)
