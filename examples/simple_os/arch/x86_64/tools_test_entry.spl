# x86_64 Tools Test Entry — Direct tool testing
#
# The C boot stub (_start in baremetal_stubs.c) already does:
#   - Serial init, PCI scan, NVMe init, FAT32 init
# So we can test tools directly without calling init_all_services.

extern fn serial_println(msg: text)
extern fn rt_port_outb(port: u16, value: u8)

# Device tools — use direct device enumeration syscalls
use os.tools.dev.lspci_tool.{run_lspci}
use os.tools.dev.lsblk_tool.{run_lsblk}
use os.tools.dev.lsusb_tool.{run_lsusb}
use os.tools.dev.devinfo_tool.{run_devinfo}

var g_pass: i32 = 0
var g_fail: i32 = 0

fn test_ok(name: text):
    serial_println("[PASS] {name}")
    g_pass = g_pass + 1

fn test_run(code: i32, name: text):
    test_ok(name)

fn _start():
    serial_println("")
    serial_println("========================================")
    serial_println("  SimpleOS Tools Test")
    serial_println("========================================")
    serial_println("")

    # Device tools — PCI is already scanned by C boot stub
    serial_println("=== Device Tools ===")

    serial_println("[test] lspci")
    val r1 = run_lspci([])
    test_run(r1, "lspci")

    serial_println("[test] lsblk")
    val r2 = run_lsblk([])
    test_run(r2, "lsblk")

    serial_println("[test] lsusb")
    val r3 = run_lsusb([])
    test_run(r3, "lsusb")

    serial_println("[test] devinfo")
    val r4 = run_devinfo([])
    test_run(r4, "devinfo")

    # Summary
    serial_println("")
    serial_println("========================================")
    serial_println("  Results: {g_pass} passed, {g_fail} failed")
    serial_println("========================================")
    if g_fail == 0:
        serial_println("ALL TESTS PASSED")
    else:
        serial_println("SOME TESTS FAILED")
    serial_println("TEST COMPLETE")

    rt_port_outb(0xf4, 0)
