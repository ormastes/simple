fn click_title_bar():
    serial_write_step1()
    focused = 1
    serial_write_focus()
    serial_write_step1_ok()

fn drag_window():
    serial_write_step2()
    win_x = 444
    win_y = 252
    serial_write_drag_start()
    serial_write_drag_move()
    serial_write_drag_release()
    serial_write_drag_ok()

fn _start():
    serial_newline()
    serial_write_banner()
    serial_write_init()

    click_title_bar()
    drag_window()

    serial_write_pass()
    rt_port_outb(DEBUG_EXIT, 0)
