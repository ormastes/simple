# x86_64 Entry — SimpleOS boot shim
#
# Minimal entry point. Uses pass_do_nothing to avoid runtime allocations
# until the LLVM codegen RuntimeValue tagging is aligned with C stubs.

fn serial_println(msg: text):
    print msg

fn _start():
    # Simple entry point reached — the C stubs handle serial init and banner.
    # print statements currently cause heap exhaustion due to codegen/stubs
    # value tagging mismatch. This will be fixed when the LLVM backend
    # aligns its string literal encoding with the RuntimeValue tagged pointer
    # scheme used by baremetal_stubs.c.
    pass_do_nothing
