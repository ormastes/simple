fn _start():
    serial_println("")
    serial_println("=== SimpleOS SSH Live Boot ===")
    serial_println("")

    # POSIX layer init
    fd_table_init()
    async_io_init()
    signal_init()
    serial_println("[boot] POSIX layer initialized")

    # All services
    init_all_services()

    # Verify network is available (required for SSH)
    if not services_network_ready():
        serial_println("[FATAL] Network stack unavailable — cannot start SSH daemon")
        serial_println("[FATAL] Ensure QEMU has: -netdev user,id=n0 -device virtio-net-pci,netdev=n0")
        return

    serial_println("[boot] Network ready")

    if services_storage_ready():
        serial_println("[boot] Storage ready")

    # Start SSH daemon on port 22
    if SSHD_PORT != 22:
        serial_println("[boot] WARNING: SSHD_PORT constant differs from live entry port 22")
    serial_println("[boot] Starting SSH daemon on port 22...")
    val daemon = apps__sshd__sshd__SshDaemon_dot_new(22)
    val rsa_pkcs8 = _embedded_host_rsa_pkcs8()
    val rsa_public_blob = _embedded_host_rsa_public_blob()
    val _set_rsa = apps__sshd__sshd__SshDaemon_dot_set_host_rsa_key(daemon, rsa_pkcs8)
    val _set_rsa_pub = apps__sshd__sshd__SshDaemon_dot_set_host_rsa_public_blob(daemon, rsa_public_blob)
    serial_println("[boot] Loaded embedded RSA host key ({rsa_pkcs8.len()} bytes, pub={rsa_public_blob.len()} bytes)")
    serial_println("[boot] SSH daemon created (users: root/simpleos, user/password)")
    serial_println("[boot] Entering accept loop — connect with: ssh -p 2222 root@localhost")
    serial_println("")

    # This blocks forever, accepting SSH connections
    val _start_result = apps__sshd__sshd__SshDaemon_dot_start(daemon)
