# x86_64 SSH Live Entry — Full OS boot with SSH daemon accept loop
#
# Boots all services and starts the SSH daemon listening on port 22.
# The daemon enters accept_loop() and blocks forever, allowing SSH clients
# to connect from the host via QEMU port forwarding (-hostfwd=tcp::2222-:22).
#
# Usage:
#   qemu-system-x86_64 ... -netdev user,id=n0,hostfwd=tcp::2222-:22 \
#     -device virtio-net-pci,netdev=n0 ...
#   ssh -p 2222 root@localhost  (password: simpleos)

# POSIX layer
use os.posix.fd_table.{fd_table_init}
use os.posix.async_io.{async_io_init}
use os.posix.signal_compat.{signal_init}
use os.kernel.arch.x86_64.console.{serial_writeln}

# Services
use os.kernel.boot.init_services.{init_all_services, services_network_ready, services_storage_ready}

# SSH
use os.apps.sshd.sshd.{SSHD_PORT}
extern fn apps__sshd__sshd__SshDaemon_dot_new(port: u64) -> u64
extern fn apps__sshd__sshd__SshDaemon_dot_set_host_rsa_key(daemon: u64, pkcs8: [u8]) -> u64
extern fn apps__sshd__sshd__SshDaemon_dot_start(daemon: u64) -> u64

fn serial_println(msg: text):
    serial_writeln(msg)

fn _hex_nibble(c: u8) -> u8:
    if c >= 0x30 and c <= 0x39:
        return c - 0x30
    if c >= 0x61 and c <= 0x66:
        return c - 0x61 + 10
    if c >= 0x41 and c <= 0x46:
        return c - 0x41 + 10
    0

fn _hex_decode(hex: text) -> [u8]:
    val hex_bytes = hex.to_bytes()
    var result: [u8] = []
    var i: u64 = 0
    while i + 1 < hex_bytes.len():
        val hi = _hex_nibble(hex_bytes[i])
        val lo = _hex_nibble(hex_bytes[i + 1])
        result.push((hi << 4) | lo)
        i = i + 2
    result

fn _embedded_host_rsa_pkcs8() -> [u8]:
    _hex_decode("")

fn _start():
    serial_println("")
    serial_println("=== SimpleOS SSH Live Boot ===")
    serial_println("")

    # POSIX layer init
    fd_table_init()
    async_io_init()
    signal_init()
    serial_println("[boot] POSIX layer initialized")

    # All services
    init_all_services()

    # Verify network is available (required for SSH)
    if not services_network_ready():
        serial_println("[FATAL] Network stack unavailable — cannot start SSH daemon")
        serial_println("[FATAL] Ensure QEMU has: -netdev user,id=n0 -device virtio-net-pci,netdev=n0")
        return

    serial_println("[boot] Network ready")

    if services_storage_ready():
        serial_println("[boot] Storage ready")

    # Start SSH daemon on port 22
    if SSHD_PORT != 22:
        serial_println("[boot] WARNING: SSHD_PORT constant differs from live entry port 22")
    serial_println("[boot] Starting SSH daemon on port 22...")
    val daemon = apps__sshd__sshd__SshDaemon_dot_new(22)
    val rsa_pkcs8 = _embedded_host_rsa_pkcs8()
    val _set_rsa = apps__sshd__sshd__SshDaemon_dot_set_host_rsa_key(daemon, rsa_pkcs8)
    serial_println("[boot] Loaded embedded RSA host key ({rsa_pkcs8.len()} bytes)")
    serial_println("[boot] SSH daemon created (users: root/simpleos, user/password)")
    serial_println("[boot] Entering accept loop — connect with: ssh -p 2222 root@localhost")
    serial_println("")

    # This blocks forever, accepting SSH connections
    val _start_result = apps__sshd__sshd__SshDaemon_dot_start(daemon)
