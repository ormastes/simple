# x86_64 GUI Entry -- Browser Engine variant
#
# Boots the same BGA framebuffer path as gui_entry_engine2d.spl, but
# instead of hand-drawing rectangles through Engine2D, routes a real
# HTML page through the browser_engine pipeline:
#
#   HTML -> DOM (html_string_to_dom)
#        -> BrowserRenderer.render_dom_to_pixels
#        -> layout -> paint -> scene -> software rasterizer
#        -> framebuffer blit
#        -> BGA framebuffer
#
# This is the first in-guest demonstration of actual HTML rendering
# on SimpleOS. The rendered frame stays on screen via a halt loop so
# QMP capture can read it back.
#
# Boot sequence:
#   1. Serial init
#   2. Install bootstrap trap + syscall shim exports
#   3. BGA framebuffer init (1024x768x32)
#   4. Create FramebufferDriver from boot info
#   5. Create BrowserRenderer
#   6. html_string_to_dom(welcome_html())
#   7. renderer.render_dom_to_pixels(dom)
#   8. Blit pixels to FramebufferDriver
#   9. Halt loop (no Compositor, no DesktopShell)

use os.kernel.arch.x86_64.console.{serial_init, serial_writeln}
use os.kernel.arch.x86_64.interrupt.{X86Interrupt}
use os.kernel.arch.x86_64.arch_init.{arch_x86_64_early_init}
use os.kernel.abi.syscall_shim.{shim_init}
use os.kernel.scheduler.scheduler.{Scheduler}
use os.kernel.ipc.ipc.{IpcManager}
use os.kernel.log.klog.{KernelLog}
use os.drivers.framebuffer.bga_init.{bga_init_framebuffer}
use os.drivers.framebuffer.fb_driver.{FramebufferDriver, Color}
use std.gc_async_mut.gpu.browser_engine.browser_renderer.{BrowserRenderer}
use std.gc_async_mut.gpu.browser_engine.widget_to_dom.{html_string_to_dom}
use examples.simple_os.assets.welcome.{welcome_html}

extern fn serial_println(msg: text)
extern fn rt_gui_set_fb(addr: u64, width: u64)
extern fn rt_hlt()

fn _argb_to_color(pixel: u32) -> Color:
    Color(
        r: ((pixel >> 16) & 0xFF) as u8,
        g: ((pixel >> 8) & 0xFF) as u8,
        b: (pixel & 0xFF) as u8,
        a: ((pixel >> 24) & 0xFF) as u8
    )

fn spl_start():
    """x86_64 GUI entry -- browser_engine + software rasterizer + framebuffer.

    Initializes the BGA framebuffer, parses the SimpleOS welcome HTML
    into a DOM, renders it through the in-repo browser_engine pipeline to
    a software pixel buffer, and blits that buffer to the real framebuffer.
    The rendered frame is preserved via a halt loop for QMP capture.
    """
    serial_init()
    serial_writeln("SimpleOS x86_64 GUI boot (BGA mode, browser_engine variant)")
    serial_writeln("[BOOT] COM1 serial initialized at 0x3F8")

    # Mirror the desktop wrapper boot path enough to install the strong
    # syscall shim exports required by the freestanding linker aliases.
    arch_x86_64_early_init()
    shim_init(Scheduler.new(), IpcManager.new(), KernelLog.new(256))
    if not X86Interrupt.runtime_installed():
        X86Interrupt.install_bootstrap_runtime(64)

    # BGA framebuffer
    serial_writeln("[BOOT] Initializing BGA framebuffer (1024x768x32)...")
    val fb_info = bga_init_framebuffer(1024, 768, 32)
    serial_writeln("[BOOT] BGA framebuffer ready")

    # C runtime hook for rt_gui_* glass rendering
    serial_println("[GUI] Setting up C runtime framebuffer...")
    rt_gui_set_fb(fb_info.addr.addr, fb_info.width.to_u64())
    serial_println("[GUI] rt_gui_set_fb done")

    # FramebufferDriver
    serial_println("[GUI] Creating FramebufferDriver...")
    var fb = FramebufferDriver.from_boot_info(fb_info)
    serial_println("[GUI] FramebufferDriver created")

    # ---- Browser engine pipeline ----
    serial_println("[BE] Creating BrowserRenderer...")
    var renderer = BrowserRenderer.create(fb.width.to_i32(), fb.height.to_i32())
    serial_println("[BE] BrowserRenderer created")

    serial_println("[BE] Loading welcome HTML...")
    val html = welcome_html()
    serial_println("[BE] Welcome HTML loaded")

    serial_println("[BE] Parsing HTML to DOM...")
    val dom = html_string_to_dom(html)
    serial_println("[BE] DOM parsed")

    serial_println("[BE] Rendering DOM to pixels...")
    val result = renderer.render_dom_to_pixels(dom)
    serial_println("[BE] Pixel buffer generated")

    serial_println("[BE] Blitting pixels to framebuffer...")
    val pixels = result.pixel_data
    var y: u32 = 0
    while y < fb.height:
        var x: u32 = 0
        while x < fb.width:
            val idx = (y * fb.width + x).to_i64()
            if idx < pixels.length().to_i64():
                fb.put_pixel(x, y, _argb_to_color(pixels[idx]))
            x = x + 1
        y = y + 1
    serial_println("[BE] Frame painted: HTML -> DOM -> layout -> paint -> scene -> software rasterizer -> framebuffer")

    serial_println("[GUI] Entering halt loop (rendered frame held for QMP capture)")
    while true:
        rt_hlt()
