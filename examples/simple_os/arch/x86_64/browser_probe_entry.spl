# x86_64 Browser Probe Entry
#
# Minimal baremetal probe used to prove the wrapper reaches spl_start.

extern fn rt_port_inb(port: u64) -> u64
extern fn rt_port_outb(port: u64, value: u64)

val SERIAL_DATA: u64 = 0x3F8
val SERIAL_LSR: u64 = 0x3FD
val DEBUG_EXIT: u64 = 0xF4

fn serial_wait_ready():
    var guard: i64 = 100000
    while guard > 0:
        if (rt_port_inb(SERIAL_LSR) & 0x20) != 0:
            return
        guard = guard - 1

fn serial_put(ch: u64):
    serial_wait_ready()
    rt_port_outb(SERIAL_DATA, ch)

fn serial_newline():
    serial_put(13)
    serial_put(10)

fn write_probe_marker():
    serial_put(91)   # [
    serial_put(112)  # p
    serial_put(114)  # r
    serial_put(111)  # o
    serial_put(98)   # b
    serial_put(101)  # e
    serial_put(93)   # ]
    serial_put(32)   # ' '
    serial_put(98)   # b
    serial_put(114)  # r
    serial_put(111)  # o
    serial_put(119)  # w
    serial_put(115)  # s
    serial_put(101)  # e
    serial_put(114)  # r
    serial_put(32)   # ' '
    serial_put(115)  # s
    serial_put(112)  # p
    serial_put(108)  # l
    serial_put(95)   # _
    serial_put(115)  # s
    serial_put(116)  # t
    serial_put(97)   # a
    serial_put(114)  # r
    serial_put(116)  # t
    serial_newline()

fn spl_start():
    write_probe_marker()
    rt_port_outb(DEBUG_EXIT, 0)
