# x86_64 GUI Entry — Engine2D + WM + Simple Web demo
#
# This entry is the visible integrated QEMU lane:
#   - BGA framebuffer in an x86_64 QEMU Cocoa window
#   - WmService + launcher registry initialized
#   - freestanding Engine2D core paints the desktop/window chrome
#   - Simple Web renderer produces browser pixels blitted by Engine2D
#
# The full std.gpu.engine2d facade currently has a known method-dispatch
# bug in --entry-closure baremetal builds. This entry uses the freestanding
# Engine2D core so the demo boots reliably while still exercising the 2D
# drawing layer and the Simple Web rendering library in the same frame.

use os.kernel.arch.x86_64.console.{serial_init, serial_writeln}
use os.kernel.boot.mmio.{mmio_write32}
use os.drivers.framebuffer.bga_init.{bga_init_framebuffer}
use os.compositor.engine2d_baremetal_core.{create_fb_engine_core}
use os.services.wm.wm_service.{WmService}
use os.services.launcher.launcher.{launcher_init, launcher_get_app_count}
use std.gc_async_mut.gpu.browser_engine.simple_web_renderer.{simple_web_render_engine2d_demo_pixels}

extern fn serial_println(msg: text)
extern fn rt_gui_set_fb(addr: u64, width: u64)
extern fn rt_port_outb(port: u16, value: u8)

val FB_W: i32 = 1024
val FB_H: i32 = 768
val CAPTURE_WAIT_ITERS: u64 = 5000000

fn _web_demo_html() -> text:
    "<html><body style='margin:0; background-color:#101820; color:#f3f4f6;'><div style='height:30px; background-color:#2050a0; color:#ffffff;'>about:engine2d-wm</div><div style='height:86px; background-color:#182230; color:#44ff44;'>Simple Web Renderer</div><div style='height:86px; background-color:#1f2937; color:#e0e0f0;'>HTML -> layout -> paint -> pixels -> Engine2D</div></body></html>"

fn _draw_window(engine, x: i32, y: i32, w: i32, h: i32, panel_color: u32, title_color: u32):
    engine.draw_rect_filled(x + 5, y + 6, w, h, 0x66000000)
    engine.draw_rect_filled(x, y, w, h, panel_color)
    engine.draw_rect_filled(x, y, w, 28, title_color)
    engine.draw_rect_filled(x + 12, y + 9, 10, 10, 0xFFE74C3C)
    engine.draw_rect_filled(x + 30, y + 9, 10, 10, 0xFFF1C40F)
    engine.draw_rect_filled(x + 48, y + 9, 10, 10, 0xFF27AE60)

fn _draw_launcher(engine, app_count: i64, panel_color: u32, accent_color: u32):
    val x0: i32 = 32
    val y0: i32 = 64
    val tile_w: i32 = 132
    val tile_h: i32 = 52
    var i: i32 = 0
    while i < 5:
        val x = x0
        val y = y0 + (i * 64)
        val accent = if i == 0: accent_color elif i == 1: 0xFF16A085 elif i == 2: 0xFFE67E22 elif i == 3: 0xFF9B59B6 else: 0xFF7F8C8D
        engine.draw_rect_filled(x, y, tile_w, tile_h, panel_color)
        engine.draw_rect_filled(x, y, 8, tile_h, accent)
        i = i + 1
    engine.draw_rect_filled(32, 420, 132, 30, panel_color)
    if app_count > 0:
        engine.draw_rect_filled(44, 431, 90, 8, accent_color)

fn _draw_mouse_cursor(engine, x: i32, y: i32):
    engine.draw_rect_filled(x, y, 2, 22, 0xFFFFFFFF)
    engine.draw_rect_filled(x + 2, y + 2, 2, 18, 0xFFFFFFFF)
    engine.draw_rect_filled(x + 4, y + 4, 2, 14, 0xFFFFFFFF)
    engine.draw_rect_filled(x + 6, y + 6, 2, 10, 0xFFFFFFFF)
    engine.draw_rect_filled(x + 8, y + 8, 2, 6, 0xFFFFFFFF)
    engine.draw_rect_filled(x + 5, y + 16, 10, 2, 0xFFFFFFFF)
    engine.draw_rect_filled(x + 8, y + 18, 8, 2, 0xFFFFFFFF)
    engine.draw_rect_filled(x + 12, y + 20, 6, 2, 0xFFFFFFFF)

fn _capture_settle_window():
    var iter: u64 = 0
    while iter < CAPTURE_WAIT_ITERS:
        rt_port_outb(0x80u16, 0u8)
        iter = iter + 1

fn _fail_and_exit(msg: text):
    serial_println(msg)
    serial_println("TEST FAILED")
    rt_port_outb(0xf4u16, 1u8)

fn _draw_mmio_probe(fb_addr: u64, width: i32):
    var x: i32 = 0
    while x < 32:
        val offset = (x * 4).to_u64()
        mmio_write32(fb_addr + offset, 0xFFFF0000)
        x = x + 1

fn spl_start():
    serial_init()
    serial_writeln("SimpleOS x86_64 GUI boot (Engine2D + WM + Simple Web)")
    serial_writeln("[BOOT] COM1 serial ready")

    serial_writeln("[BOOT] Initializing BGA framebuffer (1024x768x32)...")
    val fb_info = bga_init_framebuffer(FB_W.to_u32(), FB_H.to_u32(), 32)
    serial_writeln("[BOOT] BGA framebuffer ready")

    rt_gui_set_fb(fb_info.addr.addr, FB_W.to_u64())
    serial_println("[GUI] framebuffer bound")
    _draw_mmio_probe(fb_info.addr.addr, FB_W)
    serial_println("[GUI] mmio-probe-painted")

    var wm = WmService.new()
    if wm.init():
        serial_println("[wm-demo] wm-service-ready")
    else:
        serial_println("[wm-demo] wm-service-failed")
    launcher_init()
    val app_count = launcher_get_app_count()
    serial_println("[wm-demo] launcher-ready apps={app_count}")

    var engine = create_fb_engine_core(fb_info.addr.addr, FB_W, FB_H)
    serial_println("[e2d-demo] freestanding-engine2d-ready")
    serial_println("[e2d-demo] engine-core-ready")

    val web_w: i32 = 520
    val web_h: i32 = 220
    serial_println("[web-demo] rendering Simple Web pixels")
    val web_pixels = simple_web_render_engine2d_demo_pixels(web_w, web_h)
    serial_println("[web-demo] pixels-ready count={web_pixels.len()}")
    val expected_web_pixels = (web_w * web_h).to_u64()
    if web_pixels.len() != expected_web_pixels:
        _fail_and_exit("[web-demo] pixels-ready failed expected=114400")
        return

    engine.clear(0xFF0A2540)
    engine.draw_rect_filled(0, 0, FB_W, 36, 0xFF17202A)
    engine.draw_rect_filled(0, FB_H - 42, FB_W, 42, 0xFF101820)
    engine.draw_rect_filled(18, FB_H - 31, 96, 20, 0xFF3498DB)
    engine.draw_rect_filled(840, FB_H - 28, 142, 14, 0xFF34495E)

    _draw_launcher(engine, app_count, 0xFF202A36, 0xFF3498DB)

    _draw_window(engine, 220, 82, 600, 306, 0xFF1E1E2E, 0xFF2050A0)
    engine.draw_image(260, 126, web_w, web_h, web_pixels)
    engine.draw_rect(260, 126, web_w, web_h, 0xFF3A6EA5)

    _draw_window(engine, 470, 430, 360, 180, 0xFF1E1E2E, 0xFF16A085)
    engine.draw_rect_filled(500, 468, 180, 18, 0xFF182230)
    engine.draw_rect_filled(500, 506, 140, 18, 0xFF1F2937)
    engine.draw_rect_filled(500, 544, 120, 18, 0xFF223044)
    _draw_mouse_cursor(engine, 794, 366)
    engine.draw_rect_filled(0, 0, 32, 1, 0xFFFF0000)
    engine.present()

    serial_println("[integrated-demo] render-ready")
    serial_println("TEST PASSED")
    serial_println("[GUI] Holding rendered frame for capture")
    _capture_settle_window()
    rt_port_outb(0xf4u16, 0u8)
