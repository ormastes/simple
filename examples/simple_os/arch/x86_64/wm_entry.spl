# SimpleOS Window Manager Entry — BGA framebuffer + Simple window management
#
# Self-contained entry that:
# 1. Programs BGA framebuffer (1024x768x32) via port I/O
# 2. Detects LFB address via PCI BAR scan
# 3. Renders desktop background, taskbar, dock icons
# 4. Creates and renders application windows with title bars
# 5. Shows hello world app content
# 6. Handles PS/2 keyboard input for basic window management
#
# All rendering via C helpers (rt_gui_*) for efficiency.
# Window management logic is pure Simple.

extern fn serial_println(msg: text)
extern fn rt_port_outw(port: u64, value: u64)
extern fn rt_port_inw(port: u64) -> u64
extern fn rt_port_outl(port: u64, value: u64)
extern fn rt_port_inl(port: u64) -> u64
extern fn rt_port_outb(port: u64, value: u64)
extern fn rt_port_inb(port: u64) -> u64
extern fn rt_gui_set_fb(addr: u64, width: u64)
extern fn rt_gui_fill4(xy: u64, wh: u64, color: u64, unused: u64)
extern fn rt_gui_hline(y: u64, x: u64, count: u64, color: u64)
extern fn rt_hlt()

# Pack two u32 values into one u64 (high|low)
fn pack(hi: u64, lo: u64) -> u64:
    (hi << 32) | (lo & 0xFFFFFFFF)

# Colors (ARGB)
val BG_COLOR: u64        = 0x001A1B26  # Dark navy background
val TITLEBAR_COLOR: u64  = 0x001E1E2E  # System bar
val TASKBAR_COLOR: u64   = 0x001E1E2E  # Bottom taskbar
val WIN_TITLE_BG: u64    = 0x00007ACC  # Blue window title
val WIN_TITLE_ACTIVE: u64 = 0x00007ACC
val WIN_TITLE_INACTIVE: u64 = 0x00505070
val WIN_BODY_BG: u64     = 0x00FFFFFF  # White window body
val WIN_BORDER: u64      = 0x00404060  # Window border
val CLOSE_BTN: u64       = 0x00E74C3C  # Red close button
val MIN_BTN: u64         = 0x00F39C12  # Yellow minimize
val MAX_BTN: u64         = 0x002ECC71  # Green maximize
val TEXT_COLOR: u64      = 0x00333333
val TEXT_LIGHT: u64      = 0x00CCCCCC
val DOCK_TERM: u64       = 0x003498DB  # Blue - Terminal
val DOCK_FILES: u64      = 0x0027AE60  # Green - Files
val DOCK_CALC: u64       = 0x00E74C3C  # Red - Calculator
val DOCK_CLOCK: u64      = 0x00F39C12  # Yellow - Clock
val DOCK_SETTINGS: u64   = 0x009B59B6  # Purple - Settings
val CLOCK_BG: u64        = 0x002C2C3E  # Clock background
val STATUS_BAR: u64      = 0x00E0E0E0  # Light gray status bar
val ACCENT: u64          = 0x00BB86FC  # Purple accent

# Screen dimensions
val SCREEN_W: u64 = 1024
val SCREEN_H: u64 = 768

# BGA register write
fn bga_wr(idx: u64, val_: u64):
    rt_port_outw(0x01CE, idx)
    rt_port_outw(0x01CF, val_)

# PCI config read (bus 0)
fn pci_rd(dev: u64, off: u64) -> u64:
    val a: u64 = 0x80000000 | (dev << 11) | (off & 0xFC)
    rt_port_outl(0x0CF8, a)
    rt_port_inl(0x0CFC)

# PCI config write (bus 0)
fn pci_wr(dev: u64, off: u64, val_: u64):
    val a: u64 = 0x80000000 | (dev << 11) | (off & 0xFC)
    rt_port_outl(0x0CF8, a)
    rt_port_outl(0x0CFC, val_)

# Find VGA device on PCI bus, enable memory space, return BAR0 address
fn find_vga_fb() -> u64:
    var d: u64 = 0
    while d < 32:
        val v = pci_rd(d, 0) & 0xFFFF
        if v != 0xFFFF and v != 0:
            val c = pci_rd(d, 8)
            if ((c >> 24) & 0xFF) == 3:
                # Enable PCI Memory Space + Bus Master
                val cmd = pci_rd(d, 0x04)
                pci_wr(d, 0x04, cmd | 0x06)
                val bar0 = pci_rd(d, 0x10)
                val addr = bar0 & 0xFFFFFFF0
                if addr != 0:
                    return addr
        d = d + 1
    0xFD000000  # Fallback

# Fill a rectangle: rt_gui_fill4(pack(x,y), pack(w,h), color, 0)
fn fill(x: u64, y: u64, w: u64, h: u64, color: u64):
    rt_gui_fill4(pack(x, y), pack(w, h), color, 0)

# Draw a window with title bar, body, close/min/max buttons
fn draw_window(x: u64, y: u64, w: u64, h: u64, title_color: u64, is_active: u64):
    val title_h: u64 = 28
    val btn_size: u64 = 14
    val btn_y = y + 7
    val body_y = y + title_h
    val body_h = h - title_h

    # Border (1px)
    fill(x - 1, y - 1, w + 2, h + 2, WIN_BORDER)

    # Title bar
    if is_active == 1:
        fill(x, y, w, title_h, WIN_TITLE_ACTIVE)
    else:
        fill(x, y, w, title_h, WIN_TITLE_INACTIVE)

    # Window control buttons (right side of title bar)
    # Close (red)
    fill(x + w - 22, btn_y, btn_size, btn_size, CLOSE_BTN)
    # Maximize (green)
    fill(x + w - 40, btn_y, btn_size, btn_size, MAX_BTN)
    # Minimize (yellow)
    fill(x + w - 58, btn_y, btn_size, btn_size, MIN_BTN)

    # Window body
    fill(x, body_y, w, body_h, WIN_BODY_BG)

# Draw system title bar at top
fn draw_system_bar():
    fill(0, 0, SCREEN_W, 24, TITLEBAR_COLOR)
    # "SimpleOS" text area (left)
    fill(6, 4, 60, 16, ACCENT)
    # Clock area (right)
    fill(SCREEN_W - 80, 4, 74, 16, CLOCK_BG)

# Draw taskbar/dock at bottom
fn draw_taskbar():
    val bar_h: u64 = 40
    val bar_y = SCREEN_H - bar_h

    # Taskbar background
    fill(0, bar_y, SCREEN_W, bar_h, TASKBAR_COLOR)

    # Dock icons (app launchers)
    val icon_size: u64 = 28
    val icon_y = bar_y + 6
    val gap: u64 = 8
    var ix: u64 = 12

    # Terminal icon
    fill(ix, icon_y, icon_size, icon_size, DOCK_TERM)
    ix = ix + icon_size + gap

    # Files icon
    fill(ix, icon_y, icon_size, icon_size, DOCK_FILES)
    ix = ix + icon_size + gap

    # Calculator icon
    fill(ix, icon_y, icon_size, icon_size, DOCK_CALC)
    ix = ix + icon_size + gap

    # Clock icon
    fill(ix, icon_y, icon_size, icon_size, DOCK_CLOCK)
    ix = ix + icon_size + gap

    # Settings icon
    fill(ix, icon_y, icon_size, icon_size, DOCK_SETTINGS)

    # Running app indicator (small white dots under active apps)
    fill(12 + 12, bar_y + 36, 4, 3, TEXT_LIGHT)  # Terminal active
    fill(12 + icon_size + gap + 12, bar_y + 36, 4, 3, TEXT_LIGHT)  # Files active

# Draw a "Hello World" application window
fn draw_hello_app(x: u64, y: u64):
    val w: u64 = 360
    val h: u64 = 240

    draw_window(x, y, w, h, WIN_TITLE_ACTIVE, 1)

    # App content area
    val content_y = y + 28
    val pad: u64 = 16

    # Greeting banner
    fill(x + pad, content_y + pad, w - pad * 2, 40, 0x00F0F4FF)
    # Accent stripe on left
    fill(x + pad, content_y + pad, 4, 40, ACCENT)

    # Color blocks showing rendering works
    val block_y = content_y + pad + 56
    fill(x + pad, block_y, 80, 32, 0x00FF6B6B)       # Red
    fill(x + pad + 90, block_y, 80, 32, 0x0051CF66)   # Green
    fill(x + pad + 180, block_y, 80, 32, 0x005B9BD5)  # Blue

    # Status bar at bottom of window
    fill(x, y + h - 24, w, 24, STATUS_BAR)

# Draw a "Terminal" window (second app)
fn draw_terminal(x: u64, y: u64):
    val w: u64 = 400
    val h: u64 = 280

    draw_window(x, y, w, h, WIN_TITLE_ACTIVE, 0)

    # Terminal body (dark)
    val body_y = y + 28
    val body_h = h - 28
    fill(x, body_y, w, body_h, 0x001A1B26)

    # Cursor block (blinking cursor simulation)
    fill(x + 12, body_y + 12, 8, 16, 0x0044FF44)

    # Some "text lines" (colored rectangles simulating text)
    fill(x + 24, body_y + 12, 120, 2, 0x0044FF44)
    fill(x + 12, body_y + 32, 200, 2, 0x00AAAAAA)
    fill(x + 12, body_y + 48, 160, 2, 0x00AAAAAA)
    fill(x + 12, body_y + 64, 240, 2, 0x005588CC)
    fill(x + 12, body_y + 80, 100, 2, 0x00AAAAAA)
    fill(x + 12, body_y + 96, 180, 2, 0x0044FF44)

# Draw a file manager window
fn draw_file_manager(x: u64, y: u64):
    val w: u64 = 320
    val h: u64 = 200

    draw_window(x, y, w, h, WIN_TITLE_ACTIVE, 0)

    # Sidebar
    val body_y = y + 28
    fill(x, body_y, 80, h - 28, 0x00F0F0F0)

    # Sidebar items (small colored blocks)
    fill(x + 8, body_y + 8, 64, 16, 0x00E0E0E0)
    fill(x + 8, body_y + 28, 64, 16, 0x00E0E0E0)
    fill(x + 8, body_y + 48, 64, 16, 0x00D0E8FF)  # Selected

    # File list (grid of file icons)
    var fy: u64 = body_y + 8
    var fx: u64 = x + 92
    var row: u64 = 0
    while row < 3:
        var col: u64 = 0
        while col < 3:
            # File icon
            fill(fx + col * 72, fy + row * 52, 48, 36, 0x00E8E8E8)
            # File icon accent
            fill(fx + col * 72, fy + row * 52, 48, 4, 0x005B9BD5)
            col = col + 1
        row = row + 1

# Redraw desktop with given window focused (drawn last = on top)
fn redraw_desktop(active: u64):
    # Clear desktop
    fill(0, 24, SCREEN_W, SCREEN_H - 64, BG_COLOR)

    # Draw windows in z-order (active window drawn last = on top)
    if active == 0:
        # Terminal focused: draw others first, terminal last
        draw_file_manager(520, 320)
        draw_hello_app(320, 140)
        draw_terminal(60, 80)
    else:
        if active == 1:
            # Hello focused
            draw_file_manager(520, 320)
            draw_terminal(60, 80)
            draw_hello_app(320, 140)
        else:
            # Files focused
            draw_terminal(60, 80)
            draw_hello_app(320, 140)
            draw_file_manager(520, 320)

fn spl_start():
    serial_println("[WM] SimpleOS Window Manager starting...")

    # 1. Program BGA framebuffer: 1024x768x32
    serial_println("[WM] Programming BGA: 1024x768x32")
    bga_wr(4, 0)          # Disable
    bga_wr(1, SCREEN_W)   # X resolution
    bga_wr(2, SCREEN_H)   # Y resolution
    bga_wr(3, 32)         # BPP
    bga_wr(6, SCREEN_W)   # Virtual width
    bga_wr(4, 0x41)       # Enable + LFB

    # 2. Find VGA framebuffer via PCI
    serial_println("[WM] Scanning PCI for VGA device...")
    val fb_addr = find_vga_fb()
    rt_gui_set_fb(fb_addr, SCREEN_W)
    serial_println("[WM] Framebuffer configured")

    # 3. Draw desktop background
    serial_println("[WM] Drawing desktop background...")
    fill(0, 0, SCREEN_W, SCREEN_H, BG_COLOR)

    # 4. Draw system bar (top)
    serial_println("[WM] Drawing system bar...")
    draw_system_bar()

    # 5. Draw taskbar with dock (bottom)
    serial_println("[WM] Drawing taskbar...")
    draw_taskbar()

    # 6. Draw application windows (cascaded)
    serial_println("[WM] Drawing Terminal window...")
    draw_terminal(60, 80)

    serial_println("[WM] Drawing Hello World window...")
    draw_hello_app(320, 140)

    serial_println("[WM] Drawing File Manager window...")
    draw_file_manager(520, 320)

    serial_println("[WM] Desktop rendering complete!")
    serial_println("[WM] SimpleOS Window Manager is running.")
    serial_println("[WM] 3 windows active: Terminal, Hello World, File Manager")

    # 7. Keyboard event loop
    serial_println("[WM] Entering keyboard event loop...")
    serial_println("[WM] Press 1/2/3 to focus Terminal/Hello/Files, Tab to cycle, Q to quit")

    var active_win: u64 = 1  # 0=Terminal, 1=Hello, 2=Files
    var running: u64 = 1

    while running == 1:
        # Poll PS/2 keyboard (port 0x64 status, port 0x60 data)
        val status = rt_port_inb(0x64)
        if (status & 1) != 0:
            val scancode = rt_port_inb(0x60)

            # Only handle key-down (bit 7 = 0)
            if (scancode & 0x80) == 0:
                # Tab (0x0F) = cycle windows
                if scancode == 0x0F:
                    active_win = (active_win + 1) % 3
                    redraw_desktop(active_win)
                    serial_println("[WM] Window focus changed")

                # 1 (0x02) = focus Terminal
                if scancode == 0x02:
                    active_win = 0
                    redraw_desktop(active_win)
                    serial_println("[WM] Focus: Terminal")

                # 2 (0x03) = focus Hello
                if scancode == 0x03:
                    active_win = 1
                    redraw_desktop(active_win)
                    serial_println("[WM] Focus: Hello World")

                # 3 (0x04) = focus Files
                if scancode == 0x04:
                    active_win = 2
                    redraw_desktop(active_win)
                    serial_println("[WM] Focus: File Manager")

                # Q (0x10) = quit
                if scancode == 0x10:
                    running = 0
                    serial_println("[WM] Quit requested")

    serial_println("[WM] Window Manager shutting down")
