# === Hardware init ===

fn bga_wr(idx: u64, val_: u64):
    rt_port_outw(0x01CE, idx)
    rt_port_outw(0x01CF, val_)

fn pci_rd(dev: u64, off: u64) -> u64:
    val a: u64 = 0x80000000 | (dev << 11) | (off & 0xFC)
    rt_port_outl(0x0CF8, a)
    rt_port_inl(0x0CFC)

fn pci_wr(dev: u64, off: u64, val_: u64):
    val a: u64 = 0x80000000 | (dev << 11) | (off & 0xFC)
    rt_port_outl(0x0CF8, a)
    rt_port_outl(0x0CFC, val_)

fn find_vga_fb() -> u64:
    var d: u64 = 0
    while d < 32:
        val v = pci_rd(d, 0) & 0xFFFF
        if v != 0xFFFF and v != 0:
            val c = pci_rd(d, 8)
            if ((c >> 24) & 0xFF) == 3:
                val cmd = pci_rd(d, 0x04)
                pci_wr(d, 0x04, cmd | 0x06)
                val bar0 = pci_rd(d, 0x10)
                val addr = bar0 & 0xFFFFFFF0
                if addr != 0:
                    return addr
        d = d + 1
    0xFD000000

