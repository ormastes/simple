# === Hardware init ===

fn bga_wr(idx: u64, val_: u64):
    rt_port_outw(0x01CE, idx)
    rt_port_outw(0x01CF, val_)

fn pci_rd(dev: u64, off: u64) -> u64:
    val a: u64 = 0x80000000 | (dev << 11) | (off & 0xFC)
    rt_port_outl(0x0CF8, a)
    rt_port_inl(0x0CFC)

fn pci_wr(dev: u64, off: u64, val_: u64):
    val a: u64 = 0x80000000 | (dev << 11) | (off & 0xFC)
    rt_port_outl(0x0CF8, a)
    rt_port_outl(0x0CFC, val_)

fn find_vga_fb() -> u64:
    var d: u64 = 0
    while d < 32:
        val v = pci_rd(d, 0) & 0xFFFF
        if v != 0xFFFF and v != 0:
            val c = pci_rd(d, 8)
            if ((c >> 24) & 0xFF) == 3:
                val cmd = pci_rd(d, 0x04)
                pci_wr(d, 0x04, cmd | 0x06)
                val bar0 = pci_rd(d, 0x10)
                val addr = bar0 & 0xFFFFFFF0
                if addr != 0:
                    return addr
        d = d + 1
    0xFD000000

# === Rendering helpers ===

fn fill(x: u64, y: u64, w: u64, h: u64, color: u64):
    rt_gui_shadow_fill(pack(x, y), pack(w, h), color, 0)

fn blend(x: u64, y: u64, w: u64, h: u64, color: u64, alpha: u64):
    rt_gui_blend_fill(pack(x, y), pack(w, h), color, alpha)

fn blur(x: u64, y: u64, w: u64, h: u64, radius: u64):
    rt_gui_box_blur(pack(x, y), pack(w, h), radius, 0)

fn grad_v(x: u64, y: u64, w: u64, h: u64, c1: u64, c2: u64):
    rt_gui_gradient_v(pack(x, y), pack(w, h), c1, c2)

fn grad_h(x: u64, y: u64, w: u64, h: u64, c1: u64, c2: u64):
    rt_gui_gradient_h(pack(x, y), pack(w, h), c1, c2)

fn shadow(x: u64, y: u64, w: u64, h: u64, blur_r: u64, alpha: u64, offset: u64):
    rt_gui_shadow(pack(x, y), pack(w, h), pack(blur_r, alpha), offset)

fn rrect(x: u64, y: u64, w: u64, h: u64, color: u64, radius: u64, alpha: u64):
    rt_gui_rounded_rect(pack(x, y), pack(w, h), pack(color, radius), alpha)

fn rrect_top(x: u64, y: u64, w: u64, h: u64, color: u64, radius: u64, alpha: u64):
    rt_gui_rounded_rect_top(pack(x, y), pack(w, h), pack(color, radius), alpha)

fn circle(cx: u64, cy: u64, diameter: u64, color: u64, alpha: u64):
    rt_gui_filled_circle(pack(cx, cy), pack(diameter, color), alpha, 0)

fn rrect_aa(x: u64, y: u64, w: u64, h: u64, color: u64, radius: u64, alpha: u64):
    rt_gui_rounded_rect_aa(pack(x, y), pack(w, h), pack(color, radius), alpha)

fn line(x1: u64, y1: u64, x2: u64, y2: u64, color: u64, thick: u64, alpha: u64):
    rt_gui_line(pack(x1, y1), pack(x2, y2), pack(color, thick), alpha)

fn ring(cx: u64, cy: u64, diameter: u64, thick: u64, color: u64, alpha: u64):
    rt_gui_ring(pack(cx, cy), pack(diameter, thick), pack(color, 0), alpha)

fn grad_rect(x: u64, y: u64, w: u64, h: u64, c1: u64, radius: u64, c2: u64, alpha: u64):
    rt_gui_gradient_rect(pack(x, y), pack(w, h), pack(c1, radius), pack(c2, alpha))

# Text rendering helpers — pack 8 ASCII chars into u64 for rt_gui_set_text_buf
fn pack8(a: u64, b: u64, c: u64, d: u64, e: u64, f: u64, g: u64, h: u64) -> u64:
    (a << 56) | (b << 48) | (c << 40) | (d << 32) | (e << 24) | (f << 16) | (g << 8) | h

fn draw_label(x: u64, y: u64, color: u64, alpha: u64, chars: u64, len: u64):
    rt_gui_set_text_buf(chars, 0, 0, 0)
    rt_gui_draw_text_buf(pack(x, y), pack(color, len), alpha, 0)

# Layout engine constants
val LT_HSTACK: u64 = 1
val LT_VSTACK: u64 = 2
val LT_ZSTACK: u64 = 3
val SM_FIXED: u64 = 0
val SM_FILL: u64 = 1
val SM_AUTO: u64 = 2
val ALIGN_START: u64 = 0
val ALIGN_CENTER: u64 = 1
val ALIGN_END: u64 = 2

# Layout helpers
fn layout_fixed(size: u64) -> u64:
    pack(SM_FIXED, size)

fn layout_fill(weight: u64) -> u64:
    pack(SM_FILL, weight)

fn layout_auto() -> u64:
    pack(SM_AUTO, 0)

fn layout_x(id: u64) -> u64:
    rt_layout_get(id, 0, 0, 0) >> 32

fn layout_y(id: u64) -> u64:
    rt_layout_get(id, 0, 0, 0) & 0xFFFFFFFF

fn layout_w(id: u64) -> u64:
    rt_layout_get_size(id, 0, 0, 0) >> 32

fn layout_h(id: u64) -> u64:
    rt_layout_get_size(id, 0, 0, 0) & 0xFFFFFFFF

# === Theme-aware color getters ===

fn bg_top(theme: u64) -> u64:
    if theme == 0: DARK_BG_TOP
    else: LIGHT_BG_TOP

fn bg_bot(theme: u64) -> u64:
    if theme == 0: DARK_BG_BOT
    else: LIGHT_BG_BOT

fn surface(theme: u64) -> u64:
    if theme == 0: DARK_SURFACE
    else: LIGHT_SURFACE

fn surface_a(theme: u64) -> u64:
    if theme == 0: DARK_SURFACE_A
    else: LIGHT_SURFACE_A

fn elevated(theme: u64) -> u64:
    if theme == 0: DARK_ELEVATED
    else: LIGHT_ELEVATED

fn elevated_a(theme: u64) -> u64:
    if theme == 0: DARK_ELEVATED_A
    else: LIGHT_ELEVATED_A

fn border_c(theme: u64) -> u64:
    if theme == 0: DARK_BORDER
    else: LIGHT_BORDER

fn border_a(theme: u64) -> u64:
    if theme == 0: DARK_BORDER_A
    else: LIGHT_BORDER_A

fn accent(theme: u64) -> u64:
    if theme == 0: DARK_ACCENT
    else: LIGHT_ACCENT

fn accent2(theme: u64) -> u64:
    if theme == 0: DARK_ACCENT2
    else: LIGHT_ACCENT2

fn shadow_a(theme: u64) -> u64:
    if theme == 0: DARK_SHADOW_A
    else: LIGHT_SHADOW_A

fn text_c(theme: u64) -> u64:
    if theme == 0: DARK_TEXT
    else: LIGHT_TEXT

# ===========================================================================
# Glass Window Drawing
# ===========================================================================

fn draw_glass_window(x: u64, y: u64, w: u64, h: u64, is_active: u64, theme: u64):
    # 1. Multi-layer shadows (ambient + directional)
    # Ambient shadow (soft, large, subtle)
    shadow(x, y, w, h, 16, 30, 2)
    # Directional shadow (sharper, offset, stronger)
    shadow(x, y, w, h, 8, shadow_a(theme), 6)

    # 2. Blur background (frosted glass)
    blur(x, y, w, h, BLUR_SURFACE)
    # Saturation boost — brighten blurred area slightly for visible frosted effect
    blend(x, y, w, h, 0x00FFFFFF, 15)

    # 3. Glass surface — anti-aliased rounded corners
    rrect_aa(x, y, w, h, surface(theme), 12, surface_a(theme))

    # 4. Title bar with gradient depth (lighter top → darker bottom)
    val tb_light = elevated(theme)
    val tb_dark = surface(theme)
    grad_rect(x + 1, y + 1, w - 2, TITLE_BAR_H, tb_light, 12, tb_dark, elevated_a(theme))
    # Top highlight line (specular)
    blend(x + 14, y + 2, w - 28, 1, 0x00FFFFFF, 20)
    # Title bar bottom separator
    blend(x + 1, y + TITLE_BAR_H, w - 2, 1, border_c(theme), border_a(theme))

    # 5. Traffic light buttons with inner symbols
    val btn_y = y + 10
    val btn_d: u64 = 12
    val btn_gap: u64 = 8
    var bx: u64 = x + 12
    # Close (red circle with X)
    circle(bx, btn_y, btn_d, BTN_CLOSE, 255)
    line(bx + 3, btn_y + 3, bx + 9, btn_y + 9, 0x00800000, 2, 180)
    line(bx + 9, btn_y + 3, bx + 3, btn_y + 9, 0x00800000, 2, 180)
    bx = bx + btn_d + btn_gap
    # Minimize (yellow circle with -)
    circle(bx, btn_y, btn_d, BTN_MIN, 255)
    line(bx + 3, btn_y + 6, bx + 9, btn_y + 6, 0x00806000, 2, 180)
    bx = bx + btn_d + btn_gap
    # Maximize (green circle with +)
    circle(bx, btn_y, btn_d, BTN_MAX, 255)
    line(bx + 3, btn_y + 6, bx + 9, btn_y + 6, 0x00005800, 2, 180)
    line(bx + 6, btn_y + 3, bx + 6, btn_y + 9, 0x00005800, 2, 180)

    # 6. Glass border — anti-aliased
    rrect_aa(x, y, w, h, border_c(theme), 12, border_a(theme))

    # 7. Focus ring (soft glow, not hard outline)
    if is_active == 1:
        rrect_aa(x - 2, y - 2, w + 4, h + 4, accent(theme), 14, 40)
        rrect_aa(x - 1, y - 1, w + 2, h + 2, accent(theme), 13, 60)

# ===========================================================================
# Glass System Bar (top)
# ===========================================================================

fn draw_glass_system_bar(theme: u64):
    val y: u64 = 0
    val h = SYSTEM_BAR_H

    # Blur background (strong frosted glass)
    blur(0, y, SCREEN_W, h, BLUR_ELEVATED)

    # Glass surface — very transparent
    blend(0, y, SCREEN_W, h, surface(theme), 70)

    # Bottom border with subtle highlight
    blend(0, h - 1, SCREEN_W, 1, border_c(theme), border_a(theme) + 10)

    # Left: App logo + menu items
    rrect_aa(6, 5, 24, 18, accent(theme), 6, 180)
    # Menu items with text labels
    # "File"
    draw_label(40, 8, text_c(theme), 180, pack8(70, 105, 108, 101, 0, 0, 0, 0), 4)
    # "Edit"
    draw_label(72, 8, text_c(theme), 180, pack8(69, 100, 105, 116, 0, 0, 0, 0), 4)
    # "View"
    draw_label(104, 8, text_c(theme), 180, pack8(86, 105, 101, 119, 0, 0, 0, 0), 4)

    # Right: Status icons
    # Wi-Fi icon (3 arcs)
    ring(SCREEN_W - 152, 4, 18, 2, text_c(theme), 100)
    ring(SCREEN_W - 149, 7, 12, 2, text_c(theme), 120)
    ring(SCREEN_W - 146, 10, 6, 2, text_c(theme), 140)

    # Battery icon (outline rect + fill)
    rrect_aa(SCREEN_W - 126, 8, 24, 12, text_c(theme), 3, 120)
    rrect_aa(SCREEN_W - 124, 10, 16, 8, 0x0030D158, 2, 200)
    rrect_aa(SCREEN_W - 102, 11, 3, 6, text_c(theme), 1, 100)

    # Volume icon (speaker shape)
    rrect_aa(SCREEN_W - 92, 9, 6, 10, text_c(theme), 2, 120)
    line(SCREEN_W - 86, 9, SCREEN_W - 82, 6, text_c(theme), 2, 100)
    line(SCREEN_W - 86, 19, SCREEN_W - 82, 22, text_c(theme), 2, 100)

    # Clock area with time text
    rrect_aa(SCREEN_W - 74, 5, 66, 18, elevated(theme), 8, 70)
    # "12:00 PM" (ASCII: 49=1, 50=2, 58=:, 48=0, 32=space, 80=P, 77=M)
    draw_label(SCREEN_W - 68, 9, text_c(theme), 200, pack8(49, 50, 58, 48, 48, 32, 80, 77), 8)

    # Center status dots
    circle(SCREEN_W / 2 - 12, 11, 6, accent(theme), 160)
    circle(SCREEN_W / 2, 11, 6, accent2(theme), 160)
    circle(SCREEN_W / 2 + 12, 11, 6, 0x0030D158, 160)

# ===========================================================================
# Glass Dock (bottom)
# ===========================================================================

fn draw_glass_dock(theme: u64):
    # Floating pill dock — centered, raised from bottom (uses layout constants)
    val num_icons: u64 = 7
    val icon_size = DOCK_ICON_SIZE
    val icon_gap = DOCK_ICON_GAP
    val icon_pad = DOCK_ICON_PAD
    val pill_w = DOCK_PILL_SIZE
    val dock_pad = DOCK_H_PAD
    val dock_w = num_icons * (pill_w + icon_gap) - icon_gap + dock_pad * 2
    val dock_h = DOCK_ACTUAL_H
    val dock_x = (SCREEN_W - dock_w) / 2
    val dock_y = SCREEN_H - dock_h - DOCK_MARGIN_BOTTOM

    # Dock shadow (floating depth effect)
    shadow(dock_x, dock_y, dock_w, dock_h, 8, 50, 4)

    # Blur background
    blur(dock_x, dock_y, dock_w, dock_h, BLUR_ELEVATED)
    # Saturation boost for dock glass
    blend(dock_x, dock_y, dock_w, dock_h, 0x00FFFFFF, 12)

    # Glass pill surface — ROUNDED 18px
    rrect(dock_x, dock_y, dock_w, dock_h, surface(theme), 18, surface_a(theme))

    # Glass border
    rrect(dock_x, dock_y, dock_w, dock_h, border_c(theme), 18, border_a(theme))

    # Icons
    val icon_y = dock_y + 8
    var ix: u64 = dock_x + dock_pad

    # Terminal
    rrect(ix, icon_y, pill_w, pill_w, surface(theme), 12, 60)
    rrect_aa(ix + icon_pad, icon_y + icon_pad, icon_size, icon_size, ICON_TERM, 10, 255)
    rrect_aa(ix + 8, icon_y + 8, icon_size - 8, icon_size - 8, 0x001A1A2E, 6, 200)
    line(ix + 12, icon_y + 18, ix + 18, icon_y + 18, 0x0044FF44, 2, 255)
    fill(ix + 20, icon_y + 16, 2, 6, 0x0044FF44)
    ix = ix + pill_w + icon_gap

    # Files
    rrect(ix, icon_y, pill_w, pill_w, surface(theme), 12, 60)
    rrect_aa(ix + icon_pad, icon_y + icon_pad, icon_size, icon_size, ICON_FILES, 10, 255)
    rrect_aa(ix + 8, icon_y + 12, 24, 20, 0x001E8449, 4, 220)
    rrect_aa(ix + 8, icon_y + 10, 14, 6, 0x001E8449, 3, 220)
    ix = ix + pill_w + icon_gap

    # Calculator
    rrect(ix, icon_y, pill_w, pill_w, surface(theme), 12, 60)
    rrect_aa(ix + icon_pad, icon_y + icon_pad, icon_size, icon_size, ICON_CALC, 10, 255)
    rrect_aa(ix + 8, icon_y + 8, 24, 8, 0x00FFFFFF, 3, 120)
    fill(ix + 9, icon_y + 19, 6, 6, 0x00FFFFFF)
    fill(ix + 17, icon_y + 19, 6, 6, 0x00FFFFFF)
    fill(ix + 25, icon_y + 19, 6, 6, 0x00FFFFFF)
    fill(ix + 9, icon_y + 27, 6, 6, 0x00FFFFFF)
    fill(ix + 17, icon_y + 27, 6, 6, 0x00FFFFFF)
    fill(ix + 25, icon_y + 27, 6, 6, 0x00FFFFFF)
    ix = ix + pill_w + icon_gap

    # Clock
    rrect(ix, icon_y, pill_w, pill_w, surface(theme), 12, 60)
    rrect_aa(ix + icon_pad, icon_y + icon_pad, icon_size, icon_size, ICON_CLOCK, 10, 255)
    ring(ix + 8, icon_y + 8, 24, 2, 0x00FFFFFF, 180)
    line(ix + 20, icon_y + 20, ix + 20, icon_y + 12, 0x00FFFFFF, 2, 200)
    line(ix + 20, icon_y + 20, ix + 26, icon_y + 18, 0x00FFFFFF, 2, 200)
    ix = ix + pill_w + icon_gap

    # Settings
    rrect(ix, icon_y, pill_w, pill_w, surface(theme), 12, 60)
    rrect_aa(ix + icon_pad, icon_y + icon_pad, icon_size, icon_size, ICON_SETTINGS, 10, 255)
    ring(ix + 10, icon_y + 10, 20, 3, 0x00FFFFFF, 160)
    circle(ix + 17, icon_y + 17, 8, 0x00FFFFFF, 180)
    ix = ix + pill_w + icon_gap

    # Browser
    rrect(ix, icon_y, pill_w, pill_w, surface(theme), 12, 60)
    rrect_aa(ix + icon_pad, icon_y + icon_pad, icon_size, icon_size, ICON_BROWSER, 10, 255)
    ring(ix + 8, icon_y + 8, 24, 2, 0x00FFFFFF, 180)
    line(ix + 8, icon_y + 20, ix + 32, icon_y + 20, 0x00FFFFFF, 1, 140)
    line(ix + 20, icon_y + 8, ix + 20, icon_y + 32, 0x00FFFFFF, 1, 140)
    ix = ix + pill_w + icon_gap

    # Editor
    rrect(ix, icon_y, pill_w, pill_w, surface(theme), 12, 60)
    rrect_aa(ix + icon_pad, icon_y + icon_pad, icon_size, icon_size, ICON_EDITOR, 10, 255)
    rrect_aa(ix + 10, icon_y + 8, 20, 24, 0x00FFFFFF, 3, 140)
    fill(ix + 14, icon_y + 13, 12, 2, 0x00148F77)
    fill(ix + 14, icon_y + 18, 10, 2, 0x00148F77)
    fill(ix + 14, icon_y + 23, 14, 2, 0x00148F77)

    # Running indicators — glowing dots
    val dot_y = dock_y + dock_h - 6
    val first_ix = dock_x + dock_pad + pill_w / 2 - 2
    circle(first_ix - 1, dot_y - 1, 8, accent(theme), 40)
    circle(first_ix, dot_y, 6, accent(theme), 220)
    circle(first_ix + pill_w + icon_gap - 1, dot_y - 1, 8, accent(theme), 40)
    circle(first_ix + pill_w + icon_gap, dot_y, 6, accent(theme), 220)

# ===========================================================================
# Application Window Content
# ===========================================================================

fn draw_hello_content(x: u64, y: u64, w: u64, h: u64, theme: u64):
    val cy = y + TITLE_BAR_H + 2
    val pad: u64 = 16

    # Greeting banner with accent stripe — ROUNDED
    rrect_aa(x + pad, cy + pad, w - pad * 2, 44, surface(theme), 8, 80)
    rrect_aa(x + pad, cy + pad, 4, 44, accent(theme), 2, 255)

    # Color blocks — ROUNDED
    val block_y = cy + pad + 60
    rrect_aa(x + pad, block_y, 80, 28, 0x00FF6B6B, 8, 255)
    rrect_aa(x + pad + 90, block_y, 80, 28, 0x0051CF66, 8, 255)
    rrect_aa(x + pad + 180, block_y, 80, 28, 0x005B9BD5, 8, 255)

    # Bottom accent line — keep as gradient
    grad_h(x + pad, y + h - 28, w - pad * 2, 2, accent(theme), accent2(theme))

fn draw_terminal_content(x: u64, y: u64, w: u64, h: u64, theme: u64):
    val cy = y + TITLE_BAR_H + 2

    # Terminal dark interior — rounded bottom corners
    rrect(x + 1, cy, w - 2, h - TITLE_BAR_H - 3, 0x000A0A14, 10, 200)

    # Cursor
    rrect(x + 14, cy + 14, 8, 16, 0x0044FF44, 2, 255)

    # Text lines (keep as fills — they're thin lines)
    fill(x + 26, cy + 14, 140, 2, 0x0044FF44)
    fill(x + 14, cy + 36, 220, 2, 0x00888888)
    fill(x + 14, cy + 52, 180, 2, 0x00888888)
    fill(x + 14, cy + 68, 260, 2, 0x005588CC)
    fill(x + 14, cy + 84, 120, 2, 0x00888888)
    fill(x + 14, cy + 100, 200, 2, 0x0044FF44)
    fill(x + 14, cy + 116, 160, 2, 0x00888888)
    fill(x + 14, cy + 132, 100, 2, 0x005588CC)

fn draw_files_content(x: u64, y: u64, w: u64, h: u64, theme: u64):
    val cy = y + TITLE_BAR_H + 2

    # Sidebar — rounded
    rrect(x + 1, cy, 84, h - TITLE_BAR_H - 3, surface(theme), 8, 100)
    # Sidebar border
    blend(x + 85, cy, 1, h - TITLE_BAR_H - 3, border_c(theme), border_a(theme))

    # Sidebar items — rounded
    rrect(x + 8, cy + 8, 68, 18, surface(theme), 6, 60)
    rrect(x + 8, cy + 30, 68, 18, surface(theme), 6, 60)
    rrect(x + 8, cy + 52, 68, 18, accent(theme), 6, 80)

    # File grid — rounded
    var fy: u64 = cy + 10
    var fx: u64 = x + 96
    var row: u64 = 0
    while row < 3:
        var col: u64 = 0
        while col < 3:
            rrect(fx + col * 72, fy + row * 50, 52, 38, surface(theme), 6, 80)
            rrect(fx + col * 72, fy + row * 50, 52, 3, accent(theme), 6, 255)
            col = col + 1
        row = row + 1

# ===========================================================================
# Full Desktop Rendering
# ===========================================================================

fn draw_desktop(active: u64, theme: u64):
    # Begin frame
    rt_gui_begin_frame(SCREEN_W, SCREEN_H, 0, 0)

    # 1. Procedural wallpaper
    rt_gui_draw_wallpaper(pack(SCREEN_W, SCREEN_H), theme, 0, 0)

    # Animation: active window slides up by bounce_offset pixels
    val boff = bounce_offset(g_anim_progress)

    # 2. Windows in z-order (active drawn last = on top, with bounce)
    if active == 0:
        draw_glass_window(WIN2_X, WIN2_Y, WIN2_W, WIN2_H, 0, theme)
        draw_files_content(WIN2_X, WIN2_Y, WIN2_W, WIN2_H, theme)
        draw_glass_window(WIN1_X, WIN1_Y, WIN1_W, WIN1_H, 0, theme)
        draw_hello_content(WIN1_X, WIN1_Y, WIN1_W, WIN1_H, theme)
        draw_glass_window(WIN0_X, WIN0_Y - boff, WIN0_W, WIN0_H, 1, theme)
        draw_terminal_content(WIN0_X, WIN0_Y - boff, WIN0_W, WIN0_H, theme)
    else:
        if active == 1:
            draw_glass_window(WIN2_X, WIN2_Y, WIN2_W, WIN2_H, 0, theme)
            draw_files_content(WIN2_X, WIN2_Y, WIN2_W, WIN2_H, theme)
            draw_glass_window(WIN0_X, WIN0_Y, WIN0_W, WIN0_H, 0, theme)
            draw_terminal_content(WIN0_X, WIN0_Y, WIN0_W, WIN0_H, theme)
            draw_glass_window(WIN1_X, WIN1_Y - boff, WIN1_W, WIN1_H, 1, theme)
            draw_hello_content(WIN1_X, WIN1_Y - boff, WIN1_W, WIN1_H, theme)
        else:
            draw_glass_window(WIN0_X, WIN0_Y, WIN0_W, WIN0_H, 0, theme)
            draw_terminal_content(WIN0_X, WIN0_Y, WIN0_W, WIN0_H, theme)
            draw_glass_window(WIN1_X, WIN1_Y, WIN1_W, WIN1_H, 0, theme)
            draw_hello_content(WIN1_X, WIN1_Y, WIN1_W, WIN1_H, theme)
            draw_glass_window(WIN2_X, WIN2_Y - boff, WIN2_W, WIN2_H, 1, theme)
            draw_files_content(WIN2_X, WIN2_Y - boff, WIN2_W, WIN2_H, theme)

    # 4. System bar (glass, on top of everything)
    draw_glass_system_bar(theme)

    # 5. Dock (glass, at bottom)
    draw_glass_dock(theme)

    # Present — bulk-copy shadow buffer to MMIO framebuffer
    rt_gui_present(0, 0, 0, 0)

# ===========================================================================
# Entry Point
# ===========================================================================

fn spl_start():
    serial_println("[WM] SimpleOS Glass Window Manager starting...")

    # 1. Program BGA framebuffer
    serial_println("[WM] Programming BGA: 1024x768x32")
    bga_wr(4, 0)
    bga_wr(1, SCREEN_W)
    bga_wr(2, SCREEN_H)
    bga_wr(3, 32)
    bga_wr(6, SCREEN_W)
    bga_wr(4, 0x41)

    # 2. Find framebuffer
    serial_println("[WM] Scanning PCI for VGA...")
    val fb_addr = find_vga_fb()
    rt_gui_set_fb(fb_addr, SCREEN_W)

    # 3. Initial render (dark glass theme)
    var theme: u64 = 0  # 0=dark, 1=light
    var active_win: u64 = 1

    # Animation state
    var anim_frame: u64 = 0       # Frame counter
    var anim_start: u64 = 0       # Frame when animation started
    var anim_duration: u64 = 12   # Animation length in frames
    var animating: u64 = 0        # 1 if currently animating
    var needs_redraw: u64 = 1     # Redraw on next frame
    var idle_count: u64 = 0       # Frames since last activity

    serial_println("[WM] Rendering glass desktop (dark theme)...")
    draw_desktop(active_win, theme)

    serial_println("[WM] Glass desktop rendered!")
    serial_println("[WM] Controls: Tab=cycle, 1/2/3=focus, T=toggle theme, Q=quit")

    # 4. Continuous render loop with animation
    var running: u64 = 1
    while running == 1:
        # Poll keyboard
        val status = rt_port_inb(0x64)
        if (status & 1) != 0:
            val scancode = rt_port_inb(0x60)
            if (scancode & 0x80) == 0:

                # Tab = cycle windows (with animation)
                if scancode == 0x0F:
                    active_win = (active_win + 1) % 3
                    animating = 1
                    anim_start = anim_frame
                    g_anim_progress = 0
                    needs_redraw = 1
                    serial_println("[WM] Focus cycled")

                # 1/2/3 = direct focus
                if scancode == 0x02:
                    active_win = 0
                    animating = 1
                    anim_start = anim_frame
                    g_anim_progress = 0
                    needs_redraw = 1
                    serial_println("[WM] Focus: Terminal")
                if scancode == 0x03:
                    active_win = 1
                    animating = 1
                    anim_start = anim_frame
                    g_anim_progress = 0
                    needs_redraw = 1
                    serial_println("[WM] Focus: Hello World")
                if scancode == 0x04:
                    active_win = 2
                    animating = 1
                    anim_start = anim_frame
                    g_anim_progress = 0
                    needs_redraw = 1
                    serial_println("[WM] Focus: Files")

                # T = toggle theme (with animation)
                if scancode == 0x14:
                    theme = (theme + 1) % 2
                    animating = 1
                    anim_start = anim_frame
                    g_anim_progress = 0
                    needs_redraw = 1
                    if theme == 0:
                        serial_println("[WM] Theme: Dark Glass")
                    else:
                        serial_println("[WM] Theme: White Glass")

                # Q = quit
                if scancode == 0x10:
                    running = 0
                    serial_println("[WM] Quit requested")

        # Update animation
        if animating == 1:
            val elapsed = anim_frame - anim_start
            if elapsed >= anim_duration:
                animating = 0
                g_anim_progress = 100
            else:
                g_anim_progress = (elapsed * 100) / anim_duration
            needs_redraw = 1

        # Redraw if needed
        if needs_redraw == 1:
            draw_desktop(active_win, theme)
            needs_redraw = 0
            idle_count = 0

        anim_frame = anim_frame + 1

        # Throttle: simple busy-wait to avoid 100% CPU spin
        # ~60fps: waste some cycles between frames when idle
        if animating == 0:
            idle_count = idle_count + 1
            # After settling, stop redrawing until next input
            var spin: u64 = 0
            while spin < 50000:
                spin = spin + 1

    serial_println("[WM] Window Manager shutting down")
