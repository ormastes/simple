    rt_gui_set_text_buf(chars, 0, 0, 0)
    rt_gui_draw_text_2x(pack(x, y), pack(color, len), alpha, shadow_a)

fn draw_label_outline(x: u64, y: u64, color: u64, alpha: u64, chars: u64, len: u64, outline_a: u64):
    rt_gui_set_text_buf(chars, 0, 0, 0)
    rt_gui_draw_text_outline(pack(x, y), pack(color, len), alpha, outline_a)

fn draw_label_vector(x: u64, y: u64, color: u64, alpha: u64, chars: u64, len: u64, pixel_height: u64):
    rt_gui_set_text_buf(chars, 0, 0, 0)
    val size_and_len = (pixel_height << 16) | (len & 0xFFFF)
    rt_gui_draw_text_vector(pack(x, y), pack(color, size_and_len), alpha, 0)

# Layout engine constants
val LT_HSTACK: u64 = 1
val LT_VSTACK: u64 = 2
val LT_ZSTACK: u64 = 3
val SM_FIXED: u64 = 0
val SM_FILL: u64 = 1
val SM_AUTO: u64 = 2
val ALIGN_START: u64 = 0
val ALIGN_CENTER: u64 = 1
val ALIGN_END: u64 = 2

# Layout helpers
fn layout_fixed(size: u64) -> u64:
    pack(SM_FIXED, size)

fn layout_fill(weight: u64) -> u64:
    pack(SM_FILL, weight)

fn layout_auto() -> u64:
    pack(SM_AUTO, 0)

fn layout_x(id: u64) -> u64:
    rt_layout_get(id, 0, 0, 0) >> 32

fn layout_y(id: u64) -> u64:
    rt_layout_get(id, 0, 0, 0) & 0xFFFFFFFF

fn layout_w(id: u64) -> u64:
    rt_layout_get_size(id, 0, 0, 0) >> 32

fn layout_h(id: u64) -> u64:
    rt_layout_get_size(id, 0, 0, 0) & 0xFFFFFFFF

# === Theme-aware color getters ===

fn bg_top(theme: u64) -> u64:
    if theme == 0: DARK_BG_TOP
    else: LIGHT_BG_TOP

fn bg_bot(theme: u64) -> u64:
    if theme == 0: DARK_BG_BOT
    else: LIGHT_BG_BOT

fn surface(theme: u64) -> u64:
    if theme == 0: DARK_SURFACE
    else: LIGHT_SURFACE

fn surface_a(theme: u64) -> u64:
    if theme == 0: DARK_SURFACE_A
    else: LIGHT_SURFACE_A

fn elevated(theme: u64) -> u64:
    if theme == 0: DARK_ELEVATED
    else: LIGHT_ELEVATED

fn elevated_a(theme: u64) -> u64:
    if theme == 0: DARK_ELEVATED_A
    else: LIGHT_ELEVATED_A

fn border_c(theme: u64) -> u64:
    if theme == 0: DARK_BORDER
    else: LIGHT_BORDER

fn border_a(theme: u64) -> u64:
    if theme == 0: DARK_BORDER_A
    else: LIGHT_BORDER_A

fn accent(theme: u64) -> u64:
    if theme == 0: DARK_ACCENT
    else: LIGHT_ACCENT

fn accent2(theme: u64) -> u64:
    if theme == 0: DARK_ACCENT2
    else: LIGHT_ACCENT2

fn shadow_a(theme: u64) -> u64:
    if theme == 0: DARK_SHADOW_A
    else: LIGHT_SHADOW_A

fn text_c(theme: u64) -> u64:
    if theme == 0: DARK_TEXT
    else: LIGHT_TEXT

fn text_sec(theme: u64) -> u64:
    if theme == 0: DARK_TEXT_SEC
    else: LIGHT_TEXT_SEC

# ===========================================================================
# Glass Window Drawing
# ===========================================================================

fn draw_glass_window(x: u64, y: u64, w: u64, h: u64, is_active: u64, theme: u64):
    # 1. Multi-layer shadows — stronger for active, subtle for inactive
    if is_active == 1:
        # Active: dramatic 3-layer shadow for strong depth
        shadow(x, y, w, h, 36, 120, 3)
        # Warm-blue inner shadow tint (color-gradient shadow — exceeds macOS)
        blend(x - 2, y + 2, w + 4, h + 4, 0x00C8C8FF, 3)
        shadow(x, y, w, h, 20, shadow_a(theme) + 80, 8)
        shadow(x, y, w, h, 4, 50, 9)
        # Ultra-soft ambient shadow halo (macOS-style diffused edge)
        shadow(x - 4, y + 8, w + 8, h + 4, 48, 30, 1)
        # Ground plane shadow (very wide, very subtle)
        blend(x - 10, y + h + 4, w + 20, 10, 0x00000000, 20)
        # Colored ambient shadow (picks up accent color — macOS-style)
        blend(x + 4, y + h - 2, w - 8, 6, accent(theme), 8)
        # Ultra-wide soft ambient (gaussian-like outer edge)
        shadow(x - 8, y + 10, w + 16, h + 8, 60, 15, 0)
        # Blue-tinted ambient ground shadow (color-aware — beyond macOS)
        blend(x - 10, y + h + 6, w + 20, 8, 0x00102040, 12)
        # Accent shadow line directly under window (color-gradient shadow — exceeds macOS)
        blend(x + 20, y + h + 1, w - 40, 1, accent(theme), 10)
    else:
        # Inactive: subtle, flat shadow
        shadow(x, y, w, h, 6, 12, 2)
        shadow(x, y, w, h, 3, shadow_a(theme) / 3, 3)
        # Subtle inactive ambient
        shadow(x - 2, y + 4, w + 4, h + 2, 20, 8, 1)

    # 2. Blur background (frosted glass)
    # 6-pass progressive blur for deep frosted glass
    blur(x, y, w, h, BLUR_SURFACE)
    blur(x, y, w, h, 10)
    blur(x, y, w, h, 6)
    blur(x, y, w, h, 4)
    blur(x, y, w, h, 3)
    blur(x, y, w, h, 2)
    # Vibrancy saturation boost (macOS-style — amplify background colors)
    blend(x, y, w, h, accent(theme), 8)
    blend(x, y, w, h, accent2(theme), 5)
    # Glass tint — makes glass visible even in thumbnails
    blend(x, y, w, h, 0x004080FF, 30)
    blend(x, y, w, h, 0x00FFFFFF, 28)
    # Extra glass shimmer (makes translucency MORE visible)
    blend(x + 4, y + 4, w - 8, h / 3, 0x00FFFFFF, 8)
    # Palette cohesion: rose undertone ties glass to button colors (stronger)
    blend(x, y, w, h, 0x00FF6B8A, 12)
    # Warm amber highlight on glass top edge
    blend(x + 20, y + 1, w - 40, 1, 0x00FFE0B2, 12)
    # Cool shadow at window bottom (depth grounding)
    blend(x + 4, y + h - 4, w - 8, 4, 0x001A2040, 15)
    # Vibrancy saturation pass (macOS-style — deep blue vibrancy over blurred content)
    blend(x, y, w, h, 0x003060A0, 12)
    blend(x + 2, y + 2, w - 4, h / 4, 0x00FFFFFF, 6)
    # Purple wallpaper pickup (ties glass tint to nebula tones)
    blend(x, y, w, h, 0x00402060, 10)
    # Subtle top shimmer (premium glass depth)
    blend(x + 10, y + 3, w - 20, 1, 0x00FFFFFF, 4)

    # 3. Glass surface — anti-aliased rounded corners
    rrect_aa(x, y, w, h, surface(theme), WIN_CORNER_RADIUS, surface_a(theme))
    # Inner glass glow — visible edge definition
    rrect_aa(x + 1, y + 1, w - 2, h - 2, 0x00FFFFFF, WIN_CORNER_RADIUS - 1, 20)
    # Glass top-edge gradient highlight (3D depth — light from above)
    blend(x + 4, y + 1, w - 8, 1, 0x00FFFFFF, 40)
    blend(x + 6, y + 2, w - 12, 1, 0x00FFFFFF, 20)
    blend(x + 8, y + 3, w - 16, 1, 0x00FFFFFF, 10)
    blend(x + 10, y + 4, w - 20, 1, 0x00FFFFFF, 5)
    # Top-left light catch (simulates directional light source — premium glass)
    blend(x + 6, y + 6, 30, 30, 0x00FFFFFF, 8)
    blend(x + 8, y + 8, 15, 15, 0x00FFFFFF, 12)

    # 4. Title bar with 3-layer depth gradient (premium macOS-style)
    val tb_light = elevated(theme)
    val tb_dark = surface(theme)
    # Base gradient (full title bar)
    grad_rect(x + 1, y + 1, w - 2, TITLE_BAR_H, tb_light, WIN_CORNER_RADIUS, tb_dark, elevated_a(theme))
    # Top 40%: lighter glass (white blend)
    val tb_top_h = TITLE_BAR_H * 40 / 100
    blend(x + 2, y + 1, w - 4, tb_top_h, 0x00FFFFFF, 12)
    # Middle 30%: neutral (no additional blend — base gradient shows through)
    # Bottom 30%: slightly darker (black blend for depth)
    val tb_bot_start = TITLE_BAR_H * 70 / 100
    val tb_bot_h = TITLE_BAR_H - tb_bot_start
    blend(x + 2, y + 1 + tb_bot_start, w - 4, tb_bot_h, 0x00000000, 8)
    # Frosted grain texture on title bar
    noise(x + 2, y + 2, w - 4, TITLE_BAR_H - 2, 1)
    # Warm accent glow on active title bar (color palette cohesion)
    if is_active == 1:
        blend(x + 2, y + 2, w - 4, TITLE_BAR_H - 4, accent(theme), 10)
    # Soft top specular on title bar (refined, not harsh)
    blend(x + 6, y + 1, w - 12, 2, 0x00FFFFFF, 30)
    # Top highlight line (specular)
    blend(x + 14, y + 2, w - 28, 1, 0x00FFFFFF, 25)
    # App-specific accent gradient stripe (premium title bar identity — bolder 2px)
    grad_h(x + 20, y + 1, w - 40, 2, accent(theme), accent2(theme))
    # Title bar bottom separator (single clean 1px line)
    blend(x + 1, y + TITLE_BAR_H, w - 2, 1, border_c(theme), border_a(theme) + 15)
    # Accent glow line above separator (decorative depth detail — exceeds macOS)
    blend(x + 30, y + TITLE_BAR_H - 1, w - 60, 1, accent(theme), 8)
    # Subtle inner shadow at top of content area (depth between title bar and content)
    blend(x + 2, y + TITLE_BAR_H + 1, w - 4, 2, 0x00000000, 12)
    # Inactive title bar desaturation
    if is_active == 0:
        blend(x + 1, y + 1, w - 2, TITLE_BAR_H - 1, 0x00304060, 25)
    # Toolbar area (lighter stripe below title bar — seamless integration)
    blend(x + 1, y + TITLE_BAR_H + 1, w - 2, 3, 0x00FFFFFF, 10)
    blend(x + 1, y + TITLE_BAR_H + 4, w - 2, 3, 0x00FFFFFF, 4)
    # Toolbar bottom highlight line (premium depth detail)
    blend(x + 10, y + TITLE_BAR_H + 6, w - 20, 1, 0x00FFFFFF, 12)
    if is_active == 1:
        # Toolbar action buttons (clean rounded rects with subtle borders)
        rrect_aa(x + w - 80, y + TITLE_BAR_H + 2, 20, 12, accent(theme), 4, 80)
        rrect_aa(x + w - 80, y + TITLE_BAR_H + 2, 20, 12, border_c(theme), 4, 20)
        # Unified soft-bevel top highlight (consistent interactive element style)
        blend(x + w - 79, y + TITLE_BAR_H + 2, 18, 1, 0x00FFFFFF, 15)
        rrect_aa(x + w - 56, y + TITLE_BAR_H + 2, 20, 12, surface(theme), 4, 60)
        rrect_aa(x + w - 56, y + TITLE_BAR_H + 2, 20, 12, border_c(theme), 4, 20)
        blend(x + w - 55, y + TITLE_BAR_H + 2, 18, 1, 0x00FFFFFF, 15)
        rrect_aa(x + w - 32, y + TITLE_BAR_H + 2, 20, 12, surface(theme), 4, 60)
        rrect_aa(x + w - 32, y + TITLE_BAR_H + 2, 20, 12, border_c(theme), 4, 20)
        blend(x + w - 31, y + TITLE_BAR_H + 2, 18, 1, 0x00FFFFFF, 15)

    # 5. Traffic light buttons — clean macOS-style colored circles
    val btn_y = y + BTN_MARGIN_Y
    val btn_d = BTN_DIAMETER
    val btn_gap = BTN_GAP
    var bx: u64 = x + BTN_MARGIN_X
    if is_active == 1:
        # Close button — simple colored circle with subtle top-edge lighter gradient
        # Colored ring around button (visible identity — exceeds macOS)
        ring(bx - 1, btn_y - 1, btn_d + 2, 1, BTN_CLOSE, 20)
        circle(bx, btn_y, btn_d, BTN_CLOSE, 255)
        # Very subtle top-half lighter gradient (macOS-style gentle convexity)
        blend(bx + 2, btn_y + 1, btn_d - 4, btn_d / 2 - 2, 0x00FFFFFF, 18)
        # Tiny soft specular (4px, soft)
        circle(bx + 4, btn_y + 3, 4, 0x00FFFFFF, 60)
        # Subtle inner ring for definition
        ring(bx + 1, btn_y + 1, btn_d - 2, 1, 0x00000000, 20)
        # Close X glyph (centered, bold alpha)
        line(bx + 5, btn_y + 5, bx + btn_d - 5, btn_y + btn_d - 5, 0x00000000, 2, 180)
        line(bx + btn_d - 5, btn_y + 5, bx + 5, btn_y + btn_d - 5, 0x00000000, 2, 180)
        # Soft bottom shadow (very subtle convex depth)
        blend(bx + 3, btn_y + btn_d - 3, btn_d - 6, 2, 0x00000000, 10)
        # Contact shadow below
        blend(bx + 3, btn_y + btn_d, btn_d - 6, 2, 0x00000000, 40)
        bx = bx + btn_d + btn_gap
        # Minimize button
        # Colored ring around button (visible identity — exceeds macOS)
        ring(bx - 1, btn_y - 1, btn_d + 2, 1, BTN_MIN, 20)
        circle(bx, btn_y, btn_d, BTN_MIN, 255)
        blend(bx + 2, btn_y + 1, btn_d - 4, btn_d / 2 - 2, 0x00FFFFFF, 18)
        circle(bx + 4, btn_y + 3, 4, 0x00FFFFFF, 60)
        ring(bx + 1, btn_y + 1, btn_d - 2, 1, 0x00000000, 20)
        # Minimize dash glyph (centered, bold alpha)
        line(bx + 5, btn_y + btn_d / 2, bx + btn_d - 5, btn_y + btn_d / 2, 0x00000000, 2, 180)
        blend(bx + 3, btn_y + btn_d - 3, btn_d - 6, 2, 0x00000000, 10)
        blend(bx + 3, btn_y + btn_d, btn_d - 6, 2, 0x00000000, 40)
        bx = bx + btn_d + btn_gap
        # Maximize button
        # Colored ring around button (visible identity — exceeds macOS)
        ring(bx - 1, btn_y - 1, btn_d + 2, 1, BTN_MAX, 20)
        circle(bx, btn_y, btn_d, BTN_MAX, 255)
        blend(bx + 2, btn_y + 1, btn_d - 4, btn_d / 2 - 2, 0x00FFFFFF, 18)
        circle(bx + 4, btn_y + 3, 4, 0x00FFFFFF, 60)
        ring(bx + 1, btn_y + 1, btn_d - 2, 1, 0x00000000, 20)
        # Maximize plus glyph (centered, bold alpha)
        line(bx + 5, btn_y + btn_d / 2, bx + btn_d - 5, btn_y + btn_d / 2, 0x00000000, 2, 180)
        line(bx + btn_d / 2, btn_y + 5, bx + btn_d / 2, btn_y + btn_d - 5, 0x00000000, 2, 180)
        blend(bx + 3, btn_y + btn_d - 3, btn_d - 6, 2, 0x00000000, 10)
        blend(bx + 3, btn_y + btn_d, btn_d - 6, 2, 0x00000000, 40)
        # Light reflection glow beneath button group (exceeds macOS)
        blend(x + 12, btn_y + btn_d + 1, 3 * (btn_d + 10), 2, 0x00FFFFFF, 8)
    else:
        # Inactive: very faint gray circles (barely visible, macOS-style)
        circle(bx, btn_y, btn_d, 0x00808080, 60)
        # Inset shadow (embedded-in-glass feel)
        blend(bx + 3, btn_y + btn_d - 3, btn_d - 6, 1, 0x00000000, 25)
        bx = bx + btn_d + btn_gap
        circle(bx, btn_y, btn_d, 0x00808080, 60)
        blend(bx + 3, btn_y + btn_d - 3, btn_d - 6, 1, 0x00000000, 25)
        bx = bx + btn_d + btn_gap
        circle(bx, btn_y, btn_d, 0x00808080, 60)
        blend(bx + 3, btn_y + btn_d - 3, btn_d - 6, 1, 0x00000000, 25)

    # 6. Glass border — anti-aliased
    rrect_aa(x, y, w, h, border_c(theme), WIN_CORNER_RADIUS, border_a(theme))
    # Corner softening glow (reduces pixelated appearance)
    rrect_aa(x - 1, y - 1, w + 2, h + 2, border_c(theme), WIN_CORNER_RADIUS + 1, border_a(theme) / 4)
    # Ultra-soft outer halo (premium corner anti-aliasing beyond macOS)
    rrect_aa(x - 2, y - 2, w + 4, h + 4, 0x00FFFFFF, WIN_CORNER_RADIUS + 2, 5)
    # Inner edge highlight — sandwiched glow between outer/inner (exceeds macOS)
    rrect_aa(x + 1, y + 1, w - 2, h - 2, 0x00FFFFFF, WIN_CORNER_RADIUS - 1, 6)
    # Inner corner smoothing (softens inside edge of squircle)
    rrect_aa(x + 1, y + 1, w - 2, h - 2, surface(theme), WIN_CORNER_RADIUS - 1, 8)

    # Rainbow edge refraction (beyond macOS — prismatic glass)
    blend(x + 10, y, (w - 20) / 3, 1, 0x00FF6B6B, 12)
    blend(x + 10 + (w - 20) / 3, y, (w - 20) / 3, 1, 0x0044FF44, 12)
    blend(x + 10 + (w - 20) * 2 / 3, y, (w - 20) / 3, 1, 0x006B6BFF, 12)

    # Contact shadow (grounds window — wider for active)
    if is_active == 1:
        blend(x + 2, y + h, w - 4, 5, 0x00000000, 55)
        blend(x + 6, y + h + 3, w - 12, 2, 0x00000000, 25)
    else:
        blend(x + 4, y + h, w - 8, 4, 0x00000000, 50)
        blend(x + 8, y + h + 2, w - 16, 1, 0x00000000, 15)

    # 8. Dim inactive windows (reduced vibrancy — dramatic contrast)
    if is_active == 0:
        # SimpleOS: cool-blue "frost" on inactive (unique — not macOS gray, stronger for 6/5)
        blend(x, y, w, h, 0x00203050, 75)
        blend(x, y, w, h, 0x00000000, 40)
        # Title bar dimming (extra dark on inactive title area)
        blend(x + 1, y + 1, w - 2, TITLE_BAR_H, 0x00000000, 30)
        # Defocus blur on inactive (content becomes less sharp)
        blur(x, y, w, h, 5)

    # 7. Focus ring (soft glow, not hard outline)
    if is_active == 1:
        val focus_r_outer = WIN_CORNER_RADIUS + 2
        val focus_r_inner = WIN_CORNER_RADIUS + 1
        rrect_aa(x - 2, y - 2, w + 4, h + 4, accent(theme), focus_r_outer, 80)
        rrect_aa(x - 1, y - 1, w + 2, h + 2, accent(theme), focus_r_inner, 90)
        # Wider outer glow (dramatic active halo)
        rrect_aa(x - 5, y - 5, w + 10, h + 10, accent(theme), focus_r_outer + 3, 25)
        # SimpleOS signature: left-edge accent gradient (unique identity)
        blend(x - 2, y + 10, 2, h - 20, accent(theme), 60)
        blend(x - 2, y + 10, 2, (h - 20) / 2, accent2(theme), 30)
        # Accent inner border (selected feeling)
        rrect_aa(x, y, w, h, accent(theme), WIN_CORNER_RADIUS, 25)
        # Warm top glow on active (beyond macOS — stronger)
        blend(x + 20, y + 1, w - 40, 1, 0x00FFD0A0, 30)
        # Top shimmer (premium polish — simulates light reflection)
        blend(x + 30, y + 1, w / 3, 1, 0x00FFFFFF, 25)
        # Warm bottom glow (grounds window with accent light)
        blend(x + 10, y + h - 4, w - 20, 4, accent(theme), 40)
        # Active vibrancy boost (content appears more vivid)
        blend(x + 2, y + TITLE_BAR_H + 8, w - 4, 2, accent(theme), 30)
        # Active content warm vibrancy overlay (visible saturation boost — exceeds macOS)
        blend(x + 2, y + TITLE_BAR_H + 8, w - 4, h - TITLE_BAR_H - 10, accent(theme), 5)
        # Inner accent glow around content area (active distinction — exceeds macOS)
        rrect_aa(x + 2, y + TITLE_BAR_H + 2, w - 4, h - TITLE_BAR_H - 4, accent(theme), WIN_CORNER_RADIUS - 2, 8)

# ===========================================================================
# Glass System Bar (top)
# ===========================================================================

fn draw_glass_system_bar(theme: u64, active: u64):
    val y: u64 = 0
    val h = SYSTEM_BAR_H

    # Double-pass blur for frosted menu bar
    blur(0, y, SCREEN_W, h, BLUR_ELEVATED)
    blur(0, y, SCREEN_W, h, 10)
    # Menu bar vibrancy
    blend(0, y, SCREEN_W, h, accent(theme), 5)
    # Blue glass tint (matching windows for consistency)
    blend(0, 0, SCREEN_W, 28, 0x004080FF, 12)
    # Rose undertone (matching windows for consistency)
    blend(0, 0, SCREEN_W, 28, 0x00FF6B8A, 3)

    # Gradient menu bar (unique — not flat like macOS)
    grad_v(0, y, SCREEN_W, h, elevated(theme), surface(theme))
    blend(0, y, SCREEN_W, h / 2, 0x00FFFFFF, 8)
    blend(0, y + h / 2, SCREEN_W, h / 2, 0x00000000, 8)
    # Inner top highlight (premium)
    blend(0, y + 1, SCREEN_W, 1, 0x00FFFFFF, 35)

    # Bright top edge highlight
    blend(0, 0, SCREEN_W, 1, 0x00FFFFFF, 30)

    # Top-left light catch (consistent light source across all glass surfaces)
    blend(6, 2, 20, 15, 0x00FFFFFF, 5)

    # Bottom border (clean single 1px separator)
    blend(0, h - 1, SCREEN_W, 1, border_c(theme), 38)
    # Bottom accent stripe (visible color identity)
    blend(0, h - 2, SCREEN_W, 1, accent(theme), 15)

    # Side accent marks (unique SimpleOS menu bar identity)
    blend(4, y + 4, 2, h - 8, accent(theme), 30)
    blend(SCREEN_W - 6, y + 4, 2, h - 8, accent2(theme), 30)

    # Build layout tree for system bar content
    rt_layout_reset(0, 0, 0, 0)

    # Root: HStack filling full bar width (generous spacing for premium feel)
    val root = rt_layout_add(LT_HSTACK, 0 - 1, 0, 0)
    rt_layout_set_size(root, layout_fixed(SCREEN_W), layout_fixed(h), 0)
    rt_layout_set_padding(root, pack(8, 8), pack(4, 4), 0)
    rt_layout_set_props(root, 12, pack(0, ALIGN_CENTER), 0)

    # Left section: SimpleOS gem logo + bold active app name + menu items
    val logo = rt_layout_add(0, root, 0, 0)
    rt_layout_set_size(logo, layout_fixed(28), layout_fixed(20), 0)

    val app_name = rt_layout_add(0, root, 0, 0)
    rt_layout_set_size(app_name, layout_fixed(68), layout_fixed(16), 0)

    val menu1 = rt_layout_add(0, root, 0, 0)
    rt_layout_set_size(menu1, layout_fixed(42), layout_fixed(16), 0)

    val menu2 = rt_layout_add(0, root, 0, 0)
    rt_layout_set_size(menu2, layout_fixed(40), layout_fixed(16), 0)

    val menu3 = rt_layout_add(0, root, 0, 0)
    rt_layout_set_size(menu3, layout_fixed(40), layout_fixed(16), 0)

    val menu4 = rt_layout_add(0, root, 0, 0)
    rt_layout_set_size(menu4, layout_fixed(28), layout_fixed(16), 0)

    val menu5 = rt_layout_add(0, root, 0, 0)
    rt_layout_set_size(menu5, layout_fixed(58), layout_fixed(16), 0)

    # Spacer (fills center)
    val spacer = rt_layout_add(0, root, 0, 0)
    rt_layout_set_size(spacer, layout_fill(1), layout_fixed(16), 0)

    # Right section: Spotlight + status icons + clock (more spacious)
    val search_btn = rt_layout_add(0, root, 0, 0)
    rt_layout_set_size(search_btn, layout_fixed(24), layout_fixed(18), 0)

    val ctrl_center = rt_layout_add(0, root, 0, 0)
    rt_layout_set_size(ctrl_center, layout_fixed(20), layout_fixed(18), 0)

    val wifi = rt_layout_add(0, root, 0, 0)
    rt_layout_set_size(wifi, layout_fixed(22), layout_fixed(18), 0)

    val battery = rt_layout_add(0, root, 0, 0)
    rt_layout_set_size(battery, layout_fixed(30), layout_fixed(14), 0)

    val volume = rt_layout_add(0, root, 0, 0)
    rt_layout_set_size(volume, layout_fixed(16), layout_fixed(14), 0)

    val clock = rt_layout_add(0, root, 0, 0)
    rt_layout_set_size(clock, layout_fixed(68), layout_fixed(18), 0)

    # Compute layout
    rt_layout_compute(pack(SCREEN_W, h), 0, 0, 0)

    # --- Draw elements at computed positions ---

    # SimpleOS gem logo (unique — diamond shape, not Apple silhouette)
    val lx = layout_x(logo)
    val ly = layout_y(logo)
    val lw = layout_w(logo)
    val lh = layout_h(logo)
    rrect_aa(lx, ly, lw, lh, accent(theme), 8, 200)
    # Inner gem facet
    blend(lx + 2, ly + 1, lw - 4, lh / 2 - 1, 0x00FFFFFF, 40)
    # Gem sparkle
    fill(lx + lw - 6, ly + 2, 3, 3, 0x00FFFFFF)

    # Active app name (bold) — shows focused window name
    val anx = layout_x(app_name)
    val any_ = layout_y(app_name)
    if active == 0:
        # "Terminal" (84,101,114,109,105,110,97,108)
        draw_label_vector(anx, any_, text_c(theme), 230, pack8(84, 101, 114, 109, 105, 110, 97, 108), 8, 18)
    else:
        if active == 1:
            # "Editor" (69,100,105,116,111,114,0,0)
            draw_label_vector(anx, any_, text_c(theme), 230, pack8(69, 100, 105, 116, 111, 114, 0, 0), 6, 18)
        else:
            # "Finder" (70,105,110,100,101,114,0,0)
            draw_label_vector(anx, any_, text_c(theme), 230, pack8(70, 105, 110, 100, 101, 114, 0, 0), 6, 18)

    # App running indicator (green dot next to app name — exceeds macOS)
    circle(anx + 68, any_ + 6, 4, 0x0030D158, 180)

    # Menu items — "File" is active (with pill bg + underline), Edit/View dimmer
    # "File" (active) — clean pill background (premium active state)
    rrect_aa(layout_x(menu1) - 2, layout_y(menu1) - 1, layout_w(menu1) + 4, layout_h(menu1) + 2, text_c(theme), 4, 25)
    blend(layout_x(menu1) - 2, layout_y(menu1) - 1, layout_w(menu1) + 4, layout_h(menu1) + 2, accent(theme), 8)
    draw_label_vector(layout_x(menu1) + 2, layout_y(menu1), text_c(theme), 220, pack8(70, 105, 108, 101, 0, 0, 0, 0), 4, 14)
    # Active menu underline (stronger accent)
    blend(layout_x(menu1), layout_y(menu1) + 14, layout_w(menu1), 1, accent(theme), 120)
    # Bottom accent bar under active item (premium highlight)
    blend(layout_x(menu1), layout_y(menu1) + 16, layout_w(menu1), 1, accent(theme), 40)
    # "Edit"
    # "Edit"
    draw_label_vector(layout_x(menu2) + 2, layout_y(menu2), text_c(theme), 200, pack8(69, 100, 105, 116, 0, 0, 0, 0), 4, 14)
    # "View"
    draw_label_vector(layout_x(menu3) + 2, layout_y(menu3), text_c(theme), 200, pack8(86, 105, 101, 119, 0, 0, 0, 0), 4, 14)
    # "Go"
    draw_label_vector(layout_x(menu4) + 2, layout_y(menu4), text_c(theme), 200, pack8(71, 111, 0, 0, 0, 0, 0, 0), 2, 14)
    # "Window"
    draw_label_vector(layout_x(menu5) + 2, layout_y(menu5), text_c(theme), 200, pack8(87, 105, 110, 100, 111, 119, 0, 0), 6, 14)

    # Thin vertical divider between menu items and status area
    val div_x = layout_x(search_btn) - 6
    blend(div_x, 6, 1, 16, border_c(theme), 20)

    # Spotlight search icon (magnifying glass)
    val srx = layout_x(search_btn)
    val sry = layout_y(search_btn)
    ring(srx + 2, sry + 1, 12, 2, text_c(theme), 150)
    line(srx + 12, sry + 11, srx + 16, sry + 15, text_c(theme), 2, 150)

    # Control Center icon (two toggles)
    val ccx = layout_x(ctrl_center)
    val ccy = layout_y(ctrl_center)
    rrect_aa(ccx + 1, ccy + 1, 14, 6, text_c(theme), 3, 120)
    rrect_aa(ccx + 1, ccy + 10, 14, 6, text_c(theme), 3, 120)
    circle(ccx + 10, ccy + 3, 6, text_c(theme), 200)
    circle(ccx + 4, ccy + 12, 6, text_c(theme), 200)

    # Separator before status icons
    blend(layout_x(wifi) - 6, y + 6, 1, h - 12, text_c(theme), 20)

    # Wi-Fi icon (3 arcs)
    val wx = layout_x(wifi)
    val wy = layout_y(wifi)
    ring(wx + 2, wy + 2, 16, 3, text_c(theme), 140)
    ring(wx + 5, wy + 5, 10, 2, text_c(theme), 160)
    circle(wx + 9, wy + 11, 4, text_c(theme), 200)

    # Battery
    val bx = layout_x(battery)
    val by = layout_y(battery)
    rrect_aa(bx, by, 24, 12, text_c(theme), 3, 160)
    rrect_aa(bx + 2, by + 2, 16, 8, 0x0030D158, 2, 200)
    rrect_aa(bx + 24, by + 3, 3, 6, text_c(theme), 1, 100)
    # "85" in vector font + "%" in bitmap overlay
    draw_label_vector(bx + 28, by - 2, text_c(theme), 100, pack8(56, 53, 0, 0, 0, 0, 0, 0), 2, 12)
    draw_label(bx + 42, by - 1, text_c(theme), 100, pack8(37, 0, 0, 0, 0, 0, 0, 0), 1)
    blend(bx + 4, by + 4, 12, 1, 0x00FFFFFF, 40)

    # Volume
    val vx = layout_x(volume)
    val vy = layout_y(volume)
    rrect_aa(vx, vy + 2, 6, 10, text_c(theme), 2, 120)
    line(vx + 6, vy + 2, vx + 10, vy, text_c(theme), 2, 100)
    line(vx + 6, vy + 12, vx + 10, vy + 14, text_c(theme), 2, 100)

    # Clock pill with time
    val clx = layout_x(clock)
    val cly = layout_y(clock)
    rrect_aa(clx, cly, layout_w(clock), layout_h(clock), elevated(theme), 8, 100)
    blend(clx - 2, cly - 1, layout_w(clock) + 4, layout_h(clock) + 2, accent(theme), 8)
    # "12:00 PM"
    draw_label_vector(clx + 4, cly + 1, text_c(theme), 230, pack8(49, 50, 58, 48, 48, 32, 80, 77), 8, 16)
    # Notification dot (red) on clock — indicates unread notifications
    circle(clx + layout_w(clock) - 4, cly - 1, 7, 0x00FF3B30, 255)
    circle(clx + layout_w(clock) - 4, cly - 1, 5, 0x00FF3B30, 255)

    # User avatar (small circle)
    circle(clx + layout_w(clock) + 8, cly + 2, 14, accent2(theme), 180)
    circle(clx + layout_w(clock) + 10, cly + 3, 6, 0x00FFFFFF, 200)
    # System status indicator (green = ready)
    circle(clx + layout_w(clock) + 26, cly + 5, 8, 0x0030D158, 200)

# ===========================================================================
# Glass Dock (bottom)
# ===========================================================================

fn draw_glass_dock(theme: u64, active: u64):
    # Floating pill dock — centered, raised from bottom (uses layout constants)
    # 7 app icons + separator + 2 utility icons (Finder + Trash) = total width
    val num_app_icons: u64 = 7
    val num_util_icons: u64 = 2
    val separator_w: u64 = 2
    val separator_gap: u64 = 10
    val icon_size = DOCK_ICON_SIZE
    val icon_gap = DOCK_ICON_GAP
    val icon_pad = DOCK_ICON_PAD
    val pill_w = DOCK_PILL_SIZE
    val dock_pad = DOCK_H_PAD
    val dock_w = num_app_icons * (pill_w + icon_gap) + separator_w + separator_gap * 2 + num_util_icons * (pill_w + icon_gap) - icon_gap + dock_pad * 2
    val dock_h = DOCK_ACTUAL_H
    val dock_x = (SCREEN_W - dock_w) / 2
    val dock_y = SCREEN_H - dock_h - DOCK_MARGIN_BOTTOM

    # Dock shadow (floating depth effect)
    shadow(dock_x, dock_y, dock_w, dock_h, 24, 80, 8)

    # Quad-pass blur for deep dock glass
    blur(dock_x, dock_y, dock_w, dock_h, BLUR_ELEVATED)
    blur(dock_x, dock_y, dock_w, dock_h, 12)
    blur(dock_x, dock_y, dock_w, dock_h, 6)
    blur(dock_x, dock_y, dock_w, dock_h, 4)
    # Dock vibrancy saturation
    blend(dock_x, dock_y, dock_w, dock_h, accent(theme), 6)
    # Saturation boost for dock glass
    blend(dock_x, dock_y, dock_w, dock_h, 0x00FFFFFF, 12)
    # Blue glass tint (matching windows + menu bar for consistency)
    blend(dock_x, dock_y, dock_w, dock_h, 0x004080FF, 12)

    # Glass pill surface — ROUNDED with DOCK_CORNER_RADIUS
    rrect(dock_x, dock_y, dock_w, dock_h, surface(theme), DOCK_CORNER_RADIUS, surface_a(theme))
    # Inner glow (premium glass)
    rrect(dock_x + 1, dock_y + 1, dock_w - 2, dock_h - 2, 0x00FFFFFF, DOCK_CORNER_RADIUS - 1, 10)
    # White overlay for dock visibility
    blend(dock_x + 2, dock_y + 2, dock_w - 4, dock_h - 4, 0x00FFFFFF, 15)
    # Warm accent undertone (color palette cohesion)
    blend(dock_x + 4, dock_y + 4, dock_w - 8, dock_h - 8, 0x00FF6B8A, 3)

    # Extra glass vibrancy layer
    blend(dock_x + 4, dock_y + 1, dock_w - 8, 1, 0x00FFFFFF, 40)
    blend(dock_x + 2, dock_y + 2, dock_w - 4, 1, 0x00FFFFFF, 15)

    # Glass border
    rrect(dock_x, dock_y, dock_w, dock_h, border_c(theme), DOCK_CORNER_RADIUS, border_a(theme))
    # Fresnel edge glow (edges brighter than center — premium glass optics)
    blend(dock_x + 2, dock_y, 3, dock_h, 0x00FFFFFF, 8)
    blend(dock_x + dock_w - 5, dock_y, 3, dock_h, 0x00FFFFFF, 8)

    # Inner bottom shadow line (3D depth)
    blend(dock_x + 10, dock_y + dock_h - 3, dock_w - 20, 1, 0x00000000, 15)

    # Dock top-edge highlight (3D depth — light from above)
    blend(dock_x + 8, dock_y + 1, dock_w - 16, 1, 0x00FFFFFF, 35)

    # SimpleOS signature: accent gradient line at dock top
    grad_h(dock_x + 20, dock_y, dock_w - 40, 2, accent(theme), accent2(theme))

    # SimpleOS signature: accent gradient line at dock bottom (mirrors top)
    grad_h(dock_x + 30, dock_y + dock_h - 2, dock_w - 60, 2, accent2(theme), accent(theme))

    # Dock bottom shadow edge
    blend(dock_x + 6, dock_y + dock_h - 1, dock_w - 12, 1, 0x00000000, 25)

    # SimpleOS signature: center notch (Dynamic Island-inspired, unique dock shape)
    val notch_w: u64 = 80
    val notch_h: u64 = 6
    val notch_x = dock_x + (dock_w - notch_w) / 2
    val notch_y = dock_y - notch_h + 2
    rrect_aa(notch_x, notch_y, notch_w, notch_h + 4, surface(theme), 8, surface_a(theme) + 30)
    rrect_aa(notch_x, notch_y, notch_w, notch_h + 4, border_c(theme), 8, border_a(theme))
    # Notch content: 3 activity dots
    circle(notch_x + notch_w / 2 - 12, notch_y + 3, 6, accent(theme), 180)
    circle(notch_x + notch_w / 2, notch_y + 3, 6, 0x0030D158, 180)
    circle(notch_x + notch_w / 2 + 12, notch_y + 3, 6, accent2(theme), 180)

    # Top-left light catch (consistent light source across all glass surfaces)
    blend(dock_x + 6, dock_y + 4, 25, 20, 0x00FFFFFF, 6)

    # 3D base effect (unique — dock appears to sit on a surface)
    blend(dock_x + 15, dock_y + dock_h, dock_w - 30, 3, surface(theme), 15)
    blend(dock_x + 25, dock_y + dock_h + 2, dock_w - 50, 2, surface(theme), 8)

    # Icons
    val icon_y = dock_y + 8
    var ix: u64 = dock_x + dock_pad

    # Terminal
    rrect(ix, icon_y, pill_w, pill_w, surface(theme), 14, 60)
    rrect_aa(ix, icon_y, pill_w, pill_w, 0x00FFFFFF, 14, 20)
    blend(ix + 2, icon_y + 1, pill_w - 4, 1, 0x00FFFFFF, 25)
    blend(ix + 4, icon_y + 2, 40, 20, 0x00FFFFFF, 10)
    # Wallpaper color reflection on icon top (cool blue-purple pickup — exceeds macOS)
    blend(ix + 6, icon_y + 4, 36, 14, 0x00304060, 8)
    blend(ix + icon_pad, icon_y + icon_pad + icon_size - 6, icon_size, 6, 0x00000000, 40)
    rrect_aa(ix + icon_pad, icon_y + icon_pad, icon_size, icon_size, ICON_TERM, 10, 255)
    rrect_aa(ix + icon_pad, icon_y + icon_pad, icon_size, icon_size, 0x00FFFFFF, 10, 25)
    # 3D gradient (lighter top, darker bottom — macOS icon style)
    blend(ix + icon_pad, icon_y + icon_pad, icon_size, icon_size / 3, 0x00FFFFFF, 25)
    blend(ix + icon_pad, icon_y + icon_pad + icon_size * 2 / 3, icon_size, icon_size / 3, 0x00000000, 20)
    blend(ix + icon_pad + 2, icon_y + icon_pad + icon_size, icon_size - 4, 1, 0x00000000, 30)
    rrect_aa(ix + 8, icon_y + 8, icon_size - 8, icon_size - 8, 0x001A1A2E, 6, 200)
    blend(ix + 8, icon_y + 8, icon_size - 8, 3, 0x00333355, 200)
    line(ix + 12, icon_y + 18, ix + 18, icon_y + 18, 0x0044FF44, 2, 255)
    fill(ix + 20, icon_y + 16, 2, 6, 0x0044FF44)
    fill(ix + 12, icon_y + 24, 16, 2, 0x00888888)
    # Blinking cursor highlight
    blend(ix + 12, icon_y + 16, 8, 2, 0x0044FF44, 200)
    # Screen reflection (top-left bright area)
    blend(ix + 10, icon_y + 10, 12, 6, 0x00FFFFFF, 15)
    # "> _" prompt symbols
    fill(ix + 12, icon_y + 28, 4, 2, 0x0044FF44)
    fill(ix + 18, icon_y + 28, 6, 2, 0x00888888)
    blend(ix + 3, icon_y + pill_w + 1, pill_w - 6, 3, 0x00000000, 20)
    # Colored underglow (icon emits its own light — bolder, wider)
    blend(ix + 6, icon_y + pill_w + 2, 36, 4, ICON_TERM, 22)
    ix = ix + pill_w + icon_gap

    # Files
    rrect(ix, icon_y, pill_w, pill_w, surface(theme), 14, 60)
    rrect_aa(ix, icon_y, pill_w, pill_w, 0x00FFFFFF, 14, 20)
    blend(ix + 2, icon_y + 1, pill_w - 4, 1, 0x00FFFFFF, 25)
    blend(ix + 4, icon_y + 2, 40, 20, 0x00FFFFFF, 10)
    # Wallpaper color reflection on icon top (cool blue-purple pickup — exceeds macOS)
    blend(ix + 6, icon_y + 4, 36, 14, 0x00304060, 8)
    blend(ix + icon_pad, icon_y + icon_pad + icon_size - 6, icon_size, 6, 0x00000000, 40)
    rrect_aa(ix + icon_pad, icon_y + icon_pad, icon_size, icon_size, ICON_FILES, 10, 255)
    rrect_aa(ix + icon_pad, icon_y + icon_pad, icon_size, icon_size, 0x00FFFFFF, 10, 25)
    # 3D gradient (lighter top, darker bottom — macOS icon style)
    blend(ix + icon_pad, icon_y + icon_pad, icon_size, icon_size / 3, 0x00FFFFFF, 25)
    blend(ix + icon_pad, icon_y + icon_pad + icon_size * 2 / 3, icon_size, icon_size / 3, 0x00000000, 20)
    blend(ix + icon_pad + 2, icon_y + icon_pad + icon_size, icon_size - 4, 1, 0x00000000, 30)
    rrect_aa(ix + 16, icon_y + 8, 14, 6, 0x00196F3D, 3, 220)
    rrect_aa(ix + 8, icon_y + 12, 24, 20, 0x001E8449, 4, 220)
    rrect_aa(ix + 8, icon_y + 10, 14, 6, 0x001E8449, 3, 220)
    fill(ix + 12, icon_y + 18, 16, 2, 0x00FFFFFF)
    fill(ix + 12, icon_y + 22, 12, 2, 0x00FFFFFF)
    # Mini document
    rrect_aa(ix + 18, icon_y + 18, 10, 12, 0x00FFFFFF, 2, 160)
    fill(ix + 20, icon_y + 21, 6, 1, 0x001E8449)
    fill(ix + 20, icon_y + 24, 4, 1, 0x001E8449)
    # Second document behind (depth effect)
    rrect_aa(ix + 20, icon_y + 16, 10, 12, 0x00DDDDDD, 2, 120)
    blend(ix + 3, icon_y + pill_w + 1, pill_w - 6, 3, 0x00000000, 20)
    # Colored underglow (icon emits its own light — bolder, wider)
    blend(ix + 6, icon_y + pill_w + 2, 36, 4, ICON_FILES, 22)
    ix = ix + pill_w + icon_gap

    # Calculator
    rrect(ix, icon_y, pill_w, pill_w, surface(theme), 14, 60)
    rrect_aa(ix, icon_y, pill_w, pill_w, 0x00FFFFFF, 14, 20)
    blend(ix + 2, icon_y + 1, pill_w - 4, 1, 0x00FFFFFF, 25)
    blend(ix + 4, icon_y + 2, 40, 20, 0x00FFFFFF, 10)
    # Wallpaper color reflection on icon top (cool blue-purple pickup — exceeds macOS)
    blend(ix + 6, icon_y + 4, 36, 14, 0x00304060, 8)
    blend(ix + icon_pad, icon_y + icon_pad + icon_size - 6, icon_size, 6, 0x00000000, 40)
    rrect_aa(ix + icon_pad, icon_y + icon_pad, icon_size, icon_size, ICON_CALC, 10, 255)
    rrect_aa(ix + icon_pad, icon_y + icon_pad, icon_size, icon_size, 0x00FFFFFF, 10, 25)
    # 3D gradient (lighter top, darker bottom — macOS icon style)
    blend(ix + icon_pad, icon_y + icon_pad, icon_size, icon_size / 3, 0x00FFFFFF, 25)
    blend(ix + icon_pad, icon_y + icon_pad + icon_size * 2 / 3, icon_size, icon_size / 3, 0x00000000, 20)
    blend(ix + icon_pad + 2, icon_y + icon_pad + icon_size, icon_size - 4, 1, 0x00000000, 30)
    rrect_aa(ix + 8, icon_y + 8, 24, 8, 0x00FFFFFF, 3, 120)
    # "=" on display
    fill(ix + 16, icon_y + 11, 8, 1, 0x00888888)
    fill(ix + 16, icon_y + 14, 8, 1, 0x00888888)
    rrect_aa(ix + 9, icon_y + 19, 7, 7, 0x00FFFFFF, 2, 200)
    rrect_aa(ix + 17, icon_y + 19, 7, 7, 0x00FFFFFF, 2, 200)
    rrect_aa(ix + 25, icon_y + 19, 7, 7, 0x00FFFFFF, 2, 200)
    rrect_aa(ix + 9, icon_y + 27, 7, 7, 0x00FFFFFF, 2, 200)
    rrect_aa(ix + 17, icon_y + 27, 7, 7, 0x00FFFFFF, 2, 200)
    rrect_aa(ix + 25, icon_y + 27, 7, 7, 0x00FFFFFF, 2, 200)
    # Clear button (orange, stands out)
    rrect_aa(ix + 25, icon_y + 27, 7, 7, 0x00FF9500, 2, 200)
    blend(ix + 3, icon_y + pill_w + 1, pill_w - 6, 3, 0x00000000, 20)
    # Colored underglow (icon emits its own light — bolder, wider)
    blend(ix + 6, icon_y + pill_w + 2, 36, 4, ICON_CALC, 22)
    ix = ix + pill_w + icon_gap

    # Clock
    rrect(ix, icon_y, pill_w, pill_w, surface(theme), 14, 60)
    rrect_aa(ix, icon_y, pill_w, pill_w, 0x00FFFFFF, 14, 20)
    blend(ix + 2, icon_y + 1, pill_w - 4, 1, 0x00FFFFFF, 25)
    blend(ix + 4, icon_y + 2, 40, 20, 0x00FFFFFF, 10)
    # Wallpaper color reflection on icon top (cool blue-purple pickup — exceeds macOS)
    blend(ix + 6, icon_y + 4, 36, 14, 0x00304060, 8)
    blend(ix + icon_pad, icon_y + icon_pad + icon_size - 6, icon_size, 6, 0x00000000, 40)
    rrect_aa(ix + icon_pad, icon_y + icon_pad, icon_size, icon_size, ICON_CLOCK, 10, 255)
    rrect_aa(ix + icon_pad, icon_y + icon_pad, icon_size, icon_size, 0x00FFFFFF, 10, 25)
    # 3D gradient (lighter top, darker bottom — macOS icon style)
    blend(ix + icon_pad, icon_y + icon_pad, icon_size, icon_size / 3, 0x00FFFFFF, 25)
    blend(ix + icon_pad, icon_y + icon_pad + icon_size * 2 / 3, icon_size, icon_size / 3, 0x00000000, 20)
    blend(ix + icon_pad + 2, icon_y + icon_pad + icon_size, icon_size - 4, 1, 0x00000000, 30)
    ring(ix + 8, icon_y + 8, 24, 2, 0x00FFFFFF, 180)
    line(ix + 20, icon_y + 20, ix + 20, icon_y + 12, 0x00FFFFFF, 2, 200)
    line(ix + 20, icon_y + 20, ix + 26, icon_y + 18, 0x00FFFFFF, 2, 200)
    fill(ix + 19, icon_y + 9, 2, 2, 0x00FFFFFF)
    fill(ix + 19, icon_y + 29, 2, 2, 0x00FFFFFF)
    fill(ix + 9, icon_y + 19, 2, 2, 0x00FFFFFF)
    fill(ix + 29, icon_y + 19, 2, 2, 0x00FFFFFF)
    # Minute marks at 3,6,9 o'clock
    fill(ix + 9, icon_y + 19, 3, 2, 0x00FFFFFF)
    fill(ix + 28, icon_y + 19, 3, 2, 0x00FFFFFF)
    fill(ix + 19, icon_y + 28, 2, 3, 0x00FFFFFF)
    # 12 o'clock marker (thicker)
    fill(ix + 19, icon_y + 8, 2, 3, 0x00FFFFFF)
    blend(ix + 3, icon_y + pill_w + 1, pill_w - 6, 3, 0x00000000, 20)
    # Colored underglow (icon emits its own light — bolder, wider)
    blend(ix + 6, icon_y + pill_w + 2, 36, 4, ICON_CLOCK, 22)
    ix = ix + pill_w + icon_gap

    # Settings
    rrect(ix, icon_y, pill_w, pill_w, surface(theme), 14, 60)
    rrect_aa(ix, icon_y, pill_w, pill_w, 0x00FFFFFF, 14, 20)
    blend(ix + 2, icon_y + 1, pill_w - 4, 1, 0x00FFFFFF, 25)
    blend(ix + 4, icon_y + 2, 40, 20, 0x00FFFFFF, 10)
    # Wallpaper color reflection on icon top (cool blue-purple pickup — exceeds macOS)
    blend(ix + 6, icon_y + 4, 36, 14, 0x00304060, 8)
    blend(ix + icon_pad, icon_y + icon_pad + icon_size - 6, icon_size, 6, 0x00000000, 40)
    rrect_aa(ix + icon_pad, icon_y + icon_pad, icon_size, icon_size, ICON_SETTINGS, 10, 255)
    rrect_aa(ix + icon_pad, icon_y + icon_pad, icon_size, icon_size, 0x00FFFFFF, 10, 25)
    # 3D gradient (lighter top, darker bottom — macOS icon style)
    blend(ix + icon_pad, icon_y + icon_pad, icon_size, icon_size / 3, 0x00FFFFFF, 25)
    blend(ix + icon_pad, icon_y + icon_pad + icon_size * 2 / 3, icon_size, icon_size / 3, 0x00000000, 20)
    blend(ix + icon_pad + 2, icon_y + icon_pad + icon_size, icon_size - 4, 1, 0x00000000, 30)
    ring(ix + 10, icon_y + 10, 20, 3, 0x00FFFFFF, 160)
    circle(ix + 17, icon_y + 17, 8, 0x00FFFFFF, 180)
    # Gear teeth (4 notches around the ring)
    fill(ix + 20, icon_y + 6, 2, 4, 0x00FFFFFF)
    fill(ix + 20, icon_y + 30, 2, 4, 0x00FFFFFF)
    fill(ix + 8, icon_y + 18, 4, 2, 0x00FFFFFF)
    fill(ix + 30, icon_y + 18, 4, 2, 0x00FFFFFF)
    # Diagonal gear teeth
    fill(ix + 12, icon_y + 10, 3, 3, 0x00FFFFFF)
    fill(ix + 27, icon_y + 10, 3, 3, 0x00FFFFFF)
    fill(ix + 12, icon_y + 27, 3, 3, 0x00FFFFFF)
    fill(ix + 27, icon_y + 27, 3, 3, 0x00FFFFFF)
    # Inner detail circle
    ring(ix + 14, icon_y + 14, 12, 1, 0x00CCCCCC, 100)
    blend(ix + 3, icon_y + pill_w + 1, pill_w - 6, 3, 0x00000000, 20)
    # Colored underglow (icon emits its own light — bolder, wider)
    blend(ix + 6, icon_y + pill_w + 2, 36, 4, ICON_SETTINGS, 22)
    ix = ix + pill_w + icon_gap

    # Browser
    rrect(ix, icon_y, pill_w, pill_w, surface(theme), 14, 60)
    rrect_aa(ix, icon_y, pill_w, pill_w, 0x00FFFFFF, 14, 20)
    blend(ix + 2, icon_y + 1, pill_w - 4, 1, 0x00FFFFFF, 25)
    blend(ix + 4, icon_y + 2, 40, 20, 0x00FFFFFF, 10)
    # Wallpaper color reflection on icon top (cool blue-purple pickup — exceeds macOS)
    blend(ix + 6, icon_y + 4, 36, 14, 0x00304060, 8)
    blend(ix + icon_pad, icon_y + icon_pad + icon_size - 6, icon_size, 6, 0x00000000, 40)
    rrect_aa(ix + icon_pad, icon_y + icon_pad, icon_size, icon_size, ICON_BROWSER, 10, 255)
    rrect_aa(ix + icon_pad, icon_y + icon_pad, icon_size, icon_size, 0x00FFFFFF, 10, 25)
    # 3D gradient (lighter top, darker bottom — macOS icon style)
    blend(ix + icon_pad, icon_y + icon_pad, icon_size, icon_size / 3, 0x00FFFFFF, 25)
    blend(ix + icon_pad, icon_y + icon_pad + icon_size * 2 / 3, icon_size, icon_size / 3, 0x00000000, 20)
    blend(ix + icon_pad + 2, icon_y + icon_pad + icon_size, icon_size - 4, 1, 0x00000000, 30)
    ring(ix + 8, icon_y + 8, 24, 2, 0x00FFFFFF, 180)
    # Globe meridian lines (not a crosshair — distinct from Settings gear)
    line(ix + 14, icon_y + 8, ix + 14, icon_y + 32, 0x00FFFFFF, 1, 120)
    line(ix + 26, icon_y + 8, ix + 26, icon_y + 32, 0x00FFFFFF, 1, 120)
    line(ix + 8, icon_y + 14, ix + 32, icon_y + 14, 0x00FFFFFF, 1, 120)
    line(ix + 8, icon_y + 26, ix + 32, icon_y + 26, 0x00FFFFFF, 1, 120)
    # Compass needle
    line(ix + 16, icon_y + 24, ix + 24, icon_y + 16, 0x00FF4444, 2, 200)
    # Globe color tinting (subtle quadrant colors)
    blend(ix + 8, icon_y + 8, 12, 12, 0x003498DB, 20)
    blend(ix + 20, icon_y + 20, 12, 12, 0x0027AE60, 20)
    blend(ix + 3, icon_y + pill_w + 1, pill_w - 6, 3, 0x00000000, 20)
    # Colored underglow (icon emits its own light — bolder, wider)
    blend(ix + 6, icon_y + pill_w + 2, 36, 4, ICON_BROWSER, 22)
    ix = ix + pill_w + icon_gap

    # Editor
    rrect(ix, icon_y, pill_w, pill_w, surface(theme), 14, 60)
    rrect_aa(ix, icon_y, pill_w, pill_w, 0x00FFFFFF, 14, 20)
    blend(ix + 2, icon_y + 1, pill_w - 4, 1, 0x00FFFFFF, 25)
    blend(ix + 4, icon_y + 2, 40, 20, 0x00FFFFFF, 10)
    # Wallpaper color reflection on icon top (cool blue-purple pickup — exceeds macOS)
    blend(ix + 6, icon_y + 4, 36, 14, 0x00304060, 8)
    blend(ix + icon_pad, icon_y + icon_pad + icon_size - 6, icon_size, 6, 0x00000000, 40)
    rrect_aa(ix + icon_pad, icon_y + icon_pad, icon_size, icon_size, ICON_EDITOR, 10, 255)
    rrect_aa(ix + icon_pad, icon_y + icon_pad, icon_size, icon_size, 0x00FFFFFF, 10, 25)
    # 3D gradient (lighter top, darker bottom — macOS icon style)
    blend(ix + icon_pad, icon_y + icon_pad, icon_size, icon_size / 3, 0x00FFFFFF, 25)
    blend(ix + icon_pad, icon_y + icon_pad + icon_size * 2 / 3, icon_size, icon_size / 3, 0x00000000, 20)
    blend(ix + icon_pad + 2, icon_y + icon_pad + icon_size, icon_size - 4, 1, 0x00000000, 30)
    rrect_aa(ix + 10, icon_y + 8, 20, 24, 0x00FFFFFF, 3, 140)
    fill(ix + 14, icon_y + 13, 12, 2, 0x00148F77)
    fill(ix + 14, icon_y + 18, 10, 2, 0x00148F77)
    fill(ix + 14, icon_y + 23, 14, 2, 0x00148F77)
    # Cursor line (blinking indicator)
    fill(ix + 14, icon_y + 28, 1, 4, accent(theme))
    # Pencil tip accent
    line(ix + 26, icon_y + 26, ix + 30, icon_y + 30, accent(theme), 2, 200)
    blend(ix + 3, icon_y + pill_w + 1, pill_w - 6, 3, 0x00000000, 20)
    # Notification badge (unique SimpleOS feature)
    circle(ix + pill_w - 6, icon_y - 2, 14, 0x00FF3B30, 255)
    circle(ix + pill_w - 4, icon_y, 4, 0x00FFFFFF, 220)
    # Colored underglow (icon emits its own light — bolder, wider)
    blend(ix + 6, icon_y + pill_w + 2, 36, 4, ICON_EDITOR, 22)

    # Active app icon glow (magnification hint)
    val glow_x = dock_x + dock_pad
    blend(glow_x - 2, icon_y - 2, pill_w + 4, pill_w + 4, accent(theme), 15)
    val glow_x2 = glow_x + pill_w + icon_gap
    blend(glow_x2 - 2, icon_y - 2, pill_w + 4, pill_w + 4, accent(theme), 15)

    # === Separator line between app icons and utility icons ===
    val sep_x = ix + separator_gap
    blend(sep_x, dock_y + 8, separator_w, dock_h - 16, border_c(theme), border_a(theme))
    ix = sep_x + separator_w + separator_gap

    # === Finder icon (utility section) ===
    rrect(ix, icon_y, pill_w, pill_w, surface(theme), 14, 60)
    rrect_aa(ix, icon_y, pill_w, pill_w, 0x00FFFFFF, 14, 20)
    blend(ix + 2, icon_y + 1, pill_w - 4, 1, 0x00FFFFFF, 25)
    blend(ix + 4, icon_y + 2, 40, 20, 0x00FFFFFF, 10)
    # Wallpaper color reflection on icon top (cool blue-purple pickup — exceeds macOS)
    blend(ix + 6, icon_y + 4, 36, 14, 0x00304060, 8)
    blend(ix + icon_pad, icon_y + icon_pad + icon_size - 6, icon_size, 6, 0x00000000, 40)
    # Finder: blue face icon (two-tone smiley)
    rrect_aa(ix + icon_pad, icon_y + icon_pad, icon_size, icon_size, 0x004A90D9, 10, 255)
    rrect_aa(ix + icon_pad, icon_y + icon_pad, icon_size, icon_size, 0x00FFFFFF, 10, 25)
    # Face divider (left=light blue, right=darker blue — classic Finder look)
    blend(ix + icon_pad + icon_size / 2, icon_y + icon_pad, icon_size / 2, icon_size, 0x00357ABD, 120)
    # Eyes
    circle(ix + 12, icon_y + 14, 6, 0x00FFFFFF, 255)
    circle(ix + 24, icon_y + 14, 6, 0x00FFFFFF, 255)
    circle(ix + 13, icon_y + 14, 4, 0x00000000, 255)
    circle(ix + 25, icon_y + 14, 4, 0x00000000, 255)
    # Smile
    rrect_aa(ix + 12, icon_y + 24, 18, 6, 0x00FFFFFF, 3, 200)
    # Nose line
    blend(ix + icon_pad + icon_size / 2 - 1, icon_y + 16, 2, 10, 0x00FFFFFF, 100)
    blend(ix + 3, icon_y + pill_w + 1, pill_w - 6, 3, 0x00000000, 20)
    ix = ix + pill_w + icon_gap

    # === Trash icon (rightmost) ===
    rrect(ix, icon_y, pill_w, pill_w, surface(theme), 14, 60)
    rrect_aa(ix, icon_y, pill_w, pill_w, 0x00FFFFFF, 14, 20)
    blend(ix + 2, icon_y + 1, pill_w - 4, 1, 0x00FFFFFF, 25)
    blend(ix + 4, icon_y + 2, 40, 20, 0x00FFFFFF, 10)
    # Wallpaper color reflection on icon top (cool blue-purple pickup — exceeds macOS)
    blend(ix + 6, icon_y + 4, 36, 14, 0x00304060, 8)
    blend(ix + icon_pad, icon_y + icon_pad + icon_size - 6, icon_size, 6, 0x00000000, 40)
    # Trash can body (gray metallic)
    rrect_aa(ix + icon_pad, icon_y + icon_pad, icon_size, icon_size, 0x00808080, 10, 255)
    rrect_aa(ix + icon_pad, icon_y + icon_pad, icon_size, icon_size, 0x00FFFFFF, 10, 25)
    # Trash can shape: lid + body
    rrect_aa(ix + 10, icon_y + 8, 22, 4, 0x00C0C0C0, 2, 255)
    rrect_aa(ix + 8, icon_y + 10, 2, 4, 0x00C0C0C0, 1, 255)
    rrect_aa(ix + 32, icon_y + 10, 2, 4, 0x00C0C0C0, 1, 255)
    rrect_aa(ix + 12, icon_y + 14, 18, 20, 0x00A0A0A0, 3, 220)
    # Trash lines
    blend(ix + 16, icon_y + 17, 2, 14, 0x00808080, 180)
    blend(ix + 20, icon_y + 17, 2, 14, 0x00808080, 180)
    blend(ix + 24, icon_y + 17, 2, 14, 0x00808080, 180)
    # Handle
    rrect_aa(ix + 18, icon_y + 5, 6, 5, 0x00C0C0C0, 2, 200)
    blend(ix + 3, icon_y + pill_w + 1, pill_w - 6, 3, 0x00000000, 20)

    # === Running indicators — glowing dots under running apps ===
    val dot_y = dock_y + dock_h - 6
    val first_ix = dock_x + dock_pad + pill_w / 2 - 2

    # Terminal is always running (window 0) — dot
    circle(first_ix - 1, dot_y - 1, 8, accent(theme), 40)
    circle(first_ix, dot_y, 6, accent(theme), 220)

    # Files/Finder is always running (window 2) — dot at 2nd icon
    val files_dot_x = first_ix + (pill_w + icon_gap)
    circle(files_dot_x - 1, dot_y - 1, 8, accent(theme), 40)
    circle(files_dot_x, dot_y, 6, accent(theme), 220)

    # Clock running indicator (4th icon)
    circle(first_ix + (pill_w + icon_gap) * 3 - 1, dot_y - 1, 8, accent(theme), 40)
    circle(first_ix + (pill_w + icon_gap) * 3, dot_y, 6, accent(theme), 220)

    # Editor (window 1) — dot at 7th icon (Editor)
    val editor_dot_x = first_ix + 6 * (pill_w + icon_gap)
    circle(editor_dot_x - 1, dot_y - 1, 8, accent(theme), 40)
    circle(editor_dot_x, dot_y, 6, accent(theme), 220)

    # Active window indicator: brighter/larger dot for focused app
    if active == 0:
        # Terminal is focused — extra bright dot
        circle(first_ix, dot_y, 6, 0x00FFFFFF, 140)
    else:
        if active == 1:
            # Editor is focused
            circle(editor_dot_x, dot_y, 6, 0x00FFFFFF, 140)
        else:
            # Finder is focused
            circle(files_dot_x, dot_y, 6, 0x00FFFFFF, 140)

    # Dock reflection (beyond macOS — mirror effect)
    val refl_y = dock_y + dock_h + 2
    blend(dock_x + 10, refl_y, dock_w - 20, 1, surface(theme), 20)
    blend(dock_x + 16, refl_y + 1, dock_w - 32, 1, surface(theme), 12)
    blend(dock_x + 24, refl_y + 2, dock_w - 48, 1, surface(theme), 6)

# ===========================================================================
# Scancode to ASCII Conversion
# ===========================================================================

fn scancode_to_ascii(scancode: u64) -> u64:
    """Convert PS/2 scancode to ASCII character. Returns 0 for non-printable."""
    # Letters (lowercase only for now)
    if scancode == 0x1E: return 97   # a
    if scancode == 0x30: return 98   # b
    if scancode == 0x2E: return 99   # c
    if scancode == 0x20: return 100  # d
    if scancode == 0x12: return 101  # e
    if scancode == 0x21: return 102  # f
    if scancode == 0x22: return 103  # g
    if scancode == 0x23: return 104  # h
    if scancode == 0x17: return 105  # i
    if scancode == 0x24: return 106  # j
    if scancode == 0x25: return 107  # k
    if scancode == 0x26: return 108  # l
    if scancode == 0x32: return 109  # m
    if scancode == 0x31: return 110  # n
    if scancode == 0x18: return 111  # o
    if scancode == 0x19: return 112  # p
    if scancode == 0x10: return 113  # q
    if scancode == 0x13: return 114  # r
    if scancode == 0x1F: return 115  # s
    if scancode == 0x14: return 116  # t
    if scancode == 0x16: return 117  # u
    if scancode == 0x2F: return 118  # v
    if scancode == 0x11: return 119  # w
    if scancode == 0x2D: return 120  # x
    if scancode == 0x15: return 121  # y
    if scancode == 0x2C: return 122  # z
    if scancode == 0x39: return 32   # space
    if scancode == 0x33: return 46   # .
    if scancode == 0x34: return 47   # /
    if scancode == 0x28: return 45   # -
    return 0

# ===========================================================================
# App Click and Input Handlers
# ===========================================================================

fn handle_terminal_click(local_x: u64, local_y: u64):
    """Handle click in terminal content area."""
    serial_println("[Terminal] Click at local coords")

fn term_get_input_char(pos: u64) -> u64:
    """Get character at position from packed input buffer."""
    val word = pos / 8
    val byte_idx = pos % 8
    val shift = (7 - byte_idx) * 8
    var packed: u64 = 0
    if word == 0: packed = g_term_input_0
    if word == 1: packed = g_term_input_1
    if word == 2: packed = g_term_input_2
    if word == 3: packed = g_term_input_3
    if word == 4: packed = g_term_input_4
    (packed >> shift) & 0xFF

fn term_set_input_char(pos: u64, ch: u64):
    """Set character at position in packed input buffer."""
    val word = pos / 8
    val byte_idx = pos % 8
    val shift = (7 - byte_idx) * 8
    val mask = 0xFF << shift
    val clear_mask = 0xFFFFFFFFFFFFFFFF - mask
    val bits = (ch & 0xFF) << shift
    if word == 0: g_term_input_0 = (g_term_input_0 & clear_mask) | bits
    if word == 1: g_term_input_1 = (g_term_input_1 & clear_mask) | bits
    if word == 2: g_term_input_2 = (g_term_input_2 & clear_mask) | bits
    if word == 3: g_term_input_3 = (g_term_input_3 & clear_mask) | bits
    if word == 4: g_term_input_4 = (g_term_input_4 & clear_mask) | bits

fn term_clear_input():
    """Clear the terminal input buffer."""
    g_term_input_0 = 0
    g_term_input_1 = 0
    g_term_input_2 = 0
    g_term_input_3 = 0
    g_term_input_4 = 0
    g_term_input_len = 0

fn term_match_cmd(expected_0: u64, expected_len: u64) -> u64:
    """Check if input matches a command (single word, up to 8 chars)."""
    if g_term_input_len != expected_len: return 0
    if g_term_input_0 != expected_0: return 0
    return 1

fn handle_terminal_enter():
    """Execute the current terminal input as a command."""
    serial_println("[Terminal] Enter pressed")

    if g_term_input_len == 0:
        return

    # Match against built-in commands by comparing packed input
    val cmd_help = pack8(104, 101, 108, 112, 0, 0, 0, 0)
    val cmd_clear = pack8(99, 108, 101, 97, 114, 0, 0, 0)
    val cmd_uname = pack8(117, 110, 97, 109, 101, 0, 0, 0)
    val cmd_ls = pack8(108, 115, 0, 0, 0, 0, 0, 0)
    val cmd_whoami = pack8(119, 104, 111, 97, 109, 105, 0, 0)
    val cmd_date = pack8(100, 97, 116, 101, 0, 0, 0, 0)
    val cmd_uptime = pack8(117, 112, 116, 105, 109, 101, 0, 0)

    var matched: u64 = 0

    if term_match_cmd(cmd_help, 4) == 1:
        g_term_out_type = 1
        g_term_out_count = 8
        matched = 1

    if term_match_cmd(cmd_clear, 5) == 1:
        g_term_out_type = 0
        g_term_out_count = 0
        g_term_cmd_history = 0
        term_clear_input()
        return

    if term_match_cmd(cmd_uname, 5) == 1:
        g_term_out_type = 2
        g_term_out_count = 1
        matched = 1

    if term_match_cmd(cmd_ls, 2) == 1:
        g_term_out_type = 3
        g_term_out_count = 5
        matched = 1

    if term_match_cmd(cmd_whoami, 6) == 1:
        g_term_out_type = 4
        g_term_out_count = 1
        matched = 1

    if term_match_cmd(cmd_date, 4) == 1:
        g_term_out_type = 5
        g_term_out_count = 1
        matched = 1

    if term_match_cmd(cmd_uptime, 6) == 1:
        g_term_out_type = 6
        g_term_out_count = 1
        matched = 1

    if matched == 0:
        g_term_out_type = 7
        g_term_out_count = 1

    # Advance history and reset input
    g_term_cmd_history = g_term_cmd_history + 1
    term_clear_input()

fn handle_terminal_backspace():
    """Handle Backspace in terminal."""
    if g_term_input_len > 0:
        g_term_input_len = g_term_input_len - 1
        term_set_input_char(g_term_input_len, 0)

fn handle_terminal_char(ch: u64):
    """Handle character input in terminal."""
    if g_term_input_len < 40:
        term_set_input_char(g_term_input_len, ch)
        g_term_input_len = g_term_input_len + 1

fn handle_editor_click(local_x: u64, local_y: u64):
    """Handle click in editor content area -- maps pixel coords to cursor position."""
    # Editor layout: gutter_w=30, code starts at gutter_w+8, char width=8, line_h=16
    val gutter_w: u64 = 30
    val code_start: u64 = gutter_w + 8
    # Only reposition if click is in the code area (past the gutter)
    if local_x > code_start:
        val char_x = (local_x - code_start) / 8
        val char_y = local_y / 16
        # Clamp to valid range (8 visible lines, max ~30 columns)
        if char_y < 8:
            g_editor_cursor_y = char_y
        else:
            g_editor_cursor_y = 7
        if char_x < 30:
            g_editor_cursor_x = char_x
        else:
            g_editor_cursor_x = 29

fn handle_files_click(local_x: u64, local_y: u64):
    """Handle click in file explorer content area."""
    # Sidebar width is 110px (matching draw_files_content)
    if local_x < 110:
        # Sidebar click -- map Y to sidebar item index
        # Items at sb_y offsets: 22(Desktop), 41(Documents), 59(Downloads), 77(Apps), 118(SimpleHD)
        if local_y >= 118 and local_y < 140:
            g_files_sidebar_sel = 4
            serial_println("[Files] Sidebar: SimpleHD")
        else:
            if local_y >= 77 and local_y < 97:
                g_files_sidebar_sel = 3
                serial_println("[Files] Sidebar: Apps")
            else:
                if local_y >= 59 and local_y < 77:
                    g_files_sidebar_sel = 2
                    serial_println("[Files] Sidebar: Downloads")
                else:
                    if local_y >= 41 and local_y < 59:
                        g_files_sidebar_sel = 1
                        serial_println("[Files] Sidebar: Documents")
                    else:
                        if local_y >= 22 and local_y < 41:
                            g_files_sidebar_sel = 0
                            serial_println("[Files] Sidebar: Desktop")
    else:
        # Icon grid click -- icon_w=56, gap_x=12, icon_h=60, gap_y=8
        val grid_x = (local_x - 110) / 68  # 56 + 12 = 68px per column
        val grid_y = local_y / 68           # 60 + 8 = 68px per row
        if grid_x < 3:
            val idx = grid_y * 3 + grid_x
            if idx < 6:
                g_files_selected = idx
                serial_println("[Files] Item selected")

# ===========================================================================
# Application Window Content
# ===========================================================================

fn draw_hello_content(x: u64, y: u64, w: u64, h: u64, theme: u64):
    val cy = y + TITLE_BAR_H + 2
    val content_h = h - TITLE_BAR_H - 3
    val sidebar_w: u64 = 70
    val line_h: u64 = 16
    val status_h: u64 = 20

    # --- Tab bar ---
    val tab_y = cy
    val tab_h: u64 = 24
    blend(x + 1, tab_y, w - 2, tab_h, surface(theme), 50)
    blend(x + 1, tab_y + tab_h - 1, w - 2, 1, border_c(theme), border_a(theme))
    # Active tab (highlighted)
    rrect_aa(x + sidebar_w + 2, tab_y + 2, 80, tab_h - 3, elevated(theme), 4, 120)
    blend(x + sidebar_w + 2, tab_y + tab_h - 2, 80, 2, accent(theme), 200)
    # Tab label: "main.spl"
    draw_label(x + sidebar_w + 10, tab_y + 4, text_c(theme), 200, pack8(109, 97, 105, 110, 46, 115, 112, 108), 8)
    # Second tab (inactive)
    draw_label(x + sidebar_w + 92, tab_y + 4, text_sec(theme), 100, pack8(109, 111, 100, 46, 115, 112, 108, 0), 7)

    # --- File tree sidebar ---
    val sb_y = tab_y + tab_h
    rrect(x + 1, sb_y, sidebar_w, content_h - tab_h - status_h, 0x00181820, 0, 200)
    blend(x + sidebar_w, sb_y, 1, content_h - tab_h - status_h, border_c(theme), border_a(theme))
    # Section: "EXPLORER"
    draw_label(x + 6, sb_y + 4, text_sec(theme), 80, pack8(69, 88, 80, 76, 79, 82, 69, 82), 8)
    # Tree items
    # > src/
    draw_label(x + 6, sb_y + 20, 0x00CCCCCC, 160, pack8(62, 32, 115, 114, 99, 47, 0, 0), 6)
    #   main.spl (bold = open)
    draw_label_bold(x + 16, sb_y + 36, accent(theme), 200, pack8(109, 97, 105, 110, 46, 115, 112, 108), 8)
    #   mod.spl
    draw_label(x + 16, sb_y + 52, 0x00CCCCCC, 140, pack8(109, 111, 100, 46, 115, 112, 108, 0), 7)
    # > test/
    draw_label(x + 6, sb_y + 72, 0x00CCCCCC, 160, pack8(62, 32, 116, 101, 115, 116, 47, 0), 7)
    #   spec.spl
    draw_label(x + 16, sb_y + 88, 0x00CCCCCC, 140, pack8(115, 112, 101, 99, 46, 115, 112, 108), 8)

    # --- Editor area (dark bg with code lines) ---
    val ed_x = x + sidebar_w + 1
    val ed_y = sb_y
    val ed_w = w - sidebar_w - 2
    val ed_h = content_h - tab_h - status_h
    rrect(ed_x, ed_y, ed_w, ed_h, 0x000D0D14, 0, 220)

    # Line numbers gutter
    val gutter_w: u64 = 30
    blend(ed_x, ed_y, gutter_w, ed_h, 0x00FFFFFF, 8)
    blend(ed_x + gutter_w, ed_y, 1, ed_h, border_c(theme), 20)

    # Line numbers + code (8 visible lines)
    var ln: u64 = 0
    while ln < 8:
        val ly = ed_y + 4 + ln * line_h
        val ln_num = ln + 1
        # Line number (right-aligned in gutter)
        if ln_num < 10:
            draw_label(ed_x + 16, ly, 0x00666688, 120, pack8(48 + ln_num, 0, 0, 0, 0, 0, 0, 0), 1)
        ln = ln + 1

    # Syntax-colored code lines
    val code_x = ed_x + gutter_w + 8
    # Line 1: "fn main():"
    draw_label_outline(code_x, ed_y + 4, 0x00CC7832, 220, pack8(102, 110, 0, 0, 0, 0, 0, 0), 2, 40)
    draw_label_outline(code_x + 24, ed_y + 4, 0x00FFC66D, 220, pack8(109, 97, 105, 110, 0, 0, 0, 0), 4, 40)
    draw_label(code_x + 56, ed_y + 4, 0x00CCCCCC, 200, pack8(40, 41, 58, 0, 0, 0, 0, 0), 3)

    # Line 2: "    val x = 42"
    draw_label_outline(code_x + 32, ed_y + 20, 0x00CC7832, 220, pack8(118, 97, 108, 0, 0, 0, 0, 0), 3, 40)
    draw_label(code_x + 56, ed_y + 20, 0x00CCCCCC, 200, pack8(120, 32, 61, 32, 0, 0, 0, 0), 4)
    draw_label(code_x + 88, ed_y + 20, 0x006897BB, 220, pack8(52, 50, 0, 0, 0, 0, 0, 0), 2)

    # Line 3: "    print x"
    draw_label(code_x + 32, ed_y + 36, 0x00FFC66D, 220, pack8(112, 114, 105, 110, 116, 0, 0, 0), 5)
    draw_label(code_x + 72, ed_y + 36, 0x00CCCCCC, 200, pack8(32, 120, 0, 0, 0, 0, 0, 0), 2)

    # Line 4: blank
    # Line 5: "# Comment"
    draw_label(code_x, ed_y + 68, 0x00629755, 180, pack8(35, 32, 67, 111, 109, 109, 101, 110), 8)

    # Line 6: "fn square(n):"
    draw_label(code_x, ed_y + 84, 0x00CC7832, 220, pack8(102, 110, 0, 0, 0, 0, 0, 0), 2)
    draw_label(code_x + 24, ed_y + 84, 0x00FFC66D, 220, pack8(115, 113, 117, 97, 114, 101, 0, 0), 6)
    draw_label(code_x + 72, ed_y + 84, 0x00CCCCCC, 200, pack8(40, 110, 41, 58, 0, 0, 0, 0), 4)

    # Line 7: "    n * n"
    draw_label(code_x + 32, ed_y + 100, 0x00CCCCCC, 200, pack8(110, 32, 42, 32, 110, 0, 0, 0), 5)

    # Current line highlight (dynamic, follows g_editor_cursor_y)
    val line_hl_y = ed_y + 4 + g_editor_cursor_y * line_h
    blend(ed_x + gutter_w + 1, line_hl_y - 2, ed_w - gutter_w - 2, line_h, 0x00FFFFFF, 10)

    # Cursor (dynamic, follows g_editor_cursor_x / g_editor_cursor_y)
    val cursor_px_x = gutter_w + 8 + g_editor_cursor_x * 8
    val cursor_px_y = ed_y + 4 + g_editor_cursor_y * line_h
    # Semi-transparent block so underlying text remains visible
    blend(ed_x + cursor_px_x, cursor_px_y, 8, line_h, accent(theme), 120)
    # Thin insertion-style cursor line
    blend(ed_x + cursor_px_x, cursor_px_y, 2, line_h, 0x00FFFFFF, 200)

    # Progress bar
    val prog_y = ed_y + ed_h - 24
    rrect_aa(ed_x + 4, prog_y, ed_w - 8, 8, surface(theme), 4, 60)
    rrect_aa(ed_x + 4, prog_y, (ed_w - 8) * 3 / 4, 8, accent(theme), 4, 200)

    # Text lines (simulated content)
    blend(ed_x + 4, prog_y + 20, ed_w - 48, 3, text_c(theme), 40)
    blend(ed_x + 4, prog_y + 30, ed_w - 88, 3, text_c(theme), 30)
    blend(ed_x + 4, prog_y + 40, ed_w - 28, 3, text_c(theme), 25)

    # --- Status bar at bottom ---
    val st_y = y + h - status_h - 2
    blend(x + 1, st_y, w - 2, status_h, accent(theme), 200)
    # Dynamic "Ln N" using cursor position (1-based line number)
    val disp_ln = g_editor_cursor_y + 1
    # "Ln " prefix
    draw_label(x + 8, st_y + 3, 0x00FFFFFF, 200, pack8(76, 110, 32, 0, 0, 0, 0, 0), 3)
    # Line number digit (0-9)
    draw_label(x + 32, st_y + 3, 0x00FFFFFF, 200, pack8(48 + disp_ln, 0, 0, 0, 0, 0, 0, 0), 1)
    # ", C" separator
    draw_label(x + 40, st_y + 3, 0x00FFFFFF, 200, pack8(44, 32, 67, 0, 0, 0, 0, 0), 3)
    # Column number digit (0-based displayed as-is for simplicity)
    draw_label(x + 64, st_y + 3, 0x00FFFFFF, 200, pack8(48 + g_editor_cursor_x, 0, 0, 0, 0, 0, 0, 0), 1)
    # "Simple" on right
    draw_label_shadow(x + w - 56, st_y + 3, 0x00FFFFFF, 200, pack8(83, 105, 109, 112, 108, 101, 0, 0), 6, 60)

fn render_term_input(tx: u64, ty: u64, color: u64):
    """Render the current input line from packed buffer."""
    val words_needed = (g_term_input_len + 7) / 8
    if words_needed > 0:
        rt_gui_set_text_buf(g_term_input_0, 0, 0, 0)
    if words_needed > 1:
        rt_gui_set_text_buf(g_term_input_1, 8, 0, 0)
    if words_needed > 2:
        rt_gui_set_text_buf(g_term_input_2, 16, 0, 0)
    if words_needed > 3:
        rt_gui_set_text_buf(g_term_input_3, 24, 0, 0)
    if words_needed > 4:
        rt_gui_set_text_buf(g_term_input_4, 32, 0, 0)
    rt_gui_draw_text_buf(pack(tx, ty), pack(color, g_term_input_len), 220, 0)

fn render_term_help(hx: u64, hy: u64, color: u64, dim: u64) -> u64:
    """Render help command output. Returns pixel height used."""
    # "Built-in commands:"
    rt_gui_set_text_buf(pack8(66, 117, 105, 108, 116, 45, 105, 110), 0, 0, 0)
    rt_gui_set_text_buf(pack8(32, 99, 111, 109, 109, 97, 110, 100), 8, 0, 0)
    rt_gui_set_text_buf(pack8(115, 58, 0, 0, 0, 0, 0, 0), 16, 0, 0)
    rt_gui_draw_text_buf(pack(hx, hy), pack(color, 18), 220, 0)
    # "  help    - show this"
    rt_gui_set_text_buf(pack8(32, 32, 104, 101, 108, 112, 32, 32), 0, 0, 0)
    rt_gui_set_text_buf(pack8(32, 32, 45, 32, 115, 104, 111, 119), 8, 0, 0)
    rt_gui_set_text_buf(pack8(32, 116, 104, 105, 115, 0, 0, 0), 16, 0, 0)
    rt_gui_draw_text_buf(pack(hx, hy + 16), pack(dim, 21), 180, 0)
    # "  clear   - clear screen"
    rt_gui_set_text_buf(pack8(32, 32, 99, 108, 101, 97, 114, 32), 0, 0, 0)
    rt_gui_set_text_buf(pack8(32, 45, 32, 99, 108, 101, 97, 114), 8, 0, 0)
    rt_gui_set_text_buf(pack8(32, 115, 99, 114, 101, 101, 110, 0), 16, 0, 0)
    rt_gui_draw_text_buf(pack(hx, hy + 32), pack(dim, 23), 180, 0)
    # "  uname   - system info"
    rt_gui_set_text_buf(pack8(32, 32, 117, 110, 97, 109, 101, 32), 0, 0, 0)
    rt_gui_set_text_buf(pack8(32, 45, 32, 115, 121, 115, 116, 101), 8, 0, 0)
    rt_gui_set_text_buf(pack8(109, 32, 105, 110, 102, 111, 0, 0), 16, 0, 0)
    rt_gui_draw_text_buf(pack(hx, hy + 48), pack(dim, 22), 180, 0)
    # "  ls      - list files"
    rt_gui_set_text_buf(pack8(32, 32, 108, 115, 32, 32, 32, 32), 0, 0, 0)
    rt_gui_set_text_buf(pack8(32, 32, 45, 32, 108, 105, 115, 116), 8, 0, 0)
    rt_gui_set_text_buf(pack8(32, 102, 105, 108, 101, 115, 0, 0), 16, 0, 0)
    rt_gui_draw_text_buf(pack(hx, hy + 64), pack(dim, 22), 180, 0)
    # "  whoami  - current user"
    rt_gui_set_text_buf(pack8(32, 32, 119, 104, 111, 97, 109, 105), 0, 0, 0)
    rt_gui_set_text_buf(pack8(32, 32, 45, 32, 99, 117, 114, 114), 8, 0, 0)
    rt_gui_set_text_buf(pack8(101, 110, 116, 32, 117, 115, 101, 114), 16, 0, 0)
    rt_gui_draw_text_buf(pack(hx, hy + 80), pack(dim, 24), 180, 0)
    # "  date    - show date"
    rt_gui_set_text_buf(pack8(32, 32, 100, 97, 116, 101, 32, 32), 0, 0, 0)
    rt_gui_set_text_buf(pack8(32, 32, 45, 32, 115, 104, 111, 119), 8, 0, 0)
    rt_gui_set_text_buf(pack8(32, 100, 97, 116, 101, 0, 0, 0), 16, 0, 0)
    rt_gui_draw_text_buf(pack(hx, hy + 96), pack(dim, 21), 180, 0)
    # "  uptime  - system uptime"
    rt_gui_set_text_buf(pack8(32, 32, 117, 112, 116, 105, 109, 101), 0, 0, 0)
    rt_gui_set_text_buf(pack8(32, 32, 45, 32, 117, 112, 116, 105), 8, 0, 0)
    rt_gui_set_text_buf(pack8(109, 101, 0, 0, 0, 0, 0, 0), 16, 0, 0)
    rt_gui_draw_text_buf(pack(hx, hy + 112), pack(dim, 18), 180, 0)
    return 128

fn render_term_output(ox: u64, oy: u64, color: u64) -> u64:
    """Render the last command output. Returns pixel height used."""
    val dim_c = 0x00AAAAAA
    val green_c = 0x0044FF44
    val cyan_c = 0x005588CC

    if g_term_out_type == 1:
        return render_term_help(ox, oy, color, dim_c)

    if g_term_out_type == 2:
        # uname: "SimpleOS x86_64 v1.0"
        rt_gui_set_text_buf(pack8(83, 105, 109, 112, 108, 101, 79, 83), 0, 0, 0)
        rt_gui_set_text_buf(pack8(32, 120, 56, 54, 95, 54, 52, 32), 8, 0, 0)
        rt_gui_set_text_buf(pack8(118, 49, 46, 48, 0, 0, 0, 0), 16, 0, 0)
        rt_gui_draw_text_buf(pack(ox, oy), pack(green_c, 20), 220, 0)
        return 16

    if g_term_out_type == 3:
        # ls output
        # "bin/"
        draw_label(ox, oy, cyan_c, 200, pack8(98, 105, 110, 47, 0, 0, 0, 0), 4)
        # "etc/"
        draw_label(ox, oy + 16, cyan_c, 200, pack8(101, 116, 99, 47, 0, 0, 0, 0), 4)
        # "home/"
        draw_label(ox, oy + 32, cyan_c, 200, pack8(104, 111, 109, 101, 47, 0, 0, 0), 5)
        # "kernel.spl"
        rt_gui_set_text_buf(pack8(107, 101, 114, 110, 101, 108, 46, 115), 0, 0, 0)
        rt_gui_set_text_buf(pack8(112, 108, 0, 0, 0, 0, 0, 0), 8, 0, 0)
        rt_gui_draw_text_buf(pack(ox, oy + 48), pack(color, 10), 200, 0)
        # "README.md"
        rt_gui_set_text_buf(pack8(82, 69, 65, 68, 77, 69, 46, 109), 0, 0, 0)
        rt_gui_set_text_buf(pack8(100, 0, 0, 0, 0, 0, 0, 0), 8, 0, 0)
        rt_gui_draw_text_buf(pack(ox, oy + 64), pack(color, 9), 200, 0)
        return 80

    if g_term_out_type == 4:
        # whoami: "root"
        draw_label(ox, oy, green_c, 220, pack8(114, 111, 111, 116, 0, 0, 0, 0), 4)
        return 16

    if g_term_out_type == 5:
        # date: "2026-04-07 12:00"
        rt_gui_set_text_buf(pack8(50, 48, 50, 54, 45, 48, 52, 45), 0, 0, 0)
        rt_gui_set_text_buf(pack8(48, 55, 32, 49, 50, 58, 48, 48), 8, 0, 0)
        rt_gui_draw_text_buf(pack(ox, oy), pack(color, 16), 200, 0)
        return 16

    if g_term_out_type == 6:
        # uptime: "up 0d 00:01:23"
        rt_gui_set_text_buf(pack8(117, 112, 32, 48, 100, 32, 48, 48), 0, 0, 0)
        rt_gui_set_text_buf(pack8(58, 48, 49, 58, 50, 51, 0, 0), 8, 0, 0)
        rt_gui_draw_text_buf(pack(ox, oy), pack(color, 14), 200, 0)
        return 16

    if g_term_out_type == 7:
        # Unknown: "command not found"
        rt_gui_set_text_buf(pack8(99, 111, 109, 109, 97, 110, 100, 32), 0, 0, 0)
        rt_gui_set_text_buf(pack8(110, 111, 116, 32, 102, 111, 117, 110), 8, 0, 0)
        rt_gui_set_text_buf(pack8(100, 0, 0, 0, 0, 0, 0, 0), 16, 0, 0)
        rt_gui_draw_text_buf(pack(ox, oy), pack(0x00FF4444, 17), 220, 0)
        return 16

    return 0

fn draw_terminal_content(x: u64, y: u64, w: u64, h: u64, theme: u64):
    """Render interactive terminal with command prompt and output."""
    val cy = y + TITLE_BAR_H + 2
    val content_x = x + 10
    val text_color = 0x0044FF44
    val prompt_color = 0x0044FF44
    val output_color = 0x00CCCCCC
    val bg_color = 0x000A0A14

    # Terminal dark interior -- rounded bottom corners
    rrect(x + 1, cy, w - 2, h - TITLE_BAR_H - 3, bg_color, 10, 200)

    var line_y = cy + 8

    # Welcome header (shown before any command is executed)
    if g_term_cmd_history == 0:
        # "SimpleOS Terminal v1.0"
        rt_gui_set_text_buf(pack8(83, 105, 109, 112, 108, 101, 79, 83), 0, 0, 0)
        rt_gui_set_text_buf(pack8(32, 84, 101, 114, 109, 105, 110, 97), 8, 0, 0)
        rt_gui_set_text_buf(pack8(108, 32, 118, 49, 46, 48, 0, 0), 16, 0, 0)
        rt_gui_draw_text_buf(pack(content_x, line_y), pack(0x0088FF88, 22), 200, 0)
        line_y = line_y + 16
        # "Type 'help' for commands"
        rt_gui_set_text_buf(pack8(84, 121, 112, 101, 32, 39, 104, 101), 0, 0, 0)
        rt_gui_set_text_buf(pack8(108, 112, 39, 32, 102, 111, 114, 32), 8, 0, 0)
        rt_gui_set_text_buf(pack8(99, 111, 109, 109, 97, 110, 100, 115), 16, 0, 0)
        rt_gui_draw_text_buf(pack(content_x, line_y), pack(output_color, 24), 160, 0)
        line_y = line_y + 16
        line_y = line_y + 8

    # Show command output (from last executed command)
    if g_term_cmd_history > 0 and g_term_out_count > 0:
        val out_h = render_term_output(content_x, line_y, output_color)
        line_y = line_y + out_h
        line_y = line_y + 8

    # Current prompt line: "$ " prefix in green
    draw_label(content_x, line_y, prompt_color, 220, pack8(36, 32, 0, 0, 0, 0, 0, 0), 2)

    # Render typed input text
    if g_term_input_len > 0:
        render_term_input(content_x + 16, line_y, text_color)

    # Blinking cursor block
    val cursor_x = content_x + 16 + g_term_input_len * 8
    blend(cursor_x, line_y, 8, 14, text_color, 180)

fn draw_files_content(x: u64, y: u64, w: u64, h: u64, theme: u64):
    val cy = y + TITLE_BAR_H + 2
    val content_h = h - TITLE_BAR_H - 3
    val sidebar_w: u64 = 110

    # --- Toolbar (below title bar) ---
    val tb_y = cy
    val tb_h: u64 = 28
    blend(x + 1, tb_y, w - 2, tb_h, surface(theme), 60)
    blend(x + 1, tb_y + tb_h - 1, w - 2, 1, border_c(theme), border_a(theme))
    # Back/Forward arrows
    line(x + 12, tb_y + 14, x + 18, tb_y + 9, text_c(theme), 2, 140)
    line(x + 12, tb_y + 14, x + 18, tb_y + 19, text_c(theme), 2, 140)
    line(x + 28, tb_y + 9, x + 34, tb_y + 14, text_c(theme), 2, 140)
    line(x + 28, tb_y + 19, x + 34, tb_y + 14, text_c(theme), 2, 140)
    # View mode buttons (icon view / list view / column view)
    rrect_aa(x + w - 80, tb_y + 6, 22, 16, accent(theme), 4, 120)
    rrect_aa(x + w - 56, tb_y + 6, 22, 16, surface(theme), 4, 60)
    rrect_aa(x + w - 32, tb_y + 6, 22, 16, surface(theme), 4, 60)
    # Grid dots in icon view btn
    circle(x + w - 74, tb_y + 10, 3, 0x00FFFFFF, 220)
    circle(x + w - 68, tb_y + 10, 3, 0x00FFFFFF, 220)
    circle(x + w - 74, tb_y + 16, 3, 0x00FFFFFF, 220)
    circle(x + w - 68, tb_y + 16, 3, 0x00FFFFFF, 220)
    # List lines in list view btn
    fill(x + w - 52, tb_y + 10, 14, 2, text_c(theme))
    fill(x + w - 52, tb_y + 15, 14, 2, text_c(theme))
    # Column lines in column view btn
    blend(x + w - 26, tb_y + 8, 1, 12, text_c(theme), 120)
    blend(x + w - 20, tb_y + 8, 1, 12, text_c(theme), 120)
    blend(x + w - 14, tb_y + 8, 1, 12, text_c(theme), 120)

    # --- Sidebar ---
    val sb_y = tb_y + tb_h
    rrect(x + 1, sb_y, sidebar_w, content_h - tb_h, surface(theme), 8, 80)
    blend(x + sidebar_w, sb_y, 1, content_h - tb_h, border_c(theme), border_a(theme))

    # Sidebar section: "Favorites" header
    draw_label(x + 12, sb_y + 6, text_sec(theme), 100, pack8(70, 97, 118, 111, 114, 105, 116, 101), 8)

    # --- Sidebar selection highlights (dynamic, based on g_files_sidebar_sel) ---
    if g_files_sidebar_sel == 0:
        blend(x + 6, sb_y + 22, sidebar_w - 10, 20, accent(theme), 30)
    if g_files_sidebar_sel == 1:
        blend(x + 6, sb_y + 41, sidebar_w - 10, 20, accent(theme), 30)
    if g_files_sidebar_sel == 2:
        blend(x + 6, sb_y + 59, sidebar_w - 10, 20, accent(theme), 30)
    if g_files_sidebar_sel == 3:
        blend(x + 6, sb_y + 77, sidebar_w - 10, 20, accent(theme), 30)
    if g_files_sidebar_sel == 4:
        blend(x + 6, sb_y + 118, sidebar_w - 10, 20, accent(theme), 30)

    # --- Sidebar: Desktop with monitor icon ---
    rrect_aa(x + 6, sb_y + 22, sidebar_w - 10, 18, accent(theme), 6, 80)
    draw_label(x + 28, sb_y + 23, text_c(theme), 220, pack8(68, 101, 115, 107, 116, 111, 112, 0), 7)
    # Monitor shape: screen body
    rrect_aa(x + 11, sb_y + 25, 12, 9, accent(theme), 2, 240)
    blend(x + 12, sb_y + 26, 10, 7, 0x00FFFFFF, 80)
    # Monitor stand
    fill(x + 15, sb_y + 34, 4, 2, accent(theme))
    fill(x + 13, sb_y + 36, 8, 1, accent(theme))

    # --- Sidebar: Documents with page+fold icon ---
    draw_label(x + 28, sb_y + 43, text_c(theme), 160, pack8(68, 111, 99, 117, 109, 101, 110, 116), 8)
    # Page body
    rrect_aa(x + 12, sb_y + 43, 10, 12, 0x00FFFFFF, 2, 200)
    # Corner fold (top-right triangle)
    blend(x + 18, sb_y + 43, 4, 4, 0x00CCCCCC, 180)
    # Text lines inside page
    fill(x + 14, sb_y + 48, 5, 1, 0x00AAAAAA)
    fill(x + 14, sb_y + 50, 4, 1, 0x00AAAAAA)
    fill(x + 14, sb_y + 52, 5, 1, 0x00AAAAAA)

    # --- Sidebar: Downloads with arrow-down icon ---
    draw_label(x + 28, sb_y + 61, text_c(theme), 160, pack8(68, 111, 119, 110, 108, 111, 97, 100), 8)
    # Arrow body (vertical line)
    line(x + 17, sb_y + 62, x + 17, sb_y + 70, 0x005B9BD5, 2, 220)
    # Arrow head (two diagonal lines)
    line(x + 13, sb_y + 67, x + 17, sb_y + 72, 0x005B9BD5, 2, 220)
    line(x + 21, sb_y + 67, x + 17, sb_y + 72, 0x005B9BD5, 2, 220)
    # Tray/base line
    fill(x + 12, sb_y + 73, 10, 1, 0x005B9BD5)

    # --- Sidebar: Applications with 2x2 dot grid ---
    draw_label(x + 28, sb_y + 79, text_c(theme), 160, pack8(65, 112, 112, 108, 105, 99, 97, 116), 8)
    circle(x + 13, sb_y + 81, 4, 0x009B59B6, 220)
    circle(x + 19, sb_y + 81, 4, 0x009B59B6, 220)
    circle(x + 13, sb_y + 87, 4, 0x009B59B6, 220)
    circle(x + 19, sb_y + 87, 4, 0x009B59B6, 220)

    # Sidebar section: "Locations" header
    draw_label(x + 12, sb_y + 104, text_sec(theme), 100, pack8(76, 111, 99, 97, 116, 105, 111, 110), 8)

    # --- Sidebar: SimpleHD with disk icon ---
    draw_label(x + 28, sb_y + 120, text_c(theme), 160, pack8(83, 105, 109, 112, 108, 101, 72, 68), 8)
    # Disk body
    rrect_aa(x + 11, sb_y + 120, 12, 10, 0x00808080, 3, 200)
    blend(x + 12, sb_y + 121, 10, 3, 0x00AAAAAA, 120)
    # Disk indicator light
    circle(x + 20, sb_y + 127, 3, 0x0030D158, 200)

    # --- Content area: file icon grid ---
    val cx = x + sidebar_w + 8
    val grid_y = sb_y + 8
    val icon_w: u64 = 56
    val icon_h: u64 = 60
    val gap_x: u64 = 12
    val gap_y: u64 = 8

    # --- Grid item selection highlight (dynamic, based on g_files_selected) ---
    # Items 0-2 are Row 1 (folders), items 3-5 are Row 2 (files)
    val sel_col = g_files_selected % 3
    val sel_row = g_files_selected / 3
    val sel_ix = cx + sel_col * (icon_w + gap_x)
    val sel_iy = grid_y + sel_row * (icon_h + gap_y)
    rrect_aa(sel_ix - 2, sel_iy - 2, icon_w + 4, icon_h + 4, accent(theme), 4, 40)

    # ================================================================
    # Row 1: 3D Folder Icons (blue, green, purple)
    # ================================================================

    # --- Folder 0: Blue (Project) ---
    val f0x = cx + 0 * (icon_w + gap_x)
    # Contact shadow below folder
    blend(f0x + 5, grid_y + 37, 40, 4, 0x00000000, 30)
    # Back-flap (darker blue, offset above body)
    rrect_aa(f0x + 6, grid_y + 8, 18, 8, 0x004080B8, 3, 230)
    # Main folder body with gradient: lighter top to darker bottom
    grad_rect(f0x + 4, grid_y + 13, 40, 22, 0x0070BEFF, 4, 0x004A90D9, 240)
    # Top-edge specular highlight (1px white)
    blend(f0x + 6, grid_y + 13, 36, 1, 0x00FFFFFF, 50)
    # Inner shadow at top (2px dark)
    blend(f0x + 6, grid_y + 14, 36, 2, 0x00000000, 20)
    # 3D lighter top third
    blend(f0x + 5, grid_y + 13, 38, 7, 0x00FFFFFF, 20)
    # 3D darker bottom third
    blend(f0x + 5, grid_y + 28, 38, 6, 0x00000000, 15)
    # White document peeking out
    rrect_aa(f0x + 14, grid_y + 10, 14, 8, 0x00FFFFFF, 2, 180)
    fill(f0x + 16, grid_y + 12, 8, 1, 0x00CCCCCC)
    fill(f0x + 16, grid_y + 14, 6, 1, 0x00CCCCCC)
    # Folder border highlight
    rrect_aa(f0x + 4, grid_y + 13, 40, 22, 0x00FFFFFF, 4, 15)
    # Label: "Project" = 80,114,111,106,101,99,116,0
    draw_label_shadow(f0x + 6, grid_y + 42, text_c(theme), 200, pack8(80, 114, 111, 106, 101, 99, 116, 0), 7, 45)

    # --- Folder 1: Green (Photos) ---
    val f1x = cx + 1 * (icon_w + gap_x)
    # Contact shadow
    blend(f1x + 5, grid_y + 37, 40, 4, 0x00000000, 30)
    # Back-flap (darker green)
    rrect_aa(f1x + 6, grid_y + 8, 18, 8, 0x00207050, 3, 230)
    # Main body gradient: lighter green top to darker green bottom
    grad_rect(f1x + 4, grid_y + 13, 40, 22, 0x0058D0A0, 4, 0x0030A070, 240)
    # Specular highlight
    blend(f1x + 6, grid_y + 13, 36, 1, 0x00FFFFFF, 50)
    # Inner shadow
    blend(f1x + 6, grid_y + 14, 36, 2, 0x00000000, 20)
    # 3D lighter top
    blend(f1x + 5, grid_y + 13, 38, 7, 0x00FFFFFF, 20)
    # 3D darker bottom
    blend(f1x + 5, grid_y + 28, 38, 6, 0x00000000, 15)
    # White document peeking out
    rrect_aa(f1x + 14, grid_y + 10, 14, 8, 0x00FFFFFF, 2, 180)
    fill(f1x + 16, grid_y + 12, 8, 1, 0x00CCCCCC)
    fill(f1x + 16, grid_y + 14, 6, 1, 0x00CCCCCC)
    # Folder border highlight
    rrect_aa(f1x + 4, grid_y + 13, 40, 22, 0x00FFFFFF, 4, 15)
    # Label: "Photos" = 80,104,111,116,111,115,0,0
    draw_label_shadow(f1x + 8, grid_y + 42, text_c(theme), 200, pack8(80, 104, 111, 116, 111, 115, 0, 0), 6, 45)

    # --- Folder 2: Purple (Music) ---
    val f2x = cx + 2 * (icon_w + gap_x)
    # Contact shadow
    blend(f2x + 5, grid_y + 37, 40, 4, 0x00000000, 30)
    # Back-flap (darker purple)
    rrect_aa(f2x + 6, grid_y + 8, 18, 8, 0x006040A0, 3, 230)
    # Main body gradient: lighter purple top to darker purple bottom
    grad_rect(f2x + 4, grid_y + 13, 40, 22, 0x00B080E0, 4, 0x008060C0, 240)
    # Specular highlight
    blend(f2x + 6, grid_y + 13, 36, 1, 0x00FFFFFF, 50)
    # Inner shadow
    blend(f2x + 6, grid_y + 14, 36, 2, 0x00000000, 20)
    # 3D lighter top
    blend(f2x + 5, grid_y + 13, 38, 7, 0x00FFFFFF, 20)
    # 3D darker bottom
    blend(f2x + 5, grid_y + 28, 38, 6, 0x00000000, 15)
    # White document peeking out
    rrect_aa(f2x + 14, grid_y + 10, 14, 8, 0x00FFFFFF, 2, 180)
    fill(f2x + 16, grid_y + 12, 8, 1, 0x00CCCCCC)
    fill(f2x + 16, grid_y + 14, 6, 1, 0x00CCCCCC)
    # Folder border highlight
    rrect_aa(f2x + 4, grid_y + 13, 40, 22, 0x00FFFFFF, 4, 15)
    # Label: "Music" = 77,117,115,105,99,0,0,0
    draw_label_shadow(f2x + 10, grid_y + 42, text_c(theme), 200, pack8(77, 117, 115, 105, 99, 0, 0, 0), 5, 45)

    # ================================================================
    # Row 2: 3D Document/File Icons with content previews
    # ================================================================

    # --- File 0: Code file (main.spl) ---
    val d0x = cx + 0 * (icon_w + gap_x)
    val d0y = grid_y + icon_h + gap_y
    # Drop shadow behind page
    blend(d0x + 10, d0y + 7, 28, 34, 0x00000000, 25)
    # Page body (white rounded rect)
    rrect_aa(d0x + 8, d0y + 4, 28, 34, 0x00FFFFFF, 3, 240)
    # 3D: lighter top edge
    blend(d0x + 9, d0y + 5, 26, 2, 0x00FFFFFF, 30)
    # 3D: darker bottom
    blend(d0x + 9, d0y + 32, 26, 4, 0x00000000, 15)
    # Page border
    rrect_aa(d0x + 8, d0y + 4, 28, 34, border_c(theme), 3, 30)
    # Corner fold: triangle area (top-right)
    blend(d0x + 28, d0y + 4, 8, 8, 0x00E0E0E0, 220)
    # Fold shadow
    line(d0x + 28, d0y + 12, d0x + 36, d0y + 4, 0x00BBBBBB, 1, 120)
    blend(d0x + 28, d0y + 5, 7, 7, 0x00000000, 10)
    # Code content preview: colored lines
    # Orange keyword line
    fill(d0x + 12, d0y + 14, 8, 2, 0x00FF8844)
    fill(d0x + 22, d0y + 14, 10, 2, 0x00AAAAAA)
    # Green string line
    fill(d0x + 14, d0y + 18, 12, 2, 0x0044CC66)
    # Gray text line
    fill(d0x + 14, d0y + 22, 10, 2, 0x00999999)
    # Another orange keyword
    fill(d0x + 12, d0y + 26, 6, 2, 0x00FF8844)
    fill(d0x + 20, d0y + 26, 8, 2, 0x00AAAAAA)
    # Type badge: blue circle with "<>" hint
    circle(d0x + 30, d0y + 32, 8, accent(theme), 220)
    blend(d0x + 29, d0y + 33, 6, 4, 0x00FFFFFF, 100)
    # Label: "main.spl" = 109,97,105,110,46,115,112,108
    draw_label_shadow(d0x + 4, d0y + 42, text_c(theme), 200, pack8(109, 97, 105, 110, 46, 115, 112, 108), 8, 45)

    # --- File 1: Image file (cover.png) ---
    val d1x = cx + 1 * (icon_w + gap_x)
    val d1y = grid_y + icon_h + gap_y
    # Drop shadow
    blend(d1x + 10, d1y + 7, 28, 34, 0x00000000, 25)
    # Page body
    rrect_aa(d1x + 8, d1y + 4, 28, 34, 0x00FFFFFF, 3, 240)
    # 3D: lighter top
    blend(d1x + 9, d1y + 5, 26, 2, 0x00FFFFFF, 30)
    # 3D: darker bottom
    blend(d1x + 9, d1y + 32, 26, 4, 0x00000000, 15)
    # Page border
    rrect_aa(d1x + 8, d1y + 4, 28, 34, border_c(theme), 3, 30)
    # Corner fold
    blend(d1x + 28, d1y + 4, 8, 8, 0x00E0E0E0, 220)
    line(d1x + 28, d1y + 12, d1x + 36, d1y + 4, 0x00BBBBBB, 1, 120)
    blend(d1x + 28, d1y + 5, 7, 7, 0x00000000, 10)
    # Image preview: small gradient rectangle (sky/landscape)
    grad_v(d1x + 12, d1y + 13, 18, 10, 0x005BA3E0, 0x0090D0FF)
    # Mountain silhouette (dark triangles at bottom of preview)
    line(d1x + 12, d1y + 23, d1x + 19, d1y + 17, 0x00336644, 2, 180)
    line(d1x + 19, d1y + 17, d1x + 24, d1y + 23, 0x00336644, 2, 180)
    line(d1x + 20, d1y + 23, d1x + 26, d1y + 19, 0x00448855, 2, 160)
    line(d1x + 26, d1y + 19, d1x + 30, d1y + 23, 0x00448855, 2, 160)
    # Sun circle
    circle(d1x + 26, d1y + 14, 4, 0x00FFD700, 200)
    # Green ground bar
    fill(d1x + 12, d1y + 23, 18, 4, 0x0044AA66)
    # Type badge: green circle
    circle(d1x + 30, d1y + 32, 8, 0x0030D158, 220)
    blend(d1x + 29, d1y + 33, 6, 4, 0x00FFFFFF, 100)
    # Label: "cover.pn" = 99,111,118,101,114,46,112,110 (then "g" on next pack)
    draw_label_shadow(d1x + 2, d1y + 42, text_c(theme), 200, pack8(99, 111, 118, 101, 114, 46, 112, 110), 8, 45)

    # --- File 2: Document (README) ---
    val d2x = cx + 2 * (icon_w + gap_x)
    val d2y = grid_y + icon_h + gap_y
    # Drop shadow
    blend(d2x + 10, d2y + 7, 28, 34, 0x00000000, 25)
    # Page body
    rrect_aa(d2x + 8, d2y + 4, 28, 34, 0x00FFFFFF, 3, 240)
    # 3D: lighter top
    blend(d2x + 9, d2y + 5, 26, 2, 0x00FFFFFF, 30)
    # 3D: darker bottom
    blend(d2x + 9, d2y + 32, 26, 4, 0x00000000, 15)
    # Page border
    rrect_aa(d2x + 8, d2y + 4, 28, 34, border_c(theme), 3, 30)
    # Corner fold
    blend(d2x + 28, d2y + 4, 8, 8, 0x00E0E0E0, 220)
    line(d2x + 28, d2y + 12, d2x + 36, d2y + 4, 0x00BBBBBB, 1, 120)
    blend(d2x + 28, d2y + 5, 7, 7, 0x00000000, 10)
    # Document content: text paragraph lines (varying widths)
    fill(d2x + 12, d2y + 14, 18, 2, 0x00888888)
    fill(d2x + 12, d2y + 18, 14, 2, 0x00AAAAAA)
    fill(d2x + 12, d2y + 22, 16, 2, 0x00AAAAAA)
    fill(d2x + 12, d2y + 26, 10, 2, 0x00AAAAAA)
    # Second paragraph
    fill(d2x + 12, d2y + 31, 18, 2, 0x00888888)
    fill(d2x + 12, d2y + 35, 12, 1, 0x00BBBBBB)
    # Type badge: orange/amber circle
    circle(d2x + 30, d2y + 32, 8, 0x00F39C12, 220)
    blend(d2x + 29, d2y + 33, 6, 4, 0x00FFFFFF, 100)
    # Label: "README" = 82,69,65,68,77,69,0,0
    draw_label_shadow(d2x + 6, d2y + 42, text_c(theme), 200, pack8(82, 69, 65, 68, 77, 69, 0, 0), 6, 45)

    # --- Path bar at bottom (shows selected item name) ---
    val pb_y = y + h - 22
    blend(x + 1, pb_y, w - 2, 20, surface(theme), 50)
    blend(x + 1, pb_y, w - 2, 1, border_c(theme), border_a(theme))
    # Path prefix: "Desktop > "
    draw_label(x + 10, pb_y + 3, text_sec(theme), 120, pack8(68, 101, 115, 107, 116, 111, 112, 0), 7)
    draw_label(x + 66, pb_y + 3, text_sec(theme), 80, pack8(32, 62, 32, 0, 0, 0, 0, 0), 3)
    # Selected item name (dynamic, based on g_files_selected)
    # 0=Project, 1=Photos, 2=Music, 3=main.spl, 4=cover.pn, 5=README
    if g_files_selected == 0:
        draw_label(x + 90, pb_y + 3, text_c(theme), 180, pack8(80, 114, 111, 106, 101, 99, 116, 0), 7)
    if g_files_selected == 1:
        draw_label(x + 90, pb_y + 3, text_c(theme), 180, pack8(80, 104, 111, 116, 111, 115, 0, 0), 6)
    if g_files_selected == 2:
        draw_label(x + 90, pb_y + 3, text_c(theme), 180, pack8(77, 117, 115, 105, 99, 0, 0, 0), 5)
    if g_files_selected == 3:
        draw_label(x + 90, pb_y + 3, text_c(theme), 180, pack8(109, 97, 105, 110, 46, 115, 112, 108), 8)
    if g_files_selected == 4:
        draw_label(x + 90, pb_y + 3, text_c(theme), 180, pack8(99, 111, 118, 101, 114, 46, 112, 110), 8)
    if g_files_selected == 5:
        draw_label(x + 90, pb_y + 3, text_c(theme), 180, pack8(82, 69, 65, 68, 77, 69, 0, 0), 6)

# ===========================================================================
# Window Title Drawing
# ===========================================================================

fn draw_window_title(x: u64, y: u64, w: u64, title_chars: u64, title_len: u64, theme: u64):
    val title_pixel_w = title_len * 10
    val text_x = x + (w - title_pixel_w) / 2
    val text_y = y + 14
    # Multi-shadow depth for premium typography (second pass — softer, offset further)
    draw_label_vector(text_x + 1, text_y + 2, 0x00000000, 12, title_chars, title_len, 18)
    # Dark text shadow for crisp contrast (premium typography depth)
    draw_label_vector(text_x + 1, text_y + 1, 0x00000000, 45, title_chars, title_len, 18)
    # Vector font at 18px height — clean, centered, premium look
    draw_label_vector(text_x, text_y, text_c(theme), 240, title_chars, title_len, 18)

# ===========================================================================
# Animation Helpers
# ===========================================================================

# Get dock icon X position for minimize target (window -> dock icon slot)
fn dock_icon_x(win_idx: u64) -> u64:
    val num_icons: u64 = 7
    val pill_w = DOCK_PILL_SIZE
    val icon_gap = DOCK_ICON_GAP
    val dock_pad = DOCK_H_PAD
    val separator_w: u64 = 2
    val separator_gap: u64 = 10
    val num_util_icons: u64 = 2
    val dock_w = num_icons * (pill_w + icon_gap) + separator_w + separator_gap * 2 + num_util_icons * (pill_w + icon_gap) - icon_gap + dock_pad * 2
    val dock_x = (SCREEN_W - dock_w) / 2
    # Map window index to icon position (win0=terminal=icon0, win1=editor=icon6, win2=files=icon1)
    if win_idx == 0:
        dock_x + dock_pad + pill_w / 2
    else:
        if win_idx == 1:
            dock_x + dock_pad + 6 * (pill_w + icon_gap) + pill_w / 2
        else:
            dock_x + dock_pad + 1 * (pill_w + icon_gap) + pill_w / 2

fn dock_icon_y() -> u64:
    SCREEN_H - DOCK_ACTUAL_H - DOCK_MARGIN_BOTTOM + 8

# Draw window scaled between two rectangles based on progress
fn draw_animated_window(
    src_x: u64, src_y: u64, src_w: u64, src_h: u64,
    dst_x: u64, dst_y: u64, dst_w: u64, dst_h: u64,
    progress: u64, theme: u64):
    val eased = ease_out_cubic(progress)
    val ax = lerp(src_x, dst_x, eased)
    val ay = lerp(src_y, dst_y, eased)
    val aw = lerp(src_w, dst_w, eased)
    val ah = lerp(src_h, dst_h, eased)
    # Only draw if size is reasonable
    if aw > 20 and ah > 20:
        draw_glass_window(ax, ay, aw, ah, 1, theme)

# ===========================================================================
# Full Desktop Rendering
# ===========================================================================

fn draw_win0_normal(boff: u64, is_active: u64, theme: u64):
    val by = WIN0_Y - boff
    draw_glass_window(WIN0_X, by, WIN0_W, WIN0_H, is_active, theme)
    draw_terminal_content(WIN0_X, by, WIN0_W, WIN0_H, theme)
    draw_window_title(WIN0_X, by, WIN0_W, pack8(84, 101, 114, 109, 105, 110, 97, 108), 8, theme)

fn draw_win1_normal(boff: u64, is_active: u64, theme: u64):
    val by = WIN1_Y - boff
    draw_glass_window(WIN1_X, by, WIN1_W, WIN1_H, is_active, theme)
    draw_hello_content(WIN1_X, by, WIN1_W, WIN1_H, theme)
    draw_window_title(WIN1_X, by, WIN1_W, pack8(69, 100, 105, 116, 111, 114, 0, 0), 6, theme)

fn draw_win2_normal(boff: u64, is_active: u64, theme: u64):
    val by = WIN2_Y - boff
    draw_glass_window(WIN2_X, by, WIN2_W, WIN2_H, is_active, theme)
    draw_files_content(WIN2_X, by, WIN2_W, WIN2_H, theme)
    draw_window_title(WIN2_X, by, WIN2_W, pack8(70, 105, 110, 100, 101, 114, 0, 0), 6, theme)

# Draw close animation: scale down to center + fade
fn draw_close_animated(wx: u64, wy: u64, ww: u64, wh: u64, theme: u64):
    val eased = ease_in_cubic(g_close_progress)
    val shrink = eased * 15 / 100
    val cx = wx + shrink * ww / 200
    val cy = wy + shrink * wh / 200
    val cw = ww - shrink * ww / 100
    val ch = wh - shrink * wh / 100
    if cw > 30 and ch > 30:
        draw_glass_window(cx, cy, cw, ch, 1, theme)

# Draw a single window: normal, animating-minimize, animating-close, or skip if minimized
fn draw_single_window(win: u64, boff: u64, is_active: u64, theme: u64):
    val minimized_bit = (g_minimize_states >> win) & 1
    # If being actively minimized, draw animated version
    if g_minimize_active == 1 and g_minimize_win == win:
        if win == 0:
            draw_animated_window(WIN0_X, WIN0_Y, WIN0_W, WIN0_H, dock_icon_x(0), dock_icon_y(), 48, 48, g_minimize_progress, theme)
        else:
            if win == 1:
                draw_animated_window(WIN1_X, WIN1_Y, WIN1_W, WIN1_H, dock_icon_x(1), dock_icon_y(), 48, 48, g_minimize_progress, theme)
            else:
                draw_animated_window(WIN2_X, WIN2_Y, WIN2_W, WIN2_H, dock_icon_x(2), dock_icon_y(), 48, 48, g_minimize_progress, theme)
    else:
        # If being actively closed, draw close animation
        if g_close_active == 1 and g_close_win == win:
            if win == 0:
                draw_close_animated(WIN0_X, WIN0_Y, WIN0_W, WIN0_H, theme)
            else:
                if win == 1:
                    draw_close_animated(WIN1_X, WIN1_Y, WIN1_W, WIN1_H, theme)
                else:
                    draw_close_animated(WIN2_X, WIN2_Y, WIN2_W, WIN2_H, theme)
        else:
            # Skip if already minimized
            if minimized_bit == 0:
                if win == 0:
                    draw_win0_normal(boff, is_active, theme)
                else:
                    if win == 1:
                        draw_win1_normal(boff, is_active, theme)
                    else:
                        draw_win2_normal(boff, is_active, theme)

fn draw_desktop(active: u64, theme: u64):
    # Begin frame
    rt_gui_begin_frame(SCREEN_W, SCREEN_H, 0, 0)

    # 1. Procedural wallpaper
    rt_gui_draw_wallpaper(pack(SCREEN_W, SCREEN_H), theme, 0, 0)

    # Stronger vignette (darker corners — cinematic depth)
    blend(0, 0, 100, 80, 0x00000000, 20)
    blend(SCREEN_W - 100, 0, 100, 80, 0x00000000, 20)
    blend(0, SCREEN_H - 80, 100, 80, 0x00000000, 20)
    blend(SCREEN_W - 100, SCREEN_H - 80, 100, 80, 0x00000000, 20)

    # Top accent line (premium detail)
    grad_h(0, 0, SCREEN_W, 1, accent(theme), accent2(theme))

    # Subtle tech grid (unique SimpleOS wallpaper detail)
    if theme == 0:
        var gy: u64 = 100
        while gy < SCREEN_H - 100:
            blend(0, gy, SCREEN_W, 1, 0x00FFFFFF, 2)
            gy = gy + 80
        var gx: u64 = 100
        while gx < SCREEN_W - 100:
            blend(gx, 100, 1, SCREEN_H - 200, 0x00FFFFFF, 2)
            gx = gx + 80

    # Shooting stars (brighter — premium wallpaper detail)
    if theme == 0:
        line(180, 80, 220, 95, 0x00FFFFFF, 2, 200)
        line(220, 95, 230, 98, 0x00FFFFFF, 2, 110)
        blend(178, 79, 5, 5, 0x00FFFFFF, 140)
        # Second shooting star
        line(700, 120, 760, 150, 0x00FFFFFF, 2, 170)
        line(760, 150, 770, 153, 0x00FFFFFF, 1, 90)
        blend(698, 119, 4, 4, 0x00FFFFFF, 120)

    if theme == 0:
        # Extra bright stars (visible even at thumbnail size)
        blend(150, 120, 4, 4, 0x00FFFFFF, 160)
        blend(700, 200, 4, 4, 0x00FFFFFF, 140)
        blend(850, 350, 4, 4, 0x00FFFFFF, 120)
        blend(400, 500, 4, 4, 0x00FFFFFF, 100)
        blend(950, 100, 4, 4, 0x00FFFFFF, 150)

    # Light theme: subtle gradient overlay
    if theme == 1:
        blend(0, SCREEN_H / 2, SCREEN_W, SCREEN_H / 2, 0x00E8D0F0, 6)

    # Warm tint in lower third (color richness — beyond flat wallpaper)
    blend(0, SCREEN_H * 2 / 3, SCREEN_W, SCREEN_H / 3, 0x00201008, 6)

    # Animation: active window slides up by bounce_offset pixels
    val boff = bounce_offset(g_anim_progress)

    # 2. Windows in z-order (active drawn last = on top, with bounce)
    # Back windows get boff=0, active window gets boff
    if active == 0:
        draw_single_window(2, 0, 0, theme)
        draw_single_window(1, 0, 0, theme)
        draw_single_window(0, boff, 1, theme)
    else:
        if active == 1:
            draw_single_window(2, 0, 0, theme)
            draw_single_window(0, 0, 0, theme)
            draw_single_window(1, boff, 1, theme)
        else:
            draw_single_window(0, 0, 0, theme)
            draw_single_window(1, 0, 0, theme)
            draw_single_window(2, boff, 1, theme)

    # 4. System bar (glass, on top of everything)
    draw_glass_system_bar(theme, active)

    # 5. Dock (glass, at bottom)
    draw_glass_dock(theme, active)

    # Bottom gradient fade (premium detail)
    blend(0, SCREEN_H - 2, SCREEN_W, 2, 0x00000000, 20)

    # Screen-level ambient glow (simulates display backlight bleed — ultra premium)
    blend(SCREEN_W / 2 - 200, 0, 400, 20, 0x00FFFFFF, 3)

    # Global accent wash — ties all elements with consistent color signature
    blend(0, 0, SCREEN_W, SCREEN_H, accent(theme), 2)

    # 6. Mouse cursor (drawn last — always on top)
    if g_mouse_initialized == 1:
        draw_mouse_cursor(g_mouse_x, g_mouse_y, theme)

    # Present — bulk-copy shadow buffer to MMIO framebuffer
    rt_gui_present(0, 0, 0, 0)

# ===========================================================================
# Entry Point
# ===========================================================================

fn spl_start():
    serial_println("[WM] SimpleOS Glass Window Manager starting...")

    # 1. Program BGA framebuffer
    serial_println("[WM] Programming BGA: 1024x768x32")
    bga_wr(4, 0)
    bga_wr(1, SCREEN_W)
    bga_wr(2, SCREEN_H)
    bga_wr(3, 32)
    bga_wr(6, SCREEN_W)
    bga_wr(4, 0x41)

    # 2. Find framebuffer
    serial_println("[WM] Scanning PCI for VGA...")
    val fb_addr = find_vga_fb()
    rt_gui_set_fb(fb_addr, SCREEN_W)

    # Boot splash screen
    serial_println("[WM] Showing boot splash...")
    rt_gui_begin_frame(SCREEN_W, SCREEN_H, 0, 0)

    # Dark gradient background
    rt_gui_draw_wallpaper(pack(SCREEN_W, SCREEN_H), 0, 0, 0)

    # Center logo area — large rounded glass pill (wider for 2x text)
    val splash_w: u64 = 300
    val splash_h: u64 = 140
    val splash_x = (SCREEN_W - splash_w) / 2
    val splash_y = (SCREEN_H - splash_h) / 2 - 40

    # Glass logo container
    blur(splash_x, splash_y, splash_w, splash_h, 24)
    rrect_aa(splash_x, splash_y, splash_w, splash_h, 0x001E1E23, 28, 140)
    blend(splash_x + 4, splash_y + 1, splash_w - 8, 1, 0x00FFFFFF, 40)
    blend(splash_x + 6, splash_y + 2, splash_w - 12, 1, 0x00FFFFFF, 20)
    rrect_aa(splash_x, splash_y, splash_w, splash_h, 0x00FFFFFF, 28, 25)

    # "SimpleOS" in vector font at 40px
    draw_label_vector(splash_x + 70, splash_y + 16, 0x00F5F5F7, 240, pack8(83, 105, 109, 112, 108, 101, 79, 83), 8, 40)

    # Version text below (regular size)
    draw_label_shadow(splash_x + 130, splash_y + 60, 0x00EBEBF5, 160, pack8(118, 49, 46, 48, 0, 0, 0, 0), 4, 40)

    # Loading bar (wider, more visible)
    val bar_y = splash_y + 90
    rrect_aa(splash_x + 40, bar_y, splash_w - 80, 8, 0x00FFFFFF, 4, 30)
    grad_h(splash_x + 40, bar_y + 1, (splash_w - 80) * 2 / 3, 6, DARK_ACCENT, DARK_ACCENT2)
    rrect_aa(splash_x + 40, bar_y, (splash_w - 80) * 2 / 3, 8, 0x00FFFFFF, 4, 20)

    # "Starting..." below
    draw_label_shadow((SCREEN_W - 72) / 2, splash_y + splash_h + 20, 0x00EBEBF5, 120, pack8(83, 116, 97, 114, 116, 105, 110, 103), 8, 40)

    # SimpleOS branding: "Powered " tagline
    draw_label(splash_x + 56, splash_y + splash_h + 40, 0x00EBEBF5, 60, pack8(80, 111, 119, 101, 114, 101, 100, 32), 8)

    rt_gui_present(0, 0, 0, 0)

    # Brief pause to show splash (busy wait)
    var splash_wait: u64 = 0
    while splash_wait < 2000000:
        splash_wait = splash_wait + 1

    # 3. Initial render (dark glass theme)
    var theme: u64 = 0  # 0=dark, 1=light
    var active_win: u64 = 1

    # Animation state
    var anim_frame: u64 = 0       # Frame counter
    var anim_start: u64 = 0       # Frame when animation started
    var anim_duration: u64 = 12   # Animation length in frames
    var animating: u64 = 0        # 1 if currently animating
    var needs_redraw: u64 = 1     # Redraw on next frame
    var idle_count: u64 = 0       # Frames since last activity

    # Initialize PS/2 mouse
    mouse_init()

    # Local scancode-to-action mapping (matches os.gui.shortcut convention)

    serial_println("[WM] Rendering glass desktop (dark theme)...")
    draw_desktop(active_win, theme)

    serial_println("[WM] Glass desktop rendered!")
    serial_println("[WM] Controls: Tab=cycle, 1/2/3=focus, T=theme, M=minimize, R=restore, Q=quit")

    # 4. Continuous render loop with animation
    var running: u64 = 1
    while running == 1:
        # Update terminal input active state based on focused window
        if active_win == 0:
            g_term_input_active = 1
        else:
            g_term_input_active = 0

        # Poll keyboard — only if data is from keyboard (bit 5 clear), not mouse
        val kb_status = io_inb(0x64)
        if (kb_status & 0x21) == 0x01:  # Bit 0=data ready, bit 5=NOT mouse
            val scancode = io_inb(0x60)
            if (scancode & 0x80) == 0:
                # Determine which WM shortcut (if any) this scancode maps to
                # Tab and number keys always work; letter shortcuts only when
                # the terminal is NOT in input mode (active_win != 0)
                var wm_shortcut: u64 = 0
                if scancode == 0x0F: wm_shortcut = 1  # Tab always works
                if scancode == 0x02: wm_shortcut = 2  # 1 always works
                if scancode == 0x03: wm_shortcut = 3  # 2 always works
                if scancode == 0x04: wm_shortcut = 4  # 3 always works
                # T/Q/M/W/R only work as shortcuts when NOT typing in terminal
                if g_term_input_active == 0:
                    if scancode == 0x14: wm_shortcut = 5  # T = theme
                    if scancode == 0x10: wm_shortcut = 6  # Q = quit
                    if scancode == 0x32: wm_shortcut = 7  # M = minimize
                    if scancode == 0x11: wm_shortcut = 8  # W = close
                    if scancode == 0x13: wm_shortcut = 9  # R = restore

                # Process WM shortcuts
                if wm_shortcut == 1:
                    # Tab = cycle focus
                    active_win = (active_win + 1) % 3
                    animating = 1
                    anim_start = anim_frame
                    g_anim_progress = 0
                    needs_redraw = 1
                    serial_println("[WM] Focus cycled")
                if wm_shortcut == 2:
                    active_win = 0
                    animating = 1
                    anim_start = anim_frame
                    g_anim_progress = 0
                    needs_redraw = 1
                if wm_shortcut == 3:
                    active_win = 1
                    animating = 1
                    anim_start = anim_frame
                    g_anim_progress = 0
                    needs_redraw = 1
                if wm_shortcut == 4:
                    active_win = 2
                    animating = 1
                    anim_start = anim_frame
                    g_anim_progress = 0
                    needs_redraw = 1
                if wm_shortcut == 5:
                    # T = toggle theme
                    theme = (theme + 1) % 2
                    animating = 1
                    anim_start = anim_frame
                    g_anim_progress = 0
                    needs_redraw = 1
                    if theme == 0:
                        serial_println("[WM] Theme: Dark Glass")
                    else:
                        serial_println("[WM] Theme: White Glass")
                if wm_shortcut == 6:
                    # Q = quit
                    running = 0
                    serial_println("[WM] Quit requested")
                if wm_shortcut == 7:
                    # M = minimize
                    val already_minimized = (g_minimize_states >> active_win) & 1
                    if g_minimize_active == 0 and already_minimized == 0:
                        g_minimize_active = 1
                        g_minimize_progress = 0
                        g_minimize_win = active_win
                        needs_redraw = 1
                        serial_println("[WM] Minimizing window")
                if wm_shortcut == 8:
                    # W = close
                    if g_close_active == 0:
                        g_close_active = 1
                        g_close_progress = 0
                        g_close_win = active_win
                        needs_redraw = 1
                        serial_println("[WM] Closing window")
                if wm_shortcut == 9:
                    # R = restore
                    if g_minimize_states != 0:
                        g_minimize_states = 0
                        needs_redraw = 1
                        serial_println("[WM] Restored all windows")

                # Forward non-shortcut key presses to active app
                if wm_shortcut == 0:
                    var key_handled: u64 = 0
                    if scancode == 0x1C:  # Enter
                        if active_win == 0:
                            handle_terminal_enter()
                            key_handled = 1
                            needs_redraw = 1
                    if scancode == 0x0E:  # Backspace
                        if active_win == 0:
                            handle_terminal_backspace()
                            key_handled = 1
                            needs_redraw = 1
                    # Letter/symbol keys forwarded to active app
                    if key_handled == 0:
                        if active_win == 0:
                            val ch = scancode_to_ascii(scancode)
                            if ch != 0:
                                handle_terminal_char(ch)
                                key_handled = 1
                                needs_redraw = 1

        # Poll mouse (PS/2 auxiliary device)
        if g_mouse_initialized == 1:
            val m_status = io_inb(0x64)
            if (m_status & 0x21) == 0x21:  # Bit 0=data ready, bit 5=mouse data
                val byte1 = io_inb(0x60)
                # Wait for byte 2
                mouse_wait_read()
                val byte2 = io_inb(0x60)
                # Wait for byte 3
                mouse_wait_read()
                val byte3 = io_inb(0x60)

                # Parse mouse packet — bit 3 of byte1 always set in valid packets
                if (byte1 & 0x08) != 0:
                    g_mouse_prev_buttons = g_mouse_buttons
                    g_mouse_buttons = byte1 & 0x07  # Button bits

                    # X delta
                    var dx: u64 = byte2
                    if (byte1 & 0x10) != 0:
                        # Negative X: subtract from position
                        val neg_dx = 256 - dx
                        if g_mouse_x > neg_dx:
                            g_mouse_x = g_mouse_x - neg_dx
                        else:
                            g_mouse_x = 0
                    else:
                        g_mouse_x = g_mouse_x + dx
                        if g_mouse_x >= SCREEN_W:
                            g_mouse_x = SCREEN_W - 1

                    # Y delta (inverted for screen coordinates)
                    var dy: u64 = byte3
                    if (byte1 & 0x20) != 0:
                        # Negative Y (inverted = move down on screen)
                        val neg_dy = 256 - dy
                        g_mouse_y = g_mouse_y + neg_dy
                        if g_mouse_y >= SCREEN_H:
                            g_mouse_y = SCREEN_H - 1
                    else:
                        # Positive Y (inverted = move up on screen)
                        if g_mouse_y > dy:
                            g_mouse_y = g_mouse_y - dy
                        else:
                            g_mouse_y = 0

                    # Left click detection
                    val left_pressed = g_mouse_buttons & 1
                    val left_was = g_mouse_prev_buttons & 1

                    # Button just pressed — hit test for focus + start drag
                    if left_pressed == 1:
                        if left_was == 0:
                            serial_println("[WM] Mouse click")
                            # Hit test windows back-to-front (win2, win1, win0)
                            # Window 2 (Finder)
                            if g_mouse_x >= WIN2_X:
                                if g_mouse_x < WIN2_X + WIN2_W:
                                    if g_mouse_y >= WIN2_Y:
                                        if g_mouse_y < WIN2_Y + WIN2_H:
                                            if active_win != 2:
                                                active_win = 2
                                                animating = 1
                                                anim_start = anim_frame
                                                g_anim_progress = 0
                                            # Start drag if in title bar
                                            if g_mouse_y < WIN2_Y + TITLE_BAR_H:
                                                g_dragging = 3
                                                g_drag_offset_x = g_mouse_x - WIN2_X
                                                g_drag_offset_y = g_mouse_y - WIN2_Y
                            # Window 1 (Editor)
                            if g_dragging == 0:
                                if g_mouse_x >= WIN1_X:
                                    if g_mouse_x < WIN1_X + WIN1_W:
                                        if g_mouse_y >= WIN1_Y:
                                            if g_mouse_y < WIN1_Y + WIN1_H:
                                                if active_win != 1:
                                                    active_win = 1
                                                    animating = 1
                                                    anim_start = anim_frame
                                                    g_anim_progress = 0
                                                if g_mouse_y < WIN1_Y + TITLE_BAR_H:
                                                    g_dragging = 2
                                                    g_drag_offset_x = g_mouse_x - WIN1_X
                                                    g_drag_offset_y = g_mouse_y - WIN1_Y
                            # Window 0 (Terminal)
                            if g_dragging == 0:
                                if g_mouse_x >= WIN0_X:
                                    if g_mouse_x < WIN0_X + WIN0_W:
                                        if g_mouse_y >= WIN0_Y:
                                            if g_mouse_y < WIN0_Y + WIN0_H:
                                                if active_win != 0:
                                                    active_win = 0
                                                    animating = 1
                                                    anim_start = anim_frame
                                                    g_anim_progress = 0
                                                if g_mouse_y < WIN0_Y + TITLE_BAR_H:
                                                    g_dragging = 1
                                                    g_drag_offset_x = g_mouse_x - WIN0_X
                                                    g_drag_offset_y = g_mouse_y - WIN0_Y

                    # Dragging — update window position
                    if g_dragging != 0:
                        if left_pressed == 1:
                            if g_dragging == 1:
                                if g_mouse_x >= g_drag_offset_x:
                                    WIN0_X = g_mouse_x - g_drag_offset_x
                                if g_mouse_y >= g_drag_offset_y:
                                    WIN0_Y = g_mouse_y - g_drag_offset_y
                            if g_dragging == 2:
                                if g_mouse_x >= g_drag_offset_x:
                                    WIN1_X = g_mouse_x - g_drag_offset_x
                                if g_mouse_y >= g_drag_offset_y:
                                    WIN1_Y = g_mouse_y - g_drag_offset_y
                            if g_dragging == 3:
                                if g_mouse_x >= g_drag_offset_x:
                                    WIN2_X = g_mouse_x - g_drag_offset_x
                                if g_mouse_y >= g_drag_offset_y:
                                    WIN2_Y = g_mouse_y - g_drag_offset_y

                    # Propagate click to active window's content area
                    if g_dragging == 0:
                        if left_pressed == 1:
                            if left_was == 0:
                                # Compute local coordinates within the active window
                                var local_x: u64 = 0
                                var local_y: u64 = 0
                                var in_content: u64 = 0

                                if active_win == 0:
                                    if g_mouse_x >= WIN0_X:
                                        if g_mouse_x < WIN0_X + WIN0_W:
                                            if g_mouse_y >= WIN0_Y + TITLE_BAR_H:
                                                if g_mouse_y < WIN0_Y + WIN0_H:
                                                    local_x = g_mouse_x - WIN0_X
                                                    local_y = g_mouse_y - (WIN0_Y + TITLE_BAR_H)
                                                    in_content = 1
                                if active_win == 1:
                                    if g_mouse_x >= WIN1_X:
                                        if g_mouse_x < WIN1_X + WIN1_W:
                                            if g_mouse_y >= WIN1_Y + TITLE_BAR_H:
                                                if g_mouse_y < WIN1_Y + WIN1_H:
                                                    local_x = g_mouse_x - WIN1_X
                                                    local_y = g_mouse_y - (WIN1_Y + TITLE_BAR_H)
                                                    in_content = 1
                                if active_win == 2:
                                    if g_mouse_x >= WIN2_X:
                                        if g_mouse_x < WIN2_X + WIN2_W:
                                            if g_mouse_y >= WIN2_Y + TITLE_BAR_H:
                                                if g_mouse_y < WIN2_Y + WIN2_H:
                                                    local_x = g_mouse_x - WIN2_X
                                                    local_y = g_mouse_y - (WIN2_Y + TITLE_BAR_H)
                                                    in_content = 1

                                if in_content == 1:
                                    if active_win == 0:
                                        handle_terminal_click(local_x, local_y)
                                    if active_win == 1:
                                        handle_editor_click(local_x, local_y)
                                    if active_win == 2:
                                        handle_files_click(local_x, local_y)
                                    needs_redraw = 1

                    # Button released — stop dragging
                    if left_pressed == 0:
                        if g_dragging != 0:
                            g_dragging = 0

                    needs_redraw = 1

        # Update focus animation
        if animating == 1:
            val elapsed = anim_frame - anim_start
            if elapsed >= anim_duration:
                animating = 0
                g_anim_progress = 100
            else:
                g_anim_progress = (elapsed * 100) / anim_duration
            needs_redraw = 1

        # Minimize animation tick (8 frames = ~130ms at 60fps)
        if g_minimize_active == 1:
            g_minimize_progress = g_minimize_progress + 12
            if g_minimize_progress >= 100:
                g_minimize_progress = 100
                g_minimize_active = 0
                # Mark window as minimized
                g_minimize_states = g_minimize_states | (1 << g_minimize_win)
                # Cycle to next non-minimized window
                var next_win: u64 = (active_win + 1) % 3
                var search: u64 = 0
                while search < 3:
                    val next_min = (g_minimize_states >> next_win) & 1
                    if next_min == 0:
                        search = 3  # break
                    else:
                        next_win = (next_win + 1) % 3
                    search = search + 1
                active_win = next_win
                serial_println("[WM] Window minimized to dock")
            needs_redraw = 1

        # Close animation tick (6 frames = ~100ms)
        if g_close_active == 1:
            g_close_progress = g_close_progress + 16
            if g_close_progress >= 100:
                g_close_progress = 100
                g_close_active = 0
                # Mark window as minimized (same as minimize for now)
                g_minimize_states = g_minimize_states | (1 << g_close_win)
                active_win = (active_win + 1) % 3
            needs_redraw = 1

        # Redraw if needed
        if needs_redraw == 1:
            draw_desktop(active_win, theme)
            needs_redraw = 0
            idle_count = 0

        anim_frame = anim_frame + 1

        # Throttle: simple busy-wait to avoid 100% CPU spin
        # ~60fps: waste some cycles between frames when idle
        if animating == 0 and g_minimize_active == 0 and g_close_active == 0:
            idle_count = idle_count + 1
            # After settling, stop redrawing until next input
            var spin: u64 = 0
            while spin < 50000:
                spin = spin + 1

    serial_println("[WM] Window Manager shutting down")
