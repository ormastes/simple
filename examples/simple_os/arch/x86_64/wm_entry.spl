# === Hardware init ===

fn bga_wr(idx: u64, val_: u64):
    io_outw(0x01CE, idx)
    io_outw(0x01CF, val_)

fn pci_rd(dev: u64, off: u64) -> u64:
    val a: u64 = 0x80000000 | (dev << 11) | (off & 0xFC)
    io_outl(0x0CF8, a)
    io_inl(0x0CFC)

fn pci_wr(dev: u64, off: u64, val_: u64):
    val a: u64 = 0x80000000 | (dev << 11) | (off & 0xFC)
    io_outl(0x0CF8, a)
    io_outl(0x0CFC, val_)

fn find_vga_fb() -> u64:
    var d: u64 = 0
    while d < 32:
        val v = pci_rd(d, 0) & 0xFFFF
        if v != 0xFFFF and v != 0:
            val c = pci_rd(d, 8)
            if ((c >> 24) & 0xFF) == 3:
                val cmd = pci_rd(d, 0x04)
                pci_wr(d, 0x04, cmd | 0x06)
                val bar0 = pci_rd(d, 0x10)
                val addr = bar0 & 0xFFFFFFF0
                if addr != 0:
                    return addr
        d = d + 1
    0xFD000000

# === PS/2 Mouse ===

fn mouse_wait_write():
    var i: u64 = 0
    while i < 100000:
        if (io_inb(0x64) & 2) == 0:
            return
        i = i + 1

fn mouse_wait_read():
    var i: u64 = 0
    while i < 100000:
        if (io_inb(0x64) & 1) != 0:
            return
        i = i + 1

fn mouse_cmd(cmd: u64):
    mouse_wait_write()
    io_outb(0x64, 0xD4)  # Send to mouse
    mouse_wait_write()
    io_outb(0x60, cmd)
    mouse_wait_read()
    io_inb(0x60)  # Read ACK

fn mouse_init():
    """Initialize PS/2 mouse with basic 3-byte packet mode."""
    # Enable auxiliary device
    mouse_wait_write()
    io_outb(0x64, 0xA8)

    # Enable interrupts — get controller config byte
    mouse_wait_write()
    io_outb(0x64, 0x20)  # Get compaq status
    mouse_wait_read()
    val status = io_inb(0x60)
    mouse_wait_write()
    io_outb(0x64, 0x60)  # Set compaq status
    mouse_wait_write()
    io_outb(0x60, (status | 2) & 0xDF)  # Enable IRQ12, disable clock disable

    # Set defaults
    mouse_cmd(0xF6)

    # Enable data reporting
    mouse_cmd(0xF4)

    g_mouse_initialized = 1
    serial_println("[WM] PS/2 mouse initialized")

fn draw_mouse_cursor(mx: u64, my: u64, theme: u64):
    """Draw a simple arrow cursor at mouse position."""
    # Cursor: 16-row triangle, each row has width = row/2 + 1
    # Black outline on left edge, right edge, top, and bottom row
    # White fill interior
    # Drop shadow offset by 2px
    # Shadow first (behind cursor)
    blend(mx + 2, my + 2, 10, 16, 0x00000000, 30)

    var row: u64 = 0
    while row < 16:
        var col: u64 = 0
        val width = row / 2 + 1
        while col < width:
            val px = mx + col
            val py = my + row
            if px < SCREEN_W:
                if py < SCREEN_H:
                    if col == 0:
                        # Left edge — black outline
                        blend(px, py, 1, 1, 0x00000000, 220)
                    else:
                        if row < 3:
                            # Top rows — white fill (too narrow for outline)
                            blend(px, py, 1, 1, 0x00FFFFFF, 240)
                        else:
                            if col == width - 1:
                                # Right edge — black outline
                                blend(px, py, 1, 1, 0x00000000, 220)
                            else:
                                # Interior — white fill
                                blend(px, py, 1, 1, 0x00FFFFFF, 240)
            col = col + 1
        # Bottom row — all black outline
        if row == 15:
            var c2: u64 = 0
            while c2 < width:
                val bx = mx + c2
                val by = my + row
                if bx < SCREEN_W:
                    if by < SCREEN_H:
                        blend(bx, by, 1, 1, 0x00000000, 220)
                c2 = c2 + 1
        row = row + 1

# === Rendering helpers ===

