# SimpleOS Glass Window Manager — Modern Glassmorphism Desktop
#
# Self-contained entry with frosted glass UI effects:
# 1. BGA framebuffer (1024x768x32) via port I/O
# 2. PCI BAR scan for VGA LFB address
# 3. Gradient desktop background (midnight → purple)
# 4. Frosted glass windows with blur + alpha blend + shadows
# 5. Glass system bar and dock with backdrop blur
# 6. macOS-style traffic light buttons (close/min/max)
# 7. Dark Glass / White Glass theme toggle (T key)
# 8. Focus ring effect on active window
# 9. PS/2 keyboard input for window management

# === Input handling ===
# Shared modules exist at os.gui.input_event + os.gui.shortcut but
# using imported classes in --entry-closure baremetal builds causes
# FAULT (class instantiation fails). Using local scancode mapping
# with matching action code convention from the shared modules.

# === Extern FFI declarations ===
extern fn serial_println(msg: text)
extern fn rt_gui_set_fb(addr: u64, width: u64)

# Port I/O — direct extern (u64 params match RuntimeValue ABI)
extern fn rt_port_inb(port: u64) -> u64
extern fn rt_port_outb(port: u64, value: u64)
extern fn rt_port_outw(port: u64, value: u64)
extern fn rt_port_inl(port: u64) -> u64
extern fn rt_port_outl(port: u64, value: u64)

# Aliases for readability
fn io_inb(port: u64) -> u64: rt_port_inb(port)
fn io_outb(port: u64, value: u64): rt_port_outb(port, value)
fn io_inw(port: u64) -> u64: rt_port_inb(port)
fn io_outw(port: u64, value: u64): rt_port_outw(port, value)
fn io_inl(port: u64) -> u64: rt_port_inl(port)
fn io_outl(port: u64, value: u64): rt_port_outl(port, value)

