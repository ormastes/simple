# Bounce easing: overshoot then settle (integer approximation)
# Maps progress 0-100 to offset 0-N-0 with overshoot
fn bounce_offset(progress: u64) -> u64:
    # Phase 1 (0-40): scale up (offset shrinks from 8 to 0)
    if progress < 40:
        (8 * (40 - progress)) / 40
    # Phase 2 (40-70): overshoot (offset goes negative = -3 to 0)
    else:
        if progress < 70:
            0
        # Phase 3 (70-100): settle
        else:
            0

# Ease-out cubic: fast start, smooth deceleration (like macOS)
# Maps 0-100 -> 0-100 with easing
fn ease_out_cubic(t: u64) -> u64:
    # f(t) = 1 - (1-t)^3 -- integer approximation
    val inv = 100 - t  # (1-t) scaled to 0-100
    val inv2 = inv * inv / 100  # (1-t)^2
    val inv3 = inv2 * inv / 100  # (1-t)^3
    100 - inv3

# Ease-in-out quad: smooth start and end
fn ease_in_out_quad(t: u64) -> u64:
    if t < 50:
        t * t * 2 / 100
    else:
        val inv = 100 - t
        100 - inv * inv * 2 / 100

# Spring easing: slight overshoot then settle (for dock bounce)
fn spring_ease(t: u64) -> u64:
    if t < 60:
        # Rise to 110%
        t * 110 / 60
    else:
        if t < 80:
            # Overshoot then pull back to 95%
            110 - (t - 60) * 15 / 20
        else:
            # Settle to 100%
            95 + (t - 80) * 5 / 20

# Ease-in cubic: slow start, fast finish (for window close)
fn ease_in_cubic(t: u64) -> u64:
    t * t * t / 10000

# Linear interpolation between two values based on progress 0-100
fn lerp(start: u64, end_: u64, progress: u64) -> u64:
    if end_ >= start:
        start + (end_ - start) * progress / 100
    else:
        start - (start - end_) * progress / 100

