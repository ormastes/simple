# x86_64 Browser Software Entry -- boot-safe software-render browser smoke test
#
# This lane intentionally avoids the browser-engine object graph and renders a
# browser-like page directly with rt_gui_* so the baremetal QEMU path stays
# boot-safe. The goal is to validate framebuffer init, drawing, and pixel
# readback from the last known working desktop/WM shape.

extern fn rt_port_outb(port: u64, value: u64)
extern fn rt_port_inb(port: u64) -> u64

extern fn rt_gui_set_fb(addr: u64, width: u64) -> u64
extern fn rt_gui_begin_frame(width: u64, height: u64, u1: u64, u2: u64) -> u64
extern fn rt_gui_present(u1: u64, u2: u64, u3: u64, u4: u64) -> u64
extern fn rt_gui_fill4(xy: u64, wh: u64, color: u64, unused: u64) -> u64
extern fn rt_gui_blend_fill(xy: u64, wh: u64, color: u64, alpha: u64) -> u64
extern fn rt_gui_read_pixel(x_y: u64, u1: u64, u2: u64, u3: u64) -> u64

fn pack(hi: i64, lo: i64) -> u64:
    val h = if hi < 0: 0 else: hi.to_u64()
    val l = if lo < 0: 0 else: lo.to_u64()
    (h << 32) | (l & 0xFFFFFFFF)

val SCREEN_W: i64 = 1024
val SCREEN_H: i64 = 768
val BG_COLOR: u64 = 0xFF111827
val CARD_COLOR: u64 = 0xFFE8ECF3
val TITLE_COLOR: u64 = 0xFF1D4ED8
val ACCENT_COLOR: u64 = 0xFF10B981
val TEXT_DARK: u64 = 0xFF1F2937
val CHROME_COLOR: u64 = 0xFFF3F4F6
val URL_COLOR: u64 = 0xFFFFFFFF

fn read_px(x: i64, y: i64) -> u64:
    rt_gui_read_pixel(pack(x, y), 0, 0, 0)

fn is_visible(c: u64) -> bool:
    val r = ((c >> 16) & 0xFF).to_i64()
    val g = ((c >> 8) & 0xFF).to_i64()
    val b = (c & 0xFF).to_i64()
    r > 40 or g > 40 or b > 40

fn sputc(c: u64):
    while (rt_port_inb(0x3FD) & 0x20) == 0:
        pass_dn
    rt_port_outb(0x3F8, c)

fn newline():
    sputc(13)
    sputc(10)

fn draw_page():
    rt_gui_begin_frame(1024, 768, 0, 0)

    # Base background and browser chrome.
    rt_gui_fill4(pack(0, 0), pack(SCREEN_W, SCREEN_H), BG_COLOR, 0)
    rt_gui_blend_fill(pack(32, 24), pack(960, 708), 0xFF000000, 38)
    rt_gui_fill4(pack(24, 20), pack(976, 716), CHROME_COLOR, 0)

    # Top chrome.
    rt_gui_fill4(pack(24, 20), pack(976, 56), 0xFFE5E7EB, 0)
    rt_gui_fill4(pack(52, 34), pack(42, 28), TITLE_COLOR, 0)
    rt_gui_fill4(pack(106, 34), pack(84, 28), 0xFFF59E0B, 0)
    rt_gui_fill4(pack(202, 34), pack(84, 28), ACCENT_COLOR, 0)
    rt_gui_fill4(pack(304, 34), pack(660, 28), URL_COLOR, 0)

    # Browser UI details.
    rt_gui_fill4(pack(318, 42), pack(28, 12), 0xFFCBD5E1, 0)
    rt_gui_fill4(pack(358, 42), pack(220, 12), 0xFF94A3B8, 0)
    rt_gui_fill4(pack(592, 42), pack(180, 12), 0xFFCBD5E1, 0)
    rt_gui_fill4(pack(786, 42), pack(140, 12), 0xFF94A3B8, 0)

    # Content area.
    rt_gui_fill4(pack(52, 92), pack(920, 136), CARD_COLOR, 0)
    rt_gui_fill4(pack(52, 248), pack(610, 384), CARD_COLOR, 0)
    rt_gui_fill4(pack(686, 248), pack(286, 384), CARD_COLOR, 0)

    # Header blocks.
    rt_gui_fill4(pack(76, 116), pack(240, 24), TITLE_COLOR, 0)
    rt_gui_fill4(pack(76, 152), pack(380, 14), 0xFF9CA3AF, 0)
    rt_gui_fill4(pack(76, 176), pack(328, 14), 0xFFCBD5E1, 0)
    rt_gui_fill4(pack(76, 200), pack(180, 14), ACCENT_COLOR, 0)

    # Three article cards.
    rt_gui_fill4(pack(76, 284), pack(164, 132), 0xFFFFFFFF, 0)
    rt_gui_fill4(pack(256, 284), pack(164, 132), 0xFFFFFFFF, 0)
    rt_gui_fill4(pack(436, 284), pack(164, 132), 0xFFFFFFFF, 0)
    rt_gui_fill4(pack(92, 300), pack(132, 42), 0xFFD1D5DB, 0)
    rt_gui_fill4(pack(272, 300), pack(132, 42), 0xFFD1D5DB, 0)
    rt_gui_fill4(pack(452, 300), pack(132, 42), 0xFFD1D5DB, 0)
    rt_gui_fill4(pack(92, 354), pack(102, 10), 0xFF9CA3AF, 0)
    rt_gui_fill4(pack(272, 354), pack(102, 10), 0xFF9CA3AF, 0)
    rt_gui_fill4(pack(452, 354), pack(102, 10), 0xFF9CA3AF, 0)

    # Sidebar layout.
    rt_gui_fill4(pack(710, 284), pack(228, 24), ACCENT_COLOR, 0)
    rt_gui_fill4(pack(710, 324), pack(208, 20), 0xFFCBD5E1, 0)
    rt_gui_fill4(pack(710, 356), pack(188, 20), 0xFFD1D5DB, 0)
    rt_gui_fill4(pack(710, 388), pack(220, 20), 0xFFC7D2FE, 0)
    rt_gui_fill4(pack(710, 428), pack(176, 96), 0xFFFFFFFF, 0)
    rt_gui_fill4(pack(728, 446), pack(140, 20), 0xFF94A3B8, 0)
    rt_gui_fill4(pack(728, 478), pack(102, 12), 0xFFD1D5DB, 0)

    # Footer and status strip.
    rt_gui_fill4(pack(52, 652), pack(920, 44), 0xFFE5E7EB, 0)
    rt_gui_fill4(pack(76, 664), pack(168, 14), 0xFF64748B, 0)
    rt_gui_fill4(pack(260, 664), pack(108, 14), 0xFF64748B, 0)
    rt_gui_fill4(pack(388, 664), pack(208, 14), TITLE_COLOR, 0)
    rt_gui_fill4(pack(820, 664), pack(116, 14), ACCENT_COLOR, 0)

    rt_gui_present(0, 0, 0, 0)

fn count_visible_samples() -> i64:
    var visible: i64 = 0
    if is_visible(read_px(64, 40)): visible = visible + 1
    if is_visible(read_px(340, 44)): visible = visible + 1
    if is_visible(read_px(84, 120)): visible = visible + 1
    if is_visible(read_px(92, 314)): visible = visible + 1
    if is_visible(read_px(726, 300)): visible = visible + 1
    if is_visible(read_px(836, 448)): visible = visible + 1
    if is_visible(read_px(884, 664)): visible = visible + 1
    visible

