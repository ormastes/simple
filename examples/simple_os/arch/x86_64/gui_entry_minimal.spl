# Minimal GUI Entry — cross-module extern fn test
#
# Uses extern fn declarations (not `use` imports) to avoid
# cross-module type resolution issues. Tests:
# 1. serial_println from C runtime
# 2. rt_port_outl / rt_port_inl for PCI config access
#
# This proves the Cranelift cross-compilation + bare-metal boot works
# end-to-end with extern fn calls.

extern fn serial_println(msg: text)
extern fn rt_port_outl(port: u64, value: u64)
extern fn rt_port_inl(port: u64) -> u64

fn spl_start():
    serial_println("[GUI-MIN] Starting PCI test")

    # Read PCI config for devices 0-3 directly
    rt_port_outl(0xCF8, 0x80000000)
    val r0 = rt_port_inl(0xCFC)
    if (r0 & 0xFFFF) != 0xFFFF:
        serial_println("[GUI-MIN] Dev 0 found")

    rt_port_outl(0xCF8, 0x80000800)
    val r1 = rt_port_inl(0xCFC)
    if (r1 & 0xFFFF) != 0xFFFF:
        serial_println("[GUI-MIN] Dev 1 found")

    rt_port_outl(0xCF8, 0x80001000)
    val r2 = rt_port_inl(0xCFC)
    if (r2 & 0xFFFF) != 0xFFFF:
        serial_println("[GUI-MIN] Dev 2 VGA found")

    rt_port_outl(0xCF8, 0x80001800)
    val r3 = rt_port_inl(0xCFC)
    if (r3 & 0xFFFF) != 0xFFFF:
        serial_println("[GUI-MIN] Dev 3 NIC found")

    # BGA init: program Bochs VGA for 1024x768x32
    extern fn rt_port_outw(port: u64, value: u64)
    rt_port_outw(0x01CE, 4)
    rt_port_outw(0x01CF, 0)
    rt_port_outw(0x01CE, 1)
    rt_port_outw(0x01CF, 1024)
    rt_port_outw(0x01CE, 2)
    rt_port_outw(0x01CF, 768)
    rt_port_outw(0x01CE, 3)
    rt_port_outw(0x01CF, 32)
    rt_port_outw(0x01CE, 4)
    rt_port_outw(0x01CF, 0x41)
    serial_println("[GUI-MIN] BGA framebuffer programmed 1024x768x32")

    # Enable PCI memory space for VGA (dev 2)
    rt_port_outl(0xCF8, 0x80001004)
    val cmd = rt_port_inl(0xCFC)
    rt_port_outl(0xCF8, 0x80001004)
    rt_port_outl(0xCFC, cmd | 0x06)

    # Read BAR0 for framebuffer address
    rt_port_outl(0xCF8, 0x80001010)
    val bar0 = rt_port_inl(0xCFC)
    val fb_addr = bar0 & 0xFFFFFFF0
    serial_println("[GUI-MIN] BAR0 framebuffer address read")

    # Set framebuffer and render desktop via C helper
    extern fn rt_gui_set_fb(addr: u64, width: u64)
    extern fn rt_gui_render_desktop(unused1: u64, unused2: u64)
    rt_gui_set_fb(fb_addr, 1024)
    rt_gui_render_desktop(0, 0)

    serial_println("[GUI-MIN] Desktop rendered successfully")
    serial_println("[GUI-MIN] Test complete")
