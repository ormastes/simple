# x86_64 Desktop E2E Baremetal Entry
#
# Minimal wrapper that boots the baremetal runtime, runs the desktop E2E
# test harness, and then exits QEMU through ISA debug-exit.

extern fn serial_println(msg: text)
extern fn rt_port_outb(port: u16, value: u8)

use os.services.launcher.launcher.{launcher_init, launcher_shortcut_dispatch, launcher_list, launcher_get_app_count, launcher_is_running, MOD_META}
use os.services.wm.wm_service.{wm_notify_app_launched}
use os.apps.browser_demo.browser_demo.{BrowserDemoApp}

fn desktop_e2e_main():
    serial_println("=== Desktop End-to-End Test ===")
    serial_println("")

    serial_println("[test] Step 1: Initialize launcher...")
    launcher_init()
    val app_count = launcher_get_app_count()
    if app_count < 4:
        serial_println("[test] FAIL: Expected >= 4 registered apps, got {app_count}")
        serial_println("TEST FAILED")
        return
    serial_println("[test] PASS: {app_count} apps registered")
    launcher_list()

    serial_println("")
    serial_println("[test] Step 2: Simulate Meta+B shortcut...")
    val launched = launcher_shortcut_dispatch(0x42, MOD_META)
    if not launched:
        serial_println("[test] FAIL: Shortcut dispatch returned false")
        serial_println("TEST FAILED")
        return
    serial_println("[test] PASS: Shortcut dispatched successfully")

    serial_println("")
    serial_println("[test] Step 3: Verify Browser Demo is running...")
    val running = launcher_is_running(3)
    if not running:
        serial_println("[test] WARN: App not marked as running (spawn may be async)")
    else:
        serial_println("[test] PASS: Browser Demo is running")

    serial_println("")
    serial_println("[test] Step 4: Notify WM of app launch...")
    wm_notify_app_launched("Browser Demo", 4)
    serial_println("[test] PASS: Window created for Browser Demo")

    serial_println("")
    serial_println("[test] Step 5: Run Browser Demo render...")
    var app = BrowserDemoApp.new()
    app.run_browser_render()
    if not app.render_done:
        serial_println("[test] FAIL: Browser Demo render did not complete")
        serial_println("TEST FAILED")
        return
    if app.node_count <= 0:
        serial_println("[test] FAIL: Browser Demo node_count={app.node_count}")
        serial_println("TEST FAILED")
        return
    if app.pixel_count <= 0:
        serial_println("[test] FAIL: Browser Demo pixel_count={app.pixel_count}")
        serial_println("TEST FAILED")
        return
    serial_println("[test] PASS: Browser Demo render executed")
    serial_println("[test] PASS: Browser Demo stats nodes={app.node_count} pixels={app.pixel_count}")

    serial_println("")
    serial_println("=== All desktop tests passed ===")
    serial_println("TEST PASSED")

fn spl_start():
    serial_println("")
    serial_println("=== SimpleOS Desktop E2E ===")
    serial_println("[desktop-e2e] Starting desktop_e2e_test.desktop_e2e_main()")

    desktop_e2e_main()

    serial_println("[desktop-e2e] desktop_e2e_main() returned")
    rt_port_outb(0xf4, 0)
