# x86_64 Desktop E2E Baremetal Entry
#
# Lean wrapper that boots the baremetal runtime, exercises launcher/WM
# integration, and exits QEMU through ISA debug-exit.

extern fn rt_port_inb(port: u64) -> u64
extern fn rt_port_outb(port: u64, value: u64)

use os.services.launcher.launcher.{launcher_init, launcher_shortcut_dispatch, launcher_get_app_count, MOD_META}
use os.services.wm.wm_service.{wm_notify_app_launched}

val SERIAL_DATA: u64 = 0x3F8
val SERIAL_LSR: u64 = 0x3FD
val DEBUG_EXIT: u64 = 0xF4

fn serial_wait_ready():
    var guard: i64 = 100000
    while guard > 0:
        if (rt_port_inb(SERIAL_LSR) & 0x20) != 0:
            return
        guard = guard - 1

fn serial_put(ch: u64):
    serial_wait_ready()
    rt_port_outb(SERIAL_DATA, ch)

fn serial_newline():
    serial_put(13)
    serial_put(10)

fn write_desktop_spl_start():
    serial_put(91)
    serial_put(100)
    serial_put(101)
    serial_put(115)
    serial_put(107)
    serial_put(116)
    serial_put(111)
    serial_put(112)
    serial_put(45)
    serial_put(101)
    serial_put(50)
    serial_put(101)
    serial_put(93)
    serial_put(32)
    serial_put(115)
    serial_put(112)
    serial_put(108)
    serial_put(95)
    serial_put(115)
    serial_put(116)
    serial_put(97)
    serial_put(114)
    serial_put(116)
    serial_newline()

