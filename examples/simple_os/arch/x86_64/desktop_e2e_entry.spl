fn write_desktop_test_passed():
    serial_put(84)
    serial_put(69)
    serial_put(83)
    serial_put(84)
    serial_put(32)
    serial_put(80)
    serial_put(65)
    serial_put(83)
    serial_put(83)
    serial_put(69)
    serial_put(68)
    serial_newline()

fn write_desktop_test_failed():
    serial_put(84)
    serial_put(69)
    serial_put(83)
    serial_put(84)
    serial_put(32)
    serial_put(70)
    serial_put(65)
    serial_put(73)
    serial_put(76)
    serial_put(69)
    serial_put(68)
    serial_newline()

fn desktop_e2e_main():
    write_desktop_main_start()
    launcher_init()
    write_desktop_launcher_init()
    val app_count = launcher_get_app_count()
    if app_count < 4:
        write_desktop_test_failed()
        return
    write_desktop_launcher_ready()

    val launched = launcher_shortcut_dispatch(0x42, MOD_META)
    if not launched:
        write_desktop_test_failed()
        return
    write_desktop_shortcut_ok()

    wm_notify_app_launched("Browser Demo", 4)
    write_desktop_wm_ok()
    write_desktop_test_passed()

fn spl_start():
    write_desktop_spl_start()
    desktop_e2e_main()
    write_desktop_done()
    rt_port_outb(DEBUG_EXIT, 0)
