# x86_64 Desktop E2E Boot Wrapper
#
# Temporary bootable wrapper for the desktop E2E test source.

use os.kernel.arch.x86_64.console.{serial_init, serial_println}
use os.test.desktop_e2e_test.{test_main}

extern fn rt_port_outb(port: u16, value: u8)

fn _start():
    serial_init()
    serial_println("")
    serial_println("=== SimpleOS Desktop E2E Boot Wrapper ===")
    serial_println("[desktop-e2e] Running actual src/os/test/desktop_e2e_test.spl...")
    test_main()
    serial_println("[desktop-e2e] Wrapper done")
    rt_port_outb(0xf4, 0)
