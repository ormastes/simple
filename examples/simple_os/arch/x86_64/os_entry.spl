# x86_64 OS Entry — Full-stack SimpleOS boot (bare-metal Multiboot path)

extern fn serial_println(msg: text)

# Direct POSIX init (bypass mod.spl to avoid weak-stub cascade from
# socket_compat/select_compat inline asm dependency)
use os.posix.fd_table.{fd_table_init}
use os.posix.async_io.{async_io_init}
use os.posix.signal_compat.{signal_init}

# Services
use os.kernel.boot.init_services.{init_all_services}
use os.kernel.arch.x86_64.interrupt.{X86Interrupt}

# Shell
use os.apps.shell.shell_app.{ShellApp}

fn _start():
    serial_println("")
    serial_println("=== SimpleOS Boot ===")
    serial_println("")

    # POSIX layer init
    fd_table_init()
    async_io_init()
    signal_init()
    serial_println("[boot] POSIX layer initialized")

    # Install the minimal runtime bundle that future trap/syscall dispatch
    # will own on x86_64 baremetal.
    if not X86Interrupt.runtime_installed():
        X86Interrupt.install_bootstrap_runtime(64)
        serial_println("[boot] x86 runtime bundle installed")

    # Services
    init_all_services()

    # Shell
    var shell = ShellApp.new()
    serial_println("[boot] Shell ready")

    serial_println("")
    serial_println("=== SimpleOS ready ===")
    serial_println("TEST PASSED")
