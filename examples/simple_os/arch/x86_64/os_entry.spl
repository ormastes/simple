# x86_64 OS Entry — Full-stack SimpleOS boot
#
# Called by crt0.s after Multiboot → 64-bit mode switch.
# The build system automatically compiles boot/crt0.s and boot/baremetal_stubs.c
# because they're in a boot/ directory adjacent to this entry file.

use os.kernel.boot.os_main.{os_main}

fn _start():
    """Entry point called from crt0.s after hardware init."""
    os_main()
