#!/bin/sh
# Run simple_os on QEMU ARM (32-bit)
KERNEL="${1:-build/simple_os_arm.elf}"
TIMEOUT="${2:-10}"

qemu-system-arm \
    -machine virt \
    -cpu cortex-a15 \
    -kernel "$KERNEL" \
    -nographic \
    -serial stdio \
    -m 128M \
    2>&1 | timeout "$TIMEOUT" grep -m1 "BOOT OK\|IPC_TEST_PASS\|PANIC"
