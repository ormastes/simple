#!/bin/bash
# Run QEMU boot tests for all architectures
# Usage: ./run_all.shs [ref|spl]
VARIANT=${1:-ref}
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PASS=0
FAIL=0

for arch in x86 x86_64 arm32 aarch64 riscv32 riscv64; do
    echo "--- $arch ---"
    if "$SCRIPT_DIR/run_${arch}.shs" "$VARIANT"; then
        PASS=$((PASS + 1))
    else
        FAIL=$((FAIL + 1))
    fi
    echo ""
done

echo "=== Summary: $PASS passed, $FAIL failed ==="
[ $FAIL -eq 0 ]
