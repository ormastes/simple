#!/bin/bash
# QEMU boot test for ARM32 kernel
# Usage: ./run_arm32.shs [ref|spl]
set -e
VARIANT=${1:-ref}
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_DIR="$(cd "$SCRIPT_DIR/../.." && pwd)"

if [ "$VARIANT" = "ref" ]; then
    KERNEL="$PROJECT_DIR/ref/build/arm32/kernel.elf"
else
    KERNEL="$PROJECT_DIR/spl/build/simple_os_arm.elf"
fi

if [ ! -f "$KERNEL" ]; then
    echo "ERROR: Kernel not found: $KERNEL"
    exit 1
fi

echo "=== QEMU ARM32 Boot Test ($VARIANT) ==="
echo "Kernel: $KERNEL"

OUTPUT=$(timeout 5 qemu-system-arm \
    -M virt \
    -cpu cortex-a15 \
    -kernel "$KERNEL" \
    -serial stdio \
    -display none \
    -no-reboot \
    2>/dev/null || true)

echo "$OUTPUT"

if echo "$OUTPUT" | grep -q "\[BOOT OK\]"; then
    echo "RESULT: PASS"
    exit 0
else
    echo "RESULT: FAIL (no [BOOT OK] found)"
    exit 1
fi
