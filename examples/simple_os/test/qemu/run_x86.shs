#!/bin/sh
# Run simple_os on QEMU x86 (32-bit)
KERNEL="${1:-build/simple_os.elf}"
TIMEOUT="${2:-10}"

qemu-system-i386 \
    -kernel "$KERNEL" \
    -nographic \
    -serial stdio \
    -device isa-debug-exit,iobase=0xf4,iosize=0x04 \
    -no-reboot \
    -m 128M \
    2>&1 | timeout "$TIMEOUT" grep -m1 "BOOT OK\|IPC_TEST_PASS\|PANIC"
