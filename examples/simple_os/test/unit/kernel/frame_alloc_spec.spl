# Frame Allocator Unit Tests
use kernel.mm.frame_alloc.{BitmapFrameAllocator}
use kernel.lib.bitmap.{Bitmap}

describe "Bitmap Frame Allocator":
    it "allocates first available frame":
        var alloc = BitmapFrameAllocator(base: 0x100000, num_frames: 1024)
        val frame = alloc.alloc()
        expect(frame.?).to_equal(0x100000)

    it "allocates consecutive frames":
        var alloc = BitmapFrameAllocator(base: 0x100000, num_frames: 1024)
        val f1 = alloc.alloc()
        val f2 = alloc.alloc()
        expect(f1.?).to_equal(0x100000)
        expect(f2.?).to_equal(0x101000)

    it "frees and reuses frames":
        var alloc = BitmapFrameAllocator(base: 0x100000, num_frames: 1024)
        val frame = alloc.alloc()
        alloc.free(frame.?)
        val reused = alloc.alloc()
        expect(reused.?).to_equal(0x100000)

    it "returns nil when exhausted":
        var alloc = BitmapFrameAllocator(base: 0x100000, num_frames: 2)
        alloc.alloc()
        alloc.alloc()
        expect(alloc.alloc()).to_be_nil()
