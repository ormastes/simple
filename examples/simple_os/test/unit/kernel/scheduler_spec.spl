# Scheduler Unit Tests
use kernel.core.scheduler.{Scheduler, Priority}
use kernel.core.tcb.{Tcb, ThreadState}

describe "Scheduler":
    it "creates scheduler with priority levels":
        var sched = Scheduler(num_priorities: 256)
        expect(sched.num_priorities()).to_equal(256)

    it "returns nil when no runnable threads":
        var sched = Scheduler(num_priorities: 256)
        expect(sched.pick_next()).to_be_nil()

    it "picks highest priority thread":
        var sched = Scheduler(num_priorities: 256)
        var low = Tcb(id: 1, priority: 10)
        var high = Tcb(id: 2, priority: 200)
        sched.enqueue(low)
        sched.enqueue(high)
        val next = sched.pick_next()
        expect(next.?.id).to_equal(2)
