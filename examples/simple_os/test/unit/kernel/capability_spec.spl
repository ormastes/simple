# Capability System Unit Tests
use kernel.core.capability.{CapTable, CapSlot, CapRights}
use kernel.core.capability_types.{CapType}

describe "Capability Table":
    it "creates empty capability table":
        var table = CapTable(size: 256)
        expect(table.count()).to_equal(0)

    it "inserts and retrieves capability":
        var table = CapTable(size: 256)
        val rights = CapRights(read: true, write: true, grant: false, revoke: false)
        val slot = table.insert(CapType.Endpoint, 0x1000, rights)
        expect(slot.?.type_tag).to_equal(CapType.Endpoint)

    it "mints capability with reduced rights":
        var table = CapTable(size: 256)
        val full_rights = CapRights(read: true, write: true, grant: true, revoke: true)
        val slot_idx = table.insert(CapType.Endpoint, 0x1000, full_rights)
        val reduced = CapRights(read: true, write: false, grant: false, revoke: false)
        val minted = table.mint(slot_idx.?, reduced)
        expect(minted.?.rights.write).to_equal(false)

    it "revokes capability":
        var table = CapTable(size: 256)
        val rights = CapRights(read: true, write: true, grant: false, revoke: false)
        val idx = table.insert(CapType.Endpoint, 0x1000, rights)
        table.revoke(idx.?)
        expect(table.lookup(idx.?).?).to_be_nil()
