# IPC Unit Tests
use kernel.core.ipc.{IpcMessage, IpcBuffer}
use kernel.core.endpoint.{Endpoint}

describe "IPC Buffer":
    it "writes and reads message registers":
        var buf = IpcBuffer()
        buf.set_mr(0, 0xDEADBEEF)
        buf.set_mr(1, 0xCAFEBABE)
        expect(buf.get_mr(0)).to_equal(0xDEADBEEF)
        expect(buf.get_mr(1)).to_equal(0xCAFEBABE)

    it "respects message register count":
        var buf = IpcBuffer()
        buf.set_length(2)
        buf.set_mr(0, 100)
        buf.set_mr(1, 200)
        expect(buf.length()).to_equal(2)

describe "Endpoint":
    it "creates endpoint in idle state":
        var ep = Endpoint()
        expect(ep.is_idle()).to_equal(true)
        expect(ep.sender_queue_empty()).to_equal(true)
