import std.spec

describe "Untyped":
    context "when newly created":
        it "has full space remaining":
            var ut = untyped_create(0x100000, 4096)
            expect(untyped_remaining(ut)).to_equal(4096)

    context "when retyping":
        it "allocates aligned memory":
            var ut = untyped_create(0x100000, 4096)
            val addr = untyped_retype(ut, 256, 256)
            expect(addr.?).to_equal(true)

        it "reduces remaining space":
            var ut = untyped_create(0x100000, 4096)
            untyped_retype(ut, 256, 256)
            expect(untyped_remaining(ut)).to_be_less_than(4096)

        it "returns None when exhausted":
            var ut = untyped_create(0x100000, 256)
            untyped_retype(ut, 256, 256)
            val addr = untyped_retype(ut, 256, 256)
            expect(addr.?).to_equal(false)

    context "when revoking":
        it "resets watermark to start":
            var ut = untyped_create(0x100000, 4096)
            untyped_retype(ut, 256, 256)
            untyped_revoke(ut)
            expect(untyped_remaining(ut)).to_equal(4096)
