import std.spec

describe "LinkedList":
    context "when newly created":
        it "is empty":
            var list = linked_list_create(32)
            expect(linked_list_is_empty(list)).to_equal(true)
            expect(linked_list_count(list)).to_equal(0)

    context "when pushing back":
        it "adds elements to the tail":
            var list = linked_list_create(32)
            linked_list_push_back(list, 5)
            linked_list_push_back(list, 10)
            expect(linked_list_count(list)).to_equal(2)

    context "when pushing front":
        it "adds elements to the head":
            var list = linked_list_create(32)
            linked_list_push_back(list, 5)
            linked_list_push_front(list, 3)
            val front = linked_list_peek_front(list)
            expect(front.?).to_equal(true)

    context "when popping front":
        it "returns head element":
            var list = linked_list_create(32)
            linked_list_push_back(list, 7)
            linked_list_push_back(list, 8)
            val popped = linked_list_pop_front(list)
            expect(popped.?).to_equal(true)
            expect(linked_list_count(list)).to_equal(1)

        it "returns None when empty":
            var list = linked_list_create(32)
            val popped = linked_list_pop_front(list)
            expect(popped.?).to_equal(false)

    context "when removing by index":
        it "removes from middle":
            var list = linked_list_create(32)
            linked_list_push_back(list, 1)
            linked_list_push_back(list, 2)
            linked_list_push_back(list, 3)
            linked_list_remove(list, 2)
            expect(linked_list_count(list)).to_equal(2)
            expect(linked_list_contains(list, 2)).to_equal(false)

    context "when checking contains":
        it "returns true for active nodes":
            var list = linked_list_create(32)
            linked_list_push_back(list, 5)
            expect(linked_list_contains(list, 5)).to_equal(true)
            expect(linked_list_contains(list, 6)).to_equal(false)

    context "when preventing duplicates":
        it "ignores push of already active node":
            var list = linked_list_create(32)
            linked_list_push_back(list, 5)
            linked_list_push_back(list, 5)
            expect(linked_list_count(list)).to_equal(1)
