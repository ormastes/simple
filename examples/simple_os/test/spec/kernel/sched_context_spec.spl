import std.spec

describe "SchedContext":
    context "when newly created":
        it "has configured budget":
            var sc = sched_context_create(1000, 10000)
            expect(sched_context_remaining(sc)).to_equal(1000)

    context "when charging":
        it "decreases remaining budget":
            var sc = sched_context_create(1000, 10000)
            sched_context_charge(sc, 100)
            expect(sched_context_remaining(sc)).to_equal(900)

        it "reports inactive when budget exhausted":
            var sc = sched_context_create(100, 10000)
            sched_context_charge(sc, 100)
            expect(sched_context_is_active(sc)).to_equal(false)

    context "when refilling":
        it "restores budget to full":
            var sc = sched_context_create(1000, 10000)
            sched_context_charge(sc, 500)
            sched_context_refill(sc)
            expect(sched_context_remaining(sc)).to_equal(1000)
