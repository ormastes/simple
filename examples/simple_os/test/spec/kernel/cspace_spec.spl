import std.spec

describe "CSpace":
    context "when newly created":
        it "has empty root":
            var cs = cspace_create(64)
            val slot = cspace_lookup(cs, 0)
            expect(slot.?).to_equal(false)

    context "when inserting":
        it "stores and retrieves capabilities":
            var cs = cspace_create(64)
            var rights = cap_rights_all()
            val idx = cspace_insert(cs, CapType.Endpoint, 0x1000, rights)
            expect(idx.?).to_equal(true)
