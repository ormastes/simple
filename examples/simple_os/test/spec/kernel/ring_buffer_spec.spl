import std.spec

describe "RingBuffer":
    context "when newly created":
        it "is empty":
            var rb = ring_buffer_create(16)
            expect(ring_buffer_is_empty(rb)).to_equal(true)
            expect(ring_buffer_is_full(rb)).to_equal(false)
            expect(ring_buffer_count(rb)).to_equal(0)

    context "when pushing elements":
        it "stores and retrieves values":
            var rb = ring_buffer_create(16)
            val ok = ring_buffer_push(rb, 42)
            expect(ok).to_equal(true)
            expect(ring_buffer_count(rb)).to_equal(1)

        it "rejects push when full":
            var rb = ring_buffer_create(4)
            ring_buffer_push(rb, 1)
            ring_buffer_push(rb, 2)
            ring_buffer_push(rb, 3)
            val ok = ring_buffer_push(rb, 4)
            expect(ok).to_equal(false)

    context "when popping elements":
        it "returns values in FIFO order":
            var rb = ring_buffer_create(16)
            ring_buffer_push(rb, 10)
            ring_buffer_push(rb, 20)
            val v1 = ring_buffer_pop(rb)
            val v2 = ring_buffer_pop(rb)
            expect(v1.?).to_equal(true)
            expect(v2.?).to_equal(true)

        it "returns None when empty":
            var rb = ring_buffer_create(16)
            val v = ring_buffer_pop(rb)
            expect(v.?).to_equal(false)

    context "when wrapping around":
        it "handles wrap correctly":
            var rb = ring_buffer_create(4)
            ring_buffer_push(rb, 1)
            ring_buffer_push(rb, 2)
            ring_buffer_push(rb, 3)
            ring_buffer_pop(rb)
            ring_buffer_pop(rb)
            ring_buffer_push(rb, 4)
            ring_buffer_push(rb, 5)
            expect(ring_buffer_count(rb)).to_equal(3)

    context "when peeking":
        it "shows head without removing":
            var rb = ring_buffer_create(16)
            ring_buffer_push(rb, 99)
            val peeked = ring_buffer_peek(rb)
            expect(peeked.?).to_equal(true)
            expect(ring_buffer_count(rb)).to_equal(1)

    context "when clearing":
        it "resets to empty":
            var rb = ring_buffer_create(16)
            ring_buffer_push(rb, 1)
            ring_buffer_push(rb, 2)
            ring_buffer_clear(rb)
            expect(ring_buffer_is_empty(rb)).to_equal(true)
