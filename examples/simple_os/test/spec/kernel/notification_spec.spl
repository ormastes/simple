import std.spec

describe "Notification":
    context "when newly created":
        it "has zero notification word":
            var ntfn = notification_create()
            val word = notification_poll(ntfn)
            expect(word).to_equal(0)

    context "when signaled":
        it "ORs bits into notification word":
            var ntfn = notification_create()
            notification_signal(ntfn, 0x01)
            notification_signal(ntfn, 0x04)
            val word = notification_poll(ntfn)
            expect(word).to_equal(5)

    context "when polled":
        it "clears the word after reading":
            var ntfn = notification_create()
            notification_signal(ntfn, 0xFF)
            notification_poll(ntfn)
            val word = notification_poll(ntfn)
            expect(word).to_equal(0)
