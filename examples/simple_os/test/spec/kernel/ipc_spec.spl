import std.spec

describe "IpcBuffer":
    context "when newly created":
        it "has zero length":
            var buf = ipc_buffer_create()
            expect(ipc_buffer_get_length(buf)).to_equal(0)

    context "when writing message registers":
        it "stores and retrieves values":
            var buf = ipc_buffer_create()
            ipc_buffer_set_mr(buf, 0, 0xDEAD)
            ipc_buffer_set_mr(buf, 1, 0xBEEF)
            expect(ipc_buffer_get_mr(buf, 0)).to_equal(0xDEAD)
            expect(ipc_buffer_get_mr(buf, 1)).to_equal(0xBEEF)

    context "when setting tag":
        it "stores label and length":
            var buf = ipc_buffer_create()
            ipc_buffer_set_tag(buf, 42, 3)
            expect(ipc_buffer_get_label(buf)).to_equal(42)
            expect(ipc_buffer_get_length(buf)).to_equal(3)
