import std.spec

describe "TCB":
    context "when newly created":
        it "is in Inactive state":
            var tcb = tcb_create(0)
            expect(tcb_get_state(tcb)).to_equal(ThreadState.Inactive)

    context "when configured":
        it "sets priority and time slice":
            var tcb = tcb_create(0)
            tcb_set_priority(tcb, 128)
            expect(tcb_get_priority(tcb)).to_equal(128)

    context "when suspended":
        it "transitions to Suspended state":
            var tcb = tcb_create(0)
            tcb_resume(tcb)
            tcb_suspend(tcb)
            expect(tcb_get_state(tcb)).to_equal(ThreadState.Suspended)
