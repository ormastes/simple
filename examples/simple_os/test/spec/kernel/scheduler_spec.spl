import std.spec

describe "Scheduler":
    context "when initialized":
        it "has no ready threads":
            var sched = scheduler_create()
            val next = scheduler_pick_next(sched)
            expect(next.?).to_equal(false)

    context "when enqueueing threads":
        it "returns thread on pick_next":
            var sched = scheduler_create()
            scheduler_enqueue(sched, 1, 128)
            val next = scheduler_pick_next(sched)
            expect(next.?).to_equal(true)

        it "picks highest priority first":
            var sched = scheduler_create()
            scheduler_enqueue(sched, 1, 100)
            scheduler_enqueue(sched, 2, 200)
            val next = scheduler_pick_next(sched)
            expect(next.?).to_equal(true)

    context "when dequeueing threads":
        it "removes from ready queue":
            var sched = scheduler_create()
            scheduler_enqueue(sched, 5, 128)
            scheduler_dequeue(sched, 5, 128)
            val next = scheduler_pick_next(sched)
            expect(next.?).to_equal(false)

    context "when handling tick":
        it "decrements time slice":
            var sched = scheduler_create()
            scheduler_enqueue(sched, 1, 128)
            scheduler_pick_next(sched)
            val preempt = scheduler_tick(sched)
            expect(preempt).to_equal(false)
