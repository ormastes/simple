import std.spec

describe "Endpoint":
    context "when newly created":
        it "is in idle state":
            var ep = endpoint_create()
            expect(endpoint_is_idle(ep)).to_equal(true)

    context "when sender blocks":
        it "transitions to SendWait state":
            var ep = endpoint_create()
            endpoint_enqueue_sender(ep, 1)
            expect(endpoint_is_idle(ep)).to_equal(false)

    context "when receiver blocks":
        it "transitions to RecvWait state":
            var ep = endpoint_create()
            endpoint_enqueue_receiver(ep, 1)
            expect(endpoint_is_idle(ep)).to_equal(false)
