import std.spec

describe "Bitmap":
    context "when newly created":
        it "has all bits clear":
            var bm = bitmap_create(64)
            expect(bitmap_test(bm, 0)).to_equal(false)
            expect(bitmap_test(bm, 63)).to_equal(false)
            expect(bitmap_count_set(bm)).to_equal(0)
            expect(bitmap_count_clear(bm)).to_equal(64)

        it "reports correct capacity":
            var bm = bitmap_create(128)
            expect(bitmap_count_clear(bm)).to_equal(128)

    context "when setting bits":
        it "sets and tests individual bits":
            var bm = bitmap_create(64)
            bitmap_set(bm, 5)
            expect(bitmap_test(bm, 5)).to_equal(true)
            expect(bitmap_test(bm, 4)).to_equal(false)
            expect(bitmap_count_set(bm)).to_equal(1)

        it "sets multiple bits":
            var bm = bitmap_create(64)
            bitmap_set(bm, 0)
            bitmap_set(bm, 31)
            bitmap_set(bm, 32)
            expect(bitmap_count_set(bm)).to_equal(3)

        it "ignores out-of-range bits":
            var bm = bitmap_create(64)
            bitmap_set(bm, 100)
            expect(bitmap_count_set(bm)).to_equal(0)

    context "when clearing bits":
        it "clears a previously set bit":
            var bm = bitmap_create(64)
            bitmap_set(bm, 10)
            bitmap_clear(bm, 10)
            expect(bitmap_test(bm, 10)).to_equal(false)
            expect(bitmap_count_set(bm)).to_equal(0)

    context "when finding first clear":
        it "returns 0 for empty bitmap":
            var bm = bitmap_create(64)
            val first = bitmap_find_first_clear(bm)
            expect(first.?).to_equal(true)

        it "skips set bits":
            var bm = bitmap_create(64)
            bitmap_set(bm, 0)
            bitmap_set(bm, 1)
            val first = bitmap_find_first_clear(bm)
            expect(first.?).to_equal(true)

    context "when finding first set":
        it "returns None for empty bitmap":
            var bm = bitmap_create(64)
            val first = bitmap_find_first_set(bm)
            expect(first.?).to_equal(false)

        it "finds the first set bit":
            var bm = bitmap_create(64)
            bitmap_set(bm, 42)
            val first = bitmap_find_first_set(bm)
            expect(first.?).to_equal(true)

    context "when using ranges":
        it "sets a contiguous range":
            var bm = bitmap_create(64)
            bitmap_set_range(bm, 4, 8)
            expect(bitmap_count_set(bm)).to_equal(8)
            expect(bitmap_test(bm, 3)).to_equal(false)
            expect(bitmap_test(bm, 4)).to_equal(true)
            expect(bitmap_test(bm, 11)).to_equal(true)
            expect(bitmap_test(bm, 12)).to_equal(false)

    context "when finding contiguous clear bits":
        it "finds space at the start":
            var bm = bitmap_create(64)
            val start = bitmap_find_contiguous_clear(bm, 4)
            expect(start.?).to_equal(true)

        it "finds space after used bits":
            var bm = bitmap_create(64)
            bitmap_set_range(bm, 0, 8)
            val start = bitmap_find_contiguous_clear(bm, 4)
            expect(start.?).to_equal(true)

        it "returns None when no space":
            var bm = bitmap_create(32)
            bitmap_set_range(bm, 0, 32)
            val start = bitmap_find_contiguous_clear(bm, 1)
            expect(start.?).to_equal(false)

    context "when clamping capacity":
        it "caps at maximum":
            var bm = bitmap_create(99999)
            expect(bitmap_count_clear(bm)).to_equal(32768)
