# Tree Widget — File Browser Demo
#
# Non-interactive demo that builds a file-browser tree with expand/collapse
# states. Renders to an 80x24 screen buffer and verifies the output
# contains the expected strings.
# Prints PASS/FAIL for each check and returns 0 on success, 1 on failure.

use common.ui.builder.{column, tree_widget, tree_node, tree_leaf, build_tree_with_title}
use common.ui.widget.{UIState}
use common.ui.layout.{compute_layout}
use common.ui.state.{init_state}
use app.ui.tui.screen.{Screen}
use app.ui.render.widgets.{render_tui_tree}

fn build_demo_tree() -> UIState:
    """Build a file browser tree with nested folders and files."""
    # Documents folder (expanded)
    val projects_simple = tree_leaf("f_simple", "simple.spl")
    val projects_readme = tree_leaf("f_readme", "readme.md")
    val projects = tree_node("d_projects", "Projects", [projects_simple, projects_readme])

    # Archive folder (collapsed)
    val archive_old = tree_leaf("f_old", "old_data.zip")
    var archive = tree_node("d_archive", "Archive", [archive_old])
    archive = archive.set_prop("expanded", "false")

    val documents = tree_node("d_documents", "Documents", [projects, archive])

    # Pictures folder (expanded)
    val photo = tree_leaf("f_photo", "photo.jpg")
    val pictures = tree_node("d_pictures", "Pictures", [photo])

    # Downloads folder (collapsed)
    val installer = tree_leaf("f_installer", "setup.exe")
    var downloads = tree_node("d_downloads", "Downloads", [installer])
    downloads = downloads.set_prop("expanded", "false")

    val file_tree = tree_widget("file_browser", [documents, pictures, downloads])
    val root = column("root", [file_tree])
    val tree = build_tree_with_title(root, "File Browser Tree Demo", "dark")
    return init_state(tree)

fn check(label: text, condition: bool, failures: i32) -> i32:
    if condition:
        print "PASS: {label}"
        return failures
    else:
        print "FAIL: {label}"
        return failures + 1

fn main() -> i64:
    var failures = 0

    # --- Build the widget tree ---
    val state = build_demo_tree()
    val ids = state.tree.all_widget_ids()
    failures = check("tree built with {ids.len()} widgets (expect >= 5)", ids.len() >= 5, failures)

    # --- Compute layout for 80x24 ---
    val width = 80
    val height = 24
    val rects = compute_layout(state.tree.root_node(), 0, 0, width, height - 1)
    failures = check("layout computed with {rects.len()} rects", rects.len() > 0, failures)

    # --- Render to screen buffer ---
    var screen = Screen.new(width, height - 1)
    screen = render_tui_tree(screen, state.tree.root_node(), rects, state)

    # Collect raw buffer text for content checks
    var buf_text = ""
    var row = 0
    while row < height - 1:
        buf_text = "{buf_text}{screen.buffer[row]}\n"
        row = row + 1

    # Print the rendered buffer for visual inspection
    print "--- Rendered buffer ({width}x{height - 1}) ---"
    print buf_text
    print "--- End buffer ---"

    # --- Verify expanded folders show "v" marker ---
    failures = check("buffer contains 'v Documents'", buf_text.contains("v Documents"), failures)
    failures = check("buffer contains 'v Projects'", buf_text.contains("v Projects"), failures)
    failures = check("buffer contains 'v Pictures'", buf_text.contains("v Pictures"), failures)

    # --- Verify collapsed folders show ">" marker ---
    failures = check("buffer contains '> Archive'", buf_text.contains("> Archive"), failures)
    failures = check("buffer contains '> Downloads'", buf_text.contains("> Downloads"), failures)

    # --- Verify leaf files are shown (indented, under expanded parents) ---
    failures = check("buffer contains 'simple.spl'", buf_text.contains("simple.spl"), failures)
    failures = check("buffer contains 'readme.md'", buf_text.contains("readme.md"), failures)
    failures = check("buffer contains 'photo.jpg'", buf_text.contains("photo.jpg"), failures)

    # --- Verify collapsed children are NOT shown ---
    failures = check("buffer does not contain 'old_data.zip'", not buf_text.contains("old_data.zip"), failures)
    failures = check("buffer does not contain 'setup.exe'", not buf_text.contains("setup.exe"), failures)

    # --- Summary ---
    if failures == 0:
        print "All checks passed."
        return 0
    else:
        print "{failures} check(s) failed."
        return 1
