# Smoke Test — Non-interactive TUI Builder Verification
#
# Builds a widget tree, computes layout, renders to an 80x24 screen buffer,
# and verifies the output is non-empty. Prints PASS/FAIL and exits.

use common.ui.builder.{column, panel, text_widget, progress, statusbar, build_tree_with_title}
use common.ui.widget.{UIState}
use common.ui.layout.{compute_layout}
use common.ui.state.{init_state}
use app.ui.tui.screen.{Screen}
use app.ui.render.widgets.{render_tui_tree}

fn build_test_tree() -> UIState:
    """Build a widget tree identical to hello_gui for testing."""
    val greeting = text_widget("greeting", "Hello from Simple! This is a working GUI.")
    val help = text_widget("help", "Press q to quit, j/k to navigate, : for commands.")
    val bar = progress("build_progress", 75)
    val header = panel("header", "Simple GUI Demo", [greeting, help, bar])
    val status = statusbar("status", "NORMAL MODE", "Hello Simple GUI")
    val root = column("root", [header, status])
    val tree = build_tree_with_title(root, "Hello Simple GUI", "dark")
    return init_state(tree)

fn main() -> i64:
    var failures = 0

    # Build the widget tree
    val state = build_test_tree()

    # Verify the tree was built
    val ids = state.tree.all_widget_ids()
    if ids.len() > 0:
        print "PASS: tree built with {ids.len()} widgets"
    else:
        print "FAIL: tree has no widgets"
        failures = failures + 1

    # Compute layout for 80x24 screen
    val width = 80
    val height = 24
    val rects = compute_layout(state.tree.root, 0, 0, width, height - 1)

    if rects.len() > 0:
        print "PASS: layout computed with {rects.len()} rects"
    else:
        print "FAIL: layout produced no rects"
        failures = failures + 1

    # Render to screen buffer
    var screen = Screen.new(width, height - 1)
    screen = render_tui_tree(screen, state.tree.root, rects, state)
    val output = screen.render()

    if output.len() > 0:
        print "PASS: TUI builder render ({output.len()} chars)"
    else:
        print "FAIL: render produced empty output"
        failures = failures + 1

    # Verify the output contains expected content
    if output.contains("Simple GUI Demo"):
        print "PASS: output contains panel title"
    else:
        print "FAIL: output missing panel title"
        failures = failures + 1

    if output.contains("Hello from Simple"):
        print "PASS: output contains greeting text"
    else:
        print "FAIL: output missing greeting text"
        failures = failures + 1

    # Summary
    if failures == 0:
        print "All tests passed."
        return 0
    else:
        print "{failures} test(s) failed."
        return 1
