# Minimal Simple-backed Canvas2D line drawing app for the Electron host.
#
# Launch:
#   ./tools/electron-shell/node_modules/.bin/electron --no-sandbox tools/electron-shell \
#       --simple-bin bin/simple --entry examples/ui/line_drawing_canvas.spl

use examples.browser.entity.dom.paint_types.{PaintOp, DisplayList, from_rgb}
use common.render_scene.scene_to_canvas2d_json.{display_list_to_canvas2d_ops}
use app.ui.ipc.protocol.{build_ipc_paint_canvas, parse_ipc_message}
use common.ui.widget.{UIEvent}

extern fn rt_stdin_read_line() -> text?

fn line_rect(ops: [PaintOp], x: f64, y: f64, w: f64, h: f64, r: i64, g: i64, b: i64) -> [PaintOp]:
    ops.push(PaintOp.FillRect(x: x, y: y, w: w, h: h, color: from_rgb(r, g, b)))

fn build_lines() -> DisplayList:
    var ops: [PaintOp] = []
    ops = line_rect(ops, 0.0, 0.0, 1280.0, 800.0, 16, 24, 32)
    ops = line_rect(ops, 140.0, 140.0, 1000.0, 4.0, 51, 161, 253)
    ops = line_rect(ops, 140.0, 260.0, 1000.0, 4.0, 74, 222, 128)
    ops = line_rect(ops, 140.0, 380.0, 1000.0, 4.0, 255, 200, 87)
    ops = line_rect(ops, 260.0, 100.0, 4.0, 500.0, 244, 114, 182)
    ops = line_rect(ops, 640.0, 100.0, 4.0, 500.0, 255, 255, 255)
    ops = line_rect(ops, 1020.0, 100.0, 4.0, 500.0, 51, 161, 253)
    DisplayList(ops: ops)

fn main() -> i64:
    print build_ipc_paint_canvas(display_list_to_canvas2d_ops(build_lines()), 1280, 800)

    var running = true
    while running:
        val line = rt_stdin_read_line()
        if line != nil and line != "":
            val event = parse_ipc_message(line)
            if event != nil:
                match event:
                    UIEvent.Quit:
                        running = false
                    _:
                        pass_dn
    return 0
