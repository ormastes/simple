# Fast default 2D shapes GUI smoke.
#
# Low DPI is intentionally compact so the example starts under the default
# watchdog. High DPI delegates to the full SDF renderer:
#   SIMPLE_GUI_DPI=high scripts/macos-gui-run.shs examples/ui/engine2d_shapes_gui.spl

extern fn rt_winit_event_loop_new() -> i64
extern fn rt_winit_window_new(el: i64, w: i64, h: i64, title: text) -> i64
extern fn rt_winit_window_present_rgba(win: i64, w: i64, h: i64, pixels: [i64])
extern fn rt_winit_event_loop_poll_events(el: i64, max: i64) -> i64
extern fn rt_winit_event_get_type(ev: i64) -> i64
extern fn rt_winit_event_free(ev: i64)
extern fn rt_winit_window_free(win: i64)
extern fn rt_winit_event_loop_free(el: i64)
extern fn rt_env_get(key: text) -> text
extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

val W: i32 = 80
val H: i32 = 60
val EVT_CLOSE: i64 = 3
val BG: u32 = 0xFF101822u32

fn simple_bin() -> text:
    val env_binary = rt_env_get("SIMPLE_BINARY") ?? ""
    if env_binary != "":
        return env_binary
    val env_bin = rt_env_get("SIMPLE_BIN") ?? ""
    if env_bin != "":
        return env_bin
    "src/compiler_rust/target/gui/debug/simple"

fn fill_rect(buf: [u32], x: i32, y: i32, rw: i32, rh: i32, col: u32):
    var yy = y
    while yy < y + rh:
        if yy >= 0 and yy < H:
            var xx = x
            while xx < x + rw:
                if xx >= 0 and xx < W:
                    buf[yy * W + xx] = col
                xx = xx + 1
        yy = yy + 1

fn fill_circle(buf: [u32], cx: i32, cy: i32, r: i32, col: u32):
    val rr = r * r
    var y = cy - r
    while y <= cy + r:
        var x = cx - r
        while x <= cx + r:
            val dx = x - cx
            val dy = y - cy
            if dx * dx + dy * dy <= rr and x >= 0 and x < W and y >= 0 and y < H:
                buf[y * W + x] = col
            x = x + 1
        y = y + 1

fn draw_scene() -> [u32]:
    var px: [u32] = [BG; W * H]
    fill_rect(px, 5, 14, 18, 18, 0xFFE53935u32)
    fill_circle(px, 56, 23, 12, 0xFF43A047u32)
    fill_rect(px, 5, 41, 70, 3, 0xFF1E88E5u32)
    fill_rect(px, 5, 47, 33, 11, 0xFFFFB300u32)
    fill_rect(px, 43, 47, 31, 11, 0xFF00ACC1u32)
    fill_rect(px, 22, 5, 34, 3, 0xFFFFFFFFu32)
    px

fn pack(src: [u32]) -> [i64]:
    var out: [i64] = [0; src.len()]
    var i = 0
    while i < src.len():
        out[i] = src[i].to_i64() & 0xFFFFFF
        i = i + 1
    out

fn preview(px: [u32]):
    print "ASCII preview (80x60 -> 40x15):"
    var ry = 0
    while ry < 15:
        var line = ""
        var rx = 0
        while rx < 40:
            val c = px[((ry * H) / 15) * W + (rx * W) / 40]
            var ch = "."
            if c == 0xFFE53935u32:
                ch = "R"
            elif c == 0xFF43A047u32:
                ch = "G"
            elif c == 0xFF1E88E5u32:
                ch = "B"
            elif c == 0xFFFFB300u32:
                ch = "Y"
            elif c == 0xFF00ACC1u32:
                ch = "C"
            elif c == 0xFFFFFFFFu32:
                ch = "W"
            line = line + ch
            rx = rx + 1
        print line
        ry = ry + 1

fn run_high() -> i64:
    val result = rt_process_run(simple_bin(), ["run", "examples/ui/engine2d_shapes_high_gui.spl"])
    if result.0 != "":
        print result.0
    if result.1 != "":
        eprint result.1
    result.2

fn main() -> i64:
    if (rt_env_get("SIMPLE_GUI_DPI") ?? "low") == "high":
        return run_high()

    print "Engine2D shapes GUI — low DPI fast path: render {W}x{H} -> window 480x360"
    val pixels = draw_scene()
    print "Rendered {pixels.len()} px"
    preview(pixels)

    if (rt_env_get("SIMPLE_GUI") ?? "") != "1":
        print "No GUI requested (use scripts/macos-gui-run.shs to open a window); headless only."
        return 0

    val el = rt_winit_event_loop_new()
    if el == 0:
        print "No GUI runtime available."
        return 0
    val win = rt_winit_window_new(el, 480, 360, "Simple 2D Shapes")
    if win == 0:
        rt_winit_event_loop_free(el)
        return 0
    val packed = pack(pixels)
    var running = true
    var iters = 0
    while running and iters < 2000000:
        if iters % 200 == 0:
            rt_winit_window_present_rgba(win, W.to_i64(), H.to_i64(), packed)
        var ev = rt_winit_event_loop_poll_events(el, 1)
        while ev != 0:
            if rt_winit_event_get_type(ev) == EVT_CLOSE:
                running = false
            rt_winit_event_free(ev)
            ev = rt_winit_event_loop_poll_events(el, 1)
        iters = iters + 1
    rt_winit_window_free(win)
    rt_winit_event_loop_free(el)
    return 0
