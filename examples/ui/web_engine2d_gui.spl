# web_engine2d_gui.spl — GUI app: Simple Web Renderer + Engine2D software (CPU) backend
#
# Renders HTML through SimpleWebRenderer with the "software" (CPU) engine2d
# backend, then presents the resulting [u32] pixel buffer to a host winit
# window via rt_winit_window_present_rgba. A headless PPM snapshot is also
# written so the render can be verified without a display.
#
# The renderer is corpus-driven, not a full layout engine: it maps recognized
# HTML markers to colored rects (background color + wm-app-titlebar header +
# wm-app-content panel + a "Simple Web" title block). This entry uses markers
# that produce three visually distinct regions.
#
# Run (window):   SIMPLE_GUI=1 SIMPLE_EXECUTION_MODE=interpret bin/simple examples/ui/web_engine2d_gui.spl
# Run (headless):                SIMPLE_EXECUTION_MODE=interpret bin/simple examples/ui/web_engine2d_gui.spl
#
# NOTE: must run under SIMPLE_EXECUTION_MODE=interpret — the renderer uses the
# array-repeat form [bg; w*h] (rt_array_repeat) which the JIT cannot resolve.

use std.gc_async_mut.gpu.browser_engine.simple_web_renderer.{SimpleWebRenderer}

extern fn rt_winit_event_loop_new() -> i64
extern fn rt_winit_window_new(el: i64, w: i64, h: i64, title: text) -> i64
extern fn rt_winit_window_present_rgba(win: i64, w: i64, h: i64, pixels: [i64])
extern fn rt_winit_event_loop_poll_events(el: i64, max: i64) -> i64
extern fn rt_winit_event_get_type(ev: i64) -> i64
extern fn rt_winit_event_free(ev: i64)
extern fn rt_winit_window_free(win: i64)
extern fn rt_winit_event_loop_free(el: i64)
extern fn rt_thread_sleep(ms: i64)
extern fn rt_file_write_text(path: text, content: text) -> bool

val SCREEN_W: i32 = 160
val SCREEN_H: i32 = 120
val EVT_CLOSE: i64 = 3

fn demo_html() -> text:
    # Markers recognized by simple_web_engine2d_renderer:
    #   background-color: #44aa22  -> green page background (0xFF44AA22)
    #   wm-app-titlebar            -> blue header bar (0xFF2050A0, top 24px)
    #   "Simple Web"               -> white title block (24x3 at 6,6)
    return "<html><body style='background-color: #44aa22'>" +
        "<div class='wm-app-titlebar'>Simple Web</div>" +
        "</body></html>"

fn pack_pixels(src: [u32]) -> [i64]:
    # softbuffer treats each u32 as 0x00RRGGBB (top byte ignored); mask to the
    # proven 24-bit RGB present format.
    var out: [i64] = []
    var i = 0
    while i < src.len():
        out = out.push(src[i].to_i64() & 0xFFFFFF)
        i = i + 1
    return out

fn write_ppm(src: [u32], w: i32, h: i32, path: text):
    var parts: [text] = ["P3\n{w} {h}\n255\n"]
    var y = 0
    while y < h:
        var x = 0
        while x < w:
            val p = src[y * w + x].to_i64()
            val r = (p >> 16) & 0xFF
            val g = (p >> 8) & 0xFF
            val b = p & 0xFF
            parts = parts.push("{r} {g} {b} ")
            x = x + 1
        parts = parts.push("\n")
        y = y + 1
    rt_file_write_text(path, parts.join(""))

fn main() -> i64:
    print "Simple Web Renderer + Engine2D (software/CPU) GUI {SCREEN_W}x{SCREEN_H}"
    val renderer = SimpleWebRenderer.create_with_backend(SCREEN_W, SCREEN_H, "software")
    val pixels = renderer.render_html_to_pixels(demo_html())
    print "Rendered {pixels.len()} px via backend '{renderer.backend_name}'"
    write_ppm(pixels, SCREEN_W, SCREEN_H, "/tmp/web_engine2d_gui.ppm")
    print "Wrote /tmp/web_engine2d_gui.ppm"

    val el = rt_winit_event_loop_new()
    if el == 0:
        print "No GUI runtime (set SIMPLE_GUI=1 to open a window); headless render only."
        return 0
    val win = rt_winit_window_new(el, SCREEN_W.to_i64(), SCREEN_H.to_i64(), "Simple Web + Engine2D (CPU)")
    if win == 0:
        print "Window creation failed."
        rt_winit_event_loop_free(el)
        return 0
    val packed = pack_pixels(pixels)
    var frame = 0
    var running = true
    while running and frame < 200:
        rt_winit_window_present_rgba(win, SCREEN_W.to_i64(), SCREEN_H.to_i64(), packed)
        var ev = rt_winit_event_loop_poll_events(el, 50)
        while ev != 0:
            if rt_winit_event_get_type(ev) == EVT_CLOSE:
                running = false
            rt_winit_event_free(ev)
            ev = rt_winit_event_loop_poll_events(el, 50)
        rt_thread_sleep(50)
        frame = frame + 1
    rt_winit_window_free(win)
    rt_winit_event_loop_free(el)
    return 0
