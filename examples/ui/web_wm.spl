# Web Window Manager
#
# Multi-window desktop WM served via HTTP+WebSocket.
# Open http://localhost:3333 in a browser to view.
# The main page is a WM desktop. When loaded, the wm.js creates
# floating windows from a "render" message containing the SDN layout.
# Future: WebSocket sends openWindow messages for individual windows.

use app.ui.web.server.{run_web}

fn main() -> i64:
    return run_web("examples/ui/hello_electron.ui.sdn", 3333)
