# engine2d_backend_test.spl — 2D engine drawing test across backends.
#
# Draws the core primitives — square, circle, line, text, shade (vertical
# gradient) and a rounded-edge square — then reads the framebuffer back and
# pixel-checks each shape. Runs the CPU, Metal and Vulkan backends, reports
# which are implemented/available on this host, and renders+checks every
# backend that initializes. The CPU backend is always available.
#
# Run all three backends (default):
#   bin/simple run examples/ui/engine2d_backend_test.spl
#
# Switch to a single backend:
#   bin/simple run examples/ui/engine2d_backend_test.spl --backend=cpu
#   bin/simple run examples/ui/engine2d_backend_test.spl metal
#   bin/simple run examples/ui/engine2d_backend_test.spl vulkan
#
# Exit code is 0 when at least one backend passes all checks (CPU always
# should), 1 otherwise.

use std.gpu.engine2d.engine.{Engine2D}
use std.gpu.engine2d.backend_probe.{BackendProbeResult, BackendStatus, backend_status_text}

extern fn rt_cli_get_args() -> [text]

val W: i32 = 200
val H: i32 = 200

# Packed 0xAARRGGBB colors, all distinct and != BG.
val BG: u32 = 0xFF101018u32
val SQUARE_COL: u32 = 0xFFE53935u32
val CIRCLE_COL: u32 = 0xFF43A047u32
val LINE_COL: u32 = 0xFF1E88E5u32
val TEXT_COL: u32 = 0xFFFFFFFFu32
val GRAD_TOP: u32 = 0xFFFFB300u32
val GRAD_BOT: u32 = 0xFF6A1B9Au32
val ROUND_COL: u32 = 0xFF00ACC1u32

fn _px(pixels: [u32], x: i32, y: i32) -> u32:
    pixels[y * W + x]

fn _count_non_bg(pixels: [u32], x0: i32, y0: i32, x1: i32, y1: i32) -> i32:
    var n: i32 = 0
    var y = y0
    while y < y1:
        var x = x0
        while x < x1:
            if _px(pixels, x, y) != BG:
                n = n + 1
            x = x + 1
        y = y + 1
    n

fn _report(label: text, ok: bool) -> i32:
    val mark = if ok: "PASS" else: "FAIL"
    print "    [{mark}] {label}"
    if ok: 1 else: 0

# Verify the drawn scene from the read-back framebuffer. Returns passed count.
fn _check_scene(pixels: [u32]) -> i32:
    var passed: i32 = 0
    passed = passed + _report("square  (filled rect, solid center)", _px(pixels, 40, 35) == SQUARE_COL)
    passed = passed + _report("circle  (filled, solid center)", _px(pixels, 140, 35) == CIRCLE_COL)
    passed = passed + _report("line    (thick horizontal midpoint)", _px(pixels, 100, 75) == LINE_COL)
    val g_top = _px(pixels, 40, 98)
    val g_bot = _px(pixels, 40, 141)
    passed = passed + _report("shade   (vertical gradient varies top->bottom)", g_top != BG and g_bot != BG and g_top != g_bot)
    val edge_ok = _px(pixels, 150, 95) == ROUND_COL
    val corner_rounded = _px(pixels, 115, 95) == BG
    passed = passed + _report("rounded (edge drawn, corner rounded away)", edge_ok and corner_rounded)
    val text_px = _count_non_bg(pixels, 18, 150, 182, 192)
    passed = passed + _report("text    ({text_px} glyph pixels)", text_px > 0)
    passed

# Probe, render and check one backend. Returns true if it ran and passed 6/6.
fn _run_backend(name: text) -> bool:
    print "  backend '{name}':"
    val probe = Engine2D.probe_backend(W, H, name)
    if probe.status != BackendStatus.Initialized:
        print "    status: {backend_status_text(probe.status)} — {probe.reason}"
        print "    -> skipped (not implemented/available on this host)"
        return false
    match Engine2D.create_with_backend_strict(W, H, name):
        case Ok(eng):
            var engine = eng
            print "    status: Initialized (active: {engine.backend_name()})"
            engine.clear(BG)
            engine.draw_rect_filled(20, 15, 40, 40, SQUARE_COL)
            engine.draw_circle_filled(140, 35, 22, CIRCLE_COL)
            engine.draw_line(15, 75, 185, 75, LINE_COL, 5)
            engine.draw_gradient_rect(20, 95, 70, 50, GRAD_TOP, GRAD_BOT)
            engine.draw_rounded_rect(115, 95, 70, 50, 16, ROUND_COL)
            engine.draw_text(20, 165, "Engine2D", TEXT_COL, 16)
            engine.present()
            val pixels = engine.read_pixels()
            if pixels.len() < W * H:
                print "    -> readback unavailable (got {pixels.len()} px, need {W * H})"
                engine.shutdown()
                return false
            val passed = _check_scene(pixels)
            engine.shutdown()
            print "    result: {passed}/6 checks passed"
            return passed == 6
        case Err(p):
            print "    -> create failed: {p.diagnostic_text()}"
            return false

fn _join(items: [text], sep: text) -> text:
    var out = ""
    var i = 0
    while i < items.len():
        if i > 0:
            out = out + sep
        out = out + items[i]
        i = i + 1
    out

fn _selected_backends(args: [text]) -> [text]:
    var sel = "all"
    for a in args:
        if a.index_of("--backend=") == 0:
            sel = a.substring(10, a.len())
        elif a == "cpu" or a == "metal" or a == "vulkan" or a == "software" or a == "all":
            sel = a
    if sel == "all":
        return ["cpu", "metal", "vulkan"]
    [sel]

fn main() -> i64:
    print "=== Engine2D drawing test: square / circle / line / text / shade / rounded ==="
    val args = rt_cli_get_args()
    val backends = _selected_backends(args)
    print "Testing: " + _join(backends, ", ")
    print ""
    var passed_count: i32 = 0
    var ran_count: i32 = 0
    for name in backends:
        if _run_backend(name):
            passed_count = passed_count + 1
        ran_count = ran_count + 1
        print ""
    print "=== summary: {passed_count}/{ran_count} backend(s) passed all checks ==="
    if passed_count > 0:
        return 0
    print "No backend rendered all primitives correctly."
    return 1
