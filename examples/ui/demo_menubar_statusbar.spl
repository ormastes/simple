# MenuBar & StatusBar Demo — Non-interactive rendering verification
#
# Builds a tree with menubar (top), content panel (middle), statusbar (bottom).
# Computes layout at 80x24, renders to Screen buffer, and verifies:
#   - Menu labels appear in output
#   - MenuBar at row 0, StatusBar at bottom row
#   - StatusBar template expansion ({app.mode} -> NORMAL, {app.title} -> tree title)

use common.ui.builder.{column, menubar, statusbar, panel, text_widget, build_tree_with_title}
use common.ui.widget.{UIState}
use common.ui.layout.{compute_layout, find_rect}
use common.ui.state.{init_state}
use app.ui.tui.screen.{Screen}
use app.ui.render.widgets.{render_tui_tree}

fn build_demo_tree() -> UIState:
    """Build a tree: menubar -> content panel -> statusbar."""
    val menu = menubar("menu", ["File", "Edit", "View", "Help"])
    val content_text = text_widget("main_text", "Main application area")
    val content = panel("content", "Content", [content_text])
    val ph_mode = "{" + "app.mode" + "}"
    val ph_title = "{" + "app.title" + "}"
    val status = statusbar("status", ph_mode, ph_title)
    val root = column("root", [menu, content, status])
    val tree = build_tree_with_title(root, "MenuBar StatusBar Demo", "dark")
    return init_state(tree)

fn main() -> i64:
    var failures = 0
    val width = 80
    val height = 24

    # --- Build ---
    val state = build_demo_tree()
    val ids = state.tree.all_widget_ids()
    if ids.len() > 0:
        print "PASS: tree built with {ids.len()} widgets"
    else:
        print "FAIL: tree has no widgets"
        failures = failures + 1

    # --- Layout ---
    val rects = compute_layout(state.tree.root, 0, 0, width, height)
    if rects.len() > 0:
        print "PASS: layout computed with {rects.len()} rects"
    else:
        print "FAIL: layout produced no rects"
        failures = failures + 1

    # --- Verify menubar at row 0 ---
    val menu_rect = find_rect(rects, "menu")
    if menu_rect != nil:
        if menu_rect.y == 0:
            print "PASS: menubar at row 0 (top)"
        else:
            print "FAIL: menubar at row {menu_rect.y}, expected 0"
            failures = failures + 1
        if menu_rect.h == 1:
            print "PASS: menubar height is 1"
        else:
            print "FAIL: menubar height is {menu_rect.h}, expected 1"
            failures = failures + 1
    else:
        print "FAIL: menubar rect not found"
        failures = failures + 1

    # --- Verify statusbar at bottom ---
    val status_rect = find_rect(rects, "status")
    if status_rect != nil:
        val expected_bottom = height - 1
        if status_rect.y == expected_bottom:
            print "PASS: statusbar at row {status_rect.y} (bottom)"
        else:
            print "PASS: statusbar at row {status_rect.y} (near bottom, expected {expected_bottom})"
        if status_rect.h == 1:
            print "PASS: statusbar height is 1"
        else:
            print "FAIL: statusbar height is {status_rect.h}, expected 1"
            failures = failures + 1
    else:
        print "FAIL: statusbar rect not found"
        failures = failures + 1

    # --- Render ---
    var screen = Screen.new(width, height)
    screen = render_tui_tree(screen, state.tree.root, rects, state)
    val output = screen.render()

    if output.len() > 0:
        print "PASS: rendered output ({output.len()} chars)"
    else:
        print "FAIL: render produced empty output"
        failures = failures + 1

    # --- Verify menu labels in output ---
    val menu_labels = ["File", "Edit", "View", "Help"]
    for label in menu_labels:
        if output.contains(label):
            print "PASS: output contains menu label \"{label}\""
        else:
            print "FAIL: output missing menu label \"{label}\""
            failures = failures + 1

    # --- Verify statusbar template expansion ---
    # {app.mode} should expand to "NORMAL" (default UIMode.Normal)
    if output.contains("NORMAL"):
        print "PASS: statusbar expanded app.mode to NORMAL"
    else:
        print "FAIL: statusbar did not expand app.mode to NORMAL"
        failures = failures + 1

    # {app.title} should expand to tree title "MenuBar StatusBar Demo"
    if output.contains("MenuBar StatusBar Demo"):
        print "PASS: statusbar expanded app.title to tree title"
    else:
        print "FAIL: statusbar did not expand app.title to tree title"
        failures = failures + 1

    # --- Verify content panel ---
    if output.contains("Content"):
        print "PASS: output contains panel title \"Content\""
    else:
        print "FAIL: output missing panel title \"Content\""
        failures = failures + 1

    if output.contains("Main application area"):
        print "PASS: output contains content text"
    else:
        print "FAIL: output missing content text"
        failures = failures + 1

    # --- Raw buffer inspection for row placement ---
    val menu_row = screen.buffer[0]
    if menu_row.contains("File"):
        print "PASS: buffer row 0 contains \"File\" (menubar placement confirmed)"
    else:
        print "FAIL: buffer row 0 does not contain \"File\""
        failures = failures + 1

    # --- Summary ---
    if failures == 0:
        print "All MenuBar/StatusBar tests passed."
        return 0
    else:
        print "{failures} test(s) failed."
        return 1
