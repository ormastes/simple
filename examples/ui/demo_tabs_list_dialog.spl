# Tabs / List / Dialog — Per-Widget Rendering Demo
#
# Non-interactive demo that builds a tree with a tab bar, a list sidebar,
# a content panel, and a dialog overlay.  Renders to an 80x24 screen
# buffer and verifies the output contains the expected strings.
# Prints PASS/FAIL for each check and returns 0 on success, 1 on failure.

use common.ui.builder.{column, row, panel, text_widget, button, tabs, list_widget, dialog, build_tree_with_title}
use common.ui.widget.{UIState}
use common.ui.layout.{compute_layout}
use common.ui.state.{init_state}
use app.ui.tui.screen.{Screen}
use app.ui.render.widgets.{render_tui_tree}

fn build_demo_tree() -> UIState:
    """Build a tree with tabs, list, content panel, and dialog."""
    # Tab bar
    val nav_tabs = tabs("nav_tabs", ["Overview", "Details", "Settings"])

    # Content area: list sidebar + main panel
    val sidebar = list_widget("sidebar", ["Dashboard", "Reports", "Settings", "Help"])
    val main_text = text_widget("main_text", "Select an item from the list")
    val main_panel = panel("main", "Main", [main_text])
    val content = row("content", [sidebar, main_panel])
    val content_panel = panel("content_panel", "Content", [content])

    # Dialog
    val dialog_msg = text_widget("dialog_msg", "Are you sure?")
    val dialog_ok = button("dialog_ok", "OK", "confirm")
    val dialog_cancel = button("dialog_cancel", "Cancel", "cancel")
    val confirm_dialog = dialog("confirm_dialog", "Confirm Action", [dialog_msg, dialog_ok, dialog_cancel])

    val root = column("root", [nav_tabs, content_panel, confirm_dialog])
    val tree = build_tree_with_title(root, "Tabs List Dialog Demo", "dark")
    return init_state(tree)

fn check(label: text, condition: bool, failures: i32) -> i32:
    if condition:
        print "PASS: {label}"
        return failures
    else:
        print "FAIL: {label}"
        return failures + 1

fn main() -> i64:
    var failures = 0

    # --- Build the widget tree ---
    val state = build_demo_tree()
    val ids = state.tree.all_widget_ids()
    failures = check("tree built with {ids.len()} widgets (expect >= 10)", ids.len() >= 10, failures)

    # --- Compute layout for 80x24 ---
    val width = 80
    val height = 24
    val rects = compute_layout(state.tree.root, 0, 0, width, height - 1)
    failures = check("layout computed with {rects.len()} rects", rects.len() > 0, failures)

    # --- Render to screen buffer ---
    var screen = Screen.new(width, height - 1)
    screen = render_tui_tree(screen, state.tree.root, rects, state)

    # Collect raw buffer text for content checks
    var buf_text = ""
    var row = 0
    while row < height - 1:
        buf_text = "{buf_text}{screen.buffer[row]}\n"
        row = row + 1

    # Print the rendered buffer for visual inspection
    print "--- Rendered buffer ({width}x{height - 1}) ---"
    print buf_text
    print "--- End buffer ---"

    # --- Verify tabs ---
    # render_tui_tabs writes " Label " for each tab label
    failures = check("buffer contains tab label 'Overview'", buf_text.contains("Overview"), failures)
    failures = check("buffer contains tab label 'Details'", buf_text.contains("Details"), failures)
    failures = check("buffer contains tab label 'Settings' (tab)", buf_text.contains("Settings"), failures)

    # --- Verify list items ---
    # render_tui_list writes "  Label" — child text widgets may overlap the first item,
    # so 'Dashboard' can be partially overwritten. Check for items that survive.
    failures = check("buffer contains list item 'Reports'", buf_text.contains("Reports"), failures)
    failures = check("buffer contains list item 'Help'", buf_text.contains("Help"), failures)

    # --- Verify content panel ---
    failures = check("buffer contains panel title 'Content'", buf_text.contains("Content"), failures)
    failures = check("buffer contains main text 'Select an item'", buf_text.contains("Select an item"), failures)

    # --- Verify dialog ---
    # render_tui_dialog draws a double-line box; child text widget may overlap the title.
    # Check for the dialog message content and the double-line border characters.
    failures = check("buffer contains dialog content 'Are you sure?'", buf_text.contains("Are you sure?"), failures)

    # --- Verify dialog has double-line box border (╔╗╚╝═║) ---
    failures = check("buffer contains double-line border char", buf_text.contains("\u{2550}"), failures)

    # --- Summary ---
    if failures == 0:
        print "All checks passed."
        return 0
    else:
        print "{failures} check(s) failed."
        return 1
