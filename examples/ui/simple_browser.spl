# Simple Browser
#
# Standalone browser app. Single Electron window with one full-bleed
# web view — no system bar, no dock, no WM chrome. The host macOS
# title bar provides minimize/close.
#
# Launch:
#   ./tools/electron-shell/node_modules/.bin/electron \
#       tools/electron-shell examples/ui/simple_browser.spl
#
# Override URL:
#   SIMPLE_BROWSER_URL=https://example.com ./tools/electron-shell/...
#
# Override theme (affects the address-strip color only):
#   SIMPLE_THEME=light ./tools/electron-shell/...

use app.ui.ipc.protocol.{parse_ipc_message, build_ipc_render}
use common.ui.widget.{UIEvent}

extern fn rt_stdin_read_line() -> text?
extern fn rt_env_get(key: text) -> text

fn _resolve_theme() -> text:
    val env_val = rt_env_get("SIMPLE_THEME") ?? ""
    if env_val == "light" or env_val == "glass_obsidian_light":
        return "glass_obsidian_light"
    return "glass_obsidian_dark"

fn _resolve_url() -> text:
    val env_val = rt_env_get("SIMPLE_BROWSER_URL") ?? ""
    if env_val != "":
        return env_val
    return "https://example.com"

fn _build_browser_html(url: text, theme: text) -> text:
    val is_light = theme == "glass_obsidian_light"
    val bg = if is_light: "#F0ECF5" else: "#060612"
    val fg = if is_light: "#1D1D1F" else: "#E3E0F3"
    val accent = if is_light: "#7C69A3" else: "#C6C6C8"
    val strip_bg = if is_light:
        "linear-gradient(180deg,rgba(255,255,255,0.92),rgba(245,242,250,0.78))"
    else:
        "linear-gradient(180deg,rgba(18,18,31,0.92),rgba(13,13,26,0.78))"
    val strip_border = if is_light: "rgba(74,69,77,0.18)" else: "rgba(149,142,152,0.20)"
    # CSS uses raw strings (r"...") so the `{`/`}` braces don't trigger
    # Simple's interpolation. Variables get glued in via `+`.
    val btn_bg = if is_light: "rgba(124,105,163,0.14)" else: "rgba(198,198,200,0.14)"
    # CSS uses raw strings (r"...") so the `{`/`}` braces don't trigger
    # Simple's interpolation. Variables get glued in via `+`.
    var css = r"<style>html,body{margin:0;padding:0;height:100vh;width:100vw;overflow:hidden;background:" + bg
    css = css + r";color:" + fg
    css = css + r";font-family:'Space Grotesk','Manrope','Inter',-apple-system,BlinkMacSystemFont,sans-serif;}"
    css = css + r".sb-wrap{display:flex;flex-direction:column;height:100vh;width:100vw;}"
    # The address strip is the window-drag region (mac hidden-inset titlebar).
    # `-webkit-app-region:drag` lets the user grab the strip to move the window.
    css = css + r".sb-strip{flex:0 0 auto;display:flex;align-items:center;gap:10px;padding:10px 16px 10px 88px;background:" + strip_bg
    css = css + r";border-bottom:1px solid " + strip_border
    css = css + r";backdrop-filter:blur(24px) saturate(170%);-webkit-backdrop-filter:blur(24px) saturate(170%);-webkit-app-region:drag;}"
    css = css + r".sb-label{font-size:11px;text-transform:uppercase;letter-spacing:1.4px;color:" + accent
    css = css + r";font-weight:650;}"
    css = css + r".sb-form{flex:1;display:flex;align-items:center;gap:8px;-webkit-app-region:no-drag;}"
    css = css + r".sb-input{flex:1;font-size:13px;color:" + fg
    css = css + r";font-family:'Fira Code','SF Mono',monospace;padding:6px 12px;background:rgba(127,127,127,0.10);border-radius:8px;border:1px solid " + strip_border
    css = css + r";outline:none;-webkit-app-region:no-drag;}"
    css = css + r".sb-input:focus{border-color:" + accent
    css = css + r";background:rgba(127,127,127,0.18);}"
    css = css + r".sb-go{font-size:12px;color:" + fg
    css = css + r";background:" + btn_bg
    css = css + r";border:1px solid " + strip_border
    css = css + r";padding:6px 12px;border-radius:8px;cursor:pointer;font-weight:600;-webkit-app-region:no-drag;}"
    css = css + r".sb-go:hover{background:rgba(127,127,127,0.24);}"
    css = css + r".sb-frame{flex:1;width:100%;height:100%;border:none;background:#FFFFFF;}</style>"

    # The form submits to the iframe via target="sb-frame" — pressing Enter
    # in the input navigates the iframe to the typed URL. No JS, no IPC.
    val body = "<div class=\"sb-wrap\"><div class=\"sb-strip\"><div class=\"sb-label\">Simple Browser</div><form class=\"sb-form\" action=\"\" target=\"sb-frame\" method=\"GET\" onsubmit=\"event.preventDefault(); document.getElementById('sb-frame').src=document.getElementById('sb-input').value; return false;\"><input class=\"sb-input\" id=\"sb-input\" type=\"text\" value=\"" + url + "\" spellcheck=\"false\" autocomplete=\"off\" /><button class=\"sb-go\" type=\"submit\">Go</button></form></div><iframe class=\"sb-frame\" id=\"sb-frame\" name=\"sb-frame\" src=\"" + url + "\" sandbox=\"allow-scripts allow-same-origin allow-forms allow-popups allow-popups-to-escape-sandbox\"></iframe></div>"
    return "<html><head><title>Simple Browser</title></head><body>" + css + body + "</body></html>"

fn main() -> i64:
    val theme = _resolve_theme()
    val url = _resolve_url()
    val page = _build_browser_html(url, theme)
    print build_ipc_render(page)

    var running = true
    while running:
        val line = rt_stdin_read_line()
        if line != nil and line != "":
            val event = parse_ipc_message(line)
            if event != nil:
                match event:
                    UIEvent.Quit:
                        running = false
                    _:
                        pass_dn

    return 0
