#![allow(unnamed_duplicate_typed_args)]
# Per-Widget Rendering Demo — Button, Checkbox, Dropdown
#
# Non-interactive demo that builds a widget tree containing buttons,
# checkboxes, and a dropdown, renders to an 80x24 TUI screen buffer,
# and verifies the rendered output contains expected markers.
# Prints PASS/FAIL for each check and returns 0 on all pass.

use common.ui.builder.{column, panel, button, checkbox, dropdown, build_tree_with_title, with_height}
use common.ui.widget.{UIState}
use common.ui.layout.{compute_layout}
use common.ui.state.{init_state}
use app.ui.tui.screen.{Screen}
use app.ui.render.widgets.{render_tui_tree}

fn build_demo_tree() -> UIState:
    """Build a tree with buttons, checkboxes, and a dropdown inside a panel."""
    val btn_submit = with_height(button("btn1", "Submit", "submit_form"), 1)
    val btn_cancel = with_height(button("btn2", "Cancel", "cancel_form"), 1)
    val cb_terms = with_height(checkbox("cb1", "Accept Terms", true), 1)
    val cb_news = with_height(checkbox("cb2", "Newsletter", false), 1)
    val dd_opts = with_height(dropdown("dd1", ["Option A", "Option B", "Option C"]), 1)

    val controls = panel("controls", "Interactive Controls", [
        btn_submit,
        btn_cancel,
        cb_terms,
        cb_news,
        dd_opts
    ])

    val root = column("root", [controls])
    val tree = build_tree_with_title(root, "Button Checkbox Dropdown Demo", "dark")
    return init_state(tree)

fn check(output: text, needle: text, description: text, failures: i32) -> i32:
    if output.contains(needle):
        print "PASS: {description}"
        return failures
    else:
        print "FAIL: {description} (expected '{needle}')"
        return failures + 1

fn main() -> i64:
    var failures = 0
    val width = 80
    val height = 24

    # Build the widget tree
    val state = build_demo_tree()

    # Verify tree was built
    val ids = state.tree.all_widget_ids()
    if ids.len() > 0:
        print "PASS: tree built with {ids.len()} widgets"
    else:
        print "FAIL: tree has no widgets"
        failures = failures + 1

    # Compute layout
    val rects = compute_layout(state.tree.root, 0, 0, width, height - 1)
    if rects.len() > 0:
        print "PASS: layout computed with {rects.len()} rects"
    else:
        print "FAIL: layout produced no rects"
        failures = failures + 1

    # Render to screen buffer
    var screen = Screen.new(width, height - 1)
    screen = render_tui_tree(screen, state.tree.root, rects, state)
    val output = screen.render()

    if output.len() > 0:
        print "PASS: render produced output ({output.len()} chars)"
    else:
        print "FAIL: render produced empty output"
        failures = failures + 1

    # Print the rendered buffer for visual inspection
    print "--- Rendered Output ---"
    var row_idx = 0
    while row_idx < screen.buffer.len():
        print screen.buffer[row_idx]
        row_idx = row_idx + 1
    print "--- End Output ---"

    # Verify panel title
    failures = check(output, "Interactive Controls", "panel title 'Interactive Controls'", failures)

    # Verify button labels — rendered as [ Submit ] and [ Cancel ]
    failures = check(output, "Submit", "button label 'Submit'", failures)
    failures = check(output, "Cancel", "button label 'Cancel'", failures)

    # Verify checkbox labels
    failures = check(output, "Accept Terms", "checkbox label 'Accept Terms'", failures)
    failures = check(output, "Newsletter", "checkbox label 'Newsletter'", failures)

    # Verify checked marker [✓] for Accept Terms (checked: true)
    # The renderer uses Unicode check mark \u{2713} not 'x'
    failures = check(output, "[\u{2713}]", "checked marker [✓] for Accept Terms", failures)

    # Verify unchecked marker [ ] for Newsletter (checked: false)
    failures = check(output, "[ ]", "unchecked marker [ ] for Newsletter", failures)

    # Verify dropdown shows option items (children render as text widgets)
    failures = check(output, "Option", "dropdown renders option items", failures)

    # Verify dropdown arrow marker — renderer uses Unicode triangles
    # Unfocused: \u{25bf} (▿), focused: \u{25be} (▾)
    # Note: child text widgets may overlap the dropdown prefix in the buffer,
    # so we just verify at least one option label is visible.
    failures = check(output, "Option C", "dropdown option 'Option C' visible", failures)

    # Summary
    if failures == 0:
        print "All tests passed."
        return 0
    else:
        print "{failures} test(s) failed."
        return 1
