# Electron Window Manager
#
# Launches a desktop WM in Electron with system bar, dock, and
# multiple application windows. Uses multi-window IPC to create
# separate Electron BrowserWindow instances for each app.

use app.ui.ipc.protocol.{parse_ipc_message, build_ipc_render, build_ipc_open_window, build_ipc_close_window, build_ipc_render_window, escape_ipc_json}
use common.ui.widget.{UIEvent}
use app.ui.web.html.{generate_css}

extern fn rt_stdin_read_line() -> text?
extern fn rt_thread_sleep(ms: i64)

fn _build_desktop_html(css: text) -> text:
    """Build the main desktop HTML with system bar and dock."""
    val bar_html = "<div class=\"widget-menubar\" id=\"sysbar\"><span class=\"menu-item\">File</span><span class=\"menu-item\">Edit</span><span class=\"menu-item\">View</span><span class=\"menu-item\">Go</span><span class=\"menu-item\">Window</span><span class=\"menu-item\">Help</span></div>"
    val dock_html = "<div class=\"widget-tab-bar\" id=\"dock\"><div class=\"tab-bar-item tab-bar-item-active\" data-action=\"app_terminal\"><span class=\"tab-bar-icon\">&gt;</span><span class=\"tab-bar-label\">Terminal</span></div><div class=\"tab-bar-item\" data-action=\"app_editor\"><span class=\"tab-bar-icon\">E</span><span class=\"tab-bar-label\">Editor</span></div><div class=\"tab-bar-item\" data-action=\"app_browser\"><span class=\"tab-bar-icon\">W</span><span class=\"tab-bar-label\">Browser</span></div><div class=\"tab-bar-item\" data-action=\"app_files\"><span class=\"tab-bar-icon\">D</span><span class=\"tab-bar-label\">Files</span></div><div class=\"tab-bar-item\" data-action=\"app_calc\"><span class=\"tab-bar-icon\">#</span><span class=\"tab-bar-label\">Calc</span></div><div class=\"tab-bar-item\" data-action=\"app_settings\"><span class=\"tab-bar-icon\">*</span><span class=\"tab-bar-label\">Settings</span></div></div>"
    val desktop = "<div style=\"display:flex;flex-direction:column;height:100vh;\">" + bar_html + "<div style=\"flex:1;\"></div>" + dock_html + "</div>"
    return "<html><head><style>" + css + "</style></head><body>" + desktop + "</body></html>"

fn _build_app_html(css: text, title: text, content: text) -> text:
    """Build HTML for an application window."""
    val body = "<div style=\"display:flex;flex-direction:column;height:100vh;\"><div class=\"widget-panel layout-vbox\" style=\"flex:1;\"><div class=\"panel-title\">" + title + "</div><div class=\"panel-content\"><div class=\"widget-text\">" + content + "</div></div></div></div>"
    return "<html><head><style>" + css + "</style></head><body>" + body + "</body></html>"

fn _open_window(id: text, title: text, html: text):
    """Send openWindow IPC message."""
    val escaped_title = escape_ipc_json(title)
    val escaped_html = escape_ipc_json(html)
    val msg = "{\"type\":\"openWindow\",\"windowId\":\"" + id + "\",\"title\":\"" + escaped_title + "\",\"html\":\"" + escaped_html + "\"}"
    print msg

fn main() -> i64:
    val css = generate_css("glass_dark")

    # Render desktop (system bar + dock)
    val desktop_html = _build_desktop_html(css)
    val desktop_msg = build_ipc_render(desktop_html)
    print desktop_msg

    # Small delay to let the main window render
    rt_thread_sleep(500)

    # Open application windows
    val term_html = _build_app_html(css, "TERMINAL", "$ simple --version\nSimple Language v0.9.5\n\n$ _")
    _open_window("terminal", "Terminal", term_html)

    rt_thread_sleep(200)

    val editor_html = _build_app_html(css, "EDITOR", "# hello.spl\n\nfn main() -> i64:\n    print \"Hello, World!\"\n    return 0")
    _open_window("editor", "Editor", editor_html)

    rt_thread_sleep(200)

    val browser_html = _build_app_html(css, "BROWSER", "Simple Language — Documentation\n\nA modern systems programming language.")
    _open_window("browser", "Browser", browser_html)

    rt_thread_sleep(200)

    val files_html = _build_app_html(css, "FILE MANAGER", "src/\n  compiler/\n  lib/\n  app/\nexamples/\n  ui/\n  simple_os/")
    _open_window("files", "File Manager", files_html)

    # Main IPC loop — keep running until quit
    var running = true
    while running:
        val line = rt_stdin_read_line()
        if line != nil and line != "":
            val event = parse_ipc_message(line)
            if event != nil:
                match event:
                    UIEvent.Quit:
                        running = false
                    _:
                        pass_dn

    return 0
