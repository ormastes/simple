app:
  title: "Minimal"
  theme: dark

keybindings:
  normal:
    q: quit

layout:
  type: vbox
  children:
    0:
      type: panel
      id: main
      title: Hello
      flex: 1
      children:
        0:
          type: text
          id: greeting
          content: "Hello from Simple UI!"
    1:
      type: statusbar
      id: status
      left: "{app.mode} MODE"
      right: "{app.title}"
