# Hello generated-WASM GUI entry.
#
# This source is intentionally dependency-light so the WASM compiler/linker
# path can use it as the first no-JavaScript GUI artifact across mobile and WM
# targets.

fn hello_wasm_gui_title() -> text:
    "Hello World"

fn hello_wasm_gui_body() -> text:
    "<main data-simple-wasm='hello'><button id='hello_button'>Hello World</button><p id='hello_text'>Generated WASM UI</p></main>"

fn hello_wasm_gui_css() -> text:
    "main{display:flex;flex-direction:column;gap:8px;padding:16px;}button{min-height:44px;}"

fn hello_wasm_gui_event_response(event_name: text, target_id: text) -> text:
    if event_name == "click" and target_id == "hello_button":
        return "hello_button:clicked"
    if event_name == "scroll":
        return "hello_scroll:accepted"
    if event_name == "text":
        return "hello_text:accepted"
    "hello_event:ignored"

fn main() -> i64:
    print "wasm_gui:title:{hello_wasm_gui_title()}"
    print "wasm_gui:body:{hello_wasm_gui_body()}"
    print "wasm_gui:css:{hello_wasm_gui_css()}"
    print "wasm_gui:event:{hello_wasm_gui_event_response(\"click\", \"hello_button\")}"
    return 0
