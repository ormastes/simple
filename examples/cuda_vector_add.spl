# CUDA Vector Add Example
#
# Demonstrates a real GPU kernel that performs element-wise vector addition.
# Uses raw device pointers (i64) matching the kernel parameter convention.
#
# In compiled mode with CUDA backend, the @gpu_kernel function is lowered
# to PTX with .entry directive. Memory intrinsics (gpu_load_f64, gpu_store_f64)
# are emitted as ld.global.f64 / st.global.f64 instructions.

# GPU kernel intrinsics (resolved by compiler)
extern fn gpu_global_id_x() -> i64
extern fn gpu_load_f64(ptr: i64, index: i64) -> f64
extern fn gpu_store_f64(ptr: i64, index: i64, value: f64)

@gpu_kernel
fn vector_add(a: i64, b: i64, c: i64, n: i64):
    val idx = gpu_global_id_x()
    if idx < n:
        val av = gpu_load_f64(a, idx)
        val bv = gpu_load_f64(b, idx)
        gpu_store_f64(c, idx, av + bv)

fn main():
    print "CUDA vector_add kernel (real computation)"
