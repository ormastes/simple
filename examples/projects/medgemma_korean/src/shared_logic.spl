            batch_size: 16,
            num_batches: 20,
            num_epochs: 3,
            learning_rate: 0.001,
            lora_rank: 8,
            lora_alpha: 16.0,
            max_grad_norm: 1.0,
            warmup_steps: 10,
            log_every: 5
