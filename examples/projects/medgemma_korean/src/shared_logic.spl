# Shared Logic for MedGemma Korean Training Pipeline
#
# Common utilities used across all training phases:
#   - Training configuration
#   - Batch creation
#   - Loss computation wrappers
#   - Validation scoring
#   - GPU memory reporting
#   - Learning rate scheduling
#
# Import this module from all phase scripts to avoid duplication.

use src.torch_dyn.{
    tensor_randn_2d,
    t_add, t_sub, t_mul, t_mul_scalar, t_neg,
    t_log_softmax, t_gather,
    t_sum_dim, t_mean, t_mean_dim, t_argmax,
    t_matmul,
    t_cuda, t_free, t_clone,
    autograd_backward, autograd_no_grad_begin, autograd_no_grad_end,
    cuda_memory_allocated, cuda_max_memory_allocated, cuda_empty_cache
}

export TrainConfig, TrainState
export make_batch_on_cuda, make_randn_batch_on_cuda
export compute_ce_loss, compute_mse_loss
export report_gpu_memory, report_training_step, report_epoch_end
export lr_linear_warmup
export set_selected_hidden_dim, selected_hidden_dim

# ============================================================================
# Model Size Selection (Small vs Large)
# ============================================================================

var _selected_hidden_dim: i64 = 128

fn set_selected_hidden_dim(dim: i64):
    _selected_hidden_dim = dim
    print("Selected hidden_dim: {dim}")

fn selected_hidden_dim() -> i64:
    _selected_hidden_dim

