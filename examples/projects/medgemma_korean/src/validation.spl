# Validation Utilities for MedGemma Korean Training
#
# All functions return simple values (f64, bool) instead of class instances
# to avoid class constructor issues with transitive module imports.

use model.{TextModel, compute_mse_loss, check_gpu}
use shared_logic.{
    TrainConfig,
    make_randn_batch_on_cuda, compute_ce_loss
}
use lora_utils.{
    LoRAConfig, LoRAAdapter,
    create_lora_adapter, lora_forward
}
use embedding_utils.{
    KorEngEmbedding, RoPECache,
    make_embedding_batch, embed_with_routing, apply_rope, mean_pool_seq
}
use layer_utils.{
    ExtendedModel, extended_lora_forward
}

use src.torch_dyn.{
    t_free,
    t_mean,
    t_sub,
    t_mul,
    t_argmax,
    t_add_scalar,
    t_pow,
    autograd_no_grad_begin,
    autograd_no_grad_end
}

export validate_model, validate_with_lora
export validate_accuracy, validate_all_phases, check_english_retention
export validate_extended_model, validate_korean_accuracy, validate_exam_accuracy
export validate_per_layer_retention, validate_all_phases_extended


# ============================================================================
# Validation: Model without LoRA
# Returns avg_loss (f64)
# ============================================================================

fn validate_model(model: TextModel, phase_name: text, threshold: f64) -> f64:
    print("  Validating: {phase_name}")
    autograd_no_grad_begin()

    val input_dim = model.config.input_dim
    val output_dim = model.config.output_dim

    var total_loss = 0.0
    for i in 0..5:
        val batch = make_randn_batch_on_cuda(8, input_dim, output_dim)
        val x = batch[0]
        val target = batch[1]

        val logits = model.forward(x)
        val loss_h = compute_mse_loss(logits, target)
        val loss_val = t_mean(loss_h)

        total_loss = total_loss + loss_val

        t_free(x)
        t_free(target)
        t_free(logits)
        t_free(loss_h)

    autograd_no_grad_end()

    val avg_loss = total_loss / 5
    val passed = avg_loss < threshold
    var status = "PASS"
    if not passed:
        status = "FAIL"
    print("  [{status}] {phase_name}: loss={avg_loss} (threshold={threshold})")
    avg_loss


# ============================================================================
# Validation: Model with LoRA adapters
# Returns avg_loss (f64)
# ============================================================================

fn validate_with_lora(
    model: TextModel,
    lora_l1: LoRAAdapter,
    lora_l2: LoRAAdapter,
    phase_name: text,
    threshold: f64
) -> f64:
    print("  Validating (with LoRA): {phase_name}")
    autograd_no_grad_begin()

    val input_dim = model.config.input_dim
    val output_dim = model.config.output_dim

    var total_loss = 0.0
    for i in 0..5:
        val batch = make_randn_batch_on_cuda(8, input_dim, output_dim)
        val x = batch[0]
        val target = batch[1]

        val logits = lora_forward(model, x, lora_l1, lora_l2)
        val loss_h = compute_mse_loss(logits, target)
        val loss_val = t_mean(loss_h)

        total_loss = total_loss + loss_val

        t_free(x)
        t_free(target)
        t_free(logits)
        t_free(loss_h)

    autograd_no_grad_end()

    val avg_loss = total_loss / 5
    val passed = avg_loss < threshold
    var status = "PASS"
    if not passed:
        status = "FAIL"
    print("  [{status}] {phase_name}: loss={avg_loss} (threshold={threshold})")
    avg_loss


# ============================================================================
# MCQ Accuracy Validation
# ============================================================================

fn validate_accuracy(model: TextModel, config: TrainConfig) -> f64:
    autograd_no_grad_begin()

    var total_accuracy = 0.0
    var num_batches = 0

    for i in 0..5:
        val batch = make_randn_batch_on_cuda(8, config.input_dim, config.output_dim)
        val x = batch[0]
        val target = batch[1]

        val logits = model.forward(x)

        val preds = t_argmax(logits, 1, false)
        val target_classes = t_argmax(target, 1, false)

        val diff = t_sub(preds, target_classes)
        val diff_sq = t_mul(diff, diff)
        t_free(diff)
        val denom = t_add_scalar(diff_sq, 1.0)
        t_free(diff_sq)
        val inv = t_pow(denom, -1.0)
        t_free(denom)
        val batch_accuracy = t_mean(inv)
        t_free(inv)

        total_accuracy = total_accuracy + batch_accuracy
        num_batches = num_batches + 1

        t_free(x)
        t_free(target)
        t_free(logits)
        t_free(preds)
        t_free(target_classes)

    autograd_no_grad_end()

    if num_batches == 0:
        return 0.0
    total_accuracy / num_batches


# ============================================================================
# English Retention Check
# ============================================================================

fn check_english_retention(model: TextModel, config: TrainConfig) -> bool:
    print("  Checking English retention...")
    val accuracy = validate_accuracy(model, config)
    val passed = accuracy >= 0.95
    if passed:
        print("  English retention: {accuracy} >= 0.95 PASS")
    else:
        print("  English retention: {accuracy} < 0.95 FAIL")
        print("  WARNING: Catastrophic forgetting detected!")
    passed


# ============================================================================
# Comprehensive Validation (all phases)
# ============================================================================

fn validate_all_phases(model: TextModel, current_phase: i64):
    print("")
    print("-" * 70)
    print("VALIDATION AFTER PHASE {current_phase}")
    print("-" * 70)

    val threshold = 100.0

    if current_phase >= 0:
        val r0 = validate_model(model, "Phase 0: English medical baseline", threshold)

    if current_phase >= 1:
        val r1 = validate_model(model, "Phase 1: English medical LoRA", threshold)

    if current_phase >= 2:
        val r2 = validate_model(model, "Phase 2: MCQ reasoning", threshold)

    val config = TrainConfig.default_config()
    val retained = check_english_retention(model, config)

    print("-" * 70)
    print("")


# ============================================================================
# Extended Model Validation (Phases 3-6)
# Returns avg_loss (f64)
# ============================================================================

fn validate_extended_model(ext: ExtendedModel, lora_l1: LoRAAdapter, lora_l2: LoRAAdapter, phase_name: text, threshold: f64) -> f64:
    print("  Validating extended: {phase_name}")
    autograd_no_grad_begin()

    val output_dim = ext.base.config.output_dim
    var total_loss = 0.0

    for i in 0..5:
        val batch = make_embedding_batch(8, 8, ext.emb, output_dim)
        val kor_ids = batch[0]
        val eng_ids = batch[1]
        val mask_h = batch[2]
        val target = batch[3]

        val logits = extended_lora_forward(ext, kor_ids, eng_ids, mask_h, lora_l1, lora_l2)
        val loss_h = compute_mse_loss(logits, target)
        val loss_val = t_mean(loss_h)

        total_loss = total_loss + loss_val

        t_free(kor_ids)
        t_free(eng_ids)
        t_free(mask_h)
        t_free(target)
        t_free(logits)
        t_free(loss_h)

    autograd_no_grad_end()

    val avg_loss = total_loss / 5
    val passed = avg_loss < threshold
    var status = "PASS"
    if not passed:
        status = "FAIL"
    print("  [{status}] {phase_name}: loss={avg_loss} (threshold={threshold})")
    avg_loss


# ============================================================================
# Korean Accuracy Validation
# ============================================================================

fn validate_korean_accuracy(ext: ExtendedModel, lora_l1: LoRAAdapter, lora_l2: LoRAAdapter, config: TrainConfig) -> f64:
    print("  Checking Korean accuracy...")
    autograd_no_grad_begin()

    var total_accuracy = 0.0
    var num_batches = 0

    for i in 0..5:
        val batch = make_embedding_batch(8, 8, ext.emb, config.output_dim)
        val kor_ids = batch[0]
        val eng_ids = batch[1]
        val mask_h = batch[2]
        val target = batch[3]

        val logits = extended_lora_forward(ext, kor_ids, eng_ids, mask_h, lora_l1, lora_l2)

        val preds = t_argmax(logits, 1, false)
        val target_classes = t_argmax(target, 1, false)

        val diff = t_sub(preds, target_classes)
        val diff_sq = t_mul(diff, diff)
        t_free(diff)
        val denom = t_add_scalar(diff_sq, 1.0)
        t_free(diff_sq)
        val inv = t_pow(denom, -1.0)
        t_free(denom)
        val batch_accuracy = t_mean(inv)
        t_free(inv)

        total_accuracy = total_accuracy + batch_accuracy
        num_batches = num_batches + 1

        t_free(kor_ids)
        t_free(eng_ids)
        t_free(mask_h)
        t_free(target)
        t_free(logits)
        t_free(preds)
        t_free(target_classes)

    autograd_no_grad_end()

    if num_batches == 0:
        return 0.0
    val accuracy = total_accuracy / num_batches
    print("  Korean accuracy: {accuracy}")
    accuracy


# ============================================================================
# Exam Accuracy Validation
# ============================================================================

fn validate_exam_accuracy(ext: ExtendedModel, lora_l1: LoRAAdapter, lora_l2: LoRAAdapter, config: TrainConfig) -> f64:
    print("  Checking exam accuracy...")
    val accuracy = validate_korean_accuracy(ext, lora_l1, lora_l2, config)
    accuracy


# ============================================================================
# Per-Layer English Retention Check
# ============================================================================

fn validate_per_layer_retention(ext: ExtendedModel, config: TrainConfig) -> bool:
    print("  Checking per-layer English retention...")
    val accuracy = validate_accuracy(ext.base, config)
    val threshold = 0.97
    val passed = accuracy >= threshold
    if passed:
        print("  Per-layer retention: {accuracy} >= {threshold} PASS")
    else:
        print("  Per-layer retention: {accuracy} < {threshold} FAIL")
    passed


# ============================================================================
# Comprehensive Extended Validation (Phases 3-6)
# ============================================================================

fn validate_all_phases_extended(ext: ExtendedModel, lora_l1: LoRAAdapter, lora_l2: LoRAAdapter, current_phase: i64):
    print("")
    print("-" * 70)
    print("EXTENDED VALIDATION AFTER PHASE {current_phase}")
    print("-" * 70)

    val threshold = 100.0

    val r_base = validate_model(ext.base, "Base model (phases 0-2 merged)", threshold)

    if current_phase >= 3:
        val r3 = validate_extended_model(ext, lora_l1, lora_l2, "Phase 3: Embedding training", threshold)

    if current_phase >= 4:
        val r4 = validate_extended_model(ext, lora_l1, lora_l2, "Phase 4: Korean text", threshold)

    if current_phase >= 5:
        val r5 = validate_extended_model(ext, lora_l1, lora_l2, "Phase 5: Korean translation", threshold)

    if current_phase >= 6:
        val r6 = validate_extended_model(ext, lora_l1, lora_l2, "Phase 6: Reasoning", threshold)

    val config = TrainConfig.default_config()
    val retained = check_english_retention(ext.base, config)

    print("-" * 70)
    print("")
