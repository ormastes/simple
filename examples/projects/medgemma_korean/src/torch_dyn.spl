# MedGemma Torch Dynamic FFI Helper
#
# Self-contained dynamic FFI wrapper for libtorch operations.
# Bypasses DynLoader and calls spl_dlopen/spl_dlsym/spl_wffi_call_i64 directly.
#
# Usage: import needed functions via `use src.torch_dyn.{...}`

extern fn spl_dlopen(path: text) -> i64
extern fn spl_dlsym(handle: i64, name: text) -> i64
extern fn spl_wffi_call_i64(fptr: i64, args: [i64], nargs: i64) -> i64
extern fn spl_f64_to_bits(f: f64) -> i64
extern fn spl_bits_to_f64(bits: i64) -> f64
extern fn rt_env_get(key: text) -> text

# ============================================================================
# Library Handle (module-level state)
# ============================================================================

var _torch_lib: i64 = 0

fn _ensure_torch() -> i64:
    if _torch_lib != 0:
        return _torch_lib
    val base = rt_env_get("SIMPLE_SFFI_PATH") ?? "build"
    var path = "{base}/libspl_torch.so"
    if base == "":
        path = "build/libspl_torch.so"
    _torch_lib = spl_dlopen(path)
    if _torch_lib == 0:
        print "FATAL: Cannot open {path}"
        print "  Build with: bash scripts/build/build-torch-ffi.sh"
    _torch_lib

fn _sym(name: text) -> i64:
    spl_dlsym(_ensure_torch(), name)

fn _c0(name: text) -> i64:
    val f = _sym(name)
    spl_wffi_call_i64(f, [], 0)

fn _c1(name: text, a0: i64) -> i64:
    val f = _sym(name)
    var args: [i64] = []
    args.push(a0)
    spl_wffi_call_i64(f, args, 1)

fn _c2(name: text, a0: i64, a1: i64) -> i64:
    val f = _sym(name)
    var args: [i64] = []
    args.push(a0)
    args.push(a1)
    spl_wffi_call_i64(f, args, 2)

fn _c3(name: text, a0: i64, a1: i64, a2: i64) -> i64:
    val f = _sym(name)
    var args: [i64] = []
    args.push(a0)
    args.push(a1)
    args.push(a2)
    spl_wffi_call_i64(f, args, 3)

fn _c4(name: text, a0: i64, a1: i64, a2: i64, a3: i64) -> i64:
    val f = _sym(name)
    var args: [i64] = []
    args.push(a0)
    args.push(a1)
    args.push(a2)
    args.push(a3)
    spl_wffi_call_i64(f, args, 4)

fn _c5(name: text, a0: i64, a1: i64, a2: i64, a3: i64, a4: i64) -> i64:
    val f = _sym(name)
    var args: [i64] = []
    args.push(a0)
    args.push(a1)
    args.push(a2)
    args.push(a3)
    args.push(a4)
    spl_wffi_call_i64(f, args, 5)

# ============================================================================
# Library Information
# ============================================================================

fn torch_available() -> bool:
    _c0("rt_torch_available") != 0

fn cuda_available() -> bool:
    _c0("rt_torch_cuda_available") != 0

# ============================================================================
# Tensor Creation (fixed-dimension variants)
# ============================================================================

fn tensor_zeros_1d(d0: i64) -> i64:
    _c1("rt_torch_tensor_zeros_1d", d0)

fn tensor_zeros_2d(d0: i64, d1: i64) -> i64:
    _c2("rt_torch_tensor_zeros_2d", d0, d1)

fn tensor_ones_1d(d0: i64) -> i64:
    _c1("rt_torch_tensor_ones_1d", d0)

fn tensor_ones_2d(d0: i64, d1: i64) -> i64:
    _c2("rt_torch_tensor_ones_2d", d0, d1)

fn tensor_randn_1d(d0: i64) -> i64:
    _c1("rt_torch_tensor_randn_1d", d0)

fn tensor_randn_2d(d0: i64, d1: i64) -> i64:
    _c2("rt_torch_tensor_randn_2d", d0, d1)

fn tensor_randn_3d(d0: i64, d1: i64, d2: i64) -> i64:
    _c3("rt_torch_tensor_randn_3d", d0, d1, d2)

fn tensor_rand_2d(d0: i64, d1: i64) -> i64:
    _c2("rt_torch_tensor_rand_2d", d0, d1)

fn tensor_full_1d(d0: i64, value: f64) -> i64:
    _c2("rt_torch_tensor_full_1d", d0, spl_f64_to_bits(value))

fn tensor_full_2d(d0: i64, d1: i64, value: f64) -> i64:
    _c3("rt_torch_tensor_full_2d", d0, d1, spl_f64_to_bits(value))

fn tensor_eye(n: i64) -> i64:
    _c1("rt_torch_tensor_eye", n)

fn tensor_arange_int(start: i64, end_val: i64, step: i64) -> i64:
    _c3("rt_torch_tensor_arange_int", start, end_val, step)

fn tensor_zeros_int_1d(d0: i64) -> i64:
    _c1("rt_torch_tensor_zeros_int_1d", d0)

fn tensor_zeros_int_2d(d0: i64, d1: i64) -> i64:
    _c2("rt_torch_tensor_zeros_int_2d", d0, d1)

fn tensor_full_int_1d(d0: i64, value: i64) -> i64:
    _c2("rt_torch_tensor_full_int_1d", d0, value)

fn tensor_full_int_2d(d0: i64, d1: i64, value: i64) -> i64:
    _c3("rt_torch_tensor_full_int_2d", d0, d1, value)

# ============================================================================
# Element-wise Arithmetic
# ============================================================================

fn t_add(a: i64, b: i64) -> i64:
    _c2("rt_torch_torchtensor_add", a, b)

fn t_sub(a: i64, b: i64) -> i64:
    _c2("rt_torch_torchtensor_sub", a, b)

fn t_mul(a: i64, b: i64) -> i64:
    _c2("rt_torch_torchtensor_mul", a, b)

fn t_div(a: i64, b: i64) -> i64:
    _c2("rt_torch_torchtensor_div", a, b)

fn t_neg(a: i64) -> i64:
    _c1("rt_torch_torchtensor_neg", a)

fn t_abs(a: i64) -> i64:
    _c1("rt_torch_torchtensor_abs", a)

fn t_sqrt(a: i64) -> i64:
    _c1("rt_torch_torchtensor_sqrt", a)

fn t_exp(a: i64) -> i64:
    _c1("rt_torch_torchtensor_exp", a)

fn t_log(a: i64) -> i64:
    _c1("rt_torch_torchtensor_log", a)

fn t_add_scalar(a: i64, scalar: f64) -> i64:
    _c2("rt_torch_torchtensor_add_scalar_bits", a, spl_f64_to_bits(scalar))

fn t_mul_scalar(a: i64, scalar: f64) -> i64:
    _c2("rt_torch_torchtensor_mul_scalar_bits", a, spl_f64_to_bits(scalar))

fn t_pow(a: i64, exponent: f64) -> i64:
    _c2("rt_torch_torchtensor_pow_bits", a, spl_f64_to_bits(exponent))

# ============================================================================
# Activations
# ============================================================================

fn t_relu(a: i64) -> i64:
    _c1("rt_torch_torchtensor_relu", a)

fn t_sigmoid(a: i64) -> i64:
    _c1("rt_torch_torchtensor_sigmoid", a)

fn t_tanh(a: i64) -> i64:
    _c1("rt_torch_torchtensor_tanh", a)

fn t_gelu(a: i64) -> i64:
    _c1("rt_torch_torchtensor_gelu", a)

fn t_softmax(a: i64, dim: i64) -> i64:
    _c2("rt_torch_torchtensor_softmax", a, dim)

fn t_log_softmax(a: i64, dim: i64) -> i64:
    _c2("rt_torch_torchtensor_log_softmax", a, dim)

# ============================================================================
# Linear Algebra
# ============================================================================

fn t_matmul(a: i64, b: i64) -> i64:
    _c2("rt_torch_torchtensor_matmul", a, b)

fn t_dot(a: i64, b: i64) -> i64:
    _c2("rt_torch_torchtensor_dot", a, b)

fn t_transpose(a: i64, d0: i64, d1: i64) -> i64:
    _c3("rt_torch_torchtensor_transpose", a, d0, d1)

fn t_t(a: i64) -> i64:
    _c1("rt_torch_torchtensor_t", a)

# ============================================================================
# Reductions
# ============================================================================

fn t_sum_dim(a: i64, dim: i64, keepdim: bool) -> i64:
    var kd = 0
    if keepdim:
        kd = 1
    _c3("rt_torch_torchtensor_sum_dim", a, dim, kd)

fn t_mean_dim(a: i64, dim: i64, keepdim: bool) -> i64:
    var kd = 0
    if keepdim:
        kd = 1
    _c3("rt_torch_torchtensor_mean_dim", a, dim, kd)

fn t_max_dim(a: i64, dim: i64, keepdim: bool) -> i64:
    var kd = 0
    if keepdim:
        kd = 1
    _c3("rt_torch_torchtensor_max_dim", a, dim, kd)

fn t_min_dim(a: i64, dim: i64, keepdim: bool) -> i64:
    var kd = 0
    if keepdim:
        kd = 1
    _c3("rt_torch_torchtensor_min_dim", a, dim, kd)

fn t_argmax(a: i64, dim: i64, keepdim: bool) -> i64:
    var kd = 0
    if keepdim:
        kd = 1
    _c3("rt_torch_torchtensor_argmax", a, dim, kd)

fn t_argmin(a: i64, dim: i64, keepdim: bool) -> i64:
    var kd = 0
    if keepdim:
        kd = 1
    _c3("rt_torch_torchtensor_argmin", a, dim, kd)

# f64-returning reductions
fn t_sum(a: i64) -> f64:
    spl_bits_to_f64(_c1("rt_torch_torchtensor_sum_bits", a))

fn t_mean(a: i64) -> f64:
    spl_bits_to_f64(_c1("rt_torch_torchtensor_mean_bits", a))

fn t_norm(a: i64) -> f64:
    spl_bits_to_f64(_c1("rt_torch_torchtensor_norm_bits", a))

# ============================================================================
# Shape Operations
# ============================================================================

fn t_ndim(a: i64) -> i64:
    _c1("rt_torch_torchtensor_ndim", a)

fn t_numel(a: i64) -> i64:
    _c1("rt_torch_torchtensor_numel", a)

fn t_shape_dim(a: i64, dim: i64) -> i64:
    _c2("rt_torch_torchtensor_shape_dim", a, dim)

fn t_reshape_1d(a: i64, d0: i64) -> i64:
    _c2("rt_torch_torchtensor_reshape_1d", a, d0)

fn t_reshape_2d(a: i64, d0: i64, d1: i64) -> i64:
    _c3("rt_torch_torchtensor_reshape_2d", a, d0, d1)

fn t_unsqueeze(a: i64, dim: i64) -> i64:
    _c2("rt_torch_torchtensor_unsqueeze", a, dim)

fn t_squeeze(a: i64) -> i64:
    _c1("rt_torch_torchtensor_squeeze", a)

fn t_squeeze_dim(a: i64, dim: i64) -> i64:
    _c2("rt_torch_torchtensor_squeeze_dim", a, dim)

fn t_flatten(a: i64) -> i64:
    _c1("rt_torch_torchtensor_flatten", a)

fn t_contiguous(a: i64) -> i64:
    _c1("rt_torch_torchtensor_contiguous", a)

# ============================================================================
# Indexing / Slicing
# ============================================================================

fn t_slice(a: i64, dim: i64, start: i64, end_idx: i64, step: i64) -> i64:
    _c5("rt_torch_torchtensor_slice", a, dim, start, end_idx, step)

fn t_index_select(a: i64, dim: i64, indices: i64) -> i64:
    _c3("rt_torch_torchtensor_index_select", a, dim, indices)

fn t_gather(a: i64, dim: i64, indices: i64) -> i64:
    _c3("rt_torch_torchtensor_gather", a, dim, indices)

fn t_cat_2(t0: i64, t1: i64, dim: i64) -> i64:
    _c3("rt_torch_torchtensor_cat_2", t0, t1, dim)

fn t_stack_2(t0: i64, t1: i64, dim: i64) -> i64:
    _c3("rt_torch_torchtensor_stack_2", t0, t1, dim)

# ============================================================================
# NN Operations
# ============================================================================

fn nn_linear(input: i64, weight: i64, bias: i64) -> i64:
    _c3("rt_torch_nn_linear", input, weight, bias)

fn nn_embedding(input: i64, weight: i64) -> i64:
    _c2("rt_torch_nn_embedding", input, weight)

# ============================================================================
# Loss Functions (return f64)
# ============================================================================

fn nn_mse_loss(input: i64, target: i64) -> f64:
    spl_bits_to_f64(_c2("rt_torch_nn_mse_loss_bits", input, target))

fn nn_cross_entropy(input: i64, target: i64) -> f64:
    spl_bits_to_f64(_c2("rt_torch_nn_cross_entropy_bits", input, target))

# ============================================================================
# Autograd
# ============================================================================

fn autograd_set_requires_grad(a: i64, requires: bool):
    var rg = 0
    if requires:
        rg = 1
    _c2("rt_torch_autograd_set_requires_grad", a, rg)

fn autograd_requires_grad(a: i64) -> bool:
    _c1("rt_torch_autograd_requires_grad", a) != 0

fn autograd_grad(a: i64) -> i64:
    _c1("rt_torch_autograd_grad", a)

fn autograd_backward(a: i64):
    _c1("rt_torch_autograd_backward", a)

fn autograd_zero_grad(a: i64):
    _c1("rt_torch_autograd_zero_grad", a)

fn autograd_detach(a: i64) -> i64:
    _c1("rt_torch_autograd_detach", a)

fn autograd_no_grad_begin():
    _c0("rt_torch_autograd_no_grad_begin")

fn autograd_no_grad_end():
    _c0("rt_torch_autograd_no_grad_end")

# ============================================================================
# Device Management
# ============================================================================

fn t_cuda(a: i64, device_id: i64) -> i64:
    _c2("rt_torch_torchtensor_cuda", a, device_id)

fn t_cpu(a: i64) -> i64:
    _c1("rt_torch_torchtensor_cpu", a)

fn t_is_cuda(a: i64) -> bool:
    _c1("rt_torch_torchtensor_is_cuda", a) != 0

fn t_clone(a: i64) -> i64:
    _c1("rt_torch_torchtensor_clone", a)

# ============================================================================
# Memory Management
# ============================================================================

fn t_free(a: i64):
    _c1("rt_torch_torchtensor_free", a)

# NOTE: cuda_memory_allocated takes int32_t in C but we pass i64 via WFFI.
# On x86_64 this works for small values (lower 32 bits match).
# Returns 0 if CUDA not initialized.
fn cuda_memory_allocated(device_id: i64) -> i64:
    if not cuda_available():
        return 0
    _c1("rt_torch_cuda_memory_allocated", device_id)

fn cuda_max_memory_allocated(device_id: i64) -> i64:
    if not cuda_available():
        return 0
    _c1("rt_torch_cuda_max_memory_allocated", device_id)

fn cuda_empty_cache():
    _c0("rt_torch_cuda_empty_cache")

# ============================================================================
# Trig (for RoPE)
# ============================================================================

fn t_sin(a: i64) -> i64:
    _c1("rt_torch_torchtensor_sin", a)

fn t_cos(a: i64) -> i64:
    _c1("rt_torch_torchtensor_cos", a)

# ============================================================================
# Type Casting
# ============================================================================

fn t_to_float(a: i64) -> i64:
    _c1("rt_torch_torchtensor_to_float", a)

fn t_to_int(a: i64) -> i64:
    _c1("rt_torch_torchtensor_to_int", a)

fn t_to_float32(a: i64) -> i64:
    _c1("rt_torch_torchtensor_to_float32", a)

# ============================================================================
# Exports
# ============================================================================

export torch_available, cuda_available
export tensor_zeros_1d, tensor_zeros_2d
export tensor_ones_1d, tensor_ones_2d
export tensor_randn_1d, tensor_randn_2d, tensor_randn_3d
export tensor_rand_2d
export tensor_full_1d, tensor_full_2d
export tensor_eye
export tensor_arange_int
export tensor_zeros_int_1d, tensor_zeros_int_2d
export tensor_full_int_1d, tensor_full_int_2d
export t_add, t_sub, t_mul, t_div, t_neg, t_abs, t_sqrt, t_exp, t_log
export t_add_scalar, t_mul_scalar, t_pow
export t_relu, t_sigmoid, t_tanh, t_gelu, t_softmax, t_log_softmax
export t_matmul, t_dot, t_transpose, t_t
export t_sum_dim, t_mean_dim, t_max_dim, t_min_dim, t_argmax, t_argmin
export t_sum, t_mean, t_norm
export t_ndim, t_numel, t_shape_dim
export t_reshape_1d, t_reshape_2d
export t_unsqueeze, t_squeeze, t_squeeze_dim, t_flatten, t_contiguous
export t_slice, t_index_select, t_gather, t_cat_2, t_stack_2
export nn_linear, nn_embedding
export nn_mse_loss, nn_cross_entropy
export autograd_set_requires_grad, autograd_requires_grad
export autograd_grad, autograd_backward, autograd_zero_grad, autograd_detach
export autograd_no_grad_begin, autograd_no_grad_end
export t_cuda, t_cpu, t_is_cuda, t_clone
export t_free
export cuda_memory_allocated, cuda_max_memory_allocated, cuda_empty_cache
export t_sin, t_cos
export t_to_float, t_to_int, t_to_float32
export spl_f64_to_bits, spl_bits_to_f64
