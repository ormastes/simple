# Elemental Siege - Element System
#
# Ported from C# ElementType.cs, InteractionMatrix.cs, ElementInteraction.cs
# Categories, element data, interaction results, and damage lookup matrix.

# ============================================================================
# ElementCategory Enum
# ============================================================================

"""Element category used for interaction lookups and effect resolution."""
enum ElementCategory:
    Stone       # Earthen, defensive (0)
    Fire        # Burning, aggressive (1)
    Ice         # Freezing, slowing (2)
    Lightning   # Electric, chain (3)
    Wind        # Mobile, knockback (4)
    Crystal     # Prismatic, reflecting (5)
    Gravity     # Warping, pulling (6)
    Void        # Nullifying, consuming (7)

impl ElementCategory:
    """Convert to i32 index."""
    fn to_i32() -> i32:
        match self:
            ElementCategory.Stone:     0
            ElementCategory.Fire:      1
            ElementCategory.Ice:       2
            ElementCategory.Lightning: 3
            ElementCategory.Wind:      4
            ElementCategory.Crystal:   5
            ElementCategory.Gravity:   6
            ElementCategory.Void:      7

    """Convert from i32. Returns ElementCategory.Stone for unknown values."""
    static fn from_i32(value: i32) -> ElementCategory:
        match value:
            0: ElementCategory.Stone
            1: ElementCategory.Fire
            2: ElementCategory.Ice
            3: ElementCategory.Lightning
            4: ElementCategory.Wind
            5: ElementCategory.Crystal
            6: ElementCategory.Gravity
            7: ElementCategory.Void
            _: ElementCategory.Stone

    """Get display name as text."""
    fn to_string() -> text:
        match self:
            ElementCategory.Stone:     "Stone"
            ElementCategory.Fire:      "Fire"
            ElementCategory.Ice:       "Ice"
            ElementCategory.Lightning: "Lightning"
            ElementCategory.Wind:      "Wind"
            ElementCategory.Crystal:   "Crystal"
            ElementCategory.Gravity:   "Gravity"
            ElementCategory.Void:      "Void"

# ============================================================================
# ElementType Data Class
# ============================================================================

"""Defines an elemental type with gameplay properties.

Ported from ElementType ScriptableObject. Visual/audio fields omitted
(handled by the engine asset layer). Gameplay fields retained.
"""
struct ElementType:
    category:        ElementCategory
    name:            text
    base_damage:     f32
    speed_modifier:  f32
    radius:          f32
    special_ability: text

impl ElementType:
    """Stone: heavy, slow, area denial."""
    static fn stone() -> ElementType:
        ElementType(
            category:        ElementCategory.Stone,
            name:            "Stone",
            base_damage:     15.0,
            speed_modifier:  0.7,
            radius:          4.0,
            special_ability: "Tremor"
        )

    """Fire: high damage, burning DoT."""
    static fn fire() -> ElementType:
        ElementType(
            category:        ElementCategory.Fire,
            name:            "Fire",
            base_damage:     20.0,
            speed_modifier:  1.2,
            radius:          3.0,
            special_ability: "Ignite"
        )

    """Ice: moderate damage, freeze slow."""
    static fn ice() -> ElementType:
        ElementType(
            category:        ElementCategory.Ice,
            name:            "Ice",
            base_damage:     12.0,
            speed_modifier:  1.0,
            radius:          3.5,
            special_ability: "Freeze"
        )

    """Lightning: fast, chain between targets."""
    static fn lightning() -> ElementType:
        ElementType(
            category:        ElementCategory.Lightning,
            name:            "Lightning",
            base_damage:     18.0,
            speed_modifier:  1.8,
            radius:          2.0,
            special_ability: "Chain"
        )

    """Wind: low damage, strong knockback."""
    static fn wind() -> ElementType:
        ElementType(
            category:        ElementCategory.Wind,
            name:            "Wind",
            base_damage:     8.0,
            speed_modifier:  1.5,
            radius:          5.0,
            special_ability: "Gust"
        )

    """Crystal: medium damage, reflects projectiles."""
    static fn crystal() -> ElementType:
        ElementType(
            category:        ElementCategory.Crystal,
            name:            "Crystal",
            base_damage:     14.0,
            speed_modifier:  0.9,
            radius:          2.5,
            special_ability: "Refract"
        )

    """Gravity: warps trajectories, pulls enemies."""
    static fn gravity() -> ElementType:
        ElementType(
            category:        ElementCategory.Gravity,
            name:            "Gravity",
            base_damage:     16.0,
            speed_modifier:  0.8,
            radius:          6.0,
            special_ability: "Singularity"
        )

    """Void: nullifies buffs, consumes other elements."""
    static fn void_type() -> ElementType:
        ElementType(
            category:        ElementCategory.Void,
            name:            "Void",
            base_damage:     25.0,
            speed_modifier:  1.0,
            radius:          3.0,
            special_ability: "Annihilate"
        )

# ============================================================================
# InteractionResult Enum
# ============================================================================

"""Result of two elements interacting."""
enum InteractionResult:
    Neutral    # No special interaction — base damage only
    Weak       # Attenuated — elements partially cancel
    Strong     # Amplified — elements synergize
    Absorb     # Defender absorbs attacker — zero damage
    Amplify    # Chain reaction — bonus area effect
    Combo      # Unique combo effect triggered

impl InteractionResult:
    """Get the default damage multiplier for this result."""
    fn default_multiplier() -> f32:
        match self:
            InteractionResult.Neutral: 1.0
            InteractionResult.Weak:    0.5
            InteractionResult.Strong:  1.5
            InteractionResult.Absorb:  0.0
            InteractionResult.Amplify: 2.0
            InteractionResult.Combo:   1.75

    """Get result name as text."""
    fn to_string() -> text:
        match self:
            InteractionResult.Neutral: "Neutral"
            InteractionResult.Weak:    "Weak"
            InteractionResult.Strong:  "Strong"
            InteractionResult.Absorb:  "Absorb"
            InteractionResult.Amplify: "Amplify"
            InteractionResult.Combo:   "Combo"

# ============================================================================
# ElementInteraction Data Class
# ============================================================================

"""Defines the result of two elements interacting — combo name, multiplier."""
struct ElementInteraction:
    element_a:        ElementCategory
    element_b:        ElementCategory
    result:           InteractionResult
    result_effect:    ElementCategory
    combo_name:       text
    combo_description: text
    damage_multiplier: f32

# ============================================================================
# InteractionMatrix — Flat lookup via match
# ============================================================================

"""Return the canonical ordered pair (lower index first) for commutative lookup."""
fn make_key(a: ElementCategory, b: ElementCategory) -> (i32, i32):
    val ai = a.to_i32()
    val bi = b.to_i32()
    if ai <= bi:
        (ai, bi)
    else:
        (bi, ai)

"""Get the interaction result for two element categories.

Lookup is commutative: get_interaction(Fire, Ice) == get_interaction(Ice, Fire).
Returns InteractionResult.Neutral when no special interaction is defined.
"""
fn get_interaction(a: ElementCategory, b: ElementCategory) -> InteractionResult:
    val key = make_key(a, b)
    val lo = key.0
    val hi = key.1
    # Stone=0  Fire=1  Ice=2  Lightning=3  Wind=4  Crystal=5  Gravity=6  Void=7
    if lo == 0 and hi == 1:   # Stone + Fire  → Fire melts stone (Strong)
        return InteractionResult.Strong
    if lo == 0 and hi == 2:   # Stone + Ice   → Ice coats stone (Weak)
        return InteractionResult.Weak
    if lo == 0 and hi == 3:   # Stone + Lightning → Grounds bolt (Absorb)
        return InteractionResult.Absorb
    if lo == 0 and hi == 4:   # Stone + Wind  → Wind scatters rock (Strong)
        return InteractionResult.Strong
    if lo == 0 and hi == 5:   # Stone + Crystal → Crystalline ore (Combo)
        return InteractionResult.Combo
    if lo == 0 and hi == 6:   # Stone + Gravity → Crushing pull (Amplify)
        return InteractionResult.Amplify
    if lo == 0 and hi == 7:   # Stone + Void  → Void absorbs stone (Absorb)
        return InteractionResult.Absorb
    if lo == 1 and hi == 2:   # Fire + Ice    → Steam (Combo)
        return InteractionResult.Combo
    if lo == 1 and hi == 3:   # Fire + Lightning → Plasma (Amplify)
        return InteractionResult.Amplify
    if lo == 1 and hi == 4:   # Fire + Wind   → Firestorm (Strong)
        return InteractionResult.Strong
    if lo == 1 and hi == 5:   # Fire + Crystal → Prism shatter (Weak)
        return InteractionResult.Weak
    if lo == 1 and hi == 6:   # Fire + Gravity → Fire warps space (Combo)
        return InteractionResult.Combo
    if lo == 1 and hi == 7:   # Fire + Void   → Void extinguishes (Absorb)
        return InteractionResult.Absorb
    if lo == 2 and hi == 3:   # Ice + Lightning → Frozen conduit (Combo)
        return InteractionResult.Combo
    if lo == 2 and hi == 4:   # Ice + Wind    → Blizzard (Amplify)
        return InteractionResult.Amplify
    if lo == 2 and hi == 5:   # Ice + Crystal → Crystal frost (Strong)
        return InteractionResult.Strong
    if lo == 2 and hi == 6:   # Ice + Gravity → Glacial crush (Strong)
        return InteractionResult.Strong
    if lo == 2 and hi == 7:   # Ice + Void    → Void absorbs cold (Absorb)
        return InteractionResult.Absorb
    if lo == 3 and hi == 4:   # Lightning + Wind → Thunderstorm (Amplify)
        return InteractionResult.Amplify
    if lo == 3 and hi == 5:   # Lightning + Crystal → Prismatic arc (Combo)
        return InteractionResult.Combo
    if lo == 3 and hi == 6:   # Lightning + Gravity → Disrupted field (Weak)
        return InteractionResult.Weak
    if lo == 3 and hi == 7:   # Lightning + Void → Void grounds (Absorb)
        return InteractionResult.Absorb
    if lo == 4 and hi == 5:   # Wind + Crystal → Resonant shards (Strong)
        return InteractionResult.Strong
    if lo == 4 and hi == 6:   # Wind + Gravity → Vortex (Combo)
        return InteractionResult.Combo
    if lo == 4 and hi == 7:   # Wind + Void   → Void disperses wind (Weak)
        return InteractionResult.Weak
    if lo == 5 and hi == 6:   # Crystal + Gravity → Fractured space (Combo)
        return InteractionResult.Combo
    if lo == 5 and hi == 7:   # Crystal + Void → Void shatters crystal (Strong)
        return InteractionResult.Strong
    if lo == 6 and hi == 7:   # Gravity + Void → Collapse (Amplify)
        return InteractionResult.Amplify
    InteractionResult.Neutral

"""Get the damage multiplier for two interacting element categories.

Uses the interaction result's default multiplier.
"""
fn get_damage_multiplier(a: ElementCategory, b: ElementCategory) -> f32:
    val result = get_interaction(a, b)
    result.default_multiplier()

"""Check whether two element categories produce a combo effect."""
fn has_combo(a: ElementCategory, b: ElementCategory) -> bool:
    val result = get_interaction(a, b)
    result.to_i32() == InteractionResult.Combo.to_i32()

impl InteractionResult:
    fn to_i32() -> i32:
        match self:
            InteractionResult.Neutral: 0
            InteractionResult.Weak:    1
            InteractionResult.Strong:  2
            InteractionResult.Absorb:  3
            InteractionResult.Amplify: 4
            InteractionResult.Combo:   5
