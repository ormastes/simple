# Elemental Siege - UI State
#
# Tracks which screen is active and the values shown in the HUD.
# No inheritance — plain data + functions.

# ============================================================================
# Enums
# ============================================================================

enum UIScreen:
    None
    MainMenu
    LevelSelect
    HUD
    PauseMenu
    LevelComplete
    LevelFailed
    Settings

# ============================================================================
# Data
# ============================================================================

class UIState:
    active_screen: UIScreen
    previous_screen: UIScreen
    hud_visible: bool
    score_display: i32
    orbs_display: i32
    time_display: f32
    stars_display: i32

# ============================================================================
# Constructor
# ============================================================================

fn create_ui_state() -> UIState:
    UIState(
        active_screen: UIScreen.None,
        previous_screen: UIScreen.None,
        hud_visible: false,
        score_display: 0,
        orbs_display: 0,
        time_display: 0.0,
        stars_display: 0
    )

# ============================================================================
# Screen management
# ============================================================================

fn show_screen(state: UIState, screen: UIScreen):
    state.previous_screen = state.active_screen
    state.active_screen = screen
    state.hud_visible = screen == UIScreen.HUD

# ============================================================================
# HUD updates
# ============================================================================

fn update_hud(state: UIState, score: i32, orbs: i32, time: f32):
    state.score_display = score
    state.orbs_display = orbs
    state.time_display = time

fn show_level_result(state: UIState, stars: i32, score: i32):
    state.stars_display = stars
    state.score_display = score
    state.hud_visible = false
