# Simple Game - Spinning Cube Demo
#
# Minimal game demonstrating the Game3D library.
# Compiles to WASM → runs identically in Unity, Godot, and Unreal.

use std.nogc_async_mut.game3d.*

# ============================================================================
# Game State
# ============================================================================

var cube: Entity = Entity.invalid()
var camera_entity: Entity = Entity.invalid()
var light_entity: Entity = Entity.invalid()
var rotation_speed: f32 = 1.0
var time_elapsed: f32 = 0.0

# ============================================================================
# Game Lifecycle
# ============================================================================

fn init() -> i32:
    """Called once when the game starts."""
    debug.log("Simple Game initializing...")

    # Create a spinning cube
    cube = render.create_primitive(PrimitiveType.Cube)
    cube.set_position(Vec3(0.0, 1.0, 0.0))

    # Set cube material (red)
    val mat = Material.create()
    mat.set_color(0.8, 0.2, 0.1, 1.0)
    render.set_material(cube, mat)

    # Add physics
    physics.add_rigidbody(cube, BodyType.Kinematic)
    physics.add_box_collider(cube, Vec3(0.5, 0.5, 0.5))

    # Create a ground plane
    val ground = render.create_primitive(PrimitiveType.Plane)
    ground.set_position(Vec3(0.0, 0.0, 0.0))
    ground.set_scale(Vec3(10.0, 1.0, 10.0))
    val ground_mat = Material.create()
    ground_mat.set_color(0.3, 0.6, 0.3, 1.0)
    render.set_material(ground, ground_mat)
    physics.add_rigidbody(ground, BodyType.Static)
    physics.add_box_collider(ground, Vec3(5.0, 0.01, 5.0))

    # Create a directional light
    val light = Light.create(LightType.Directional)
    light.set_color(1.0, 0.95, 0.8)
    light.set_intensity(1.0)

    # Create camera
    val cam = Camera.create()
    cam.set_fov(60.0)
    cam.set_active(true)

    # Position camera to look at cube
    camera_entity = Entity(id: cam.id)
    camera_entity.set_position(Vec3(3.0, 3.0, 3.0))
    camera_entity.look_at(Vec3(0.0, 1.0, 0.0))

    debug.log("Simple Game initialized!")
    0

fn update(dt: f32):
    """Called every frame."""
    time_elapsed = time_elapsed + dt

    # Rotate the cube
    cube.rotate(Vec3.up(), rotation_speed * dt)

    # Pulse scale with sine wave
    val pulse = 1.0 + (time_elapsed * 2.0).sin() * 0.1
    cube.set_scale(Vec3(pulse, pulse, pulse))

    # Handle input
    if input.is_key_pressed(KeyCode.Space):
        rotation_speed = 5.0
    else:
        rotation_speed = 1.0

    # WASD camera movement
    val move_dir = input.get_wasd_direction()
    if move_dir.length_squared() > 0.0:
        val move_speed = 5.0 * dt
        val cam_forward = camera_entity.get_forward()
        val cam_right = camera_entity.get_right()
        val movement = cam_forward.scale(move_dir.y * move_speed).add(cam_right.scale(move_dir.x * move_speed))
        camera_entity.translate(movement)

    # Process collision events
    val events = game_loop.get_event_queue()
    var i = 0
    while i < events.count():
        val event = events.get(i)
        if event.event_type.to_i32() == GameEventType.CollisionEnter.to_i32():
            debug.log("Collision detected!")
        i = i + 1

    # Debug visualization
    debug.draw_line(Vec3.zero(), Vec3.up().scale(2.0), Vec3(0.0, 1.0, 0.0))

fn shutdown():
    """Called when the game shuts down."""
    debug.log("Simple Game shutting down...")
    cube.destroy()

# ============================================================================
# Register callbacks
# ============================================================================

game_loop.set_init_callback(init)
game_loop.set_update_callback(update)
game_loop.set_shutdown_callback(shutdown)

