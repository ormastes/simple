# RTL Simulation Engine
#
# Feature-dimension signal tracking and backend helpers for the MDSOC RTL tree.

use std.io_runtime.{file_exists, env_get, cwd, process_run}
use rtl.types.{SimBackendKind, Rv32Checkpoint, BackendRunStats, VerilatorBackendConfig}

struct RtlSignalState:
    name: text
    width: i64
    value: i64
    is_register: bool

impl RtlSignalState:
    static fn new(name: text, width: i64, value: i64, is_register: bool) -> RtlSignalState:
        RtlSignalState(name: name, width: width, value: value, is_register: is_register)

struct RtlTraceSample:
    cycle: i64
    signal_name: text
    value: i64

impl RtlTraceSample:
    static fn new(cycle: i64, signal_name: text, value: i64) -> RtlTraceSample:
        RtlTraceSample(cycle: cycle, signal_name: signal_name, value: value)

    fn to_text() -> text:
        "{self.cycle} {self.signal_name}=0x{self.value}"

class RtlSimEngine:
    signals: [RtlSignalState]
    trace: [RtlTraceSample]
    trace_enabled: bool
    current_cycle: i64

impl RtlSimEngine:
    static fn new() -> RtlSimEngine:
        RtlSimEngine(signals: [], trace: [], trace_enabled: false, current_cycle: 0)

    me define_signal(name: text, width: i64, initial_value: i64, is_register: bool):
        if self._find_signal_index(name) >= 0:
            self.set_signal(name, initial_value)
            return
        self.signals.push(RtlSignalState.new(name, width, initial_value, is_register))

    me set_signal(name: text, value: i64):
        val idx = self._find_signal_index(name)
        if idx >= 0:
            val signal = self.signals[idx]
            val masked = self._mask_to_width(value, signal.width)
            self.signals[idx] = RtlSignalState.new(signal.name, signal.width, masked, signal.is_register)
            return
        self.signals.push(RtlSignalState.new(name, 64, value, false))

    fn read_signal(name: text) -> i64?:
        val idx = self._find_signal_index(name)
        if idx >= 0:
            return Some(self.signals[idx].value)
        nil

    me begin_cycle(cycle: i64):
        self.current_cycle = cycle
        self.set_signal("cycle", cycle)

    me enable_trace():
        self.trace_enabled = true

    me disable_trace():
        self.trace_enabled = false

    me clear_trace():
        self.trace = []

    me sample_all():
        if not self.trace_enabled:
            return
        for signal in self.signals:
            self.trace.push(RtlTraceSample.new(self.current_cycle, signal.name, signal.value))

    fn trace_text() -> text:
        var out = ""
        for sample in self.trace:
            if out != "":
                out = out + "\n"
            out = out + sample.to_text()
        out

    fn signal_count() -> i64:
        self.signals.len()

    fn trace_count() -> i64:
        self.trace.len()

    fn _find_signal_index(name: text) -> i64:
        for i in 0..self.signals.len():
            if self.signals[i].name == name:
                return i
        -1

    fn _mask_to_width(value: i64, width: i64) -> i64:
        if width <= 0:
            return 0
        if width >= 64:
            return value
        val mask = (1 << width) - 1
        value & mask

class NativeRtlBackend:
    engine: RtlSimEngine
    last_host_time_ns: i64

impl NativeRtlBackend:
    static fn new() -> NativeRtlBackend:
        var engine = RtlSimEngine.new()
        engine.define_signal("cycle", 64, 0, true)
        engine.define_signal("pc", 32, 0x80000000, true)
        engine.define_signal("retired_pc", 32, 0x80000000, true)
        engine.define_signal("inst_word", 32, 0, false)
        engine.define_signal("a0", 32, 0, true)
        engine.define_signal("sp", 32, 0, true)
        engine.define_signal("halted", 1, 0, true)
        engine.define_signal("mem_reads", 64, 0, false)
        engine.define_signal("mem_writes", 64, 0, false)
        NativeRtlBackend(engine: engine, last_host_time_ns: 0)

    me refresh(checkpoint: Rv32Checkpoint, a0: i64, sp: i64, inst_word: i64, mem_reads: i64, mem_writes: i64):
        self.engine.set_signal("cycle", checkpoint.cycle_count)
        self.engine.set_signal("pc", checkpoint.pc)
        self.engine.set_signal("retired_pc", checkpoint.pc)
        self.engine.set_signal("inst_word", inst_word)
        self.engine.set_signal("a0", a0)
        self.engine.set_signal("sp", sp)
        self.engine.set_signal("halted", if checkpoint.halted: 1 else: 0)
        self.engine.set_signal("mem_reads", mem_reads)
        self.engine.set_signal("mem_writes", mem_writes)

    fn read_signal(name: text) -> i64?:
        self.engine.read_signal(name)

    me begin_cycle(cycle: i64):
        self.engine.begin_cycle(cycle)

    me enable_trace():
        self.engine.enable_trace()

    me disable_trace():
        self.engine.disable_trace()

    me sample_all():
        self.engine.sample_all()

    me record_host_time_ns(host_time_ns: i64):
        self.last_host_time_ns = host_time_ns

    fn waveform_text() -> text:
        self.engine.trace_text()

    fn stats(checkpoint: Rv32Checkpoint) -> BackendRunStats:
        BackendRunStats
            .new(SimBackendKind.NativeRtl, checkpoint.cycle_count, self.engine.signal_count(), self.engine.trace_count(), checkpoint.halted, "")
            .with_host_time(self.last_host_time_ns)

class VerilatorRtkBackend:
    engine: RtlSimEngine
    available: bool
    config: VerilatorBackendConfig?
    status_note: text
    last_host_time_ns: i64

impl VerilatorRtkBackend:
    static fn detect_default() -> VerilatorRtkBackend:
        val selected = Self._find_verilator_executable()
        var engine = RtlSimEngine.new()
        engine.define_signal("cycle", 64, 0, true)
        engine.define_signal("pc", 32, 0x80000000, true)
        engine.define_signal("halted", 1, 1, true)
        engine.define_signal("available", 1, 0, true)
        engine.define_signal("host_ns", 64, 0, false)
        if selected == "":
            return VerilatorRtkBackend(
                engine: engine,
                available: false,
                config: nil,
                status_note: "verilator not configured; set VERILATOR_BIN or install verilator in PATH",
                last_host_time_ns: 0
            )

        val (stdout, stderr, code) = process_run(selected, ["--version"])
        val work_dir = Self._default_work_dir()
        val top_module = Self._default_top_module()
        val trace_path = "{work_dir}/rtk_trace.vcd"
        val config = VerilatorBackendConfig.new(selected, work_dir, top_module, trace_path)
        if code != 0:
            return VerilatorRtkBackend(
                engine: engine,
                available: false,
                config: Some(config),
                status_note: "verilator probe failed: {stderr.trim()}",
                last_host_time_ns: 0
            )

        engine.set_signal("available", 1)
        VerilatorRtkBackend(
            engine: engine,
            available: true,
            config: Some(config),
            status_note: stdout.trim(),
            last_host_time_ns: 0
        )

    me refresh(checkpoint: Rv32Checkpoint):
        self.engine.set_signal("cycle", checkpoint.cycle_count)
        self.engine.set_signal("pc", checkpoint.pc)
        self.engine.set_signal("halted", if checkpoint.halted: 1 else: 0)
        self.engine.set_signal("available", if self.available: 1 else: 0)
        self.engine.set_signal("host_ns", self.last_host_time_ns)

    fn read_signal(name: text) -> i64?:
        self.engine.read_signal(name)

    me record_host_time_ns(host_time_ns: i64):
        self.last_host_time_ns = host_time_ns
        self.engine.set_signal("host_ns", host_time_ns)

    fn status_text() -> text:
        if val Some(config) = self.config:
            return "{self.status_note} {config.to_text()}"
        self.status_note

    fn stats(checkpoint: Rv32Checkpoint) -> BackendRunStats:
        BackendRunStats
            .new(SimBackendKind.RtkVerilator, checkpoint.cycle_count, self.engine.signal_count(), self.engine.trace_count(), checkpoint.halted, self.status_text())
            .with_host_time(self.last_host_time_ns)

    fn _find_verilator_executable() -> text:
        val env_bin = env_get("VERILATOR_BIN")
        if env_bin != "":
            if file_exists(env_bin):
                return env_bin

        val (stdout, stderr, code) = process_run("/bin/sh", ["-c", "which verilator 2>/dev/null"])
        if code == 0:
            val path = stdout.trim()
            if path != "":
                return path
        ""

    fn _default_work_dir() -> text:
        val env_dir = env_get("MLLVM_QEMU_RTL_RTK_DIR")
        if env_dir != "":
            return env_dir
        "{cwd()}/examples/mllvm_qemu_rtl/.rtk"

    fn _default_top_module() -> text:
        val env_top = env_get("MLLVM_QEMU_RTL_TOP")
        if env_top != "":
            return env_top
        "picorv32"
