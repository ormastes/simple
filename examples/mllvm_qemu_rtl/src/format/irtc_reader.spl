# IR_TC Reader — Deserialize [i64] byte stream to IrTcModule
#
# Reads a .irtc binary and reconstructs an in-memory IrTcModule.
# Must round-trip with irtc_writer: write -> read -> write produces identical bytes.

use core.types.{IrTcTypeKind, IrTcValue, IrTcCond, CallConv, GuestArch}
use core.ops.{IrTcOp, IrTcInst, SwitchCase, PhiEntry}
use core.mem_op.{MemOp, Endian, BarrierKind, GuestRegId}
use core.block.{BlockId, IrTcBlock, IrTcFunction, IrTcParam, IrTcModule, IrTcModuleMode, IrTcGlobal}
use format.irtc_binary.{
    IRTC_MAGIC_0, IRTC_MAGIC_1, IRTC_MAGIC_2, IRTC_MAGIC_3,
    IRTC_VERSION,
    SECTION_TYPE_TABLE, SECTION_STRING_TABLE, SECTION_GLOBAL_TABLE,
    SECTION_FUNCTION_TABLE, SECTION_END,
    TYPE_TAG_I1, TYPE_TAG_I8, TYPE_TAG_I16, TYPE_TAG_I32, TYPE_TAG_I64,
    TYPE_TAG_F32, TYPE_TAG_F64, TYPE_TAG_PTR, TYPE_TAG_VEC, TYPE_TAG_STRUCT,
    TYPE_TAG_ARRAY, TYPE_TAG_VOID, TYPE_TAG_FLAG,
    decode_cond, decode_call_conv, decode_endian, decode_barrier,
    decode_guest_arch, decode_module_mode,
    decode_u16_le, decode_u32_le, decode_u64_le,
    OP_ADD, OP_SUB, OP_MUL, OP_DIV, OP_REM, OP_NEG,
    OP_AND, OP_OR, OP_XOR, OP_NOT, OP_SHL, OP_SHR, OP_SAR, OP_ROTL, OP_ROTR,
    OP_CMP, OP_EXT, OP_TRUNC, OP_BITCAST,
    OP_LOAD, OP_STORE, OP_ALLOCA, OP_GUEST_LOAD, OP_GUEST_STORE,
    OP_BR, OP_BR_COND, OP_SWITCH, OP_RET,
    OP_CALL, OP_CALL_HELPER,
    OP_READ_GUEST_REG, OP_WRITE_GUEST_REG,
    OP_EXIT_TB, OP_GOTO_TB, OP_LOOKUP_GOTO_TB,
    OP_GET_ELEMENT_PTR, OP_EXTRACT_VALUE, OP_INSERT_VALUE,
    OP_PHI, OP_SYNC_GUEST_PC, OP_BARRIER, OP_NOP, OP_UNREACHABLE
}

# ============================================================================
# Error Type
# ============================================================================

enum FormatError:
    """Errors during binary deserialization."""
    InvalidMagic(message: text)
    UnsupportedVersion(version: i64)
    UnexpectedEnd(context: text)
    InvalidTypeTag(tag: i64)
    InvalidOpcode(opcode: i64)
    InvalidEnum(context: text, value: i64)
    CorruptData(message: text)

impl FormatError:
    fn to_text() -> text:
        match self:
            InvalidMagic(msg): "invalid magic: {msg}"
            UnsupportedVersion(v): "unsupported version: {v}"
            UnexpectedEnd(ctx): "unexpected end of data at: {ctx}"
            InvalidTypeTag(tag): "invalid type tag: {tag}"
            InvalidOpcode(op): "invalid opcode: {op}"
            InvalidEnum(ctx, v): "invalid enum value {v} at: {ctx}"
            CorruptData(msg): "corrupt data: {msg}"

# ============================================================================
# Byte Reader — cursor over input bytes
# ============================================================================

struct ByteReader:
    """Cursor over a byte array."""
    data: [i64]
    pos: i64

impl ByteReader:
    static fn new(data: [i64]) -> ByteReader:
        ByteReader(data: data, pos: 0)

    fn remaining() -> i64:
        self.data.len() - self.pos

    fn has(n: i64) -> bool:
        self.remaining() >= n

    me read_u8() -> Result<i64, FormatError>:
        if self.pos >= self.data.len():
            return Err(FormatError.UnexpectedEnd(context: "read_u8"))
        val byte = self.data[self.pos]
        self.pos = self.pos + 1
        Ok(byte)

    me read_u16() -> Result<i64, FormatError>:
        if self.remaining() < 2:
            return Err(FormatError.UnexpectedEnd(context: "read_u16"))
        val v = decode_u16_le(self.data, self.pos)
        self.pos = self.pos + 2
        Ok(v)

    me read_u32() -> Result<i64, FormatError>:
        if self.remaining() < 4:
            return Err(FormatError.UnexpectedEnd(context: "read_u32"))
        val v = decode_u32_le(self.data, self.pos)
        self.pos = self.pos + 4
        Ok(v)

    me read_u64() -> Result<i64, FormatError>:
        if self.remaining() < 8:
            return Err(FormatError.UnexpectedEnd(context: "read_u64"))
        val v = decode_u64_le(self.data, self.pos)
        self.pos = self.pos + 8
        Ok(v)

    me read_i64() -> Result<i64, FormatError>:
        self.read_u64()

    me read_bool() -> Result<bool, FormatError>:
        val byte = self.read_u8()?
        Ok(byte != 0)

    me read_bytes(n: i64) -> Result<[i64], FormatError>:
        if self.remaining() < n:
            return Err(FormatError.UnexpectedEnd(context: "read_bytes"))
        var result: [i64] = []
        for _ in 0..n:
            result.push(self.data[self.pos])
            self.pos = self.pos + 1
        Ok(result)

# ============================================================================
# String Decoding
# ============================================================================

fn _read_string(reader: ByteReader) -> Result<text, FormatError>:
    """Read a length-prefixed string."""
    val len = reader.read_u16()?
    val bytes = reader.read_bytes(len)?
    Ok(_bytes_to_text(bytes))

fn _bytes_to_text(bytes: [i64]) -> text:
    """Convert byte array to text (ASCII subset)."""
    var result = ""
    for b in bytes:
        result = result + _byte_to_char(b)
    result

fn _byte_to_char(b: i64) -> text:
    """Map an ASCII byte value to a single character."""
    if b == 32: return " "
    if b == 33: return "!"
    if b == 34: return "\""
    if b == 35: return "#"
    if b == 46: return "."
    if b == 47: return "/"
    if b == 48: return "0"
    if b == 49: return "1"
    if b == 50: return "2"
    if b == 51: return "3"
    if b == 52: return "4"
    if b == 53: return "5"
    if b == 54: return "6"
    if b == 55: return "7"
    if b == 56: return "8"
    if b == 57: return "9"
    if b == 58: return ":"
    if b == 59: return ";"
    if b == 60: return "<"
    if b == 61: return "="
    if b == 62: return ">"
    if b == 64: return "@"
    if b == 65: return "A"
    if b == 66: return "B"
    if b == 67: return "C"
    if b == 68: return "D"
    if b == 69: return "E"
    if b == 70: return "F"
    if b == 71: return "G"
    if b == 72: return "H"
    if b == 73: return "I"
    if b == 74: return "J"
    if b == 75: return "K"
    if b == 76: return "L"
    if b == 77: return "M"
    if b == 78: return "N"
    if b == 79: return "O"
    if b == 80: return "P"
    if b == 81: return "Q"
    if b == 82: return "R"
    if b == 83: return "S"
    if b == 84: return "T"
    if b == 85: return "U"
    if b == 86: return "V"
    if b == 87: return "W"
    if b == 88: return "X"
    if b == 89: return "Y"
    if b == 90: return "Z"
    if b == 91: return "["
    if b == 93: return "]"
    if b == 95: return "_"
    if b == 97: return "a"
    if b == 98: return "b"
    if b == 99: return "c"
    if b == 100: return "d"
    if b == 101: return "e"
    if b == 102: return "f"
    if b == 103: return "g"
    if b == 104: return "h"
    if b == 105: return "i"
    if b == 106: return "j"
    if b == 107: return "k"
    if b == 108: return "l"
    if b == 109: return "m"
    if b == 110: return "n"
    if b == 111: return "o"
    if b == 112: return "p"
    if b == 113: return "q"
    if b == 114: return "r"
    if b == 115: return "s"
    if b == 116: return "t"
    if b == 117: return "u"
    if b == 118: return "v"
    if b == 119: return "w"
    if b == 120: return "x"
    if b == 121: return "y"
    if b == 122: return "z"
    if b == 123: return "{"
    if b == 124: return "|"
    if b == 125: return "}"
    if b == 126: return "~"
    "?"  # Fallback

# ============================================================================
# Module Reader
# ============================================================================

fn read_module(bytes: [i64]) -> Result<IrTcModule, FormatError>:
    """Deserialize a byte stream into an IrTcModule."""
    var reader = ByteReader.new(bytes)

    # --- Header (8 bytes) ---
    val m0 = reader.read_u8()?
    val m1 = reader.read_u8()?
    val m2 = reader.read_u8()?
    val m3 = reader.read_u8()?
    if m0 != IRTC_MAGIC_0:
        return Err(FormatError.InvalidMagic(message: "byte 0 mismatch"))
    if m1 != IRTC_MAGIC_1:
        return Err(FormatError.InvalidMagic(message: "byte 1 mismatch"))
    if m2 != IRTC_MAGIC_2:
        return Err(FormatError.InvalidMagic(message: "byte 2 mismatch"))
    if m3 != IRTC_MAGIC_3:
        return Err(FormatError.InvalidMagic(message: "byte 3 mismatch"))

    val version = reader.read_u8()?
    if version != IRTC_VERSION:
        return Err(FormatError.UnsupportedVersion(version: version))

    val flags = reader.read_u8()?
    val width = reader.read_u8()?
    val reserved = reader.read_u8()?

    # --- Module metadata ---
    val mode_byte = reader.read_u8()?
    val mode_opt = decode_module_mode(mode_byte)
    if mode_opt.? == nil:
        return Err(FormatError.InvalidEnum(context: "module_mode", value: mode_byte))
    # Unwrap: we know it is Some
    var mode = IrTcModuleMode.Compilation
    if val m = mode_opt:
        mode = m

    val name = _read_string(reader)?

    val arch_byte = reader.read_u8()?
    var target_arch: GuestArch? = nil
    if arch_byte != 0xFF:
        val arch_opt = decode_guest_arch(arch_byte)
        if arch_opt.? == nil:
            return Err(FormatError.InvalidEnum(context: "guest_arch", value: arch_byte))
        if val a = arch_opt:
            target_arch = Some(a)

    var module = IrTcModule.new(name, mode)
    module.target_arch = target_arch

    # --- Sections ---
    var type_table: [IrTcTypeKind] = []

    var done = false
    while !done:
        val section_id = reader.read_u8()?
        if section_id == SECTION_TYPE_TABLE:
            type_table = _read_type_table(reader)?
        else if section_id == SECTION_STRING_TABLE:
            module.string_table = _read_string_table(reader)?
        else if section_id == SECTION_GLOBAL_TABLE:
            module.globals = _read_global_table(reader, type_table)?
        else if section_id == SECTION_FUNCTION_TABLE:
            module.functions = _read_function_table(reader, type_table)?
        else if section_id == SECTION_END:
            done = true
        else:
            return Err(FormatError.CorruptData(message: "unknown section id: {section_id}"))

    Ok(module)

# ============================================================================
# Type Table Reading
# ============================================================================

fn _read_type_table(reader: ByteReader) -> Result<[IrTcTypeKind], FormatError>:
    """Read the type table section body."""
    val count = reader.read_u32()?
    var types: [IrTcTypeKind] = []
    for _ in 0..count:
        val type_ = _read_type(reader, types)?
        types.push(type_)
    Ok(types)

fn _read_type(reader: ByteReader, types: [IrTcTypeKind]) -> Result<IrTcTypeKind, FormatError>:
    """Read a single type definition."""
    val tag = reader.read_u8()?
    if tag == TYPE_TAG_I1: return Ok(IrTcTypeKind.I1)
    if tag == TYPE_TAG_I8: return Ok(IrTcTypeKind.I8)
    if tag == TYPE_TAG_I16: return Ok(IrTcTypeKind.I16)
    if tag == TYPE_TAG_I32: return Ok(IrTcTypeKind.I32)
    if tag == TYPE_TAG_I64: return Ok(IrTcTypeKind.I64)
    if tag == TYPE_TAG_F32: return Ok(IrTcTypeKind.F32)
    if tag == TYPE_TAG_F64: return Ok(IrTcTypeKind.F64)
    if tag == TYPE_TAG_VOID: return Ok(IrTcTypeKind.Void)
    if tag == TYPE_TAG_FLAG: return Ok(IrTcTypeKind.Flag)

    if tag == TYPE_TAG_PTR:
        val addr_space = reader.read_u8()?
        return Ok(IrTcTypeKind.Ptr(addr_space: addr_space))

    if tag == TYPE_TAG_VEC:
        val elem_idx = reader.read_u32()?
        val count = reader.read_u32()?
        if elem_idx >= types.len():
            return Err(FormatError.CorruptData(message: "vec elem type index out of range"))
        return Ok(IrTcTypeKind.Vec(elem: types[elem_idx], count: count))

    if tag == TYPE_TAG_STRUCT:
        val field_count = reader.read_u16()?
        var fields: [IrTcTypeKind] = []
        for _ in 0..field_count:
            val f_idx = reader.read_u32()?
            if f_idx >= types.len():
                return Err(FormatError.CorruptData(message: "struct field type index out of range"))
            fields.push(types[f_idx])
        return Ok(IrTcTypeKind.Struct(fields: fields))

    if tag == TYPE_TAG_ARRAY:
        val elem_idx = reader.read_u32()?
        val count = reader.read_u32()?
        if elem_idx >= types.len():
            return Err(FormatError.CorruptData(message: "array elem type index out of range"))
        return Ok(IrTcTypeKind.Array(elem: types[elem_idx], count: count))

    Err(FormatError.InvalidTypeTag(tag: tag))

# ============================================================================
# String Table Reading
# ============================================================================

fn _read_string_table(reader: ByteReader) -> Result<[text], FormatError>:
    """Read the string table section body."""
    val count = reader.read_u32()?
    var strings: [text] = []
    for _ in 0..count:
        val s = _read_string(reader)?
        strings.push(s)
    Ok(strings)

# ============================================================================
# Global Table Reading
# ============================================================================

fn _read_global_table(reader: ByteReader, type_table: [IrTcTypeKind]) -> Result<[IrTcGlobal], FormatError>:
    """Read the global table section body."""
    val count = reader.read_u32()?
    var globals: [IrTcGlobal] = []
    for _ in 0..count:
        val g = _read_global(reader, type_table)?
        globals.push(g)
    Ok(globals)

fn _read_global(reader: ByteReader, type_table: [IrTcTypeKind]) -> Result<IrTcGlobal, FormatError>:
    """Read a single global definition."""
    val name = _read_string(reader)?
    val type_idx = reader.read_u32()?
    if type_idx >= type_table.len():
        return Err(FormatError.CorruptData(message: "global type index out of range"))
    val is_const = reader.read_bool()?
    val addr_space = reader.read_u8()?
    val has_init = reader.read_u8()?
    var initializer: [i64]? = nil
    if has_init == 1:
        val init_len = reader.read_u32()?
        var init_bytes: [i64] = []
        for _ in 0..init_len:
            val b = reader.read_u8()?
            init_bytes.push(b)
        initializer = Some(init_bytes)

    Ok(IrTcGlobal(
        name: name,
        type_: type_table[type_idx],
        is_const: is_const,
        initializer: initializer,
        addr_space: addr_space
    ))

# ============================================================================
# Function Table Reading
# ============================================================================

fn _read_function_table(reader: ByteReader, type_table: [IrTcTypeKind]) -> Result<[IrTcFunction], FormatError>:
    """Read the function table section body."""
    val count = reader.read_u32()?
    var functions: [IrTcFunction] = []
    for _ in 0..count:
        val func = _read_function(reader, type_table)?
        functions.push(func)
    Ok(functions)

fn _read_function(reader: ByteReader, type_table: [IrTcTypeKind]) -> Result<IrTcFunction, FormatError>:
    """Read a single function definition."""
    val name = _read_string(reader)?
    val is_declaration = reader.read_bool()?

    # Return type
    val ret_idx = reader.read_u32()?
    if ret_idx >= type_table.len():
        return Err(FormatError.CorruptData(message: "function return type index out of range"))

    # Parameters
    val param_count = reader.read_u16()?
    var params: [IrTcParam] = []
    for _ in 0..param_count:
        val pname = _read_string(reader)?
        val ptype_idx = reader.read_u32()?
        if ptype_idx >= type_table.len():
            return Err(FormatError.CorruptData(message: "param type index out of range"))
        params.push(IrTcParam(name: pname, type_: type_table[ptype_idx]))

    # Next IDs
    val next_value_id = reader.read_u32()?
    val next_block_id = reader.read_u32()?

    # Blocks
    val block_count = reader.read_u32()?
    var blocks: [IrTcBlock] = []
    for _ in 0..block_count:
        val block = _read_block(reader, type_table)?
        blocks.push(block)

    Ok(IrTcFunction(
        name: name,
        params: params,
        return_type: type_table[ret_idx],
        blocks: blocks,
        is_declaration: is_declaration,
        next_value_id: next_value_id,
        next_block_id: next_block_id
    ))

fn _read_block(reader: ByteReader, type_table: [IrTcTypeKind]) -> Result<IrTcBlock, FormatError>:
    """Read a single basic block."""
    val block_id = reader.read_u32()?
    val has_label = reader.read_u8()?
    var label: text? = nil
    if has_label == 1:
        label = Some(_read_string(reader)?)

    val inst_count = reader.read_u32()?
    var instructions: [IrTcInst] = []
    for _ in 0..inst_count:
        val inst = _read_instruction(reader, type_table)?
        instructions.push(inst)

    Ok(IrTcBlock(
        id: BlockId(id: block_id),
        label: label,
        instructions: instructions
    ))

# ============================================================================
# Instruction Reading
# ============================================================================

fn _read_instruction(reader: ByteReader, type_table: [IrTcTypeKind]) -> Result<IrTcInst, FormatError>:
    """Read a single instruction."""
    val debug_flags = reader.read_u8()?
    var source_line: i64? = nil
    var source_file: i64? = nil

    if debug_flags % 2 == 1:
        source_line = Some(reader.read_u32()?)
    if debug_flags / 2 % 2 == 1:
        source_file = Some(reader.read_u32()?)

    val op = _read_op(reader, type_table)?
    Ok(IrTcInst(kind: op, source_line: source_line, source_file: source_file))

fn _read_op(reader: ByteReader, type_table: [IrTcTypeKind]) -> Result<IrTcOp, FormatError>:
    """Read an opcode with its operands."""
    val opcode = reader.read_u8()?

    # ==== Arithmetic ====
    if opcode == OP_ADD:
        val dest = _read_value(reader, type_table)?
        val a = _read_value(reader, type_table)?
        val b = _read_value(reader, type_table)?
        return Ok(IrTcOp.Add(dest: dest, a: a, b: b))

    if opcode == OP_SUB:
        val dest = _read_value(reader, type_table)?
        val a = _read_value(reader, type_table)?
        val b = _read_value(reader, type_table)?
        return Ok(IrTcOp.Sub(dest: dest, a: a, b: b))

    if opcode == OP_MUL:
        val dest = _read_value(reader, type_table)?
        val a = _read_value(reader, type_table)?
        val b = _read_value(reader, type_table)?
        return Ok(IrTcOp.Mul(dest: dest, a: a, b: b))

    if opcode == OP_DIV:
        val dest = _read_value(reader, type_table)?
        val a = _read_value(reader, type_table)?
        val b = _read_value(reader, type_table)?
        val signed = reader.read_bool()?
        return Ok(IrTcOp.Div(dest: dest, a: a, b: b, signed: signed))

    if opcode == OP_REM:
        val dest = _read_value(reader, type_table)?
        val a = _read_value(reader, type_table)?
        val b = _read_value(reader, type_table)?
        val signed = reader.read_bool()?
        return Ok(IrTcOp.Rem(dest: dest, a: a, b: b, signed: signed))

    if opcode == OP_NEG:
        val dest = _read_value(reader, type_table)?
        val a = _read_value(reader, type_table)?
        return Ok(IrTcOp.Neg(dest: dest, a: a))

    # ==== Bitwise ====
    if opcode == OP_AND:
        val dest = _read_value(reader, type_table)?
        val a = _read_value(reader, type_table)?
        val b = _read_value(reader, type_table)?
        return Ok(IrTcOp.And(dest: dest, a: a, b: b))

    if opcode == OP_OR:
        val dest = _read_value(reader, type_table)?
        val a = _read_value(reader, type_table)?
        val b = _read_value(reader, type_table)?
        return Ok(IrTcOp.Or(dest: dest, a: a, b: b))

    if opcode == OP_XOR:
        val dest = _read_value(reader, type_table)?
        val a = _read_value(reader, type_table)?
        val b = _read_value(reader, type_table)?
        return Ok(IrTcOp.Xor(dest: dest, a: a, b: b))

    if opcode == OP_NOT:
        val dest = _read_value(reader, type_table)?
        val a = _read_value(reader, type_table)?
        return Ok(IrTcOp.Not(dest: dest, a: a))

    if opcode == OP_SHL:
        val dest = _read_value(reader, type_table)?
        val a = _read_value(reader, type_table)?
        val b = _read_value(reader, type_table)?
        return Ok(IrTcOp.Shl(dest: dest, a: a, b: b))

    if opcode == OP_SHR:
        val dest = _read_value(reader, type_table)?
        val a = _read_value(reader, type_table)?
        val b = _read_value(reader, type_table)?
        return Ok(IrTcOp.Shr(dest: dest, a: a, b: b))

    if opcode == OP_SAR:
        val dest = _read_value(reader, type_table)?
        val a = _read_value(reader, type_table)?
        val b = _read_value(reader, type_table)?
        return Ok(IrTcOp.Sar(dest: dest, a: a, b: b))

    if opcode == OP_ROTL:
        val dest = _read_value(reader, type_table)?
        val a = _read_value(reader, type_table)?
        val b = _read_value(reader, type_table)?
        return Ok(IrTcOp.RotL(dest: dest, a: a, b: b))

    if opcode == OP_ROTR:
        val dest = _read_value(reader, type_table)?
        val a = _read_value(reader, type_table)?
        val b = _read_value(reader, type_table)?
        return Ok(IrTcOp.RotR(dest: dest, a: a, b: b))

    # ==== Comparison ====
    if opcode == OP_CMP:
        val dest = _read_value(reader, type_table)?
        val cond_byte = reader.read_u8()?
        val cond_opt = decode_cond(cond_byte)
        if cond_opt.? == nil:
            return Err(FormatError.InvalidEnum(context: "cond", value: cond_byte))
        var cond = IrTcCond.Eq
        if val c = cond_opt:
            cond = c
        val a = _read_value(reader, type_table)?
        val b = _read_value(reader, type_table)?
        return Ok(IrTcOp.Cmp(dest: dest, cond: cond, a: a, b: b))

    # ==== Width Conversion ====
    if opcode == OP_EXT:
        val dest = _read_value(reader, type_table)?
        val src = _read_value(reader, type_table)?
        val signed = reader.read_bool()?
        return Ok(IrTcOp.Ext(dest: dest, src: src, signed: signed))

    if opcode == OP_TRUNC:
        val dest = _read_value(reader, type_table)?
        val src = _read_value(reader, type_table)?
        return Ok(IrTcOp.Trunc(dest: dest, src: src))

    if opcode == OP_BITCAST:
        val dest = _read_value(reader, type_table)?
        val src = _read_value(reader, type_table)?
        return Ok(IrTcOp.Bitcast(dest: dest, src: src))

    # ==== Memory — Compilation ====
    if opcode == OP_LOAD:
        val dest = _read_value(reader, type_table)?
        val addr = _read_value(reader, type_table)?
        val mem = _read_mem_op(reader)?
        return Ok(IrTcOp.Load(dest: dest, addr: addr, mem: mem))

    if opcode == OP_STORE:
        val value = _read_value(reader, type_table)?
        val addr = _read_value(reader, type_table)?
        val mem = _read_mem_op(reader)?
        return Ok(IrTcOp.Store(value: value, addr: addr, mem: mem))

    if opcode == OP_ALLOCA:
        val dest = _read_value(reader, type_table)?
        val type_idx = reader.read_u32()?
        if type_idx >= type_table.len():
            return Err(FormatError.CorruptData(message: "alloca type index out of range"))
        val has_count = reader.read_u8()?
        var count: IrTcValue? = nil
        if has_count == 1:
            count = Some(_read_value(reader, type_table)?)
        return Ok(IrTcOp.Alloca(dest: dest, type_: type_table[type_idx], count: count))

    # ==== Memory — Emulation ====
    if opcode == OP_GUEST_LOAD:
        val dest = _read_value(reader, type_table)?
        val addr = _read_value(reader, type_table)?
        val mem = _read_mem_op(reader)?
        val mmu_idx = reader.read_u8()?
        return Ok(IrTcOp.GuestLoad(dest: dest, addr: addr, mem: mem, mmu_idx: mmu_idx))

    if opcode == OP_GUEST_STORE:
        val value = _read_value(reader, type_table)?
        val addr = _read_value(reader, type_table)?
        val mem = _read_mem_op(reader)?
        val mmu_idx = reader.read_u8()?
        return Ok(IrTcOp.GuestStore(value: value, addr: addr, mem: mem, mmu_idx: mmu_idx))

    # ==== Control Flow ====
    if opcode == OP_BR:
        val target_id = reader.read_u32()?
        return Ok(IrTcOp.Br(target: BlockId(id: target_id)))

    if opcode == OP_BR_COND:
        val cond = _read_value(reader, type_table)?
        val true_id = reader.read_u32()?
        val false_id = reader.read_u32()?
        return Ok(IrTcOp.BrCond(cond: cond, true_: BlockId(id: true_id), false_: BlockId(id: false_id)))

    if opcode == OP_SWITCH:
        val value = _read_value(reader, type_table)?
        val case_count = reader.read_u32()?
        var cases: [SwitchCase] = []
        for _ in 0..case_count:
            val case_val = reader.read_i64()?
            val case_target = reader.read_u32()?
            cases.push(SwitchCase(value: case_val, target: BlockId(id: case_target)))
        val default_id = reader.read_u32()?
        return Ok(IrTcOp.Switch(value: value, cases: cases, default: BlockId(id: default_id)))

    if opcode == OP_RET:
        val has_value = reader.read_u8()?
        var value: IrTcValue? = nil
        if has_value == 1:
            value = Some(_read_value(reader, type_table)?)
        return Ok(IrTcOp.Ret(value: value))

    # ==== Function Calls ====
    if opcode == OP_CALL:
        val has_dest = reader.read_u8()?
        var dest: IrTcValue? = nil
        if has_dest == 1:
            dest = Some(_read_value(reader, type_table)?)
        val func = _read_value(reader, type_table)?
        val cc_byte = reader.read_u8()?
        val cc_opt = decode_call_conv(cc_byte)
        var cc = CallConv.Default
        if val c = cc_opt:
            cc = c
        val arg_count = reader.read_u16()?
        var args: [IrTcValue] = []
        for _ in 0..arg_count:
            args.push(_read_value(reader, type_table)?)
        return Ok(IrTcOp.Call(dest: dest, func: func, args: args, cc: cc))

    if opcode == OP_CALL_HELPER:
        val has_dest = reader.read_u8()?
        var dest: IrTcValue? = nil
        if has_dest == 1:
            dest = Some(_read_value(reader, type_table)?)
        val helper_id = reader.read_u32()?
        val arg_count = reader.read_u16()?
        var args: [IrTcValue] = []
        for _ in 0..arg_count:
            args.push(_read_value(reader, type_table)?)
        return Ok(IrTcOp.CallHelper(dest: dest, helper_id: helper_id, args: args))

    # ==== Guest State ====
    if opcode == OP_READ_GUEST_REG:
        val dest = _read_value(reader, type_table)?
        val guest_reg = _read_guest_reg_id(reader)?
        return Ok(IrTcOp.ReadGuestReg(dest: dest, guest_reg: guest_reg))

    if opcode == OP_WRITE_GUEST_REG:
        val guest_reg = _read_guest_reg_id(reader)?
        val value = _read_value(reader, type_table)?
        return Ok(IrTcOp.WriteGuestReg(guest_reg: guest_reg, value: value))

    # ==== Translation Block Control ====
    if opcode == OP_EXIT_TB:
        val exit_code = reader.read_i64()?
        return Ok(IrTcOp.ExitTB(exit_code: exit_code))

    if opcode == OP_GOTO_TB:
        val tb_index = reader.read_i64()?
        return Ok(IrTcOp.GotoTB(tb_index: tb_index))

    if opcode == OP_LOOKUP_GOTO_TB:
        val target_pc = _read_value(reader, type_table)?
        return Ok(IrTcOp.LookupGotoTB(target_pc: target_pc))

    # ==== Aggregates ====
    if opcode == OP_GET_ELEMENT_PTR:
        val dest = _read_value(reader, type_table)?
        val base = _read_value(reader, type_table)?
        val idx_count = reader.read_u16()?
        var indices: [IrTcValue] = []
        for _ in 0..idx_count:
            indices.push(_read_value(reader, type_table)?)
        return Ok(IrTcOp.GetElementPtr(dest: dest, base: base, indices: indices))

    if opcode == OP_EXTRACT_VALUE:
        val dest = _read_value(reader, type_table)?
        val agg = _read_value(reader, type_table)?
        val index = reader.read_u32()?
        return Ok(IrTcOp.ExtractValue(dest: dest, agg: agg, index: index))

    if opcode == OP_INSERT_VALUE:
        val dest = _read_value(reader, type_table)?
        val agg = _read_value(reader, type_table)?
        val value = _read_value(reader, type_table)?
        val index = reader.read_u32()?
        return Ok(IrTcOp.InsertValue(dest: dest, agg: agg, value: value, index: index))

    # ==== SSA ====
    if opcode == OP_PHI:
        val dest = _read_value(reader, type_table)?
        val entry_count = reader.read_u16()?
        var incoming: [PhiEntry] = []
        for _ in 0..entry_count:
            val block_id = reader.read_u32()?
            val value = _read_value(reader, type_table)?
            incoming.push(PhiEntry(block: BlockId(id: block_id), value: value))
        return Ok(IrTcOp.Phi(dest: dest, incoming: incoming))

    # ==== Special ====
    if opcode == OP_SYNC_GUEST_PC:
        val value = _read_value(reader, type_table)?
        return Ok(IrTcOp.SyncGuestPC(value: value))

    if opcode == OP_BARRIER:
        val kind_byte = reader.read_u8()?
        val kind_opt = decode_barrier(kind_byte)
        var kind = BarrierKind.Full
        if val k = kind_opt:
            kind = k
        return Ok(IrTcOp.Barrier(kind: kind))

    if opcode == OP_NOP:
        return Ok(IrTcOp.Nop)

    if opcode == OP_UNREACHABLE:
        return Ok(IrTcOp.Unreachable)

    Err(FormatError.InvalidOpcode(opcode: opcode))

# ============================================================================
# Value Reading
# ============================================================================

fn _read_value(reader: ByteReader, type_table: [IrTcTypeKind]) -> Result<IrTcValue, FormatError>:
    """Read a typed SSA value: u32 id + u32 type index."""
    val id = reader.read_u32()?
    val type_idx = reader.read_u32()?
    if type_idx >= type_table.len():
        return Err(FormatError.CorruptData(message: "value type index {type_idx} out of range"))
    Ok(IrTcValue(id: id, type_: type_table[type_idx], const_value: nil))

# ============================================================================
# MemOp Reading
# ============================================================================

fn _read_mem_op(reader: ByteReader) -> Result<MemOp, FormatError>:
    """Read a MemOp descriptor."""
    val width = reader.read_u8()?
    val signed = reader.read_bool()?
    val endian_byte = reader.read_u8()?
    val endian_opt = decode_endian(endian_byte)
    var endian = Endian.Little
    if val e = endian_opt:
        endian = e
    val align = reader.read_u8()?
    val addr_space = reader.read_u8()?
    Ok(MemOp(
        width: width,
        signed: signed,
        endian: endian,
        align: align,
        addr_space: addr_space
    ))

# ============================================================================
# GuestRegId Reading
# ============================================================================

fn _read_guest_reg_id(reader: ByteReader) -> Result<GuestRegId, FormatError>:
    """Read a GuestRegId: arch(u8) + index(u16) + name(string)."""
    val arch_byte = reader.read_u8()?
    val arch_opt = decode_guest_arch(arch_byte)
    var arch = GuestArch.Avr
    if val a = arch_opt:
        arch = a
    val index = reader.read_u16()?
    val name = _read_string(reader)?
    Ok(GuestRegId(arch: arch, index: index, name: name))
