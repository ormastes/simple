# Guest Architecture Registry
#
# Central registry for all supported guest architectures.
# Maps architecture enum to CPU definition builders.

use core.types.{GuestArch}
use guest.cpu_def.{GuestCpuDef}
use guest.avr.cpu.{build_avr_cpu_def}
use guest.i8086.cpu.{build_i8086_cpu_def}
use guest.riscv.cpu32.{build_rv32_cpu_def}
use guest.riscv.cpu64.{build_rv64_cpu_def}

# ============================================================================
# Architecture Registry
# ============================================================================

fn get_cpu_def(arch: GuestArch) -> GuestCpuDef?:
    """Get the CPU definition for a guest architecture."""
    match arch:
        Avr: Some(build_avr_cpu_def())
        I8086: Some(build_i8086_cpu_def())
        Riscv32: Some(build_rv32_cpu_def())
        Riscv64: Some(build_rv64_cpu_def())
        _: nil

fn supported_guest_archs() -> [GuestArch]:
    """List all currently supported guest architectures."""
    [GuestArch.Avr, GuestArch.I8086, GuestArch.Riscv32, GuestArch.Riscv64]

fn guest_arch_from_name(name: text) -> GuestArch?:
    """Look up a guest architecture by name."""
    match name:
        "avr": Some(GuestArch.Avr)
        "i8086": Some(GuestArch.I8086)
        "8086": Some(GuestArch.I8086)
        "riscv32": Some(GuestArch.Riscv32)
        "rv32": Some(GuestArch.Riscv32)
        "riscv64": Some(GuestArch.Riscv64)
        "rv64": Some(GuestArch.Riscv64)
        _: nil
