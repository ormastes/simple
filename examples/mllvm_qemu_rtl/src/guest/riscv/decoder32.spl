# RV32I Instruction Decoder — Guest Binary to IR_TC
#
# Translates RV32I machine code into IR_TC operations.
# All RV32I base instructions are 32-bit (4 bytes).
#
# Uses shared emit helpers from decoder_common.spl, parameterized with
# word_type=IrTcTypeKind.I32 and arch=GuestArch.Riscv32.
#
# RISC-V has no flags register — all comparisons are done inline
# via compare-and-branch or set-less-than instructions.

use core.types.{IrTcTypeKind, IrTcValue, IrTcCond, GuestArch}
use core.mem_op.{MemOp, Endian, GuestRegId, ADDR_SPACE_DEFAULT}
use core.ops.{IrTcOp}
use core.builder.{IrTcBuilder}
use core.block.{BlockId, IrTcModuleMode}
use guest.cpu_def.{GuestCpuDef, GuestState}
use guest.riscv.common.{RV_REG_PC, rv_gpr_name}
use guest.riscv.opcodes.{RvOpcode, decode_rv_opcode}
use guest.riscv.decoder_common.{
    RvAluOp,
    rv_reg_id, rv_read_gpr, rv_write_gpr, rv_const,
    emit_rv_alu, emit_rv_alu_imm,
    emit_rv_load, emit_rv_store,
    emit_rv_branch,
    emit_rv_lui, emit_rv_auipc,
    emit_rv_jal, emit_rv_jalr,
    emit_rv_csr,
    emit_rv_ecall, emit_rv_ebreak, emit_rv_fence
}

# ============================================================================
# Decoder Error
# ============================================================================

enum Rv32DecoderError:
    """Errors during RV32I instruction decoding."""
    UnknownOpcode(word: i64, pc: i64)
    Rv64OnlyOpcode(word: i64, pc: i64)

impl Rv32DecoderError:
    fn to_text() -> text:
        match self:
            UnknownOpcode(w, pc): "unknown opcode 0x{w} at PC=0x{pc}"
            Rv64OnlyOpcode(w, pc): "RV64-only opcode 0x{w} at PC=0x{pc} (running in RV32 mode)"

# ============================================================================
# RV32I Decoder
# ============================================================================

class Rv32Decoder:
    """Translates RV32I machine code into IR_TC operations.

    Usage:
        var builder = IrTcBuilder.new("rv32_tb", IrTcModuleMode.Emulation)
        val cpu_def = build_rv32_cpu_def()
        var decoder = Rv32Decoder(builder: builder, cpu_def: cpu_def)
        val bytes_consumed = decoder.decode_instruction(word, pc)
    """
    builder: IrTcBuilder
    cpu_def: GuestCpuDef

impl Rv32Decoder:
    me decode_instruction(inst_word: i64, pc: i64) -> Result<i64, Rv32DecoderError>:
        """Decode one RV32I instruction and emit IR_TC ops.

        Args:
            inst_word: 32-bit instruction word (little-endian)
            pc: Current program counter (byte address)

        Returns:
            Ok(4) — all RV32I base instructions are 4 bytes
            Err(Rv32DecoderError) for unrecognized or RV64-only instructions
        """
        val opcode = decode_rv_opcode(inst_word, false)
        if opcode.? == nil:
            return Err(Rv32DecoderError.UnknownOpcode(word: inst_word, pc: pc))

        val op = opcode.!

        # Reject RV64-only opcodes
        if op.is_rv64_only():
            return Err(Rv32DecoderError.Rv64OnlyOpcode(word: inst_word, pc: pc))

        val arch = GuestArch.Riscv32
        val wt = IrTcTypeKind.I32

        match op:
            # ============================================================
            # Upper Immediate
            # ============================================================

            RvOpcode.LUI(rd, imm):
                emit_rv_lui(self.builder, arch, rd, imm, wt)
                return Ok(4)

            RvOpcode.AUIPC(rd, imm):
                emit_rv_auipc(self.builder, arch, rd, imm, pc, wt)
                return Ok(4)

            # ============================================================
            # Jumps
            # ============================================================

            RvOpcode.JAL(rd, offset):
                emit_rv_jal(self.builder, arch, rd, offset, pc, wt)
                return Ok(4)

            RvOpcode.JALR(rd, rs1, offset):
                emit_rv_jalr(self.builder, arch, rd, rs1, offset, pc, wt)
                return Ok(4)

            # ============================================================
            # Branches
            # ============================================================

            RvOpcode.BEQ(rs1, rs2, offset):
                emit_rv_branch(self.builder, arch, rs1, rs2, IrTcCond.Eq, offset, pc, wt)
                return Ok(4)

            RvOpcode.BNE(rs1, rs2, offset):
                emit_rv_branch(self.builder, arch, rs1, rs2, IrTcCond.Ne, offset, pc, wt)
                return Ok(4)

            RvOpcode.BLT(rs1, rs2, offset):
                emit_rv_branch(self.builder, arch, rs1, rs2, IrTcCond.Lt, offset, pc, wt)
                return Ok(4)

            RvOpcode.BGE(rs1, rs2, offset):
                emit_rv_branch(self.builder, arch, rs1, rs2, IrTcCond.Ge, offset, pc, wt)
                return Ok(4)

            RvOpcode.BLTU(rs1, rs2, offset):
                emit_rv_branch(self.builder, arch, rs1, rs2, IrTcCond.Ltu, offset, pc, wt)
                return Ok(4)

            RvOpcode.BGEU(rs1, rs2, offset):
                emit_rv_branch(self.builder, arch, rs1, rs2, IrTcCond.Geu, offset, pc, wt)
                return Ok(4)

            # ============================================================
            # Loads (RV32I: LB, LH, LW, LBU, LHU)
            # ============================================================

            RvOpcode.LB(rd, rs1, offset):
                emit_rv_load(self.builder, arch, rd, rs1, offset, 1, true, wt)
                return Ok(4)

            RvOpcode.LH(rd, rs1, offset):
                emit_rv_load(self.builder, arch, rd, rs1, offset, 2, true, wt)
                return Ok(4)

            RvOpcode.LW(rd, rs1, offset):
                emit_rv_load(self.builder, arch, rd, rs1, offset, 4, true, wt)
                return Ok(4)

            RvOpcode.LBU(rd, rs1, offset):
                emit_rv_load(self.builder, arch, rd, rs1, offset, 1, false, wt)
                return Ok(4)

            RvOpcode.LHU(rd, rs1, offset):
                emit_rv_load(self.builder, arch, rd, rs1, offset, 2, false, wt)
                return Ok(4)

            # ============================================================
            # Stores (RV32I: SB, SH, SW)
            # ============================================================

            RvOpcode.SB(rs1, rs2, offset):
                emit_rv_store(self.builder, arch, rs1, rs2, offset, 1, wt)
                return Ok(4)

            RvOpcode.SH(rs1, rs2, offset):
                emit_rv_store(self.builder, arch, rs1, rs2, offset, 2, wt)
                return Ok(4)

            RvOpcode.SW(rs1, rs2, offset):
                emit_rv_store(self.builder, arch, rs1, rs2, offset, 4, wt)
                return Ok(4)

            # ============================================================
            # Immediate ALU
            # ============================================================

            RvOpcode.ADDI(rd, rs1, imm):
                emit_rv_alu_imm(self.builder, arch, rd, rs1, imm, RvAluOp.Add, wt)
                return Ok(4)

            RvOpcode.SLTI(rd, rs1, imm):
                emit_rv_alu_imm(self.builder, arch, rd, rs1, imm, RvAluOp.Slt, wt)
                return Ok(4)

            RvOpcode.SLTIU(rd, rs1, imm):
                emit_rv_alu_imm(self.builder, arch, rd, rs1, imm, RvAluOp.Sltu, wt)
                return Ok(4)

            RvOpcode.XORI(rd, rs1, imm):
                emit_rv_alu_imm(self.builder, arch, rd, rs1, imm, RvAluOp.Xor, wt)
                return Ok(4)

            RvOpcode.ORI(rd, rs1, imm):
                emit_rv_alu_imm(self.builder, arch, rd, rs1, imm, RvAluOp.Or, wt)
                return Ok(4)

            RvOpcode.ANDI(rd, rs1, imm):
                emit_rv_alu_imm(self.builder, arch, rd, rs1, imm, RvAluOp.And, wt)
                return Ok(4)

            RvOpcode.SLLI(rd, rs1, shamt):
                emit_rv_alu_imm(self.builder, arch, rd, rs1, shamt, RvAluOp.Sll, wt)
                return Ok(4)

            RvOpcode.SRLI(rd, rs1, shamt):
                emit_rv_alu_imm(self.builder, arch, rd, rs1, shamt, RvAluOp.Srl, wt)
                return Ok(4)

            RvOpcode.SRAI(rd, rs1, shamt):
                emit_rv_alu_imm(self.builder, arch, rd, rs1, shamt, RvAluOp.Sra, wt)
                return Ok(4)

            # ============================================================
            # Register ALU
            # ============================================================

            RvOpcode.ADD(rd, rs1, rs2):
                emit_rv_alu(self.builder, arch, rd, rs1, rs2, RvAluOp.Add, wt)
                return Ok(4)

            RvOpcode.SUB(rd, rs1, rs2):
                emit_rv_alu(self.builder, arch, rd, rs1, rs2, RvAluOp.Sub, wt)
                return Ok(4)

            RvOpcode.SLL(rd, rs1, rs2):
                emit_rv_alu(self.builder, arch, rd, rs1, rs2, RvAluOp.Sll, wt)
                return Ok(4)

            RvOpcode.SLT(rd, rs1, rs2):
                emit_rv_alu(self.builder, arch, rd, rs1, rs2, RvAluOp.Slt, wt)
                return Ok(4)

            RvOpcode.SLTU(rd, rs1, rs2):
                emit_rv_alu(self.builder, arch, rd, rs1, rs2, RvAluOp.Sltu, wt)
                return Ok(4)

            RvOpcode.XOR(rd, rs1, rs2):
                emit_rv_alu(self.builder, arch, rd, rs1, rs2, RvAluOp.Xor, wt)
                return Ok(4)

            RvOpcode.SRL(rd, rs1, rs2):
                emit_rv_alu(self.builder, arch, rd, rs1, rs2, RvAluOp.Srl, wt)
                return Ok(4)

            RvOpcode.SRA(rd, rs1, rs2):
                emit_rv_alu(self.builder, arch, rd, rs1, rs2, RvAluOp.Sra, wt)
                return Ok(4)

            RvOpcode.OR(rd, rs1, rs2):
                emit_rv_alu(self.builder, arch, rd, rs1, rs2, RvAluOp.Or, wt)
                return Ok(4)

            RvOpcode.AND(rd, rs1, rs2):
                emit_rv_alu(self.builder, arch, rd, rs1, rs2, RvAluOp.And, wt)
                return Ok(4)

            # ============================================================
            # CSR Instructions
            # ============================================================

            RvOpcode.CSRRW(rd, csr, rs1):
                emit_rv_csr(self.builder, arch, rd, csr, rs1, false, "w", wt)
                return Ok(4)

            RvOpcode.CSRRS(rd, csr, rs1):
                emit_rv_csr(self.builder, arch, rd, csr, rs1, false, "s", wt)
                return Ok(4)

            RvOpcode.CSRRC(rd, csr, rs1):
                emit_rv_csr(self.builder, arch, rd, csr, rs1, false, "c", wt)
                return Ok(4)

            RvOpcode.CSRRWI(rd, csr, uimm):
                emit_rv_csr(self.builder, arch, rd, csr, uimm, true, "w", wt)
                return Ok(4)

            RvOpcode.CSRRSI(rd, csr, uimm):
                emit_rv_csr(self.builder, arch, rd, csr, uimm, true, "s", wt)
                return Ok(4)

            RvOpcode.CSRRCI(rd, csr, uimm):
                emit_rv_csr(self.builder, arch, rd, csr, uimm, true, "c", wt)
                return Ok(4)

            # ============================================================
            # System
            # ============================================================

            RvOpcode.ECALL:
                emit_rv_ecall(self.builder, arch, pc, wt)
                return Ok(4)

            RvOpcode.EBREAK:
                emit_rv_ebreak(self.builder, arch, pc, wt)
                return Ok(4)

            # ============================================================
            # Fence
            # ============================================================

            RvOpcode.FENCE(pred, succ):
                emit_rv_fence(self.builder)
                return Ok(4)

            # ============================================================
            # RV64-only (should not reach here due to is_rv64_only guard)
            # ============================================================

            _:
                return Err(Rv32DecoderError.UnknownOpcode(word: inst_word, pc: pc))

# ============================================================================
# Translation Block Builder
# ============================================================================

fn decode_rv32_block(builder: IrTcBuilder, cpu_def: GuestCpuDef, code: [i64], start_pc: i64, max_insns: i64) -> Result<i64, Rv32DecoderError>:
    """Decode a sequence of RV32I instructions into a translation block.

    Args:
        builder: IR_TC builder with a current block set
        cpu_def: RV32I CPU definition
        code: Array of 32-bit instruction words
        start_pc: Starting byte PC
        max_insns: Maximum number of instructions to decode

    Returns:
        Ok(insn_count) -- number of instructions decoded
        Err(Rv32DecoderError) on first decode failure
    """
    var decoder = Rv32Decoder(builder: builder, cpu_def: cpu_def)
    var pc = start_pc
    var insn_count: i64 = 0

    while insn_count < max_insns:
        if insn_count >= code.len():
            # End of code buffer -- sync PC and exit
            val final_pc = rv_const(builder, IrTcTypeKind.I32, pc)
            builder.sync_guest_pc(final_pc)
            builder.exit_tb(0)
            return Ok(insn_count)

        val word = code[insn_count]
        val opcode = decode_rv_opcode(word, false)
        if opcode.? == nil:
            return Err(Rv32DecoderError.UnknownOpcode(word: word, pc: pc))

        val result = decoder.decode_instruction(word, pc)
        if val Err(e) = result:
            return Err(e)

        insn_count = insn_count + 1
        pc = pc + 4

        # Check if the instruction was a terminator (branch/jump/ecall/ebreak)
        val op = opcode.!
        match op:
            RvOpcode.JAL(_, _): return Ok(insn_count)
            RvOpcode.JALR(_, _, _): return Ok(insn_count)
            RvOpcode.BEQ(_, _, _): return Ok(insn_count)
            RvOpcode.BNE(_, _, _): return Ok(insn_count)
            RvOpcode.BLT(_, _, _): return Ok(insn_count)
            RvOpcode.BGE(_, _, _): return Ok(insn_count)
            RvOpcode.BLTU(_, _, _): return Ok(insn_count)
            RvOpcode.BGEU(_, _, _): return Ok(insn_count)
            RvOpcode.ECALL: return Ok(insn_count)
            RvOpcode.EBREAK: return Ok(insn_count)
            _: pass_dn

    # Reached max_insns -- sync PC and exit
    val final_pc = rv_const(builder, IrTcTypeKind.I32, pc)
    builder.sync_guest_pc(final_pc)
    builder.exit_tb(0)
    Ok(insn_count)
