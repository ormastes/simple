# RISC-V 64-bit Guest CPU Definition
#
# RV64I base integer ISA
# - 32 x 64-bit general purpose registers (x0-x31, x0 hardwired to 0)
# - 64-bit program counter (PC)
# - No flags register
# - 9 M-mode CSRs for interrupt handling (64-bit each)
# - Little-endian, flat address space

use core.types.{GuestArch}
use core.mem_op.{Endian, GuestRegId, ADDR_SPACE_DEFAULT}
use guest.cpu_def.{GuestCpuDef, GuestRegDef, GuestRegAlias, AddrSpaceDef}
use guest.riscv.common.{
    RV_REG_PC, RV_CSR_MSTATUS, RV_CSR_MTVEC, RV_CSR_MEPC,
    RV_CSR_MCAUSE, RV_CSR_MTVAL, RV_CSR_MIE, RV_CSR_MIP,
    RV_CSR_MSCRATCH, RV_CSR_MHARTID, RV_TOTAL_REGS, rv_gpr_name
}

# ============================================================================
# RV64I CPU Definition Builder
# ============================================================================

fn build_rv64_cpu_def() -> GuestCpuDef:
    """Build the complete RV64I CPU definition.

    Register layout (42 total):
      [0..31]  x0-x31  64-bit general purpose registers
      [32]     PC      64-bit program counter
      [33..41] CSRs    9 machine-mode control/status registers (64-bit each)
    """
    var registers: [GuestRegDef] = []

    # x0-x31: 64-bit general purpose registers
    for i in 0..32:
        val reg_id = GuestRegId.new(GuestArch.Riscv64, i, rv_gpr_name(i))
        registers.push(GuestRegDef.new(reg_id, 64))

    # PC: 64-bit program counter
    val pc_id = GuestRegId.new(GuestArch.Riscv64, RV_REG_PC, "pc")
    registers.push(GuestRegDef.new(pc_id, 64))

    # M-mode CSRs: 64-bit each
    val csr_names = ["mstatus", "mtvec", "mepc", "mcause", "mtval", "mie", "mip", "mscratch", "mhartid"]
    val csr_indices = [RV_CSR_MSTATUS, RV_CSR_MTVEC, RV_CSR_MEPC, RV_CSR_MCAUSE, RV_CSR_MTVAL, RV_CSR_MIE, RV_CSR_MIP, RV_CSR_MSCRATCH, RV_CSR_MHARTID]
    for i in 0..csr_names.len():
        val csr_id = GuestRegId.new(GuestArch.Riscv64, csr_indices[i], csr_names[i])
        registers.push(GuestRegDef.new(csr_id, 64))

    val sp_id = GuestRegId.new(GuestArch.Riscv64, 2, "sp")

    # Single flat address space — 256MB practical limit for emulation
    val addr_spaces = [
        AddrSpaceDef.new(ADDR_SPACE_DEFAULT, "memory", 64, 268435456)
    ]

    GuestCpuDef(
        name: "riscv64",
        arch: GuestArch.Riscv64,
        word_size: 64,
        endian: Endian.Little,
        registers: registers,
        pc_reg: pc_id,
        sp_reg: Some(sp_id),
        flags_reg: nil,
        addr_spaces: addr_spaces
    )
