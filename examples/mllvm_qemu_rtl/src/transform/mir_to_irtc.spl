# Simple MIR -> IR_TC Adapter
#
# MDSOC transform dimension adapter that wraps MirBridge with a
# standardized interface for converting Simple compiler MIR data
# into IR_TC modules.

use core.block.{IrTcModule}
use frontend.mir_bridge.{MirBridge, MirBridgeError, MirModuleData}

# ============================================================================
# MIR -> IR_TC Adapter
# ============================================================================

class MirToIrtcAdapter:
    """MDSOC-compliant adapter: Simple MIR -> IR_TC module.

    Wraps the MirBridge frontend and translates its error types to
    plain text for uniform error handling across transform adapters.

    Usage:
        val adapter = MirToIrtcAdapter.new()
        val data = MirModuleData(name: "my_module", functions: [...])
        match adapter.convert(data):
            Ok(module): # use module
            Err(msg): print("Error: {msg}")
    """
    bridge: MirBridge

impl MirToIrtcAdapter:
    static fn new() -> MirToIrtcAdapter:
        MirToIrtcAdapter(bridge: MirBridge.new())

    me convert(data: MirModuleData) -> Result<IrTcModule, text>:
        """Convert a serialized MIR module to IR_TC.

        This is the primary conversion entry point. Walks every function,
        block, and instruction in the MirModuleData and emits corresponding
        IR_TC operations.
        """
        val result = self.bridge.convert_module_data(data)
        match result:
            Ok(module):
                Ok(module)
            Err(e):
                Err(e.to_text())

    fn convert_by_name(name: text) -> Result<IrTcModule, text>:
        """Convert a MIR module by name via the compiler registry.

        Creates an empty scaffold module. Use convert() with actual
        MirModuleData for real conversion.
        """
        val result = self.bridge.convert_module(name)
        match result:
            Ok(module):
                Ok(module)
            Err(e):
                Err(e.to_text())
