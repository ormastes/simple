# LLVM IR -> IR_TC Adapter
#
# MDSOC transform dimension adapter that wraps LlvmReader with a
# standardized interface for converting LLVM IR files and byte buffers
# into IR_TC modules.

use core.block.{IrTcModule}
use frontend.llvm_reader.{LlvmReader, LlvmReaderError}

# ============================================================================
# LLVM -> IR_TC Adapter
# ============================================================================

class LlvmToIrtcAdapter:
    """MDSOC-compliant adapter: LLVM IR -> IR_TC module.

    Wraps the LlvmReader frontend and translates its error types to
    plain text for uniform error handling across transform adapters.

    Usage:
        val adapter = LlvmToIrtcAdapter.new()
        match adapter.convert_file("input.ll"):
            Ok(module): # use module
            Err(msg): print("Error: {msg}")
    """
    reader: LlvmReader

impl LlvmToIrtcAdapter:
    static fn new() -> LlvmToIrtcAdapter:
        LlvmToIrtcAdapter(reader: LlvmReader.new())

    fn convert_file(path: text) -> Result<IrTcModule, text>:
        """Read an LLVM IR file (.ll or .bc) and convert to IR_TC module.

        For .bc files the bitcode magic is validated but full parsing
        requires LLVM C API bindings not yet available.
        """
        val result = self.reader.read_bitcode_file(path)
        match result:
            Ok(module):
                Ok(module)
            Err(e):
                Err(e.to_text())

    fn convert_bytes(bytes: [i64]) -> Result<IrTcModule, text>:
        """Read LLVM IR from a byte buffer and convert to IR_TC module.

        If the buffer starts with bitcode magic (BC\\xC0\\xDE), returns
        an error directing the caller to use text IR instead.
        """
        val result = self.reader.read_bitcode_bytes(bytes)
        match result:
            Ok(module):
                Ok(module)
            Err(e):
                Err(e.to_text())
