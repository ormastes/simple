# IR_TC -> Guest State Adapter
#
# MDSOC transform dimension adapter that interprets IR_TC module
# instructions and applies the resulting state changes to a GuestState.
# This is the "interpretive" execution path used for verification and
# step-by-step debugging of emulated guest programs.

use core.types.{IrTcTypeKind, IrTcValue, IrTcCond}
use core.ops.{IrTcOp, IrTcInst}
use core.block.{IrTcModule, IrTcFunction, IrTcBlock}
use guest.cpu_def.{GuestState}

# ============================================================================
# IR_TC -> Guest State Adapter
# ============================================================================

class IrtcToGuestAdapter:
    """MDSOC-compliant adapter: IR_TC module -> GuestState updates.

    Walks IR_TC instructions in a module and interprets guest-state-modifying
    operations (ReadGuestReg, WriteGuestReg, GuestLoad, GuestStore, SyncGuestPC)
    to produce an updated GuestState.

    This is the verification/debug path -- not for performance-critical emulation.
    The host backend + JIT cache path should be used for fast execution.

    Usage:
        val adapter = IrtcToGuestAdapter.new()
        val new_state = adapter.apply_to_state(module, current_state)
    """
    # Value storage for interpretive execution (value id -> i64)
    _values: {i64: i64}
    # Error messages accumulated during interpretation
    errors: [text]

impl IrtcToGuestAdapter:
    static fn new() -> IrtcToGuestAdapter:
        IrtcToGuestAdapter(_values: {}, errors: [])

    me apply_to_state(module: IrTcModule, state: GuestState) -> GuestState:
        """Apply all guest-state-modifying ops in the module to the state.

        Walks every function and block in order, interpreting:
        - WriteGuestReg: updates the corresponding register
        - SyncGuestPC: updates the program counter
        - Arithmetic ops: computes values for use by downstream ops
        - ReadGuestReg: reads current register value

        Returns the updated GuestState.
        """
        var result = state
        self._values = {}
        self.errors = []

        for func in module.functions:
            if func.is_declaration:
                continue
            result = _apply_function(func, result)
        result

    me apply_function_by_name(module: IrTcModule, name: text, state: GuestState) -> GuestState:
        """Apply only the named function's ops to the guest state."""
        self._values = {}
        self.errors = []

        if val func = module.find_function(name):
            return _apply_function(func, state)
        self.errors.push("function not found: {name}")
        state

    # ── Internal: function / block walking ──

    me _apply_function(func: IrTcFunction, state: GuestState) -> GuestState:
        """Interpret all blocks in a function."""
        var result = state
        for block in func.blocks:
            result = _apply_block(block, result)
        result

    me _apply_block(block: IrTcBlock, state: GuestState) -> GuestState:
        """Interpret all instructions in a block."""
        var result = state
        for inst in block.instructions:
            result = _apply_inst(inst.kind, result)
        result

    # ── Instruction interpretation ──

    me _apply_inst(op: IrTcOp, state: GuestState) -> GuestState:
        """Interpret a single IR_TC op and update state if applicable."""
        var result = state
        match op:
            # ── Guest state ops ──
            ReadGuestReg(dest, guest_reg):
                val value = result.get_reg(guest_reg.index)
                self._values[dest.id] = value

            WriteGuestReg(guest_reg, value):
                val v = _resolve_value(value)
                result.set_reg(guest_reg.index, v)

            SyncGuestPC(value):
                val v = _resolve_value(value)
                result.pc = v

            # ── Arithmetic ops (compute values for use by guest ops) ──
            Add(dest, a, b):
                val va = _resolve_value(a)
                val vb = _resolve_value(b)
                self._values[dest.id] = va + vb

            Sub(dest, a, b):
                val va = _resolve_value(a)
                val vb = _resolve_value(b)
                self._values[dest.id] = va - vb

            Mul(dest, a, b):
                val va = _resolve_value(a)
                val vb = _resolve_value(b)
                self._values[dest.id] = va * vb

            Div(dest, a, b, _):
                val va = _resolve_value(a)
                val vb = _resolve_value(b)
                if vb != 0:
                    self._values[dest.id] = va / vb
                else:
                    self._values[dest.id] = 0
                    self.errors.push("division by zero")

            And(dest, a, b):
                val va = _resolve_value(a)
                val vb = _resolve_value(b)
                self._values[dest.id] = va & vb

            Or(dest, a, b):
                val va = _resolve_value(a)
                val vb = _resolve_value(b)
                self._values[dest.id] = va | vb

            Xor(dest, a, b):
                val va = _resolve_value(a)
                val vb = _resolve_value(b)
                self._values[dest.id] = va ^ vb

            Not(dest, a):
                val va = _resolve_value(a)
                self._values[dest.id] = va ^ (-1)

            Neg(dest, a):
                val va = _resolve_value(a)
                self._values[dest.id] = 0 - va

            Shl(dest, a, b):
                val va = _resolve_value(a)
                val vb = _resolve_value(b)
                self._values[dest.id] = va << vb

            Shr(dest, a, b):
                val va = _resolve_value(a)
                val vb = _resolve_value(b)
                self._values[dest.id] = va >> vb

            Ext(dest, src, _):
                val v = _resolve_value(src)
                self._values[dest.id] = v

            Trunc(dest, src):
                val v = _resolve_value(src)
                val bits = dest.type_.bit_width()
                val mask = if bits >= 64: -1 else: (1 << bits) - 1
                self._values[dest.id] = v & mask

            Bitcast(dest, src):
                val v = _resolve_value(src)
                self._values[dest.id] = v

            Cmp(dest, cond, a, b):
                val va = _resolve_value(a)
                val vb = _resolve_value(b)
                val cmp_result = match cond:
                    IrTcCond.Eq: if va == vb: 1 else: 0
                    IrTcCond.Ne: if va != vb: 1 else: 0
                    IrTcCond.Lt: if va < vb: 1 else: 0
                    IrTcCond.Le: if va <= vb: 1 else: 0
                    IrTcCond.Gt: if va > vb: 1 else: 0
                    IrTcCond.Ge: if va >= vb: 1 else: 0
                    _: 0
                self._values[dest.id] = cmp_result

            # ── Memory ops (guest load/store would need a GuestMemory handle) ──
            GuestLoad(dest, _, _, _):
                # Without memory handle, store zero as placeholder
                self._values[dest.id] = 0

            GuestStore(_, _, _, _):
                # Without memory handle, silently skip
                pass_do_nothing

            # ── Control flow / other ops -- no state effect in linear walk ──
            _:
                # Record dest value as 0 if the op has one
                if val dest = op.dest_value():
                    self._values[dest.id] = 0

        result

    # ── Value resolution ──

    fn _resolve_value(value: IrTcValue) -> i64:
        """Resolve an IrTcValue to its computed i64.

        If the value has been computed, return it.
        Otherwise return 0 as a default.
        """
        if val v = self._values.get(value.id):
            v
        else:
            0
