# x86_64 Machine Instruction Representation
#
# Shared types for the x86_64 host backend instruction selection, register
# allocation, and encoding pipeline.
#
# Pipeline: IrTcOp -> ISel (X64Inst) -> RegAlloc -> Encode (bytes)

use core.types.{IrTcTypeKind, IrTcValue, IrTcCond}

# ============================================================================
# x86_64 Physical Register IDs
# ============================================================================
# Standard encoding matching hardware register numbers.

val X64_RAX: i64 = 0
val X64_RCX: i64 = 1
val X64_RDX: i64 = 2
val X64_RBX: i64 = 3
val X64_RSP: i64 = 4
val X64_RBP: i64 = 5
val X64_RSI: i64 = 6
val X64_RDI: i64 = 7
val X64_R8: i64 = 8
val X64_R9: i64 = 9
val X64_R10: i64 = 10
val X64_R11: i64 = 11
val X64_R12: i64 = 12
val X64_R13: i64 = 13
val X64_R14: i64 = 14
val X64_R15: i64 = 15

# System V AMD64 ABI argument registers (integer)
val X64_ARG_REGS: [i64] = [X64_RDI, X64_RSI, X64_RDX, X64_RCX, X64_R8, X64_R9]
val X64_ARG_REG_COUNT: i64 = 6

# Return register
val X64_RET_REG: i64 = X64_RAX

# Callee-saved registers (must be preserved across calls)
val X64_CALLEE_SAVED: [i64] = [X64_RBX, X64_R12, X64_R13, X64_R14, X64_R15]

# Caller-saved (scratch) registers
val X64_CALLER_SAVED: [i64] = [X64_RAX, X64_RCX, X64_RDX, X64_RSI, X64_RDI, X64_R8, X64_R9, X64_R10, X64_R11]

# Allocatable registers (excludes RSP, RBP)
# Callee-saved first so values survive across CALL instructions
val X64_ALLOCATABLE: [i64] = [X64_RBX, X64_R12, X64_R13, X64_R14, X64_R15, X64_RAX, X64_RCX, X64_RDX, X64_RSI, X64_RDI, X64_R8, X64_R9, X64_R10, X64_R11]
val X64_ALLOCATABLE_COUNT: i64 = 14

fn x64_reg_name(id: i64) -> text:
    """Human-readable register name."""
    if id == X64_RAX: "rax"
    elif id == X64_RCX: "rcx"
    elif id == X64_RDX: "rdx"
    elif id == X64_RBX: "rbx"
    elif id == X64_RSP: "rsp"
    elif id == X64_RBP: "rbp"
    elif id == X64_RSI: "rsi"
    elif id == X64_RDI: "rdi"
    elif id == X64_R8: "r8"
    elif id == X64_R9: "r9"
    elif id == X64_R10: "r10"
    elif id == X64_R11: "r11"
    elif id == X64_R12: "r12"
    elif id == X64_R13: "r13"
    elif id == X64_R14: "r14"
    elif id == X64_R15: "r15"
    else: "r?"

# ============================================================================
# Register Representation
# ============================================================================

enum X64RegKind:
    Virtual(id: i64)
    Physical(id: i64)

struct X64Reg:
    """A register — either virtual (pre-regalloc) or physical (post-regalloc)."""
    kind: X64RegKind

fn virt_reg(id: i64) -> X64Reg:
    X64Reg(kind: X64RegKind::Virtual(id))

fn phys_reg(id: i64) -> X64Reg:
    X64Reg(kind: X64RegKind::Physical(id))

fn reg_is_virtual(reg: X64Reg) -> bool:
    match reg.kind:
        Virtual(_): true
        Physical(_): false

fn reg_is_physical(reg: X64Reg) -> bool:
    match reg.kind:
        Physical(_): true
        Virtual(_): false

fn reg_id(reg: X64Reg) -> i64:
    match reg.kind:
        Virtual(id): id
        Physical(id): id

fn reg_to_text(reg: X64Reg) -> text:
    match reg.kind:
        Virtual(id): "v{id}"
        Physical(id): x64_reg_name(id)

# ============================================================================
# Operands
# ============================================================================

enum X64OperandKind:
    Reg(reg: X64Reg)
    Imm(value: i64)
    Mem(base: X64Reg, offset: i64)
    MemIdx(base: X64Reg, index: X64Reg, scale: i64, offset: i64)
    Label(block_id: i64)

struct X64Operand:
    kind: X64OperandKind

fn op_reg(reg: X64Reg) -> X64Operand:
    X64Operand(kind: X64OperandKind::Reg(reg))

fn op_phys(id: i64) -> X64Operand:
    X64Operand(kind: X64OperandKind::Reg(phys_reg(id)))

fn op_virt(id: i64) -> X64Operand:
    X64Operand(kind: X64OperandKind::Reg(virt_reg(id)))

fn op_imm(value: i64) -> X64Operand:
    X64Operand(kind: X64OperandKind::Imm(value))

fn op_mem(base: X64Reg, offset: i64) -> X64Operand:
    X64Operand(kind: X64OperandKind::Mem(base, offset))

fn op_mem_idx(base: X64Reg, index: X64Reg, scale: i64, offset: i64) -> X64Operand:
    X64Operand(kind: X64OperandKind::MemIdx(base, index, scale, offset))

fn op_label(block_id: i64) -> X64Operand:
    X64Operand(kind: X64OperandKind::Label(block_id))

fn operand_is_reg(op: X64Operand) -> bool:
    match op.kind:
        Reg(_): true
        _: false

fn operand_get_reg(op: X64Operand) -> X64Reg:
    match op.kind:
        Reg(r): r
        _: virt_reg(0)

# ============================================================================
# x86_64 Condition Codes (for Jcc / SETcc)
# ============================================================================

enum X64Cond:
    E       # Equal (ZF=1)
    NE      # Not equal (ZF=0)
    L       # Less (signed) (SF!=OF)
    LE      # Less or equal (signed) (ZF=1 or SF!=OF)
    G       # Greater (signed) (ZF=0 and SF=OF)
    GE      # Greater or equal (signed) (SF=OF)
    B       # Below (unsigned) (CF=1)
    BE      # Below or equal (unsigned) (CF=1 or ZF=1)
    A       # Above (unsigned) (CF=0 and ZF=0)
    AE      # Above or equal (unsigned) (CF=0)

fn irtc_cond_to_x64(cond: IrTcCond) -> X64Cond:
    """Map IR_TC comparison condition to x86_64 condition code."""
    match cond:
        Eq: X64Cond::E
        Ne: X64Cond::NE
        Lt: X64Cond::L
        Le: X64Cond::LE
        Gt: X64Cond::G
        Ge: X64Cond::GE
        Ltu: X64Cond::B
        Leu: X64Cond::BE
        Gtu: X64Cond::A
        Geu: X64Cond::AE

fn x64_cond_to_text(cond: X64Cond) -> text:
    match cond:
        E: "e"
        NE: "ne"
        L: "l"
        LE: "le"
        G: "g"
        GE: "ge"
        B: "b"
        BE: "be"
        A: "a"
        AE: "ae"

# ============================================================================
# x86_64 Opcodes
# ============================================================================

# Data movement
val X64_OP_MOV_RR: i64 = 1       # mov reg, reg
val X64_OP_MOV_RI: i64 = 2       # mov reg, imm64
val X64_OP_MOV_RM: i64 = 3       # mov reg, [mem]
val X64_OP_MOV_MR: i64 = 4       # mov [mem], reg
val X64_OP_MOV_MI: i64 = 5       # mov [mem], imm32
val X64_OP_MOV_RI32: i64 = 6     # mov reg, imm32 (sign-extended)
val X64_OP_LEA: i64 = 7          # lea reg, [mem]
val X64_OP_MOVZX8: i64 = 8       # movzx reg, byte [mem]
val X64_OP_MOVZX16: i64 = 9      # movzx reg, word [mem]
val X64_OP_MOVSX8: i64 = 10      # movsx reg, byte [mem]
val X64_OP_MOVSX16: i64 = 11     # movsx reg, word [mem]
val X64_OP_MOVSXD: i64 = 12      # movsxd reg, dword [mem] (32->64)
val X64_OP_MOV32_RR: i64 = 13    # mov r32, r32 (zero-extends to 64)
val X64_OP_MOV32_RM: i64 = 14    # mov r32, [mem] (32-bit load)
val X64_OP_MOV32_MR: i64 = 15    # mov [mem], r32 (32-bit store)
val X64_OP_MOV16_MR: i64 = 16    # mov [mem], r16 (16-bit store)
val X64_OP_MOV8_MR: i64 = 17     # mov [mem], r8 (8-bit store)
val X64_OP_MOV8_RM: i64 = 18     # mov r8, [mem] (8-bit load)

# Arithmetic (reg, reg form — dst = dst op src)
val X64_OP_ADD_RR: i64 = 20      # add reg, reg
val X64_OP_ADD_RI: i64 = 21      # add reg, imm32
val X64_OP_SUB_RR: i64 = 22      # sub reg, reg
val X64_OP_SUB_RI: i64 = 23      # sub reg, imm32
val X64_OP_IMUL_RR: i64 = 24     # imul reg, reg
val X64_OP_IMUL_RRI: i64 = 25    # imul reg, reg, imm32
val X64_OP_IDIV_R: i64 = 26      # idiv reg (RDX:RAX / reg)
val X64_OP_DIV_R: i64 = 27       # div reg (unsigned)
val X64_OP_NEG_R: i64 = 28       # neg reg
val X64_OP_CQO: i64 = 29         # cqo (sign-extend RAX into RDX:RAX)

# Bitwise
val X64_OP_AND_RR: i64 = 30      # and reg, reg
val X64_OP_AND_RI: i64 = 31      # and reg, imm32
val X64_OP_OR_RR: i64 = 32       # or reg, reg
val X64_OP_OR_RI: i64 = 33       # or reg, imm32
val X64_OP_XOR_RR: i64 = 34      # xor reg, reg
val X64_OP_XOR_RI: i64 = 35      # xor reg, imm32
val X64_OP_NOT_R: i64 = 36       # not reg
val X64_OP_SHL_RR: i64 = 37      # shl reg, cl
val X64_OP_SHL_RI: i64 = 38      # shl reg, imm8
val X64_OP_SHR_RR: i64 = 39      # shr reg, cl
val X64_OP_SHR_RI: i64 = 40      # shr reg, imm8
val X64_OP_SAR_RR: i64 = 41      # sar reg, cl
val X64_OP_SAR_RI: i64 = 42      # sar reg, imm8
val X64_OP_ROL_RR: i64 = 43      # rol reg, cl
val X64_OP_ROL_RI: i64 = 44      # rol reg, imm8
val X64_OP_ROR_RR: i64 = 45      # ror reg, cl
val X64_OP_ROR_RI: i64 = 46      # ror reg, imm8

# Comparison
val X64_OP_CMP_RR: i64 = 50      # cmp reg, reg
val X64_OP_CMP_RI: i64 = 51      # cmp reg, imm32
val X64_OP_TEST_RR: i64 = 52     # test reg, reg
val X64_OP_SETE: i64 = 53        # sete r8
val X64_OP_SETNE: i64 = 54       # setne r8
val X64_OP_SETL: i64 = 55        # setl r8
val X64_OP_SETLE: i64 = 56       # setle r8
val X64_OP_SETG: i64 = 57        # setg r8
val X64_OP_SETGE: i64 = 58       # setge r8
val X64_OP_SETB: i64 = 59        # setb r8
val X64_OP_SETBE: i64 = 60       # setbe r8
val X64_OP_SETA: i64 = 61        # seta r8
val X64_OP_SETAE: i64 = 62       # setae r8

# Control flow
val X64_OP_JMP: i64 = 70         # jmp rel32
val X64_OP_JCC: i64 = 71         # jcc rel32 (condition in operand)
val X64_OP_CALL: i64 = 72        # call rel32
val X64_OP_CALL_R: i64 = 73      # call reg (indirect)
val X64_OP_RET: i64 = 74         # ret

# Stack
val X64_OP_PUSH: i64 = 80        # push reg
val X64_OP_POP: i64 = 81         # pop reg

# Special
val X64_OP_NOP: i64 = 90         # nop
val X64_OP_INT3: i64 = 91        # int3 (breakpoint)
val X64_OP_SYSCALL: i64 = 92     # syscall

# ============================================================================
# Machine Instruction
# ============================================================================

struct X64Inst:
    """A single x86_64 machine instruction with opcode + operands."""
    opcode: i64
    operands: [X64Operand]
    cond: X64Cond?          # Condition code for Jcc/SETcc
    width: i64              # Operand width in bits (8, 16, 32, 64), 0 = default 64

fn new_x64_inst(opcode: i64, operands: [X64Operand]) -> X64Inst:
    X64Inst(opcode: opcode, operands: operands, cond: nil, width: 0)

fn x64_inst_with_cond(opcode: i64, operands: [X64Operand], cond: X64Cond) -> X64Inst:
    X64Inst(opcode: opcode, operands: operands, cond: Some(cond), width: 0)

fn x64_inst_with_width(opcode: i64, operands: [X64Operand], width: i64) -> X64Inst:
    X64Inst(opcode: opcode, operands: operands, cond: nil, width: width)

# ============================================================================
# Machine Block, Function, Module
# ============================================================================

struct X64Block:
    """A basic block of machine instructions."""
    label: text
    insts: [X64Inst]
    block_id: i64

fn new_x64_block(label: text, block_id: i64) -> X64Block:
    X64Block(label: label, insts: [], block_id: block_id)

fn x64_block_add_inst(block: X64Block, inst: X64Inst) -> X64Block:
    var new_insts = block.insts
    new_insts.push(inst)
    X64Block(label: block.label, insts: new_insts, block_id: block.block_id)

struct X64Function:
    """A function of machine blocks."""
    name: text
    blocks: [X64Block]
    frame_size: i64
    num_vregs: i64
    used_callee_saved: [i64]
    param_count: i64

fn new_x64_function(name: text) -> X64Function:
    X64Function(
        name: name,
        blocks: [],
        frame_size: 0,
        num_vregs: 0,
        used_callee_saved: [],
        param_count: 0
    )

fn x64_func_add_block(func: X64Function, block: X64Block) -> X64Function:
    var new_blocks = func.blocks
    new_blocks.push(block)
    X64Function(
        name: func.name,
        blocks: new_blocks,
        frame_size: func.frame_size,
        num_vregs: func.num_vregs,
        used_callee_saved: func.used_callee_saved,
        param_count: func.param_count
    )

struct X64Module:
    """A module of compiled functions."""
    name: text
    functions: [X64Function]

fn new_x64_module(name: text) -> X64Module:
    X64Module(name: name, functions: [])

fn x64_module_add_func(module: X64Module, func: X64Function) -> X64Module:
    var new_funcs = module.functions
    new_funcs.push(func)
    X64Module(name: module.name, functions: new_funcs)

# ============================================================================
# ISel Context
# ============================================================================

struct ISelContext:
    """Instruction selection context — tracks virtual register allocation."""
    next_vreg: i64
    value_to_vreg: Dict<i64, i64>   # IrTcValue.id -> vreg ID
    frame_slots: Dict<i64, i64>     # value.id -> stack frame offset
    next_frame_offset: i64

fn new_isel_context() -> ISelContext:
    ISelContext(
        next_vreg: 0,
        value_to_vreg: {},
        frame_slots: {},
        next_frame_offset: 0
    )

fn isel_alloc_vreg(ctx: ISelContext) -> ISelContext:
    """Allocate a new virtual register. Retrieve with isel_get_vreg."""
    ISelContext(
        next_vreg: ctx.next_vreg + 1,
        value_to_vreg: ctx.value_to_vreg,
        frame_slots: ctx.frame_slots,
        next_frame_offset: ctx.next_frame_offset
    )

fn isel_get_vreg(ctx: ISelContext) -> i64:
    """Get the most recently allocated virtual register ID."""
    ctx.next_vreg - 1

fn isel_map_value(ctx: ISelContext, value_id: i64, vreg_id: i64) -> ISelContext:
    """Map an IrTcValue ID to a virtual register."""
    var new_map = ctx.value_to_vreg
    new_map[value_id] = vreg_id
    ISelContext(
        next_vreg: ctx.next_vreg,
        value_to_vreg: new_map,
        frame_slots: ctx.frame_slots,
        next_frame_offset: ctx.next_frame_offset
    )

fn isel_get_value_vreg(ctx: ISelContext, value_id: i64) -> i64:
    """Get the vreg assigned to an IrTcValue. Returns -1 if not found."""
    if ctx.value_to_vreg.contains_key(value_id):
        ctx.value_to_vreg[value_id]
    else:
        -1

fn isel_alloc_frame_slot(ctx: ISelContext, value_id: i64, size: i64) -> ISelContext:
    """Allocate a stack frame slot for a value."""
    val aligned_size = if size < 8: 8 else: size
    val offset = ctx.next_frame_offset + aligned_size
    var slots = ctx.frame_slots
    slots[value_id] = offset
    ISelContext(
        next_vreg: ctx.next_vreg,
        value_to_vreg: ctx.value_to_vreg,
        frame_slots: slots,
        next_frame_offset: offset
    )

fn isel_frame_offset(ctx: ISelContext, value_id: i64) -> i64:
    """Get frame offset for a value (0 if not allocated)."""
    if ctx.frame_slots.contains_key(value_id):
        ctx.frame_slots[value_id]
    else:
        0

# ============================================================================
# ISel Result
# ============================================================================

struct ISelInstResult:
    """Result of lowering a single IR_TC instruction."""
    insts: [X64Inst]
    ctx: ISelContext
