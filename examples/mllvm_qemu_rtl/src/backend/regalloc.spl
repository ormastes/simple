# Linear Scan Register Allocator
#
# Assigns physical x86_64 registers to virtual registers using linear scan.
# Simple, fast, good enough for -O0/-O1.
#
# Algorithm:
# 1. Compute live intervals for each virtual register
# 2. Sort intervals by start position
# 3. Walk intervals in order, assign physical registers
# 4. When all registers used, spill longest-lived interval to stack
# 5. Insert spill/reload instructions

use backend.isel_common.{X64Reg, X64Inst, X64Operand, X64Block, X64Function, X64Module}
use backend.isel_common.{virt_reg, phys_reg, reg_is_virtual, reg_is_physical, reg_id}
use backend.isel_common.{op_reg, op_mem, op_phys, operand_is_reg, operand_get_reg}
use backend.isel_common.{new_x64_inst, new_x64_block, x64_block_add_inst, new_x64_function, x64_func_add_block}
use backend.isel_common.{X64_RAX, X64_RCX, X64_RDX, X64_RBX, X64_RSP, X64_RBP}
use backend.isel_common.{X64_RSI, X64_RDI, X64_R8, X64_R9, X64_R10, X64_R11}
use backend.isel_common.{X64_R12, X64_R13, X64_R14, X64_R15}
use backend.isel_common.{X64_ALLOCATABLE, X64_ALLOCATABLE_COUNT, X64_CALLEE_SAVED}
use backend.isel_common.{X64_OP_MOV_RR, X64_OP_MOV_RM, X64_OP_MOV_MR}

# ============================================================================
# Live Intervals
# ============================================================================

struct LiveInterval:
    """A live range for a virtual register."""
    vreg_id: i64
    start_pos: i64      # First definition position
    end_pos: i64        # Last use position
    assigned_reg: i64   # Physical register assigned (-1 = none)
    spill_slot: i64     # Stack offset for spill (-1 = none)
    is_spilled: bool

fn new_live_interval(vreg_id: i64) -> LiveInterval:
    LiveInterval(
        vreg_id: vreg_id,
        start_pos: 999999,
        end_pos: -1,
        assigned_reg: -1,
        spill_slot: -1,
        is_spilled: false
    )

fn interval_update_start(interval: LiveInterval, pos: i64) -> LiveInterval:
    val new_start = if pos < interval.start_pos: pos else: interval.start_pos
    LiveInterval(
        vreg_id: interval.vreg_id,
        start_pos: new_start,
        end_pos: interval.end_pos,
        assigned_reg: interval.assigned_reg,
        spill_slot: interval.spill_slot,
        is_spilled: interval.is_spilled
    )

fn interval_update_end(interval: LiveInterval, pos: i64) -> LiveInterval:
    val new_end = if pos > interval.end_pos: pos else: interval.end_pos
    LiveInterval(
        vreg_id: interval.vreg_id,
        start_pos: interval.start_pos,
        end_pos: new_end,
        assigned_reg: interval.assigned_reg,
        spill_slot: interval.spill_slot,
        is_spilled: interval.is_spilled
    )

fn interval_assign_reg(interval: LiveInterval, reg: i64) -> LiveInterval:
    LiveInterval(
        vreg_id: interval.vreg_id,
        start_pos: interval.start_pos,
        end_pos: interval.end_pos,
        assigned_reg: reg,
        spill_slot: interval.spill_slot,
        is_spilled: false
    )

fn interval_spill(interval: LiveInterval, slot: i64) -> LiveInterval:
    LiveInterval(
        vreg_id: interval.vreg_id,
        start_pos: interval.start_pos,
        end_pos: interval.end_pos,
        assigned_reg: -1,
        spill_slot: slot,
        is_spilled: true
    )

fn interval_length(interval: LiveInterval) -> i64:
    interval.end_pos - interval.start_pos

# ============================================================================
# Compute Live Intervals
# ============================================================================

fn _collect_vreg_from_reg(reg: X64Reg, pos: i64, intervals: Dict<i64, LiveInterval>, is_def: bool) -> Dict<i64, LiveInterval>:
    """Update intervals dict for a register reference at position pos."""
    if reg_is_virtual(reg):
        val vid = reg_id(reg)
        var iv = if intervals.contains_key(vid):
            intervals[vid]
        else:
            new_live_interval(vid)
        if is_def:
            iv = interval_update_start(iv, pos)
        iv = interval_update_end(iv, pos)
        intervals[vid] = iv
    intervals

fn _collect_vreg_from_operand(op: X64Operand, pos: i64, intervals: Dict<i64, LiveInterval>, is_def: bool) -> Dict<i64, LiveInterval>:
    """Scan an operand for virtual register uses/defs."""
    match op.kind:
        Reg(r):
            _collect_vreg_from_reg(r, pos, intervals, is_def)
        Mem(base, _):
            _collect_vreg_from_reg(base, pos, intervals, false)
        MemIdx(base, index, _, _):
            var iv_map = _collect_vreg_from_reg(base, pos, intervals, false)
            _collect_vreg_from_reg(index, pos, iv_map, false)
        _:
            intervals

fn compute_live_intervals(func: X64Function) -> [LiveInterval]:
    """Compute live intervals for all virtual registers in a function."""
    var intervals: Dict<i64, LiveInterval> = {}
    var pos = 0

    for block in func.blocks:
        for inst in block.insts:
            # First operand of most instructions is the destination (def)
            if inst.operands.len() > 0:
                val first_op = inst.operands[0]
                intervals = _collect_vreg_from_operand(first_op, pos, intervals, true)
            # Remaining operands are sources (uses)
            var i = 1
            while i < inst.operands.len():
                intervals = _collect_vreg_from_operand(inst.operands[i], pos, intervals, false)
                i = i + 1
            pos = pos + 1

    # Collect into list
    var result: [LiveInterval] = []
    for key in intervals.keys():
        result.push(intervals[key])
    result

# ============================================================================
# Sort Intervals by Start Position
# ============================================================================

fn sort_intervals(intervals: [LiveInterval]) -> [LiveInterval]:
    """Simple insertion sort by start_pos."""
    var sorted: [LiveInterval] = []
    for iv in intervals:
        sorted.push(iv)
    # Insertion sort
    var i = 1
    while i < sorted.len():
        val key = sorted[i]
        var j = i - 1
        while j >= 0:
            if sorted[j].start_pos > key.start_pos:
                sorted[j + 1] = sorted[j]
                j = j - 1
            else:
                j = -1  # break
        sorted[j + 1] = key
        i = i + 1
    sorted

# ============================================================================
# Linear Scan Algorithm
# ============================================================================

struct RegAllocResult:
    """Result of register allocation."""
    assignments: Dict<i64, i64>       # vreg -> physical reg ID
    spills: Dict<i64, i64>            # vreg -> spill slot offset
    frame_size_addition: i64          # Additional stack space needed for spills
    used_callee_saved: [i64]          # Physical callee-saved regs used

fn linear_scan(intervals: [LiveInterval]) -> RegAllocResult:
    """Run linear scan register allocation on sorted intervals."""
    val sorted = sort_intervals(intervals)
    var assignments: Dict<i64, i64> = {}
    var spills: Dict<i64, i64> = {}
    var active: [LiveInterval] = []
    var free_regs: [bool] = []
    var next_spill_slot: i64 = 0
    var used_callee_saved: [i64] = []

    # Initialize free register pool (16 registers, indexed by phys ID)
    var ri = 0
    while ri < 16:
        free_regs.push(false)
        ri = ri + 1
    for reg in X64_ALLOCATABLE:
        free_regs[reg] = true

    for interval in sorted:
        # Expire old intervals — free registers of intervals that ended
        var new_active: [LiveInterval] = []
        for act in active:
            if act.end_pos < interval.start_pos:
                # Interval expired, free its register
                if act.assigned_reg >= 0:
                    free_regs[act.assigned_reg] = true
            else:
                new_active.push(act)
        active = new_active

        # Try to find a free register
        var found_reg: i64 = -1
        for reg in X64_ALLOCATABLE:
            if free_regs[reg]:
                found_reg = reg
                free_regs[reg] = false
                # break equivalent
                reg = X64_ALLOCATABLE[X64_ALLOCATABLE_COUNT - 1]

        if found_reg >= 0:
            # Assign register
            val assigned = interval_assign_reg(interval, found_reg)
            assignments[interval.vreg_id] = found_reg
            active.push(assigned)

            # Track callee-saved usage
            var is_callee_saved = false
            for cs_reg in X64_CALLEE_SAVED:
                if found_reg == cs_reg:
                    is_callee_saved = true
            if is_callee_saved:
                var already_tracked = false
                for used in used_callee_saved:
                    if used == found_reg:
                        already_tracked = true
                if not already_tracked:
                    used_callee_saved.push(found_reg)
        else:
            # No free register — spill the longest-lived active interval
            var longest_idx: i64 = -1
            var longest_len: i64 = -1
            var ai = 0
            while ai < active.len():
                val len = interval_length(active[ai])
                if len > longest_len:
                    longest_len = len
                    longest_idx = ai
                ai = ai + 1

            if longest_idx >= 0:
                val longest_end = active[longest_idx].end_pos
                if longest_end > interval.end_pos:
                    # Spill the longer interval, reuse its register
                    val spill_vreg = active[longest_idx].vreg_id
                    val freed_reg = active[longest_idx].assigned_reg
                    spills[spill_vreg] = next_spill_slot
                    next_spill_slot = next_spill_slot + 1
                    assignments[spill_vreg] = -1

                    # Remove spilled interval from active
                    var filtered: [LiveInterval] = []
                    var fi = 0
                    while fi < active.len():
                        if fi != longest_idx:
                            filtered.push(active[fi])
                        fi = fi + 1
                    active = filtered

                    # Assign freed register to current interval
                    assignments[interval.vreg_id] = freed_reg
                    free_regs[freed_reg] = false
                    val assigned = interval_assign_reg(interval, freed_reg)
                    active.push(assigned)
                else:
                    # Current interval is longer — spill it instead
                    spills[interval.vreg_id] = next_spill_slot
                    next_spill_slot = next_spill_slot + 1
                    assignments[interval.vreg_id] = -1
            else:
                # No active intervals — spill current
                spills[interval.vreg_id] = next_spill_slot
                next_spill_slot = next_spill_slot + 1
                assignments[interval.vreg_id] = -1

    RegAllocResult(
        assignments: assignments,
        spills: spills,
        frame_size_addition: next_spill_slot * 8,
        used_callee_saved: used_callee_saved
    )

# ============================================================================
# Apply Register Allocation — rewrite virtual regs to physical
# ============================================================================

fn _rewrite_reg(reg: X64Reg, result: RegAllocResult) -> X64Reg:
    """Replace a virtual register with its assigned physical register."""
    if reg_is_virtual(reg):
        val vid = reg_id(reg)
        if result.assignments.contains_key(vid):
            val phys_id = result.assignments[vid]
            if phys_id >= 0:
                return phys_reg(phys_id)
        # Spilled — keep virtual (spill/reload pass handles it)
        reg
    else:
        reg

fn _rewrite_operand(op: X64Operand, result: RegAllocResult) -> X64Operand:
    """Rewrite virtual registers in an operand."""
    match op.kind:
        Reg(r):
            op_reg(_rewrite_reg(r, result))
        Mem(base, offset):
            op_mem(_rewrite_reg(base, result), offset)
        MemIdx(base, index, scale, offset):
            val new_base = _rewrite_reg(base, result)
            val new_index = _rewrite_reg(index, result)
            X64Operand(kind: X64OperandKind::MemIdx(new_base, new_index, scale, offset))
        _:
            op

fn _rewrite_inst(inst: X64Inst, result: RegAllocResult) -> X64Inst:
    """Rewrite all virtual registers in an instruction."""
    var new_ops: [X64Operand] = []
    for op in inst.operands:
        new_ops.push(_rewrite_operand(op, result))
    X64Inst(opcode: inst.opcode, operands: new_ops, cond: inst.cond, width: inst.width)

fn _insert_spill_reload(block: X64Block, result: RegAllocResult, base_frame_offset: i64) -> X64Block:
    """Insert spill stores and reload loads for spilled virtual registers.

    For each instruction, if a source operand is spilled, insert a reload
    (mov from stack) before the instruction. If the destination is spilled,
    insert a spill (mov to stack) after.
    Uses R11 as scratch register for spill/reload.
    """
    var new_block = new_x64_block(block.label, block.block_id)

    for inst in block.insts:
        var pre_insts: [X64Inst] = []
        var post_insts: [X64Inst] = []

        # Check source operands for spills (indices 1+)
        var si = 1
        while si < inst.operands.len():
            val sop = inst.operands[si]
            if operand_is_reg(sop):
                val sreg = operand_get_reg(sop)
                if reg_is_virtual(sreg):
                    val svid = reg_id(sreg)
                    if result.spills.contains_key(svid):
                        val slot = result.spills[svid]
                        val stack_off = base_frame_offset + (slot * 8) + 8
                        # Reload: mov R11, [RBP - stack_off]
                        pre_insts.push(new_x64_inst(X64_OP_MOV_RM, [
                            op_phys(X64_R11),
                            op_mem(phys_reg(X64_RBP), 0 - stack_off)
                        ]))
            si = si + 1

        # Check dest operand for spill (index 0)
        if inst.operands.len() > 0:
            val dop = inst.operands[0]
            if operand_is_reg(dop):
                val dreg = operand_get_reg(dop)
                if reg_is_virtual(dreg):
                    val dvid = reg_id(dreg)
                    if result.spills.contains_key(dvid):
                        val slot = result.spills[dvid]
                        val stack_off = base_frame_offset + (slot * 8) + 8
                        # Spill: mov [RBP - stack_off], R11
                        post_insts.push(new_x64_inst(X64_OP_MOV_MR, [
                            op_mem(phys_reg(X64_RBP), 0 - stack_off),
                            op_phys(X64_R11)
                        ]))

        for pre in pre_insts:
            new_block = x64_block_add_inst(new_block, pre)
        new_block = x64_block_add_inst(new_block, _rewrite_inst(inst, result))
        for post in post_insts:
            new_block = x64_block_add_inst(new_block, post)

    new_block

# ============================================================================
# Module-level Register Allocation
# ============================================================================

fn regalloc_function(func: X64Function) -> X64Function:
    """Run register allocation on a single function."""
    val intervals = compute_live_intervals(func)
    val result = linear_scan(intervals)

    val base_frame_offset = func.frame_size
    val total_frame = base_frame_offset + result.frame_size_addition

    var new_func = new_x64_function(func.name)
    new_func = X64Function(
        name: func.name,
        blocks: [],
        frame_size: total_frame,
        num_vregs: func.num_vregs,
        used_callee_saved: result.used_callee_saved,
        param_count: func.param_count
    )

    for block in func.blocks:
        val new_block = _insert_spill_reload(block, result, base_frame_offset)
        new_func = x64_func_add_block(new_func, new_block)

    new_func

fn regalloc_module(module: X64Module) -> X64Module:
    """Run register allocation on all functions in a module."""
    var new_module = new_x64_module(module.name)
    for func in module.functions:
        val allocated = regalloc_function(func)
        new_module = x64_module_add_func(new_module, allocated)
    new_module
