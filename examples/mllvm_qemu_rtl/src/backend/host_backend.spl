# Host Backend Trait and CompiledModule
#
# Defines the interface for host-architecture code generation backends.
# Each host backend (x86_64, AArch64, etc.) implements HostBackend to compile
# IR_TC functions/modules into native machine code.

use core.types.{IrTcTypeKind, IrTcValue}
use core.block.{IrTcFunction, IrTcModule}

# ============================================================================
# Backend Error
# ============================================================================

struct BackendError:
    """Error produced during backend compilation."""
    message: text

impl BackendError:
    static fn new(message: text) -> BackendError:
        BackendError(message: message)

    fn to_text() -> text:
        "BackendError: {self.message}"

# ============================================================================
# Compiled Module
# ============================================================================

struct CompiledModule:
    """Result of compiling an IrTcModule — machine code bytes + entry offsets."""
    name: text
    code: [i64]                     # Machine code bytes (each element 0-255)
    entry_offsets: Dict<text, i64>  # function name -> byte offset in code

impl CompiledModule:
    static fn new(name: text) -> CompiledModule:
        CompiledModule(name: name, code: [], entry_offsets: {})

    fn code_size() -> i64:
        self.code.len()

    fn get_entry(name: text) -> i64?:
        if self.entry_offsets.contains_key(name):
            Some(self.entry_offsets[name])
        else:
            nil

# ============================================================================
# Compiled Function (intermediate result before linking into module)
# ============================================================================

struct CompiledFunction:
    """A single compiled function — machine code bytes + metadata."""
    name: text
    code: [i64]             # Machine code bytes
    frame_size: i64         # Stack frame size in bytes
    used_callee_saved: [i64]  # Physical register IDs of callee-saved regs used

impl CompiledFunction:
    static fn new(name: text) -> CompiledFunction:
        CompiledFunction(name: name, code: [], frame_size: 0, used_callee_saved: [])

    fn code_size() -> i64:
        self.code.len()
