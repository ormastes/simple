#![allow(unnamed_duplicate_typed_args)]
# x86_64 Machine Code Encoder
#
# Encodes X64Inst machine instructions into raw bytes.
# x86_64 is variable-length (1-15 bytes per instruction).
#
# Encoding format:
#   [REX prefix] [Opcode 1-3 bytes] [ModRM] [SIB] [Displacement] [Immediate]
#
# REX prefix: 0x40 | W(3) | R(2) | X(1) | B(0)
#   W = 1 for 64-bit operand size
#   R = extends ModRM reg field
#   X = extends SIB index field
#   B = extends ModRM r/m or SIB base field

use backend.isel_common.{X64Reg, X64Inst, X64Operand, X64Block, X64Function, X64Module, X64Cond}
use backend.isel_common.{reg_is_physical, reg_id, operand_is_reg, operand_get_reg}
use backend.isel_common.{X64_RAX, X64_RCX, X64_RDX, X64_RBX, X64_RSP, X64_RBP}
use backend.isel_common.{X64_RSI, X64_RDI, X64_R8, X64_R9, X64_R10, X64_R11}
use backend.isel_common.{X64_OP_MOV_RR, X64_OP_MOV_RI, X64_OP_MOV_RM, X64_OP_MOV_MR, X64_OP_MOV_MI}
use backend.isel_common.{X64_OP_MOV_RI32, X64_OP_MOV32_RR, X64_OP_MOV32_RM, X64_OP_MOV32_MR}
use backend.isel_common.{X64_OP_MOV16_MR, X64_OP_MOV8_MR, X64_OP_MOV8_RM}
use backend.isel_common.{X64_OP_MOVZX8, X64_OP_MOVZX16, X64_OP_MOVSX8, X64_OP_MOVSX16, X64_OP_MOVSXD}
use backend.isel_common.{X64_OP_LEA}
use backend.isel_common.{X64_OP_ADD_RR, X64_OP_ADD_RI, X64_OP_SUB_RR, X64_OP_SUB_RI}
use backend.isel_common.{X64_OP_IMUL_RR, X64_OP_IDIV_R, X64_OP_DIV_R, X64_OP_NEG_R, X64_OP_CQO}
use backend.isel_common.{X64_OP_AND_RR, X64_OP_AND_RI, X64_OP_OR_RR, X64_OP_XOR_RR, X64_OP_NOT_R}
use backend.isel_common.{X64_OP_SHL_RR, X64_OP_SHL_RI, X64_OP_SHR_RR, X64_OP_SHR_RI}
use backend.isel_common.{X64_OP_SAR_RR, X64_OP_SAR_RI}
use backend.isel_common.{X64_OP_ROL_RR, X64_OP_ROL_RI, X64_OP_ROR_RR, X64_OP_ROR_RI}
use backend.isel_common.{X64_OP_CMP_RR, X64_OP_CMP_RI, X64_OP_TEST_RR}
use backend.isel_common.{X64_OP_SETE, X64_OP_SETNE, X64_OP_SETL, X64_OP_SETLE}
use backend.isel_common.{X64_OP_SETG, X64_OP_SETGE, X64_OP_SETB, X64_OP_SETBE}
use backend.isel_common.{X64_OP_SETA, X64_OP_SETAE}
use backend.isel_common.{X64_OP_JMP, X64_OP_JCC, X64_OP_CALL, X64_OP_CALL_R, X64_OP_RET}
use backend.isel_common.{X64_OP_PUSH, X64_OP_POP, X64_OP_NOP, X64_OP_INT3, X64_OP_SYSCALL}

use backend.host_backend.{CompiledFunction}

# ============================================================================
# Encoding Helpers
# ============================================================================

fn _reg_low3(reg_id: i64) -> i64:
    """Lower 3 bits of register encoding."""
    reg_id % 8

fn _reg_needs_rex_ext(reg_id: i64) -> bool:
    """Register R8-R15 needs REX extension bit."""
    reg_id >= 8

fn _rex_w() -> i64:
    """REX.W prefix for 64-bit operand size."""
    0x48

fn _rex_wr(reg: i64, rm: i64) -> i64:
    """REX prefix with W=1, optional R and B extension."""
    var rx = 0x48   # REX.W
    if reg >= 8:
        rx = rx + 4  # REX.R
    if rm >= 8:
        rx = rx + 1  # REX.B
    rx

fn _rex_wb(rm: i64) -> i64:
    """REX prefix with W=1, optional B extension."""
    var rx = 0x48
    if rm >= 8:
        rx = rx + 1
    rx

fn _rex_r(reg: i64, rm: i64) -> i64:
    """REX prefix without W (32-bit), optional R and B."""
    var rx = 0x40
    if reg >= 8:
        rx = rx + 4
    if rm >= 8:
        rx = rx + 1
    if rx == 0x40:
        0   # No REX needed for 32-bit without extended regs
    else:
        rx

fn _modrm(md: i64, reg: i64, rm: i64) -> i64:
    """Encode ModR/M byte: mod(2) | reg(3) | rm(3)."""
    ((md % 4) * 64) + (_reg_low3(reg) * 8) + _reg_low3(rm)

fn _modrm_direct(reg: i64, rm: i64) -> i64:
    """ModR/M with mod=11 (register direct)."""
    _modrm(3, reg, rm)

fn _modrm_indirect(reg: i64, rm: i64) -> i64:
    """ModR/M with mod=00 (memory indirect, no displacement)."""
    _modrm(0, reg, rm)

fn _modrm_disp8(reg: i64, rm: i64) -> i64:
    """ModR/M with mod=01 (memory + 8-bit displacement)."""
    _modrm(1, reg, rm)

fn _modrm_disp32(reg: i64, rm: i64) -> i64:
    """ModR/M with mod=10 (memory + 32-bit displacement)."""
    _modrm(2, reg, rm)

fn _sib_byte(scale: i64, index: i64, base: i64) -> i64:
    """Encode SIB byte: scale(2) | index(3) | base(3)."""
    ((scale % 4) * 64) + (_reg_low3(index) * 8) + _reg_low3(base)

# ============================================================================
# Byte Emission Helpers
# ============================================================================

fn _emit_i8(buf: [i64], value: i64) -> [i64]:
    """Append a single byte (masked to 0-255)."""
    var b = buf
    b.push(value % 256)
    b

fn _emit_i32_le(buf: [i64], value: i64) -> [i64]:
    """Append a 32-bit value in little-endian."""
    var b = buf
    # Handle negative values via two's complement
    var v = value
    if v < 0:
        v = v + 4294967296  # 2^32
    b.push(v % 256)
    b.push((v / 256) % 256)
    b.push((v / 65536) % 256)
    b.push((v / 16777216) % 256)
    b

fn _emit_i64_le(buf: [i64], value: i64) -> [i64]:
    """Append a 64-bit value in little-endian."""
    var b = buf
    var v = value
    if v < 0:
        # Two's complement for 64-bit
        v = v + 9223372036854775807 + 1  # Approximate
    var i = 0
    while i < 8:
        b.push(v % 256)
        v = v / 256
        i = i + 1
    b

fn _fits_i8(value: i64) -> bool:
    """Check if a value fits in a signed 8-bit integer."""
    value >= -128 and value <= 127

fn _fits_i32(value: i64) -> bool:
    """Check if a value fits in a signed 32-bit integer."""
    value >= -2147483648 and value <= 2147483647

# ============================================================================
# Memory Operand Encoding
# ============================================================================

fn _encode_mem_operand(buf: [i64], reg: i64, base_id: i64, offset: i64) -> [i64]:
    """Encode a memory operand [base + offset] with the given register field.

    Special cases:
    - RSP (4) as base requires SIB byte
    - RBP (5) as base with offset=0 requires disp8=0
    """
    var b = buf

    if offset == 0 and _reg_low3(base_id) != 5:
        # [base] — mod=00 (but RSP needs SIB)
        if _reg_low3(base_id) == 4:
            # RSP base needs SIB: [RSP] = ModRM(00, reg, 100) + SIB(00, 100, RSP)
            b.push(_modrm_indirect(reg, 4))
            b.push(_sib_byte(0, 4, base_id))
        else:
            b.push(_modrm_indirect(reg, base_id))
    elif _fits_i8(offset):
        # [base + disp8] — mod=01
        if _reg_low3(base_id) == 4:
            b.push(_modrm_disp8(reg, 4))
            b.push(_sib_byte(0, 4, base_id))
        else:
            b.push(_modrm_disp8(reg, base_id))
        b = _emit_i8(b, offset)
    else:
        # [base + disp32] — mod=10
        if _reg_low3(base_id) == 4:
            b.push(_modrm_disp32(reg, 4))
            b.push(_sib_byte(0, 4, base_id))
        else:
            b.push(_modrm_disp32(reg, base_id))
        b = _emit_i32_le(b, offset)

    b

# ============================================================================
# Get Physical Register ID from Operand
# ============================================================================

fn _op_reg_id(op: X64Operand) -> i64:
    """Extract physical register ID from an operand. Returns 0 if not a physical reg."""
    match op.kind:
        Reg(r): reg_id(r)
        _: 0

fn _op_mem_base_id(op: X64Operand) -> i64:
    """Extract base register ID from a memory operand."""
    match op.kind:
        Mem(base, _): reg_id(base)
        _: 0

fn _op_mem_offset(op: X64Operand) -> i64:
    """Extract offset from a memory operand."""
    match op.kind:
        Mem(_, offset): offset
        _: 0

fn _op_imm_value(op: X64Operand) -> i64:
    """Extract immediate value from an operand."""
    match op.kind:
        Imm(v): v
        _: 0

fn _op_label_id(op: X64Operand) -> i64:
    """Extract block ID from a label operand."""
    match op.kind:
        Label(id): id
        _: 0

# ============================================================================
# Instruction Encoding
# ============================================================================

fn encode_inst(inst: X64Inst, block_offsets: Dict<i64, i64>, current_offset: i64) -> [i64]:
    """Encode a single X64Inst into machine code bytes."""
    var buf: [i64] = []
    val opc = inst.opcode

    # ---- MOV reg, reg (64-bit) ----
    if opc == X64_OP_MOV_RR:
        val dst = _op_reg_id(inst.operands[0])
        val src = _op_reg_id(inst.operands[1])
        buf.push(_rex_wr(src, dst))
        buf.push(0x89)  # MOV r/m64, r64
        buf.push(_modrm_direct(src, dst))

    # ---- MOV reg, imm64 ----
    elif opc == X64_OP_MOV_RI:
        val dst = _op_reg_id(inst.operands[0])
        val imm = _op_imm_value(inst.operands[1])
        buf.push(_rex_wb(dst))
        buf.push(0xB8 + _reg_low3(dst))  # MOV r64, imm64
        buf = _emit_i64_le(buf, imm)

    # ---- MOV reg, imm32 (sign-extended) ----
    elif opc == X64_OP_MOV_RI32:
        val dst = _op_reg_id(inst.operands[0])
        val imm = _op_imm_value(inst.operands[1])
        buf.push(_rex_wb(dst))
        buf.push(0xC7)
        buf.push(_modrm_direct(0, dst))
        buf = _emit_i32_le(buf, imm)

    # ---- MOV reg, [mem] (64-bit load) ----
    elif opc == X64_OP_MOV_RM:
        val dst = _op_reg_id(inst.operands[0])
        val base = _op_mem_base_id(inst.operands[1])
        val offset = _op_mem_offset(inst.operands[1])
        buf.push(_rex_wr(dst, base))
        buf.push(0x8B)  # MOV r64, r/m64
        buf = _encode_mem_operand(buf, dst, base, offset)

    # ---- MOV [mem], reg (64-bit store) ----
    elif opc == X64_OP_MOV_MR:
        val base = _op_mem_base_id(inst.operands[0])
        val offset = _op_mem_offset(inst.operands[0])
        val src = _op_reg_id(inst.operands[1])
        buf.push(_rex_wr(src, base))
        buf.push(0x89)  # MOV r/m64, r64
        buf = _encode_mem_operand(buf, src, base, offset)

    # ---- MOV r32, r32 (zero-extends to 64) ----
    elif opc == X64_OP_MOV32_RR:
        val dst = _op_reg_id(inst.operands[0])
        val src = _op_reg_id(inst.operands[1])
        val rex = _rex_r(src, dst)
        if rex != 0:
            buf.push(rex)
        buf.push(0x89)
        buf.push(_modrm_direct(src, dst))

    # ---- MOV r32, [mem] (32-bit load) ----
    elif opc == X64_OP_MOV32_RM:
        val dst = _op_reg_id(inst.operands[0])
        val base = _op_mem_base_id(inst.operands[1])
        val offset = _op_mem_offset(inst.operands[1])
        val rex = _rex_r(dst, base)
        if rex != 0:
            buf.push(rex)
        buf.push(0x8B)
        buf = _encode_mem_operand(buf, dst, base, offset)

    # ---- MOV [mem], r32 (32-bit store) ----
    elif opc == X64_OP_MOV32_MR:
        val base = _op_mem_base_id(inst.operands[0])
        val offset = _op_mem_offset(inst.operands[0])
        val src = _op_reg_id(inst.operands[1])
        val rex = _rex_r(src, base)
        if rex != 0:
            buf.push(rex)
        buf.push(0x89)
        buf = _encode_mem_operand(buf, src, base, offset)

    # ---- MOV [mem], r16 (16-bit store) ----
    elif opc == X64_OP_MOV16_MR:
        val base = _op_mem_base_id(inst.operands[0])
        val offset = _op_mem_offset(inst.operands[0])
        val src = _op_reg_id(inst.operands[1])
        buf.push(0x66)  # Operand size override
        val rex = _rex_r(src, base)
        if rex != 0:
            buf.push(rex)
        buf.push(0x89)
        buf = _encode_mem_operand(buf, src, base, offset)

    # ---- MOV [mem], r8 (8-bit store) ----
    elif opc == X64_OP_MOV8_MR:
        val base = _op_mem_base_id(inst.operands[0])
        val offset = _op_mem_offset(inst.operands[0])
        val src = _op_reg_id(inst.operands[1])
        # Need REX for R8-R15 or to access SPL/BPL/SIL/DIL
        if src >= 4:
            buf.push(0x40 + (if src >= 8: 4 else: 0) + (if base >= 8: 1 else: 0))
        buf.push(0x88)
        buf = _encode_mem_operand(buf, src, base, offset)

    # ---- MOV r8, [mem] (8-bit load) ----
    elif opc == X64_OP_MOV8_RM:
        val dst = _op_reg_id(inst.operands[0])
        val base = _op_mem_base_id(inst.operands[1])
        val offset = _op_mem_offset(inst.operands[1])
        if dst >= 4:
            buf.push(0x40 + (if dst >= 8: 4 else: 0) + (if base >= 8: 1 else: 0))
        buf.push(0x8A)
        buf = _encode_mem_operand(buf, dst, base, offset)

    # ---- MOVZX r64, r/m8 ----
    elif opc == X64_OP_MOVZX8:
        val dst = _op_reg_id(inst.operands[0])
        val src = _op_reg_id(inst.operands[1])
        buf.push(_rex_wr(dst, src))
        buf.push(0x0F)
        buf.push(0xB6)
        buf.push(_modrm_direct(dst, src))

    # ---- MOVZX r64, r/m16 ----
    elif opc == X64_OP_MOVZX16:
        val dst = _op_reg_id(inst.operands[0])
        val src = _op_reg_id(inst.operands[1])
        buf.push(_rex_wr(dst, src))
        buf.push(0x0F)
        buf.push(0xB7)
        buf.push(_modrm_direct(dst, src))

    # ---- MOVSX r64, r/m8 ----
    elif opc == X64_OP_MOVSX8:
        val dst = _op_reg_id(inst.operands[0])
        val src = _op_reg_id(inst.operands[1])
        buf.push(_rex_wr(dst, src))
        buf.push(0x0F)
        buf.push(0xBE)
        buf.push(_modrm_direct(dst, src))

    # ---- MOVSX r64, r/m16 ----
    elif opc == X64_OP_MOVSX16:
        val dst = _op_reg_id(inst.operands[0])
        val src = _op_reg_id(inst.operands[1])
        buf.push(_rex_wr(dst, src))
        buf.push(0x0F)
        buf.push(0xBF)
        buf.push(_modrm_direct(dst, src))

    # ---- MOVSXD r64, r/m32 ----
    elif opc == X64_OP_MOVSXD:
        val dst = _op_reg_id(inst.operands[0])
        val src = _op_reg_id(inst.operands[1])
        buf.push(_rex_wr(dst, src))
        buf.push(0x63)
        buf.push(_modrm_direct(dst, src))

    # ---- LEA r64, [mem] ----
    elif opc == X64_OP_LEA:
        val dst = _op_reg_id(inst.operands[0])
        val base = _op_mem_base_id(inst.operands[1])
        val offset = _op_mem_offset(inst.operands[1])
        buf.push(_rex_wr(dst, base))
        buf.push(0x8D)
        buf = _encode_mem_operand(buf, dst, base, offset)

    # ---- ADD r64, r64 ----
    elif opc == X64_OP_ADD_RR:
        val dst = _op_reg_id(inst.operands[0])
        val src = _op_reg_id(inst.operands[1])
        buf.push(_rex_wr(src, dst))
        buf.push(0x01)  # ADD r/m64, r64
        buf.push(_modrm_direct(src, dst))

    # ---- ADD r64, imm32 ----
    elif opc == X64_OP_ADD_RI:
        val dst = _op_reg_id(inst.operands[0])
        val imm = _op_imm_value(inst.operands[1])
        buf.push(_rex_wb(dst))
        if _fits_i8(imm):
            buf.push(0x83)
            buf.push(_modrm_direct(0, dst))
            buf = _emit_i8(buf, imm)
        else:
            buf.push(0x81)
            buf.push(_modrm_direct(0, dst))
            buf = _emit_i32_le(buf, imm)

    # ---- SUB r64, r64 ----
    elif opc == X64_OP_SUB_RR:
        val dst = _op_reg_id(inst.operands[0])
        val src = _op_reg_id(inst.operands[1])
        buf.push(_rex_wr(src, dst))
        buf.push(0x29)
        buf.push(_modrm_direct(src, dst))

    # ---- SUB r64, imm32 ----
    elif opc == X64_OP_SUB_RI:
        val dst = _op_reg_id(inst.operands[0])
        val imm = _op_imm_value(inst.operands[1])
        buf.push(_rex_wb(dst))
        if _fits_i8(imm):
            buf.push(0x83)
            buf.push(_modrm_direct(5, dst))  # /5 = SUB
            buf = _emit_i8(buf, imm)
        else:
            buf.push(0x81)
            buf.push(_modrm_direct(5, dst))
            buf = _emit_i32_le(buf, imm)

    # ---- IMUL r64, r64 ----
    elif opc == X64_OP_IMUL_RR:
        val dst = _op_reg_id(inst.operands[0])
        val src = _op_reg_id(inst.operands[1])
        buf.push(_rex_wr(dst, src))
        buf.push(0x0F)
        buf.push(0xAF)
        buf.push(_modrm_direct(dst, src))

    # ---- IDIV r64 ----
    elif opc == X64_OP_IDIV_R:
        val src = _op_reg_id(inst.operands[0])
        buf.push(_rex_wb(src))
        buf.push(0xF7)
        buf.push(_modrm_direct(7, src))  # /7 = IDIV

    # ---- DIV r64 ----
    elif opc == X64_OP_DIV_R:
        val src = _op_reg_id(inst.operands[0])
        buf.push(_rex_wb(src))
        buf.push(0xF7)
        buf.push(_modrm_direct(6, src))  # /6 = DIV

    # ---- NEG r64 ----
    elif opc == X64_OP_NEG_R:
        val dst = _op_reg_id(inst.operands[0])
        buf.push(_rex_wb(dst))
        buf.push(0xF7)
        buf.push(_modrm_direct(3, dst))  # /3 = NEG

    # ---- CQO (sign-extend RAX -> RDX:RAX) ----
    elif opc == X64_OP_CQO:
        buf.push(0x48)  # REX.W
        buf.push(0x99)

    # ---- AND r64, r64 ----
    elif opc == X64_OP_AND_RR:
        val dst = _op_reg_id(inst.operands[0])
        val src = _op_reg_id(inst.operands[1])
        buf.push(_rex_wr(src, dst))
        buf.push(0x21)
        buf.push(_modrm_direct(src, dst))

    # ---- AND r64, imm32 ----
    elif opc == X64_OP_AND_RI:
        val dst = _op_reg_id(inst.operands[0])
        val imm = _op_imm_value(inst.operands[1])
        buf.push(_rex_wb(dst))
        if _fits_i8(imm):
            buf.push(0x83)
            buf.push(_modrm_direct(4, dst))  # /4 = AND
            buf = _emit_i8(buf, imm)
        else:
            buf.push(0x81)
            buf.push(_modrm_direct(4, dst))
            buf = _emit_i32_le(buf, imm)

    # ---- OR r64, r64 ----
    elif opc == X64_OP_OR_RR:
        val dst = _op_reg_id(inst.operands[0])
        val src = _op_reg_id(inst.operands[1])
        buf.push(_rex_wr(src, dst))
        buf.push(0x09)
        buf.push(_modrm_direct(src, dst))

    # ---- OR r64, imm32 ----
    elif opc == X64_OP_OR_RI:
        val dst = _op_reg_id(inst.operands[0])
        val imm = _op_imm_value(inst.operands[1])
        buf.push(_rex_wb(dst))
        if _fits_i8(imm):
            buf.push(0x83)
            buf.push(_modrm_direct(1, dst))  # /1 = OR
            buf = _emit_i8(buf, imm)
        else:
            buf.push(0x81)
            buf.push(_modrm_direct(1, dst))
            buf = _emit_i32_le(buf, imm)

    # ---- XOR r64, r64 ----
    elif opc == X64_OP_XOR_RR:
        val dst = _op_reg_id(inst.operands[0])
        val src = _op_reg_id(inst.operands[1])
        buf.push(_rex_wr(src, dst))
        buf.push(0x31)
        buf.push(_modrm_direct(src, dst))

    # ---- XOR r64, imm32 ----
    elif opc == X64_OP_XOR_RI:
        val dst = _op_reg_id(inst.operands[0])
        val imm = _op_imm_value(inst.operands[1])
        buf.push(_rex_wb(dst))
        if _fits_i8(imm):
            buf.push(0x83)
            buf.push(_modrm_direct(6, dst))  # /6 = XOR
            buf = _emit_i8(buf, imm)
        else:
            buf.push(0x81)
            buf.push(_modrm_direct(6, dst))
            buf = _emit_i32_le(buf, imm)

    # ---- NOT r64 ----
    elif opc == X64_OP_NOT_R:
        val dst = _op_reg_id(inst.operands[0])
        buf.push(_rex_wb(dst))
        buf.push(0xF7)
        buf.push(_modrm_direct(2, dst))  # /2 = NOT

    # ---- SHL r64, CL ----
    elif opc == X64_OP_SHL_RR:
        val dst = _op_reg_id(inst.operands[0])
        buf.push(_rex_wb(dst))
        buf.push(0xD3)
        buf.push(_modrm_direct(4, dst))  # /4 = SHL

    # ---- SHL r64, imm8 ----
    elif opc == X64_OP_SHL_RI:
        val dst = _op_reg_id(inst.operands[0])
        val imm = _op_imm_value(inst.operands[1])
        buf.push(_rex_wb(dst))
        buf.push(0xC1)
        buf.push(_modrm_direct(4, dst))
        buf = _emit_i8(buf, imm)

    # ---- SHR r64, CL ----
    elif opc == X64_OP_SHR_RR:
        val dst = _op_reg_id(inst.operands[0])
        buf.push(_rex_wb(dst))
        buf.push(0xD3)
        buf.push(_modrm_direct(5, dst))  # /5 = SHR

    # ---- SHR r64, imm8 ----
    elif opc == X64_OP_SHR_RI:
        val dst = _op_reg_id(inst.operands[0])
        val imm = _op_imm_value(inst.operands[1])
        buf.push(_rex_wb(dst))
        buf.push(0xC1)
        buf.push(_modrm_direct(5, dst))
        buf = _emit_i8(buf, imm)

    # ---- SAR r64, CL ----
    elif opc == X64_OP_SAR_RR:
        val dst = _op_reg_id(inst.operands[0])
        buf.push(_rex_wb(dst))
        buf.push(0xD3)
        buf.push(_modrm_direct(7, dst))  # /7 = SAR

    # ---- SAR r64, imm8 ----
    elif opc == X64_OP_SAR_RI:
        val dst = _op_reg_id(inst.operands[0])
        val imm = _op_imm_value(inst.operands[1])
        buf.push(_rex_wb(dst))
        buf.push(0xC1)
        buf.push(_modrm_direct(7, dst))
        buf = _emit_i8(buf, imm)

    # ---- ROL r64, CL ----
    elif opc == X64_OP_ROL_RR:
        val dst = _op_reg_id(inst.operands[0])
        buf.push(_rex_wb(dst))
        buf.push(0xD3)
        buf.push(_modrm_direct(0, dst))  # /0 = ROL

    # ---- ROL r64, imm8 ----
    elif opc == X64_OP_ROL_RI:
        val dst = _op_reg_id(inst.operands[0])
        val imm = _op_imm_value(inst.operands[1])
        buf.push(_rex_wb(dst))
        buf.push(0xC1)
        buf.push(_modrm_direct(0, dst))
        buf = _emit_i8(buf, imm)

    # ---- ROR r64, CL ----
    elif opc == X64_OP_ROR_RR:
        val dst = _op_reg_id(inst.operands[0])
        buf.push(_rex_wb(dst))
        buf.push(0xD3)
        buf.push(_modrm_direct(1, dst))  # /1 = ROR

    # ---- ROR r64, imm8 ----
    elif opc == X64_OP_ROR_RI:
        val dst = _op_reg_id(inst.operands[0])
        val imm = _op_imm_value(inst.operands[1])
        buf.push(_rex_wb(dst))
        buf.push(0xC1)
        buf.push(_modrm_direct(1, dst))
        buf = _emit_i8(buf, imm)

    # ---- CMP r64, r64 ----
    elif opc == X64_OP_CMP_RR:
        val dst = _op_reg_id(inst.operands[0])
        val src = _op_reg_id(inst.operands[1])
        buf.push(_rex_wr(src, dst))
        buf.push(0x39)
        buf.push(_modrm_direct(src, dst))

    # ---- CMP r64, imm32 ----
    elif opc == X64_OP_CMP_RI:
        val dst = _op_reg_id(inst.operands[0])
        val imm = _op_imm_value(inst.operands[1])
        buf.push(_rex_wb(dst))
        if _fits_i8(imm):
            buf.push(0x83)
            buf.push(_modrm_direct(7, dst))  # /7 = CMP
            buf = _emit_i8(buf, imm)
        else:
            buf.push(0x81)
            buf.push(_modrm_direct(7, dst))
            buf = _emit_i32_le(buf, imm)

    # ---- TEST r64, r64 ----
    elif opc == X64_OP_TEST_RR:
        val dst = _op_reg_id(inst.operands[0])
        val src = _op_reg_id(inst.operands[1])
        buf.push(_rex_wr(src, dst))
        buf.push(0x85)
        buf.push(_modrm_direct(src, dst))

    # ---- SETcc r8 ----
    elif opc == X64_OP_SETE:
        buf = _encode_setcc(buf, inst, 0x94)
    elif opc == X64_OP_SETNE:
        buf = _encode_setcc(buf, inst, 0x95)
    elif opc == X64_OP_SETL:
        buf = _encode_setcc(buf, inst, 0x9C)
    elif opc == X64_OP_SETLE:
        buf = _encode_setcc(buf, inst, 0x9E)
    elif opc == X64_OP_SETG:
        buf = _encode_setcc(buf, inst, 0x9F)
    elif opc == X64_OP_SETGE:
        buf = _encode_setcc(buf, inst, 0x9D)
    elif opc == X64_OP_SETB:
        buf = _encode_setcc(buf, inst, 0x92)
    elif opc == X64_OP_SETBE:
        buf = _encode_setcc(buf, inst, 0x96)
    elif opc == X64_OP_SETA:
        buf = _encode_setcc(buf, inst, 0x97)
    elif opc == X64_OP_SETAE:
        buf = _encode_setcc(buf, inst, 0x93)

    # ---- JMP rel32 ----
    elif opc == X64_OP_JMP:
        val target_block = _op_label_id(inst.operands[0])
        val target_offset = if block_offsets.contains_key(target_block): block_offsets[target_block] else: 0
        # JMP uses 5 bytes: E9 + rel32
        val rel = target_offset - (current_offset + 5)
        buf.push(0xE9)
        buf = _emit_i32_le(buf, rel)

    # ---- Jcc rel32 ----
    elif opc == X64_OP_JCC:
        val target_block = _op_label_id(inst.operands[0])
        val target_offset = if block_offsets.contains_key(target_block): block_offsets[target_block] else: 0
        # Jcc uses 6 bytes: 0F 8x + rel32
        val rel = target_offset - (current_offset + 6)
        buf.push(0x0F)
        val cc_byte = _jcc_opcode_byte(inst.cond)
        buf.push(cc_byte)
        buf = _emit_i32_le(buf, rel)

    # ---- CALL rel32 ----
    elif opc == X64_OP_CALL:
        val imm = _op_imm_value(inst.operands[0])
        # CALL uses 5 bytes: E8 + rel32
        val rel = imm - (current_offset + 5)
        buf.push(0xE8)
        buf = _emit_i32_le(buf, rel)

    # ---- CALL reg (indirect) ----
    elif opc == X64_OP_CALL_R:
        val src = _op_reg_id(inst.operands[0])
        if src >= 8:
            buf.push(0x41)  # REX.B
        buf.push(0xFF)
        buf.push(_modrm_direct(2, src))  # /2 = CALL

    # ---- RET ----
    elif opc == X64_OP_RET:
        buf.push(0xC3)

    # ---- PUSH r64 ----
    elif opc == X64_OP_PUSH:
        val src = _op_reg_id(inst.operands[0])
        if src >= 8:
            buf.push(0x41)  # REX.B
        buf.push(0x50 + _reg_low3(src))

    # ---- POP r64 ----
    elif opc == X64_OP_POP:
        val dst = _op_reg_id(inst.operands[0])
        if dst >= 8:
            buf.push(0x41)  # REX.B
        buf.push(0x58 + _reg_low3(dst))

    # ---- NOP ----
    elif opc == X64_OP_NOP:
        buf.push(0x90)

    # ---- INT3 ----
    elif opc == X64_OP_INT3:
        buf.push(0xCC)

    # ---- SYSCALL ----
    elif opc == X64_OP_SYSCALL:
        buf.push(0x0F)
        buf.push(0x05)

    # ---- Unknown opcode — emit INT3 as trap ----
    else:
        buf.push(0xCC)

    buf

# ============================================================================
# SETcc Helper
# ============================================================================

fn _encode_setcc(buf: [i64], inst: X64Inst, opcode_byte: i64) -> [i64]:
    """Encode a SETcc instruction: 0F <opcode> ModRM."""
    var b = buf
    val dst = _op_reg_id(inst.operands[0])
    # REX prefix for R8-R15 or to access SPL/BPL/SIL/DIL
    if dst >= 4:
        b.push(0x40 + (if dst >= 8: 1 else: 0))
    b.push(0x0F)
    b.push(opcode_byte)
    b.push(_modrm_direct(0, dst))
    b

# ============================================================================
# Jcc condition code byte
# ============================================================================

fn _jcc_opcode_byte(cond: X64Cond?) -> i64:
    """Get the second byte of the 0F 8x Jcc opcode for a condition."""
    if val c = cond:
        match c:
            E: 0x84       # JE
            NE: 0x85      # JNE
            L: 0x8C       # JL
            LE: 0x8E      # JLE
            G: 0x8F       # JG
            GE: 0x8D      # JGE
            B: 0x82       # JB
            BE: 0x86      # JBE
            A: 0x87       # JA
            AE: 0x83      # JAE
    else:
        0x84  # Default to JE

# ============================================================================
# Block and Function Encoding
# ============================================================================

fn encode_block(block: X64Block, block_offsets: Dict<i64, i64>, start_offset: i64) -> [i64]:
    """Encode all instructions in a block, returning byte array."""
    var code: [i64] = []
    var offset = start_offset
    for inst in block.insts:
        val bytes = encode_inst(inst, block_offsets, offset)
        for b in bytes:
            code.push(b)
        offset = offset + bytes.len()
    code

fn _compute_block_offsets(func: X64Function) -> Dict<i64, i64>:
    """First pass: estimate block offsets for jump target resolution.

    Uses a conservative estimate of instruction sizes (each inst = 8 bytes avg).
    A second pass re-encodes with correct offsets.
    """
    var offsets: Dict<i64, i64> = {}
    var offset: i64 = 0
    for block in func.blocks:
        offsets[block.block_id] = offset
        # Estimate: each instruction averages ~5 bytes
        offset = offset + (block.insts.len() * 5)
    offsets

fn encode_function(func: X64Function) -> CompiledFunction:
    """Encode a complete function.

    Two-pass encoding:
    1. Estimate block offsets
    2. Encode with estimated offsets
    3. Re-compute actual offsets from encoded sizes
    4. Re-encode with correct offsets (fixup pass)
    """
    # Pass 1: estimate offsets
    var block_offsets = _compute_block_offsets(func)

    # Pass 2: encode with estimated offsets, compute real sizes
    var real_offsets: Dict<i64, i64> = {}
    var offset: i64 = 0
    for block in func.blocks:
        real_offsets[block.block_id] = offset
        for inst in block.insts:
            val bytes = encode_inst(inst, block_offsets, offset)
            offset = offset + bytes.len()

    # Pass 3: re-encode with correct offsets
    var code: [i64] = []
    var final_offset: i64 = 0
    for block in func.blocks:
        for inst in block.insts:
            val bytes = encode_inst(inst, real_offsets, final_offset)
            for b in bytes:
                code.push(b)
            final_offset = final_offset + bytes.len()

    CompiledFunction(
        name: func.name,
        code: code,
        frame_size: func.frame_size,
        used_callee_saved: func.used_callee_saved
    )

fn encode_module(module: X64Module) -> [CompiledFunction]:
    """Encode all functions in a module."""
    var results: [CompiledFunction] = []
    for func in module.functions:
        if func.blocks.len() > 0:
            results.push(encode_function(func))
    results
