# IR_TC Translation Block Chaining Pass
#
# When a GotoTB target is a statically known block within the same module,
# merge the two translation blocks to eliminate exit/re-enter overhead.
# Only applies to emulation-mode modules.
#
# Before:
#   TB_A: ... ; GotoTB(1)  -> exits to dispatcher, re-enters TB_B
#   TB_B: entry; ... ; ExitTB(0)
#
# After:
#   TB_A: ... ; Br(TB_B.entry)
#   TB_B: entry; ... ; ExitTB(0)
#   (TB_B's blocks are inlined into the function)

use core.types.{IrTcValue, IrTcTypeKind, GuestArch}
use core.ops.{IrTcOp, IrTcInst, SwitchCase, PhiEntry}
use core.block.{IrTcBlock, IrTcFunction, IrTcModule, IrTcModuleMode, BlockId}

# ============================================================================
# TB Index Map — maps tb_index to function/block info
# ============================================================================

struct TbEntry:
    """Records a translation block's function index and entry block ID."""
    tb_index: i64
    func_index: i64
    entry_block_id: i64

impl TbEntry:
    static fn new(tb_index: i64, func_index: i64, entry_block_id: i64) -> TbEntry:
        TbEntry(tb_index: tb_index, func_index: func_index, entry_block_id: entry_block_id)

struct TbMap:
    """Maps GotoTB indices to their target translation blocks."""
    entries: [TbEntry]

impl TbMap:
    static fn new() -> TbMap:
        TbMap(entries: [])

    me add(tb_index: i64, func_index: i64, entry_block_id: i64):
        self.entries.push(TbEntry.new(tb_index, func_index, entry_block_id))

    fn find(tb_index: i64) -> TbEntry?:
        for entry in self.entries:
            if entry.tb_index == tb_index:
                return Some(entry)
        nil

# ============================================================================
# Block ID Remapping — avoid collisions when inlining blocks
# ============================================================================

struct BlockRemap:
    """Maps old block ID to new block ID."""
    old_id: i64
    new_id: i64

impl BlockRemap:
    static fn new(old_id: i64, new_id: i64) -> BlockRemap:
        BlockRemap(old_id: old_id, new_id: new_id)

struct BlockRemapTable:
    """Table of block ID remappings for inlined TBs."""
    entries: [BlockRemap]

impl BlockRemapTable:
    static fn new() -> BlockRemapTable:
        BlockRemapTable(entries: [])

    me add(old_id: i64, new_id: i64):
        self.entries.push(BlockRemap.new(old_id, new_id))

    fn remap(id: i64) -> i64:
        for entry in self.entries:
            if entry.old_id == id:
                return entry.new_id
        id

    fn remap_block_id(bid: BlockId) -> BlockId:
        BlockId.new(self.remap(bid.id))

# ============================================================================
# TB Chaining Pass
# ============================================================================

struct TbChainPass:
    """Translation block chaining pass.

    Scans for GotoTB instructions that target statically known TBs.
    When found, inlines the target TB's blocks into the current function
    and replaces GotoTB with a direct Br.
    Only operates on emulation-mode modules.
    """
    _placeholder: i64

impl TbChainPass:
    static fn new() -> TbChainPass:
        TbChainPass(_placeholder: 0)

    fn name() -> text:
        "tb_chain"

    fn run_on_function(func: IrTcFunction) -> IrTcFunction:
        """Chain translation blocks within a single function.

        Looks for GotoTB(idx) where idx maps to another block in the
        same function and replaces it with a direct branch.
        """
        # Build a map from tb_index to entry block within this function
        var tb_targets = _build_intra_function_tb_map(func)

        var new_blocks: [IrTcBlock] = []
        for block in func.blocks:
            var new_block = IrTcBlock.new(block.id)
            new_block = IrTcBlock(..new_block, label: block.label)

            for inst in block.instructions:
                val chained = _try_chain_goto(inst, tb_targets)
                new_block.append(chained)

            new_blocks.push(new_block)

        IrTcFunction(..func, blocks: new_blocks)

    fn run_on_module(module: IrTcModule) -> IrTcModule:
        """Run TB chaining across the entire module.

        First tries intra-function chaining, then cross-function inlining
        for statically known targets.
        """
        # Only applies to emulation modules
        if !module.mode.allows_emulation_ops():
            return module

        # Phase 1: Intra-function chaining
        var new_functions: [IrTcFunction] = []
        for func in module.functions:
            if func.is_declaration:
                new_functions.push(func)
            else:
                new_functions.push(self.run_on_function(func))

        # Phase 2: Cross-function TB inlining
        val cross_tb_map = _build_cross_function_tb_map(new_functions)
        var final_functions: [IrTcFunction] = []
        for func in new_functions:
            if func.is_declaration:
                final_functions.push(func)
            else:
                val inlined = _inline_cross_function_tbs(func, cross_tb_map, new_functions)
                final_functions.push(inlined)

        IrTcModule(..module, functions: final_functions)

# ============================================================================
# Intra-function TB map
# ============================================================================

struct IntraTbEntry:
    """Maps a label-derived TB index to a block ID within the same function."""
    tb_index: i64
    block_id: i64

impl IntraTbEntry:
    static fn new(tb_index: i64, block_id: i64) -> IntraTbEntry:
        IntraTbEntry(tb_index: tb_index, block_id: block_id)

struct IntraTbMap:
    entries: [IntraTbEntry]

impl IntraTbMap:
    static fn new() -> IntraTbMap:
        IntraTbMap(entries: [])

    me add(tb_index: i64, block_id: i64):
        self.entries.push(IntraTbEntry.new(tb_index, block_id))

    fn find(tb_index: i64) -> i64?:
        for entry in self.entries:
            if entry.tb_index == tb_index:
                return Some(entry.block_id)
        nil

fn _build_intra_function_tb_map(func: IrTcFunction) -> IntraTbMap:
    """Build a map from TB index to entry block ID.

    Convention: a block labeled "tb_N" is the entry for TB index N.
    """
    var map = IntraTbMap.new()
    for block in func.blocks:
        if val Some(label) = block.label:
            if label.starts_with("tb_"):
                val idx_str = label[3:label.len()]
                # Parse the index from the label suffix
                val idx = _parse_i64(idx_str)
                if idx >= 0:
                    map.add(idx, block.id.id)
    map

fn _parse_i64(s: text) -> i64:
    """Simple integer parser. Returns -1 on failure."""
    var result: i64 = 0
    for i in 0..s.len():
        val c = s[i:i + 1]
        if c == "0": result = result * 10
        else if c == "1": result = result * 10 + 1
        else if c == "2": result = result * 10 + 2
        else if c == "3": result = result * 10 + 3
        else if c == "4": result = result * 10 + 4
        else if c == "5": result = result * 10 + 5
        else if c == "6": result = result * 10 + 6
        else if c == "7": result = result * 10 + 7
        else if c == "8": result = result * 10 + 8
        else if c == "9": result = result * 10 + 9
        else: return -1
    result

# ============================================================================
# GotoTB -> Br transformation
# ============================================================================

fn _try_chain_goto(inst: IrTcInst, tb_map: IntraTbMap) -> IrTcInst:
    """If inst is GotoTB(idx) and idx maps to a known block, replace with Br."""
    match inst.kind:
        IrTcOp.GotoTB(tb_index):
            if val Some(block_id) = tb_map.find(tb_index):
                return IrTcInst(..inst, kind: IrTcOp.Br(BlockId.new(block_id)))
        _: pass_do_nothing
    inst

# ============================================================================
# Cross-function TB inlining
# ============================================================================

struct CrossTbEntry:
    """Maps TB index to the function that contains it."""
    tb_index: i64
    func_index: i64

impl CrossTbEntry:
    static fn new(tb_index: i64, func_index: i64) -> CrossTbEntry:
        CrossTbEntry(tb_index: tb_index, func_index: func_index)

struct CrossTbMap:
    entries: [CrossTbEntry]

impl CrossTbMap:
    static fn new() -> CrossTbMap:
        CrossTbMap(entries: [])

    me add(tb_index: i64, func_index: i64):
        self.entries.push(CrossTbEntry.new(tb_index, func_index))

    fn find(tb_index: i64) -> i64?:
        for entry in self.entries:
            if entry.tb_index == tb_index:
                return Some(entry.func_index)
        nil

fn _build_cross_function_tb_map(functions: [IrTcFunction]) -> CrossTbMap:
    """Build a map from TB index to function index across the whole module."""
    var map = CrossTbMap.new()
    for fi in 0..functions.len():
        val func = functions[fi]
        if func.is_declaration:
            pass_do_nothing
        else:
            # Convention: function named "tb_N" handles TB index N
            if func.name.starts_with("tb_"):
                val idx_str = func.name[3:func.name.len()]
                val idx = _parse_i64(idx_str)
                if idx >= 0:
                    map.add(idx, fi)
    map

fn _inline_cross_function_tbs(
    func: IrTcFunction,
    tb_map: CrossTbMap,
    all_functions: [IrTcFunction]
) -> IrTcFunction:
    """Inline cross-function GotoTB targets.

    For each GotoTB that targets a different function:
    1. Copy all blocks from the target function with remapped IDs
    2. Replace GotoTB with Br to the inlined entry block
    """
    var current = func
    var any_changed = false

    for block in current.blocks:
        for inst in block.instructions:
            match inst.kind:
                IrTcOp.GotoTB(tb_index):
                    if val Some(target_func_idx) = tb_map.find(tb_index):
                        val target_func = all_functions[target_func_idx]
                        # Don't inline self
                        if target_func.name != current.name:
                            current = _do_inline(current, block.id, tb_index, target_func)
                            any_changed = true
                _: pass_do_nothing

    current

fn _do_inline(
    host_func: IrTcFunction,
    source_block_id: BlockId,
    tb_index: i64,
    target_func: IrTcFunction
) -> IrTcFunction:
    """Inline target_func's blocks into host_func.

    Remaps all block IDs in the target to avoid collisions.
    Replaces the GotoTB in source_block with Br to inlined entry.
    """
    if target_func.blocks.len() == 0:
        return host_func

    # Create block ID remapping: offset all target block IDs
    val offset = host_func.next_block_id
    var remap = BlockRemapTable.new()
    for block in target_func.blocks:
        remap.add(block.id.id, block.id.id + offset)

    # Remap and copy target blocks
    var inlined_blocks: [IrTcBlock] = []
    for block in target_func.blocks:
        val new_id = BlockId.new(block.id.id + offset)
        var new_block = IrTcBlock.new(new_id)
        new_block = IrTcBlock(..new_block, label: block.label)
        for inst in block.instructions:
            val remapped = _remap_block_refs(inst, remap)
            new_block.append(remapped)
        inlined_blocks.push(new_block)

    # Entry block of inlined code
    val inlined_entry_id = BlockId.new(target_func.blocks[0].id.id + offset)

    # Rewrite GotoTB in the source block to Br to inlined entry
    var new_blocks: [IrTcBlock] = []
    for block in host_func.blocks:
        if block.id.id == source_block_id.id:
            var new_block = IrTcBlock.new(block.id)
            new_block = IrTcBlock(..new_block, label: block.label)
            for inst in block.instructions:
                match inst.kind:
                    IrTcOp.GotoTB(idx):
                        if idx == tb_index:
                            new_block.append(IrTcInst(..inst, kind: IrTcOp.Br(inlined_entry_id)))
                        else:
                            new_block.append(inst)
                    _:
                        new_block.append(inst)
            new_blocks.push(new_block)
        else:
            new_blocks.push(block)

    # Append inlined blocks
    for ib in inlined_blocks:
        new_blocks.push(ib)

    val new_next_block = offset + target_func.next_block_id
    val new_next_value = host_func.next_value_id + target_func.next_value_id

    IrTcFunction(
        ..host_func,
        blocks: new_blocks,
        next_block_id: new_next_block,
        next_value_id: new_next_value
    )

fn _remap_block_refs(inst: IrTcInst, remap: BlockRemapTable) -> IrTcInst:
    """Remap all BlockId references in an instruction."""
    val new_kind = match inst.kind:
        IrTcOp.Br(target):
            IrTcOp.Br(remap.remap_block_id(target))
        IrTcOp.BrCond(c, t, f):
            IrTcOp.BrCond(c, remap.remap_block_id(t), remap.remap_block_id(f))
        IrTcOp.Switch(v, cases, default):
            var new_cases: [SwitchCase] = []
            for case_ in cases:
                new_cases.push(SwitchCase.new(case_.value, remap.remap_block_id(case_.target)))
            IrTcOp.Switch(v, new_cases, remap.remap_block_id(default))
        IrTcOp.Phi(d, incoming):
            var new_inc: [PhiEntry] = []
            for entry in incoming:
                new_inc.push(PhiEntry.new(remap.remap_block_id(entry.block), entry.value))
            IrTcOp.Phi(d, new_inc)
        _: inst.kind

    IrTcInst(..inst, kind: new_kind)
