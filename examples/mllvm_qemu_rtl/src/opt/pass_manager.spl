# IR_TC Pass Manager
#
# Infrastructure for running optimization passes on IR_TC modules.
# Provides a trait for passes, a manager to sequence them, and a
# default pipeline factory.

use core.types.{IrTcValue, IrTcTypeKind}
use core.ops.{IrTcOp, IrTcInst}
use core.block.{IrTcBlock, IrTcFunction, IrTcModule}
use opt.const_fold.{ConstFoldPass}
use opt.dce.{DcePass}
use opt.cse.{CsePass}
use opt.width_narrow.{WidthNarrowPass}
use opt.tb_chain.{TbChainPass}

# ============================================================================
# OptPass Trait
# ============================================================================

trait OptPass:
    """Interface for IR_TC optimization passes.

    Each pass transforms a function and returns the optimized version.
    Passes must be pure: they take a function and return a new one
    without modifying the original.
    """
    fn name() -> text
    fn run_on_function(func: IrTcFunction) -> IrTcFunction

# ============================================================================
# Pass Wrapper — dynamic dispatch for heterogeneous pass lists
# ============================================================================

enum PassKind:
    """Wrapper enum for concrete pass types.

    Simple does not support trait objects / dyn dispatch directly,
    so we use an enum to hold concrete pass instances.
    """
    ConstFold(pass_: ConstFoldPass)
    Dce(pass_: DcePass)
    Cse(pass_: CsePass)
    WidthNarrow(pass_: WidthNarrowPass)
    TbChain(pass_: TbChainPass)

impl PassKind:
    fn name() -> text:
        match self:
            ConstFold(p): p.name()
            Dce(p): p.name()
            Cse(p): p.name()
            WidthNarrow(p): p.name()
            TbChain(p): p.name()

    fn run_on_function(func: IrTcFunction) -> IrTcFunction:
        match self:
            ConstFold(p): p.run_on_function(func)
            Dce(p): p.run_on_function(func)
            Cse(p): p.run_on_function(func)
            WidthNarrow(p): p.run_on_function(func)
            TbChain(p): p.run_on_function(func)

# ============================================================================
# Pass Manager
# ============================================================================

struct PassManager:
    """Sequences and runs optimization passes on IR_TC modules.

    Passes are executed in order. Each pass transforms every non-declaration
    function in the module.
    """
    passes: [PassKind]
    verbose: bool           # Print pass names when running

impl PassManager:
    static fn new() -> PassManager:
        PassManager(passes: [], verbose: false)

    static fn with_verbose() -> PassManager:
        PassManager(passes: [], verbose: true)

    me add_pass(pass_: PassKind):
        """Add a pass to the pipeline."""
        self.passes.push(pass_)

    me add_const_fold():
        """Add constant folding pass."""
        self.passes.push(PassKind.ConstFold(ConstFoldPass.new()))

    me add_dce():
        """Add dead code elimination pass."""
        self.passes.push(PassKind.Dce(DcePass.new()))

    me add_cse():
        """Add common subexpression elimination pass."""
        self.passes.push(PassKind.Cse(CsePass.new()))

    me add_width_narrow():
        """Add width narrowing pass."""
        self.passes.push(PassKind.WidthNarrow(WidthNarrowPass.new()))

    me add_tb_chain():
        """Add translation block chaining pass."""
        self.passes.push(PassKind.TbChain(TbChainPass.new()))

    fn run_all(module: IrTcModule) -> IrTcModule:
        """Run all passes on every function in the module.

        Returns a new module with optimized functions.
        """
        var current = module

        for pass_ in self.passes:
            if self.verbose:
                print "  [opt] running pass: {pass_.name()}"

            # Special handling for TbChain which operates at module level
            match pass_:
                PassKind.TbChain(tb_pass):
                    current = tb_pass.run_on_module(current)
                _:
                    var new_functions: [IrTcFunction] = []
                    for func in current.functions:
                        if func.is_declaration:
                            new_functions.push(func)
                        else:
                            val optimized = pass_.run_on_function(func)
                            new_functions.push(optimized)
                    current = IrTcModule(..current, functions: new_functions)

        current

    fn pass_count() -> i64:
        self.passes.len()

    fn pass_names() -> [text]:
        var names: [text] = []
        for p in self.passes:
            names.push(p.name())
        names

# ============================================================================
# Default Pipeline Factory
# ============================================================================

fn create_default_pipeline() -> PassManager:
    """Create the default optimization pipeline.

    Order:
    1. const_fold — evaluate constant expressions first
    2. dce — remove dead code exposed by folding
    3. cse — eliminate redundant computations
    """
    var pm = PassManager.new()
    pm.add_const_fold()
    pm.add_dce()
    pm.add_cse()
    pm

fn create_full_pipeline() -> PassManager:
    """Create a full optimization pipeline including width narrowing and TB chaining.

    Order:
    1. const_fold — evaluate constant expressions
    2. dce — remove dead code
    3. cse — eliminate common subexpressions
    4. width_narrow — narrow to minimal bit widths
    5. dce — clean up after narrowing inserts Trunc/Ext
    6. tb_chain — chain translation blocks (emulation only)
    """
    var pm = PassManager.new()
    pm.add_const_fold()
    pm.add_dce()
    pm.add_cse()
    pm.add_width_narrow()
    pm.add_dce()
    pm.add_tb_chain()
    pm

fn create_emulation_pipeline() -> PassManager:
    """Create an optimization pipeline tuned for emulation workloads.

    Emphasizes TB chaining and width narrowing — the biggest wins
    for dynamic binary translation of narrow-word guests (AVR, 8086).
    """
    var pm = PassManager.new()
    pm.add_const_fold()
    pm.add_dce()
    pm.add_width_narrow()
    pm.add_dce()
    pm.add_cse()
    pm.add_tb_chain()
    pm
