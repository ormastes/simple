# IR_TC Dead Code Elimination Pass
#
# Removes instructions whose destination value is never used,
# unless the instruction has side effects.
# Iterates to a fixpoint since removing one instruction may make others dead.

use core.types.{IrTcValue}
use core.ops.{IrTcOp, IrTcInst}
use core.block.{IrTcBlock, IrTcFunction, IrTcModule, BlockId}

# ============================================================================
# Used-Value Set
# ============================================================================

struct UsedSet:
    """Tracks which value IDs are referenced as operands."""
    ids: [i64]

impl UsedSet:
    static fn new() -> UsedSet:
        UsedSet(ids: [])

    me add(id: i64):
        for existing in self.ids:
            if existing == id:
                return
        self.ids.push(id)

    fn contains(id: i64) -> bool:
        for existing in self.ids:
            if existing == id:
                return true
        false

    me add_value(val_: IrTcValue):
        self.add(val_.id)

# ============================================================================
# Side-Effect Detection
# ============================================================================

fn _is_side_effecting(op: IrTcOp) -> bool:
    """Returns true if the instruction has observable side effects.

    Side-effecting instructions must not be removed even if their
    result is unused.
    """
    match op:
        IrTcOp.Store(_, _, _): true
        IrTcOp.GuestStore(_, _, _, _): true
        IrTcOp.WriteGuestReg(_, _): true
        IrTcOp.Call(_, _, _, _): true
        IrTcOp.CallHelper(_, _, _): true
        IrTcOp.ExitTB(_): true
        IrTcOp.GotoTB(_): true
        IrTcOp.LookupGotoTB(_): true
        IrTcOp.SyncGuestPC(_): true
        IrTcOp.Barrier(_): true
        IrTcOp.Br(_): true
        IrTcOp.BrCond(_, _, _): true
        IrTcOp.Switch(_, _, _): true
        IrTcOp.Ret(_): true
        IrTcOp.Unreachable: true
        _: false

# ============================================================================
# Operand Collection — gather all values used by an instruction
# ============================================================================

fn _collect_operands(op: IrTcOp, used: UsedSet):
    """Add all operand value IDs from this instruction to the used set."""
    match op:
        # Arithmetic
        IrTcOp.Add(_, a, b):
            used.add_value(a)
            used.add_value(b)
        IrTcOp.Sub(_, a, b):
            used.add_value(a)
            used.add_value(b)
        IrTcOp.Mul(_, a, b):
            used.add_value(a)
            used.add_value(b)
        IrTcOp.Div(_, a, b, _):
            used.add_value(a)
            used.add_value(b)
        IrTcOp.Rem(_, a, b, _):
            used.add_value(a)
            used.add_value(b)
        IrTcOp.Neg(_, a):
            used.add_value(a)

        # Bitwise
        IrTcOp.And(_, a, b):
            used.add_value(a)
            used.add_value(b)
        IrTcOp.Or(_, a, b):
            used.add_value(a)
            used.add_value(b)
        IrTcOp.Xor(_, a, b):
            used.add_value(a)
            used.add_value(b)
        IrTcOp.Not(_, a):
            used.add_value(a)
        IrTcOp.Shl(_, a, b):
            used.add_value(a)
            used.add_value(b)
        IrTcOp.Shr(_, a, b):
            used.add_value(a)
            used.add_value(b)
        IrTcOp.Sar(_, a, b):
            used.add_value(a)
            used.add_value(b)
        IrTcOp.RotL(_, a, b):
            used.add_value(a)
            used.add_value(b)
        IrTcOp.RotR(_, a, b):
            used.add_value(a)
            used.add_value(b)

        # Comparison
        IrTcOp.Cmp(_, _, a, b):
            used.add_value(a)
            used.add_value(b)

        # Width conversion
        IrTcOp.Ext(_, src, _):
            used.add_value(src)
        IrTcOp.Trunc(_, src):
            used.add_value(src)
        IrTcOp.Bitcast(_, src):
            used.add_value(src)

        # Memory
        IrTcOp.Load(_, addr, _):
            used.add_value(addr)
        IrTcOp.Store(value, addr, _):
            used.add_value(value)
            used.add_value(addr)
        IrTcOp.Alloca(_, _, count):
            if val Some(c) = count:
                used.add_value(c)
        IrTcOp.GuestLoad(_, addr, _, _):
            used.add_value(addr)
        IrTcOp.GuestStore(value, addr, _, _):
            used.add_value(value)
            used.add_value(addr)

        # Control flow
        IrTcOp.BrCond(cond, _, _):
            used.add_value(cond)
        IrTcOp.Switch(value, _, _):
            used.add_value(value)
        IrTcOp.Ret(value):
            if val Some(v) = value:
                used.add_value(v)

        # Calls
        IrTcOp.Call(_, func, args, _):
            used.add_value(func)
            for arg in args:
                used.add_value(arg)
        IrTcOp.CallHelper(_, _, args):
            for arg in args:
                used.add_value(arg)

        # Guest state
        IrTcOp.WriteGuestReg(_, value):
            used.add_value(value)

        # TB control
        IrTcOp.LookupGotoTB(target_pc):
            used.add_value(target_pc)

        # Aggregates
        IrTcOp.GetElementPtr(_, base, indices):
            used.add_value(base)
            for idx in indices:
                used.add_value(idx)
        IrTcOp.ExtractValue(_, agg, _):
            used.add_value(agg)
        IrTcOp.InsertValue(_, agg, value, _):
            used.add_value(agg)
            used.add_value(value)

        # SSA
        IrTcOp.Phi(_, incoming):
            for entry in incoming:
                used.add_value(entry.value)

        # Special
        IrTcOp.SyncGuestPC(value):
            used.add_value(value)

        _: pass_do_nothing

# ============================================================================
# DCE Pass
# ============================================================================

struct DcePass:
    """Dead code elimination pass.

    Builds a used-value set from all operand references, then removes
    instructions whose destination is not in the set (unless side-effecting).
    Iterates until fixpoint.
    """
    _placeholder: i64

impl DcePass:
    static fn new() -> DcePass:
        DcePass(_placeholder: 0)

    fn name() -> text:
        "dce"

    fn run_on_function(func: IrTcFunction) -> IrTcFunction:
        """Eliminate dead code with fixpoint iteration."""
        var current = func
        var changed = true

        while changed:
            changed = false
            # Build used set
            var used = UsedSet.new()
            for block in current.blocks:
                for inst in block.instructions:
                    _collect_operands(inst.kind, used)

            # Remove dead instructions
            var new_blocks: [IrTcBlock] = []
            for block in current.blocks:
                var new_block = IrTcBlock.new(block.id)
                new_block = IrTcBlock(..new_block, label: block.label)

                for inst in block.instructions:
                    if _should_keep(inst, used):
                        new_block.append(inst)
                    else:
                        changed = true

                new_blocks.push(new_block)

            current = IrTcFunction(..current, blocks: new_blocks)

        current

fn _should_keep(inst: IrTcInst, used: UsedSet) -> bool:
    """Determine if an instruction should be kept."""
    # Always keep side-effecting instructions
    if _is_side_effecting(inst.kind):
        return true

    # Keep Nop (may be inserted by other passes)
    match inst.kind:
        IrTcOp.Nop: return true
        _: pass_do_nothing

    # If the instruction produces a value, keep it only if the value is used
    if val Some(dest) = inst.kind.dest_value():
        return used.contains(dest.id)

    # No dest, not side-effecting — can remove
    false
