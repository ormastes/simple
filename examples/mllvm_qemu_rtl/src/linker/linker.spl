# Width-Aware Linker Dispatcher
#
# Takes compiled CompactObject files and produces final executables
# for different target widths (8/16/32/64-bit).
# Dispatches to avr_elf, mz_exe, or smf_bridge based on output format.

use core.types.{GuestArch}
use format.compact_obj.{
    CompactObject, IrTcCompactSection, IrTcCompactSymbol,
    SECT_FLAG_READ, SECT_FLAG_WRITE, SECT_FLAG_EXEC,
    SYM_FLAG_GLOBAL, SYM_FLAG_WEAK, SYM_FLAG_FUNCTION,
    SECTION_ABS, read_string_at
}
use format.irtc_binary.{encode_u16_le, encode_u32_le, decode_u16_le}

# ============================================================================
# Output Formats
# ============================================================================

enum OutputFormat:
    """Supported output executable formats."""
    AvrElf          # ELF32 for AVR (8-bit, Harvard arch)
    AvrIntelHex     # Intel HEX for AVR flash programmers
    MzExe           # MS-DOS MZ EXE (16-bit real mode)
    Com             # MS-DOS COM flat binary (16-bit, ORG 0x100)
    Elf32           # Generic 32-bit ELF
    Elf64           # Generic 64-bit ELF
    RiscvElf32      # RISC-V 32-bit ELF
    RiscvElf64      # RISC-V 64-bit ELF

impl OutputFormat:
    fn to_text() -> text:
        match self:
            AvrElf: "avr-elf"
            AvrIntelHex: "avr-ihex"
            MzExe: "mz-exe"
            Com: "com"
            Elf32: "elf32"
            Elf64: "elf64"
            RiscvElf32: "riscv-elf32"
            RiscvElf64: "riscv-elf64"

    fn target_width() -> i64:
        """Implied target width for format."""
        match self:
            AvrElf: 8
            AvrIntelHex: 8
            MzExe: 16
            Com: 16
            Elf32: 32
            Elf64: 64
            RiscvElf32: 32
            RiscvElf64: 64

# ============================================================================
# Linker Configuration
# ============================================================================

struct LinkerConfig:
    """Configuration for the width-aware linker."""
    target_width: i64       # 8, 16, 32, or 64
    output_format: OutputFormat
    entry_point: text       # Symbol name for entry (e.g. "_start", "main")
    base_address: i64       # Base load address (0 for default)

impl LinkerConfig:
    static fn avr_elf() -> LinkerConfig:
        """Default config for AVR ELF output."""
        LinkerConfig(
            target_width: 8,
            output_format: OutputFormat.AvrElf,
            entry_point: "__vectors",
            base_address: 0
        )

    static fn avr_hex() -> LinkerConfig:
        """Default config for AVR Intel HEX output."""
        LinkerConfig(
            target_width: 8,
            output_format: OutputFormat.AvrIntelHex,
            entry_point: "__vectors",
            base_address: 0
        )

    static fn dos_exe() -> LinkerConfig:
        """Default config for MS-DOS MZ EXE output."""
        LinkerConfig(
            target_width: 16,
            output_format: OutputFormat.MzExe,
            entry_point: "_start",
            base_address: 0
        )

    static fn dos_com() -> LinkerConfig:
        """Default config for MS-DOS COM output."""
        LinkerConfig(
            target_width: 16,
            output_format: OutputFormat.Com,
            entry_point: "_start",
            base_address: 0x100
        )

    static fn elf32() -> LinkerConfig:
        """Default config for 32-bit ELF output."""
        LinkerConfig(
            target_width: 32,
            output_format: OutputFormat.Elf32,
            entry_point: "_start",
            base_address: 0x08048000
        )

    static fn elf64() -> LinkerConfig:
        """Default config for 64-bit ELF output."""
        LinkerConfig(
            target_width: 64,
            output_format: OutputFormat.Elf64,
            entry_point: "_start",
            base_address: 0x400000
        )

    static fn riscv32_elf() -> LinkerConfig:
        """Default config for RISC-V 32-bit ELF output."""
        LinkerConfig(
            target_width: 32,
            output_format: OutputFormat.RiscvElf32,
            entry_point: "_start",
            base_address: 0x80000000
        )

    static fn riscv64_elf() -> LinkerConfig:
        """Default config for RISC-V 64-bit ELF output."""
        LinkerConfig(
            target_width: 64,
            output_format: OutputFormat.RiscvElf64,
            entry_point: "_start",
            base_address: 0x80000000
        )

# ============================================================================
# Linker Error
# ============================================================================

enum LinkerError:
    """Errors during linking."""
    UndefinedSymbol(name: text)
    DuplicateSymbol(name: text)
    NoEntryPoint(name: text)
    SectionOverlap(sect_a: text, sect_b: text)
    WidthMismatch(expected: i64, got: i64)
    OutputTooLarge(size: i64, max_size: i64)
    InvalidFormat(message: text)

impl LinkerError:
    fn to_text() -> text:
        match self:
            UndefinedSymbol(name): "undefined symbol: {name}"
            DuplicateSymbol(name): "duplicate symbol: {name}"
            NoEntryPoint(name): "entry point not found: {name}"
            SectionOverlap(a, b): "sections overlap: {a} and {b}"
            WidthMismatch(exp, got): "width mismatch: expected {exp}-bit, got {got}-bit"
            OutputTooLarge(sz, mx): "output too large: {sz} bytes (max {mx})"
            InvalidFormat(msg): "invalid format: {msg}"

# ============================================================================
# Resolved Symbol
# ============================================================================

struct ResolvedSymbol:
    """A symbol after resolution across all objects."""
    name: text
    section_name: text      # Which merged section this belongs to
    value: i64              # Final address after section merging
    flags: i64              # Original symbol flags
    object_index: i64       # Source object index

impl ResolvedSymbol:
    fn is_global() -> bool:
        self.flags % 2 == 1

    fn is_weak() -> bool:
        (self.flags / 2) % 2 == 1

    fn is_function() -> bool:
        (self.flags / 4) % 2 == 1

# ============================================================================
# Merged Section
# ============================================================================

struct MergedSection:
    """A section merged from multiple objects."""
    name: text
    flags: i64
    addr: i64               # Final load address
    data: [i64]             # Combined section data

impl MergedSection:
    static fn new(name: text, flags: i64, addr: i64) -> MergedSection:
        MergedSection(name: name, flags: flags, addr: addr, data: [])

    fn size() -> i64:
        self.data.len()

    fn is_executable() -> bool:
        (self.flags / 4) % 2 == 1

    fn is_writable() -> bool:
        (self.flags / 2) % 2 == 1

# ============================================================================
# Link Result
# ============================================================================

struct LinkResult:
    """Output of the linker — merged sections and resolved symbols."""
    sections: [MergedSection]
    symbols: [ResolvedSymbol]
    entry_address: i64

# ============================================================================
# Main Linker Entry Point
# ============================================================================

fn link(objects: [CompactObject], config: LinkerConfig) -> Result<[i64], LinkerError>:
    """Link multiple CompactObjects into a final executable.

    Dispatches to the appropriate format writer based on config.output_format.
    """
    # Validate width consistency
    for obj in objects:
        if obj.header.width != config.target_width:
            return Err(LinkerError.WidthMismatch(
                expected: config.target_width,
                got: obj.header.width
            ))

    # Phase 1: Merge sections and resolve symbols
    val link_result = _merge_and_resolve(objects, config)?

    # Phase 2: Dispatch to format writer
    match config.output_format:
        AvrElf:
            use linker.avr_elf.{write_avr_elf}
            write_avr_elf(link_result, config)
        AvrIntelHex:
            use linker.avr_elf.{write_intel_hex}
            write_intel_hex(link_result, config)
        MzExe:
            use linker.mz_exe.{write_mz_exe}
            write_mz_exe(link_result, config)
        Com:
            use linker.mz_exe.{write_com}
            write_com(link_result, config)
        Elf32:
            use linker.smf_bridge.{link_via_smf}
            link_via_smf(link_result, config)
        Elf64:
            use linker.smf_bridge.{link_via_smf}
            link_via_smf(link_result, config)
        RiscvElf32:
            use linker.riscv_elf.{write_riscv32_elf}
            write_riscv32_elf(link_result, config)
        RiscvElf64:
            use linker.riscv_elf.{write_riscv64_elf}
            write_riscv64_elf(link_result, config)

# ============================================================================
# Section Merging and Symbol Resolution
# ============================================================================

fn _merge_and_resolve(objects: [CompactObject], config: LinkerConfig) -> Result<LinkResult, LinkerError>:
    """Merge sections from all objects and resolve symbol references."""
    # Collect all section names and merge
    var merged_sections: [MergedSection] = []
    var section_map: [text] = []    # Maps index -> section name

    # First pass: discover unique section names and set up merged sections
    for obj in objects:
        for sect in obj.sections:
            val name = read_string_at(obj.string_table, sect.name_off)
            var found = false
            for ms in merged_sections:
                if ms.name == name:
                    found = true
            if not found:
                val addr = _default_section_address(name, config)
                var ms = MergedSection.new(name, sect.flags, addr)
                merged_sections.push(ms)

    # Second pass: merge section data and record offsets for symbol relocation
    # section_offsets[obj_idx][sect_idx] = offset within merged section
    var all_offsets: [[i64]] = []
    for obj in objects:
        var obj_offsets: [i64] = []
        for sect in obj.sections:
            val name = read_string_at(obj.string_table, sect.name_off)
            # Find the merged section
            var offset: i64 = 0
            for i in 0..merged_sections.len():
                if merged_sections[i].name == name:
                    offset = merged_sections[i].data.len()
                    # Append section data
                    for b in sect.data:
                        merged_sections[i].data.push(b)
            obj_offsets.push(offset)
        all_offsets.push(obj_offsets)

    # Assign final addresses to merged sections
    var current_addr = config.base_address
    for i in 0..merged_sections.len():
        if merged_sections[i].addr == 0:
            merged_sections[i].addr = current_addr
        current_addr = merged_sections[i].addr + merged_sections[i].data.len()
        # Align to next 16-byte boundary
        if current_addr % 16 != 0:
            current_addr = current_addr + (16 - current_addr % 16)

    # Third pass: resolve symbols
    var resolved: [ResolvedSymbol] = []
    var global_names: [text] = []

    for obj_idx in 0..objects.len():
        val obj = objects[obj_idx]
        for sym in obj.symbols:
            val name = read_string_at(obj.string_table, sym.name_off)
            val is_global = sym.flags % 2 == 1
            val is_weak = (sym.flags / 2) % 2 == 1

            if sym.section == SECTION_ABS:
                # Absolute symbol — value is final
                var rs = ResolvedSymbol(
                    name: name,
                    section_name: "",
                    value: sym.value,
                    flags: sym.flags,
                    object_index: obj_idx
                )
                resolved.push(rs)
            else:
                if sym.section < obj.sections.len():
                    val sect = obj.sections[sym.section]
                    val sect_name = read_string_at(obj.string_table, sect.name_off)
                    # Find merged section and compute final address
                    var final_addr: i64 = sym.value
                    for mi in 0..merged_sections.len():
                        if merged_sections[mi].name == sect_name:
                            val base = merged_sections[mi].addr
                            val offset_in_merged = all_offsets[obj_idx][sym.section]
                            final_addr = base + offset_in_merged + sym.value

                    # Check for duplicate global symbols
                    if is_global and not is_weak:
                        for existing in global_names:
                            if existing == name:
                                return Err(LinkerError.DuplicateSymbol(name: name))
                        global_names.push(name)

                    var rs = ResolvedSymbol(
                        name: name,
                        section_name: sect_name,
                        value: final_addr,
                        flags: sym.flags,
                        object_index: obj_idx
                    )
                    resolved.push(rs)

    # Find entry point
    var entry_addr: i64 = config.base_address
    var entry_found = false
    for sym in resolved:
        if sym.name == config.entry_point:
            entry_addr = sym.value
            entry_found = true

    if not entry_found:
        return Err(LinkerError.NoEntryPoint(name: config.entry_point))

    Ok(LinkResult(
        sections: merged_sections,
        symbols: resolved,
        entry_address: entry_addr
    ))

# ============================================================================
# Default Section Addresses
# ============================================================================

fn _default_section_address(name: text, config: LinkerConfig) -> i64:
    """Assign default load addresses based on section name and target width."""
    match config.target_width:
        8:
            # AVR: .text in Flash (0x0000), .data/.bss in SRAM (0x0060 for ATmega)
            if name == ".text" or name == ".vectors":
                return 0
            if name == ".data":
                return 0x0060
            if name == ".bss":
                return 0      # Follows .data — will be computed
            if name == ".rodata":
                return 0      # In Flash after .text
            0
        16:
            # 8086: real mode segments
            if name == ".text":
                return 0
            if name == ".data":
                return 0
            if name == ".bss":
                return 0
            0
        32:
            # Typical 32-bit ELF layout
            if name == ".text":
                return 0x08048000
            if name == ".data":
                return 0x0804A000
            if name == ".bss":
                return 0
            0
        64:
            # Typical 64-bit ELF layout
            if name == ".text":
                return 0x400000
            if name == ".data":
                return 0x600000
            if name == ".bss":
                return 0
            0
        _:
            0

# ============================================================================
# Utility: Find symbol by name
# ============================================================================

fn find_symbol(result: LinkResult, name: text) -> ResolvedSymbol?:
    """Look up a resolved symbol by name."""
    for sym in result.symbols:
        if sym.name == name:
            return Some(sym)
    nil
