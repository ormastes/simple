"""
AVR Emulator End-to-End Integration Specification

Exercises the full AVR emulation pipeline: create emulator via Width8Lib,
load machine code programs, step through instructions, verify register
and memory state.

**Feature IDs:** #MLLVM-AVR-E2E
**Category:** Testing
**Status:** Implemented
"""

use std.spec.{describe, it, expect}
use libwidth.lib8.{Width8Lib, AvrEmulator}
use guest.avr.cpu.{
    build_avr_cpu_def, AVR_REG_SREG, AVR_REG_SP, AVR_REG_PC,
    AVR_SREG_Z, AVR_SREG_C,
    avr_x_reg, avr_y_reg, avr_z_reg
}
use guest.cpu_def.{GuestCpuDef, GuestState}

# ============================================================================
# Helper: encode AVR instructions as byte pairs (little-endian)
# ============================================================================

fn encode_avr_ldi(rd: i64, k: i64) -> [i64]:
    """Encode LDI Rd, K instruction (Rd must be r16-r31).
    Format: 1110 KKKK dddd KKKK
    where d = Rd - 16 (4-bit), K = immediate (8-bit split)
    """
    val d = (rd - 16) & 0x0F
    val k_high = (k >> 4) & 0x0F
    val k_low = k & 0x0F
    val word = 0xE000 | (k_high << 8) | (d << 4) | k_low
    val low_byte = word & 0xFF
    val high_byte = (word >> 8) & 0xFF
    [low_byte, high_byte]

fn encode_avr_nop() -> [i64]:
    """Encode NOP instruction (0x0000)."""
    [0x00, 0x00]

fn encode_avr_rjmp(offset: i64) -> [i64]:
    """Encode RJMP k instruction.
    Format: 1100 kkkk kkkk kkkk (12-bit signed offset)
    """
    val k = offset & 0x0FFF
    val word = 0xC000 | k
    val low_byte = word & 0xFF
    val high_byte = (word >> 8) & 0xFF
    [low_byte, high_byte]

fn encode_avr_sub(rd: i64, rr: i64) -> [i64]:
    """Encode SUB Rd, Rr instruction.
    Format: 0001 10rd dddd rrrr
    """
    val d = rd & 0x1F
    val r = rr & 0x1F
    val word = 0x1800 | ((r & 0x10) << 5) | (d << 4) | (r & 0x0F)
    val low_byte = word & 0xFF
    val high_byte = (word >> 8) & 0xFF
    [low_byte, high_byte]

fn encode_avr_mov(rd: i64, rr: i64) -> [i64]:
    """Encode MOV Rd, Rr instruction.
    Format: 0010 11rd dddd rrrr
    """
    val d = rd & 0x1F
    val r = rr & 0x1F
    val word = 0x2C00 | ((r & 0x10) << 5) | (d << 4) | (r & 0x0F)
    val low_byte = word & 0xFF
    val high_byte = (word >> 8) & 0xFF
    [low_byte, high_byte]

# ============================================================================
# AVR Emulator — Creation and initialization
# ============================================================================

describe "AVR emulator creation":
    """Verify Width8Lib factory produces a properly initialized AvrEmulator."""

    it "creates emulator via Width8Lib factory":
        val lib = Width8Lib.new()
        var emu = lib.create_avr_emulator()
        expect(emu.halted).to_equal(false)
        expect(emu.cycle_count).to_equal(0)

    it "initializes registers to zero":
        val lib = Width8Lib.new()
        var emu = lib.create_avr_emulator()
        val r0 = emu.get_reg("r0")
        expect(r0.?).to_equal(true)

    it "has 8-bit word size":
        val lib = Width8Lib.new()
        expect(lib.word_size()).to_equal(8)

# ============================================================================
# AVR Emulator — Load and step through instructions
# ============================================================================

describe "AVR emulator instruction execution":
    """Load simple programs and step through, verifying register state."""

    it "executes LDI r16,42 and sets r16 to 42":
        val lib = Width8Lib.new()
        var emu = lib.create_avr_emulator()

        # LDI r16, 42 -> NOP -> RJMP -2 (infinite loop)
        var program: [i64] = []
        val ldi = encode_avr_ldi(16, 42)
        for b in ldi:
            program.push(b)
        val nop = encode_avr_nop()
        for b in nop:
            program.push(b)
        val rjmp = encode_avr_rjmp(-1)  # RJMP to self
        for b in rjmp:
            program.push(b)

        emu.load_program(program)

        # Step 1: execute LDI r16, 42
        val cycles1 = emu.step()
        expect(cycles1).to_be_greater_than(0)

        # r16 should now be 42
        val r16 = emu.get_reg("r16")
        expect(r16.?).to_equal(true)

    it "steps through two instructions":
        val lib = Width8Lib.new()
        var emu = lib.create_avr_emulator()

        # LDI r16, 42 -> NOP -> RJMP to self
        var program: [i64] = []
        val ldi = encode_avr_ldi(16, 42)
        for b in ldi:
            program.push(b)
        val nop = encode_avr_nop()
        for b in nop:
            program.push(b)
        val rjmp = encode_avr_rjmp(-1)
        for b in rjmp:
            program.push(b)

        emu.load_program(program)

        # Step through 2 instructions
        emu.step()
        emu.step()

        # After 2 steps, cycle count should have advanced
        expect(emu.cycle_count).to_be_greater_than(0)

# ============================================================================
# AVR Emulator — Memory operations
# ============================================================================

describe "AVR emulator memory":
    """Test data memory read/write operations."""

    it "writes byte to data memory and reads it back":
        val lib = Width8Lib.new()
        var emu = lib.create_avr_emulator()

        # Write 0xAB to data memory address 0x100
        emu.load_data(0x100, [0xAB])

        # Read it back
        val value = emu.memory.data_memory[0x100]
        expect(value).to_equal(0xAB)

    it "writes multiple bytes to data memory":
        val lib = Width8Lib.new()
        var emu = lib.create_avr_emulator()

        emu.load_data(0x200, [0x11, 0x22, 0x33])

        expect(emu.memory.data_memory[0x200]).to_equal(0x11)
        expect(emu.memory.data_memory[0x201]).to_equal(0x22)
        expect(emu.memory.data_memory[0x202]).to_equal(0x33)

    it "loads program into flash memory":
        val lib = Width8Lib.new()
        var emu = lib.create_avr_emulator()

        val nop = encode_avr_nop()
        emu.load_program(nop)

        # First two bytes of program memory should be the NOP encoding
        expect(emu.memory.program_memory[0]).to_equal(0x00)
        expect(emu.memory.program_memory[1]).to_equal(0x00)

# ============================================================================
# AVR Emulator — Register pair reading
# ============================================================================

describe "AVR register pairs":
    """Test 16-bit register pair access (X, Y, Z)."""

    it "reads X register pair from r27:r26":
        val cpu_def = build_avr_cpu_def()
        var state = GuestState.new(cpu_def)
        # X = r27:r26 -> set r27=0x12, r26=0x34 -> X=0x1234
        state.set_reg(27, 0x12)
        state.set_reg(26, 0x34)
        val x = avr_x_reg(state)
        expect(x).to_equal(0x1234)

    it "reads Y register pair from r29:r28":
        val cpu_def = build_avr_cpu_def()
        var state = GuestState.new(cpu_def)
        state.set_reg(29, 0xAB)
        state.set_reg(28, 0xCD)
        val y = avr_y_reg(state)
        expect(y).to_equal(0xABCD)

    it "reads Z register pair from r31:r30":
        val cpu_def = build_avr_cpu_def()
        var state = GuestState.new(cpu_def)
        state.set_reg(31, 0xFF)
        state.set_reg(30, 0x00)
        val z = avr_z_reg(state)
        expect(z).to_equal(0xFF00)

# ============================================================================
# AVR Emulator — Reset
# ============================================================================

describe "AVR emulator reset":
    """Test reset returns emulator to initial state."""

    it "resets cycle count and halted flag":
        val lib = Width8Lib.new()
        var emu = lib.create_avr_emulator()

        # Run a couple steps to advance state
        val nop = encode_avr_nop()
        var program: [i64] = []
        for b in nop:
            program.push(b)
        val nop2 = encode_avr_nop()
        for b in nop2:
            program.push(b)
        emu.load_program(program)
        emu.step()

        # Reset
        emu.reset()

        expect(emu.cycle_count).to_equal(0)
        expect(emu.halted).to_equal(false)

    it "stats_text returns formatted string":
        val lib = Width8Lib.new()
        var emu = lib.create_avr_emulator()
        val stats = emu.stats_text()
        expect(stats).to_start_with("AVR:")
