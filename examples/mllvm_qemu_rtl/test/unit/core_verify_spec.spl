"""
IR_TC Verifier Specification

Tests for IrTcVerifier: valid module passes, emulation op mode enforcement,
missing terminators, type mismatches, and BrCond condition checks.
"""

use std.spec.{describe, it, expect}
use core.types.{IrTcTypeKind, IrTcValue, IrTcCond, GuestArch}
use core.ops.{IrTcOp, IrTcInst}
use core.mem_op.{MemOp, Endian, GuestRegId}
use core.block.{BlockId, IrTcBlock, IrTcFunction, IrTcParam, IrTcModule, IrTcModuleMode}
use core.builder.{IrTcBuilder}
use core.verify.{IrTcVerifier, VerifyError}

# ============================================================================
# Helper: build a valid compilation module
# ============================================================================

fn build_valid_compilation_module() -> IrTcModule:
    var builder = IrTcBuilder.new("valid_mod", IrTcModuleMode.Compilation)
    builder.begin_function("add_i32", [
        IrTcParam.new("a", IrTcTypeKind.I32),
        IrTcParam.new("b", IrTcTypeKind.I32)
    ], IrTcTypeKind.I32)

    val entry = builder.new_block("entry")
    builder.set_block(entry)
    val a = builder.param_value(0)
    val b = builder.param_value(1)
    val result = builder.add(a, b)
    builder.ret(Some(result))
    builder.end_function()
    builder.finish()

# ============================================================================
# Verifier — Valid module
# ============================================================================

describe "IrTcVerifier valid module":
    """
    ## Irtcverifier Valid Module Tests

    Validates IrTcVerifier valid module functionality.
    """

    it "reports zero errors for a well-formed compilation module":
        val module = build_valid_compilation_module()
        val errors = IrTcVerifier.verify_module(module)
        expect(errors.len()).to_equal(0)

# ============================================================================
# Verifier — Emulation ops in compilation mode
# ============================================================================

describe "IrTcVerifier emulation op enforcement":
    it "reports error for emulation op in compilation mode":
        var builder = IrTcBuilder.new("bad_mod", IrTcModuleMode.Compilation)
        builder.begin_function("bad_fn", [
            IrTcParam.new("addr", IrTcTypeKind.I32)
        ], IrTcTypeKind.Void)

        val entry = builder.new_block("entry")
        builder.set_block(entry)

        # Emit an emulation-only op in compilation mode
        val addr = builder.param_value(0)
        val mem = MemOp.new(4, false, Endian.Little)
        val loaded = builder.guest_load(addr, IrTcTypeKind.I32, mem, 0)
        builder.ret(nil)
        builder.end_function()

        val module = builder.finish()
        val errors = IrTcVerifier.verify_module(module)
        expect(errors.len()).to_be_greater_than(0)

        # At least one error should mention emulation
        val first_msg = errors[0].message
        expect(first_msg).to_contain("emulation")

    it "allows emulation ops in emulation mode":
        var builder = IrTcBuilder.new("emu_mod", IrTcModuleMode.Emulation)
        builder.begin_function("emu_fn", [
            IrTcParam.new("addr", IrTcTypeKind.I16)
        ], IrTcTypeKind.Void)

        val entry = builder.new_block("entry")
        builder.set_block(entry)

        val addr = builder.param_value(0)
        val mem = MemOp.new(1, false, Endian.Little)
        val loaded = builder.guest_load(addr, IrTcTypeKind.I8, mem, 0)
        builder.exit_tb(0)
        builder.end_function()

        val module = builder.finish()
        val errors = IrTcVerifier.verify_module(module)
        expect(errors.len()).to_equal(0)

# ============================================================================
# Verifier — Missing block terminator
# ============================================================================

describe "IrTcVerifier missing terminator":
    it "reports error when block has no terminator":
        # Manually build a function with a non-terminated block
        var func = IrTcFunction.new("unterminated", [], IrTcTypeKind.Void)
        val bid = func.new_block_with_label("entry")

        # Add a non-terminator instruction but no terminator
        var block = func.blocks[0]
        val a = IrTcValue.new(0, IrTcTypeKind.I32)
        val b = IrTcValue.new(1, IrTcTypeKind.I32)
        val dest = IrTcValue.new(2, IrTcTypeKind.I32)
        block.append(IrTcInst.new(IrTcOp.Add(dest: dest, a: a, b: b)))
        func.blocks[0] = block

        var module = IrTcModule.new("test", IrTcModuleMode.Compilation)
        module.add_function(func)

        val errors = IrTcVerifier.verify_module(module)
        expect(errors.len()).to_be_greater_than(0)

        val found_terminator_error = errors[0].message
        expect(found_terminator_error).to_contain("terminated")

# ============================================================================
# Verifier — Type mismatch in binary ops
# ============================================================================

describe "IrTcVerifier type mismatch":
    it "reports error when Add operand types differ":
        var func = IrTcFunction.new("bad_add", [], IrTcTypeKind.I32)
        val bid = func.new_block_with_label("entry")

        var block = func.blocks[0]
        # a: i32, b: i16 — type mismatch
        val a = IrTcValue.new(0, IrTcTypeKind.I32)
        val b = IrTcValue.new(1, IrTcTypeKind.I16)
        val dest = IrTcValue.new(2, IrTcTypeKind.I32)
        block.append(IrTcInst.new(IrTcOp.Add(dest: dest, a: a, b: b)))
        block.append(IrTcInst.new(IrTcOp.Ret(value: Some(dest))))
        func.blocks[0] = block

        var module = IrTcModule.new("test", IrTcModuleMode.Compilation)
        module.add_function(func)

        val errors = IrTcVerifier.verify_module(module)
        expect(errors.len()).to_be_greater_than(0)

        val first_msg = errors[0].message
        expect(first_msg).to_contain("mismatch")

# ============================================================================
# Verifier — BrCond with non-i1 condition
# ============================================================================

describe "IrTcVerifier BrCond condition type":
    it "reports error when BrCond condition is not i1":
        var func = IrTcFunction.new("bad_brcond", [], IrTcTypeKind.Void)
        val bb0 = func.new_block_with_label("entry")
        val bb1 = func.new_block_with_label("then")
        val bb2 = func.new_block_with_label("else")

        # Entry block: BrCond with i32 condition (wrong — should be i1)
        var block0 = func.blocks[0]
        val cond = IrTcValue.new(0, IrTcTypeKind.I32)
        block0.append(IrTcInst.new(IrTcOp.BrCond(cond: cond, true_: bb1, false_: bb2)))
        func.blocks[0] = block0

        # Then block
        var block1 = func.blocks[1]
        block1.append(IrTcInst.new(IrTcOp.Ret(value: nil)))
        func.blocks[1] = block1

        # Else block
        var block2 = func.blocks[2]
        block2.append(IrTcInst.new(IrTcOp.Ret(value: nil)))
        func.blocks[2] = block2

        var module = IrTcModule.new("test", IrTcModuleMode.Compilation)
        module.add_function(func)

        val errors = IrTcVerifier.verify_module(module)
        expect(errors.len()).to_be_greater_than(0)

        val first_msg = errors[0].message
        expect(first_msg).to_contain("i1")
