"""
RISC-V Shared Decoder Common Helpers Specification

Tests for the shared decoder_common module: register read/write helpers
that enforce x0 hardwired-zero semantics, and constant creation.

**Feature IDs:** #MLLVM-RISCV-DECODER-COMMON
**Category:** Testing
**Status:** Implemented
"""

use std.spec.{describe, it, expect}
use core.types.{IrTcTypeKind, GuestArch}
use core.builder.{IrTcBuilder}
use core.block.{IrTcModuleMode}
use guest.riscv.decoder_common.{rv_read_gpr, rv_write_gpr, rv_const}

# ============================================================================
# Helper: create a fresh builder for IR emission tests
# ============================================================================

fn make_builder() -> IrTcBuilder:
    """Create a fresh IrTcBuilder in emulation mode for testing."""
    IrTcBuilder.new("test_dc", IrTcModuleMode.Emulation)

# ============================================================================
# rv_read_gpr -- x0 always returns zero constant
# ============================================================================

describe "rv_read_gpr":
    """Verify x0 returns a zero constant, other registers produce read ops."""

    it "returns zero constant for x0 (RV32)":
        var builder = make_builder()
        val result = rv_read_gpr(builder, GuestArch.Riscv32, 0, IrTcTypeKind.I32)
        # x0 should produce a value (the zero constant), not nil
        expect(result.?).to_equal(true)

    it "returns zero constant for x0 (RV64)":
        var builder = make_builder()
        val result = rv_read_gpr(builder, GuestArch.Riscv64, 0, IrTcTypeKind.I64)
        expect(result.?).to_equal(true)

    it "returns a value for non-zero register":
        var builder = make_builder()
        val result = rv_read_gpr(builder, GuestArch.Riscv32, 10, IrTcTypeKind.I32)
        expect(result.?).to_equal(true)

# ============================================================================
# rv_write_gpr -- x0 writes are silently discarded
# ============================================================================

describe "rv_write_gpr":
    """Verify writes to x0 are discarded, writes to other regs emit ops."""

    it "skips write to x0 without error":
        var builder = make_builder()
        val value = rv_const(builder, IrTcTypeKind.I32, 42)
        # Should not crash — write to x0 is silently ignored
        rv_write_gpr(builder, GuestArch.Riscv32, 0, value)
        # Verify no write op was emitted by checking op count stays low
        val ops = builder.op_count()
        # Only the const allocation should be present, no write op
        expect(ops).to_be_less_than(3)

    it "emits write for non-zero register":
        var builder = make_builder()
        val value = rv_const(builder, IrTcTypeKind.I32, 99)
        rv_write_gpr(builder, GuestArch.Riscv32, 10, value)
        # A write op should now be emitted
        val ops = builder.op_count()
        expect(ops).to_be_greater_than(0)

# ============================================================================
# rv_const -- creates a word-sized constant value
# ============================================================================

describe "rv_const":
    """Verify constant creation produces valid IrTcValue objects."""

    it "creates I32 constant":
        var builder = make_builder()
        val result = rv_const(builder, IrTcTypeKind.I32, 123)
        expect(result.?).to_equal(true)

    it "creates I64 constant":
        var builder = make_builder()
        val result = rv_const(builder, IrTcTypeKind.I64, 456)
        expect(result.?).to_equal(true)

    it "creates zero constant":
        var builder = make_builder()
        val result = rv_const(builder, IrTcTypeKind.I32, 0)
        expect(result.?).to_equal(true)
