"""
AVR Guest CPU Definition Specification

Tests for build_avr_cpu_def(): register count, widths, address spaces,
and GuestState register read/write with masking.
"""

use std.spec.{describe, it, expect}
use core.types.{GuestArch}
use core.mem_op.{Endian}
use guest.cpu_def.{GuestCpuDef, GuestState}
use guest.avr.cpu.{build_avr_cpu_def, AVR_REG_SREG, AVR_REG_SP, AVR_REG_PC}

# ============================================================================
# AVR CPU Definition — Structure
# ============================================================================

describe "AVR CPU definition structure":
    it "has word_size of 8":
        val cpu = build_avr_cpu_def()
        expect(cpu.word_size).to_equal(8)

    it "has architecture set to Avr":
        val cpu = build_avr_cpu_def()
        expect(cpu.arch.to_text()).to_equal("avr")

    it "has 35 registers (r0-r31 + SREG + SP + PC)":
        val cpu = build_avr_cpu_def()
        expect(cpu.registers.len()).to_equal(35)

    it "has little-endian byte order":
        val cpu = build_avr_cpu_def()
        expect(cpu.endian.to_text()).to_equal("le")

    it "has name 'avr'":
        val cpu = build_avr_cpu_def()
        expect(cpu.name).to_equal("avr")

# ============================================================================
# AVR CPU Definition — Register widths
# ============================================================================

describe "AVR register widths":
    it "general purpose registers r0-r31 are 8-bit":
        val cpu = build_avr_cpu_def()
        # Check r0 (index 0)
        expect(cpu.registers[0].width).to_equal(8)
        # Check r31 (index 31)
        expect(cpu.registers[31].width).to_equal(8)

    it "SREG is 8-bit":
        val cpu = build_avr_cpu_def()
        expect(cpu.registers[AVR_REG_SREG].width).to_equal(8)

    it "SP is 16-bit":
        val cpu = build_avr_cpu_def()
        expect(cpu.registers[AVR_REG_SP].width).to_equal(16)

    it "PC is 16-bit":
        val cpu = build_avr_cpu_def()
        expect(cpu.registers[AVR_REG_PC].width).to_equal(16)

# ============================================================================
# AVR CPU Definition — Address spaces
# ============================================================================

describe "AVR address spaces":
    it "has 3 address spaces (data, program, io)":
        val cpu = build_avr_cpu_def()
        expect(cpu.addr_spaces.len()).to_equal(3)

    it "data address space is 16-bit":
        val cpu = build_avr_cpu_def()
        expect(cpu.addr_spaces[0].addr_width).to_equal(16)

    it "program address space is 16-bit":
        val cpu = build_avr_cpu_def()
        expect(cpu.addr_spaces[1].addr_width).to_equal(16)

    it "io address space is 8-bit":
        val cpu = build_avr_cpu_def()
        expect(cpu.addr_spaces[2].addr_width).to_equal(8)

# ============================================================================
# GuestState — Register access with masking
# ============================================================================

describe "GuestState register access":
    it "initializes all registers to zero":
        val cpu = build_avr_cpu_def()
        val state = GuestState.new(cpu)
        expect(state.get_reg(0)).to_equal(0)
        expect(state.get_reg(AVR_REG_SREG)).to_equal(0)

    it "set_reg masks to 8-bit for general purpose registers":
        val cpu = build_avr_cpu_def()
        var state = GuestState.new(cpu)
        # Set r0 to 0x1FF (exceeds 8-bit)
        state.set_reg(0, 0x1FF)
        # Should be masked to 0xFF
        expect(state.get_reg(0)).to_equal(0xFF)

    it "set_reg masks to 16-bit for SP":
        val cpu = build_avr_cpu_def()
        var state = GuestState.new(cpu)
        # Set SP to 0x1FFFF (exceeds 16-bit)
        state.set_reg(AVR_REG_SP, 0x1FFFF)
        # Should be masked to 0xFFFF
        expect(state.get_reg(AVR_REG_SP)).to_equal(0xFFFF)

    it "get_reg_by_name returns value for valid name":
        val cpu = build_avr_cpu_def()
        var state = GuestState.new(cpu)
        state.set_reg(AVR_REG_SREG, 0x42)
        val result = state.get_reg_by_name("SREG")
        expect(result.?).to_equal(true)

    it "get_reg_by_name returns nil for invalid name":
        val cpu = build_avr_cpu_def()
        val state = GuestState.new(cpu)
        val result = state.get_reg_by_name("NONEXISTENT")
        expect(result).to_be_nil()
