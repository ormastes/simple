"""
8086 Guest CPU Definition Specification

Tests for build_i8086_cpu_def(): register count, widths, sub-register aliases,
and segment:offset address resolution.
"""

use std.spec.{describe, it, expect}
use core.types.{GuestArch}
use core.mem_op.{Endian}
use guest.cpu_def.{GuestCpuDef, GuestState}
use guest.i8086.cpu.{
    build_i8086_cpu_def,
    X86_REG_AX, X86_REG_BX, X86_REG_CX, X86_REG_DX,
    X86_REG_SI, X86_REG_DI, X86_REG_BP, X86_REG_SP,
    X86_REG_CS, X86_REG_DS, X86_REG_SS, X86_REG_ES,
    X86_REG_IP, X86_REG_FLAGS
}
use guest.i8086.segment.{resolve_segment_offset}

# ============================================================================
# 8086 CPU Definition — Structure
# ============================================================================

describe "8086 CPU definition structure":
    """
    ## 8086 Cpu Definition Structure Tests

    Validates 8086 CPU definition structure functionality.
    """

    it "has word_size of 16":
        val cpu = build_i8086_cpu_def()
        expect(cpu.word_size).to_equal(16)

    it "has architecture set to I8086":
        val cpu = build_i8086_cpu_def()
        expect(cpu.arch.to_text()).to_equal("i8086")

    it "has 14 registers (AX-SP + CS-ES + IP + FLAGS)":
        val cpu = build_i8086_cpu_def()
        expect(cpu.registers.len()).to_equal(14)

    it "has little-endian byte order":
        val cpu = build_i8086_cpu_def()
        expect(cpu.endian.to_text()).to_equal("le")

    it "has name 'i8086'":
        val cpu = build_i8086_cpu_def()
        expect(cpu.name).to_equal("i8086")

# ============================================================================
# 8086 CPU Definition — Register widths
# ============================================================================

describe "8086 register widths":
    it "AX is 16-bit":
        val cpu = build_i8086_cpu_def()
        expect(cpu.registers[X86_REG_AX].width).to_equal(16)

    it "FLAGS is 16-bit":
        val cpu = build_i8086_cpu_def()
        expect(cpu.registers[X86_REG_FLAGS].width).to_equal(16)

    it "IP is 16-bit":
        val cpu = build_i8086_cpu_def()
        expect(cpu.registers[X86_REG_IP].width).to_equal(16)

    it "CS segment register is 16-bit":
        val cpu = build_i8086_cpu_def()
        expect(cpu.registers[X86_REG_CS].width).to_equal(16)

# ============================================================================
# 8086 CPU Definition — Sub-register aliases
# ============================================================================

describe "8086 sub-register aliases":
    it "AX has AL and AH aliases":
        val cpu = build_i8086_cpu_def()
        val ax = cpu.registers[X86_REG_AX]
        expect(ax.aliases.len()).to_equal(2)

    it "AX first alias is AL (bit 0, width 8)":
        val cpu = build_i8086_cpu_def()
        val ax = cpu.registers[X86_REG_AX]
        val al = ax.aliases[0]
        expect(al.name).to_equal("AL")
        expect(al.bit_offset).to_equal(0)
        expect(al.width).to_equal(8)

    it "AX second alias is AH (bit 8, width 8)":
        val cpu = build_i8086_cpu_def()
        val ax = cpu.registers[X86_REG_AX]
        val ah = ax.aliases[1]
        expect(ah.name).to_equal("AH")
        expect(ah.bit_offset).to_equal(8)
        expect(ah.width).to_equal(8)

    it "BX has BL and BH aliases":
        val cpu = build_i8086_cpu_def()
        val bx = cpu.registers[X86_REG_BX]
        expect(bx.aliases.len()).to_equal(2)
        expect(bx.aliases[0].name).to_equal("BL")
        expect(bx.aliases[1].name).to_equal("BH")

    it "SI has no sub-register aliases":
        val cpu = build_i8086_cpu_def()
        val si = cpu.registers[X86_REG_SI]
        expect(si.aliases.len()).to_equal(0)

# ============================================================================
# 8086 CPU Definition — Address spaces
# ============================================================================

describe "8086 address spaces":
    it "has 1 address space (20-bit memory)":
        val cpu = build_i8086_cpu_def()
        expect(cpu.addr_spaces.len()).to_equal(1)

    it "memory address space is 20-bit":
        val cpu = build_i8086_cpu_def()
        expect(cpu.addr_spaces[0].addr_width).to_equal(20)

    it "memory address space is 1MB":
        val cpu = build_i8086_cpu_def()
        expect(cpu.addr_spaces[0].size).to_equal(1048576)

# ============================================================================
# Segment:Offset address resolution
# ============================================================================

describe "resolve_segment_offset":
    it "calculates physical address from segment and offset":
        # 0x1000 * 16 + 0x0100 = 0x10000 + 0x100 = 0x10100
        val addr = resolve_segment_offset(0x1000, 0x0100)
        expect(addr).to_equal(0x10100)

    it "wraps at 1MB boundary (20-bit mask)":
        # 0xFFFF * 16 + 0x0010 = 0x100000 → masked to 0x00000
        val addr = resolve_segment_offset(0xFFFF, 0x0010)
        expect(addr).to_equal(0x00000)

    it "handles zero segment and offset":
        val addr = resolve_segment_offset(0, 0)
        expect(addr).to_equal(0)

    it "handles segment 0 with offset":
        val addr = resolve_segment_offset(0, 0x100)
        expect(addr).to_equal(0x100)

    it "handles classic DOS segment:offset 0x0700:0x0000":
        val addr = resolve_segment_offset(0x0700, 0x0000)
        expect(addr).to_equal(0x7000)

    it "handles wrap-around at boundary":
        # 0xFFFF * 16 + 0xFFFF = 0xFFFEF + 0xFFFF = 0x10FFEF → & 0xFFFFF = 0x0FFEF
        val addr = resolve_segment_offset(0xFFFF, 0xFFFF)
        expect(addr).to_equal(0x0FFEF)
