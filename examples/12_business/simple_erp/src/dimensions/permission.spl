# UBS Dimension — Permission (capability / effect)
#
# Owns "who may see/do what" — and, critically, the agent-safety primitive. An
# agent or request runs with an explicit capability set; an effect it was not
# granted is simply absent. A "collections agent" handed only {read:AR,
# write:dunning} is structurally incapable of touching payroll (doc §2.6). The
# design target lifts this to the compile-time effect system; here it is the
# runtime-checked equivalent.

struct CapabilitySet:
    val effects: [text]

fn empty_caps() -> CapabilitySet:
    var e: [text] = []
    return CapabilitySet { effects: e }

fn grant(caps: CapabilitySet, effect: text) -> CapabilitySet:
    var e = caps.effects
    e.push(effect)
    return CapabilitySet { effects: e }

# Does the set carry the named effect? Absence == denial.
fn has_capability(caps: CapabilitySet, effect: text) -> bool:
    for e in caps.effects:
        if e == effect:
            return true
    return false
