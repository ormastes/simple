# Web Route Layer — pure, testable request routing over the shared
# guarded-write framework
#
# No live server here: `route_table` is the declarative map from HTTP
# method+path to a lane action, `find_route` resolves a request to one of
# those routes, and `dispatch` runs the request through the ONE gate every
# lane already uses (read routes check role_can directly; write routes go
# through gate_write so session -> rbac -> validation -> idempotency is
# enforced exactly once, in exactly one place).

use framework.guarded.{Tenant, Actor, Session, WriteResult, gate_write, role_can}

struct Route:
    val method: text
    val path: text
    val action: text
    val requires_write: bool

fn route_table() -> [Route]:
    var routes: [Route] = []
    routes.push(Route { method: "POST", path: "/api/crm/leads", action: "crm.write", requires_write: true })
    routes.push(Route { method: "POST", path: "/api/reservations", action: "reservation.write", requires_write: true })
    routes.push(Route { method: "POST", path: "/api/sales", action: "sale.write", requires_write: true })
    routes.push(Route { method: "POST", path: "/api/market/listings", action: "market.write", requires_write: true })
    routes.push(Route { method: "POST", path: "/api/restaurant/orders", action: "restaurant.write", requires_write: true })
    routes.push(Route { method: "GET", path: "/api/audit", action: "audit.read", requires_write: false })
    routes.push(Route { method: "GET", path: "/api/reports/summary", action: "report.read", requires_write: false })
    return routes

# Sentinel returned by find_route on a miss: an empty action marks "no route".
fn not_found_route() -> Route:
    return Route { method: "", path: "", action: "", requires_write: false }

fn find_route(method: text, path: text) -> Route:
    for route in route_table():
        if route.method == method and route.path == path:
            return route
    return not_found_route()

# Route a request through the gate. Unknown routes are denied with
# reason "not-found". Read routes are allowed iff the actor's role can perform
# the action (no session/idempotency needed for a read). Write routes go
# through the full framework.gate_write pipeline.
fn dispatch(session: Session, tenant: Tenant, user: Actor, method: text, path: text, record_valid: bool, key: text, used_keys: [text]) -> WriteResult:
    val route = find_route(method, path)
    if route.action == "":
        return WriteResult { ok: false, reason: "not-found", audit_action: "", ledger_key: "" }
    if not route.requires_write:
        if role_can(user.role, route.action):
            return WriteResult { ok: true, reason: "accepted", audit_action: route.action, ledger_key: "" }
        return WriteResult { ok: false, reason: "forbidden", audit_action: route.action, ledger_key: "" }
    return gate_write(session, tenant, user, route.action, record_valid, key, used_keys)
