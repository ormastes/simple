# Business Suite — entrypoint
#
# Exercises every lane (CRM, reservation, sale, market, restaurant) through
# the shared guarded-write framework: one accepted write and one denied write
# per lane via each lane's own submit_*_write entry point, plus the same
# writes replayed through the web route layer's dispatch() (which itself
# funnels into framework.gate_write) to prove the routing table wires up to
# the ONE gate every lane already shares.

use framework.guarded.{Tenant, Actor, Session, WriteResult, gate_write_with_approval}
use kernel.event_log.{EventLog, new_event_log, event_count}
use kernel.projection.{JournalEntry, account_balance}
use kernel.posting.{cash_account, journal_for_accepted, post_accepted_write, posting_balanced}
use lanes.crm.{Lead, submit_lead_write}
use lanes.reservation.{Reservation, submit_reservation_write}
use lanes.sale.{Sale, submit_sale_write}
use lanes.market.{Listing, submit_listing_write}
use lanes.restaurant.{TableOrder, submit_order_write}
use web.routes.{route_table, dispatch}

fn demo_tenant() -> Tenant:
    return Tenant { id: "tenant-suite-demo", name: "Suite Demo Co" }

fn operator_actor() -> Actor:
    return Actor { id: 1, name: "Oli", role: "operator" }

fn auditor_actor() -> Actor:
    return Actor { id: 3, name: "Ana", role: "auditor" }

fn active_session(user_id: i64, tenant_id: text) -> Session:
    return Session { token: "sess-{user_id}", user_id: user_id, tenant_id: tenant_id, active: true }

fn inactive_session(user_id: i64, tenant_id: text) -> Session:
    return Session { token: "sess-{user_id}", user_id: user_id, tenant_id: tenant_id, active: false }

fn accepted_count(results: [WriteResult]) -> i64:
    var count = 0
    for r in results:
        if r.ok:
            count = count + 1
    return count

fn denied_count(results: [WriteResult]) -> i64:
    var count = 0
    for r in results:
        if not r.ok:
            count = count + 1
    return count

fn run_crm_lane(tenant: Tenant) -> [WriteResult]:
    val op = operator_actor()
    val ok_session = active_session(op.id, tenant.id)
    val bad_session = inactive_session(op.id, tenant.id)
    val lead = Lead { id: 1, name: "Acme", account: "Acme", contact: "ops@acme.test", stage: "new", value: 10000, next_action: "call" }
    var used: [text] = []
    var results: [WriteResult] = []
    results.push(submit_lead_write(ok_session, tenant, op, lead, "crm-suite-1", used))
    results.push(submit_lead_write(bad_session, tenant, op, lead, "crm-suite-2", used))
    return results

fn run_reservation_lane(tenant: Tenant) -> [WriteResult]:
    val op = operator_actor()
    val ok_session = active_session(op.id, tenant.id)
    val bad_session = inactive_session(op.id, tenant.id)
    val r = Reservation { id: 1, resource: "table-1", kind: "dine-in", capacity: 4, booked: 0, status: "open", deposit: 0 }
    var used: [text] = []
    var results: [WriteResult] = []
    results.push(submit_reservation_write(ok_session, tenant, op, r, "reservation-suite-1", used))
    results.push(submit_reservation_write(bad_session, tenant, op, r, "reservation-suite-2", used))
    return results

fn run_sale_lane(tenant: Tenant) -> [WriteResult]:
    val op = operator_actor()
    val ok_session = active_session(op.id, tenant.id)
    val bad_session = inactive_session(op.id, tenant.id)
    val s = Sale { id: 1, channel: "web", subtotal: 10000, tax: 800, paid: false, status: "open", audit_note: "suite-demo" }
    var used: [text] = []
    var results: [WriteResult] = []
    results.push(submit_sale_write(ok_session, tenant, op, s, "sale-suite-1", used))
    results.push(submit_sale_write(bad_session, tenant, op, s, "sale-suite-2", used))
    return results

fn run_market_lane(tenant: Tenant) -> [WriteResult]:
    val op = operator_actor()
    val ok_session = active_session(op.id, tenant.id)
    val bad_session = inactive_session(op.id, tenant.id)
    val listing = Listing { id: 1, seller_id: 1, sku: "sku-1", title: "Widget", price: 500, stock: 10, status: "active" }
    var used: [text] = []
    var results: [WriteResult] = []
    results.push(submit_listing_write(ok_session, tenant, op, listing, "market-suite-1", used))
    results.push(submit_listing_write(bad_session, tenant, op, listing, "market-suite-2", used))
    return results

fn run_restaurant_lane(tenant: Tenant) -> [WriteResult]:
    val op = operator_actor()
    val ok_session = active_session(op.id, tenant.id)
    val bad_session = inactive_session(op.id, tenant.id)
    var item_ids: [i64] = []
    item_ids.push(1)
    val order = TableOrder { id: 1, table_no: 5, item_ids: item_ids, status: "open", total: 1500 }
    var used: [text] = []
    var results: [WriteResult] = []
    results.push(submit_order_write(ok_session, tenant, op, order, "restaurant-suite-1", used))
    results.push(submit_order_write(bad_session, tenant, op, order, "restaurant-suite-2", used))
    return results

# Replay the write routes through the route layer's dispatch() (which itself
# calls framework.gate_write) to prove the route table wires up to the ONE
# gate, and check the read routes and an unknown route while we're at it.
fn check_routes(tenant: Tenant):
    val op = operator_actor()
    val aud = auditor_actor()
    val op_session = active_session(op.id, tenant.id)
    val aud_session = active_session(aud.id, tenant.id)
    var used: [text] = []

    val crm_write = dispatch(op_session, tenant, op, "POST", "/api/crm/leads", true, "route-crm-1", used)
    assert crm_write.ok
    val reservation_write = dispatch(op_session, tenant, op, "POST", "/api/reservations", true, "route-reservation-1", used)
    assert reservation_write.ok
    val sale_write = dispatch(op_session, tenant, op, "POST", "/api/sales", true, "route-sale-1", used)
    assert sale_write.ok
    val market_write = dispatch(op_session, tenant, op, "POST", "/api/market/listings", true, "route-market-1", used)
    assert market_write.ok
    val restaurant_write = dispatch(op_session, tenant, op, "POST", "/api/restaurant/orders", true, "route-restaurant-1", used)
    assert restaurant_write.ok

    val invalid_write = dispatch(op_session, tenant, op, "POST", "/api/market/listings", false, "route-market-2", used)
    assert not invalid_write.ok
    assert invalid_write.reason == "invalid-record"

    val forbidden_write = dispatch(aud_session, tenant, aud, "POST", "/api/restaurant/orders", true, "route-restaurant-3", used)
    assert not forbidden_write.ok
    assert forbidden_write.reason == "forbidden"

    val audit_read = dispatch(aud_session, tenant, aud, "GET", "/api/audit", true, "", used)
    assert audit_read.ok

    val unknown = dispatch(op_session, tenant, op, "DELETE", "/api/nope", true, "", used)
    assert not unknown.ok
    assert unknown.reason == "not-found"

fn main():
    val tenant = demo_tenant()

    val crm_results = run_crm_lane(tenant)
    val reservation_results = run_reservation_lane(tenant)
    val sale_results = run_sale_lane(tenant)
    val market_results = run_market_lane(tenant)
    val restaurant_results = run_restaurant_lane(tenant)

    assert accepted_count(crm_results) >= 1
    assert denied_count(crm_results) >= 1
    assert accepted_count(reservation_results) >= 1
    assert denied_count(reservation_results) >= 1
    assert accepted_count(sale_results) >= 1
    assert denied_count(sale_results) >= 1
    assert accepted_count(market_results) >= 1
    assert denied_count(market_results) >= 1
    assert accepted_count(restaurant_results) >= 1
    assert denied_count(restaurant_results) >= 1

    check_routes(tenant)

    val routes = route_table()

    # Accounting + approval evidence: every accepted lane write posts an event
    # into the event-sourced ledger and a balanced journal entry; large writes
    # are held for approval by the guarded gate.
    var log = new_event_log()
    log = post_accepted_write(log, "crm.write", 1, 0)
    log = post_accepted_write(log, "sale.write", 1, 11000)
    log = post_accepted_write(log, "market.write", 1, 5000)
    log = post_accepted_write(log, "restaurant.write", 1, 15000)
    log = post_accepted_write(log, "reservation.write", 1, 2000)

    var entries: [JournalEntry] = []
    entries.push(journal_for_accepted(1, "USD", 11000))
    entries.push(journal_for_accepted(2, "USD", 5000))
    entries.push(journal_for_accepted(3, "USD", 15000))
    entries.push(journal_for_accepted(4, "USD", 2000))
    for entry in entries:
        assert posting_balanced(entry)

    val cash = account_balance(entries, cash_account(), "USD")
    assert cash.minor == 33000

    val op = operator_actor()
    val admin = Actor { id: 9, name: "Del", role: "admin" }
    val op_session = active_session(op.id, tenant.id)
    val admin_session = active_session(admin.id, tenant.id)
    var appr_used: [text] = []
    val held = gate_write_with_approval(op_session, tenant, op, "sale.write", true, "appr-1", appr_used, 999999, 500000, "admin")
    assert not held.ok
    assert held.reason == "needs-approval"
    val cleared = gate_write_with_approval(admin_session, tenant, admin, "sale.write", true, "appr-2", appr_used, 999999, 500000, "admin")
    assert cleared.ok

    print "Business Suite:"
    print "lane=crm status=ok accepted={accepted_count(crm_results)} denied={denied_count(crm_results)}"
    print "lane=reservation status=ok accepted={accepted_count(reservation_results)} denied={denied_count(reservation_results)}"
    print "lane=sale status=ok accepted={accepted_count(sale_results)} denied={denied_count(sale_results)}"
    print "lane=market status=ok accepted={accepted_count(market_results)} denied={denied_count(market_results)}"
    print "lane=restaurant status=ok accepted={accepted_count(restaurant_results)} denied={denied_count(restaurant_results)}"
    print "routes={routes.length()}"
    print "ledger_events={event_count(log)}"
    print "ledger_balanced=true cash={cash.minor}"
    print "approval=enforced threshold=500000 denied=needs-approval"
    print "framework=guarded-write gates=session+rbac+validation+idempotency"
