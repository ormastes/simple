# transform/provider/gemini — Gemini CLI invocation

fn _send_gemini(idx: i64, prompt: text) -> (text, text):
    var cmd = REG_CLI_PATHS[idx]
    if cmd == "":
        cmd = "gemini"
    var args: [text] = []
    args = args + ["--sandbox", "off"]
    args = args + ["-p", prompt]
    args = args + ["--output-format", "json"]
    val model = REG_MODELS[idx]
    if model != "":
        args = args + ["--model", model]
    val result = rt_process_run(cmd, args)
    val stdout = result.0 ?? ""
    val stderr = result.1 ?? ""
    val exit_code = result.2
    if exit_code != 0:
        var err = "gemini CLI error (code " + exit_code.to_text() + ")"
        if stderr != "":
            err = err + ": " + stderr
        return ("", err)
    val content = _extract_string(stdout, "response")
    val error_val = _extract_string(stdout, "error")
    if error_val != "":
        return ("", error_val)
    (content, "")
