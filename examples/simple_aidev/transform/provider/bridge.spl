# transform/provider/bridge — Registry state + dispatch routing

fn _registry_find_index(id: text) -> i64:
    var i = 0
    while i < REG_COUNT:
        if REG_IDS[i] == id:
            return i
        i = i + 1
    -1

fn _registry_find_by_capability(capability: text) -> [text]:
    var matches: [text] = []
    var i = 0
    while i < REG_COUNT:
        val caps = REG_CAPABILITIES[i].split(",")
        for cap in caps:
            if cap.trim() == capability:
                matches = matches + [REG_IDS[i]]
                break
        i = i + 1
    matches

fn _dispatch_send(agent_id: text, prompt: text) -> (text, text):
    val idx = _registry_find_index(agent_id)
    if idx < 0:
        return ("", "Agent not found: " + agent_id)
    val provider = REG_PROVIDERS[idx]
    if provider == "claude_cli":
        return _send_claude(idx, prompt)
    elif provider == "gemini_cli":
        return _send_gemini(idx, prompt)
    elif provider == "openai_compat":
        return _send_openai_compat(idx, prompt)
    ("", "Unsupported provider: " + provider)
