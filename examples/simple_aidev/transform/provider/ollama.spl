# transform/provider/ollama — Ollama HTTP invocation (OpenAI-compatible)

extern fn rt_http_request(method: text, url: text, headers: text, body: text) -> (i64, text, text)

fn _send_openai_compat(idx: i64, prompt: text) -> (text, text):
    var base_url = REG_BASE_URLS[idx]
    if base_url == "":
        base_url = "http://localhost:11434"
    val url = base_url + "/v1/chat/completions"
    var model = REG_MODELS[idx]
    if model == "":
        model = "llama3"
    val q = "\""
    val body = "{" + q + "model" + q + ":" + q + model + q + "," + q + "messages" + q + ":[{" + q + "role" + q + ":" + q + "user" + q + "," + q + "content" + q + ":" + q + prompt + q + "}]}"
    val headers = "Content-Type: application/json"
    val result = rt_http_request("POST", url, headers, body)
    val resp_body = result.1 ?? ""
    val http_error = result.2 ?? ""
    if http_error != "":
        return ("", "HTTP error: " + http_error)
    val content = _extract_string(resp_body, "content")
    (content, "")
