# transform/provider/claude — Claude CLI invocation

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

fn _send_claude(idx: i64, prompt: text) -> (text, text):
    var cmd = REG_CLI_PATHS[idx]
    if cmd == "":
        cmd = "claude"
    var args: [text] = []
    args = args + ["--dangerously-skip-permissions"]
    args = args + ["-p", prompt]
    args = args + ["--output-format", "json"]
    val model = REG_MODELS[idx]
    if model != "":
        args = args + ["--model", model]
    val sys_prompt = REG_SYSTEM_PROMPTS[idx]
    if sys_prompt != "":
        args = args + ["--system-prompt", sys_prompt]
    if CHAT_SESSION_ID != "":
        args = args + ["--resume", CHAT_SESSION_ID]
    val result = rt_process_run(cmd, args)
    val stdout = result.0 ?? ""
    val stderr = result.1 ?? ""
    val exit_code = result.2
    if exit_code != 0:
        var err = "claude CLI error (code " + exit_code.to_text() + ")"
        if stderr != "":
            err = err + ": " + stderr
        return ("", err)
    val content = _extract_string(stdout, "result")
    val sess = _extract_string(stdout, "session_id")
    val is_err = _extract_bool(stdout, "is_error")
    if sess != "":
        CHAT_SESSION_ID = sess
    if is_err:
        return ("", content)
    (content, "")
