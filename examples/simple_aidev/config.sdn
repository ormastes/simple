project:
  name: simple-aidev
  version: 1.0.0

agents:
  claude:
    provider: claude_cli
    cli_path: claude
    model: claude-sonnet-4-20250514
    system_prompt: You are a helpful coding assistant.
    capabilities: [code, review, research, test]

  ollama:
    provider: openai_compat
    base_url: http://localhost:11434
    model: llama3
    capabilities: [code, research]

  gemini:
    provider: gemini_cli
    cli_path: gemini
    capabilities: [code, research]

routing:
  default_agent: claude
  fallback_agent: ollama
  strategy: capability
  rules:
    - pattern: "local|offline|private"
      agent: ollama
    - pattern: "claude|anthropic"
      agent: claude
    - pattern: "gemini|google"
      agent: gemini

task_queue:
  persistence_path: data/task_queue.sdn
  max_items: 100

themes:
  directory: themes
  auto_load: true
