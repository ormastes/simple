features:
  multi_agent_chat:
    status: enabled
    description: Multi-agent room chat orchestration
  task_queue:
    status: enabled
    description: Priority-based task queue with persistence
  theme_discovery:
    status: enabled
    description: Auto-discover themes from themes directory
  env_var_resolution:
    status: enabled
    description: Resolve $VAR and ${VAR} in config values
