# entity/config — Configuration state variables and RoutingRule

struct RoutingRule:
    pattern: text
    agent: text

fn routing_rule(pattern: text, agent: text) -> RoutingRule:
    RoutingRule(pattern: pattern, agent: agent)

# Module-level config state
var CFG_PROJECT_NAME = "simple-aidev"
var CFG_PROJECT_VERSION = "1.0.0"
var CFG_DEFAULT_AGENT = "claude"
var CFG_FALLBACK_AGENT = "ollama"
var CFG_STRATEGY = "capability"
var CFG_TASK_PERSISTENCE_PATH = "data/task_queue.sdn"
var CFG_TASK_MAX_ITEMS = 100
var CFG_THEMES_DIR = "themes"
var CFG_THEMES_AUTO_LOAD = true

# Agent registry (parallel arrays + manual counter)
var REG_IDS: [text] = []
var REG_PROVIDERS: [text] = []
var REG_CLI_PATHS: [text] = []
var REG_MODELS: [text] = []
var REG_BASE_URLS: [text] = []
var REG_SYSTEM_PROMPTS: [text] = []
var REG_CAPABILITIES: [text] = []
var REG_API_KEYS: [text] = []
var REG_COUNT = 0  # manual counter (.len() bug workaround)

# Task queue state (parallel arrays + manual counter)
var TQ_IDS: [text] = []
var TQ_CONTENTS: [text] = []
var TQ_PRIORITIES: [i64] = []
var TQ_STATUSES: [text] = []
var TQ_AGENT_IDS: [text] = []
var TQ_RESULTS: [text] = []
var TQ_ERRORS: [text] = []
var TQ_NEXT_ID = 1
var TQ_COUNT = 0  # manual counter

# Chat session state
var CHAT_SESSION_ID = ""
var CHAT_AGENT_ID = ""

# Routing rules
var CFG_RULE_PATTERNS: [text] = []
var CFG_RULE_AGENTS: [text] = []

# Config loaded flag
var APP_CONFIG_LOADED = false
var APP_BASE_DIR = ""
