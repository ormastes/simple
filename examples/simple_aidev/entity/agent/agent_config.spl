# entity/agent — AgentConfig data structure
#
# Data-only, no behavior beyond field access.

struct AgentConfig:
    id: text
    provider: text       # "claude_cli", "openai_compat", "gemini_cli"
    cli_path: text
    model: text
    base_url: text
    system_prompt: text
    capabilities: [text]
    api_key: text

fn agent_config(id: text, provider: text) -> AgentConfig:
    AgentConfig(
        id: id,
        provider: provider,
        cli_path: "",
        model: "",
        base_url: "",
        system_prompt: "",
        capabilities: [],
        api_key: ""
    )

fn agent_config_full(id: text, provider: text, cli_path: text, model: text,
                     base_url: text, system_prompt: text,
                     capabilities: [text]) -> AgentConfig:
    AgentConfig(
        id: id,
        provider: provider,
        cli_path: cli_path,
        model: model,
        base_url: base_url,
        system_prompt: system_prompt,
        capabilities: capabilities,
        api_key: ""
    )

impl AgentConfig:
    fn has_capability(cap: text) -> bool:
        for c in self.capabilities:
            if c == cap:
                return true
        false

    fn to_text() -> text:
        "Agent(" + self.id + ", " + self.provider + ", model=" + self.model + ")"
