# entity/theme — ThemeManifest data structure

struct ThemeManifest:
    name: text
    description: text
    version: text
    directory: text
    default_agent: text
    capabilities: [text]

fn theme_manifest(name: text, description: text, directory: text) -> ThemeManifest:
    ThemeManifest(
        name: name,
        description: description,
        version: "1.0.0",
        directory: directory,
        default_agent: "",
        capabilities: []
    )

impl ThemeManifest:
    fn to_text() -> text:
        "Theme(" + self.name + ", v" + self.version + ")"
