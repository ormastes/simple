# entity/task — Task and TaskResult data structures

struct Task:
    id: text
    content: text
    priority: i64
    status: text         # "pending", "running", "completed", "failed"
    agent_id: text
    capability: text
    result: text
    error: text
    created_at: text

fn task_new(id: text, content: text) -> Task:
    Task(
        id: id,
        content: content,
        priority: 0,
        status: "pending",
        agent_id: "",
        capability: "",
        result: "",
        error: "",
        created_at: ""
    )

fn task_with_priority(id: text, content: text, priority: i64) -> Task:
    Task(
        id: id,
        content: content,
        priority: priority,
        status: "pending",
        agent_id: "",
        capability: "",
        result: "",
        error: "",
        created_at: ""
    )

impl Task:
    fn is_pending() -> bool:
        self.status == "pending"

    fn is_completed() -> bool:
        self.status == "completed"

    fn is_failed() -> bool:
        self.status == "failed"

    fn to_text() -> text:
        "Task(" + self.id + ", " + self.status + ", p=" + self.priority.to_text() + ")"

struct TaskResult:
    task_id: text
    agent_id: text
    content: text
    error: text
    success: bool

fn task_result_ok(task_id: text, agent_id: text, content: text) -> TaskResult:
    TaskResult(
        task_id: task_id,
        agent_id: agent_id,
        content: content,
        error: "",
        success: true
    )

fn task_result_err(task_id: text, agent_id: text, error: text) -> TaskResult:
    TaskResult(
        task_id: task_id,
        agent_id: agent_id,
        content: "",
        error: error,
        success: false
    )
