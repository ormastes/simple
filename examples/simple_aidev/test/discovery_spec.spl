# Tests for theme discovery parsing

fn _parse_theme_line(line: text) -> (text, text):
    val trimmed = line.trim()
    if not trimmed.contains(":"):
        return ("", "")
    val colon_pos = trimmed.index_of(":") ?? 0
    val key = trimmed.substring(0, colon_pos).trim()
    var value = ""
    if colon_pos + 1 < trimmed.len():
        value = trimmed.substring(colon_pos + 1).trim()
    (key, value)

describe "ThemeDiscovery":
    it "parses key-value lines":
        val r1 = _parse_theme_line("name: test-theme")
        expect(r1.0).to_equal("name")
        expect(r1.1).to_equal("test-theme")

    it "handles empty value":
        val r = _parse_theme_line("agents:")
        expect(r.0).to_equal("agents")
        expect(r.1).to_equal("")

    it "handles no colon":
        val r = _parse_theme_line("just text")
        expect(r.0).to_equal("")
        expect(r.1).to_equal("")

    it "parses capabilities format":
        val raw = "[code, research]"
        var caps = raw
        if caps.starts_with("["):
            caps = caps.substring(1)
        if caps.ends_with("]"):
            caps = caps.substring(0, caps.len() - 1)
        caps = caps.replace(" ", "")
        expect(caps).to_equal("code,research")
