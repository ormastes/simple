# Tests for config parsing

fn _resolve_env_test(value: text) -> text:
    # Simplified env resolution for testing (no actual env vars)
    if not value.contains("$"):
        return value
    value

describe "Config":
    it "resolves non-env text unchanged":
        val result = _resolve_env_test("hello world")
        expect(result).to_equal("hello world")

    it "detects env var syntax":
        val value = "$HOME/projects"
        expect(value.contains("$")).to_equal(true)

    it "parses capabilities array format":
        val raw = "[code, review, research]"
        var caps = raw
        if caps.starts_with("["):
            caps = caps.substring(1)
        if caps.ends_with("]"):
            caps = caps.substring(0, caps.len() - 1)
        caps = caps.replace(" ", "")
        val parts = caps.split(",")
        expect(parts.len()).to_equal(3)
        expect(parts[0]).to_equal("code")
        expect(parts[1]).to_equal("review")
        expect(parts[2]).to_equal("research")
