# Tests for core types

describe "AgentConfig":
    it "creates with factory function":
        val agent = AgentConfig(
            id: "test",
            provider: "claude_cli",
            cli_path: "claude",
            model: "test-model",
            base_url: "",
            system_prompt: "test prompt",
            capabilities: ["code", "review"],
            api_key: ""
        )
        expect(agent.id).to_equal("test")
        expect(agent.provider).to_equal("claude_cli")
        expect(agent.model).to_equal("test-model")

    it "checks capabilities":
        val agent = AgentConfig(
            id: "test",
            provider: "claude_cli",
            cli_path: "",
            model: "",
            base_url: "",
            system_prompt: "",
            capabilities: ["code", "review"],
            api_key: ""
        )
        expect(agent.has_capability("code")).to_equal(true)
        expect(agent.has_capability("review")).to_equal(true)
        expect(agent.has_capability("deploy")).to_equal(false)

describe "Task":
    it "creates with defaults":
        val t = Task(
            id: "task-1",
            content: "test content",
            priority: 5,
            status: "pending",
            agent_id: "",
            capability: "",
            result: "",
            error: "",
            created_at: ""
        )
        expect(t.id).to_equal("task-1")
        expect(t.status).to_equal("pending")
        expect(t.priority).to_equal(5)
        expect(t.is_pending()).to_equal(true)
        expect(t.is_completed()).to_equal(false)

describe "TaskResult":
    it "creates success result":
        val r = TaskResult(
            task_id: "task-1",
            agent_id: "claude",
            content: "result text",
            error: "",
            success: true
        )
        expect(r.success).to_equal(true)
        expect(r.content).to_equal("result text")
        expect(r.error).to_equal("")

    it "creates error result":
        val r = TaskResult(
            task_id: "task-1",
            agent_id: "claude",
            content: "",
            error: "something failed",
            success: false
        )
        expect(r.success).to_equal(false)
        expect(r.error).to_equal("something failed")

describe "ThemeManifest":
    it "creates with factory":
        val t = ThemeManifest(
            name: "test-theme",
            description: "A test theme",
            version: "1.0.0",
            directory: "themes/test",
            default_agent: "claude",
            capabilities: ["code"]
        )
        expect(t.name).to_equal("test-theme")
        expect(t.version).to_equal("1.0.0")
