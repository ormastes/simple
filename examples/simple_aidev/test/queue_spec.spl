# Tests for task queue

# Module-level queue state
var Q_IDS: [text] = []
var Q_CONTENTS: [text] = []
var Q_PRIORITIES: [i64] = []
var Q_STATUSES: [text] = []
var Q_AGENT_IDS: [text] = []
var Q_RESULTS: [text] = []
var Q_ERRORS: [text] = []
var Q_NEXT_ID = 1

fn _queue_clear():
    Q_IDS = []
    Q_CONTENTS = []
    Q_PRIORITIES = []
    Q_STATUSES = []
    Q_AGENT_IDS = []
    Q_RESULTS = []
    Q_ERRORS = []
    Q_NEXT_ID = 1

fn _queue_add(content: text, priority: i64) -> text:
    val id = "task-" + Q_NEXT_ID.to_text()
    Q_NEXT_ID = Q_NEXT_ID + 1
    Q_IDS.push(id)
    Q_CONTENTS.push(content)
    Q_PRIORITIES.push(priority)
    Q_STATUSES.push("pending")
    Q_AGENT_IDS.push("")
    Q_RESULTS.push("")
    Q_ERRORS.push("")
    id

fn _queue_pop_index() -> i64:
    var best_idx = -1
    var best_priority = -1
    var i = 0
    while i < Q_IDS.len():
        if Q_STATUSES[i] == "pending" and Q_PRIORITIES[i] > best_priority:
            best_priority = Q_PRIORITIES[i]
            best_idx = i
        i = i + 1
    best_idx

describe "TaskQueue":
    it "adds tasks":
        _queue_clear()
        val id1 = _queue_add("task one", 0)
        val id2 = _queue_add("task two", 5)
        expect(id1).to_equal("task-1")
        expect(id2).to_equal("task-2")
        expect(Q_IDS.len()).to_equal(2)

    it "pops highest priority":
        _queue_clear()
        _queue_add("low priority", 1)
        _queue_add("high priority", 10)
        _queue_add("medium priority", 5)
        val idx = _queue_pop_index()
        expect(idx).to_equal(1)
        expect(Q_CONTENTS[idx]).to_equal("high priority")

    it "returns -1 when empty":
        _queue_clear()
        val idx = _queue_pop_index()
        expect(idx).to_equal(-1)

    it "skips completed tasks":
        _queue_clear()
        _queue_add("first", 10)
        _queue_add("second", 5)
        Q_STATUSES[0] = "completed"
        val idx = _queue_pop_index()
        expect(idx).to_equal(1)
