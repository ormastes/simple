# feature/theme_manager/discovery — Scan + load theme manifests

extern fn rt_dir_list(path: text) -> [text]

fn _discover_themes() -> [text]:
    var themes: [text] = []
    if not rt_file_exists(CFG_THEMES_DIR):
        return themes
    val entries = rt_dir_list(CFG_THEMES_DIR)
    for entry in entries:
        val manifest_path = CFG_THEMES_DIR + "/" + entry + "/theme.sdn"
        if rt_file_exists(manifest_path):
            themes = themes + [entry]
    themes

fn _theme_list_text() -> text:
    val themes = _discover_themes()
    if themes.len() == 0:
        return "  (no themes found in " + CFG_THEMES_DIR + "/)"
    var parts: [text] = []
    for t in themes:
        parts = parts + ["  " + t]
    parts.join("\n")
