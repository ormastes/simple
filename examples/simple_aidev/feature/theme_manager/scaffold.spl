# feature/theme_manager/scaffold — Create new theme directory

extern fn rt_dir_create_all(path: text) -> bool
extern fn rt_file_write_text(path: text, content: text) -> bool

fn _theme_create(name: text) -> text:
    val dir = CFG_THEMES_DIR + "/" + name
    if rt_file_exists(dir):
        return "Theme directory already exists: " + dir
    rt_dir_create_all(dir)
    val manifest = "name: " + name + "\ndescription: A new theme\nversion: 1.0.0\ndefault_agent: claude\ncapabilities: [code, research]\n"
    rt_file_write_text(dir + "/theme.sdn", manifest)
    "Created theme: " + dir
