# simple-aidev Gemini CLI Provider
#
# Direct invocation of the `gemini` binary via rt_process_run.

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

# ============================================================================
# JSON helpers
# ============================================================================

fn _gemini_extract_string(json: text, key: text) -> text:
    val quote = "\""
    val search = quote + key + quote + ":"
    val idx_opt = json.index_of(search)
    if not idx_opt.?:
        return ""
    val idx = idx_opt.unwrap()
    val start = idx + search.len()
    val after = json.substring(start).trim()
    if not after.starts_with(quote):
        return ""
    val rest = after.substring(1)
    var end = 0
    var escaped = false
    while end < rest.len():
        val ch = rest[end:end + 1]
        if escaped:
            escaped = false
        elif ch == "\\":
            escaped = true
        elif ch == "\"":
            return rest.substring(0, end)
        end = end + 1
    ""

# ============================================================================
# Send message
# ============================================================================

fn gemini_send(cli_path: text, prompt: text, model: text,
               session_id: text) -> (text, text, text):
    # Returns (content, error, session_id)
    var cmd = cli_path
    if cmd == "":
        cmd = "gemini"
    var args: [text] = []
    args = args + ["--sandbox", "off"]
    args = args + ["-p", prompt]
    args = args + ["--output-format", "json"]
    if model != "":
        args = args + ["--model", model]
    if session_id != "":
        args = args + ["--resume", session_id]

    val result = rt_process_run(cmd, args)
    val stdout = result.0 ?? ""
    val stderr = result.1 ?? ""
    val exit_code = result.2

    if exit_code != 0:
        var err = "gemini CLI error (code " + exit_code.to_text() + ")"
        if stderr != "":
            err = err + ": " + stderr
        return ("", err, "")

    val content = _gemini_extract_string(stdout, "response")
    val error_val = _gemini_extract_string(stdout, "error")
    if error_val != "":
        return ("", error_val, "")
    (content, "", "")

fn gemini_send_simple(prompt: text) -> (text, text):
    val r = gemini_send("gemini", prompt, "", "")
    (r.0, r.1)

fn gemini_test(cli_path: text) -> (bool, text):
    var cmd = cli_path
    if cmd == "":
        cmd = "gemini"
    val result = rt_process_run(cmd, ["--version"])
    val stdout = result.0 ?? ""
    val exit_code = result.2
    if exit_code != 0:
        return (false, "gemini CLI not found or not working")
    (true, "gemini CLI version: " + stdout.trim())
