# simple-aidev Agent Registry
#
# Register, lookup, list, and find agents by capability.
# Uses module-level parallel arrays pattern.

# ============================================================================
# Module-level state
# ============================================================================

var REG_IDS: [text] = []
var REG_PROVIDERS: [text] = []
var REG_CLI_PATHS: [text] = []
var REG_MODELS: [text] = []
var REG_BASE_URLS: [text] = []
var REG_SYSTEM_PROMPTS: [text] = []
var REG_CAPABILITIES: [text] = []   # comma-separated per agent
var REG_API_KEYS: [text] = []

# ============================================================================
# Registration
# ============================================================================

fn registry_clear():
    REG_IDS = []
    REG_PROVIDERS = []
    REG_CLI_PATHS = []
    REG_MODELS = []
    REG_BASE_URLS = []
    REG_SYSTEM_PROMPTS = []
    REG_CAPABILITIES = []
    REG_API_KEYS = []

fn registry_register(id: text, provider: text, cli_path: text, model: text,
                     base_url: text, system_prompt: text,
                     capabilities: text, api_key: text):
    # Check for duplicate
    var i = 0
    while i < REG_IDS.len():
        if REG_IDS[i] == id:
            # Update existing
            REG_PROVIDERS[i] = provider
            REG_CLI_PATHS[i] = cli_path
            REG_MODELS[i] = model
            REG_BASE_URLS[i] = base_url
            REG_SYSTEM_PROMPTS[i] = system_prompt
            REG_CAPABILITIES[i] = capabilities
            REG_API_KEYS[i] = api_key
            return
        i = i + 1
    # Add new
    REG_IDS.push(id)
    REG_PROVIDERS.push(provider)
    REG_CLI_PATHS.push(cli_path)
    REG_MODELS.push(model)
    REG_BASE_URLS.push(base_url)
    REG_SYSTEM_PROMPTS.push(system_prompt)
    REG_CAPABILITIES.push(capabilities)
    REG_API_KEYS.push(api_key)

# ============================================================================
# Lookup
# ============================================================================

fn registry_count() -> i64:
    REG_IDS.len()

fn registry_exists(id: text) -> bool:
    for agent_id in REG_IDS:
        if agent_id == id:
            return true
    false

fn registry_index_of(id: text) -> i64:
    var i = 0
    while i < REG_IDS.len():
        if REG_IDS[i] == id:
            return i
        i = i + 1
    -1

fn registry_get_id(idx: i64) -> text:
    if idx >= 0 and idx < REG_IDS.len():
        return REG_IDS[idx]
    ""

fn registry_get_provider(idx: i64) -> text:
    if idx >= 0 and idx < REG_PROVIDERS.len():
        return REG_PROVIDERS[idx]
    ""

fn registry_get_cli_path(idx: i64) -> text:
    if idx >= 0 and idx < REG_CLI_PATHS.len():
        return REG_CLI_PATHS[idx]
    ""

fn registry_get_model(idx: i64) -> text:
    if idx >= 0 and idx < REG_MODELS.len():
        return REG_MODELS[idx]
    ""

fn registry_get_base_url(idx: i64) -> text:
    if idx >= 0 and idx < REG_BASE_URLS.len():
        return REG_BASE_URLS[idx]
    ""

fn registry_get_system_prompt(idx: i64) -> text:
    if idx >= 0 and idx < REG_SYSTEM_PROMPTS.len():
        return REG_SYSTEM_PROMPTS[idx]
    ""

fn registry_get_capabilities(idx: i64) -> [text]:
    if idx >= 0 and idx < REG_CAPABILITIES.len():
        val caps = REG_CAPABILITIES[idx]
        if caps == "":
            return []
        return caps.split(",")
    []

fn registry_get_api_key(idx: i64) -> text:
    if idx >= 0 and idx < REG_API_KEYS.len():
        return REG_API_KEYS[idx]
    ""

# ============================================================================
# List
# ============================================================================

fn registry_list_ids() -> [text]:
    var ids: [text] = []
    for id in REG_IDS:
        ids.push(id)
    ids

fn registry_list_text() -> text:
    var parts: [text] = []
    var i = 0
    while i < REG_IDS.len():
        val caps = REG_CAPABILITIES[i]
        parts.push("  " + REG_IDS[i] + " (" + REG_PROVIDERS[i] + ", model=" + REG_MODELS[i] + ", caps=[" + caps + "])")
        i = i + 1
    if parts.len() == 0:
        return "  (no agents registered)"
    parts.join("\n")

# ============================================================================
# Find by capability
# ============================================================================

fn registry_find_by_capability(capability: text) -> [text]:
    var matches: [text] = []
    var i = 0
    while i < REG_IDS.len():
        val caps = REG_CAPABILITIES[i].split(",")
        for cap in caps:
            if cap.trim() == capability:
                matches.push(REG_IDS[i])
                break
        i = i + 1
    matches

fn registry_find_first_by_capability(capability: text) -> text:
    val matches = registry_find_by_capability(capability)
    if matches.len() > 0:
        return matches[0]
    ""
