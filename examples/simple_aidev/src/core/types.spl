# simple-aidev Core Types
#
# Data structures for agents, tasks, task results, and theme manifests.

# ============================================================================
# AgentConfig
# ============================================================================

struct AgentConfig:
    id: text
    provider: text       # "claude_cli", "openai_compat", "gemini_cli"
    cli_path: text
    model: text
    base_url: text
    system_prompt: text
    capabilities: [text]
    api_key: text

fn agent_config(id: text, provider: text) -> AgentConfig:
    AgentConfig(
        id: id,
        provider: provider,
        cli_path: "",
        model: "",
        base_url: "",
        system_prompt: "",
        capabilities: [],
        api_key: ""
    )

fn agent_config_full(id: text, provider: text, cli_path: text, model: text,
                     base_url: text, system_prompt: text,
                     capabilities: [text]) -> AgentConfig:
    AgentConfig(
        id: id,
        provider: provider,
        cli_path: cli_path,
        model: model,
        base_url: base_url,
        system_prompt: system_prompt,
        capabilities: capabilities,
        api_key: ""
    )

impl AgentConfig:
    fn has_capability(cap: text) -> bool:
        for c in self.capabilities:
            if c == cap:
                return true
        false

    fn to_text() -> text:
        "Agent(" + self.id + ", " + self.provider + ", model=" + self.model + ")"

# ============================================================================
# Task
# ============================================================================

struct Task:
    id: text
    content: text
    priority: i64        # Higher = more urgent
    status: text         # "pending", "running", "completed", "failed"
    agent_id: text       # Assigned agent (empty = auto-route)
    capability: text     # Required capability for routing
    result: text
    error: text
    created_at: text

fn task_new(id: text, content: text) -> Task:
    Task(
        id: id,
        content: content,
        priority: 0,
        status: "pending",
        agent_id: "",
        capability: "",
        result: "",
        error: "",
        created_at: ""
    )

fn task_with_priority(id: text, content: text, priority: i64) -> Task:
    Task(
        id: id,
        content: content,
        priority: priority,
        status: "pending",
        agent_id: "",
        capability: "",
        result: "",
        error: "",
        created_at: ""
    )

impl Task:
    fn is_pending() -> bool:
        self.status == "pending"

    fn is_completed() -> bool:
        self.status == "completed"

    fn is_failed() -> bool:
        self.status == "failed"

    fn to_text() -> text:
        "Task(" + self.id + ", " + self.status + ", p=" + self.priority.to_text() + ")"

# ============================================================================
# TaskResult
# ============================================================================

struct TaskResult:
    task_id: text
    agent_id: text
    content: text
    error: text
    success: bool

fn task_result_ok(task_id: text, agent_id: text, content: text) -> TaskResult:
    TaskResult(
        task_id: task_id,
        agent_id: agent_id,
        content: content,
        error: "",
        success: true
    )

fn task_result_err(task_id: text, agent_id: text, error: text) -> TaskResult:
    TaskResult(
        task_id: task_id,
        agent_id: agent_id,
        content: "",
        error: error,
        success: false
    )

# ============================================================================
# ThemeManifest
# ============================================================================

struct ThemeManifest:
    name: text
    description: text
    version: text
    directory: text
    default_agent: text
    capabilities: [text]

fn theme_manifest(name: text, description: text, directory: text) -> ThemeManifest:
    ThemeManifest(
        name: name,
        description: description,
        version: "1.0.0",
        directory: directory,
        default_agent: "",
        capabilities: []
    )

impl ThemeManifest:
    fn to_text() -> text:
        "Theme(" + self.name + ", v" + self.version + ")"

# ============================================================================
# RoutingRule
# ============================================================================

struct RoutingRule:
    pattern: text
    agent: text

fn routing_rule(pattern: text, agent: text) -> RoutingRule:
    RoutingRule(pattern: pattern, agent: agent)
