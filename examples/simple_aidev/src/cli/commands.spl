# simple-aidev CLI Commands
#
# Command dispatch hub for all CLI subcommands.
# This module is referenced by main.spl for the command routing logic.

# ============================================================================
# Command names
# ============================================================================

fn command_names() -> [text]:
    var names: [text] = []
    names.push("chat")
    names.push("task")
    names.push("agent")
    names.push("theme")
    names.push("config")
    names.push("init")
    names.push("help")
    names

fn is_valid_command(name: text) -> bool:
    val names = command_names()
    for n in names:
        if n == name:
            return true
    false
