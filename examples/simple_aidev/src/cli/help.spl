# simple-aidev Help
#
# Help text generation for CLI commands.

fn help_full() -> text:
    var parts: [text] = []
    parts.push("simple-aidev - AI Development Platform")
    parts.push("")
    parts.push("Usage: simple-aidev <command> [options]")
    parts.push("")
    parts.push("Commands:")
    parts.push("  chat <message>              Chat with default agent")
    parts.push("  chat --agent <id> <msg>     Chat with specific agent")
    parts.push("  chat --room <name> <msg>    Multi-agent room chat")
    parts.push("")
    parts.push("  task add <content>          Add task to queue")
    parts.push("  task list                   List tasks")
    parts.push("  task run                    Execute next task")
    parts.push("  task run --all              Execute all pending tasks")
    parts.push("")
    parts.push("  agent list                  List registered agents")
    parts.push("  agent test <id>             Test agent connectivity")
    parts.push("")
    parts.push("  theme list                  List discovered themes")
    parts.push("  theme create <name>         Create new theme")
    parts.push("")
    parts.push("  config show                 Display configuration")
    parts.push("  init [name]                 Create new project")
    parts.push("  help                        Show this help")
    parts.push("")
    parts.push("Options:")
    parts.push("  --config <path>             Config file path (default: config.sdn)")
    parts.push("  --verbose, -v               Verbose output")
    parts.join("\n")

fn help_chat() -> text:
    var parts: [text] = []
    parts.push("Usage: simple-aidev chat [options] <message>")
    parts.push("")
    parts.push("Options:")
    parts.push("  --agent <id>    Use specific agent")
    parts.push("  --room <name>   Use multi-agent room")
    parts.join("\n")

fn help_task() -> text:
    var parts: [text] = []
    parts.push("Usage: simple-aidev task <subcommand>")
    parts.push("")
    parts.push("Subcommands:")
    parts.push("  add <content>     Add a task (--priority <n>)")
    parts.push("  list              List all tasks")
    parts.push("  run               Run next pending task")
    parts.push("  run --all         Run all pending tasks")
    parts.join("\n")

fn help_agent() -> text:
    var parts: [text] = []
    parts.push("Usage: simple-aidev agent <subcommand>")
    parts.push("")
    parts.push("Subcommands:")
    parts.push("  list              List registered agents")
    parts.push("  test <id>         Test agent connectivity")
    parts.join("\n")

fn help_theme() -> text:
    var parts: [text] = []
    parts.push("Usage: simple-aidev theme <subcommand>")
    parts.push("")
    parts.push("Subcommands:")
    parts.push("  list              List discovered themes")
    parts.push("  create <name>     Create new theme directory")
    parts.join("\n")
