# simple-aidev Task Runner
#
# Dequeues tasks, dispatches to agents, collects results.

# ============================================================================
# Run single task (called with external queue + dispatch state)
# ============================================================================

fn runner_run_task(task_idx: i64, task_content: text,
                   agent_id: text, send_fn_result: (text, text)) -> (bool, text):
    # Takes pre-dispatched result
    val content = send_fn_result.0
    val error = send_fn_result.1
    if error != "":
        return (false, error)
    (true, content)

# ============================================================================
# Batch runner result summary
# ============================================================================

fn runner_summary(total: i64, completed: i64, failed: i64) -> text:
    var parts: [text] = []
    parts.push("Task Runner Summary:")
    parts.push("  Total: " + total.to_text())
    parts.push("  Completed: " + completed.to_text())
    parts.push("  Failed: " + failed.to_text())
    parts.join("\n")
