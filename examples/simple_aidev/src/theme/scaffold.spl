# simple-aidev Theme Scaffold
#
# Create new theme directory structure.

extern fn rt_dir_create_all(path: text) -> bool
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_exists(path: text) -> bool

fn scaffold_theme(themes_dir: text, name: text) -> (bool, text):
    val dir = themes_dir + "/" + name
    if rt_file_exists(dir):
        return (false, "Theme directory already exists: " + dir)

    rt_dir_create_all(dir)

    # Write theme.sdn manifest
    var lines: [text] = []
    lines.push("name: " + name)
    lines.push("description: A new theme")
    lines.push("version: 1.0.0")
    lines.push("default_agent: claude")
    lines.push("capabilities: [code, research]")
    rt_file_write_text(dir + "/theme.sdn", lines.join("\n") + "\n")

    (true, "Created theme: " + dir)
