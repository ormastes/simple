# shared/env_resolver — Environment variable resolution in strings

extern fn rt_env_get(key: text) -> text

fn _resolve_env(value: text) -> text:
    if not value.contains("$"):
        return value
    var out_parts: [text] = []
    var i = 0
    while i < value.len():
        if value[i:i + 1] == "$":
            var j = i + 1
            var has_brace = false
            if j < value.len() and value[j:j + 1] == "{":
                has_brace = true
                j = j + 1
            var name_start = j
            while j < value.len():
                val ch = value[j:j + 1]
                if has_brace and ch == "}":
                    break
                if not has_brace:
                    val is_alnum = (ch >= "a" and ch <= "z") or (ch >= "A" and ch <= "Z") or (ch >= "0" and ch <= "9") or ch == "_"
                    if not is_alnum:
                        break
                j = j + 1
            val var_name = value[name_start:j]
            if has_brace and j < value.len():
                j = j + 1
            val env_val = rt_env_get(var_name) ?? ""
            out_parts.push(env_val)
            i = j
        else:
            out_parts.push(value[i:i + 1])
            i = i + 1
    out_parts.join("")
