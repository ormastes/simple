# shared/json_helpers — JSON string extraction utilities

fn _extract_string(json: text, key: text) -> text:
    val quote = "\""
    val search = quote + key + quote + ":"
    val idx_opt = json.index_of(search)
    if not idx_opt.?:
        return ""
    val idx = idx_opt.unwrap()
    val start = idx + search.len()
    val after = json[start:json.len()].trim()
    if not after.starts_with(quote):
        return ""
    val rest = after[1:after.len()]
    var end = 0
    var escaped = false
    while end < rest.len():
        val ch = rest[end:end + 1]
        if escaped:
            escaped = false
        elif ch == "\\":
            escaped = true
        elif ch == "\"":
            return rest[0:end]
        end = end + 1
    ""

fn _extract_bool(json: text, key: text) -> bool:
    val quote = "\""
    val search = quote + key + quote + ":"
    val idx_opt = json.index_of(search)
    if not idx_opt.?:
        return false
    val idx = idx_opt.unwrap()
    val start = idx + search.len()
    val after = json[start:json.len()].trim()
    after.starts_with("true")
