# shared/sdn_parser — Indent-preserving SDN line parser
#
# Workaround for split("\n") stripping leading whitespace.

# Parsed line storage
var _PARSED_LINES: [text] = []
var _PARSED_INDENTS: [i64] = []
var _PARSED_COUNT = 0

fn _parse_lines_with_indent(content: text):
    _PARSED_LINES = []
    _PARSED_INDENTS = []
    _PARSED_COUNT = 0
    var line_starts: [i64] = []
    var line_ends: [i64] = []
    var start = 0
    var pos = 0
    val clen = content.len()
    while pos < clen:
        val ch = content[pos:pos + 1]
        if ch == "\n":
            line_starts = line_starts + [start]
            line_ends = line_ends + [pos]
            start = pos + 1
        pos = pos + 1
    if start < clen:
        line_starts = line_starts + [start]
        line_ends = line_ends + [clen]
    var li = 0
    for ls in line_starts:
        val le = line_ends[li]
        var spaces = 0
        var sp = ls
        while sp < le:
            val sc = content[sp:sp + 1]
            if sc == " ":
                spaces = spaces + 1
            else:
                break
            sp = sp + 1
        val trimmed_start = ls + spaces
        if trimmed_start < le:
            val line_text = content[trimmed_start:le]
            val final_text = line_text.trim()
            if final_text != "":
                _PARSED_LINES = _PARSED_LINES + [final_text]
                _PARSED_INDENTS = _PARSED_INDENTS + [spaces]
                _PARSED_COUNT = _PARSED_COUNT + 1
        li = li + 1
