# Multi-GPU vector addition
# Splits work across two GPUs, each processing half the data

use std.gpu.*

@gpu_kernel
fn vector_add_kernel(a: GpuBuffer<f32>, b: GpuBuffer<f32>, c: GpuBuffer<f32>, n: i64):
    val idx = gpu_block_id_x() * gpu_block_dim_x() + gpu_local_id_x()
    if idx < n:
        c[idx] = a[idx] + b[idx]

fn split_work_across_gpus(a: List<f32>, b: List<f32>) -> Result<List<f32>, GpuError>:
    val device_count = gpu_device_count()
    if device_count < 2:
        return Err(GpuError(message: "Need at least 2 GPUs"))

    val n = a.len()
    val half = n / 2

    # --- Device 0: first half ---
    gpu_set_device(0)?

    val buf_a0 = gpu_alloc_f32(half)?
    val buf_b0 = gpu_alloc_f32(half)?
    val buf_c0 = gpu_alloc_f32(half)?

    # Copy first half of input to device 0
    var a_first = List(_items: [])
    var i = 0
    while i < half:
        a_first.push(a[i])
        i = i + 1
    var b_first = List(_items: [])
    i = 0
    while i < half:
        b_first.push(b[i])
        i = i + 1

    gpu_upload_f32(buf_a0, a_first)?
    gpu_upload_f32(buf_b0, b_first)?

    val block_size = 256
    val grid0 = (half + block_size - 1) / block_size
    vector_add_kernel<<<grid: (grid0, 1, 1), block: (block_size, 1, 1)>>>(buf_a0, buf_b0, buf_c0, half)
    gpu_sync()?

    val result_first = gpu_download_f32(buf_c0, half)?

    gpu_free(buf_a0)?
    gpu_free(buf_b0)?
    gpu_free(buf_c0)?

    # --- Device 1: second half ---
    val second_half = n - half
    gpu_set_device(1)?

    val buf_a1 = gpu_alloc_f32(second_half)?
    val buf_b1 = gpu_alloc_f32(second_half)?
    val buf_c1 = gpu_alloc_f32(second_half)?

    # Copy second half of input to device 1
    var a_second = List(_items: [])
    i = half
    while i < n:
        a_second.push(a[i])
        i = i + 1
    var b_second = List(_items: [])
    i = half
    while i < n:
        b_second.push(b[i])
        i = i + 1

    gpu_upload_f32(buf_a1, a_second)?
    gpu_upload_f32(buf_b1, b_second)?

    val grid1 = (second_half + block_size - 1) / block_size
    vector_add_kernel<<<grid: (grid1, 1, 1), block: (block_size, 1, 1)>>>(buf_a1, buf_b1, buf_c1, second_half)
    gpu_sync()?

    val result_second = gpu_download_f32(buf_c1, second_half)?

    gpu_free(buf_a1)?
    gpu_free(buf_b1)?
    gpu_free(buf_c1)?

    # Combine results
    var result = List(_items: [])
    i = 0
    while i < result_first.len():
        result.push(result_first[i])
        i = i + 1
    i = 0
    while i < result_second.len():
        result.push(result_second[i])
        i = i + 1
    Ok(result)

fn device_info():
    val count = gpu_device_count()
    print "Available GPU devices: {count}"

fn main():
    device_info()

    val n = 1024
    var a = List(_items: [])
    var b = List(_items: [])
    var i = 0
    while i < n:
        a.push(1.0)
        b.push(2.0)
        i = i + 1

    val result = split_work_across_gpus(a, b)
    match result:
        Ok(c):
            print "Multi-GPU addition complete"
            print "First element: {c[0]}"
            print "Last element: {c[n - 1]}"
        Err(e):
            print "Error: {e.message}"
