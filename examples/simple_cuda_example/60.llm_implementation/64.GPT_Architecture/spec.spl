# 64. GPT Architecture - Tests
#
# Tests GPT config, model creation, forward pass, sampling, generation,
# and pipeline description. All CPU reference implementations.
# Uses small sizes for interpreter performance.

use std.gpu.{GpuError}
use self.main.{GptConfig, GptModel, create_small_test_config, create_gpt2_small_config, create_gpt_model, gpt_forward, top_k_sample, generate, build_gpt_pipeline}

describe "GPT architecture":

    it "should create GPT config":
        val config = create_small_test_config()
        expect(config.d_model).to_equal(8)
        expect(config.num_layers).to_equal(2)
        expect(config.num_heads).to_equal(2)
        expect(config.vocab_size).to_equal(20)

    it "should create GPT model":
        val config = create_small_test_config()
        val model = create_gpt_model(config)
        expect(model.config.d_model).to_equal(8)
        # weights = vocab_size * d_model = 20 * 8 = 160
        expect(model.weights.len()).to_equal(160)

    it "should produce correct output shape from forward pass":
        val config = create_small_test_config()
        val model = create_gpt_model(config)
        val token_ids = [1, 5, 10]
        val result = gpt_forward(model, token_ids)
        match result:
            Ok(logits):
                # Output: seq_len * vocab_size = 3 * 20 = 60
                expect(logits.len()).to_equal(60)
            Err(e):
                expect("forward should not fail").to_equal("ok")

    it "should sample from top-k":
        val logits = [1.0, 5.0, 2.0, 0.5, 3.0]
        val token = top_k_sample(logits, 3, 1.0)
        # Should pick index 1 (value 5.0 is the max)
        expect(token).to_equal(1)

    it "should generate tokens autoregressively":
        val config = create_small_test_config()
        val model = create_gpt_model(config)
        val prompt = [1, 2, 3]
        val result = generate(model, prompt, 2, 1.0, 5)
        match result:
            Ok(tokens):
                # 3 prompt + 2 generated = 5 total
                expect(tokens.len()).to_equal(5)
                # First 3 should be the prompt
                expect(tokens[0]).to_equal(1)
                expect(tokens[1]).to_equal(2)
                expect(tokens[2]).to_equal(3)
            Err(e):
                expect("generate should not fail").to_equal("ok")

    it "should build GPT pipeline description":
        val config = create_small_test_config()
        val desc = build_gpt_pipeline(config)
        expect(desc).to_contain("Embedding")
        expect(desc).to_contain("Transformer")
        expect(desc).to_contain("LayerNorm")

    it "should support GPT-2 small config":
        val config = create_gpt2_small_config()
        expect(config.d_model).to_equal(768)
        expect(config.num_layers).to_equal(12)
        expect(config.num_heads).to_equal(12)
        expect(config.vocab_size).to_equal(50257)

    it "should handle top-k with single element":
        val logits = [42.0]
        val token = top_k_sample(logits, 1, 1.0)
        expect(token).to_equal(0)
