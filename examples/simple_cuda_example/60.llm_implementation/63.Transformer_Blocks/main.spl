# 63. Transformer Blocks
#
# Implements a full transformer block with:
# - Layer normalization (GPU kernel)
# - GELU activation (GPU kernel)
# - Residual connections (GPU kernel)
# - Feed-forward network
# - Multi-head attention (stub)
# - Pipeline composition with ~> operator
#
# Uses CPU-reference tensor operations with GPU kernel stubs.

use std.gpu.*

# Custom float sqrt (std.math.sqrt is integer-only in interpreter)
fn float_sqrt(x: f64) -> f64:
    if x <= 0.0:
        return 0.0
    var guess = x
    if x > 1.0:
        guess = x / 2.0
    var i = 0
    while i < 20:
        guess = (guess + x / guess) / 2.0
        i = i + 1
    guess

# ============================================================================
# Tensor: simple dense tensor with shape and data
# ============================================================================

class Tensor:
    shape: [i64]
    data: [f32]

    fn len() -> i64:
        self.data.len()

    fn add(other: Tensor) -> Result<Tensor, GpuError>:
        if self.data.len() != other.data.len():
            return Err(GpuError(code: 1, message: "Shape mismatch in add"))
        val n = self.data.len()
        var result_data = [for idx in 0..n: 0.0]
        var i = 0
        while i < n:
            result_data[i] = self.data[i] + other.data[i]
            i = i + 1
        Ok(Tensor(shape: self.shape, data: result_data))

    fn matmul(other: Tensor) -> Result<Tensor, GpuError>:
        # self: [rows, inner], other: [inner, cols]
        val rows = self.shape[0]
        val inner = self.shape[1]
        val cols = other.shape[1]
        if inner != other.shape[0]:
            return Err(GpuError(code: 2, message: "Dimension mismatch in matmul"))
        var result_data = [for idx in 0..(rows * cols): 0.0]
        var r = 0
        while r < rows:
            var c = 0
            while c < cols:
                var sum = 0.0
                var k = 0
                while k < inner:
                    sum = sum + self.data[r * inner + k] * other.data[k * cols + c]
                    k = k + 1
                result_data[r * cols + c] = sum
                c = c + 1
            r = r + 1
        Ok(Tensor(shape: [rows, cols], data: result_data))

    fn add_bias(bias: Tensor) -> Result<Tensor, GpuError>:
        val rows = self.shape[0]
        val cols = self.shape[1]
        if bias.data.len() != cols:
            return Err(GpuError(code: 3, message: "Bias size mismatch"))
        var result_data = [for idx in 0..(rows * cols): 0.0]
        var r = 0
        while r < rows:
            var c = 0
            while c < cols:
                result_data[r * cols + c] = self.data[r * cols + c] + bias.data[c]
                c = c + 1
            r = r + 1
        Ok(Tensor(shape: self.shape, data: result_data))

# Create a tensor filled with a constant value
fn create_tensor(shape: [i64], fill_value: f32) -> Tensor:
    val total = shape[0] * shape[1]
    Tensor(shape: shape, data: [for i in 0..total: fill_value])

# Create a tensor with pseudo-random data (deterministic seed)
fn create_randn(shape: [i64]) -> Tensor:
    val total = shape[0] * shape[1]
    Tensor(shape: shape, data: [for i in 0..total: (((i * 1237 + 7919) % 10000) * 1.0) / 10000.0 - 0.5])

# Create a tensor of zeros
fn create_zeros(shape: [i64]) -> Tensor:
    create_tensor(shape, 0.0)

# Create a tensor of ones
fn create_ones(shape: [i64]) -> Tensor:
    create_tensor(shape, 1.0)

# ============================================================================
# GPU kernels
# ============================================================================

# GPU kernel: layer normalization
@gpu_kernel
fn layer_norm_kernel(input: GpuPtr, output: GpuPtr, gamma: GpuPtr, beta: GpuPtr, seq_len: i64, d_model: i64, eps: f32):
    val row = gpu_block_id_x()
    if row < seq_len:
        # Compute mean
        var mean = 0.0
        var i = 0
        while i < d_model:
            mean = mean + gpu_load_f32(input, row * d_model + i)
            i = i + 1
        mean = mean / d_model * 1.0

        # Compute variance
        var variance = 0.0
        i = 0
        while i < d_model:
            val diff = gpu_load_f32(input, row * d_model + i) - mean
            variance = variance + diff * diff
            i = i + 1
        variance = variance / d_model * 1.0

        # Normalize
        val inv_std = 1.0 / float_sqrt(variance + eps)
        i = 0
        while i < d_model:
            val offset = row * d_model + i
            val normed = gpu_load_f32(gamma, i) * (gpu_load_f32(input, offset) - mean) * inv_std + gpu_load_f32(beta, i)
            gpu_store_f32(output, offset, normed)
            i = i + 1

# GPU kernel: GELU activation
@gpu_kernel
fn gelu_kernel(input: GpuPtr, output: GpuPtr, n: i64):
    val idx = gpu_local_id_x() + gpu_block_id_x() * gpu_block_dim_x()
    if idx < n:
        val x = gpu_load_f32(input, idx)
        # Approximate GELU: 0.5 * x * (1 + tanh(sqrt(2/pi) * (x + 0.044715 * x^3)))
        val c = 0.7978845608
        val inner = c * (x + 0.044715 * x * x * x)
        gpu_store_f32(output, idx, 0.5 * x * (1.0 + tanh(inner)))

# GPU kernel: residual addition
@gpu_kernel
fn residual_add_kernel(x: GpuPtr, residual: GpuPtr, output: GpuPtr, n: i64):
    val idx = gpu_local_id_x() + gpu_block_id_x() * gpu_block_dim_x()
    if idx < n:
        gpu_store_f32(output, idx, gpu_load_f32(x, idx) + gpu_load_f32(residual, idx))

# ============================================================================
# CPU reference: tanh approximation and GELU activation
# ============================================================================

# Simple tanh approximation using exp approximation
# tanh(x) = (e^2x - 1) / (e^2x + 1)
fn tanh_approx(x: f32) -> f32:
    # Clamp to avoid overflow
    var clamped = x
    if clamped > 5.0:
        clamped = 5.0
    if clamped < -5.0:
        clamped = -5.0
    # Pade approximant for tanh, accurate for |x| < 5
    val x2 = clamped * clamped
    clamped * (135135.0 + x2 * (17325.0 + x2 * (378.0 + x2))) / (135135.0 + x2 * (62370.0 + x2 * (3150.0 + x2 * 28.0)))

fn gelu_cpu(x: f32) -> f32:
    val c = 0.7978845608
    val inner = c * (x + 0.044715 * x * x * x)
    0.5 * x * (1.0 + tanh_approx(inner))

# ============================================================================
# Layer normalization (CPU reference)
# ============================================================================

class LNorm:
    d_model: i64
    gamma: [f32]
    beta: [f32]
    eps: f32

    static fn create(d_model: i64) -> LNorm:
        LNorm(d_model: d_model, gamma: [for i in 0..d_model: 1.0], beta: [for i in 0..d_model: 0.0], eps: 0.00001)

    fn forward(x: Tensor) -> Result<Tensor, GpuError>:
        val seq_len = x.shape[0]
        val d = self.d_model
        val total = seq_len * d
        var result_data = [for idx in 0..total: 0.0]
        var row = 0
        while row < seq_len:
            # Compute mean of this row
            var mean = 0.0
            var i = 0
            while i < d:
                mean = mean + x.data[row * d + i]
                i = i + 1
            mean = mean / d * 1.0
            # Compute variance
            var variance = 0.0
            i = 0
            while i < d:
                val diff = x.data[row * d + i] - mean
                variance = variance + diff * diff
                i = i + 1
            variance = variance / d * 1.0
            # Normalize
            val inv_std = 1.0 / float_sqrt(variance + self.eps)
            i = 0
            while i < d:
                result_data[row * d + i] = self.gamma[i] * (x.data[row * d + i] - mean) * inv_std + self.beta[i]
                i = i + 1
            row = row + 1
        Ok(Tensor(shape: x.shape, data: result_data))

# ============================================================================
# Multi-head attention (stub / CPU reference)
# ============================================================================

class MultiHeadAttention:
    d_model: i64
    num_heads: i64

    static fn create(d_model: i64, num_heads: i64) -> MultiHeadAttention:
        MultiHeadAttention(d_model: d_model, num_heads: num_heads)

    fn forward(query: Tensor, key: Tensor, value: Tensor, causal: bool) -> Result<Tensor, GpuError>:
        # Stub: returns value tensor scaled (real impl would do Q*K^T/sqrt(d_k) * V)
        val n = value.data.len()
        var result_data = [for idx in 0..n: 0.0]
        var i = 0
        while i < n:
            result_data[i] = value.data[i] * 0.5
            i = i + 1
        Ok(Tensor(shape: value.shape, data: result_data))

# ============================================================================
# Feed-forward network: Linear(d_model, d_ff) -> GELU -> Linear(d_ff, d_model)
# ============================================================================

class FeedForward:
    d_model: i64
    d_ff: i64
    w1: Tensor
    b1: Tensor
    w2: Tensor
    b2: Tensor

    static fn create(d_model: i64, d_ff: i64) -> FeedForward:
        FeedForward(d_model: d_model, d_ff: d_ff, w1: create_randn([d_model, d_ff]), b1: create_zeros([1, d_ff]), w2: create_randn([d_ff, d_model]), b2: create_zeros([1, d_model]))

    fn forward(x: Tensor) -> Result<Tensor, GpuError>:
        # Linear 1: x @ w1 + b1
        val h1 = x.matmul(self.w1)?
        val hidden = h1.add_bias(self.b1)?

        # GELU activation (CPU reference)
        val act_n = hidden.data.len()
        var activated_data = [for idx in 0..act_n: 0.0]
        var i = 0
        while i < act_n:
            activated_data[i] = gelu_cpu(hidden.data[i])
            i = i + 1
        val activated = Tensor(shape: hidden.shape, data: activated_data)

        # Linear 2: activated @ w2 + b2
        val h2 = activated.matmul(self.w2)?
        h2.add_bias(self.b2)

# ============================================================================
# Full transformer block
# ============================================================================

class TransformerBlock:
    d_model: i64
    num_heads: i64
    d_ff: i64
    attention: MultiHeadAttention
    ffn: FeedForward
    ln1: LNorm
    ln2: LNorm

    static fn create(d_model: i64, num_heads: i64, d_ff: i64) -> TransformerBlock:
        TransformerBlock(d_model: d_model, num_heads: num_heads, d_ff: d_ff, attention: MultiHeadAttention.create(d_model, num_heads), ffn: FeedForward.create(d_model, d_ff), ln1: LNorm.create(d_model), ln2: LNorm.create(d_model))

    fn forward(x: Tensor, causal: bool) -> Result<Tensor, GpuError>:
        # Pre-norm architecture: LN -> Attention -> Residual -> LN -> FFN -> Residual
        val normed1 = self.ln1.forward(x)?
        val attn_out = self.attention.forward(normed1, normed1, normed1, causal)?
        val residual1 = x.add(attn_out)?

        val normed2 = self.ln2.forward(residual1)?
        val ffn_out = self.ffn.forward(normed2)?
        residual1.add(ffn_out)

# ============================================================================
# Layer: pipeline element for ~> composition
# ============================================================================

class Layer:
    name: text

    fn describe() -> text:
        self.name

# Build transformer block as a pipeline description
fn build_transformer_pipeline(d_model: i64, num_heads: i64, d_ff: i64) -> Layer:
    val desc = "Residual(LayerNorm({d_model}) -> MultiHeadAttention({d_model}, {num_heads})) -> Residual(LayerNorm({d_model}) -> Linear({d_model}, {d_ff}) -> GELU -> Linear({d_ff}, {d_model}))"
    Layer(name: desc)

# ============================================================================
# Main
# ============================================================================

fn main():
    val d_model = 8
    val num_heads = 2
    val d_ff = 16
    val seq_len = 4

    print "Transformer block: d_model={d_model}, heads={num_heads}, d_ff={d_ff}"

    val block = TransformerBlock.create(d_model, num_heads, d_ff)
    val input = create_randn([seq_len, d_model])

    val result = block.forward(input, true)
    match result:
        Ok(out):
            print "Output shape: [{out.shape[0]}, {out.shape[1]}]"
            print "First 4 values: [{out.data[0]}, {out.data[1]}, {out.data[2]}, {out.data[3]}]"
        Err(e):
            print "Error: {e.message}"

    # Pipeline version
    val pipeline = build_transformer_pipeline(d_model, num_heads, d_ff)
    print "Pipeline: {pipeline.describe()}"
