    pass_dn

# ============================================================================
# Tensor (local definition, CPU-only)
# ============================================================================

class Tensor:
    shape: [i64]
    data: [f64]

    fn len() -> i64:
        self.data.len()

fn create_tensor(shape: [i64], data: [f64]) -> Tensor:
    Tensor(shape: shape, data: data)

fn create_ones(rows: i64, cols: i64) -> Tensor:
    val total = rows * cols
    var d: [f64] = []
    for i in 0..total:
        d = d + [1.0]
    Tensor(shape: [rows, cols], data: d)

fn create_randn(rows: i64, cols: i64) -> Tensor:
    val total = rows * cols
    var d: [f64] = []
    for i in 0..total:
        # Deterministic pseudo-random based on index
        val v = ((i * 7 + 3) % 100) * 0.01 - 0.5
        d = d + [v]
    Tensor(shape: [rows, cols], data: d)

# ============================================================================
# Helper: simple sqrt approximation for scaling
# ============================================================================

fn simple_sqrt(x: f64) -> f64:
    if x <= 0.0:
        return 0.0
    # Newton's method, 10 iterations
    var guess = x / 2.0
    for iter in 0..10:
        guess = (guess + x / guess) / 2.0
    guess

# ============================================================================
# Scaled dot-product attention (CPU reference)
#
# Computes: softmax(QK^T / sqrt(d_k)) * V
# Q: [seq_len, d_k], K: [seq_len, d_k], V: [seq_len, d_v]
# Output: [seq_len, d_v]
# ============================================================================

fn scaled_dot_product_attention(q: Tensor, k: Tensor, v: Tensor, causal: bool) -> Result<Tensor, GpuError>:
    val seq_len = q.shape[0]
    val d_k = q.shape[1]
    val d_v = v.shape[1]
    val scale = 1.0 / simple_sqrt(d_k * 1.0)

    # Step 1: Compute QK^T / sqrt(d_k) -> scores [seq_len, seq_len]
    var scores: [f64] = []
    for i in 0..seq_len:
        for j in 0..seq_len:
            var dot = 0.0
            for dd in 0..d_k:
                dot = dot + q.data[i * d_k + dd] * k.data[j * d_k + dd]
            var sc = dot * scale
            # Apply causal mask: future positions get large negative value
            if causal:
                if j > i:
                    sc = -1000000.0
            scores = scores + [sc]

    # Step 2: Row-wise softmax
    var weights: [f64] = []
    for i in 0..seq_len:
        # Find max in row for numerical stability
        var row_max = scores[i * seq_len]
        for j in 1..seq_len:
            val sv = scores[i * seq_len + j]
            if sv > row_max:
                row_max = sv

        # Compute exp and sum (using simple approximation: e^x ~ (1+x/256)^256)
        var row_exp: [f64] = []
        var exp_sum = 0.0
        for j in 0..seq_len:
            val x = scores[i * seq_len + j] - row_max
            # Simple exp approximation
            val ex = approx_exp(x)
            row_exp = row_exp + [ex]
            exp_sum = exp_sum + ex

        # Normalize
        for j in 0..seq_len:
            if exp_sum > 0.0:
                weights = weights + [row_exp[j] / exp_sum]
            else:
                weights = weights + [0.0]

    # Step 3: Multiply weights by V -> output [seq_len, d_v]
    var output: [f64] = []
    for i in 0..seq_len:
        for d in 0..d_v:
            var val_sum = 0.0
            for j in 0..seq_len:
                val_sum = val_sum + weights[i * seq_len + j] * v.data[j * d_v + d]
            output = output + [val_sum]

    Ok(Tensor(shape: [seq_len, d_v], data: output))

# Simple exp approximation using repeated squaring: (1 + x/n)^n
fn approx_exp(x: f64) -> f64:
    if x < -20.0:
        return 0.0
    if x > 20.0:
        return 500000000.0
    val n = 256.0
    var result = 1.0 + x / n
    if result < 0.0:
        result = 0.0
    # Square 8 times: (1+x/256)^256
    result = result * result
    result = result * result
    result = result * result
    result = result * result
    result = result * result
    result = result * result
    result = result * result
    result = result * result
    result

# Multi-head attention (simplified: treat as single-head for CPU stub)
fn multi_head_attention(q: Tensor, k: Tensor, v: Tensor, num_heads: i64, causal: bool) -> Result<Tensor, GpuError>:
    # For the CPU stub, we run single-head attention on the full tensors
    # A real implementation would split Q,K,V into heads and concatenate
    scaled_dot_product_attention(q, k, v, causal)

fn main():
    pass_dn
