# 61. Tokenization and Embeddings - Tests
#
# Verifies embedding table creation, token lookup, positional encoding,
# and the full embedding pipeline. All CPU reference implementations.
# Uses small sizes for interpreter performance.

use std.gpu.{GpuError}
use self.main.{create_token_embedding, lookup_tokens, compute_positional_encoding, embed_tokens, build_embedding_pipeline, TokenEmbedding}

describe "Tokenization and embeddings":

    it "should create embedding table":
        val result = create_token_embedding(10, 4)
        match result:
            Ok(emb):
                expect(emb.vocab_size).to_equal(10)
                expect(emb.embed_dim).to_equal(4)
                expect(emb.table.len()).to_equal(40)
            Err(e):
                expect("should not fail").to_equal("ok")

    it "should lookup single token embedding":
        val result = create_token_embedding(10, 4)
        match result:
            Ok(emb):
                val lookup = lookup_tokens(emb, [0])
                match lookup:
                    Ok(data):
                        expect(data.len()).to_equal(4)
                    Err(e):
                        expect("lookup should not fail").to_equal("ok")
            Err(e):
                expect("create should not fail").to_equal("ok")

    it "should lookup batch of tokens":
        val result = create_token_embedding(10, 4)
        match result:
            Ok(emb):
                val lookup = lookup_tokens(emb, [1, 5, 3, 2])
                match lookup:
                    Ok(data):
                        # 4 tokens * 4 dims = 16 values
                        expect(data.len()).to_equal(16)
                    Err(e):
                        expect("lookup should not fail").to_equal("ok")
            Err(e):
                expect("create should not fail").to_equal("ok")

    it "should produce different embeddings for different tokens":
        val result = create_token_embedding(10, 4)
        match result:
            Ok(emb):
                val r1 = lookup_tokens(emb, [0])
                val r2 = lookup_tokens(emb, [1])
                match r1:
                    Ok(d1):
                        match r2:
                            Ok(d2):
                                # Token 0 starts at offset 0, token 1 at offset 4
                                # They use different table values so should differ
                                val differs = d1[0] != d2[0]
                                expect(differs).to_equal(true)
                            Err(e):
                                expect("lookup2 should not fail").to_equal("ok")
                    Err(e):
                        expect("lookup1 should not fail").to_equal("ok")
            Err(e):
                expect("create should not fail").to_equal("ok")

    it "should compute positional encoding":
        val pe = compute_positional_encoding(4, 4)
        # 4 positions * 4 dims = 16 values
        expect(pe.len()).to_equal(16)
        # Position 0 should be all zeros (p=0 makes numerator 0)
        expect(pe[0]).to_equal(0.0)

    it "should add positional encoding to embeddings":
        val result = embed_tokens([0, 1], 10, 4, 8)
        match result:
            Ok(data):
                # 2 tokens * 4 dims = 8 values
                expect(data.len()).to_equal(8)
            Err(e):
                expect("embed should not fail").to_equal("ok")

    it "should build pipeline description":
        val desc = build_embedding_pipeline(50000, 512, 2048)
        expect(desc).to_contain("Embedding")
        expect(desc).to_contain("PositionalEncoding")
