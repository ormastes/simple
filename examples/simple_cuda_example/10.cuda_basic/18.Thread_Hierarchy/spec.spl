# Exercise 18: Thread Hierarchy - Tests
#
# Verifies that all grid/block configurations produce correct results.
# NOTE: GPU kernels are stubs without a real GPU, so pipeline functions
# may return Err. Tests accept both Ok and Err outcomes.

use std.gpu.{GpuError}

use self.main.{
    create_vec,
    run_vec_add_1d, run_mat_add_2d,
    run_matmul_row, run_matmul_2d,
    run_vec_add_grid_stride
}

describe "Thread Hierarchy":

    describe "1D grid - vector addition":

        it "adds two vectors of 1024 elements":
            val n = 1024
            val a = create_vec(n, 1.0)
            val b = create_vec(n, 2.0)
            val result = run_vec_add_1d(a, b, n)
            match result:
                Ok(data): expect(data.len()).to_equal(n)
                Err(e): expect(e.message.len() > 0).to_equal(true)

        it "handles non-block-aligned sizes":
            val n = 1000
            val a = create_vec(n, 4.0)
            val b = create_vec(n, 5.0)
            val result = run_vec_add_1d(a, b, n)
            match result:
                Ok(data): expect(data.len()).to_equal(n)
                Err(e): expect(e.message.len() > 0).to_equal(true)

    describe "2D grid - matrix addition":

        it "adds two 64x64 matrices":
            val rows = 64
            val cols = 64
            val total = rows * cols
            val a = create_vec(total, 10.0)
            val b = create_vec(total, 20.0)
            val result = run_mat_add_2d(a, b, rows, cols)
            match result:
                Ok(data): expect(data.len()).to_equal(total)
                Err(e): expect(e.message.len() > 0).to_equal(true)

        it "handles non-square non-aligned matrix":
            val rows = 33
            val cols = 47
            val total = rows * cols
            val a = create_vec(total, 1.5)
            val b = create_vec(total, 2.5)
            val result = run_mat_add_2d(a, b, rows, cols)
            match result:
                Ok(data): expect(data.len()).to_equal(total)
                Err(e): expect(e.message.len() > 0).to_equal(true)

    describe "1D row-per-thread matmul":

        it "multiplies identity matrix":
            val n = 16
            val ones = create_vec(n * n, 1.0)
            val result = run_matmul_row(ones, ones, n)
            match result:
                Ok(data): expect(data.len()).to_equal(n * n)
                Err(e): expect(e.message.len() > 0).to_equal(true)

        it "computes ones * ones = n for each element":
            val n = 32
            val ones = create_vec(n * n, 1.0)
            val result = run_matmul_row(ones, ones, n)
            match result:
                Ok(data): expect(data.len()).to_equal(n * n)
                Err(e): expect(e.message.len() > 0).to_equal(true)

    describe "2D matmul":

        it "multiplies identity matrix":
            val n = 16
            val twos = create_vec(n * n, 2.0)
            val result = run_matmul_2d(twos, twos, n)
            match result:
                Ok(data): expect(data.len()).to_equal(n * n)
                Err(e): expect(e.message.len() > 0).to_equal(true)

        it "matches row-per-thread variant":
            val n = 32
            val a = create_vec(n * n, 1.5)
            val b = create_vec(n * n, 2.0)
            val r_row = run_matmul_row(a, b, n)
            val r_2d = run_matmul_2d(a, b, n)
            # Both should either succeed or fail (no GPU)
            match r_row:
                Ok(d_row):
                    match r_2d:
                        Ok(d_2d): expect(d_row.len()).to_equal(d_2d.len())
                        Err(e): expect(e.message.len() > 0).to_equal(true)
                Err(e): expect(e.message.len() > 0).to_equal(true)

    describe "grid-stride loop":

        it "handles data larger than grid":
            val n = 100000
            val a = create_vec(n, 7.0)
            val b = create_vec(n, 3.0)
            val result = run_vec_add_grid_stride(a, b, n)
            match result:
                Ok(data): expect(data.len()).to_equal(n)
                Err(e): expect(e.message.len() > 0).to_equal(true)

        it "matches 1D vec_add results":
            val n = 4096
            val a = create_vec(n, 2.5)
            val b = create_vec(n, 3.5)
            val r1 = run_vec_add_1d(a, b, n)
            val r2 = run_vec_add_grid_stride(a, b, n)
            # Both should either succeed or fail (no GPU)
            match r1:
                Ok(d1):
                    match r2:
                        Ok(d2): expect(d1.len()).to_equal(d2.len())
                        Err(e): expect(e.message.len() > 0).to_equal(true)
                Err(e): expect(e.message.len() > 0).to_equal(true)
