# ============================================================================
# Exhaustive match
# ============================================================================

describe "DriverInstance — exhaustive match":
    """
    ## All 4 variants

    Exhaustive match must cover all 4 DriverInstance variants.
    RamFs is exercised; others are pass_todo.
    """

    it "exhaustive match over RamFs returns correct driver_name":
        val inst = DriverInstance.RamFs(RamFsStub(name: "boot"))
        var found_name = ""
        match inst:
            DriverInstance.RamFs(stub):
                found_name = stub.name
            DriverInstance.Fat32(_):
                found_name = "fat32"
            DriverInstance.Nvfs(_):
                found_name = "nvfs"
            DriverInstance.NvfsPosix(_):
                found_name = "nvfs-posix"
        expect(found_name).to_equal("boot")
