# @cover src/lib/nogc_sync_mut/fs_driver/instance.spl 80%
"""
# NVFS DriverInstance Unit Tests

**Feature IDs:** #NVFS-FS-DRIVER-INST
**Category:** Infrastructure
**Difficulty:** 3/5
**Status:** In Progress
**Design:** doc/05_design/nvfs_design.md §5.6

## Overview

Tests for DriverInstance enum (4 variants):
  - Fat32(Fat32Driver)
  - Nvfs(NvfsDriver)
  - NvfsPosix(NvfsPosixDriver)
  - RamFs(RamFsStub)

RamFs is usable in host-test context. Nvfs/NvfsPosix may require
native driver submodules not available at host-test time → pass_todo.
"""

use std.sspec.*
use std.fs_driver.instance.*


# ============================================================================
# RamFs variant
# ============================================================================

describe "DriverInstance — RamFs":
    """
    ## RamFs stub

    RamFsStub is available in host-test context and provides driver_name().
    """

    it "RamFs constructs with name field":
        val inst = DriverInstance.RamFs(RamFsStub(name: "test"))
        match inst:
            DriverInstance.RamFs(stub):
                expect(stub.name).to_equal("test")
            _:
                expect(false).to_equal(true)

    it "RamFs driver_name returns the stub name":
        val inst = DriverInstance.RamFs(RamFsStub(name: "rootfs"))
        expect(inst.driver_name()).to_equal("rootfs")

    it "RamFs with empty name is valid":
        val inst = DriverInstance.RamFs(RamFsStub(name: ""))
        match inst:
            DriverInstance.RamFs(stub):
                expect(stub.name).to_equal("")
            _:
                expect(false).to_equal(true)


