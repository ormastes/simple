# NVFS driver — extension handle impl blocks.
#
# The struct definitions live in std.fs_driver.extension (main repo).
# This file provides impl blocks with real method signatures over those
# structs. Methods return Err(Unsupported) until the feature milestone
# that implements them.
#
# Source: doc/05_design/fs_driver_interface.md §4; nvfs_design_v2.md §6-§14.

use std.fs_driver.error.{FsError}
use std.fs_driver.extension.{SnapshotExt, DedupExt, ChecksumExt, SendRecvExt, ScrubExt, CompressExt, EncryptExt, ReflinkExt}

# ---------------------------------------------------------------------------
# SnapshotExt — point-in-time snapshot operations
# ---------------------------------------------------------------------------

impl SnapshotExt:
    fn create(name: text) -> Result<u64, FsError>:
        """Create a named snapshot; return snapshot generation id.

        Not yet implemented — full snapshot tree (§6) is milestone N3.
        """
        Err(FsError.Unsupported)

    fn delete(snap_gen: u64) -> Result<(), FsError>:
        """Delete a snapshot identified by generation id.

        Not yet implemented.
        """
        Err(FsError.Unsupported)

    fn list() -> Result<[u64], FsError>:
        """Return all snapshot generation ids in ascending order.

        Not yet implemented.
        """
        Err(FsError.Unsupported)

# ---------------------------------------------------------------------------
# DedupExt — offline content-hash deduplication
# ---------------------------------------------------------------------------

impl DedupExt:
    fn run_scan() -> Result<u64, FsError>:
        """Trigger an offline dedup scan; return estimated bytes saved.

        Not yet implemented — dedup is milestone N6.
        """
        Err(FsError.Unsupported)

    fn report_saved_bytes() -> Result<u64, FsError>:
        """Return cumulative bytes saved by dedup since mount.

        Not yet implemented.
        """
        Err(FsError.Unsupported)

# ---------------------------------------------------------------------------
# ChecksumExt — per-block checksum verification
# ---------------------------------------------------------------------------

impl ChecksumExt:
    fn verify_file(path: text) -> Result<bool, FsError>:
        """Verify all checksums for the file at path.

        Returns true if all blocks pass; false if any mismatch detected.
        Not yet implemented as a standalone API (verification runs inline
        on every read in N1+).
        """
        Err(FsError.Unsupported)

    fn get_algo_tag() -> Result<u8, FsError>:
        """Return the checksum algorithm tag (ChecksumAlgo) in use for this volume.

        Not yet exposed via the extension API.
        """
        Err(FsError.Unsupported)

# ---------------------------------------------------------------------------
# SendRecvExt — incremental stream send/receive
# ---------------------------------------------------------------------------

impl SendRecvExt:
    fn send_full(snap_gen: u64) -> Result<[u8], FsError>:
        """Produce a full send-stream for the given snapshot.

        Not yet implemented — send/receive is milestone N5.
        """
        Err(FsError.Unsupported)

    fn send_incremental(from_gen: u64, to_gen: u64) -> Result<[u8], FsError>:
        """Produce an incremental send-stream between two snapshot generations.

        Not yet implemented.
        """
        Err(FsError.Unsupported)

# ---------------------------------------------------------------------------
# ScrubExt — background online data integrity scrub
# ---------------------------------------------------------------------------

impl ScrubExt:
    fn start() -> Result<(), FsError>:
        """Start a background scrub pass over all data blocks.

        Not yet implemented — scrub is milestone N4.
        """
        Err(FsError.Unsupported)

    fn status() -> Result<u64, FsError>:
        """Return number of blocks verified so far in the current scrub pass.

        Not yet implemented.
        """
        Err(FsError.Unsupported)

# ---------------------------------------------------------------------------
# CompressExt — transparent per-file compression
# ---------------------------------------------------------------------------

impl CompressExt:
    fn set_file_algo(path: text, algo_tag: u8) -> Result<(), FsError>:
        """Set the compression algorithm for the file at path.

        Not yet implemented — compression is milestone N4+.
        """
        Err(FsError.Unsupported)

    fn get_file_ratio(path: text) -> Result<u64, FsError>:
        """Return compressed-to-uncompressed ratio * 1000 for the file at path.

        Not yet implemented.
        """
        Err(FsError.Unsupported)

# ---------------------------------------------------------------------------
# EncryptExt — transparent at-rest encryption
# ---------------------------------------------------------------------------

impl EncryptExt:
    fn set_volume_key(key_id: u64) -> Result<(), FsError>:
        """Associate a master key slot with this volume.

        Not yet implemented — encryption is milestone N7.
        """
        Err(FsError.Unsupported)

    fn rotate_key(old_key_id: u64, new_key_id: u64) -> Result<(), FsError>:
        """Rotate the volume encryption key.

        Not yet implemented.
        """
        Err(FsError.Unsupported)

# ---------------------------------------------------------------------------
# ReflinkExt — COW file-range clone (O(1) metadata op)
# ---------------------------------------------------------------------------

impl ReflinkExt:
    fn clone_range(src_path: text, src_off: i64, dst_path: text, dst_off: i64, len: i64) -> Result<(), FsError>:
        """Clone a byte range from src to dst using COW extent sharing.

        Not yet implemented as full reflink — arena_clone_range_impl exists
        but full reflink syscall integration is milestone N3.
        """
        Err(FsError.Unsupported)

    fn clone_file(src_path: text, dst_path: text) -> Result<(), FsError>:
        """Clone an entire file as a reflink (O(1) COW metadata op).

        Not yet implemented.
        """
        Err(FsError.Unsupported)
