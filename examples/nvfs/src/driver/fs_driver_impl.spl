# NVFS native driver — NvfsDriver implements FsDriver.
#
# Provides the DriverInstance::Nvfs variant implementation.
# append-only write: if offset != current arena length, returns Err(Unsupported)
# (callers route random-write to POSIX shim via NvfsPosixDriver, agent B2).
#
# Source: doc/05_design/fs_driver_interface.md §3; nvfs_design_v2.md §17.

use std.fs_driver.error.{FsError}
use std.fs_driver.types.{FileHandle, DirHandle, Inode, Path, OpenFlags, MountOptions, FsStatfs, FileStat, DirEntry}
use std.fs_driver.capability.{Capability, CapabilitySet}
use std.fs_driver.extension.{Extension, SnapshotExt, DedupExt, ChecksumExt, SendRecvExt, ScrubExt, CompressExt, EncryptExt, ReflinkExt}
use std.fs_driver.ops.{FsDriver}
use examples.nvfs.src.core.arena.{arena_create_impl, arena_append_impl, arena_readv_impl, arena_total_bytes_impl, arena_discard_impl}
use examples.nvfs.src.core.ns_tree.{Namespace, NsInodeKind}
use examples.nvfs.src.core.pmap.{PmapEntry, pmap_entry_verify, pmap_entry_checksum_for}
use examples.nvfs.src.core.pmap_btree.{PmapBTree, PmapBTreeEntry, PmapKey, pmap_btree_new, pmap_btree_insert, pmap_btree_lookup, pmap_btree_snapshot}
use examples.nvfs.src.core.reflink.{reflink_bump, reflink_drop, reflink_get}
use examples.nvfs.src.driver.capabilities.{nvfs_native_capabilities}

# ---------------------------------------------------------------------------
# Module-level: verify-on-read toggle (shared with extensions.spl)
# ---------------------------------------------------------------------------

var _verify_on_read: bool = true

fn nvfs_set_verify_on_read(enabled: bool):
    """Enable or disable checksum verification on every read."""
    _verify_on_read = enabled

fn nvfs_get_verify_on_read() -> bool:
    """Return current verify-on-read setting."""
    _verify_on_read

# ---------------------------------------------------------------------------
# Module-level: pmap index (arena_id + offset -> PmapBTreeEntry)
# N5a: B-tree backed; replaces the flat list from N3.
# FR-N3-001: Closed — B-tree keyed pmap sidecar implemented.
# ---------------------------------------------------------------------------

# Re-export PmapSidecarEntry as a type alias for scrub.spl compatibility.
# scrub.spl imports PmapSidecarEntry from this module and accesses
# .arena_id, .offset, .length, .entry — same fields as PmapBTreeEntry.
struct PmapSidecarEntry:
    """Pmap sidecar entry (wraps PmapBTreeEntry for scrub.spl compatibility).

    arena_id, offset, length, entry mirror PmapBTreeEntry fields.
    """
    arena_id: i64
    offset:   i64
    length:   i64
    entry:    PmapEntry

var _pmap_btree: PmapBTree = pmap_btree_new(16)

fn _pmap_sidecar_put(arena_id: i64, offset: i64, length: i64, entry: PmapEntry):
    """Store a PmapEntry in the B-tree; overwrites existing entry for same key."""
    val _ = pmap_btree_insert(_pmap_btree, arena_id, offset, length, entry)

fn _pmap_sidecar_get(arena_id: i64, offset: i64) -> Option<PmapEntry>:
    """Look up the PmapEntry for a given arena_id + offset. O(log n)."""
    val key = PmapKey(arena_id: arena_id, offset: offset)
    val result = pmap_btree_lookup(_pmap_btree, key)
    match result:
        case None:
            None
        case Some(bt_entry):
            Some(bt_entry.entry)

fn nvfs_pmap_sidecar_snapshot() -> [PmapSidecarEntry]:
    """Return a snapshot of all current pmap entries in key order.

    Used by the scrub pass (scrub.spl) to iterate over tracked ranges.
    Returns a copy; mutations to the returned list do not affect the index.
    """
    val all_entries = pmap_btree_snapshot(_pmap_btree)
    var out: [PmapSidecarEntry] = []
    var i = 0
    while i < all_entries.len() as i64:
        val bt = all_entries[i]
        out.push(PmapSidecarEntry(
            arena_id: bt.arena_id,
            offset:   bt.offset,
            length:   bt.length,
            entry:    bt.entry
        ))
        i = i + 1
    out

# ---------------------------------------------------------------------------
# NvfsOpenHandle — internal record for an open file
# ---------------------------------------------------------------------------

struct NvfsOpenHandle:
    """Internal tracking record for a file opened via NvfsDriver.

    handle_id  — opaque id returned to callers (matches FileHandle.id).
    arena_id   — the underlying arena backing this file.
    read_only  — true if file was opened without write permission.
    """
    handle_id: u64
    arena_id:  i64
    path:      text
    read_only: bool

# ---------------------------------------------------------------------------
# Module-level handle table (maps FileHandle.id to NvfsOpenHandle)
# ---------------------------------------------------------------------------

var _open_handles: [NvfsOpenHandle] = []
var _next_handle_id: u64 = 1

fn _find_handle(id: u64) -> i64:
    """Return index of handle with id in _open_handles, or -1."""
    var i = 0
    while i < _open_handles.len() as i64:
        if _open_handles[i].handle_id == id:
            return i
        i = i + 1
    -1

fn _alloc_handle(arena_id: i64, path: text, read_only: bool) -> FileHandle:
    """Allocate a new handle entry and return the opaque FileHandle."""
    val id = _next_handle_id
    _next_handle_id = _next_handle_id + 1
    val h = NvfsOpenHandle(handle_id: id, arena_id: arena_id, path: path, read_only: read_only)
    _open_handles.push(h)
    FileHandle(id: id)

fn _remove_handle(idx: i64):
    """Remove the handle at idx from the table (swap-remove for O(1))."""
    val last = _open_handles.len() as i64 - 1
    if idx != last:
        _open_handles[idx] = _open_handles[last]
    # pop last element
    var new_list: [NvfsOpenHandle] = []
    var i = 0
    while i < last:
        new_list.push(_open_handles[i])
        i = i + 1
    _open_handles = new_list

# ---------------------------------------------------------------------------
# NvfsDriver struct
# ---------------------------------------------------------------------------

struct NvfsDriver:
    """NVFS native driver — append-only COW storage over arena_* API.

    Capabilities: COW, Snapshot, Checksum, SelfHeal, Reflink, Compress,
    CaseSensitive, Hardlinks, SparseFiles, LargeFiles, UnicodeNames,
    SendReceive, Dedup, Scrub, Encrypt, AsyncIo.

    Does NOT provide PosixCompat — route random-write callers to NvfsPosixDriver.
    """
    name:      text
    mounted:   bool
    read_only: bool
    ns: Namespace

impl NvfsDriver:

    static fn new(name: text) -> NvfsDriver:
        NvfsDriver(
            name:      name,
            mounted:   false,
            read_only: false,
            ns: Namespace.new()
        )

    me fn _update_inode_size_for_arena(arena_id: i64, size: u64):
        """Update namespace size metadata for the file backed by arena_id."""
        var i = 0
        while i < self.ns.inodes.len() as i64:
            val inode = self.ns.inodes[i]
            if inode.arena_id == arena_id:
                self.ns.inodes[i] = NsInode(
                    ino: inode.ino,
                    kind: inode.kind,
                    arena_id: inode.arena_id,
                    sym_target: inode.sym_target,
                    size: size,
                    mode: inode.mode,
                    ctime: inode.ctime,
                    mtime: inode.mtime
                )
                return
            i = i + 1

    fn _file_stat_for_inode(n: NsInode) -> FileStat:
        """Build FileStat from namespace metadata."""
        val blocks = (n.size + 4095) / 4096
        FileStat(
            inode:         n.ino,
            size:          n.size,
            blocks:        blocks,
            block_size:    4096,
            mode:          n.mode,
            uid:           0,
            gid:           0,
            nlinks:        1,
            atime_ns:      0,
            mtime_ns:      n.mtime,
            ctime_ns:      n.ctime,
            birth_time_ns: n.ctime
        )

impl FsDriver for NvfsDriver:

    # --- Lifecycle ---

    fn mount(opts: MountOptions) -> Result<(), FsError>:
        """Record mount options; mark driver as mounted."""
        self.mounted   = true
        self.read_only = opts.read_only
        Ok(())

    fn unmount() -> Result<(), FsError>:
        """Flush and unmount. Fails with Busy if any handles remain open."""
        if _open_handles.len() as i64 > 0:
            return Err(FsError.Busy)
        self.mounted = false
        Ok(())

    fn remount(opts: MountOptions) -> Result<(), FsError>:
        """Update mount options in-place."""
        self.read_only = opts.read_only
        Ok(())

    fn statfs() -> Result<FsStatfs, FsError>:
        """Return zero-filled statistics (real accounting deferred to N2)."""
        Ok(FsStatfs(
            total_bytes: 0,
            free_bytes:  0,
            avail_bytes: 0,
            files_total: 0,
            files_free:  0,
            block_size:  4096
        ))

    # --- Root ---

    fn root() -> Result<Inode, FsError>:
        """Return the root inode (id=1 for NVFS)."""
        Ok(Inode(id: 1))

    # --- File I/O ---

    fn open(path: Path, flags: OpenFlags) -> Result<FileHandle, FsError>:
        """Open a file by path, creating it when requested by writable flags."""
        if (not self.mounted):
            return Err(FsError.InvalidArg)
        val writable = flags.is_writable()
        if (writable and self.read_only):
            return Err(FsError.ReadOnly)
        val existing = self.ns.resolve_path(path.raw)
        if existing.is_ok():
            val inode = existing.unwrap()
            match inode.kind:
                case NsInodeKind.File:
                    return Ok(_alloc_handle(inode.arena_id, path.raw, not writable))
                case _:
                    return Err(FsError.InvalidArg)
        if not writable:
            return Err(FsError.NotFound)
        val pair = self.ns.resolve_parent(path.raw)?
        val arena_id = arena_create_impl(0, 4096)
        val inode = self.ns.create_file(pair.0, pair.1, arena_id, 0o644)?
        Ok(_alloc_handle(inode.arena_id, path.raw, false))

    fn close(handle: FileHandle) -> Result<(), FsError>:
        """Release an open FileHandle."""
        val idx = _find_handle(handle.id)
        if idx < 0:
            return Err(FsError.InvalidArg)
        _remove_handle(idx)
        Ok(())

    fn read(handle: FileHandle, offset: i64, buf: [u8]) -> Result<i64, FsError>:
        """Read from the arena backing handle at offset.

        When verify_on_read is true, fetches the pmap entry for the range
        and verifies the checksum of the returned bytes.  Returns
        Err(Corrupt) on mismatch.
        """
        val idx = _find_handle(handle.id)
        if idx < 0:
            return Err(FsError.InvalidArg)
        val h = _open_handles[idx]
        val data = arena_readv_impl(h.arena_id, offset, buf.len() as i64)
        var i = 0
        while i < data.len() as i64 and i < buf.len() as i64:
            buf[i] = data[i]
            i = i + 1
        if _verify_on_read and data.len() as i64 > 0:
            val entry_opt = _pmap_sidecar_get(h.arena_id, offset)
            match entry_opt:
                case Some(entry):
                    if not pmap_entry_verify(entry, data):
                        return Err(FsError.Corrupt)
                case None:
                    val _verify_skipped_for_untracked_range = true
        Ok(data.len() as i64)

    fn write(handle: FileHandle, offset: i64, buf: [u8]) -> Result<i64, FsError>:
        """Append-only write. If offset != current length, return Err(Unsupported).

        Callers requiring random-write must use NvfsPosixDriver (agent B2).
        Records a pmap sidecar entry (checksum) for verify-on-read.
        """
        val idx = _find_handle(handle.id)
        if idx < 0:
            return Err(FsError.InvalidArg)
        val h = _open_handles[idx]
        if h.read_only:
            return Err(FsError.ReadOnly)
        val current_len = arena_total_bytes_impl(h.arena_id)
        if offset != current_len:
            return Err(FsError.Unsupported)
        val written = arena_append_impl(h.arena_id, buf, 0)
        if written < 0:
            return Err(FsError.IoError(0))
        self._update_inode_size_for_arena(h.arena_id, (offset + written) as u64)
        # Record pmap entry for this written range.
        val cksum = pmap_entry_checksum_for(buf)
        val pentry = PmapEntry(
            logical:        offset as u64,
            phys:           h.arena_id,
            offset:         offset as u64,
            len:            written as u64,
            birth_gen:      0,
            checksum_algo:  0,
            compress_algo:  0,
            compressed_len: 0,
            checksum:       cksum
        )
        _pmap_sidecar_put(h.arena_id, offset, written, pentry)
        Ok(written)

    fn pread(handle: FileHandle, offset: i64, buf: [u8]) -> Result<i64, FsError>:
        """Positional read — delegates to read (N1: no position tracking)."""
        self.read(handle, offset, buf)

    fn pwrite(handle: FileHandle, offset: i64, buf: [u8]) -> Result<i64, FsError>:
        """Positional write — enforces append-only constraint via write."""
        self.write(handle, offset, buf)

    fn fstat(handle: FileHandle) -> Result<FileStat, FsError>:
        """Return zero-filled stat for the file backing handle."""
        val idx = _find_handle(handle.id)
        if idx < 0:
            return Err(FsError.InvalidArg)
        val h = _open_handles[idx]
        val size = arena_total_bytes_impl(h.arena_id)
        val sz = if size < 0: 0 else: size as u64
        Ok(FileStat(
            inode:         h.arena_id as u64,
            size:          sz,
            blocks:        (sz + 4095) / 4096,
            block_size:    4096,
            mode:          0o644,
            uid:           0,
            gid:           0,
            nlinks:        1,
            atime_ns:      0,
            mtime_ns:      0,
            ctime_ns:      0,
            birth_time_ns: 0
        ))

    fn stat(path: Path) -> Result<FileStat, FsError>:
        """Path-based stat backed by the in-memory namespace."""
        val inode = self.ns.resolve_path(path.raw)?
        match inode.kind:
            case NsInodeKind.File:
                Ok(self._file_stat_for_inode(inode))
            case NsInodeKind.Dir:
                Ok(self._file_stat_for_inode(inode))
            case NsInodeKind.Symlink:
                Ok(self._file_stat_for_inode(inode))

    fn truncate(path: Path, length: i64) -> Result<(), FsError>:
        """Truncate not supported on append-only native driver."""
        Err(FsError.Unsupported)

    fn ftruncate(handle: FileHandle, length: i64) -> Result<(), FsError>:
        """ftruncate not supported on append-only native driver."""
        Err(FsError.Unsupported)

    fn fsync(handle: FileHandle) -> Result<(), FsError>:
        """fsync — N1 in-memory: no-op (all writes already durable in-process)."""
        val idx = _find_handle(handle.id)
        if idx < 0:
            return Err(FsError.InvalidArg)
        Ok(())

    fn fdatasync(handle: FileHandle) -> Result<(), FsError>:
        """fdatasync — N1 in-memory: no-op."""
        val idx = _find_handle(handle.id)
        if idx < 0:
            return Err(FsError.InvalidArg)
        Ok(())

    # --- Namespace ---

    fn readdir(handle: DirHandle) -> Result<[DirEntry], FsError>:
        """readdir — list children of the directory identified by handle.id."""
        val raw_entries = self.ns.readdir(handle.id)?
        var out: [DirEntry] = []
        var i = 0
        while i < raw_entries.len() as i64:
            val e = raw_entries[i]
            val child_opt = self.ns._get_inode(e.child_ino)
            val is_dir = match child_opt:
                case None: false
                case Some(n):
                    match n.kind:
                        case NsInodeKind.Dir: true
                        case _: false
            out.push(DirEntry(
                name:   e.name,
                inode:  Inode(id: e.child_ino),
                is_dir: is_dir
            ))
            i = i + 1
        Ok(out)

    fn mkdir(path: Path, mode: u32) -> Result<(), FsError>:
        """mkdir — create a directory; resolve parent path."""
        val pair = self.ns.resolve_parent(path.raw)?
        val parent_ino = pair.0
        val leaf = pair.1
        val _ = self.ns.mkdir(parent_ino, leaf, mode)?
        Ok(())

    fn rmdir(path: Path) -> Result<(), FsError>:
        """rmdir — remove an empty directory."""
        val pair = self.ns.resolve_parent(path.raw)?
        val parent_ino = pair.0
        val leaf = pair.1
        self.ns.rmdir(parent_ino, leaf)

    fn unlink(path: Path) -> Result<(), FsError>:
        """unlink — remove a file or symlink via namespace.

        Decrements the reflink refcount for the arena.  Discards the arena
        only when the refcount drops to zero.
        """
        val pair = self.ns.resolve_parent(path.raw)?
        val parent_ino = pair.0
        val leaf = pair.1
        val removed = self.ns.unlink(parent_ino, leaf)?
        if removed.arena_id >= 0:
            val should_discard = reflink_drop(removed.arena_id)
            if should_discard:
                val _ = arena_discard_impl(removed.arena_id)
        Ok(())

    fn rename(old: Path, new: Path) -> Result<(), FsError>:
        """rename — atomic move within namespace."""
        val old_pair = self.ns.resolve_parent(old.raw)?
        val old_parent = old_pair.0
        val old_leaf = old_pair.1
        val new_pair = self.ns.resolve_parent(new.raw)?
        val new_parent = new_pair.0
        val new_leaf = new_pair.1
        self.ns.rename(old_parent, old_leaf, new_parent, new_leaf)

    fn symlink(target: Path, link: Path) -> Result<(), FsError>:
        """symlink — create a symlink at `link` pointing to `target`."""
        val pair = self.ns.resolve_parent(link.raw)?
        val parent_ino = pair.0
        val leaf = pair.1
        val _ = self.ns.symlink(parent_ino, leaf, target.raw)?
        Ok(())

    fn readlink(path: Path) -> Result<Path, FsError>:
        """readlink — resolve symlink target for path."""
        val ns_inode = self.ns.resolve_path(path.raw)?
        val target = self.ns.readlink(ns_inode.ino)?
        Ok(Path(raw: target))

    fn link(target: Path, link: Path) -> Result<(), FsError>:
        """Hard link (reflink) — resolve target to arena_id; bump refcount;
        create a namespace alias at link pointing to the same inode.

        Returns Err(NotFound) if target does not exist in the namespace.
        """
        val ns_inode = self.ns.resolve_path(target.raw)?
        val arena_id = ns_inode.arena_id
        val _ = reflink_bump(arena_id)
        val pair = self.ns.resolve_parent(link.raw)?
        val parent_ino = pair.0
        val leaf = pair.1
        self.ns.link(parent_ino, leaf, ns_inode.ino)

    # --- Extension probe ---

    fn capabilities() -> CapabilitySet:
        """Return the full NVFS native capability set (16 capabilities)."""
        nvfs_native_capabilities()

    fn probe(cap: Capability) -> Option<Extension>:
        """Return a concrete Extension handle for the requested capability.

        Returns None for capabilities not in the NVFS native set, and for
        capabilities whose extension structs are not yet fully implemented.
        In those cases the caller falls back to Err(Unsupported) per the
        contract in fs_driver_interface.md §4.
        """
        match cap:
            case Capability.Snapshot:
                Some(Extension.Snapshot(ext: SnapshotExt(
                    volume_name: self.name,
                    snap_count:  0
                )))
            case Capability.Dedup:
                Some(Extension.Dedup(ext: DedupExt(
                    bytes_saved: 0,
                    scan_active: false
                )))
            case Capability.Checksum:
                Some(Extension.Checksum(ext: ChecksumExt(
                    algo_tag:  3,
                    block_size: 4096
                )))
            case Capability.SendReceive:
                Some(Extension.SendReceive(ext: SendRecvExt(
                    last_sent_gen: 0,
                    stream_format: 1
                )))
            case Capability.Scrub:
                Some(Extension.Scrub(ext: ScrubExt(
                    blocks_verified: 0,
                    errors_found:    0
                )))
            case Capability.Compress:
                Some(Extension.Compress(ext: CompressExt(
                    default_algo: 0,
                    enabled:      false
                )))
            case Capability.Encrypt:
                Some(Extension.Encrypt(ext: EncryptExt(
                    key_id:   0,
                    key_bits: 256
                )))
            case Capability.Reflink:
                Some(Extension.Reflink(ext: ReflinkExt(
                    shared_extents: 0,
                    cow_pending:    false
                )))
            case _:
                None
