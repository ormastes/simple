# NVFS core — shared storage and durability ordinals.
#
# These constants are the canonical integer tags used by cross-submodule
# consumers that still call the in-memory arena APIs with class_tag/durability
# ordinals instead of typed storage enums.

val STORAGE_CLASS_DB_WAL: i32 = 1
val STORAGE_CLASS_META_DURABLE: i32 = 2
val STORAGE_CLASS_DB_TEMP: i32 = 3

val DURABILITY_DATA_DURABLE: i32 = 1
