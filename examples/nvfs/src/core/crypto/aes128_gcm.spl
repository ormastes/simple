#![allow(unnamed_duplicate_typed_args)]
# AES-128-GCM — Pure Simple Implementation
#
# AES-128 in Galois/Counter Mode per NIST SP 800-38D.
# No SFFI/Rust FFI — pure Simple language, suitable for baremetal.
#
# Reference: FIPS 197 (AES)
# Reference: NIST SP 800-38D (GCM)

extern fn rt_bytes_u8_at(arr: [u8], idx: i64) -> i64
extern fn serial_println(msg: text)
extern fn rt_array_new_with_cap(cap: i64) -> [u8]
extern fn rt_aes_sbox(i: i64) -> i64
extern fn rt_aes_rcon(i: i64) -> i64
extern fn rt_aes128_encrypt_block_into(key: [u8], block: [u8], out: [u8]) -> i64

fn _u8_at(buf: [u8], idx: u64) -> u8:
    rt_bytes_u8_at(buf, idx.to_i64()).to_u8()

fn _gcm_debug(msg: text):
    serial_println("[aes128_gcm] {msg}")

fn _debug_bytes4(label: text, buf: [u8]):
    if buf.len() >= 4:
        _gcm_debug("{label} b0={_u8_at(buf, 0)} b1={_u8_at(buf, 1)} b2={_u8_at(buf, 2)} b3={_u8_at(buf, 3)} len={buf.len()}")
    else:
        _gcm_debug("{label} short len={buf.len()}")

fn _debug_bytes16(label: text, buf: [u8]):
    if buf.len() >= 16:
        _gcm_debug("{label} 0={_u8_at(buf, 0)} 1={_u8_at(buf, 1)} 2={_u8_at(buf, 2)} 3={_u8_at(buf, 3)}")
        _gcm_debug("{label} 4={_u8_at(buf, 4)} 5={_u8_at(buf, 5)} 6={_u8_at(buf, 6)} 7={_u8_at(buf, 7)}")
        _gcm_debug("{label} 8={_u8_at(buf, 8)} 9={_u8_at(buf, 9)} 10={_u8_at(buf, 10)} 11={_u8_at(buf, 11)}")
        _gcm_debug("{label} 12={_u8_at(buf, 12)} 13={_u8_at(buf, 13)} 14={_u8_at(buf, 14)} 15={_u8_at(buf, 15)}")
    else:
        _gcm_debug("{label} short len={buf.len()}")

fn _debug_bytes_all(label: text, buf: [u8]):
    var i: u64 = 0
    while i < buf.len():
        val b0 = _u8_at(buf, i)
        val b1 = if (i + 1) < buf.len(): _u8_at(buf, i + 1) else: 0
        val b2 = if (i + 2) < buf.len(): _u8_at(buf, i + 2) else: 0
        val b3 = if (i + 3) < buf.len(): _u8_at(buf, i + 3) else: 0
        val b4 = if (i + 4) < buf.len(): _u8_at(buf, i + 4) else: 0
        val b5 = if (i + 5) < buf.len(): _u8_at(buf, i + 5) else: 0
        val b6 = if (i + 6) < buf.len(): _u8_at(buf, i + 6) else: 0
        val b7 = if (i + 7) < buf.len(): _u8_at(buf, i + 7) else: 0
        _gcm_debug("{label} off={i} 0={b0} 1={b1} 2={b2} 3={b3} 4={b4} 5={b5} 6={b6} 7={b7}")
        i = i + 8

# ============================================================================
# AES S-Box (FIPS 197, Section 5.1.1)
# ============================================================================

fn _aes_sbox(index: i64) -> u8:
    rt_aes_sbox(index).to_u8()

fn _aes_rcon(index: i64) -> u32:
    rt_aes_rcon(index).to_u32()

# ============================================================================
# Result Type for Decryption
# ============================================================================

enum Aes128GcmResult:
    Ok(data: [u8])
    Err(msg: text)

# ============================================================================
# AES-128 Core Helpers
# ============================================================================

fn _sub_word(w: u32) -> u32:
    """Apply S-box to each byte of a 32-bit word."""
    val b0 = _aes_sbox(((w >> 24) & 0xFF).to_i64())
    val b1 = _aes_sbox(((w >> 16) & 0xFF).to_i64())
    val b2 = _aes_sbox(((w >> 8) & 0xFF).to_i64())
    val b3 = _aes_sbox((w & 0xFF).to_i64())
    (b0.to_u32() << 24) | (b1.to_u32() << 16) | (b2.to_u32() << 8) | b3.to_u32()

fn _rot_word(w: u32) -> u32:
    """Rotate word left by 8 bits: [a0,a1,a2,a3] -> [a1,a2,a3,a0]."""
    ((w << 8) | (w >> 24)) & 0xFFFFFFFF

# ============================================================================
# AES-128 Key Expansion (FIPS 197, Section 5.2)
# ============================================================================

fn aes128_key_expansion(key: [u8]) -> [u8]:
    """Expand 16-byte AES-128 key into 176 round-key bytes."""
    val nk: u64 = 4
    val nr: u64 = 10
    val total_words: u64 = 4 * (nr + 1)  # 44
    val total_bytes: u64 = total_words * 4

    var expanded: [u8] = rt_array_new_with_cap(total_bytes.to_i64())

    var i: u64 = 0
    while i < 16:
        expanded.push(_u8_at(key, i))
        i = i + 1

    var word_idx: u64 = nk
    while word_idx < total_words:
        val prev_base = (word_idx - 1) * 4
        var t0 = _u8_at(expanded, prev_base)
        var t1 = _u8_at(expanded, prev_base + 1)
        var t2 = _u8_at(expanded, prev_base + 2)
        var t3 = _u8_at(expanded, prev_base + 3)

        if (word_idx % nk) == 0:
            val rot0 = t1
            val rot1 = t2
            val rot2 = t3
            val rot3 = t0
            t0 = _aes_sbox(rot0.to_i64())
            t1 = _aes_sbox(rot1.to_i64())
            t2 = _aes_sbox(rot2.to_i64())
            t3 = _aes_sbox(rot3.to_i64())
            val rcon = _aes_rcon(((word_idx / nk) - 1).to_i64())
            t0 = t0 ^ ((rcon >> 24) & 0xFF).to_u8()
            t1 = t1 ^ ((rcon >> 16) & 0xFF).to_u8()
            t2 = t2 ^ ((rcon >> 8) & 0xFF).to_u8()
            t3 = t3 ^ (rcon & 0xFF).to_u8()

        val prev_word_base = (word_idx - nk) * 4
        expanded.push(_u8_at(expanded, prev_word_base) ^ t0)
        expanded.push(_u8_at(expanded, prev_word_base + 1) ^ t1)
        expanded.push(_u8_at(expanded, prev_word_base + 2) ^ t2)
        expanded.push(_u8_at(expanded, prev_word_base + 3) ^ t3)
        word_idx = word_idx + 1

    expanded

# ============================================================================
# AES State Operations (4x4 byte matrix, column-major)
# ============================================================================
#
# State is represented as [u8] of length 16.
# state[r + 4*c] = byte at row r, column c.

fn _sub_bytes(state: [u8]) -> [u8]:
    """Apply S-box substitution to each byte."""
    var result: [u8] = rt_array_new_with_cap(16)
    var i: u64 = 0
    while i < 16:
        result.push(_aes_sbox(_u8_at(state, i).to_i64()))
        i = i + 1
    result

fn _shift_rows(state: [u8]) -> [u8]:
    """Cyclically shift rows.

    Row 0: no shift
    Row 1: shift left 1
    Row 2: shift left 2
    Row 3: shift left 3
    """
    var r: [u8] = rt_array_new_with_cap(16)
    r.push(_u8_at(state, 0))
    r.push(_u8_at(state, 5))
    r.push(_u8_at(state, 10))
    r.push(_u8_at(state, 15))
    r.push(_u8_at(state, 4))
    r.push(_u8_at(state, 9))
    r.push(_u8_at(state, 14))
    r.push(_u8_at(state, 3))
    r.push(_u8_at(state, 8))
    r.push(_u8_at(state, 13))
    r.push(_u8_at(state, 2))
    r.push(_u8_at(state, 7))
    r.push(_u8_at(state, 12))
    r.push(_u8_at(state, 1))
    r.push(_u8_at(state, 6))
    r.push(_u8_at(state, 11))
    r

fn _xtime(b: u8) -> u8:
    """Multiply by x (0x02) in GF(2^8) with reduction polynomial 0x1b."""
    val shifted = (b.to_u32() << 1) & 0xFF
    if (b & 0x80) != 0:
        (shifted ^ 0x1b).to_u8()
    else:
        shifted.to_u8()

fn _gf_mul(a: u8, b: u8) -> u8:
    """Multiply two bytes in GF(2^8)."""
    var result: u8 = 0x00
    var aa = a
    var bb = b
    var i: u64 = 0
    while i < 8:
        if (bb & 0x01) != 0:
            result = result ^ aa
        aa = _xtime(aa)
        bb = (bb >> 1).to_u8()
        i = i + 1
    result

fn _mix_columns(state: [u8]) -> [u8]:
    """Mix columns using GF(2^8) matrix multiplication."""
    var r: [u8] = rt_array_new_with_cap(16)
    var c: u64 = 0
    while c < 4:
        val base = c * 4
        val s0 = _u8_at(state, base)
        val s1 = _u8_at(state, base + 1)
        val s2 = _u8_at(state, base + 2)
        val s3 = _u8_at(state, base + 3)

        r.push(_gf_mul(0x02, s0) ^ _gf_mul(0x03, s1) ^ s2 ^ s3)
        r.push(s0 ^ _gf_mul(0x02, s1) ^ _gf_mul(0x03, s2) ^ s3)
        r.push(s0 ^ s1 ^ _gf_mul(0x02, s2) ^ _gf_mul(0x03, s3))
        r.push(_gf_mul(0x03, s0) ^ s1 ^ s2 ^ _gf_mul(0x02, s3))

        c = c + 1
    r

fn _add_round_key(state: [u8], round_keys: [u8], round: u64) -> [u8]:
    """XOR state with the 16-byte round key for the given round."""
    var result: [u8] = rt_array_new_with_cap(16)
    val base = round * 16
    var i: u64 = 0
    while i < 16:
        result.push(_u8_at(state, i) ^ _u8_at(round_keys, base + i))
        i = i + 1
    result

# ============================================================================
# AES-128 Encryption (single block)
# ============================================================================

fn aes128_encrypt_block(plaintext: [u8], round_keys: [u8]) -> [u8]:
    """Encrypt one 16-byte block with AES-128 using the runtime helper."""
    var output: [u8] = rt_array_new_with_cap(16)
    var key: [u8] = rt_array_new_with_cap(16)
    var i: u64 = 0
    while i < 16:
        key.push(_u8_at(round_keys, i))
        output.push(0x00)
        i = i + 1
    if rt_aes128_encrypt_block_into(key, plaintext, output) != 0:
        return []
    output

# ============================================================================
# GF(2^128) Multiplication for GHASH
# ============================================================================

fn gf128_mul(x: [u8], y: [u8]) -> [u8]:
    """Multiply two 128-bit elements in GF(2^128)."""
    var z: [u8] = rt_array_new_with_cap(16)
    var i: u64 = 0
    while i < 16:
        z.push(0x00)
        i = i + 1

    var v: [u8] = rt_array_new_with_cap(16)
    i = 0
    while i < 16:
        v.push(_u8_at(y, i))
        i = i + 1

    i = 0
    while i < 128:
        val byte_idx = i / 8
        val bit_idx = 7 - (i % 8)

        if ((_u8_at(x, byte_idx) >> bit_idx) & 0x01) != 0:
            var z_next: [u8] = rt_array_new_with_cap(16)
            var j: u64 = 0
            while j < 16:
                z_next.push(_u8_at(z, j) ^ _u8_at(v, j))
                j = j + 1
            z = z_next

        val lsb = _u8_at(v, 15) & 0x01
        var v_next: [u8] = rt_array_new_with_cap(16)
        var first = (_u8_at(v, 0).to_u32() >> 1).to_u8()
        if lsb != 0:
            first = first ^ 0xE1
        v_next.push(first)
        var j: u64 = 1
        while j < 16:
            val cur = _u8_at(v, j).to_u32()
            val prev = _u8_at(v, j - 1).to_u32()
            v_next.push((((cur >> 1) | ((prev & 0x01) << 7)) & 0xFF).to_u8())
            j = j + 1
        v = v_next
        i = i + 1

    z

# ============================================================================
# GHASH
# ============================================================================

fn _ghash_block(h: [u8], y: [u8], x_block: [u8]) -> [u8]:
    """Process one 16-byte block for GHASH: Y_i = (Y_{i-1} XOR X_i) * H."""
    var xored: [u8] = rt_array_new_with_cap(16)
    var i: u64 = 0
    while i < 16:
        xored.push(_u8_at(y, i) ^ _u8_at(x_block, i))
        i = i + 1
    gf128_mul(xored, h)

fn _pad_to_16(data: [u8]) -> [u8]:
    """Pad data to a multiple of 16 bytes with zeros."""
    val padded_len = if (data.len() % 16) == 0:
        data.len()
    else:
        ((data.len() / 16) + 1) * 16
    var result: [u8] = rt_array_new_with_cap(padded_len.to_i64())
    var i: u64 = 0
    while i < data.len():
        result.push(_u8_at(data, i))
        i = i + 1
    while (result.len() % 16) != 0:
        result.push(0x00)
    result

fn _append_bytes(a: [u8], b: [u8]) -> [u8]:
    """Append two byte arrays without relying on array concatenation."""
    var out: [u8] = rt_array_new_with_cap((a.len() + b.len()).to_i64())
    var i: u64 = 0
    while i < a.len():
        out.push(_u8_at(a, i))
        i = i + 1
    i = 0
    while i < b.len():
        out.push(_u8_at(b, i))
        i = i + 1
    out

fn ghash(h: [u8], aad: [u8], ciphertext: [u8]) -> [u8]:
    """Compute GHASH for GCM."""
    var y: [u8] = rt_array_new_with_cap(16)
    var i: u64 = 0
    while i < 16:
        y.push(0x00)
        i = i + 1

    val padded_aad = _pad_to_16(aad)
    i = 0
    while i < padded_aad.len():
        var block: [u8] = rt_array_new_with_cap(16)
        var j: u64 = 0
        while j < 16:
            block.push(_u8_at(padded_aad, i + j))
            j = j + 1
        y = _ghash_block(h, y, block)
        i = i + 16

    val padded_ct = _pad_to_16(ciphertext)
    i = 0
    while i < padded_ct.len():
        var block: [u8] = rt_array_new_with_cap(16)
        var j: u64 = 0
        while j < 16:
            block.push(_u8_at(padded_ct, i + j))
            j = j + 1
        y = _ghash_block(h, y, block)
        i = i + 16

    val aad_bits: u64 = aad.len() * 8
    val ct_bits: u64 = ciphertext.len() * 8

    var len_block: [u8] = rt_array_new_with_cap(16)
    len_block.push(((aad_bits >> 56) & 0xFF).to_u8())
    len_block.push(((aad_bits >> 48) & 0xFF).to_u8())
    len_block.push(((aad_bits >> 40) & 0xFF).to_u8())
    len_block.push(((aad_bits >> 32) & 0xFF).to_u8())
    len_block.push(((aad_bits >> 24) & 0xFF).to_u8())
    len_block.push(((aad_bits >> 16) & 0xFF).to_u8())
    len_block.push(((aad_bits >> 8) & 0xFF).to_u8())
    len_block.push((aad_bits & 0xFF).to_u8())
    len_block.push(((ct_bits >> 56) & 0xFF).to_u8())
    len_block.push(((ct_bits >> 48) & 0xFF).to_u8())
    len_block.push(((ct_bits >> 40) & 0xFF).to_u8())
    len_block.push(((ct_bits >> 32) & 0xFF).to_u8())
    len_block.push(((ct_bits >> 24) & 0xFF).to_u8())
    len_block.push(((ct_bits >> 16) & 0xFF).to_u8())
    len_block.push(((ct_bits >> 8) & 0xFF).to_u8())
    len_block.push((ct_bits & 0xFF).to_u8())

    y = _ghash_block(h, y, len_block)
    y

# ============================================================================
# GCTR — AES-CTR with Incrementing Counter
# ============================================================================

fn _inc32(counter: [u8]) -> [u8]:
    """Increment the rightmost 32 bits of a 16-byte counter block."""
    val c = (_u8_at(counter, 12).to_u32() << 24) |
            (_u8_at(counter, 13).to_u32() << 16) |
            (_u8_at(counter, 14).to_u32() << 8) |
            _u8_at(counter, 15).to_u32()
    val c_inc = (c + 1) & 0xFFFFFFFF

    var result: [u8] = rt_array_new_with_cap(16)
    var i: u64 = 0
    while i < 12:
        result.push(_u8_at(counter, i))
        i = i + 1
    result.push(((c_inc >> 24) & 0xFF).to_u8())
    result.push(((c_inc >> 16) & 0xFF).to_u8())
    result.push(((c_inc >> 8) & 0xFF).to_u8())
    result.push((c_inc & 0xFF).to_u8())
    result

fn gctr(round_keys: [u8], icb: [u8], input: [u8]) -> [u8]:
    """AES-CTR mode encryption/decryption."""
    if input.len() == 0:
        return []

    var output: [u8] = rt_array_new_with_cap(input.len().to_i64())
    var cb = icb
    val num_full_blocks = input.len() / 16

    var i: u64 = 0
    while i < num_full_blocks:
        val enc_cb = aes128_encrypt_block(cb, round_keys)
        val offset = i * 16
        var j: u64 = 0
        while j < 16:
            output.push(_u8_at(input, offset + j) ^ _u8_at(enc_cb, j))
            j = j + 1
        cb = _inc32(cb)
        i = i + 1

    val remaining = input.len() % 16
    if remaining > 0:
        val enc_cb = aes128_encrypt_block(cb, round_keys)
        val offset = num_full_blocks * 16
        var j: u64 = 0
        while j < remaining:
            output.push(_u8_at(input, offset + j) ^ _u8_at(enc_cb, j))
            j = j + 1

    output

# ============================================================================
# AES-128-GCM Encryption
# ============================================================================

fn _make_j0(nonce: [u8]) -> [u8]:
    """Construct J0 (initial counter block) from 12-byte nonce."""
    var j0: [u8] = rt_array_new_with_cap(16)
    var i: u64 = 0
    while i < 12:
        j0.push(_u8_at(nonce, i))
        i = i + 1
    j0.push(0x00)
    j0.push(0x00)
    j0.push(0x00)
    j0.push(0x01)
    j0

fn aes128_gcm_encrypt(key: [u8], nonce: [u8], plaintext: [u8], aad: [u8]) -> [u8]:
    """AES-128-GCM authenticated encryption.

    Returns: ciphertext || 16-byte authentication tag (concatenated).
    The last 16 bytes of the result are the tag.
    """
    val round_keys = aes128_key_expansion(key)

    var zero_block: [u8] = rt_array_new_with_cap(16)
    var i: u64 = 0
    while i < 16:
        zero_block.push(0x00)
        i = i + 1
    val h = aes128_encrypt_block(zero_block, round_keys)

    val j0 = _make_j0(nonce)
    val icb = _inc32(j0)
    val ciphertext = gctr(round_keys, icb, plaintext)
    val s = ghash(h, aad, ciphertext)
    val tag = gctr(round_keys, j0, s)

    _append_bytes(ciphertext, tag)

# ============================================================================
# AES-128-GCM Decryption
# ============================================================================

fn aes128_gcm_decrypt(key: [u8], nonce: [u8], ciphertext: [u8], aad: [u8], tag: [u8]) -> Aes128GcmResult:
    """AES-128-GCM authenticated decryption.

    Returns: Aes128GcmResult.Ok with plaintext on success,
             Aes128GcmResult.Err on tag mismatch.
    """
    val round_keys = aes128_key_expansion(key)

    var zero_block: [u8] = rt_array_new_with_cap(16)
    var i: u64 = 0
    while i < 16:
        zero_block.push(0x00)
        i = i + 1
    val h = aes128_encrypt_block(zero_block, round_keys)

    val j0 = _make_j0(nonce)
    val s = ghash(h, aad, ciphertext)
    val expected_tag = gctr(round_keys, j0, s)

    # Constant-time tag comparison
    var diff: u8 = 0x00
    i = 0
    while i < 16:
        diff = diff | (_u8_at(expected_tag, i) ^ _u8_at(tag, i))
        i = i + 1

    if diff != 0:
        return Aes128GcmResult.Err("authentication tag mismatch")

    val icb = _inc32(j0)
    val plaintext = gctr(round_keys, icb, ciphertext)

    Aes128GcmResult.Ok(data: plaintext)
