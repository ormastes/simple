# NVFS offline integrity audit tool — N8 skeleton.
#
# Walks the full filesystem structure offline and reports structural issues:
# orphaned extents, pmap entries without backing arenas, checkpoint ring
# inconsistencies, reflink refcount mismatches, and intent-log tail anomalies.
#
# Reference tools: btrfs-check, zpool scrub.
# Design: doc/05_design/nvfs/check_tool.md
# FR-NVFS-N8-001 (skeleton) — Implemented
# FR-NVFS-N8-002 (full walker impl) — Open

use examples.nvfs.src.core.arena.{arena_readv_impl}
use examples.nvfs.src.core.checkpoint.{checkpoint_count, checkpoint_latest_valid}
use examples.nvfs.src.core.intent_log.{intent_log_len, intent_latest_seq, intent_replay_from}
use examples.nvfs.src.core.pmap.{pmap_entry_verify}
use examples.nvfs.src.core.superblock.{Superblock, superblock_replica_raw}
use examples.nvfs.src.driver.fs_driver_impl.{nvfs_pmap_sidecar_snapshot}

# ---------------------------------------------------------------------------
# Options
# ---------------------------------------------------------------------------

pub struct NvfsCheckOpts:
    """Options parsed from the CLI before dispatch.

    path            — path to the NVFS volume root or block device.
    verbose         — emit per-entry progress lines in addition to the summary.
    check_checksums — phase 1: re-verify stored checksums on every extent.
    check_refcount  — phase 4: compare reflink table refcounts against actual
                      reflink back-references in the pmap B-tree.
    """
    path:            text
    verbose:         bool
    check_checksums: bool
    check_refcount:  bool

# ---------------------------------------------------------------------------
# Report types
# ---------------------------------------------------------------------------

pub struct CheckIssue:
    """One problem entry in a CheckReport.

    severity — INFO / WARN / ERROR / FATAL (string tag).
    phase    — which check phase produced this issue (1–5).
    message  — human-readable description.
    detail   — optional structured detail (arena_id, offset, etc.) or empty.
    """
    severity: text
    phase:    i32
    message:  text
    detail:   text

pub struct CheckReport:
    """Aggregated output of nvfs_check_main.

    info_count  — total INFO-severity entries.
    warn_count  — total WARN-severity entries.
    error_count — total ERROR-severity entries.
    fatal_count — total FATAL-severity entries.
    issues      — sample problem entries (future full walker may persist all entries).
    clean       — true iff error_count == 0 and fatal_count == 0.
    """
    info_count:  u64
    warn_count:  u64
    error_count: u64
    fatal_count: u64
    issues:      [CheckIssue]
    clean:       bool

# ---------------------------------------------------------------------------
# CheckReport helpers
# ---------------------------------------------------------------------------

pub fn check_report_new() -> CheckReport:
    """Return a zero-initialised CheckReport."""
    val empty: [CheckIssue] = []
    CheckReport(
        info_count:  0,
        warn_count:  0,
        error_count: 0,
        fatal_count: 0,
        issues:      empty,
        clean:       true,
    )

pub fn check_report_add(report: CheckReport, issue: CheckIssue) -> CheckReport:
    """Append one issue and update severity counters + clean flag."""
    var r = report
    r.issues.push(issue)
    if issue.severity == "INFO":
        r.info_count = r.info_count + 1
    if issue.severity == "WARN":
        r.warn_count = r.warn_count + 1
    if issue.severity == "ERROR":
        r.error_count = r.error_count + 1
        r.clean = false
    if issue.severity == "FATAL":
        r.fatal_count = r.fatal_count + 1
        r.clean = false
    r

pub fn check_report_pretty(report: CheckReport) -> text:
    """Return a JSON-like structured summary string for the report.

    Format (one block per severity tier, counts, then sample issues):
      { "clean": true/false, "info": N, "warn": N, "error": N, "fatal": N,
        "issues": [ { "severity": "...", "phase": N, "message": "..." }, ... ] }
    """
    var out = "{ "
    if report.clean:
        out = out + "\"clean\": true, "
    else:
        out = out + "\"clean\": false, "
    out = out + "\"info\": "
    out = out + (report.info_count as text)
    out = out + ", \"warn\": "
    out = out + (report.warn_count as text)
    out = out + ", \"error\": "
    out = out + (report.error_count as text)
    out = out + ", \"fatal\": "
    out = out + (report.fatal_count as text)
    out = out + ", \"issues\": ["
    var idx = 0
    while idx < report.issues.len():
        val iss = report.issues[idx]
        if idx > 0:
            out = out + ", "
        out = out + "{ \"severity\": \""
        out = out + iss.severity
        out = out + "\", \"phase\": "
        out = out + (iss.phase as text)
        out = out + ", \"message\": \""
        out = out + iss.message
        out = out + "\" }"
        idx = idx + 1
    out = out + "] }"
    out

fn _check_report_print_latest(report: CheckReport, phase_label: text):
    """Emit the newest issue as a compact verbose progress line."""
    if report.issues.len() == 0:
        print "[nvfs-check] {phase_label}: no issues recorded"
        return
    val issue = report.issues[report.issues.len() - 1]
    print "[nvfs-check] {phase_label}: {issue.severity} {issue.message} ({issue.detail})"

fn _superblock_crc(sb: Superblock) -> u32:
    """Recompute the current in-memory superblock checksum substitute."""
    val h0 = sb.magic + sb.version
    val h1 = (sb.uuid_hi + sb.uuid_lo) % 0xFFFFFFFF
    val h2 = (sb.feature_bits + sb.mount_generation + sb.checkpoint_root) % 0xFFFFFFFF
    ((h0 + h1 + h2) % 0xFFFFFFFF) as u32

fn _superblock_magic_version_ok(sb: Superblock) -> bool:
    """Return true for NVFS magic and supported in-memory format versions."""
    if sb.magic != 0x4E564653:
        return false
    sb.version == 1 or sb.version == 2 or sb.version == 3

# ---------------------------------------------------------------------------
# Check phases — each returns an updated CheckReport
# ---------------------------------------------------------------------------

fn _check_phase1_superblock(opts: NvfsCheckOpts, report: CheckReport) -> CheckReport:
    """Phase 1: walk superblock replicas.

    For each of the N superblock replicas:
      - Re-read raw bytes from the device at the replica's fixed offset.
      - Verify the stored CRC32C (or Blake3) checksum matches recomputed value.
      - Check magic bytes == b"NVFS0002" (or b"NVFS0003" for v3 volumes).
      - Confirm generation counters are monotonically non-decreasing across replicas.
      - Flag any replica whose generation lags the most-recent by > 1 (WARN) or
        whose checksum is wrong (ERROR).

    Current implementation audits the two in-memory replica slots exposed by
    superblock_replica_raw. Raw block-device offsets and third-replica probing
    remain deferred because the current NVFS core has no disk I/O reader API.
    """
    var r = report
    var seen = 0
    var good = 0
    var newest: u64 = 0
    var replica = 0
    while replica < 2:
        val sb = superblock_replica_raw(replica as u8)
        if sb.valid:
            seen = seen + 1
            if not _superblock_magic_version_ok(sb):
                r = check_report_add(r, CheckIssue(
                    severity: "ERROR",
                    phase:    1,
                    message:  "superblock replica has invalid magic or version",
                    detail:   "replica={replica}",
                ))
            else:
                val expected = _superblock_crc(sb)
                if expected != sb.checksum:
                    r = check_report_add(r, CheckIssue(
                        severity: "ERROR",
                        phase:    1,
                        message:  "superblock replica checksum mismatch",
                        detail:   "replica={replica}",
                    ))
                else:
                    good = good + 1
                    if sb.mount_generation > newest:
                        newest = sb.mount_generation
        replica = replica + 1

    if seen == 0:
        return check_report_add(r, CheckIssue(
            severity: "INFO",
            phase:    1,
            message:  "phase1: no initialized superblock replicas in current NVFS state",
            detail:   opts.path,
        ))
    if good == 0:
        return check_report_add(r, CheckIssue(
            severity: "FATAL",
            phase:    1,
            message:  "no valid superblock replica remains mountable",
            detail:   opts.path,
        ))

    replica = 0
    while replica < 2:
        val lag_sb = superblock_replica_raw(replica as u8)
        if lag_sb.valid and _superblock_magic_version_ok(lag_sb) and _superblock_crc(lag_sb) == lag_sb.checksum:
            if newest > lag_sb.mount_generation + 1:
                r = check_report_add(r, CheckIssue(
                    severity: "WARN",
                    phase:    1,
                    message:  "superblock replica generation lags newest replica by more than one",
                    detail:   "replica={replica}",
                ))
        replica = replica + 1
    r

fn _check_phase2_checkpoint_ring(opts: NvfsCheckOpts, report: CheckReport) -> CheckReport:
    """Phase 2: walk the checkpoint ring.

    Walk every slot in the on-disk checkpoint ring (checkpoint.spl):
      - Verify each slot's CRC32C.
      - Confirm generation numbers are gapless and monotonically increasing.
      - Detect wrap-around anomalies: newest_gen > oldest_gen + ring_capacity.
      - Cross-check: the generation in the checkpoint slot matches the
        superblock's last_checkpoint_gen field.
      - Flag slots that reference arena_ids outside the live arena table (ERROR).

    Current implementation checks the exported latest-valid/count view. Full
    slot-by-slot CRC and arena-list validation is deferred until checkpoint.spl
    exposes a ring snapshot API.
    """
    val count = checkpoint_count()
    if count == 0:
        return check_report_add(report, CheckIssue(
            severity: "INFO",
            phase:    2,
            message:  "phase2: no checkpoint entries in current NVFS state",
            detail:   opts.path,
        ))
    val latest = checkpoint_latest_valid()
    if latest.checkpoint_generation == 0:
        return check_report_add(report, CheckIssue(
            severity: "ERROR",
            phase:    2,
            message:  "checkpoint ring contains entries but no valid latest checkpoint",
            detail:   "count={count}",
        ))
    check_report_add(report, CheckIssue(
        severity: "INFO",
        phase:    2,
        message:  "phase2: latest checkpoint view is valid; full ring scan deferred",
        detail:   "count={count}",
    ))

fn _check_phase3_pmap_btree(opts: NvfsCheckOpts, report: CheckReport) -> CheckReport:
    """Phase 3: walk the pmap B-tree.

    For every PmapEntry in the B-tree (pmap_btree.spl):
      - Confirm the (arena_id, offset) key is within a live arena's byte range.
      - If opts.check_checksums: re-read the extent bytes from the arena and
        verify the stored checksum (same logic as N4a scrub_all, but offline).
      - Detect orphaned extents: arena_id in pmap but arena_id absent from the
        arena table → ERROR "orphaned pmap extent".
      - Detect unreachable pmap entries: logical_page_no not reachable from any
        inode tree → WARN "unreachable pmap entry".

    Current implementation snapshots the live pmap sidecar, verifies each
    backing arena range exists, checks key/entry consistency, and optionally
    re-verifies stored checksums. Inode reachability remains deferred because
    no namespace snapshot API is exposed to this tool.
    """
    var r = report
    val entries = nvfs_pmap_sidecar_snapshot()
    if entries.len() == 0:
        return check_report_add(r, CheckIssue(
            severity: "INFO",
            phase:    3,
            message:  "phase3: no pmap entries in current NVFS state",
            detail:   opts.path,
        ))

    var i = 0
    while i < entries.len() as i64:
        val sc = entries[i]
        if sc.length <= 0:
            r = check_report_add(r, CheckIssue(
                severity: "ERROR",
                phase:    3,
                message:  "pmap entry has non-positive extent length",
                detail:   "arena_id={sc.arena_id} offset={sc.offset}",
            ))
        else:
            if sc.entry.phys != sc.arena_id or sc.entry.offset != sc.offset as u64:
                r = check_report_add(r, CheckIssue(
                    severity: "ERROR",
                    phase:    3,
                    message:  "pmap key does not match embedded entry address",
                    detail:   "arena_id={sc.arena_id} offset={sc.offset}",
                ))
            val data = arena_readv_impl(sc.arena_id, sc.offset, sc.length)
            if data.len() == 0:
                r = check_report_add(r, CheckIssue(
                    severity: "ERROR",
                    phase:    3,
                    message:  "orphaned pmap extent",
                    detail:   "arena_id={sc.arena_id} offset={sc.offset}",
                ))
            else:
                if data.len() < sc.length:
                    r = check_report_add(r, CheckIssue(
                        severity: "ERROR",
                        phase:    3,
                        message:  "pmap extent extends past backing arena data",
                        detail:   "arena_id={sc.arena_id} offset={sc.offset}",
                    ))
                if opts.check_checksums and not pmap_entry_verify(sc.entry, data):
                    r = check_report_add(r, CheckIssue(
                        severity: "ERROR",
                        phase:    3,
                        message:  "pmap extent checksum mismatch",
                        detail:   "arena_id={sc.arena_id} offset={sc.offset}",
                    ))
        i = i + 1
    r

fn _check_phase4_reflink_refcount(opts: NvfsCheckOpts, report: CheckReport) -> CheckReport:
    """Phase 4: walk the reflink refcount table.

    Only runs when opts.check_refcount is true.
    For every entry in the reflink table (reflink.spl):
      - Count actual back-references in the pmap B-tree that share the same
        logical_page_no.
      - Compare against the stored refcount field.
      - Mismatch by 1 → WARN "refcount off-by-one".
      - Mismatch by > 1 → ERROR "refcount mismatch: stored N actual M".
      - Stored refcount == 0 but entry not freed → WARN "dangling reflink entry".

    Deferred: reflink.spl currently exposes arena_id lookup only, not a
    reflink table snapshot keyed by logical page. The checker reports that
    limitation instead of guessing from pmap extent counts.
    """
    check_report_add(report, CheckIssue(
        severity: "INFO",
        phase:    4,
        message:  "phase4: reflink logical refcount audit deferred; no table snapshot API",
        detail:   opts.path,
    ))

fn _check_phase5_intent_log(opts: NvfsCheckOpts, report: CheckReport) -> CheckReport:
    """Phase 5: walk the intent-log tail.

    Walk WAL/intent-log records from the tail pointer back to the last
    checkpointed LSN (intent_log.spl):
      - Verify each record's CRC32C.
      - Confirm LSNs are monotonically increasing within the tail window.
      - Flag records referencing arena_ids that do not exist in the live
        arena table → ERROR "intent-log references unknown arena".
      - Flag records that appear to have already been replayed (LSN <=
        checkpoint_lsn from the most-recent checkpoint) → WARN "replayed
        record in intent-log tail".

    Current implementation validates the exported log length/latest sequence
    view and reports replayable tail size. Per-record CRC and arena-reference
    checks remain deferred until intent_log.spl exposes a record iterator.
    """
    val log_len = intent_log_len()
    val latest_seq = intent_latest_seq()
    if log_len == 0:
        return check_report_add(report, CheckIssue(
            severity: "INFO",
            phase:    5,
            message:  "phase5: no intent-log records in current NVFS state",
            detail:   opts.path,
        ))
    if latest_seq == 0:
        return check_report_add(report, CheckIssue(
            severity: "ERROR",
            phase:    5,
            message:  "intent-log has records but latest sequence is zero",
            detail:   "records={log_len}",
        ))
    val cp = checkpoint_latest_valid()
    val replayable = intent_replay_from(cp.checkpoint_generation as i64)
    check_report_add(report, CheckIssue(
        severity: "INFO",
        phase:    5,
        message:  "phase5: intent-log sequence view is valid; record scan deferred",
        detail:   "records={log_len} latest_seq={latest_seq} replayable={replayable}",
    ))

# ---------------------------------------------------------------------------
# Main dispatcher
# ---------------------------------------------------------------------------

pub fn nvfs_check_main(opts: NvfsCheckOpts) -> i32:
    """Run all enabled check phases and return an exit code.

    Exit codes:
      0 — clean (no warnings, no errors)
      1 — warnings found, no errors
      2 — errors found (but volume is still mountable)
      3 — fatal structural corruption (do not mount)

    Phases are run in order 1–5.  Each phase updates the report.
    verbose output is emitted after each phase when opts.verbose is true.
    """
    var report = check_report_new()

    report = _check_phase1_superblock(opts, report)
    if opts.verbose:
        _check_report_print_latest(report, "phase1")

    report = _check_phase2_checkpoint_ring(opts, report)
    if opts.verbose:
        _check_report_print_latest(report, "phase2")

    report = _check_phase3_pmap_btree(opts, report)
    if opts.verbose:
        _check_report_print_latest(report, "phase3")

    if opts.check_refcount:
        report = _check_phase4_reflink_refcount(opts, report)
        if opts.verbose:
            _check_report_print_latest(report, "phase4")

    report = _check_phase5_intent_log(opts, report)
    if opts.verbose:
        _check_report_print_latest(report, "phase5")

    # Determine exit code from severity counts.
    if report.fatal_count > 0:
        return 3
    if report.error_count > 0:
        return 2
    if report.warn_count > 0:
        return 1
    0
