# POSIX-over-NVFS shim — submodule root.
#
# Re-exports the concrete types that main-repo code needs:
#   NvfsPosixDriver — FsDriver impl for POSIX semantics over arena storage.
#   FdTable         — per-driver fd table.
#   CowShadow       — CoW staging record used for random writes.
#
# Capability set: PosixCompat | CaseSensitive | Hardlinks | SparseFiles |
#                 LargeFiles  | UnicodeNames  | AsyncIo.
# Deliberately omitted: COW, Snapshot, Dedup, Checksum, Reflink — the shim
# hides those arena-level features behind POSIX semantics.
#
# Phase 9 B2 — doc/05_design/nvfs_posix_wrapper.md.

use examples.nvfs.src.posix.fd_table.{FdEntry, FdTable}
use examples.nvfs.src.posix.cow_engine.{CowShadow}
use examples.nvfs.src.posix.capabilities.{nvfs_posix_capabilities}
use examples.nvfs.src.posix.fs_driver_impl.{NvfsPosixDriver}
