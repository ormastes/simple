# FdTable — per-driver file descriptor table for the POSIX-over-NVFS shim.
#
# Each entry tracks:
#   arena_id  — the underlying arena_* id backing this fd.
#   refcount  — number of user fds sharing this slot (inc on dup, dec on close).
#   dead      — true if the pathname was unlinked; arena is discarded when
#               refcount reaches zero.
#   offset    — current file position (i64, POSIX semantics).
#   mode      — bitmask: bit 0 = O_APPEND, bit 1 = O_NONBLOCK, bit 2 = O_RDWR,
#               bit 3 = O_WRONLY. (Low bits mirror OpenFlags.bits.)
#
# Free slots are tracked in a stack so fd numbers stay dense; `open()` reuses
# the lowest-index free slot if available, otherwise appends.
#
# Phase 9 B2 — doc/05_design/nvfs_posix_wrapper.md §5.

use std.fs_driver.error.{FsError}

struct FdEntry:
    """Per-fd state tracked by the POSIX shim.

    An fd slot may be live (refcount > 0) and either alive (dead=false)
    or tombstoned (dead=true, discarded on final close).
    """
    arena_id: i64
    refcount: u32
    dead:     bool
    offset:   i64
    mode:     u32

struct FdTable:
    """Dense fd allocator keyed by u32 index.

    entries[0] is reserved as a sentinel ("null fd"); real fds start at 1.
    """
    entries:    [FdEntry]
    free_slots: [u32]

impl FdTable:

    static fn new() -> FdTable:
        """Create an empty fd table (with index 0 reserved as sentinel)."""
        val sentinel = FdEntry {
            arena_id: -1,
            refcount: 0,
            dead:     false,
            offset:   0,
            mode:     0
        }
        FdTable { entries: [sentinel], free_slots: [] }

    me fn open(arena_id: i64, mode: u32) -> u32:
        """Allocate a fresh fd slot for arena_id with the given mode flags.

        Reuses a free slot if available; otherwise appends. Returns the fd id.
        """
        val entry = FdEntry {
            arena_id: arena_id,
            refcount: 1,
            dead:     false,
            offset:   0,
            mode:     mode
        }
        if self.free_slots.len() as i64 > 0:
            val last = self.free_slots.len() as i64 - 1
            val idx = self.free_slots[last]
            var new_free: [u32] = []
            var i = 0
            while i < last:
                new_free.push(self.free_slots[i])
                i = i + 1
            self.free_slots = new_free
            self.entries[idx as i64] = entry
            return idx
        val idx = self.entries.len() as u32
        self.entries.push(entry)
        idx

    fn lookup(fd: u32) -> Option<FdEntry>:
        """Return the entry for fd, or None if out-of-range/uninitialized."""
        if fd == 0:
            return None
        val idx = fd as i64
        if idx >= self.entries.len() as i64:
            return None
        val e = self.entries[idx]
        if e.refcount == 0:
            return None
        Some(e)

    fn refcount(fd: u32) -> u32:
        """Return the refcount of fd, or 0 if absent."""
        match self.lookup(fd):
            case Some(e): e.refcount
            case None:    0

    me fn dup(fd: u32) -> Result<u32, FsError>:
        """Increment refcount; return the same fd id (shared slot)."""
        val idx = fd as i64
        if fd == 0 or idx >= self.entries.len() as i64:
            return Err(FsError.InvalidArg)
        val e = self.entries[idx]
        if e.refcount == 0:
            return Err(FsError.InvalidArg)
        val updated = FdEntry {
            arena_id: e.arena_id,
            refcount: e.refcount + 1,
            dead:     e.dead,
            offset:   e.offset,
            mode:     e.mode
        }
        self.entries[idx] = updated
        Ok(fd)

    me fn close(fd: u32) -> Result<(), FsError>:
        """Decrement refcount; if it reaches 0, free the slot.

        Caller is responsible for arena_discard when the slot was dead and
        refcount just reached zero — use `mark_dead` + `refcount` to detect.
        """
        val idx = fd as i64
        if fd == 0 or idx >= self.entries.len() as i64:
            return Err(FsError.InvalidArg)
        val e = self.entries[idx]
        if e.refcount == 0:
            return Err(FsError.InvalidArg)
        val new_rc = e.refcount - 1
        val updated = FdEntry {
            arena_id: e.arena_id,
            refcount: new_rc,
            dead:     e.dead,
            offset:   e.offset,
            mode:     e.mode
        }
        self.entries[idx] = updated
        if new_rc == 0:
            self.free_slots.push(fd)
        Ok(())

    me fn mark_dead(fd: u32):
        """Tombstone fd — final close will discard the arena."""
        val idx = fd as i64
        if fd == 0 or idx >= self.entries.len() as i64:
            return
        val e = self.entries[idx]
        val updated = FdEntry {
            arena_id: e.arena_id,
            refcount: e.refcount,
            dead:     true,
            offset:   e.offset,
            mode:     e.mode
        }
        self.entries[idx] = updated
