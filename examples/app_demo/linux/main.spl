# Dungeon Crawl — Linux Desktop Entry Point
#
# Desktop startup using the App Interface Library.
# Usage: bin/simple run examples/app_demo/linux/main.spl

use nogc_sync_mut.src.app.config.{AppConfig}
use nogc_sync_mut.src.app.runner.{run_app}
use nogc_sync_mut.src.app.startup.{desktop_start}
use ..shared.game.{DungeonGame}

# ============================================================================
# Linux Desktop Main
# ============================================================================

fn main() -> i32:
    print("[Linux] Starting Dungeon Crawl via desktop_start()...")
    print("")

    var game = DungeonGame.create()

    # Use the App Interface Library's standard lifecycle
    val config = AppConfig.from_env("dungeon-crawl", "1.0.0")

    val init_result = game.init(config)
    if init_result.is_err():
        val err = init_result.unwrap_err()
        print("Init failed: {err}")
        return 1

    var running = true
    while running:
        running = game.update()

    game.shutdown()
    0

# Run the game
val exit_code = main()
