# Dungeon Crawl — Android Entry Point
#
# Android startup using the App Interface Library.
# In production, this would be called from bridges/android/SimpleActivity.java
# via JNI → jni_bridge.c → simple_app_main() → this code.
#
# For interpreter testing: bin/simple run examples/app_demo/android/main.spl

use nogc_sync_mut.src.app.config.{AppConfig}
use nogc_sync_mut.src.app.startup.{mobile_start}
use ..shared.game.{DungeonGame}

# ============================================================================
# Android Main
# ============================================================================

fn main() -> i32:
    print("[Android] Starting Dungeon Crawl via mobile_start()...")
    print("[Android] In production: SimpleActivity.onCreate → JNI → app_main()")
    print("")

    var game = DungeonGame.create()

    # Simulate Android launch — on real device, args come from Intent extras
    val config = AppConfig.create(
        name: "dungeon-crawl",
        version: "1.0.0",
        args: [],
        platform: "android",
        arch: "aarch64"
    )

    val init_result = game.init(config)
    if init_result.is_err():
        val err = init_result.unwrap_err()
        print("Init failed: {err}")
        return 1

    var running = true
    while running:
        running = game.update()

    game.shutdown()
    0

# Run the game
val exit_code = main()
