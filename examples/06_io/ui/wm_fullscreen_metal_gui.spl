# wm_fullscreen_metal_gui.spl — Windowed <-> fullscreen WM demo on the Metal GPU
# lane in a real on-screen winit window, with NATIVE-RESOLUTION fullscreen render.
#
# Proves the macOS host Simple WM app supports BOTH windowed and fullscreen modes
# with genuine GPU render evidence AND correct fullscreen re-layout:
#   - opens a real window (windowed), renders >=2 Metal GPU frames
#     (gpu_frame_complete=true), logs `[wm-fullscreen] mode=windowed size=WxH`.
#   - calls set_fullscreen(true), verifies is_fullscreen() and that the window
#     inner size grew (read back from the real winit API, not assumed), logs
#     `[wm-fullscreen] mode=fullscreen size=WxH`.
#   - reads the REAL fullscreen dims and creates a SECOND Metal backend at native
#     resolution (once), then re-evaluates every element's x/y/w/h + text size and
#     re-renders the scene at native res in TWO modes:
#       * fit: aspect-preserving scale = min(SW/W, SH/H), content centered,
#         letterbox bars filled with the background color.
#       * no-resize: content at its ORIGINAL element sizes anchored top-left,
#         background color extended across the remaining screen.
#     Presents each mode 1:1 (no upscaling → crisp pixels, no blocky bits), logs
#     `[wm-fullscreen] scale_mode=fit screen=SWxSH content=CWxCH offset=OXxOY`
#     and the no-resize equivalent.
#   - returns to windowed, verifies is_fullscreen()==false, logs
#     `[wm-fullscreen] restored=true`, exits 0.
#
# Mode order is selected via SIMPLE_WM_FS_SCALE_MODE ("fit" | "no-resize",
# default "fit"); BOTH modes always run so a gate can check both.
#
# Launch (real window, macOS):
#   SIMPLE_GUI_RUN_SKIP_NUDGE=1 scripts/gui/macos-gui-run.shs \
#     examples/06_io/ui/wm_fullscreen_metal_gui.spl
# Driven end-to-end by:
#   scripts/check/check-macos-wm-fullscreen-metal-evidence.shs

use std.gpu.engine2d.backend_metal.{MetalBackend}
use std.io.window_winit.{WinitLoop, WinitWindow, WinitInput, winit_loop_new, winit_loop_free, winit_window_new, winit_window_free, winit_present_rgba, winit_poll_input, winit_window_set_fullscreen, winit_window_is_fullscreen, winit_window_get_size}

use std.io_runtime.{env_get}

extern fn rt_time_now_unix_micros() -> i64

val W: i32 = 320
val H: i32 = 200

fn pack(src: [u32]) -> [i64]:
    var out: [i64] = [0; src.len()]
    var i = 0
    while i < src.len():
        out[i] = src[i].to_i64() & 0xFFFFFF
        i = i + 1
    out

# Scale a coordinate/size by a float factor, rounding to the nearest pixel.
fn sc(v: i32, scale: f64) -> i32:
    (v.to_f64() * scale).to_i32()

# Scale a font size, never below 1px.
fn sc_font(v: i32, scale: f64) -> i32:
    var f = (v.to_f64() * scale).to_i32()
    if f < 1:
        f = 1
    f

# Draw the demo scene into `b`, offset by (ox, oy) and scaled by `scale`.
# `b.clear` fills the WHOLE backend with the background color first, so both the
# fit letterbox bars and the no-resize extended background are covered for free.
fn draw_scene_scaled(b: MetalBackend, ox: i32, oy: i32, scale: f64, label: text):
    b.clear(0xFF14141Cu32)
    b.draw_rect_filled(ox + sc(24, scale), oy + sc(24, scale), sc(W - 48, scale), sc(60, scale), 0xFF2D6CDFu32)
    b.draw_text(ox + sc(40, scale), oy + sc(44, scale), "WM FULLSCREEN DEMO", 0xFFFFFFFFu32, sc_font(8, scale))
    b.draw_text(ox + sc(40, scale), oy + sc(110, scale), label, 0xFFB0C4DEu32, sc_font(6, scale))
    # Frame-progress bar, fixed near-full for the still fullscreen image.
    val bar_max_w = W - 80
    var bar_w = 180 + 4 * 16
    if bar_w > bar_max_w:
        bar_w = bar_max_w
    b.draw_rect_filled(ox + sc(40, scale), oy + sc(148, scale), sc(bar_w, scale), sc(24, scale), 0xFFE5533Du32)
    b.draw_rect(ox + sc(20, scale), oy + sc(20, scale), sc(W - 40, scale), sc(H - 40, scale), 0xFF00E5FFu32)
    b.present()

# Render one Metal GPU frame into the windowed backend `b`, present it to the
# window (the runtime upscales when the window is larger than the render buffer),
# and report GPU completeness read back from the backend.
fn render_and_present(b: MetalBackend, win: WinitWindow, phase: text, frame: i32) -> bool:
    draw_scene_scaled(b, 0, 0, 1.0, phase)

    val frame_complete = b.gpu_frame_complete
    val pixels = b.read_pixels_gpu_only()
    if not frame_complete:
        print "frame {frame} phase={phase} FAIL gpu_frame_complete=false (software mirror fallback)"
        return false
    if pixels.len() < W * H:
        print "frame {frame} phase={phase} FAIL GPU readback short ({pixels.len()} of {W * H})"
        return false

    val packed = pack(pixels)
    winit_present_rgba(win, W.to_i64(), H.to_i64(), packed)
    print "frame {frame} phase={phase} gpu_frame_complete=true pixels={pixels.len()}"
    return true

# Read back the native-resolution backend `nb` and present it 1:1 to the window
# (no upscaling → crisp). This is the ONLY full readback+pack+present per mode.
fn present_native(nb: MetalBackend, win: WinitWindow, sw: i64, sh: i64, phase: text) -> bool:
    val frame_complete = nb.gpu_frame_complete
    val pixels = nb.read_pixels_gpu_only()
    if not frame_complete:
        print "frame native phase={phase} FAIL gpu_frame_complete=false (software mirror fallback)"
        return false
    val want = sw * sh
    if pixels.len() < want:
        print "frame native phase={phase} FAIL GPU readback short ({pixels.len()} of {want})"
        return false
    val packed = pack(pixels)
    winit_present_rgba(win, sw, sh, packed)
    print "frame native phase={phase} gpu_frame_complete=true pixels={pixels.len()}"
    return true

# Hold the presented frame on screen for ~`secs` seconds, pumping the event loop
# so the window stays live (and an external gate can screencapture it). Does NOT
# re-read or re-pack the framebuffer.
fn hold(lp: WinitLoop, secs: i64):
    val until = rt_time_now_unix_micros() + secs * 1000000
    while rt_time_now_unix_micros() < until:
        val poll = winit_poll_input(lp)

fn cleanup(b: MetalBackend, win: WinitWindow, lp: WinitLoop):
    b.shutdown()
    winit_window_free(win)
    winit_loop_free(lp)

# Render + present + hold one native-res fullscreen mode, emitting its marker.
# mode is "fit" or "no-resize". Returns true when the GPU frame completed.
fn run_fs_mode(nb: MetalBackend, win: WinitWindow, lp: WinitLoop, mode: text, sw: i64, sh: i64) -> bool:
    var ox: i32 = 0
    var oy: i32 = 0
    var scale = 1.0
    var cw: i64 = W.to_i64()
    var ch: i64 = H.to_i64()
    if mode == "fit":
        val scale_x = sw.to_f64() / W.to_f64()
        val scale_y = sh.to_f64() / H.to_f64()
        # min(scale_x, scale_y): whichever axis binds. Set the bound axis to the
        # exact screen extent so content=screen on that axis; letterbox the other.
        if scale_x <= scale_y:
            scale = scale_x
            cw = sw
            ch = (H.to_f64() * scale).to_i64()
        else:
            scale = scale_y
            ch = sh
            cw = (W.to_f64() * scale).to_i64()
        ox = ((sw - cw) / 2).to_i32()
        oy = ((sh - ch) / 2).to_i32()
    else:
        scale = 1.0
        cw = W.to_i64()
        ch = H.to_i64()
        ox = 0
        oy = 0

    draw_scene_scaled(nb, ox, oy, scale, "fullscreen native-res ({mode})")
    val ok = present_native(nb, win, sw, sh, "fullscreen-{mode}")
    print "[wm-fullscreen] scale_mode={mode} screen={sw}x{sh} content={cw}x{ch} offset={ox}x{oy}"
    hold(lp, 4)
    return ok

fn main() -> i64:
    print "WM Fullscreen Metal GUI — windowed <-> fullscreen, native-res fit/no-resize"

    if (env_get("SIMPLE_GUI") ?? "") != "1":
        print "[wm-fullscreen] error=no-gui-requested (launch via macos-gui-run.shs / gate)"
        return 2

    var first_mode = env_get("SIMPLE_WM_FS_SCALE_MODE") ?? "fit"
    if first_mode != "no-resize":
        first_mode = "fit"
    var second_mode = "no-resize"
    if first_mode == "no-resize":
        second_mode = "fit"
    print "[wm-fullscreen] scale_mode_order={first_mode},{second_mode}"

    val lp = winit_loop_new()
    if not lp.is_valid:
        print "[wm-fullscreen] error=no-gui-runtime"
        return 1
    val win = winit_window_new(lp, W.to_i64(), H.to_i64(), "WM Fullscreen Metal")
    if not win.is_valid:
        print "[wm-fullscreen] error=window-create-failed"
        winit_loop_free(lp)
        return 1

    var b = MetalBackend.create()
    if not b.init(W, H):
        print "[wm-fullscreen] error=metal-init-failed"
        winit_window_free(win)
        winit_loop_free(lp)
        return 1

    # ---------------------------------------------------------------------
    # Phase 1: windowed — render >=2 GPU frames.
    # ---------------------------------------------------------------------
    var ok = true
    var f = 0
    while f < 3:
        if not render_and_present(b, win, "windowed", f):
            ok = false
        val poll_win = winit_poll_input(lp)
        f = f + 1
    if not ok:
        print "[wm-fullscreen] error=windowed-gpu-frame-incomplete"
        cleanup(b, win, lp)
        return 1

    val (win_w, win_h) = winit_window_get_size(win)
    print "[wm-fullscreen] mode=windowed size={win_w}x{win_h}"

    # ---------------------------------------------------------------------
    # Phase 2: fullscreen — set, then verify from real API readback.
    # ---------------------------------------------------------------------
    val applied = winit_window_set_fullscreen(win, true)
    if not applied:
        print "[wm-fullscreen] error=set-fullscreen-failed"
        cleanup(b, win, lp)
        return 1

    # macOS fullscreen resize is asynchronous: pump + present (windowed backend,
    # upscaled — cheap) until the real window inner size reflects the transition.
    var fs_w: i64 = win_w
    var fs_h: i64 = win_h
    var settle = 0
    while settle < 60:
        val poll_settle = winit_poll_input(lp)
        val settle_frame = render_and_present(b, win, "fullscreen-settle", 0)
        val (cw2, ch2) = winit_window_get_size(win)
        fs_w = cw2
        fs_h = ch2
        if cw2 > win_w:
            settle = 1000
        else:
            settle = settle + 1

    val is_fs = winit_window_is_fullscreen(win)
    print "[wm-fullscreen] is_fullscreen={is_fs}"
    print "[wm-fullscreen] mode=fullscreen size={fs_w}x{fs_h}"

    if not is_fs:
        print "[wm-fullscreen] error=is-fullscreen-false-after-set"
        cleanup(b, win, lp)
        return 1
    if fs_w <= win_w:
        print "[wm-fullscreen] error=fullscreen-size-did-not-grow (was {win_w}, now {fs_w})"
        cleanup(b, win, lp)
        return 1

    # ---------------------------------------------------------------------
    # Phase 2b: native-resolution re-render. Create ONE backend at the real
    # fullscreen dims (creation costs ~seconds interpreted — do it once), then
    # render BOTH modes so edges stay crisp at native res (no pixel blow-up).
    # ---------------------------------------------------------------------
    var nb = MetalBackend.create()
    if not nb.init(fs_w.to_i32(), fs_h.to_i32()):
        print "[wm-fullscreen] error=metal-native-init-failed ({fs_w}x{fs_h})"
        cleanup(b, win, lp)
        return 1

    if not run_fs_mode(nb, win, lp, first_mode, fs_w, fs_h):
        ok = false
    if not run_fs_mode(nb, win, lp, second_mode, fs_w, fs_h):
        ok = false
    nb.shutdown()
    if not ok:
        print "[wm-fullscreen] error=fullscreen-gpu-frame-incomplete"
        cleanup(b, win, lp)
        return 1

    # ---------------------------------------------------------------------
    # Phase 3: restore to windowed — verify is_fullscreen() clears.
    # ---------------------------------------------------------------------
    val restored = winit_window_set_fullscreen(win, false)
    var r = 0
    while r < 4:
        val poll_restore = winit_poll_input(lp)
        val restore_frame = render_and_present(b, win, "restored", 0)
        r = r + 1

    val is_fs_after = winit_window_is_fullscreen(win)
    val (rw, rh) = winit_window_get_size(win)
    print "[wm-fullscreen] restored_size={rw}x{rh} is_fullscreen_after={is_fs_after}"

    if restored and not is_fs_after:
        print "[wm-fullscreen] restored=true"
    else:
        print "[wm-fullscreen] restored=false"
        cleanup(b, win, lp)
        return 1

    print "[wm-fullscreen] done windowed={win_w}x{win_h} fullscreen={fs_w}x{fs_h}"
    cleanup(b, win, lp)
    return 0
