# web_render_file_gui.spl — render an HTML file through the pure-Simple web
# renderer backed by Engine2D CPU SIMD and present it to a window.
#
# This is intended as a web-renderer sanity view, so prefer sample pages with
# class/id selectors; those route through the generic layout renderer instead of
# the legacy corpus heuristic path.
#
# Run (window):
#   SIMPLE_TIMEOUT_SECONDS=0 scripts/gui/macos-gui-run.shs examples/06_io/ui/web_render_file_gui.spl \
#     examples/06_io/ui/browser_common_elements_showcase.html
# Headless: drop SIMPLE_GUI / use bin/simple run.
#
# Resolution convention (shared across all showcase apps): SHOWCASE_RESOLUTION
# env var selects the render size — "4k" (default) => 3840x2160, "8k" =>
# 7680x4320, or an explicit "WIDTHxHEIGHT" (e.g. "1920x1080"). See
# `showcase_resolution_dims()` below.
#
# DPI: SHOWCASE_DPI (default 300) is read and reported, but the shared layout
# engine (simple_web_html_layout_renderer.spl) has no device-pixel-ratio /
# logical-vs-physical-viewport concept — `width`/`height` serve as both the
# raster buffer size and the CSS viewport in one unified value, so there is no
# hook to lay out at a scaled logical size while rasterizing denser without a
# naive upscale (which the DPI requirement explicitly forbids). This is a real
# engine gap, not implemented here — see
# doc/08_tracking/bug/web_render_dpi_scaling_unsupported_2026-07-12.md.

use std.gc_async_mut.gpu.browser_engine.simple_web_renderer.{
    simple_web_render_html_to_pixels_with_engine2d_backend,
    simple_web_resolved_engine2d_backend_name}
use std.io.window_winit.{WinitLoop, WinitWindow, winit_loop_new, winit_loop_free, winit_window_new, winit_window_free, winit_present_rgba, winit_poll_close_requested}
use std.nogc_sync_mut.io.time_ops.{time_now_unix_micros}

use std.io_runtime.{read_file, file_exists, env_get}

class ShowcaseDims:
    w: i32
    h: i32

# Resolve the render resolution from SHOWCASE_RESOLUTION: "4k" (or unset) =>
# 3840x2160 (DEFAULT), "8k" => 7680x4320, or an explicit "WIDTHxHEIGHT".
pub fn showcase_resolution_dims() -> ShowcaseDims:
    val raw = (env_get("SHOWCASE_RESOLUTION") ?? "").trim().lower()
    if raw == "" or raw == "4k":
        return ShowcaseDims(w: 3840, h: 2160)
    if raw == "8k":
        return ShowcaseDims(w: 7680, h: 4320)
    if raw.contains("x"):
        val parts = raw.split("x")
        if parts.len() == 2:
            val pw = parts[0].trim().to_i64()
            val ph = parts[1].trim().to_i64()
            if pw != nil and ph != nil and pw > 0 and ph > 0:
                return ShowcaseDims(w: pw.to_i32(), h: ph.to_i32())
    ShowcaseDims(w: 3840, h: 2160)

# Resolve SHOWCASE_DPI (default 300). Reported only — see the engine-gap note
# in the module header; the layout/paint engine has no DPI hook to apply it to.
pub fn showcase_dpi() -> i32:
    val raw = (env_get("SHOWCASE_DPI") ?? "").trim()
    if raw == "":
        return 300
    val n = raw.to_i64()
    if n == nil or n <= 0:
        return 300
    n.to_i32()

val SHOWCASE_DIMS: ShowcaseDims = showcase_resolution_dims()
val RW: i32 = SHOWCASE_DIMS.w
val RH: i32 = SHOWCASE_DIMS.h
val W: i32 = SHOWCASE_DIMS.w
val H: i32 = SHOWCASE_DIMS.h
val SHOWCASE_DPI_VALUE: i32 = showcase_dpi()

fn pack_pixels(src: [u32]) -> [i64]:
    var out: [i64] = [0; src.len()]
    var i = 0
    while i < src.len():
        out[i] = src[i].to_i64() & 0xFFFFFF
        i = i + 1
    out

fn showcase_checksum(pixels: [u32]) -> i64:
    var checksum: i64 = 0
    var i = 0
    while i < pixels.len():
        checksum = (checksum + (pixels[i].to_i64() & 0xFFFFFFFF) * ((i % 251) + 1)) % 2147483647
        i = i + 1
    checksum

pub fn run_web_standards_showcase(gui: bool, path: text) -> i64:
    if not file_exists(path):
        print "HTML file not found: {path}"
        return 1
    val raw_html = read_file(path)
    val resolved = simple_web_resolved_engine2d_backend_name(RW, RH, "cpu_simd")
    val pixels = simple_web_render_html_to_pixels_with_engine2d_backend(raw_html, RW, RH, "cpu_simd")
    if pixels.len() != RW * RH:
        print "web_standards_showcase status=fail reason=wrong-pixel-count expected={RW * RH} actual={pixels.len()}"
        return 2
    val checksum = showcase_checksum(pixels)
    var first = pixels[0]
    var varied = false
    var nonzero = 0
    var i = 0
    while i < pixels.len():
        if pixels[i] != first:
            varied = true
        if (pixels[i] & 0x00FFFFFFu32) != 0u32:
            nonzero = nonzero + 1
        i = i + 1
    if not varied or nonzero == 0 or checksum == 0:
        print "web_standards_showcase status=fail reason=blank-or-uniform pixels={pixels.len()} nonzero={nonzero} checksum={checksum}"
        return 3
    print "web_standards_showcase status=pass path={path} html_bytes={raw_html.len()} width={RW} height={RH} pixels={pixels.len()} nonzero={nonzero} checksum={checksum} requested=cpu_simd resolved={resolved} dpi={SHOWCASE_DPI_VALUE} dpi_scale_applied=false"

    if not gui:
        return 0

    val lp = winit_loop_new()
    if not lp.is_valid:
        print "No GUI runtime available."
        return 4
    val win = winit_window_new(lp, W.to_i64(), H.to_i64(), "Pure-Simple web renderer CPU SIMD — {path}")
    if not win.is_valid:
        print "Window creation failed."
        winit_loop_free(lp)
        return 5
    val packed = pack_pixels(pixels)
    winit_present_rgba(win, RW.to_i64(), RH.to_i64(), packed)
    # The rendered buffer is static, so present it once and then idle. Each
    # Poll continuously so AppKit retains its event handler between frames; the
    # reusable headless path never enters this loop. Re-present only periodically.
    var running = true
    var frames = 0
    val end_at = time_now_unix_micros() + 60000000
    while running and time_now_unix_micros() < end_at:
        if winit_poll_close_requested(lp):
            running = false
        if frames % 15 == 0:
            winit_present_rgba(win, RW.to_i64(), RH.to_i64(), packed)
        frames = frames + 1
    winit_window_free(win)
    winit_loop_free(lp)
    return 0

fn main() -> i64:
    run_web_standards_showcase(false, "examples/06_io/ui/browser_common_elements_showcase.html")
