# Metal Engine2D window smoke (pure-Simple Metal lane).
#
# Renders the same scene as engine2d_cpu_simd_gui.spl but through the Metal GPU
# drawing backend (clear/rect/circle/line/gradient/rounded_rect are all GPU-
# dispatched), then presents the GPU framebuffer in a real on-screen window.
#
# Launch:
#   SIMPLE_GUI_RUN_SKIP_NUDGE=1 scripts/gui/macos-gui-run.shs examples/06_io/ui/engine2d_metal_gui.spl

use std.gpu.engine2d.backend_metal.{MetalBackend}

extern fn rt_winit_event_loop_new() -> i64
extern fn rt_winit_window_new(el: i64, w: i64, h: i64, title: text) -> i64
extern fn rt_winit_window_present_rgba(win: i64, w: i64, h: i64, pixels: [i64])
extern fn rt_winit_event_loop_poll_events(el: i64, max: i64) -> i64
extern fn rt_winit_event_get_type(ev: i64) -> i64
extern fn rt_winit_event_free(ev: i64)
extern fn rt_winit_window_free(win: i64)
extern fn rt_winit_event_loop_free(el: i64)
extern fn rt_env_get(key: text) -> text

val W: i32 = 96
val H: i32 = 72
val EVT_CLOSE: i64 = 3

fn pack(src: [u32]) -> [i64]:
    var out: [i64] = [0; src.len()]
    var i = 0
    while i < src.len():
        out[i] = src[i].to_i64() & 0xFFFFFF
        i = i + 1
    out

fn build_frame() -> [u32]:
    var backend = MetalBackend.create()
    if not backend.init(W, H):
        print "Metal Engine2D backend failed to initialize"
        return []
    backend.clear(0xFF101820u32)
    backend.draw_text(6, 4, "METAL", 0xFFFFFFFFu32, 6)
    backend.draw_rect_filled(8, 8, 22, 18, 0xFFE53935u32)
    backend.draw_circle_filled(72, 18, 12, 0xFF43A047u32)
    backend.draw_line(8, 38, 88, 38, 0xFF33A1FDu32, 4)
    backend.draw_gradient_rect(8, 50, 34, 14, 0xFFFFB300u32, 0xFF6A1B9Au32)
    backend.draw_rounded_rect(56, 50, 32, 14, 4, 0xFF00ACC1u32)
    backend.present()
    val pixels = backend.read_pixels()
    backend.shutdown()
    pixels

fn main() -> i64:
    print "Metal Engine2D GUI — render {W}x{H}"
    val pixels = build_frame()
    if pixels.len() < W * H:
        return 1

    if (rt_env_get("SIMPLE_GUI") ?? "") != "1":
        print "No GUI requested (use scripts/gui/macos-gui-run.shs to open a window); headless only."
        return 0

    val el = rt_winit_event_loop_new()
    if el == 0:
        print "No GUI runtime available."
        return 1
    val win = rt_winit_window_new(el, W.to_i64(), H.to_i64(), "Metal Engine2D")
    if win == 0:
        rt_winit_event_loop_free(el)
        return 1

    val packed = pack(pixels)
    var running = true
    var iters = 0
    while running and iters < 2000000:
        rt_winit_window_present_rgba(win, W.to_i64(), H.to_i64(), packed)
        var ev = rt_winit_event_loop_poll_events(el, 1)
        while ev != 0:
            if rt_winit_event_get_type(ev) == EVT_CLOSE:
                running = false
            rt_winit_event_free(ev)
            ev = rt_winit_event_loop_poll_events(el, 1)
        iters = iters + 1
    rt_winit_window_free(win)
    rt_winit_event_loop_free(el)
    return 0
