# wm_graphics_2d_showcase_gui.spl — Simple WM host that launches the widget showcase
# from the filesystem as a separate process, using the SAME source file as the
# native showcase app.
#
# Launch:
#   SIMPLE_GUI_RUN_SKIP_NUDGE=1 scripts/gui/macos-gui-run.shs \
#     examples/06_io/ui/wm_graphics_2d_showcase_gui.spl

use std.io.window_winit.{WinitLoop, WinitWindow, WinitInput, winit_loop_new, winit_loop_free, winit_window_new, winit_window_free, winit_present_rgba, winit_wait_input}
use std.io_runtime.{env_get, file_exists, file_read, file_read_bytes, file_write, dir_create_all, getpid, time_now_unix_micros}
use std.nogc_sync_mut.concurrent.thread.{thread_sleep}
use std.common.image.ppm_decode.{decode_ppm_to_argb}
use std.common.science_math.perf_sugar.{alloc_i64}
# Direct defining-module imports, NOT the app.io.mod hub: the hub re-exports
# cli_ops -> run_commands -> compiler.driver -> hir, dragging the ENTIRE
# compiler (800+ transitive modules) into a GUI adapter and blowing the
# interpreter module-count limit before main() (host-WM lane regression,
# proven by RUST_LOG module trace 2026-07-18).
use app.io.process_ops.{process_spawn_async, process_kill}
use app.io.process_env_ops.{process_spawn_async_env}
use app.io.env_ops.{host_os, cwd}
use common.window_protocol.geometry.{Size}
use common.ui.wm_chrome_theme.{wm_chrome_theme}
use common.ui.wm_app_process_contract.{GRAPHICS_2D_SHOWCASE_APP_SOURCE, GRAPHICS_2D_SHOWCASE_TITLE, WM_EVENT_FILE_ENV, WM_FRAME_SEQ_FILE_ENV, wm_fs_bridge_decode, wm_graphics_2d_showcase_client_env, wm_graphics_2d_showcase_event_path, wm_graphics_2d_showcase_frame_seq_path, wm_fs_app_event, wm_fs_app_event_encode, wm_fs_app_event_seq_path}
use os.compositor.host_compositor_entry.{HostCompositor, HeadlessHostCompositorBackend, host_compositor_pointer_move, host_compositor_left_button_at, host_taskbar_dock_width, host_taskbar_item_width, host_taskbar_item_x}
use os.userlib.ipc_protocol.{COMP_CREATE_WINDOW}

val W: i32 = 808
val H: i32 = 632
val LOCATOR: u32 = 0xFFFF00FFu32
val MUTED: u32 = 0xFF94A3B8u32

struct WmLoopState:
    comp: HostCompositor
    mouse_x: i32
    mouse_y: i32
    child_pointer_down: bool
    child_drag_forwarding: bool
    child_event_seq: i64
    child_refresh_pending: bool
    child_refresh_deadline: i64
    dirty: bool
    running: bool

struct ChildFrame:
    ok: bool
    pixels: [u32]
    w: i32
    h: i32
    reason: text

struct ChildLocalHit:
    ok: bool
    x: i32
    y: i32

fn argb(color: u32) -> i64:
    color.to_i64()

fn rgb(color: u32) -> i64:
    color.to_i64() & 0xFFFFFF

fn sleep_ms(ms: i64):
    thread_sleep(ms)

fn read_frame_seq(seq_path: text) -> i64:
    if seq_path == "" or not file_exists(seq_path):
        return 0
    file_read(seq_path).trim().to_i64() ?? 0

fn write_wm_trace(trace_path: text, phase: text):
    if trace_path != "":
        file_write(trace_path, "phase={phase}\n")

fn should_close(input: WinitInput) -> bool:
    if input.close:
        return true
    for k in input.keys:
        if k == 27 or k == 113 or k == 81:
            return true
    false

fn wait_for_bridge(path: text, timeout_ms: i64) -> text:
    val deadline = time_now_unix_micros() + timeout_ms * 1000
    while time_now_unix_micros() < deadline:
        if file_exists(path):
            val body = file_read(path)
            if body.contains("kind=create_window"):
                return body
        sleep_ms(50)
    ""

fn path_join(root: text, rel: text) -> text:
    if root.ends_with("/") or root.ends_with("\\"):
        return root + rel
    root + "/" + rel

fn resolve_repo_root() -> text:
    val explicit = env_get("SIMPLE_REPO_ROOT") ?? ""
    if explicit != "":
        return explicit
    val lib = env_get("SIMPLE_LIB") ?? ""
    if lib.ends_with("/src") or lib.ends_with("\\src"):
        return lib.substring(0, lib.len() - 4)
    val here = cwd()
    if here != "":
        return here
    "."

fn fill_rect_pixels(pixels: [u32], x: i32, y: i32, w: i32, h: i32, color: u32) -> [u32]:
    var out = pixels
    var yy = 0
    while yy < h:
        val dy = y + yy
        if dy >= 0 and dy < H:
            var xx = 0
            while xx < w:
                val dx = x + xx
                if dx >= 0 and dx < W:
                    out[dy * W + dx] = color
                xx = xx + 1
        yy = yy + 1
    out

fn draw_taskbar_pixels(pixels: [u32], comp: HostCompositor) -> [u32]:
    var out = pixels
    val theme = wm_chrome_theme()
    val count = comp.windows.len().to_i32()
    if count <= 0:
        return out
    val dock_w = host_taskbar_dock_width(W, count)
    val dock_x = (W - dock_w) / 2
    val dock_y = H - 62
    out = fill_rect_pixels(out, dock_x, dock_y, dock_w, 44, theme.taskbar)
    val item_w = host_taskbar_item_width(W, count)
    var i = 0
    while i < count:
        val win = comp.windows[i]
        val ix = host_taskbar_item_x(W, count, i)
        var color = theme.title_unfocused
        if win.focused and not win.minimized:
            color = theme.accent
        elif win.minimized:
            color = theme.host_window_body
        out = fill_rect_pixels(out, ix + 2, dock_y + 6, item_w - 4, 32, theme.command_lane)
        out = fill_rect_pixels(out, ix + 4, dock_y + 8, item_w - 8, 28, color)
        out = fill_rect_pixels(out, ix + 12, dock_y + 14, 12, 12, theme.text_primary)
        if win.focused and not win.minimized:
            out = fill_rect_pixels(out, ix + 8, dock_y + 35, item_w - 16, 2, theme.text_primary)
        i = i + 1
    out

fn compose_pixels(comp: HostCompositor, trace_path: text) -> [u32]:
    write_wm_trace(trace_path, "compose_theme_start")
    val theme = wm_chrome_theme()
    write_wm_trace(trace_path, "compose_alloc_start")
    val pixel_count = W * H
    var out: [u32] = [0u32 for fill_idx in 0..pixel_count]
    write_wm_trace(trace_path, "compose_bg_start")
    out = fill_rect_pixels(out, 0, 0, W, H, theme.compositor_bg)
    write_wm_trace(trace_path, "compose_windows_start")
    out = fill_rect_pixels(out, 0, 0, W, 38, theme.command_lane)
    var i = 0
    while i < comp.windows.len():
        val win = comp.windows[i]
        if not win.minimized:
            out = fill_rect_pixels(out, win.x + 7, win.y + 7, win.w, win.h, theme.window_shadow)
            out = fill_rect_pixels(out, win.x, win.y, win.w, win.h, theme.host_window_body)
            val title_color = if win.focused: theme.accent else: theme.title_unfocused
            out = fill_rect_pixels(out, win.x, win.y, win.w, 24, title_color)
            out = fill_rect_pixels(out, win.x + win.w - 24, win.y, 24, 24, theme.close_button)
            out = fill_rect_pixels(out, win.x + win.w - 17, win.y + 7, 10, 10, theme.text_primary)
            out = fill_rect_pixels(out, win.x + 4, win.y + 28, win.w - 8, win.h - 32, theme.compositor_bg)
        i = i + 1
    write_wm_trace(trace_path, "compose_taskbar_start")
    out = draw_taskbar_pixels(out, comp)
    write_wm_trace(trace_path, "compose_locator_start")
    out = fill_rect_pixels(out, 0, 0, W, 3, LOCATOR)
    out = fill_rect_pixels(out, 0, H - 3, W, 3, LOCATOR)
    out = fill_rect_pixels(out, 0, 0, 3, H, LOCATOR)
    out = fill_rect_pixels(out, W - 3, 0, 3, H, LOCATOR)
    out

fn load_child_frame(frame_path: text) -> ChildFrame:
    if frame_path == "" or not file_exists(frame_path):
        return ChildFrame(ok: false, pixels: [], w: 0, h: 0, reason: "missing")
    var ok = false
    var pixels: [u32] = []
    var frame_w = 0
    var frame_h = 0
    var reason = ""
    val bytes = file_read_bytes(frame_path)
    if bytes.len() == 0:
        reason = "empty"
    else:
        val decoded = decode_ppm_to_argb(bytes)
        match decoded:
            Ok(img):
                if img.pixels.len() > 0 and img.width > 0 and img.height > 0:
                    ok = true
                    pixels = img.pixels
                    frame_w = img.width
                    frame_h = img.height
                else:
                    reason = "decoded-empty"
            Err(msg):
                reason = msg
    if not ok and reason == "":
        reason = "decode-no-result"
    ChildFrame(ok: ok, pixels: pixels, w: frame_w, h: frame_h, reason: reason)

fn blit_child_frame_pixels(base_pixels: [u32], comp: HostCompositor, child_pixels: [u32], child_w: i32, child_h: i32) -> [u32]:
    var out = base_pixels
    var i = 0
    while i < comp.windows.len():
        val win = comp.windows[i]
        if not win.minimized:
            val cx = win.x + 4
            val cy = win.y + 28
            var y = 0
            while y < child_h:
                val dy = cy + y
                if dy >= 0 and dy < H:
                    var x = 0
                    while x < child_w:
                        val dx = cx + x
                        val sidx = y * child_w + x
                        val didx = dy * W + dx
                        if dx >= 0 and dx < W and sidx >= 0 and sidx < child_pixels.len() and didx >= 0 and didx < out.len():
                            out[didx] = child_pixels[sidx]
                        x = x + 1
                y = y + 1
        i = i + 1
    out

fn pack_pixels(pixels: [u32]) -> [i64]:
    var packed = alloc_i64(pixels.len().to_i64())
    var i = 0
    while i < pixels.len():
        packed[i] = pixels[i].to_i64() & 0xFFFFFF
        i = i + 1
    packed

fn render_and_present(win: WinitWindow, comp: HostCompositor, frame_w: i32, frame_h: i32, frame_path: text, state: text, trace_path: text) -> bool:
    write_wm_trace(trace_path, "render_compose_start")
    val base_pixels = compose_pixels(comp, trace_path)
    write_wm_trace(trace_path, "render_compose_done")
    if base_pixels.len() < W * H:
        print "[wm-graphics-2d] present state={state} FAIL compose_short={base_pixels.len()} want={W * H}"
        return false
    write_wm_trace(trace_path, "render_child_load_start")
    val child = load_child_frame(frame_path)
    write_wm_trace(trace_path, "render_child_load_done")
    var present_pixels = base_pixels
    if child.ok:
        present_pixels = blit_child_frame_pixels(base_pixels, comp, child.pixels, child.w, child.h)
    else:
        print "[wm-graphics-2d] child_frame_decode_timeout reason={child.reason}"
    write_wm_trace(trace_path, "render_pack_start")
    val packed = pack_pixels(present_pixels)
    write_wm_trace(trace_path, "render_pack_done")
    write_wm_trace(trace_path, "render_winit_present_start")
    winit_present_rgba(win, W.to_i64(), H.to_i64(), packed)
    write_wm_trace(trace_path, "render_winit_present_done")
    if state != "hold":
        print "[wm-graphics-2d] present state={state} dims={W}x{H} child_frame=from-filesystem renderer=wm-pixel-compositor requested_child={frame_w}x{frame_h}"
    true

fn child_local_at(comp: HostCompositor, fx: i32, fy: i32, frame_w: i32, frame_h: i32, require_inside: bool) -> ChildLocalHit:
    var i = comp.windows.len() - 1
    while i >= 0:
        val win = comp.windows[i]
        if not win.minimized:
            val lx = fx - (win.x + 4)
            val ly = fy - (win.y + 28)
            val inside = lx >= 0 and ly >= 0 and lx < frame_w and ly < frame_h
            if inside or not require_inside:
                return ChildLocalHit(ok: true, x: lx, y: ly)
        i = i - 1
    ChildLocalHit(ok: false, x: 0, y: 0)

fn write_child_pointer_event(event_path: text, seq: i64, kind: text, x: i32, y: i32, button: i64, pressed: bool) -> i64:
    if event_path == "":
        return seq
    val next_seq = seq + 1
    val ev = wm_fs_app_event(next_seq, kind, x, y, button, pressed)
    val encoded = wm_fs_app_event_encode(ev)
    val seq_path = wm_fs_app_event_seq_path(event_path, next_seq)
    if file_write(seq_path, encoded) and file_write(event_path, encoded):
        print "[wm-graphics-2d] child_event kind={kind} seq={next_seq} x={x} y={y} pressed={pressed}"
        return next_seq
    print "[wm-graphics-2d] child_event_write_failed path={event_path}"
    seq

fn child_needs_press_stream(x: i32, y: i32) -> bool:
    (x >= 268 and x < 398 and y >= 186 and y < 214) or
    (x >= 134 and x < 199 and y >= 93 and y < 107)

fn apply_wm_input(state: WmLoopState, input: WinitInput, event_path: text, frame_w: i32, frame_h: i32) -> WmLoopState:
    var out = state.comp
    var mx = state.mouse_x
    var my = state.mouse_y
    var child_down = state.child_pointer_down
    var child_drag_forwarding = state.child_drag_forwarding
    var child_seq = state.child_event_seq
    var child_refresh_pending = state.child_refresh_pending
    var child_refresh_deadline = state.child_refresh_deadline
    var dirty = false
    var running = state.running
    if should_close(input):
        running = false
    if input.mouse_x != 0.0 or input.mouse_y != 0.0:
        mx = input.mouse_x.to_i32()
        my = input.mouse_y.to_i32()
        val was_dragging = state.comp.dragging or state.comp.resizing
        out = host_compositor_pointer_move(out, mx, my)
        dirty = was_dragging or out.dragging or out.resizing
        if child_down and child_drag_forwarding:
            val loc = child_local_at(out, mx, my, frame_w, frame_h, false)
            if loc.ok:
                val before_move_seq = child_seq
                child_seq = write_child_pointer_event(event_path, child_seq, "move", loc.x, loc.y, 0, true)
                if child_seq > before_move_seq:
                    child_refresh_pending = true
                    child_refresh_deadline = 0
    var ci = 0
    while ci < input.click_buttons.len():
        val btn = input.click_buttons[ci]
        val pressed = input.click_pressed[ci]
        if btn == 0:
            var fx = input.click_x[ci].to_i32()
            var fy = input.click_y[ci].to_i32()
            if fx == 0 and fy == 0:
                fx = mx
                fy = my
            else:
                mx = fx
                my = fy
            if pressed:
                val loc_down = child_local_at(out, fx, fy, frame_w, frame_h, true)
                if loc_down.ok:
                    child_drag_forwarding = child_needs_press_stream(loc_down.x, loc_down.y)
                    if child_drag_forwarding:
                        val before_down_seq = child_seq
                        child_seq = write_child_pointer_event(event_path, child_seq, "down", loc_down.x, loc_down.y, btn, true)
                        if child_seq > before_down_seq:
                            child_refresh_pending = true
                            child_refresh_deadline = 0
                    child_down = true
            elif not pressed:
                val loc_up = child_local_at(out, fx, fy, frame_w, frame_h, false)
                if loc_up.ok:
                    val before_up_seq = child_seq
                    child_seq = write_child_pointer_event(event_path, child_seq, "up", loc_up.x, loc_up.y, btn, false)
                    if child_seq > before_up_seq:
                        child_refresh_pending = true
                        child_refresh_deadline = 0
                child_down = false
                child_drag_forwarding = false
            out = host_compositor_left_button_at(out, pressed, fx, fy)
            dirty = true
            print "[wm-graphics-2d] input left_button pressed={pressed} x={fx} y={fy} windows={out.windows.len()} dragging={out.dragging}"
        ci = ci + 1
    if out.windows.len() == 0:
        running = false
    WmLoopState(comp: out, mouse_x: mx, mouse_y: my, child_pointer_down: child_down, child_drag_forwarding: child_drag_forwarding, child_event_seq: child_seq, child_refresh_pending: child_refresh_pending, child_refresh_deadline: child_refresh_deadline, dirty: dirty, running: running)

fn launch_showcase_child(bridge_path: text, frame_path: text, repo_root: text) -> i64:
    var env = wm_graphics_2d_showcase_client_env(bridge_path, frame_path)
    val lib = env_get("SIMPLE_LIB") ?? ""
    if lib != "":
        env["SIMPLE_LIB"] = lib
    else:
        env["SIMPLE_LIB"] = path_join(repo_root, "src")
    val requested_scale = env_get("SHOWCASE_PPM_SCALE") ?? ""
    if requested_scale != "":
        env["SHOWCASE_PPM_SCALE"] = requested_scale
    else:
        env["SHOWCASE_PPM_SCALE"] = "1"
    env["SIMPLE_TIMEOUT_SECONDS"] = "0"
    env["SIMPLE_EXECUTION_LIMIT"] = "0"
    val simple_lib = env["SIMPLE_LIB"]
    val showcase_scale = env["SHOWCASE_PPM_SCALE"]
    val simple_bin = path_join(repo_root, "bin/simple")
    val showcase_source_path = path_join(repo_root, GRAPHICS_2D_SHOWCASE_APP_SOURCE)
    val event_path = wm_graphics_2d_showcase_event_path(frame_path)
    val seq_path = wm_graphics_2d_showcase_frame_seq_path(frame_path)
    if host_os().lower().contains("windows"):
        return process_spawn_async_env(simple_bin, ["run", showcase_source_path], env)
    process_spawn_async("env", [
        "SIMPLE_WM_APP_MODE=client",
        "SIMPLE_WM_BRIDGE_FILE={bridge_path}",
        "SIMPLE_WM_FRAME_FILE={frame_path}",
        "{WM_EVENT_FILE_ENV}={event_path}",
        "{WM_FRAME_SEQ_FILE_ENV}={seq_path}",
        "SIMPLE_WM_CLIENT_HOLD=1",
        "SHOWCASE_PPM_SCALE={showcase_scale}",
        "SIMPLE_TIMEOUT_SECONDS=0",
        "SIMPLE_EXECUTION_LIMIT=0",
        "SIMPLE_LIB={simple_lib}",
        simple_bin,
        "run",
        showcase_source_path
    ])

fn cleanup(child_pid: i64, win: WinitWindow, lp: WinitLoop):
    if child_pid > 0:
        process_kill(child_pid)
    winit_window_free(win)
    winit_loop_free(lp)

fn main() -> i64:
    print "WM Graphics 2D Showcase GUI - launching same source from filesystem"
    if (env_get("SIMPLE_GUI") ?? "") != "1":
        print "[wm-graphics-2d] error=no-gui-requested (launch via macos-gui-run.shs)"
        return 2

    val repo_root = resolve_repo_root()
    val tmp_root = path_join(repo_root, "build/tmp")
    dir_create_all(tmp_root)
    val stamp = "{getpid()}_{time_now_unix_micros()}"
    val bridge_path = path_join(tmp_root, "wm_graphics_2d_showcase_{stamp}.bridge")
    val frame_path = path_join(tmp_root, "wm_graphics_2d_showcase_{stamp}.ppm")
    val trace_path = frame_path + ".trace"
    val event_path = wm_graphics_2d_showcase_event_path(frame_path)
    val seq_path = wm_graphics_2d_showcase_frame_seq_path(frame_path)
    val showcase_source_path = path_join(repo_root, GRAPHICS_2D_SHOWCASE_APP_SOURCE)
    write_wm_trace(trace_path, "start")
    print "[wm-graphics-2d] repo_root={repo_root} child_source_fs={showcase_source_path}"
    val child_pid = launch_showcase_child(bridge_path, frame_path, repo_root)
    if child_pid <= 0:
        print "[wm-graphics-2d] error=child-spawn-failed source={GRAPHICS_2D_SHOWCASE_APP_SOURCE}"
        return 1
    write_wm_trace(trace_path, "child_spawned")

    val bridge_body = wait_for_bridge(bridge_path, 300000)
    if bridge_body == "":
        print "[wm-graphics-2d] error=child-bridge-timeout source={GRAPHICS_2D_SHOWCASE_APP_SOURCE} pid={child_pid}"
        process_kill(child_pid)
        return 1
    write_wm_trace(trace_path, "bridge_ready")
    val req = wm_fs_bridge_decode(bridge_body)
    var frame_w = req.window_w - 8
    var frame_h = req.window_h - 32
    if frame_w <= 0:
        frame_w = 1
    if frame_h <= 0:
        frame_h = 1
    write_wm_trace(trace_path, "frame_ready")
    val child_event_path = if req.event_path != "": req.event_path else: event_path
    val child_seq_path = if req.frame_seq_path != "": req.frame_seq_path else: seq_path
    var last_frame_seq = read_frame_seq(child_seq_path)

    write_wm_trace(trace_path, "before_loop_new")
    val lp = winit_loop_new()
    if not lp.is_valid:
        print "[wm-graphics-2d] error=no-gui-runtime"
        process_kill(child_pid)
        return 1
    write_wm_trace(trace_path, "after_loop_new")
    val win = winit_window_new(lp, W.to_i64(), H.to_i64(), "Simple WM - Graphics 2D Showcase")
    if not win.is_valid:
        print "[wm-graphics-2d] error=window-create-failed"
        winit_loop_free(lp)
        process_kill(child_pid)
        return 1
    write_wm_trace(trace_path, "after_window_new")
    write_wm_trace(trace_path, "after_pixel_compositor_create")

    val backend = HeadlessHostCompositorBackend.new(W, H)
    var comp = HostCompositor.new(backend, Size.wh(W, H))
    comp.apply_bridge_request(1, 701, COMP_CREATE_WINDOW.to_i64(), 0, req.title, 54, 70, req.window_w, req.window_h, req.content, req.pid, req.app_id)
    print "[wm-graphics-2d] launched source={req.source_path} child_pid={child_pid} bridge_pid={req.pid} app_id={req.app_id} windows={comp.windows.len()} taskbar_items={comp.windows.len()}"
    if comp.windows.len() != 1:
        cleanup(child_pid, win, lp)
        return 1
    write_wm_trace(trace_path, "before_first_present")
    if not render_and_present(win, comp, frame_w, frame_h, frame_path, "launched", trace_path):
        cleanup(child_pid, win, lp)
        return 1
    write_wm_trace(trace_path, "loop_start")

    var state = WmLoopState(comp: comp, mouse_x: 0, mouse_y: 0, child_pointer_down: false, child_drag_forwarding: false, child_event_seq: 0, child_refresh_pending: false, child_refresh_deadline: 0, dirty: false, running: true)
    var last_anim_tick = time_now_unix_micros()
    var frames = 0
    while state.running and frames < 2000000:
        val wait_ms = if state.child_refresh_pending: 20 else: 80
        val input = winit_wait_input(lp, wait_ms)
        state = apply_wm_input(state, input, child_event_path, frame_w, frame_h)
        val now = time_now_unix_micros()
        if state.child_refresh_pending and state.child_refresh_deadline == 0:
            state.child_refresh_deadline = now + 250000
        if not state.child_refresh_pending and now - last_anim_tick >= 1000000:
            val before_tick_seq = state.child_event_seq
            state.child_event_seq = write_child_pointer_event(child_event_path, state.child_event_seq, "tick", 0, 0, 0, false)
            if state.child_event_seq > before_tick_seq:
                state.child_refresh_pending = true
                state.child_refresh_deadline = now + 250000
                write_wm_trace(trace_path, "tick_sent:{state.child_event_seq}")
            last_anim_tick = now
        var current_frame_seq = last_frame_seq
        if state.child_refresh_pending:
            current_frame_seq = read_frame_seq(child_seq_path)
            if current_frame_seq <= last_frame_seq:
                if state.child_refresh_deadline > 0 and now > state.child_refresh_deadline:
                    print "[wm-graphics-2d] child_frame_refresh_timeout last_seq={last_frame_seq} event_seq={state.child_event_seq}"
                    write_wm_trace(trace_path, "refresh_timeout:{state.child_event_seq}")
                    state.child_refresh_pending = false
                    state.child_refresh_deadline = 0
        if state.child_refresh_pending and current_frame_seq > last_frame_seq:
            last_frame_seq = current_frame_seq
            state.dirty = true
            state.child_refresh_pending = false
            state.child_refresh_deadline = 0
            write_wm_trace(trace_path, "frame_refresh:{last_frame_seq}")
            print "[wm-graphics-2d] child_frame_refresh seq={last_frame_seq} size={frame_w}x{frame_h}"
        if state.dirty:
            if not render_and_present(win, state.comp, frame_w, frame_h, frame_path, "hold", trace_path):
                cleanup(child_pid, win, lp)
                return 1
            state.dirty = false
            sleep_ms(16)
        frames = frames + 1

    cleanup(child_pid, win, lp)
    return 0
