# widget_showcase_gui.spl — GUI sanity app: a comprehensive gallery of the
# common UI widgets drawn directly on the pure-Simple Engine2D CPU lane and
# presented to an on-screen window.
#
# This is one of the three main GUI check apps (see .claude/skills/lib/spipe_ui.md):
#   1. 2D rendering  — engine2d_shapes_gui.spl
#   2. GUI widgets   — THIS app
#   3. HTML rendering — web_render_file_gui.spl
#
# Draws widgets with engine2d primitives (rect/rounded_rect/line/circle/triangle/
# text) rather than the web layout path, so it renders fast and is a reliable
# visual sanity check of widget chrome + legible glyph text on the CPU lane.
#
# Launch (window):
#   SIMPLE_GUI_RUN_SKIP_NUDGE=1 scripts/gui/macos-gui-run.shs examples/06_io/ui/widget_showcase_gui.spl
# Headless: bin/simple run examples/06_io/ui/widget_showcase_gui.spl

use std.gpu.engine2d.engine.{Engine2D}
use std.io.window_winit.{WinitLoop, WinitWindow, WinitInput, winit_loop_new, winit_loop_free, winit_window_new, winit_window_free, winit_present_rgba, winit_poll_input}
use std.common.image.ppm_decode.{encode_ppm_p6}
use std.nogc_sync_mut.sffi.io.{file_write_bytes}
use std.io_runtime.{file_write, file_exists, file_read, getpid, get_args}
use std.nogc_sync_mut.io.time_ops.{time_now_micros}
use std.nogc_sync_mut.io.env_ops.{env_get}
use std.nogc_sync_mut.concurrent.thread.{thread_sleep}
use std.common.science_math.perf_sugar.{alloc_i64}
use common.ui.widget.{UITree, WidgetNode, WidgetKind}
use common.ui.wm_app_process_contract.{WM_APP_MODE_ENV, WM_BRIDGE_FILE_ENV, WM_FRAME_FILE_ENV, WM_EVENT_FILE_ENV, WM_FRAME_SEQ_FILE_ENV, WM_CLIENT_HOLD_ENV, WIDGET_SHOWCASE_APP_SOURCE, wm_app_mode_is_client, wm_widget_showcase_bridge_request_sized, wm_fs_bridge_encode, wm_widget_showcase_event_path, wm_widget_showcase_frame_seq_path, wm_fs_app_event_seq_path, wm_fs_app_event_decode}

val W: i32 = 3840
val H: i32 = 2160

# Palette
val BG: u32 = 0xFF14141Cu32
val CARD: u32 = 0xFF1E1E28u32
val FG: u32 = 0xFFE6E6F0u32
val MUTED: u32 = 0xFF8A8A9Au32
val LINE: u32 = 0xFF34343Eu32
val ACCENT: u32 = 0xFF3B82F6u32
val ACCENT_D: u32 = 0xFF1D4ED8u32
val GREEN: u32 = 0xFF22C55Eu32
val RED: u32 = 0xFFEF4444u32
val AMBER: u32 = 0xFFF59E0Bu32
val WHITE: u32 = 0xFFFFFFFFu32
val TRACK: u32 = 0xFF2A2A38u32

# ponytail: native rounded-rect emulation crashes in this compiled perf gate; plain rects keep the widget evidence alive.

# Interactive widget state driven by synthetic SHOWCASE_EVENTS (W1/G1.5).
# Defaults reproduce the historical static frame exactly.
struct ShowcaseState:
    button_count: i32
    button_pressed: bool
    checkbox_on: bool
    switch_on: bool
    slider_value: i32
    progress_value: i32
    slider_dragging: bool

fn showcase_state_default() -> ShowcaseState:
    ShowcaseState(button_count: 0, button_pressed: false, checkbox_on: true, switch_on: true, slider_value: 60, progress_value: 62, slider_dragging: false)

fn showcase_ui_tree(st: ShowcaseState) -> UITree:
    var root = WidgetNode.new("showcase_root", WidgetKind.Panel.to_wire())
    var button = WidgetNode.new("showcase_button", WidgetKind.Button.to_wire()).set_prop("text", "Run").set_prop("count", st.button_count.to_text())
    var checkbox = WidgetNode.new("showcase_checkbox", WidgetKind.Checkbox.to_wire()).set_prop("checked", st.checkbox_on.to_text())
    var toggle = WidgetNode.new("showcase_toggle", WidgetKind.Switch.to_wire()).set_prop("checked", st.switch_on.to_text())
    var slider = WidgetNode.new("showcase_slider", WidgetKind.Input.to_wire()).set_prop("role", "slider").set_prop("value", st.slider_value.to_text())
    var progress = WidgetNode.new("showcase_progress", WidgetKind.Progress.to_wire()).set_prop("value", st.progress_value.to_text())
    root = root.add_child(button)
    root = root.add_child(checkbox)
    root = root.add_child(toggle)
    root = root.add_child(slider)
    root = root.add_child(progress)
    UITree.new(root).with_title("Widget Showcase")

# Pure reducer: one synthetic event -> new state (widget_interact_model style).
fn apply_showcase_event(st: ShowcaseState, ev: text) -> ShowcaseState:
    if ev == "click:button":
        return ShowcaseState(button_count: st.button_count + 1, button_pressed: not st.button_pressed, checkbox_on: st.checkbox_on, switch_on: st.switch_on, slider_value: st.slider_value, progress_value: st.progress_value, slider_dragging: false)
    if ev == "toggle:switch":
        return ShowcaseState(button_count: st.button_count, button_pressed: st.button_pressed, checkbox_on: st.checkbox_on, switch_on: not st.switch_on, slider_value: st.slider_value, progress_value: st.progress_value, slider_dragging: false)
    if ev == "advance:progress":
        var pct = st.progress_value + 20
        if pct > 100:
            pct = 100
        return ShowcaseState(button_count: st.button_count, button_pressed: st.button_pressed, checkbox_on: st.checkbox_on, switch_on: st.switch_on, slider_value: st.slider_value, progress_value: pct, slider_dragging: false)
    print "unknown showcase event: {ev}"
    st

fn clamp_i32(v: i32, lo: i32, hi: i32) -> i32:
    if v < lo:
        return lo
    if v > hi:
        return hi
    v

fn hit_rect(px: i32, py: i32, x: i32, y: i32, w: i32, h: i32) -> bool:
    px >= x and px < x + w and py >= y and py < y + h

# Density scale helpers: `s` is a permille scale factor (1000 = 1.0x = the
# historical 96-DPI baseline design). sc() scales a geometry value; sc1()
# additionally floors at 1 so strokes/radii/fonts never vanish at low DPI.
fn sc(v: i32, s: i32) -> i32:
    v * s / 1000

fn sc1(v: i32, s: i32) -> i32:
    val r = sc(v, s)
    if r < 1: 1 else: r

# SHOWCASE_DPI (default 300): density used to size widget chrome when the
# grid is rebalanced for a wide/tall canvas (see grid_params). 96 DPI == 1x.
fn showcase_dpi() -> i32:
    val raw = env_get("SHOWCASE_DPI") ?? ""
    val v = (raw.trim().parse_i64() ?? 300i64).to_i32()
    if v < 1: 96 else: v

# SHOWCASE_RESOLUTION: "4k" (default), "8k", or an explicit "WxH" token.
fn showcase_resolution_wh() -> (i32, i32):
    val raw = (env_get("SHOWCASE_RESOLUTION") ?? "").trim().to_lower()
    if raw == "" or raw == "4k":
        return (W, H)
    if raw == "8k":
        return (7680, 4320)
    val parts = raw.split("x")
    if parts.len() == 2:
        val pw = (parts[0].parse_i64() ?? 0i64).to_i32()
        val ph = (parts[1].parse_i64() ?? 0i64).to_i32()
        if pw > 0 and ph > 0:
            return (pw, ph)
    (W, H)

fn slider_value_from_x(local_x: i32) -> i32:
    val slider_x = 268
    val rel = clamp_i32(local_x - slider_x, 0, 130)
    rel * 100 / 130

fn showcase_on_tick(state: ShowcaseState) -> ShowcaseState:
    var out = state
    out.progress_value = (out.progress_value + 2) % 101
    out

fn showcase_on_pointer(state: ShowcaseState, kind: text, x: i32, y: i32, pressed: bool) -> ShowcaseState:
    if kind == "tick":
        return showcase_on_tick(state)
    var out = state
    if kind == "down" and pressed and hit_rect(x, y, 12, 56, 60, 18):
        out.button_pressed = true
    if kind == "down" and pressed and hit_rect(x, y, 268, 186, 130, 28):
        out.slider_dragging = true
        out.slider_value = slider_value_from_x(x)
    elif kind == "move" and out.slider_dragging:
        out.slider_value = slider_value_from_x(x)
    elif kind == "up":
        if hit_rect(x, y, 12, 56, 60, 18):
            out.button_count = out.button_count + 1
        if hit_rect(x, y, 268, 58, 120, 22):
            out.checkbox_on = not out.checkbox_on
        if hit_rect(x, y, 12, 124, 78, 18):
            out.switch_on = not out.switch_on
        out.button_pressed = false
        if out.slider_dragging:
            out.slider_value = slider_value_from_x(x)
        out.slider_dragging = false
    out

fn showcase_state_same(a: ShowcaseState, b: ShowcaseState) -> bool:
    a.button_count == b.button_count and
    a.button_pressed == b.button_pressed and
    a.checkbox_on == b.checkbox_on and
    a.switch_on == b.switch_on and
    a.slider_value == b.slider_value and
    a.progress_value == b.progress_value and
    a.slider_dragging == b.slider_dragging

# Grid cell index of the widget an event targets (-1 = unknown).
fn showcase_event_cell(ev: text) -> i32:
    if ev == "click:button":
        return 0
    if ev == "toggle:switch":
        return 1
    if ev == "advance:progress":
        return 3
    -1

# section label above each widget cell
# Returns the engine: paints made through an Engine2D class PARAM are lost to
# the caller on the deployed interpreter lane (param handle detaches; mut
# alone does not write back — see graphics_2d_showcase.spl's draw_showcase
# for the original root-cause writeup). Every widget helper below threads
# the engine back explicitly through its return value.
fn label(mut b: Engine2D, x: i32, y: i32, name: text, s: i32) -> Engine2D:
    b.draw_text(x, y, name, MUTED, sc1(6, s))
    b

fn w_button(mut b: Engine2D, x: i32, y: i32, st: ShowcaseState, s: i32) -> Engine2D:
    b = label(b, x, y, "Button", s)
    if st.button_pressed:
        b.draw_rect_filled(x, y + sc(10, s), sc(60, s), sc(18, s), ACCENT_D)
        b.draw_rect(x, y + sc(10, s), sc(60, s), sc(18, s), WHITE)
        b.draw_text(x + sc(16, s), y + sc(15, s), "Run", AMBER, sc1(7, s))
    else:
        b.draw_rect_filled(x, y + sc(10, s), sc(60, s), sc(18, s), ACCENT)
        b.draw_rect(x, y + sc(10, s), sc(60, s), sc(18, s), ACCENT_D)
        b.draw_text(x + sc(16, s), y + sc(15, s), "Run", WHITE, sc1(7, s))
    # secondary (outline)
    b.draw_rect(x + sc(70, s), y + sc(10, s), sc(60, s), sc(18, s), MUTED)
    b.draw_text(x + sc(82, s), y + sc(15, s), "Cancel", FG, sc1(7, s))
    b.draw_text(x + sc(18, s), y + sc(33, s), "Clicks {st.button_count}", MUTED, sc1(6, s))
    b

fn w_checkbox(mut b: Engine2D, x: i32, y: i32, st: ShowcaseState, s: i32) -> Engine2D:
    b = label(b, x, y, "Checkbox / Radio", s)
    b.draw_rect(x, y + sc(12, s), sc(13, s), sc(13, s), MUTED)
    if st.checkbox_on:
        b.draw_rect_filled(x + sc(3, s), y + sc(15, s), sc(7, s), sc(7, s), GREEN)
    b.draw_text(x + sc(18, s), y + sc(14, s), "On", FG, sc1(7, s))
    b.draw_rect(x + sc(50, s), y + sc(12, s), sc(13, s), sc(13, s), MUTED)
    if not st.checkbox_on:
        b.draw_rect_filled(x + sc(53, s), y + sc(15, s), sc(7, s), sc(7, s), AMBER)
    b.draw_text(x + sc(68, s), y + sc(14, s), "Off", FG, sc1(7, s))
    # radio
    b.draw_circle(x + sc(100, s), y + sc(18, s), sc1(7, s), MUTED)
    b.draw_circle_filled(x + sc(100, s), y + sc(18, s), sc1(3, s), ACCENT)
    b.draw_circle(x + sc(124, s), y + sc(18, s), sc1(7, s), MUTED)
    b

fn w_switch(mut b: Engine2D, x: i32, y: i32, on: bool, s: i32) -> Engine2D:
    b = label(b, x, y, "Toggle switch", s)
    # first switch reflects state
    if on:
        b.draw_rect_filled(x, y + sc(12, s), sc(34, s), sc(16, s), GREEN)
        b.draw_circle_filled(x + sc(26, s), y + sc(20, s), sc1(6, s), WHITE)
    else:
        b.draw_rect_filled(x, y + sc(12, s), sc(34, s), sc(16, s), TRACK)
        b.draw_circle_filled(x + sc(8, s), y + sc(20, s), sc1(6, s), MUTED)
    # second stays off (static reference)
    b.draw_rect_filled(x + sc(44, s), y + sc(12, s), sc(34, s), sc(16, s), TRACK)
    b.draw_circle_filled(x + sc(52, s), y + sc(20, s), sc1(6, s), MUTED)
    b

fn w_input(mut b: Engine2D, x: i32, y: i32, s: i32) -> Engine2D:
    b = label(b, x, y, "Text input", s)
    b.draw_rect(x, y + sc(11, s), sc(150, s), sc(18, s), MUTED)
    b.draw_text(x + sc(5, s), y + sc(16, s), "name...", MUTED, sc1(7, s))
    b

fn w_dropdown(mut b: Engine2D, x: i32, y: i32, s: i32) -> Engine2D:
    b = label(b, x, y, "Dropdown", s)
    b.draw_rect(x, y + sc(11, s), sc(130, s), sc(18, s), MUTED)
    b.draw_text(x + sc(5, s), y + sc(16, s), "Option A", FG, sc1(7, s))
    b.draw_triangle_filled(x + sc(116, s), y + sc(16, s), x + sc(124, s), y + sc(16, s), x + sc(120, s), y + sc(22, s), FG)
    b

fn w_slider(mut b: Engine2D, x: i32, y: i32, value: i32, s: i32) -> Engine2D:
    b = label(b, x, y, "Slider", s)
    val fill = sc(130 * value / 100, s)
    b.draw_rect_filled(x, y + sc(18, s), sc(130, s), sc(4, s), TRACK)
    b.draw_rect_filled(x, y + sc(18, s), fill, sc(4, s), ACCENT)
    b.draw_circle_filled(x + fill, y + sc(20, s), sc1(6, s), WHITE)
    b

fn w_progress(mut b: Engine2D, x: i32, y: i32, pct: i32, s: i32) -> Engine2D:
    b = label(b, x, y, "Progress", s)
    b.draw_rect_filled(x, y + sc(14, s), sc(130, s), sc(10, s), TRACK)
    b.draw_rect_filled(x, y + sc(14, s), sc(130 * pct / 100, s), sc(10, s), ACCENT)
    b.draw_text(x + sc(136, s), y + sc(14, s), "{pct}%", MUTED, sc1(6, s))
    b

fn w_search(mut b: Engine2D, x: i32, y: i32, s: i32) -> Engine2D:
    b = label(b, x, y, "Search bar", s)
    b.draw_rect(x, y + sc(11, s), sc(150, s), sc(18, s), MUTED)
    b.draw_circle(x + sc(12, s), y + sc(19, s), sc1(4, s), MUTED)
    b.draw_line(x + sc(15, s), y + sc(22, s), x + sc(19, s), y + sc(26, s), MUTED, sc1(1, s))
    b.draw_text(x + sc(24, s), y + sc(16, s), "Search...", MUTED, sc1(7, s))
    b

fn w_tabs(mut b: Engine2D, x: i32, y: i32, s: i32) -> Engine2D:
    b = label(b, x, y, "Tabs", s)
    b.draw_text(x + sc(4, s), y + sc(14, s), "Home", FG, sc1(7, s))
    b.draw_text(x + sc(44, s), y + sc(14, s), "Edit", MUTED, sc1(7, s))
    b.draw_text(x + sc(80, s), y + sc(14, s), "View", MUTED, sc1(7, s))
    b.draw_rect_filled(x + sc(2, s), y + sc(26, s), sc(32, s), sc(2, s), ACCENT)
    b.draw_line(x, y + sc(27, s), x + sc(150, s), y + sc(27, s), LINE, sc1(1, s))
    b

fn w_segmented(mut b: Engine2D, x: i32, y: i32, s: i32) -> Engine2D:
    b = label(b, x, y, "Segmented", s)
    b.draw_rect(x, y + sc(11, s), sc(120, s), sc(18, s), MUTED)
    b.draw_rect_filled(x + sc(2, s), y + sc(13, s), sc(38, s), sc(14, s), ACCENT)
    b.draw_text(x + sc(8, s), y + sc(16, s), "Day", WHITE, sc1(6, s))
    b.draw_text(x + sc(50, s), y + sc(16, s), "Week", MUTED, sc1(6, s))
    b.draw_text(x + sc(90, s), y + sc(16, s), "Mo", MUTED, sc1(6, s))
    b

fn w_list(mut b: Engine2D, x: i32, y: i32, s: i32) -> Engine2D:
    b = label(b, x, y, "List", s)
    b.draw_text(x + sc(2, s), y + sc(14, s), "- First item", FG, sc1(7, s))
    b.draw_text(x + sc(2, s), y + sc(26, s), "- Second item", FG, sc1(7, s))
    b.draw_text(x + sc(2, s), y + sc(38, s), "- Third item", MUTED, sc1(7, s))
    b

fn w_tree(mut b: Engine2D, x: i32, y: i32, s: i32) -> Engine2D:
    b = label(b, x, y, "Tree", s)
    b.draw_triangle_filled(x + sc(2, s), y + sc(12, s), x + sc(2, s), y + sc(20, s), x + sc(8, s), y + sc(16, s), FG)
    b.draw_text(x + sc(12, s), y + sc(13, s), "src", FG, sc1(7, s))
    b.draw_text(x + sc(22, s), y + sc(26, s), "main.spl", MUTED, sc1(7, s))
    b.draw_text(x + sc(22, s), y + sc(38, s), "lib.spl", MUTED, sc1(7, s))
    b

fn w_table(mut b: Engine2D, x: i32, y: i32, s: i32) -> Engine2D:
    b = label(b, x, y, "Table", s)
    b.draw_rect_filled(x, y + sc(11, s), sc(150, s), sc(12, s), TRACK)
    b.draw_text(x + sc(4, s), y + sc(13, s), "Name", FG, sc1(6, s))
    b.draw_text(x + sc(80, s), y + sc(13, s), "Size", FG, sc1(6, s))
    b.draw_text(x + sc(4, s), y + sc(27, s), "a.spl", MUTED, sc1(6, s))
    b.draw_text(x + sc(80, s), y + sc(27, s), "1.2k", MUTED, sc1(6, s))
    b.draw_text(x + sc(4, s), y + sc(39, s), "b.spl", MUTED, sc1(6, s))
    b.draw_text(x + sc(80, s), y + sc(39, s), "3.4k", MUTED, sc1(6, s))
    b.draw_line(x, y + sc(23, s), x + sc(150, s), y + sc(23, s), LINE, sc1(1, s))
    b.draw_line(x + sc(74, s), y + sc(11, s), x + sc(74, s), y + sc(48, s), LINE, sc1(1, s))
    b

fn w_card(mut b: Engine2D, x: i32, y: i32, s: i32) -> Engine2D:
    b = label(b, x, y, "Card", s)
    b.draw_rect_filled(x + sc(3, s), y + sc(14, s), sc(130, s), sc(44, s), 0xFF0C0C12u32)
    b.draw_rect(x, y + sc(11, s), sc(130, s), sc(44, s), LINE)
    b.draw_rect_filled(x + sc(1, s), y + sc(12, s), sc(128, s), sc(42, s), CARD)
    b.draw_text(x + sc(8, s), y + sc(18, s), "Title", FG, sc1(7, s))
    b.draw_text(x + sc(8, s), y + sc(32, s), "Body text here", MUTED, sc1(6, s))
    b

fn w_chip(mut b: Engine2D, x: i32, y: i32, s: i32) -> Engine2D:
    b = label(b, x, y, "Badge / Chip", s)
    b.draw_rect_filled(x, y + sc(12, s), sc(40, s), sc(14, s), GREEN)
    b.draw_text(x + sc(8, s), y + sc(14, s), "New", WHITE, sc1(6, s))
    b.draw_rect_filled(x + sc(48, s), y + sc(12, s), sc(44, s), sc(14, s), AMBER)
    b.draw_text(x + sc(55, s), y + sc(14, s), "Beta", 0xFF1A1A1Au32, sc1(6, s))
    b

fn w_tooltip(mut b: Engine2D, x: i32, y: i32, s: i32) -> Engine2D:
    b = label(b, x, y, "Tooltip", s)
    b.draw_rect_filled(x, y + sc(12, s), sc(88, s), sc(18, s), 0xFF2D2D3Au32)
    b.draw_text(x + sc(6, s), y + sc(17, s), "Helpful hint", FG, sc1(6, s))
    b.draw_triangle_filled(x + sc(12, s), y + sc(30, s), x + sc(22, s), y + sc(30, s), x + sc(17, s), y + sc(35, s), 0xFF2D2D3Au32)
    b

fn w_dialog(mut b: Engine2D, x: i32, y: i32, s: i32) -> Engine2D:
    b = label(b, x, y, "Dialog / Modal", s)
    b.draw_rect(x, y + sc(11, s), sc(150, s), sc(50, s), LINE)
    b.draw_rect_filled(x + sc(1, s), y + sc(12, s), sc(148, s), sc(48, s), CARD)
    b.draw_text(x + sc(8, s), y + sc(17, s), "Delete file?", FG, sc1(7, s))
    b.draw_text(x + sc(8, s), y + sc(30, s), "This cannot be undone.", MUTED, sc1(6, s))
    b.draw_rect_filled(x + sc(60, s), y + sc(42, s), sc(36, s), sc(14, s), TRACK)
    b.draw_text(x + sc(66, s), y + sc(45, s), "No", FG, sc1(6, s))
    b.draw_rect_filled(x + sc(102, s), y + sc(42, s), sc(40, s), sc(14, s), RED)
    b.draw_text(x + sc(108, s), y + sc(45, s), "Yes", WHITE, sc1(6, s))
    b

fn w_scrollbar(mut b: Engine2D, x: i32, y: i32, s: i32) -> Engine2D:
    b = label(b, x, y, "Scrollbar", s)
    b.draw_rect_filled(x, y + sc(11, s), sc(8, s), sc(60, s), TRACK)
    b.draw_rect_filled(x, y + sc(14, s), sc(8, s), sc(26, s), MUTED)
    b

fn w_avatar(mut b: Engine2D, x: i32, y: i32, s: i32) -> Engine2D:
    b = label(b, x, y, "Avatar", s)
    b.draw_circle_filled(x + sc(16, s), y + sc(26, s), sc1(14, s), ACCENT)
    b.draw_text(x + sc(11, s), y + sc(22, s), "JS", WHITE, sc1(7, s))
    b

# Column-major cell position: cells flow down a column, then wrap to the
# next. Keeps every widget inside the viewport at low resolutions (G1.3).
fn cell_pos(i: i32, rows: i32, col_w: i32, header: i32, step: i32) -> (i32, i32):
    val c = i / rows
    val r = i % rows
    (12 + c * col_w, header + r * step)

# Grid layout constants shared by draw_frame and the event-diff oracle.
val GRID_HEADER: i32 = 46
val GRID_FOOTER: i32 = 14
val GRID_STEP: i32 = 66
val GRID_CELLS: i32 = 18
val WM_CLIENT_DRAIN_LIMIT: i32 = 64

fn wm_client_log_enabled() -> bool:
    (env_get("SIMPLE_WM_CLIENT_LOG") ?? "") == "1"

fn wm_client_log(msg: text):
    if wm_client_log_enabled():
        print msg

# (rows, col_w, step, header, s) for a given viewport — must match
# draw_frame's grid. `s` is the permille density scale (1000 = 1.0x) applied
# to widget chrome via sc()/sc1(). Baseline (narrow/short) viewports keep the
# exact historical rows-first formula byte-for-byte at s=1000 (low-res gates
# + interaction hit-tests depend on it). Wide/tall viewports (4K/8K default)
# where the rows-first formula collapses to a single very wide column are
# rebalanced across both axes AND scaled to SHOWCASE_DPI (default 300) so the
# 18 widget cells spread across the whole canvas with crisp, generously sized
# chrome instead of clustering in one tall strip of tiny widgets.
fn grid_params(w: i32, h: i32) -> (i32, i32, i32, i32, i32):
    var rows = (h - GRID_HEADER - GRID_FOOTER) / GRID_STEP
    if rows < 1:
        rows = 1
    val ncols = (GRID_CELLS + rows - 1) / rows
    var col_w = (w - 12) / ncols
    # ponytail: below ~170px columns widgets overlap; accept clipping there
    if col_w < 170:
        col_w = 170
    if ncols > 1:
        return (rows, col_w, GRID_STEP, GRID_HEADER, 1000)
    # Rebalance: pick a column count that fills width and height together
    # (sqrt of cells scaled by aspect ratio), then derive rows/col_w/step from
    # that instead of the degenerate single-column result above. Also derive
    # the density scale from SHOWCASE_DPI so widget chrome grows with it.
    val s = showcase_dpi() * 1000 / 96
    val header = sc(GRID_HEADER, s)
    val footer = sc(GRID_FOOTER, s)
    val step_min = sc(GRID_STEP, s)
    val col_min = sc(170, s)
    val cells_f = GRID_CELLS.to_f64()
    val cols_f = (cells_f * w.to_f64() / h.to_f64()).sqrt()
    var cols = (cols_f + 0.5).to_i32()
    if cols < 1:
        cols = 1
    if cols > GRID_CELLS:
        cols = GRID_CELLS
    val rows2 = (GRID_CELLS + cols - 1) / cols
    var col_w2 = (w - 12) / cols
    if col_w2 < col_min:
        col_w2 = col_min
    var step2 = (h - header - footer) / rows2
    if step2 < step_min:
        step2 = step_min
    (rows2, col_w2, step2, header, s)

fn draw_frame(mut b: Engine2D, w: i32, h: i32, st: ShowcaseState) -> Engine2D:
    b.clear(BG)
    # Adaptive grid: 18 cells, rows per column from available height,
    # column count from cell count, column width from viewport width. `s` is
    # the density scale (1000 = 1x baseline; SHOWCASE_DPI-derived for the
    # wide/tall 4K/8K default) applied to the menubar/title/statusbar chrome
    # below and to every widget cell via sc()/sc1().
    val gp = grid_params(w, h)
    val rows = gp.0
    val col_w = gp.1
    val step = gp.2
    val header = gp.3
    val s = gp.4

    # menubar
    b.draw_rect_filled(0, 0, w, sc(16, s), CARD)
    b.draw_text(sc(6, s), sc(4, s), "File  Edit  View  Help", FG, sc1(7, s))
    # title
    b.draw_text(sc(8, s), sc(22, s), "Widget Showcase (Engine2D CPU lane)", FG, sc1(8, s))
    b.draw_line(sc(8, s), sc(38, s), w - sc(8, s), sc(38, s), LINE, sc1(1, s))

    val p0 = cell_pos(0, rows, col_w, header, step)
    b = w_button(b, p0.0, p0.1, st, s)
    val p1 = cell_pos(1, rows, col_w, header, step)
    b = w_switch(b, p1.0, p1.1, st.switch_on, s)
    val p2 = cell_pos(2, rows, col_w, header, step)
    b = w_dropdown(b, p2.0, p2.1, s)
    val p3 = cell_pos(3, rows, col_w, header, step)
    b = w_progress(b, p3.0, p3.1, st.progress_value, s)
    val p4 = cell_pos(4, rows, col_w, header, step)
    b = w_tabs(b, p4.0, p4.1, s)
    val p5 = cell_pos(5, rows, col_w, header, step)
    b = w_list(b, p5.0, p5.1, s)
    val p6 = cell_pos(6, rows, col_w, header, step)
    b = w_table(b, p6.0, p6.1, s)
    val p7 = cell_pos(7, rows, col_w, header, step)
    b = w_chip(b, p7.0, p7.1, s)
    val p8 = cell_pos(8, rows, col_w, header, step)
    b = w_dialog(b, p8.0, p8.1, s)
    val p9 = cell_pos(9, rows, col_w, header, step)
    b = w_checkbox(b, p9.0, p9.1, st, s)
    val p10 = cell_pos(10, rows, col_w, header, step)
    b = w_input(b, p10.0, p10.1, s)
    val p11 = cell_pos(11, rows, col_w, header, step)
    b = w_slider(b, p11.0, p11.1, st.slider_value, s)
    val p12 = cell_pos(12, rows, col_w, header, step)
    b = w_search(b, p12.0, p12.1, s)
    val p13 = cell_pos(13, rows, col_w, header, step)
    b = w_segmented(b, p13.0, p13.1, s)
    val p14 = cell_pos(14, rows, col_w, header, step)
    b = w_tree(b, p14.0, p14.1, s)
    val p15 = cell_pos(15, rows, col_w, header, step)
    b = w_card(b, p15.0, p15.1, s)
    val p16 = cell_pos(16, rows, col_w, header, step)
    b = w_tooltip(b, p16.0, p16.1, s)
    val p17 = cell_pos(17, rows, col_w, header, step)
    b = w_scrollbar(b, p17.0, p17.1, s)
    b = w_avatar(b, p17.0 + sc(76, s), p17.1, s)

    # statusbar
    b.draw_rect_filled(0, h - sc(14, s), w, sc(14, s), CARD)
    b.draw_text(sc(6, s), h - sc(11, s), "Ready", MUTED, sc1(6, s))
    b.draw_text(w - sc(60, s), h - sc(11, s), "Ln 1, Col 1", MUTED, sc1(6, s))
    b

fn draw_g1_1_frame(mut b: Engine2D, w: i32, h: i32, st: ShowcaseState) -> Engine2D:
    b.clear(BG)
    b.draw_rect_filled(0, 0, w, 16, CARD)
    b.draw_text(6, 4, "File  Edit", FG, 7)
    b.draw_text(8, 22, "Widget Showcase", FG, 8)
    b.draw_line(8, 38, w - 8, 38, LINE, 1)
    b = w_button(b, 12, 46, st, 1000)
    b.draw_rect_filled(0, h - 14, w, 14, CARD)
    b.draw_text(6, h - 11, "Ready", MUTED, 6)
    b

# Rendering backend key. `--backend=<name>` CLI flag wins, then the
# SIMPLE_GUI_BACKEND env (e.g. "metal", "vulkan"); default "software" keeps the
# historical CPU-lane behavior byte-for-byte (Engine2D "software" delegates to
# SoftwareBackend). CPU stays the default until GPU parity + perf are proven
# per resolution — see test/02_integration/rendering/engine2d_gpu_offload_evidence.spl.
fn showcase_backend_key() -> text:
    val args = get_args()
    var i = 0
    while i < args.len():
        val arg = args[i]
        if arg.starts_with("--backend="):
            val flag = arg.substring(10, arg.len()).trim()
            if flag != "":
                return flag
        i = i + 1
    val raw = (env_get("SIMPLE_GUI_BACKEND") ?? "").trim()
    if raw == "":
        return "software"
    raw

# Create the showcase render engine. For "metal" this is the persistent
# GPU-only fast session (1x1 CPU mirror, device framebuffer is the source of
# truth, single-hop readback); for every other backend
# create_with_backend_fast() transparently falls back to the regular
# create_with_backend() path, keeping the CPU default lane unchanged.
fn showcase_engine_create(w: i32, h: i32) -> Engine2D:
    Engine2D.create_with_backend_fast(w, h, showcase_backend_key())

# Paint one showcase frame into an EXISTING engine (no per-frame session
# create/shutdown — the persistent-session "gpu process" fix). draw_frame
# starts with clear(), which re-arms gpu_frame_complete for the Metal
# GPU-only lane each frame.
fn build_frame_state_into(mut b: Engine2D, w: i32, h: i32, st: ShowcaseState) -> (Engine2D, [u32]):
    if (env_get("SHOWCASE_G1_1_COMPACT") ?? "") == "1":
        b = draw_g1_1_frame(b, w, h, st)
    else:
        b = draw_frame(b, w, h, st)
    b.present()
    (b, b.read_pixels())

# One greppable renderer-provenance line proving which backend + device rendered
# the frame. For vulkan, includes the physical-device diagnostic (lavapipe under
# Xvfb). This is the G1.1 evidence line.
fn emit_renderer_log(key: text, w: i32, h: i32):
    var probe_engine = Engine2D.create_with_backend(64, 64, key)
    val name = probe_engine.backend_name()
    probe_engine.shutdown()
    var device = ""
    if key == "vulkan":
        val probe = Engine2D.probe_backend(64, 64, "vulkan")
        device = probe.diagnostic_text()
    print "showcase_renderer_backend={name};requested={key};vulkan_device={device}"

fn build_frame_state(w: i32, h: i32, st: ShowcaseState) -> [u32]:
    var b = showcase_engine_create(w, h)
    val (next_b, pixels) = build_frame_state_into(b, w, h, st)
    b = next_b
    b.shutdown()
    pixels

fn build_frame_sized(w: i32, h: i32) -> [u32]:
    build_frame_state(w, h, showcase_state_default())

fn build_frame() -> [u32]:
    build_frame_sized(W, H)

fn showcase_ppm_scale() -> i32:
    val raw = env_get("SHOWCASE_PPM_SCALE") ?? ""
    if raw == "8":
        return 8
    if raw == "4":
        return 4
    if raw == "2":
        return 2
    1

fn downsample_nearest(src: [u32], src_w: i32, src_h: i32, scale: i32) -> [u32]:
    if scale <= 1:
        return src
    val dst_w = src_w / scale
    val dst_h = src_h / scale
    var out: [u32] = []
    var y = 0
    while y < dst_h:
        var x = 0
        val sy = y * scale
        while x < dst_w:
            val sx = x * scale
            out.push(src[sy * src_w + sx])
            x = x + 1
        y = y + 1
    out

fn checksum_pixels(pixels: [u32]) -> i64:
    var sum = 0i64
    var i = 0
    val n = pixels.len()
    while i < n:
        sum = sum + (pixels[i].to_i64() & 0xFFFFFFFF)
        i = i + 1
    sum

fn nonzero_pixels(pixels: [u32]) -> i64:
    var count = 0i64
    var i = 0
    val n = pixels.len()
    while i < n:
        if pixels[i] != 0u32:
            count = count + 1
        i = i + 1
    count

fn pixel_stats(pixels: [u32]) -> (i64, i64):
    var nonzero = 0i64
    var checksum = 0i64
    var i = 0
    val n = pixels.len()
    while i < n:
        val pixel = pixels[i]
        if pixel != 0u32:
            nonzero = nonzero + 1
        checksum = checksum + (pixel.to_i64() & 0xFFFFFFFF)
        i = i + 1
    (nonzero, checksum)

fn write_widget_event_evidence(path: text, backend: text, source: text,
                               backend_handle: i64, initial_checksum: i64,
                               interaction_checksum: i64, keyboard_events: i64,
                               pointer_events: i64, click_events: i64,
                               interaction_revision: i64) -> bool:
    if path == "":
        return true
    file_write(path,
        "widget_showcase_event_backend={backend}\n" +
        "widget_showcase_event_source={source}\n" +
        "widget_showcase_event_backend_handle={backend_handle}\n" +
        "widget_showcase_event_initial_checksum={initial_checksum}\n" +
        "widget_showcase_event_interaction_checksum={interaction_checksum}\n" +
        "widget_showcase_event_keyboard_events={keyboard_events}\n" +
        "widget_showcase_event_pointer_events={pointer_events}\n" +
        "widget_showcase_event_click_events={click_events}\n" +
        "widget_showcase_event_interaction_revision={interaction_revision}\n")

fn run_widget_showcase_perf_probe(w: i32, h: i32, frames: i64, prefix: text) -> i64:
    var b = Engine2D.create_with_backend(w, h, showcase_backend_key())
    b = draw_frame(b, w, h, showcase_state_default())
    val frame_start_us = time_now_micros()
    var frame = 0
    while frame < frames:
        b.present()
        frame = frame + 1
    val frame_elapsed_ns = (time_now_micros() - frame_start_us) * 1000
    val pixels = b.read_pixels()
    val stats = pixel_stats(pixels)
    val nonzero = stats.0
    val checksum = stats.1
    val pixel_count = pixels.len()
    val ok = pixel_count >= w * h
    print "{prefix}_width={w}"
    print "{prefix}_height={h}"
    print "{prefix}_frames={frames}"
    print "{prefix}_frame_elapsed_ns={frame_elapsed_ns}"
    print "{prefix}_redraw_frames=1"
    print "{prefix}_render_mode=retained-static-frame"
    print "{prefix}_pixels={pixel_count}"
    print "{prefix}_nonzero_pixels={nonzero}"
    print "{prefix}_checksum={checksum}"
    print "{prefix}_readback_status=full-scan"
    print "{prefix}_status={if ok and nonzero > 0: \"pass\" else: \"fail\"}"
    return if ok and nonzero > 0: 0 else: 1

fn run_4k_perf_probe() -> i64:
    run_widget_showcase_perf_probe(3840, 2160, 200, "gui_showcase_4k_perf")

fn run_8k_perf_probe() -> i64:
    run_widget_showcase_perf_probe(7680, 4320, 200, "gui_showcase_8k_perf")

fn write_frame_ppm(path: text, pixels: [u32], w: i32, h: i32):
    if path == "":
        return
    val bytes = encode_ppm_p6(w.to_u32(), h.to_u32(), pixels)
    if file_write_bytes(path, bytes):
        print "wrote {path} ({w}x{h}, {bytes.len()} bytes)"
    else:
        print "failed to write {path}"

# Count differing pixels inside a rect (clamped to the frame).
fn count_diffs_rect(before: [u32], after: [u32], w: i32, h: i32, rx: i32, ry: i32, rw: i32, rh: i32) -> i64:
    var x0 = rx
    if x0 < 0:
        x0 = 0
    var y0 = ry
    if y0 < 0:
        y0 = 0
    var x1 = rx + rw
    if x1 > w:
        x1 = w
    var y1 = ry + rh
    if y1 > h:
        y1 = h
    var count = 0i64
    var y = y0
    while y < y1:
        var x = x0
        while x < x1:
            if before[y * w + x] != after[y * w + x]:
                count = count + 1
            x = x + 1
        y = y + 1
    count

fn count_diffs_all(before: [u32], after: [u32]) -> i64:
    var count = 0i64
    var i = 0
    val n = before.len()
    while i < n:
        if before[i] != after[i]:
            count = count + 1
        i = i + 1
    count

# Offscreen event-driven mode (W1/G1.5): render a baseline frame, apply each
# synthetic event with a re-render, then verify the before/after frames differ
# ONLY inside the targeted widgets' grid cells (region-scoped oracle).
fn run_showcase_events(w: i32, h: i32, events_raw: text) -> i64:
    var st = showcase_state_default()
    val before = build_frame_state(w, h, st)
    if before.len() < w * h:
        return 1
    write_frame_ppm(env_get("SHOWCASE_BEFORE_PPM") ?? "", before, w, h)

    val events = events_raw.split(",")
    var after: [u32] = before
    var applied: [text] = []
    for ev in events:
        if ev == "":
            continue
        st = apply_showcase_event(st, ev)
        after = build_frame_state(w, h, st)
        applied.push(ev)
        print "showcase_event_applied={ev}"
    write_frame_ppm(env_get("SHOWCASE_AFTER_PPM") ?? "", after, w, h)

    val gp = grid_params(w, h)
    val rows = gp.0
    val col_w = gp.1
    val step = gp.2
    val header = gp.3
    var fails = 0
    var region_total = 0i64
    for ev in applied:
        val idx = showcase_event_cell(ev)
        if idx < 0:
            print "FAIL showcase_event={ev} reason=unknown-event"
            fails = fails + 1
            continue
        val p = cell_pos(idx, rows, col_w, header, step)
        val rx = p.0
        val ry = p.1
        val d = count_diffs_rect(before, after, w, h, rx, ry, col_w, step)
        region_total = region_total + d
        if d > 0:
            print "PASS showcase_event={ev} region=({rx},{ry},{col_w},{step}) diff={d}"
        else:
            print "FAIL showcase_event={ev} region=({rx},{ry},{col_w},{step}) diff=0"
            fails = fails + 1
    val total = count_diffs_all(before, after)
    val outside = total - region_total
    if outside == 0:
        print "PASS showcase_event_outside diff=0"
    else:
        print "FAIL showcase_event_outside diff={outside}"
        fails = fails + 1
    if fails == 0:
        print "PASS showcase_event_overall events={applied.len()}"
        return 0
    print "FAIL showcase_event_overall fails={fails}"
    1

fn pack(src: [u32]) -> [i64]:
    var out: [i64] = alloc_i64(src.len().to_i64())
    var i = 0
    val n = src.len()
    while i < n:
        out[i] = src[i].to_i64() & 0xFFFFFF
        i = i + 1
    out

fn showcase_should_close(input: WinitInput) -> bool:
    if input.close:
        return true
    for k in input.keys:
        if k == 27 or k == 113 or k == 81:
            return true
    false

fn wm_env_path_or(default_path: text, key: text) -> text:
    val raw = env_get(key) ?? ""
    if raw == "":
        return default_path
    raw

fn write_wm_frame(frame_path: text, seq_path: text, seq: i64, frame_w: i32, frame_h: i32, pixels: [u32]) -> bool:
    val frame_bytes = encode_ppm_p6(frame_w.to_u32(), frame_h.to_u32(), pixels)
    if frame_bytes.len() == 0 or not file_write_bytes(frame_path, frame_bytes):
        return false
    file_write(seq_path, seq.to_text())

fn write_wm_state(state_path: text, state: ShowcaseState, event_seq: i64, frame_seq: i64, frame_scale: i32) -> bool:
    file_write(state_path,
        "frame_seq={frame_seq}\n" +
        "event_seq={event_seq}\n" +
        "frame_scale={frame_scale}\n" +
        "button_count={state.button_count}\n" +
        "checkbox_on={state.checkbox_on}\n" +
        "switch_on={state.switch_on}\n" +
        "slider_value={state.slider_value}\n" +
        "progress_value={state.progress_value}\n")

fn consume_wm_event(event_path: text, last_seq: i64, state: ShowcaseState, coord_scale: i32) -> (ShowcaseState, i64, bool):
    if event_path == "":
        return (state, last_seq, false)
    val next_seq_path = wm_fs_app_event_seq_path(event_path, last_seq + 1)
    var body = ""
    if file_exists(next_seq_path):
        body = file_read(next_seq_path)
    elif file_exists(event_path):
        body = file_read(event_path)
    if body == "":
        return (state, last_seq, false)
    val ev = wm_fs_app_event_decode(body)
    if ev.seq <= last_seq:
        return (state, last_seq, false)
    var next_state = showcase_on_pointer(state, ev.kind, ev.x * coord_scale, ev.y * coord_scale, ev.pressed)
    if coord_scale > 1 and showcase_state_same(next_state, state):
        next_state = showcase_on_pointer(state, ev.kind, ev.x, ev.y, ev.pressed)
    (next_state, ev.seq, not showcase_state_same(next_state, state))

fn build_wm_pixels(w: i32, h: i32, state: ShowcaseState, frame_scale: i32) -> [u32]:
    # Render DIRECTLY at the output size instead of rendering the full 4K
    # design frame and downsampling: the interpreted 4K render takes >>300s,
    # so the WM client never reached its bridge post (silent host-side
    # child-bridge-timeout, 2026-07-18). build_frame_state scales honestly
    # to any target size.
    if frame_scale > 1:
        return build_frame_state(w / frame_scale, h / frame_scale, state)
    build_frame_state(w, h, state)

fn run_wm_client() -> i64:
    val bridge_path = env_get(WM_BRIDGE_FILE_ENV) ?? ""
    val frame_path = env_get(WM_FRAME_FILE_ENV) ?? ""
    if bridge_path == "" or frame_path == "":
        print "[wm-showcase-client] error=missing-bridge-env"
        return 2
    val event_path = wm_env_path_or(wm_widget_showcase_event_path(frame_path), WM_EVENT_FILE_ENV)
    val seq_path = wm_env_path_or(wm_widget_showcase_frame_seq_path(frame_path), WM_FRAME_SEQ_FILE_ENV)
    val state_path = frame_path + ".state"
    var state = showcase_state_default()
    val _tree = showcase_ui_tree(state)
    var frame_seq = 1
    val frame_scale = showcase_ppm_scale()
    val frame_w = W / frame_scale
    val frame_h = H / frame_scale
    # Bridge FIRST, frame second: the host's window/bridge wait must not sit
    # behind the (interpreted, slow) first render. Dimensions are known
    # up-front; the host polls frame_seq separately and tolerates the first
    # frame arriving after the window opens.
    val pid = getpid()
    val req = wm_widget_showcase_bridge_request_sized(pid, frame_path, frame_w + 8, frame_h + 32)
    if not file_write(bridge_path, wm_fs_bridge_encode(req)):
        print "[wm-showcase-client] error=bridge-write-failed path={bridge_path}"
        return 1
    val pixels = build_wm_pixels(W, H, state, frame_scale)
    if pixels.len() < frame_w * frame_h or not write_wm_frame(frame_path, seq_path, frame_seq, frame_w, frame_h, pixels):
        print "[wm-showcase-client] error=frame-write-failed path={frame_path}"
        return 1
    write_wm_state(state_path, state, 0, frame_seq, frame_scale)
    wm_client_log("[wm-showcase-client] source={WIDGET_SHOWCASE_APP_SOURCE} pid={pid} bridge={bridge_path} frame={frame_path} event={event_path} seq={seq_path}")
    if (env_get(WM_CLIENT_HOLD_ENV) ?? "") == "1":
        var ticks = 0
        var last_event_seq = 0
        while ticks < 2000000:
            var drain = 0
            var consumed_event = false
            var render_dirty = false
            while drain < WM_CLIENT_DRAIN_LIMIT:
                val (event_state, event_seq, event_dirty) = consume_wm_event(event_path, last_event_seq, state, frame_scale)
                if event_seq <= last_event_seq:
                    drain = WM_CLIENT_DRAIN_LIMIT
                else:
                    consumed_event = true
                    last_event_seq = event_seq
                    if event_dirty:
                        state = event_state
                        render_dirty = true
                    drain = drain + 1
            if render_dirty:
                frame_seq = frame_seq + 1
                val next_pixels = build_wm_pixels(W, H, state, frame_scale)
                if next_pixels.len() < frame_w * frame_h or not write_wm_frame(frame_path, seq_path, frame_seq, frame_w, frame_h, next_pixels):
                    print "[wm-showcase-client] error=frame-refresh-failed path={frame_path}"
                    return 1
                write_wm_state(state_path, state, last_event_seq, frame_seq, frame_scale)
                wm_client_log("[wm-showcase-client] frame seq={frame_seq} event_seq={last_event_seq} clicks={state.button_count} checkbox={state.checkbox_on} switch={state.switch_on} slider={state.slider_value} progress={state.progress_value}")
            elif consumed_event:
                write_wm_state(state_path, state, last_event_seq, frame_seq, frame_scale)
            if consumed_event:
                thread_sleep(1)
            else:
                thread_sleep(30)
            ticks = ticks + 1
    0

fn apply_native_input(input: WinitInput, mouse_x: i32, mouse_y: i32, state: ShowcaseState) -> (ShowcaseState, i32, i32, bool, bool):
    var out = state
    var mx = mouse_x
    var my = mouse_y
    var dirty = false
    var running = true
    if showcase_should_close(input):
        running = false
    if input.mouse_x != 0.0 or input.mouse_y != 0.0:
        mx = input.mouse_x.to_i32()
        my = input.mouse_y.to_i32()
        if out.slider_dragging:
            out = showcase_on_pointer(out, "move", mx, my, false)
            dirty = true
    var ci = 0
    while ci < input.click_buttons.len():
        val btn = input.click_buttons[ci]
        val pressed = input.click_pressed[ci]
        if btn == 0:
            var fx = input.click_x[ci].to_i32()
            var fy = input.click_y[ci].to_i32()
            if fx == 0 and fy == 0:
                fx = mx
                fy = my
            else:
                mx = fx
                my = fy
            val kind = if pressed: "down" else: "up"
            out = showcase_on_pointer(out, kind, fx, fy, pressed)
            dirty = true
            print "[widget-showcase] input left_button pressed={pressed} x={fx} y={fy} clicks={out.button_count} checkbox={out.checkbox_on} switch={out.switch_on} slider={out.slider_value}"
        ci = ci + 1
    (out, mx, my, dirty, running)

fn main() -> i64:
    if (env_get("SHOWCASE_4K_PERF") ?? "") == "1":
        return run_4k_perf_probe()
    if (env_get("SHOWCASE_8K_PERF") ?? "") == "1":
        return run_8k_perf_probe()
    if wm_app_mode_is_client(env_get(WM_APP_MODE_ENV) ?? ""):
        return run_wm_client()

    # Frame size: SHOWCASE_RESOLUTION picks the default ("4k" == 3840x2160
    # unless unset/"4k"; "8k" == 7680x4320; or an explicit "WxH"). SHOWCASE_W/
    # SHOWCASE_H (low-res gates) override that default when set.
    val default_wh = showcase_resolution_wh()
    val default_w = default_wh.0
    val default_h = default_wh.1
    val w_raw = env_get("SHOWCASE_W") ?? ""
    val h_raw = env_get("SHOWCASE_H") ?? ""
    val fw0 = (w_raw.parse_i64() ?? default_w.to_i64()).to_i32()
    val fh0 = (h_raw.parse_i64() ?? default_h.to_i64()).to_i32()
    val fw = if fw0 < 64: default_w else: fw0
    val fh = if fh0 < 64: default_h else: fh0

    emit_renderer_log(showcase_backend_key(), fw, fh)

    # Synthetic event mode: offscreen only, no winit (W1/G1.5).
    val events_raw = env_get("SHOWCASE_EVENTS") ?? ""
    if events_raw != "":
        print "Widget showcase GUI — synthetic event mode {fw}x{fh}"
        return run_showcase_events(fw, fh, events_raw)

    print "Widget showcase GUI — render {fw}x{fh} via Engine2D {showcase_backend_key()} lane"
    var state = showcase_state_default()
    val _tree = showcase_ui_tree(state)
    # ONE persistent render session for the app's whole lifetime (created once,
    # reused across every redraw, shut down on every exit path) — never a
    # per-frame create. For metal this keeps the GPU device/queue/framebuffer
    # alive across frames.
    var engine = showcase_engine_create(fw, fh)
    val (engine_after_first, pixels) = build_frame_state_into(engine, fw, fh, state)
    engine = engine_after_first
    if pixels.len() < fw * fh:
        engine.shutdown()
        return 1
    # Honest frame provenance (one line, greppable): for metal this must say
    # source=device_readback — a cpu_mirror source means the GPU lane silently
    # fell back and must not be presented as GPU rendering.
    val prov = engine.read_pixels_with_source()
    print "showcase_frame_backend={engine.backend_name()};source={prov.source};checksum={prov.checksum}"
    print "rendered {pixels.len()} px (24 widget types)"

    # Capture the framebuffer to a P6 PPM (absolute oracle) when SHOWCASE_PPM is set.
    val ppm_path = env_get("SHOWCASE_PPM") ?? ""
    if ppm_path != "":
        val scale = showcase_ppm_scale()
        val ppm_pixels = downsample_nearest(pixels, fw, fh, scale)
        val ppm_w = fw / scale
        val ppm_h = fh / scale
        val bytes = encode_ppm_p6(ppm_w.to_u32(), ppm_h.to_u32(), ppm_pixels)
        if file_write_bytes(ppm_path, bytes):
            print "wrote {ppm_path} ({ppm_w}x{ppm_h}, {bytes.len()} bytes)"
        else:
            print "failed to write {ppm_path}"

    if (env_get("SIMPLE_GUI") ?? "") != "1":
        print "No GUI requested (use scripts/gui/macos-gui-run.shs to open a window); headless only."
        engine.shutdown()
        return 0

    val lp = winit_loop_new()
    if not lp.is_valid:
        print "No GUI runtime available."
        engine.shutdown()
        return 1
    val win = winit_window_new(lp, fw.to_i64(), fh.to_i64(), "Simple Widget Showcase (CPU lane)")
    if not win.is_valid:
        winit_loop_free(lp)
        engine.shutdown()
        return 1

    var packed = pack(pixels)
    var running = true
    var iters = 0
    var mouse_x = 0
    var mouse_y = 0
    var last_tick = time_now_micros()
    val event_path = env_get("SIMPLE_GUI_EVENT_EVIDENCE_PATH") ?? ""
    val exit_after_interaction = (env_get("SIMPLE_GUI_EXIT_AFTER_INTERACTION") ?? "") == "1"
    var keyboard_events: i64 = 0
    var pointer_events: i64 = 0
    var click_events: i64 = 0
    var interaction_revision: i64 = 0
    var interaction_checksum = prov.checksum
    var current_source = prov.source
    var current_handle = prov.backend_handle
    # GUI-5a: present once up front so the initial frame is shown, then only
    # on dirty — avoids presenting the unchanged frame on every ~30ms tick.
    winit_present_rgba(win, fw.to_i64(), fh.to_i64(), packed)
    if not write_widget_event_evidence(
            event_path, engine.backend_name(), current_source, current_handle,
            prov.checksum, interaction_checksum, keyboard_events,
            pointer_events, click_events, interaction_revision):
        winit_window_free(win)
        winit_loop_free(lp)
        engine.shutdown()
        return 1
    while running and iters < 2000000:
        val input = winit_poll_input(lp)
        val (next_state, next_mx, next_my, input_dirty, next_running) = apply_native_input(input, mouse_x, mouse_y, state)
        state = next_state
        mouse_x = next_mx
        mouse_y = next_my
        running = next_running
        var dirty = input_dirty
        val keyboard_delta = input.keys.len().to_i64()
        val pointer_delta = input.mouse_moves
        val click_delta = input.click_buttons.len().to_i64()
        keyboard_events = keyboard_events + keyboard_delta
        pointer_events = pointer_events + pointer_delta
        click_events = click_events + click_delta
        val real_input = keyboard_delta > 0 or pointer_delta > 0 or click_delta > 0
        if real_input:
            interaction_revision = interaction_revision + 1
            # Every real input batch changes a visible widget, including a
            # pointer move or click outside a widget's ordinary hit target.
            state.progress_value = (state.progress_value + 7) % 101
            dirty = true
        val now = time_now_micros()
        if now - last_tick >= 500000:
            state = showcase_on_tick(state)
            last_tick = now
            dirty = true
        if dirty:
            # Repaint into the SAME persistent session (no create/shutdown per
            # redraw — the session-reuse delta is measured in the gpu-offload
            # evidence harness).
            val (engine_after_redraw, next_pixels) = build_frame_state_into(engine, fw, fh, state)
            engine = engine_after_redraw
            if next_pixels.len() < fw * fh:
                winit_window_free(win)
                winit_loop_free(lp)
                engine.shutdown()
                return 1
            packed = pack(next_pixels)
            winit_present_rgba(win, fw.to_i64(), fh.to_i64(), packed)
            if real_input:
                val interaction_prov = engine.read_pixels_with_source()
                interaction_checksum = interaction_prov.checksum
                current_source = interaction_prov.source
                current_handle = interaction_prov.backend_handle
                if (current_source != prov.source or
                        current_handle != prov.backend_handle or
                        interaction_checksum == prov.checksum or
                        not write_widget_event_evidence(
                            event_path, engine.backend_name(), current_source,
                            current_handle, prov.checksum, interaction_checksum,
                            keyboard_events, pointer_events, click_events,
                            interaction_revision)):
                    winit_window_free(win)
                    winit_loop_free(lp)
                    engine.shutdown()
                    return 1
                print "widget_showcase_event_revision={interaction_revision}"
                print "widget_showcase_event_checksum={interaction_checksum}"
                if (exit_after_interaction and keyboard_events > 0 and
                        pointer_events > 0 and click_events > 0):
                    running = false
        thread_sleep(30)
        iters = iters + 1
    winit_window_free(win)
    winit_loop_free(lp)
    engine.shutdown()
    return 0
