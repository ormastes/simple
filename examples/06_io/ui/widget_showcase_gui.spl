# widget_showcase_gui.spl — GUI sanity app: a comprehensive gallery of the
# common UI widgets drawn directly on the pure-Simple Engine2D CPU lane and
# presented to an on-screen window.
#
# This is one of the three main GUI check apps (see .claude/skills/lib/spipe_ui.md):
#   1. 2D rendering  — engine2d_shapes_gui.spl
#   2. GUI widgets   — THIS app
#   3. HTML rendering — web_render_file_gui.spl
#
# Draws widgets with engine2d primitives (rect/rounded_rect/line/circle/triangle/
# text) rather than the web layout path, so it renders fast and is a reliable
# visual sanity check of widget chrome + legible glyph text on the CPU lane.
#
# Launch (window):
#   SIMPLE_GUI_RUN_SKIP_NUDGE=1 scripts/gui/macos-gui-run.shs examples/06_io/ui/widget_showcase_gui.spl
# Headless: bin/simple run examples/06_io/ui/widget_showcase_gui.spl

use std.gpu.engine2d.engine.{Engine2D}
use std.io.window_winit.{WinitLoop, WinitWindow, WinitInput, winit_loop_new, winit_loop_free, winit_window_new, winit_window_free, winit_present_rgba, winit_poll_input}
use std.common.image.ppm_decode.{encode_ppm_p6}
use std.nogc_sync_mut.sffi.io.{file_write_bytes}
use std.io_runtime.{file_write, file_exists, file_read, getpid}
use std.nogc_sync_mut.io.time_ops.{time_now_micros}
use std.nogc_sync_mut.io.env_ops.{env_get}
use std.nogc_sync_mut.concurrent.thread.{thread_sleep}
use common.ui.widget.{UITree, WidgetNode}
use common.ui.wm_app_process_contract.{WM_APP_MODE_ENV, WM_BRIDGE_FILE_ENV, WM_FRAME_FILE_ENV, WM_EVENT_FILE_ENV, WM_FRAME_SEQ_FILE_ENV, WM_CLIENT_HOLD_ENV, WIDGET_SHOWCASE_APP_SOURCE, wm_app_mode_is_client, wm_widget_showcase_bridge_request_sized, wm_fs_bridge_encode, wm_widget_showcase_event_path, wm_widget_showcase_frame_seq_path, wm_fs_app_event_decode, wm_fs_app_event_seq_path}

val W: i32 = 520
val H: i32 = 660

# Palette
val BG: u32 = 0xFF14141Cu32
val CARD: u32 = 0xFF1E1E28u32
val FG: u32 = 0xFFE6E6F0u32
val MUTED: u32 = 0xFF8A8A9Au32
val LINE: u32 = 0xFF34343Eu32
val ACCENT: u32 = 0xFF3B82F6u32
val ACCENT_D: u32 = 0xFF1D4ED8u32
val GREEN: u32 = 0xFF22C55Eu32
val RED: u32 = 0xFFEF4444u32
val AMBER: u32 = 0xFFF59E0Bu32
val WHITE: u32 = 0xFFFFFFFFu32
val TRACK: u32 = 0xFF2A2A38u32

# ponytail: native rounded-rect emulation crashes in this compiled perf gate; plain rects keep the widget evidence alive.

# Interactive widget state driven by synthetic SHOWCASE_EVENTS (W1/G1.5).
# Defaults reproduce the historical static frame exactly.
struct ShowcaseState:
    button_count: i32
    button_pressed: bool
    checkbox_on: bool
    switch_on: bool
    slider_value: i32
    progress_value: i32
    slider_dragging: bool

fn showcase_state_default() -> ShowcaseState:
    ShowcaseState(button_count: 0, button_pressed: false, checkbox_on: true, switch_on: true, slider_value: 60, progress_value: 62, slider_dragging: false)

fn showcase_ui_tree(st: ShowcaseState) -> UITree:
    var root = WidgetNode.new("showcase_root", "panel")
    root = root.set_layout("vbox")
    root = root.set_prop("title", "Widget Showcase")
    root = root.set_prop("theme", "simple")

    var button_node = WidgetNode.new("showcase_button", "button")
    button_node = button_node.set_prop("label", "Clicks {st.button_count}")
    button_node = button_node.set_prop("action", "click:button")
    root = root.add_child(button_node)

    var checkbox_node = WidgetNode.new("showcase_checkbox", "checkbox")
    checkbox_node = checkbox_node.set_prop("label", "On")
    var checkbox_checked = "false"
    if st.checkbox_on:
        checkbox_checked = "true"
    checkbox_node = checkbox_node.set_prop("checked", checkbox_checked)
    root = root.add_child(checkbox_node)

    var switch_node = WidgetNode.new("showcase_switch", "switch")
    switch_node = switch_node.set_prop("label", "Switch")
    var switch_checked = "false"
    if st.switch_on:
        switch_checked = "true"
    switch_node = switch_node.set_prop("checked", switch_checked)
    root = root.add_child(switch_node)

    var slider_node = WidgetNode.new("showcase_slider", "progress")
    slider_node = slider_node.set_prop("value", "{st.slider_value}")
    root = root.add_child(slider_node)

    var progress_node = WidgetNode.new("showcase_progress", "progress")
    progress_node = progress_node.set_prop("value", "{st.progress_value}")
    root = root.add_child(progress_node)

    var status_node = WidgetNode.new("showcase_status", "statusbar")
    status_node = status_node.set_prop("left", "Ready clicks={st.button_count} slider={st.slider_value}% progress={st.progress_value}%")
    status_node = status_node.set_prop("right", "Ln 1, Col 1")
    root = root.add_child(status_node)
    UITree.new(root)

# Pure reducer: one synthetic event -> new state (widget_interact_model style).
fn apply_showcase_event(st: ShowcaseState, ev: text) -> ShowcaseState:
    if ev == "click:button":
        return ShowcaseState(button_count: st.button_count + 1, button_pressed: not st.button_pressed, checkbox_on: st.checkbox_on, switch_on: st.switch_on, slider_value: st.slider_value, progress_value: st.progress_value, slider_dragging: false)
    if ev == "toggle:switch":
        return ShowcaseState(button_count: st.button_count, button_pressed: st.button_pressed, checkbox_on: st.checkbox_on, switch_on: not st.switch_on, slider_value: st.slider_value, progress_value: st.progress_value, slider_dragging: false)
    if ev == "advance:progress":
        var pct = st.progress_value + 20
        if pct > 100:
            pct = 100
        return ShowcaseState(button_count: st.button_count, button_pressed: st.button_pressed, checkbox_on: st.checkbox_on, switch_on: st.switch_on, slider_value: st.slider_value, progress_value: pct, slider_dragging: false)
    print "unknown showcase event: {ev}"
    st

fn clamp_i32(v: i32, lo: i32, hi: i32) -> i32:
    if v < lo:
        return lo
    if v > hi:
        return hi
    v

fn hit_rect(px: i32, py: i32, x: i32, y: i32, w: i32, h: i32) -> bool:
    px >= x and px < x + w and py >= y and py < y + h

fn slider_value_from_x(local_x: i32) -> i32:
    val slider_x = 268
    val rel = clamp_i32(local_x - slider_x, 0, 130)
    rel * 100 / 130

fn showcase_on_tick(state: ShowcaseState) -> ShowcaseState:
    var out = state
    out.progress_value = (out.progress_value + 2) % 101
    out

fn showcase_on_pointer(state: ShowcaseState, kind: text, x: i32, y: i32, pressed: bool) -> ShowcaseState:
    if kind == "tick":
        return showcase_on_tick(state)
    var out = state
    if kind == "down" and pressed and hit_rect(x, y, 12, 56, 60, 18):
        out.button_pressed = true
    if kind == "down" and pressed and hit_rect(x, y, 268, 186, 130, 28):
        out.slider_dragging = true
        out.slider_value = slider_value_from_x(x)
    elif kind == "move" and out.slider_dragging:
        out.slider_value = slider_value_from_x(x)
    elif kind == "up":
        if hit_rect(x, y, 12, 56, 60, 18):
            out.button_count = out.button_count + 1
        if hit_rect(x, y, 268, 58, 120, 22):
            out.checkbox_on = not out.checkbox_on
        if hit_rect(x, y, 12, 124, 78, 18):
            out.switch_on = not out.switch_on
        out.button_pressed = false
        if out.slider_dragging:
            out.slider_value = slider_value_from_x(x)
        out.slider_dragging = false
    out

fn showcase_state_same(a: ShowcaseState, b: ShowcaseState) -> bool:
    a.button_count == b.button_count and
    a.button_pressed == b.button_pressed and
    a.checkbox_on == b.checkbox_on and
    a.switch_on == b.switch_on and
    a.slider_value == b.slider_value and
    a.progress_value == b.progress_value and
    a.slider_dragging == b.slider_dragging

# Grid cell index of the widget an event targets (-1 = unknown).
fn showcase_event_cell(ev: text) -> i32:
    if ev == "click:button":
        return 0
    if ev == "toggle:switch":
        return 1
    if ev == "advance:progress":
        return 3
    -1

# section label above each widget cell
fn label(b: Engine2D, x: i32, y: i32, name: text):
    b.draw_text(x, y, name, MUTED, 6)

fn w_button(b: Engine2D, x: i32, y: i32, pressed: bool):
    label(b, x, y, "Button")
    if pressed:
        b.draw_rect_filled(x, y + 10, 60, 18, ACCENT_D)
        b.draw_rect(x, y + 10, 60, 18, WHITE)
        b.draw_text(x + 16, y + 15, "Run", AMBER, 7)
    else:
        b.draw_rect_filled(x, y + 10, 60, 18, ACCENT)
        b.draw_rect(x, y + 10, 60, 18, ACCENT_D)
        b.draw_text(x + 16, y + 15, "Run", WHITE, 7)
    # secondary (outline)
    b.draw_rect(x + 70, y + 10, 60, 18, MUTED)
    b.draw_text(x + 82, y + 15, "Cancel", FG, 7)

fn w_checkbox(b: Engine2D, x: i32, y: i32, st: ShowcaseState):
    label(b, x, y, "Checkbox / Radio")
    b.draw_rect(x, y + 12, 13, 13, MUTED)
    if st.checkbox_on:
        b.draw_rect_filled(x + 3, y + 15, 7, 7, GREEN)
    b.draw_text(x + 18, y + 14, "On", FG, 7)
    b.draw_rect(x + 50, y + 12, 13, 13, MUTED)
    if not st.checkbox_on:
        b.draw_rect_filled(x + 53, y + 15, 7, 7, AMBER)
    b.draw_text(x + 68, y + 14, "Off", FG, 7)
    # radio
    b.draw_circle(x + 100, y + 18, 7, MUTED)
    b.draw_circle_filled(x + 100, y + 18, 3, ACCENT)
    b.draw_circle(x + 124, y + 18, 7, MUTED)

fn w_switch(b: Engine2D, x: i32, y: i32, on: bool):
    label(b, x, y, "Toggle switch")
    # first switch reflects state
    if on:
        b.draw_rect_filled(x, y + 12, 34, 16, GREEN)
        b.draw_circle_filled(x + 26, y + 20, 6, WHITE)
    else:
        b.draw_rect_filled(x, y + 12, 34, 16, TRACK)
        b.draw_circle_filled(x + 8, y + 20, 6, MUTED)
    # second stays off (static reference)
    b.draw_rect_filled(x + 44, y + 12, 34, 16, TRACK)
    b.draw_circle_filled(x + 52, y + 20, 6, MUTED)

fn w_input(b: Engine2D, x: i32, y: i32):
    label(b, x, y, "Text input")
    b.draw_rect(x, y + 11, 150, 18, MUTED)
    b.draw_text(x + 5, y + 16, "name...", MUTED, 7)

fn w_dropdown(b: Engine2D, x: i32, y: i32):
    label(b, x, y, "Dropdown")
    b.draw_rect(x, y + 11, 130, 18, MUTED)
    b.draw_text(x + 5, y + 16, "Option A", FG, 7)
    b.draw_triangle_filled(x + 116, y + 16, x + 124, y + 16, x + 120, y + 22, FG)

fn w_slider(b: Engine2D, x: i32, y: i32, st: ShowcaseState):
    label(b, x, y, "Slider")
    val fill = 130 * st.slider_value / 100
    b.draw_rect_filled(x, y + 18, 130, 4, TRACK)
    b.draw_rect_filled(x, y + 18, fill, 4, ACCENT)
    b.draw_circle_filled(x + fill, y + 20, 6, WHITE)

fn w_progress(b: Engine2D, x: i32, y: i32, pct: i32):
    label(b, x, y, "Progress")
    b.draw_rect_filled(x, y + 14, 130, 10, TRACK)
    b.draw_rect_filled(x, y + 14, 130 * pct / 100, 10, ACCENT)
    b.draw_text(x + 136, y + 14, "{pct}%", MUTED, 6)

fn w_search(b: Engine2D, x: i32, y: i32):
    label(b, x, y, "Search bar")
    b.draw_rect(x, y + 11, 150, 18, MUTED)
    b.draw_circle(x + 12, y + 19, 4, MUTED)
    b.draw_line(x + 15, y + 22, x + 19, y + 26, MUTED, 1)
    b.draw_text(x + 24, y + 16, "Search...", MUTED, 7)

fn w_tabs(b: Engine2D, x: i32, y: i32):
    label(b, x, y, "Tabs")
    b.draw_text(x + 4, y + 14, "Home", FG, 7)
    b.draw_text(x + 44, y + 14, "Edit", MUTED, 7)
    b.draw_text(x + 80, y + 14, "View", MUTED, 7)
    b.draw_rect_filled(x + 2, y + 26, 32, 2, ACCENT)
    b.draw_line(x, y + 27, x + 150, y + 27, LINE, 1)

fn w_segmented(b: Engine2D, x: i32, y: i32):
    label(b, x, y, "Segmented")
    b.draw_rect(x, y + 11, 120, 18, MUTED)
    b.draw_rect_filled(x + 2, y + 13, 38, 14, ACCENT)
    b.draw_text(x + 8, y + 16, "Day", WHITE, 6)
    b.draw_text(x + 50, y + 16, "Week", MUTED, 6)
    b.draw_text(x + 90, y + 16, "Mo", MUTED, 6)

fn w_list(b: Engine2D, x: i32, y: i32):
    label(b, x, y, "List")
    b.draw_text(x + 2, y + 14, "- First item", FG, 7)
    b.draw_text(x + 2, y + 26, "- Second item", FG, 7)
    b.draw_text(x + 2, y + 38, "- Third item", MUTED, 7)

fn w_tree(b: Engine2D, x: i32, y: i32):
    label(b, x, y, "Tree")
    b.draw_triangle_filled(x + 2, y + 12, x + 2, y + 20, x + 8, y + 16, FG)
    b.draw_text(x + 12, y + 13, "src", FG, 7)
    b.draw_text(x + 22, y + 26, "main.spl", MUTED, 7)
    b.draw_text(x + 22, y + 38, "lib.spl", MUTED, 7)

fn w_table(b: Engine2D, x: i32, y: i32):
    label(b, x, y, "Table")
    b.draw_rect_filled(x, y + 11, 150, 12, TRACK)
    b.draw_text(x + 4, y + 13, "Name", FG, 6)
    b.draw_text(x + 80, y + 13, "Size", FG, 6)
    b.draw_text(x + 4, y + 27, "a.spl", MUTED, 6)
    b.draw_text(x + 80, y + 27, "1.2k", MUTED, 6)
    b.draw_text(x + 4, y + 39, "b.spl", MUTED, 6)
    b.draw_text(x + 80, y + 39, "3.4k", MUTED, 6)
    b.draw_line(x, y + 23, x + 150, y + 23, LINE, 1)
    b.draw_line(x + 74, y + 11, x + 74, y + 48, LINE, 1)

fn w_card(b: Engine2D, x: i32, y: i32):
    label(b, x, y, "Card")
    b.draw_rect_filled(x + 3, y + 14, 130, 44, 0xFF0C0C12u32)
    b.draw_rect(x, y + 11, 130, 44, LINE)
    b.draw_rect_filled(x + 1, y + 12, 128, 42, CARD)
    b.draw_text(x + 8, y + 18, "Title", FG, 7)
    b.draw_text(x + 8, y + 32, "Body text here", MUTED, 6)

fn w_chip(b: Engine2D, x: i32, y: i32):
    label(b, x, y, "Badge / Chip")
    b.draw_rect_filled(x, y + 12, 40, 14, GREEN)
    b.draw_text(x + 8, y + 14, "New", WHITE, 6)
    b.draw_rect_filled(x + 48, y + 12, 44, 14, AMBER)
    b.draw_text(x + 55, y + 14, "Beta", 0xFF1A1A1Au32, 6)

fn w_tooltip(b: Engine2D, x: i32, y: i32):
    label(b, x, y, "Tooltip")
    b.draw_rect_filled(x, y + 12, 88, 18, 0xFF2D2D3Au32)
    b.draw_text(x + 6, y + 17, "Helpful hint", FG, 6)
    b.draw_triangle_filled(x + 12, y + 30, x + 22, y + 30, x + 17, y + 35, 0xFF2D2D3Au32)

fn w_dialog(b: Engine2D, x: i32, y: i32):
    label(b, x, y, "Dialog / Modal")
    b.draw_rect(x, y + 11, 150, 50, LINE)
    b.draw_rect_filled(x + 1, y + 12, 148, 48, CARD)
    b.draw_text(x + 8, y + 17, "Delete file?", FG, 7)
    b.draw_text(x + 8, y + 30, "This cannot be undone.", MUTED, 6)
    b.draw_rect_filled(x + 60, y + 42, 36, 14, TRACK)
    b.draw_text(x + 66, y + 45, "No", FG, 6)
    b.draw_rect_filled(x + 102, y + 42, 40, 14, RED)
    b.draw_text(x + 108, y + 45, "Yes", WHITE, 6)

fn w_scrollbar(b: Engine2D, x: i32, y: i32):
    label(b, x, y, "Scrollbar")
    b.draw_rect_filled(x, y + 11, 8, 60, TRACK)
    b.draw_rect_filled(x, y + 14, 8, 26, MUTED)

fn w_avatar(b: Engine2D, x: i32, y: i32):
    label(b, x, y, "Avatar")
    b.draw_circle_filled(x + 16, y + 26, 14, ACCENT)
    b.draw_text(x + 11, y + 22, "JS", WHITE, 7)

# Column-major cell position: cells flow down a column, then wrap to the
# next. Keeps every widget inside the viewport at low resolutions (G1.3).
fn cell_pos(i: i32, rows: i32, col_w: i32, header: i32, step: i32) -> (i32, i32):
    val c = i / rows
    val r = i % rows
    (12 + c * col_w, header + r * step)

# Grid layout constants shared by draw_frame and the event-diff oracle.
val GRID_HEADER: i32 = 46
val GRID_FOOTER: i32 = 14
val GRID_STEP: i32 = 66
val GRID_CELLS: i32 = 18

# (rows, col_w) for a given viewport — must match draw_frame's grid.
fn grid_params(w: i32, h: i32) -> (i32, i32):
    var rows = (h - GRID_HEADER - GRID_FOOTER) / GRID_STEP
    if rows < 1:
        rows = 1
    val ncols = (GRID_CELLS + rows - 1) / rows
    var col_w = (w - 12) / ncols
    # ponytail: below ~170px columns widgets overlap; accept clipping there
    if col_w < 170:
        col_w = 170
    (rows, col_w)

fn draw_frame(b: Engine2D, w: i32, h: i32, st: ShowcaseState):
    b.clear(BG)
    # menubar
    b.draw_rect_filled(0, 0, w, 16, CARD)
    b.draw_text(6, 4, "File  Edit  View  Help", FG, 7)
    # title
    b.draw_text(8, 22, "Widget Showcase (Simple UI API)", FG, 8)
    b.draw_line(8, 38, w - 8, 38, LINE, 1)

    # Adaptive grid: 18 cells, rows per column from available height,
    # column count from cell count, column width from viewport width.
    val header = GRID_HEADER
    val step = GRID_STEP
    val gp = grid_params(w, h)
    val rows = gp.0
    val col_w = gp.1

    val p0 = cell_pos(0, rows, col_w, header, step)
    w_button(b, p0.0, p0.1, st.button_pressed)
    val p1 = cell_pos(1, rows, col_w, header, step)
    w_switch(b, p1.0, p1.1, st.switch_on)
    val p2 = cell_pos(2, rows, col_w, header, step)
    w_dropdown(b, p2.0, p2.1)
    val p3 = cell_pos(3, rows, col_w, header, step)
    w_progress(b, p3.0, p3.1, st.progress_value)
    val p4 = cell_pos(4, rows, col_w, header, step)
    w_tabs(b, p4.0, p4.1)
    val p5 = cell_pos(5, rows, col_w, header, step)
    w_list(b, p5.0, p5.1)
    val p6 = cell_pos(6, rows, col_w, header, step)
    w_table(b, p6.0, p6.1)
    val p7 = cell_pos(7, rows, col_w, header, step)
    w_chip(b, p7.0, p7.1)
    val p8 = cell_pos(8, rows, col_w, header, step)
    w_dialog(b, p8.0, p8.1)
    val p9 = cell_pos(9, rows, col_w, header, step)
    w_checkbox(b, p9.0, p9.1, st)
    val p10 = cell_pos(10, rows, col_w, header, step)
    w_input(b, p10.0, p10.1)
    val p11 = cell_pos(11, rows, col_w, header, step)
    w_slider(b, p11.0, p11.1, st)
    val p12 = cell_pos(12, rows, col_w, header, step)
    w_search(b, p12.0, p12.1)
    val p13 = cell_pos(13, rows, col_w, header, step)
    w_segmented(b, p13.0, p13.1)
    val p14 = cell_pos(14, rows, col_w, header, step)
    w_tree(b, p14.0, p14.1)
    val p15 = cell_pos(15, rows, col_w, header, step)
    w_card(b, p15.0, p15.1)
    val p16 = cell_pos(16, rows, col_w, header, step)
    w_tooltip(b, p16.0, p16.1)
    val p17 = cell_pos(17, rows, col_w, header, step)
    w_scrollbar(b, p17.0, p17.1)
    w_avatar(b, p17.0 + 76, p17.1)

    # statusbar
    b.draw_rect_filled(0, h - 14, w, 14, CARD)
    b.draw_text(6, h - 11, "Ready clicks={st.button_count} slider={st.slider_value}% progress={st.progress_value}%", MUTED, 6)
    b.draw_text(w - 60, h - 11, "Ln 1, Col 1", MUTED, 6)

fn draw_g1_1_frame(b: Engine2D, w: i32, h: i32, st: ShowcaseState):
    b.clear(BG)
    b.draw_rect_filled(0, 0, w, 16, CARD)
    b.draw_text(6, 4, "File  Edit", FG, 7)
    b.draw_text(8, 22, "Widget Showcase", FG, 8)
    b.draw_line(8, 38, w - 8, 38, LINE, 1)
    w_button(b, 12, 46, st.button_pressed)
    b.draw_rect_filled(0, h - 14, w, 14, CARD)
    b.draw_text(6, h - 11, "Ready", MUTED, 6)

# Rendering backend key. SIMPLE_GUI_BACKEND selects the Engine2D backend
# (e.g. "vulkan"); default "software" keeps the historical CPU-lane behavior
# byte-for-byte (Engine2D "software" delegates to SoftwareBackend).
fn showcase_backend_key() -> text:
    val raw = (env_get("SIMPLE_GUI_BACKEND") ?? "").trim()
    if raw == "":
        return "software"
    raw

# One greppable renderer-provenance line proving which backend + device rendered
# the frame. For vulkan, includes the physical-device diagnostic (lavapipe under
# Xvfb). This is the G1.1 evidence line.
fn emit_renderer_log(key: text, w: i32, h: i32):
    var probe_engine = Engine2D.create_with_backend(64, 64, key)
    val name = probe_engine.backend_name()
    probe_engine.shutdown()
    var device = ""
    if key == "vulkan":
        val probe = Engine2D.probe_backend(64, 64, "vulkan")
        device = probe.diagnostic_text()
    print "showcase_renderer_backend={name};requested={key};vulkan_device={device}"

fn build_frame_state(w: i32, h: i32, st: ShowcaseState) -> [u32]:
    val ui_tree = showcase_ui_tree(st)
    if ui_tree.root_id == "":
        print "invalid Simple UI showcase tree"
        return []
    var b = Engine2D.create_with_backend(w, h, showcase_backend_key())
    if (env_get("SHOWCASE_G1_1_COMPACT") ?? "") == "1":
        draw_g1_1_frame(b, w, h, st)
    else:
        draw_frame(b, w, h, st)
    b.present()
    val pixels = b.read_pixels()
    b.shutdown()
    pixels

fn build_frame_sized(w: i32, h: i32) -> [u32]:
    build_frame_state(w, h, showcase_state_default())

fn build_frame() -> [u32]:
    build_frame_sized(W, H)

fn showcase_ppm_scale() -> i32:
    val raw = env_get("SHOWCASE_PPM_SCALE") ?? ""
    if raw == "8":
        return 8
    if raw == "4":
        return 4
    if raw == "2":
        return 2
    1

fn downsample_nearest(src: [u32], src_w: i32, src_h: i32, scale: i32) -> [u32]:
    if scale <= 1:
        return src
    val dst_w = src_w / scale
    val dst_h = src_h / scale
    var out: [u32] = []
    var y = 0
    while y < dst_h:
        var x = 0
        val sy = y * scale
        while x < dst_w:
            val sx = x * scale
            out.push(src[sy * src_w + sx])
            x = x + 1
        y = y + 1
    out

fn checksum_pixels(pixels: [u32]) -> i64:
    var sum = 0i64
    var i = 0
    val n = pixels.len()
    while i < n:
        sum = sum + (pixels[i].to_i64() & 0xFFFFFFFF)
        i = i + 1
    sum

fn nonzero_pixels(pixels: [u32]) -> i64:
    var count = 0i64
    var i = 0
    val n = pixels.len()
    while i < n:
        if pixels[i] != 0u32:
            count = count + 1
        i = i + 1
    count

fn pixel_stats(pixels: [u32]) -> (i64, i64):
    var nonzero = 0i64
    var checksum = 0i64
    var i = 0
    val n = pixels.len()
    while i < n:
        val pixel = pixels[i]
        if pixel != 0u32:
            nonzero = nonzero + 1
        checksum = checksum + (pixel.to_i64() & 0xFFFFFFFF)
        i = i + 1
    (nonzero, checksum)

fn run_widget_showcase_perf_probe(w: i32, h: i32, frames: i64, prefix: text) -> i64:
    var b = Engine2D.create_with_backend(w, h, showcase_backend_key())
    draw_frame(b, w, h, showcase_state_default())
    val frame_start_us = time_now_micros()
    var frame = 0
    while frame < frames:
        b.present()
        frame = frame + 1
    val frame_elapsed_ns = (time_now_micros() - frame_start_us) * 1000
    val pixels = b.read_pixels()
    val stats = pixel_stats(pixels)
    val nonzero = stats.0
    val checksum = stats.1
    val pixel_count = pixels.len()
    val ok = pixel_count >= w * h
    print "{prefix}_width={w}"
    print "{prefix}_height={h}"
    print "{prefix}_frames={frames}"
    print "{prefix}_frame_elapsed_ns={frame_elapsed_ns}"
    print "{prefix}_redraw_frames=1"
    print "{prefix}_render_mode=retained-static-frame"
    print "{prefix}_pixels={pixel_count}"
    print "{prefix}_nonzero_pixels={nonzero}"
    print "{prefix}_checksum={checksum}"
    print "{prefix}_readback_status=full-scan"
    var status = "fail"
    var code = 1
    if ok and nonzero > 0:
        status = "pass"
        code = 0
    print "{prefix}_status={status}"
    return code

fn run_4k_perf_probe() -> i64:
    run_widget_showcase_perf_probe(3840, 2160, 200, "gui_showcase_4k_perf")

fn run_8k_perf_probe() -> i64:
    run_widget_showcase_perf_probe(7680, 4320, 200, "gui_showcase_8k_perf")

fn write_frame_ppm(path: text, pixels: [u32], w: i32, h: i32):
    if path == "":
        return
    val bytes = encode_ppm_p6(w.to_u32(), h.to_u32(), pixels)
    if file_write_bytes(path, bytes):
        print "wrote {path} ({w}x{h}, {bytes.len()} bytes)"
    else:
        print "failed to write {path}"

# Count differing pixels inside a rect (clamped to the frame).
fn count_diffs_rect(before: [u32], after: [u32], w: i32, h: i32, rx: i32, ry: i32, rw: i32, rh: i32) -> i64:
    var x0 = rx
    if x0 < 0:
        x0 = 0
    var y0 = ry
    if y0 < 0:
        y0 = 0
    var x1 = rx + rw
    if x1 > w:
        x1 = w
    var y1 = ry + rh
    if y1 > h:
        y1 = h
    var count = 0i64
    var y = y0
    while y < y1:
        var x = x0
        while x < x1:
            if before[y * w + x] != after[y * w + x]:
                count = count + 1
            x = x + 1
        y = y + 1
    count

fn count_diffs_all(before: [u32], after: [u32]) -> i64:
    var count = 0i64
    var i = 0
    val n = before.len()
    while i < n:
        if before[i] != after[i]:
            count = count + 1
        i = i + 1
    count

# Offscreen event-driven mode (W1/G1.5): render a baseline frame, apply each
# synthetic event with a re-render, then verify the before/after frames differ
# ONLY inside the targeted widgets' grid cells (region-scoped oracle).
fn run_showcase_events(w: i32, h: i32, events_raw: text) -> i64:
    var st = showcase_state_default()
    val before = build_frame_state(w, h, st)
    if before.len() < w * h:
        return 1
    write_frame_ppm(env_get("SHOWCASE_BEFORE_PPM") ?? "", before, w, h)

    val events = events_raw.split(",")
    var after: [u32] = before
    var applied: [text] = []
    for ev in events:
        if ev == "":
            continue
        st = apply_showcase_event(st, ev)
        after = build_frame_state(w, h, st)
        applied.push(ev)
        print "showcase_event_applied={ev}"
    write_frame_ppm(env_get("SHOWCASE_AFTER_PPM") ?? "", after, w, h)

    val gp = grid_params(w, h)
    val rows = gp.0
    val col_w = gp.1
    var fails = 0
    var region_total = 0i64
    for ev in applied:
        val idx = showcase_event_cell(ev)
        if idx < 0:
            print "FAIL showcase_event={ev} reason=unknown-event"
            fails = fails + 1
            continue
        val p = cell_pos(idx, rows, col_w, GRID_HEADER, GRID_STEP)
        val rx = p.0
        val ry = p.1
        val d = count_diffs_rect(before, after, w, h, rx, ry, col_w, GRID_STEP)
        region_total = region_total + d
        if d > 0:
            print "PASS showcase_event={ev} region=({rx},{ry},{col_w},{GRID_STEP}) diff={d}"
        else:
            print "FAIL showcase_event={ev} region=({rx},{ry},{col_w},{GRID_STEP}) diff=0"
            fails = fails + 1
    val total = count_diffs_all(before, after)
    val outside = total - region_total
    if outside == 0:
        print "PASS showcase_event_outside diff=0"
    else:
        print "FAIL showcase_event_outside diff={outside}"
        fails = fails + 1
    if fails == 0:
        print "PASS showcase_event_overall events={applied.len()}"
        return 0
    print "FAIL showcase_event_overall fails={fails}"
    1

fn pack(src: [u32]) -> [i64]:
    var out: [i64] = []
    var i = 0
    val n = src.len()
    while i < n:
        out.push(src[i].to_i64() & 0xFFFFFF)
        i = i + 1
    out

fn showcase_should_close(input: WinitInput) -> bool:
    if input.close:
        return true
    for k in input.keys:
        if k == 27 or k == 113 or k == 81:
            return true
    false

fn wm_env_path_or(default_path: text, key: text) -> text:
    val raw = env_get(key) ?? ""
    if raw == "":
        return default_path
    raw

fn write_wm_frame(frame_path: text, seq_path: text, seq: i64, frame_w: i32, frame_h: i32, pixels: [u32]) -> bool:
    val frame_bytes = encode_ppm_p6(frame_w.to_u32(), frame_h.to_u32(), pixels)
    if frame_bytes.len() == 0 or not file_write_bytes(frame_path, frame_bytes):
        return false
    file_write(seq_path, seq.to_text())

fn write_wm_state(state_path: text, state: ShowcaseState, event_seq: i64, frame_seq: i64, frame_scale: i32) -> bool:
    file_write(state_path,
        "frame_seq={frame_seq}\n" +
        "event_seq={event_seq}\n" +
        "frame_scale={frame_scale}\n" +
        "button_count={state.button_count}\n" +
        "checkbox_on={state.checkbox_on}\n" +
        "switch_on={state.switch_on}\n" +
        "slider_value={state.slider_value}\n" +
        "progress_value={state.progress_value}\n")

fn consume_wm_event(event_path: text, last_seq: i64, state: ShowcaseState, coord_scale: i32) -> (ShowcaseState, i64, bool):
    if event_path == "" or not file_exists(event_path):
        return (state, last_seq, false)
    var out = state
    var seq = last_seq
    var dirty = false
    var drained = 0
    while drained < 32:
        var body = ""
        val next_path = wm_fs_app_event_seq_path(event_path, seq + 1)
        if file_exists(next_path):
            body = file_read(next_path)
        elif drained == 0:
            body = file_read(event_path)
        if body == "":
            return (out, seq, dirty)
        val ev = wm_fs_app_event_decode(body)
        if ev.seq <= seq:
            return (out, seq, dirty)
        val before_clicks = out.button_count
        val before_checkbox = out.checkbox_on
        val before_switch = out.switch_on
        val before_slider = out.slider_value
        print "[wm-showcase-client] consume_event seq={ev.seq} kind={ev.kind} local={ev.x},{ev.y} pressed={ev.pressed} before_clicks={before_clicks} before_checkbox={before_checkbox} before_switch={before_switch} before_slider={before_slider}"
        val raw_next = showcase_on_pointer(out, ev.kind, ev.x, ev.y, ev.pressed)
        if coord_scale > 1 and showcase_state_same(raw_next, out):
            out = showcase_on_pointer(out, ev.kind, ev.x * coord_scale, ev.y * coord_scale, ev.pressed)
        else:
            out = raw_next
        print "[wm-showcase-client] event_state seq={ev.seq} clicks={out.button_count} checkbox={out.checkbox_on} switch={out.switch_on} slider={out.slider_value} progress={out.progress_value}"
        seq = ev.seq
        dirty = true
        drained = drained + 1
    (out, seq, dirty)

fn run_wm_client() -> i64:
    val bridge_path = env_get(WM_BRIDGE_FILE_ENV) ?? ""
    val frame_path = env_get(WM_FRAME_FILE_ENV) ?? ""
    if bridge_path == "" or frame_path == "":
        print "[wm-showcase-client] error=missing-bridge-env"
        return 2
    val event_path = wm_env_path_or(wm_widget_showcase_event_path(frame_path), WM_EVENT_FILE_ENV)
    val seq_path = wm_env_path_or(wm_widget_showcase_frame_seq_path(frame_path), WM_FRAME_SEQ_FILE_ENV)
    val state_path = frame_path + ".state"

    var state = showcase_state_default()
    var frame_seq = 1
    val frame_scale = showcase_ppm_scale()
    val frame_w = W / frame_scale
    val frame_h = H / frame_scale
    val pixels = build_frame_state(W, H, state)
    var wm_pixels = pixels
    if frame_scale > 1:
        wm_pixels = downsample_nearest(pixels, W, H, frame_scale)
    if wm_pixels.len() < frame_w * frame_h or not write_wm_frame(frame_path, seq_path, frame_seq, frame_w, frame_h, wm_pixels):
        print "[wm-showcase-client] error=frame-write-failed path={frame_path}"
        return 1
    write_wm_state(state_path, state, 0, frame_seq, frame_scale)

    val pid = getpid()
    val req = wm_widget_showcase_bridge_request_sized(pid, frame_path, W + 8, H + 32)
    if not file_write(bridge_path, wm_fs_bridge_encode(req)):
        print "[wm-showcase-client] error=bridge-write-failed path={bridge_path}"
        return 1

    print "[wm-showcase-client] source={WIDGET_SHOWCASE_APP_SOURCE} pid={pid} bridge={bridge_path} frame={frame_path} event={event_path} seq={seq_path}"
    if (env_get(WM_CLIENT_HOLD_ENV) ?? "") == "1":
        var ticks = 0
        var last_event_seq = 0
        while ticks < 2000000:
            val (event_state, event_seq, event_dirty) = consume_wm_event(event_path, last_event_seq, state, frame_scale)
            var dirty = event_dirty
            if event_dirty:
                state = event_state
                last_event_seq = event_seq
            if dirty:
                frame_seq = frame_seq + 1
                val next_pixels = build_frame_state(W, H, state)
                var next_wm_pixels = next_pixels
                if frame_scale > 1:
                    next_wm_pixels = downsample_nearest(next_pixels, W, H, frame_scale)
                if next_wm_pixels.len() < frame_w * frame_h or not write_wm_frame(frame_path, seq_path, frame_seq, frame_w, frame_h, next_wm_pixels):
                    print "[wm-showcase-client] error=frame-refresh-failed path={frame_path}"
                    return 1
                write_wm_state(state_path, state, last_event_seq, frame_seq, frame_scale)
                print "[wm-showcase-client] frame seq={frame_seq} event_seq={last_event_seq} clicks={state.button_count} checkbox={state.checkbox_on} switch={state.switch_on} slider={state.slider_value} progress={state.progress_value}"
            var sleep_ms = 32
            if dirty:
                sleep_ms = 16
            thread_sleep(sleep_ms)
            ticks = ticks + 1
    0

fn apply_native_input(input: WinitInput, mouse_x: i32, mouse_y: i32, state: ShowcaseState) -> (ShowcaseState, i32, i32, bool, bool):
    var out = state
    var mx = mouse_x
    var my = mouse_y
    var dirty = false
    var running = true
    if showcase_should_close(input):
        running = false
    if input.mouse_x != 0.0 or input.mouse_y != 0.0:
        mx = input.mouse_x.to_i32()
        my = input.mouse_y.to_i32()
        if out.slider_dragging:
            out = showcase_on_pointer(out, "move", mx, my, false)
            dirty = true
    var ci = 0
    while ci < input.click_buttons.len():
        val btn = input.click_buttons[ci]
        val pressed = input.click_pressed[ci]
        if btn == 0:
            var fx = input.click_x[ci].to_i32()
            var fy = input.click_y[ci].to_i32()
            if fx == 0 and fy == 0:
                fx = mx
                fy = my
            else:
                mx = fx
                my = fy
            var kind = "up"
            if pressed:
                kind = "down"
            out = showcase_on_pointer(out, kind, fx, fy, pressed)
            dirty = true
            print "[widget-showcase] input left_button pressed={pressed} x={fx} y={fy} clicks={out.button_count} slider={out.slider_value}"
        ci = ci + 1
    (out, mx, my, dirty, running)

fn main() -> i64:
    if wm_app_mode_is_client(env_get(WM_APP_MODE_ENV) ?? ""):
        return run_wm_client()
    if (env_get("SHOWCASE_4K_PERF") ?? "") == "1":
        return run_4k_perf_probe()
    if (env_get("SHOWCASE_8K_PERF") ?? "") == "1":
        return run_8k_perf_probe()

    # Frame size: SHOWCASE_W/SHOWCASE_H override the 520x660 default (low-res gates).
    val w_raw = env_get("SHOWCASE_W") ?? ""
    val h_raw = env_get("SHOWCASE_H") ?? ""
    val fw0 = (w_raw.parse_i64() ?? W.to_i64()).to_i32()
    val fh0 = (h_raw.parse_i64() ?? H.to_i64()).to_i32()
    var fw = fw0
    if fw0 < 64:
        fw = W
    var fh = fh0
    if fh0 < 64:
        fh = H

    emit_renderer_log(showcase_backend_key(), fw, fh)

    # Synthetic event mode: offscreen only, no winit (W1/G1.5).
    val events_raw = env_get("SHOWCASE_EVENTS") ?? ""
    if events_raw != "":
        print "Widget showcase GUI — synthetic event mode {fw}x{fh}"
        return run_showcase_events(fw, fh, events_raw)

    print "Widget showcase GUI — render {fw}x{fh} via Engine2D CPU lane"
    val pixels = build_frame_sized(fw, fh)
    if pixels.len() < fw * fh:
        return 1
    print "rendered {pixels.len()} px (24 widget types)"

    # Capture the framebuffer to a P6 PPM (absolute oracle) when SHOWCASE_PPM is set.
    val ppm_path = env_get("SHOWCASE_PPM") ?? ""
    if ppm_path != "":
        val scale = showcase_ppm_scale()
        val ppm_pixels = downsample_nearest(pixels, fw, fh, scale)
        val ppm_w = fw / scale
        val ppm_h = fh / scale
        val bytes = encode_ppm_p6(ppm_w.to_u32(), ppm_h.to_u32(), ppm_pixels)
        if file_write_bytes(ppm_path, bytes):
            print "wrote {ppm_path} ({ppm_w}x{ppm_h}, {bytes.len()} bytes)"
        else:
            print "failed to write {ppm_path}"

    if (env_get("SIMPLE_GUI") ?? "") != "1":
        print "No GUI requested (use scripts/gui/macos-gui-run.shs to open a window); headless only."
        return 0

    val lp = winit_loop_new()
    if not lp.is_valid:
        print "No GUI runtime available."
        return 1
    val win = winit_window_new(lp, fw.to_i64(), fh.to_i64(), "Simple Widget Showcase (CPU lane)")
    if not win.is_valid:
        winit_loop_free(lp)
        return 1

    var native_state = showcase_state_default()
    var live_pixels = pixels
    var packed = pack(live_pixels)
    var mouse_x = 0
    var mouse_y = 0
    var running = true
    var iters = 0
    while running and iters < 2000000:
        winit_present_rgba(win, fw.to_i64(), fh.to_i64(), packed)
        val input = winit_poll_input(lp)
        val applied = apply_native_input(input, mouse_x, mouse_y, native_state)
        native_state = applied.0
        mouse_x = applied.1
        mouse_y = applied.2
        if applied.3:
            live_pixels = build_frame_state(fw, fh, native_state)
            packed = pack(live_pixels)
        running = applied.4
        iters = iters + 1
    winit_window_free(win)
    winit_loop_free(lp)
    return 0
