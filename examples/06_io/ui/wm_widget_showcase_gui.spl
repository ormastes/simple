# wm_widget_showcase_gui.spl — Simple WM host that launches the widget showcase
# from the filesystem as a separate process, using the SAME source file as the
# native showcase app.
#
# Launch:
#   SIMPLE_GUI_RUN_SKIP_NUDGE=1 scripts/gui/macos-gui-run.shs \
#     examples/06_io/ui/wm_widget_showcase_gui.spl

use std.gpu.engine2d.backend_metal.{MetalBackend}
use std.io.window_winit.{WinitLoop, WinitWindow, WinitInput, winit_loop_new, winit_loop_free, winit_window_new, winit_window_free, winit_present_rgba, winit_poll_input, winit_wait_input}
use std.common.image.ppm_decode.{decode_ppm_to_argb}
use std.io_runtime.{env_get, file_exists, file_read, file_write, file_read_bytes, dir_create_all, getpid, time_now_unix_micros}
use std.nogc_sync_mut.concurrent.thread.{thread_sleep}
use app.io.mod.{process_spawn_async, process_spawn_async_env, process_kill, host_os, cwd}
use common.window_protocol.geometry.{Size}
use common.ui.wm_chrome_theme.{wm_chrome_theme}
use common.ui.wm_app_process_contract.{WIDGET_SHOWCASE_APP_SOURCE, WIDGET_SHOWCASE_TITLE, WM_EVENT_FILE_ENV, WM_FRAME_SEQ_FILE_ENV, wm_fs_bridge_decode, wm_widget_showcase_client_env, wm_widget_showcase_event_path, wm_widget_showcase_frame_seq_path, wm_fs_app_event, wm_fs_app_event_encode, wm_fs_app_event_seq_path}
use os.compositor.host_compositor_entry.{HostCompositor, HeadlessHostCompositorBackend, host_compositor_pointer_move, host_compositor_left_button_at, host_taskbar_dock_width, host_taskbar_item_width, host_taskbar_item_x}
use os.userlib.ipc_protocol.{COMP_CREATE_WINDOW}

val W: i32 = 660
val H: i32 = 840
val ANIM_TICK_INTERVAL_US: i64 = 5000000
val CHILD_REFRESH_TIMEOUT_US: i64 = 5000000
val LOCATOR: u32 = 0xFFFF00FFu32
val MUTED: u32 = 0xFF94A3B8u32

struct WmLoopState:
    comp: HostCompositor
    mouse_x: i32
    mouse_y: i32
    child_pointer_down: bool
    child_drag_forwarding: bool
    child_event_seq: i64
    child_refresh_pending: bool
    child_refresh_deadline: i64
    dirty: bool
    running: bool

fn sleep_ms(ms: i64):
    thread_sleep(ms)

fn scale_frame_nearest(src: [u32], src_w: i32, src_h: i32, dst_w: i32, dst_h: i32) -> [u32]:
    if src_w <= 0 or src_h <= 0 or dst_w <= 0 or dst_h <= 0:
        return []
    if src_w == dst_w and src_h == dst_h:
        return src
    var out: [u32] = []
    var y = 0
    while y < dst_h:
        val sy = (y * src_h) / dst_h
        var x = 0
        while x < dst_w:
            val sx = (x * src_w) / dst_w
            out.push(src[sy * src_w + sx])
            x = x + 1
        y = y + 1
    out

fn load_child_frame(frame_path: text, target_w: i32, target_h: i32) -> (bool, i32, i32, [u32]):
    val frame_bytes = file_read_bytes(frame_path)
    val decoded = decode_ppm_to_argb(frame_bytes)
    if decoded.is_err():
        return (false, 0, 0, [])
    val frame = decoded.unwrap()
    if target_w > 0 and target_h > 0 and (frame.width != target_w or frame.height != target_h):
        val scaled = scale_frame_nearest(frame.pixels, frame.width, frame.height, target_w, target_h)
        if scaled.len() < target_w * target_h:
            return (false, 0, 0, [])
        return (true, target_w, target_h, scaled)
    (true, frame.width, frame.height, frame.pixels)

fn read_frame_seq(seq_path: text) -> i64:
    if seq_path == "" or not file_exists(seq_path):
        return 0
    file_read(seq_path).trim().to_i64() ?? 0

fn read_state_value(state_path: text, key: text) -> text:
    if state_path == "" or not file_exists(state_path):
        return ""
    val prefix = key + "="
    val lines = file_read(state_path).split("\n")
    var i = 0
    while i < lines.len():
        val line = lines[i]
        if line.starts_with(prefix):
            return line.substring(prefix.len(), line.len())
        i = i + 1
    ""

fn read_child_state_event_seq(state_path: text) -> i64:
    read_state_value(state_path, "event_seq").to_i64() ?? -1

fn write_wm_trace(trace_path: text, phase: text):
    if trace_path != "":
        file_write(trace_path, "phase={phase}\n")

fn should_close(input: WinitInput) -> bool:
    if input.close:
        return true
    for k in input.keys:
        if k == 27 or k == 113 or k == 81:
            return true
    false

fn wait_for_bridge(path: text, timeout_ms: i64) -> text:
    val deadline = time_now_unix_micros() + timeout_ms * 1000
    while time_now_unix_micros() < deadline:
        if file_exists(path):
            val body = file_read(path)
            if body.contains("kind=create_window"):
                return body
        sleep_ms(50)
    ""

fn path_join(root: text, rel: text) -> text:
    if root.ends_with("/") or root.ends_with("\\"):
        return root + rel
    root + "/" + rel

fn resolve_repo_root() -> text:
    val explicit = env_get("SIMPLE_REPO_ROOT") ?? ""
    if explicit != "":
        return explicit
    val lib = env_get("SIMPLE_LIB") ?? ""
    if lib.ends_with("/src") or lib.ends_with("\\src"):
        return lib.substring(0, lib.len() - 4)
    val here = cwd()
    if here != "":
        return here
    "."

fn fill_rect_metal(b: MetalBackend, x: i32, y: i32, w: i32, h: i32, color: u32):
    b.draw_rect_filled(x, y, w, h, color)

fn draw_text_metal(b: MetalBackend, x: i32, y: i32, text_val: text, fg: u32):
    b.draw_text(x, y, text_val, fg, 8)

fn draw_taskbar_metal(b: MetalBackend, comp: HostCompositor):
    val theme = wm_chrome_theme()
    val count = comp.windows.len().to_i32()
    if count <= 0:
        return
    val dock_w = host_taskbar_dock_width(W, count)
    val dock_x = (W - dock_w) / 2
    val dock_y = H - 62
    fill_rect_metal(b, dock_x, dock_y, dock_w, 44, theme.taskbar)
    val item_w = host_taskbar_item_width(W, count)
    var i = 0
    while i < count:
        val win = comp.windows[i]
        val ix = host_taskbar_item_x(W, count, i)
        var color = theme.title_unfocused
        if win.focused and not win.minimized:
            color = theme.accent
        elif win.minimized:
            color = theme.host_window_body
        fill_rect_metal(b, ix + 2, dock_y + 6, item_w - 4, 32, theme.command_lane)
        fill_rect_metal(b, ix + 4, dock_y + 8, item_w - 8, 28, color)
        fill_rect_metal(b, ix + 12, dock_y + 14, 12, 12, theme.text_primary)
        draw_text_metal(b, ix + 30, dock_y + 13, win.title, theme.text_primary)
        if win.focused and not win.minimized:
            fill_rect_metal(b, ix + 8, dock_y + 35, item_w - 16, 2, theme.text_primary)
        i = i + 1

fn compose_metal(b: MetalBackend, comp: HostCompositor, frame_w: i32, frame_h: i32, frame_pixels: [u32]) -> bool:
    val theme = wm_chrome_theme()
    var frame_ok = true
    b.clear(theme.compositor_bg)
    fill_rect_metal(b, 0, 0, W, 38, theme.command_lane)
    draw_text_metal(b, 14, 12, "Simple WM", theme.text_primary)
    draw_text_metal(b, 112, 12, "fs child: {WIDGET_SHOWCASE_APP_SOURCE}", MUTED)
    var i = 0
    while i < comp.windows.len():
        val win = comp.windows[i]
        if not win.minimized:
            fill_rect_metal(b, win.x + 7, win.y + 7, win.w, win.h, theme.window_shadow)
            fill_rect_metal(b, win.x, win.y, win.w, win.h, theme.host_window_body)
            val title_color = if win.focused: theme.accent else: theme.title_unfocused
            fill_rect_metal(b, win.x, win.y, win.w, 24, title_color)
            draw_text_metal(b, win.x + 10, win.y + 7, win.title, theme.text_primary)
            fill_rect_metal(b, win.x + win.w - 24, win.y, 24, 24, theme.close_button)
            draw_text_metal(b, win.x + win.w - 17, win.y + 5, "X", theme.text_primary)
            val cx = win.x + 4
            val cy = win.y + 28
            if frame_pixels.len() < frame_w * frame_h:
                frame_ok = false
                draw_text_metal(b, cx + 8, cy + 8, "frame pending", theme.text_primary)
            else:
                b.draw_image(cx, cy, frame_w, frame_h, frame_pixels)
        i = i + 1
    draw_taskbar_metal(b, comp)
    fill_rect_metal(b, 0, 0, W, 3, LOCATOR)
    fill_rect_metal(b, 0, H - 3, W, 3, LOCATOR)
    fill_rect_metal(b, 0, 0, 3, H, LOCATOR)
    fill_rect_metal(b, W - 3, 0, 3, H, LOCATOR)
    frame_ok

fn render_and_present(b: MetalBackend, win: WinitWindow, lp: WinitLoop, comp: HostCompositor, frame_w: i32, frame_h: i32, frame_pixels: [u32], state: text) -> bool:
    val frame_ok = compose_metal(b, comp, frame_w, frame_h, frame_pixels)
    if not frame_ok:
        print "[wm-showcase] present state={state} child_frame_blit_failed"
        return false
    b.present()
    val frame_complete = b.gpu_frame_complete
    val pixels = b.read_pixels_gpu_only()
    if not frame_complete:
        print "[wm-showcase] present state={state} FAIL metal_frame_incomplete"
        return false
    if pixels.len() < W * H:
        print "[wm-showcase] present state={state} FAIL metal_readback_short={pixels.len()} want={W * H}"
        return false
    var packed: [i64] = []
    var i = 0
    while i < pixels.len():
        packed.push(pixels[i].to_i64() & 0xFFFFFF)
        i = i + 1
    winit_present_rgba(win, W.to_i64(), H.to_i64(), packed)
    val ignored_pump = winit_poll_input(lp)
    if state != "hold":
        print "[wm-showcase] present state={state} dims={W}x{H} child_frame=from-filesystem renderer=metal-sffi gpu_frame_complete={frame_complete}"
    true

fn child_local_at(comp: HostCompositor, fx: i32, fy: i32, frame_w: i32, frame_h: i32, require_inside: bool) -> (bool, i32, i32):
    var i = comp.windows.len() - 1
    while i >= 0:
        val win = comp.windows[i]
        if not win.minimized:
            val lx = fx - (win.x + 4)
            val ly = fy - (win.y + 28)
            val inside = lx >= 0 and ly >= 0 and lx < frame_w and ly < frame_h
            if inside or not require_inside:
                return (true, lx, ly)
        i = i - 1
    (false, 0, 0)

fn write_child_pointer_event(event_path: text, seq: i64, kind: text, x: i32, y: i32, button: i64, pressed: bool) -> i64:
    if event_path == "":
        return seq
    val next_seq = seq + 1
    val ev = wm_fs_app_event(next_seq, kind, x, y, button, pressed)
    val encoded = wm_fs_app_event_encode(ev)
    val seq_path = wm_fs_app_event_seq_path(event_path, next_seq)
    if file_write(seq_path, encoded) and file_write(event_path, encoded):
        print "[wm-showcase] child_event kind={kind} seq={next_seq} x={x} y={y} pressed={pressed}"
        return next_seq
    print "[wm-showcase] child_event_write_failed path={event_path}"
    seq

fn child_rect_hit_scaled(x: i32, y: i32, rx: i32, ry: i32, rw: i32, rh: i32, scale: i32) -> bool:
    val sx = rx / scale
    val sy = ry / scale
    val sw = rw / scale
    val sh = rh / scale
    x >= sx and x < sx + sw and y >= sy and y < sy + sh

fn child_needs_press_stream_at_scale(x: i32, y: i32, scale: i32) -> bool:
    child_rect_hit_scaled(x, y, 12, 56, 60, 18, scale) or
    child_rect_hit_scaled(x, y, 268, 58, 120, 22, scale) or
    child_rect_hit_scaled(x, y, 12, 124, 78, 18, scale) or
    child_rect_hit_scaled(x, y, 268, 186, 130, 28, scale)

fn child_needs_press_stream(x: i32, y: i32) -> bool:
    child_needs_press_stream_at_scale(x, y, 1) or
    child_needs_press_stream_at_scale(x, y, 2) or
    child_needs_press_stream_at_scale(x, y, 4) or
    child_needs_press_stream_at_scale(x, y, 8)

fn apply_wm_input(state: WmLoopState, input: WinitInput, event_path: text, frame_w: i32, frame_h: i32) -> WmLoopState:
    var out = state.comp
    var mx = state.mouse_x
    var my = state.mouse_y
    var child_down = state.child_pointer_down
    var child_drag_forwarding = state.child_drag_forwarding
    var child_seq = state.child_event_seq
    var child_refresh_pending = state.child_refresh_pending
    var child_refresh_deadline = state.child_refresh_deadline
    var dirty = false
    var running = state.running
    if should_close(input):
        running = false
    if input.mouse_x != 0.0 or input.mouse_y != 0.0:
        val next_mx = input.mouse_x.to_i32()
        val next_my = input.mouse_y.to_i32()
        val moved = next_mx != mx or next_my != my
        if moved or child_down:
            mx = next_mx
            my = next_my
            val was_dragging = state.comp.dragging or state.comp.resizing
            out = host_compositor_pointer_move(out, mx, my)
            dirty = was_dragging or out.dragging or out.resizing
        if moved and child_down and child_drag_forwarding:
            val loc = child_local_at(out, mx, my, frame_w, frame_h, false)
            if loc.0:
                val before_move_seq = child_seq
                child_seq = write_child_pointer_event(event_path, child_seq, "move", loc.1, loc.2, 0, true)
                if child_seq > before_move_seq:
                    child_refresh_pending = true
                    child_refresh_deadline = 0
    var ci = 0
    while ci < input.click_buttons.len():
        val btn = input.click_buttons[ci]
        val pressed = input.click_pressed[ci]
        if btn == 0:
            var fx = input.click_x[ci].to_i32()
            var fy = input.click_y[ci].to_i32()
            if fx == 0 and fy == 0:
                fx = mx
                fy = my
            else:
                mx = fx
                my = fy
            if pressed:
                val loc_down = child_local_at(out, fx, fy, frame_w, frame_h, true)
                print "[wm-showcase] route_down screen={fx},{fy} child_hit={loc_down.0} local={loc_down.1},{loc_down.2}"
                if loc_down.0:
                    child_drag_forwarding = child_needs_press_stream(loc_down.1, loc_down.2)
                    print "[wm-showcase] route_down_stream local={loc_down.1},{loc_down.2} stream={child_drag_forwarding}"
                    if child_drag_forwarding:
                        val before_down_seq = child_seq
                        child_seq = write_child_pointer_event(event_path, child_seq, "down", loc_down.1, loc_down.2, btn, true)
                        if child_seq > before_down_seq:
                            child_refresh_pending = true
                            child_refresh_deadline = 0
                    child_down = true
            elif not pressed:
                val loc_up = child_local_at(out, fx, fy, frame_w, frame_h, false)
                print "[wm-showcase] route_up screen={fx},{fy} child_hit={loc_up.0} local={loc_up.1},{loc_up.2}"
                if loc_up.0:
                    val before_up_seq = child_seq
                    child_seq = write_child_pointer_event(event_path, child_seq, "up", loc_up.1, loc_up.2, btn, false)
                    if child_seq > before_up_seq:
                        child_refresh_pending = true
                        child_refresh_deadline = 0
                child_down = false
                child_drag_forwarding = false
            out = host_compositor_left_button_at(out, pressed, fx, fy)
            dirty = true
            print "[wm-showcase] input left_button pressed={pressed} x={fx} y={fy} windows={out.windows.len()} dragging={out.dragging}"
        ci = ci + 1
    if out.windows.len() == 0:
        running = false
    WmLoopState(comp: out, mouse_x: mx, mouse_y: my, child_pointer_down: child_down, child_drag_forwarding: child_drag_forwarding, child_event_seq: child_seq, child_refresh_pending: child_refresh_pending, child_refresh_deadline: child_refresh_deadline, dirty: dirty, running: running)

fn launch_showcase_child(bridge_path: text, frame_path: text, repo_root: text) -> i64:
    var env = wm_widget_showcase_client_env(bridge_path, frame_path)
    val lib = env_get("SIMPLE_LIB") ?? ""
    if lib != "":
        env["SIMPLE_LIB"] = lib
    else:
        env["SIMPLE_LIB"] = path_join(repo_root, "src")
    env["SHOWCASE_PPM_SCALE"] = env_get("SHOWCASE_PPM_SCALE") ?? "1"
    env["SIMPLE_EXECUTION_LIMIT"] = env_get("SIMPLE_EXECUTION_LIMIT") ?? "0"
    env["SIMPLE_TIMEOUT_SECONDS"] = env_get("SIMPLE_TIMEOUT_SECONDS") ?? "0"
    val simple_lib = env["SIMPLE_LIB"]
    val showcase_scale = env["SHOWCASE_PPM_SCALE"]
    val execution_limit = env["SIMPLE_EXECUTION_LIMIT"]
    val timeout_seconds = env["SIMPLE_TIMEOUT_SECONDS"]
    val simple_bin = path_join(repo_root, "bin/simple")
    val showcase_source_path = path_join(repo_root, WIDGET_SHOWCASE_APP_SOURCE)
    val event_path = wm_widget_showcase_event_path(frame_path)
    val seq_path = wm_widget_showcase_frame_seq_path(frame_path)
    if host_os().lower().contains("windows"):
        return process_spawn_async_env(simple_bin, ["run", showcase_source_path], env)
    process_spawn_async("env", [
        "SIMPLE_WM_APP_MODE=client",
        "SIMPLE_WM_BRIDGE_FILE={bridge_path}",
        "SIMPLE_WM_FRAME_FILE={frame_path}",
        "{WM_EVENT_FILE_ENV}={event_path}",
        "{WM_FRAME_SEQ_FILE_ENV}={seq_path}",
        "SIMPLE_WM_CLIENT_HOLD=1",
        "SHOWCASE_PPM_SCALE={showcase_scale}",
        "SIMPLE_EXECUTION_LIMIT={execution_limit}",
        "SIMPLE_TIMEOUT_SECONDS={timeout_seconds}",
        "SIMPLE_LIB={simple_lib}",
        simple_bin,
        "run",
        showcase_source_path
    ])

fn cleanup(child_pid: i64, b: MetalBackend, win: WinitWindow, lp: WinitLoop):
    if child_pid > 0:
        process_kill(child_pid)
    b.shutdown()
    winit_window_free(win)
    winit_loop_free(lp)

fn main() -> i64:
    print "WM Widget Showcase GUI - launching same source from filesystem"
    if (env_get("SIMPLE_GUI") ?? "") != "1":
        print "[wm-showcase] error=no-gui-requested (launch via macos-gui-run.shs)"
        return 2

    val repo_root = resolve_repo_root()
    val tmp_root = path_join(repo_root, "build/tmp")
    dir_create_all(tmp_root)
    val stamp = "{getpid()}_{time_now_unix_micros()}"
    val bridge_path = path_join(tmp_root, "wm_widget_showcase_{stamp}.bridge")
    val frame_path = path_join(tmp_root, "wm_widget_showcase_{stamp}.ppm")
    val trace_path = frame_path + ".trace"
    val event_path = wm_widget_showcase_event_path(frame_path)
    val seq_path = wm_widget_showcase_frame_seq_path(frame_path)
    val showcase_source_path = path_join(repo_root, WIDGET_SHOWCASE_APP_SOURCE)
    write_wm_trace(trace_path, "start")
    print "[wm-showcase] repo_root={repo_root} child_source_fs={showcase_source_path}"
    val child_pid = launch_showcase_child(bridge_path, frame_path, repo_root)
    if child_pid <= 0:
        print "[wm-showcase] error=child-spawn-failed source={WIDGET_SHOWCASE_APP_SOURCE}"
        return 1
    write_wm_trace(trace_path, "child_spawned")

    val bridge_body = wait_for_bridge(bridge_path, 120000)
    if bridge_body == "":
        print "[wm-showcase] error=child-bridge-timeout source={WIDGET_SHOWCASE_APP_SOURCE} pid={child_pid}"
        process_kill(child_pid)
        return 1
    write_wm_trace(trace_path, "bridge_ready")
    val req = wm_fs_bridge_decode(bridge_body)
    var frame_w = req.window_w - 8
    var frame_h = req.window_h - 32
    if frame_w <= 0:
        frame_w = 1
    if frame_h <= 0:
        frame_h = 1
    val loaded = load_child_frame(frame_path, frame_w, frame_h)
    if not loaded.0:
        print "[wm-showcase] error=child-frame-decode-failed path={frame_path}"
        process_kill(child_pid)
        return 1
    frame_w = loaded.1
    frame_h = loaded.2
    var frame_pixels = loaded.3
    write_wm_trace(trace_path, "frame_ready")
    val child_event_path = if req.event_path != "": req.event_path else: event_path
    val child_seq_path = if req.frame_seq_path != "": req.frame_seq_path else: seq_path
    val child_state_path = frame_path + ".state"
    var last_frame_seq = read_frame_seq(child_seq_path)

    write_wm_trace(trace_path, "before_loop_new")
    val lp = winit_loop_new()
    if not lp.is_valid:
        print "[wm-showcase] error=no-gui-runtime"
        process_kill(child_pid)
        return 1
    write_wm_trace(trace_path, "after_loop_new")
    val win = winit_window_new(lp, W.to_i64(), H.to_i64(), "Simple WM - Widget Showcase")
    if not win.is_valid:
        print "[wm-showcase] error=window-create-failed"
        winit_loop_free(lp)
        process_kill(child_pid)
        return 1
    write_wm_trace(trace_path, "after_window_new")
    var b = MetalBackend.create()
    if not b.init(W, H):
        print "[wm-showcase] error=metal-init-failed"
        winit_window_free(win)
        winit_loop_free(lp)
        process_kill(child_pid)
        return 1
    b.use_gpu_only()
    write_wm_trace(trace_path, "after_buffer_create")

    val backend = HeadlessHostCompositorBackend.new(W, H)
    var comp = HostCompositor.new(backend, Size.wh(W, H))
    comp.apply_bridge_request(1, 701, COMP_CREATE_WINDOW.to_i64(), 0, req.title, 54, 70, req.window_w, req.window_h, req.content, req.pid, req.app_id)
    print "[wm-showcase] launched source={req.source_path} child_pid={child_pid} bridge_pid={req.pid} app_id={req.app_id} windows={comp.windows.len()} taskbar_items={comp.windows.len()}"
    if comp.windows.len() != 1:
        cleanup(child_pid, b, win, lp)
        return 1
    write_wm_trace(trace_path, "before_first_present")
    if not render_and_present(b, win, lp, comp, frame_w, frame_h, frame_pixels, "launched"):
        cleanup(child_pid, b, win, lp)
        return 1
    write_wm_trace(trace_path, "loop_start")

    var state = WmLoopState(comp: comp, mouse_x: 0, mouse_y: 0, child_pointer_down: false, child_drag_forwarding: false, child_event_seq: 0, child_refresh_pending: false, child_refresh_deadline: 0, dirty: false, running: true)
    var last_anim_tick = time_now_unix_micros()
    var frames = 0
    while state.running and frames < 2000000:
        val idle_sleep_ms = if state.child_refresh_pending: 8 else: 24
        val input = winit_wait_input(lp, idle_sleep_ms)
        state = apply_wm_input(state, input, child_event_path, frame_w, frame_h)
        val now = time_now_unix_micros()
        if state.child_refresh_pending and state.child_refresh_deadline == 0:
            state.child_refresh_deadline = now + CHILD_REFRESH_TIMEOUT_US
        if not state.child_refresh_pending and now - last_anim_tick >= ANIM_TICK_INTERVAL_US:
            val before_tick_seq = state.child_event_seq
            state.child_event_seq = write_child_pointer_event(child_event_path, state.child_event_seq, "tick", 0, 0, 0, false)
            if state.child_event_seq > before_tick_seq:
                state.child_refresh_pending = true
                state.child_refresh_deadline = now + CHILD_REFRESH_TIMEOUT_US
                write_wm_trace(trace_path, "tick_sent:{state.child_event_seq}")
            last_anim_tick = now
        var current_frame_seq = last_frame_seq
        var child_state_event_seq: i64 = -1
        if state.child_refresh_pending:
            current_frame_seq = read_frame_seq(child_seq_path)
            child_state_event_seq = read_child_state_event_seq(child_state_path)
            if current_frame_seq <= last_frame_seq or child_state_event_seq < state.child_event_seq:
                if state.child_refresh_deadline > 0 and now > state.child_refresh_deadline:
                    print "[wm-showcase] refresh_wait target_event={state.child_event_seq} child_event={child_state_event_seq} frame_seq={current_frame_seq} last_frame_seq={last_frame_seq}"
                    write_wm_trace(trace_path, "refresh_wait:{state.child_event_seq}:{child_state_event_seq}:{current_frame_seq}")
                    state.child_refresh_deadline = now + CHILD_REFRESH_TIMEOUT_US
        if state.child_refresh_pending and current_frame_seq > last_frame_seq and child_state_event_seq >= state.child_event_seq:
            val refreshed = load_child_frame(frame_path, req.window_w - 8, req.window_h - 32)
            if refreshed.0:
                frame_w = refreshed.1
                frame_h = refreshed.2
                frame_pixels = refreshed.3
                last_frame_seq = current_frame_seq
                state.dirty = true
                state.child_refresh_pending = false
                state.child_refresh_deadline = 0
                write_wm_trace(trace_path, "frame_refresh:{last_frame_seq}")
                print "[wm-showcase] refresh_load frame_seq={last_frame_seq} target_event={state.child_event_seq} child_event={child_state_event_seq} size={frame_w}x{frame_h}"
            elif state.child_refresh_deadline > 0 and now > state.child_refresh_deadline:
                print "[wm-showcase] child_frame_decode_wait seq={current_frame_seq} last_seq={last_frame_seq} target_event={state.child_event_seq} child_event={child_state_event_seq}"
                write_wm_trace(trace_path, "decode_timeout:{current_frame_seq}")
                state.child_refresh_deadline = now + CHILD_REFRESH_TIMEOUT_US
        if state.dirty:
            if not render_and_present(b, win, lp, state.comp, frame_w, frame_h, frame_pixels, "hold"):
                cleanup(child_pid, b, win, lp)
                return 1
            state.dirty = false
        frames = frames + 1

    cleanup(child_pid, b, win, lp)
    return 0
