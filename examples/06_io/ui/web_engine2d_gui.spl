# web_engine2d_gui.spl — GUI app: Simple Web Renderer + Engine2D CPU SIMD backend
#
# Renders HTML through SimpleWebRenderer with the explicit Engine2D backend
# requested below, then presents the resulting [u32] pixel buffer to a host
# winit window via winit_present_rgba (std.io.window_winit) when SIMPLE_GUI=1.
#
# The renderer is corpus-driven, not a full layout engine: it maps recognized
# HTML markers to colored rects (background color + wm-app-titlebar header +
# wm-app-content panel + a "Simple Web" title block). This entry uses markers
# that produce three visually distinct regions.
#
# Run (window):   SIMPLE_GUI=1 SIMPLE_EXECUTION_MODE=interpret bin/simple examples/ui/web_engine2d_gui.spl
# Run (headless):                SIMPLE_EXECUTION_MODE=interpret bin/simple examples/ui/web_engine2d_gui.spl
#
# NOTE: must run under SIMPLE_EXECUTION_MODE=interpret — the renderer uses the
# array-repeat form [bg; w*h] (rt_array_repeat) which the JIT cannot resolve.

use std.gc_async_mut.gpu.browser_engine.simple_web_renderer.{
    SimpleWebRenderer,
    simple_web_resolved_engine2d_backend_name}

use std.io.window_winit.{WinitLoop, WinitWindow, winit_loop_new, winit_loop_free, winit_window_new, winit_window_free, winit_present_rgba, winit_poll_close_requested}

use std.io_runtime.{env_get}
use std.nogc_sync_mut.io.time_ops.{time_now_unix_micros}
val SCREEN_W: i32 = 32
val SCREEN_H: i32 = 24
val WINDOW_W: i32 = 640
val WINDOW_H: i32 = 480

fn demo_html() -> text:
    # Markers recognized by simple_web_engine2d_renderer:
    #   background-color: #44aa22  -> green page background (0xFF44AA22)
    #   wm-app-titlebar            -> blue header bar (0xFF2050A0, top 24px)
    #   "Simple Web"               -> white title block (24x3 at 6,6)
    return "<html><body style='background-color: #44aa22'>" +
        "<div class='wm-app-titlebar'>Simple Web</div>" +
        "</body></html>"

fn pack_pixels(src: [u32]) -> [i64]:
    # softbuffer treats each u32 as 0x00RRGGBB (top byte ignored); mask to the
    # proven 24-bit RGB present format.
    var out: [i64] = [0; src.len()]
    var i = 0
    while i < src.len():
        out[i] = src[i].to_i64() & 0xFFFFFF
        i = i + 1
    return out

fn render_backend(backend: text) -> [u32]:
    val renderer = SimpleWebRenderer.create_with_backend(SCREEN_W, SCREEN_H, backend)
    val pixels = renderer.render_html_to_pixels(demo_html())
    val resolved = simple_web_resolved_engine2d_backend_name(SCREEN_W, SCREEN_H, renderer.backend_name)
    print "Rendered {pixels.len()} px via requested backend '{renderer.backend_name}' resolved='{resolved}' sample={pixels[0]}/{pixels[6 + 6 * SCREEN_W]}/{pixels[pixels.len() - 1]}"
    pixels

fn main() -> i64:
    print "Simple Web Renderer + Engine2D CPU SIMD GUI {SCREEN_W}x{SCREEN_H} presented at {WINDOW_W}x{WINDOW_H}"
    val cpu_simd_pixels = render_backend("cpu_simd")

    if env_get("SIMPLE_GUI") != "1":
        print "No GUI requested (set SIMPLE_GUI=1 to open a window); headless render only."
        return 0

    val lp = winit_loop_new()
    if not lp.is_valid:
        print "No GUI runtime (set SIMPLE_GUI=1 to open a window); headless render only."
        return 0
    val win = winit_window_new(lp, WINDOW_W.to_i64(), WINDOW_H.to_i64(), "Simple Web + Engine2D CPU SIMD")
    if not win.is_valid:
        print "Window creation failed."
        winit_loop_free(lp)
        return 0
    val packed = pack_pixels(cpu_simd_pixels)
    winit_present_rgba(win, SCREEN_W.to_i64(), SCREEN_H.to_i64(), packed)
    # macOS: winit_poll_close_requested pumps the native event loop, and the
    # interpreter owns the main thread — so poll CONTINUOUSLY (never rt_thread_sleep)
    # or AppKit loses its handler between frames and the window never composites.
    # (Launch via a .app bundle so the process is window-server registered:
    # scripts/macos-gui-run.shs. See doc/08_tracking/bug/macos_winit_window_not_displayed_*.md)
    var running = true
    var iters = 0
    val end_at = time_now_unix_micros() + 60000000
    while running and time_now_unix_micros() < end_at:
        if winit_poll_close_requested(lp):
            running = false
        if iters % 200 == 0:
            winit_present_rgba(win, SCREEN_W.to_i64(), SCREEN_H.to_i64(), packed)
        iters = iters + 1
    winit_window_free(win)
    winit_loop_free(lp)
    return 0
