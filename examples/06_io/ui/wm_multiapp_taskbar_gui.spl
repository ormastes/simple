# wm_multiapp_taskbar_gui.spl — Multi-app launch + working taskbar on the live
# Simple WM (hosted compositor) in a real on-screen winit window.
#
# Proves the Simple WM can LAUNCH MULTIPLE distinct GUI apps as internal windows
# through the real HostCompositor, that a TASKBAR reflects them and WORKS
# (clicking a taskbar item focuses/restores its window), and holds each state so
# an external gate can screencapture the live window.
#
#   - Opens a real 512x384 winit window and presents HostCompositor frames
#     through the common winit-buffer CompositorBackend facade.
#   - Creates a HostCompositor over the live winit backend and LAUNCHES apps one
#     at a time via apply_bridge_request(COMP_CREATE_WINDOW):
#     Terminal, Editor, File Manager, Calculator. Each launch adds a HostedWindow;
#     the taskbar item count grows. Emits `[wm-multiapp] launched app=..
#     windows=N taskbar_items=N`.
#   - Draws desktop backdrop + every non-minimized window (body/titlebar/close +
#     distinct per-app content) + a bottom taskbar with one colored segment per
#     window (focused item highlighted).
#   - TASKBAR INTERACTION on the REAL compositor state (not a parallel model),
#     synthesized through host_compositor_left_button_at() at the taskbar item's
#     x/y:
#       (a) focus a background window (Calculator is focused; click Terminal's
#           taskbar item -> focus moves to Terminal), logging focused_window_id
#           before/after.
#       (b) minimize the focused window, then restore it by clicking its taskbar
#           item — a minimized window's taskbar entry restores + focuses it.
#   - Holds a long final "all-visible" steady state for the capture window.
#
# Driven end-to-end by scripts/check/check-wm-multiapp-taskbar-evidence.shs

use std.io.window_winit.{WinitLoop, WinitWindow, WinitInput, winit_loop_new, winit_loop_free, winit_window_new, winit_window_free, winit_poll_input, winit_window_get_size, winit_window_scale_factor}
use std.io_runtime.{env_get}
use common.window_protocol.geometry.{Size}
use os.compositor.hosted_backend_winit.{HostedWinitBufferBackend}
use os.compositor.host_compositor_entry.{HostCompositor, host_wm_force_direct_chrome, host_compositor_left_button_at, host_compositor_focused_window_id, host_compositor_minimize_focused, host_taskbar_item_x, host_taskbar_item_width}
use os.userlib.ipc_protocol.{COMP_CREATE_WINDOW}

extern fn rt_time_now_unix_micros() -> i64

val W: i32 = 512
val H: i32 = 384
val BG: u32 = 0xFF0F172Au32

fn render_and_present(lp: WinitLoop, comp: HostCompositor, state: text) -> bool:
    print "[wm-multiapp] render_stage={state}:begin"
    comp.render_frame()
    print "[wm-multiapp] present state={state} dims={W}x{H} backend=host-compositor-winit-buffer"
    return true

fn apply_live_input(comp: HostCompositor, input: WinitInput) -> bool:
    var dirty = false
    if input.mouse_x != 0.0 or input.mouse_y != 0.0:
        val mx = input.mouse_x.to_i32()
        val my = input.mouse_y.to_i32()
        val was_dragging = comp.dragging or comp.resizing
        comp.handle_mouse_move(mx, my)
        dirty = true
        if was_dragging or comp.dragging or comp.resizing:
            print "[wm-multiapp] input mouse_move x={mx} y={my} dragging={comp.dragging} resizing={comp.resizing}"
    var ci = 0
    while ci < input.click_buttons.len():
        val button = input.click_buttons[ci]
        val pressed = input.click_pressed[ci]
        var fx = input.click_x[ci].to_i32()
        var fy = input.click_y[ci].to_i32()
        if fx == 0 and fy == 0:
            fx = comp.pointer_x
            fy = comp.pointer_y
        else:
            comp.handle_mouse_move(fx, fy)
        comp.handle_mouse_button(button, pressed)
        dirty = true
        print "[wm-multiapp] input mouse_button button={button} pressed={pressed} x={fx} y={fy} dragging={comp.dragging} resizing={comp.resizing} focused={host_compositor_focused_window_id(comp)}"
        ci = ci + 1
    if input.scroll_y != 0.0:
        comp.handle_mouse_wheel(0.0, input.scroll_y)
        dirty = true
        print "[wm-multiapp] input scroll_y={input.scroll_y}"
    dirty

# Hold the presented frame ~secs seconds, pumping the loop so the window stays
# live for the external screencapture.
fn hold(lp: WinitLoop, comp: HostCompositor, secs: i64, state: text):
    val until = rt_time_now_unix_micros() + secs * 1000000
    while rt_time_now_unix_micros() < until:
        val input = winit_poll_input(lp)
        if apply_live_input(comp, input):
            render_and_present(lp, comp, state)

# Index of the window with `id` in the compositor's current window list, or -1.
fn window_index_of(comp: HostCompositor, id: i64) -> i32:
    var i = 0
    while i < comp.windows.len():
        if comp.windows[i].id == id:
            return i
        i = i + 1
    -1

# Center x of a window's taskbar item, for synthesizing a taskbar click.
fn taskbar_click_x(comp: HostCompositor, id: i64) -> i32:
    val count = comp.windows.len().to_i32()
    val item_w = host_taskbar_item_width(W, count)
    host_taskbar_item_x(W, count, window_index_of(comp, id)) + item_w / 2

# Launch one app as an internal window and log the growth marker.
fn launch_app(comp: HostCompositor, seq: i64, owner_port: i64, title: text, x: i32, y: i32, w: i32, h: i32, content: text, pid: i64, app_id: text):
    comp.apply_bridge_request(seq, owner_port, COMP_CREATE_WINDOW.to_i64(), 0, title, x, y, w, h, content, pid, app_id)
    print "[wm-multiapp] launched app={title} windows={comp.windows.len()} taskbar_items={comp.windows.len()}"

fn main() -> i64:
    print "WM Multi-App Taskbar GUI — launch apps + working taskbar on live Simple WM (winit buffer)"

    if (env_get("SIMPLE_GUI") ?? "") != "1":
        print "[wm-multiapp] error=no-gui-requested (launch via the gate)"
        return 2

    val lp = winit_loop_new()
    if not lp.is_valid:
        print "[wm-multiapp] error=no-gui-runtime"
        return 1
    print "[wm-multiapp] stage=winit-loop-ready"
    val win = winit_window_new(lp, W.to_i64(), H.to_i64(), "Simple WM — Multi-App")
    if not win.is_valid:
        print "[wm-multiapp] error=window-create-failed"
        winit_loop_free(lp)
        return 1
    print "[wm-multiapp] stage=winit-window-ready"
    val backend_opt = HostedWinitBufferBackend.create(win.handle, W, H, BG)
    if not backend_opt.?:
        print "[wm-multiapp] error=buffer-create-failed"
        winit_window_free(win)
        winit_loop_free(lp)
        return 1
    val backend = backend_opt ?? HostedWinitBufferBackend.new(0, 0, W, H)
    print "[wm-multiapp] stage=winit-buffer-ready"

    print "[wm-multiapp] stage=winit-compositor-backend-create"
    host_wm_force_direct_chrome(true)
    # comp is `var`: launch_app mutates it in place (class params pass by
    # reference, so `me` apply_bridge_request persists), but the interaction free
    # functions (host_compositor_left_button_at / minimize) return a MODIFIED
    # compositor by value — their result must be captured back into comp.
    print "[wm-multiapp] stage=host-compositor-create"
    var comp = HostCompositor.new(backend, Size.wh(W, H))
    print "[wm-multiapp] stage=host-compositor-ready"

    # -----------------------------------------------------------------------
    # Launch four distinct GUI apps one at a time (markers show the taskbar count
    # growing). Positions fit a 512x384 desktop with the taskbar band at y>=322.
    # -----------------------------------------------------------------------
    launch_app(comp, 1, 101, "Terminal", 24, 40, 180, 120, "simple$ build", 901, "/sys/apps/terminal")
    launch_app(comp, 2, 102, "Editor", 220, 55, 190, 130, "main.spl", 902, "/sys/apps/editor")
    launch_app(comp, 3, 103, "File Manager", 56, 195, 180, 115, "home", 903, "/sys/apps/files")
    launch_app(comp, 4, 104, "Calculator", 290, 200, 160, 110, "0", 904, "/sys/apps/calc")

    if comp.windows.len() != 4:
        print "[wm-multiapp] error=expected-4-windows got={comp.windows.len()}"
        backend.free()
        winit_window_free(win)
        winit_loop_free(lp)
        return 1

    # Log every window's geometry + app for the gate's per-window crop mapping.
    var g = 0
    while g < comp.windows.len():
        val gw = comp.windows[g]
        print "[wm-multiapp] geom id={gw.id} app={gw.title} x={gw.x} y={gw.y} w={gw.w} h={gw.h}"
        g = g + 1
    print "[wm-multiapp] taskbar_count={comp.windows.len()}"

    # The window stays a normal 512x384 window. The gate captures it directly by
    # its CGWindowID (`screencapture -l`), which is Space/foreground-independent —
    # so there is no need to go fullscreen or fight macOS Space switching. The
    # gate validates the real captured frame size and compositor pixels.
    if not render_and_present(lp, comp, "launched-all"):
        print "[wm-multiapp] error=present-failed-launched-all"
        backend.free()
        winit_window_free(win)
        winit_loop_free(lp)
        return 1
    print "[wm-multiapp] state_ready=launched-all windows={comp.windows.len()}"
    hold(lp, comp, 2, "launched-all-live")

    # -----------------------------------------------------------------------
    # (a) Taskbar click focuses a BACKGROUND window. Calculator (last launched)
    # is focused; click Terminal's taskbar item and prove focus moves to it.
    # -----------------------------------------------------------------------
    val terminal_id: i64 = 1
    val focus_before = host_compositor_focused_window_id(comp)
    val fidx = window_index_of(comp, terminal_id)
    val cx_a = taskbar_click_x(comp, terminal_id)
    val cy_tb = H - 62 + 22
    comp = host_compositor_left_button_at(comp, true, cx_a, cy_tb)
    comp = host_compositor_left_button_at(comp, false, cx_a, cy_tb)
    val focus_after = host_compositor_focused_window_id(comp)
    print "[wm-multiapp] taskbar_focus item_index={fidx} app=Terminal before={focus_before} after={focus_after}"
    if focus_after != terminal_id:
        print "[wm-multiapp] error=taskbar-focus-did-not-change (want {terminal_id} got {focus_after})"
        backend.free()
        winit_window_free(win)
        winit_loop_free(lp)
        return 1

    # -----------------------------------------------------------------------
    # (b) Minimize the focused (Terminal), then restore it via its taskbar item.
    # -----------------------------------------------------------------------
    comp = host_compositor_minimize_focused(comp)
    val min_idx = window_index_of(comp, terminal_id)
    val terminal_minimized = comp.windows[min_idx].minimized
    print "[wm-multiapp] minimized id={terminal_id} app=Terminal minimized={terminal_minimized} focused_now={host_compositor_focused_window_id(comp)}"
    if not terminal_minimized:
        print "[wm-multiapp] error=minimize-failed"
        backend.free()
        winit_window_free(win)
        winit_loop_free(lp)
        return 1
    if not render_and_present(lp, comp, "minimized"):
        print "[wm-multiapp] error=present-failed-minimized"
        backend.free()
        winit_window_free(win)
        winit_loop_free(lp)
        return 1
    print "[wm-multiapp] state_ready=minimized windows_visible={comp.windows.len() - 1}"
    hold(lp, comp, 2, "minimized-live")

    val restore_before = host_compositor_focused_window_id(comp)
    val cx_b = taskbar_click_x(comp, terminal_id)
    comp = host_compositor_left_button_at(comp, true, cx_b, cy_tb)
    comp = host_compositor_left_button_at(comp, false, cx_b, cy_tb)
    val restore_after = host_compositor_focused_window_id(comp)
    val ridx = window_index_of(comp, terminal_id)
    val terminal_restored = not comp.windows[ridx].minimized
    print "[wm-multiapp] taskbar_restore restored_id={terminal_id} before={restore_before} after={restore_after} minimized_now={comp.windows[ridx].minimized}"
    if not terminal_restored or restore_after != terminal_id:
        print "[wm-multiapp] error=taskbar-restore-failed (minimized_now={comp.windows[ridx].minimized} focus={restore_after})"
        backend.free()
        winit_window_free(win)
        winit_loop_free(lp)
        return 1

    # -----------------------------------------------------------------------
    # Final steady state: all four windows visible again, Terminal focused. Hold
    # long so the gate can enforce frontmost and screencapture the money shot.
    # -----------------------------------------------------------------------
    var fg = 0
    while fg < comp.windows.len():
        val fw = comp.windows[fg]
        print "[wm-multiapp] final_geom id={fw.id} app={fw.title} x={fw.x} y={fw.y} w={fw.w} h={fw.h} minimized={fw.minimized}"
        fg = fg + 1
    if not render_and_present(lp, comp, "final"):
        print "[wm-multiapp] error=present-failed-final"
        backend.free()
        winit_window_free(win)
        winit_loop_free(lp)
        return 1
    val (rw, rh) = winit_window_get_size(win)
    val sf = winit_window_scale_factor(win)
    print "[wm-multiapp] final_state_ready windows={comp.windows.len()} all_visible=true window_px={rw}x{rh} scale_factor={sf}"
    # Re-present a few times across the long hold so the window keeps a live frame
    # while the gate enforces frontmost and screencaptures.
    var hh = 0
    while hh < 3:
        val ok = render_and_present(lp, comp, "final-hold")
        hold(lp, comp, 3, "final-live")
        hh = hh + 1

    print "[wm-multiapp] done windows={comp.windows.len()}"
    backend.free()
    winit_window_free(win)
    winit_loop_free(lp)
    return 0
