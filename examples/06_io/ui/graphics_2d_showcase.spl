# graphics_2d_showcase.spl — canonical standalone Engine2D primitive gallery.
#
# Headless: bin/simple run examples/06_io/ui/graphics_2d_showcase.spl
# Window:   bin/simple run examples/06_io/ui/graphics_2d_showcase_gui.spl

use std.gpu.engine2d.engine.{Engine2D}
use std.io.window_winit.{WinitInput, winit_loop_new, winit_loop_free, winit_window_new, winit_window_free, winit_present_rgba, winit_poll_input}
use std.nogc_sync_mut.concurrent.thread.{thread_sleep}

val W: i32 = 800
val H: i32 = 600
val BG: u32 = 0xFF101522u32
val PANEL: u32 = 0xFF1B2435u32
val WHITE: u32 = 0xFFF3F6FCu32
val BLUE: u32 = 0xFF3B82F6u32
val CYAN: u32 = 0xFF22D3EEu32
val GREEN: u32 = 0xFF22C55Eu32
val AMBER: u32 = 0xFFF59E0Bu32
val RED: u32 = 0xFFEF4444u32
val PURPLE: u32 = 0xFFA855F7u32

fn gpu_backend_requested(name: text) -> bool:
    name == "metal" or name == "vulkan" or name == "cuda" or
        name == "rocm" or name == "directx" or name == "opencl" or
        name == "opengl" or name == "webgpu" or name == "intel" or
        name == "qualcomm" or name == "virtio_gpu"

fn checker_pixels() -> [u32]:
    [RED, AMBER, GREEN, CYAN, BLUE, PURPLE, WHITE, PANEL,
     CYAN, BLUE, PURPLE, RED, AMBER, GREEN, PANEL, WHITE]

fn showcase_mask() -> [u8]:
    var mask: [u8] = [0u8; W * H]
    var y = 0
    while y < H:
        var x = 0
        while x < W:
            if x >= 610 and x < 780 and y >= 350 and y < 430:
                mask[y * W + x] = 255u8
            x = x + 1
        y = y + 1
    mask

fn label(e: Engine2D, x: i32, y: i32, value: text):
    e.draw_text_bg(x, y, value, WHITE, 0xCC101522u32, 12)

fn draw_showcase(e: Engine2D):
    e.clear(BG)
    e.draw_text(20, 12, "Simple Engine2D — complete primitive showcase", WHITE, 18)

    # Rectangles, outlines, rounded geometry, and line families.
    e.draw_rect_filled(18, 48, 245, 150, PANEL)
    label(e, 28, 55, "RECT / LINE")
    e.draw_rect(30, 80, 55, 38, BLUE)
    e.draw_rect_filled(94, 80, 55, 38, CYAN)
    e.draw_rect_thick(158, 80, 55, 38, GREEN, 4)
    e.draw_rounded_rect(30, 130, 80, 45, 12, PURPLE)
    e.draw_rounded_rect_outline(122, 130, 92, 45, 12, AMBER, 3)
    e.draw_line(30, 185, 215, 185, RED, 3)
    e.draw_polyline([30, 65, 100, 140, 180, 215], [190, 178, 194, 176, 193, 180], 6, CYAN, 2)

    # Circles, ellipses, arcs, triangles, polygon, and cubic bezier.
    e.draw_rect_filled(276, 48, 250, 245, PANEL)
    label(e, 286, 55, "CURVES / SHAPES")
    e.draw_circle(310, 105, 25, BLUE)
    e.draw_circle_filled(375, 105, 25, GREEN)
    e.draw_circle_thick(440, 105, 25, AMBER, 5)
    e.draw_ellipse(320, 165, 35, 20, CYAN)
    e.draw_ellipse_filled(405, 165, 35, 20, PURPLE)
    e.draw_arc(480, 165, 30, 30, 300, RED, 4)
    e.draw_triangle_filled(295, 225, 345, 190, 365, 245, BLUE)
    e.draw_triangle_outline(375, 245, 410, 195, 450, 245, WHITE, 3)
    e.draw_polygon_filled([465, 495, 520, 505, 475], [205, 190, 215, 248, 245], 5, GREEN)
    e.draw_bezier(290, 275, 345, 235, 430, 315, 510, 270, AMBER, 3)

    # Vertical, horizontal, and radial gradients.
    e.draw_rect_filled(539, 48, 243, 245, PANEL)
    label(e, 549, 55, "GRADIENT / EFFECT")
    e.draw_gradient_rect(551, 82, 65, 70, BLUE, PURPLE)
    e.draw_gradient_rect_h(626, 82, 65, 70, GREEN, CYAN)
    e.draw_radial_gradient(739, 117, 38, WHITE, RED)
    e.draw_shadow_rect(558, 180, 85, 55, 8, 8, 8, 0xAA000000u32)
    e.draw_rect_filled(558, 180, 85, 55, BLUE)
    e.draw_gradient_rect(660, 177, 105, 62, CYAN, PURPLE)
    e.draw_blur_rect(680, 192, 65, 32, 5)
    e.draw_rect_blend(558, 252, 65, 25, 0x887C3AEDu32)
    e.draw_rect_blend_mode(635, 252, 65, 25, 0xAA22C55Eu32, 1)

    # Generated image operations and text backgrounds.
    e.draw_rect_filled(18, 307, 365, 130, PANEL)
    label(e, 28, 315, "IMAGE / TEXT")
    val image = checker_pixels()
    e.draw_image(30, 345, 4, 4, image)
    e.draw_image_blend(65, 345, 4, 4, image)
    e.draw_image_scaled(105, 345, 64, 64, 4, 4, image)
    e.draw_image_transform(185, 345, 4, 4, 256, 64, 0, 256, 0, 0, image)
    e.draw_text(235, 350, "glyph text", GREEN, 14)
    e.draw_text_bg(235, 380, "text background", WHITE, BLUE, 14)

    # Clip is visibly confined to the cyan frame.
    e.draw_rect_filled(397, 307, 180, 130, PANEL)
    label(e, 407, 315, "CLIP")
    e.draw_rect(414, 346, 142, 70, CYAN)
    e.set_clip(416, 348, 138, 66)
    e.draw_circle_filled(416, 380, 55, RED)
    e.draw_rect_filled(480, 340, 100, 85, PURPLE)
    e.clear_clip()

    # Full-frame alpha mask confines this draw to the lower-right mask region.
    e.draw_rect_filled(591, 307, 191, 130, PANEL)
    label(e, 601, 315, "MASK")
    val mask = showcase_mask()
    e.set_mask(mask, W, H)
    e.draw_gradient_rect_h(600, 350, 180, 80, AMBER, RED)
    e.clear_mask()

    # Engine-to-engine composition, with normal and reduced opacity copies.
    var child = Engine2D.create_with_backend_fast(80, 60, "software")
    child.clear(0x00000000u32)
    child.draw_rounded_rect(5, 5, 70, 50, 10, BLUE)
    child.draw_circle_filled(40, 30, 16, AMBER)
    child.present()
    e.draw_rect_filled(18, 452, 570, 125, PANEL)
    label(e, 28, 460, "ENGINE COMPOSITION / OPACITY")
    e.draw_engine(38, 495, child)
    e.draw_engine_opacity(138, 495, child, 450)
    child.shutdown()

fn pack_rgb(pixels: [u32]) -> [i64]:
    var packed: [i64] = [0i64; pixels.len()]
    var i = 0
    while i < pixels.len():
        packed[i] = pixels[i].to_i64() & 0xFFFFFF
        i = i + 1
    packed

fn should_close(input: WinitInput) -> bool:
    if input.close:
        return true
    for key in input.keys:
        if key == 27 or key == 81 or key == 113:
            return true
    false

fn semantic_sample_differences(pixels: [u32]) -> i32:
    # Exact interiors of five independently rendered primitives. Adjacent
    # samples must differ, preventing a uniform/background-only frame from
    # satisfying the showcase evidence contract.
    val samples = [pixels[90 * W + 100], pixels[105 * W + 375],
                   pixels[200 * W + 570], pixels[165 * W + 405],
                   pixels[590 * W + 790]]
    var differences = 0
    var i = 1
    while i < samples.len():
        if samples[i] != samples[i - 1]:
            differences = differences + 1
        i = i + 1
    differences

fn run_graphics_2d_showcase(gui: bool, backend: text) -> i64:
    var engine = if backend == "software": Engine2D.create_offscreen(W, H) else: Engine2D.create_with_backend_fast(W, H, backend)
    val actual = engine.backend_name()
    draw_showcase(engine)
    engine.present()
    val readback = engine.read_pixels_with_source()
    var nonzero = 0
    for pixel in readback.pixels:
        if pixel != 0u32:
            nonzero = nonzero + 1
    val semantic_differences = semantic_sample_differences(readback.pixels)
    val gpu_requested = gpu_backend_requested(backend)
    print "graphics_2d_requested_backend={backend}"
    print "graphics_2d_backend={actual}"
    print "graphics_2d_source={readback.source}"
    print "graphics_2d_backend_handle={readback.backend_handle}"
    print "graphics_2d_checksum={readback.checksum}"
    print "graphics_2d_nonzero={nonzero}"
    print "graphics_2d_semantic_differences={semantic_differences}"
    print "graphics_2d_dimensions={W}x{H}"
    print "graphics_2d_pixels={readback.pixel_count}"
    if actual != backend or readback.pixel_count != (W * H).to_i64() or
            readback.checksum == 0 or nonzero == 0 or semantic_differences < 4:
        engine.shutdown()
        return 1
    if gpu_requested and (readback.source != "device_readback" or readback.backend_handle <= 0):
        engine.shutdown()
        return 1

    if not gui:
        engine.shutdown()
        return 0

    val lp = winit_loop_new()
    if not lp.is_valid:
        engine.shutdown()
        return 1
    val win = winit_window_new(lp, W.to_i64(), H.to_i64(), "Simple Engine2D Showcase")
    if not win.is_valid:
        winit_loop_free(lp)
        engine.shutdown()
        return 1
    val packed = pack_rgb(readback.pixels)
    winit_present_rgba(win, W.to_i64(), H.to_i64(), packed)
    var running = true
    while running:
        val input = winit_poll_input(lp)
        running = not should_close(input)
        thread_sleep(16)
    winit_window_free(win)
    winit_loop_free(lp)
    engine.shutdown()
    0

fn main() -> i64:
    run_graphics_2d_showcase(false, "software")

export run_graphics_2d_showcase
