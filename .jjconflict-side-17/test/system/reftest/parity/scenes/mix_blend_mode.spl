# mix_blend_mode scene — CSS mix-blend-mode Darken, cull 301x300

use std.skia.entity.picture.{SkPicture, SkPictureOp, SkPictureOpKind, sk_picture_op_draw_rect}
use std.skia.entity.paint.{SkPaint, sk_paint_fill}
use std.skia.entity.geometry.{SkRect}
use std.skia.entity.enums.{SkBlendMode}
use std.skia.entity.color.{sk_color_argb}

fn scene() -> SkPicture:
    val cull = SkRect(left: 0.0, top: 0.0, right: 301.0, bottom: 300.0)
    # Bottom rect: yellow
    val bottom = SkRect(left: 20.0, top: 20.0, right: 250.0, bottom: 200.0)
    val paint_bottom = sk_paint_fill(sk_color_argb(255, 255, 220, 0))
    # Top rect overlapping, blend_mode=Darken
    val top = SkRect(left: 80.0, top: 80.0, right: 280.0, bottom: 260.0)
    val base_top = sk_paint_fill(sk_color_argb(255, 0, 100, 200))
    val paint_top = base_top.with_blend_mode(SkBlendMode.Darken)
    val ops = [SkPictureOp]()
    ops.push(sk_picture_op_draw_rect(bottom, paint_bottom))
    ops.push(sk_picture_op_draw_rect(top, paint_top))
    SkPicture(cull_rect: cull, op_count: ops.len() as i64, ops: ops)
