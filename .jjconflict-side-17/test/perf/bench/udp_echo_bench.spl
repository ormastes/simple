"""
UDP Echo Benchmark — measures UDP round-trip throughput via IoDriver.

Spawns a UDP echo server on 127.0.0.1:19876, then sends N packets from
a client socket and counts successful round-trips per second.

Usage:
    bin/simple run test/perf/bench/udp_echo_bench.spl
"""

use std.nogc_async_mut.io.driver.{IoDriver}
use std.nogc_async_mut.io.udp.{AsyncUdpSocket}
use std.io.types.{IoError, IoErrorKind}
use std.nogc_sync_mut.io.tcp.{tcp_backend_set_nonblocking}

extern fn rt_io_udp_bind(addr: text) -> i64
extern fn rt_io_udp_close(fd: i64) -> bool
extern fn rt_time_ms() -> i64

val SERVER_ADDR = "127.0.0.1:19876"
val CLIENT_ADDR = "127.0.0.1:19877"
val PACKET_COUNT = 5000
val PAYLOAD = "hello-udp-bench-payload-64bytes-padding-xxxxxxxxxxxxxxxxxxxxxxxxx"

fn main():
    print "=== UDP Echo Benchmark ==="
    print "  Packets: {PACKET_COUNT}"
    print "  Payload: {PAYLOAD.len()} bytes"

    val driver = IoDriver.new()

    val server_res = AsyncUdpSocket.bind(driver, SERVER_ADDR)
    if server_res.is_err():
        print "FAIL: cannot bind server to {SERVER_ADDR}"
        return

    val server = server_res.unwrap()
    tcp_backend_set_nonblocking(server.fd(), true)

    val client_res = AsyncUdpSocket.bind(driver, CLIENT_ADDR)
    if client_res.is_err():
        print "FAIL: cannot bind client to {CLIENT_ADDR}"
        server.close()
        return

    val client = client_res.unwrap()
    tcp_backend_set_nonblocking(client.fd(), true)

    print "  Server bound: {SERVER_ADDR}"
    print "  Client bound: {CLIENT_ADDR}"

    val start = rt_time_ms()
    var sent = 0
    var received = 0
    var server_echoed = 0

    var send_ops: Dict<i64, bool> = {}
    var recv_ops: Dict<i64, bool> = {}
    var server_recv_op = server.recv_from(1024)

    while sent < PACKET_COUNT:
        val op = client.send_to(PAYLOAD, SERVER_ADDR)
        send_ops[op] = true
        sent = sent + 1

        if sent % 100 == 0 or sent == PACKET_COUNT:
            driver.flush()
            val count = driver.poll_count(256, 10)
            var idx = 0
            while idx < count:
                val op_id = driver.poll_id(idx)
                val result = driver.poll_result(idx)

                if op_id == server_recv_op:
                    if result > 0:
                        server_echoed = server_echoed + 1
                        val echo_op = server.send_to(PAYLOAD, CLIENT_ADDR)
                        server_recv_op = server.recv_from(1024)
                elif recv_ops.get(op_id).?:
                    if result > 0:
                        received = received + 1
                    recv_ops.remove(op_id)

                idx = idx + 1

            val client_recv_op = client.recv_from(1024)
            recv_ops[client_recv_op] = true

    var drain_rounds = 0
    while received < server_echoed and drain_rounds < 200:
        driver.flush()
        val count = driver.poll_count(256, 10)
        var idx = 0
        while idx < count:
            val op_id = driver.poll_id(idx)
            val result = driver.poll_result(idx)

            if op_id == server_recv_op:
                if result > 0:
                    server_echoed = server_echoed + 1
                    val echo_op = server.send_to(PAYLOAD, CLIENT_ADDR)
                    server_recv_op = server.recv_from(1024)
            elif recv_ops.get(op_id).?:
                if result > 0:
                    received = received + 1
                recv_ops.remove(op_id)

            idx = idx + 1

        if received < server_echoed:
            val client_recv_op = client.recv_from(1024)
            recv_ops[client_recv_op] = true

        drain_rounds = drain_rounds + 1

    val elapsed = rt_time_ms() - start
    val rps = if elapsed > 0: (received * 1000) / elapsed else: 0

    print ""
    print "=== Results ==="
    print "  Sent:          {sent}"
    print "  Server echoed: {server_echoed}"
    print "  Received:      {received}"
    print "  Elapsed:       {elapsed} ms"
    print "  Throughput:    {rps} round-trips/sec"
    print "  Per-packet:    {if received > 0: elapsed * 1000 / received else: 0} us"

    client.close()
    server.close()
    driver.close()

main()
