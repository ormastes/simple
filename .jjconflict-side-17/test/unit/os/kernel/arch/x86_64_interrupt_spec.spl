use std.spec
use os.kernel.arch.x86_64.interrupt.{X86Interrupt, x86_install_runtime, x86_runtime_installed, x86_dispatch_installed_syscall, x86_dispatch_installed_syscall_abi, x86_read_trap_log}
use os.kernel.arch.x86_64.trap_runtime.{X86TrapRuntime}
use os.kernel.scheduler.scheduler.{Scheduler}
use os.kernel.ipc.ipc.{IpcManager}
use os.kernel.log.klog.{KernelLog}
use os.kernel.types.syscall_types.{SyscallArgs}
use os.kernel.types.task_types.{TaskId}
use os.kernel.loader.executable_source.{_set_synthetic_vfs_file_for_test, _clear_synthetic_vfs_for_test}

describe "x86_64 interrupt runtime bridge":
    it "reports missing runtime until installed":
        expect(x86_runtime_installed()).to_equal(false)

    it "fails cleanly when syscall dispatch runs without runtime":
        val result = x86_dispatch_installed_syscall(SyscallArgs(
            id: 4,
            arg0: 0,
            arg1: 0,
            arg2: 0,
            arg3: 0,
            arg4: 0,
            arg5: 0
        ))
        expect(result.is_err()).to_equal(true)
        expect(result.err().unwrap()).to_contain("runtime is not installed")

        val entries = x86_read_trap_log(0, 0, 4)
        expect(entries.len()).to_equal(0)

    it "allows direct runtime installation":
        x86_install_runtime(Scheduler.new(), IpcManager.new(), KernelLog.new(16))
        expect(x86_runtime_installed()).to_equal(true)

    it "allows the interrupt HAL to own runtime installation":
        X86Interrupt.install_runtime(Scheduler.new(), IpcManager.new(), KernelLog.new(8))
        expect(X86Interrupt.runtime_installed()).to_equal(true)

    it "accepts a precomposed trap runtime bundle":
        val runtime = X86TrapRuntime.new(Scheduler.new(), IpcManager.new(), KernelLog.new(8))
        X86Interrupt.install_runtime_bundle(runtime)
        expect(X86Interrupt.runtime_installed()).to_equal(true)

    it "accepts a bootstrap runtime install":
        X86Interrupt.install_bootstrap_runtime(8)
        expect(X86Interrupt.runtime_installed()).to_equal(true)

    it "dispatches a syscall through installed runtime objects":
        x86_install_runtime(Scheduler.new(), IpcManager.new(), KernelLog.new(16))

        val result = x86_dispatch_installed_syscall(SyscallArgs(
            id: 4,
            arg0: 0,
            arg1: 0,
            arg2: 0,
            arg3: 0,
            arg4: 0,
            arg5: 0
        ))
        expect(result.is_err()).to_equal(false)
        expect(result.unwrap().value).to_equal(0)

    it "exposes a primitive ABI bridge for C-side callers":
        x86_install_runtime(Scheduler.new(), IpcManager.new(), KernelLog.new(16))
        expect(x86_dispatch_installed_syscall_abi(4, 0, 0, 0, 0, 0, 0)).to_equal(0)

    it "preserves scheduler state for direct spawn through the installed bundle":
        _clear_synthetic_vfs_for_test()
        _set_synthetic_vfs_file_for_test("/sys/apps/hello_world", _make_x86_64_exec())

        var scheduler = Scheduler.new()
        val runtime = X86TrapRuntime.new(scheduler, IpcManager.new(), KernelLog.new(16))
        X86Interrupt.install_runtime_bundle(runtime)

        val pid = x86_dispatch_installed_syscall_abi(13, 3, 0, 2, 0, 0, 0)
        expect(pid).to_be_greater_than(0)

        val spawned = scheduler.get_task(TaskId(id: pid as u64))
        val found = if spawned == nil: 0 else: 1
        expect(found).to_equal(1)
        if spawned != nil:
            val task = spawned
            expect(task.is_user).to_equal(true)
            expect(task.entry_point).to_equal(0x400000)

        _clear_synthetic_vfs_for_test()

fn _push_u16_le(buf: [u8], value: i64) -> [u8]:
    buf.push((value & 0xFF).to_u8())
    buf.push(((value >> 8) & 0xFF).to_u8())
    buf

fn _push_u32_le(buf: [u8], value: i64) -> [u8]:
    buf.push((value & 0xFF).to_u8())
    buf.push(((value >> 8) & 0xFF).to_u8())
    buf.push(((value >> 16) & 0xFF).to_u8())
    buf.push(((value >> 24) & 0xFF).to_u8())
    buf

fn _push_u64_le(buf: [u8], value: i64) -> [u8]:
    var out = buf
    out = _push_u32_le(out, value & 0xFFFFFFFF)
    out = _push_u32_le(out, (value >> 32) & 0xFFFFFFFF)
    out

fn _make_x86_64_exec() -> [u8]:
    var bytes: [u8] = []
    bytes.push(0x7F.to_u8())
    bytes.push(0x45.to_u8())
    bytes.push(0x4C.to_u8())
    bytes.push(0x46.to_u8())
    bytes.push(2.to_u8())
    bytes.push(1.to_u8())
    bytes.push(1.to_u8())
    bytes.push(0.to_u8())
    bytes.push(0.to_u8())
    while bytes.len() < 16:
        bytes.push(0.to_u8())
    bytes = _push_u16_le(bytes, 2)
    bytes = _push_u16_le(bytes, 62)
    bytes = _push_u32_le(bytes, 1)
    bytes = _push_u64_le(bytes, 0x400000)
    bytes = _push_u64_le(bytes, 64)
    bytes = _push_u64_le(bytes, 0)
    bytes = _push_u32_le(bytes, 0)
    bytes = _push_u16_le(bytes, 64)
    bytes = _push_u16_le(bytes, 56)
    bytes = _push_u16_le(bytes, 1)
    bytes = _push_u16_le(bytes, 0)
    bytes = _push_u16_le(bytes, 0)
    bytes = _push_u16_le(bytes, 0)
    bytes = _push_u32_le(bytes, 1)
    bytes = _push_u32_le(bytes, 5)
    bytes = _push_u64_le(bytes, 0x1000)
    bytes = _push_u64_le(bytes, 0x400000)
    bytes = _push_u64_le(bytes, 0x400000)
    bytes = _push_u64_le(bytes, 4)
    bytes = _push_u64_le(bytes, 4)
    bytes = _push_u64_le(bytes, 0x1000)
    while bytes.len() < 0x1000:
        bytes.push(0.to_u8())
    bytes.push(0xC3.to_u8())
    bytes
