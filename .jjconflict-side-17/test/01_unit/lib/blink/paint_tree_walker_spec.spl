# @cover src/lib/blink/paint/paint_tree_walker.spl 80%
"""
# Blink PaintTreeWalker Specification

**Category:** Browser / Blink / Paint
**Status:** Active

## Overview

Tests for paint_tree_walker: PaintContext creation, style lookup, background
fill emission, transparent-background suppression, and full two-box walk.
Mirrors Blink's BlockPainter / BoxPainter block-box paint pass.
"""

use std.spipe.*
use std.lib.blink.layout.block_flow.{
    BoxGeometry, LayoutBox, LayoutContext,
    box_geometry_zero, box_geometry_new,
    layout_box_new, layout_context_new
}
use std.lib.blink.entity.computed_style.{
    ComputedStyle, computed_style_default
}
use std.lib.blink.paint.paint_tree_walker.{
    StyledBox, PaintContext,
    paint_tree_new, finalize_paint, paint_tree
}
use std.lib.skia.entity.color.{sk_color4f}

# ============================================================================
# Helpers
# ============================================================================

fn make_ctx_800x600() -> LayoutContext:
    layout_context_new(800.0, 600.0)

fn make_opaque_style() -> ComputedStyle:
    val s = computed_style_default()
    # background_color with a = 1.0 (fully opaque red)
    s.background_color = sk_color4f(1.0, 0.0, 0.0, 1.0)
    s

fn make_transparent_style() -> ComputedStyle:
    val s = computed_style_default()
    # background_color with a = 0.0 (fully transparent — default)
    s.background_color = sk_color4f(0.0, 0.0, 0.0, 0.0)
    s

fn make_single_box_ctx() -> LayoutContext:
    val geo = box_geometry_new(200.0, 100.0, 0.0, 0.0, 0.0)
    val root = layout_box_new(1, geo)
    val ctx = make_ctx_800x600()
    ctx.add_box(root)
    ctx.set_root(1)
    ctx.compute_layout()
    ctx

fn make_two_box_ctx() -> LayoutContext:
    val parent_geo = box_geometry_new(400.0, 300.0, 0.0, 0.0, 0.0)
    val parent = layout_box_new(10, parent_geo)
    parent.children_ids.push(11)

    val child_geo = box_geometry_new(200.0, 100.0, 0.0, 0.0, 0.0)
    val child = layout_box_new(11, child_geo)

    val ctx = make_ctx_800x600()
    ctx.add_box(parent)
    ctx.add_box(child)
    ctx.set_root(10)
    ctx.compute_layout()
    ctx

# ============================================================================
# paint_tree_new
# ============================================================================

describe "paint_tree_new":
    it "creates PaintContext with recorder-attached canvas":
        val ctx = make_ctx_800x600()
        val styles = [StyledBox]()
        val pc = paint_tree_new(ctx, styles)
        # Canvas must have a recorder attached — verified by checking width/height
        # match the viewport and that end_recording yields a valid SkPicture.
        expect(pc.canvas.width).to_equal(800)
        expect(pc.canvas.height).to_equal(600)
        val pic = finalize_paint(pc)
        # A freshly started recording with no draw calls has 0 ops.
        expect(pic.op_count).to_equal(0)

# ============================================================================
# find_style
# ============================================================================

describe "find_style":
    it "missing layout_id returns None":
        val ctx = make_ctx_800x600()
        val styles = [StyledBox]()
        val pc = paint_tree_new(ctx, styles)
        val result = pc.find_style(99)
        expect(result is None).to_equal(true)

    it "present layout_id returns Some":
        val ctx = make_ctx_800x600()
        val sb = StyledBox(layout_id: 42, style: make_opaque_style())
        val styles = [StyledBox]()
        styles.push(sb)
        val pc = paint_tree_new(ctx, styles)
        val result = pc.find_style(42)
        expect(result is None).to_equal(false)

# ============================================================================
# paint_box — background-color emission
# ============================================================================

describe "paint_box":
    it "background color with a>0 emits a DrawRect op in the canvas' recorder":
        val ctx = make_single_box_ctx()
        val sb = StyledBox(layout_id: 1, style: make_opaque_style())
        val styles = [StyledBox]()
        styles.push(sb)
        val pc = paint_tree_new(ctx, styles)
        pc.paint_box(1, 0.0, 0.0)
        val pic = finalize_paint(pc)
        # One DrawRect op expected for the opaque background fill.
        expect(pic.op_count).to_be_greater_than(0)

    it "transparent background (a=0) emits no ops":
        val ctx = make_single_box_ctx()
        val sb = StyledBox(layout_id: 1, style: make_transparent_style())
        val styles = [StyledBox]()
        styles.push(sb)
        val pc = paint_tree_new(ctx, styles)
        pc.paint_box(1, 0.0, 0.0)
        val pic = finalize_paint(pc)
        # Transparent background must produce zero ops.
        expect(pic.op_count).to_equal(0)

# ============================================================================
# paint_tree — full walk
# ============================================================================

describe "paint_tree":
    it "full walk of 2 boxes emits 2 DrawRect ops (parent + child)":
        val ctx = make_two_box_ctx()
        val sb_parent = StyledBox(layout_id: 10, style: make_opaque_style())
        val sb_child  = StyledBox(layout_id: 11, style: make_opaque_style())
        val styles = [StyledBox]()
        styles.push(sb_parent)
        styles.push(sb_child)
        val pic = paint_tree(ctx, styles)
        # Exactly 2 DrawRect ops: one for parent background, one for child.
        expect(pic.op_count).to_equal(2)
