# @cover src/os/services/nvfs/src/fs_driver/capability.spl 80%
"""
# NVFS FsCapabilitySet Unit Tests

**Feature IDs:** #NVFS-FS-DRIVER-CAP
**Category:** Infrastructure
**Difficulty:** 2/5
**Status:** In Progress
**Design:** doc/05_design/nvfs_design.md §5.1

## Overview

Tests for the Capability enum and FsCapabilitySet struct:
  - empty() has no caps, count=0
  - with(cap) adds one cap
  - multiple with() calls accumulate caps
  - union() merges two sets
  - with(cap) is idempotent (no duplicates)
  - all current caps can be added
"""

use std.spipe.*
use std.fs_driver.capability.*


# ============================================================================
# empty() baseline
# ============================================================================

describe "FsCapabilitySet — empty()":
    """
    ## Empty set invariants

    empty() must have no capabilities and count=0.
    """

    it "empty() has no COW capability":
        val cs = FsCapabilitySet.empty()
        expect(cs.has(Capability.COW)).to_equal(false)

    it "empty() count is 0":
        val cs = FsCapabilitySet.empty()
        expect(cs.count()).to_equal(0)


# ============================================================================
# with(cap) — single cap
# ============================================================================

describe "FsCapabilitySet — with(cap)":
    """
    ## Adding a single capability

    with(cap) returns a new set that has the cap and nothing else.
    """

    it "with(COW) has COW":
        val cs = FsCapabilitySet.empty().with(Capability.COW)
        expect(cs.has(Capability.COW)).to_equal(true)

    it "with(COW) does not have Snapshot":
        val cs = FsCapabilitySet.empty().with(Capability.COW)
        expect(cs.has(Capability.Snapshot)).to_equal(false)

    it "with(COW).with(Snapshot) has both, count=2":
        val cs = FsCapabilitySet.empty().with(Capability.COW).with(Capability.Snapshot)
        expect(cs.has(Capability.COW)).to_equal(true)
        expect(cs.has(Capability.Snapshot)).to_equal(true)
        expect(cs.count()).to_equal(2)


# ============================================================================
# union()
# ============================================================================

describe "FsCapabilitySet — union()":
    """
    ## Merging two sets

    union(other) produces a set with all caps from both operands.
    """

    it "union merges caps from both sets":
        val a = FsCapabilitySet.empty().with(Capability.COW)
        val b = FsCapabilitySet.empty().with(Capability.Snapshot)
        val c = a.union(b)
        expect(c.has(Capability.COW)).to_equal(true)
        expect(c.has(Capability.Snapshot)).to_equal(true)

    it "union of identical sets has same count":
        val a = FsCapabilitySet.empty().with(Capability.COW)
        val b = FsCapabilitySet.empty().with(Capability.COW)
        val c = a.union(b)
        expect(c.count()).to_equal(1)


# ============================================================================
# Idempotency
# ============================================================================

describe "FsCapabilitySet — idempotency":
    """
    ## with() is idempotent

    Adding the same cap twice must not increase count beyond 1.
    """

    it "with(COW).with(COW) is idempotent, count=1":
        val cs = FsCapabilitySet.empty().with(Capability.COW).with(Capability.COW)
        expect(cs.count()).to_equal(1)


# ============================================================================
# All capabilities
# ============================================================================

describe "FsCapabilitySet — all capabilities":
    """
    ## Full capability coverage

    Verifies every known variant can be stored and retrieved.
    """

    it "all current caps can be added and queried":
        var cs = FsCapabilitySet.empty()
        cs = cs.with(Capability.COW)
        cs = cs.with(Capability.Snapshot)
        cs = cs.with(Capability.Clone)
        cs = cs.with(Capability.Dedup)
        cs = cs.with(Capability.Checksum)
        cs = cs.with(Capability.SelfHeal)
        cs = cs.with(Capability.SendReceive)
        cs = cs.with(Capability.Compress)
        cs = cs.with(Capability.Encrypt)
        cs = cs.with(Capability.Quota)
        cs = cs.with(Capability.Reflink)
        cs = cs.with(Capability.Atime)
        cs = cs.with(Capability.Xattr)
        cs = cs.with(Capability.Acl)
        cs = cs.with(Capability.CaseFold)
        cs = cs.with(Capability.Hardlinks)
        cs = cs.with(Capability.SparseFiles)
        cs = cs.with(Capability.LargeFiles)
        cs = cs.with(Capability.UnicodeNames)
        cs = cs.with(Capability.CaseSensitive)
        cs = cs.with(Capability.PosixCompat)
        cs = cs.with(Capability.AsyncIo)
        cs = cs.with(Capability.DirectIo)
        expect(cs.count()).to_equal(23)
        expect(cs.has(Capability.COW)).to_equal(true)
        expect(cs.has(Capability.DirectIo)).to_equal(true)
