use std.spec.{describe, it, expect}

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

fn _run_game(args: [text]) -> (text, text, i64):
    val joined = args.join(" ")
    rt_process_run("/bin/sh", [
        "-c",
        "REPO=$(pwd); SIMPLE_LIB=\"$REPO/src\" \"$REPO/bin/simple\" run \"$REPO/src/app/game/main.spl\" " + joined
    ])

describe "game log mode CLI options":
    it "shows shared log options in help":
        val (out, err, code) = _run_game(["--help"])
        expect(code).to_equal(0)
        expect(out).to_contain("Usage: simple game")
        expect(out).to_contain("--log-mode")
        expect(out).to_contain("--progress")

    it "supports log-mode json for usage output":
        val (out, err, code) = _run_game(["--log-mode=json"])
        expect(code).to_equal(0)
        expect(out).to_contain("\"command\":\"game\"")
        expect(out).to_contain("\"status\":\"usage\"")

    it "supports dot progress for help output":
        val (out, err, code) = _run_game(["--progress=dot", "--help"])
        expect(code).to_equal(0)
        expect(out).to_start_with(".")
        expect(out).to_contain("Usage: simple game")

    it "rejects invalid log mode":
        val (out, err, code) = _run_game(["--log-mode=noisy"])
        expect(code).to_equal(1)

    it "emits json for unknown subcommands":
        val (out, err, code) = _run_game(["--log-mode=json", "bogus"])
        expect(code).to_equal(2)
        expect(out).to_contain("\"command\":\"game\"")
        expect(out).to_contain("\"status\":\"error\"")
