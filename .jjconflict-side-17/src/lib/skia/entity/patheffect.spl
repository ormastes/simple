# Skia PathEffect
#
# SkPathEffect — modifies the geometry of a path before stroking/filling.

# ============================================================================
# SkPathEffectKind
# ============================================================================

enum SkPathEffectKind:
    Dash
    Discrete
    CornerPathEffect
    Compose
    Sum
    Trim
    Empty

# ============================================================================
# SkPathEffect
# ============================================================================

class SkPathEffect:
    kind: SkPathEffectKind
    # dash effect
    intervals: [f64]
    phase: f64
    # discrete effect
    seg_length: f64
    deviation: f64
    # trim effect
    start_t: f64
    stop_t: f64

fn sk_path_effect_dash(intervals: [f64], phase: f64) -> SkPathEffect:
    SkPathEffect(
        kind: SkPathEffectKind.Dash,
        intervals: intervals,
        phase: phase,
        seg_length: 0.0,
        deviation: 0.0,
        start_t: 0.0,
        stop_t: 1.0
    )

fn sk_path_effect_discrete(seg_length: f64, deviation: f64) -> SkPathEffect:
    SkPathEffect(
        kind: SkPathEffectKind.Discrete,
        intervals: [],
        phase: 0.0,
        seg_length: seg_length,
        deviation: deviation,
        start_t: 0.0,
        stop_t: 1.0
    )

fn sk_path_effect_trim(start_t: f64, stop_t: f64) -> SkPathEffect:
    SkPathEffect(
        kind: SkPathEffectKind.Trim,
        intervals: [],
        phase: 0.0,
        seg_length: 0.0,
        deviation: 0.0,
        start_t: start_t,
        stop_t: stop_t
    )

impl SkPathEffect:
    fn to_string() -> text:
        "SkPathEffect({self.kind})"
