# Glyph cache module — re-exports.
#
# Mirrors Skia's SkGlyphCache / SkStrikeCache: bounded LRU cache of
# rasterized glyph bitmaps keyed by (font hash, glyph id, size).

use std.skia.feature.glyph_cache.cache.{
    GlyphCacheKey,
    GlyphCacheEntry,
    GlyphCache,
    glyph_cache_new,
    glyph_cache_key_equal,
    hash_font
}

export GlyphCacheKey
export GlyphCacheEntry
export GlyphCache
export glyph_cache_new
export glyph_cache_key_equal
export hash_font
