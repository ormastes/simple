# EditorMode — editor operating modes

# ============================================================================
# EditorMode
# ============================================================================

enum EditorMode:
    Edit2D
    Edit3D
    Play2D
    Play3D

impl EditorMode:
    fn is_2d(self) -> bool:
        match self:
            EditorMode.Edit2D => true
            EditorMode.Play2D => true
            _ => false

    fn is_3d(self) -> bool:
        match self:
            EditorMode.Edit3D => true
            EditorMode.Play3D => true
            _ => false

    fn is_playing(self) -> bool:
        match self:
            EditorMode.Play2D => true
            EditorMode.Play3D => true
            _ => false

    fn is_editing(self) -> bool:
        match self:
            EditorMode.Edit2D => true
            EditorMode.Edit3D => true
            _ => false

    fn to_text(self) -> text:
        match self:
            EditorMode.Edit2D => "Edit2D"
            EditorMode.Edit3D => "Edit3D"
            EditorMode.Play2D => "Play2D"
            EditorMode.Play3D => "Play3D"
