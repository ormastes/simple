#![allow(primitive_api)]
use std.io_runtime
use std.nogc_sync_mut.spec.{describe, it, expect}
use std.nogc_sync_mut.debug.remote.target.x86_64.X86_64Target
use std.nogc_sync_mut.debug.remote.target.simpleos.SimpleOsTarget

fn main():
    describe("X86_64Target"):
        var target = X86_64Target.create()

        it("has 24 registers"):
            expect(target.register_count()).to_equal(24)

        it("returns correct name"):
            expect(target.name()).to_equal("x86_64")

        it("returns rax at index 0"):
            expect(target.register_name(0)).to_equal("rax")

        it("returns rip at index 16"):
            expect(target.register_name(16)).to_equal("rip")

        it("returns rflags at index 17"):
            expect(target.register_name(17)).to_equal("rflags")

        it("returns gs at index 23"):
            expect(target.register_name(23)).to_equal("gs")

        it("maps rax name to index 0"):
            expect(target.register_index("rax")).to_equal(0)

        it("maps rip name to index 16"):
            expect(target.register_index("rip")).to_equal(16)

        it("returns -1 for unknown register"):
            expect(target.register_index("xmm0")).to_equal(-1)

        it("has pc register at index 16"):
            expect(target.pc_register_index()).to_equal(16)

        it("has sp register at index 7"):
            expect(target.sp_register_index()).to_equal(7)

        it("has fp register at index 6"):
            expect(target.fp_register_index()).to_equal(6)

        it("has return register at index 0"):
            expect(target.return_register_index()).to_equal(0)

        it("has 8-byte registers"):
            expect(target.register_size(0)).to_equal(8)

        it("has correct arg registers"):
            val t = X86_64Target.create()
            val args = t.arg_registers()
            expect(args.len()).to_equal(6)
            expect(args[0]).to_equal(5)
            expect(args[1]).to_equal(4)
            expect(args[5]).to_equal(9)

        it("has correct callee saved registers"):
            val t = X86_64Target.create()
            val saved = t.callee_saved_registers()
            expect(saved.len()).to_equal(6)
            expect(saved[0]).to_equal(1)
            expect(saved[1]).to_equal(6)

        it("has INT3 breakpoint instruction"):
            val t = X86_64Target.create()
            val bp = t.breakpoint_instruction()
            expect(bp.len()).to_equal(1)
            expect(bp[0]).to_equal(0xCC)

        it("supports single step"):
            expect(target.supports_single_step()).to_equal(true)

        it("has 4 hw breakpoints"):
            expect(target.hw_breakpoint_count()).to_equal(4)

    describe("SimpleOsTarget"):
        var os_target = SimpleOsTarget.create()

        it("delegates register_count to X86_64Target"):
            expect(os_target.register_count()).to_equal(24)

        it("delegates name to X86_64Target"):
            expect(os_target.name()).to_equal("x86_64")

        it("delegates pc_register_index to X86_64Target"):
            expect(os_target.pc_register_index()).to_equal(16)

        it("identifies kernel addresses"):
            expect(os_target.is_kernel_addr(0xFFFFFFFF80000000)).to_equal(true)
            expect(os_target.is_kernel_addr(0xFFFFFFFF80001000)).to_equal(true)

        it("identifies user addresses"):
            expect(os_target.is_kernel_addr(0x00400000)).to_equal(false)
            expect(os_target.is_kernel_addr(0x00000000)).to_equal(false)
