fn _ponytail_line_count(source: text) -> i64:
    if source == "":
        return 0
    var count: i64 = 1
    for ch in source:
        if ch == "\n":
            count = count + 1
    count

fn _ponytail_count(source: text, needle: text) -> i64:
    var count: i64 = 0
    for line in source.split("\n"):
        if line.contains(needle):
            count = count + 1
    count

fn ponytail_audit_source(path: text, source: text) -> text:
    var lines: [text] = []
    lines.push("Ponytail Audit")
    lines.push("source: " + path)
    lines.push("lines: " + str(_ponytail_line_count(source)))

    val placeholder_count = _ponytail_count(source, "pass_todo") + _ponytail_count(source, "expect(true).to_equal(true)")
    val abstraction_count = _ponytail_count(source, "interface ") + _ponytail_count(source, "factory") + _ponytail_count(source, "Factory")
    val todo_count = _ponytail_count(source, "TODO") + _ponytail_count(source, "todo")

    if placeholder_count == 0 and abstraction_count == 0 and todo_count == 0:
        lines.push("status: ok")
    else:
        lines.push("status: review")
    if placeholder_count > 0:
        lines.push("placeholder markers: " + str(placeholder_count))
    if abstraction_count > 0:
        lines.push("abstraction smells: " + str(abstraction_count))
    if todo_count > 0:
        lines.push("todo markers: " + str(todo_count))

    lines.join("\n")

fn ponytail_simplification_report_source(path: text, source: text) -> text:
    var lines: [text] = []
    lines.push("Ponytail Simplification Report")
    lines.push("source: " + path)
    lines.push("lines: " + str(_ponytail_line_count(source)))

    val placeholder_count = _ponytail_count(source, "pass_todo") + _ponytail_count(source, "expect(true).to_equal(true)")
    val abstraction_count = _ponytail_count(source, "interface ") + _ponytail_count(source, "factory") + _ponytail_count(source, "Factory")
    val todo_count = _ponytail_count(source, "TODO") + _ponytail_count(source, "todo")
    val total = placeholder_count + abstraction_count + todo_count

    if total == 0:
        lines.push("status: ok")
        lines.push("summary: no simplification targets found")
    else:
        lines.push("status: review")
        lines.push("summary: simplification targets found")
    if placeholder_count > 0:
        lines.push("cut placeholder passes: " + str(placeholder_count))
        lines.push("replace with: real assertion or explicit unsupported result")
    if abstraction_count > 0:
        lines.push("cut speculative abstraction: " + str(abstraction_count))
        lines.push("replace with: direct function or concrete data shape")
    if todo_count > 0:
        lines.push("resolve todo markers: " + str(todo_count))
        lines.push("replace with: tracked requirement, failing test, or implementation")
    lines.push("total_suggestions: " + str(total))
    lines.join("\n")
