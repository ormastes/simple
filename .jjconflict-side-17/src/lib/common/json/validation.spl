# JSON Validation
#
# Deep equality, deep clone, and schema validation over the JSON value model.
#
# Value model (see lib.json.types):
#   ("null", nil) | ("boolean", bool) | ("number", f64)
#   ("string", text) | ("array", [any]) | ("object", {text: any})

use lib.json.types.{json_get_type, json_null, json_boolean, json_number, json_string, json_array, json_object, json_is_object, json_to_boolean, json_to_number, json_to_string, json_to_array}
use lib.json.object_ops.{json_object_keys, json_object_get, json_object_has}

fn json_deep_equals(a: any, b: any) -> bool:
    """Structurally compare two JSON values (nil counts as null-absent)."""
    if a == nil and b == nil:
        return true
    if a == nil or b == nil:
        return false
    val ta = json_get_type(a)
    val tb = json_get_type(b)
    if ta != tb:
        return false
    if ta == "null":
        return true
    if ta == "boolean":
        return json_to_boolean(a) == json_to_boolean(b)
    if ta == "number":
        return json_to_number(a) == json_to_number(b)
    if ta == "string":
        return json_to_string(a) == json_to_string(b)
    if ta == "array":
        return _json_array_deep_equals(json_to_array(a), json_to_array(b))
    if ta == "object":
        return _json_object_deep_equals(a, b)
    false

fn _json_array_deep_equals(a: any, b: any) -> bool:
    if a == nil or b == nil:
        return a == b
    if a.len() != b.len():
        return false
    var i = 0
    while i < a.len():
        if not json_deep_equals(a[i], b[i]):
            return false
        i = i + 1
    true

fn _json_object_deep_equals(a: any, b: any) -> bool:
    val ka = json_object_keys(a)
    val kb = json_object_keys(b)
    if ka.len() != kb.len():
        return false
    for key in ka:
        if not json_object_has(b, key):
            return false
        if not json_deep_equals(json_object_get(a, key), json_object_get(b, key)):
            return false
    true

fn json_deep_clone(value: any) -> any:
    """Recursively copy a JSON value into fresh tuples/containers."""
    if value == nil:
        return nil
    val t = json_get_type(value)
    if t == "null":
        return json_null()
    if t == "boolean":
        return json_boolean(json_to_boolean(value))
    if t == "number":
        return json_number(json_to_number(value))
    if t == "string":
        return json_string(json_to_string(value))
    if t == "array":
        val items = json_to_array(value)
        var out = []
        for item in items:
            out.push(json_deep_clone(item))
        return json_array(out)
    if t == "object":
        var m = {}
        for key in json_object_keys(value):
            m[key] = json_deep_clone(json_object_get(value, key))
        return json_object(m)
    value

fn json_validate_schema(value: any, schema: any) -> (bool, text):
    """Validate a JSON value against a minimal schema.

    A nil schema accepts anything. An object schema may carry a "type" key
    naming the required JSON type; mismatches are reported.
    """
    if schema == nil:
        return (true, "")
    if not json_is_object(schema):
        return (true, "")
    if json_object_has(schema, "type"):
        val expected = json_to_string(json_object_get(schema, "type"))
        if expected != nil and json_get_type(value) != expected:
            return (false, "expected type {expected}")
    (true, "")
