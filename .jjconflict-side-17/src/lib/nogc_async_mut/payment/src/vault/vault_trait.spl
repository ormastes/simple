use std.io_runtime

struct VaultToken:
    val token_id: text
    val card_last4: text
    val card_brand: text
    val expiry_month: int
    val expiry_year: int
    val created_at: text

struct StoreRequest:
    val card_number: text
    val expiry_month: int
    val expiry_year: int
    val cardholder_name: text

struct VaultResult:
    val success: bool
    val token: VaultToken
    val error_message: text

struct VaultDeleteResult:
    val success: bool
    val error_message: text

trait Vault:
    fn store_token(self, req: StoreRequest) -> VaultResult
    fn retrieve(self, token_id: text) -> VaultResult
    fn delete(self, token_id: text) -> VaultDeleteResult
    fn list_tokens(self) -> list<VaultToken>
