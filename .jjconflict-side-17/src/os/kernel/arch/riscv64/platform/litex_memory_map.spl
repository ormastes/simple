# LitexFpgaMemoryMap — memory layout for DE10-Nano / LiteX softcore targets.
#
# LiteX defaults: DRAM=0x40000000, UART=0xf0001000, CLINT=0xf0010000, PLIC=0xf0c00000.
# Free-function module implementing the RiscvBoardMemoryMap contract.
#
# IMPORTANT: all address constants are function-local hex literals.
# Module-level val constants are zero in baremetal LLVM targets because
# BSS clearing runs before any static initializer.

fn litex_uart_base() -> u64:
    """LiteX UART MMIO base address on DE10-Nano."""
    val base: u64 = 0xf0001000
    base

fn litex_ram_base() -> u64:
    """DRAM base address on DE10-Nano / LiteX."""
    val base: u64 = 0x40000000
    base

fn litex_ram_size() -> u64:
    """DRAM size: 256 MB (DE10-Nano Cyclone V has 1 GB DDR3; LiteX default window)."""
    val size: u64 = 0x10000000
    size

fn litex_heap_size() -> u64:
    """Heap reservation: top 16 MB of RAM."""
    val size: u64 = 0x01000000
    size

fn litex_heap_start() -> u64:
    """Heap start = RAM base + RAM size - heap size."""
    val base: u64 = 0x40000000
    val ram: u64 = 0x10000000
    val heap: u64 = 0x01000000
    base + ram - heap

fn litex_clint_base() -> u64:
    """LiteX CLINT base address."""
    val base: u64 = 0xf0010000
    base

fn litex_plic_base() -> u64:
    """LiteX PLIC base address."""
    val base: u64 = 0xf0c00000
    base

fn litex_board_name() -> text:
    """Board identifier string."""
    "de10nano-litex"

class LitexFpgaMemoryMap:
    """Object API wrapper for specs and hosted tooling.

    Baremetal code should keep using the free functions above so all constants
    stay function-local.
    """

    me uart_base() -> u64:
        litex_uart_base()

    me ram_base() -> u64:
        litex_ram_base()

    me ram_size() -> u64:
        litex_ram_size()

    me heap_start() -> u64:
        litex_heap_start()

    me heap_size() -> u64:
        litex_heap_size()

    me clint_base() -> u64:
        litex_clint_base()

    me plic_base() -> u64:
        litex_plic_base()

    me board_name() -> text:
        litex_board_name()

fn litex_memory_map_new() -> LitexFpgaMemoryMap:
    LitexFpgaMemoryMap()
