#!/bin/sh
# Shared helpers for normalized Simple render-log evidence.

render_log_value_of() {
    key="$1"
    file="$2"
    sed -n "s/^${key}=//p" "$file" 2>/dev/null | tail -n 1
}

render_log_append_kv() {
    key="$1"
    value="$2"
    printf '%s=%s\n' "$key" "$value"
}

render_log_original_native_format() {
    capture_tool="$1"
    artifact_magic="$2"
    case "$artifact_magic" in
        RDOC) printf '%s\n' "renderdoc-rdc" ;;
        XCODE-GPUTRACE) printf '%s\n' "xcode-gputrace" ;;
        PIX) printf '%s\n' "pix-capture" ;;
        *)
            case "$capture_tool" in
                *renderdoc*) printf '%s\n' "renderdoc-diagnostic" ;;
                *gpu-debugger*) printf '%s\n' "gpu-debugger-log" ;;
                browser-gpu-metadata) printf '%s\n' "browser-gpu-metadata" ;;
                "") printf '%s\n' "unavailable" ;;
                *) printf '%s\n' "$capture_tool" ;;
            esac
            ;;
    esac
}

render_log_is_positive_int() {
    value="$1"
    case "$value" in
        ""|*[!0-9]*) return 1 ;;
        *) [ "$value" -gt 0 ] ;;
    esac
}

render_log_is_unsigned_int() {
    value="$1"
    case "$value" in
        ""|*[!0-9]*) return 1 ;;
        *) return 0 ;;
    esac
}

render_log_argb_source_reason() {
    prefix="$1"
    source_name="$2"
    source_env="$3"
    width="$(render_log_value_of "${prefix}_${source_name}_argb_width" "$source_env")"
    height="$(render_log_value_of "${prefix}_${source_name}_argb_height" "$source_env")"
    nonblank="$(render_log_value_of "${prefix}_${source_name}_argb_nonblank_pixel_count" "$source_env")"

    if ! render_log_is_positive_int "$width" || ! render_log_is_positive_int "$height"; then
        printf '%s\n' "${source_name}-argb-missing-viewport"
    elif ! render_log_is_positive_int "$nonblank"; then
        printf '%s\n' "${source_name}-argb-blank"
    else
        printf '%s\n' "pass"
    fi
}

render_log_argb_checksum_reason() {
    prefix="$1"
    source_env="$2"
    simple_checksum="$(render_log_value_of "${prefix}_simple_argb_checksum" "$source_env")"
    chrome_checksum="$(render_log_value_of "${prefix}_chrome_argb_checksum" "$source_env")"
    electron_checksum="$(render_log_value_of "${prefix}_electron_argb_checksum" "$source_env")"

    if ! render_log_is_unsigned_int "$simple_checksum"; then
        printf '%s\n' "simple-argb-checksum-missing"
    elif ! render_log_is_unsigned_int "$chrome_checksum"; then
        printf '%s\n' "chrome-argb-checksum-missing"
    elif ! render_log_is_unsigned_int "$electron_checksum"; then
        printf '%s\n' "electron-argb-checksum-missing"
    elif [ "$simple_checksum" != "$chrome_checksum" ] || [ "$simple_checksum" != "$electron_checksum" ]; then
        printf '%s\n' "argb-checksum-mismatch"
    else
        printf '%s\n' "pass"
    fi
}

render_log_argb_viewport_match_reason() {
    prefix="$1"
    source_env="$2"
    simple_w="$(render_log_value_of "${prefix}_simple_argb_width" "$source_env")"
    simple_h="$(render_log_value_of "${prefix}_simple_argb_height" "$source_env")"
    chrome_w="$(render_log_value_of "${prefix}_chrome_argb_width" "$source_env")"
    chrome_h="$(render_log_value_of "${prefix}_chrome_argb_height" "$source_env")"
    electron_w="$(render_log_value_of "${prefix}_electron_argb_width" "$source_env")"
    electron_h="$(render_log_value_of "${prefix}_electron_argb_height" "$source_env")"

    if [ "$simple_w" = "$chrome_w" ] && [ "$simple_w" = "$electron_w" ] &&
        [ "$simple_h" = "$chrome_h" ] && [ "$simple_h" = "$electron_h" ]; then
        printf '%s\n' "pass"
    else
        printf '%s\n' "argb-viewport-mismatch"
    fi
}

render_log_status_from_rdoc_env() {
    source_env="$1"
    gate_key="$2"
    capture_key="$3"
    magic_key="$4"
    if [ ! -s "$source_env" ]; then
        printf '%s\n' "unavailable"
        return
    fi
    gate_status="$(render_log_value_of "$gate_key" "$source_env")"
    capture_status="$(render_log_value_of "$capture_key" "$source_env")"
    artifact="$(render_log_value_of rdoc_capture_file "$source_env")"
    [ -n "$artifact" ] || artifact="$(render_log_value_of rdoc_external_host_capture_file "$source_env")"
    artifact_magic="$(render_log_rdoc_artifact_magic "$source_env" "$artifact")"
    if { [ "$gate_status" = "pass" ] || [ "$capture_status" = "pass" ]; } && [ "$artifact_magic" = "RDOC" ]; then
        printf '%s\n' "pass"
    else
        printf '%s\n' "fail"
    fi
}

render_log_rdoc_artifact_path() {
    source_env="$1"
    artifact="$2"
    if [ -z "$artifact" ]; then
        return 1
    fi
    case "$artifact" in
        /*)
            [ -f "$artifact" ] && printf '%s\n' "$artifact"
            ;;
        */*)
            if [ -f "$artifact" ]; then
                printf '%s\n' "$artifact"
            elif [ -f "$(dirname -- "$source_env")/$artifact" ]; then
                printf '%s\n' "$(dirname -- "$source_env")/$artifact"
            fi
            ;;
        *)
            if [ -f "$(dirname -- "$source_env")/$artifact" ]; then
                printf '%s\n' "$(dirname -- "$source_env")/$artifact"
            fi
            ;;
    esac
}

render_log_rdoc_artifact_magic() {
    source_env="$1"
    artifact="$2"
    artifact_path="$(render_log_rdoc_artifact_path "$source_env" "$artifact" || true)"
    if [ -z "$artifact_path" ]; then
        printf '%s\n' ""
        return
    fi
    magic="$(dd if="$artifact_path" bs=4 count=1 2>/dev/null || true)"
    if [ "$magic" = "RDOC" ]; then
        printf '%s\n' "RDOC"
    else
        printf '%s\n' ""
    fi
}

render_log_reason_from_rdoc_env() {
    source_env="$1"
    gate_reason_key="$2"
    capture_reason_key="$3"
    if [ ! -s "$source_env" ]; then
        printf '%s\n' "missing-source-env"
        return
    fi
    gate_reason="$(render_log_value_of "$gate_reason_key" "$source_env")"
    capture_reason="$(render_log_value_of "$capture_reason_key" "$source_env")"
    if [ -n "$gate_reason" ]; then
        printf '%s\n' "$gate_reason"
    elif [ -n "$capture_reason" ]; then
        printf '%s\n' "$capture_reason"
    else
        printf '%s\n' "missing-reason"
    fi
}

render_log_write_source_log() {
    out_file="$1"
    source_name="$2"
    capture_tool="$3"
    source_env="$4"
    native_env="$5"
    status="$6"
    artifact="$7"
    artifact_magic="$8"
    native_info="$9"
    reason="${10:-}"

    width="$(render_log_value_of "gui_web_2d_vulkan_${source_name}_argb_width" "$native_env")"
    height="$(render_log_value_of "gui_web_2d_vulkan_${source_name}_argb_height" "$native_env")"
    nonblank="$(render_log_value_of "gui_web_2d_vulkan_${source_name}_argb_nonblank_pixel_count" "$native_env")"
    checksum="$(render_log_value_of "gui_web_2d_vulkan_${source_name}_argb_checksum" "$native_env")"
    backend="$(render_log_value_of "gui_web_2d_vulkan_${source_name}_argb_backend" "$native_env")"
    [ -n "$backend" ] || backend="$(render_log_value_of "gui_web_2d_vulkan_${source_name}_backend_name" "$native_env")"
    [ -n "$backend" ] || backend="vulkan"

    nonblank_status="fail"
    case "$nonblank" in
        ""|*[!0-9]*) nonblank_status="fail" ;;
        *) [ "$nonblank" -gt 0 ] && nonblank_status="pass" ;;
    esac
    original_native_format="$(render_log_original_native_format "$capture_tool" "$artifact_magic")"

    {
        render_log_append_kv "simple_render_log_format" "simple-render-log-v1"
        render_log_append_kv "simple_render_log_platform" "linux"
        render_log_append_kv "simple_render_log_native_api" "vulkan"
        render_log_append_kv "simple_render_log_source" "$source_name"
        render_log_append_kv "simple_render_log_capture_tool" "$capture_tool"
        render_log_append_kv "simple_render_log_backend" "$backend"
        render_log_append_kv "simple_render_log_scene" "gui-web-2d-vulkan"
        render_log_append_kv "simple_render_log_status" "$status"
        render_log_append_kv "simple_render_log_reason" "$reason"
        render_log_append_kv "simple_render_log_source_env" "$source_env"
        render_log_append_kv "simple_render_log_original_capture_tool" "$capture_tool"
        render_log_append_kv "simple_render_log_original_native_log_format" "$original_native_format"
        render_log_append_kv "simple_render_log_original_native_log_source" "$source_env"
        render_log_append_kv "simple_render_log_viewport_width" "$width"
        render_log_append_kv "simple_render_log_viewport_height" "$height"
        render_log_append_kv "simple_render_log_nonblank_pixel_count" "$nonblank"
        render_log_append_kv "simple_render_log_nonblank_status" "$nonblank_status"
        render_log_append_kv "simple_render_log_artifact" "$artifact"
        render_log_append_kv "simple_render_log_artifact_magic" "$artifact_magic"
        render_log_append_kv "simple_render_log_checksum" "$checksum"
        render_log_append_kv "simple_render_log_native_info" "$native_info"
    } >"$out_file"
}

render_log_write_native_log() {
    out_file="$1"
    platform="$2"
    native_api="$3"
    source_name="$4"
    capture_tool="$5"
    source_env="$6"
    status="$7"
    backend="$8"
    width="$9"
    height="${10}"
    nonblank="${11}"
    artifact="${12}"
    artifact_magic="${13}"
    checksum="${14}"
    native_info="${15}"

    nonblank_status="fail"
    case "$nonblank" in
        ""|*[!0-9]*) nonblank_status="fail" ;;
        *) [ "$nonblank" -gt 0 ] && nonblank_status="pass" ;;
    esac
    original_native_format="$(render_log_original_native_format "$capture_tool" "$artifact_magic")"

    {
        render_log_append_kv "simple_render_log_format" "simple-render-log-v1"
        render_log_append_kv "simple_render_log_platform" "$platform"
        render_log_append_kv "simple_render_log_native_api" "$native_api"
        render_log_append_kv "simple_render_log_source" "$source_name"
        render_log_append_kv "simple_render_log_capture_tool" "$capture_tool"
        render_log_append_kv "simple_render_log_backend" "$backend"
        render_log_append_kv "simple_render_log_scene" "gui-web-2d-native"
        render_log_append_kv "simple_render_log_status" "$status"
        render_log_append_kv "simple_render_log_source_env" "$source_env"
        render_log_append_kv "simple_render_log_original_capture_tool" "$capture_tool"
        render_log_append_kv "simple_render_log_original_native_log_format" "$original_native_format"
        render_log_append_kv "simple_render_log_original_native_log_source" "$source_env"
        render_log_append_kv "simple_render_log_viewport_width" "$width"
        render_log_append_kv "simple_render_log_viewport_height" "$height"
        render_log_append_kv "simple_render_log_nonblank_pixel_count" "$nonblank"
        render_log_append_kv "simple_render_log_nonblank_status" "$nonblank_status"
        render_log_append_kv "simple_render_log_artifact" "$artifact"
        render_log_append_kv "simple_render_log_artifact_magic" "$artifact_magic"
        render_log_append_kv "simple_render_log_checksum" "$checksum"
        render_log_append_kv "simple_render_log_native_info" "$native_info"
    } >"$out_file"
}
