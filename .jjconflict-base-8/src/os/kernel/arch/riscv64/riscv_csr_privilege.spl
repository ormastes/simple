class CsrRegister:
    addr: i32
    name: text
    value: i32
    read_mask: i32
    write_mask: i32
    min_privilege: i32

    me is_readable_at(priv_level: i32):
        return priv_level >= self.min_privilege

    me is_writable_at(priv_level: i32):
        return priv_level >= self.min_privilege and self.write_mask > 0

    static fn mstatus() -> CsrRegister:
        return CsrRegister { addr: 768, name: "mstatus", value: 0, read_mask: -1, write_mask: -1, min_privilege: 3 }

    static fn mtvec() -> CsrRegister:
        return CsrRegister { addr: 773, name: "mtvec", value: 0, read_mask: -1, write_mask: -1, min_privilege: 3 }

    static fn mepc() -> CsrRegister:
        return CsrRegister { addr: 833, name: "mepc", value: 0, read_mask: -1, write_mask: -1, min_privilege: 3 }

    static fn mcause() -> CsrRegister:
        return CsrRegister { addr: 834, name: "mcause", value: 0, read_mask: -1, write_mask: -1, min_privilege: 3 }


class CsrFile:
    count: i32
    c0_name: text
    c0_addr: i32
    c0_value: i32
    c1_name: text
    c1_addr: i32
    c1_value: i32
    c2_name: text
    c2_addr: i32
    c2_value: i32
    c3_name: text
    c3_addr: i32
    c3_value: i32
    c4_name: text
    c4_addr: i32
    c4_value: i32
    c5_name: text
    c5_addr: i32
    c5_value: i32

    me has_csr(addr: i32):
        if self.count > 0 and self.c0_addr == addr:
            return true
        if self.count > 1 and self.c1_addr == addr:
            return true
        if self.count > 2 and self.c2_addr == addr:
            return true
        if self.count > 3 and self.c3_addr == addr:
            return true
        if self.count > 4 and self.c4_addr == addr:
            return true
        if self.count > 5 and self.c5_addr == addr:
            return true
        return false

    me read_csr(addr: i32):
        if self.count > 0 and self.c0_addr == addr:
            return self.c0_value
        if self.count > 1 and self.c1_addr == addr:
            return self.c1_value
        if self.count > 2 and self.c2_addr == addr:
            return self.c2_value
        if self.count > 3 and self.c3_addr == addr:
            return self.c3_value
        if self.count > 4 and self.c4_addr == addr:
            return self.c4_value
        if self.count > 5 and self.c5_addr == addr:
            return self.c5_value
        return 0

    static fn machine_csrs() -> CsrFile:
        return CsrFile {
            count: 6,
            c0_name: "mstatus", c0_addr: 768, c0_value: 0,
            c1_name: "mtvec",   c1_addr: 773, c1_value: 0,
            c2_name: "mepc",    c2_addr: 833, c2_value: 0,
            c3_name: "mcause",  c3_addr: 834, c3_value: 0,
            c4_name: "mie",     c4_addr: 772, c4_value: 0,
            c5_name: "mip",     c5_addr: 836, c5_value: 0
        }


class PrivilegeMode:
    current_mode: i32
    previous_mode: i32
    mpp_field: i32
    spp_field: i32

    me is_machine():
        return self.current_mode == 3

    me is_supervisor():
        return self.current_mode == 1

    me is_user():
        return self.current_mode == 0

    me mode_name():
        if self.current_mode == 3:
            return "M"
        if self.current_mode == 1:
            return "S"
        if self.current_mode == 0:
            return "U"
        return "unknown"

    me can_access_m_csr():
        return self.current_mode >= 3

    static fn machine() -> PrivilegeMode:
        return PrivilegeMode { current_mode: 3, previous_mode: 3, mpp_field: 3, spp_field: 0 }

    static fn user_mode() -> PrivilegeMode:
        return PrivilegeMode { current_mode: 0, previous_mode: 1, mpp_field: 1, spp_field: 0 }


class ModeTransition:
    from_mode: i32
    to_mode: i32
    cause: text
    is_trap: bool
    is_return: bool

    me is_escalation():
        return self.to_mode > self.from_mode and self.is_trap

    me is_deescalation():
        return self.to_mode < self.from_mode and self.is_return

    me is_valid():
        return (self.is_trap and self.is_return == false) or (self.is_return and self.is_trap == false)

    static fn trap_to_machine(from: i32, cause: text) -> ModeTransition:
        return ModeTransition { from_mode: from, to_mode: 3, cause: cause, is_trap: true, is_return: false }

    static fn mret(to: i32) -> ModeTransition:
        return ModeTransition { from_mode: 3, to_mode: to, cause: "mret", is_trap: false, is_return: true }


fn main():
    print("riscv_csr_privilege loaded")
