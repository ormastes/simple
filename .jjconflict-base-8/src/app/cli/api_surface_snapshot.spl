"""
API Surface Snapshot — AC-8 guard tooling.

Enumerates the public symbols (exported names) for a given set of modules
by grepping `^export ` statements from their source files.

Design rationale (tool-choice):
  - `symbol_analyzer.spl` (src/compiler/90.tools/): an AST *consumer*;
    it requires a pre-built `[AnalysisNode]` list fed in — there is no
    source-file entry point.  It cannot enumerate a module on its own.
  - `metadata_symbol_surface.spl` (src/compiler/99.loader/): fixed-capacity
    3-module × 4-symbol count-only struct (`MetadataSymbolIndex`); returns
    symbol counts, not names.  Useless for a diffable surface.
  Fallback (authorised in task spec): grep over `export` statements.
  The snapshot is intentionally name-level only (no signature join) so
  it remains stable over internal refactors; added/removed names are the
  highest-value break detector.

Output format: deterministic SDN (sorted by module then symbol name).
  - No timestamps, no absolute paths, no host info.
  - Suitable for text-diff via `diff`.

Usage:
  bin/simple src/app/cli/api_surface_snapshot.spl --out=<path>
  (default out: doc/08_tracking/api_surface/baseline.sdn)
"""

use std.io_runtime
use std.fs

# ---------------------------------------------------------------------------
# Public types
# ---------------------------------------------------------------------------

struct SnapshotEntry:
    module_key: text   # e.g. "src/app/cli"
    symbol_name: text  # e.g. "dispatch_command"

export SnapshotEntry

struct SnapshotResult:
    entries: [SnapshotEntry]
    module_count: i64
    symbol_count: i64

export SnapshotResult

# ---------------------------------------------------------------------------
# Module set — the perf-relevant PUBLIC entry modules
#
# Scope rules:
#   * Only __init__.spl files (re-export layer) plus inline export-bearing
#     sibling files that are directly under the module root.
#   * Vendored/third-party paths excluded per CLAUDE.md "Owned-Code Scope".
#   * OS domain: src/os/ uses direct file exports (no central __init__ for
#     nvfs exports); we scan the posix/core/driver subdirs.
# ---------------------------------------------------------------------------

val SNAPSHOT_ROOTS: [text] = [
    # --- Lang / Compiler driver public API ---
    "src/app/cli",
    # --- Web (HTTP) public API ---
    "src/lib/nogc_sync_mut/http",
    # --- DB public API ---
    "src/lib/nogc_sync_mut/database",
    "src/lib/nogc_sync_mut/simple_db_if",
    # --- OS public API ---
    "src/os/services/nvfs",
    "src/os/services/nvfs/core",
    "src/os/services/nvfs/driver",
    "src/os/services/nvfs/posix",
    "src/os/kernel/net",
]

export SNAPSHOT_ROOTS

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

fn _trim_space(s: text) -> text:
    var result: text = s
    val ws: [text] = [" ", "\t", "\r", "\n"]
    var changed: bool = true
    while changed:
        changed = false
        for w in ws:
            if result.starts_with(w):
                result = result.slice(w.len(), result.len())
                changed = true
            if result.ends_with(w):
                result = result.slice(0, result.len() - w.len())
                changed = true
    return result

fn _split_comma(line: text) -> [text]:
    """Split a comma-separated list of export names."""
    var parts: [text] = []
    var current: text = ""
    var i: i64 = 0
    while i < line.len():
        val ch: text = line.slice(i, i + 1)
        if ch == ",":
            val t: text = _trim_space(current)
            if t.len() > 0:
                parts = parts.push(t)
            current = ""
        else:
            current = current + ch
        i = i + 1
    val t: text = _trim_space(current)
    if t.len() > 0:
        parts = parts.push(t)
    return parts

fn _parse_export_line(raw: text) -> [text]:
    """
    Parse one `export ...` line and return the exported names.
    Handles:
      export Foo
      export foo, Bar, baz
      export foo.Bar, foo.Baz   (dotted re-exports — keep as-is)
    """
    var line: text = _trim_space(raw)
    # Strip leading "export "
    if not line.starts_with("export "):
        return []
    line = _trim_space(line.slice(7, line.len()))
    if line.len() == 0:
        return []
    return _split_comma(line)

fn _module_key_for(file_path: text, repo_root: text) -> text:
    """
    Convert absolute file path to a repo-relative module key.
    E.g. /home/.../simple/src/app/cli/__init__.spl -> src/app/cli/__init__.spl
    """
    val prefix: text = repo_root + "/"
    if file_path.starts_with(prefix):
        return file_path.slice(prefix.len(), file_path.len())
    return file_path

fn _parent_dir(path: text) -> text:
    """Return the directory part of a file path."""
    var i: i64 = path.len() - 1
    while i >= 0:
        if path.slice(i, i + 1) == "/":
            return path.slice(0, i)
        i = i - 1
    return ""

# ---------------------------------------------------------------------------
# Core snapshot logic
# ---------------------------------------------------------------------------

fn collect_exports_from_file(file_path: text, module_key: text) -> [SnapshotEntry]:
    """Read one .spl file and extract exported names."""
    var entries: [SnapshotEntry] = []
    val content: text = fs.read_file(file_path)
    val lines: [text] = content.split("\n")
    for line in lines:
        val trimmed: text = _trim_space(line)
        if trimmed.starts_with("export "):
            val names: [text] = _parse_export_line(trimmed)
            for name in names:
                if name.len() > 0:
                    entries = entries.push(SnapshotEntry {
                        module_key: module_key,
                        symbol_name: name,
                    })
    return entries

export collect_exports_from_file

fn collect_exports_from_dir(dir_path: text, repo_root: text) -> [SnapshotEntry]:
    """
    Collect exports from all .spl files directly under dir_path (non-recursive).
    Focuses on __init__.spl (the re-export layer) + any sibling *.spl files.
    """
    var entries: [SnapshotEntry] = []
    val files: [text] = fs.list_dir(dir_path)
    var sorted_files: [text] = files.sort()
    for fname in sorted_files:
        if fname.ends_with(".spl"):
            val full_path: text = dir_path + "/" + fname
            val key: text = _module_key_for(full_path, repo_root)
            val file_entries: [SnapshotEntry] = collect_exports_from_file(full_path, key)
            for e in file_entries:
                entries = entries.push(e)
    return entries

export collect_exports_from_dir

fn snapshot_modules(roots: [text], repo_root: text) -> SnapshotResult:
    """
    Enumerate exported public symbols for all roots.
    Returns a SnapshotResult with a sorted, deduplicated entry list.
    """
    var all_entries: [SnapshotEntry] = []
    var seen_modules: [text] = []

    for root in roots:
        val dir_path: text = repo_root + "/" + root
        val new_entries: [SnapshotEntry] = collect_exports_from_dir(dir_path, repo_root)
        for e in new_entries:
            all_entries = all_entries.push(e)
        seen_modules = seen_modules.push(root)

    # Sort by (module_key, symbol_name) for determinism
    val sorted: [SnapshotEntry] = all_entries.sort_by(fn(a: SnapshotEntry, b: SnapshotEntry) -> i64:
        if a.module_key < b.module_key:
            return -1
        if a.module_key > b.module_key:
            return 1
        if a.symbol_name < b.symbol_name:
            return -1
        if a.symbol_name > b.symbol_name:
            return 1
        return 0
    )

    return SnapshotResult {
        entries: sorted,
        module_count: seen_modules.len(),
        symbol_count: sorted.len(),
    }

export snapshot_modules

# ---------------------------------------------------------------------------
# SDN serialisation
# ---------------------------------------------------------------------------

fn emit_sdn(result: SnapshotResult) -> text:
    """
    Serialise SnapshotResult as a deterministic SDN document.
    Format:
      [api_surface]
      generated_by = api_surface_snapshot.spl
      module_count = N
      symbol_count = N

      [symbol]
      module = src/app/cli/__init__.spl
      name   = dispatch_command

      ...
    """
    var out: text = "[api_surface]\n"
    out = out + "generated_by = api_surface_snapshot.spl\n"
    out = out + "module_count = " + result.module_count.to_string() + "\n"
    out = out + "symbol_count = " + result.symbol_count.to_string() + "\n"

    var last_module: text = ""
    for e in result.entries:
        if e.module_key != last_module:
            out = out + "\n[module]\n"
            out = out + "path = " + e.module_key + "\n"
            last_module = e.module_key
        out = out + "symbol = " + e.symbol_name + "\n"

    return out

export emit_sdn

# ---------------------------------------------------------------------------
# Entry point
# ---------------------------------------------------------------------------

fn main():
    val args: [text] = runtime_args()
    var out_path: text = "doc/08_tracking/api_surface/baseline.sdn"
    for arg in args:
        if arg.starts_with("--out="):
            out_path = arg.slice(6, arg.len())

    val repo_root: text = fs.cwd()
    val result: SnapshotResult = snapshot_modules(SNAPSHOT_ROOTS, repo_root)
    val sdn: text = emit_sdn(result)
    fs.write_file(out_path, sdn)
    print("api_surface_ok=true")
    print("modules=" + result.module_count.to_string())
    print("symbols=" + result.symbol_count.to_string())
    print("out=" + out_path)
