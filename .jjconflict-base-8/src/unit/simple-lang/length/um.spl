# Unit: Um
# Kind: Length
# Symbol: um
# Canonical scale: 1e-06 m

class Um:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Um) -> Um: Um(value: self.value + other.value)
    fn sub(other: Um) -> Um: Um(value: self.value - other.value)

    static fn kind() -> text: "Length"
    static fn symbol() -> text: "um"
    static fn scale_to_base() -> f64: 1e-06
    static fn base_unit() -> text: "m"
    static fn zero() -> Um: Um(value: 0.0)

export Um
