# RTL QoR types.

class RtlQorRun:
    """One captured RTL quality-of-results run."""
    run_id: text
    design: text
    target: text
    toolchain: text
    git_rev: text
    lut_count: i32
    ff_count: i32
    bram_count: i32
    dsp_count: i32
    fmax_mhz: i32
    cycles: i64
    passed: bool

    me area_score() -> i32:
        return self.lut_count + self.ff_count + (self.bram_count * 200) + (self.dsp_count * 100)

    me ppa_score() -> i32:
        if self.fmax_mhz <= 0:
            return self.area_score()
        return self.area_score() / self.fmax_mhz

    me to_sdn() -> text:
        return "rtl_qor_run { id: \"" + self.run_id + "\" design: \"" + self.design + "\" target: \"" + self.target + "\" toolchain: \"" + self.toolchain + "\" git_rev: \"" + self.git_rev + "\" lut: " + self.lut_count.to_text() + " ff: " + self.ff_count.to_text() + " bram: " + self.bram_count.to_text() + " dsp: " + self.dsp_count.to_text() + " fmax_mhz: " + self.fmax_mhz.to_text() + " cycles: " + self.cycles.to_text() + " passed: " + self.passed.to_text() + " }"

    static fn create(run_id: text, design: text, target: text, toolchain: text) -> RtlQorRun:
        return RtlQorRun(
            run_id: run_id,
            design: design,
            target: target,
            toolchain: toolchain,
            git_rev: "",
            lut_count: 0,
            ff_count: 0,
            bram_count: 0,
            dsp_count: 0,
            fmax_mhz: 0,
            cycles: 0,
            passed: false
        )

class RtlQorDelta:
    """Difference between two QoR runs."""
    baseline_id: text
    candidate_id: text
    lut_delta: i32
    ff_delta: i32
    bram_delta: i32
    dsp_delta: i32
    fmax_delta: i32
    cycle_delta: i64
    area_delta: i32

    me improved_area() -> bool:
        return self.area_delta < 0

    me improved_fmax() -> bool:
        return self.fmax_delta > 0

fn compare_qor_runs(baseline: RtlQorRun, candidate: RtlQorRun) -> RtlQorDelta:
    return RtlQorDelta(
        baseline_id: baseline.run_id,
        candidate_id: candidate.run_id,
        lut_delta: candidate.lut_count - baseline.lut_count,
        ff_delta: candidate.ff_count - baseline.ff_count,
        bram_delta: candidate.bram_count - baseline.bram_count,
        dsp_delta: candidate.dsp_count - baseline.dsp_count,
        fmax_delta: candidate.fmax_mhz - baseline.fmax_mhz,
        cycle_delta: candidate.cycles - baseline.cycles,
        area_delta: candidate.area_score() - baseline.area_score()
    )
