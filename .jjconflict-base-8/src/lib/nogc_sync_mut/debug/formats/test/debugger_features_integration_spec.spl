#![allow(primitive_api)]
"""Wave 2 debugger integration — connection matrix, new backends, feature rank constants."""

use std.io_runtime
use std.nogc_sync_mut.spec.{describe, it, expect}
use std.nogc_sync_mut.debug.remote.connection_matrix.{ConnectionMatrix, DebuggerKind, DebugTarget}
use std.nogc_sync_mut.debug.remote.feature.features.{FeatureId, FeatureRank}

fn main():
    describe("ConnectionMatrix integration"):
        it("has 19 specs after Wave 2"):
            var matrix = ConnectionMatrix.default()
            expect(matrix.count()).to_equal(19)

        it("spec 16 is NativeLinux via LldbDap"):
            var matrix = ConnectionMatrix.default()
            var spec16 = matrix.get(16)
            expect(spec16 != nil).to_equal(true)
            expect(spec16!.target.to_string()).to_equal("Native Linux")
            expect(spec16!.debugger.to_string()).to_equal("LLDB DAP")

        it("spec 17 is NativeWindows via DbgEngNative"):
            var matrix = ConnectionMatrix.default()
            var spec17 = matrix.get(17)
            expect(spec17 != nil).to_equal(true)
            expect(spec17!.target.to_string()).to_equal("Native Windows")
            expect(spec17!.debugger.to_string()).to_equal("DbgEng Native")

        it("spec 18 is NativeMacOS via LldbDap"):
            var matrix = ConnectionMatrix.default()
            var spec18 = matrix.get(18)
            expect(spec18 != nil).to_equal(true)
            expect(spec18!.target.to_string()).to_equal("Native macOS")
            expect(spec18!.debugger.to_string()).to_equal("LLDB DAP")

        it("spec 19 is QemuRiscV32 via GdbRsp"):
            var matrix = ConnectionMatrix.default()
            var spec19 = matrix.get(19)
            expect(spec19 != nil).to_equal(true)
            expect(spec19!.target.to_string()).to_equal("QEMU RISC-V32")
            expect(spec19!.debugger.to_string()).to_equal("GDB RSP")

    describe("DebuggerKind new variants"):
        it("LldbDap to_string"):
            expect(DebuggerKind.LldbDap.to_string()).to_equal("LLDB DAP")

        it("DbgEngNative to_string"):
            expect(DebuggerKind.DbgEngNative.to_string()).to_equal("DbgEng Native")

        it("GdbRsp to_string"):
            expect(DebuggerKind.GdbRsp.to_string()).to_equal("GDB RSP")

    describe("DebugTarget new variants"):
        it("NativeWindows to_string"):
            expect(DebugTarget.NativeWindows.to_string()).to_equal("Native Windows")

        it("NativeMacOS to_string"):
            expect(DebugTarget.NativeMacOS.to_string()).to_equal("Native macOS")

    describe("is_hardware returns false for new kinds"):
        it("LldbDap spec is not hardware"):
            var matrix = ConnectionMatrix.default()
            var spec16 = matrix.get(16)
            expect(spec16!.is_hardware()).to_equal(false)

        it("DbgEngNative spec is not hardware"):
            var matrix = ConnectionMatrix.default()
            var spec17 = matrix.get(17)
            expect(spec17!.is_hardware()).to_equal(false)

        it("LldbDap macOS spec is not hardware"):
            var matrix = ConnectionMatrix.default()
            var spec18 = matrix.get(18)
            expect(spec18!.is_hardware()).to_equal(false)

        it("GdbRsp spec is not hardware"):
            var matrix = ConnectionMatrix.default()
            var spec19 = matrix.get(19)
            expect(spec19!.is_hardware()).to_equal(false)

    describe("is_t32/is_stlink/is_openocd return false for new kinds"):
        it("new specs are not t32"):
            var matrix = ConnectionMatrix.default()
            expect(matrix.get(16)!.is_t32()).to_equal(false)
            expect(matrix.get(17)!.is_t32()).to_equal(false)
            expect(matrix.get(18)!.is_t32()).to_equal(false)
            expect(matrix.get(19)!.is_t32()).to_equal(false)

        it("new specs are not stlink"):
            var matrix = ConnectionMatrix.default()
            expect(matrix.get(16)!.is_stlink()).to_equal(false)
            expect(matrix.get(17)!.is_stlink()).to_equal(false)
            expect(matrix.get(18)!.is_stlink()).to_equal(false)
            expect(matrix.get(19)!.is_stlink()).to_equal(false)

        it("new specs are not openocd"):
            var matrix = ConnectionMatrix.default()
            expect(matrix.get(16)!.is_openocd()).to_equal(false)
            expect(matrix.get(17)!.is_openocd()).to_equal(false)
            expect(matrix.get(18)!.is_openocd()).to_equal(false)
            expect(matrix.get(19)!.is_openocd()).to_equal(false)

    describe("FeatureRank constants"):
        it("NATIVE is 0"):
            expect(FeatureRank.NATIVE()).to_equal(0)

        it("BRIDGE is 1"):
            expect(FeatureRank.BRIDGE()).to_equal(1)

        it("SECONDARY is 2"):
            expect(FeatureRank.SECONDARY()).to_equal(2)

        it("EXTERNAL is 3"):
            expect(FeatureRank.EXTERNAL()).to_equal(3)

        it("EMULATED is 4"):
            expect(FeatureRank.EMULATED()).to_equal(4)

    describe("FeatureId coverage"):
        it("has 54 variants"):
            # Verify all variant to_string() calls succeed (compile-time completeness)
            var count = 0
            # Execution control (5)
            expect(FeatureId.Halt.to_string()).to_equal("Halt")
            expect(FeatureId.Resume.to_string()).to_equal("Resume")
            expect(FeatureId.SingleStep.to_string()).to_equal("SingleStep")
            expect(FeatureId.StepOver.to_string()).to_equal("StepOver")
            expect(FeatureId.Reset.to_string()).to_equal("Reset")
            count = count + 5
            # Memory (2)
            expect(FeatureId.ReadMemory.to_string()).to_equal("ReadMemory")
            expect(FeatureId.WriteMemory.to_string()).to_equal("WriteMemory")
            count = count + 2
            # Registers (3)
            expect(FeatureId.ReadRegister.to_string()).to_equal("ReadRegister")
            expect(FeatureId.WriteRegister.to_string()).to_equal("WriteRegister")
            expect(FeatureId.ReadAllRegisters.to_string()).to_equal("ReadAllRegisters")
            count = count + 3
            # Breakpoints (8)
            expect(FeatureId.SetBreakpoint.to_string()).to_equal("SetBreakpoint")
            expect(FeatureId.ClearBreakpoint.to_string()).to_equal("ClearBreakpoint")
            expect(FeatureId.SetWatchpoint.to_string()).to_equal("SetWatchpoint")
            expect(FeatureId.ConditionalBreakpoint.to_string()).to_equal("ConditionalBreakpoint")
            expect(FeatureId.FunctionBreakpoint.to_string()).to_equal("FunctionBreakpoint")
            expect(FeatureId.EnableBreakpoint.to_string()).to_equal("EnableBreakpoint")
            expect(FeatureId.DisableBreakpoint.to_string()).to_equal("DisableBreakpoint")
            expect(FeatureId.ListBreakpoints.to_string()).to_equal("ListBreakpoints")
            count = count + 8
            # Inspection (5)
            expect(FeatureId.ReadLocals.to_string()).to_equal("ReadLocals")
            expect(FeatureId.ReadGlobals.to_string()).to_equal("ReadGlobals")
            expect(FeatureId.ReadArguments.to_string()).to_equal("ReadArguments")
            expect(FeatureId.EvaluateExpression.to_string()).to_equal("EvaluateExpression")
            expect(FeatureId.ReadStackTrace.to_string()).to_equal("ReadStackTrace")
            count = count + 5
            # Frame (4)
            expect(FeatureId.SelectFrame.to_string()).to_equal("SelectFrame")
            expect(FeatureId.FrameLocals.to_string()).to_equal("FrameLocals")
            expect(FeatureId.FrameArguments.to_string()).to_equal("FrameArguments")
            expect(FeatureId.SetVariable.to_string()).to_equal("SetVariable")
            count = count + 4
            # Ptrace (6)
            expect(FeatureId.PtraceAttach.to_string()).to_equal("PtraceAttach")
            expect(FeatureId.PtraceDetach.to_string()).to_equal("PtraceDetach")
            expect(FeatureId.PtraceContinue.to_string()).to_equal("PtraceContinue")
            expect(FeatureId.PtraceSingleStep.to_string()).to_equal("PtraceSingleStep")
            expect(FeatureId.PtraceReadMemory.to_string()).to_equal("PtraceReadMemory")
            expect(FeatureId.PtraceWriteMemory.to_string()).to_equal("PtraceWriteMemory")
            count = count + 6
            # DWARF (3)
            expect(FeatureId.DwarfAddrToSource.to_string()).to_equal("DwarfAddrToSource")
            expect(FeatureId.DwarfSourceToAddr.to_string()).to_equal("DwarfSourceToAddr")
            expect(FeatureId.DwarfFunctionName.to_string()).to_equal("DwarfFunctionName")
            count = count + 3
            # System (3)
            expect(FeatureId.ProfileSample.to_string()).to_equal("ProfileSample")
            expect(FeatureId.FlashProgram.to_string()).to_equal("FlashProgram")
            expect(FeatureId.SystemReset.to_string()).to_equal("SystemReset")
            count = count + 3
            # T32/OpenOCD (5)
            expect(FeatureId.TraceCapture.to_string()).to_equal("TraceCapture")
            expect(FeatureId.CoverageCollect.to_string()).to_equal("CoverageCollect")
            expect(FeatureId.PracticeScript.to_string()).to_equal("PracticeScript")
            expect(FeatureId.OpenocdMonitor.to_string()).to_equal("OpenocdMonitor")
            expect(FeatureId.SemihostRead.to_string()).to_equal("SemihostRead")
            count = count + 5
            # RSP (2)
            expect(FeatureId.RspConnect.to_string()).to_equal("RspConnect")
            expect(FeatureId.RspPacketSend.to_string()).to_equal("RspPacketSend")
            count = count + 2
            # GDB enhancements (5)
            expect(FeatureId.ReverseStep.to_string()).to_equal("ReverseStep")
            expect(FeatureId.ReverseContinue.to_string()).to_equal("ReverseContinue")
            expect(FeatureId.NonStopMode.to_string()).to_equal("NonStopMode")
            expect(FeatureId.AsyncInterrupt.to_string()).to_equal("AsyncInterrupt")
            expect(FeatureId.PrettyPrint.to_string()).to_equal("PrettyPrint")
            count = count + 5
            # LLDB DAP (2)
            expect(FeatureId.LldbDapLaunch.to_string()).to_equal("LldbDapLaunch")
            expect(FeatureId.LldbDapAttach.to_string()).to_equal("LldbDapAttach")
            count = count + 2
            # DbgEng (1)
            expect(FeatureId.DbgEngAttach.to_string()).to_equal("DbgEngAttach")
            count = count + 1
            # Total
            expect(count).to_equal(54)
