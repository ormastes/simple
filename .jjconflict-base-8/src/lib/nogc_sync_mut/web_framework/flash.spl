"""
Flash Messages

One-shot messages stored in the session and consumed on the next request.
Typical use: success/error banners after a redirect.
"""

# ============================================================================
# FlashMessage type
# ============================================================================

struct FlashMessage:
    """A single flash message with a type tag and display text."""
    flash_type: text   # "success", "error", "warning", "info"
    message: text

# ============================================================================
# Session-based storage
# ============================================================================

val FLASH_SESSION_KEY = "_flash"

fn flash_add(session_data: Dict<text, text>, flash_type: text, message: text):
    """Append a flash message to the session.

    Multiple messages are pipe-separated: "type|message||type|message".
    """
    val existing = session_data.get(FLASH_SESSION_KEY) ?? ""
    val entry = flash_type + "|" + message
    if existing.len() == 0:
        session_data[FLASH_SESSION_KEY] = entry
    else:
        session_data[FLASH_SESSION_KEY] = existing + "||" + entry

fn flash_get(session_data: Dict<text, text>) -> [FlashMessage]:
    """Read all flash messages from the session without clearing them."""
    val raw = session_data.get(FLASH_SESSION_KEY) ?? ""
    if raw.len() == 0:
        return []
    var messages: [FlashMessage] = []
    val entries = raw.split("||")
    var i = 0
    while i < entries.len():
        val entry = entries[i]
        val parts = entry.split("|")
        if parts.len() >= 2:
            messages.push(FlashMessage(flash_type: parts[0], message: parts[1]))
        i = i + 1
    messages

fn flash_clear(session_data: Dict<text, text>):
    """Remove all flash messages from the session."""
    session_data.remove(FLASH_SESSION_KEY)

fn flash_success(session_data: Dict<text, text>, message: text):
    """Add a success flash message."""
    flash_add(session_data, "success", message)

fn flash_error(session_data: Dict<text, text>, message: text):
    """Add an error flash message."""
    flash_add(session_data, "error", message)

fn flash_warning(session_data: Dict<text, text>, message: text):
    """Add a warning flash message."""
    flash_add(session_data, "warning", message)

fn flash_info(session_data: Dict<text, text>, message: text):
    """Add an info flash message."""
    flash_add(session_data, "info", message)
