# PrintJob: print job descriptor with paper and layout information

use std.skia.entity.geometry.{SkRect}

enum PaperSize:
    Letter
    A4
    Legal
    Custom

class PrintJob:
    id: i32
    page_count: i32
    paper: PaperSize
    page_bounds: SkRect
    landscape: bool

    static fn new(id: i32, page_count: i32) -> PrintJob:
        val bounds = SkRect(left: 0.0, top: 0.0, right: 612.0, bottom: 792.0)
        PrintJob(
            id: id,
            page_count: page_count,
            paper: PaperSize.Letter,
            page_bounds: bounds,
            landscape: false
        )

    me total_bounds() -> SkRect:
        val total_h = me.page_bounds.bottom * me.page_count.to_f64()
        SkRect(
            left: me.page_bounds.left,
            top: me.page_bounds.top,
            right: me.page_bounds.right,
            bottom: total_h
        )
