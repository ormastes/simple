# ============================================================================
# RISC-V Memory Interface
# ============================================================================
#
# Provides a trait-based memory interface for load/store operations that works
# for both RV32 and RV64.  Concrete implementations can back this with a flat
# byte array (simulation), MMIO regions, or real hardware pointers.
# ============================================================================

use std.nogc_async_mut_noalloc.baremetal.riscv_common.xlen.XlenConfig

# ============================================================================
# Memory access width
# ============================================================================

val MEM_BYTE: i64  = 1
val MEM_HALF: i64  = 2
val MEM_WORD: i64  = 4
val MEM_DWORD: i64 = 8

# ============================================================================
# MemoryBus trait — abstract load/store
# ============================================================================

trait MemoryBus:
    """Abstract memory bus for RISC-V load/store operations."""
    fn load_byte(addr: i64) -> i64
    fn load_half(addr: i64) -> i64
    fn load_word(addr: i64) -> i64
    fn load_dword(addr: i64) -> i64
    fn store_byte(addr: i64, value: i64)
    fn store_half(addr: i64, value: i64)
    fn store_word(addr: i64, value: i64)
    fn store_dword(addr: i64, value: i64)

# ============================================================================
# FlatMemory — simple byte-array backed memory for simulation/testing
# ============================================================================

struct FlatMemory:
    """Flat byte-array memory for simulation.  Base address offsets all
    accesses so the memory array starts at index 0."""
    data: [i64]      # Byte values stored as i64
    base_addr: i64   # Base address (e.g. 0x80000000 for QEMU virt RAM)
    size: i64        # Size in bytes

impl FlatMemory:
    static fn create(base_addr: i64, size: i64) -> FlatMemory:
        """Create a flat memory region of the given size, zeroed."""
        var data: [i64] = []
        var i = 0
        while i < size:
            data = data + [0]
            i = i + 1
        FlatMemory(data: data, base_addr: base_addr, size: size)

    fn offset(addr: i64) -> i64:
        """Compute the byte offset into the data array."""
        addr - self.base_addr

    fn in_range(addr: i64) -> bool:
        """Check if an address is within this memory region."""
        val off = self.offset(addr)
        off >= 0 and off < self.size

    fn read_byte(addr: i64) -> i64:
        """Read a single byte."""
        val off = self.offset(addr)
        if off >= 0 and off < self.size:
            self.data[off] & 0xFF
        else:
            0

    fn write_byte(addr: i64, value: i64):
        """Write a single byte."""
        val off = self.offset(addr)
        if off >= 0 and off < self.size:
            self.data[off] = value & 0xFF

    fn read_half(addr: i64) -> i64:
        """Read a 16-bit half-word (little-endian)."""
        val b0 = self.read_byte(addr)
        val b1 = self.read_byte(addr + 1)
        b0 | (b1 << 8)

    fn write_half(addr: i64, value: i64):
        """Write a 16-bit half-word (little-endian)."""
        self.write_byte(addr, value & 0xFF)
        self.write_byte(addr + 1, (value >> 8) & 0xFF)

    fn read_word(addr: i64) -> i64:
        """Read a 32-bit word (little-endian)."""
        val b0 = self.read_byte(addr)
        val b1 = self.read_byte(addr + 1)
        val b2 = self.read_byte(addr + 2)
        val b3 = self.read_byte(addr + 3)
        b0 | (b1 << 8) | (b2 << 16) | (b3 << 24)

    fn write_word(addr: i64, value: i64):
        """Write a 32-bit word (little-endian)."""
        self.write_byte(addr, value & 0xFF)
        self.write_byte(addr + 1, (value >> 8) & 0xFF)
        self.write_byte(addr + 2, (value >> 16) & 0xFF)
        self.write_byte(addr + 3, (value >> 24) & 0xFF)

    fn read_dword(addr: i64) -> i64:
        """Read a 64-bit double-word (little-endian)."""
        val lo = self.read_word(addr)
        val hi = self.read_word(addr + 4)
        lo | (hi << 32)

    fn write_dword(addr: i64, value: i64):
        """Write a 64-bit double-word (little-endian)."""
        self.write_word(addr, value & 0xFFFFFFFF)
        self.write_word(addr + 4, (value >> 32) & 0xFFFFFFFF)

    fn load_bytes(addr: i64, data_bytes: [i64]):
        """Bulk-load a sequence of bytes into memory starting at addr."""
        var i = 0
        while i < data_bytes.len():
            self.write_byte(addr + i, data_bytes[i])
            i = i + 1

# ============================================================================
# MemoryBus implementation for FlatMemory
# ============================================================================

impl MemoryBus for FlatMemory:
    fn load_byte(addr: i64) -> i64:
        self.read_byte(addr)

    fn load_half(addr: i64) -> i64:
        self.read_half(addr)

    fn load_word(addr: i64) -> i64:
        self.read_word(addr)

    fn load_dword(addr: i64) -> i64:
        self.read_dword(addr)

    fn store_byte(addr: i64, value: i64):
        self.write_byte(addr, value)

    fn store_half(addr: i64, value: i64):
        self.write_half(addr, value)

    fn store_word(addr: i64, value: i64):
        self.write_word(addr, value)

    fn store_dword(addr: i64, value: i64):
        self.write_dword(addr, value)

# ============================================================================
# Sign-extending load helpers (used by instruction execution)
# ============================================================================

fn load_signed_byte(cfg: XlenConfig, mem: FlatMemory, addr: i64) -> i64:
    """Load a byte and sign-extend to XLEN."""
    val raw = mem.read_byte(addr)
    cfg.sign_extend_imm(raw, 8)

fn load_signed_half(cfg: XlenConfig, mem: FlatMemory, addr: i64) -> i64:
    """Load a half-word and sign-extend to XLEN."""
    val raw = mem.read_half(addr)
    cfg.sign_extend_imm(raw, 16)

fn load_signed_word(cfg: XlenConfig, mem: FlatMemory, addr: i64) -> i64:
    """Load a word and sign-extend to XLEN."""
    val raw = mem.read_word(addr)
    cfg.sign_extend_imm(raw, 32)
