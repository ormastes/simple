#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../../.." && pwd)"
BENCH_DIR="$ROOT/test/perf/net_parity"
BUILD_DIR="$ROOT/build/perf/net_parity"
SIMPLE_BIN="${SIMPLE_BIN:-$ROOT/bin/simple}"
NET_PARITY_ITERS="${NET_PARITY_ITERS:-10000}"
NET_PARITY_PAYLOAD="${NET_PARITY_PAYLOAD:-1024}"
NET_PARITY_PORT="${NET_PARITY_PORT:-39091}"

mkdir -p "$BUILD_DIR"

echo "=================================================================="
echo "  Net I/O C/Rust/Simple Parity Benchmark"
echo "=================================================================="
echo "Simple:  $SIMPLE_BIN"
echo "Port:    $NET_PARITY_PORT"
echo "Payload: $NET_PARITY_PAYLOAD"
echo "Iters:   $NET_PARITY_ITERS"
echo "Build:   $BUILD_DIR"
echo ""

gcc -O3 -march=native -std=c11 "$BENCH_DIR/net_echo_server.c" -o "$BUILD_DIR/net_echo_server"
gcc -O3 -march=native -std=c11 "$BENCH_DIR/net_parity_ref.c" -o "$BUILD_DIR/net_parity_c"
rustc -C opt-level=3 -C target-cpu=native "$BENCH_DIR/net_parity_ref.rs" -o "$BUILD_DIR/net_parity_rust"

simple_compile_log="$BUILD_DIR/simple_compile.log"
if ! "$SIMPLE_BIN" compile "$BENCH_DIR/net_parity_simple.spl" --native --cpu native --opt-level aggressive -o "$BUILD_DIR/net_parity_simple" >"$simple_compile_log" 2>&1; then
    echo "[netbench-note] simple_native_compile=failed fallback=interpreter log=$simple_compile_log"
fi

run_with_server() {
    local lang="$1"
    local command="$2"
    local output="$3"
    local ready="$BUILD_DIR/server_${lang}.ready"
    rm -f "$ready"
    "$BUILD_DIR/net_echo_server" "$NET_PARITY_PORT" "$ready" &
    local server_pid="$!"
    trap 'kill "$server_pid" 2>/dev/null || true' RETURN
    for _ in {1..100}; do
        [[ -f "$ready" ]] && break
        sleep 0.01
    done
    if [[ ! -f "$ready" ]]; then
        echo "[netbench-error] server not ready lang=$lang" >&2
        kill "$server_pid" 2>/dev/null || true
        wait "$server_pid" 2>/dev/null || true
        return 1
    fi
    NET_PARITY_PORT="$NET_PARITY_PORT" \
    NET_PARITY_ADDR="127.0.0.1:$NET_PARITY_PORT" \
    NET_PARITY_ITERS="$NET_PARITY_ITERS" \
    NET_PARITY_PAYLOAD="$NET_PARITY_PAYLOAD" \
    bash -c "$command" | tee "$output"
    kill "$server_pid" 2>/dev/null || true
    wait "$server_pid" 2>/dev/null || true
    trap - RETURN
}

echo "--- C client ---"
run_with_server c "'$BUILD_DIR/net_parity_c'" "$BUILD_DIR/c.out"

echo "--- Rust client ---"
run_with_server rust "'$BUILD_DIR/net_parity_rust'" "$BUILD_DIR/rust.out"

echo "--- Simple client ---"
if [[ -x "$BUILD_DIR/net_parity_simple" ]]; then
    run_with_server simple "'$BUILD_DIR/net_parity_simple'" "$BUILD_DIR/simple.out"
else
    run_with_server simple "SIMPLE_LIB='$ROOT/src' '$SIMPLE_BIN' run '$BENCH_DIR/net_parity_simple.spl'" "$BUILD_DIR/simple.out"
fi

c_sum="$(grep 'case=tcp_echo ' "$BUILD_DIR/c.out" | sed -n 's/.*checksum=\([0-9]*\).*/\1/p')"
rust_sum="$(grep 'case=tcp_echo ' "$BUILD_DIR/rust.out" | sed -n 's/.*checksum=\([0-9]*\).*/\1/p')"
simple_sum="$(grep 'case=tcp_echo ' "$BUILD_DIR/simple.out" | sed -n 's/.*checksum=\([0-9]*\).*/\1/p')"
if [[ -z "$c_sum" || -z "$rust_sum" || -z "$simple_sum" ]]; then
    echo "[netbench-error] missing checksum c=$c_sum rust=$rust_sum simple=$simple_sum" >&2
    exit 1
fi
if [[ "$c_sum" != "$rust_sum" || "$c_sum" != "$simple_sum" ]]; then
    echo "[netbench-error] checksum mismatch c=$c_sum rust=$rust_sum simple=$simple_sum" >&2
    exit 1
fi

echo "[netbench-ok] net I/O parity benchmark completed"
