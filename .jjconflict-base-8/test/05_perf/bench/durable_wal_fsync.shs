#!/bin/sh
# Host durable WAL fsync probe — measures real kernel write + fsync fences on the host filesystem.
set -eu

if ! command -v python3 >/dev/null 2>&1; then
    echo "ERROR: python3 required for this benchmark" >&2
    exit 1
fi

exec python3 - "$@" <<'PYTHON_EOF'
#!/usr/bin/env python3
"""Host durable WAL fsync probe.

This measures real kernel write + fsync fences on the host filesystem. It is
not an NVMe/FUA compliance test and does not prove crash recovery, but it
prevents the DB benchmark story from relying only on the in-process SharedWal
shim.
"""

from __future__ import annotations

import os
import struct
import statistics
import time
import zlib
from pathlib import Path


OUT = Path(os.environ.get("SIMPLE_DURABLE_WAL_BENCH_PATH", "/tmp/simple_durable_wal_fsync_bench.log"))
PAYLOAD = b"x" * 256
RECOVERY_OUT = OUT.with_suffix(".recovery.log")
RECOVERY_MATRIX_OUT = OUT.with_suffix(".recovery_matrix.log")


def now_ns() -> int:
    return time.perf_counter_ns()


def percentile(sorted_samples: list[int], numerator: int, denominator: int) -> int:
    if not sorted_samples:
        return 0
    idx = (len(sorted_samples) * numerator) // denominator
    if idx >= len(sorted_samples):
        idx = len(sorted_samples) - 1
    return sorted_samples[idx]


def result(label: str, samples: list[int]) -> dict[str, int | str]:
    ordered = sorted(samples)
    total = sum(ordered)
    iters = len(ordered)
    return {
        "label": label,
        "iters": iters,
        "avg_us": total // iters // 1_000 if iters > 0 else 0,
        "ops_per_s": (iters * 1_000_000_000) // total if total > 0 else 0,
        "p50_ns": percentile(ordered, 50, 100),
        "p99_ns": percentile(ordered, 99, 100),
        "p99_9_ns": percentile(ordered, 999, 1000),
        "min_ns": ordered[0] if ordered else 0,
        "max_ns": ordered[-1] if ordered else 0,
        "total_ns": total,
        "kops_per_s": (iters * 1_000_000) // total if total > 0 else 0,
    }


def print_result(row: dict[str, int | str]) -> None:
    print(f"bench: {row['label']}")
    print(f"  iters={row['iters']}  total_ns={row['total_ns']}")
    print(f"  avg_us={row['avg_us']}  ops/s={row['ops_per_s']}")
    print(
        "  min={min_ns}  p50={p50_ns}  p99={p99_ns}  "
        "p99.9={p99_9_ns}  max={max_ns}".format(**row)
    )
    print(f"  throughput(kops/s)={row['kops_per_s']}")


def bench_write_fsync_each(fd: int, iters: int = 32) -> dict[str, int | str]:
    samples: list[int] = []
    for _ in range(iters):
        t0 = now_ns()
        os.write(fd, PAYLOAD)
        os.fsync(fd)
        t1 = now_ns()
        samples.append(t1 - t0)
    return result("durable_wal_write_256B_fsync_each_x32", samples)


def bench_group_fsync(fd: int, groups: int = 16, group_size: int = 10) -> dict[str, int | str]:
    samples: list[int] = []
    for _ in range(groups):
        t0 = now_ns()
        for _ in range(group_size):
            os.write(fd, PAYLOAD)
        os.fsync(fd)
        t1 = now_ns()
        samples.append(t1 - t0)
    return result("durable_wal_group_10x256B_fsync_x16", samples)


def encode_record(payload: bytes) -> bytes:
    crc = zlib.crc32(payload) & 0xFFFFFFFF
    return struct.pack("<II", len(payload), crc) + payload


def encode_bad_crc_record(payload: bytes) -> bytes:
    crc = (zlib.crc32(payload) ^ 0xFFFF_FFFF) & 0xFFFFFFFF
    return struct.pack("<II", len(payload), crc) + payload


def recover_framed_wal(path: Path) -> tuple[int, int]:
    data = path.read_bytes()
    offset = 0
    records = 0
    while offset + 8 <= len(data):
        length, expected_crc = struct.unpack_from("<II", data, offset)
        end = offset + 8 + length
        if length > 16 * 1024 * 1024 or end > len(data):
            break
        payload = data[offset + 8 : end]
        actual_crc = zlib.crc32(payload) & 0xFFFFFFFF
        if actual_crc != expected_crc:
            break
        records += 1
        offset = end
    return records, offset


def verify_torn_tail_recovery(records: int = 16) -> dict[str, int | str]:
    RECOVERY_OUT.parent.mkdir(parents=True, exist_ok=True)
    fd = os.open(RECOVERY_OUT, os.O_WRONLY | os.O_CREAT | os.O_TRUNC, 0o644)
    try:
        for i in range(records):
            payload = f"record-{i:04d}:".encode("ascii") + PAYLOAD
            os.write(fd, encode_record(payload))
            os.fsync(fd)
        os.write(fd, encode_record(b"torn-tail")[:6])
        os.fsync(fd)
    finally:
        os.close(fd)

    recovered, valid_bytes = recover_framed_wal(RECOVERY_OUT)
    with RECOVERY_OUT.open("r+b") as f:
        f.truncate(valid_bytes)
        f.flush()
        os.fsync(f.fileno())
    recovered_after_truncate, _ = recover_framed_wal(RECOVERY_OUT)
    if recovered != records or recovered_after_truncate != records:
        raise SystemExit(
            f"recovery failed: before={recovered} after={recovered_after_truncate} expected={records}"
        )
    return {
        "label": "durable_wal_torn_tail_recovery_x16",
        "records": records,
        "valid_bytes": valid_bytes,
        "file_bytes_after_truncate": RECOVERY_OUT.stat().st_size,
    }


def write_valid_records(fd: int, records: int) -> int:
    valid_bytes = 0
    for i in range(records):
        payload = f"record-{i:04d}:".encode("ascii") + PAYLOAD
        encoded = encode_record(payload)
        os.write(fd, encoded)
        valid_bytes += len(encoded)
    os.fsync(fd)
    return valid_bytes


def verify_recovery_case(name: str, tail: bytes, records: int = 16) -> dict[str, int | str]:
    path = RECOVERY_MATRIX_OUT.with_name(f"{RECOVERY_MATRIX_OUT.stem}.{name}.log")
    path.parent.mkdir(parents=True, exist_ok=True)
    fd = os.open(path, os.O_WRONLY | os.O_CREAT | os.O_TRUNC, 0o644)
    try:
        expected_valid_bytes = write_valid_records(fd, records)
        if tail:
            os.write(fd, tail)
            os.fsync(fd)
    finally:
        os.close(fd)

    recovered, valid_bytes = recover_framed_wal(path)
    with path.open("r+b") as f:
        f.truncate(valid_bytes)
        f.flush()
        os.fsync(f.fileno())
    recovered_after_truncate, valid_bytes_after_truncate = recover_framed_wal(path)
    if (
        recovered != records
        or recovered_after_truncate != records
        or valid_bytes != expected_valid_bytes
        or valid_bytes_after_truncate != expected_valid_bytes
    ):
        raise SystemExit(
            "recovery matrix failed for {name}: before={before} after={after} "
            "valid={valid} expected_valid={expected_valid}".format(
                name=name,
                before=recovered,
                after=recovered_after_truncate,
                valid=valid_bytes,
                expected_valid=expected_valid_bytes,
            )
        )
    return {
        "case": name,
        "records": records,
        "valid_bytes": valid_bytes,
        "file_bytes_after_truncate": path.stat().st_size,
    }


def verify_recovery_matrix(records: int = 16) -> list[dict[str, int | str]]:
    valid_tail_payload = b"tail-record"
    valid_tail = encode_record(valid_tail_payload)
    oversized_tail = struct.pack("<II", 16 * 1024 * 1024 + 1, 0)
    cases = [
        ("clean", b""),
        ("partial_header", valid_tail[:3]),
        ("partial_payload", valid_tail[: 8 + len(valid_tail_payload) // 2]),
        ("bad_crc", encode_bad_crc_record(valid_tail_payload)),
        ("oversized_length", oversized_tail),
        ("garbage_tail", b"\xffgarbage-after-valid-records"),
    ]
    return [verify_recovery_case(name, tail, records) for name, tail in cases]


def main() -> None:
    OUT.parent.mkdir(parents=True, exist_ok=True)
    fd = os.open(OUT, os.O_WRONLY | os.O_CREAT | os.O_TRUNC, 0o644)
    try:
        rows = [bench_write_fsync_each(fd), bench_group_fsync(fd)]
    finally:
        os.close(fd)
    recovery = verify_torn_tail_recovery()
    recovery_matrix = verify_recovery_matrix()

    print("=== Durable WAL fsync benchmark ===")
    print("DISCLAIMER: host filesystem write+fsync probe, not raw NVMe/FUA or crash-recovery proof.")
    print(f"path={OUT}")
    print("")
    for row in rows:
        print_result(row)
        print("")
    print("recovery:", recovery)
    print("recovery_matrix:", recovery_matrix)
    print("")
    print("=== CSV ===")
    print("label,iters,avg_us,ops_per_s,p50_ns,p99_ns,p99_9_ns,min_ns,max_ns,total_ns,kops_per_s")
    for row in rows:
        print(
            "{label},{iters},{avg_us},{ops_per_s},{p50_ns},{p99_ns},{p99_9_ns},{min_ns},{max_ns},{total_ns},{kops_per_s}".format(
                **row
            )
        )
    med = statistics.median([int(row["p50_ns"]) for row in rows])
    if med <= 0:
        raise SystemExit("invalid fsync timing")


if __name__ == "__main__":
    main()
PYTHON_EOF
