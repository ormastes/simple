#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../../.." && pwd)"
BENCH_DIR="$ROOT/test/perf/io_parity"
BUILD_DIR="$ROOT/build/perf/io_parity"
SIMPLE_BIN="${SIMPLE_BIN:-$ROOT/bin/simple}"
IO_PARITY_MIB="${IO_PARITY_MIB:-16}"
IO_PARITY_ITERS="${IO_PARITY_ITERS:-64}"
IO_PARITY_STARTUP_ITERS="${IO_PARITY_STARTUP_ITERS:-100}"

mkdir -p "$BUILD_DIR"

fixture="$BUILD_DIR/fixture.txt"
set +o pipefail
yes "simple-io-parity-0123456789abcdef" | head -c "$((IO_PARITY_MIB * 1024 * 1024))" >"$fixture"
set -o pipefail

echo "=================================================================="
echo "  File I/O C/Rust/Simple Parity Benchmark"
echo "=================================================================="
echo "Simple:  $SIMPLE_BIN"
echo "Fixture: $fixture (${IO_PARITY_MIB}MiB)"
echo "Iters:   $IO_PARITY_ITERS"
echo "Build:   $BUILD_DIR"
echo ""

gcc -O3 -march=native -std=c11 "$BENCH_DIR/io_parity_ref.c" -o "$BUILD_DIR/io_parity_c"
rustc -C opt-level=3 -C target-cpu=native "$BENCH_DIR/io_parity_ref.rs" -o "$BUILD_DIR/io_parity_rust"
gcc -O3 -march=native -std=c11 "$BENCH_DIR/startup_ref.c" -o "$BUILD_DIR/startup_c"
rustc -C opt-level=3 -C target-cpu=native "$BENCH_DIR/startup_ref.rs" -o "$BUILD_DIR/startup_rust"

echo "--- C reference ---"
IO_PARITY_FIXTURE="$fixture" \
IO_PARITY_OUTPUT="$BUILD_DIR/c_append.out" \
IO_PARITY_ITERS="$IO_PARITY_ITERS" \
"$BUILD_DIR/io_parity_c" | tee "$BUILD_DIR/c.out"

echo "--- Rust reference ---"
IO_PARITY_FIXTURE="$fixture" \
IO_PARITY_OUTPUT="$BUILD_DIR/rust_append.out" \
IO_PARITY_ITERS="$IO_PARITY_ITERS" \
"$BUILD_DIR/io_parity_rust" | tee "$BUILD_DIR/rust.out"

echo "--- Simple reference ---"
simple_compile_log="$BUILD_DIR/simple_compile.log"
if "$SIMPLE_BIN" compile "$BENCH_DIR/io_parity_simple.spl" --native --cpu native --opt-level aggressive -o "$BUILD_DIR/io_parity_simple" >"$simple_compile_log" 2>&1; then
    IO_PARITY_FIXTURE="$fixture" \
    IO_PARITY_OUTPUT="$BUILD_DIR/simple_append.out" \
    IO_PARITY_ITERS="$IO_PARITY_ITERS" \
    "$BUILD_DIR/io_parity_simple" | tee "$BUILD_DIR/simple.out"
else
    echo "[iobench-note] simple_native_compile=failed fallback=interpreter log=$simple_compile_log"
    IO_PARITY_FIXTURE="$fixture" \
    IO_PARITY_OUTPUT="$BUILD_DIR/simple_append.out" \
    IO_PARITY_ITERS="$IO_PARITY_ITERS" \
    SIMPLE_LIB="$ROOT/src" "$SIMPLE_BIN" run "$BENCH_DIR/io_parity_simple.spl" | tee "$BUILD_DIR/simple.out"
fi

startup_compile_log="$BUILD_DIR/startup_simple_compile.log"
if "$SIMPLE_BIN" compile "$BENCH_DIR/startup_simple.spl" --native --cpu native --opt-level aggressive -o "$BUILD_DIR/startup_simple" >"$startup_compile_log" 2>&1; then
    measure_startup() {
        local lang="$1"
        local bin="$2"
        local start_ns end_ns elapsed_us
        start_ns="$(date +%s%N)"
        for ((i = 0; i < IO_PARITY_STARTUP_ITERS; i++)); do
            "$bin"
        done
        end_ns="$(date +%s%N)"
        elapsed_us="$(((end_ns - start_ns) / 1000))"
        echo "[startupbench] lang=$lang case=process_startup iters=$IO_PARITY_STARTUP_ITERS micros=$elapsed_us"
    }

    echo "--- Startup reference ---"
    measure_startup c "$BUILD_DIR/startup_c" | tee "$BUILD_DIR/startup_c.out"
    measure_startup rust "$BUILD_DIR/startup_rust" | tee "$BUILD_DIR/startup_rust.out"
    measure_startup simple "$BUILD_DIR/startup_simple" | tee "$BUILD_DIR/startup_simple.out"
else
    echo "[startupbench-note] simple_native_compile=failed log=$startup_compile_log"
    sed -n '1,12p' "$startup_compile_log"
fi

for case_name in read_text mmap_text append_at; do
    c_sum="$(grep "case=$case_name " "$BUILD_DIR/c.out" | sed -n 's/.*checksum=\([0-9]*\).*/\1/p')"
    rust_sum="$(grep "case=$case_name " "$BUILD_DIR/rust.out" | sed -n 's/.*checksum=\([0-9]*\).*/\1/p')"
    simple_sum="$(grep "case=$case_name " "$BUILD_DIR/simple.out" | sed -n 's/.*checksum=\([0-9]*\).*/\1/p')"
    if [[ -z "$c_sum" || -z "$rust_sum" || -z "$simple_sum" ]]; then
        echo "[iobench-error] missing checksum case=$case_name c=$c_sum rust=$rust_sum simple=$simple_sum" >&2
        exit 1
    fi
    if [[ "$case_name" != "mmap_text" && ( "$c_sum" != "$rust_sum" || "$c_sum" != "$simple_sum" ) ]]; then
        echo "[iobench-error] checksum mismatch case=$case_name c=$c_sum rust=$rust_sum simple=$simple_sum" >&2
        exit 1
    fi
done

echo "[iobench-ok] file I/O parity benchmark completed"
