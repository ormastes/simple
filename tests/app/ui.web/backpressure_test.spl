# Backpressure / BoundedChannel Tests
#
# Exercises BoundedChannel<T> drop-oldest ring-buffer semantics.
#
# Key implementation facts (from bounded_channel.spl):
# - try_send on overflow: drops oldest (advances head), increments dropped,
#   returns Err(OverflowError) — NOT Ok.
# - recv() returns Option<T>: None when empty.
# - close() is pass_do_nothing — no closed-state tracking.
#   "try_send after close fails" is NOT testable; documented below.
# - dropped counter is cumulative across all overflows.

use std.sspec.*
use app.ui.web.bounded_channel.{BoundedChannel, OverflowError}

# ============================================================================
# Test Group 1: Within capacity
# ============================================================================

describe "BoundedChannel within capacity":
    """
    ## Normal sends within buffer limit

    All sends below capacity succeed with Ok(()) and dropped stays 0.
    """

    it "4 sends into capacity-4 channel all return Ok":
        var ch: BoundedChannel<text> = BoundedChannel.new(4i64)
        val r1 = ch.try_send("a")
        val r2 = ch.try_send("b")
        val r3 = ch.try_send("c")
        val r4 = ch.try_send("d")
        expect(r1.is_ok()).to_equal(true)
        expect(r2.is_ok()).to_equal(true)
        expect(r3.is_ok()).to_equal(true)
        expect(r4.is_ok()).to_equal(true)

    it "dropped counter stays 0 after sends within capacity":
        var ch: BoundedChannel<text> = BoundedChannel.new(4i64)
        ch.try_send("a")
        ch.try_send("b")
        ch.try_send("c")
        ch.try_send("d")
        expect(ch.dropped).to_equal(0u64)

    it "size equals number of items sent":
        var ch: BoundedChannel<text> = BoundedChannel.new(4i64)
        ch.try_send("a")
        ch.try_send("b")
        expect(ch.size).to_equal(2i64)

# ============================================================================
# Test Group 2: Overflow drops oldest
# ============================================================================

describe "BoundedChannel overflow drops oldest":
    """
    ## Drop-oldest on overflow

    When the buffer is full, try_send drops the oldest item (head) and
    returns Err(OverflowError). Draining after overflow yields the most
    recent capacity items in FIFO order.
    """

    it "5th send into capacity-4 channel returns Err(OverflowError)":
        var ch: BoundedChannel<text> = BoundedChannel.new(4i64)
        ch.try_send("a")
        ch.try_send("b")
        ch.try_send("c")
        ch.try_send("d")
        val r5 = ch.try_send("e")
        expect(r5.is_err()).to_equal(true)

    it "dropped is 1 after one overflow":
        var ch: BoundedChannel<text> = BoundedChannel.new(4i64)
        ch.try_send("a")
        ch.try_send("b")
        ch.try_send("c")
        ch.try_send("d")
        ch.try_send("e")
        expect(ch.dropped).to_equal(1u64)

    it "draining capacity-4 channel after one overflow yields b,c,d,e":
        var ch: BoundedChannel<text> = BoundedChannel.new(4i64)
        ch.try_send("a")
        ch.try_send("b")
        ch.try_send("c")
        ch.try_send("d")
        # overflow: "a" is dropped
        ch.try_send("e")
        val i1 = ch.recv()
        val i2 = ch.recv()
        val i3 = ch.recv()
        val i4 = ch.recv()
        expect(i1).to_equal(Some("b"))
        expect(i2).to_equal(Some("c"))
        expect(i3).to_equal(Some("d"))
        expect(i4).to_equal(Some("e"))

    it "channel still holds capacity items after overflow":
        var ch: BoundedChannel<text> = BoundedChannel.new(4i64)
        ch.try_send("a")
        ch.try_send("b")
        ch.try_send("c")
        ch.try_send("d")
        ch.try_send("e")
        expect(ch.size).to_equal(4i64)

# ============================================================================
# Test Group 3: Many overflows
# ============================================================================

describe "BoundedChannel many overflows":
    """
    ## High-volume overflow stress

    Sending N items into a capacity-C channel drops N-C oldest items
    (when N > C).  The channel should hold exactly C items after drain
    and dropped should be >= N - C.
    """

    it "sending 10 items into capacity-4 channel drops 6":
        var ch: BoundedChannel<text> = BoundedChannel.new(4i64)
        ch.try_send("0")
        ch.try_send("1")
        ch.try_send("2")
        ch.try_send("3")
        ch.try_send("4")
        ch.try_send("5")
        ch.try_send("6")
        ch.try_send("7")
        ch.try_send("8")
        ch.try_send("9")
        expect(ch.dropped).to_be_greater_than(5u64)
        expect(ch.size).to_equal(4i64)

    it "drain after 10 sends into capacity-4 yields exactly 4 items":
        var ch: BoundedChannel<text> = BoundedChannel.new(4i64)
        ch.try_send("0")
        ch.try_send("1")
        ch.try_send("2")
        ch.try_send("3")
        ch.try_send("4")
        ch.try_send("5")
        ch.try_send("6")
        ch.try_send("7")
        ch.try_send("8")
        ch.try_send("9")
        val d1 = ch.recv()
        val d2 = ch.recv()
        val d3 = ch.recv()
        val d4 = ch.recv()
        val d5 = ch.recv()
        expect(d1.is_some()).to_equal(true)
        expect(d2.is_some()).to_equal(true)
        expect(d3.is_some()).to_equal(true)
        expect(d4.is_some()).to_equal(true)
        # 5th recv must return None (channel drained)
        expect(d5).to_be_nil()

    it "after 10 sends into capacity-4, most recent item is 9":
        var ch: BoundedChannel<text> = BoundedChannel.new(4i64)
        ch.try_send("0")
        ch.try_send("1")
        ch.try_send("2")
        ch.try_send("3")
        ch.try_send("4")
        ch.try_send("5")
        ch.try_send("6")
        ch.try_send("7")
        ch.try_send("8")
        ch.try_send("9")
        # Drain to last item
        ch.recv()
        ch.recv()
        ch.recv()
        val last = ch.recv()
        expect(last).to_equal(Some("9"))

# ============================================================================
# Test Group 4: Recv on empty channel
# ============================================================================

describe "BoundedChannel recv on empty":
    """
    ## Empty channel behaviour

    recv() on an empty channel returns None.
    """

    it "recv on fresh channel returns None":
        var ch: BoundedChannel<text> = BoundedChannel.new(4i64)
        val result = ch.recv()
        expect(result).to_be_nil()

    it "recv after draining all items returns None":
        var ch: BoundedChannel<text> = BoundedChannel.new(4i64)
        ch.try_send("x")
        ch.recv()
        val result = ch.recv()
        expect(result).to_be_nil()

    it "is_empty is true on a fresh channel":
        var ch: BoundedChannel<text> = BoundedChannel.new(4i64)
        expect(ch.is_empty()).to_equal(true)

    it "is_empty is false after one send":
        var ch: BoundedChannel<text> = BoundedChannel.new(4i64)
        ch.try_send("hello")
        expect(ch.is_empty()).to_equal(false)

    it "is_empty is true again after draining":
        var ch: BoundedChannel<text> = BoundedChannel.new(4i64)
        ch.try_send("hello")
        ch.recv()
        expect(ch.is_empty()).to_equal(true)

# ============================================================================
# Test Group 5: Close behaviour
# ============================================================================

describe "BoundedChannel close":
    """
    ## Close semantics

    BoundedChannel.close() is pass_do_nothing — there is no closed-state
    tracking. After close(), try_send succeeds as if close were never called.
    This is a documented v1 limitation: the async_server uses the dropped
    counter to detect lagging clients and closes the WebSocket externally.

    NOTE: "try_send fails after close" is intentionally NOT tested because
    the implementation has no closed state — any such assertion would always
    fail as a test bug, not an implementation bug.
    """

    it "close does not crash":
        var ch: BoundedChannel<text> = BoundedChannel.new(4i64)
        ch.close()
        expect(ch.size).to_equal(0i64)
        expect(ch.dropped).to_equal(0u64)
        expect(ch.recv()).to_be_nil()

    it "try_send after close still works (no closed-state in v1)":
        var ch: BoundedChannel<text> = BoundedChannel.new(4i64)
        ch.close()
        val result = ch.try_send("after-close")
        # close() is pass_do_nothing — channel still accepts items
        expect(result.is_ok()).to_equal(true)
