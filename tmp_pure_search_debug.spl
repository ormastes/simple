use std.io_runtime
use nogc_sync_mut.database.pure_sql.database.{PureDatabase, PureSearchAlgorithm}

fn main():
    var db = PureDatabase.memory().unwrap()
    db.exec_sql("CREATE TABLE docs (id INTEGER, title TEXT, body TEXT)").unwrap()
    db.exec_sql("INSERT INTO docs (id, title, body) VALUES (1, 'SQLite FTS5', 'embedded search engine bm25 ranking')").unwrap()
    db.exec_sql("INSERT INTO docs (id, title, body) VALUES (2, 'Other Storage', 'plain key value storage')").unwrap()
    db.exec_sql("INSERT INTO docs (id, title, body) VALUES (3, 'BM25 Search', 'bm25 bm25 search ranking support')").unwrap()
    val sr = db.bm25_search("docs", ["title", "body"], "bm25 search", 10).unwrap()
    print("len={sr.len()}")
    var i: i32 = 0
    while i < sr.len() as i32:
        print("id={sr[i].row.get_int(\"id\").unwrap()} score={sr[i].score}")
        i = i + 1
