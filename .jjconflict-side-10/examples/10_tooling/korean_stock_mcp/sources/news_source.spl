#![allow(unnamed_duplicate_typed_args)]
# Korean Stock MCP - News Source
#
# Market news via Google News RSS (XML parsing)
# Stock-specific news via Naver Finance (HTTP + string parsing)

# ============================================================================
# Market News (Google News RSS)
# ============================================================================

fn get_market_news(max_items: i64) -> text:
    # Google News RSS for Korean stock market
    val encoded_query = rt_http_url_encode("한국 주식시장") ?? "한국+주식시장"
    val rss_url = "https://news.google.com/rss/search?q=" + encoded_query + "&hl=ko&gl=KR&ceid=KR:ko"
    val headers: [text] = ["User-Agent: Mozilla/5.0", "Accept: application/xml"]
    var status: i64 = 0
    var resp_body = ""
    var error = ""
    (status, resp_body, error) = rt_http_request("GET", rss_url, headers, "")

    if status < 200 or status >= 300:
        return "Market News (Unable to fetch - using fallback)\n" + get_fallback_market_news()

    # Parse RSS XML for items
    var results: [text] = []
    results.push("Korean Stock Market News")
    results.push("=" .repeat(40))

    var item_count = 0
    var search_pos = 0
    while search_pos < resp_body.len() and item_count < max_items:
        val remaining = mcp_substr(resp_body, search_pos, resp_body.len())
        val item_start_result = remaining.index_of("<item>")
        var item_start = -1
        match item_start_result:
            Some(i): item_start = i
            nil: break
        if item_start < 0:
            break

        val item_end_result = remaining.index_of("</item>")
        var item_end = -1
        match item_end_result:
            Some(i): item_end = i + 7
            nil: break
        if item_end < 0:
            break

        val item_xml = mcp_substr(remaining, item_start, item_end)

        val title = extract_xml_tag(item_xml, "title")
        val link = extract_xml_tag(item_xml, "link")
        val pub_date = extract_xml_tag(item_xml, "pubDate")
        val source = extract_xml_tag(item_xml, "source")

        item_count = item_count + 1
        results.push("")
        results.push(str(item_count) + ". " + clean_html_entities(title))
        if source != "":
            results.push("   Source: " + source)
        if pub_date != "":
            results.push("   Date: " + pub_date)
        if link != "":
            results.push("   Link: " + link)

        search_pos = search_pos + item_end

    if item_count == 0:
        results.push("(No news items found)")

    results.join("\n")

# ============================================================================
# Stock-specific News (Naver Finance)
# ============================================================================

fn get_stock_news(query: text, max_items: i64) -> text:
    val encoded_query = rt_http_url_encode(query) ?? query
    val rss_url = "https://news.google.com/rss/search?q=" + encoded_query + "+주식&hl=ko&gl=KR&ceid=KR:ko"
    val headers: [text] = ["User-Agent: Mozilla/5.0", "Accept: application/xml"]
    var status: i64 = 0
    var resp_body = ""
    var error = ""
    (status, resp_body, error) = rt_http_request("GET", rss_url, headers, "")

    if status < 200 or status >= 300:
        return "News for '" + query + "' (Unable to fetch news feed)"

    var results: [text] = []
    results.push("News for: " + query)
    results.push("=" .repeat(40))

    var item_count = 0
    var search_pos = 0
    while search_pos < resp_body.len() and item_count < max_items:
        val remaining = mcp_substr(resp_body, search_pos, resp_body.len())
        val item_start_result = remaining.index_of("<item>")
        var item_start = -1
        match item_start_result:
            Some(i): item_start = i
            nil: break
        if item_start < 0:
            break

        val item_end_result = remaining.index_of("</item>")
        var item_end = -1
        match item_end_result:
            Some(i): item_end = i + 7
            nil: break
        if item_end < 0:
            break

        val item_xml = mcp_substr(remaining, item_start, item_end)

        val title = extract_xml_tag(item_xml, "title")
        val link = extract_xml_tag(item_xml, "link")
        val pub_date = extract_xml_tag(item_xml, "pubDate")
        val source = extract_xml_tag(item_xml, "source")

        item_count = item_count + 1
        results.push("")
        results.push(str(item_count) + ". " + clean_html_entities(title))
        if source != "":
            results.push("   Source: " + source)
        if pub_date != "":
            results.push("   Date: " + pub_date)
        if link != "":
            results.push("   Link: " + link)

        search_pos = search_pos + item_end

    if item_count == 0:
        results.push("(No news items found)")

    results.join("\n")

# ============================================================================
# XML / HTML Helpers
# ============================================================================

fn extract_xml_tag(xml: text, tag_name: text) -> text:
    val open_tag = "<" + tag_name + ">"
    val close_tag = "</" + tag_name + ">"
    val start_result = xml.index_of(open_tag)
    var start = -1
    match start_result:
        Some(i): start = i
        nil: return ""
    if start < 0:
        return ""
    val content_start = start + open_tag.len()
    val remaining = mcp_substr(xml, content_start, xml.len())
    val end_result = remaining.index_of(close_tag)
    var end_pos = -1
    match end_result:
        Some(i): end_pos = i
        nil: return ""
    if end_pos < 0:
        return ""
    mcp_substr(remaining, 0, end_pos)

fn clean_html_entities(text: text) -> text:
    var result = text
    result = result.replace("&amp;", "&")
    result = result.replace("&lt;", "<")
    result = result.replace("&gt;", ">")
    result = result.replace("&quot;", Q())
    result = result.replace("&#39;", "'")
    result = result.replace("&apos;", "'")
    result

fn get_fallback_market_news() -> text:
    var lines: [text] = []
    lines.push("Unable to fetch live news. Check your network connection.")
    lines.push("")
    lines.push("For Korean stock market news, visit:")
    lines.push("- https://finance.naver.com/")
    lines.push("- https://www.hankyung.com/")
    lines.push("- https://www.mk.co.kr/")
    lines.join("\n")
