#!/bin/sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
cd "$ROOT_DIR"

BUILD_DIR="${BUILD_DIR:-build/portable_compute_toolchains}"
REPORT_PATH="${REPORT_PATH:-doc/09_report/portable_compute_toolchains_$(date -u +%F).md}"
SIMPLE_BIN="${SIMPLE_BIN:-bin/simple}"
NVCC_TOOL="${NVCC_TOOL:-nvcc}"
HIPCC_TOOL="${HIPCC_TOOL:-hipcc}"
OPENCL_SPIRV_TOOL="${OPENCL_SPIRV_TOOL:-opencl-c-to-spirv}"
METAL_TOOL="${METAL_TOOL:-metal}"
METALLIB_TOOL="${METALLIB_TOOL:-metallib}"
CUDA_ARCH="${CUDA_ARCH:-}"
HIP_ARCH="${HIP_ARCH:-gfx1100}"
TIMEOUT_SECS="${PORTABLE_COMPUTE_TOOLCHAIN_TIMEOUT_SECS:-180}"
KILL_SECS="${PORTABLE_COMPUTE_TOOLCHAIN_TIMEOUT_KILL_SECS:-10}"

mkdir -p "$BUILD_DIR" "$(dirname "$REPORT_PATH")"

have() {
    command -v "$1" >/dev/null 2>&1
}

run_with_timeout() {
    if have timeout; then
        timeout -k "$KILL_SECS" "$TIMEOUT_SECS" "$@"
    else
        "$@"
    fi
}

bytes_of() {
    if [ -f "$1" ]; then
        wc -c <"$1" | tr -d ' '
    else
        echo 0
    fi
}

contains_symbol() {
    path="$1"
    symbol="$2"
    if [ ! -f "$path" ]; then
        return 1
    fi
    if have strings; then
        strings "$path" | grep -F "$symbol" >/dev/null 2>&1
    else
        grep -a -F "$symbol" "$path" >/dev/null 2>&1
    fi
}

write_generated_source() {
    target="$1"
    path="$2"
    program="$BUILD_DIR/emit_${target}_portable_2d_source.spl"
    case "$target" in
        cuda) target_ctor=Cuda ;;
        hip) target_ctor=Hip ;;
        opencl) target_ctor=OpenCl ;;
        metal) target_ctor=Metal ;;
        *) return 1 ;;
    esac
    cat >"$program" <<SIMPLE
use compiler.backend.gpu_portable_compute.{PortableComputeTarget, emit_portable_2d_optimization_module}

fn main() -> i64:
    val artifact = emit_portable_2d_optimization_module(PortableComputeTarget.${target_ctor})
    print(artifact.source)
    return 0
SIMPLE
    SIMPLE_LIB="${SIMPLE_LIB:-src}" run_with_timeout "$SIMPLE_BIN" run "$program" --mode=interpreter --clean >"$path" 2>"$BUILD_DIR/${target}_source.err"
}

write_cuda_source() {
    path="$1"
    {
        printf '%s\n' 'extern "C" __global__ void simple_2d_fill_u32(unsigned int* dst, unsigned int value, unsigned int count) {'
        printf '%s\n' '    unsigned int i = blockIdx.x * blockDim.x + threadIdx.x;'
        printf '%s\n' '    if (i >= count) { return; }'
        printf '%s\n' '    dst[i] = value;'
        printf '%s\n' '}'
        printf '%s\n' 'extern "C" __global__ void simple_2d_copy_u32(const unsigned int* src, unsigned int* dst, unsigned int count) {'
        printf '%s\n' '    unsigned int i = blockIdx.x * blockDim.x + threadIdx.x;'
        printf '%s\n' '    if (i >= count) { return; }'
        printf '%s\n' '    dst[i] = src[i];'
        printf '%s\n' '}'
        printf '%s\n' 'extern "C" __global__ void simple_2d_alpha_u32(const unsigned int* src, unsigned int* dst, unsigned int alpha, unsigned int count) {'
        printf '%s\n' '    unsigned int i = blockIdx.x * blockDim.x + threadIdx.x;'
        printf '%s\n' '    if (i >= count) { return; }'
        printf '%s\n' '    unsigned int s = src[i];'
        printf '%s\n' '    unsigned int d = dst[i];'
        printf '%s\n' '    unsigned int inv = 255u - alpha;'
        printf '%s\n' '    unsigned int rb = (((s & 0x00ff00ffu) * alpha) + ((d & 0x00ff00ffu) * inv)) >> 8;'
        printf '%s\n' '    unsigned int g = (((s & 0x0000ff00u) * alpha) + ((d & 0x0000ff00u) * inv)) >> 8;'
        printf '%s\n' '    dst[i] = 0xff000000u | (rb & 0x00ff00ffu) | (g & 0x0000ff00u);'
        printf '%s\n' '}'
        printf '%s\n' 'extern "C" __global__ void simple_2d_scroll_u32(const unsigned int* src, unsigned int* dst, unsigned int width, unsigned int height, int delta_y) {'
        printf '%s\n' '    unsigned int i = blockIdx.x * blockDim.x + threadIdx.x;'
        printf '%s\n' '    unsigned int count = width * height;'
        printf '%s\n' '    if (i >= count) { return; }'
        printf '%s\n' '    unsigned int x = i % width;'
        printf '%s\n' '    unsigned int y = i / width;'
        printf '%s\n' '    int sy = (int)y - delta_y;'
        printf '%s\n' '    if (sy < 0 || sy >= (int)height) { dst[i] = 0u; return; }'
        printf '%s\n' '    dst[i] = src[(unsigned int)sy * width + x];'
        printf '%s\n' '}'
    } >"$path"
}

write_opencl_source() {
    path="$1"
    {
        printf '%s\n' '__kernel void simple_2d_fill_u32(__global uint* dst, uint value, uint count) {'
        printf '%s\n' '    uint i = get_global_id(0);'
        printf '%s\n' '    if (i >= count) { return; }'
        printf '%s\n' '    dst[i] = value;'
        printf '%s\n' '}'
        printf '%s\n' '__kernel void simple_2d_copy_u32(__global const uint* src, __global uint* dst, uint count) {'
        printf '%s\n' '    uint i = get_global_id(0);'
        printf '%s\n' '    if (i >= count) { return; }'
        printf '%s\n' '    dst[i] = src[i];'
        printf '%s\n' '}'
        printf '%s\n' '__kernel void simple_2d_alpha_u32(__global const uint* src, __global uint* dst, uint alpha, uint count) {'
        printf '%s\n' '    uint i = get_global_id(0);'
        printf '%s\n' '    if (i >= count) { return; }'
        printf '%s\n' '    uint s = src[i];'
        printf '%s\n' '    uint d = dst[i];'
        printf '%s\n' '    uint inv = 255u - alpha;'
        printf '%s\n' '    uint rb = (((s & 0x00ff00ffu) * alpha) + ((d & 0x00ff00ffu) * inv)) >> 8;'
        printf '%s\n' '    uint g = (((s & 0x0000ff00u) * alpha) + ((d & 0x0000ff00u) * inv)) >> 8;'
        printf '%s\n' '    dst[i] = 0xff000000u | (rb & 0x00ff00ffu) | (g & 0x0000ff00u);'
        printf '%s\n' '}'
        printf '%s\n' '__kernel void simple_2d_scroll_u32(__global const uint* src, __global uint* dst, uint width, uint height, int delta_y) {'
        printf '%s\n' '    uint i = get_global_id(0);'
        printf '%s\n' '    uint count = width * height;'
        printf '%s\n' '    if (i >= count) { return; }'
        printf '%s\n' '    uint x = i % width;'
        printf '%s\n' '    uint y = i / width;'
        printf '%s\n' '    int sy = (int)y - delta_y;'
        printf '%s\n' '    if (sy < 0 || sy >= (int)height) { dst[i] = 0u; return; }'
        printf '%s\n' '    dst[i] = src[(uint)sy * width + x];'
        printf '%s\n' '}'
    } >"$path"
}

write_metal_source() {
    path="$1"
    {
        printf '%s\n' '#include <metal_stdlib>'
        printf '%s\n' 'using namespace metal;'
        printf '%s\n' 'kernel void simple_2d_fill_u32(device uint* dst [[buffer(0)]], constant uint& value [[buffer(1)]], constant uint& count [[buffer(2)]], uint gid [[thread_position_in_grid]]) {'
        printf '%s\n' '    if (gid >= count) { return; }'
        printf '%s\n' '    dst[gid] = value;'
        printf '%s\n' '}'
        printf '%s\n' 'kernel void simple_2d_copy_u32(device const uint* src [[buffer(0)]], device uint* dst [[buffer(1)]], constant uint& count [[buffer(2)]], uint gid [[thread_position_in_grid]]) {'
        printf '%s\n' '    if (gid >= count) { return; }'
        printf '%s\n' '    dst[gid] = src[gid];'
        printf '%s\n' '}'
        printf '%s\n' 'kernel void simple_2d_alpha_u32(device const uint* src [[buffer(0)]], device uint* dst [[buffer(1)]], constant uint& alpha [[buffer(2)]], constant uint& count [[buffer(3)]], uint gid [[thread_position_in_grid]]) {'
        printf '%s\n' '    if (gid >= count) { return; }'
        printf '%s\n' '    uint s = src[gid];'
        printf '%s\n' '    uint d = dst[gid];'
        printf '%s\n' '    uint inv = 255u - alpha;'
        printf '%s\n' '    uint rb = (((s & 0x00ff00ffu) * alpha) + ((d & 0x00ff00ffu) * inv)) >> 8;'
        printf '%s\n' '    uint g = (((s & 0x0000ff00u) * alpha) + ((d & 0x0000ff00u) * inv)) >> 8;'
        printf '%s\n' '    dst[gid] = 0xff000000u | (rb & 0x00ff00ffu) | (g & 0x0000ff00u);'
        printf '%s\n' '}'
        printf '%s\n' 'kernel void simple_2d_scroll_u32(device const uint* src [[buffer(0)]], device uint* dst [[buffer(1)]], constant uint& width [[buffer(2)]], constant uint& height [[buffer(3)]], constant int& delta_y [[buffer(4)]], uint gid [[thread_position_in_grid]]) {'
        printf '%s\n' '    uint count = width * height;'
        printf '%s\n' '    if (gid >= count) { return; }'
        printf '%s\n' '    uint x = gid % width;'
        printf '%s\n' '    uint y = gid / width;'
        printf '%s\n' '    int sy = (int)y - delta_y;'
        printf '%s\n' '    if (sy < 0 || sy >= (int)height) { dst[gid] = 0u; return; }'
        printf '%s\n' '    dst[gid] = src[(uint)sy * width + x];'
        printf '%s\n' '}'
    } >"$path"
}

status_for_artifact() {
    target="$1"
    artifact="$2"
    shift 2
    bytes="$(bytes_of "$artifact")"
    if [ "$bytes" -le 0 ]; then
        echo "invalid:missing-artifact-bytes:0"
        return
    fi
    case "$target" in
        cuda)
            if ! grep -a -F ".version" "$artifact" >/dev/null 2>&1; then
                echo "invalid:artifact-magic-mismatch:$bytes"
                return
            fi
            ;;
        hip)
            magic="$(od -An -tx1 -N4 "$artifact" 2>/dev/null | tr -d ' \n')"
            if [ "$magic" != "7f454c46" ]; then
                echo "invalid:artifact-magic-mismatch:$bytes"
                return
            fi
            ;;
        opencl)
            magic="$(od -An -tx1 -N4 "$artifact" 2>/dev/null | tr -d ' \n')"
            if [ "$magic" != "03022307" ] && [ "$magic" != "07230203" ]; then
                echo "invalid:artifact-magic-mismatch:$bytes"
                return
            fi
            ;;
        metal)
            if ! grep -a -F "MTLB" "$artifact" >/dev/null 2>&1; then
                echo "invalid:artifact-magic-mismatch:$bytes"
                return
            fi
            ;;
    esac
    for symbol in "$@"; do
        if ! contains_symbol "$artifact" "$symbol"; then
            echo "invalid:missing-entry-symbol:$bytes"
            return
        fi
    done
    echo "valid:pass:$bytes"
}

emit_result() {
    target="$1"
    status="$2"
    reason="$3"
    bytes="$4"
    command_line="$5"
    artifact="$6"
    {
        echo "${target}_status=$status"
        echo "${target}_reason=$reason"
        echo "${target}_bytes=$bytes"
        echo "${target}_artifact=$artifact"
        echo "${target}_command=$command_line"
    } >>"$BUILD_DIR/evidence.env"
}

run_cuda() {
    src="$BUILD_DIR/simple_2d_optimization.cu"
    out="$BUILD_DIR/simple_2d_optimization.ptx"
    if ! write_generated_source cuda "$src"; then
        cmd="$SIMPLE_BIN run <cuda portable emitter> > $src"
        emit_result cuda generated_source_failed generated-source-failed 0 "$cmd" "$out"
        return
    fi
    if ! have "$NVCC_TOOL"; then
        cmd="$NVCC_TOOL --ptx -arch=<auto> -o $out $src"
        emit_result cuda unavailable missing-primary-tool 0 "$cmd" "$out"
        return
    fi
    cuda_arch="$CUDA_ARCH"
    if [ "$cuda_arch" = "" ]; then
        cuda_arch="$($NVCC_TOOL --list-gpu-arch 2>/dev/null | sed -n '1p')"
    fi
    if [ "$cuda_arch" = "" ]; then
        cmd="$NVCC_TOOL --ptx -arch=<auto> -o $out $src"
        emit_result cuda unavailable missing-cuda-arch 0 "$cmd" "$out"
        return
    fi
    cmd="$NVCC_TOOL --ptx -arch=$cuda_arch -o $out $src"
    if $NVCC_TOOL --ptx "-arch=$cuda_arch" -o "$out" "$src" >"$BUILD_DIR/cuda.out" 2>"$BUILD_DIR/cuda.err"; then
        IFS=: read -r valid reason bytes <<EOF
$(status_for_artifact cuda "$out" simple_2d_fill_u32 simple_2d_copy_u32 simple_2d_alpha_u32 simple_2d_scroll_u32)
EOF
        if [ "$valid" = "valid" ]; then
            emit_result cuda compiled_artifact_verified "$reason" "$bytes" "$cmd" "$out"
        else
            emit_result cuda "$valid" "$reason" "$bytes" "$cmd" "$out"
        fi
    else
        emit_result cuda toolchain_failed "toolchain_failed" 0 "$cmd" "$out"
    fi
}

run_hip() {
    src="$BUILD_DIR/simple_2d_optimization.hip.cpp"
    out="$BUILD_DIR/simple_2d_optimization.hsaco"
    if ! write_generated_source hip "$src"; then
        cmd="$SIMPLE_BIN run <hip portable emitter> > $src"
        emit_result hip generated_source_failed generated-source-failed 0 "$cmd" "$out"
        return
    fi
    cmd="$HIPCC_TOOL --genco --offload-arch=$HIP_ARCH -o $out $src"
    if ! have "$HIPCC_TOOL"; then
        emit_result hip unavailable missing-primary-tool 0 "$cmd" "$out"
        return
    fi
    if $HIPCC_TOOL --genco "--offload-arch=$HIP_ARCH" -o "$out" "$src" >"$BUILD_DIR/hip.out" 2>"$BUILD_DIR/hip.err"; then
        IFS=: read -r valid reason bytes <<EOF
$(status_for_artifact hip "$out" simple_2d_fill_u32 simple_2d_copy_u32 simple_2d_alpha_u32 simple_2d_scroll_u32)
EOF
        if [ "$valid" = "valid" ]; then
            emit_result hip compiled_artifact_verified "$reason" "$bytes" "$cmd" "$out"
        else
            emit_result hip "$valid" "$reason" "$bytes" "$cmd" "$out"
        fi
    else
        emit_result hip toolchain_failed "toolchain_failed" 0 "$cmd" "$out"
    fi
}

run_opencl() {
    src="$BUILD_DIR/simple_2d_optimization.cl"
    out="$BUILD_DIR/simple_2d_optimization.spirv"
    write_opencl_source "$src"
    cmd="$OPENCL_SPIRV_TOOL -cl-std=CL2.0 -emit-spirv -o $out $src"
    if ! have "$OPENCL_SPIRV_TOOL"; then
        emit_result opencl unavailable missing-primary-tool 0 "$cmd" "$out"
        return
    fi
    if $OPENCL_SPIRV_TOOL -cl-std=CL2.0 -emit-spirv -o "$out" "$src" >"$BUILD_DIR/opencl.out" 2>"$BUILD_DIR/opencl.err"; then
        IFS=: read -r valid reason bytes <<EOF
$(status_for_artifact opencl "$out" simple_2d_fill_u32 simple_2d_copy_u32 simple_2d_alpha_u32 simple_2d_scroll_u32)
EOF
        if [ "$valid" = "valid" ]; then
            emit_result opencl compiled_artifact_verified "$reason" "$bytes" "$cmd" "$out"
        else
            emit_result opencl "$valid" "$reason" "$bytes" "$cmd" "$out"
        fi
    else
        emit_result opencl toolchain_failed "toolchain_failed" 0 "$cmd" "$out"
    fi
}

run_metal() {
    src="$BUILD_DIR/simple_2d_optimization.metal"
    air="$BUILD_DIR/simple_2d_optimization.air"
    out="$BUILD_DIR/simple_2d_optimization.metallib"
    write_metal_source "$src"
    cmd="$METAL_TOOL -c $src -o $air && $METALLIB_TOOL $air -o $out"
    if ! have "$METAL_TOOL"; then
        emit_result metal unavailable missing-primary-tool 0 "$cmd" "$out"
        return
    fi
    if ! have "$METALLIB_TOOL"; then
        emit_result metal unavailable missing-metallib-tool 0 "$cmd" "$out"
        return
    fi
    if $METAL_TOOL -c "$src" -o "$air" >"$BUILD_DIR/metal.out" 2>"$BUILD_DIR/metal.err" && $METALLIB_TOOL "$air" -o "$out" >>"$BUILD_DIR/metal.out" 2>>"$BUILD_DIR/metal.err"; then
        IFS=: read -r valid reason bytes <<EOF
$(status_for_artifact metal "$out" simple_2d_fill_u32 simple_2d_copy_u32 simple_2d_alpha_u32 simple_2d_scroll_u32)
EOF
        if [ "$valid" = "valid" ]; then
            emit_result metal compiled_artifact_verified "$reason" "$bytes" "$cmd" "$out"
        else
            emit_result metal "$valid" "$reason" "$bytes" "$cmd" "$out"
        fi
    else
        emit_result metal toolchain_failed "toolchain_failed" 0 "$cmd" "$out"
    fi
}

rm -f "$BUILD_DIR/evidence.env"
run_cuda
run_hip
run_opencl
run_metal

{
    echo "# Portable Compute Toolchain Evidence"
    echo
    echo "Date: $(date -u +%F)"
    echo
    echo "| Target | Status | Reason | Bytes | Artifact |"
    echo "|---|---|---|---:|---|"
    for target in cuda hip opencl metal; do
        status="$(awk -F= -v k="${target}_status" '$1 == k { print $2 }' "$BUILD_DIR/evidence.env")"
        reason="$(awk -F= -v k="${target}_reason" '$1 == k { print $2 }' "$BUILD_DIR/evidence.env")"
        bytes="$(awk -F= -v k="${target}_bytes" '$1 == k { print $2 }' "$BUILD_DIR/evidence.env")"
        artifact="$(awk -F= -v k="${target}_artifact" '$1 == k { print $2 }' "$BUILD_DIR/evidence.env")"
        echo "| $target | $status | $reason | $bytes | $artifact |"
    done
    echo
    echo "## Commands"
    echo
    for target in cuda hip opencl metal; do
        command_line="$(awk -F= -v k="${target}_command" '$1 == k { print $2 }' "$BUILD_DIR/evidence.env")"
        echo "- $target: \`$command_line\`"
    done
} >"$REPORT_PATH"

echo "portable_compute_toolchains_ready=true"
echo "report_path=$REPORT_PATH"
cat "$BUILD_DIR/evidence.env"
