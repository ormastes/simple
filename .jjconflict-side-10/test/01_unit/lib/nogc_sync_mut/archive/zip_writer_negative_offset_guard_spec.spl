extern fn rt_file_read_text(path: text) -> text

fn _contains_zip_writer_negative_guards(path: text) -> bool:
    val source = rt_file_read_text(path) ?? ""
    return source.to_contain("fn read_u16_le(data: [u8], offset: i64) -> u16:") and
        source.to_contain("if offset < 0 or offset + 1 >= data.len():\n        return 0") and
        source.to_contain("fn read_u32_le(data: [u8], offset: i64) -> u32:") and
        source.to_contain("if offset < 0 or offset + 3 >= data.len():\n        return 0") and
        source.to_contain("val b0 = data[offset] as u16") and
        source.to_contain("val b0 = data[offset] as u32")

describe "ZIP writer negative offset guards":
    it "guards little-endian readers before indexed reads":
        expect(_contains_zip_writer_negative_guards("src/lib/nogc_sync_mut/archive/zip_writer.spl")).to_equal(true)
