use std.concurrent.thread.{thread_spawn_with_args}

extern fn rt_exit(code: i32)

fn add_pair(left: i64, right: i64) -> i64:
    left + right

fn lcg_pair(seed: i64, iters: i64) -> i64:
    var x = seed
    for i in 0..iters:
        x = (x * 1103515245 + 12345) % 2147483648
    x

fn main() -> i64:
    val direct_handle = thread_spawn_with_args(10, 32, add_pair)
    val direct_result = direct_handle.join()
    if direct_result != 42:
        rt_exit(41)

    val lambda_handle = thread_spawn_with_args(7, 11, \seed, iters: lcg_pair(seed, iters))
    val lambda_result = lambda_handle.join()
    val expected_lambda = lcg_pair(7, 11)
    if lambda_result != expected_lambda:
        rt_exit(42)

    0
