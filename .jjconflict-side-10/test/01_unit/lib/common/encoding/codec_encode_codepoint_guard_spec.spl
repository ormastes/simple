use std.spec.{describe, it, assert_equal}
use std.common.encoding.codec.{encode_from_codepoints, Encoding}

describe "encoding codec codepoint encode guards":
    it "keeps valid ASCII codepoints":
        assert_equal(encode_from_codepoints([65, 66], Encoding.Ascii), [65, 66])

    it "rejects negative ASCII codepoints as question marks":
        assert_equal(encode_from_codepoints([-1, 0x80], Encoding.Ascii), [0x3F, 0x3F])

    it "keeps valid Latin-1 codepoints":
        assert_equal(encode_from_codepoints([65, 255], Encoding.Latin1), [65, 255])

    it "rejects negative Latin-1 codepoints as question marks":
        assert_equal(encode_from_codepoints([-1, 256], Encoding.Latin1), [0x3F, 0x3F])
