use std.spec.{describe, it, assert_equal}
use std.common.cbor.types.{bytes_slice}

describe "CBOR bytes slice invalid guard":
    it "fails closed when selected slice contains malformed byte values":
        assert_equal(bytes_slice([1, -1, 2], 0, 3).len(), 0)
        assert_equal(bytes_slice([1, 300, 2], 1, 1).len(), 0)

    it "ignores malformed values outside the selected slice":
        val result = bytes_slice([1, 2, 300], 0, 2)
        assert_equal(result.len(), 2)
        assert_equal(result[0], 1)
        assert_equal(result[1], 2)

    it "keeps valid partial slicing behavior":
        val result = bytes_slice([10, 20, 30], -1, 3)
        assert_equal(result.len(), 2)
        assert_equal(result[0], 10)
        assert_equal(result[1], 20)
