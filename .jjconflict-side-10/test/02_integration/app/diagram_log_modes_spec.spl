use std.spec.{describe, it, expect}

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

fn _run_diagram(args: [text]) -> (text, text, i64):
    val joined = args.join(" ")
    rt_process_run("/bin/sh", [
        "-c",
        "REPO=$(pwd); TMP=/tmp/simple-diagram-log-modes; mkdir -p \"$TMP\"; printf '1|call|Main|Worker|x|ok|5\\n' > \"$TMP/profile.log\"; SIMPLE_LIB=\"$REPO/src\" \"$REPO/bin/simple\" run \"$REPO/src/app/diagram/main.spl\" " + joined
    ])

describe "diagram log mode CLI options":
    it "shows shared log options in help":
        val (out, err, code) = _run_diagram(["--help"])
        expect(code).to_equal(0)
        expect(out).to_contain("--log-mode")
        expect(out).to_contain("--progress")

    it "supports log-mode json for usage output":
        val (out, err, code) = _run_diagram(["--log-mode=json"])
        expect(code).to_equal(0)
        expect(out).to_contain("\"command\":\"diagram\"")
        expect(out).to_contain("\"status\":\"usage\"")

    it "supports dot progress for usage output":
        val (out, err, code) = _run_diagram(["--progress=dot"])
        expect(code).to_equal(0)
        expect(out).to_start_with(".")
        expect(out).to_contain("Usage: simple diagram")

    it "rejects invalid log mode":
        val (out, err, code) = _run_diagram(["--log-mode=noisy"])
        expect(code).to_equal(1)

    it "emits json for generated diagrams":
        val (out, err, code) = _run_diagram([
            "--log-mode=json",
            "--from-file",
            "/tmp/simple-diagram-log-modes/profile.log",
            "--output",
            "/tmp/simple-diagram-log-modes",
            "--name",
            "sample"
        ])
        expect(code).to_equal(0)
        expect(out).to_contain("\"command\":\"diagram\"")
        expect(out).to_contain("\"status\":\"ok\"")
        expect(out).to_contain("\"generated\":1")
