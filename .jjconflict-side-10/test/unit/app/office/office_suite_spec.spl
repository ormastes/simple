use std.spec.{describe, it, expect}

use app.office.mod.{run_office}
use app.office.launcher.{build_launcher_ui}
use app.office.word.word_app.{WordApp}
use app.office.sheets.sheets_app.{SheetsApp}
use app.office.sheets.render.{apply_cell_format}
use app.office.slides.slides_app.{SlidesApp}
use app.office.slides.slide.{current_slide, SlideElementKind}
use app.office.mail.mail_app.{MailApp}
use app.office.planner.planner_app.{PlannerApp}
use app.office.planner.task.{new_task, priority_name, priority_icon}
use common.office.file_ops.{RecentFile}
use common.ui.widget.{UIEvent}
use common.office.search.{default_search_options, replace_first}

describe "Office CLI":
    it "defaults to launcher":
        expect(run_office([])).to_equal(0)

    it "loads word":
        expect(run_office(["word"])).to_equal(0)

    it "loads sheets":
        expect(run_office(["sheets"])).to_equal(0)

    it "loads slides":
        expect(run_office(["slides"])).to_equal(0)

    it "loads mail":
        expect(run_office(["mail"])).to_equal(0)

    it "loads planner":
        expect(run_office(["planner"])).to_equal(0)

    it "rejects unknown app":
        expect(run_office(["unknown"])).to_equal(1)

describe "Office UI":
    it "builds launcher ui":
        val recent = [
            RecentFile(path: "/tmp/test.sdoc", app_name: "word", title: "Test Doc", timestamp: "2026-03-25")
        ]
        val ui = build_launcher_ui(recent)
        expect(ui.root_id).to_equal("root")

    it "builds word ui":
        val app = WordApp.new()
        val ui = app.build_ui()
        expect(ui.root_id).to_equal("word_root")
        expect(app.word_count()).to_equal(0)

    it "builds sheets ui":
        val app = SheetsApp.new()
        val ui = app.build_ui()
        expect(ui.root_id).to_equal("root")

    it "builds slides ui":
        val app = SlidesApp.new()
        val ui = app.build_ui()
        expect(ui.root_id).to_equal("root")

    it "builds mail ui with sample data":
        val app = MailApp.new()
        val ui = app.build_ui()
        expect(ui.root_id).to_equal("root")
        expect(app.emails.len()).to_equal(5)
        expect(app.unread_count()).to_equal(2)

    it "builds planner ui":
        val app = PlannerApp.new()
        val ui = app.build_ui()
        expect(ui.root_id).to_equal("root")

describe "Office Hardening":
    it "adds slides image element without fake asset path":
        var app = SlidesApp.new()
        app.handle_event(UIEvent.Action(name: "add_image"))
        val slide = current_slide(app.presentation)
        expect(slide.elements.len()).to_equal(1)
        match slide.elements[0].kind:
            SlideElementKind.ImageEl(src, alt):
                expect(src).to_equal("")
                expect(alt).to_equal("Image Frame")
            _:
                expect(false).to_equal(true)

    it "formats date values honestly in sheets":
        val formatted = apply_cell_format(366.0, "date")
        expect(formatted).to_equal("1971-01-02")

    it "replaces the first office search match":
        val options = default_search_options()
        val result = replace_first("draft draft", "draft", "final", 0, options)
        expect(result).to_equal("final draft")

    it "uses a stable unset planner priority without command warnings":
        val task = new_task("task_0", "Backlog")
        expect(priority_name(task.priority)).to_equal("None")
        expect(priority_icon(task.priority)).to_equal("-")
