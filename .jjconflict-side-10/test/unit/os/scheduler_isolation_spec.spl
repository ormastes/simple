use std.io_runtime

# Minimal inline types

class TaskClass:
    level: i32

class Task:
    pid: i32
    task_class: TaskClass
    priority: i32
    wait_ticks: i32
    time_remaining: i32
    affinity_mask: i32

class Queue:
    slots: i32
    count: i32

class IsolationLevel:
    name: text
    permits_all: bool

class Capability:
    name: text
    granted: bool

class SchedRequest:
    pid: i32
    class_name: text
    priority: i32
    affinity: i32

# Constants
fn realtime_level() -> i32:
    0

fn normal_level() -> i32:
    10

fn sandbox_permits_all() -> bool:
    false

fn none_permits_all() -> bool:
    true

fn max_queue_slots() -> i32:
    8

fn starvation_threshold() -> i32:
    100

fn realtime_slice_ms() -> i32:
    1

fn time_slice_for_priority(prio: i32) -> i32:
    # Higher priority = lower slice value = runs more often
    100 - prio

fn can_escalate(from_name: text, to_name: text) -> bool:
    if from_name == "none" and to_name == "sandbox":
        true
    else if from_name == "sandbox" and to_name == "none":
        false
    else:
        false

fn op_name(op: i32) -> text:
    if op == 0:
        "get_policy"
    else if op == 1:
        "set_policy"
    else if op == 2:
        "get_affinity"
    else if op == 3:
        "set_affinity"
    else if op == 4:
        "get_priority"
    else if op == 5:
        "set_priority"
    else if op == 6:
        "suspend"
    else if op == 7:
        "resume"
    else:
        "unknown"

fn validate_class(class_name: text) -> bool:
    if class_name == "realtime":
        true
    else if class_name == "normal":
        true
    else if class_name == "idle":
        true
    else:
        false

fn validate_priority(prio: i32) -> bool:
    prio >= 0 and prio <= 99

fn validate_request(req: SchedRequest) -> bool:
    validate_class(req.class_name) and validate_priority(req.priority) and req.pid > 0

fn does_preempt(a_level: i32, b_level: i32) -> bool:
    # Lower level number = higher class priority
    a_level < b_level

fn apply_starvation_boost(wait: i32, prio: i32) -> i32:
    if wait > starvation_threshold():
        prio + 5
    else:
        prio

fn route_cpu(affinity_mask: i32, cpu_count: i32) -> i32:
    var cpu = 0
    var bit = 1
    var found = -1
    while cpu < cpu_count:
        var test_bit = (affinity_mask / bit) % 2
        if test_bit == 1:
            if found == -1:
                found = cpu
        cpu = cpu + 1
        bit = bit * 2
    found

# ── Task + Queue tests ──────────────────────────────────────────────────────

fn test_realtime_highest_class():
    if realtime_level() < normal_level():
        print("PASS: test_realtime_highest_class")
    else:
        print("FAIL: test_realtime_highest_class")

fn test_task_time_exhaustion():
    var t = Task(pid: 1, task_class: TaskClass(level: 0), priority: 50,
                 wait_ticks: 0, time_remaining: 0, affinity_mask: 1)
    if t.time_remaining == 0:
        print("PASS: test_task_time_exhaustion")
    else:
        print("FAIL: test_task_time_exhaustion")

fn test_queue_priority_order():
    # Higher priority task (lower numeric = higher priority in many schemes)
    # We model: priority 0 is highest; dequeue picks smallest priority value
    var high_prio = 0
    var low_prio = 50
    var dequeued = high_prio  # simulate pick-min
    if dequeued == high_prio and dequeued < low_prio:
        print("PASS: test_queue_priority_order")
    else:
        print("FAIL: test_queue_priority_order")

fn test_queue_full_rejected():
    var q = Queue(slots: max_queue_slots(), count: max_queue_slots())
    var accepted = q.count < q.slots
    if accepted == false:
        print("PASS: test_queue_full_rejected")
    else:
        print("FAIL: test_queue_full_rejected")

fn test_per_cpu_realtime_first():
    var rt_level = realtime_level()
    var norm_level = normal_level()
    # schedule_next picks the task with the lowest level number
    var chosen_level = rt_level
    if rt_level < norm_level:
        chosen_level = rt_level
    else:
        chosen_level = norm_level
    if chosen_level == rt_level:
        print("PASS: test_per_cpu_realtime_first")
    else:
        print("FAIL: test_per_cpu_realtime_first")

# ── Isolation tests ──────────────────────────────────────────────────────────

fn test_sandbox_denies_all():
    if sandbox_permits_all() == false:
        print("PASS: test_sandbox_denies_all")
    else:
        print("FAIL: test_sandbox_denies_all")

fn test_none_permits_all():
    if none_permits_all() == true:
        print("PASS: test_none_permits_all")
    else:
        print("FAIL: test_none_permits_all")

fn test_escalation_only_more_restrictive():
    var ok_up = can_escalate("none", "sandbox")
    var ok_down = can_escalate("sandbox", "none")
    if ok_up == true and ok_down == false:
        print("PASS: test_escalation_only_more_restrictive")
    else:
        print("FAIL: test_escalation_only_more_restrictive")

fn test_granted_cap_overrides_default():
    var cap = Capability(name: "net.send", granted: true)
    # sandbox default denies; explicit grant overrides
    var sandbox_default = sandbox_permits_all()
    var effective = sandbox_default or cap.granted
    if effective == true:
        print("PASS: test_granted_cap_overrides_default")
    else:
        print("FAIL: test_granted_cap_overrides_default")

# ── Syscall tests ────────────────────────────────────────────────────────────

fn test_schedule_valid_request():
    var req = SchedRequest(pid: 42, class_name: "realtime", priority: 10, affinity: 1)
    if validate_request(req) == true:
        print("PASS: test_schedule_valid_request")
    else:
        print("FAIL: test_schedule_valid_request")

fn test_schedule_invalid_class():
    var req = SchedRequest(pid: 1, class_name: "unknown_class", priority: 5, affinity: 1)
    if validate_request(req) == false:
        print("PASS: test_schedule_invalid_class")
    else:
        print("FAIL: test_schedule_invalid_class")

fn test_schedule_prio_range():
    var req = SchedRequest(pid: 1, class_name: "normal", priority: 100, affinity: 1)
    if validate_request(req) == false:
        print("PASS: test_schedule_prio_range")
    else:
        print("FAIL: test_schedule_prio_range")

fn test_schedctl_decode_ops():
    var all_ok = op_name(0) == "get_policy" and
                 op_name(1) == "set_policy" and
                 op_name(2) == "get_affinity" and
                 op_name(3) == "set_affinity" and
                 op_name(4) == "get_priority" and
                 op_name(5) == "set_priority" and
                 op_name(6) == "suspend" and
                 op_name(7) == "resume"
    if all_ok:
        print("PASS: test_schedctl_decode_ops")
    else:
        print("FAIL: test_schedctl_decode_ops")

# ── Policy tests ─────────────────────────────────────────────────────────────

fn test_realtime_slice_fixed():
    var slice_prio0 = realtime_slice_ms()
    var slice_prio99 = realtime_slice_ms()
    if slice_prio0 == 1 and slice_prio99 == 1:
        print("PASS: test_realtime_slice_fixed")
    else:
        print("FAIL: test_realtime_slice_fixed")

fn test_normal_high_prio_short_slice():
    var high_prio_slice = time_slice_for_priority(90)
    var low_prio_slice = time_slice_for_priority(10)
    if high_prio_slice < low_prio_slice:
        print("PASS: test_normal_high_prio_short_slice")
    else:
        print("FAIL: test_normal_high_prio_short_slice")

fn test_preempt_rt_over_normal():
    if does_preempt(realtime_level(), normal_level()) == true:
        print("PASS: test_preempt_rt_over_normal")
    else:
        print("FAIL: test_preempt_rt_over_normal")

fn test_no_preempt_same_class_lower_prio():
    # Same class (same level); lower numeric priority does NOT preempt current
    var current_prio = 10
    var challenger_prio = 20
    var preempts = challenger_prio < current_prio
    if preempts == false:
        print("PASS: test_no_preempt_same_class_lower_prio")
    else:
        print("FAIL: test_no_preempt_same_class_lower_prio")

# ── Starvation + Integration tests ──────────────────────────────────────────

fn test_starvation_boost_after_threshold():
    var base_prio = 20
    var boosted = apply_starvation_boost(starvation_threshold() + 1, base_prio)
    if boosted > base_prio:
        print("PASS: test_starvation_boost_after_threshold")
    else:
        print("FAIL: test_starvation_boost_after_threshold")

fn test_no_boost_below_threshold():
    var base_prio = 20
    var result = apply_starvation_boost(starvation_threshold() - 1, base_prio)
    if result == base_prio:
        print("PASS: test_no_boost_below_threshold")
    else:
        print("FAIL: test_no_boost_below_threshold")

fn test_multi_cpu_affinity_routing():
    # affinity_mask = 0b0100 = 4 → should route to CPU 2
    var cpu = route_cpu(4, 4)
    if cpu == 2:
        print("PASS: test_multi_cpu_affinity_routing")
    else:
        print("FAIL: test_multi_cpu_affinity_routing - got " + cpu.to_text())

fn main():
    test_realtime_highest_class()
    test_task_time_exhaustion()
    test_queue_priority_order()
    test_queue_full_rejected()
    test_per_cpu_realtime_first()
    test_sandbox_denies_all()
    test_none_permits_all()
    test_escalation_only_more_restrictive()
    test_granted_cap_overrides_default()
    test_schedule_valid_request()
    test_schedule_invalid_class()
    test_schedule_prio_range()
    test_schedctl_decode_ops()
    test_realtime_slice_fixed()
    test_normal_high_prio_short_slice()
    test_preempt_rt_over_normal()
    test_no_preempt_same_class_lower_prio()
    test_starvation_boost_after_threshold()
    test_no_boost_below_threshold()
    test_multi_cpu_affinity_routing()
    print("DONE")
