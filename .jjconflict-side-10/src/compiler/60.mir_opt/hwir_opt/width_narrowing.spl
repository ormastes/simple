# HWIR width narrowing.

use compiler.mir.hwir.types.{HwModule}
use compiler.mir_opt.hwir_opt.pass_model.{HwirOptPassResult, hwir_cost_delta_lut}

class HwirWidthRange:
    """Static value range used to narrow a hardware value."""
    node_id: text
    min_value: i64
    max_value: i64
    original_width: i32
    signed_value: bool

    me required_width() -> i32:
        var bits = 1
        var limit: i64 = 1
        var value = self.max_value
        if self.signed_value:
            value = self.max_value.abs()
        while limit <= value:
            bits = bits + 1
            limit = limit * 2
        if self.signed_value:
            return bits + 1
        return bits

    me narrowed_bits() -> i32:
        val required = self.required_width()
        if required >= self.original_width:
            return 0
        return self.original_width - required

fn hwir_width_narrowing_pass(module: HwModule, ranges: [HwirWidthRange]) -> HwirOptPassResult:
    var narrowed = 0
    for r in ranges:
        narrowed = narrowed + r.narrowed_bits()
    if narrowed == 0:
        return HwirOptPassResult.unchanged("width_narrowing", module, "no narrower static ranges")
    val lut_reduction = 0 - (narrowed / 4)
    return HwirOptPassResult.changed("width_narrowing", module, hwir_cost_delta_lut(module.cost, lut_reduction), 0, narrowed, 0, 0, "reduced operator widths from static ranges")
