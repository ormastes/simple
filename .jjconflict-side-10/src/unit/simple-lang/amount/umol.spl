# Unit: Umol
# Kind: Amount
# Symbol: umol
# Canonical scale: 1e-06 mol

class Umol:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Umol) -> Umol: Umol(value: self.value + other.value)
    fn sub(other: Umol) -> Umol: Umol(value: self.value - other.value)

    static fn kind() -> text: "Amount"
    static fn symbol() -> text: "umol"
    static fn scale_to_base() -> f64: 1e-06
    static fn base_unit() -> text: "mol"
    static fn zero() -> Umol: Umol(value: 0.0)

export Umol
