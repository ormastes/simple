# ============================================================================
# Headless device probe (lavapipe / CpuOnly selection)
# ============================================================================
#
# vulkan_sffi_find_headless_device() searches the enumerated Vulkan device list
# for a CpuOnly (software ICD) device.  The lavapipe ICD
# (/usr/share/vulkan/icd.d/lvp_icd.json) enumerates as type "cpu".
#
# Returns the device id (>=0) on success, -1 when no CpuOnly device is found.
# The caller must call vulkan_sffi_init() and verify vulkan_sffi_is_available()
# before calling this function.

fn vulkan_sffi_find_headless_device() -> i64:
    val count = rt_vulkan_device_count()
    var i: i64 = 0
    var found: i64 = -1
    while i < count:
        val dt = rt_vulkan_device_type(i)
        if dt == "cpu" or dt == "CpuOnly":
            found = i
        i = i + 1
    found

fn vulkan_sffi_select_headless() -> bool:
    """Select the first CpuOnly (lavapipe) device.  Returns false when none found."""
    val dev = vulkan_sffi_find_headless_device()
    if dev < 0:
        false
    else:
        rt_vulkan_select_device(dev)
