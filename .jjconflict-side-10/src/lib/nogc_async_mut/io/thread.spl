"""
# No-GC Async Thread Operations

Compatibility facade over the no-GC sync thread backend.
"""

export use std.nogc_sync_mut.io.thread.{
    thread_available_parallelism, thread_sleep_ms, thread_yield,
    thread_current_id,
    atomic_i64_load, atomic_i64_store, atomic_i64_fetch_add,
    atomic_i64_compare_exchange
}
