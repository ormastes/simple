fn len_once_text() -> i64:
    val arr = ["a", "b"]
    val _len = arr.len()
    0

fn len_once_i64() -> i64:
    val arr = [1, 2]
    val _len = arr.len()
    0

fn len_twice_text() -> i64:
    val arr = ["a", "b"]
    val _first = arr.len()
    val _second = arr.len()
    0

fn len_twice_i64() -> i64:
    val arr = [1, 2]
    val _first = arr.len()
    val _second = arr.len()
    0

fn len_then_push() -> i64:
    var arr = ["a"]
    val _len = arr.len()
    arr = arr.push("b")
    0

fn push_then_len() -> i64:
    var arr = [1]
    arr = arr.push(2)
    val _len = arr.len()
    1
