//! Target: `library/std/src/sys/mod.rs`
//!
//! Adds a `simpleos` arm to the `target_os` selector that picks the PAL.
//! Apply by replacing `library/std/src/sys/mod.rs` with this file, or
//! splice just the new `cfg_if` branch into the upstream file.

#![allow(missing_docs, nonstandard_style)]

// All the existing unix/windows/etc. modules remain — only the `cfg_if`
// chain that selects `pal` gets the new SimpleOS arm.

pub mod anonymous_pipe;
pub mod backtrace;
pub mod cmath;
pub mod exit_guard;
pub mod fd;
pub mod fs;
pub mod io;
pub mod net;
pub mod os_str;
pub mod pal;
pub mod path;
pub mod personality;
pub mod process;
pub mod random;
pub mod stdio;
pub mod sync;
pub mod thread;
pub mod thread_local;
pub mod time;

cfg_if::cfg_if! {
    if #[cfg(target_family = "unix")] {
        // Keep the stock unix path for host builds.
        pub use self::pal::unix::*;
    } else if #[cfg(target_os = "simpleos")] {
        pub use self::pal::simpleos::*;
    } else if #[cfg(target_family = "windows")] {
        pub use self::pal::windows::*;
    } else if #[cfg(target_os = "hermit")] {
        pub use self::pal::hermit::*;
    } else if #[cfg(target_os = "wasi")] {
        pub use self::pal::wasi::*;
    } else {
        pub use self::pal::unsupported::*;
    }
}

// NOTE: Upstream `library/std/src/sys/mod.rs` is more elaborate; this patch
// is a minimal illustration of the `cfg_if` splice. In practice, the
// maintainer should hand-merge the `target_os = "simpleos"` arm into the
// upstream file rather than overwriting it wholesale.
