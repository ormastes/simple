# Arch-Common Helper Module — re-exports all 9 shared-helper modules.
#
# Per-arch code under `src/os/kernel/arch/<arch>/` imports from
# `os.kernel.arch.common.<helper>` directly; this `mod.spl` is the
# umbrella entry-point used by the harden audit + LoC-reduction reports
# to see one root for the shared layer.
#
# Wave 2 — added 2026-04-25 for AC-3 helper extraction.

use os.kernel.arch.common.console_framing
use os.kernel.arch.common.paging_walker
use os.kernel.arch.common.interrupt_dispatch
use os.kernel.arch.common.timer_math
use os.kernel.arch.common.context_layout
use os.kernel.arch.common.sbi_shim
use os.kernel.arch.common.gic_common
use os.kernel.arch.common.x86_descriptor
use os.kernel.arch.common.relocations
