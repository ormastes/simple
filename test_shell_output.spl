use std.nogc_sync_mut.io.process_ops.{shell_output}

val result = shell_output("find test/fixtures/duplicate_check -name '*.spl' 2>/dev/null || true", "")
val lines = result.split("\n")
print "Found {lines.len()} lines"
for line in lines:
    val trimmed = line.trim()
    if trimmed.len() > 0:
        print "  {trimmed}"
