# Unit: Byte
# Kind: Data
# Symbol: B
# Canonical scale: 1.0 B

class Byte:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Byte) -> Byte: Byte(value: self.value + other.value)
    fn sub(other: Byte) -> Byte: Byte(value: self.value - other.value)

    static fn kind() -> text: "Data"
    static fn symbol() -> text: "B"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "B"
    static fn zero() -> Byte: Byte(value: 0.0)

export Byte
