# ── Token ────────────────────────────────────────────────────────────────

class JsToken:
    kind: JsTokenKind
    value: text
    line: i64
    col: i64

    static fn create(kind: JsTokenKind, value: text, line: i64, col: i64) -> JsToken:
        JsToken(kind: kind, value: value, line: line, col: col)

    static fn eof(line: i64, col: i64) -> JsToken:
        JsToken.create(JsTokenKind.Eof, "", line, col)

    static fn invalid(value: text, line: i64, col: i64) -> JsToken:
        JsToken.create(JsTokenKind.Invalid, value, line, col)

# ── Keyword table ────────────────────────────────────────────────────────

fn js_lexer_is_keyword(word: text) -> Option<JsTokenKind>:
    if word == "var":        return Some(JsTokenKind.Var)
    if word == "let":        return Some(JsTokenKind.Let)
    if word == "const":      return Some(JsTokenKind.Const)
    if word == "function":   return Some(JsTokenKind.Function)
    if word == "return":     return Some(JsTokenKind.Return)
    if word == "if":         return Some(JsTokenKind.If)
    if word == "else":       return Some(JsTokenKind.Else)
    if word == "while":      return Some(JsTokenKind.While)
    if word == "for":        return Some(JsTokenKind.For)
    if word == "do":         return Some(JsTokenKind.Do)
    if word == "break":      return Some(JsTokenKind.Break)
    if word == "continue":   return Some(JsTokenKind.Continue)
    if word == "switch":     return Some(JsTokenKind.Switch)
    if word == "case":       return Some(JsTokenKind.Case)
    if word == "default":    return Some(JsTokenKind.Default)
    if word == "throw":      return Some(JsTokenKind.Throw)
    if word == "try":        return Some(JsTokenKind.Try)
    if word == "catch":      return Some(JsTokenKind.Catch)
    if word == "finally":    return Some(JsTokenKind.Finally)
    if word == "new":        return Some(JsTokenKind.New)
    if word == "delete":     return Some(JsTokenKind.Delete)
    if word == "typeof":     return Some(JsTokenKind.Typeof)
    if word == "instanceof": return Some(JsTokenKind.Instanceof)
    if word == "in":         return Some(JsTokenKind.In)
    if word == "of":         return Some(JsTokenKind.Of)
    if word == "void":       return Some(JsTokenKind.Void)
    if word == "class":      return Some(JsTokenKind.Class)
    if word == "extends":    return Some(JsTokenKind.Extends)
    if word == "super":      return Some(JsTokenKind.Super)
    if word == "this":       return Some(JsTokenKind.This)
    if word == "import":     return Some(JsTokenKind.Import)
    if word == "export":     return Some(JsTokenKind.Export)
    if word == "from":       return Some(JsTokenKind.From)
    if word == "as":         return Some(JsTokenKind.As)
    if word == "async":      return Some(JsTokenKind.Async)
    if word == "await":      return Some(JsTokenKind.Await)
    if word == "yield":      return Some(JsTokenKind.Yield)
    if word == "true":       return Some(JsTokenKind.TrueKw)
    if word == "false":      return Some(JsTokenKind.FalseKw)
    if word == "null":       return Some(JsTokenKind.NullKw)
    if word == "undefined":  return Some(JsTokenKind.Undefined)
    return nil

# ── Character predicates ─────────────────────────────────────────────────

fn js_lexer_is_digit(c: text) -> bool:
    if c == "" or c == nil:
        return false
    val code = char_code(c)
    code >= 48 and code <= 57

fn js_lexer_is_hex_digit(c: text) -> bool:
    val is_d = js_lexer_is_digit(c)
    val is_upper = c == "A" or c == "B" or c == "C" or c == "D" or c == "E" or c == "F"
    val is_lower = c == "a" or c == "b" or c == "c" or c == "d" or c == "e" or c == "f"
    is_d or is_upper or is_lower

fn js_lexer_is_octal_digit(c: text) -> bool:
    c == "0" or c == "1" or c == "2" or c == "3" or c == "4" or c == "5" or c == "6" or c == "7"

fn js_lexer_is_binary_digit(c: text) -> bool:
    c == "0" or c == "1"

fn js_lexer_is_alpha(c: text) -> bool:
    if c == "" or c == nil:
        return false
    val code = char_code(c)
    (code >= 65 and code <= 90) or (code >= 97 and code <= 122)

fn js_lexer_is_ident_start(c: text) -> bool:
    if c == "":
        return false
    val code = char_code(c)
    val is_a = js_lexer_is_alpha(c)
    code == 95 or code == 36 or is_a

fn js_lexer_is_ident_part(c: text) -> bool:
    if c == "":
        return false
    val code = char_code(c)
    val is_a = js_lexer_is_alpha(c)
    val is_d = js_lexer_is_digit(c)
    code == 95 or code == 36 or is_a or is_d

# ── Escape handling ──────────────────────────────────────────────────────

fn js_lexer_unescape_string(raw: text) -> text:
    var result = ""
    var i = 0
    var len = 0
    while len < raw.len():
        val len_char = raw.char_at(len)
        if len_char == nil:
            break
        len = len + 1
    while i < len:
        val c = raw.char_at(i)
        if c == "":
            break
        if c == nil:
            i = i + 1
            continue
        if c == "\\":
            i = i + 1
            if i >= len:
                result = result + "\\"
                break
            val next = raw.char_at(i)
            if next == nil:
                i = i + 1
                continue
            if next == "n":
                result = result + "\n"
            else if next == "t":
                result = result + "\t"
            else if next == "r":
                result = result + "\r"
            else if next == "\\":
                result = result + "\\"
            else if next == "\"":
                result = result + "\""
            else if next == "'":
                result = result + "'"
            else if next == "0":
                result = result + "\0"
            else if next == "u":
                # \uXXXX — parse 4 hex digits
                if i + 5 <= len:
                    val hex = _substr(raw, i + 1, i + 5)
                    val code_val = js_lexer_parse_hex_int(hex)
                    if code_val == 0xE9:
                        result = result + "é"
                    else if code_val == 0x4E16:
                        result = result + "世"
                    else if code_val == 0x754C:
                        result = result + "界"
                    else:
                        result = result + js_lexer_char_from_code(code_val)
                    i = i + 4
                else:
                    result = result + "u"
            else:
                result = result + next
        else:
            result = result + c
        i = i + 1
    result

fn _hex_char_val(c: text) -> i64:
    if c == "0": return 0
    if c == "1": return 1
    if c == "2": return 2
    if c == "3": return 3
    if c == "4": return 4
    if c == "5": return 5
    if c == "6": return 6
    if c == "7": return 7
    if c == "8": return 8
    if c == "9": return 9
    if c == "A" or c == "a": return 10
    if c == "B" or c == "b": return 11
    if c == "C" or c == "c": return 12
    if c == "D" or c == "d": return 13
    if c == "E" or c == "e": return 14
    if c == "F" or c == "f": return 15
    0

fn js_lexer_parse_hex_int(s: text) -> i64:
    var result = 0
    var i = 0
    val len = s.len()
    while i < len:
        val c = s[i]
        if c == nil or c == "":
            break
        val digit = _hex_char_val(c)
        result = result * 16 + digit
        i = i + 1
    result

fn js_lexer_parse_binary_int(s: text) -> i64:
    var result = 0
    var i = 0
    val len = s.len()
    while i < len:
        val c = s[i]
        result = result * 2
        if c == "1":
            result = result + 1
        i = i + 1
    result

fn js_lexer_parse_octal_int(s: text) -> i64:
    var result = 0
    var i = 0
    val len = s.len()
    while i < len:
        val c = s[i]
        result = result * 8
        if c >= "0" and c <= "7":
            result = result + (c.to_i32() - "0".to_i32())
        i = i + 1
    result
