"""Dynamic-loading coexistence contract for Wine substrate work."""

use common.wine_host_gate.{wine_dynamic_gate}
use common.wine_ntdll_loader.{WineNtdllLoaderResult}

class WineDynloadAdapterResult:
    ready: bool
    state: text
    dynload_features: text

fn _dynload_result(ready: bool, state: text, dynload_features: text) -> WineDynloadAdapterResult:
    WineDynloadAdapterResult(ready: ready, state: state, dynload_features: dynload_features)

pub fn wine_dynload_adapter_required_apis() -> [text]:
    [
        "native-module-open",
        "native-module-close",
        "native-self-handle",
        "native-symbol-lookup",
        "search-path",
        "dependency-list",
        "link-namespace",
        "relocation-apply",
        "import-bind",
        "tls-callback",
        "pe-loader-boundary",
        "structured-loader-error"
    ]

pub fn wine_dynload_adapter_missing_apis(apis: text) -> [text]:
    var missing: [text] = []
    for api in wine_dynload_adapter_required_apis():
        if not apis.contains(api):
            missing.push(api)
    missing

pub fn wine_dynload_adapter_native_binding(api: text) -> text:
    if api == "native-module-open":
        return "spl_dlopen"
    if api == "native-symbol-lookup":
        return "spl_dlsym"
    if api == "native-module-close":
        return "spl_dlclose"
    if api == "native-self-handle":
        return "dlopen(NULL)"
    ""

pub fn wine_dynload_adapter_feature_string(apis: text) -> text:
    var features = ""
    if apis.contains("native-module-open") and apis.contains("native-module-close") and apis.contains("native-self-handle"):
        features = features + " dynload"
    if apis.contains("native-symbol-lookup") and apis.contains("import-bind"):
        features = features + " symbol-lookup"
    if apis.contains("relocation-apply"):
        features = features + " relocation"
    if apis.contains("structured-loader-error") and apis.contains("pe-loader-boundary"):
        features = features + " loader-errors"
    features

pub fn wine_dynload_adapter_gate(apis: text) -> WineDynloadAdapterResult:
    val missing = wine_dynload_adapter_missing_apis(apis)
    val features = wine_dynload_adapter_feature_string(apis)
    if missing.len() > 0:
        return _dynload_result(false, "missing-api-" + missing[0], features)

    val state = wine_dynamic_gate(features)
    if state != "ready":
        return _dynload_result(false, state, features)

    _dynload_result(true, "ready", features)

pub fn wine_dynload_adapter_gate_with_loader_result(apis: text, loader_result: WineNtdllLoaderResult) -> WineDynloadAdapterResult:
    val base = wine_dynload_adapter_gate(apis)
    if not base.ready:
        return base
    if not loader_result.ok:
        return _dynload_result(false, "loader-resolution-" + loader_result.error, base.dynload_features)
    if not loader_result.operations.contains("LdrLoadDll") or
       not loader_result.operations.contains("LdrGetProcedureAddress") or
       not loader_result.operations.contains("LdrUnloadDll"):
        return _dynload_result(false, "loader-resolution-incomplete", base.dynload_features)
    _dynload_result(true, "ready", base.dynload_features + " ntdll-loader-resolution")
