# Cache Set Operations
#
# Purpose: Store values in different cache types
#
# Contains:
# - LRU cache put
# - FIFO cache put
# - LFU cache put
# - TTL cache put
# - Generic cache put

# ============================================================================
# LRU Cache Put
# ============================================================================

fn cache_lru_put(cache, key: text, value):
    """Put value into LRU cache.
    Evicts least recently used entry if at capacity."""
    _ensure_base_arrays(cache)
    val capacity = _cache_i64(cache, 'capacity', 0)
    if capacity <= 0:
        return cache
    val keys = cache['keys']
    val values = cache['values']
    val index = _find_key_index_in(cache, key)

    if index >= 0 and index < values.len():
        # Update existing entry
        cache['keys'] = _remove_at_index(keys, index)
        cache['values'] = _remove_at_index(values, index)
    else:
        # New entry - check capacity
        if keys.len() >= capacity and keys.len() > 0:
            # Evict least recently used (first element)
            cache['keys'] = _remove_at_index(keys, 0)
            cache['values'] = _remove_at_index(values, 0)

    # Add to end (most recently used)
    var new_keys = cache['keys']
    new_keys.push(key)
    cache['keys'] = new_keys

    var new_values = cache['values']
    new_values.push(value)
    cache['values'] = new_values

    # Rebuild key_index after structural change
    _rebuild_key_index(cache)

    cache

# ============================================================================
# FIFO Cache Put
# ============================================================================

fn cache_fifo_put(cache, key: text, value):
    """Put value into FIFO cache.
    Evicts oldest entry if at capacity."""
    _ensure_base_arrays(cache)
    val capacity = _cache_i64(cache, 'capacity', 0)
    if capacity <= 0:
        return cache
    val keys = cache['keys']
    val values = cache['values']
    val index = _find_key_index_in(cache, key)

    if index >= 0 and index < values.len():
        # Update existing entry in place
        var new_values = cache['values']
        new_values[index] = value
        cache['values'] = new_values
    else:
        # New entry - check capacity
        if keys.len() >= capacity and keys.len() > 0:
            # Evict first entry (oldest)
            cache['keys'] = _remove_at_index(keys, 0)
            cache['values'] = _remove_at_index(values, 0)

        # Add to end
        var new_keys = cache['keys']
        new_keys.push(key)
        cache['keys'] = new_keys

        var new_values = cache['values']
        new_values.push(value)
        cache['values'] = new_values

        # Rebuild key_index after structural change
        _rebuild_key_index(cache)

    cache

# ============================================================================
# LFU Cache Put
# ============================================================================

fn cache_lfu_put(cache, key: text, value):
    """Put value into LFU cache.
    Evicts least frequently used entry if at capacity."""
    _ensure_base_arrays(cache)
    _ensure_array(cache, 'frequencies')
    val capacity = _cache_i64(cache, 'capacity', 0)
    if capacity <= 0:
        return cache
    val keys = cache['keys']
    val values = cache['values']
    val frequencies = cache['frequencies']
    val index = _find_key_index_in(cache, key)

    if index >= 0 and index < values.len() and index < frequencies.len():
        # Update existing entry
        var new_values = values
        new_values[index] = value
        cache['values'] = new_values

        # Increment frequency
        var new_frequencies = frequencies
        new_frequencies[index] = frequencies[index] + 1
        cache['frequencies'] = new_frequencies
    else:
        # New entry - check capacity
        if keys.len() >= capacity and frequencies.len() > 0:
            # Find least frequently used entry
            var min_freq = frequencies[0]
            var min_index = 0
            var i = 1
            while i < frequencies.len():
                if frequencies[i] < min_freq:
                    min_freq = frequencies[i]
                    min_index = i
                i = i + 1

            # Evict least frequently used
            cache['keys'] = _remove_at_index(keys, min_index)
            cache['values'] = _remove_at_index(values, min_index)
            cache['frequencies'] = _remove_at_index(frequencies, min_index)

        # Add new entry with frequency 1
        var new_keys = cache['keys']
        new_keys.push(key)
        cache['keys'] = new_keys

        var new_values = cache['values']
        new_values.push(value)
        cache['values'] = new_values

        var new_frequencies = cache['frequencies']
        new_frequencies.push(1)
        cache['frequencies'] = new_frequencies

        # Rebuild key_index after structural change
        _rebuild_key_index(cache)

    cache

# ============================================================================
# TTL Cache Put
# ============================================================================

fn cache_ttl_put(cache, key: text, value):
    """Put value into TTL cache with expiry time.
    Evicts oldest entry if at capacity."""
    _ensure_base_arrays(cache)
    _ensure_array(cache, 'expiry_times')
    val capacity = _cache_i64(cache, 'capacity', 0)
    if capacity <= 0:
        return cache
    val keys = cache['keys']
    val values = cache['values']
    val expiry_times = cache['expiry_times']
    val index = _find_key_index_in(cache, key)
    val now = _get_timestamp()
    val expiry = now + _cache_i64(cache, 'ttl', 0)

    if index >= 0 and index < values.len() and index < expiry_times.len():
        # Update existing entry
        var new_values = values
        new_values[index] = value
        cache['values'] = new_values

        var new_expiry_times = expiry_times
        new_expiry_times[index] = expiry
        cache['expiry_times'] = new_expiry_times
    else:
        # New entry - check capacity
        if keys.len() >= capacity and keys.len() > 0:
            # Evict first entry (oldest)
            cache['keys'] = _remove_at_index(keys, 0)
            cache['values'] = _remove_at_index(values, 0)
            cache['expiry_times'] = _remove_at_index(expiry_times, 0)

        # Add new entry
        var new_keys = cache['keys']
        new_keys.push(key)
        cache['keys'] = new_keys

        var new_values = cache['values']
        new_values.push(value)
        cache['values'] = new_values

        var new_expiry_times = cache['expiry_times']
        new_expiry_times.push(expiry)
        cache['expiry_times'] = new_expiry_times

        # Rebuild key_index after structural change
        _rebuild_key_index(cache)

    cache

# ============================================================================
# Generic Cache Operations
# ============================================================================

fn cache_put(cache, key: text, value):
    """Generic cache put operation. Works with any cache type."""
    val cache_type = if cache.has('type'): cache['type'] else: ''
    if cache_type == 'lru':
        cache_lru_put(cache, key, value)
    elif cache_type == 'fifo':
        cache_fifo_put(cache, key, value)
    elif cache_type == 'lfu':
        cache_lfu_put(cache, key, value)
    elif cache_type == 'ttl':
        cache_ttl_put(cache, key, value)
    else:
        cache

# ============================================================================
# Helper Functions
# ============================================================================

fn _find_key_index_in(cache, key: text) -> i64:
    """Find index of key using the key_index dict. Returns -1 if not found."""
    if not cache.has('key_index'):
        return -1
    val ki = cache['key_index']
    if ki.has(key):
        return ki[key]
    -1

fn _remove_at_index(arr, index: i64):
    """Remove element at index from array. Returns new array."""
    var result = []
    var i = 0
    while i < arr.len():
        if i != index:
            result.push(arr[i])
        i = i + 1
    result

fn _rebuild_key_index(cache):
    """Rebuild the key_index dict from the keys array."""
    var ki = {}
    if not cache.has('keys'):
        cache['key_index'] = ki
        return
    val keys = cache['keys']
    var i = 0
    while i < keys.len():
        ki[keys[i]] = i
        i = i + 1
    cache['key_index'] = ki

fn _cache_i64(cache, key: text, default_value: i64) -> i64:
    if cache.has(key):
        return cache[key]
    default_value

fn _ensure_array(cache, key: text):
    if not cache.has(key):
        cache[key] = []

fn _ensure_base_arrays(cache):
    _ensure_array(cache, 'keys')
    _ensure_array(cache, 'values')

extern fn rt_time_now_unix_micros() -> i64

fn _get_timestamp() -> i64:
    """Get current timestamp in milliseconds."""
    rt_time_now_unix_micros() / 1000
