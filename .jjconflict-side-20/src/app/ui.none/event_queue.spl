# Headless Event Queue
#
# Programmatic event injection queue for testing UI without a display.
# Events are pushed in and popped FIFO for simulated input.
# Note: Used internally by NoneBackend. Not intended for direct cross-module use
# due to bootstrap interpreter limitations with class method dispatch.

use common.ui.widget.{UIEvent}

# =========================================================================
# Event Queue
# =========================================================================

class EventQueue:
    events: [UIEvent]
    head: i32

    static fn new() -> EventQueue:
        return EventQueue(events: [], head: 0)

    me push(event: UIEvent):
        self.events.push(event)

    me push_all(events: [UIEvent]):
        for event in events:
            self.events.push(event)

    me dequeue() -> UIEvent?:
        val event_count = self.events.len()
        if self.head >= event_count:
            self.events = []
            self.head = 0
            return nil
        val event = self.events[self.head]
        self.head = self.head + 1
        if self.head >= event_count:
            self.events = []
            self.head = 0
        elif self.head > 64 and self.head * 2 >= event_count:
            var compacted: [UIEvent] = []
            var i = self.head
            while i < event_count:
                compacted.push(self.events[i])
                i = i + 1
            self.events = compacted
            self.head = 0
        return event

    fn is_empty() -> bool:
        return self.len() == 0

    fn len() -> i32:
        val remaining = self.events.len() - self.head
        if remaining < 0:
            return 0
        return remaining

    me clear():
        self.events = []
        self.head = 0
