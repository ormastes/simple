use std.spec.{describe, it, expect}

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

val FIXTURE_DIR = "/tmp/simple_traceability_log_mode_fixture"

fn _setup_fixture():
    val (_out, _err, _code) = rt_process_run("/bin/sh", [
        "-c",
        "rm -rf " + FIXTURE_DIR + " && mkdir -p " + FIXTURE_DIR
    ])

fn _run_traceability(args: [text]) -> (text, text, i64):
    val joined = args.join(" ")
    rt_process_run("/bin/sh", [
        "-c",
        "REPO=$(pwd); cd " + FIXTURE_DIR + " && SIMPLE_LIB=\"$REPO/src\" \"$REPO/bin/simple\" run \"$REPO/src/app/traceability/main.spl\" " + joined
    ])

describe "traceability log mode CLI options":
    it "shows shared log options in help":
        _setup_fixture()
        val (out, err, code) = _run_traceability(["--help"])
        expect(code).to_equal(0)
        expect(out).to_contain("--log-mode")
        expect(out).to_contain("--progress")

    it "supports log-mode json":
        _setup_fixture()
        val (out, err, code) = _run_traceability(["--log-mode=json", "."])
        expect(code).to_equal(0)
        expect(out).to_contain("\"warnings\"")

    it "supports dot progress":
        _setup_fixture()
        val (out, err, code) = _run_traceability(["--progress=dot", "."])
        expect(code).to_equal(0)
        expect(out).to_contain(".")
        expect(out).to_contain("traceability: clean")

    it "rejects invalid log mode":
        _setup_fixture()
        val (out, err, code) = _run_traceability(["--log-mode=noisy", "."])
        expect(code).to_equal(1)
