use common.ui.parse.sdn.{parse_to_flat, s_strip, s_find, s_len, s_starts, s_split, unwrap_opt, make_full_path, pop_stack, count_indent, s_ends}

extern fn rt_file_read_text(path: text) -> text

fn main():
    val raw = rt_file_read_text("examples/ui/demo.ui.sdn")
    val source = unwrap_opt(raw)
    val lines = s_split(source, "\n")
    var result: Dict<text, text> = {}
    var path_indents: [i64] = []
    var path_keys: [text] = []
    var line_count = 0

    for line in lines:
        line_count = line_count + 1
        val stripped = s_strip(line)
        if stripped == "":
            continue
        if s_starts(stripped, "#"):
            continue

        val indent = count_indent(line)
        val cp = s_find(stripped, ":")
        if cp < 0:
            continue

        val key = s_strip(stripped[0:cp])
        val sl = s_len(stripped)
        var after = ""
        if cp + 1 < sl:
            after = s_strip(stripped[cp + 1:])

        val popped = pop_stack(path_indents, path_keys, indent)
        path_indents = popped.0
        path_keys = popped.1

        val full_path = make_full_path(path_keys, key)

        if after == "" or after == "|":
            path_indents = path_indents + [indent]
            path_keys = path_keys + [key]
            print "L{line_count}: CONTAINER {full_path}"
        else:
            var val_text = after
            val vl = s_len(val_text)
            if vl >= 2:
                if s_starts(val_text, "\""):
                    if s_ends(val_text, "\""):
                        val_text = val_text[1:vl - 1]
            print "L{line_count}: LEAF {full_path} = {val_text}"
            result[full_path] = val_text

    print "Done! Keys: {result.len()}"
