# JIT Hotspot Test: x86_64 (Cranelift)

use std.io

extern fn rt_jit_create() -> i64
extern fn rt_jit_create_for_target(arch: text) -> i64
extern fn rt_jit_backend_name(handle: i64) -> text
extern fn rt_jit_compile_source(handle: i64, source: text) -> text
extern fn rt_jit_call_i64(handle: i64, name: text, arg: i64) -> i64
extern fn rt_jit_has_function(handle: i64, name: text) -> bool
extern fn rt_jit_cleanup(handle: i64) -> i64
extern fn rt_time_now_micros() -> i64

fn main():
    print("=== JIT Hotspot Test: x86_64 (Cranelift) ===")

    val h = rt_jit_create()
    print("Handle: " + h.to_text())
    print("Backend: " + rt_jit_backend_name(h))

    if h < 1:
        print("SKIP: JIT not available")
        return

    # Compile a hot loop function
    val src = "fn hot_sum(n: i64) -> i64:\n    var s: i64 = 0\n    var i: i64 = 0\n    while i < n:\n        s = s + i\n        i = i + 1\n    return s\n"
    val err = rt_jit_compile_source(h, src)
    if err != "":
        print("FAIL: compile error: " + err)
        rt_jit_cleanup(h)
        return

    print("Compiled: " + rt_jit_has_function(h, "hot_sum").to_text())

    # Correctness check
    val result = rt_jit_call_i64(h, "hot_sum", 1000)
    val expected: i64 = 499500
    if result == expected:
        print("PASS: hot_sum(1000) = " + result.to_text())
    else:
        print("FAIL: hot_sum(1000) = " + result.to_text() + " expected " + expected.to_text())

    # Benchmark the JIT-compiled hot path
    val t0 = rt_time_now_micros()
    val calls = 1000
    var i = 0
    while i < calls:
        rt_jit_call_i64(h, "hot_sum", 10000)
        i = i + 1
    val t1 = rt_time_now_micros()
    val avg_us = (t1 - t0) / calls
    print(calls.to_text() + " calls: avg " + avg_us.to_text() + " us/call (work_size=10000)")

    rt_jit_cleanup(h)
    print("DONE")
