# Regression coverage for the no-GC sync immutable compatibility family.

use std.nogc_sync_immut.{Atom, VersionedSnapshot, pfold, nogc_async_immut_version}

describe "nogc_sync_immut facade resolution":
    it "resolves persistent helpers through the no-GC async immutable backing family":
        expect(pfold([1, 2, 3], 0, \acc, x: acc + x)).to_equal(6)
        expect(nogc_async_immut_version()).to_equal("0.1.0")

    it "preserves root coordination type behavior through the no-GC sync facade":
        var atom = Atom.new(21)
        atom.reset(22)
        expect(atom.deref()).to_equal(22)

        var snapshot = VersionedSnapshot.new("base")
        snapshot.update("head")
        expect(snapshot.current()).to_equal("head")
