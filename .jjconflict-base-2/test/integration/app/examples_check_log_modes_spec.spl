use std.spec.{describe, it, expect}

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

val FIXTURE_DIR = "/tmp/simple_examples_check_log_mode_fixture"

fn _setup_fixture():
    val (_out, _err, _code) = rt_process_run("/bin/sh", [
        "-c",
        "rm -rf " + FIXTURE_DIR + " && mkdir -p " + FIXTURE_DIR
    ])

fn _run_examples_check(args: [text]) -> (text, text, i64):
    val joined = args.join(" ")
    rt_process_run("/bin/sh", [
        "-c",
        "REPO=$(pwd); cd " + FIXTURE_DIR + " && SIMPLE_LIB=\"$REPO/src\" \"$REPO/bin/simple\" run \"$REPO/src/app/examples_check/main.spl\" " + joined
    ])

describe "examples-check log mode CLI options":
    it "shows shared log options in help":
        _setup_fixture()
        val (out, err, code) = _run_examples_check(["--help"])
        expect(code).to_equal(0)
        expect(out).to_contain("--log-mode")
        expect(out).to_contain("--progress")

    it "supports log-mode json for empty directories":
        _setup_fixture()
        val (out, err, code) = _run_examples_check(["--log-mode=json", "examples"])
        expect(code).to_equal(1)
        expect(out).to_contain("\"command\":\"examples-check\"")
        expect(out).to_contain("\"status\":\"error\"")
        expect(out).to_contain("\"total\":0")

    it "supports dot progress for empty directories":
        _setup_fixture()
        val (out, err, code) = _run_examples_check(["--progress=dot", "examples"])
        expect(code).to_equal(1)
        expect(out).to_contain(".")
        expect(out).to_contain("No .spl files found under examples")

    it "rejects invalid log mode":
        _setup_fixture()
        val (out, err, code) = _run_examples_check(["--log-mode=noisy", "examples"])
        expect(code).to_equal(1)
