use std.spec.{describe, it, assert_equal}
use std.common.cbor.decode.{cbor_item_size, cbor_validate, cbor_validate_sequence}

describe "CBOR item size payload byte guard":
    it "rejects invalid byte and text string payload bytes":
        val byte_result = cbor_item_size([0x41, 300], 0)
        val text_result = cbor_item_size([0x61, -1], 0)
        assert_equal(byte_result, 0)
        assert_equal(text_result, 0)
        assert_equal(cbor_validate([0x41, 300]), false)
        assert_equal(cbor_validate_sequence([0x61, -1]), false)

    it "rejects invalid simple and float payload bytes":
        val simple_result = cbor_item_size([0xF8, 300], 0)
        val float16_result = cbor_item_size([0xF9, -1, 0], 0)
        val float32_result = cbor_item_size([0xFA, 0, 0, 300, 0], 0)
        assert_equal(simple_result, 0)
        assert_equal(float16_result, 0)
        assert_equal(float32_result, 0)

    it "keeps valid payload sizes working":
        assert_equal(cbor_item_size([0x41, 255], 0), 2)
        assert_equal(cbor_item_size([0x61, 65], 0), 2)
        assert_equal(cbor_item_size([0xF8, 16], 0), 2)
        assert_equal(cbor_item_size([0xF9, 0, 0], 0), 3)
