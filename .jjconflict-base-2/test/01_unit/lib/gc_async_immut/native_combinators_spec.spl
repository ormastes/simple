# Native-safe behavior coverage for the GC async immutable facade.

use std.gc_async_immut.combinators.{pmap, pfilter}

describe "gc_async_immut native combinators":
    it "runs pure combinators through the facade chain":
        expect(pmap([1, 2, 3], _1 * 3)).to_equal([3, 6, 9])
        expect(pfilter([1, 2, 3, 4], \x: x % 2 == 0)).to_equal([2, 4])
