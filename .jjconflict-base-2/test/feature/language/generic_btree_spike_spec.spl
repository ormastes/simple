"""Generic struct spike test — verifies Simple language support for generic structs.

Tests features needed to extract shared BTree/WAL/checkpoint-ring data structures
into std.storage.shared. Preserved parser-failure fixture; see doc/08_tracking/bug/generic_btree_spike_parse_dot.md
"""

use std.spec

# ---------------------------------------------------------------------------
# 1. Generic struct with typed fields
# ---------------------------------------------------------------------------

struct TestNode<K>:
    keys: [K]
    count: i64

    static fn new() -> TestNode<K>:
        TestNode(keys: [], count: 0)

    fn insert(self, key: K) -> TestNode<K>:
        var new_keys = self.keys
        new_keys.append(key)
        TestNode(keys: new_keys, count: self.count + 1)

# ---------------------------------------------------------------------------
# 2. Two-parameter generic struct (BTree-like)
# ---------------------------------------------------------------------------

struct BTreeNode<K, V>:
    node_key: K
    node_val: V

    static fn new(k: K, v: V) -> BTreeNode<K, V>:
        BTreeNode(node_key: k, node_val: v)

# ---------------------------------------------------------------------------
# 3. Generic struct with where clause
# ---------------------------------------------------------------------------

struct SortedNode<K> where K: Eq:
    keys: [K]

    static fn new() -> SortedNode<K>:
        SortedNode(keys: [])

# ---------------------------------------------------------------------------
# 4. Type aliases
# ---------------------------------------------------------------------------

type IntNode = TestNode<i64>
type TextNode = TestNode<text>
type IntTextPair = BTreeNode<i64, text>

# ---------------------------------------------------------------------------
# Specs
# ---------------------------------------------------------------------------

describe "Simple generics — TestNode<K> struct":
    it "can create generic struct with i64 via static new":
        val node = TestNode<i64>.new()
        expect(node.count).to_equal(0)
        expect(node.keys.len()).to_equal(0)

    it "can insert a key into a generic struct":
        val node = TestNode<i64>.new()
        val node2 = node.insert(42)
        expect(node2.count).to_equal(1)
        expect(node2.keys.len()).to_equal(1)

    it "can create generic struct with text key type":
        val node = TestNode<text>.new()
        val node2 = node.insert("hello")
        expect(node2.count).to_equal(1)

describe "Simple generics — type aliases":
    it "type alias IntNode forwards static constructor":
        val node = IntNode.new()
        expect(node.count).to_equal(0)

    it "type alias TextNode forwards static constructor":
        val node = TextNode.new()
        expect(node.count).to_equal(0)

    # FINDING: two-param generic type alias static constructor call fails in interpreter
    # with "semantic: unknown argument '<field>'" — single-param aliases (IntNode,
    # TextNode) work fine. Direct BTreeNode<i64, text>.new(...) also works.
    # This is a known interpreter limitation for multi-param generic type aliases.
    it "type alias two-param generic static new has interpreter limitation":
        # Direct construction via concrete type works:
        val pair = BTreeNode<i64, text>.new(1, "one")
        expect(pair.node_key).to_equal(1)
        expect(pair.node_val).to_equal("one")

describe "Simple generics — two-parameter BTreeNode<K, V>":
    it "can create BTreeNode<i64, text> directly":
        val node = BTreeNode<i64, text>.new(10, "ten")
        expect(node.node_key).to_equal(10)
        expect(node.node_val).to_equal("ten")

describe "Simple generics — where clause SortedNode<K>":
    it "can create SortedNode<i64> with where clause":
        val node = SortedNode<i64>.new()
        expect(node.keys.len()).to_equal(0)
