# Simple-native release tooling.

use std.cli.cli_util.{get_cli_args}
use std.cli.log_modes.{parse_log_options, log_options_help, render_progress}
use std.nogc_sync_mut.io.file_ops.{file_exists}
use std.log.{error}

use app.release.github.{
    create_github_release, default_repo, default_token, read_body_file
}


fn print_help():
    print "Usage: simple release <command> [options]"
    print ""
    print "Commands:"
    print "  plan                 Show the migration plan to remove shell/Node release paths"
    print "  github               Create a GitHub release and upload assets"
    print ""
    print "GitHub release options:"
    print "  --repo=OWNER/REPO    GitHub repository (default: GITHUB_REPOSITORY)"
    print "  --token=TOKEN        GitHub token (default: GITHUB_TOKEN)"
    print "  --tag=vX.Y.Z         Release tag (required)"
    print "  --name=NAME          Release title (default: tag)"
    print "  --body-file=PATH     Release notes file"
    print "  --target=SHA         Target commitish"
    print "  --files-dir=DIR      Directory of assets to upload"
    print "  --draft              Create draft release"
    print "  --prerelease         Mark as prerelease"
    print "  --json               Output as JSON"
    for line in log_options_help():
        print "  {line}"

fn _is_log_option(arg: text) -> bool:
    arg == "--human" or arg == "--llm" or arg == "--json" or
        arg == "--tui" or arg == "--stdout" or arg == "--quiet" or
        arg == "--verbose" or arg == "--dots" or arg == "--count" or
        arg == "--no-progress" or arg == "--log-mode" or arg == "--surface" or
        arg == "--progress" or arg.starts_with("--log-mode=") or
        arg.starts_with("--surface=") or arg.starts_with("--progress=")

fn _json_escape(value: text) -> text:
    val slashes = value.replace("\\", "\\\\")
    val quotes = slashes.replace("\"", "\\\"")
    quotes.replace("\n", "\\n")

fn print_plan():
    print "Release/Deploy Migration Plan"
    print ""
    print "1. Release publication"
    print "   Replace GitHub Action wrappers and gh-style release glue with `simple release github`."
    print "   Status: implemented in this change."
    print ""
    print "2. Package creation"
    print "   Route `.spk` generation through Simple package/runtime APIs instead of `tar` and `sha256sum`."
    print "   Status: partially implemented in this change."
    print ""
    print "3. Installer/download path"
    print "   Add `simple release install` to download the correct bootstrap package and install it without `install.shs`."
    print "   Status: pending."

fn print_plan_json():
    print "{\"command\":\"release plan\",\"status\":\"ok\",\"steps\":5,\"implemented\":1,\"partial\":1,\"pending\":3}"
    print ""
    print "4. Bootstrap entrypoint"
    print "   Replace shell bootstrap wrappers with a Simple-native orchestrator where feasible."
    print "   Constraint: Rust seed compiler still exists until the bootstrap cycle is fully closed."
    print ""
    print "5. Packaging backends"
    print "   Remove shell-heavy staging helpers in favor of package/runtime APIs for archive, chmod, symlink, and copy."
    print "   Status: pending."

fn arg_value(args: [text], key: text) -> text:
    val prefix = "--{key}="
    for arg in args:
        if arg.starts_with(prefix):
            return arg.slice(prefix.len(), arg.len())
    ""

fn has_flag(args: [text], key: text) -> bool:
    val flag = "--{key}"
    for arg in args:
        if arg == flag:
            return true
    false

fn run_github(args: [text], as_json: bool) -> i64:
    var repo = arg_value(args, "repo")
    if repo == "":
        repo = default_repo()

    var token = arg_value(args, "token")
    if token == "":
        token = default_token()

    val tag = arg_value(args, "tag")
    var name = arg_value(args, "name")
    val body_file = arg_value(args, "body-file")
    val target = arg_value(args, "target")
    val files_dir = arg_value(args, "files-dir")
    val draft = has_flag(args, "draft")
    val prerelease = has_flag(args, "prerelease")

    if repo == "":
        error("release", "missing --repo and GITHUB_REPOSITORY is not set")
        return 1
    if token == "":
        error("release", "missing --token and GITHUB_TOKEN is not set")
        return 1
    if tag == "":
        error("release", "missing required --tag")
        return 1
    if name == "":
        name = tag
    if body_file != "" and not file_exists(body_file):
        error("release", "body file not found: {body_file}")
        return 1

    val body_result = read_body_file(body_file)
    match body_result:
        Err(err_msg):
            error("release", err_msg)
            return 1
        Ok(body):
            print "Creating GitHub release for {repo} ({tag})"
            if files_dir != "":
                print "Uploading assets from {files_dir}"

            val release_result = create_github_release(
                repo, token, tag, name, body, target, draft, prerelease, files_dir
            )
            match release_result:
                Ok(url):
                    if as_json:
                        val repo_json = _json_escape(repo)
                        val tag_json = _json_escape(tag)
                        val url_json = _json_escape(url)
                        print "{\"command\":\"release github\",\"status\":\"ok\",\"repo\":\"{repo_json}\",\"tag\":\"{tag_json}\",\"url\":\"{url_json}\"}"
                    else:
                        print "Release published: {url}"
                    return 0
                Err(err_msg):
                    error("release", err_msg)
                    return 1

fn main() -> i64:
    val args = get_cli_args()
    val log_opts = parse_log_options(args)
    if not log_opts.valid:
        error("release", log_opts.error)
        return 1
    if args.len() == 0:
        print_help()
        return 0

    val subcommand = if args[0] == "release" and args.len() > 1: args[1] else: args[0]
    val sub_args = if args[0] == "release" and args.len() > 1: args[2:] else: args[1:]
    var as_json = log_opts.log_mode == "json"
    var ai = 0
    while ai < sub_args.len():
        val arg = sub_args[ai]
        if arg == "--json" or arg == "--log-mode=json":
            as_json = true
        elif arg == "--log-mode" or arg == "--surface" or arg == "--progress":
            ai = ai + 1
        elif _is_log_option(arg):
            pass
        ai = ai + 1

    if log_opts.progress != "summary":
        val progress_line = render_progress(log_opts.progress, 1, 1, "release {subcommand}")
        if progress_line != "":
            print progress_line

    match subcommand:
        case "plan":
            if as_json:
                print_plan_json()
            else:
                print_plan()
            return 0
        case "github":
            return run_github(sub_args, as_json)
        case "-h" | "--help" | "help":
            print_help()
            return 0
        case _:
            error("release", "unknown subcommand: {subcommand}")
            print_help()
            return 1
