# Unit: Gal
# Kind: Acceleration
# Symbol: gal
# Canonical scale: 0.01 m/s2

class Gal:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Gal) -> Gal: Gal(value: self.value + other.value)
    fn sub(other: Gal) -> Gal: Gal(value: self.value - other.value)

    static fn kind() -> text: "Acceleration"
    static fn symbol() -> text: "gal"
    static fn scale_to_base() -> f64: 0.01
    static fn base_unit() -> text: "m/s2"
    static fn zero() -> Gal: Gal(value: 0.0)

export Gal
