# Unit: Angstrom
# Kind: Length
# Symbol: angstrom
# Canonical scale: 1e-10 m

class Angstrom:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Angstrom) -> Angstrom: Angstrom(value: self.value + other.value)
    fn sub(other: Angstrom) -> Angstrom: Angstrom(value: self.value - other.value)

    static fn kind() -> text: "Length"
    static fn symbol() -> text: "angstrom"
    static fn scale_to_base() -> f64: 1e-10
    static fn base_unit() -> text: "m"
    static fn zero() -> Angstrom: Angstrom(value: 0.0)

export Angstrom
