# Part 1 of src/compiler/70.backend/linker/elf_writer.spl
use compiler.backend.linker.elf_writer.*
# ELF64 ET_REL Writer — Pure-Simple ELF64 relocatable object writer.
#
# Produces well-formed ELF64 ET_REL (relocatable) object files from
# caller-supplied sections, symbols, and relocations.
# Output bytes round-trip through elf_parse_object.
# No file I/O — returns raw [i64] byte array.

use compiler.backend.linker.elf_inspect.{ELF64_HEADER_SIZE, ELF64_SHDR_SIZE}
use compiler.backend.linker.elf_parser.{ELF64_SYM_SIZE, ELF64_RELA_SIZE, SHT_RELA, SHT_NOBITS, STB_LOCAL}
use std.string_core.{char_code}

# ============================================================================
# Constants
# ============================================================================

val ELF_W_MAGIC_0: i64 = 0x7f
val ELF_W_MAGIC_1: i64 = 0x45  # 'E'
val ELF_W_MAGIC_2: i64 = 0x4c  # 'L'
val ELF_W_MAGIC_3: i64 = 0x46  # 'F'

val ELFCLASS64: i64 = 2
val ELFDATA2LSB: i64 = 1
val EV_CURRENT: i64 = 1

val ET_REL_VAL: i64 = 1

val SHT_PROGBITS_VAL: i64 = 1
val SHT_SYMTAB_VAL: i64 = 2
val SHT_STRTAB_VAL: i64 = 3

# ============================================================================
# Input Structs
# ============================================================================

struct ElfWriterSection:
    """A section to write into the ELF object."""
    name: text         # section name (e.g. ".text", ".data")
    sh_type: i64       # SHT_PROGBITS=1, SHT_NOBITS=8, etc.
    sh_flags: i64      # section flags (SHF_ALLOC=2, SHF_WRITE=1, SHF_EXECINSTR=4)
    data: [i64]        # raw section bytes (empty for SHT_NOBITS)
    sh_link: i64       # section index link (0 for most sections)
    sh_info: i64       # extra info (0 for most sections)

struct ElfWriterSymbol:
    """A symbol to write into the symbol table."""
    name: text         # symbol name (empty for null symbol)
    st_info: i64       # (binding << 4) | type
    st_other: i64      # visibility
    st_shndx: i64      # section index (0=SHN_UNDEF)
    st_value: i64      # symbol value/address
    st_size: i64       # symbol size

struct ElfWriterReloc:
    """A relocation entry to emit."""
    r_offset: i64      # offset within target section
    r_info: i64        # (sym_idx << 32) | reloc_type — sym_idx is caller index
    r_addend: i64      # addend
    section_name: text # name of section this reloc applies to (e.g. ".text")

struct ElfWriterConfig:
    """Configuration for the ELF writer."""
    e_machine: i64     # EM_X86_64=62, EM_AARCH64=183, EM_RISCV=243

# ============================================================================
# Layout helpers (internal)
# ============================================================================

struct ElfLayoutSection:
    """Internal layout record for each section in the output."""
    name: text
    sh_name_idx: i64   # index into shstrtab
    sh_type: i64
    sh_flags: i64
    sh_offset: i64     # file offset of section data
    sh_size: i64       # section data size in bytes
    sh_link: i64
    sh_info: i64
    sh_addralign: i64
    sh_entsize: i64
    data: [i64]        # raw bytes to emit (empty for NOBITS)

# ============================================================================
# Byte Writer Helpers — little-endian push into [i64]
# ============================================================================

fn write_u8(buf: [i64], v: i64) -> [i64]:
    """Push one byte (masked to 8 bits)."""
    buf.push(v & 0xff)

fn write_u16_le(buf: [i64], v: i64) -> [i64]:
    """Push 16-bit little-endian value as 2 bytes."""
    var b = buf
    b = b.push(v & 0xff)
    b = b.push((v >> 8) & 0xff)
    b

fn write_u32_le(buf: [i64], v: i64) -> [i64]:
    """Push 32-bit little-endian value as 4 bytes."""
    var b = buf
    b = b.push(v & 0xff)
    b = b.push((v >> 8) & 0xff)
    b = b.push((v >> 16) & 0xff)
    b = b.push((v >> 24) & 0xff)
    b

fn write_u64_le(buf: [i64], v: i64) -> [i64]:
    """Push 64-bit little-endian value as 8 bytes."""
    var b = buf
    b = b.push(v & 0xff)
    b = b.push((v >> 8) & 0xff)
    b = b.push((v >> 16) & 0xff)
    b = b.push((v >> 24) & 0xff)
    b = b.push((v >> 32) & 0xff)
    b = b.push((v >> 40) & 0xff)
    b = b.push((v >> 48) & 0xff)
    b = b.push((v >> 56) & 0xff)
    b

fn write_zeros(buf: [i64], count: i64) -> [i64]:
    """Push count zero bytes."""
    var b = buf
    var i: i64 = 0
    while i < count:
        b = b.push(0)
        i = i + 1
    b

fn write_bytes(buf: [i64], data: [i64]) -> [i64]:
    """Append all bytes from data array."""
    var b = buf
    var i: i64 = 0
    while i < data.len():
        b = b.push(data[i] & 0xff)
        i = i + 1
    b

# ============================================================================
# String Table Builder
# ============================================================================

struct StringTableBuilder:
    """Builds a NUL-terminated string table (starts with NUL byte at index 0)."""
    data: [i64]        # accumulated bytes

fn strtab_new() -> StringTableBuilder:
    """Create a new string table with leading NUL byte."""
    StringTableBuilder(data: [0])

fn strtab_add(builder: StringTableBuilder, s: text) -> StringTableBuilder:
    """Add a string to the table, returning updated builder.

    Empty strings map to index 0 (the leading NUL).
    """
    if s == "":
        return builder

    var data = builder.data
    var i: i64 = 0
    while i < s.len():
        val c = s[i]
        val code = char_code(c)
        data = data.push(code & 0xff)
        i = i + 1
    # NUL terminator
    data = data.push(0)
    StringTableBuilder(data: data)

fn strtab_find(builder: StringTableBuilder, s: text) -> i64:
    """Find the byte index of a string in the table. Returns 0 if not found (empty string)."""
    if s == "":
        return 0

    val slen = s.len()
    var pos: i64 = 1  # skip leading NUL
    while pos < builder.data.len():
        # Check if string at pos matches s
        var match = true
        if pos + slen >= builder.data.len():
            match = false
        else:
            var j: i64 = 0
            while j < slen:
                val c = s[j]
                val code = char_code(c)
                if builder.data[pos + j] != (code & 0xff):
                    match = false
                    j = slen  # break
                else:
                    j = j + 1
            # Verify NUL terminator follows
            if match and (pos + slen < builder.data.len()):
                if builder.data[pos + slen] != 0:
                    match = false

        if match:
            return pos

        # Advance to next NUL-terminated string
        while pos < builder.data.len() and builder.data[pos] != 0:
            pos = pos + 1
        pos = pos + 1  # skip NUL

    0

# ============================================================================
# Alignment helper
# ============================================================================

fn align_up(value: i64, alignment: i64) -> i64:
    """Round value up to next multiple of alignment."""
    if alignment <= 1:
        return value
    val remainder = value % alignment
    if remainder == 0:
        return value
    value + (alignment - remainder)

# ============================================================================
# ELF Header Emission
# ============================================================================

# reason: many positional ELF header fields at fixed offsets
fn emit_elf_header(buf: [i64], e_machine: i64, e_shoff: i64, e_shnum: i64, e_shstrndx: i64) -> [i64]:
    """Emit the 64-byte ELF64 header for ET_REL."""
    var b = buf

    # e_ident[0..3]: ELF magic
    b = b.push(ELF_W_MAGIC_0)
    b = b.push(ELF_W_MAGIC_1)
    b = b.push(ELF_W_MAGIC_2)
    b = b.push(ELF_W_MAGIC_3)

    # e_ident[4]: EI_CLASS = ELFCLASS64
    b = b.push(ELFCLASS64)

    # e_ident[5]: EI_DATA = ELFDATA2LSB (little-endian)
    b = b.push(ELFDATA2LSB)

    # e_ident[6]: EI_VERSION = EV_CURRENT
    b = b.push(EV_CURRENT)

    # e_ident[7]: EI_OSABI = ELFOSABI_NONE
    b = b.push(0)

    # e_ident[8..15]: EI_ABIVERSION + padding (8 zero bytes)
    b = write_zeros(b, 8)

    # offset 16: e_type = ET_REL (1)
    b = write_u16_le(b, ET_REL_VAL)

    # offset 18: e_machine
    b = write_u16_le(b, e_machine)

    # offset 20: e_version = EV_CURRENT
    b = write_u32_le(b, EV_CURRENT)

    # offset 24: e_entry = 0 (no entry point for ET_REL)
    b = write_u64_le(b, 0)

    # offset 32: e_phoff = 0 (no program headers for ET_REL)
    b = write_u64_le(b, 0)

    # offset 40: e_shoff (section header table offset)
    b = write_u64_le(b, e_shoff)

    # offset 48: e_flags = 0
    b = write_u32_le(b, 0)

    # offset 52: e_ehsize = 64
    b = write_u16_le(b, ELF64_HEADER_SIZE)

    # offset 54: e_phentsize = 0 (no program headers)
    b = write_u16_le(b, 0)

    # offset 56: e_phnum = 0
    b = write_u16_le(b, 0)

    # offset 58: e_shentsize = 64
    b = write_u16_le(b, ELF64_SHDR_SIZE)

    # offset 60: e_shnum
    b = write_u16_le(b, e_shnum)

    # offset 62: e_shstrndx
    b = write_u16_le(b, e_shstrndx)

    b

# ============================================================================
# Section Header Emission
# ============================================================================

fn emit_section_header(buf: [i64], layout: ElfLayoutSection) -> [i64]:
    """Emit a single 64-byte ELF64 section header.

    ELF64 Shdr layout:
      +0  sh_name      (u32)
      +4  sh_type      (u32)
      +8  sh_flags     (u64)
      +16 sh_addr      (u64) — virtual address, =0 for ET_REL
      +24 sh_offset    (u64) — file offset of section data
      +32 sh_size      (u64)
      +40 sh_link      (u32)
      +44 sh_info      (u32)
      +48 sh_addralign (u64)
      +56 sh_entsize   (u64)
    """
    var b = buf

    # +0: sh_name (index into shstrtab)
    b = write_u32_le(b, layout.sh_name_idx)

    # +4: sh_type
    b = write_u32_le(b, layout.sh_type)

    # +8: sh_flags
    b = write_u64_le(b, layout.sh_flags)

    # +16: sh_addr = 0 for ET_REL
    b = write_u64_le(b, 0)

    # +24: sh_offset (file offset — this is what elf_parser reads into ElfSectionHeader.sh_addr)
    b = write_u64_le(b, layout.sh_offset)

    # +32: sh_size
    b = write_u64_le(b, layout.sh_size)

    # +40: sh_link
    b = write_u32_le(b, layout.sh_link)

    # +44: sh_info
    b = write_u32_le(b, layout.sh_info)

    # +48: sh_addralign
    b = write_u64_le(b, layout.sh_addralign)

    # +56: sh_entsize
    b = write_u64_le(b, layout.sh_entsize)

    b

# ============================================================================
# Symbol Table Emission
# ============================================================================

fn emit_symbol(buf: [i64], st_name: i64, st_info: i64, st_other: i64, st_shndx: i64, st_value: i64, st_size: i64) -> [i64]:
    """Emit a single 24-byte ELF64 symbol table entry.

    ELF64 Sym layout:
      +0  st_name  (u32)
      +4  st_info  (u8)
      +5  st_other (u8)
      +6  st_shndx (u16)
      +8  st_value (u64)
      +16 st_size  (u64)
    """
    var b = buf
    b = write_u32_le(b, st_name)
    b = write_u8(b, st_info)
    b = write_u8(b, st_other)
    b = write_u16_le(b, st_shndx)
    b = write_u64_le(b, st_value)
    b = write_u64_le(b, st_size)
    b

# ============================================================================
# Relocation Emission
# ============================================================================

fn emit_relocation(buf: [i64], r_offset: i64, r_info: i64, r_addend: i64) -> [i64]:
    """Emit a single 24-byte ELF64 RELA relocation entry.

    ELF64 Rela layout:
      +0  r_offset (u64)
      +8  r_info   (u64)
      +16 r_addend (u64)
    """
    var b = buf
    b = write_u64_le(b, r_offset)
    b = write_u64_le(b, r_info)
    b = write_u64_le(b, r_addend)
    b

# ============================================================================
# Symbol sorting — locals before globals
# ============================================================================

struct IndexedSymbol:
    """Symbol with its original caller index for relocation remapping."""
    sym: ElfWriterSymbol
    original_index: i64

fn sort_symbols_locals_first(symbols: [ElfWriterSymbol]) -> [IndexedSymbol]:
    """Sort symbols so STB_LOCAL comes before STB_GLOBAL/STB_WEAK.

    Returns IndexedSymbol array preserving original caller indices.
    The null symbol (index 0) is prepended by the caller, not here.
    """
    var locals: [IndexedSymbol] = []
    var globals: [IndexedSymbol] = []

    var i: i64 = 0
    while i < symbols.len():
        val sym = symbols[i]
        val binding = (sym.st_info >> 4) & 0xf
        val indexed = IndexedSymbol(sym: sym, original_index: i)
        if binding == STB_LOCAL:
            locals = locals.push(indexed)
        else:
            globals = globals.push(indexed)
        i = i + 1

    # Concatenate: locals first, then globals
    var result: [IndexedSymbol] = []
    var j: i64 = 0
    while j < locals.len():
        result = result.push(locals[j])
        j = j + 1
    var k: i64 = 0
    while k < globals.len():
        result = result.push(globals[k])
        k = k + 1

    result

fn build_sym_remap(sorted: [IndexedSymbol]) -> [i64]:
    """Build a remapping table: remap[caller_index] = final_index (1-based, after null sym).

    Caller symbols are at indices 0..N-1. In the output symtab, index 0 is the
    null symbol, so caller symbol at sorted position P gets final index P+1.
    """
    # Find max caller index to size the remap array
    var max_idx: i64 = 0
    var i: i64 = 0
    while i < sorted.len():
        if sorted[i].original_index > max_idx:
            max_idx = sorted[i].original_index
        i = i + 1

    # Initialize remap array with zeros (identity fallback)
    var remap: [i64] = []
    var j: i64 = 0
    while j <= max_idx:
        remap = remap.push(0)
        j = j + 1

    # Fill: sorted position P -> final index P + 1 (null sym at 0)
    var k: i64 = 0
    while k < sorted.len():
        val orig = sorted[k].original_index
        # Use loop-and-push to set remap[orig] = k + 1
        var new_remap: [i64] = []
        var m: i64 = 0
        while m < remap.len():
            if m == orig:
                new_remap = new_remap.push(k + 1)
            else:
                new_remap = new_remap.push(remap[m])
            m = m + 1
        remap = new_remap
        k = k + 1

    remap

fn remap_reloc_info(r_info: i64, remap: [i64]) -> i64:
    """Remap the symbol index in r_info using the remap table.

    r_info = (sym_idx << 32) | reloc_type
    """
    val sym_idx = (r_info >> 32) & 0xffffffff
    val reloc_type = r_info & 0xffffffff
    var final_idx = sym_idx
    if sym_idx >= 0 and sym_idx < remap.len():
        final_idx = remap[sym_idx]
    (final_idx << 32) | reloc_type

# ============================================================================
# Section name collection for rela sections
# ============================================================================

fn collect_rela_section_names(relocs: [ElfWriterReloc]) -> [text]:
    """Collect unique section names that have relocations, preserving first-seen order."""
    var names: [text] = []
    var i: i64 = 0
    while i < relocs.len():
        val name = relocs[i].section_name
        # Check if already in names
        var found = false
        var j: i64 = 0
        while j < names.len():
            if names[j] == name:
                found = true
                j = names.len()  # break
            j = j + 1
        if not found:
            names = names.push(name)
        i = i + 1
    names

fn find_section_index_by_name(sections: [ElfWriterSection], name: text) -> i64:
    """Find the index of a user section by name. Returns -1 if not found.

    The returned index is in the user-sections array (0-based).
    Final section table index = returned + 1 (after null section).
    """
    var i: i64 = 0
    while i < sections.len():
        if sections[i].name == name:
            return i
        i = i + 1
    -1

# ============================================================================
# Top-Level Writer
# ============================================================================
