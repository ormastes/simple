# RemovableManager — tracks removable VirtIO-BLK mounts.
#
# MDSOC: feature dimension, services layer
# Manages mount/unmount of secondary VirtIO-BLK devices as FAT32 volumes.
# Uses vfs_mount_removable/vfs_unmount_removable from vfs_init for all
# actual VFS operations; this layer tracks state for fast is_mounted queries.

use os.services.vfs.vfs_init.{vfs_mount_removable, vfs_unmount_removable}
extern fn serial_println(msg: text)

class RemovableMountEntry:
    device_index: u64
    mount_path: text
    volume_label: text

class RemovableManager:
    mounted_devices: [RemovableMountEntry]

impl RemovableManager:
    static fn new() -> RemovableManager:
        RemovableManager(mounted_devices: [])

    me mount_device(device_index: u64, mount_path: text) -> bool:
        if self.is_mounted(mount_path):
            serial_println("[removable-mgr] already mounted path={mount_path}")
            return false
        val ok = vfs_mount_removable(device_index, mount_path)
        if not ok:
            return false
        val entry = RemovableMountEntry(
            device_index: device_index,
            mount_path: mount_path,
            volume_label: ""
        )
        self.mounted_devices = self.mounted_devices.push(entry)
        true

    me unmount_device(mount_path: text) -> bool:
        if not self.is_mounted(mount_path):
            serial_println("[removable-mgr] not mounted path={mount_path}")
            return false
        val ok = vfs_unmount_removable(mount_path)
        if not ok:
            return false
        var kept: [RemovableMountEntry] = []
        var i: i32 = 0
        while i < self.mounted_devices.len():
            val entry = self.mounted_devices[i]
            if entry.mount_path != mount_path:
                kept = kept.push(entry)
            i = i + 1
        self.mounted_devices = kept
        true

    fn list_mounted() -> [RemovableMountEntry]:
        self.mounted_devices

    fn is_mounted(mount_path: text) -> bool:
        var i: i32 = 0
        while i < self.mounted_devices.len():
            if self.mounted_devices[i].mount_path == mount_path:
                return true
            i = i + 1
        false
