## Audit tool for auto-generated stub symbols in a compiled binary.
## Reads the binary with `nm`, filters symbols whose name contains the
## substring "auto_stub" (matches the convergence check in
## bootstrap_cross.spl ~line 581 that uses `grep auto_stub`), buckets
## each symbol by a known prefix, and emits an SDN manifest.
##
## Usage:
##   bin/simple run src/os/port/audit_stubs.spl -- --binary <path>
##   bin/simple run src/os/port/audit_stubs.spl -- --binary <path> --suggest-exclusions
##   bin/simple run src/os/port/audit_stubs.spl -- --help

use std.fs
use std.process
use std.text
use std.cli

val KNOWN_BUCKETS: [text] = [
    "gpu", "cuda", "vulkan", "opencl", "gfx",
    "tls", "ssl", "net", "http",
    "sqlite", "db",
    "torch", "ml",
    "audio", "video",
    "crypto",
]

val OTHER_BUCKET = "other"

val DEFAULT_MANIFEST_PATH = "build/os/stubs_manifest.sdn"

class AuditResult:
    binary: text
    total: i64
    bucket_names: List<text>
    bucket_symbols: Map<text, List<text>>
    symbols: List<text>

fn usage():
    print "Usage: bin/simple run src/os/port/audit_stubs.spl -- --binary <path> [options]"
    print ""
    print "Options:"
    print "  --binary <path>          Binary to inspect with nm (required)"
    print "  --suggest-exclusions     Print src/lib/* subtrees that dominate each bucket"
    print "  --output <path>          Manifest output (default: build/os/stubs_manifest.sdn)"
    print "  --help                   Show this help"

fn parse_args(args: List<text>) -> (text, bool, text):
    var binary = ""
    var suggest = false
    var output = DEFAULT_MANIFEST_PATH

    var i = 0
    while i < args.len():
        val arg = args[i]
        if arg == "--help" or arg == "-h":
            usage()
            process.exit(0)
        else if arg == "--binary":
            i = i + 1
            binary = args[i]
        else if arg == "--suggest-exclusions":
            suggest = true
        else if arg == "--output":
            i = i + 1
            output = args[i]
        i = i + 1

    if binary == "":
        print "error: --binary <path> is required"
        usage()
        process.exit(2)

    (binary, suggest, output)

fn run_nm(binary: text) -> List<text>:
    """Invoke nm on binary and return the raw output lines."""
    if not fs.exists(binary):
        print "error: binary not found: {binary}"
        process.exit(1)

    val result = process.run("nm", [binary])
    if result.exit_code != 0:
        print "error: nm failed on {binary}:"
        print result.stderr
        process.exit(1)

    var out: List<text> = []
    for line in result.stdout.split("\n"):
        val trimmed = line.trim()
        if trimmed != "":
            out = out + [trimmed]
    out

fn extract_symbol_name(line: text) -> text:
    """Return the symbol name from an nm line if its type letter is
    T/t/W/w (text symbols); empty otherwise. The auto_stub substring
    filter is applied by the caller to match bootstrap_cross.spl."""
    val parts = line.split(" ")
    var tokens: List<text> = []
    for p in parts:
        if p != "":
            tokens = tokens + [p]
    if tokens.len() < 2:
        return ""
    val name = tokens[tokens.len() - 1]
    val type_letter = tokens[tokens.len() - 2]
    if type_letter == "T" or type_letter == "t" or type_letter == "W" or type_letter == "w":
        return name
    ""

fn filter_stub_symbols(lines: List<text>) -> List<text>:
    var syms: List<text> = []
    for line in lines:
        val name = extract_symbol_name(line)
        if name != "" and name.contains("auto_stub"):
            syms = syms + [name]
    syms

fn strip_stub_marker(symbol: text) -> text:
    """Remove a leading 'auto_stub' (and optional underscore) to get the
    semantic core of the symbol name."""
    var s = symbol
    val idx = s.index_of("auto_stub")
    if idx >= 0:
        # Keep the prefix before auto_stub (if any), then the tail after it.
        val before = s.slice(0, idx)
        var after = s.slice(idx + 9, s.len())  # "auto_stub" is 9 chars
        if after.starts_with("_"):
            after = after.slice(1, after.len())
        s = before + after
    s

fn classify(symbol: text) -> text:
    """Return the bucket a symbol belongs to. Substring-match the known
    prefix list against the stripped symbol name (case-insensitive)."""
    val core = strip_stub_marker(symbol).lower()
    for prefix in KNOWN_BUCKETS:
        if core.contains(prefix):
            return prefix
    OTHER_BUCKET

fn ensure_bucket(result: AuditResult, prefix: text) -> AuditResult:
    if result.bucket_symbols.contains(prefix):
        return result
    var names = result.bucket_names + [prefix]
    var map = result.bucket_symbols
    map.set(prefix, [])
    AuditResult(
        binary: result.binary,
        total: result.total,
        bucket_names: names,
        bucket_symbols: map,
        symbols: result.symbols,
    )

fn classify_all(symbols: List<text>, binary: text) -> AuditResult:
    var result = AuditResult(
        binary: binary,
        total: 0,
        bucket_names: [],
        bucket_symbols: Map<text, List<text>>(),
        symbols: [],
    )

    for sym in symbols:
        val bucket = classify(sym)
        result = ensure_bucket(result, bucket)
        var list = result.bucket_symbols.get(bucket)
        list = list + [sym]
        var map = result.bucket_symbols
        map.set(bucket, list)
        result = AuditResult(
            binary: result.binary,
            total: result.total + 1,
            bucket_names: result.bucket_names,
            bucket_symbols: map,
            symbols: result.symbols + [sym],
        )
    result

fn sort_buckets_desc(result: AuditResult) -> List<text>:
    """Bucket names sorted by descending symbol count (selection sort)."""
    var names = result.bucket_names
    var n = names.len()
    var i = 0
    while i < n:
        var best = i
        var j = i + 1
        while j < n:
            val a = result.bucket_symbols.get(names[best]).len()
            val b = result.bucket_symbols.get(names[j]).len()
            if b > a:
                best = j
            j = j + 1
        if best != i:
            val tmp = names[i]
            names = names.with(i, names[best])
            names = names.with(best, tmp)
        i = i + 1
    names

fn top_longest(symbols: List<text>, k: i64) -> List<text>:
    var syms = symbols
    var n = syms.len()
    var i = 0
    while i < n:
        var best = i
        var j = i + 1
        while j < n:
            if syms[j].len() > syms[best].len():
                best = j
            j = j + 1
        if best != i:
            val tmp = syms[i]
            syms = syms.with(i, syms[best])
            syms = syms.with(best, tmp)
        i = i + 1
    val take = if n < k: n else: k
    syms.slice(0, take)

fn action_for(prefix: text) -> text:
    if prefix == OTHER_BUCKET: "review" else: "exclude"

fn print_summary(result: AuditResult, suggest: bool):
    print "=== auto_stub audit: {result.binary} ==="
    print "total auto_stub symbols: {result.total}"
    print ""
    print "buckets (descending):"
    val sorted = sort_buckets_desc(result)
    for name in sorted:
        val count = result.bucket_symbols.get(name).len()
        print "  {name}: {count}  (action: {action_for(name)})"

    print ""
    print "top-20 longest symbol names:"
    val longest = top_longest(result.symbols, 20)
    for s in longest:
        print "  [{s.len()}] {s}"

    if suggest:
        print ""
        print "suggested exclusions (per-bucket heuristic):"
        for name in sorted:
            if name != OTHER_BUCKET and result.bucket_symbols.get(name).len() > 0:
                print "  bucket {name}: review src/lib/*{name}* subtrees"

fn emit_manifest(result: AuditResult, path: text):
    """Write the SDN manifest of buckets and stub symbols."""
    val parent = fs.parent(path)
    if parent != "" and not fs.dir_exists(parent):
        fs.create_dir_all(parent)
    var text = "stubs_manifest {\n"
    text = text + "  binary: \"{result.binary}\"\n"
    text = text + "  total: {result.total}\n"
    text = text + "  buckets: [\n"
    val sorted = sort_buckets_desc(result)
    for name in sorted:
        val count = result.bucket_symbols.get(name).len()
        text = text + "    { prefix: \"{name}\", count: {count}, action: \"{action_for(name)}\" }\n"
    text = text + "  ]\n"
    text = text + "  symbols: [\n"
    for s in result.symbols:
        text = text + "    \"{s}\"\n"
    text = text + "  ]\n"
    text = text + "}\n"

    fs.write_text(path, text)
    print "manifest written: {path}"

fn main():
    val raw_args = cli.args()
    val (binary, suggest, output) = parse_args(raw_args)

    print "[audit] scanning {binary} with nm..."
    val lines = run_nm(binary)
    val symbols = filter_stub_symbols(lines)
    val result = classify_all(symbols, binary)
    print_summary(result, suggest)
    emit_manifest(result, output)
