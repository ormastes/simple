# IoDriver Shim -- Baremetal @export("C") Implementations
#
# MDSOC: feature dimension, network layer
# Status: B3 stub -- implements all rt_driver_* extern functions from
#         src/lib/nogc_async_mut/io/driver.spl for the SimpleOS baremetal
#         environment. Bridges the completion-based IoDriver model to the
#         cooperative netstack.
#
# Architecture:
#   - Each rt_driver_create() allocates a BaremetalDriver with its own queues.
#   - submit_* functions create PendingOp entries (or immediately complete for
#     send operations since B2 TCP shim discards data).
#   - flush() is a no-op (ops are "submitted" immediately to pending list).
#   - poll() drives tick counter, checks timeout expirations, and moves
#     completed ops into a batch array addressable by index.
#   - poll_id/poll_result/poll_flags/poll_data read from the last batch.
#
# Follow-up: Wire submit_accept/recv to real NetstackService when TCP
#            shim gains live packet processing.

use os.kernel.net.driver_shim_state.{
    PendingOp, CompletedOp, BaremetalDriver,
    OP_TYPE_ACCEPT, OP_TYPE_RECV, OP_TYPE_SEND, OP_TYPE_TIMEOUT,
    OP_TYPE_CONNECT, OP_TYPE_SENDFILE, OP_TYPE_READ, OP_TYPE_WRITE,
    OP_TYPE_OPEN, OP_TYPE_CLOSE, OP_TYPE_FSYNC,
    driver_create, driver_get, driver_get_index, driver_alloc_op_id,
    driver_add_pending, driver_add_completed, driver_destroy,
    g_drivers
}
use os.kernel.net.tcp_shim.{rt_io_tcp_accept, rt_io_tcp_read}

extern fn rt_bytes_to_text(data: [u8]) -> text
extern fn rt_net_tx_test() -> i64
extern fn rt_net_rx_ready() -> i64

fn driver_shim_packet_io_ready() -> bool:
    rt_net_tx_test() == 0 and rt_net_rx_ready() == 0

# ============================================================================
# Lifecycle
# ============================================================================

@export("C")
fn rt_driver_create(queue_depth: i64) -> i64:
    """Create a new baremetal IoDriver. queue_depth is advisory (ignored)."""
    driver_create()

@export("C")
fn rt_driver_destroy(handle: i64):
    """Destroy a baremetal IoDriver and release all resources."""
    driver_destroy(handle)

# ============================================================================
# Network Submissions
# ============================================================================

@export("C")
fn rt_driver_submit_accept(handle: i64, listen_fd: i64) -> i64:
    """Submit async accept. Returns op_id.

    B3 stub: creates a pending op. The op will never complete until the
    netstack is wired (follow-up phase). poll() will simply skip it.
    """
    val op_id = driver_alloc_op_id(handle)
    if op_id < 0:
        return -1
    val op = PendingOp(
        op_id: op_id, op_type: OP_TYPE_ACCEPT, fd: listen_fd,
        timeout_target: -1, buf_size: 0, data_text: "", data_len: 0,
        offset: 0, addr: "", port: 0, flags: 0, mode: 0
    )
    driver_add_pending(handle, op)
    op_id

@export("C")
fn rt_driver_submit_connect(handle: i64, fd: i64, addr: text, port: i64) -> i64:
    """Submit async connect. Returns op_id.

    B3 stub: creates a pending op. Will not complete until netstack wired.
    """
    val op_id = driver_alloc_op_id(handle)
    if op_id < 0:
        return -1
    val op = PendingOp(
        op_id: op_id, op_type: OP_TYPE_CONNECT, fd: fd,
        timeout_target: -1, buf_size: 0, data_text: "", data_len: 0,
        offset: 0, addr: addr, port: port, flags: 0, mode: 0
    )
    driver_add_pending(handle, op)
    op_id

@export("C")
fn rt_driver_submit_recv(handle: i64, fd: i64, buf_size: i64) -> i64:
    """Submit async recv. Returns op_id.

    B3 stub: creates a pending op. Since B2 TCP read returns empty (EOF),
    this will not produce data until the netstack is wired.
    """
    val op_id = driver_alloc_op_id(handle)
    if op_id < 0:
        return -1
    val op = PendingOp(
        op_id: op_id, op_type: OP_TYPE_RECV, fd: fd,
        timeout_target: -1, buf_size: buf_size, data_text: "", data_len: 0,
        offset: 0, addr: "", port: 0, flags: 0, mode: 0
    )
    driver_add_pending(handle, op)
    op_id

@export("C")
fn rt_driver_submit_send(handle: i64, fd: i64, data: text, len: i64) -> i64:
    """Submit async send. Returns op_id.

    Fails closed until the boot packet provider proves both TX and RX. This
    prevents discarded-data paths from being accepted as real network transfer.
    """
    if not driver_shim_packet_io_ready():
        return -1
    val op_id = driver_alloc_op_id(handle)
    if op_id < 0:
        return -1
    val comp = CompletedOp(
        op_id: op_id, result_val: len, flags: 0,
        data_text: "", data_len: 0
    )
    driver_add_completed(handle, comp)
    op_id

@export("C")
fn rt_driver_submit_sendfile(handle: i64, sock_fd: i64, file_fd: i64, offset: i64, len: i64) -> i64:
    """Submit async sendfile (zero-copy). Returns op_id.

    Fails closed until a real packet provider is ready. The baremetal driver
    does not currently have filesystem-backed zero-copy transfer evidence.
    """
    if not driver_shim_packet_io_ready():
        return -1
    val op_id = driver_alloc_op_id(handle)
    if op_id < 0:
        return -1
    val comp = CompletedOp(
        op_id: op_id, result_val: len, flags: 0,
        data_text: "", data_len: 0
    )
    driver_add_completed(handle, comp)
    op_id

# ============================================================================
# File I/O Submissions
