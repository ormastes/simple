# Shell Tool Registration — Register coreutils with ToolRegistry
# MDSOC: feature dimension, shell layer
#
# Registers all shell/coreutils tools so external dispatchers can find them.
# Note: Most shell tools require VFS/Terminal context and are dispatched
# directly by shell_app.spl. This registration covers tools that can
# also run standalone via the ToolRegistry (print-based output).

use os.tools.tool_registry.{ToolRegistry, ToolEntry}

struct MkdirPlan:
    path: text
    parents: bool

struct ChmodPlan:
    mode: text
    path: text

struct SudoPlan:
    command: text
    args: [text]

# Standalone wrappers (print-based, no Terminal needed)

fn parse_mkdir_args(args: [text]) -> Result<MkdirPlan, text>:
    var parents = false
    var path = ""
    for arg in args:
        if arg == "-p" or arg == "--parents":
            parents = true
        elif path == "":
            path = arg
        else:
            return Err("mkdir: too many operands")
    if path == "":
        return Err("mkdir: missing operand")
    Ok(MkdirPlan(path: path, parents: parents))

fn chmod_mode_is_octal(mode: text) -> bool:
    if mode.len() == 0:
        return false
    for ch in mode:
        if ch < "0" or ch > "7":
            return false
    true

fn parse_chmod_args(args: [text]) -> Result<ChmodPlan, text>:
    if args.len() < 2:
        return Err("chmod: missing mode or operand")
    val mode = args[0]
    if not chmod_mode_is_octal(mode):
        return Err("chmod: mode must be octal")
    Ok(ChmodPlan(mode: mode, path: args[1]))

fn parse_sudo_args(args: [text]) -> Result<SudoPlan, text>:
    if args.len() == 0:
        return Err("sudo: command required")
    Ok(SudoPlan(command: args[0], args: args.slice(1, args.len())))

fn _run_unavailable(name: text) -> i32:
    print "{name}: standalone registry runner requires shell context"
    return 1

fn _run_ls(args: [text]) -> i32:
    _run_unavailable("ls")

fn _run_mkdir(args: [text]) -> i32:
    val parsed = parse_mkdir_args(args)
    if val Err(e) = parsed:
        print e
        return 1
    _run_unavailable("mkdir")

fn _run_chmod(args: [text]) -> i32:
    val parsed = parse_chmod_args(args)
    if val Err(e) = parsed:
        print e
        return 1
    _run_unavailable("chmod")

fn _run_sudo(args: [text]) -> i32:
    val parsed = parse_sudo_args(args)
    if val Err(e) = parsed:
        print e
        return 1
    _run_unavailable("sudo")

fn _run_tmux(args: [text]) -> i32:
    _run_unavailable("tmux")

fn _run_ssh(args: [text]) -> i32:
    _run_unavailable("ssh")

fn _run_basename(args: [text]) -> i32:
    if args.len() == 0:
        print "basename: missing operand"
        return 1
    val path = args[0]
    val suffix = if args.len() > 1: args[1] else: ""
    var name = path
    var last_slash = -1
    var i = 0
    for ch in path:
        if ch == "/":
            last_slash = i
        i = i + 1
    if last_slash >= 0:
        name = path.slice(last_slash + 1, path.len())
    if suffix != "" and name.ends_with(suffix):
        name = name.slice(0, name.len() - suffix.len())
    print name
    return 0

fn _run_dirname(args: [text]) -> i32:
    if args.len() == 0:
        print "dirname: missing operand"
        return 1
    val path = args[0]
    var last_slash = -1
    var i = 0
    for ch in path:
        if ch == "/":
            last_slash = i
        i = i + 1
    if last_slash < 0:
        print "."
    elif last_slash == 0:
        print "/"
    else:
        print path.slice(0, last_slash)
    return 0

fn _run_seq(args: [text]) -> i32:
    if args.len() == 0:
        print "seq: missing operand"
        return 1
    var first: i64 = 1
    var increment: i64 = 1
    var last: i64 = 0
    if args.len() == 1:
        last = args[0].parse_i64() ?? 0
    elif args.len() == 2:
        first = args[0].parse_i64() ?? 1
        last = args[1].parse_i64() ?? 0
    else:
        first = args[0].parse_i64() ?? 1
        increment = args[1].parse_i64() ?? 1
        last = args[2].parse_i64() ?? 0
    if increment == 0:
        print "seq: zero increment"
        return 1
    var current = first
    if increment > 0:
        while current <= last:
            print "{current}"
            current = current + increment
    else:
        while current >= last:
            print "{current}"
            current = current + increment
    return 0

fn _run_expr(args: [text]) -> i32:
    if args.len() < 3:
        print "expr: syntax error"
        return 2
    val left = args[0].parse_i64() ?? 0
    val op = args[1]
    val right = args[2].parse_i64() ?? 0
    match op:
        "+":
            print "{left + right}"
            return 0
        "-":
            print "{left - right}"
            return 0
        "*":
            print "{left * right}"
            return 0
        "/":
            if right == 0:
                print "expr: division by zero"
                return 2
            print "{left / right}"
            return 0
        "%":
            if right == 0:
                print "expr: division by zero"
                return 2
            print "{left % right}"
            return 0
        _:
            print "expr: unknown operator: {op}"
            return 2

fn _run_true(args: [text]) -> i32:
    return 0

fn _run_false(args: [text]) -> i32:
    return 1

fn _run_yes(args: [text]) -> i32:
    val msg = if args.len() > 0: args[0] else: "y"
    var count = 0
    while count < 1000:
        print msg
        count = count + 1
    return 0

fn register_shell_tools(registry: ToolRegistry) -> ToolRegistry:
    """Register shell/coreutils tools with the ToolRegistry."""
    var out = registry

    out.register(ToolEntry(
        name: "ls",
        description: "List directory entries",
        category: "shell",
        run_fn: _run_ls,
        capabilities: ["read"]
    ))

    out.register(ToolEntry(
        name: "mkdir",
        description: "Create directories",
        category: "shell",
        run_fn: _run_mkdir,
        capabilities: ["write"]
    ))

    out.register(ToolEntry(
        name: "chmod",
        description: "Change file permissions",
        category: "shell",
        run_fn: _run_chmod,
        capabilities: ["write"]
    ))

    out.register(ToolEntry(
        name: "sudo",
        description: "Run a command with elevated privileges",
        category: "shell",
        run_fn: _run_sudo,
        capabilities: ["privilege"]
    ))

    out.register(ToolEntry(
        name: "tmux",
        description: "Terminal multiplexer",
        category: "shell",
        run_fn: _run_tmux,
        capabilities: ["terminal"]
    ))

    out.register(ToolEntry(
        name: "ssh",
        description: "Secure shell client",
        category: "shell",
        run_fn: _run_ssh,
        capabilities: ["network"]
    ))

    out.register(ToolEntry(
        name: "basename",
        description: "Strip directory from path",
        category: "shell",
        run_fn: _run_basename,
        capabilities: ["read"]
    ))

    out.register(ToolEntry(
        name: "dirname",
        description: "Strip filename from path",
        category: "shell",
        run_fn: _run_dirname,
        capabilities: ["read"]
    ))

    out.register(ToolEntry(
        name: "seq",
        description: "Print number sequence",
        category: "shell",
        run_fn: _run_seq,
        capabilities: ["read"]
    ))

    out.register(ToolEntry(
        name: "expr",
        description: "Evaluate arithmetic expression",
        category: "shell",
        run_fn: _run_expr,
        capabilities: ["read"]
    ))

    out.register(ToolEntry(
        name: "true",
        description: "Exit with code 0",
        category: "shell",
        run_fn: _run_true,
        capabilities: []
    ))

    out.register(ToolEntry(
        name: "false",
        description: "Exit with code 1",
        category: "shell",
        run_fn: _run_false,
        capabilities: []
    ))

    out.register(ToolEntry(
        name: "yes",
        description: "Repeatedly output a string",
        category: "shell",
        run_fn: _run_yes,
        capabilities: ["read"]
    ))

    out

fn shell_tool_registry() -> ToolRegistry:
    register_shell_tools(ToolRegistry.new())
