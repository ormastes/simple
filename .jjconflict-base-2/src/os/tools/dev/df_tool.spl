# df — Filesystem free space
# MDSOC: feature dimension, apps layer

use os.apps.terminal.terminal.{Terminal}
use os.apps.shell.shell_tools.{_write_line}

fn run_df(args: [text]) -> i32:
    """Show filesystem disk space usage."""
    print "Filesystem      Size  Used  Avail  Use%  Mounted on"
    print "/dev/vda        128M   16M   112M   12%  /"
    print "tmpfs            32M    0B    32M    0%  /tmp"
    return 0

fn tool_df(terminal: Terminal) -> i32:
    """Show filesystem disk space usage (placeholder values for SimpleOS)."""
    _write_line(terminal, "Filesystem      Size  Used  Avail  Use%  Mounted on")
    _write_line(terminal, "/dev/vda        128M   16M   112M   12%  /")
    _write_line(terminal, "tmpfs            32M    0B    32M    0%  /tmp")
    return 0
