# SSH Host Key Signature Verification + Generation SFFI
# Wraps the rt_{rsa,ed25519,ecdsa_p256}_{verify,sign} runtime externs.

# ============================================================================
# Tier 1: Extern Function Declarations (Raw SFFI)
# ============================================================================

# --- verify ---

# Verify an RSA-PKCS1-SHA256 signature (RFC 8332 rsa-sha2-256).
# Returns 1 if valid, 0 otherwise.
extern fn rt_rsa_sha256_verify(pubkey: [u8], message: [u8], signature: [u8]) -> i64

# Verify an RSA-PKCS1-SHA512 signature (RFC 8332 rsa-sha2-512).
# Returns 1 if valid, 0 otherwise.
extern fn rt_rsa_sha512_verify(pubkey: [u8], message: [u8], signature: [u8]) -> i64

# Verify an Ed25519 signature.
# Returns 1 if valid, 0 otherwise.
extern fn rt_ed25519_verify(message: [u8], pubkey: [u8], signature: [u8]) -> i64

# Verify an ECDSA P-256 SHA-256 fixed-width (64-byte r||s) signature
# (RFC 5656 ecdsa-sha2-nistp256 — the SSH-wire mpint form must be
# converted to fixed-width by the caller).
# Returns 1 if valid, 0 otherwise.
extern fn rt_ecdsa_p256_verify(pubkey: [u8], message: [u8], signature: [u8]) -> i64

# Verify an RSA-PSS-SHA256 signature (RFC 8017 §8.1, TLS 1.3 sig algo 0x0804).
# Returns 1 if valid, 0 otherwise.
extern fn rt_rsa_pss_sha256_verify(pubkey: [u8], message: [u8], signature: [u8]) -> i64

# Verify an RSA-PSS-SHA384 signature (RFC 8017 §8.1, TLS 1.3 sig algo 0x0805).
# Returns 1 if valid, 0 otherwise.
extern fn rt_rsa_pss_sha384_verify(pubkey: [u8], message: [u8], signature: [u8]) -> i64

# Verify an RSA-PSS-SHA512 signature (RFC 8017 §8.1, TLS 1.3 sig algo 0x0806).
# Returns 1 if valid, 0 otherwise.
extern fn rt_rsa_pss_sha512_verify(pubkey: [u8], message: [u8], signature: [u8]) -> i64

# Big-integer modular exponentiation: base^exp mod modulus, all big-endian byte arrays.
# Returns the result as a big-endian byte array of the same length as `modulus`.
# FR-CRYPTO-0001: runtime-accelerated path for RSA-2048 modexp in interpreter mode.
extern fn rt_bigint_mod_exp(base: [u8], exp: [u8], modulus: [u8]) -> [u8]

# --- sign ---

# Sign `message` with RSA-PKCS1-SHA256 using a PKCS#8-v1 DER private key.
# Returns the signature bytes, or an empty array on any error.
extern fn rt_rsa_sha256_sign(pkcs8: [u8], message: [u8]) -> [u8]

# Sign `message` with RSA-PKCS1-SHA512 using a PKCS#8-v1 DER private key.
# Returns the signature bytes, or an empty array on any error.
extern fn rt_rsa_sha512_sign(pkcs8: [u8], message: [u8]) -> [u8]

# Sign `message` with Ed25519 using a PKCS#8-v1 DER private key (RFC 8032).
# Returns 64-byte Ed25519 signature, or an empty array on any error.
extern fn rt_ed25519_sign(pkcs8: [u8], message: [u8]) -> [u8]

# Sign `message` with ECDSA P-256 SHA-256 using a PKCS#8-v1 DER private
# key. Returns 64-byte fixed-width r||s, or an empty array on error.
extern fn rt_ecdsa_p256_sign(pkcs8: [u8], message: [u8]) -> [u8]

# Verify an ECDSA P-384 SHA-384 fixed-width (96-byte r||s) signature.
# Returns 1 if valid, 0 otherwise.
extern fn rt_ecdsa_p384_verify(pubkey: [u8], message: [u8], signature: [u8]) -> i64

# Sign `message` with ECDSA P-384 SHA-384 using a PKCS#8-v1 DER private
# key. Returns 96-byte fixed-width r||s (48+48), or an empty array on error.
extern fn rt_ecdsa_p384_sign(pkcs8: [u8], message: [u8]) -> [u8]

# Verify an ECDSA P-521 SHA-512 fixed-width (132-byte r||s) signature.
# Returns 1 if valid, 0 otherwise.
extern fn rt_ecdsa_p521_verify(pubkey: [u8], message: [u8], signature: [u8]) -> i64

# Sign `message` with ECDSA P-521 SHA-512 using a PKCS#8-v1 DER private
# key. Returns 132-byte fixed-width r||s (66+66, 521-bit values left-padded
# into 528-bit/66-byte buffers, big-endian per RFC 8446 §4.2.3).
# Returns an empty array on error.
extern fn rt_ecdsa_p521_sign(pkcs8: [u8], message: [u8]) -> [u8]

# ============================================================================
# Tier 2: Simple-Friendly Wrapper Functions
# ============================================================================

fn rsa_sha256_verify(pubkey: [u8], message: [u8], signature: [u8]) -> bool:
    """Verify an RSA-PKCS1-SHA256 signature.

    Args:
        pubkey:    DER-encoded RSA public key (SubjectPublicKeyInfo)
        message:   Message bytes that were signed
        signature: Raw PKCS#1 v1.5 signature bytes

    Returns: true if the signature is valid, false otherwise
    """
    val result = rt_rsa_sha256_verify(pubkey, message, signature)
    result == 1

fn rsa_sha512_verify(pubkey: [u8], message: [u8], signature: [u8]) -> bool:
    """Verify an RSA-PKCS1-SHA512 signature (RFC 8332 rsa-sha2-512)."""
    val result = rt_rsa_sha512_verify(pubkey, message, signature)
    result == 1

fn ed25519_verify(pubkey: [u8], message: [u8], signature: [u8]) -> bool:
    """Verify an Ed25519 signature.

    Args:
        pubkey:    32-byte Ed25519 public key
        message:   Message bytes that were signed
        signature: 64-byte Ed25519 signature

    Returns: true if the signature is valid, false otherwise
    """
    val result = rt_ed25519_verify(message, pubkey, signature)
    result == 1

fn ecdsa_p256_verify(pubkey: [u8], message: [u8], signature_fixed64: [u8]) -> bool:
    """Verify an ECDSA P-256 fixed-width signature.

    Args:
        pubkey:           DER-encoded ECDSA P-256 public key (SPKI)
        message:          Message bytes that were signed
        signature_fixed64: 64-byte r||s form (NOT the SSH mpint pair)

    Returns: true if valid, false otherwise
    """
    val result = rt_ecdsa_p256_verify(pubkey, message, signature_fixed64)
    result == 1

# TODO: [interpreter][P1] Simple wraps SFFI [u8] returns as Option::Some([bytes]) at the call-site binding even when the wrapper return type says plain [u8] and unwraps internally. Repro: 17 failing tests in test/system/os_crypto_ref_signature_spec.spl with "method len not found on type enum (receiver value: Option::Some(...))". Root cause likely in src/compiler_rust/compiler/src/interpreter_extern/dynamic_sffi.rs return marshalling or in the type checker's handling of multi-decl externs (see fs.spl vs ffi/io.spl conflict for rt_file_read_bytes pattern). Wrapper-side `_unwrap_sig` doesn't propagate. Full notes in doc/09_report/crypto_spec_remains_2026-04-16.md.
fn _unwrap_sig(maybe: [u8]) -> [u8]:
    """Coerce Option<[u8]> -> [u8] in case Simple wraps the extern return."""
    if val bytes = maybe:
        bytes
    else:
        []

fn rsa_sha256_sign(pkcs8: [u8], message: [u8]) -> [u8]:
    """Sign `message` with RSA-PKCS1-SHA256 (deterministic).

    Args:
        pkcs8:   PKCS#8 v1 DER-encoded RSA private key
        message: Bytes to sign

    Returns: signature bytes (modulus-size); empty array on error.
             Caller must check `len(sig) > 0` before use.

    Hosted-only: requires SystemRandom in the runtime.
    """
    _unwrap_sig(rt_rsa_sha256_sign(pkcs8, message))

fn rsa_sha512_sign(pkcs8: [u8], message: [u8]) -> [u8]:
    """Sign `message` with RSA-PKCS1-SHA512 (deterministic)."""
    _unwrap_sig(rt_rsa_sha512_sign(pkcs8, message))

fn ed25519_sign_pkcs8(pkcs8: [u8], message: [u8]) -> [u8]:
    """Sign `message` with Ed25519 using a PKCS#8-encoded private key.

    This is the hosted-only, pkcs8-key variant used by TLS 1.3 and similar
    protocols that store the Ed25519 private key in PKCS#8 DER form.

    For RFC 8032 seed-based signing (baremetal-compatible), use
    `os.crypto.ed25519.ed25519_sign(private_seed, public_key, message)`.

    Args:
        pkcs8:   PKCS#8 v1 DER-encoded Ed25519 private key.
        message: Bytes to sign.

    Returns: 64-byte Ed25519 signature; empty array on error.
             Caller must check `len(sig) > 0` before use.

    Deterministic per RFC 8032 (no random nonce).
    Hosted-only.
    """
    _unwrap_sig(rt_ed25519_sign(pkcs8, message))

fn ecdsa_p256_sign(pkcs8: [u8], message: [u8]) -> [u8]:
    """Sign `message` with ECDSA P-256 (non-deterministic; 64-byte r||s).

    Convert to SSH `mpint r + mpint s` via os.crypto.ecdsa_p256 for the
    SSH wire format.
    """
    _unwrap_sig(rt_ecdsa_p256_sign(pkcs8, message))

fn ecdsa_p384_verify(pubkey: [u8], message: [u8], signature_fixed96: [u8]) -> bool:
    """Verify an ECDSA P-384 fixed-width signature.

    Args:
        pubkey:            DER-encoded ECDSA P-384 public key (SPKI)
        message:           Message bytes that were signed
        signature_fixed96: 96-byte r||s form (48+48 big-endian)

    Returns: true if valid, false otherwise.

    Note: RT externs for P-384 require a bootstrap rebuild before they resolve.
    See feedback_extern_bootstrap_rebuild.md.
    """
    val result = rt_ecdsa_p384_verify(pubkey, message, signature_fixed96)
    result == 1

fn ecdsa_p384_sign(pkcs8: [u8], message: [u8]) -> [u8]:
    """Sign `message` with ECDSA P-384 SHA-384 (96-byte r||s).

    Returns 96-byte fixed-width r||s; empty array on error.
    Caller must check len(sig) > 0 before use.

    Note: RT externs for P-384 require a bootstrap rebuild before they resolve.
    See feedback_extern_bootstrap_rebuild.md.
    """
    _unwrap_sig(rt_ecdsa_p384_sign(pkcs8, message))

fn ecdsa_p521_verify(pubkey: [u8], message: [u8], signature_fixed132: [u8]) -> bool:
    """Verify an ECDSA P-521 fixed-width signature.

    Args:
        pubkey:             DER-encoded ECDSA P-521 public key (SPKI)
        message:            Message bytes that were signed
        signature_fixed132: 132-byte r||s form (66+66, 521-bit values
                            left-padded into 528-bit buffers, big-endian;
                            RFC 8446 §4.2.3 wire form)

    Returns: true if valid, false otherwise.

    Note: RT externs for P-521 require a bootstrap rebuild before they resolve.
    See feedback_extern_bootstrap_rebuild.md.
    """
    val result = rt_ecdsa_p521_verify(pubkey, message, signature_fixed132)
    result == 1

fn ecdsa_p521_sign(pkcs8: [u8], message: [u8]) -> [u8]:
    """Sign `message` with ECDSA P-521 SHA-512 (132-byte r||s).

    Returns 132-byte fixed-width r||s; empty array on error.
    Caller must check len(sig) > 0 before use.

    Note: RT externs for P-521 require a bootstrap rebuild before they resolve.
    See feedback_extern_bootstrap_rebuild.md.
    """
    _unwrap_sig(rt_ecdsa_p521_sign(pkcs8, message))

fn rsa_pss_sha256_verify(pubkey: [u8], message: [u8], signature: [u8]) -> bool:
    """Verify an RSA-PSS-SHA256 signature (RFC 8017 §8.1, TLS 1.3 sig algo 0x0804).

    Args:
        pubkey:    DER-encoded RSA SubjectPublicKeyInfo (SPKI).
        message:   Message bytes that were signed.
        signature: Raw PSS signature bytes.

    Returns: true if valid, false otherwise.
    """
    val result = rt_rsa_pss_sha256_verify(pubkey, message, signature)
    result == 1

fn rsa_pss_sha384_verify(pubkey: [u8], message: [u8], signature: [u8]) -> bool:
    """Verify an RSA-PSS-SHA384 signature (RFC 8017 §8.1, TLS 1.3 sig algo 0x0805).

    Args:
        pubkey:    DER-encoded RSA SubjectPublicKeyInfo (SPKI).
        message:   Message bytes that were signed.
        signature: Raw PSS signature bytes.

    Returns: true if valid, false otherwise.
    """
    val result = rt_rsa_pss_sha384_verify(pubkey, message, signature)
    result == 1

fn rsa_pss_sha512_verify(pubkey: [u8], message: [u8], signature: [u8]) -> bool:
    """Verify an RSA-PSS-SHA512 signature (RFC 8017 §8.1, TLS 1.3 sig algo 0x0806).

    Args:
        pubkey:    DER-encoded RSA SubjectPublicKeyInfo (SPKI).
        message:   Message bytes that were signed.
        signature: Raw PSS signature bytes.

    Returns: true if valid, false otherwise.
    """
    val result = rt_rsa_pss_sha512_verify(pubkey, message, signature)
    result == 1

# ============================================================================
# Tier 3: SSH Host Key Dispatcher
# ============================================================================

fn verify_host_key(key_type: text, pubkey: [u8], message: [u8], signature: [u8]) -> bool:
    """Verify an SSH host key signature, dispatching on key type.

    Args:
        key_type:  SSH key type / sig-algo, one of:
                   "ssh-rsa"              — legacy SHA-1, not supported
                   "rsa-sha2-256"         — RFC 8332
                   "rsa-sha2-512"         — RFC 8332
                   "ssh-ed25519"          — RFC 8709
                   "ecdsa-sha2-nistp256"  — RFC 5656 (signature must
                                            already be fixed-width r||s)
        pubkey:    Raw public key bytes (type-specific encoding)
        message:   Signed message bytes (e.g. the SSH exchange hash)
        signature: Signature bytes

    Returns: true if the signature is valid for the given key type,
             false for unknown key types or invalid signatures.
    """
    if key_type == "rsa-sha2-256":
        rsa_sha256_verify(pubkey, message, signature)
    elif key_type == "rsa-sha2-512":
        rsa_sha512_verify(pubkey, message, signature)
    elif key_type == "ssh-ed25519":
        ed25519_verify(pubkey, message, signature)
    elif key_type == "ecdsa-sha2-nistp256":
        ecdsa_p256_verify(pubkey, message, signature)
    elif key_type == "ecdsa-sha2-nistp384":
        ecdsa_p384_verify(pubkey, message, signature)
    elif key_type == "ecdsa-sha2-nistp521":
        ecdsa_p521_verify(pubkey, message, signature)
    else:
        false
