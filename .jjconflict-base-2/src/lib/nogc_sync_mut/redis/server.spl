"""
# Redis Server (RESP)

A pure-Simple, Redis-compatible key/value server speaking the RESP wire
protocol over sync TCP. Mirrors the framing used by the Redis client
(`std.nogc_sync_mut.redis.client`) on the reply side.

It is designed so the request parser and command dispatcher are completely
independent of the socket: a spec can feed RESP byte buffers to
`parse_next_request` / `RedisServer.dispatch` and assert the encoded reply
with no real network in the loop. The accept loop is a thin wrapper.

## Usage

```simple
use std.nogc_sync_mut.redis.server.{RedisServer}

var server = RedisServer.create()
server.run("127.0.0.1", 6399)?   # blocks accepting connections
```

## Supported commands

PING, SET, GET, DEL, EXISTS, INCR, EXPIRE, TTL, FLUSHALL, COMMAND, QUIT.

Values are stored as `text` (RESP is ASCII-clean for benchmark traffic).
TTL is lazy-expiry on access, keyed off a unix-seconds clock supplied by the
connection loop (so dispatch stays deterministic for tests).
"""

use std.io.types.{IoError, IoErrorKind}
use std.nogc_sync_mut.io.tcp.{TcpListener, TcpStream}

# ============================================================================
# In-memory store (array-of-parallel-fields, mutated via me-methods only)
# ============================================================================
#
# We deliberately avoid native Dict (interp/native repr gotchas) and use three
# parallel arrays. `expires_at` holds a unix-seconds deadline, or -1 for "no
# expiry". Mutation happens only through `me` methods on the server class so
# cross-module field mutation is reliable.

class RedisServer:
    """RESP key/value server: store + command dispatcher.

    The store is three parallel arrays. `now_seconds` is the clock the
    dispatcher uses for TTL math; the accept loop refreshes it each request,
    while tests set it explicitly for determinism.
    """
    skeys: [text]
    svals: [text]
    sexp: [i64]
    now_seconds: i64

    static fn create() -> RedisServer:
        """Create an empty server with the store initialized."""
        RedisServer(skeys: [], svals: [], sexp: [], now_seconds: 0)

    # --- store primitives (me-methods) ---

    fn find_index(key: text) -> i64:
        """Return index of key, or -1 if absent. Does NOT expire."""
        var i = 0
        while i < self.skeys.len():
            if self.skeys[i] == key:
                return i
            i = i + 1
        -1

    me purge_if_expired(key: text) -> bool:
        """Lazily drop key if its deadline has passed. Returns true if removed."""
        val idx = self.find_index(key)
        if idx < 0:
            return false
        val deadline = self.sexp[idx]
        if deadline >= 0 and self.now_seconds >= deadline:
            self.remove_at(idx)
            return true
        false

    me remove_at(idx: i64):
        """Remove the entry at idx from all three parallel arrays."""
        var nk: [text] = []
        var nv: [text] = []
        var ne: [i64] = []
        var i = 0
        while i < self.skeys.len():
            if i != idx:
                nk.push(self.skeys[i])
                nv.push(self.svals[i])
                ne.push(self.sexp[i])
            i = i + 1
        self.skeys = nk
        self.svals = nv
        self.sexp = ne

    me set_value(key: text, value: text):
        """Set key=value, clearing any prior expiry (SET semantics)."""
        val idx = self.find_index(key)
        if idx >= 0:
            self.svals[idx] = value
            self.sexp[idx] = -1
        else:
            self.skeys.push(key)
            self.svals.push(value)
            self.sexp.push(-1)

    me get_value(key: text) -> Option<text>:
        """Get value, applying lazy expiry first."""
        self.purge_if_expired(key)
        val idx = self.find_index(key)
        if idx < 0:
            return nil
        Some(self.svals[idx])

    me has_key(key: text) -> bool:
        """Whether key is present (after lazy expiry). (`exists` is reserved.)"""
        self.purge_if_expired(key)
        self.find_index(key) >= 0

    me del_key(key: text) -> i64:
        """Delete key. Returns number removed (0 or 1)."""
        self.purge_if_expired(key)
        val idx = self.find_index(key)
        if idx < 0:
            return 0
        self.remove_at(idx)
        1

    me incr_key(key: text) -> Result<i64, text>:
        """INCR: parse current as int, add 1, store back. Err on non-int."""
        self.purge_if_expired(key)
        val idx = self.find_index(key)
        if idx < 0:
            self.skeys.push(key)
            self.svals.push("1")
            self.sexp.push(-1)
            return Ok(1)
        val cur = match parse_i64(self.svals[idx]):
            case Some(v): v
            case nil: return Err("value is not an integer or out of range")
        val next = cur + 1
        self.svals[idx] = "{next}"
        Ok(next)

    me expire_key(key: text, seconds: i64) -> bool:
        """Set an expiry deadline. Returns true if key exists."""
        self.purge_if_expired(key)
        val idx = self.find_index(key)
        if idx < 0:
            return false
        self.sexp[idx] = self.now_seconds + seconds
        true

    me ttl_key(key: text) -> i64:
        """TTL: -2 missing, -1 no expiry, else remaining whole seconds."""
        self.purge_if_expired(key)
        val idx = self.find_index(key)
        if idx < 0:
            return -2
        val deadline = self.sexp[idx]
        if deadline < 0:
            return -1
        val remaining = deadline - self.now_seconds
        if remaining < 0:
            return -2
        remaining

    me flush_all():
        """Drop every key."""
        self.skeys = []
        self.svals = []
        self.sexp = []

    # --- command dispatch (returns the encoded RESP reply bytes) ---

    me dispatch(args: [text]) -> text:
        """Dispatch one parsed command (array of args) to a RESP reply.

        Returns the encoded RESP reply text ready to write to the socket. QUIT
        and unknown commands still return a valid RESP frame. (Reply text is
        ASCII-clean RESP framing; binary values round-trip as UTF-8 text.)
        """
        if args.len() == 0:
            return resp_error("ERR empty command")
        val cmd = ascii_upper(args[0])

        if cmd == "PING":
            if args.len() >= 2:
                return resp_bulk(args[1])
            return resp_status("PONG")

        if cmd == "ECHO":
            if args.len() < 2:
                return resp_error("ERR wrong number of arguments for 'echo'")
            return resp_bulk(args[1])

        if cmd == "SET":
            if args.len() < 3:
                return resp_error("ERR wrong number of arguments for 'set'")
            self.set_value(args[1], args[2])
            # Optional EX <seconds> trailer (used by redis-benchmark variants).
            if args.len() >= 5 and ascii_upper(args[3]) == "EX":
                match parse_i64(args[4]):
                    case Some(secs): self.expire_key(args[1], secs)
                    case nil: pass
            return resp_status("OK")

        if cmd == "GET":
            if args.len() < 2:
                return resp_error("ERR wrong number of arguments for 'get'")
            match self.get_value(args[1]):
                case Some(v): return resp_bulk(v)
                case nil: return resp_nil()

        if cmd == "DEL":
            if args.len() < 2:
                return resp_error("ERR wrong number of arguments for 'del'")
            var removed = 0
            var i = 1
            while i < args.len():
                removed = removed + self.del_key(args[i])
                i = i + 1
            return resp_integer(removed)

        if cmd == "EXISTS":
            if args.len() < 2:
                return resp_error("ERR wrong number of arguments for 'exists'")
            var count = 0
            var i = 1
            while i < args.len():
                if self.has_key(args[i]):
                    count = count + 1
                i = i + 1
            return resp_integer(count)

        if cmd == "INCR":
            if args.len() < 2:
                return resp_error("ERR wrong number of arguments for 'incr'")
            val r = self.incr_key(args[1])
            match r:
                case Ok(n): return resp_integer(n)
                case Err(e): return resp_error("ERR {e}")

        if cmd == "EXPIRE":
            if args.len() < 3:
                return resp_error("ERR wrong number of arguments for 'expire'")
            val secs = match parse_i64(args[2]):
                case Some(v): v
                case nil: return resp_error("ERR value is not an integer or out of range")
            val ok = self.expire_key(args[1], secs)
            if ok:
                return resp_integer(1)
            return resp_integer(0)

        if cmd == "TTL":
            if args.len() < 2:
                return resp_error("ERR wrong number of arguments for 'ttl'")
            return resp_integer(self.ttl_key(args[1]))

        if cmd == "FLUSHALL":
            self.flush_all()
            return resp_status("OK")

        if cmd == "COMMAND":
            # COMMAND / COMMAND DOCS / COMMAND COUNT — minimal handshake reply.
            if args.len() >= 2 and ascii_upper(args[1]) == "COUNT":
                return resp_integer(0)
            return resp_empty_array()

        if cmd == "QUIT":
            return resp_status("OK")

        resp_error("ERR unknown command '{args[0]}'")

    # --- accept loop ---

    me run(host: text, port: i64) -> Result<(), IoError>:
        """Bind and serve connections forever (blocks).

        Each accepted connection is handled to completion before the next is
        accepted (single-threaded; sufficient for a benchmark baseline).
        """
        val addr = "{host}:{port}"
        val listener = TcpListener.bind(addr)?
        while true:
            val stream = listener.accept()?
            self.serve_connection(stream)

    me serve_connection(stream: TcpStream):
        """Read RESP requests from one connection and write replies.

        Inbound bytes are converted to text immediately (whole-array
        `rt_bytes_to_text` is reliable; per-element `[u8]` indexing is not in
        the interpreter). The text buffer is parsed with `index_of`/`substring`
        only. Drains every complete command (pipelining), retains an incomplete
        trailing fragment for the next read, closes on QUIT/EOF.
        """
        var s = stream
        var buf = ""
        var quit = false
        while not quit:
            val chunk = rt_io_tcp_read(s.fd, 16384)
            if chunk.len() == 0:
                break
            buf = buf + rt_bytes_to_text(chunk)
            self.now_seconds = rt_time_now_seconds()
            # Drain all complete commands from the buffer.
            var progressed = true
            while progressed:
                progressed = false
                match parse_next_request(buf):
                    case Some(r):
                        val reply = self.dispatch(r.args)
                        rt_io_tcp_write_text(s.fd, reply)
                        buf = r.rest
                        progressed = true
                        if r.args.len() > 0 and ascii_upper(r.args[0]) == "QUIT":
                            quit = true
                            progressed = false
                    case nil: pass
        rt_io_tcp_close(s.fd)

# ============================================================================
# Request parsing — RESP arrays of bulk strings + inline commands (text-based)
# ============================================================================

struct RequestResult:
    """A parsed request: its args plus the remaining unparsed buffer text."""
    args: [text]
    rest: text

fn parse_next_request(buf: text) -> Option<RequestResult>:
    """Parse one inbound command from the head of a text buffer.

    Handles the RESP array-of-bulk-strings form (`*N\\r\\n$len\\r\\n...`) that
    clients and benchmarks send, and the inline form (`PING\\r\\n`).
    Returns nil if the buffer does not yet hold a complete command.
    """
    if buf.len() == 0:
        return nil
    if buf.starts_with("*"):
        return parse_array_request(buf)
    parse_inline_request(buf)

fn parse_array_request(buf: text) -> Option<RequestResult>:
    """Parse `*N\\r\\n` followed by N bulk strings into [text] args.

    `text.index_of` returns an i64 with -1 sentinel (not Option), so we test
    against -1 rather than treating it as optional.
    """
    val header_end = buf.index_of("\r\n")
    if header_end < 0:
        return nil
    val count_text = buf.substring(1, header_end)
    val count = parse_i64(count_text) ?? -1
    var rest = buf.substring(header_end + 2, buf.len())
    if count < 0:
        return Some(RequestResult(args: [], rest: rest))
    var args: [text] = []
    var idx = 0
    while idx < count:
        if not rest.starts_with("$"):
            return nil
        val len_end = rest.index_of("\r\n")
        if len_end < 0:
            return nil
        val blen = parse_i64(rest.substring(1, len_end)) ?? -1
        val after_len = rest.substring(len_end + 2, rest.len())
        if blen < 0:
            args.push("")
            rest = after_len
            idx = idx + 1
            continue
        # Need blen data bytes + trailing CRLF.
        if after_len.len() < blen + 2:
            return nil
        val value = after_len.substring(0, blen)
        args.push(value)
        rest = after_len.substring(blen + 2, after_len.len())
        idx = idx + 1
    Some(RequestResult(args: args, rest: rest))

fn parse_inline_request(buf: text) -> Option<RequestResult>:
    """Parse an inline command line (whitespace-split) terminated by CRLF/LF."""
    var term = 2
    var nl = buf.index_of("\r\n")
    if nl < 0:
        nl = buf.index_of("\n")
        term = 1
    if nl < 0:
        return nil
    val line = buf.substring(0, nl)
    val rest = buf.substring(nl + term, buf.len())
    val args = split_ws(line)
    Some(RequestResult(args: args, rest: rest))

fn split_ws(s: text) -> [text]:
    """Split an inline command line into tokens on spaces, dropping empties.

    Tabs are also treated as separators; a trailing CR (from a bare-LF line)
    is stripped per token. Uses only `.split`/`.trim` (no `.replace`, which
    fails in nested-call context on the interpreter).
    """
    val tabbed = s.split("\t")
    var spaced: [text] = []
    for seg in tabbed:
        for p in seg.split(" "):
            spaced.push(p)
    var out: [text] = []
    for tok in spaced:
        val t = tok.trim()
        if t.len() > 0:
            out.push(t)
    out

fn parse_i64(s: text) -> Option<i64>:
    """Parse a base-10 signed integer reliably (Option-returning).

    Avoids `text.to_int()` typing inconsistencies on the interpreter where the
    Option wrapper is sometimes unwrapped early. Returns nil on any non-digit.
    Indexes a `.bytes()` array (reliable) rather than an extern-returned [u8].
    """
    val bytes = s.bytes()
    if bytes.len() == 0:
        return nil
    var neg = false
    var i = 0
    if bytes[0] == 45:
        neg = true
        i = 1
        if bytes.len() == 1:
            return nil
    var acc = 0
    while i < bytes.len():
        val b = bytes[i]
        if b < 48 or b > 57:
            return nil
        acc = acc * 10 + (b - 48)
        i = i + 1
    if neg:
        return Some(0 - acc)
    Some(acc)

fn ascii_upper(s: text) -> text:
    """Uppercase an ASCII command token."""
    s.to_upper()

# ============================================================================
# RESP reply encoding (server -> client) — returns RESP framing text
# ============================================================================

fn resp_status(s: text) -> text:
    """Encode a simple string reply: `+<s>\\r\\n`."""
    "+{s}\r\n"

fn resp_error(s: text) -> text:
    """Encode an error reply: `-<s>\\r\\n`."""
    "-{s}\r\n"

fn resp_integer(n: i64) -> text:
    """Encode an integer reply: `:<n>\\r\\n`."""
    ":{n}\r\n"

fn resp_bulk(s: text) -> text:
    """Encode a bulk string reply: `$<len>\\r\\n<s>\\r\\n`."""
    "${s.len()}\r\n{s}\r\n"

fn resp_nil() -> text:
    """Encode a null bulk string reply: `$-1\\r\\n`."""
    "$-1\r\n"

fn resp_empty_array() -> text:
    """Encode an empty array reply: `*0\\r\\n` (COMMAND handshake)."""
    "*0\r\n"

# ============================================================================
# SFFI
# ============================================================================

extern fn rt_io_tcp_read(fd: i64, size: i64) -> [u8]
extern fn rt_io_tcp_write_text(fd: i64, data: text) -> i64
extern fn rt_io_tcp_close(fd: i64) -> bool
extern fn rt_bytes_to_text(data: [u8]) -> text
extern fn rt_time_now_seconds() -> i64
