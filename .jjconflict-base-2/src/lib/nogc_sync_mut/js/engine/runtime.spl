# JS Runtime Native Dispatch
# Constants and dispatch for built-in JS runtime operations.

use std.js.types.js_types.JsValue
use std.js.engine.js_error.JsError

val NATIVE_FETCH = "fetch"
val NATIVE_SET_TIMEOUT = "setTimeout"
val NATIVE_SET_INTERVAL = "setInterval"
val NATIVE_CLEAR_TIMEOUT = "clearTimeout"
val NATIVE_CLEAR_INTERVAL = "clearInterval"
val NATIVE_JSON_PARSE = "JSON.parse"
val NATIVE_PROMISE_RESOLVE = "Promise.resolve"
val NATIVE_PROMISE_REJECT = "Promise.reject"
val NATIVE_PROMISE_THEN = "Promise.prototype.then"
val NATIVE_PROMISE_CATCH = "Promise.prototype.catch"
val NATIVE_PROMISE_FINALLY = "Promise.prototype.finally"
val NATIVE_RESPONSE_JSON = "Response.prototype.json"
val NATIVE_RESPONSE_TEXT = "Response.prototype.text"
val NATIVE_RESPONSE_BLOB = "Response.prototype.blob"
val NATIVE_BLOB_TEXT = "Blob.prototype.text"
val NATIVE_STORAGE_GET_ITEM = "localStorage.getItem"
val NATIVE_STORAGE_SET_ITEM = "localStorage.setItem"
val NATIVE_STORAGE_REMOVE_ITEM = "localStorage.removeItem"
val NATIVE_STORAGE_CLEAR = "localStorage.clear"
val NATIVE_STORAGE_KEY = "localStorage.key"
val NATIVE_NAVIGATOR_GPU_REQUEST_ADAPTER = "navigator.gpu.requestAdapter"

fn dispatch_native(name: text, args: [JsValue]) -> Result<JsValue, JsError>:
    Err(JsError(message: "native function '{name}' not implemented", name: "Error", stack: ""))
