struct WalRecordTable:
    entries: [WalRecordTableEntry]

impl WalRecordTable:
    static fn new() -> WalRecordTable:
        WalRecordTable(entries: [])

    fn _find_idx(lsn: i64) -> i32:
        var i: i32 = 0
        while i < self.entries.len() as i32:
            if self.entries[i].key.lsn == lsn:
                return i
            i = i + 1
        -1

    me fn insert(row: WalRecordRow) -> Result<i64, text>:
        self.entries.push(WalRecordTableEntry(key: WalRecordKey(lsn: row.lsn), row: row))
        Ok(row.lsn)

    fn get(key: WalRecordKey) -> Result<WalRecordRow, text>:
        val idx = self._find_idx(key.lsn)
        if idx >= 0:
            return Ok(self.entries[idx].row)
        Err("schema: WAL_RECORD not found")

struct StorageClassTable:
    entries: [StorageClassTableEntry]

impl StorageClassTable:
    static fn new() -> StorageClassTable:
        # Pre-populate with the 6 static rows
        val entries: [StorageClassTableEntry] = [
            StorageClassTableEntry(key: StorageClassKey(class_id: 0), row: StorageClassRow(class_id: 0, backend_kind: 0, hints: "META_DURABLE")),
            StorageClassTableEntry(key: StorageClassKey(class_id: 1), row: StorageClassRow(class_id: 1, backend_kind: 1, hints: "DB_WAL")),
            StorageClassTableEntry(key: StorageClassKey(class_id: 2), row: StorageClassRow(class_id: 2, backend_kind: 2, hints: "DB_TEMP")),
            StorageClassTableEntry(key: StorageClassKey(class_id: 3), row: StorageClassRow(class_id: 3, backend_kind: 3, hints: "MODEL_IMMUTABLE")),
            StorageClassTableEntry(key: StorageClassKey(class_id: 4), row: StorageClassRow(class_id: 4, backend_kind: 4, hints: "GENERAL_MUTABLE")),
            StorageClassTableEntry(key: StorageClassKey(class_id: 5), row: StorageClassRow(class_id: 5, backend_kind: 5, hints: "CHECKPOINT_SNAPSHOT"))
        ]
        StorageClassTable(entries: entries)

    fn _find_idx(id: i64) -> i32:
        var i: i32 = 0
        while i < self.entries.len() as i32:
            if self.entries[i].key.class_id == id:
                return i
            i = i + 1
        -1

    me fn insert(row: StorageClassRow) -> Result<i64, text>:
        val idx = self._find_idx(row.class_id)
        if idx >= 0:
            self.entries[idx].row = row
            return Ok(row.class_id)
        self.entries.push(StorageClassTableEntry(key: StorageClassKey(class_id: row.class_id), row: row))
        Ok(row.class_id)

    fn get(key: StorageClassKey) -> Result<StorageClassRow, text>:
        val idx = self._find_idx(key.class_id)
        if idx >= 0:
            return Ok(self.entries[idx].row)
        Err("schema: STORAGE_CLASS not found")

    fn scan_all() -> Result<[StorageClassRow], text>:
        """Return all storage class rows."""
        var result: [StorageClassRow] = []
        for entry in self.entries:
            result.push(entry.row)
        Ok(result)

# ============================================================
# SchemaTable — facade that exposes all 11 typed tables
# ============================================================

struct SchemaTable:
    """Facade providing named constructors for all 11 D3 catalog tables.

    Usage:
        val tbl = SchemaTable.inode()
        tbl.insert(row).unwrap()
        val got = tbl.get(InodeKey(ino_id: 1)).unwrap()
    """
    _marker: u8   # ensures non-zero size

impl SchemaTable:
    static fn inode() -> InodeTable:
        InodeTable.new()

    static fn dentry() -> DentryTable:
        DentryTable.new()

    static fn file_version() -> FileVersionTable:
        FileVersionTable.new()

    static fn extent_ref() -> ExtentRefTable:
        ExtentRefTable.new()

    static fn extent() -> ExtentTable:
        ExtentTable.new()

    static fn block_blob() -> BlockBlobTable:
        BlockBlobTable.new()

    static fn xattr() -> XattrTable:
        XattrTable.new()

    static fn acl_entry() -> AclEntryTable:
        AclEntryTable.new()

    static fn txn() -> TxnTable:
        TxnTable.new()

    static fn wal_record() -> WalRecordTable:
        WalRecordTable.new()

    static fn storage_class() -> StorageClassTable:
        StorageClassTable.new()
