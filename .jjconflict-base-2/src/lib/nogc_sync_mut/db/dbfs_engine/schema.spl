        var i: i32 = 0
        while i < self.entries.len() as i32:
            if self.entries[i].key.txn_id == id:
                return i
            i = i + 1
        -1

    me fn insert(row: TxnRow) -> Result<i64, text>:
        val idx = self._find_idx(row.txn_id)
        if idx >= 0:
            self.entries[idx].row = row
            return Ok(row.txn_id)
        self.entries.push(TxnTableEntry(key: TxnKey(txn_id: row.txn_id), row: row))
        Ok(row.txn_id)

    fn get(key: TxnKey) -> Result<TxnRow, text>:
        val idx = self._find_idx(key.txn_id)
        if idx >= 0:
