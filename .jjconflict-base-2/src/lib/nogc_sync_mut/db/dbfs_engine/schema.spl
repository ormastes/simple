# DBFS Catalog Schema — all 11 D3 tables.
#
# Each table has a Key struct, a Row struct, and a SchemaTable<Row, Key>
# that provides insert() / get() backed by an in-memory list (pager
# integration deferred to Phase 6 per MDSOC staging).
#
# Key shapes (D3, locked):
#   INODE:         InodeKey(ino_id)
#   DENTRY:        DentryKey(parent_ino, name: text)   ← text key, NOT name_hash
#   FILE_VERSION:  FileVersionKey(ino_id, gen)
#   EXTENT_REF:    ExtentRefKey(ino_id, gen, logical_offset)
#   EXTENT:        ExtentKey(extent_id)
#   BLOCK_BLOB:    BlockBlobKey(blob_id)
#   XATTR:         XattrKey(ino_id, name)
#   ACL_ENTRY:     AclEntryKey(ino_id, principal)
#   TXN:           TxnKey(txn_id)
#   WAL_RECORD:    WalRecordKey(lsn)
#   STORAGE_CLASS: StorageClassKey(class_id)
#
# Maps to: AC-3, AC-10, AC-9, D3.

use std.io_runtime
use std.db.accel.{
    accel_capability_report,
    RowBitmap, ScanPredicate, ScanPredicateKind,
    make_key_span, row_bitmap_indices, scan_key_span,
    summary_text_hash, text_starts_with_span
}

# ============================================================
# INODE
# ============================================================

struct InodeKey:
    ino_id: i64

struct InodeRow:
    ino_id:     i64
    gen:        i64
    mode:       u32
    uid:        u32
    gid:        u32
    link_count: i64
    size:       i64
    mtime:      i64
    ctime:      i64
    flags:      u32

# ============================================================
# DENTRY
# ============================================================

struct DentryKey:
    parent_ino: i64
    name:       text

struct DentryRow:
    parent_ino: i64
    name:       text
    child_ino:  i64
    gen:        i64

# ============================================================
# FILE_VERSION
# ============================================================

struct FileVersionKey:
    ino_id: i64
    gen:    i64

struct FileVersionRow:
    ino_id:          i64
    gen:             i64
    root_extent_ref: i64
    version_flags:   u32

# ============================================================
# EXTENT_REF
# ============================================================

struct ExtentRefKey:
    ino_id:         i64
    gen:            i64
    logical_offset: i64

struct ExtentRefRow:
    ino_id:         i64
    gen:            i64
    logical_offset: i64
    length:         i64
    extent_id:      i64

# ============================================================
# EXTENT
# ============================================================

struct ExtentKey:
    extent_id: i64

struct ExtentRow:
    extent_id:     i64
    blob_id:       i64
    offset_in_blob: i64
    length:        i64
    checksum:      u64
    compression:   u8
    birth_gen:     i64
    storage_class: i64

# ============================================================
# BLOCK_BLOB
# ============================================================

struct BlockBlobKey:
    blob_id: i64

struct BlockBlobRow:
    blob_id:      i64
    backend:      i64
    backend_addr: i64
    length:       i64

# ============================================================
# XATTR
# ============================================================

struct XattrKey:
    ino_id: i64
    name:   text

struct XattrRow:
    ino_id: i64
    name:   text
    value:  text

# ============================================================
# ACL_ENTRY
# ============================================================

struct AclEntryKey:
    ino_id:    i64
    principal: text

struct AclEntryRow:
    ino_id:    i64
    principal: text
    perms:     u32
    allow_deny: u8

# ============================================================
# TXN
# ============================================================

struct TxnKey:
    txn_id: i64

struct TxnRow:
    txn_id:    i64
    status:    u8
    lsn_first: i64
    lsn_last:  i64

# ============================================================
# WAL_RECORD
# ============================================================

struct WalRecordKey:
    lsn: i64

struct WalRecordRow:
    lsn:         i64
    txn_id:      i64
    record_type: i64
    payload:     text

# ============================================================
# STORAGE_CLASS
# ============================================================

struct StorageClassKey:
    class_id: i64

struct StorageClassRow:
    class_id:     i64
    backend_kind: i64
    hints:        text

# ============================================================
# Generic SchemaTable — in-memory backing for all tables
# ============================================================

struct InodeTableEntry:
    key: InodeKey
    row: InodeRow

struct DentryTableEntry:
    key: DentryKey
    row: DentryRow

struct FileVersionTableEntry:
    key: FileVersionKey
    row: FileVersionRow

struct ExtentRefTableEntry:
    key: ExtentRefKey
    row: ExtentRefRow

struct ExtentTableEntry:
    key: ExtentKey
    row: ExtentRow

struct BlockBlobTableEntry:
    key: BlockBlobKey
    row: BlockBlobRow

struct XattrTableEntry:
    key: XattrKey
    row: XattrRow

struct AclEntryTableEntry:
    key: AclEntryKey
    row: AclEntryRow

struct TxnTableEntry:
    key: TxnKey
    row: TxnRow

struct WalRecordTableEntry:
    key: WalRecordKey
    row: WalRecordRow

struct StorageClassTableEntry:
    key: StorageClassKey
    row: StorageClassRow

# --- Typed table implementations ---

struct InodeTable:
    entries: [InodeTableEntry]
    next_id: i64

impl InodeTable:
    static fn new() -> InodeTable:
        InodeTable(entries: [], next_id: 1)

    fn _find_idx(id: i64) -> i32:
        var i: i32 = 0
        while i < self.entries.len() as i32:
            if self.entries[i].key.ino_id == id:
                return i
            i = i + 1
        -1

    me fn insert(row: InodeRow) -> Result<i64, text>:
        val idx = self._find_idx(row.ino_id)
        if idx >= 0:
            self.entries[idx].row = row
            return Ok(row.ino_id)
        val key = InodeKey(ino_id: row.ino_id)
        self.entries.push(InodeTableEntry(key: key, row: row))
        Ok(row.ino_id)

    fn get(key: InodeKey) -> Result<InodeRow, text>:
        val idx = self._find_idx(key.ino_id)
        if idx >= 0:
            return Ok(self.entries[idx].row)
        Err("schema: INODE not found")

struct DentryTable:
    entries: [DentryTableEntry]

impl DentryTable:
    static fn new() -> DentryTable:
        DentryTable(entries: [])

    me fn insert(row: DentryRow) -> Result<i64, text>:
        var i: i32 = 0
        while i < self.entries.len() as i32:
            if (self.entries[i].key.parent_ino == row.parent_ino and
                self.entries[i].key.name == row.name):
                self.entries[i].row = row
                return Ok(row.child_ino)
            i = i + 1
        val key = DentryKey(parent_ino: row.parent_ino, name: row.name)
        self.entries.push(DentryTableEntry(key: key, row: row))
        Ok(row.child_ino)

    fn get(key: DentryKey) -> Result<DentryRow, text>:
        var i: i32 = 0
        while i < self.entries.len() as i32:
            if (self.entries[i].key.parent_ino == key.parent_ino and
                self.entries[i].key.name == key.name):
                return Ok(self.entries[i].row)
            i = i + 1
        Err("schema: DENTRY not found")

    fn list_children(parent_ino: i64) -> [DentryRow]:
        var result: [DentryRow] = []
        var i: i32 = 0
        while i < self.entries.len() as i32:
            if self.entries[i].key.parent_ino == parent_ino:
                result.push(self.entries[i].row)
            i = i + 1
        result

    fn find_child_accel(parent_ino: i64, name: text) -> Result<DentryRow, text>:
        if not accel_capability_report().simd_active:
            var j: i32 = 0
            while j < self.entries.len() as i32:
                val entry = self.entries[j]
                if entry.key.parent_ino == parent_ino and entry.key.name == name:
                    return Ok(entry.row)
                j = j + 1
            return Err("schema: DENTRY not found")
        var candidates: [DentryRow] = []
        var summary_hashes: [i64] = []
        var i: i32 = 0
        while i < self.entries.len() as i32:
            val entry = self.entries[i]
            if entry.key.parent_ino == parent_ino:
                candidates.push(entry.row)
                summary_hashes.push(summary_text_hash(entry.key.name))
            i = i + 1

        val target_hash = summary_text_hash(name)
        val predicate = ScanPredicate(
            kind: ScanPredicateKind.Eq,
            text_value: "",
            key_value: target_hash
        )
        val (bitmap, _) = scan_key_span(make_key_span(summary_hashes, 0, summary_hashes.len()), predicate)
        for idx in row_bitmap_indices(bitmap):
            val row = candidates[idx]
            if row.name == name:
                return Ok(row)
        Err("schema: DENTRY not found")

    fn list_children_with_prefix(parent_ino: i64, prefix: text) -> [DentryRow]:
        if not accel_capability_report().simd_active:
            var fast_result: [DentryRow] = []
            var j: i32 = 0
            while j < self.entries.len() as i32:
                val entry = self.entries[j]
                if entry.key.parent_ino == parent_ino and text_starts_with_span(entry.key.name, prefix):
                    fast_result.push(entry.row)
                j = j + 1
            return fast_result
        var result: [DentryRow] = []
        var candidates: [DentryRow] = []
        var prefix_hashes: [i64] = []
        var i: i32 = 0
        while i < self.entries.len() as i32:
            val entry = self.entries[i]
            if entry.key.parent_ino == parent_ino:
                candidates.push(entry.row)
                val prefix_match = if text_starts_with_span(entry.key.name, prefix): 1 else: 0
                prefix_hashes.push(prefix_match)
            i = i + 1

        val predicate = ScanPredicate(
            kind: ScanPredicateKind.Eq,
            text_value: "",
            key_value: 1
        )
        val (bitmap, _) = scan_key_span(make_key_span(prefix_hashes, 0, prefix_hashes.len()), predicate)
        for idx in row_bitmap_indices(bitmap):
            result.push(candidates[idx])
        result

    me fn remove(key: DentryKey) -> Result<(), text>:
        var idx: i32 = -1
        var i: i32 = 0
        while i < self.entries.len() as i32:
            if (self.entries[i].key.parent_ino == key.parent_ino and
                self.entries[i].key.name == key.name):
                idx = i
            i = i + 1
        if idx < 0:
            return Err("schema: DENTRY not found for remove")
        self.entries.remove(idx)
        Ok(())

struct FileVersionTable:
    entries: [FileVersionTableEntry]

impl FileVersionTable:
    static fn new() -> FileVersionTable:
        FileVersionTable(entries: [])

    me fn insert(row: FileVersionRow) -> Result<i64, text>:
        val key = FileVersionKey(ino_id: row.ino_id, gen: row.gen)
        self.entries.push(FileVersionTableEntry(key: key, row: row))
        Ok(row.ino_id)

    fn get(key: FileVersionKey) -> Result<FileVersionRow, text>:
        var i: i32 = 0
        while i < self.entries.len() as i32:
            if (self.entries[i].key.ino_id == key.ino_id and
                self.entries[i].key.gen == key.gen):
                return Ok(self.entries[i].row)
            i = i + 1
        Err("schema: FILE_VERSION not found")

struct ExtentRefTable:
    entries: [ExtentRefTableEntry]

impl ExtentRefTable:
    static fn new() -> ExtentRefTable:
        ExtentRefTable(entries: [])

    me fn insert(row: ExtentRefRow) -> Result<i64, text>:
        val key = ExtentRefKey(ino_id: row.ino_id, gen: row.gen, logical_offset: row.logical_offset)
        # Replace if same key exists
        var i: i32 = 0
        while i < self.entries.len() as i32:
            if (self.entries[i].key.ino_id == key.ino_id and
                self.entries[i].key.gen == key.gen and
                self.entries[i].key.logical_offset == key.logical_offset):
                self.entries[i].row = row
                return Ok(row.extent_id)
            i = i + 1
        self.entries.push(ExtentRefTableEntry(key: key, row: row))
        Ok(row.extent_id)

    fn get(key: ExtentRefKey) -> Result<ExtentRefRow, text>:
        var i: i32 = 0
        while i < self.entries.len() as i32:
            if (self.entries[i].key.ino_id == key.ino_id and
                self.entries[i].key.gen == key.gen and
                self.entries[i].key.logical_offset == key.logical_offset):
                return Ok(self.entries[i].row)
            i = i + 1
        Err("schema: EXTENT_REF not found")

struct ExtentTable:
    entries: [ExtentTableEntry]

impl ExtentTable:
    static fn new() -> ExtentTable:
        ExtentTable(entries: [])

    fn _find_idx(id: i64) -> i32:
        var i: i32 = 0
        while i < self.entries.len() as i32:
            if self.entries[i].key.extent_id == id:
                return i
            i = i + 1
        -1

    me fn insert(row: ExtentRow) -> Result<i64, text>:
        self.entries.push(ExtentTableEntry(key: ExtentKey(extent_id: row.extent_id), row: row))
        Ok(row.extent_id)

    fn get(key: ExtentKey) -> Result<ExtentRow, text>:
        val idx = self._find_idx(key.extent_id)
        if idx >= 0:
            return Ok(self.entries[idx].row)
        Err("schema: EXTENT not found")

