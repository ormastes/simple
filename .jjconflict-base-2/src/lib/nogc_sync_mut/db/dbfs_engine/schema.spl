struct XattrTable:
    entries: [XattrTableEntry]

impl XattrTable:
    static fn new() -> XattrTable:
        XattrTable(entries: [])

    me fn insert(row: XattrRow) -> Result<i64, text>:
        val key = XattrKey(ino_id: row.ino_id, name: row.name)
        var i: i32 = 0
        while i < self.entries.len() as i32:
            if (self.entries[i].key.ino_id == key.ino_id and
                self.entries[i].key.name == key.name):
                self.entries[i].row = row
                return Ok(0)
            i = i + 1
        self.entries.push(XattrTableEntry(key: key, row: row))
        Ok(0)

    fn get(key: XattrKey) -> Result<XattrRow, text>:
        var i: i32 = 0
        while i < self.entries.len() as i32:
            if (self.entries[i].key.ino_id == key.ino_id and
                self.entries[i].key.name == key.name):
                return Ok(self.entries[i].row)
            i = i + 1
        Err("schema: XATTR not found")

struct AclEntryTable:
    entries: [AclEntryTableEntry]

impl AclEntryTable:
    static fn new() -> AclEntryTable:
        AclEntryTable(entries: [])

    me fn insert(row: AclEntryRow) -> Result<i64, text>:
        val key = AclEntryKey(ino_id: row.ino_id, principal: row.principal)
        var i: i32 = 0
        while i < self.entries.len() as i32:
            if (self.entries[i].key.ino_id == key.ino_id and
                self.entries[i].key.principal == key.principal):
                self.entries[i].row = row
                return Ok(0)
            i = i + 1
        self.entries.push(AclEntryTableEntry(key: key, row: row))
        Ok(0)

    fn get(key: AclEntryKey) -> Result<AclEntryRow, text>:
        var i: i32 = 0
        while i < self.entries.len() as i32:
            if (self.entries[i].key.ino_id == key.ino_id and
                self.entries[i].key.principal == key.principal):
                return Ok(self.entries[i].row)
            i = i + 1
        Err("schema: ACL_ENTRY not found")

