extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_delete(path: text) -> bool

class BrowserScriptExecutionResult:
    scripts_collected: i64
    scripts_executed: i64
    console_output: [text]

impl BrowserScriptExecutionResult:
    static fn empty() -> BrowserScriptExecutionResult:
        var co: [text] = []
        BrowserScriptExecutionResult(scripts_collected: 0, scripts_executed: 0, console_output: co)

fn _extract_attr(tag_text: text, attr: text) -> text:
    val key_dq = attr + "=\""
    val key_sq = attr + "='"
    val lo = tag_text.lower()
    val idx_dq = lo.index_of(key_dq)
    val idx_sq = lo.index_of(key_sq)
    if idx_dq >= 0:
        val start = idx_dq + key_dq.len()
        val end = tag_text.index_of("\"", start)
        if end > start:
            return tag_text.substring(start, end)
    if idx_sq >= 0:
        val start = idx_sq + key_sq.len()
        val end = tag_text.index_of("'", start)
        if end > start:
            return tag_text.substring(start, end)
    ""

fn _script_type_is_simple(script_type: text) -> bool:
    script_type == "" or script_type == "text/simple"

fn _normalize_script_body(body: text) -> text:
    val normalized = body.replace("const ", "val ").trim()
    if normalized.len() == 0:
        return "fn main():"
    "fn main():\n    " + normalized.replace("\n", "\n    ")

fn _run_script_source(source: text) -> (bool, text):
    val tmp = "/tmp/browser_script_exec_tmp.spl"
    rt_file_write_text(tmp, _normalize_script_body(source))
    var out = ""
    var err = ""
    var rc: i64 = 0
    (out, err, rc) = rt_process_run("bin/simple", [tmp])
    rt_file_delete(tmp)
    (rc == 0, out)

fn _append_lines(out: [text], s: text):
    val trimmed = s.trim()
    if trimmed.len() > 0:
        out.push(trimmed)

fn execute_scripts_in_html(html: text) -> BrowserScriptExecutionResult:
    var result = BrowserScriptExecutionResult.empty()
    val lo = html.lower()
    var search_pos: i64 = 0
    while search_pos < html.len():
        val tag_open = lo.index_of("<script", search_pos)
        if tag_open < 0:
            return result
        val tag_close = html.index_of(">", tag_open)
        if tag_close < 0:
            return result
        val close_idx = lo.index_of("</script>", tag_close + 1)
        if close_idx < 0:
            return result
        val open_tag = html.substring(tag_open, tag_close + 1)
        val script_type = _extract_attr(open_tag, "type")
        val src_attr = _extract_attr(open_tag, "src")
        if src_attr == "" and _script_type_is_simple(script_type):
            val body = html.substring(tag_close + 1, close_idx)
            result.scripts_collected = result.scripts_collected + 1
            val (ok, stdout) = _run_script_source(body)
            if ok:
                result.scripts_executed = result.scripts_executed + 1
            _append_lines(result.console_output, stdout)
        search_pos = close_idx + 9
    result
