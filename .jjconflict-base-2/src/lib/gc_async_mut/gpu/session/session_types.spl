"""session_types — BackendSessionHandle, BackendSessionPolicy, and BackendSessionError.

Defines the core session identity and policy types for the graphics managed backend.
No externs. All constructors are static fns returning new instances (interpreter-safe).
"""

use std.io

# ---------------------------------------------------------------------------
# BackendSessionHandle — opaque session identity
# ---------------------------------------------------------------------------

class BackendSessionHandle:
    """Opaque handle representing an active graphics backend session."""

    id: i64
    kind: text
    mode: text
    device_name: text
    api_name: text
    target_arch: text
    target_bits: i64
    owner_thread_id: i64
    generation: i64
    valid: bool

    static fn invalid() -> BackendSessionHandle:
        return BackendSessionHandle(
            id: -1,
            kind: "",
            mode: "",
            device_name: "",
            api_name: "",
            target_arch: "",
            target_bits: 64,
            owner_thread_id: 0,
            generation: 0,
            valid: false
        )

    static fn create(id: i64, kind: text, mode: text) -> BackendSessionHandle:
        return BackendSessionHandle(
            id: id,
            kind: kind,
            mode: mode,
            device_name: kind + "-device",
            api_name: kind,
            target_arch: "x86_64",
            target_bits: 64,
            owner_thread_id: 1,
            generation: 1,
            valid: true
        )

    static fn with_arch(id: i64, kind: text, mode: text, arch: text, bits: i64) -> BackendSessionHandle:
        return BackendSessionHandle(
            id: id,
            kind: kind,
            mode: mode,
            device_name: kind + "-device",
            api_name: kind,
            target_arch: arch,
            target_bits: bits,
            owner_thread_id: 1,
            generation: 1,
            valid: true
        )

    static fn increment_generation(h: BackendSessionHandle) -> BackendSessionHandle:
        return BackendSessionHandle(
            id: h.id,
            kind: h.kind,
            mode: h.mode,
            device_name: h.device_name,
            api_name: h.api_name,
            target_arch: h.target_arch,
            target_bits: h.target_bits,
            owner_thread_id: h.owner_thread_id,
            generation: h.generation + 1,
            valid: h.valid
        )

    static fn is_valid(h: BackendSessionHandle) -> bool:
        return h.valid and h.id >= 0

# ---------------------------------------------------------------------------
# BackendSessionPolicy — configuration for session creation
# ---------------------------------------------------------------------------

class BackendSessionPolicy:
    """Configuration record controlling how a session is created and managed."""

    mode: text
    allow_fallback: bool
    strict_backend: bool
    allow_readback: bool
    allow_interop_present: bool
    thread_policy: text
    queue_policy: text
    allocator_policy: text
    perf_counters_enabled: bool
    cpu_features: text

    static fn default_managed() -> BackendSessionPolicy:
        return BackendSessionPolicy(
            mode: "managed_shared",
            allow_fallback: true,
            strict_backend: false,
            allow_readback: false,
            allow_interop_present: false,
            thread_policy: "shared",
            queue_policy: "default",
            allocator_policy: "default",
            perf_counters_enabled: false,
            cpu_features: ""
        )

    static fn perf_exclusive() -> BackendSessionPolicy:
        return BackendSessionPolicy(
            mode: "perf_exclusive",
            allow_fallback: false,
            strict_backend: true,
            allow_readback: true,
            allow_interop_present: false,
            thread_policy: "exclusive",
            queue_policy: "dedicated",
            allocator_policy: "exclusive",
            perf_counters_enabled: true,
            cpu_features: ""
        )

    static fn legacy_no_session() -> BackendSessionPolicy:
        return BackendSessionPolicy(
            mode: "legacy_no_session",
            allow_fallback: true,
            strict_backend: false,
            allow_readback: false,
            allow_interop_present: false,
            thread_policy: "none",
            queue_policy: "none",
            allocator_policy: "none",
            perf_counters_enabled: false,
            cpu_features: ""
        )

    static fn is_perf_mode(p: BackendSessionPolicy) -> bool:
        return p.mode == "perf_exclusive"

    static fn is_managed_mode(p: BackendSessionPolicy) -> bool:
        return p.mode == "managed_shared"

    static fn is_legacy_mode(p: BackendSessionPolicy) -> bool:
        return p.mode == "legacy_no_session"

# ---------------------------------------------------------------------------
# BackendSessionError — typed error for session operations
# ---------------------------------------------------------------------------

class BackendSessionError:
    """Error value returned from session API calls on failure."""

    code: text
    message: text
    session_id: i64
    has_error: bool

    static fn none() -> BackendSessionError:
        return BackendSessionError(code: "", message: "", session_id: -1, has_error: false)

    static fn mode_conflict(msg: text) -> BackendSessionError:
        return BackendSessionError(code: "MODE_CONFLICT", message: msg, session_id: -1, has_error: true)

    static fn invalid_handle(msg: text) -> BackendSessionError:
        return BackendSessionError(code: "INVALID_HANDLE", message: msg, session_id: -1, has_error: true)

    static fn backend_unavailable(kind: text) -> BackendSessionError:
        val msg = "Backend unavailable: " + kind
        return BackendSessionError(code: "BACKEND_UNAVAILABLE", message: msg, session_id: -1, has_error: true)

    static fn is_error(e: BackendSessionError) -> bool:
        return e.has_error

    static fn to_text(e: BackendSessionError) -> text:
        if e.has_error == false:
            return "ok"
        return "[SessionError:" + e.code + "] " + e.message
