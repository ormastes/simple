# BLAKE3 hash implementation per the BLAKE3 specification.
# Provides blake3_bytes (bytes -> 32-byte list) and blake3_text (text -> hex).
#
# Scope: single-chunk input only (up to 64 bytes — one block).
#        Data > 64 bytes is out of scope.
#
# BLAKE3 uses 32-bit words stored as i64. Additions masked with & 4294967295.
# No _wadd64 needed for 32-bit arithmetic.
# Array parameters cannot be mutated (W1006). All state uses scalar var locals.

# ---------------------------------------------------------------------------
# BLAKE3 domain separation flags
# ---------------------------------------------------------------------------

val _B3_CHUNK_START: i64 = 1
val _B3_CHUNK_END: i64   = 2
val _B3_ROOT: i64        = 8

# ---------------------------------------------------------------------------
# rotr32: rotate right a 32-bit value stored in i64.
# Uses (x & 4294967295) >> n for logical shift (avoids sign-extension).
# ---------------------------------------------------------------------------

fn _rotr32(x: i64, n: i64) -> i64:
    val xm = x & 4294967295
    ((xm >> n) | ((xm << (32 - n)) & 4294967295)) & 4294967295

# ---------------------------------------------------------------------------
# Pack 4 bytes starting at byte_off from data (length data_len) into a
# little-endian 32-bit word. Zero-pads if past end of data.
# ---------------------------------------------------------------------------

fn _pack_b3_le32(data: [i64], byte_off: i64, data_len: i64) -> i64:
    val b0: i64 = if byte_off   < data_len: data[byte_off]   & 255 else: 0
    val b1: i64 = if byte_off+1 < data_len: data[byte_off+1] & 255 else: 0
    val b2: i64 = if byte_off+2 < data_len: data[byte_off+2] & 255 else: 0
    val b3: i64 = if byte_off+3 < data_len: data[byte_off+3] & 255 else: 0
    (b0 | (b1 << 8) | (b2 << 16) | (b3 << 24)) & 4294967295

# ---------------------------------------------------------------------------
# BLAKE3 single-block compress.
# Inlines all 7 rounds with MSG_PERMUTATION applied between rounds.
# chaining_value: cv0..cv7 (8 x 32-bit words as i64)
# m0..m15: 16 message words (32-bit each)
# counter: 0 for root
# block_len: number of valid bytes in the block
# flags: CHUNK_START | CHUNK_END | ROOT for single-block root hash
# Returns (out0..out7): 8 output words = lower half XOR upper half of state
# ---------------------------------------------------------------------------

fn _b3_compress(
    cv0: i64, cv1: i64, cv2: i64, cv3: i64,
    cv4: i64, cv5: i64, cv6: i64, cv7: i64,
    mi0: i64, mi1: i64, mi2: i64, mi3: i64,
    mi4: i64, mi5: i64, mi6: i64, mi7: i64,
    mi8: i64, mi9: i64, mi10: i64, mi11: i64,
    mi12: i64, mi13: i64, mi14: i64, mi15: i64,
    counter: i64, block_len: i64, flags: i64
) -> [i64]:
    # BLAKE3 IV = SHA-256 IV
    val iv0: i64 = 1779033703    # 0x6A09E667
    val iv1: i64 = -1150833019   # 0xBB67AE85
    val iv2: i64 = 1013904242    # 0x3C6EF372
    val iv3: i64 = -1521486534   # 0xA54FF53A

    # Initialize 4x4 state
    var s0  = cv0 & 4294967295
    var s1  = cv1 & 4294967295
    var s2  = cv2 & 4294967295
    var s3  = cv3 & 4294967295
    var s4  = cv4 & 4294967295
    var s5  = cv5 & 4294967295
    var s6  = cv6 & 4294967295
    var s7  = cv7 & 4294967295
    var s8  = iv0 & 4294967295
    var s9  = iv1 & 4294967295
    var s10 = iv2 & 4294967295
    var s11 = iv3 & 4294967295
    var s12 = counter & 4294967295
    var s13: i64 = 0
    var s14 = block_len & 4294967295
    var s15 = flags & 4294967295

    # Message words for current round (permuted between rounds)
    var m0  = mi0
    var m1  = mi1
    var m2  = mi2
    var m3  = mi3
    var m4  = mi4
    var m5  = mi5
    var m6  = mi6
    var m7  = mi7
    var m8  = mi8
    var m9  = mi9
    var m10 = mi10
    var m11 = mi11
    var m12 = mi12
    var m13 = mi13
    var m14 = mi14
    var m15 = mi15

    # MSG_PERMUTATION = [2,6,3,10,7,0,4,13,1,11,12,5,9,14,15,8]
    # Applied after each round except the last.

    # Round 0
    # Column step
    s0 = (s0 + s4 + m0) & 4294967295
    s12 = _rotr32(s12 ^ s0, 16)
    s8 = (s8 + s12) & 4294967295
    s4 = _rotr32(s4 ^ s8, 12)
    s0 = (s0 + s4 + m1) & 4294967295
    s12 = _rotr32(s12 ^ s0, 8)
    s8 = (s8 + s12) & 4294967295
    s4 = _rotr32(s4 ^ s8, 7)
    s1 = (s1 + s5 + m2) & 4294967295
    s13 = _rotr32(s13 ^ s1, 16)
    s9 = (s9 + s13) & 4294967295
    s5 = _rotr32(s5 ^ s9, 12)
    s1 = (s1 + s5 + m3) & 4294967295
    s13 = _rotr32(s13 ^ s1, 8)
    s9 = (s9 + s13) & 4294967295
    s5 = _rotr32(s5 ^ s9, 7)
    s2 = (s2 + s6 + m4) & 4294967295
    s14 = _rotr32(s14 ^ s2, 16)
    s10 = (s10 + s14) & 4294967295
    s6 = _rotr32(s6 ^ s10, 12)
    s2 = (s2 + s6 + m5) & 4294967295
    s14 = _rotr32(s14 ^ s2, 8)
    s10 = (s10 + s14) & 4294967295
    s6 = _rotr32(s6 ^ s10, 7)
    s3 = (s3 + s7 + m6) & 4294967295
    s15 = _rotr32(s15 ^ s3, 16)
    s11 = (s11 + s15) & 4294967295
    s7 = _rotr32(s7 ^ s11, 12)
    s3 = (s3 + s7 + m7) & 4294967295
    s15 = _rotr32(s15 ^ s3, 8)
    s11 = (s11 + s15) & 4294967295
    s7 = _rotr32(s7 ^ s11, 7)
    # Diagonal step
    s0 = (s0 + s5 + m8) & 4294967295
    s15 = _rotr32(s15 ^ s0, 16)
    s10 = (s10 + s15) & 4294967295
    s5 = _rotr32(s5 ^ s10, 12)
    s0 = (s0 + s5 + m9) & 4294967295
    s15 = _rotr32(s15 ^ s0, 8)
    s10 = (s10 + s15) & 4294967295
    s5 = _rotr32(s5 ^ s10, 7)
    s1 = (s1 + s6 + m10) & 4294967295
    s12 = _rotr32(s12 ^ s1, 16)
    s11 = (s11 + s12) & 4294967295
    s6 = _rotr32(s6 ^ s11, 12)
    s1 = (s1 + s6 + m11) & 4294967295
    s12 = _rotr32(s12 ^ s1, 8)
    s11 = (s11 + s12) & 4294967295
    s6 = _rotr32(s6 ^ s11, 7)
    s2 = (s2 + s7 + m12) & 4294967295
    s13 = _rotr32(s13 ^ s2, 16)
    s8 = (s8 + s13) & 4294967295
    s7 = _rotr32(s7 ^ s8, 12)
    s2 = (s2 + s7 + m13) & 4294967295
    s13 = _rotr32(s13 ^ s2, 8)
    s8 = (s8 + s13) & 4294967295
    s7 = _rotr32(s7 ^ s8, 7)
    s3 = (s3 + s4 + m14) & 4294967295
    s14 = _rotr32(s14 ^ s3, 16)
    s9 = (s9 + s14) & 4294967295
    s4 = _rotr32(s4 ^ s9, 12)
    s3 = (s3 + s4 + m15) & 4294967295
    s14 = _rotr32(s14 ^ s3, 8)
    s9 = (s9 + s14) & 4294967295
    s4 = _rotr32(s4 ^ s9, 7)

    # Permute message — perm: [2,6,3,10,7,0,4,13,1,11,12,5,9,14,15,8]
    val p0=m2
    val p1=m6
    val p2=m3
    val p3=m10
    val p4=m7
    val p5=m0
    val p6=m4
    val p7=m13
    val p8=m1
    val p9=m11
    val p10=m12
    val p11=m5
    val p12=m9
    val p13=m14
    val p14=m15
    val p15=m8
    m0=p0
    m1=p1
    m2=p2
    m3=p3
    m4=p4
    m5=p5
    m6=p6
    m7=p7
    m8=p8
    m9=p9
    m10=p10
    m11=p11
    m12=p12
    m13=p13
    m14=p14
    m15=p15

    # Round 1
    s0 = (s0 + s4 + m0) & 4294967295
    s12 = _rotr32(s12 ^ s0, 16)
    s8 = (s8 + s12) & 4294967295
    s4 = _rotr32(s4 ^ s8, 12)
    s0 = (s0 + s4 + m1) & 4294967295
    s12 = _rotr32(s12 ^ s0, 8)
    s8 = (s8 + s12) & 4294967295
    s4 = _rotr32(s4 ^ s8, 7)
    s1 = (s1 + s5 + m2) & 4294967295
    s13 = _rotr32(s13 ^ s1, 16)
    s9 = (s9 + s13) & 4294967295
    s5 = _rotr32(s5 ^ s9, 12)
    s1 = (s1 + s5 + m3) & 4294967295
    s13 = _rotr32(s13 ^ s1, 8)
    s9 = (s9 + s13) & 4294967295
    s5 = _rotr32(s5 ^ s9, 7)
    s2 = (s2 + s6 + m4) & 4294967295
    s14 = _rotr32(s14 ^ s2, 16)
    s10 = (s10 + s14) & 4294967295
    s6 = _rotr32(s6 ^ s10, 12)
    s2 = (s2 + s6 + m5) & 4294967295
    s14 = _rotr32(s14 ^ s2, 8)
    s10 = (s10 + s14) & 4294967295
    s6 = _rotr32(s6 ^ s10, 7)
    s3 = (s3 + s7 + m6) & 4294967295
    s15 = _rotr32(s15 ^ s3, 16)
    s11 = (s11 + s15) & 4294967295
    s7 = _rotr32(s7 ^ s11, 12)
    s3 = (s3 + s7 + m7) & 4294967295
    s15 = _rotr32(s15 ^ s3, 8)
    s11 = (s11 + s15) & 4294967295
    s7 = _rotr32(s7 ^ s11, 7)
    s0 = (s0 + s5 + m8) & 4294967295
    s15 = _rotr32(s15 ^ s0, 16)
    s10 = (s10 + s15) & 4294967295
    s5 = _rotr32(s5 ^ s10, 12)
    s0 = (s0 + s5 + m9) & 4294967295
    s15 = _rotr32(s15 ^ s0, 8)
    s10 = (s10 + s15) & 4294967295
    s5 = _rotr32(s5 ^ s10, 7)
    s1 = (s1 + s6 + m10) & 4294967295
    s12 = _rotr32(s12 ^ s1, 16)
    s11 = (s11 + s12) & 4294967295
    s6 = _rotr32(s6 ^ s11, 12)
    s1 = (s1 + s6 + m11) & 4294967295
    s12 = _rotr32(s12 ^ s1, 8)
    s11 = (s11 + s12) & 4294967295
    s6 = _rotr32(s6 ^ s11, 7)
    s2 = (s2 + s7 + m12) & 4294967295
    s13 = _rotr32(s13 ^ s2, 16)
    s8 = (s8 + s13) & 4294967295
    s7 = _rotr32(s7 ^ s8, 12)
    s2 = (s2 + s7 + m13) & 4294967295
    s13 = _rotr32(s13 ^ s2, 8)
    s8 = (s8 + s13) & 4294967295
    s7 = _rotr32(s7 ^ s8, 7)
    s3 = (s3 + s4 + m14) & 4294967295
    s14 = _rotr32(s14 ^ s3, 16)
    s9 = (s9 + s14) & 4294967295
    s4 = _rotr32(s4 ^ s9, 12)
    s3 = (s3 + s4 + m15) & 4294967295
    s14 = _rotr32(s14 ^ s3, 8)
    s9 = (s9 + s14) & 4294967295
    s4 = _rotr32(s4 ^ s9, 7)

    # Permute message
    val q0=m2
    val q1=m6
    val q2=m3
    val q3=m10
    val q4=m7
    val q5=m0
    val q6=m4
    val q7=m13
    val q8=m1
    val q9=m11
    val q10=m12
    val q11=m5
    val q12=m9
    val q13=m14
    val q14=m15
    val q15=m8
    m0=q0
    m1=q1
    m2=q2
    m3=q3
    m4=q4
    m5=q5
    m6=q6
    m7=q7
    m8=q8
    m9=q9
    m10=q10
    m11=q11
    m12=q12
    m13=q13
    m14=q14
    m15=q15

    # Round 2
    s0 = (s0 + s4 + m0) & 4294967295
    s12 = _rotr32(s12 ^ s0, 16)
    s8 = (s8 + s12) & 4294967295
    s4 = _rotr32(s4 ^ s8, 12)
    s0 = (s0 + s4 + m1) & 4294967295
    s12 = _rotr32(s12 ^ s0, 8)
    s8 = (s8 + s12) & 4294967295
    s4 = _rotr32(s4 ^ s8, 7)
    s1 = (s1 + s5 + m2) & 4294967295
    s13 = _rotr32(s13 ^ s1, 16)
    s9 = (s9 + s13) & 4294967295
    s5 = _rotr32(s5 ^ s9, 12)
    s1 = (s1 + s5 + m3) & 4294967295
    s13 = _rotr32(s13 ^ s1, 8)
    s9 = (s9 + s13) & 4294967295
    s5 = _rotr32(s5 ^ s9, 7)
    s2 = (s2 + s6 + m4) & 4294967295
    s14 = _rotr32(s14 ^ s2, 16)
    s10 = (s10 + s14) & 4294967295
    s6 = _rotr32(s6 ^ s10, 12)
    s2 = (s2 + s6 + m5) & 4294967295
    s14 = _rotr32(s14 ^ s2, 8)
    s10 = (s10 + s14) & 4294967295
    s6 = _rotr32(s6 ^ s10, 7)
    s3 = (s3 + s7 + m6) & 4294967295
    s15 = _rotr32(s15 ^ s3, 16)
    s11 = (s11 + s15) & 4294967295
    s7 = _rotr32(s7 ^ s11, 12)
    s3 = (s3 + s7 + m7) & 4294967295
    s15 = _rotr32(s15 ^ s3, 8)
    s11 = (s11 + s15) & 4294967295
    s7 = _rotr32(s7 ^ s11, 7)
    s0 = (s0 + s5 + m8) & 4294967295
    s15 = _rotr32(s15 ^ s0, 16)
    s10 = (s10 + s15) & 4294967295
    s5 = _rotr32(s5 ^ s10, 12)
    s0 = (s0 + s5 + m9) & 4294967295
    s15 = _rotr32(s15 ^ s0, 8)
    s10 = (s10 + s15) & 4294967295
    s5 = _rotr32(s5 ^ s10, 7)
    s1 = (s1 + s6 + m10) & 4294967295
    s12 = _rotr32(s12 ^ s1, 16)
    s11 = (s11 + s12) & 4294967295
    s6 = _rotr32(s6 ^ s11, 12)
    s1 = (s1 + s6 + m11) & 4294967295
    s12 = _rotr32(s12 ^ s1, 8)
    s11 = (s11 + s12) & 4294967295
    s6 = _rotr32(s6 ^ s11, 7)
    s2 = (s2 + s7 + m12) & 4294967295
    s13 = _rotr32(s13 ^ s2, 16)
    s8 = (s8 + s13) & 4294967295
    s7 = _rotr32(s7 ^ s8, 12)
    s2 = (s2 + s7 + m13) & 4294967295
    s13 = _rotr32(s13 ^ s2, 8)
    s8 = (s8 + s13) & 4294967295
    s7 = _rotr32(s7 ^ s8, 7)
    s3 = (s3 + s4 + m14) & 4294967295
    s14 = _rotr32(s14 ^ s3, 16)
    s9 = (s9 + s14) & 4294967295
    s4 = _rotr32(s4 ^ s9, 12)
    s3 = (s3 + s4 + m15) & 4294967295
    s14 = _rotr32(s14 ^ s3, 8)
    s9 = (s9 + s14) & 4294967295
    s4 = _rotr32(s4 ^ s9, 7)

    # Permute message
    val r0=m2
    val r1=m6
    val r2=m3
    val r3=m10
    val r4=m7
    val r5=m0
    val r6=m4
    val r7=m13
    val r8=m1
    val r9=m11
    val r10=m12
    val r11=m5
    val r12=m9
    val r13=m14
    val r14=m15
    val r15=m8
    m0=r0
    m1=r1
    m2=r2
    m3=r3
    m4=r4
    m5=r5
    m6=r6
    m7=r7
    m8=r8
    m9=r9
    m10=r10
    m11=r11
    m12=r12
    m13=r13
    m14=r14
    m15=r15

    # Round 3
    s0 = (s0 + s4 + m0) & 4294967295
    s12 = _rotr32(s12 ^ s0, 16)
    s8 = (s8 + s12) & 4294967295
    s4 = _rotr32(s4 ^ s8, 12)
    s0 = (s0 + s4 + m1) & 4294967295
    s12 = _rotr32(s12 ^ s0, 8)
    s8 = (s8 + s12) & 4294967295
    s4 = _rotr32(s4 ^ s8, 7)
    s1 = (s1 + s5 + m2) & 4294967295
    s13 = _rotr32(s13 ^ s1, 16)
    s9 = (s9 + s13) & 4294967295
    s5 = _rotr32(s5 ^ s9, 12)
    s1 = (s1 + s5 + m3) & 4294967295
    s13 = _rotr32(s13 ^ s1, 8)
    s9 = (s9 + s13) & 4294967295
    s5 = _rotr32(s5 ^ s9, 7)
    s2 = (s2 + s6 + m4) & 4294967295
    s14 = _rotr32(s14 ^ s2, 16)
    s10 = (s10 + s14) & 4294967295
    s6 = _rotr32(s6 ^ s10, 12)
    s2 = (s2 + s6 + m5) & 4294967295
    s14 = _rotr32(s14 ^ s2, 8)
    s10 = (s10 + s14) & 4294967295
    s6 = _rotr32(s6 ^ s10, 7)
    s3 = (s3 + s7 + m6) & 4294967295
    s15 = _rotr32(s15 ^ s3, 16)
    s11 = (s11 + s15) & 4294967295
    s7 = _rotr32(s7 ^ s11, 12)
    s3 = (s3 + s7 + m7) & 4294967295
    s15 = _rotr32(s15 ^ s3, 8)
    s11 = (s11 + s15) & 4294967295
    s7 = _rotr32(s7 ^ s11, 7)
    s0 = (s0 + s5 + m8) & 4294967295
    s15 = _rotr32(s15 ^ s0, 16)
    s10 = (s10 + s15) & 4294967295
    s5 = _rotr32(s5 ^ s10, 12)
    s0 = (s0 + s5 + m9) & 4294967295
    s15 = _rotr32(s15 ^ s0, 8)
    s10 = (s10 + s15) & 4294967295
    s5 = _rotr32(s5 ^ s10, 7)
    s1 = (s1 + s6 + m10) & 4294967295
    s12 = _rotr32(s12 ^ s1, 16)
    s11 = (s11 + s12) & 4294967295
    s6 = _rotr32(s6 ^ s11, 12)
    s1 = (s1 + s6 + m11) & 4294967295
    s12 = _rotr32(s12 ^ s1, 8)
    s11 = (s11 + s12) & 4294967295
    s6 = _rotr32(s6 ^ s11, 7)
    s2 = (s2 + s7 + m12) & 4294967295
    s13 = _rotr32(s13 ^ s2, 16)
    s8 = (s8 + s13) & 4294967295
    s7 = _rotr32(s7 ^ s8, 12)
    s2 = (s2 + s7 + m13) & 4294967295
    s13 = _rotr32(s13 ^ s2, 8)
    s8 = (s8 + s13) & 4294967295
    s7 = _rotr32(s7 ^ s8, 7)
    s3 = (s3 + s4 + m14) & 4294967295
    s14 = _rotr32(s14 ^ s3, 16)
    s9 = (s9 + s14) & 4294967295
    s4 = _rotr32(s4 ^ s9, 12)
    s3 = (s3 + s4 + m15) & 4294967295
    s14 = _rotr32(s14 ^ s3, 8)
    s9 = (s9 + s14) & 4294967295
    s4 = _rotr32(s4 ^ s9, 7)

    # Permute message
    val t0=m2
    val t1=m6
    val t2=m3
    val t3=m10
    val t4=m7
    val t5=m0
    val t6=m4
    val t7=m13
    val t8=m1
    val t9=m11
    val t10=m12
    val t11=m5
    val t12=m9
    val t13=m14
    val t14=m15
    val t15=m8
    m0=t0
    m1=t1
    m2=t2
    m3=t3
    m4=t4
    m5=t5
    m6=t6
    m7=t7
    m8=t8
    m9=t9
    m10=t10
    m11=t11
    m12=t12
    m13=t13
    m14=t14
    m15=t15

    # Round 4
    s0 = (s0 + s4 + m0) & 4294967295
    s12 = _rotr32(s12 ^ s0, 16)
    s8 = (s8 + s12) & 4294967295
    s4 = _rotr32(s4 ^ s8, 12)
    s0 = (s0 + s4 + m1) & 4294967295
    s12 = _rotr32(s12 ^ s0, 8)
    s8 = (s8 + s12) & 4294967295
    s4 = _rotr32(s4 ^ s8, 7)
    s1 = (s1 + s5 + m2) & 4294967295
    s13 = _rotr32(s13 ^ s1, 16)
    s9 = (s9 + s13) & 4294967295
    s5 = _rotr32(s5 ^ s9, 12)
    s1 = (s1 + s5 + m3) & 4294967295
    s13 = _rotr32(s13 ^ s1, 8)
    s9 = (s9 + s13) & 4294967295
    s5 = _rotr32(s5 ^ s9, 7)
    s2 = (s2 + s6 + m4) & 4294967295
    s14 = _rotr32(s14 ^ s2, 16)
    s10 = (s10 + s14) & 4294967295
    s6 = _rotr32(s6 ^ s10, 12)
    s2 = (s2 + s6 + m5) & 4294967295
    s14 = _rotr32(s14 ^ s2, 8)
    s10 = (s10 + s14) & 4294967295
    s6 = _rotr32(s6 ^ s10, 7)
    s3 = (s3 + s7 + m6) & 4294967295
    s15 = _rotr32(s15 ^ s3, 16)
    s11 = (s11 + s15) & 4294967295
    s7 = _rotr32(s7 ^ s11, 12)
    s3 = (s3 + s7 + m7) & 4294967295
    s15 = _rotr32(s15 ^ s3, 8)
    s11 = (s11 + s15) & 4294967295
    s7 = _rotr32(s7 ^ s11, 7)
    s0 = (s0 + s5 + m8) & 4294967295
    s15 = _rotr32(s15 ^ s0, 16)
    s10 = (s10 + s15) & 4294967295
    s5 = _rotr32(s5 ^ s10, 12)
    s0 = (s0 + s5 + m9) & 4294967295
    s15 = _rotr32(s15 ^ s0, 8)
    s10 = (s10 + s15) & 4294967295
    s5 = _rotr32(s5 ^ s10, 7)
    s1 = (s1 + s6 + m10) & 4294967295
    s12 = _rotr32(s12 ^ s1, 16)
    s11 = (s11 + s12) & 4294967295
    s6 = _rotr32(s6 ^ s11, 12)
    s1 = (s1 + s6 + m11) & 4294967295
    s12 = _rotr32(s12 ^ s1, 8)
    s11 = (s11 + s12) & 4294967295
    s6 = _rotr32(s6 ^ s11, 7)
    s2 = (s2 + s7 + m12) & 4294967295
    s13 = _rotr32(s13 ^ s2, 16)
    s8 = (s8 + s13) & 4294967295
    s7 = _rotr32(s7 ^ s8, 12)
    s2 = (s2 + s7 + m13) & 4294967295
    s13 = _rotr32(s13 ^ s2, 8)
    s8 = (s8 + s13) & 4294967295
    s7 = _rotr32(s7 ^ s8, 7)
    s3 = (s3 + s4 + m14) & 4294967295
    s14 = _rotr32(s14 ^ s3, 16)
    s9 = (s9 + s14) & 4294967295
    s4 = _rotr32(s4 ^ s9, 12)
    s3 = (s3 + s4 + m15) & 4294967295
    s14 = _rotr32(s14 ^ s3, 8)
    s9 = (s9 + s14) & 4294967295
    s4 = _rotr32(s4 ^ s9, 7)

    # Permute message
    val u0=m2
    val u1=m6
    val u2=m3
    val u3=m10
    val u4=m7
    val u5=m0
    val u6=m4
    val u7=m13
    val u8=m1
    val u9=m11
    val u10=m12
    val u11=m5
    val u12=m9
    val u13=m14
    val u14=m15
    val u15=m8
    m0=u0
    m1=u1
    m2=u2
    m3=u3
    m4=u4
    m5=u5
    m6=u6
    m7=u7
    m8=u8
    m9=u9
    m10=u10
    m11=u11
    m12=u12
    m13=u13
    m14=u14
    m15=u15

    # Round 5
    s0 = (s0 + s4 + m0) & 4294967295
    s12 = _rotr32(s12 ^ s0, 16)
    s8 = (s8 + s12) & 4294967295
    s4 = _rotr32(s4 ^ s8, 12)
    s0 = (s0 + s4 + m1) & 4294967295
    s12 = _rotr32(s12 ^ s0, 8)
    s8 = (s8 + s12) & 4294967295
    s4 = _rotr32(s4 ^ s8, 7)
    s1 = (s1 + s5 + m2) & 4294967295
    s13 = _rotr32(s13 ^ s1, 16)
    s9 = (s9 + s13) & 4294967295
    s5 = _rotr32(s5 ^ s9, 12)
    s1 = (s1 + s5 + m3) & 4294967295
    s13 = _rotr32(s13 ^ s1, 8)
    s9 = (s9 + s13) & 4294967295
    s5 = _rotr32(s5 ^ s9, 7)
    s2 = (s2 + s6 + m4) & 4294967295
    s14 = _rotr32(s14 ^ s2, 16)
    s10 = (s10 + s14) & 4294967295
    s6 = _rotr32(s6 ^ s10, 12)
    s2 = (s2 + s6 + m5) & 4294967295
    s14 = _rotr32(s14 ^ s2, 8)
    s10 = (s10 + s14) & 4294967295
    s6 = _rotr32(s6 ^ s10, 7)
    s3 = (s3 + s7 + m6) & 4294967295
    s15 = _rotr32(s15 ^ s3, 16)
    s11 = (s11 + s15) & 4294967295
    s7 = _rotr32(s7 ^ s11, 12)
    s3 = (s3 + s7 + m7) & 4294967295
    s15 = _rotr32(s15 ^ s3, 8)
    s11 = (s11 + s15) & 4294967295
    s7 = _rotr32(s7 ^ s11, 7)
    s0 = (s0 + s5 + m8) & 4294967295
    s15 = _rotr32(s15 ^ s0, 16)
    s10 = (s10 + s15) & 4294967295
    s5 = _rotr32(s5 ^ s10, 12)
    s0 = (s0 + s5 + m9) & 4294967295
    s15 = _rotr32(s15 ^ s0, 8)
    s10 = (s10 + s15) & 4294967295
    s5 = _rotr32(s5 ^ s10, 7)
    s1 = (s1 + s6 + m10) & 4294967295
    s12 = _rotr32(s12 ^ s1, 16)
    s11 = (s11 + s12) & 4294967295
    s6 = _rotr32(s6 ^ s11, 12)
    s1 = (s1 + s6 + m11) & 4294967295
    s12 = _rotr32(s12 ^ s1, 8)
    s11 = (s11 + s12) & 4294967295
    s6 = _rotr32(s6 ^ s11, 7)
    s2 = (s2 + s7 + m12) & 4294967295
    s13 = _rotr32(s13 ^ s2, 16)
    s8 = (s8 + s13) & 4294967295
    s7 = _rotr32(s7 ^ s8, 12)
    s2 = (s2 + s7 + m13) & 4294967295
    s13 = _rotr32(s13 ^ s2, 8)
    s8 = (s8 + s13) & 4294967295
    s7 = _rotr32(s7 ^ s8, 7)
    s3 = (s3 + s4 + m14) & 4294967295
    s14 = _rotr32(s14 ^ s3, 16)
    s9 = (s9 + s14) & 4294967295
    s4 = _rotr32(s4 ^ s9, 12)
    s3 = (s3 + s4 + m15) & 4294967295
    s14 = _rotr32(s14 ^ s3, 8)
    s9 = (s9 + s14) & 4294967295
    s4 = _rotr32(s4 ^ s9, 7)

    # Permute message
    val w0=m2
    val w1=m6
    val w2=m3
    val w3=m10
    val w4=m7
    val w5=m0
    val w6=m4
    val w7=m13
    val w8=m1
    val w9=m11
    val w10=m12
    val w11=m5
    val w12=m9
    val w13=m14
    val w14=m15
    val w15=m8
    m0=w0
    m1=w1
    m2=w2
    m3=w3
    m4=w4
    m5=w5
    m6=w6
    m7=w7
    m8=w8
    m9=w9
    m10=w10
    m11=w11
    m12=w12
    m13=w13
    m14=w14
    m15=w15

    # Round 6 (last — no permutation after)
    s0 = (s0 + s4 + m0) & 4294967295
    s12 = _rotr32(s12 ^ s0, 16)
    s8 = (s8 + s12) & 4294967295
    s4 = _rotr32(s4 ^ s8, 12)
    s0 = (s0 + s4 + m1) & 4294967295
    s12 = _rotr32(s12 ^ s0, 8)
    s8 = (s8 + s12) & 4294967295
    s4 = _rotr32(s4 ^ s8, 7)
    s1 = (s1 + s5 + m2) & 4294967295
    s13 = _rotr32(s13 ^ s1, 16)
    s9 = (s9 + s13) & 4294967295
    s5 = _rotr32(s5 ^ s9, 12)
    s1 = (s1 + s5 + m3) & 4294967295
    s13 = _rotr32(s13 ^ s1, 8)
    s9 = (s9 + s13) & 4294967295
    s5 = _rotr32(s5 ^ s9, 7)
    s2 = (s2 + s6 + m4) & 4294967295
    s14 = _rotr32(s14 ^ s2, 16)
    s10 = (s10 + s14) & 4294967295
    s6 = _rotr32(s6 ^ s10, 12)
    s2 = (s2 + s6 + m5) & 4294967295
    s14 = _rotr32(s14 ^ s2, 8)
    s10 = (s10 + s14) & 4294967295
    s6 = _rotr32(s6 ^ s10, 7)
    s3 = (s3 + s7 + m6) & 4294967295
    s15 = _rotr32(s15 ^ s3, 16)
    s11 = (s11 + s15) & 4294967295
    s7 = _rotr32(s7 ^ s11, 12)
    s3 = (s3 + s7 + m7) & 4294967295
    s15 = _rotr32(s15 ^ s3, 8)
    s11 = (s11 + s15) & 4294967295
    s7 = _rotr32(s7 ^ s11, 7)
    s0 = (s0 + s5 + m8) & 4294967295
    s15 = _rotr32(s15 ^ s0, 16)
    s10 = (s10 + s15) & 4294967295
    s5 = _rotr32(s5 ^ s10, 12)
    s0 = (s0 + s5 + m9) & 4294967295
    s15 = _rotr32(s15 ^ s0, 8)
    s10 = (s10 + s15) & 4294967295
    s5 = _rotr32(s5 ^ s10, 7)
    s1 = (s1 + s6 + m10) & 4294967295
    s12 = _rotr32(s12 ^ s1, 16)
    s11 = (s11 + s12) & 4294967295
    s6 = _rotr32(s6 ^ s11, 12)
    s1 = (s1 + s6 + m11) & 4294967295
    s12 = _rotr32(s12 ^ s1, 8)
    s11 = (s11 + s12) & 4294967295
    s6 = _rotr32(s6 ^ s11, 7)
    s2 = (s2 + s7 + m12) & 4294967295
    s13 = _rotr32(s13 ^ s2, 16)
    s8 = (s8 + s13) & 4294967295
    s7 = _rotr32(s7 ^ s8, 12)
    s2 = (s2 + s7 + m13) & 4294967295
    s13 = _rotr32(s13 ^ s2, 8)
    s8 = (s8 + s13) & 4294967295
    s7 = _rotr32(s7 ^ s8, 7)
    s3 = (s3 + s4 + m14) & 4294967295
    s14 = _rotr32(s14 ^ s3, 16)
    s9 = (s9 + s14) & 4294967295
    s4 = _rotr32(s4 ^ s9, 12)
    s3 = (s3 + s4 + m15) & 4294967295
    s14 = _rotr32(s14 ^ s3, 8)
    s9 = (s9 + s14) & 4294967295
    s4 = _rotr32(s4 ^ s9, 7)

    # Output: v[i] ^ v[i+8] for i in 0..7
    [
        (s0  ^ s8)  & 4294967295,
        (s1  ^ s9)  & 4294967295,
        (s2  ^ s10) & 4294967295,
        (s3  ^ s11) & 4294967295,
        (s4  ^ s12) & 4294967295,
        (s5  ^ s13) & 4294967295,
        (s6  ^ s14) & 4294967295,
        (s7  ^ s15) & 4294967295
    ]

# ---------------------------------------------------------------------------
# BLAKE3 hash for single-block input (up to 64 bytes).
# Returns: 32-byte output as [i64].
# ---------------------------------------------------------------------------

fn _blake3_core(data: [i64]) -> [i64]:
    # BLAKE3 IV = SHA-256 IV
    val iv0: i64 = 1779033703    # 0x6A09E667
    val iv1: i64 = -1150833019   # 0xBB67AE85
    val iv2: i64 = 1013904242    # 0x3C6EF372
    val iv3: i64 = -1521486534   # 0xA54FF53A
    val iv4: i64 = 1359893119    # 0x510E527F
    val iv5: i64 = -1694144372   # 0x9B05688C
    val iv6: i64 = 528734635     # 0x1F83D9AB
    val iv7: i64 = 1541459225    # 0x5BE0CD19

    val data_len = data.len()
    val flags: i64 = _B3_CHUNK_START | _B3_CHUNK_END | _B3_ROOT

    # Pack 16 message words (zero-pad if data < 64 bytes)
    val mi0  = _pack_b3_le32(data,  0, data_len)
    val mi1  = _pack_b3_le32(data,  4, data_len)
    val mi2  = _pack_b3_le32(data,  8, data_len)
    val mi3  = _pack_b3_le32(data, 12, data_len)
    val mi4  = _pack_b3_le32(data, 16, data_len)
    val mi5  = _pack_b3_le32(data, 20, data_len)
    val mi6  = _pack_b3_le32(data, 24, data_len)
    val mi7  = _pack_b3_le32(data, 28, data_len)
    val mi8  = _pack_b3_le32(data, 32, data_len)
    val mi9  = _pack_b3_le32(data, 36, data_len)
    val mi10 = _pack_b3_le32(data, 40, data_len)
    val mi11 = _pack_b3_le32(data, 44, data_len)
    val mi12 = _pack_b3_le32(data, 48, data_len)
    val mi13 = _pack_b3_le32(data, 52, data_len)
    val mi14 = _pack_b3_le32(data, 56, data_len)
    val mi15 = _pack_b3_le32(data, 60, data_len)

    val out = _b3_compress(
        iv0, iv1, iv2, iv3, iv4, iv5, iv6, iv7,
        mi0, mi1, mi2, mi3, mi4, mi5, mi6, mi7,
        mi8, mi9, mi10, mi11, mi12, mi13, mi14, mi15,
        0, data_len, flags
    )

    # Serialize output: 8 words as little-endian 32-bit each
    var result: [i64] = []
    var ri = 0
    while ri < 8:
        val wd = out[ri] & 4294967295
        result.push(wd & 255)
        result.push((wd >> 8) & 255)
        result.push((wd >> 16) & 255)
        result.push((wd >> 24) & 255)
        ri = ri + 1
    result

# ---------------------------------------------------------------------------
# Public API
# ---------------------------------------------------------------------------

# BLAKE3 of a byte list. Returns 32-byte list.
# Supports data up to 64 bytes (single block).
fn blake3_bytes(data: [i64]) -> [i64]:
    _blake3_core(data)

# BLAKE3 of text input. Returns 64-char lowercase hex string.
fn blake3_text(data: text) -> text:
    use std.common.crypto.types.{text_to_bytes, bytes_to_hex}
    bytes_to_hex(blake3_bytes(text_to_bytes(data)))
