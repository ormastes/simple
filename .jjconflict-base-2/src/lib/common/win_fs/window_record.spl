# Window Record — per-window metadata stored in the /win FS tree.
#
# Provides: WindowState, Rect, BufferRef, WindowRecord, window_mark_destroyed.

enum WindowState:
    Normal
    Minimized
    Maximized
    Destroyed

struct Rect:
    x: i32
    y: i32
    w: u32
    h: u32

struct BufferRef:
    kind: text
    handle: u64
    bytes: u64

class WindowRecord:
    wid: u64
    generation: u32
    app: text
    title: text
    state: WindowState
    geometry: Rect
    buffer_ref: BufferRef
    acl_id_path: text

    static fn new(wid: u64, app: text, title: text) -> WindowRecord:
        WindowRecord(
            wid: wid,
            generation: 1 as u32,
            app: app,
            title: title,
            state: WindowState.Normal,
            geometry: Rect(x: 0 as i32, y: 0 as i32, w: 0 as u32, h: 0 as u32),
            buffer_ref: BufferRef(kind: "none", handle: 0 as u64, bytes: 0 as u64),
            acl_id_path: ""
        )

fn window_mark_destroyed(rec: WindowRecord) -> WindowRecord:
    WindowRecord(
        wid: rec.wid,
        generation: rec.generation,
        app: rec.app,
        title: rec.title,
        state: WindowState.Destroyed,
        geometry: rec.geometry,
        buffer_ref: rec.buffer_ref,
        acl_id_path: rec.acl_id_path
    )
