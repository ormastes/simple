use std.spec
use std.js.types.js_types.{JsValue}
use examples.browser.feature.script.web_api.fetch_binding.{
    js_response_blob, js_response_json, js_response_text,
    response_blob_size, response_blob_type
}

describe "Fetch binding":
    describe "Response methods":
        it "returns text response bodies":
            expect(js_response_text("hello")).to_equal(JsValue.String(v: "hello"))

        it "parses JSON string response bodies":
            val parsed = js_response_json("\"ok\"")
            match parsed:
                Ok(value): expect(value).to_equal(JsValue.String(v: "ok"))
                Err(e): expect(e.message).to_equal("")

        it "creates blob objects for response bodies":
            val blob = js_response_blob("abc")
            match blob:
                Ok(value):
                    expect(response_blob_size(value)).to_equal(3)
                    expect(response_blob_type(value)).to_equal("application/octet-stream")
                Err(e): expect(e.message).to_equal("")
