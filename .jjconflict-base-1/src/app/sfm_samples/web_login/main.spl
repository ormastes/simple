# AC-9: native entry driving the SFM web-login layer.
#
# Attempts a valid and an invalid login through the authz-gated auth layer and
# prints OK/FAIL for each.
# Run: bin/simple run src/app/sfm_samples/web_login/main.spl

use app.sfm_samples.web_login.login_sfm.{web_login_attempt}

fn ok(cond: bool, label: text):
    if cond:
        print("OK " + label)
    else:
        print("FAIL " + label)

fn main():
    match web_login_attempt("admin", "s3cret"):
        Ok(who): ok(who == "authenticated:admin", "valid login -> " + who)
        Err(e):  ok(false, "valid login rejected: " + e)

    match web_login_attempt("admin", "wrong"):
        Ok(who): ok(false, "invalid login accepted: " + who)
        Err(_):  ok(true, "invalid login denied")
