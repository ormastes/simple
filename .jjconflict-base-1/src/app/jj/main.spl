# JJ (Jujutsu) VCS Integration - Main entry point
#
# Provides built-in JJ version control operations for the Simple compiler CLI.
# Dispatches to submodules: status, commit, sync, log, diff
#
# Usage:
#   simple jj status              Show JJ status with structured output
#   simple jj commit "message"    Create new commit
#   simple jj describe "message"  Update working copy description
#   simple jj sync                Full sync workflow (fetch, rebase, push)
#   simple jj log                 Show commit log
#   simple jj diff                Show diff
#   simple jj diff --stat         Show diff statistics

use app.jj.status.{run_status}
use app.jj.commit.{run_commit}
use app.jj.sync.{run_sync}
use app.jj.log.{run_log}
use app.jj.diff.{run_diff}
use std.cli.log_modes.{parse_log_options, log_options_help, render_progress}
use std.log.{error}

extern fn rt_cli_get_args() -> [text]

fn main() -> i64:
    val raw_args = jj_get_args()
    val log_opts = parse_log_options(raw_args)
    if not log_opts.valid:
        error("jj", log_opts.error)
        return 1

    val args = jj_clean_args(raw_args)
    if args.len() == 0:
        if log_opts.log_mode == "json":
            print "{\"command\":\"jj\",\"status\":\"usage\"}"
            return 0
        val progress = render_progress(log_opts.progress, 0, 1, "usage")
        if progress != "":
            print progress
        print_jj_help()
        return 0

    if args[0] == "--help" or args[0] == "-h" or args[0] == "help":
        val progress = render_progress(log_opts.progress, 0, 1, "usage")
        if progress != "":
            print progress
        print_jj_help()
        return 0

    if log_opts.log_mode == "json" and not jj_is_known_subcommand(args[0]):
        print "{\"command\":\"jj\",\"status\":\"error\",\"error\":\"unknown command\"}"
        return 1

    handle_jj(args)

fn print_jj_help():
    print "Simple JJ (Jujutsu) VCS Integration"
    print ""
    print "Usage: simple jj <command> [args...]"
    print ""
    print "Commands:"
    print "  status                      Show working copy status"
    print "  commit \"message\"            Create new commit with message"
    print "  describe \"message\"          Update working copy description"
    print "  describe -r REV \"message\"   Update specific revision description"
    print "  sync                        Full sync: fetch, rebase, bookmark, push"
    print "  sync --no-push              Sync without pushing"
    print "  log                         Show commit log (last 10)"
    print "  log -n N                    Show last N commits"
    print "  log -r REVSET              Show specific revset"
    print "  diff                        Show working copy diff"
    print "  diff --stat                 Show diff statistics"
    print "  diff -r REV                 Show diff for specific revision"
    print ""
    print "File count safety:"
    print "  The sync command checks file counts before/after rebase."
    print "  If >20% of files are lost, it warns and aborts the push."
    print "  Use --force to override."
    print ""
    print "Shared log options:"
    for line in log_options_help():
        print "  {line}"

fn handle_jj(args: [text]) -> i64:
    """Main dispatcher for jj subcommands"""
    if args.len() == 0:
        print_jj_help()
        return 0

    val subcmd = args[0]
    val sub_args = if args.len() > 1: args[1:] else: []

    match subcmd:
        case "status" | "st":
            return run_status(sub_args)

        case "commit":
            # Prepend "commit" so run_commit knows the subcmd
            var commit_args = ["commit"]
            for a in sub_args:
                commit_args.push(a)
            return run_commit(commit_args)

        case "describe" | "desc":
            var desc_args = ["describe"]
            for a in sub_args:
                desc_args.push(a)
            return run_commit(desc_args)

        case "sync":
            return run_sync(sub_args)

        case "log":
            return run_log(sub_args)

        case "diff":
            return run_diff(sub_args)

        case "-h" | "--help" | "help":
            print_jj_help()
            return 0

        case _:
            print "Unknown jj command: {subcmd}"
            print ""
            print_jj_help()
            return 1

fn jj_is_known_subcommand(subcmd: text) -> bool:
    subcmd == "status" or subcmd == "st" or
        subcmd == "commit" or
        subcmd == "describe" or subcmd == "desc" or
        subcmd == "sync" or
        subcmd == "log" or
        subcmd == "diff" or
        subcmd == "-h" or subcmd == "--help" or subcmd == "help"

fn jj_is_log_option(arg: text) -> bool:
    arg == "--human" or arg == "--llm" or arg == "--json" or
        arg == "--tui" or arg == "--stdout" or arg == "--quiet" or
        arg == "--verbose" or arg == "--dots" or arg == "--count" or
        arg == "--no-progress" or arg == "--log-mode" or arg == "--surface" or
        arg == "--progress" or arg.starts_with("--log-mode=") or
        arg.starts_with("--surface=") or arg.starts_with("--progress=")

fn jj_clean_args(args: [text]) -> [text]:
    var cleaned: [text] = []
    var i = 0
    while i < args.len():
        val arg = args[i]
        if jj_is_log_option(arg):
            if arg == "--log-mode" or arg == "--surface" or arg == "--progress":
                i = i + 1
        else:
            cleaned.push(arg)
        i = i + 1
    cleaned

fn jj_get_args() -> [text]:
    val all_args = rt_cli_get_args()
    var args: [text] = []
    var found_jj = false
    var i = 0
    while i < all_args.len():
        if found_jj:
            args.push(all_args[i])
        elif all_args[i] == "jj":
            found_jj = true
        i = i + 1
    if found_jj:
        return args

    var start_idx = 0
    i = 0
    while i < all_args.len():
        if all_args[i].ends_with("main.spl"):
            start_idx = i + 1
        i = i + 1
    i = start_idx
    while i < all_args.len():
        args.push(all_args[i])
        i = i + 1
    args
