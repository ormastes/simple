# wm_compare Golden-Image Gate — Row 8 of GUI drawing-layer matrix
#
# Extends the Row 2 V1/V2 parity harness (`v1_v2_parity.spl`) with a
# golden-image drift detector:
#
#   * Render every parity scene through the V1 path (`render_v1`).
#   * Encode the buffer as PPM P6 (binary).
#   * On REGEN: write `test/sys/wm_compare/goldens/<scene>.ppm`.
#   * Otherwise: load the golden PPM, decode to ARGB, and compare to the
#     freshly rendered buffer using `diff_buffers`. Fail if any backend
#     drifts more than the ≤1 % perceptual budget locked in Row 2.
#
# The gate intentionally re-uses Row 2's `ParityScene`, `render_v1`, and
# `diff_buffers` — golden-image work is only the serialization layer on
# top. See doc/06_spec/app/compiler/feature/windows_spec.md (Golden-image
# gate subsection) for how to regenerate goldens.

use app.wm_compare.v1_v2_parity.{
    ParityScene, ParityResult, render_v1, render_v2, diff_buffers,
    scene_solid_fill, scene_fill_rect_row_edge, scene_text_with_bg, scene_glass_blend,
}

# ----------------------------------------------------------------------------
# Runtime FFI shims — same pattern as
# test/feature/compiler/linker/direct_elf_spec.spl: declare the rt_*
# externs locally so the spec stays self-contained and does not pull in
# the whole std.fs surface (which would require io_runtime in the
# interpreter).
# ----------------------------------------------------------------------------

extern fn rt_file_write_bytes(path: text, data: [u8]) -> bool
extern fn rt_file_read_bytes(path: text) -> [u8]
extern fn rt_file_exists(path: text) -> bool
extern fn rt_dir_create(path: text) -> bool
extern fn rt_env_get(key: text) -> text

# ----------------------------------------------------------------------------
# Public result type
# ----------------------------------------------------------------------------

struct GoldenGateResult:
    """Result of one golden-image gate check."""
    scene: text
    path: text
    regenerated: bool
    loaded_ok: bool
    diff: ParityResult        # only meaningful if loaded_ok
    pass_gate: bool           # diff.pass_perceptual && max_channel_delta tiny

struct DecodeCursor:
    """Result of consuming a decimal field from a PPM header: the parsed
    value and the byte index of the next unread byte. Mirrors the
    `ParseIntResult` shape used by `std.image.ppm_decode`."""
    value: u32
    next: u32

# ----------------------------------------------------------------------------
# PPM P6 writer — 30 lines, no std.image dependency
# ----------------------------------------------------------------------------

fn _u32_to_decimal(n: u32) -> [u8]:
    """Convert a u32 to ASCII decimal bytes. Used to build the PPM header
    without leaning on text formatting primitives the interpreter does
    not always evaluate inside `[u8]` literals."""
    if n == 0u32:
        return [48u8]
    var v = n
    var digits: [u8] = []
    while v > 0u32:
        val d = v % 10u32
        digits = [(48u32 + d).to_i32().to_u8()] + digits
        v = v / 10u32
    digits

fn encode_ppm_p6(width: u32, height: u32, pixels: [u32]) -> [u8]:
    """Serialize an ARGB8888 buffer as PPM P6 (binary).

    Header is `P6\\n{width} {height}\\n255\\n` followed by raw R,G,B
    bytes in row-major order. Alpha is intentionally dropped — the
    parity scenes always render fully opaque pixels and PPM has no
    alpha channel.
    """
    var out: [u8] = [80u8, 54u8, 10u8]              # "P6\n"
    out = out + _u32_to_decimal(width)
    out = out + [32u8]                              # ' '
    out = out + _u32_to_decimal(height)
    out = out + [10u8]                              # '\n'
    out = out + [50u8, 53u8, 53u8, 10u8]            # "255\n"
    val total = width * height
    var i: u32 = 0
    while i < total:
        val px = pixels[i]
        val r = ((px >> 16) & 0xFF).to_i32().to_u8()
        val g = ((px >> 8) & 0xFF).to_i32().to_u8()
        val b = (px & 0xFF).to_i32().to_u8()
        out = out + [r, g, b]
        i = i + 1
    out

# ----------------------------------------------------------------------------
# PPM P6 reader — minimal, only handles the headers we write ourselves.
# `std.image.ppm_decode` is more lenient (skips comments, validates
# maxval, etc.). The gate writes its own files so we trust the format.
# ----------------------------------------------------------------------------

fn _decimal_to_u32(data: [u8], start: u32) -> DecodeCursor:
    """Parse ASCII decimal from `data` starting at `start`. Returns the
    parsed value and the next-unread index. Stops at the first
    non-digit byte."""
    var i = start
    var v: u32 = 0
    val end = data.len().to_u32()
    while i < end:
        val c = data[i]
        if c < 48u8 or c > 57u8:
            return DecodeCursor(value: v, next: i)
        v = v * 10u32 + (c.to_u32() - 48u32)
        i = i + 1
    DecodeCursor(value: v, next: i)

fn decode_ppm_p6(data: [u8]) -> [u32]:
    """Decode a PPM P6 byte stream into an ARGB8888 [u32] buffer.
    Returns an empty array on malformed input — the caller treats that
    as a load failure and surfaces it via `GoldenGateResult.loaded_ok`."""
    if data.len() < 12:
        return []
    if data[0] != 80u8 or data[1] != 54u8:    # "P6"
        return []
    var pos: u32 = 3u32                       # skip "P6\n"
    val w_pair = _decimal_to_u32(data, pos)
    val w = w_pair.value
    pos = w_pair.next + 1u32                  # skip ' '
    val h_pair = _decimal_to_u32(data, pos)
    val h = h_pair.value
    pos = h_pair.next + 1u32                  # skip '\n'
    val mv_pair = _decimal_to_u32(data, pos)
    pos = mv_pair.next + 1u32                 # skip '\n' after maxval
    val total = w * h
    var out: [u32] = []
    var i: u32 = 0
    while i < total:
        val r = data[pos].to_u32()
        val g = data[pos + 1u32].to_u32()
        val b = data[pos + 2u32].to_u32()
        out = out + [0xFF000000u32 | (r << 16) | (g << 8) | b]
        pos = pos + 3u32
        i = i + 1
    out

# ----------------------------------------------------------------------------
# Gate runner
# ----------------------------------------------------------------------------

fn goldens_dir() -> text:
    "test/sys/wm_compare/goldens"

fn golden_path(scene_name: text) -> text:
    "{goldens_dir()}/{scene_name}.ppm"

fn should_regenerate() -> bool:
    """Honor the REGEN_GOLDENS env var. Setting it to anything non-empty
    rewrites every golden from the current V1 render output."""
    val v = rt_env_get("REGEN_GOLDENS") ?? ""
    v != ""

fn write_golden(scene: ParityScene) -> bool:
    """Render `scene` through V1 and serialize the buffer to disk."""
    val pixels = render_v1(scene)
    val bytes = encode_ppm_p6(width: scene.width, height: scene.height, pixels: pixels)
    rt_dir_create(goldens_dir())
    rt_file_write_bytes(golden_path(scene.name), bytes)

fn check_golden(scene: ParityScene) -> GoldenGateResult:
    """Render `scene` fresh, load the golden, diff. The gate passes if
    the perceptual delta is ≤1 % AND the max per-channel delta is ≤2 —
    i.e. drift detection, not perfect pixel comparison.

    If REGEN_GOLDENS is set, the golden is rewritten first and the
    result is reported as `regenerated=true, pass_gate=true` (we just
    wrote it, so it cannot drift from itself)."""
    val path = golden_path(scene.name)
    if should_regenerate():
        write_golden(scene)
        val fresh = render_v1(scene)
        val self_diff = diff_buffers(scene.name, scene.width, scene.height, fresh, fresh)
        return GoldenGateResult(
            scene: scene.name, path: path,
            regenerated: true, loaded_ok: true,
            diff: self_diff, pass_gate: true
        )
    if not rt_file_exists(path):
        # Surface as load failure — caller's expect() will fire.
        val empty: [u32] = []
        val placeholder = diff_buffers(scene.name, scene.width, scene.height, empty, empty)
        return GoldenGateResult(
            scene: scene.name, path: path,
            regenerated: false, loaded_ok: false,
            diff: placeholder, pass_gate: false
        )
    val raw = rt_file_read_bytes(path) ?? []
    val golden = decode_ppm_p6(raw)
    val fresh = render_v1(scene)
    if golden.len() != fresh.len():
        val placeholder = diff_buffers(scene.name, scene.width, scene.height, fresh, fresh)
        return GoldenGateResult(
            scene: scene.name, path: path,
            regenerated: false, loaded_ok: false,
            diff: placeholder, pass_gate: false
        )
    val d = diff_buffers(scene.name, scene.width, scene.height, golden, fresh)
    val gate_ok = d.pass_perceptual and (d.max_channel_delta <= 2u32)
    GoldenGateResult(
        scene: scene.name, path: path,
        regenerated: false, loaded_ok: true,
        diff: d, pass_gate: gate_ok
    )

fn all_gate_scenes() -> [ParityScene]:
    """Same set Row 2 locks — keeps the gate aligned with the parity
    runner so a Row 2 regression and a Row 8 regression surface
    together."""
    [scene_solid_fill(), scene_fill_rect_row_edge(), scene_text_with_bg(), scene_glass_blend()]
