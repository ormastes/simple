use app.simple_portal.server.{SimplePortalServer}
use app.simple_portal.content_db.{simple_portal_default_app_root, simple_portal_default_data_root}

extern fn rt_env_get(key: text) -> text

fn _port() -> i32:
    val env = rt_env_get("SIMPLE_PORTAL_PORT")
    if env == "":
        return 4040
    env.to_i32() ?? 4040

fn _token() -> text:
    val env = rt_env_get("SIMPLE_PORTAL_RUN_TOKEN")
    if env != "":
        return env
    "simple-portal-dev-token"

fn main():
    val server_result = SimplePortalServer.new(
        _port(),
        simple_portal_default_app_root(),
        simple_portal_default_data_root(),
        _token()
    )
    match server_result:
        Err(e):
            print "simple_portal bootstrap failed: {e}"
        Ok(server):
            server.start()
