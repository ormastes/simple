"""
# sj client-facing translation helpers
"""

use std.io_runtime

struct TranslationPlan:
    classification: text
    lease_kind: i64
    commands: [text]
    warning: text

fn _tail(argv: [text], start: i64) -> [text]:
    var out: [text] = []
    var i = start
    while i < argv.len():
        out.push(argv[i])
        i = i + 1i64
    out

fn _join(argv: [text]) -> text:
    argv.join(" ")

fn _direct(command: text, lease_kind: i64) -> TranslationPlan:
    TranslationPlan(classification: "direct_jj", lease_kind: lease_kind, commands: [command], warning: "")

fn _raw(command: text, lease_kind: i64, warning: text) -> TranslationPlan:
    TranslationPlan(classification: "raw_passthrough", lease_kind: lease_kind, commands: [command], warning: warning)

fn translate(argv: [text]) -> TranslationPlan:
    if argv.len() == 0i64:
        return _direct("jj", 1i64)
    if argv[0i64] == "raw" and argv.len() > 2i64:
        val lease_kind = if argv[1i64] == "jj":
            1i64
        else:
            0i64
        return _raw(_join(_tail(argv, 1i64)), lease_kind, "")
    if argv[0i64] != "git":
        return _direct("jj " + _join(argv), 0i64)

    val verb = argv[1i64]
    if verb == "status":
        return _direct("jj status", 1i64)
    if verb == "log":
        return _direct("jj " + _join(_tail(argv, 1i64)), 1i64)
    if verb == "diff":
        return _direct("jj diff", 1i64)
    if verb == "blame" and argv.len() > 2i64:
        return _direct("jj file annotate " + _join(_tail(argv, 2i64)), 1i64)
    if verb == "branch" and argv.len() > 2i64 and argv[2i64] == "--list":
        return _direct("jj bookmark list", 1i64)
    if verb == "checkout" and argv.len() > 2i64 and argv[2i64] != "-b":
        return _direct("jj new " + _join(_tail(argv, 2i64)), 0i64)
    if verb == "checkout" and argv.len() > 3i64 and argv[2i64] == "-b":
        val branch = argv[3i64]
        val base = if argv.len() > 4i64:
            "jj new " + _join(_tail(argv, 4i64))
        else:
            "jj new"
        return TranslationPlan(
            classification: "multi_step",
            lease_kind: 0i64,
            commands: [base, "jj bookmark create {branch} -r @"],
            warning: ""
        )
    if verb == "commit" and argv.len() > 2i64 and argv[2i64] == "--amend":
        return _direct("jj describe " + _join(_tail(argv, 2i64)), 0i64)
    if verb == "commit":
        return TranslationPlan(
            classification: "multi_step",
            lease_kind: 0i64,
            commands: ["jj describe " + _join(_tail(argv, 2i64)), "jj new"],
            warning: ""
        )
    if verb == "pull":
        return TranslationPlan(
            classification: "multi_step",
            lease_kind: 0i64,
            commands: ["jj git fetch", "jj rebase -d main@origin"],
            warning: ""
        )
    if verb == "lfs":
        return _raw("git " + _join(_tail(argv, 1i64)), 1i64, "")
    if verb == "clean":
        return _raw("git " + _join(_tail(argv, 1i64)), 0i64, "WARN[RAW]: git clean runs as a serialized raw passthrough")
    if verb == "submodule":
        if argv.len() > 2i64 and argv[2i64] == "status":
            return _raw("git " + _join(_tail(argv, 1i64)), 1i64, "")
        return _raw("git " + _join(_tail(argv, 1i64)), 0i64, "WARN[SUBMODULE]: submodule add is pinned immediately to preserve the gitlink in jj-managed repos")
    if verb == "push" and argv.len() > 2i64 and argv[2i64] == "--bookmark" and argv.len() > 3i64:
        return _direct("jj git push --bookmark " + argv[3i64], 0i64)
    if verb == "push" and argv.len() > 2i64 and argv[2i64] == "--via-worktree":
        return _raw("git push --via-worktree", 0i64, "")
    _raw("git " + _join(_tail(argv, 1i64)), 0i64, "")
