# CSV Import/Export
#
# Read/write spreadsheet data as CSV.

use app.office.sheets.spreadsheet.{Sheet}
use app.office.sheets.cell.{CellRef, CellValue, cell_ref_to_string, cell_display_text, col_to_letter}
use common.string_builder.{StringBuilder}

# =========================================================================
# CSV Import
# =========================================================================

fn import_csv(content: text, sheet: Sheet) -> Sheet:
    """Parse CSV content and populate cells in the sheet.
    Returns a new Sheet with the CSV data loaded.
    Handles quoted fields (double-quote escaping) and newlines within quotes."""
    var result = sheet
    val lines = _split_csv_lines(content)
    var row_idx = 0
    for line in lines:
        val fields = _parse_csv_line(line)
        var col_idx = 0
        for field in fields:
            val ref_str = cell_ref_to_string(CellRef(col: col_idx, row: row_idx))
            result.set_value(ref_str, field)
            col_idx = col_idx + 1
        row_idx = row_idx + 1
    result

# =========================================================================
# CSV Export
# =========================================================================

fn export_csv(sheet: Sheet) -> text:
    """Export sheet cells as CSV text. Uses the sheet's used range to determine bounds."""
    # Find the bounding box of non-empty cells
    var max_col = 0
    var max_row = 0
    var has_cells = false

    for key in sheet.cells.keys():
        val ref_val = _parse_cell_ref_simple(key)
        if ref_val != nil:
            has_cells = true
            if ref_val.col > max_col:
                max_col = ref_val.col
            if ref_val.row > max_row:
                max_row = ref_val.row

    if not has_cells:
        return ""

    var lines: [text] = []
    var r = 0
    while r <= max_row:
        var fields: [text] = []
        var c = 0
        while c <= max_col:
            val ref_str = cell_ref_to_string(CellRef(col: c, row: r))
            val cell = sheet.get_cell(ref_str)
            val display = cell_display_text(cell)
            val escaped = _csv_escape_field(display)
            fields = fields.push(escaped)
            c = c + 1
        lines = lines.push(_join_with_comma(fields))
        r = r + 1
    _join_with_newline(lines)

# =========================================================================
# CSV Parsing Helpers
# =========================================================================

fn _split_csv_lines(content: text) -> [text]:
    """Split CSV content into lines, respecting quoted fields that contain newlines."""
    var lines: [text] = []
    var sb = StringBuilder.new()
    var in_quotes = false
    var i = 0
    while i < content.len():
        val c = content.char_at(i)
        if c == "\"":
            in_quotes = not in_quotes
            sb.push(c)
        elif c == "\n" and not in_quotes:
            if not sb.is_empty() or lines.len() > 0:
                # Strip trailing \r
                var s = sb.to_text()
                if s.len() > 0 and s.char_at(s.len() - 1) == "\r":
                    s = s.substring(0, s.len() - 1)
                lines = lines.push(s)
            sb.clear()
        else:
            sb.push(c)
        i = i + 1
    # Last line
    if not sb.is_empty():
        var s = sb.to_text()
        if s.char_at(s.len() - 1) == "\r":
            s = s.substring(0, s.len() - 1)
        lines = lines.push(s)
    lines

fn _parse_csv_line(line: text) -> [text]:
    """Parse a single CSV line into fields. Handles quoted fields and escaped quotes."""
    var fields: [text] = []
    var sb = StringBuilder.new()
    var in_quotes = false
    var i = 0
    while i < line.len():
        val c = line.char_at(i)
        if in_quotes:
            if c == "\"":
                # Check for escaped quote ""
                if i + 1 < line.len() and line.char_at(i + 1) == "\"":
                    sb.push("\"")
                    i = i + 2
                    continue
                else:
                    in_quotes = false
            else:
                sb.push(c)
        else:
            if c == "\"":
                in_quotes = true
            elif c == ",":
                fields = fields.push(sb.to_text())
                sb.clear()
            else:
                sb.push(c)
        i = i + 1
    fields = fields.push(sb.to_text())
    fields

# =========================================================================
# CSV Escape Helpers
# =========================================================================

fn _csv_escape_field(field: text) -> text:
    """Escape a field for CSV output. Wraps in quotes if it contains comma, quote, or newline."""
    var needs_quoting = false
    var i = 0
    while i < field.len():
        val c = field.char_at(i)
        if c == "," or c == "\"" or c == "\n" or c == "\r":
            needs_quoting = true
            break
        i = i + 1
    if not needs_quoting:
        return field
    # Escape quotes by doubling them
    var sb = StringBuilder.new()
    i = 0
    while i < field.len():
        val c = field.char_at(i)
        if c == "\"":
            sb.push("\"\"")
        else:
            sb.push(c)
        i = i + 1
    val escaped = sb.to_text()
    "\"{escaped}\""

# =========================================================================
# String Join Helpers
# =========================================================================

fn _join_with_comma(items: [text]) -> text:
    """Join a list of text with comma separator."""
    var sb = StringBuilder.new()
    for item in items:
        sb.push_sep(item, ",")
    sb.to_text()

fn _join_with_newline(items: [text]) -> text:
    """Join a list of text with newline separator."""
    var sb = StringBuilder.new()
    for item in items:
        sb.push_sep(item, "\n")
    sb.to_text()

# =========================================================================
# Cell Reference Helper (local, avoid circular import)
# =========================================================================

fn _parse_cell_ref_simple(ref_str: text) -> CellRef?:
    """Minimal cell ref parser for export use. Avoids importing from cell.spl."""
    if ref_str.len() == 0:
        return nil
    val upper = ref_str.upper()
    var letter_part = ""
    var digit_part = ""
    var i = 0
    while i < upper.len():
        val c = upper.char_at(i)
        val code = c.char_code_at(0)
        if code >= 65 and code <= 90:
            if digit_part.len() > 0:
                return nil
            letter_part = "{letter_part}{c}"
        elif code >= 48 and code <= 57:
            digit_part = "{digit_part}{c}"
        else:
            return nil
        i = i + 1
    if letter_part.len() == 0 or digit_part.len() == 0:
        return nil
    # Convert letter part to col index
    var col = 0
    i = 0
    while i < letter_part.len():
        val ch = letter_part.char_at(i)
        val char_val = ch.char_code_at(0) - 65
        col = col * 26 + char_val + 1
        i = i + 1
    col = col - 1
    # Parse row
    var row_num = 0
    i = 0
    while i < digit_part.len():
        val ch = digit_part.char_at(i)
        row_num = row_num * 10 + (ch.char_code_at(0) - 48)
        i = i + 1
    if row_num <= 0:
        return nil
    CellRef(col: col, row: row_num - 1)
