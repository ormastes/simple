# Minesweeper App
#
# Classic 8x8 minesweeper with text-art board display.
# Cells: . hidden, space revealed-empty, 1-8 mine-count, * mine, F flagged

use common.ui.widget.{WidgetNode, UITree}
use common.ui.session.{UISession}
use common.ui.builder.{
    column, row, panel, text_widget, button, label, statusbar,
    build_tree_with_title, with_height, with_width, with_flex, with_background
}

# =========================================================================
# MinesweeperApp
# =========================================================================

class MinesweeperApp:
    session: UISession

    static fn new() -> MinesweeperApp:
        val tree = MinesweeperApp._build_tree()
        val session = UISession.new(tree)
        return MinesweeperApp(session: session)

    me build_ui() -> UISession:
        me.session

    static fn _board_line_1() -> text:
        return "  A B C D E F G H"

    static fn _board_line_2() -> text:
        return "1|. . . . . . . .|"

    static fn _board_line_3() -> text:
        return "2|. 1 1 1 . . . .|"

    static fn _board_line_4() -> text:
        return "3|. 1   1 1 1 . .|"

    static fn _board_line_5() -> text:
        return "4|. 1   1 * 1 . .|"

    static fn _board_line_6() -> text:
        return "5|. 1 1 2   1 . .|"

    static fn _board_line_7() -> text:
        return "6|.   1 1 1 1 . .|"

    static fn _board_line_8() -> text:
        return "7|. . 1 . . . . .|"

    static fn _board_line_9() -> text:
        return "8|. . . . . . . .|"

    static fn _board_line_10() -> text:
        return "  -----------------"

    static fn _build_tree() -> UITree:
        # Toolbar row
        val toolbar = row("toolbar", [
            button("btn_new",       "New Game",    "minesweeper.new_game"),
            button("btn_beginner",  "Beginner",    "minesweeper.difficulty.beginner"),
            button("btn_medium",    "Intermediate","minesweeper.difficulty.intermediate"),
            button("btn_expert",    "Expert",      "minesweeper.difficulty.expert"),
        ])

        # Board panel — text-art 8x8 grid
        val board_panel = panel("board_panel", "Minesweeper Board", [
            text_widget("legend",  MinesweeperApp._board_line_1()),
            text_widget("sep_top", MinesweeperApp._board_line_10()),
            text_widget("row1",    MinesweeperApp._board_line_2()),
            text_widget("row2",    MinesweeperApp._board_line_3()),
            text_widget("row3",    MinesweeperApp._board_line_4()),
            text_widget("row4",    MinesweeperApp._board_line_5()),
            text_widget("row5",    MinesweeperApp._board_line_6()),
            text_widget("row6",    MinesweeperApp._board_line_7()),
            text_widget("row7",    MinesweeperApp._board_line_8()),
            text_widget("row8",    MinesweeperApp._board_line_9()),
            text_widget("sep_bot", MinesweeperApp._board_line_10()),
        ])

        # Legend panel
        val legend_panel = panel("legend_panel", "Legend", [
            label("leg_hidden",   ".  = Hidden cell"),
            label("leg_empty",    "   = Revealed (safe)"),
            label("leg_number",   "1-8 = Adjacent mines"),
            label("leg_mine",     "*  = Mine (game over)"),
            label("leg_flag",     "F  = Flagged"),
        ])

        # Status bar
        val status = statusbar("statusbar", "Mines remaining: 9", "Time: 00:42")

        val root = column("root", [
            toolbar,
            row("main_area", [
                board_panel,
                legend_panel,
            ]),
            status,
        ])

        return build_tree_with_title(root, "Minesweeper", "default")
