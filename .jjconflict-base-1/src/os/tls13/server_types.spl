# ============================================================================
# TLS 1.3 Server-side data types — RFC 8446
# ============================================================================
#
# Shared data classes and enums for the server-side TLS 1.3 handshake.
# Extracted from server.spl to break the import cycle between server.spl
# and server_builders.spl / server_handshake.spl.
#
# Reference: RFC 8446 §4.1.2, §4.1.3, §4.3.1, §4.4.2, §4.4.3, §4.4.4.

# ============================================================================
# Data classes
# ============================================================================

class ClientHello13:
    """Decoded ClientHello fields needed to drive the server flow.

    RFC 8446 §4.1.2 — fields populated only when present:
      - random: 32-byte ClientHello.random
      - cipher_suites: u16 list, in offered order
      - named_groups: u16 list (from supported_groups, ext 10), informational
      - key_share_groups: u16 list (groups for which CH carried a key_share)
      - x25519_key_share: 32-byte CH X25519 share, empty if absent
      - p256_key_share: 65-byte uncompressed CH P-256 share, empty if absent
      - sni_host: server_name from SNI ext, empty text if absent
      - has_supported_versions_tls13: true if 0x0304 was advertised
    """
    random: [u8]
    cipher_suites: [u16]
    named_groups: [u16]
    key_share_groups: [u16]
    x25519_key_share: [u8]
    p256_key_share: [u8]
    sni_host: text
    has_supported_versions_tls13: bool

class Tls13ClientHelloRecord:
    ch: ClientHello13
    handshake_msg: [u8]

class Tls13ServerConfig:
    """Minimum server-side configuration to drive the happy-path flow.

    Fields:
      - cert_chain: server certificate chain in DER, leaf first.
      - server_pkcs8: PKCS#8 v1 DER of the leaf signing key.
      - server_sig_scheme: SignatureScheme code (e.g. 0x0807 = ed25519,
        0x0403 = ecdsa_secp256r1_sha256). Must match cert leaf algorithm.
      - alpn_protocols: ALPN protocol list (informational; minimal EE
        builder leaves the extension list empty per §4.3.1 for now).
    """
    cert_chain: [[u8]]
    server_pkcs8: [u8]
    server_sig_scheme: u16
    alpn_protocols: [text]

class Tls13ServerContext:
    """Output of a successful tls13_accept.

    Mirrors the shape of Tls13Context on the client side; populated only
    once the full server-side record loop is wired (Wave 9+).
    """
    cipher_suite: u16
    named_group: u16
    server_random: [u8]
    server_keyshare_pub: [u8]
    client_app_key: [u8]
    client_app_iv: [u8]
    server_app_key: [u8]
    server_app_iv: [u8]
    client_seq: u64
    server_seq: u64

class Tls13ServerHandshakeMaterial:
    """Offline-prepared server-side handshake crypto material.

    Built only from an already-read ClientHello record plus an explicit server
    scalar. The live accept path sources fresh production entropy before using
    this shape on a socket, writes these records, and verifies client Finished.
    """
    cipher_suite: u16
    named_group: u16
    server_random: [u8]
    server_hello: [u8]
    server_keyshare_pub: [u8]
    shared_secret: [u8]
    handshake_secret: [u8]
    client_hs_traffic: [u8]
    server_hs_traffic: [u8]
    client_hs_key: [u8]
    client_hs_iv: [u8]
    server_hs_key: [u8]
    server_hs_iv: [u8]
    client_app_traffic: [u8]
    server_app_traffic: [u8]
    client_app_key: [u8]
    client_app_iv: [u8]
    server_app_key: [u8]
    server_app_iv: [u8]
    expected_client_finished: [u8]
    encrypted_extensions: [u8]
    certificate: [u8]
    certificate_verify: [u8]
    server_finished: [u8]
    server_hello_record: [u8]
    encrypted_extensions_record: [u8]
    certificate_record: [u8]
    certificate_verify_record: [u8]
    server_finished_record: [u8]

enum Tls13AcceptResult:
    Accepted(ctx: Tls13ServerContext)
    Failed(reason: text)

enum Tls13ServerHandshakeResult:
    Prepared(material: Tls13ServerHandshakeMaterial)
    Failed(reason: text)
