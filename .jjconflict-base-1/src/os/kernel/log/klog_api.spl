# SimpleOS kernel log facade.
#
# `use std.log.*` resolves to the hosted/SIMPLE_LOG lib
# (src/lib/nogc_sync_mut/log.spl) — NOT what SimpleOS wants.
# SimpleOS kernel / services / drivers / apps route through the
# bare-metal log library (src/lib/nogc_async_mut_noalloc/log/).
#
# This facade lets SimpleOS code say:
#   use os.kernel.log.klog_api.{log_init, log_info, log_raw_println, ...}
# and get the right lib consistently. The migration script inserts this
# import line; don't widen the API here without updating the sweep rules.

use lib.nogc_async_mut_noalloc.log.*

export LOG_TRACE, LOG_DEBUG, LOG_INFO, LOG_WARN, LOG_ERROR, LOG_FATAL, LOG_OFF
export TARGET_DEVICE, TARGET_SEMIHOST, TARGET_HOST_FILE
export LOG_DEV_KIND_COM1, LOG_DEV_KIND_PL011, LOG_DEV_KIND_NS16550

export log_init, log_init_serial, log_init_from_config
export log_parse_level, log_parse_targets
export log_set_level, log_set_targets, log_set_device
export log_trace, log_debug, log_info, log_warn, log_error, log_fatal
export log_raw, log_raw_println
export log_level_name
