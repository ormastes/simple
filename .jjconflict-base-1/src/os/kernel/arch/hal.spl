fn hal_console_write_byte(b: u8):
    """Write a single byte to COM1 serial port."""
    current_hal_console_write_byte(b)

@cfg(x86_64)
fn hal_console_write(s: text):
    """Write string to COM1 serial console."""
    current_hal_console_write(s)

@cfg(x86_64)
fn hal_console_writeln(s: text):
    """Write string + newline to COM1 serial console."""
    current_hal_console_writeln(s)

