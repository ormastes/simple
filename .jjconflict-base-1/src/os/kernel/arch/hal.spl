# Timer (4 functions)
# ============================================================================

@cfg(x86_64)
fn hal_timer_init(frequency_hz: u64):
    """Initialize timer — x86_64 APIC timer calibrated via PIT."""
    current_hal_timer_init(frequency_hz)

@cfg(x86_64)
fn hal_timer_set_deadline(delay_us: u64):
    """Set one-shot timer deadline in microseconds.

    HAL contract: delay_us is a relative delay in microseconds.
    The x86_64 implementation converts to APIC timer ticks internally.
    """
    current_hal_timer_set_deadline(delay_us)

@cfg(x86_64)
fn hal_timer_current_ticks() -> u64:
    """Read current tick count — x86_64 TSC via RDTSC."""
    current_hal_timer_current_ticks()

@cfg(x86_64)
fn hal_timer_ticks_per_second() -> u64:
    """Return timer frequency — x86_64 calibrated TSC/APIC frequency."""
    current_hal_timer_ticks_per_second()

# ============================================================================
# Context (3 functions)
# ============================================================================

@cfg(x86_64)
fn hal_context_save() -> ArchContext:
    """Save current CPU state — x86_64 GPRs + rflags + segments.

    Note: A true register save requires inline assembly or a dedicated
    save trampoline. This function creates a minimal context suitable
    for use as the 'from' side of context_switch, where the switch
    assembly itself saves the live registers into this slot.
    The returned context is a placeholder that context_switch will
    overwrite with actual register values.
    """
    current_hal_context_save()

@cfg(x86_64)
fn hal_context_restore(ctx: ArchContext):
    """Restore CPU state — x86_64 load GPRs + rflags + segments."""
    current_hal_context_restore(ctx)

@cfg(x86_64)
fn hal_context_init(entry: u64, stack: u64, arg: u64) -> ArchContext:
    """Create new task context — x86_64 set rip=entry, rsp=stack, rdi=arg."""
    current_hal_context_init(entry, stack, arg)
