# ============================================================================
# RiscvSoftGpuProbe — RISC-V software renderer
# ============================================================================

class RiscvSoftGpuProbe:
    """RISC-V software GPU probe result."""
    device_id: i64
    has_rvv: bool
    vector_bits: i64
    software_vulkan_version: text
    is_emulated: bool

impl RiscvSoftGpuProbe:
    static fn probe() -> RiscvSoftGpuProbe:
        """Return default unavailable probe."""
        RiscvSoftGpuProbe(
            device_id: 0,
            has_rvv: false,
            vector_bits: 0,
            software_vulkan_version: "",
            is_emulated: false
        )

    me is_available() -> bool:
        self.device_id > 0

    me summary() -> text:
        if self.is_available():
            "riscv device=" + self.device_id.to_text() +
                " rvv=" + self.has_rvv.to_text() +
                " vec_bits=" + self.vector_bits.to_text() +
                " sw_vulkan=" + self.software_vulkan_version +
                " emulated=" + self.is_emulated.to_text()
        else:
            "riscv: unavailable"

# ============================================================================
# GpuVendorRegistry
# ============================================================================

class GpuVendorRegistry:
    """Aggregates probe results for all five GPU vendors."""
    cuda_: CudaGpuProbe
    amd_: AmdGpuProbe
    intel_: IntelGpuProbe
    qualcomm_: QualcommArmGpuProbe
    riscv_: RiscvSoftGpuProbe

impl GpuVendorRegistry:
    static fn create() -> GpuVendorRegistry:
        GpuVendorRegistry(
            cuda_: CudaGpuProbe.probe(),
            amd_: AmdGpuProbe.probe(),
            intel_: IntelGpuProbe.probe(),
            qualcomm_: QualcommArmGpuProbe.probe(),
            riscv_: RiscvSoftGpuProbe.probe()
        )

    me probe_all() -> i64:
        """Run all five probes. Returns count of available vendors."""
        var count: i64 = 0
        if self.cuda_.is_available():
            count = count + 1
        if self.amd_.is_available():
            count = count + 1
        if self.intel_.is_available():
            count = count + 1
        if self.qualcomm_.is_available():
            count = count + 1
        if self.riscv_.is_available():
            count = count + 1
        count

    me best_available() -> text:
        """Return name of the highest-priority available GPU vendor."""
        if self.cuda_.is_available():
            "cuda"
        else if self.amd_.is_available():
            "amd"
        else if self.intel_.is_available():
            "intel"
        else if self.qualcomm_.is_available():
            "qualcomm"
        else if self.riscv_.is_available():
            "riscv"
        else:
            "none"

    me report() -> text:
        """Multi-line status of all vendor probes."""
        "=== GPU Vendor Registry ===\n" +
            self.cuda_.summary() + "\n" +
            self.amd_.summary() + "\n" +
            self.intel_.summary() + "\n" +
            self.qualcomm_.summary() + "\n" +
            self.riscv_.summary() + "\n" +
            "best=" + self.best_available()
