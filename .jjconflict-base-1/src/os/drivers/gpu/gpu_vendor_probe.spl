# GPU Vendor Probe Adapters
# MDSOC: feature dimension, drivers layer
#
# Provides zero-cost probe stubs for 5 GPU vendors (NVIDIA, AMD, Intel,
# Qualcomm/ARM, RISC-V software). Each probe returns an "unavailable"
# descriptor by default; hardware-specific layers fill real values when
# the device is detected.  GpuVendorRegistry aggregates all five probes.

# ============================================================================
# CudaGpuProbe — NVIDIA CUDA
# ============================================================================

class CudaGpuProbe:
    """NVIDIA CUDA GPU probe result."""
    device_id: i64
    compute_capability_major: i64
    compute_capability_minor: i64
    vram_mb: i64
    cuda_cores: i64
    driver_version: text
    has_unified_memory: bool

impl CudaGpuProbe:
    static fn probe() -> CudaGpuProbe:
        """Return default unavailable probe."""
        CudaGpuProbe(
            device_id: 0,
            compute_capability_major: 0,
            compute_capability_minor: 0,
            vram_mb: 0,
            cuda_cores: 0,
            driver_version: "",
            has_unified_memory: false
        )

    me is_available() -> bool:
        self.device_id > 0

    me summary() -> text:
        if self.is_available():
            "cuda device=" + self.device_id.to_text() +
                " cc=" + self.compute_capability_major.to_text() +
                "." + self.compute_capability_minor.to_text() +
                " vram=" + self.vram_mb.to_text() + "MB" +
                " cores=" + self.cuda_cores.to_text() +
                " unified=" + self.has_unified_memory.to_text()
        else:
            "cuda: unavailable"

# ============================================================================
# AmdGpuProbe — AMD
# ============================================================================

class AmdGpuProbe:
    """AMD GPU probe result."""
    device_id: i64
    gcn_arch: text
    vram_mb: i64
    compute_units: i64
    vulkan_version: text
    has_raytracing: bool

impl AmdGpuProbe:
    static fn probe() -> AmdGpuProbe:
        """Return default unavailable probe."""
        AmdGpuProbe(
            device_id: 0,
            gcn_arch: "",
            vram_mb: 0,
            compute_units: 0,
            vulkan_version: "",
            has_raytracing: false
        )

    me is_available() -> bool:
        self.device_id > 0

    me summary() -> text:
        if self.is_available():
            "amd device=" + self.device_id.to_text() +
                " arch=" + self.gcn_arch +
                " vram=" + self.vram_mb.to_text() + "MB" +
                " cu=" + self.compute_units.to_text() +
                " vulkan=" + self.vulkan_version +
                " rt=" + self.has_raytracing.to_text()
        else:
            "amd: unavailable"

