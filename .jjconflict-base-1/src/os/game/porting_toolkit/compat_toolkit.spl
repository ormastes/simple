class CompatEntry:
    api_name: text
    api_category: text
    simpleos_status: text
    fallback: text

    static fn native(name: text, cat: text) -> CompatEntry:
        CompatEntry(api_name: name, api_category: cat, simpleos_status: "native", fallback: "")

    static fn translated(name: text, cat: text, via: text) -> CompatEntry:
        CompatEntry(api_name: name, api_category: cat, simpleos_status: "translated", fallback: via)

    static fn stubbed(name: text, cat: text) -> CompatEntry:
        CompatEntry(api_name: name, api_category: cat, simpleos_status: "stubbed", fallback: "stub")

    static fn missing(name: text, cat: text) -> CompatEntry:
        CompatEntry(api_name: name, api_category: cat, simpleos_status: "missing", fallback: "")

    me is_functional() -> bool:
        (self.simpleos_status == "native") or (self.simpleos_status == "translated")

    me summary() -> text:
        "[" + self.api_category + "] " + self.api_name + " => " + self.simpleos_status +
            if self.fallback == "" { "" } else { " via " + self.fallback }


class CompatDatabase:
    count: i64
    e0_name: text
    e1_name: text
    e2_name: text
    e3_name: text
    e4_name: text
    e5_name: text
    e6_name: text
    e7_name: text
    e8_name: text
    e9_name: text
    e10_name: text
    e11_name: text
    e12_name: text
    e13_name: text
    e14_name: text
    e15_name: text
    e0_cat: text
    e1_cat: text
    e2_cat: text
    e3_cat: text
    e4_cat: text
    e5_cat: text
    e6_cat: text
    e7_cat: text
    e8_cat: text
    e9_cat: text
    e10_cat: text
    e11_cat: text
    e12_cat: text
    e13_cat: text
    e14_cat: text
    e15_cat: text
    e0_status: text
    e1_status: text
    e2_status: text
    e3_status: text
    e4_status: text
    e5_status: text
    e6_status: text
    e7_status: text
    e8_status: text
    e9_status: text
    e10_status: text
    e11_status: text
    e12_status: text
    e13_status: text
    e14_status: text
    e15_status: text
    e0_fallback: text
    e1_fallback: text
    e2_fallback: text
    e3_fallback: text
    e4_fallback: text
    e5_fallback: text
    e6_fallback: text
    e7_fallback: text
    e8_fallback: text
    e9_fallback: text
    e10_fallback: text
    e11_fallback: text
    e12_fallback: text
    e13_fallback: text
    e14_fallback: text
    e15_fallback: text

    static fn create() -> CompatDatabase:
        CompatDatabase(
            count: 0,
            e0_name: "", e1_name: "", e2_name: "", e3_name: "",
            e4_name: "", e5_name: "", e6_name: "", e7_name: "",
            e8_name: "", e9_name: "", e10_name: "", e11_name: "",
            e12_name: "", e13_name: "", e14_name: "", e15_name: "",
            e0_cat: "", e1_cat: "", e2_cat: "", e3_cat: "",
            e4_cat: "", e5_cat: "", e6_cat: "", e7_cat: "",
            e8_cat: "", e9_cat: "", e10_cat: "", e11_cat: "",
            e12_cat: "", e13_cat: "", e14_cat: "", e15_cat: "",
            e0_status: "", e1_status: "", e2_status: "", e3_status: "",
            e4_status: "", e5_status: "", e6_status: "", e7_status: "",
            e8_status: "", e9_status: "", e10_status: "", e11_status: "",
            e12_status: "", e13_status: "", e14_status: "", e15_status: "",
            e0_fallback: "", e1_fallback: "", e2_fallback: "", e3_fallback: "",
            e4_fallback: "", e5_fallback: "", e6_fallback: "", e7_fallback: "",
            e8_fallback: "", e9_fallback: "", e10_fallback: "", e11_fallback: "",
            e12_fallback: "", e13_fallback: "", e14_fallback: "", e15_fallback: ""
        )

    me add(name: text, cat: text, status: text, fallback: text) -> text:
        if self.count >= 16:
            return "db full"
        val idx = self.count
        if idx == 0:
            self.e0_name = name
            self.e0_cat = cat
            self.e0_status = status
            self.e0_fallback = fallback
        else if idx == 1:
            self.e1_name = name
            self.e1_cat = cat
            self.e1_status = status
            self.e1_fallback = fallback
        else if idx == 2:
            self.e2_name = name
            self.e2_cat = cat
            self.e2_status = status
            self.e2_fallback = fallback
        else if idx == 3:
            self.e3_name = name
            self.e3_cat = cat
            self.e3_status = status
            self.e3_fallback = fallback
        else if idx == 4:
            self.e4_name = name
            self.e4_cat = cat
            self.e4_status = status
            self.e4_fallback = fallback
        else if idx == 5:
            self.e5_name = name
            self.e5_cat = cat
            self.e5_status = status
            self.e5_fallback = fallback
        else if idx == 6:
            self.e6_name = name
            self.e6_cat = cat
            self.e6_status = status
            self.e6_fallback = fallback
        else if idx == 7:
            self.e7_name = name
            self.e7_cat = cat
            self.e7_status = status
            self.e7_fallback = fallback
        else if idx == 8:
            self.e8_name = name
            self.e8_cat = cat
            self.e8_status = status
            self.e8_fallback = fallback
        else if idx == 9:
            self.e9_name = name
            self.e9_cat = cat
            self.e9_status = status
            self.e9_fallback = fallback
        else if idx == 10:
            self.e10_name = name
            self.e10_cat = cat
            self.e10_status = status
            self.e10_fallback = fallback
        else if idx == 11:
            self.e11_name = name
            self.e11_cat = cat
            self.e11_status = status
            self.e11_fallback = fallback
        else if idx == 12:
            self.e12_name = name
            self.e12_cat = cat
            self.e12_status = status
            self.e12_fallback = fallback
        else if idx == 13:
            self.e13_name = name
            self.e13_cat = cat
            self.e13_status = status
            self.e13_fallback = fallback
        else if idx == 14:
            self.e14_name = name
            self.e14_cat = cat
            self.e14_status = status
            self.e14_fallback = fallback
        else if idx == 15:
            self.e15_name = name
            self.e15_cat = cat
            self.e15_status = status
            self.e15_fallback = fallback
        self.count = self.count + 1
        ""

    me get_status(name: text) -> text:
        if self.e0_name == name: return self.e0_status
        if self.e1_name == name: return self.e1_status
        if self.e2_name == name: return self.e2_status
        if self.e3_name == name: return self.e3_status
        if self.e4_name == name: return self.e4_status
        if self.e5_name == name: return self.e5_status
        if self.e6_name == name: return self.e6_status
        if self.e7_name == name: return self.e7_status
        if self.e8_name == name: return self.e8_status
        if self.e9_name == name: return self.e9_status
        if self.e10_name == name: return self.e10_status
        if self.e11_name == name: return self.e11_status
        if self.e12_name == name: return self.e12_status
        if self.e13_name == name: return self.e13_status
        if self.e14_name == name: return self.e14_status
        if self.e15_name == name: return self.e15_status
        "unknown"

    me functional_count() -> i64:
        var n: i64 = 0
        if (self.e0_status == "native") or (self.e0_status == "translated"): n = n + 1
        if (self.e1_status == "native") or (self.e1_status == "translated"): n = n + 1
        if (self.e2_status == "native") or (self.e2_status == "translated"): n = n + 1
        if (self.e3_status == "native") or (self.e3_status == "translated"): n = n + 1
        if (self.e4_status == "native") or (self.e4_status == "translated"): n = n + 1
        if (self.e5_status == "native") or (self.e5_status == "translated"): n = n + 1
        if (self.e6_status == "native") or (self.e6_status == "translated"): n = n + 1
        if (self.e7_status == "native") or (self.e7_status == "translated"): n = n + 1
        if (self.e8_status == "native") or (self.e8_status == "translated"): n = n + 1
        if (self.e9_status == "native") or (self.e9_status == "translated"): n = n + 1
        if (self.e10_status == "native") or (self.e10_status == "translated"): n = n + 1
        if (self.e11_status == "native") or (self.e11_status == "translated"): n = n + 1
        if (self.e12_status == "native") or (self.e12_status == "translated"): n = n + 1
        if (self.e13_status == "native") or (self.e13_status == "translated"): n = n + 1
        if (self.e14_status == "native") or (self.e14_status == "translated"): n = n + 1
        if (self.e15_status == "native") or (self.e15_status == "translated"): n = n + 1
        n

    me missing_count() -> i64:
        var n: i64 = 0
        if self.e0_status == "missing": n = n + 1
        if self.e1_status == "missing": n = n + 1
        if self.e2_status == "missing": n = n + 1
        if self.e3_status == "missing": n = n + 1
        if self.e4_status == "missing": n = n + 1
        if self.e5_status == "missing": n = n + 1
        if self.e6_status == "missing": n = n + 1
        if self.e7_status == "missing": n = n + 1
        if self.e8_status == "missing": n = n + 1
        if self.e9_status == "missing": n = n + 1
        if self.e10_status == "missing": n = n + 1
        if self.e11_status == "missing": n = n + 1
        if self.e12_status == "missing": n = n + 1
        if self.e13_status == "missing": n = n + 1
        if self.e14_status == "missing": n = n + 1
        if self.e15_status == "missing": n = n + 1
        n

    me coverage_percent() -> i64:
        if self.count == 0:
            return 0
        (self.functional_count() * 100) / self.count

    me report() -> text:
        "compat_db: count=" + self.count.to_text() +
            " functional=" + self.functional_count().to_text() +
            " missing=" + self.missing_count().to_text() +
            " coverage=" + self.coverage_percent().to_text() + "%"


class MissingAbiReport:
    count: i64
    m0_symbol: text
    m1_symbol: text
    m2_symbol: text
    m3_symbol: text
    m4_symbol: text
    m5_symbol: text
    m6_symbol: text
    m7_symbol: text
    m0_library: text
    m1_library: text
    m2_library: text
    m3_library: text
    m4_library: text
    m5_library: text
    m6_library: text
    m7_library: text
    m0_callers: i64
    m1_callers: i64
    m2_callers: i64
    m3_callers: i64
    m4_callers: i64
    m5_callers: i64
    m6_callers: i64
    m7_callers: i64

    static fn create() -> MissingAbiReport:
        MissingAbiReport(
            count: 0,
            m0_symbol: "", m1_symbol: "", m2_symbol: "", m3_symbol: "",
            m4_symbol: "", m5_symbol: "", m6_symbol: "", m7_symbol: "",
            m0_library: "", m1_library: "", m2_library: "", m3_library: "",
            m4_library: "", m5_library: "", m6_library: "", m7_library: "",
            m0_callers: 0, m1_callers: 0, m2_callers: 0, m3_callers: 0,
            m4_callers: 0, m5_callers: 0, m6_callers: 0, m7_callers: 0
        )

    me add(symbol: text, library: text, callers: i64) -> text:
        if self.count >= 8:
            return "db full"
        val idx = self.count
        if idx == 0:
            self.m0_symbol = symbol
            self.m0_library = library
            self.m0_callers = callers
        else if idx == 1:
            self.m1_symbol = symbol
            self.m1_library = library
            self.m1_callers = callers
        else if idx == 2:
            self.m2_symbol = symbol
            self.m2_library = library
            self.m2_callers = callers
        else if idx == 3:
            self.m3_symbol = symbol
            self.m3_library = library
            self.m3_callers = callers
        else if idx == 4:
            self.m4_symbol = symbol
            self.m4_library = library
            self.m4_callers = callers
        else if idx == 5:
            self.m5_symbol = symbol
            self.m5_library = library
            self.m5_callers = callers
        else if idx == 6:
            self.m6_symbol = symbol
            self.m6_library = library
            self.m6_callers = callers
        else if idx == 7:
            self.m7_symbol = symbol
            self.m7_library = library
            self.m7_callers = callers
        self.count = self.count + 1
        ""

    me total_callers() -> i64:
        self.m0_callers + self.m1_callers + self.m2_callers + self.m3_callers +
            self.m4_callers + self.m5_callers + self.m6_callers + self.m7_callers

    me most_critical() -> text:
        var best_sym = ""
        var best_cal: i64 = -1
        if self.m0_callers > best_cal:
            best_sym = self.m0_symbol
            best_cal = self.m0_callers
        if self.m1_callers > best_cal:
            best_sym = self.m1_symbol
            best_cal = self.m1_callers
        if self.m2_callers > best_cal:
            best_sym = self.m2_symbol
            best_cal = self.m2_callers
        if self.m3_callers > best_cal:
            best_sym = self.m3_symbol
            best_cal = self.m3_callers
        if self.m4_callers > best_cal:
            best_sym = self.m4_symbol
            best_cal = self.m4_callers
        if self.m5_callers > best_cal:
            best_sym = self.m5_symbol
            best_cal = self.m5_callers
        if self.m6_callers > best_cal:
            best_sym = self.m6_symbol
            best_cal = self.m6_callers
        if self.m7_callers > best_cal:
            best_sym = self.m7_symbol
            best_cal = self.m7_callers
        best_sym

    me report() -> text:
        "missing_abi: count=" + self.count.to_text() +
            " total_callers=" + self.total_callers().to_text() +
            " most_critical=" + self.most_critical()


class TraceReport:
    app_id: text
    trace_id: text
    duration_ms: i64
    syscall_count: i64
    api_call_count: i64
    fault_count: i64
    first_fault_symbol: text
    first_fault_library: text

    static fn create(app: text, trace: text) -> TraceReport:
        TraceReport(
            app_id: app,
            trace_id: trace,
            duration_ms: 0,
            syscall_count: 0,
            api_call_count: 0,
            fault_count: 0,
            first_fault_symbol: "",
            first_fault_library: ""
        )

    me record_syscall() -> i64:
        self.syscall_count = self.syscall_count + 1
        self.syscall_count

    me record_api_call() -> i64:
        self.api_call_count = self.api_call_count + 1
        self.api_call_count

    me record_fault(symbol: text, library: text) -> i64:
        if self.fault_count == 0:
            self.first_fault_symbol = symbol
            self.first_fault_library = library
        self.fault_count = self.fault_count + 1
        self.fault_count

    me has_faults() -> bool:
        self.fault_count > 0

    me summary() -> text:
        "trace[" + self.trace_id + "] app=" + self.app_id +
            " syscalls=" + self.syscall_count.to_text() +
            " api_calls=" + self.api_call_count.to_text() +
            " faults=" + self.fault_count.to_text() +
            if self.fault_count == 0 { "" } else { " first_fault=" + self.first_fault_symbol + "@" + self.first_fault_library }


class PortingFixture:
    fixture_name: text
    target_api: text
    expected_status: text
    actual_status: text
    passed: bool

    static fn create(name: text, api: text, expected: text) -> PortingFixture:
        PortingFixture(
            fixture_name: name,
            target_api: api,
            expected_status: expected,
            actual_status: "",
            passed: false
        )

    me run(actual: text) -> bool:
        self.actual_status = actual
        self.passed = self.expected_status == actual
        self.passed

    me summary() -> text:
        val result = if self.passed { "PASS" } else { "FAIL" }
        result + " fixture=" + self.fixture_name +
            " api=" + self.target_api +
            " expected=" + self.expected_status +
            " actual=" + self.actual_status


class PortingToolkitReport:
    compat_db: CompatDatabase
    missing_abi: MissingAbiReport
    fixture_count: i64
    fixture_passed: i64
    fixture_failed: i64

    static fn create() -> PortingToolkitReport:
        PortingToolkitReport(
            compat_db: CompatDatabase.create(),
            missing_abi: MissingAbiReport.create(),
            fixture_count: 0,
            fixture_passed: 0,
            fixture_failed: 0
        )

    me record_fixture_result(passed: bool) -> i64:
        self.fixture_count = self.fixture_count + 1
        if passed:
            self.fixture_passed = self.fixture_passed + 1
        else:
            self.fixture_failed = self.fixture_failed + 1
        self.fixture_count

    me is_viable() -> bool:
        (self.compat_db.coverage_percent() >= 70) and (self.fixture_failed == 0)

    me report() -> text:
        self.compat_db.report() + "\n" +
            self.missing_abi.report() + "\n" +
            "fixtures: total=" + self.fixture_count.to_text() +
            " passed=" + self.fixture_passed.to_text() +
            " failed=" + self.fixture_failed.to_text() +
            " viable=" + self.is_viable().to_text()
