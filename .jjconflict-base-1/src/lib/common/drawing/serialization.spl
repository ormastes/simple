# Drawing Serialization — serialize/deserialize DrawingDocument to SDN text
#
# Converts drawing documents to and from the SDN text format for
# persistence and interchange.

use std.common.drawing.document.{DrawingDocument, DrawingLayer, BlendMode, LayerKind}

# ============================================================================
# Serialization
# ============================================================================

fn serialize_blend_mode(mode: BlendMode) -> text:
    """Convert a BlendMode to its SDN string name."""
    match mode:
        case Normal: "Normal"
        case Multiply: "Multiply"
        case Screen: "Screen"
        case Overlay: "Overlay"
        case Darken: "Darken"
        case Lighten: "Lighten"

fn serialize_layer(layer: DrawingLayer) -> text:
    """Serialize a single DrawingLayer to an SDN block."""
    var out = "    layer {\n"
    out = out + "      name: \"" + layer.name + "\"\n"
    val vis = layer.visible
    var vis_text = "false"
    if vis:
        vis_text = "true"
    out = out + "      visible: " + vis_text + "\n"
    val lck = layer.locked
    var lck_text = "false"
    if lck:
        lck_text = "true"
    out = out + "      locked: " + lck_text + "\n"
    val op = layer.opacity
    out = out + "      opacity: " + op.to_text() + "\n"
    val bm = layer.blend_mode
    out = out + "      blend_mode: \"" + serialize_blend_mode(bm) + "\"\n"
    val kind = layer.kind
    match kind:
        case Raster(width, height):
            out = out + "      kind: \"raster\"\n"
            out = out + "      raster_width: " + width.to_text() + "\n"
            out = out + "      raster_height: " + height.to_text() + "\n"
        case Vector:
            out = out + "      kind: \"vector\"\n"
    out = out + "    }"
    out

fn serialize_document(doc: DrawingDocument) -> text:
    """Serialize a DrawingDocument to SDN text format."""
    val w = doc.width
    val h = doc.height
    var out = "drawing {\n"
    out = out + "  width: " + w.to_text() + "\n"
    out = out + "  height: " + h.to_text() + "\n"
    val layers = doc.layers
    out = out + "  layers {\n"
    for layer in layers:
        out = out + serialize_layer(layer) + "\n"
    out = out + "  }\n"
    out = out + "}"
    out

# ============================================================================
# Deserialization
# ============================================================================

fn deserialize_blend_mode(name: text) -> BlendMode:
    """Parse a blend mode name string to a BlendMode enum."""
    if name == "Multiply":
        return BlendMode.Multiply
    if name == "Screen":
        return BlendMode.Screen
    if name == "Overlay":
        return BlendMode.Overlay
    if name == "Darken":
        return BlendMode.Darken
    if name == "Lighten":
        return BlendMode.Lighten
    BlendMode.Normal

fn strip_quotes(s: text) -> text:
    """Remove surrounding double quotes from a string value."""
    val slen = s.len()
    if slen >= 2:
        if s[0] == "\"" and s[slen - 1] == "\"":
            return s.slice(1, slen - 1)
    s

fn deserialize_document(sdn: text) -> DrawingDocument?:
    """Parse SDN text into a DrawingDocument.

    Simple line-by-line parser that tracks nesting depth by { and }.
    Returns none if the input is empty or has no drawing block.
    """
    val lines = sdn.split("\n")
    if lines.len() == 0:
        return none

    var doc_width = 0
    var doc_height = 0
    var found_drawing = false
    var in_layers = false
    var in_layer = false
    var depth = 0

    # Current layer state
    var layer_name = ""
    var layer_visible = true
    var layer_locked = false
    var layer_opacity = 1.0
    var layer_blend = "Normal"
    var layer_kind = "raster"
    var layer_rw = 0
    var layer_rh = 0

    var parsed_layers: [DrawingLayer] = []

    for line in lines:
        val trimmed = line.trim()
        if trimmed == "":
            continue

        # Track nesting
        if trimmed.ends_with("{"):
            depth = depth + 1
            if trimmed.starts_with("drawing"):
                found_drawing = true
            if trimmed.starts_with("layers"):
                in_layers = true
            if trimmed.starts_with("layer") and in_layers:
                in_layer = true
                # Reset layer defaults
                layer_name = ""
                layer_visible = true
                layer_locked = false
                layer_opacity = 1.0
                layer_blend = "Normal"
                layer_kind = "raster"
                layer_rw = 0
                layer_rh = 0
            continue

        if trimmed == "}":
            depth = depth - 1
            if in_layer:
                # Finalize layer
                val bm = deserialize_blend_mode(layer_blend)
                var dl: DrawingLayer
                if layer_kind == "vector":
                    dl = DrawingLayer(
                        name: layer_name,
                        visible: layer_visible,
                        locked: layer_locked,
                        opacity: layer_opacity,
                        blend_mode: bm,
                        kind: LayerKind.Vector
                    )
                else:
                    dl = DrawingLayer(
                        name: layer_name,
                        visible: layer_visible,
                        locked: layer_locked,
                        opacity: layer_opacity,
                        blend_mode: bm,
                        kind: LayerKind.Raster(width: layer_rw, height: layer_rh)
                    )
                parsed_layers = parsed_layers.push(dl)
                in_layer = false
            if in_layers and not in_layer and depth <= 2:
                in_layers = false
            continue

        # Parse key: value
        val colon_idx = trimmed.index_of(":")
        if colon_idx < 0:
            continue
        val key = trimmed.slice(0, colon_idx).trim()
        val raw_val = trimmed.slice(colon_idx + 1, trimmed.len()).trim()

        if not in_layers and not in_layer:
            # Document-level properties
            if key == "width":
                doc_width = raw_val.to_i32()
            if key == "height":
                doc_height = raw_val.to_i32()
        if in_layer:
            val val_str = strip_quotes(raw_val)
            if key == "name":
                layer_name = val_str
            if key == "visible":
                layer_visible = val_str == "true"
            if key == "locked":
                layer_locked = val_str == "true"
            if key == "opacity":
                layer_opacity = raw_val.to_f64()
            if key == "blend_mode":
                layer_blend = val_str
            if key == "kind":
                layer_kind = val_str
            if key == "raster_width":
                layer_rw = raw_val.to_i32()
            if key == "raster_height":
                layer_rh = raw_val.to_i32()

    if not found_drawing:
        return none

    var doc = DrawingDocument.new(doc_width, doc_height)
    # Remove the default background layer that new() adds
    doc.remove_layer(0)
    for pl in parsed_layers:
        doc.add_layer(pl)
    doc
