# SCV bookmark refs.

use app.io.mod (file_exists, file_read, dir_create)
use std.scv.core.{scv_bookmarks_path, scv_meta_dir}
use std.scv.store.{scv_repo_exists, scv_current_op, scv_read_workspace_commit, scv_write_operation, scv_write_text, scv_object_path, scv_tag_name_valid}

fn scv_bookmark_name_valid(name: text) -> bool:
    name != "" and not name.contains("|") and not name.contains("\n") and not name.contains("\r") and not name.contains(" ")

fn scv_bookmark_commit_valid(root: text, commit: text) -> bool:
    commit.starts_with("commit_") and not commit.contains("|") and not commit.contains("/") and not commit.contains("\\") and file_exists(scv_object_path(root, "commits", commit))

fn scv_bookmark_row_error(root: text, row: text) -> text:
    val parts = row.split("|")
    if parts.len() != 2:
        return "ERROR bad bookmark row\n"
    if not scv_bookmark_name_valid(parts[0]):
        return "ERROR invalid bookmark name\n"
    if not scv_bookmark_commit_valid(root, parts[1]):
        return "ERROR invalid bookmark commit\n"
    ""

fn scv_bookmarks(root: text) -> text:
    if not scv_repo_exists(root):
        return "ERROR repository not initialized\n"
    val path = scv_bookmarks_path(root)
    if not file_exists(path):
        return "empty\n"
    val content = file_read(path)
    if content == "":
        "empty\n"
    else:
        content

fn scv_bookmark_set(root: text, name: text, commit: text) -> text:
    if not scv_repo_exists(root):
        return "ERROR repository not initialized\n"
    if not scv_bookmark_name_valid(name):
        return "ERROR invalid bookmark name\n"
    val target = if commit == "": scv_read_workspace_commit(root) else: commit
    if target == "":
        return "ERROR no commit for bookmark\n"
    if not scv_bookmark_commit_valid(root, target):
        return "ERROR invalid bookmark commit\n"
    val path = scv_bookmarks_path(root)
    val current = if file_exists(path): file_read(path) else: ""
    var next = ""
    var replaced = false
    for line in current.split("\n"):
        val trimmed = line.trim()
        if trimmed == "":
            continue
        val row_error = scv_bookmark_row_error(root, trimmed)
        if row_error != "":
            return row_error
        val parts = trimmed.split("|")
        if parts.len() > 0 and parts[0] == name:
            next = next + "{name}|{target}\n"
            replaced = true
        else:
            next = next + trimmed + "\n"
    if not replaced:
        next = next + "{name}|{target}\n"
    scv_write_text(path, next)
    val op = scv_write_operation(root, scv_current_op(root), target, "bookmark-set {name}")
    if op.starts_with("ERROR"):
        scv_write_text(path, current)
        return op
    "bookmark {name} {target} {op}\n"

fn scv_tags_path(root: text) -> text:
    "{scv_meta_dir(root)}/tags"

fn scv_tag_commit_valid(root: text, commit: text) -> bool:
    commit.starts_with("commit_") and not commit.contains("|") and not commit.contains("/") and not commit.contains("\\") and file_exists(scv_object_path(root, "commits", commit))

fn scv_tag_set(root: text, name: text, target_commit: text) -> text:
    if not scv_repo_exists(root):
        return "ERROR repository not initialized\n"
    if not scv_tag_name_valid(name):
        return "ERROR invalid tag name\n"
    if not scv_tag_commit_valid(root, target_commit):
        return "ERROR invalid tag commit\n"
    val path = scv_tags_path(root)
    val current = if file_exists(path): file_read(path) else: ""
    var next = ""
    var replaced = false
    for line in current.split("\n"):
        val trimmed = line.trim()
        if trimmed == "":
            continue
        val parts = trimmed.split("|")
        if parts.len() >= 1 and parts[0] == name:
            next = next + "{name}|{target_commit}\n"
            replaced = true
        else:
            next = next + trimmed + "\n"
    if not replaced:
        next = next + "{name}|{target_commit}\n"
    scv_write_text(path, next)
    "tag {name} {target_commit}\n"

fn scv_tag_get(root: text, name: text) -> text:
    val path = scv_tags_path(root)
    if not file_exists(path):
        return ""
    for line in file_read(path).split("\n"):
        val trimmed = line.trim()
        if trimmed == "":
            continue
        val parts = trimmed.split("|")
        if parts.len() >= 2 and parts[0] == name:
            return parts[1]
    ""

fn scv_tag_list(root: text) -> text:
    if not scv_repo_exists(root):
        return "ERROR repository not initialized\n"
    val path = scv_tags_path(root)
    if not file_exists(path):
        return "empty\n"
    val content = file_read(path)
    if content == "":
        "empty\n"
    else:
        content

fn scv_tag_annotated_id_path(root: text, name: text) -> text:
    "{scv_meta_dir(root)}/tag_objects/{name}"

fn scv_tag_annotated_set(root: text, name: text, object_id: text) -> text:
    if not scv_tag_name_valid(name):
        return "ERROR invalid tag name\n"
    val dir = "{scv_meta_dir(root)}/tag_objects"
    dir_create(dir, true)
    val path = scv_tag_annotated_id_path(root, name)
    scv_write_text(path, "{object_id}\n")
    "tag-annotated {name} {object_id}\n"

fn scv_tag_annotated_get(root: text, name: text) -> text:
    val path = scv_tag_annotated_id_path(root, name)
    if file_exists(path):
        file_read(path).trim()
    else:
        ""

fn scv_tag_annotated_list(root: text) -> text:
    val dir = "{scv_meta_dir(root)}/tag_objects"
    if not file_exists(dir):
        return ""
    val tags_path = scv_tags_path(root)
    if not file_exists(tags_path):
        return ""
    var out = ""
    for line in file_read(tags_path).split("\n"):
        val trimmed = line.trim()
        if trimmed == "":
            continue
        val parts = trimmed.split("|")
        if parts.len() >= 1:
            val annotated_id = scv_tag_annotated_get(root, parts[0])
            if annotated_id != "":
                out = out + "{parts[0]}|{annotated_id}\n"
    out
