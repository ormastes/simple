# Document — root DOM container with URL, title, ready-state, and DOM tree.
#
# Mirrors Blink's Document. The Document owns a DomTree, tracks the
# document URL (parsed via url_parser), maintains a title string, and
# exposes lifecycle state (loading, interactive, complete).
#
# This file mirrors third_party/blink/renderer/core/dom/document.h. The
# Document is the root of the DOM tree and holds per-document metadata:
# character set, content type, title, and the WHATWG-parsed URL. The
# ready_state field tracks the HTML5 document lifecycle (Loading ->
# Interactive -> Complete) as driven by the parser and loader.

use std.lib.blink.dom.node.{DomTree, dom_tree_new}
use std.lib.blink.url.url_parser.{ParsedUrl, parse_url}

# ============================================================================
# ReadyState — HTML5 document ready-state enum
# ============================================================================
#
# Mirrors document.readyState values from the HTML Living Standard:
#   Loading      — parser is still processing the document
#   Interactive  — parser has finished, subresources may still load
#   Complete     — document and all subresources have loaded

enum ReadyState:
    Loading
    Interactive
    Complete

# ============================================================================
# Document — the DOM root container
# ============================================================================

class Document:
    tree: DomTree
    url: ParsedUrl
    title: String
    ready_state: ReadyState
    character_set: String
    content_type: String

fn document_new(url_string: String) -> Document:
    val parsed = parse_url(url_string)
    val tree = dom_tree_new()
    Document(
        tree: tree,
        url: parsed,
        title: "",
        ready_state: ReadyState.Loading,
        character_set: "UTF-8",
        content_type: "text/html"
    )

# ============================================================================
# Document methods
# ============================================================================

impl Document:
    me set_title(t: String):
        self.title = t

    me set_ready_state(state: ReadyState):
        self.ready_state = state

    me set_content_type(ct: String):
        self.content_type = ct

    me set_character_set(cs: String):
        self.character_set = cs

    me document_element_id() -> i64:
        self.tree.root_id

    me create_element(tag: String) -> i64:
        self.tree.create_element(tag)

    me create_text_node(text: String) -> i64:
        self.tree.create_text(text)

    me append_to_body(child_id: i64):
        val body_id = self.tree.root_id
        self.tree.append_child(body_id, child_id)

    me is_loading() -> bool:
        self.ready_state == ReadyState.Loading

    me is_complete() -> bool:
        self.ready_state == ReadyState.Complete
