"""2D Rendering Engine — Multi-Backend 2D Graphics

@tag:stdlib
@tag:api
@tag:gpu

A multi-backend 2D rendering engine providing an abstract rendering interface.
Each backend implements the same RenderBackend trait. The engine auto-selects
the best available backend at runtime.

## Architecture

    Apps -> UI Lib -> Browser Engine -> 2D Engine -> Backend

Backends (in priority order):
  1. CUDA   — GPU-accelerated via CUDA kernels (NVIDIA)
  2. ROCm   — GPU-accelerated via HIP (AMD)
  3. Metal  — GPU-accelerated via Metal compute (Apple)
  4. Vulkan — Cross-platform GPU compute shaders
  5. OpenGL — OpenGL 3.3+ with FBO offscreen rendering
  6. Intel  — GPU-accelerated via oneAPI Level Zero (Intel)
  7. Software — Optimized CPU with tile-based rendering + alpha blending
  8. CPU    — Pure software fallback (always available)
  9. Baremetal — OS framebuffer driver bridge (explicit only, not auto-detected)

## Quick Start

    use std.gpu.engine2d.{Engine2D}
    use std.gpu.engine2d.color.{rgb, color_white}

    var engine = Engine2D.create(800, 600)
    engine.clear(color_white())
    engine.draw_rect_filled(10, 10, 200, 100, rgb(255, 0, 0))
    engine.draw_text(20, 40, "Hello!", rgb(0, 0, 0), 14)
    engine.present()

## Layer Compositing

    use std.gpu.engine2d.compositor.{Compositor, Layer}

    var compositor = Compositor.create()
    var bg = Layer.create(0, 0, 800, 600)
    bg.fill(rgb(200, 200, 200))
    compositor.add_layer(bg)

    var fg = Layer.create(100, 100, 200, 200)
    fg.opacity = 0.7
    compositor.add_layer(fg)
    compositor.composite_to_buffer(engine.read_pixels(), 800, 600)

## Submodules

  - backend:          RenderBackend trait (combined Core + Adv)
  - backend_core:     RenderBackendCore trait (minimum required interface)
  - backend_adv:      RenderBackendAdv trait (optimized operations)
  - backend_emu:      Stateless emulation layer (Core → Adv, no internal state)
  - backend_cpu:      Pure software CPU renderer (always available)
  - backend_cuda:     CUDA GPU renderer (NVIDIA GPUs)
  - backend_rocm:     ROCm/HIP GPU renderer (AMD GPUs)
  - backend_metal:    Metal GPU renderer (Apple GPUs)
  - backend_vulkan:   Vulkan GPU renderer (compute shaders)
  - backend_opengl:   OpenGL GPU renderer (FBO offscreen)
  - backend_intel:    Intel oneAPI GPU renderer (Intel GPUs)
  - backend_software: Optimized software renderer (tile-based, alpha blend)
  - backend_baremetal: OS framebuffer driver bridge (explicit selection only)
  - backend_virtio_gpu: VirtIO-GPU backend for QEMU (OS/baremetal only)
  - backend_webgpu:   WebGPU GPU renderer (V3 browser raster path, M7)
  - backend_qualcomm: Qualcomm Adreno backend (Vulkan delegate, Linux arm64)
  - ffi_dispatch:     Dual-path FFI dispatch (static extern fn + dynamic dlopen)
  - ffi_vulkan:       Vulkan FFI dispatch class
  - ffi_cuda:         CUDA FFI dispatch class
  - ffi_rocm:         ROCm/HIP FFI dispatch class
  - ffi_intel:        Intel Level Zero FFI dispatch class
  - simd_kernels:     SIMD-accelerated pixel operations (SSE4.2/AVX2/NEON)
  - engine:           Engine2D facade with auto-detection
  - color:            Color packing, blending, interpolation, hex conversion
  - compositor:       Layer-based compositing with alpha blend
"""

# Re-export public API from submodules
use std.gpu.engine2d.engine.{Engine2D}
use std.gpu.engine2d.backend.{RenderBackend}
use std.gpu.engine2d.backend_core.{RenderBackendCore}
use std.gpu.engine2d.backend_adv.{RenderBackendAdv}
use std.gpu.engine2d.backend_emu.{
    emu_draw_rect, emu_draw_line, emu_draw_circle, emu_draw_circle_filled,
    emu_draw_rounded_rect, emu_draw_triangle_filled, emu_draw_gradient_rect,
    emu_draw_text, emu_draw_text_bg,
    emu_draw_ellipse, emu_draw_ellipse_filled,
    emu_draw_arc, emu_draw_bezier,
    emu_draw_polygon_filled, emu_draw_polyline,
    emu_draw_rect_thick, emu_draw_circle_thick, emu_draw_rounded_rect_outline,
    emu_draw_gradient_rect_h, emu_draw_radial_gradient,
    emu_draw_rect_blend, emu_draw_image_blend,
    emu_draw_image_scaled,
    emu_draw_triangle_outline,
    emu_draw_blur_rect, emu_draw_shadow_rect,
    emu_draw_image_transform,
    emu_draw_rect_blend_mode
}
use std.gpu.engine2d.backend_cpu.{CpuBackend}
use std.gpu.engine2d.backend_cuda.{CudaBackend}
use std.gpu.engine2d.backend_rocm.{RocmBackend}
use std.gpu.engine2d.backend_metal.{MetalBackend}
use std.gpu.engine2d.backend_vulkan.{VulkanBackend}
use std.gpu.engine2d.backend_opengl.{OpenGLBackend}
use std.gpu.engine2d.backend_intel.{IntelBackend}
use std.gpu.engine2d.backend_software.{SoftwareBackend}
use std.gpu.engine2d.backend_baremetal.{BaremetalBackend}
use std.gpu.engine2d.backend_virtio_gpu.{VirtioGpuBackend}
use std.gpu.engine2d.backend_webgpu.{WebGpuBackend}
use std.gpu.engine2d.backend_qualcomm.{QualcommBackend}
use std.gpu.engine2d.ffi_dispatch.{GpuFfiMode, FfiDispatchBase, default_ffi_mode}
use std.gpu.engine2d.ffi_vulkan.{VulkanFfi}
use std.gpu.engine2d.ffi_cuda.{CudaFfi}
use std.gpu.engine2d.ffi_rocm.{RocmFfi}
use std.gpu.engine2d.ffi_intel.{IntelFfi}
use std.gpu.engine2d.simd_kernels.{SimdLevel, detect_simd_level, simd_fill_row, simd_blend_row, simd_blit_row}
use std.gpu.engine2d.color.{
    rgba, rgb, color_r, color_g, color_b, color_a,
    blend, lerp_color, hex_to_color, color_to_hex,
    color_black, color_white, color_red, color_green, color_blue,
    color_yellow, color_cyan, color_magenta, color_transparent, color_gray
}
use std.gpu.engine2d.compositor.{Layer, Compositor}
