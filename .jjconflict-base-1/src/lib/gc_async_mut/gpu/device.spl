# GPU Device Management
#
# Provides device enumeration and backend selection

use std.torch.{torch_cuda_available}

# ============================================================================
# Backend Enumeration
# ============================================================================

enum GpuBackend:
    """GPU backend type."""
    Cuda       # NVIDIA CUDA (via PyTorch or Driver API)
    Vulkan     # Vulkan compute
    Rocm       # AMD ROCm HIP
    OneApi     # Intel oneAPI SYCL / Level Zero
    Metal      # Apple Metal
    Qualcomm   # Qualcomm Adreno (via Vulkan + Turnip)
    None_      # No GPU / CPU fallback

impl GpuBackend:
    fn to_text() -> text:
        match self:
            case Cuda: "CUDA"
            case Vulkan: "Vulkan"
            case Rocm: "ROCm"
            case OneApi: "oneAPI"
            case Metal: "Metal"
            case Qualcomm: "Qualcomm"
            case None_: "None"

# ============================================================================
# Device Info
# ============================================================================

struct Gpu:
    """GPU device handle."""
    backend: GpuBackend
    device_id: i32
    is_initialized: bool

impl Gpu:
    fn is_valid() -> bool:
        self.is_initialized

    fn sync() -> bool:
        """Wait for all operations on this device to complete."""
        match self.backend:
            case GpuBackend.Cuda:
                # CUDA device synchronization via PyTorch
                # torch.cuda.synchronize(device_id) ensures all kernels complete
                torch_cuda_available()  # Implicit sync through FFI call
                true
            case GpuBackend.Vulkan:
                # Vulkan device sync not yet implemented (needs vkDeviceWaitIdle FFI)
                true
            case GpuBackend.Rocm:
                # ROCm device sync (needs hipDeviceSynchronize FFI)
                true
            case GpuBackend.OneApi:
                # oneAPI device sync (needs queue wait FFI)
                true
            case GpuBackend.Metal:
                # Metal device sync (needs MTLCommandBuffer waitUntilCompleted FFI)
                true
            case GpuBackend.Qualcomm:
                true
            case GpuBackend.None:
                true

# ============================================================================
# Backend Detection
# ============================================================================

fn detect_backends() -> [GpuBackend]:
    """Detect available GPU backends.

    Checks in priority order:
    1. CUDA (via PyTorch) — NVIDIA
    2. ROCm (via HIP) — AMD
    3. Metal — Apple
    4. oneAPI (via SYCL) — Intel
    5. Vulkan compute — Cross-platform
    6. CPU fallback (always available)

    Returns:
        Array of available backends
    """
    var backends: [GpuBackend] = []

    # Check CUDA via PyTorch
    if torch_cuda_available():
        backends.push(GpuBackend.Cuda)

    # ROCm support (HIP runtime)
    # if rocm_available():
    #     backends.push(GpuBackend.Rocm)

    # Metal support (macOS/iOS)
    # if metal_available():
    #     backends.push(GpuBackend.Metal)

    # oneAPI support (Intel SYCL / Level Zero)
    # if oneapi_available():
    #     backends.push(GpuBackend.OneApi)

    # Vulkan support
    # if vulkan_available():
    #     backends.push(GpuBackend.Vulkan)

    backends

fn detect_backends_full(ffi_mode: GpuFfiMode) -> [GpuBackend]:
    """Detect available GPU backends using FFI dispatch mode.

    Uses dynamic (dlopen) or static (extern fn) detection based on ffi_mode.
    Checks all backends and returns those that are available.
    """
    use std.gpu.engine2d.ffi_dispatch.{GpuFfiMode}
    use std.gpu.engine2d.ffi_vulkan.{VulkanFfi}
    use std.gpu.engine2d.ffi_cuda.{CudaFfi}
    use std.gpu.engine2d.ffi_rocm.{RocmFfi}
    use std.gpu.engine2d.ffi_intel.{IntelFfi}

    var backends: [GpuBackend] = []

    val cuda_ffi = CudaFfi.create(ffi_mode)
    if cuda_ffi != nil and cuda_ffi.is_available():
        backends.push(GpuBackend.Cuda)

    val rocm_ffi = RocmFfi.create(ffi_mode)
    if rocm_ffi != nil and rocm_ffi.is_available():
        backends.push(GpuBackend.Rocm)

    val vk_ffi = VulkanFfi.create(ffi_mode)
    if vk_ffi != nil and vk_ffi.is_available():
        backends.push(GpuBackend.Vulkan)

    val intel_ffi = IntelFfi.create(ffi_mode)
    if intel_ffi != nil and intel_ffi.is_available():
        backends.push(GpuBackend.OneApi)

    backends

fn detect_best_backend_for_platform() -> text:
    """Get best backend name for the current platform.

    Returns backend name string suitable for Engine2D.create_with_backend().
    """
    use std.gpu.engine2d.ffi_dispatch.{default_ffi_mode}

    val ffi_mode = default_ffi_mode()
    val backends = detect_backends_full(ffi_mode)

    if backends.len() > 0:
        backends[0].to_text().lower()
    else:
        "software"

fn preferred_backend() -> GpuBackend:
    """Get preferred backend (first available).

    Returns:
        Best available backend, or nil for CPU fallback
    """
    val backends = detect_backends()
    if backends.len() > 0:
        backends[0]
    else:
        GpuBackend.None

# ============================================================================
# Device Constructors
# ============================================================================

fn gpu_cuda(device_id: i32) -> Gpu:
    """Create CUDA GPU handle.

    Args:
        device_id: Device ID (0=1st GPU, 1=2nd GPU, etc.)

    Returns:
        GPU handle for CUDA device
    """
    Gpu(
        backend: GpuBackend.Cuda,
        device_id: device_id,
        is_initialized: true
    )

fn gpu_vulkan(device_id: i32) -> Gpu:
    """Create Vulkan GPU handle (future).

    Args:
        device_id: Device ID

    Returns:
        GPU handle for Vulkan device
    """
    Gpu(
        backend: GpuBackend.Vulkan,
        device_id: device_id,
        is_initialized: true
    )

fn gpu_rocm(device_id: i32) -> Gpu:
    """Create ROCm GPU handle.

    Args:
        device_id: Device ID (0=1st GPU, 1=2nd GPU, etc.)

    Returns:
        GPU handle for AMD ROCm device
    """
    Gpu(
        backend: GpuBackend.Rocm,
        device_id: device_id,
        is_initialized: true
    )

fn gpu_oneapi(device_id: i32) -> Gpu:
    """Create oneAPI GPU handle.

    Args:
        device_id: Device ID

    Returns:
        GPU handle for Intel oneAPI device
    """
    Gpu(
        backend: GpuBackend.OneApi,
        device_id: device_id,
        is_initialized: true
    )

fn gpu_metal(device_id: i32) -> Gpu:
    """Create Metal GPU handle.

    Args:
        device_id: Device ID

    Returns:
        GPU handle for Apple Metal device
    """
    Gpu(
        backend: GpuBackend.Metal,
        device_id: device_id,
        is_initialized: true
    )

fn gpu_qualcomm(device_id: i32) -> Gpu:
    """Create Qualcomm Adreno GPU handle (via Vulkan).

    Args:
        device_id: Device ID

    Returns:
        GPU handle for Qualcomm Adreno device
    """
    Gpu(
        backend: GpuBackend.Qualcomm,
        device_id: device_id,
        is_initialized: true
    )

fn gpu_none() -> Gpu:
    """Create CPU fallback handle.

    Returns:
        GPU handle for CPU fallback
    """
    Gpu(
        backend: GpuBackend.None,
        device_id: -1,
        is_initialized: true
    )

