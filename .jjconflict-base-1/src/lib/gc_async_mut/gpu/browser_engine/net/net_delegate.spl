"""
# NetDelegate

Lazy seam interface between BrowserRenderer and the net stack.
browser_renderer never imports concrete net modules — only this interface.
NoopNetDelegate is the default; used in headless/corpus tests (D-3).
"""

#![allow(REQC001)]

use std.gc_async_mut.gpu.browser_engine.net.entity.url_types.{Url}
use std.gc_async_mut.gpu.browser_engine.net.entity.request_types.{FetchRequest, FetchResponse}

pub trait NetDelegate:
    """Interface between BrowserRenderer and the net stack."""
    fn navigate(url: Url) -> FetchResponse
    fn fetch(request: FetchRequest) -> FetchResponse

pub class NoopNetDelegate:
    """A NetDelegate that performs no network I/O.

    Returns zero-status empty responses so the renderer stays headless during
    corpus/pixel-exact tests. Satisfies the NetDelegate trait.
    """

    static fn new() -> NoopNetDelegate:
        """Create a NoopNetDelegate."""
        return NoopNetDelegate {}

    me fn navigate(url: Url) -> FetchResponse:
        """Return an empty zero-status response (no network call)."""
        return FetchResponse {
            status: 0,
            headers: "",
            body: []
        }

    me fn fetch(request: FetchRequest) -> FetchResponse:
        """Return an empty zero-status response (no network call)."""
        return FetchResponse {
            status: 0,
            headers: "",
            body: []
        }
