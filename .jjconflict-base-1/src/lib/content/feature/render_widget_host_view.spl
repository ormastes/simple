# RenderWidgetHostView: receives CompositorFrames and dispatches input events

use std.viz.entity.compositor_frame.{CompositorFrame}
use std.viz.entity.surface_id.{SurfaceId}
use std.viz.feature.display_compositor.{DisplayCompositor}
use std.viz.feature.aggregator.{AggregatorEntry}
use std.skia.entity.geometry.{SkRect, SkIRect}

enum InputEventKind:
    MouseDown
    MouseUp
    MouseMove
    KeyDown
    KeyUp
    Scroll

class InputEvent:
    kind: InputEventKind
    x: i32
    y: i32
    data: i32

class RenderWidgetHostView:
    surface_id: SurfaceId
    bounds: SkRect
    display_compositor: DisplayCompositor
    pending_input: [InputEvent]

    static fn new(surface_id: SurfaceId, bounds: SkRect, dc: DisplayCompositor) -> RenderWidgetHostView:
        RenderWidgetHostView(
            surface_id: surface_id,
            bounds: bounds,
            display_compositor: dc,
            pending_input: [InputEvent]()
        )

    me submit_compositor_frame(frame: CompositorFrame):
        val entry = AggregatorEntry(
            surface_id: me.surface_id,
            frame: frame
        )
        me.display_compositor.submit_frame(entry)

    me dispatch_input(event: InputEvent):
        me.pending_input = me.pending_input + [event]

    me draw():
        val _frame = me.display_compositor.draw_frame(me.surface_id)

    me pending_input_count() -> i32:
        me.pending_input.len().to_i32()
