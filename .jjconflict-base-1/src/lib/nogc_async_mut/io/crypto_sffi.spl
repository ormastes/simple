"""
# No-GC async io crypto ffi

Compatibility facade over the no-GC sync backend.
"""

export use std.nogc_sync_mut.io.crypto_sffi.{
    hash_sha256, hash_sha512, hash_sha3_256, hash_blake3, hash,
    hmac_sha256, hmac_sha512, hmac,
    password_hash, password_verify, password_check,
    password_hash_bcrypt, password_verify_bcrypt,
    encrypt_aes256, decrypt_aes256, encrypt, decrypt,
    generate_key, generate_key_hex, generate_aes256_key,
    derive_key_pbkdf2, derive_key,
    random_bytes, random_hex, random_salt,
    hash_verify, hmac_verify
}
