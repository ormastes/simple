# Editor Markdown Preview Pane
#
# Live preview pane for Markdown files. Wraps a BlockModel and renders
# it via md_render_blocks_for_tui. Supports scroll sync that maps the
# source cursor line to a viewport offset in the rendered output.

struct PreviewPane:
    pane_id: i64
    source_pane_id: i64
    model: BlockModel
    viewport_start: i64
    scroll_sync: bool

fn preview_pane_create(source_pane_id: i64) -> PreviewPane:
    val model = BlockModel.from_markdown("")
    PreviewPane(
        pane_id: source_pane_id + 1000,
        source_pane_id: source_pane_id,
        model: model,
        viewport_start: 0,
        scroll_sync: true
    )

fn preview_pane_update(pane: PreviewPane, content: text) -> PreviewPane:
    val new_model = BlockModel.from_markdown(content)
    PreviewPane(
        pane_id: pane.pane_id,
        source_pane_id: pane.source_pane_id,
        model: new_model,
        viewport_start: pane.viewport_start,
        scroll_sync: pane.scroll_sync
    )

fn preview_pane_render(pane: PreviewPane, height: i64) -> [text]:
    md_render_blocks_for_tui(pane.model, pane.viewport_start, height)

fn preview_pane_sync_scroll(pane: PreviewPane, source_cursor_line: i64) -> PreviewPane:
    if not pane.scroll_sync:
        return pane
    val block_idx = pane.model.block_for_line(source_cursor_line)
    var offset = 0
    if block_idx > 0:
        var i = 0
        while i < block_idx:
            val block = pane.model.block_at(i)
            offset = offset + (block.to_line - block.from_line + 1)
            i = i + 1
    PreviewPane(
        pane_id: pane.pane_id,
        source_pane_id: pane.source_pane_id,
        model: pane.model,
        viewport_start: offset,
        scroll_sync: pane.scroll_sync
    )

fn preview_pane_toggle_scroll_sync(pane: PreviewPane) -> PreviewPane:
    PreviewPane(
        pane_id: pane.pane_id,
        source_pane_id: pane.source_pane_id,
        model: pane.model,
        viewport_start: pane.viewport_start,
        scroll_sync: not pane.scroll_sync
    )

fn preview_pane_scroll(pane: PreviewPane, delta: i64, max_lines: i64) -> PreviewPane:
    var new_start = pane.viewport_start + delta
    if new_start < 0:
        new_start = 0
    if new_start >= max_lines:
        new_start = max_lines - 1
    if new_start < 0:
        new_start = 0
    PreviewPane(
        pane_id: pane.pane_id,
        source_pane_id: pane.source_pane_id,
        model: pane.model,
        viewport_start: new_start,
        scroll_sync: pane.scroll_sync
    )
