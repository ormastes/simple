
use std.nogc_sync_mut.debug.remote.replay.memory_snapshot.MemorySnapshot

enum RemoteReplayMode:
    Off
    Record
    Replay

    fn to_text(self) -> text:
        match self:
            RemoteReplayMode::Off => "off"
            RemoteReplayMode::Record => "record"
            RemoteReplayMode::Replay => "replay"

struct RemoteReplayEvent:
    seq_id: i64
    kind: text
    addr: i64
    name: text
    value: i64
    timestamp: i64

struct RemoteCheckpoint:
    id: i32
    event_index: i64
    gdb_checkpoint_id: text
    registers: [i64]
    memory_regions: [MemorySnapshot]

class RemoteReplayAdapter:
    mode: RemoteReplayMode
    events: [RemoteReplayEvent]
    checkpoints: [RemoteCheckpoint]
    _seq: i64

    static fn create(mode: RemoteReplayMode) -> RemoteReplayAdapter:
        RemoteReplayAdapter(
            mode: mode,
            events: [],
            checkpoints: [],
            _seq: 0
        )

    me fn push_event(kind: text, addr: i64, name: text, value: i64):
        val ev = RemoteReplayEvent(
            seq_id: self._seq,
            kind: kind,
            addr: addr,
            name: name,
            value: value,
            timestamp: 0
        )
        self.events.push(ev)
        self._seq = self._seq + 1

    me fn on_register_read(name: text, value: i64):
        match self.mode:
            RemoteReplayMode::Record => self.push_event("register_read", 0, name, value)
            _ => pass_dn

    me fn on_memory_read(addr: i64, size: i32, data: i64):
        match self.mode:
            RemoteReplayMode::Record => self.push_event("memory_read", addr, "", data)
            _ => pass_dn

    me fn on_breakpoint_hit(addr: i64, file: text, line: i32):
        match self.mode:
            RemoteReplayMode::Record => self.push_event("breakpoint_hit", addr, file, line as i64)
            _ => pass_dn

    me fn on_step_complete(pc: i64, file: text, line: i32):
        match self.mode:
            RemoteReplayMode::Record => self.push_event("step_complete", pc, file, line as i64)
            _ => pass_dn

    me fn save_checkpoint(name: text):
        val id = self.checkpoints.len() as i32
        val cp = RemoteCheckpoint(
            id: id,
            event_index: self.events.len() as i64,
            gdb_checkpoint_id: name,
            registers: [],
            memory_regions: []
        )
        self.checkpoints.push(cp)

    me fn restore_checkpoint(name: text):
        var i = 0
        while i < self.checkpoints.len():
            val cp = self.checkpoints[i]
            if cp.gdb_checkpoint_id == name:
                val target = cp.event_index as i32
                while self.events.len() > target:
                    self.events.pop()
                return
            i = i + 1

    me fn reverse_step():
        if self.events.len() > 0:
            self.events.pop()

    me fn reverse_continue():
        var i = self.events.len() - 1
        while i > 0:
            val ev = self.events[i]
            if ev.kind == "breakpoint_hit":
                while self.events.len() > i:
                    self.events.pop()
                return
            i = i - 1

    fn event_count() -> i64:
        self.events.len() as i64
