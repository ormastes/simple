# Durability — flush / FUA discipline attached to a FlushRequest.
#
# Maps to NVMe Flush + FUA (Force Unit Access) semantics. A spostgre commit
# decides which class its WAL flush uses; NVFS honors it through the arena
# layer. See doc/05_design/nvfs/from_spostgre.md §S7.

enum DurabilityClass:
    """Three durability levels for a flush.

    BestEffort    — no explicit barrier; rely on periodic bg flush.
    Flush         — emit NVMe Flush before returning success.
    FlushFua      — per-write FUA + final Flush, used by WAL fsync.
    """
    BestEffort
    Flush
    FlushFua

impl DurabilityClass:
    fn to_string() -> text:
        match self:
            case BestEffort: "BestEffort"
            case Flush: "Flush"
            case FlushFua: "FlushFua"

struct FlushRequest:
    """A request to publish durability for a range of arena appends.

    Fields:
      arena_id      — opaque arena identifier (see storage.arena.ArenaHandle).
      low_gen       — first generation to include in the flush.
      high_gen      — last generation (inclusive) to include.
      durability    — requested class (Flush / FlushFua / BestEffort).
    """
    arena_id: i64
    low_gen: i64
    high_gen: i64
    durability: DurabilityClass
