# Listener System — ECS components for audio
#
# Provides AudioListenerComponent and AudioSourceComponent for use
# in an ECS-style game engine. Sources track previous position for
# velocity-based Doppler calculations.
#
# Usage:
#   val listener = AudioListenerComponent.primary()
#   var source = AudioSourceComponent.new("sfx/engine.wav", "sfx")
#   val vel = source.velocity_3d(cur_x, cur_y, cur_z, dt)

use std.common.engine.math2d.{Vec2}
use std.common.engine.math3d.{Vec3}
use std.nogc_sync_mut.engine.audio.types.{SoundHandle}

# ============================================================================
# AudioListenerComponent — Marks an entity as an audio listener
# ============================================================================

struct AudioListenerComponent:
    """ECS component marking an entity as an audio listener.

    Only the primary listener drives the miniaudio listener state.
    """
    is_primary: bool

impl AudioListenerComponent:
    static fn primary() -> AudioListenerComponent:
        """Create a primary listener component."""
        AudioListenerComponent(is_primary: true)

    static fn secondary() -> AudioListenerComponent:
        """Create a secondary (non-primary) listener component."""
        AudioListenerComponent(is_primary: false)

# ============================================================================
# AudioSourceComponent — Attaches audio playback to an entity
# ============================================================================

struct AudioSourceComponent:
    """ECS component for an entity that emits audio.

    Tracks clip path, group, volume, spatial flag, auto-play,
    the active SoundHandle, and previous position for velocity.
    """
    clip_path: text
    group_name: text
    volume: f64
    spatial: bool
    auto_play: bool
    handle: SoundHandle
    prev_x: f64
    prev_y: f64
    prev_z: f64

impl AudioSourceComponent:
    static fn new(clip_path: text, group_name: text) -> AudioSourceComponent:
        """Create a source component with default volume and no active handle."""
        AudioSourceComponent(
            clip_path: clip_path,
            group_name: group_name,
            volume: 1.0,
            spatial: true,
            auto_play: false,
            handle: SoundHandle(
                playback_handle: 0,
                clip_path: clip_path,
                bus_name: group_name,
                is_spatial: true
            ),
            prev_x: 0.0,
            prev_y: 0.0,
            prev_z: 0.0
        )

    fn velocity_3d(cur_x: f64, cur_y: f64, cur_z: f64, dt: f64) -> Vec3:
        """Compute velocity from previous position to current, divided by dt.

        Returns zero vector if dt is zero or negative.
        """
        if dt <= 0.0:
            return Vec3.zero()
        Vec3(
            x: (cur_x - self.prev_x) / dt,
            y: (cur_y - self.prev_y) / dt,
            z: (cur_z - self.prev_z) / dt
        )
