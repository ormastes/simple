"""CUDA SFFI Dispatch — Static/Dynamic Dual-Path

@tag:stdlib
@tag:gpu

Wraps CUDA Driver API functions behind a CudaFfi class supporting
both static (extern fn rt_cuda_*) and dynamic (DynLib libcuda.so) dispatch.

Usage:
    val sffi = CudaFfi.create(GpuFfiMode.Dynamic)
    if ffi.is_available():
        ffi.init()
"""

use std.sffi.dynamic.{DynLib}
use std.gpu.engine2d.sffi_dispatch.{GpuFfiMode, FfiDispatchBase, try_load_gpu_lib}

# ============================================================================
# Static extern declarations
# ============================================================================

extern fn rt_cuda_available() -> i64
extern fn rt_cuda_init() -> i64
extern fn rt_cuda_shutdown() -> i64
extern fn rt_cuda_device_count() -> i64
extern fn rt_cuda_device_get(id: i64) -> i64
extern fn rt_cuda_ctx_create(device: i64) -> i64
extern fn rt_cuda_ctx_destroy(ctx: i64) -> i64
extern fn rt_cuda_module_load(ptx: text) -> i64
extern fn rt_cuda_module_load_data(ptx: text) -> i64
extern fn rt_cuda_module_unload(module: i64) -> i64
extern fn rt_cuda_module_get_function(module: i64, name: text) -> i64
extern fn rt_cuda_launch_kernel(module: i64, name: text, gx: i64, gy: i64, gz: i64, bx: i64, by: i64, bz: i64, args_ptr: i64) -> i64
extern fn rt_cuda_mem_alloc(size: i64) -> i64
extern fn rt_cuda_mem_free(ptr: i64) -> i64
extern fn rt_cuda_memcpy_htod(dst: i64, src: [u8], size: i64) -> i64
extern fn rt_cuda_memcpy_dtoh(dst: [u8], src: i64, size: i64) -> i64
extern fn rt_cuda_sync() -> i64
extern fn rt_engine2d_pack_args_4(a: i64, b: i64, c: i64, d: i64) -> i64
extern fn rt_engine2d_pack_args_8(a: i64, b: i64, c: i64, d: i64, e: i64, f: i64, g: i64, h: i64) -> i64
extern fn rt_engine2d_upload_pixels(d_dst: i64, pixels: [u32], count: i64) -> i64
extern fn rt_engine2d_download_pixels(d_src: i64, pixels: [u32], byte_size: i64) -> i64
extern fn rt_engine2d_upload_host_buf(d_dst: i64, host_buf: [u32], byte_size: i64) -> i64

fn cuda_engine2d_pack_args_4(a: i64, b: i64, c: i64, d: i64) -> i64:
    rt_engine2d_pack_args_4(a, b, c, d)

fn cuda_engine2d_pack_args_8(a: i64, b: i64, c: i64, d: i64, e: i64, f: i64, g: i64, h: i64) -> i64:
    rt_engine2d_pack_args_8(a, b, c, d, e, f, g, h)

fn cuda_engine2d_upload_pixels(d_dst: i64, pixels: [u32], count: i64) -> i64:
    rt_engine2d_upload_pixels(d_dst, pixels, count)

fn cuda_engine2d_download_pixels(d_src: i64, pixels: [u32], byte_size: i64) -> i64:
    rt_engine2d_download_pixels(d_src, pixels, byte_size)

fn cuda_engine2d_upload_host_buf(d_dst: i64, host_buf: [u32], byte_size: i64) -> i64:
    rt_engine2d_upload_host_buf(d_dst, host_buf, byte_size)

# ============================================================================
# CudaFfi
# ============================================================================

class CudaFfi:
    _mode: GpuFfiMode
    _dyn_lib: DynLib?

impl CudaFfi:
    static fn create_static() -> CudaFfi:
        CudaFfi(_mode: GpuFfiMode.Static, _dyn_lib: nil)

    static fn create_dynamic() -> CudaFfi?:
        val lib = try_load_gpu_lib("cuda")
        if lib == nil:
            return nil
        CudaFfi(_mode: GpuFfiMode.Dynamic, _dyn_lib: lib)

    static fn create_dynamic_from(path: text) -> CudaFfi?:
        val lib = DynLib.load(path)
        if lib == nil:
            return nil
        CudaFfi(_mode: GpuFfiMode.Dynamic, _dyn_lib: lib)

    static fn create(sffi_mode: GpuFfiMode) -> CudaFfi?:
        match sffi_mode:
            case Dynamic:
                val dyn_sffi = CudaFfi.create_dynamic()
                if dyn_sffi != nil:
                    return dyn_sffi
                CudaFfi.create_static()
            case Static:
                CudaFfi.create_static()

impl FfiDispatchBase for CudaFfi:

    fn mode() -> GpuFfiMode:
        self._mode

    fn api_name() -> text:
        "CUDA Driver API"

    fn is_available() -> bool:
        match self._mode:
            case Static: rt_cuda_available() != 0
            case Dynamic:
                if self._dyn_lib != nil:
                    val result = self._dyn_lib.call0("cuInit")
                    result == 0
                else:
                    false

    fn init() -> bool:
        match self._mode:
            case Static: rt_cuda_init() == 0
            case Dynamic:
                if self._dyn_lib != nil:
                    val result = self._dyn_lib.call1("cuInit", 0)
                    result == 0
                else:
                    false

    fn shutdown() -> bool:
        match self._mode:
            case Static: rt_cuda_shutdown() == 0
            case Dynamic: true

    fn device_count() -> i64:
        match self._mode:
            case Static: rt_cuda_device_count()
            case Dynamic:
                if self._dyn_lib != nil:
                    self._dyn_lib.call0("cuDeviceGetCount")
                else:
                    0

    fn ctx_create(device: i64) -> i64:
        match self._mode:
            case Static:
                val ctx = rt_cuda_ctx_create(device)
                if ctx < 0: 0 else: ctx
            case Dynamic:
                if self._dyn_lib != nil:
                    self._dyn_lib.call2("cuCtxCreate", 0, device)
                else:
                    0

    fn ctx_destroy(ctx: i64) -> bool:
        match self._mode:
            case Static: rt_cuda_ctx_destroy(ctx) == 0
            case Dynamic:
                if self._dyn_lib != nil:
                    val result = self._dyn_lib.call1("cuCtxDestroy", ctx)
                    result == 0
                else:
                    false

    fn module_load_ptx(ptx: text) -> i64:
        match self._mode:
            case Static:
                val module = rt_cuda_module_load_data(ptx)
                if module < 0: 0 else: module
            case Dynamic: 0

    fn module_unload(module: i64) -> bool:
        match self._mode:
            case Static: rt_cuda_module_unload(module) == 0
            case Dynamic:
                if self._dyn_lib != nil:
                    val result = self._dyn_lib.call1("cuModuleUnload", module)
                    result == 0
                else:
                    false

    fn kernel_get(module: i64, name: text) -> i64:
        match self._mode:
            case Static: rt_cuda_module_get_function(module, name)
            case Dynamic: 0

    fn launch_kernel(module: i64, name: text, gx: i64, gy: i64, gz: i64, bx: i64, by: i64, bz: i64, args_ptr: i64) -> bool:
        match self._mode:
            case Static: rt_cuda_launch_kernel(module, name, gx, gy, gz, bx, by, bz, args_ptr) == 0
            case Dynamic: false

    fn mem_alloc(size: i64) -> i64:
        match self._mode:
            case Static:
                val ptr = rt_cuda_mem_alloc(size)
                if ptr < 0: 0 else: ptr
            case Dynamic:
                if self._dyn_lib != nil:
                    self._dyn_lib.call1("cuMemAlloc", size)
                else:
                    0

    fn mem_free(ptr: i64) -> bool:
        match self._mode:
            case Static: rt_cuda_mem_free(ptr) == 0
            case Dynamic:
                if self._dyn_lib != nil:
                    val result = self._dyn_lib.call1("cuMemFree", ptr)
                    result == 0
                else:
                    false

    fn synchronize() -> bool:
        match self._mode:
            case Static: rt_cuda_sync() == 0
            case Dynamic:
                if self._dyn_lib != nil:
                    val result = self._dyn_lib.call0("cuCtxSynchronize")
                    result == 0
                else:
                    false
