# QPACK Static Table — RFC 9204 Appendix A
#
# The QPACK static table contains 99 entries (indices 0..98) of
# pre-defined header field (name, value) pairs. Decoders use this
# table to resolve static-indexed references without dynamic state.
#
# This module provides:
#   - QpackStaticEntry class (name, value)
#   - qpack_static_table() → [QpackStaticEntry]  (the full 99-entry table)
#   - qpack_static_lookup(index) → QpackStaticEntry?  (bounds-checked lookup)
#   - qpack_static_find_name(name) → i64  (first index matching name, or -1)
#   - qpack_static_find_exact(name, value) → i64  (exact match, or -1)
#
# Reference: RFC 9204 §3.1, Appendix A

# ============================================================================
# Entry type
# ============================================================================

pub class QpackStaticEntry:
    """One entry in the QPACK static table: (name, value)."""
    name: text
    value: text

# ============================================================================
# Static table — RFC 9204 Appendix A (99 entries, indices 0..98)
# ============================================================================

pub fn qpack_static_table() -> [QpackStaticEntry]:
    """Return the full QPACK static table (99 entries per RFC 9204 Appendix A)."""
    var t: [QpackStaticEntry] = []
    # 0
    t.push(QpackStaticEntry(name: ":authority", value: ""))
    # 1
    t.push(QpackStaticEntry(name: ":path", value: "/"))
    # 2
    t.push(QpackStaticEntry(name: "age", value: "0"))
    # 3
    t.push(QpackStaticEntry(name: "content-disposition", value: ""))
    # 4
    t.push(QpackStaticEntry(name: "content-length", value: "0"))
    # 5
    t.push(QpackStaticEntry(name: "cookie", value: ""))
    # 6
    t.push(QpackStaticEntry(name: "date", value: ""))
    # 7
    t.push(QpackStaticEntry(name: "etag", value: ""))
    # 8
    t.push(QpackStaticEntry(name: "if-modified-since", value: ""))
    # 9
    t.push(QpackStaticEntry(name: "if-none-match", value: ""))
    # 10
    t.push(QpackStaticEntry(name: "last-modified", value: ""))
    # 11
    t.push(QpackStaticEntry(name: "link", value: ""))
    # 12
    t.push(QpackStaticEntry(name: "location", value: ""))
    # 13
    t.push(QpackStaticEntry(name: "referer", value: ""))
    # 14
    t.push(QpackStaticEntry(name: "set-cookie", value: ""))
    # 15
    t.push(QpackStaticEntry(name: ":method", value: "CONNECT"))
    # 16
    t.push(QpackStaticEntry(name: ":method", value: "DELETE"))
    # 17
    t.push(QpackStaticEntry(name: ":method", value: "GET"))
    # 18
    t.push(QpackStaticEntry(name: ":method", value: "HEAD"))
    # 19
    t.push(QpackStaticEntry(name: ":method", value: "OPTIONS"))
    # 20
    t.push(QpackStaticEntry(name: ":method", value: "POST"))
    # 21
    t.push(QpackStaticEntry(name: ":method", value: "PUT"))
    # 22
    t.push(QpackStaticEntry(name: ":scheme", value: "http"))
    # 23
    t.push(QpackStaticEntry(name: ":scheme", value: "https"))
    # 24
    t.push(QpackStaticEntry(name: ":status", value: "103"))
    # 25
    t.push(QpackStaticEntry(name: ":status", value: "200"))
    # 26
    t.push(QpackStaticEntry(name: ":status", value: "304"))
    # 27
    t.push(QpackStaticEntry(name: ":status", value: "404"))
    # 28
    t.push(QpackStaticEntry(name: ":status", value: "503"))
    # 29
    t.push(QpackStaticEntry(name: "accept", value: "*/*"))
    # 30
    t.push(QpackStaticEntry(name: "accept", value: "application/dns-message"))
    # 31
    t.push(QpackStaticEntry(name: "accept-encoding", value: "gzip, deflate, br"))
    # 32
    t.push(QpackStaticEntry(name: "accept-ranges", value: "bytes"))
    # 33
    t.push(QpackStaticEntry(name: "access-control-allow-headers", value: "cache-control"))
    # 34
    t.push(QpackStaticEntry(name: "access-control-allow-headers", value: "content-type"))
    # 35
    t.push(QpackStaticEntry(name: "access-control-allow-origin", value: "*"))
    # 36
    t.push(QpackStaticEntry(name: "cache-control", value: "max-age=0"))
    # 37
    t.push(QpackStaticEntry(name: "cache-control", value: "max-age=2592000"))
    # 38
    t.push(QpackStaticEntry(name: "cache-control", value: "max-age=604800"))
    # 39
    t.push(QpackStaticEntry(name: "cache-control", value: "no-cache"))
    # 40
    t.push(QpackStaticEntry(name: "cache-control", value: "no-store"))
    # 41
    t.push(QpackStaticEntry(name: "cache-control", value: "public, max-age=31536000"))
    # 42
    t.push(QpackStaticEntry(name: "content-encoding", value: "br"))
    # 43
    t.push(QpackStaticEntry(name: "content-encoding", value: "gzip"))
    # 44
    t.push(QpackStaticEntry(name: "content-type", value: "application/dns-message"))
    # 45
    t.push(QpackStaticEntry(name: "content-type", value: "application/javascript"))
    # 46
    t.push(QpackStaticEntry(name: "content-type", value: "application/json"))
    # 47
    t.push(QpackStaticEntry(name: "content-type", value: "application/x-www-form-urlencoded"))
    # 48
    t.push(QpackStaticEntry(name: "content-type", value: "image/gif"))
    # 49
    t.push(QpackStaticEntry(name: "content-type", value: "image/jpeg"))
    # 50
    t.push(QpackStaticEntry(name: "content-type", value: "image/png"))
    # 51
    t.push(QpackStaticEntry(name: "content-type", value: "text/css"))
    # 52
    t.push(QpackStaticEntry(name: "content-type", value: "text/html; charset=utf-8"))
    # 53
    t.push(QpackStaticEntry(name: "content-type", value: "text/plain"))
    # 54
    t.push(QpackStaticEntry(name: "content-type", value: "text/plain;charset=utf-8"))
    # 55
    t.push(QpackStaticEntry(name: "range", value: "bytes=0-"))
    # 56
    t.push(QpackStaticEntry(name: "strict-transport-security", value: "max-age=31536000"))
    # 57
    t.push(QpackStaticEntry(name: "strict-transport-security", value: "max-age=31536000; includesubdomains"))
    # 58
    t.push(QpackStaticEntry(name: "strict-transport-security", value: "max-age=31536000; includesubdomains; preload"))
    # 59
    t.push(QpackStaticEntry(name: "vary", value: "accept-encoding"))
    # 60
    t.push(QpackStaticEntry(name: "vary", value: "origin"))
    # 61
    t.push(QpackStaticEntry(name: "x-content-type-options", value: "nosniff"))
    # 62
    t.push(QpackStaticEntry(name: "x-xss-protection", value: "1; mode=block"))
    # 63
    t.push(QpackStaticEntry(name: ":status", value: "100"))
    # 64
    t.push(QpackStaticEntry(name: ":status", value: "204"))
    # 65
    t.push(QpackStaticEntry(name: ":status", value: "206"))
    # 66
    t.push(QpackStaticEntry(name: ":status", value: "302"))
    # 67
    t.push(QpackStaticEntry(name: ":status", value: "400"))
    # 68
    t.push(QpackStaticEntry(name: ":status", value: "403"))
    # 69
    t.push(QpackStaticEntry(name: ":status", value: "421"))
    # 70
    t.push(QpackStaticEntry(name: ":status", value: "425"))
    # 71
    t.push(QpackStaticEntry(name: ":status", value: "500"))
    # 72
    t.push(QpackStaticEntry(name: "accept-language", value: ""))
    # 73
    t.push(QpackStaticEntry(name: "access-control-allow-credentials", value: "FALSE"))
    # 74
    t.push(QpackStaticEntry(name: "access-control-allow-credentials", value: "TRUE"))
    # 75
    t.push(QpackStaticEntry(name: "access-control-allow-headers", value: "*"))
    # 76
    t.push(QpackStaticEntry(name: "access-control-allow-methods", value: "get"))
    # 77
    t.push(QpackStaticEntry(name: "access-control-allow-methods", value: "get, post, options"))
    # 78
    t.push(QpackStaticEntry(name: "access-control-allow-methods", value: "options"))
    # 79
    t.push(QpackStaticEntry(name: "access-control-expose-headers", value: "content-length"))
    # 80
    t.push(QpackStaticEntry(name: "access-control-request-headers", value: "content-type"))
    # 81
    t.push(QpackStaticEntry(name: "access-control-request-method", value: "get"))
    # 82
    t.push(QpackStaticEntry(name: "access-control-request-method", value: "post"))
    # 83
    t.push(QpackStaticEntry(name: "alt-svc", value: "clear"))
    # 84
    t.push(QpackStaticEntry(name: "authorization", value: ""))
    # 85
    t.push(QpackStaticEntry(name: "content-security-policy", value: "script-src 'none'; object-src 'none'; base-uri 'none'"))
    # 86
    t.push(QpackStaticEntry(name: "early-data", value: "1"))
    # 87
    t.push(QpackStaticEntry(name: "expect-ct", value: ""))
    # 88
    t.push(QpackStaticEntry(name: "forwarded", value: ""))
    # 89
    t.push(QpackStaticEntry(name: "if-range", value: ""))
    # 90
    t.push(QpackStaticEntry(name: "origin", value: ""))
    # 91
    t.push(QpackStaticEntry(name: "purpose", value: "prefetch"))
    # 92
    t.push(QpackStaticEntry(name: "server", value: ""))
    # 93
    t.push(QpackStaticEntry(name: "timing-allow-origin", value: "*"))
    # 94
    t.push(QpackStaticEntry(name: "upgrade-insecure-requests", value: "1"))
    # 95
    t.push(QpackStaticEntry(name: "user-agent", value: ""))
    # 96
    t.push(QpackStaticEntry(name: "x-forwarded-for", value: ""))
    # 97
    t.push(QpackStaticEntry(name: "x-frame-options", value: "deny"))
    # 98
    t.push(QpackStaticEntry(name: "x-frame-options", value: "sameorigin"))
    return t

# ============================================================================
# Lookup helpers
# ============================================================================

pub fn qpack_static_lookup(index: i64) -> QpackStaticEntry:
    """Look up a static table entry by index (0..98).

    Returns the entry at the given index. Caller must bounds-check:
    index >= 0 and index < 99.
    """
    val table = qpack_static_table()
    return table[index]

pub fn qpack_static_find_name(name: text) -> i64:
    """Find the first static table index whose name matches (case-sensitive).

    Returns -1 if no entry matches.
    """
    val table = qpack_static_table()
    var i = 0
    val n = table.len()
    loop:
        if i >= n:
            break
        if table[i].name == name:
            return i
        i = i + 1
    return -1

pub fn qpack_static_find_exact(name: text, value: text) -> i64:
    """Find the static table index matching both name and value exactly.

    Returns -1 if no exact match found.
    """
    val table = qpack_static_table()
    var i = 0
    val n = table.len()
    loop:
        if i >= n:
            break
        if table[i].name == name and table[i].value == value:
            return i
        i = i + 1
    return -1
