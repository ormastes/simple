# Typed Event Bus — strongly-typed editor events over text pub/sub
#
# EditorEvent variants are serialized to text for routing through the
# underlying EventBus, but provide typed constructors and matchers.

use std.nogc_sync_mut.editor.selection.{NodeId}

# ============================================================================
# EditorEvent
# ============================================================================

enum EditorEvent:
    SceneNodeAdded(node_id: NodeId, parent_id: NodeId, name: text)
    SceneNodeRemoved(node_id: NodeId)
    SelectionChanged(node_ids: [NodeId])
    PropertyChanged(node_id: NodeId, property: text, value: text)
    AssetOpened(asset_path: text, asset_type: text)
    ToolChanged(tool_name: text)
    ModeChanged(mode_name: text)
    UndoPerformed(description: text)
    RedoPerformed(description: text)
    TextureSaved(asset_path: text)
    AudioSourcePlaced(node_id: NodeId, clip_path: text)
    SceneLoaded(scene_path: text)
    SceneSaved(scene_path: text)

impl EditorEvent:
    fn event_name(self) -> text:
        match self:
            EditorEvent.SceneNodeAdded(..) => "scene:node-added"
            EditorEvent.SceneNodeRemoved(..) => "scene:node-removed"
            EditorEvent.SelectionChanged(..) => "scene:selection-changed"
            EditorEvent.PropertyChanged(..) => "component:property-changed"
            EditorEvent.AssetOpened(..) => "asset:opened"
            EditorEvent.ToolChanged(..) => "tool:changed"
            EditorEvent.ModeChanged(..) => "mode:changed"
            EditorEvent.UndoPerformed(..) => "history:undo"
            EditorEvent.RedoPerformed(..) => "history:redo"
            EditorEvent.TextureSaved(..) => "asset:texture-saved"
            EditorEvent.AudioSourcePlaced(..) => "audio:source-placed"
            EditorEvent.SceneLoaded(..) => "scene:loaded"
            EditorEvent.SceneSaved(..) => "scene:saved"

# ============================================================================
# EventQueue — simple FIFO for deferred event dispatch
# ============================================================================

class EventQueue:
    events: [EditorEvent]

    static fn new() -> EventQueue:
        EventQueue(events: [])

    me push(event: EditorEvent):
        self.events = self.events.push(event)

    me drain() -> [EditorEvent]:
        val result = self.events
        self.events = []
        result

    fn is_empty(self) -> bool:
        self.events.len() == 0

    fn count(self) -> i32:
        self.events.len()
