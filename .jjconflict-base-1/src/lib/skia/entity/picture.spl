# Skia Picture
#
# SkPicture — recorded drawing commands for later playback.

use std.skia.entity.geometry.{SkRect}
use std.skia.entity.paint.{SkPaint, sk_paint_new}
use std.skia.entity.path.{SkPath}
use std.skia.entity.image.{SkImage}

# ============================================================================
# SkPictureOp — a recorded drawing operation with optional payload fields
# ============================================================================

enum SkPictureOpKind:
    Save
    SaveLayer
    Restore
    DrawRect
    DrawOval
    DrawPath
    DrawText
    DrawImage
    ClipRect
    SetMatrix
    DrawPaint
    DrawPoints
    DrawRRect
    DrawTextBlob

class SkPictureOp:
    kind: SkPictureOpKind
    rect: SkRect
    rx: f64
    ry: f64
    path: Option<SkPath>
    image: Option<SkImage>
    paint: SkPaint
    x: f64
    y: f64

fn sk_picture_op_draw_rect(rect: SkRect, paint: SkPaint) -> SkPictureOp:
    SkPictureOp(
        kind: SkPictureOpKind.DrawRect,
        rect: rect,
        rx: 0.0,
        ry: 0.0,
        path: None,
        image: None,
        paint: paint,
        x: 0.0,
        y: 0.0
    )

fn sk_picture_op_draw_rrect(rect: SkRect, rx: f64, ry: f64, paint: SkPaint) -> SkPictureOp:
    SkPictureOp(
        kind: SkPictureOpKind.DrawRRect,
        rect: rect,
        rx: rx,
        ry: ry,
        path: None,
        image: None,
        paint: paint,
        x: 0.0,
        y: 0.0
    )

fn sk_picture_op_draw_path(path: SkPath, paint: SkPaint) -> SkPictureOp:
    SkPictureOp(
        kind: SkPictureOpKind.DrawPath,
        rect: SkRect(left: 0.0, top: 0.0, right: 0.0, bottom: 0.0),
        rx: 0.0,
        ry: 0.0,
        path: Some(path),
        image: None,
        paint: paint,
        x: 0.0,
        y: 0.0
    )

fn sk_picture_op_draw_image(image: SkImage, x: f64, y: f64, paint: SkPaint) -> SkPictureOp:
    SkPictureOp(
        kind: SkPictureOpKind.DrawImage,
        rect: SkRect(left: 0.0, top: 0.0, right: 0.0, bottom: 0.0),
        rx: 0.0,
        ry: 0.0,
        path: None,
        image: Some(image),
        paint: paint,
        x: x,
        y: y
    )

fn sk_picture_op_draw_paint(paint: SkPaint) -> SkPictureOp:
    SkPictureOp(
        kind: SkPictureOpKind.DrawPaint,
        rect: SkRect(left: 0.0, top: 0.0, right: 0.0, bottom: 0.0),
        rx: 0.0,
        ry: 0.0,
        path: None,
        image: None,
        paint: paint,
        x: 0.0,
        y: 0.0
    )

# ============================================================================
# SkPicture — immutable recorded display list
# ============================================================================

class SkPicture:
    cull_rect: SkRect
    op_count: i64
    ops: [SkPictureOp]

fn sk_picture_empty() -> SkPicture:
    SkPicture(
        cull_rect: SkRect(left: 0.0, top: 0.0, right: 0.0, bottom: 0.0),
        op_count: 0,
        ops: [SkPictureOp]()
    )

impl SkPicture:
    fn cull_rect() -> SkRect:
        self.cull_rect

    fn approximate_op_count() -> i64:
        self.op_count

    fn serialize() -> [i64]:
        pass_todo

# ============================================================================
# SkPictureRecorder — records drawing commands into a picture
# ============================================================================

class SkPictureRecorder:
    recording: bool
    cull_rect: SkRect
    ops: [SkPictureOp]

fn sk_picture_recorder_new() -> SkPictureRecorder:
    SkPictureRecorder(
        recording: false,
        cull_rect: SkRect(left: 0.0, top: 0.0, right: 0.0, bottom: 0.0),
        ops: [SkPictureOp]()
    )

impl SkPictureRecorder:
    fn begin_recording(bounds: SkRect) -> SkPictureRecorder:
        SkPictureRecorder(recording: true, cull_rect: bounds, ops: [SkPictureOp]())

    fn record(op: SkPictureOp):
        self.ops.push(op)

    fn finish_recording() -> SkPicture:
        SkPicture(
            cull_rect: self.cull_rect,
            op_count: self.ops.len() as i64,
            ops: self.ops
        )

    fn is_recording() -> bool:
        self.recording
