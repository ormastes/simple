# Animation interpolation — linear + cubic-bezier timing + colour lerp.
#
# Mirrors CSS cubic-bezier(p1x, p1y, p2x, p2y) timing function and gfx::Tween
# from Chromium. Used by scroll animations, transitions, and keyframe playback.

use std.skia.entity.color.{SkColor4f, sk_color4f}

# ============================================================================
# EasingKind — tag for a timing curve
# ============================================================================

enum EasingKind:
    Linear
    EaseIn
    EaseOut
    EaseInOut
    Custom

# ============================================================================
# CubicBezierEasing — a parametric cubic-bezier curve with endpoints (0,0)
# and (1,1), and two control points (p1x,p1y) and (p2x,p2y).
# ============================================================================

class CubicBezierEasing:
    p1x: f64
    p1y: f64
    p2x: f64
    p2y: f64

fn cubic_bezier_easing(p1x: f64, p1y: f64, p2x: f64, p2y: f64) -> CubicBezierEasing:
    CubicBezierEasing(p1x: p1x, p1y: p1y, p2x: p2x, p2y: p2y)

# ============================================================================
# Predefined curves (match CSS named easings / Chrome gfx::Tween).
# ============================================================================

fn ease_in_cubic() -> CubicBezierEasing:
    cubic_bezier_easing(0.32, 0.0, 0.67, 0.0)

fn ease_out_cubic() -> CubicBezierEasing:
    cubic_bezier_easing(0.33, 1.0, 0.68, 1.0)

fn ease_in_out_cubic() -> CubicBezierEasing:
    cubic_bezier_easing(0.65, 0.0, 0.35, 1.0)

fn ease_linear() -> CubicBezierEasing:
    cubic_bezier_easing(0.0, 0.0, 1.0, 1.0)

# ============================================================================
# Bezier evaluation helpers
# ============================================================================

# B_x(s) = 3*(1-s)^2*s*p1x + 3*(1-s)*s^2*p2x + s^3
fn bezier_x_at(bezier: CubicBezierEasing, s: f64) -> f64:
    val one_minus_s = 1.0 - s
    val term1 = 3.0 * one_minus_s * one_minus_s * s * bezier.p1x
    val term2 = 3.0 * one_minus_s * s * s * bezier.p2x
    val term3 = s * s * s
    term1 + term2 + term3

# B_y(s) = 3*(1-s)^2*s*p1y + 3*(1-s)*s^2*p2y + s^3
fn bezier_y_at(bezier: CubicBezierEasing, s: f64) -> f64:
    val one_minus_s = 1.0 - s
    val term1 = 3.0 * one_minus_s * one_minus_s * s * bezier.p1y
    val term2 = 3.0 * one_minus_s * s * s * bezier.p2y
    val term3 = s * s * s
    term1 + term2 + term3

# dB_x/ds = 3*(1-s)^2*p1x + 6*(1-s)*s*(p2x - p1x) + 3*s^2*(1 - p2x)
fn bezier_dx_at(bezier: CubicBezierEasing, s: f64) -> f64:
    val one_minus_s = 1.0 - s
    val term1 = 3.0 * one_minus_s * one_minus_s * bezier.p1x
    val term2 = 6.0 * one_minus_s * s * (bezier.p2x - bezier.p1x)
    val term3 = 3.0 * s * s * (1.0 - bezier.p2x)
    term1 + term2 + term3

fn clamp_unit(x: f64) -> f64:
    if x < 0.0:
        0.0
    elif x > 1.0:
        1.0
    else:
        x

# Newton-Raphson solve for s such that B_x(s) == t, then return B_y(s).
# 8 iterations starting from s = t. Clamp s to [0, 1] each step.
fn evaluate_cubic_bezier(bezier: CubicBezierEasing, t: f64) -> f64:
    val t_clamped = clamp_unit(t)
    var s = t_clamped
    var i = 0
    while i < 8:
        val x_err = bezier_x_at(bezier, s) - t_clamped
        val dx = bezier_dx_at(bezier, s)
        if dx == 0.0:
            i = 8
        else:
            val s_next = s - x_err / dx
            s = clamp_unit(s_next)
            i = i + 1
    bezier_y_at(bezier, s)

# ============================================================================
# Linear interpolation
# ============================================================================

fn lerp_f64(a: f64, b: f64, t: f64) -> f64:
    a + (b - a) * t

fn lerp_color(a: SkColor4f, b: SkColor4f, t: f64) -> SkColor4f:
    sk_color4f(
        lerp_f64(a.r, b.r, t),
        lerp_f64(a.g, b.g, t),
        lerp_f64(a.b, b.b, t),
        lerp_f64(a.a, b.a, t)
    )

# ============================================================================
# Easing dispatch
# ============================================================================

fn apply_easing(kind: EasingKind, t: f64, custom: CubicBezierEasing) -> f64:
    match kind:
        EasingKind.Linear => t
        EasingKind.EaseIn => evaluate_cubic_bezier(ease_in_cubic(), t)
        EasingKind.EaseOut => evaluate_cubic_bezier(ease_out_cubic(), t)
        EasingKind.EaseInOut => evaluate_cubic_bezier(ease_in_out_cubic(), t)
        EasingKind.Custom => evaluate_cubic_bezier(custom, t)
