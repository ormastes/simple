# Unit: Ex
# Kind: Typography
# Symbol: ex
# Canonical scale: 0.5 em

class Ex:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Ex) -> Ex: Ex(value: self.value + other.value)
    fn sub(other: Ex) -> Ex: Ex(value: self.value - other.value)

    static fn kind() -> text: "Typography"
    static fn symbol() -> text: "ex"
    static fn scale_to_base() -> f64: 0.5
    static fn base_unit() -> text: "em"
    static fn zero() -> Ex: Ex(value: 0.0)

export Ex
