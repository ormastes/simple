# Unit: MegaWatt
# Kind: Power
# Symbol: MW
# Canonical scale: 1000000.0 W

class MegaWatt:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: MegaWatt) -> MegaWatt: MegaWatt(value: self.value + other.value)
    fn sub(other: MegaWatt) -> MegaWatt: MegaWatt(value: self.value - other.value)

    static fn kind() -> text: "Power"
    static fn symbol() -> text: "MW"
    static fn scale_to_base() -> f64: 1000000.0
    static fn base_unit() -> text: "W"
    static fn zero() -> MegaWatt: MegaWatt(value: 0.0)

export MegaWatt
