# Composite Unit: JperKgK
# Kind: SpecificHeat
# Symbol: J_per_kg_K
# Scale to SI base: 1.0 J/(kg*K)

class JperKgK:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: JperKgK) -> JperKgK: JperKgK(value: self.value + other.value)
    fn sub(other: JperKgK) -> JperKgK: JperKgK(value: self.value - other.value)

    static fn kind() -> text: "SpecificHeat"
    static fn symbol() -> text: "J_per_kg_K"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "J/(kg*K)"
    static fn numerator() -> [text]: ["J"]
    static fn denominator() -> [text]: ["kg", "K"]
    static fn zero() -> JperKgK: JperKgK(value: 0.0)

export JperKgK
