# Unit: Yd
# Kind: Length
# Symbol: yd
# Canonical scale: 0.9144 m

class Yd:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Yd) -> Yd: Yd(value: self.value + other.value)
    fn sub(other: Yd) -> Yd: Yd(value: self.value - other.value)

    static fn kind() -> text: "Length"
    static fn symbol() -> text: "yd"
    static fn scale_to_base() -> f64: 0.9144
    static fn base_unit() -> text: "m"
    static fn zero() -> Yd: Yd(value: 0.0)

export Yd
