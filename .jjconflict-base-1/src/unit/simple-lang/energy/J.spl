# Unit: Joule
# Kind: Energy
# Symbol: J
# Canonical scale: 1.0 J

class Joule:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Joule) -> Joule: Joule(value: self.value + other.value)
    fn sub(other: Joule) -> Joule: Joule(value: self.value - other.value)

    static fn kind() -> text: "Energy"
    static fn symbol() -> text: "J"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "J"
    static fn zero() -> Joule: Joule(value: 0.0)

export Joule
