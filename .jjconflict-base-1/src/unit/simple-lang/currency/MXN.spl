# Unit: Mxn
# Kind: Currency
# Symbol: MXN
# Canonical scale: 1.0 USD

class Mxn:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Mxn) -> Mxn: Mxn(value: self.value + other.value)
    fn sub(other: Mxn) -> Mxn: Mxn(value: self.value - other.value)

    static fn kind() -> text: "Currency"
    static fn symbol() -> text: "MXN"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "USD"
    static fn zero() -> Mxn: Mxn(value: 0.0)

export Mxn
