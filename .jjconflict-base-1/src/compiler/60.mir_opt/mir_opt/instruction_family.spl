# Instruction Family — L2 Matrix Layer
#
# Defines instruction families and the target enable matrix that
# evaluates which families are available on a given target triple.

use compiler.mir_opt.mir_opt.target_family.{
    target_family_enum_from_triple, target_family_name
}

# ============================================================================
# InstructionFamily — describes a rewrite family
# ============================================================================

pub struct InstructionFamily:
    id: text
    target_family: text
    required_features: [text]
    forbidden_features: [text]
    safety: text
    cost: i64
    fallback: text

pub fn instruction_family_new(id: text, target_family: text, required_features: [text], forbidden_features: [text], safety: text, cost: i64, fallback: text) -> InstructionFamily:
    InstructionFamily(
        id: id,
        target_family: target_family,
        required_features: required_features,
        forbidden_features: forbidden_features,
        safety: safety,
        cost: cost,
        fallback: fallback
    )

# ============================================================================
# FamilyDecision — result of evaluating a family against a target
# ============================================================================

pub struct FamilyDecision:
    enabled: bool
    reason: text
    source: text
    fallback_family: text

fn family_decision_enabled(source: text) -> FamilyDecision:
    FamilyDecision(enabled: true, reason: "all checks passed", source: source, fallback_family: "")

fn family_decision_disabled(reason: text, source: text, fallback: text) -> FamilyDecision:
    FamilyDecision(enabled: false, reason: reason, source: source, fallback_family: fallback)

# ============================================================================
# TargetEnableMatrix — holds families + their decisions for a triple
# ============================================================================

pub struct TargetEnableMatrix:
    triple: text
    families: [InstructionFamily]
    decisions: [FamilyDecision]

# ============================================================================
# Built-in families
# ============================================================================

fn builtin_families() -> [InstructionFamily]:
    """Register all built-in instruction families."""
    var fams: [InstructionFamily] = []
    # x86 families — target_family is "X86_64" (only valid on x86-64)
    fams.push(instruction_family_new("x86.narrow_form", "X86_64", [], [], "safe", 1, ""))
    fams.push(instruction_family_new("x86.lea_idiom", "X86_64", [], [], "safe", 1, ""))
    fams.push(instruction_family_new("x86.bmi", "X86_64", ["bmi1"], [], "safe", 2, ""))
    # AArch64 families
    fams.push(instruction_family_new("aarch64.w_register", "Aarch64", [], [], "safe", 1, ""))
    # RISC-V families — use "Rv" prefix to match both Rv64 and Rv32
    fams.push(instruction_family_new("rv.zba_zbb", "Rv", ["zba"], [], "safe", 2, ""))
    # riscv.vector.v — matches both Rv64 and Rv32 but requires "v" feature
    fams.push(instruction_family_new("riscv.vector.v", "Rv", ["v"], [], "safe", 3, ""))
    fams

# ============================================================================
# Decision evaluation
# ============================================================================

fn evaluate_family(fam: InstructionFamily, target_name: text, flags: [text]) -> FamilyDecision:
    """Evaluate whether a family is enabled for the given target and flags."""
    # Check target family match — prefix match allows "Rv" to match "Rv32" and "Rv64"
    val fam_target = fam.target_family
    if not target_name.starts_with(fam_target) and fam_target != target_name:
        return family_decision_disabled("target family mismatch: expected {fam_target}, got {target_name}", "target_check", fam.fallback)

    # Check required features
    var i = 0
    while i < fam.required_features.len():
        val req = fam.required_features[i]
        var found = false
        var j = 0
        while j < flags.len():
            if flags[j] == req:
                found = true
            j = j + 1
        if not found:
            return family_decision_disabled("missing feature: {req}", "feature_check", fam.fallback)
        i = i + 1

    # Check forbidden features
    var k = 0
    while k < fam.forbidden_features.len():
        val forbidden = fam.forbidden_features[k]
        var present = false
        var m = 0
        while m < flags.len():
            if flags[m] == forbidden:
                present = true
            m = m + 1
        if present:
            return family_decision_disabled("forbidden feature present: {forbidden}", "feature_check", fam.fallback)
        k = k + 1

    family_decision_enabled("matrix_evaluation")

# ============================================================================
# Public API
# ============================================================================

pub fn target_enable_matrix(triple: text, flags: [text]) -> TargetEnableMatrix:
    """Build a TargetEnableMatrix for the given triple and feature flags."""
    val fam_enum = target_family_enum_from_triple(triple)
    val target_name = target_family_name(fam_enum)
    val fams = builtin_families()
    var decs: [FamilyDecision] = []
    var i = 0
    while i < fams.len():
        val d = evaluate_family(fams[i], target_name, flags)
        decs.push(d)
        i = i + 1
    TargetEnableMatrix(triple: triple, families: fams, decisions: decs)

pub fn matrix_decision(matrix: TargetEnableMatrix, family_id: text) -> FamilyDecision:
    """Look up the decision for a given family id in the matrix."""
    var i = 0
    while i < matrix.families.len():
        if matrix.families[i].id == family_id:
            return matrix.decisions[i]
        i = i + 1
    # Family not found — return disabled
    family_decision_disabled("family not found: {family_id}", "lookup", "")
