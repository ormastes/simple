# EasyFix adapter: SIMD-opportunity lint (L-SIMD-001..011)
#
# Converts SimdOpportunityWarning values produced by
# compiler.semantics.lint.simd_opportunity_lint into EasyFix entries so
# that `simple lint --simd <file>` and the pipeline scanner can surface them.
#
# Confidence is always Uncertain — SIMD rewrites require human judgment.
# No replacement bodies are emitted (there is no safe mechanical fix).
# The id encodes the rule code and line so the caller can filter by severity.
#
# Severity pass-through: the EasyFix description includes the original
# severity tag ("info"/"warning"/"note") so callers can honour it.

use std.tooling.easy_fix.*
use compiler.semantics.lint.simd_opportunity_lint.{lint_simd_opportunities, SimdOpportunityWarning}

fn check_simd_opportunities(source: text, file: text) -> [EasyFix]:
    """Run all 11 SIMD-opportunity rules and return EasyFix advisory entries.

    Each entry has:
      id:          L:simd_opportunity:<RULE_CODE>:<line>
      description: [<RULE_CODE>] <severity>: <message> — hint: <hint>
      confidence:  Uncertain  (no mechanical fix; human review required)

    The check does NOT fail the lint exit code when wired via --simd flag
    because all results are advisory (Uncertain confidence, no replacements).
    """
    val warnings = lint_simd_opportunities(source, file)
    var fixes: [EasyFix] = []
    var i = 0
    while i < warnings.len():
        val w = warnings[i]
        var fix = EasyFix.create(
            id: "L:simd_opportunity:{w.code}:{w.line_num}",
            description: "[{w.code}] {w.severity}: {w.message} — hint: {w.hint}",
            confidence: FixConfidence.Uncertain
        )
        fixes.push(fix)
        i = i + 1
    fixes
