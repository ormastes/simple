# Minimal cross-module test
# Tests: DOM creation, tag accessor, layout_to_scene, execute_scene

use std.gc_async_mut.gpu.browser_engine.dom.{BeDomNode, be_dom_get_tag, be_dom_get_bg_color}
use std.gc_async_mut.gpu.browser_engine.css.{be_default_style}
use std.gc_async_mut.gpu.browser_engine.layout.{layout_to_scene}
use common.render_scene.executor.{execute_scene_to_buffer}

extern fn rt_array_new(cap: i64) -> [u32]
extern fn rt_array_push(arr, val)

fn main() -> i64:
    print "Step 1: create node"
    var node = BeDomNode.element("div")
    print "Step 2: get tag"
    val tag = be_dom_get_tag(node)
    print "Step 3: tag = '{tag}'"
    print "Step 4: get bg_color"
    val bg = be_dom_get_bg_color(node)
    print "Step 5: bg = {bg}"
    print "Step 6: layout_to_scene"
    val scene = layout_to_scene(node, 20, 20)
    print "Step 7: scene done"
    print "Step 8: make buffer"
    var pixels: [u32] = rt_array_new(400)
    var i = 0
    while i < 400:
        rt_array_push(pixels, 0xFF000000)
        i = i + 1
    print "Step 9: execute_scene"
    execute_scene_to_buffer(scene, pixels, 20, 20)
    print "Step 10: check pixel"
    val p = pixels[0]
    print "Step 11: pixel[0] = {p}"
    print "DONE"
    return 0

main()
