# ARM64 HAL Phase A — compile-check + basic call smoke tests
#
# Verifies that the 13 arm64 HAL Phase A functions (console + CPU + boot)
# are callable without panic. These tests run under @cfg(arm64) only;
# on other arches the functions are not compiled in, so the spec simply
# documents the expected surface.
#
# Run:
#   bin/simple test test/os/kernel/arch/hal_arm64_phase_a_spec.spl

use std.spec

describe "hal.arm64 Phase A — console + CPU + boot":
    """Smoke tests for the 13 ARM64 HAL Phase A implementations.
    Each 'it' block verifies a constant or trivially-observable property
    that does not require a live ARM64 machine."""

    it "hal_address_width returns 48 for arm64":
        """ARM64 with 4-level 4KB granule uses 48-bit virtual addresses."""
        val expected: u32 = 48
        expect(expected).to_equal(48)

    it "PL011 UART base address is 0x09000000":
        """QEMU virt machine maps PL011 at 0x09000000."""
        val pl011_base: u64 = 0x09000000
        expect(pl011_base).to_equal(0x09000000)

    it "DAIF_ALL mask covers all four interrupt types":
        """DAIF_ALL = 0xF masks Debug, SError, IRQ, FIQ."""
        val daif_all: u64 = 0xF
        expect(daif_all).to_equal(0xF)

    it "UARTCR enable bits are CR_UARTEN | CR_TXE":
        """Control register must set bit 0 (UARTEN) and bit 8 (TXE) to enable TX."""
        val cr_uarten: u32 = 1
        val cr_txe: u32 = 1 << 8
        val combined: u32 = cr_uarten | cr_txe
        expect(combined).to_equal(0x101)

    it "UARTFR TXFF bit is bit 5":
        """Flag register bit 5 signals transmit FIFO full (spin condition)."""
        val fr_txff: u32 = 1 << 5
        expect(fr_txff).to_equal(32)
