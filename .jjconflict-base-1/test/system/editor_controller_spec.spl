# editor_controller_spec
#
# Shared editor controller — key dispatch, mode switching,
# file tree interaction, command handling, layout zones.

use std.spec

extern fn rt_file_read_text(path: text) -> text

fn read_text(path: text) -> text:
    rt_file_read_text(path) ?? ""

describe "editor controller — class":

    it "defines EditorController class":
        val src = read_text("src/app/editor/editor_controller.spl")
        expect(src.contains("class EditorController:")).to_equal(true)
        expect(src.contains("session: EditSession")).to_equal(true)
        expect(src.contains("file_tree: FileTreeState")).to_equal(true)
        expect(src.contains("file_tree_visible: bool")).to_equal(true)
        expect(src.contains("focus_panel: text")).to_equal(true)
        expect(src.contains("status_msg: text")).to_equal(true)
        expect(src.contains("commandline: text")).to_equal(true)
        expect(src.contains("pending_prefix: text")).to_equal(true)
        expect(src.contains("running: bool")).to_equal(true)

    it "has constructor":
        val src = read_text("src/app/editor/editor_controller.spl")
        expect(src.contains("static fn new(session: EditSession) -> EditorController")).to_equal(true)

describe "editor controller — key dispatch":

    it "has unified handle_key method":
        val src = read_text("src/app/editor/editor_controller.spl")
        expect(src.contains("me handle_key(key: text, rects: [SplitRect]) -> EditorAction")).to_equal(true)

    it "defines EditorAction result struct":
        val src = read_text("src/app/editor/editor_controller.spl")
        expect(src.contains("struct EditorAction:")).to_equal(true)
        expect(src.contains("redraw: bool")).to_equal(true)
        expect(src.contains("quit: bool")).to_equal(true)
        expect(src.contains("status_msg: text")).to_equal(true)

    it "dispatches to mode-specific handlers":
        val src = read_text("src/app/editor/editor_controller.spl")
        expect(src.contains("me _dispatch_command_key(key: text) -> EditorAction")).to_equal(true)
        expect(src.contains("me _dispatch_normal_key(key: text, rects: [SplitRect]) -> EditorAction")).to_equal(true)
        expect(src.contains("me _dispatch_insert_key(key: text) -> EditorAction")).to_equal(true)
        expect(src.contains("me _dispatch_file_tree_key(key: text) -> EditorAction")).to_equal(true)

describe "editor controller — shared key handlers":

    it "has normal key handler":
        val src = read_text("src/app/editor/editor_controller.spl")
        expect(src.contains("fn ctrl_handle_normal_key(buffer: EditorBuffer, key: text) -> NormalKeyResult")).to_equal(true)
        expect(src.contains("struct NormalKeyResult:")).to_equal(true)

    it "has insert key handler":
        val src = read_text("src/app/editor/editor_controller.spl")
        expect(src.contains("fn ctrl_handle_insert_key(buffer: EditorBuffer, key: text) -> InsertKeyResult")).to_equal(true)
        expect(src.contains("struct InsertKeyResult:")).to_equal(true)

    it "has command key handler":
        val src = read_text("src/app/editor/editor_controller.spl")
        expect(src.contains("fn ctrl_handle_command_key(key: text, commandline: text) -> CommandKeyResult")).to_equal(true)
        expect(src.contains("struct CommandKeyResult:")).to_equal(true)

describe "editor controller — view state":

    it "has toggle_file_tree and toggle_focus":
        val src = read_text("src/app/editor/editor_controller.spl")
        expect(src.contains("me toggle_file_tree()")).to_equal(true)
        expect(src.contains("me toggle_focus()")).to_equal(true)

    it "has active_buffer and mode accessors":
        val src = read_text("src/app/editor/editor_controller.spl")
        expect(src.contains("fn active_buffer() -> EditorBuffer")).to_equal(true)
        expect(src.contains("fn mode() -> EditorMode")).to_equal(true)
        expect(src.contains("fn is_running() -> bool")).to_equal(true)

describe "editor controller — layout zones":

    it "defines LayoutZones struct":
        val src = read_text("src/app/editor/editor_controller.spl")
        expect(src.contains("struct LayoutZones:")).to_equal(true)
        expect(src.contains("sidebar_w: i64")).to_equal(true)
        expect(src.contains("editor_x: i64")).to_equal(true)
        expect(src.contains("editor_w: i64")).to_equal(true)
        expect(src.contains("editor_h: i64")).to_equal(true)
        expect(src.contains("status_y: i64")).to_equal(true)
        expect(src.contains("command_y: i64")).to_equal(true)

    it "has ctrl_compute_zones":
        val src = read_text("src/app/editor/editor_controller.spl")
        expect(src.contains("fn ctrl_compute_zones(ctrl: EditorController, total_w: i64, total_h: i64) -> LayoutZones")).to_equal(true)

describe "editor controller — wincmd integration":

    it "handles Ctrl+W prefix chord":
        val src = read_text("src/app/editor/editor_controller.spl")
        expect(src.contains("pending_prefix == \"ctrl_w\"")).to_equal(true)
        expect(src.contains("wincmd_dispatch")).to_equal(true)
