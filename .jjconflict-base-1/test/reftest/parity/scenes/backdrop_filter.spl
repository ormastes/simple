# backdrop_filter scene — SaveLayer with Multiply blend, DrawRect inside, Restore, cull 300x301

use std.skia.entity.picture.{SkPicture, SkPictureOp, SkPictureOpKind, sk_picture_op_draw_rect}
use std.skia.entity.paint.{SkPaint, sk_paint_new, sk_paint_fill}
use std.skia.entity.geometry.{SkRect}
use std.skia.entity.enums.{SkBlendMode}
use std.skia.entity.color.{sk_color_argb}

fn scene() -> SkPicture:
    val cull = SkRect(left: 0.0, top: 0.0, right: 300.0, bottom: 301.0)
    val zero_rect = SkRect(left: 0.0, top: 0.0, right: 0.0, bottom: 0.0)
    # Background rect
    val bg_rect = SkRect(left: 0.0, top: 0.0, right: 300.0, bottom: 301.0)
    val paint_bg = sk_paint_fill(sk_color_argb(255, 180, 200, 220))
    # SaveLayer with Multiply blend (simulating backdrop-filter)
    val layer_paint_base = sk_paint_new()
    val layer_paint = layer_paint_base.with_blend_mode(SkBlendMode.Multiply)
    val save_layer_op = SkPictureOp(
        kind: SkPictureOpKind.SaveLayer,
        rect: zero_rect,
        rx: 0.0,
        ry: 0.0,
        path: None,
        image: None,
        paint: layer_paint,
        x: 0.0,
        y: 0.0
    )
    # Inner rect inside SaveLayer
    val inner_rect = SkRect(left: 50.0, top: 60.0, right: 250.0, bottom: 240.0)
    val paint_inner = sk_paint_fill(sk_color_argb(200, 255, 255, 255))
    # Restore op
    val restore_paint = sk_paint_new()
    val restore_op = SkPictureOp(
        kind: SkPictureOpKind.Restore,
        rect: zero_rect,
        rx: 0.0,
        ry: 0.0,
        path: None,
        image: None,
        paint: restore_paint,
        x: 0.0,
        y: 0.0
    )
    val ops = [SkPictureOp]()
    ops.push(sk_picture_op_draw_rect(bg_rect, paint_bg))
    ops.push(save_layer_op)
    ops.push(sk_picture_op_draw_rect(inner_rect, paint_inner))
    ops.push(restore_op)
    SkPicture(cull_rect: cull, op_count: ops.len() as i64, ops: ops)
