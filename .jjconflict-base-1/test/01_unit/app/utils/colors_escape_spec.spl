# Tests for ANSI escape helpers.

use app.utils.colors.{reset, red, strip_colors}
use std.common.string_core.{char_from_code}

describe "app.utils.colors":
    it "builds ANSI color sequences without char casts":
        val esc = char_from_code(27)
        expect(reset()).to_equal(esc + "[0m")
        expect(red()).to_equal(esc + "[31m")
        expect(strip_colors(red() + "boom" + reset())).to_equal("boom")
