use std.spec.{describe, it, expect}
use std.nogc_sync_mut.http.h3.qpack_decoder.{
    QpackIntResult,
    QpackPrefixResult,
    QpackStringResult,
    qpack_decode_header_block_prefix,
    qpack_decode_prefixed_int,
    qpack_decode_string_literal
}

fn _bytes(vals: [i64]) -> [u8]:
    var out: [u8] = []
    var i = 0
    while i < vals.len():
        out.push(vals[i].to_u8())
        i = i + 1
    return out

fn _is_int_error(result: QpackIntResult) -> bool:
    match result:
        case Err(_):
            return true
        case Ok(_):
            return false
    return false

fn _is_string_error(result: QpackStringResult) -> bool:
    match result:
        case Err(_):
            return true
        case Ok(_):
            return false
    return false

fn _is_prefix_error(result: QpackPrefixResult) -> bool:
    match result:
        case Err(_):
            return true
        case Ok(_):
            return false
    return false

describe "QPACK malformed offset guards":
    it "rejects negative public decode offsets without indexing before the buffer":
        val bytes = _bytes([0, 0])
        expect(_is_int_error(qpack_decode_prefixed_int(bytes, -1, 8))).to_equal(true)
        expect(_is_string_error(qpack_decode_string_literal(bytes, -1))).to_equal(true)
        expect(_is_prefix_error(qpack_decode_header_block_prefix(bytes, -1))).to_equal(true)

    it "rejects invalid prefix widths before computing a prefix mask":
        val bytes = _bytes([0])
        expect(_is_int_error(qpack_decode_prefixed_int(bytes, 0, 0))).to_equal(true)
        expect(_is_int_error(qpack_decode_prefixed_int(bytes, 0, 9))).to_equal(true)
