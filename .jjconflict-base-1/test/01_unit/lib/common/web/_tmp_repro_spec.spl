use std.spec.*
use std.gc_async_mut.web.browser_session.{BrowserSession, BrowserResponse}
use std.gc_async_mut.web.browser_session_loading.*
use std.gc_async_mut.web.browser_session_runtime.*
describe "tmp":
    it "post":
        var session = BrowserSession.new()
        session.open_html("https://example.com/app", "<html><body><script>var meta='start'; window.fetch('/submit', { method: 'POST', body: 'payload' }).then(function(r){return r.text();}).then(function(t){meta='see-other:'+t;});</script></body></html>")
        var trace = ""
        match session.take_pending_request():
            Some(a): trace = "id=" + a.id + ";url=" + a.url + ";m=" + a.method + ";b=" + a.body
            nil: trace = "NONE"
        match session.take_pending_request():
            Some(b): trace = trace + ";X2=" + b.url + "/" + b.method
            nil: trace = trace + ";X2=NIL"
        expect(trace).to_equal("ZZZ")
