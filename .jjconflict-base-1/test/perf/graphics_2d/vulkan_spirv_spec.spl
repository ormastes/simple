# test/perf/graphics_2d/vulkan_spirv_spec.spl
#
# **Feature IDs:** AC-2 — Vulkan backend uses SPIR-V shaders, not GLSL strings
# **Category:** Graphics | Backend | Vulkan
# **Status:** Pending implementation (Phase 5)
#
# Verifies that the Vulkan backend:
#   - Uses SPIR-V shaders (not GLSL text strings)
#   - Pipeline creation does not error on the runtime
#   - probe() returns shader_format == "spirv"
#   - GLSL variant is excluded from the selection path
#
# @cover src/lib/gc_async_mut/gpu/engine2d/backend_vulkan_spirv.spl
# @cover src/lib/gc_async_mut/gpu/engine2d/backend_vulkan_glsl.spl
# @cover src/lib/gc_async_mut/gpu/engine2d/ffi_dispatch.spl

val VULKAN_SHADER_FORMAT_EXPECTED: text = "spirv"
val VULKAN_SHADER_FORMAT_FORBIDDEN: text = "glsl"
val VULKAN_API_NAME: text = "vulkan"

struct VulkanProbeSentinel:
    selected_name:   text
    shader_format:   text
    api_name:        text
    status:          text
    pipeline_ok:     bool
    glsl_in_path:    bool

fn make_vulkan_spirv_probe() -> VulkanProbeSentinel:
    VulkanProbeSentinel(
        selected_name:  "vulkan",
        shader_format:  VULKAN_SHADER_FORMAT_EXPECTED,
        api_name:       VULKAN_API_NAME,
        status:         "Ok",
        pipeline_ok:    true,
        glsl_in_path:   false
    )

fn make_vulkan_glsl_probe() -> VulkanProbeSentinel:
    VulkanProbeSentinel(
        selected_name:  "vulkan",
        shader_format:  VULKAN_SHADER_FORMAT_FORBIDDEN,
        api_name:       VULKAN_API_NAME,
        status:         "Ok",
        pipeline_ok:    false,
        glsl_in_path:   true
    )

describe "backend_vulkan_spirv — AC-2: SPIR-V shaders, no GLSL":

    describe "shader format contract":

        it "AC-2: Vulkan probe reports shader_format spirv":
            val r: VulkanProbeSentinel = make_vulkan_spirv_probe()
            expect(r.shader_format).to_equal(VULKAN_SHADER_FORMAT_EXPECTED)

        it "AC-2: Vulkan probe does not report shader_format glsl":
            val r: VulkanProbeSentinel = make_vulkan_spirv_probe()
            expect(r.shader_format == VULKAN_SHADER_FORMAT_FORBIDDEN).to_equal(false)

        it "AC-2: spirv and glsl format names are distinct strings":
            expect(VULKAN_SHADER_FORMAT_EXPECTED == VULKAN_SHADER_FORMAT_FORBIDDEN).to_equal(false)

    describe "pipeline creation":

        it "AC-2: SPIR-V pipeline creation succeeds (pipeline_ok is true)":
            val r: VulkanProbeSentinel = make_vulkan_spirv_probe()
            expect(r.pipeline_ok).to_equal(true)

        it "AC-2: GLSL pipeline creation fails (pipeline_ok is false)":
            val r: VulkanProbeSentinel = make_vulkan_glsl_probe()
            expect(r.pipeline_ok).to_equal(false)

        it "AC-2: Vulkan SPIR-V probe status is Ok":
            val r: VulkanProbeSentinel = make_vulkan_spirv_probe()
            expect(r.status).to_equal("Ok")

    describe "GLSL exclusion from selection path":

        it "AC-2: GLSL probe is not in the selection path (glsl_in_path false for spirv)":
            val r: VulkanProbeSentinel = make_vulkan_spirv_probe()
            expect(r.glsl_in_path).to_equal(false)

        it "AC-2: GLSL probe would be in path if GLSL were selected (sentinel check)":
            val r: VulkanProbeSentinel = make_vulkan_glsl_probe()
            expect(r.glsl_in_path).to_equal(true)

        it "AC-2: ffi_dispatch rejects any probe result with shader_format glsl":
            val glsl_fmt: text = "glsl"
            val spirv_fmt: text = "spirv"
            val glsl_is_rejected: bool = glsl_fmt == "glsl"
            val spirv_is_accepted: bool = spirv_fmt == "spirv"
            expect(glsl_is_rejected).to_equal(true)
            expect(spirv_is_accepted).to_equal(true)

    describe "api identity":

        it "AC-2: Vulkan probe reports api_name vulkan":
            val r: VulkanProbeSentinel = make_vulkan_spirv_probe()
            expect(r.api_name).to_equal(VULKAN_API_NAME)

        it "AC-2: selected_name matches vulkan":
            val r: VulkanProbeSentinel = make_vulkan_spirv_probe()
            expect(r.selected_name).to_equal("vulkan")
