# MCP JSON Primitive Performance Benchmark
#
# **Feature IDs:** MCP JSON Perf Opt Round 1
# **Category:** Performance | MCP
# **Status:** Implemented
#
# Measures wall-clock microseconds for the hot JSON primitive functions
# used on every MCP handshake message (initialize, tools/list).
# Uses rt_time_now_unix_micros() for timing.
# Note: interpreter mode only verifies file loading (it block bodies don't execute).

extern fn rt_time_now_unix_micros() -> i64

use std.mcp_sdk.core.json.{LB, RB, Q, find_text, unescape_json_string, extract_field_raw, extract_field, extract_json_string, extract_json_value}

fn check(v):
    expect(v).to_equal(true)

# ---------------------------------------------------------------------------
# Build a realistic ~2KB tools/list-style JSON fixture without interpolation.
# Uses LB()/RB()/Q() helpers since {...} in string literals would interpolate.
# ---------------------------------------------------------------------------

fn make_tool_entry(name: text, desc: text) -> text:
    val q = Q()
    val lb = LB()
    val rb = RB()
    lb + q + "name" + q + ":" + q + name + q + "," + q + "description" + q + ":" + q + desc + q + "," + q + "inputSchema" + q + ":" + lb + q + "type" + q + ":" + q + "object" + q + "," + q + "properties" + q + ":" + lb + rb + rb + rb

fn make_tools_list_json() -> text:
    val q = Q()
    val lb = LB()
    val rb = RB()
    val t1 = make_tool_entry("read_file", "Read the contents of a file from the filesystem")
    val t2 = make_tool_entry("write_file", "Write content to a file on the filesystem")
    val t3 = make_tool_entry("list_directory", "List files and directories in a given path")
    val t4 = make_tool_entry("search_text", "Search for text patterns within files recursively")
    val t5 = make_tool_entry("run_command", "Execute a shell command and return its output")
    lb + q + "jsonrpc" + q + ":" + q + "2.0" + q + "," + q + "id" + q + ":" + q + "1" + q + "," + q + "result" + q + ":" + lb + q + "tools" + q + ":[" + t1 + "," + t2 + "," + t3 + "," + t4 + "," + t5 + "]" + rb + rb

fn make_init_json() -> text:
    val q = Q()
    val lb = LB()
    val rb = RB()
    lb + q + "jsonrpc" + q + ":" + q + "2.0" + q + "," + q + "id" + q + ":" + q + "1" + q + "," + q + "method" + q + ":" + q + "initialize" + q + "," + q + "params" + q + ":" + lb + q + "protocolVersion" + q + ":" + q + "2024-11-05" + q + "," + q + "capabilities" + q + ":" + lb + q + "roots" + q + ":" + lb + q + "listChanged" + q + ":true" + rb + rb + "," + q + "clientInfo" + q + ":" + lb + q + "name" + q + ":" + q + "claude-code" + q + "," + q + "version" + q + ":" + q + "1.0.0" + q + rb + rb + rb

fn make_escaped_string() -> text:
    val q = Q()
    val lb = LB()
    val rb = RB()
    "hello\\nworld\\ttabbed\\\\backslash" + q + "quoted" + q + "end"

# =========================================================================
# Benchmark: find_text (O(n*m) loop with per-iter slice)
# =========================================================================

fn bench_find_text(n: i64) -> bool:
    """N iterations of find_text over a ~2KB JSON string."""
    val json = make_tools_list_json()
    val needle = Q() + "inputSchema" + Q()
    val start = rt_time_now_unix_micros()
    var i: i64 = 0
    var found: i64 = 0
    while i < n:
        val idx = find_text(json, needle)
        found = found + idx
        i = i + 1
    val elapsed = rt_time_now_unix_micros() - start
    print "[perf] find_text: {elapsed} us for {n} iters (found={found})"
    elapsed < 60000000

# =========================================================================
# Benchmark: unescape_json_string (6 .replace() calls)
# =========================================================================

fn bench_unescape(n: i64) -> bool:
    """N iterations of unescape_json_string."""
    val s = make_escaped_string()
    val start = rt_time_now_unix_micros()
    var i: i64 = 0
    var total_len: i64 = 0
    while i < n:
        val out = unescape_json_string(s)
        total_len = total_len + out.len()
        i = i + 1
    val elapsed = rt_time_now_unix_micros() - start
    print "[perf] unescape_json_string: {elapsed} us for {n} iters (total_len={total_len})"
    elapsed < 60000000

# =========================================================================
# Benchmark: extract_field_raw over a tools/list response
# =========================================================================

fn bench_extract_field_raw(n: i64) -> bool:
    """N iterations of extract_field_raw('result') over a ~2KB JSON."""
    val json = make_tools_list_json()
    val start = rt_time_now_unix_micros()
    var i: i64 = 0
    var total_len: i64 = 0
    while i < n:
        val v = extract_field_raw(json=json, key="result")
        total_len = total_len + v.len()
        i = i + 1
    val elapsed = rt_time_now_unix_micros() - start
    print "[perf] extract_field_raw(result): {elapsed} us for {n} iters (total_len={total_len})"
    elapsed < 60000000

# =========================================================================
# Benchmark: extract_json_string over initialize body
# =========================================================================

fn bench_extract_json_string(n: i64) -> bool:
    """N iterations of extract_json_string('method') over an initialize JSON."""
    val json = make_init_json()
    val start = rt_time_now_unix_micros()
    var i: i64 = 0
    var total_len: i64 = 0
    while i < n:
        val v = extract_json_string(json=json, key="method")
        total_len = total_len + v.len()
        i = i + 1
    val elapsed = rt_time_now_unix_micros() - start
    print "[perf] extract_json_string(method): {elapsed} us for {n} iters (total_len={total_len})"
    elapsed < 60000000

# =========================================================================
# Scaling guard: field extraction must be sub-quadratic in response size.
# The absolute thresholds above are too coarse to catch an O(n^2) regression
# (at N=200 over ~2KB, quadratic vs linear differed by only ~3x — both well
# under 60s), which is exactly how the char_at() O(n^2) scan that caused the
# codex MCP handshake timeout slipped through. Growth RATIO catches it.
# =========================================================================

fn make_tools_list_n(ntools: i64) -> text:
    val q = Q()
    val lb = LB()
    val rb = RB()
    var tools = ""
    var i = 0
    while i < ntools:
        if i > 0:
            tools = tools + ","
        tools = tools + make_tool_entry("tool_" + i.to_text(), "Reads or writes data on the filesystem for tooling")
        i = i + 1
    lb + q + "jsonrpc" + q + ":" + q + "2.0" + q + "," + q + "result" + q + ":" + lb + q + "tools" + q + ":[" + tools + "]" + rb + rb

fn bench_extract_scaling() -> bool:
    """extract_field_raw('result') over a 4x-larger tools/list must take well
    under 8x as long (linear ~4x; quadratic ~16x). Guards the MCP handshake
    against the O(n^2) char-scan regression (codex timeout)."""
    val small = make_tools_list_n(20)
    val large = make_tools_list_n(80)
    val reps = 40
    var t = rt_time_now_unix_micros()
    var i = 0
    var acc = 0
    while i < reps:
        acc = acc + extract_field_raw(json=small, key="result").len()
        i = i + 1
    val small_us = rt_time_now_unix_micros() - t
    t = rt_time_now_unix_micros()
    i = 0
    while i < reps:
        acc = acc + extract_field_raw(json=large, key="result").len()
        i = i + 1
    val large_us = rt_time_now_unix_micros() - t
    print "[perf] extract scaling: small(20 tools)={small_us}us large(80 tools)={large_us}us (acc={acc})"
    if small_us <= 0:
        return true
    large_us < small_us * 8

# =========================================================================
# Test execution
# =========================================================================

describe "MCP JSON Primitive Performance":
    """
    # MCP JSON Primitive Performance Benchmark

    Measures wall-clock time for hot JSON primitive operations used on every
    MCP handshake message (initialize, tools/list).

    ## Operations Tested
    - find_text (N=200): substring-scan loop, O(n*m) with per-iter slice
    - unescape_json_string (N=200): 6 chained .replace() calls
    - extract_field_raw (N=200): full field extraction over ~2KB JSON
    - extract_json_string (N=200): key lookup in initialize message

    ## Threshold
    All thresholds are generous (60s) — goal is detecting order-of-magnitude
    regressions and recording before/after µs for optimization work.
    """

    slow_it "find_text completes within threshold":
        check(bench_find_text(200))

    slow_it "unescape_json_string completes within threshold":
        check(bench_unescape(200))

    slow_it "extract_field_raw completes within threshold":
        check(bench_extract_field_raw(200))

    slow_it "extract_json_string completes within threshold":
        check(bench_extract_json_string(200))

    slow_it "extract_field_raw scales sub-quadratically with response size":
        check(bench_extract_scaling())
