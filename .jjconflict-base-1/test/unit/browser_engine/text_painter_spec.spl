use std.spec.*
use std.gc_async_mut.gpu.browser_engine.text_painter.{
    browser_chrome_text_scanline_write_y_probe}

describe "Browser text painter":
    it "keeps Chrome text glyph scanlines at their native y coordinate":
        expect(browser_chrome_text_scanline_write_y_probe(2)).to_equal(2)
        expect(browser_chrome_text_scanline_write_y_probe(48)).to_equal(48)
        expect(browser_chrome_text_scanline_write_y_probe(49)).to_equal(49)
