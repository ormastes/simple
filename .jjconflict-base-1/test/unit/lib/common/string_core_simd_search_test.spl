# String Core SIMD Search Wiring Tests

use std.spec.{describe, it, expect}
use common.string_core.{str_eq, str_contains, str_starts_with, str_ends_with, str_index_of, str_last_index_of, str_replace_all}

describe "string_core SIMD search wiring":
    it "preserves equality semantics":
        expect str_eq("hello", "hello") == true
        expect str_eq("hello", "world") == false
        expect str_eq("", "") == true

    it "preserves contains semantics including empty needle":
        expect str_contains("hello world", "world") == true
        expect str_contains("hello world", "xyz") == false
        expect str_contains("hello", "") == true

    it "preserves starts-with and ends-with semantics":
        expect str_starts_with("hello world", "hello") == true
        expect str_starts_with("hello world", "world") == false
        expect str_starts_with("hello", "") == true
        expect str_ends_with("hello world", "world") == true
        expect str_ends_with("hello world", "hello") == false
        expect str_ends_with("hello", "") == true
        expect str_ends_with("éclair", "clair") == true

    it "returns byte offsets for first and last search":
        expect str_index_of("hello", "l") == 2
        expect str_index_of("hello", "xyz") == -1
        expect str_index_of("Hello 世界 😀", "世界") == 6
        expect str_last_index_of("abcabc", "abc") == 3

    it "preserves replace-all optional search semantics":
        expect str_replace_all("hello", "l", "L") == "heLLo"
        expect str_replace_all("hello", "x", "X") == "hello"
        expect str_replace_all("hello", "", "X") == "hello"
