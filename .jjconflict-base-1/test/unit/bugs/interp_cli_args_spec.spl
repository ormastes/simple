# Bug: rt_cli_get_args() includes runtime args
# Severity: P3
# Workaround: Strip args up to and including the .spl path

extern fn rt_cli_get_args() -> [text]

fn strip_runtime_args(raw_args: [text]) -> [text]:
    # Skip everything up to and including the .spl script path
    var user_args: [text] = []
    var found_script = false
    for a in raw_args:
        if found_script:
            user_args = user_args + [a]
        elif a.ends_with(".spl"):
            found_script = true
    user_args

fn _empty_text_list() -> [text]:
    var result: [text] = []
    result

fn _len(a): a.len()
fn _get(a, i): a[i]

describe "rt_cli_get_args() runtime args bug":
    it "demonstrates the stripping workaround":
        # Build the array directly (var: [text] = [] broken in it blocks)
        val simulated_raw = ["simple", "run", "test/example.spl", "--flag", "value"]
        val user_args = strip_runtime_args(simulated_raw)
        expect(_len(user_args)).to_equal(2)
        expect(_get(user_args, 0)).to_equal("--flag")
        expect(_get(user_args, 1)).to_equal("value")

    it "handles no script path gracefully":
        val no_script = ["--something"]
        val result = strip_runtime_args(no_script)
        expect(result.len()).to_equal(0)

    it "handles empty args":
        val empty = _empty_text_list()
        val result = strip_runtime_args(empty)
        expect(result.len()).to_equal(0)
