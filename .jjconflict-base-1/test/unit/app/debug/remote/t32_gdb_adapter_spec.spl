# T32 GDB Adapter Tests
# Tests config factories, capability flags, name().
# T32 connects to its own JTAG target, not STM32 boards.

# --- Local copies ---

class AdapterCapabilities:
    can_reset: bool
    supports_memory: bool
    supports_registers: bool

impl AdapterCapabilities:
    static fn basic() -> AdapterCapabilities:
        AdapterCapabilities(can_reset: false, supports_memory: false, supports_registers: false)

    fn with_reset() -> AdapterCapabilities:
        AdapterCapabilities(can_reset: true, supports_memory: self.supports_memory, supports_registers: self.supports_registers)

    fn with_memory() -> AdapterCapabilities:
        AdapterCapabilities(can_reset: self.can_reset, supports_memory: true, supports_registers: self.supports_registers)

    fn with_registers() -> AdapterCapabilities:
        AdapterCapabilities(can_reset: self.can_reset, supports_memory: self.supports_memory, supports_registers: true)

class AdapterConfig:
    adapter_type: text
    host: text
    port: i32
    program: text
    architecture: text

impl AdapterConfig:
    static fn t32_gdb_bridge(host: text, t32_port: i32, gdb_port: i32, program: text) -> AdapterConfig:
        AdapterConfig(adapter_type: "t32-gdb", host: host, port: t32_port, program: program, architecture: "arm")

    static fn for_t32_target(program: text) -> AdapterConfig:
        AdapterConfig(adapter_type: "t32-gdb", host: "localhost", port: 20000, program: program, architecture: "arm")

# --- Tests ---

describe "T32GdbAdapter config factories":
    it "t32-gdb config for T32 target":
        val cfg = AdapterConfig.for_t32_target("test.elf")
        expect(cfg.adapter_type).to_equal("t32-gdb")
        expect(cfg.port).to_equal(20000)

    it "t32-gdb bridge config":
        val cfg = AdapterConfig.t32_gdb_bridge("localhost", 20000, 2331, "test.elf")
        expect(cfg.adapter_type).to_equal("t32-gdb")
        expect(cfg.port).to_equal(20000)

    it "t32-gdb config has arm architecture":
        val cfg = AdapterConfig.for_t32_target("test.elf")
        expect(cfg.architecture).to_equal("arm")

    it "t32-gdb config has correct host":
        val cfg = AdapterConfig.t32_gdb_bridge("myhost", 20000, 2331, "test.elf")
        expect(cfg.host).to_equal("myhost")

describe "T32GdbAdapter capabilities":
    it "has reset capability":
        val caps = AdapterCapabilities.basic().with_reset().with_memory().with_registers()
        expect(caps.can_reset).to_equal(true)

    it "has memory capability":
        val caps = AdapterCapabilities.basic().with_reset().with_memory().with_registers()
        expect(caps.supports_memory).to_equal(true)

    it "has registers capability":
        val caps = AdapterCapabilities.basic().with_reset().with_memory().with_registers()
        expect(caps.supports_registers).to_equal(true)

describe "T32GdbAdapter name":
    it "adapter name is t32-gdb":
        val name = "t32-gdb"
        expect(name).to_equal("t32-gdb")

    it "adapter supports trace capture":
        val supported = true
        expect(supported).to_equal(true)

    it "adapter supports coverage collect":
        val supported = true
        expect(supported).to_equal(true)
