use std.io_runtime

class DmaDesc:
    vaddr: i64
    paddr: i64
    device_addr: i64
    byte_length: i64
    cache_kind: text
    owner_task: i64
    owner_device: i64
    is_active: bool

    static fn create(v: i64, p: i64, da: i64, bl: i64, ck: text, ot: i64, od: i64) -> DmaDesc:
        DmaDesc(vaddr: v, paddr: p, device_addr: da, byte_length: bl, cache_kind: ck, owner_task: ot, owner_device: od, is_active: true)

    me release(task_id: i64) -> text:
        if self.owner_task == task_id:
            return ""
        return "error:wrong_owner"

class TaskDmaSet:
    task_id: i64
    desc_count: i64

    static fn create(tid: i64, cnt: i64) -> TaskDmaSet:
        TaskDmaSet(task_id: tid, desc_count: cnt)

    me release_all(tid: i64) -> i64:
        if self.task_id == tid:
            return self.desc_count
        return 0

class CacheSync:
    cache_kind: text

    static fn create(ck: text) -> CacheSync:
        CacheSync(cache_kind: ck)

    me cpu_to_dev() -> text:
        if self.cache_kind == "coherent":
            return "noop"
        return "flush"

    me dev_to_cpu() -> text:
        if self.cache_kind == "coherent":
            return "noop"
        return "invalidate"

class IsolDomain:
    has_iommu: bool
    mode: text

    static fn isolated() -> IsolDomain:
        IsolDomain(has_iommu: true, mode: "isolated")

    static fn trusted() -> IsolDomain:
        IsolDomain(has_iommu: false, mode: "trusted")

    static fn no_isol() -> IsolDomain:
        IsolDomain(has_iommu: false, mode: "none")

    me can_vf() -> bool:
        return self.has_iommu

    me advertises() -> bool:
        if self.mode == "trusted":
            return false
        return self.has_iommu

class DioReq:
    operation: text
    file_offset: i64
    byte_length: i64

    static fn read_at(offset: i64, length: i64) -> DioReq:
        DioReq(operation: "read", file_offset: offset, byte_length: length)

    me check_align(min_align: i64) -> bool:
        if min_align == 0:
            return true
        var rem = self.file_offset - (self.file_offset / min_align) * min_align
        return rem == 0

class DispCap:
    backend: text
    is_dma: bool
    is_accel: bool

    static fn framebuf() -> DispCap:
        DispCap(backend: "framebuffer", is_dma: false, is_accel: false)

    static fn bga() -> DispCap:
        DispCap(backend: "bga", is_dma: false, is_accel: false)

    static fn vgpu() -> DispCap:
        DispCap(backend: "virtio-gpu", is_dma: true, is_accel: true)

class DirtyRect:
    x: i32
    y: i32
    w: i32
    h: i32

    static fn region(rx: i32, ry: i32, rw: i32, rh: i32) -> DirtyRect:
        DirtyRect(x: rx, y: ry, w: rw, h: rh)

    static fn full_frame(sw: i32, sh: i32) -> DirtyRect:
        DirtyRect(x: 0, y: 0, w: sw, h: sh)

    me is_bounded() -> bool:
        if self.w < 1920:
            return true
        return false

class OwnerGate:
    desc_owner: i64
    req_task: i64

    static fn check(owner: i64, requester: i64) -> OwnerGate:
        OwnerGate(desc_owner: owner, req_task: requester)

    me is_ok() -> bool:
        return self.desc_owner == self.req_task

class DisplayPath:
    dma_available: bool

    static fn with_dma() -> DisplayPath:
        DisplayPath(dma_available: true)

    static fn fallback() -> DisplayPath:
        DisplayPath(dma_available: false)

    me effective() -> text:
        if self.dma_available:
            return "dma"
        return "framebuffer"

fn test_dma_descriptor_fields():
    var d = DmaDesc.create(1000, 2000, 3000, 4096, "coherent", 1, 5)
    if d.vaddr == 1000:
        if d.paddr == 2000:
            if d.byte_length == 4096:
                print("PASS: test_dma_descriptor_fields")
                return
    print("FAIL: test_dma_descriptor_fields")

fn test_dma_release_valid_owner():
    var d = DmaDesc.create(1000, 2000, 3000, 4096, "coherent", 7, 5)
    var result = d.release(7)
    if result == "":
        print("PASS: test_dma_release_valid_owner")
    else:
        print("FAIL: test_dma_release_valid_owner")

fn test_dma_release_wrong_owner():
    var d = DmaDesc.create(1000, 2000, 3000, 4096, "coherent", 7, 5)
    var result = d.release(99)
    if result == "":
        print("FAIL: test_dma_release_wrong_owner")
    else:
        print("PASS: test_dma_release_wrong_owner")

fn test_dma_task_cleanup_count():
    var s = TaskDmaSet.create(3, 5)
    var count = s.release_all(3)
    if count == 5:
        print("PASS: test_dma_task_cleanup_count")
    else:
        print("FAIL: test_dma_task_cleanup_count")

fn test_coherent_sync_noop():
    var cs = CacheSync.create("coherent")
    if cs.cpu_to_dev() == "noop":
        print("PASS: test_coherent_sync_noop")
    else:
        print("FAIL: test_coherent_sync_noop")

fn test_flush_required_sync():
    var cs = CacheSync.create("flush_required")
    if cs.cpu_to_dev() == "flush":
        print("PASS: test_flush_required_sync")
    else:
        print("FAIL: test_flush_required_sync")

fn test_cache_dev_to_cpu_invalidate():
    var cs = CacheSync.create("flush_required")
    if cs.dev_to_cpu() == "invalidate":
        print("PASS: test_cache_dev_to_cpu_invalidate")
    else:
        print("FAIL: test_cache_dev_to_cpu_invalidate")

fn test_sriov_with_iommu_allowed():
    var d = IsolDomain.isolated()
    if d.can_vf():
        print("PASS: test_sriov_with_iommu_allowed")
    else:
        print("FAIL: test_sriov_with_iommu_allowed")

fn test_sriov_without_iommu_rejected():
    var d = IsolDomain.no_isol()
    if d.can_vf() == false:
        print("PASS: test_sriov_without_iommu_rejected")
    else:
        print("FAIL: test_sriov_without_iommu_rejected")

fn test_no_iommu_no_isolation_advertised():
    var d = IsolDomain.trusted()
    if d.advertises() == false:
        print("PASS: test_no_iommu_no_isolation_advertised")
    else:
        print("FAIL: test_no_iommu_no_isolation_advertised")

fn test_dio_read_alignment_valid():
    var req = DioReq.read_at(4096, 512)
    if req.check_align(4096):
        print("PASS: test_dio_read_alignment_valid")
    else:
        print("FAIL: test_dio_read_alignment_valid")

fn test_dio_read_alignment_invalid():
    var req = DioReq.read_at(100, 512)
    if req.check_align(4096) == false:
        print("PASS: test_dio_read_alignment_invalid")
    else:
        print("FAIL: test_dio_read_alignment_invalid")

fn test_block_submit_nvme_vs_virtio():
    var nvme = "nvme"
    var virtio = "virtio-blk"
    if nvme == "nvme":
        if virtio == "virtio-blk":
            print("PASS: test_block_submit_nvme_vs_virtio")
            return
    print("FAIL: test_block_submit_nvme_vs_virtio")

fn test_framebuffer_not_dma():
    var cap = DispCap.framebuf()
    if cap.is_dma == false:
        print("PASS: test_framebuffer_not_dma")
    else:
        print("FAIL: test_framebuffer_not_dma")

fn test_bga_not_accelerated():
    var cap = DispCap.bga()
    if cap.is_accel == false:
        print("PASS: test_bga_not_accelerated")
    else:
        print("FAIL: test_bga_not_accelerated")

fn test_virtio_gpu_is_dma():
    var cap = DispCap.vgpu()
    if cap.is_dma:
        print("PASS: test_virtio_gpu_is_dma")
    else:
        print("FAIL: test_virtio_gpu_is_dma")

fn test_dirty_rect_bounded():
    var rect = DirtyRect.region(10, 10, 100, 100)
    if rect.is_bounded():
        print("PASS: test_dirty_rect_bounded")
    else:
        print("FAIL: test_dirty_rect_bounded")

fn test_wrong_owner_denied():
    var gate = OwnerGate.check(1, 2)
    if gate.is_ok() == false:
        print("PASS: test_wrong_owner_denied")
    else:
        print("FAIL: test_wrong_owner_denied")

fn test_same_owner_allowed():
    var gate = OwnerGate.check(1, 1)
    if gate.is_ok():
        print("PASS: test_same_owner_allowed")
    else:
        print("FAIL: test_same_owner_allowed")

fn test_display_fallback_path():
    var dp = DisplayPath.fallback()
    if dp.effective() == "framebuffer":
        print("PASS: test_display_fallback_path")
    else:
        print("FAIL: test_display_fallback_path")

fn main():
    test_dma_descriptor_fields()
    test_dma_release_valid_owner()
    test_dma_release_wrong_owner()
    test_dma_task_cleanup_count()
    test_coherent_sync_noop()
    test_flush_required_sync()
    test_cache_dev_to_cpu_invalidate()
    test_sriov_with_iommu_allowed()
    test_sriov_without_iommu_rejected()
    test_no_iommu_no_isolation_advertised()
    test_dio_read_alignment_valid()
    test_dio_read_alignment_invalid()
    test_block_submit_nvme_vs_virtio()
    test_framebuffer_not_dma()
    test_bga_not_accelerated()
    test_virtio_gpu_is_dma()
    test_dirty_rect_bounded()
    test_wrong_owner_denied()
    test_same_owner_allowed()
    test_display_fallback_path()
    print("DONE")
