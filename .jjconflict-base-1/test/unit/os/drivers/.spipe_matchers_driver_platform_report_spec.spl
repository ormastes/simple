# @tag: os, driver, mdsoc, exokernel, gpu, audio, input, team
# @cover src/os/drivers/driver_platform_report.spl 80%

use std.spec.{describe, it, expect}
use os.drivers.driver_platform_contract.{
    audio_probe_cirrus_logic_hda,
    audio_probe_realtek_hda,
    cpu_accel_features,
    driver_team_lane,
    driver_team_plan,
    exokernel_device_grant,
    gpu_probe_intel,
    input_probe_ps2,
    input_probe_usb_hid
}
use os.drivers.driver_platform_report.{
    driver_platform_report,
    driver_platform_report_blocker,
    driver_platform_report_marker,
    driver_platform_report_ready
}

fn ready_team_plan():
    driver_team_plan(
        driver_team_lane("gpu", "driver-gpu", true, true, true, true),
        driver_team_lane("audio", "driver-audio", true, true, true, true),
        driver_team_lane("input", "driver-input", true, true, true, true),
        driver_team_lane("exokernel", "driver-exokernel", true, true, true, true),
        driver_team_lane("mdsoc", "driver-architect", true, true, true, true)
    )

describe "SimpleOS driver platform report":
    it "accepts a complete concrete platform evidence report":
        val report = driver_platform_report(
            gpu_probe_intel(true, true, true, true),
            cpu_accel_features("x86_64", true, true, true, true, false, false, false),
            audio_probe_realtek_hda(true, true, true, true, true, "x86-sse2-audio"),
            audio_probe_cirrus_logic_hda(true, true, true, true, true, "x86-sse2-audio"),
            input_probe_ps2(true, true, true),
            exokernel_device_grant(true, true, true, true, false, true),
            ready_team_plan()
        )
        expect driver_platform_report_ready(report) == true
        expect driver_platform_report_blocker(report) == "ready"
        expect (driver_platform_report_marker(report)).contains("[driver-platform-report] status=ready")

    it "reports first concrete GPU blocker":
        val report = driver_platform_report(
            gpu_probe_intel(true, false, true, true),
            cpu_accel_features("x86_64", true, true, true, true, false, false, false),
            audio_probe_realtek_hda(true, true, true, true, true, "x86-sse2-audio"),
            audio_probe_cirrus_logic_hda(true, true, true, true, true, "x86-sse2-audio"),
            input_probe_ps2(true, true, true),
            exokernel_device_grant(true, true, true, true, false, true),
            ready_team_plan()
        )
        expect driver_platform_report_ready(report) == false
        expect driver_platform_report_blocker(report) == "gpu:missing-device:intel-anv-level-zero"

    it "requires CPU audio acceleration before audio readiness":
        val report = driver_platform_report(
            gpu_probe_intel(true, true, true, true),
            cpu_accel_features("x86", true, false, false, false, false, false, false),
            audio_probe_realtek_hda(true, true, true, true, true, "scalar-audio"),
            audio_probe_cirrus_logic_hda(true, true, true, true, true, "scalar-audio"),
            input_probe_ps2(true, true, true),
            exokernel_device_grant(true, true, true, true, false, true),
            ready_team_plan()
        )
        expect driver_platform_report_blocker(report) == "cpu-audio:missing-accel"

    it "requires full USB HID input evidence when USB is the input bus":
        val report = driver_platform_report(
            gpu_probe_intel(true, true, true, true),
            cpu_accel_features("x86_64", true, true, true, true, false, false, false),
            audio_probe_realtek_hda(true, true, true, true, true, "x86-sse2-audio"),
            audio_probe_cirrus_logic_hda(true, true, true, true, true, "x86-sse2-audio"),
            input_probe_usb_hid(true, true, true, false, true),
            exokernel_device_grant(true, true, true, true, false, true),
            ready_team_plan()
        )
        expect driver_platform_report_blocker(report) == "input:partial:usb-hid"

    it "rejects unsafe exokernel raw device grants":
        val report = driver_platform_report(
            gpu_probe_intel(true, true, true, true),
            cpu_accel_features("x86_64", true, true, true, true, false, false, false),
            audio_probe_realtek_hda(true, true, true, true, true, "x86-sse2-audio"),
            audio_probe_cirrus_logic_hda(true, true, true, true, true, "x86-sse2-audio"),
            input_probe_ps2(true, true, true),
            exokernel_device_grant(true, true, true, false, true, true),
            ready_team_plan()
        )
        expect driver_platform_report_blocker(report) == "exokernel:unsafe-raw-device-without-iommu"

    it "reports team lane blockers after hardware evidence is ready":
        val team = driver_team_plan(
            driver_team_lane("gpu", "driver-gpu", true, true, true, true),
            driver_team_lane("audio", "driver-audio", true, false, true, true),
            driver_team_lane("input", "driver-input", true, true, true, true),
            driver_team_lane("exokernel", "driver-exokernel", true, true, true, true),
            driver_team_lane("mdsoc", "driver-architect", true, true, true, true)
        )
        val report = driver_platform_report(
            gpu_probe_intel(true, true, true, true),
            cpu_accel_features("x86_64", true, true, true, true, false, false, false),
            audio_probe_realtek_hda(true, true, true, true, true, "x86-sse2-audio"),
            audio_probe_cirrus_logic_hda(true, true, true, true, true, "x86-sse2-audio"),
            input_probe_ps2(true, true, true),
            exokernel_device_grant(true, true, true, true, false, true),
            team
        )
        expect driver_platform_report_blocker(report) == "team:missing-tests:audio"