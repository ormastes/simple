# SimpleOS Compiled Smoke Test
#
# Build: src/compiler_rust/target/bootstrap/simple native-build --entry test/unit/os/smoke_test.spl --source src/os -o build/os_smoke_test
# Run:   build/os_smoke_test

use os.kernel.types.memory_types.{PhysAddr, PageFrame, VmFlags}
use os.kernel.types.task_types.{TaskId}
use os.kernel.types.capability_types.{CapabilityToken, CapabilityKind, CapabilitySet}

fn main():
    print "=== SimpleOS Compiled Smoke Test ==="

    # --- PageFrame arithmetic ---
    val frame = PageFrame(pfn: 42)
    val phys = frame.to_phys_addr()
    if phys.addr == 172032:
        print "OK: pfn 42 → phys 172032"
    else:
        print "FAIL: pfn 42 → phys {phys.addr}"

    val frame2 = PageFrame.from_phys_addr(PhysAddr(addr: 172032))
    if frame2.pfn == 42:
        print "OK: phys 172032 → pfn 42"
    else:
        print "FAIL: from_phys pfn={frame2.pfn}"

    # Round trip
    val rt = PageFrame(pfn: 100)
    val rt_back = PageFrame.from_phys_addr(rt.to_phys_addr())
    if rt_back.pfn == 100:
        print "OK: round trip pfn 100"
    else:
        print "FAIL: round trip pfn={rt_back.pfn}"

    # --- VmFlags (u32 bitfield) ---
    val rw = VmFlags.kernel_rw()
    if rw.present() and rw.writable() and not rw.user():
        print "OK: kernel_rw flags"
    else:
        print "FAIL: kernel_rw (bits={rw.bits})"

    val urw = VmFlags.user_rw()
    if urw.present() and urw.writable() and urw.user() and urw.no_execute():
        print "OK: user_rw W^X enforced"
    else:
        print "FAIL: user_rw (bits={urw.bits})"

    val mmio = VmFlags.mmio()
    if mmio.write_through() and mmio.cache_disable() and mmio.no_execute():
        print "OK: mmio flags"
    else:
        print "FAIL: mmio (bits={mmio.bits})"

    # --- CapabilitySet ---
    var caps = CapabilitySet.full()
    if not caps.is_pledged:
        print "OK: cap set not pledged"
    else:
        print "FAIL: cap set pledged at start"

    val tok = CapabilityToken(kind: CapabilityKind.FileRead(path_prefix: "/"), generation: 1, owner: 42)
    if tok.owner == 42:
        print "OK: capability token owner=42"
    else:
        print "FAIL: token owner={tok.owner}"

    # --- TaskId ---
    val id1 = TaskId(id: 1)
    if id1.id == 1:
        print "OK: TaskId id=1"
    else:
        print "FAIL: TaskId"

    print "=== ALL DONE ==="
