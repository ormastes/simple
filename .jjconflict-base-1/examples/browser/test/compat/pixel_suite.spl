#![allow(unnamed_duplicate_typed_args)]
# Pixel Suite — Full pixel comparison test runner
#
# Runs pixel-level comparison between Simple browser renderer and Chrome/Electron
# screenshots. Uses test manifest for discovery and image_export for metrics.
#
# Usage:
#   val suite = PixelSuite.create("examples/browser/test/compat/html", 800, 600)
#   val report = suite.run_all(simple_results, chrome_results)
#   print report.to_markdown()

use examples.browser.test.compat.test_manifest.{TestManifest, TestEntry}
use examples.browser.test.compat.image_export.{ComparisonMetrics, compare_pixel_buffers}

# =========================================================================
# PixelTestResult — single test comparison result
# =========================================================================

class PixelTestResult:
    test_name: text
    category: text
    feature: text
    match_percentage: f64
    rmse: f64
    max_channel_diff: i32
    passed: bool

    fn display() -> text:
        val status = if self.passed: "PASS" else: "FAIL"
        "[{status}] {self.category}/{self.test_name}: {self.match_percentage}% match, RMSE={self.rmse}"

# =========================================================================
# PixelSuiteReport — aggregated results
# =========================================================================

class PixelSuiteReport:
    results: [PixelTestResult]
    total_tests: i32
    passed_tests: i32
    failed_tests: i32
    categories: [text]

    static fn empty() -> PixelSuiteReport:
        PixelSuiteReport(
            results: [],
            total_tests: 0,
            passed_tests: 0,
            failed_tests: 0,
            categories: []
        )

    fn overall_pass_rate() -> f64:
        if self.total_tests == 0:
            return 0.0
        (self.passed_tests.to_f64() / self.total_tests.to_f64()) * 100.0

    fn category_pass_rate(category: text) -> f64:
        var cat_total = 0
        var cat_pass = 0
        for r in self.results:
            if r.category == category:
                cat_total = cat_total + 1
                if r.passed:
                    cat_pass = cat_pass + 1
        if cat_total == 0:
            return 0.0
        (cat_pass.to_f64() / cat_total.to_f64()) * 100.0

    fn worst_tests(n: i32) -> [PixelTestResult]:
        """Return the n tests with lowest match percentage."""
        # Simple selection sort for worst tests
        var sorted: [PixelTestResult] = []
        var used: [bool] = []
        for _ in self.results:
            used = used + [false]

        var count = 0
        while count < n and count < self.results.len():
            var best_idx = -1
            var best_pct = 200.0  # higher than any real value
            var idx = 0
            for r in self.results:
                if not used[idx] and r.match_percentage < best_pct:
                    best_pct = r.match_percentage
                    best_idx = idx
                idx = idx + 1
            if best_idx >= 0:
                sorted = sorted + [self.results[best_idx]]
                used[best_idx] = true
            count = count + 1
        sorted

    fn to_markdown() -> text:
        var md = "# Pixel Comparison Suite Report\n\n"
        md = "{md}## Summary\n"
        md = "{md}- Total tests: {self.total_tests}\n"
        md = "{md}- Passed: {self.passed_tests}\n"
        md = "{md}- Failed: {self.failed_tests}\n"
        md = "{md}- Overall pass rate: {self.overall_pass_rate()}%\n\n"

        md = "{md}## Category Results\n\n"
        md = "{md}| Category | Pass Rate | Tests |\n"
        md = "{md}|----------|-----------|-------|\n"
        for cat in self.categories:
            val rate = self.category_pass_rate(cat)
            var cat_count = 0
            for r in self.results:
                if r.category == cat:
                    cat_count = cat_count + 1
            md = "{md}| {cat} | {rate}% | {cat_count} |\n"

        md = "{md}\n## All Test Results\n\n"
        md = "{md}| Test | Category | Match % | RMSE | Max Diff | Status |\n"
        md = "{md}|------|----------|---------|------|----------|--------|\n"
        for r in self.results:
            val status = if r.passed: "PASS" else: "FAIL"
            md = "{md}| {r.test_name} | {r.category} | {r.match_percentage}% | {r.rmse} | {r.max_channel_diff} | {status} |\n"

        val worst = self.worst_tests(5)
        if worst.len() > 0:
            md = "{md}\n## Worst 5 Tests\n\n"
            for w in worst:
                md = "{md}- **{w.category}/{w.test_name}**: {w.match_percentage}% match, RMSE={w.rmse}\n"

        md

# =========================================================================
# PixelSuite — test runner
# =========================================================================

class PixelSuite:
    manifest: TestManifest
    threshold: f64
    viewport_w: i32
    viewport_h: i32

    static fn create(html_dir: text, w: i32, h: i32) -> PixelSuite:
        val manifest = TestManifest.from_directory(html_dir)
        PixelSuite(
            manifest: manifest,
            threshold: 85.0,
            viewport_w: w,
            viewport_h: h
        )

    static fn create_with_threshold(html_dir: text, w: i32, h: i32, threshold: f64) -> PixelSuite:
        val manifest = TestManifest.from_directory(html_dir)
        PixelSuite(
            manifest: manifest,
            threshold: threshold,
            viewport_w: w,
            viewport_h: h
        )

    fn run_all(simple_pixels_map: [TestPixelData], chrome_pixels_map: [TestPixelData]) -> PixelSuiteReport:
        """Run pixel comparison for all tests.
        Each TestPixelData pairs a test name with its rendered pixel buffer.
        """
        run_for_entries(self.manifest.all_tests(), simple_pixels_map, chrome_pixels_map, self.threshold)

    fn run_category(category: text, simple_pixels_map: [TestPixelData], chrome_pixels_map: [TestPixelData]) -> PixelSuiteReport:
        """Run pixel comparison for tests in a specific category."""
        val entries = self.manifest.tests_for_category(category)
        run_for_entries(entries, simple_pixels_map, chrome_pixels_map, self.threshold)

# =========================================================================
# TestPixelData — links test name to pixel buffer
# =========================================================================

class TestPixelData:
    test_name: text
    pixels: [u32]
    width: i32
    height: i32

# =========================================================================
# Runner Implementation
# =========================================================================

fn run_for_entries(entries: [TestEntry], simple_map: [TestPixelData], chrome_map: [TestPixelData], threshold: f64) -> PixelSuiteReport:
    """Compare pixel data for each entry and build a report."""
    var report = PixelSuiteReport.empty()
    var categories: [text] = []

    for entry in entries:
        # Track unique categories
        var cat_found = false
        for c in categories:
            if c == entry.category:
                cat_found = true
        if not cat_found:
            categories = categories + [entry.category]

        # Find matching pixel data
        val simple_data = find_pixel_data(simple_map, entry.name)
        val chrome_data = find_pixel_data(chrome_map, entry.name)

        if simple_data.pixels.len() == 0 or chrome_data.pixels.len() == 0:
            # Missing data — record as failed with 0% match
            val result = PixelTestResult(
                test_name: entry.name,
                category: entry.category,
                feature: entry.feature,
                match_percentage: 0.0,
                rmse: 999.0,
                max_channel_diff: 255,
                passed: false
            )
            report.results = report.results + [result]
            report.total_tests = report.total_tests + 1
            report.failed_tests = report.failed_tests + 1
        else:
            val w = simple_data.width
            val h = simple_data.height
            val metrics = compare_pixel_buffers(simple_data.pixels, chrome_data.pixels, w, h)
            val passed = metrics.match_percentage >= threshold

            val result = PixelTestResult(
                test_name: entry.name,
                category: entry.category,
                feature: entry.feature,
                match_percentage: metrics.match_percentage,
                rmse: metrics.rmse,
                max_channel_diff: metrics.max_channel_diff,
                passed: passed
            )
            report.results = report.results + [result]
            report.total_tests = report.total_tests + 1
            if passed:
                report.passed_tests = report.passed_tests + 1
            else:
                report.failed_tests = report.failed_tests + 1

    report.categories = categories
    report

fn find_pixel_data(data_list: [TestPixelData], test_name: text) -> TestPixelData:
    """Find TestPixelData by test_name. Returns empty data if not found."""
    for d in data_list:
        if d.test_name == test_name:
            return d
    TestPixelData(test_name: test_name, pixels: [], width: 0, height: 0)
