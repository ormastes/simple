#![allow(REQC001)]
#![allow(REQC004)]
#![allow(unnamed_duplicate_typed_args)]

"""
QUIC entity types — RFC 9000.
Packet headers, connection IDs, streams, frames, congestion state, and config.
"""

enum QuicPacketType:
    Initial
    Handshake
    ZeroRtt
    OneRtt
    Retry

class QuicConnectionId:
    bytes: [u8]
    length: i64

    static fn new(bytes: [u8], length: i64) -> QuicConnectionId:
        QuicConnectionId(bytes: bytes, length: length)

class QuicPacketHeader:
    packet_type: i64
    version: i64
    dcid: QuicConnectionId
    scid: QuicConnectionId
    packet_number: i64
    payload_length: i64

    static fn new(packet_type: i64, version: i64, dcid: QuicConnectionId, scid: QuicConnectionId, packet_number: i64, payload_length: i64) -> QuicPacketHeader:
        QuicPacketHeader(
            packet_type: packet_type,
            version: version,
            dcid: dcid,
            scid: scid,
            packet_number: packet_number,
            payload_length: payload_length
        )

class QuicConfig:
    max_idle_timeout: i64
    initial_max_data: i64
    initial_max_streams_bidi: i64
    initial_max_streams_uni: i64

    static fn default() -> QuicConfig:
        QuicConfig(
            max_idle_timeout: 30000,
            initial_max_data: 1048576,
            initial_max_streams_bidi: 100,
            initial_max_streams_uni: 100
        )

    static fn create(max_idle_timeout: i64, initial_max_data: i64, initial_max_streams_bidi: i64, initial_max_streams_uni: i64) -> QuicConfig:
        QuicConfig(
            max_idle_timeout: max_idle_timeout,
            initial_max_data: initial_max_data,
            initial_max_streams_bidi: initial_max_streams_bidi,
            initial_max_streams_uni: initial_max_streams_uni
        )

class QuicCongestionState:
    cwnd: i64
    ssthresh: i64
    bytes_in_flight: i64
    rtt_min: i64
    rtt_smoothed: i64

    static fn new() -> QuicCongestionState:
        QuicCongestionState(
            cwnd: 14720,
            ssthresh: 9223372036854775807,
            bytes_in_flight: 0,
            rtt_min: 0,
            rtt_smoothed: 0
        )

class QuicStream:
    stream_id: i64
    offset: i64
    data: [u8]
    fin: bool

    static fn new(stream_id: i64) -> QuicStream:
        var empty: [u8] = []
        QuicStream(stream_id: stream_id, offset: 0, data: empty, fin: false)

class QuicFrame:
    frame_type: i64
    stream_id: i64
    offset: i64
    length: i64
    data: [u8]

    static fn new(frame_type: i64, stream_id: i64, offset: i64, length: i64, data: [u8]) -> QuicFrame:
        QuicFrame(frame_type: frame_type, stream_id: stream_id, offset: offset, length: length, data: data)
