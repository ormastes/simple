use examples.browser.entity.net.bundle_types.{BundleModule, SharedChunk, SplitPoint, BundleManifest}

fn hash_text(s: text) -> i64:
    var h: i64 = 0
    var i: i64 = 0
    val n = s.len()
    while i < n:
        h = h + s.char_at(i) * (i + 1)
        i = i + 1
    h

fn hash_to_hex(h: i64) -> text:
    val digits = "0123456789abcdef"
    var result = ""
    var v = h
    if v < 0:
        v = -v
    var count = 0
    while count < 8:
        val idx = v % 16
        result = digits.char_at(idx).to_text() + result
        v = v / 16
        count = count + 1
    result

fn ids_contains(ids: [text], id: text) -> bool:
    var i = 0
    while i < ids.len():
        if ids[i] == id:
            return true
        i = i + 1
    false

class BundleGraph:
    module_ids: [text]
    module_paths: [text]
    module_imports: [[text]]
    module_exports: [[text]]
    module_sizes: [i64]
    module_hashes: [text]
    edge_froms: [text]
    edge_tos: [text]

    static fn new() -> BundleGraph:
        BundleGraph(
            module_ids: [text](),
            module_paths: [text](),
            module_imports: [[text]](),
            module_exports: [[text]](),
            module_sizes: [i64](),
            module_hashes: [text](),
            edge_froms: [text](),
            edge_tos: [text]()
        )

    me add_module(module: BundleModule):
        if ids_contains(self.module_ids, module.id):
            return
        self.module_ids.push(module.id)
        self.module_paths.push(module.path)
        self.module_imports.push(module.imports)
        self.module_exports.push(module.exports)
        self.module_sizes.push(module.size)
        self.module_hashes.push(module.content_hash)

    me add_edge(from_id: text, to_id: text):
        self.edge_froms.push(from_id)
        self.edge_tos.push(to_id)

    me parse_imports(source: text) -> [text]:
        var result = [text]()
        val n = source.len()
        var i = 0
        while i < n:
            val remaining = n - i
            var found_keyword = false
            if remaining >= 6:
                val word6 = source.slice(i, i + 6)
                if word6 == "import" or word6 == "export":
                    found_keyword = true
            if remaining >= 7 and not found_keyword:
                val word7 = source.slice(i, i + 7)
                if word7 == "require":
                    var j = i + 7
                    while j < n and source.char_at(j) == ' ':
                        j = j + 1
                    if j < n and source.char_at(j) == '(':
                        j = j + 1
                        while j < n and source.char_at(j) == ' ':
                            j = j + 1
                        if j < n:
                            val q = source.char_at(j)
                            if q == '"' or q == '\'':
                                j = j + 1
                                var path = ""
                                while j < n and source.char_at(j) != q:
                                    path = path + source.char_at(j).to_text()
                                    j = j + 1
                                if path.len() > 0:
                                    result.push(path)
                    i = i + 7
                    found_keyword = true
            if found_keyword and remaining >= 6:
                var j = i + 6
                while j < n and source.char_at(j) == ' ':
                    j = j + 1
                var scan = j
                while scan < n - 5:
                    val chunk = source.slice(scan, scan + 5)
                    if chunk == "from ":
                        var k = scan + 5
                        while k < n and source.char_at(k) == ' ':
                            k = k + 1
                        if k < n:
                            val q = source.char_at(k)
                            if q == '"' or q == '\'':
                                k = k + 1
                                var path = ""
                                while k < n and source.char_at(k) != q:
                                    path = path + source.char_at(k).to_text()
                                    k = k + 1
                                if path.len() > 0:
                                    result.push(path)
                        scan = n
                    else:
                        scan = scan + 1
                i = j
            else:
                i = i + 1
        result

    me build_from_source(entry_path: text, source: text):
        val imports = self.parse_imports(source)
        val sz = source.len()
        val h = hash_to_hex(hash_text(source))
        val m = BundleModule.create(
            id: entry_path,
            path: entry_path,
            imports: imports,
            exports: [text](),
            size: sz,
            content_hash: h
        )
        self.add_module(m)
        var i = 0
        while i < imports.len():
            self.add_edge(entry_path, imports[i])
            i = i + 1

    me get_dependencies(module_id: text) -> [text]:
        var result = [text]()
        var i = 0
        while i < self.edge_froms.len():
            if self.edge_froms[i] == module_id:
                result.push(self.edge_tos[i])
            i = i + 1
        result

    me get_dependents(module_id: text) -> [text]:
        var result = [text]()
        var i = 0
        while i < self.edge_tos.len():
            if self.edge_tos[i] == module_id:
                result.push(self.edge_froms[i])
            i = i + 1
        result

    me module_count() -> i64:
        self.module_ids.len()

    me edge_count() -> i64:
        self.edge_froms.len()

    me topological_sort() -> [text]:
        val n = self.module_ids.len()
        var in_degree = [i64]()
        var idx = 0
        while idx < n:
            in_degree.push(0)
            idx = idx + 1
        var e = 0
        while e < self.edge_froms.len():
            val to_id = self.edge_tos[e]
            var m = 0
            while m < n:
                if self.module_ids[m] == to_id:
                    in_degree[m] = in_degree[m] + 1
                m = m + 1
            e = e + 1
        var queue = [text]()
        var qi = 0
        while qi < n:
            if in_degree[qi] == 0:
                queue.push(self.module_ids[qi])
            qi = qi + 1
        var result = [text]()
        var head = 0
        while head < queue.len():
            val node = queue[head]
            head = head + 1
            result.push(node)
            val deps = self.get_dependencies(node)
            var di = 0
            while di < deps.len():
                val dep = deps[di]
                var mi = 0
                while mi < n:
                    if self.module_ids[mi] == dep:
                        in_degree[mi] = in_degree[mi] - 1
                        if in_degree[mi] == 0:
                            queue.push(dep)
                        mi = n
                    mi = mi + 1
                di = di + 1
        result

fn collect_reachable(graph: BundleGraph, start: text) -> [text]:
    var visited = [text]()
    var stack = [text]()
    stack.push(start)
    while stack.len() > 0:
        val top = stack[stack.len() - 1]
        stack.pop()
        if not ids_contains(visited, top):
            visited.push(top)
            val deps = graph.get_dependencies(top)
            var i = 0
            while i < deps.len():
                if not ids_contains(visited, deps[i]):
                    stack.push(deps[i])
                i = i + 1
    visited

class SharedChunkResolver:
    threshold: i64

    static fn new(threshold: i64) -> SharedChunkResolver:
        SharedChunkResolver(threshold: threshold)

    me find_shared_modules(graph: BundleGraph, entries: [text]) -> [SharedChunk]:
        val all_ids = graph.module_ids
        var ref_counts = [i64]()
        var mi = 0
        while mi < all_ids.len():
            ref_counts.push(0)
            mi = mi + 1
        var ei = 0
        while ei < entries.len():
            val reachable = collect_reachable(graph, entries[ei])
            var ri = 0
            while ri < reachable.len():
                var mi2 = 0
                while mi2 < all_ids.len():
                    if all_ids[mi2] == reachable[ri]:
                        ref_counts[mi2] = ref_counts[mi2] + 1
                        mi2 = all_ids.len()
                    mi2 = mi2 + 1
                ri = ri + 1
            ei = ei + 1
        var shared = [SharedChunk]()
        var si = 0
        while si < all_ids.len():
            if ref_counts[si] >= self.threshold:
                val mod_id = all_ids[si]
                val mods = [text]()
                mods.push(mod_id)
                val ch = hash_to_hex(hash_text(mod_id))
                val chunk = SharedChunk.create(
                    id: ch,
                    modules: mods,
                    content_hash: ch,
                    size: 0,
                    ref_count: ref_counts[si]
                )
                shared.push(chunk)
            si = si + 1
        shared

    me compute_content_hash(modules: [text]) -> text:
        var combined = ""
        var sorted = [text]()
        var i = 0
        while i < modules.len():
            sorted.push(modules[i])
            i = i + 1
        var swapped = true
        while swapped:
            swapped = false
            var j = 0
            while j < sorted.len() - 1:
                if sorted[j] > sorted[j + 1]:
                    val tmp = sorted[j]
                    sorted[j] = sorted[j + 1]
                    sorted[j + 1] = tmp
                    swapped = true
                j = j + 1
        var k = 0
        while k < sorted.len():
            combined = combined + sorted[k]
            k = k + 1
        hash_to_hex(hash_text(combined))

    me dedup_chunks(chunks: [SharedChunk]) -> [SharedChunk]:
        var result = [SharedChunk]()
        var i = 0
        while i < chunks.len():
            val ch = chunks[i]
            var dup = false
            var j = 0
            while j < result.len():
                if result[j].content_hash == ch.content_hash:
                    dup = true
                    j = result.len()
                j = j + 1
            if not dup:
                result.push(ch)
            i = i + 1
        result

    me calculate_savings(manifest: BundleManifest) -> i64:
        var saved: i64 = 0
        var i = 0
        while i < manifest.shared.len():
            val chunk = manifest.shared[i]
            if chunk.ref_count > 1:
                saved = saved + chunk.size * (chunk.ref_count - 1)
            i = i + 1
        saved

    me resolve(graph: BundleGraph, entries: [text]) -> BundleManifest:
        val raw_shared = self.find_shared_modules(graph, entries)
        val deduped = self.dedup_chunks(raw_shared)
        var split_points = [SplitPoint]()
        var ei = 0
        while ei < entries.len():
            val entry = entries[ei]
            var entry_chunks = [text]()
            var entry_shared = [text]()
            var si = 0
            while si < deduped.len():
                entry_shared.push(deduped[si].id)
                si = si + 1
            val sp = SplitPoint.create(
                entry_id: entry,
                chunks: entry_chunks,
                shared_chunks: entry_shared
            )
            split_points.push(sp)
            ei = ei + 1
        var total: i64 = 0
        var si2 = 0
        while si2 < deduped.len():
            total = total + deduped[si2].size
            si2 = si2 + 1
        val manifest = BundleManifest.create(
            entries: split_points,
            shared: deduped,
            total_size: total,
            dedup_savings: 0
        )
        val savings = self.calculate_savings(manifest)
        BundleManifest.create(
            entries: split_points,
            shared: deduped,
            total_size: total,
            dedup_savings: savings
        )
