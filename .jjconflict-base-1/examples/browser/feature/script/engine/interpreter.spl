#![allow(REQC001)]
# Legacy interpreter module retained for old browser source paths.
#
# The browser example now uses std.js.engine.interpreter through the shared
# runtime. This shim keeps the old module path compileable without importing a
# second AST/interpreter surface into grouped tests.

class BrowserLegacyJsInterpreter:
    static fn new(logger: any) -> BrowserLegacyJsInterpreter:
        BrowserLegacyJsInterpreter()
