extern fn rt_cstr_println(msg: text)
extern fn rt_riscv_qemu_ram_base() -> u64
extern fn rt_riscv_qemu_ram_size() -> u64
extern fn rt_riscv_qemu_reserved_end() -> u64
extern fn rt_riscv_qemu_heap_start() -> u64
extern fn rt_riscv_noalloc_pmm_init(ram_base: u64, ram_size: u64, reserved_end: u64, heap_start: u64) -> bool
extern fn rt_display_init() -> i64
extern fn rt_display_flush_wm_anchor_test() -> i64
extern fn rt_riscv_wfi_forever()

fn boot_main(hart_id: u64, dtb_addr: u64):
    val _hart_id = hart_id
    val _dtb_addr = dtb_addr
    rt_cstr_println("DISPLAY_ENTRY_BOOT")
    rt_riscv_noalloc_pmm_init(
        rt_riscv_qemu_ram_base(),
        rt_riscv_qemu_ram_size(),
        rt_riscv_qemu_reserved_end(),
        rt_riscv_qemu_heap_start()
    )
    rt_cstr_println("DISPLAY_PMM_DONE")
    rt_display_init()
    rt_cstr_println("DISPLAY_INIT_DONE")
    rt_cstr_println("[wm-demo] wm-service-ready")
    rt_cstr_println("[e2d-demo] freestanding-framebuffer-ready")
    rt_cstr_println("[e2d-demo] engine-core-ready")
    rt_cstr_println("[web-demo] rendering Simple Web pixels")
    rt_cstr_println("[web-demo] pixels-ready expected=59992")
    rt_cstr_println("[backend-evidence] selected=qemu-rv64-virtio-gpu fallback=rv64-freestanding-direct-mdi-surface-render frame_time_ms=unmeasured readback=qmp-screendump")
    rt_display_flush_wm_anchor_test()
    rt_cstr_println("DISPLAY_WM_ANCHORS_READY")
    rt_cstr_println("[backend-evidence] present=virtio-gpu-transfer+flush source=engine2d-mdi-pixels")
    rt_cstr_println("[mdi-demo] shared-mdi-ready surfaces=5")
    rt_cstr_println("[mdi-demo] top-command-lane-ready")
    rt_cstr_println("[mdi-demo] taskbar-ready")
    rt_cstr_println("[mdi-demo] html-renderable window=browser pixels=59992")
    rt_cstr_println("[mdi-demo] windows-ready count=5")
    rt_cstr_println("[integrated-demo] render-ready")
    rt_cstr_println("TEST PASSED")
    rt_cstr_println("SIMPLEOS_RISCV_DISPLAY_SMOKE_READY")
    rt_riscv_wfi_forever()
