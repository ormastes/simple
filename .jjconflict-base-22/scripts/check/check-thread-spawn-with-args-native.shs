#!/bin/sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
cd "$ROOT_DIR"

SIMPLE_BIN="${SIMPLE_BIN:-${SIMPLE_BINARY:-./src/compiler_rust/target/debug/simple}}"
OUT_DIR="${OUT_DIR:-build/check/thread_spawn_with_args}"
OUT_BIN="$OUT_DIR/thread_spawn_with_args_native"
SMOKE_SRC="${SMOKE_SRC:-test/01_unit/lib/nogc_async_mut/thread_spawn_with_args_native.spl}"

fail() {
    echo "thread_spawn_with_args_native=false"
    echo "error=$1"
    exit 1
}

require_file() {
    [ -f "$1" ] || fail "missing file: $1"
}

require_file "$SIMPLE_BIN"
require_file "$SMOKE_SRC"
mkdir -p "$OUT_DIR"

SIMPLE_LIB=src "$SIMPLE_BIN" compile "$SMOKE_SRC" --native -o "$OUT_BIN" \
    >/tmp/simple_thread_spawn_with_args_native_build.out 2>&1 || {
        cat /tmp/simple_thread_spawn_with_args_native_build.out
        fail "native compile failed"
    }

"$OUT_BIN" >/tmp/simple_thread_spawn_with_args_native_run.out 2>&1 || {
    cat /tmp/simple_thread_spawn_with_args_native_run.out
    fail "native binary failed"
}

rm -f /tmp/simple_thread_spawn_with_args_native_build.out /tmp/simple_thread_spawn_with_args_native_run.out

echo "thread_spawn_with_args_native=true"
echo "smoke=$SMOKE_SRC"
