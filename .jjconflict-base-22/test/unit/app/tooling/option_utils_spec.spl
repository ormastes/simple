describe "Option Utils":
    it "uses nil coalescing fallback for absent values":
        val configured = nil
        val effective = configured ?? "default"
        expect effective == "default"

    it "preserves present option values":
        val configured = Some("explicit")
        val effective = configured ?? "default"
        expect effective == "explicit"

    it "matches Some values":
        val value = Some(42)
        val rendered = match value:
            Some(n): "value={n}"
            nil: "missing"
        expect rendered == "value=42"

    it "matches nil values":
        val value = nil
        val rendered = match value:
            Some(n): "value={n}"
            nil: "missing"
        expect rendered == "missing"
