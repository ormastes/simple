# Audio Effects Stub Tests
#
# Verifies the pure-Simple audio effects stubs (pitch, filters, reverb, delay)
# all return 0, matching the behaviour of the C stubs in runtime_audio_effects.c.

use std.spec
use std.io_runtime

fn rt_audio_set_pitch(sound_handle: i64, pitch: f64) -> i64:
    0

fn rt_audio_add_lowpass(sound_handle: i64, cutoff_hz: f64) -> i64:
    0

fn rt_audio_add_highpass(sound_handle: i64, cutoff_hz: f64) -> i64:
    0

fn rt_audio_add_reverb(sound_handle: i64, decay: f64, wet_dry: f64) -> i64:
    0

fn rt_audio_add_delay(sound_handle: i64, time_ms: f64, feedback: f64) -> i64:
    0

fn rt_audio_remove_effect(sound_handle: i64, effect_handle: i64) -> i64:
    0

fn rt_audio_clear_effects(sound_handle: i64) -> i64:
    0

describe "Audio Effects Stubs":
    context "Pitch control":
        it "rt_audio_set_pitch returns 0":
            expect rt_audio_set_pitch(1, 1.0) == 0

    context "Filter stubs":
        it "rt_audio_add_lowpass returns 0":
            expect rt_audio_add_lowpass(1, 1000.0) == 0

        it "rt_audio_add_highpass returns 0":
            expect rt_audio_add_highpass(1, 500.0) == 0

    context "Effect stubs":
        it "rt_audio_add_reverb returns 0":
            expect rt_audio_add_reverb(1, 0.5, 0.3) == 0

        it "rt_audio_add_delay returns 0":
            expect rt_audio_add_delay(1, 200.0, 0.4) == 0

        it "rt_audio_remove_effect returns 0":
            expect rt_audio_remove_effect(1, 2) == 0

        it "rt_audio_clear_effects returns 0":
            expect rt_audio_clear_effects(1) == 0
