app:
    title: "Test App"
    theme: dark

layout:
    type: vbox
    children:
        main:
            type: panel
            id: main
            title: Test
            flex: 1
            children:
                greeting:
                    type: text
                    id: greeting
                    content: "Hello Test GUI"
        status:
            type: statusbar
            id: status
            left: "NORMAL"
            right: "Test App"
