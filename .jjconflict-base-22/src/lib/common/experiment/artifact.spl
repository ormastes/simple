# Experiment Artifact Tracking
#
# Tracks outputs (binaries, models, logs, datasets, checkpoints, reports)
# produced by experiment runs.  All data structures are immutable; operations
# return new values rather than mutating in place.

# ---------------------------------------------------------------------------
# ArtifactKind — what type of output this artifact represents
# ---------------------------------------------------------------------------

enum ArtifactKind:
    Binary
    Model
    Log
    Dataset
    Checkpoint
    Report

# ---------------------------------------------------------------------------
# ArtifactMeta — a single key-value metadata pair
# ---------------------------------------------------------------------------

struct ArtifactMeta:
    key: text
    value: text

fn artifact_meta(key: text, value: text) -> ArtifactMeta:
    """Construct a metadata key-value pair."""
    ArtifactMeta(key: key, value: value)

# ---------------------------------------------------------------------------
# Artifact — a single tracked output
# ---------------------------------------------------------------------------

struct Artifact:
    """A single experiment output artifact."""
    name: text
    kind: ArtifactKind
    path: text
    size_bytes: i64
    checksum: text
    created_at: text
    metadata: [ArtifactMeta]

fn artifact_new(name: text, kind: ArtifactKind, path: text, size_bytes: i64, checksum: text, created_at: text) -> Artifact:
    """Construct an Artifact with no metadata."""
    Artifact(
        name: name,
        kind: kind,
        path: path,
        size_bytes: size_bytes,
        checksum: checksum,
        created_at: created_at,
        metadata: []
    )

fn artifact_with_meta(a: Artifact, meta: [ArtifactMeta]) -> Artifact:
    """Return a copy of the artifact with the given metadata list attached."""
    Artifact(
        name: a.name,
        kind: a.kind,
        path: a.path,
        size_bytes: a.size_bytes,
        checksum: a.checksum,
        created_at: a.created_at,
        metadata: meta
    )

fn artifact_add_meta(a: Artifact, key: text, value: text) -> Artifact:
    """Return a copy of the artifact with one additional metadata entry."""
    artifact_with_meta(a, a.metadata.push(artifact_meta(key, value)))

fn artifact_get_meta(a: Artifact, key: text) -> text?:
    """Look up a metadata value by key; returns nil if not found."""
    for m in a.metadata:
        if m.key == key:
            return Some(m.value)
    nil

# ---------------------------------------------------------------------------
# ArtifactStore — an ordered collection of artifacts
# ---------------------------------------------------------------------------

struct ArtifactStore:
    """Ordered collection of experiment artifacts."""
    artifacts: [Artifact]

fn artifact_store_new() -> ArtifactStore:
    """Return an empty ArtifactStore."""
    ArtifactStore(artifacts: [])

fn artifact_add(store: ArtifactStore, artifact: Artifact) -> ArtifactStore:
    """Return a new store with the artifact appended."""
    ArtifactStore(artifacts: store.artifacts.push(artifact))

fn artifact_find(store: ArtifactStore, name: text) -> Artifact?:
    """Find the first artifact with the given name; returns nil if absent."""
    for a in store.artifacts:
        if a.name == name:
            return Some(a)
    nil

fn artifact_by_kind(store: ArtifactStore, kind: ArtifactKind) -> [Artifact]:
    """Return all artifacts whose kind matches the given kind."""
    var result: [Artifact] = []
    for a in store.artifacts:
        if a.kind == kind:
            result = result.push(a)
    result

fn artifact_count(store: ArtifactStore) -> i64:
    """Return the total number of artifacts in the store."""
    store.artifacts.len()

fn artifact_total_bytes(store: ArtifactStore) -> i64:
    """Return the sum of size_bytes across all artifacts."""
    var total = 0
    for a in store.artifacts:
        total = total + a.size_bytes
    total

# ---------------------------------------------------------------------------
# artifact_summary — human-readable overview
# ---------------------------------------------------------------------------

fn _kind_label(kind: ArtifactKind) -> text:
    match kind:
        case ArtifactKind.Binary:     "Binary"
        case ArtifactKind.Model:      "Model"
        case ArtifactKind.Log:        "Log"
        case ArtifactKind.Dataset:    "Dataset"
        case ArtifactKind.Checkpoint: "Checkpoint"
        case ArtifactKind.Report:     "Report"

fn _format_bytes(n: i64) -> text:
    if n < 1024:
        n.to_text() + " B"
    else if n < 1048576:
        (n / 1024).to_text() + " KB"
    else if n < 1073741824:
        (n / 1048576).to_text() + " MB"
    else:
        (n / 1073741824).to_text() + " GB"

fn artifact_summary(store: ArtifactStore) -> text:
    """Return a human-readable summary of the artifact store."""
    val total = store.artifacts.len()
    val bytes = artifact_total_bytes(store)
    var lines = "ArtifactStore: " + total.to_text() + " artifact(s), " + _format_bytes(bytes) + " total\n"
    for a in store.artifacts:
        lines = lines + "  [" + _kind_label(a.kind) + "] " + a.name + " (" + _format_bytes(a.size_bytes) + ") @ " + a.path + "\n"
    lines
