# Split-pane layout manager for the text editor.

use std.editor.types

class SplitPaneLayout:
    panes: [i64]
    active_pane: i64
    next_id: i64

fn split_pane_create() -> SplitPaneLayout:
    SplitPaneLayout(panes: [0], active_pane: 0, next_id: 1)

fn split_pane_list_panes(layout: SplitPaneLayout) -> [i64]:
    layout.panes

fn split_pane_split(layout: SplitPaneLayout, direction: SplitDirection) -> i64:
    val new_id = layout.next_id
    layout.panes.push(new_id)
    layout.next_id = layout.next_id + 1
    layout.active_pane = new_id
    new_id

fn split_pane_focus(layout: SplitPaneLayout, pane_id: i64):
    layout.active_pane = pane_id

fn split_pane_active(layout: SplitPaneLayout) -> i64:
    layout.active_pane

fn split_pane_close(layout: SplitPaneLayout, pane_id: i64):
    var new_panes: [i64] = []
    var i = 0
    while i < layout.panes.len():
        if layout.panes[i] != pane_id:
            new_panes.push(layout.panes[i])
        i = i + 1
    layout.panes = new_panes
    if layout.active_pane == pane_id and layout.panes.len() > 0:
        layout.active_pane = layout.panes[0]
