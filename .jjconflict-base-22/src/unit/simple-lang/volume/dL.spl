# Unit: DlVol
# Kind: Volume
# Symbol: dL
# Canonical scale: 0.0001 m3

class DlVol:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: DlVol) -> DlVol: DlVol(value: self.value + other.value)
    fn sub(other: DlVol) -> DlVol: DlVol(value: self.value - other.value)

    static fn kind() -> text: "Volume"
    static fn symbol() -> text: "dL"
    static fn scale_to_base() -> f64: 0.0001
    static fn base_unit() -> text: "m3"
    static fn zero() -> DlVol: DlVol(value: 0.0)

export DlVol
