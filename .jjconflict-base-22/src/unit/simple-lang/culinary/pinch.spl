# Unit: Pinch
# Kind: Culinary
# Symbol: pinch
# Canonical scale: 0.3 mL

class Pinch:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Pinch) -> Pinch: Pinch(value: self.value + other.value)
    fn sub(other: Pinch) -> Pinch: Pinch(value: self.value - other.value)

    static fn kind() -> text: "Culinary"
    static fn symbol() -> text: "pinch"
    static fn scale_to_base() -> f64: 0.3
    static fn base_unit() -> text: "mL"
    static fn zero() -> Pinch: Pinch(value: 0.0)

export Pinch
