# Environment variables for PyTorch/LibTorch integration
# Source this file with: source .envrc

# Default to CPU mode (working perfectly)
# Set SIMPLE_PYTORCH_DEVICE=cuda to attempt CUDA mode
export SIMPLE_PYTORCH_DEVICE="${SIMPLE_PYTORCH_DEVICE:-cpu}"

# Use Python's PyTorch installation
export LIBTORCH_USE_PYTORCH=1
export LIBTORCH_BYPASS_VERSION_CHECK=1
export LD_LIBRARY_PATH="/home/ormastes/.local/lib/python3.12/site-packages/torch/lib:$LD_LIBRARY_PATH"

echo "Simple PyTorch Environment:"
echo "  Mode: $SIMPLE_PYTORCH_DEVICE"
echo "  Using Python PyTorch: 2.9.1+cu130"
echo "  CPU operations: ✅ Working"
echo "  CUDA operations: ⚠️  Requires proper LibTorch build"
echo ""
echo "To switch modes:"
echo "  CPU:  export SIMPLE_PYTORCH_DEVICE=cpu"
echo "  CUDA: export SIMPLE_PYTORCH_DEVICE=cuda (requires CUDA-enabled LibTorch)"

# LLM API keys (set in shell profile or pass at invocation — NEVER hardcode)
export OPENAI_API_KEY="${OPENAI_API_KEY:-}"
export GEMINI_API_KEY="${GEMINI_API_KEY:-}"

if [ -n "$OPENAI_API_KEY" ]; then
  echo "  OpenAI API: ✅ Key set"
else
  echo "  OpenAI API: ⚠️  OPENAI_API_KEY not set (codex_api provider unavailable)"
fi
if [ -n "$GEMINI_API_KEY" ]; then
  echo "  Gemini API: ✅ Key set"
else
  echo "  Gemini API: ⚠️  GEMINI_API_KEY not set (gemini_api provider unavailable)"
fi
