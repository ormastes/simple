# Generator for-in iteration regression spec (S7)
#
# Bug: doc/08_tracking/bug/async_await_interpreter_crashes_2026-06-11.md (B3/S7)
# Iterating a `gen` function with for-in failed in the interpreter. Root cause:
# iter_to_vec() (interpreter_helpers/collections.rs), the iteration helper used
# by the module-scope for-loop, lacked a Value::Generator arm and errored with
# "cannot iterate over this type". Async semantics are eager, so a gen call runs
# the body to completion collecting all yields into a Value::Generator that
# for-in then drains in order. Fixed by adding the Generator arm (mirrors
# block_execution::get_iterator_values). This spec pins the behavior.

use std.spec.*

gen counter() -> i64:
    yield 1
    yield 2
    yield 3

gen empty() -> i64:
    return

# Encode visitation order into one integer: yields 1,2,3 -> 123.
fn ordered_total() -> i64:
    var total = 0
    for x in counter():
        total = total * 10 + x
    total

fn count_iterations() -> i64:
    var count = 0
    for x in empty():
        count = count + 1
    count

# Plain (non-generator) function returning an array must still iterate.
fn plain_nums() -> [i64]:
    [4, 5, 6]

fn plain_total() -> i64:
    var total = 0
    for x in plain_nums():
        total = total + x
    total

describe "generator for-in iteration (S7)":

    it "collects multi-yield generator values in order":
        val got = ordered_total()
        expect(got).to_equal(123)

    it "iterates a zero-yield generator zero times":
        val got = count_iterations()
        expect(got).to_equal(0)

    it "still iterates a plain function returning an array":
        val got = plain_total()
        expect(got).to_equal(15)
