use common.wine_dll_file_probe.{wine_dll_probe_file}
use common.wine_dll_file_view.{wine_dll_map_file_backed_view, wine_dll_map_file_backed_view_with_peb_teb_vm_writes}
use common.wine_peb_teb.{wine_peb_teb_apply_layout_byte_writes, wine_peb_teb_init_default, wine_peb_teb_layout_byte_writes, wine_peb_teb_layout_write_plan, wine_peb_teb_memory_write_gate}
use common.wine_vm_adapter.{WineVmSpace, wine_vm_commit, wine_vm_process_space_new, wine_vm_reserve_fixed, wine_vm_space_find}

fn _zero_bytes(count: i64) -> [u8]:
    var out: [u8] = []
    var i = 0
    while i < count:
        out.push(0)
        i = i + 1
    out

fn _put_u16_le(data: [u8], offset: i64, value: i64) -> [u8]:
    data[offset] = (value & 0xff) as u8
    data[offset + 1] = ((value >> 8) & 0xff) as u8
    data

fn _put_u32_le(data: [u8], offset: i64, value: i64) -> [u8]:
    data[offset] = (value & 0xff) as u8
    data[offset + 1] = ((value >> 8) & 0xff) as u8
    data[offset + 2] = ((value >> 16) & 0xff) as u8
    data[offset + 3] = ((value >> 24) & 0xff) as u8
    data

fn _dll_bytes() -> [u8]:
    var data = _zero_bytes(1024)
    data[0] = 0x4d
    data[1] = 0x5a
    data = _put_u32_le(data, 0x3c, 0x80)
    data[0x80] = 0x50
    data[0x81] = 0x45
    data = _put_u16_le(data, 0x84, 0x8664)
    data = _put_u16_le(data, 0x86, 1)
    data = _put_u16_le(data, 0x94, 0xf0)
    data = _put_u16_le(data, 0x96, 0x2022)
    data = _put_u16_le(data, 0x98, 0x20b)
    data = _put_u32_le(data, 0x98 + 0x10, 0x1200)
    data = _put_u32_le(data, 0x98 + 0x38, 0x5000)
    data = _put_u32_le(data, 0x98 + 0x3c, 0x200)
    data

fn _commit_fixed(space: WineVmSpace, base: i64, size: i64, perms: text) -> WineVmSpace:
    val reserved = wine_vm_reserve_fixed(space, base, size)
    if not reserved.ok:
        return reserved.space
    val committed = wine_vm_commit(reserved.space, reserved.region.base, perms)
    committed.space

fn _startup_write_space() -> WineVmSpace:
    var space = wine_vm_process_space_new(10, 30, "pid fs ipc net capability")
    space = _commit_fixed(space, 0x7ffdc000, 0x1000, "rw")
    space = _commit_fixed(space, 0x7ffdd000, 0x1000, "rw")
    space = _commit_fixed(space, 0x7ffde000, 0x1000, "rw")
    _commit_fixed(space, 0x7ffdf000, 0x1000, "rw")

describe "wine dll file view":
    it "maps a validated DLL file probe into a persistent process image view":
        val files = [wine_dll_probe_file("\\KnownDlls\\kernel32.dll", _dll_bytes())]
        val result = wine_dll_map_file_backed_view("kernel32.dll", "C:\\Games", "C:\\Users\\Player", [], ["kernel32.dll"], files, 33, 44, "pid fs ipc net capability", 0x79000000)
        expect(result.ok).to_equal(true)
        expect(result.selected_path).to_equal("\\KnownDlls\\kernel32.dll")
        expect(result.mapped_base).to_equal(0x79000000)
        expect(result.mapped_size).to_equal(0x5000)
        expect(result.entrypoint_rva).to_equal(0x1200)
        expect(result.status).to_equal("dll-file-backed-view-mapped")
        val region = wine_vm_space_find(result.space, 0x79000000)
        expect(region.kind).to_equal("image")
        expect(region.perms).to_equal("rx")
        expect(result.evidence).to_contain("dll-file-probe-validated")
        expect(result.evidence).to_contain("file-backed-dll-view-persistent")
        expect(result.evidence).to_contain("os-vma")
        expect(result.evidence).to_contain("no-dll-entrypoint-executed")

    it "maps a retained DLL file view only after PEB/TEB VM byte-write readback":
        val files = [wine_dll_probe_file("\\KnownDlls\\kernel32.dll", _dll_bytes())]
        val init = wine_peb_teb_init_default()
        val writes = wine_peb_teb_memory_write_gate(init, _startup_write_space())
        val layout = wine_peb_teb_layout_write_plan(init, writes)
        val bytes = wine_peb_teb_layout_byte_writes(layout)
        val vm_writes = wine_peb_teb_apply_layout_byte_writes(_startup_write_space(), bytes)
        val result = wine_dll_map_file_backed_view_with_peb_teb_vm_writes("kernel32.dll", "C:\\Games", "C:\\Users\\Player", [], ["kernel32.dll"], files, 33, 44, "pid fs ipc net capability", 0x79000000, vm_writes)
        expect(result.ok).to_equal(true)
        expect(result.status).to_equal("dll-file-backed-view-mapped")
        expect(result.mapped_base).to_equal(0x79000000)
        expect(result.evidence).to_contain("peb-teb-vm-writes-ready")
        expect(result.evidence).to_contain("VMWriteReadback:PEBTEBLayoutBytes")
        expect(result.evidence).to_contain("file-backed-dll-view-mapped")
        expect(result.evidence).to_contain("no-dll-entrypoint-executed")

    it "rejects invalid probe or mapping inputs":
        val invalid_base = wine_dll_map_file_backed_view("kernel32.dll", "C:\\Games", "C:\\Users\\Player", [], ["kernel32.dll"], [], 33, 44, "pid fs ipc net capability", 0)
        expect(invalid_base.ok).to_equal(false)
        expect(invalid_base.error).to_equal("invalid-image-base")
        val missing = wine_dll_map_file_backed_view("gameaudio.dll", "C:\\Games", "C:\\Users\\Player", [], [], [], 33, 44, "pid fs ipc net capability", 0x79000000)
        expect(missing.ok).to_equal(false)
        expect(missing.error).to_equal("dll-file-probe:dll-file-not-found")
