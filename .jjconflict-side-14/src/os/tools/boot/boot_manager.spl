use os.userlib.fs.{read_text, write_text}

## Limine boot config manager.
## Usage: bootctl list|default INDEX|add LABEL KERNEL [CMDLINE]

struct BootEntry:
    label: text
    kernel_path: text
    cmdline: text
    is_default: bool

struct LimineConfig:
    timeout: i32
    entries: [BootEntry]

val LIMINE_CFG_PATH = "/boot/limine.cfg"

fn parse_limine_cfg(content: text) -> LimineConfig:
    var timeout = 5
    var entries: [BootEntry] = []
    var current_label = ""
    var current_kernel = ""
    var current_cmdline = ""
    var current_default = false
    var in_entry = false

    val lines = content.split("\n")
    for line in lines:
        val trimmed = line.trim()

        if trimmed.starts_with("TIMEOUT="):
            val val_str = trimmed.slice(8, trimmed.len())
            timeout = val_str.to_i32() ?? 5
        else if trimmed.starts_with(":"):
            if in_entry:
                val entry = BootEntry(
                    label: current_label,
                    kernel_path: current_kernel,
                    cmdline: current_cmdline,
                    is_default: current_default,
                )
                entries.push(entry)
            current_label = trimmed.slice(1, trimmed.len())
            current_kernel = ""
            current_cmdline = ""
            current_default = false
            in_entry = true
        else if trimmed.starts_with("PROTOCOL="):
            pass_dn
        else if trimmed.starts_with("KERNEL_PATH="):
            current_kernel = trimmed.slice(12, trimmed.len())
        else if trimmed.starts_with("CMDLINE="):
            current_cmdline = trimmed.slice(8, trimmed.len())
        else if trimmed == "DEFAULT_ENTRY=1":
            current_default = true

    if in_entry:
        val entry = BootEntry(
            label: current_label,
            kernel_path: current_kernel,
            cmdline: current_cmdline,
            is_default: current_default,
        )
        entries.push(entry)

    LimineConfig(timeout: timeout, entries: entries)

fn write_limine_cfg(cfg: LimineConfig) -> text:
    var out = "TIMEOUT={cfg.timeout}\n\n"
    var idx = 0
    for entry in cfg.entries:
        val label = entry.label
        val kernel = entry.kernel_path
        val cmdline = entry.cmdline
        out = out + ":{label}\n"
        out = out + "PROTOCOL=limine\n"
        out = out + "KERNEL_PATH={kernel}\n"
        if cmdline.len() > 0:
            out = out + "CMDLINE={cmdline}\n"
        if entry.is_default:
            out = out + "DEFAULT_ENTRY=1\n"
        out = out + "\n"
        idx = idx + 1
    out

fn list_boot_entries(cfg: LimineConfig) -> text:
    var out = "Boot entries (timeout={cfg.timeout}s):\n"
    var idx = 0
    for entry in cfg.entries:
        val default_marker = if entry.is_default: " [default]" else: ""
        val label = entry.label
        val kernel = entry.kernel_path
        out = out + "  {idx}: {label} -> {kernel}{default_marker}\n"
        idx = idx + 1
    out

fn _cmd_list() -> i32:
    val content = read_text(LIMINE_CFG_PATH)
    val cfg = parse_limine_cfg(content)
    val output = list_boot_entries(cfg)
    print output
    0

fn _cmd_default(index_str: text) -> i32:
    val content = read_text(LIMINE_CFG_PATH)
    var cfg = parse_limine_cfg(content)
    val index = index_str.to_i32() ?? -1

    if index < 0 or index >= cfg.entries.len():
        print "Error: invalid index {index_str}"
        return 1

    var new_entries: [BootEntry] = []
    var idx = 0
    for entry in cfg.entries:
        val is_def = idx == index
        val new_entry = BootEntry(
            label: entry.label,
            kernel_path: entry.kernel_path,
            cmdline: entry.cmdline,
            is_default: is_def,
        )
        new_entries.push(new_entry)
        idx = idx + 1

    val new_cfg = LimineConfig(timeout: cfg.timeout, entries: new_entries)
    val out_text = write_limine_cfg(new_cfg)
    write_text(LIMINE_CFG_PATH, out_text)
    print "Default set to entry {index_str}"
    0

fn _cmd_add(label: text, kernel: text, cmdline: text) -> i32:
    val content = read_text(LIMINE_CFG_PATH)
    var cfg = parse_limine_cfg(content)
    val is_first = cfg.entries.len() == 0

    val entry = BootEntry(
        label: label,
        kernel_path: kernel,
        cmdline: cmdline,
        is_default: is_first,
    )
    cfg.entries.push(entry)

    val out_text = write_limine_cfg(cfg)
    write_text(LIMINE_CFG_PATH, out_text)
    print "Added boot entry: {label}"
    0

fn _print_usage():
    print "Usage: bootctl <command> [args]"
    print ""
    print "Commands:"
    print "  list              List boot entries"
    print "  default INDEX     Set default boot entry"
    print "  add LABEL KERNEL [CMDLINE]  Add a boot entry"

fn run_bootctl(args: [text]) -> i32:
    if args.len() == 0:
        _print_usage()
        return 0

    val cmd = args[0]

    if cmd == "list":
        return _cmd_list()
    else if cmd == "default":
        if args.len() < 2:
            print "Error: missing INDEX"
            return 1
        return _cmd_default(args[1])
    else if cmd == "add":
        if args.len() < 3:
            print "Error: missing LABEL and KERNEL"
            return 1
        val cmdline = if args.len() >= 4: args[3] else: ""
        return _cmd_add(args[1], args[2], cmdline)
    else if cmd == "-h":
        _print_usage()
        return 0
    else:
        print "Unknown command: {cmd}"
        _print_usage()
        return 1
