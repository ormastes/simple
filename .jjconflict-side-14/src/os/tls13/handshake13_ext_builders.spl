# TLS 1.3 Extension Builders and ClientHello Construction.
#
# Private extension builder functions (_build_ext_*) and the public
# build_client_hello_bytes / build_client_hello_bytes_with_p256 entry points.
# Imported by handshake13.spl (the hub).
#
# Constants that overlap with handshake13.spl are redeclared locally so this
# file has no import-cycle dependency on the hub.

extern fn rt_array_new_with_cap(cap: i64) -> [u8]
extern fn rt_bytes_u8_at(arr: [u8], idx: i64) -> i64

# Local constant copies (canonical definitions live in handshake13.spl)
val _EB_TLS13_ASCII_PRINTABLE: text = " !\"#$%&'()*+,-./0123456789:;<=>?@ABCDEFGHIJKLMNOPQRSTUVWXYZ[\\]^_`abcdefghijklmnopqrstuvwxyz{|}~"
val _EB_HS_CLIENT_HELLO: u8         = 1
val _EB_EXT_SNI: u16                = 0
val _EB_EXT_SUPPORTED_GROUPS: u16   = 10
val _EB_EXT_SIG_ALGS: u16           = 13
val _EB_EXT_SUPPORTED_VERSIONS: u16 = 43
val _EB_EXT_KEY_SHARE: u16          = 51
val _EB_GROUP_X25519: u16           = 0x001D
val _EB_GROUP_SECP256R1: u16        = 0x0017
val _EB_SIG_ED25519: u16            = 0x0807
val _EB_SIG_ECDSA_SECP384R1_SHA384: u16 = 0x0503
val _EB_SIG_ECDSA_SECP521R1_SHA512: u16 = 0x0603

fn _u8_at_eb(data: [u8], offset: u64) -> u8:
    rt_bytes_u8_at(data, offset.to_i64()).to_u8()

fn _byte_buf_eb(cap: u64) -> [u8]:
    rt_array_new_with_cap(cap.to_i64())

fn _push_byte_eb(buf: [u8], byte_val: i64) -> [u8]:
    buf.push(byte_val.to_u8())
    buf

fn _put_u16_be_eb(value: u16) -> [u8]:
    var out: [u8] = _byte_buf_eb(2)
    out = _push_byte_eb(out, ((value.to_u32() >> 8) & 0xFF).to_i64())
    out = _push_byte_eb(out, (value.to_u32() & 0xFF).to_i64())
    out

fn _put_u24_be_eb(value: u64) -> [u8]:
    var out: [u8] = _byte_buf_eb(3)
    out = _push_byte_eb(out, ((value >> 16) & 0xFF).to_i64())
    out = _push_byte_eb(out, ((value >> 8) & 0xFF).to_i64())
    out = _push_byte_eb(out, (value & 0xFF).to_i64())
    out

fn _append_bytes_eb(a: [u8], b: [u8]) -> [u8]:
    var out: [u8] = _byte_buf_eb(a.len() + b.len())
    var i: u64 = 0
    while i < a.len():
        out = _push_byte_eb(out, _u8_at_eb(a, i).to_u64().to_i64())
        i = i + 1
    i = 0
    while i < b.len():
        out = _push_byte_eb(out, _u8_at_eb(b, i).to_u64().to_i64())
        i = i + 1
    out

fn _text_to_bytes_eb(s: text) -> [u8]:
    var result: [u8] = []
    val chars = s.split("")
    for ch in chars:
        if ch != "":
            var idx: i64 = 0
            var found = false
            while idx < _EB_TLS13_ASCII_PRINTABLE.len() and not found:
                if _EB_TLS13_ASCII_PRINTABLE[idx:idx + 1] == ch:
                    result.push((idx + 32).to_u8())
                    found = true
                idx = idx + 1
    result

# ============================================================================
# Extension Builders (private)
# ============================================================================

fn _build_ext_supported_versions_eb() -> [u8]:
    val ext_type = _put_u16_be_eb(_EB_EXT_SUPPORTED_VERSIONS)
    var versions: [u8] = _byte_buf_eb(3)
    versions = _push_byte_eb(versions, 0x02)
    versions = _push_byte_eb(versions, 0x03)
    versions = _push_byte_eb(versions, 0x04)
    val ext_len = _put_u16_be_eb(versions.len().to_u16())
    var out: [u8] = _byte_buf_eb(7)
    out = _append_bytes_eb(out, ext_type)
    out = _append_bytes_eb(out, ext_len)
    out = _append_bytes_eb(out, versions)
    out

fn _build_key_share_entry_eb(group: u16, key: [u8]) -> [u8]:
    val group_bytes = _put_u16_be_eb(group)
    val key_len_bytes = _put_u16_be_eb(key.len().to_u16())
    var entry: [u8] = _byte_buf_eb(key.len() + 4)
    entry = _append_bytes_eb(entry, group_bytes)
    entry = _append_bytes_eb(entry, key_len_bytes)
    entry = _append_bytes_eb(entry, key)
    entry

fn _build_ext_key_share_single_eb(x25519_pub: [u8]) -> [u8]:
    val entry = _build_key_share_entry_eb(_EB_GROUP_X25519, x25519_pub)
    val list_len = _put_u16_be_eb(entry.len().to_u16())
    var client_shares: [u8] = _byte_buf_eb(entry.len() + 2)
    client_shares = _append_bytes_eb(client_shares, list_len)
    client_shares = _append_bytes_eb(client_shares, entry)
    val ext_type = _put_u16_be_eb(_EB_EXT_KEY_SHARE)
    val ext_len = _put_u16_be_eb(client_shares.len().to_u16())
    var out: [u8] = _byte_buf_eb(client_shares.len() + 4)
    out = _append_bytes_eb(out, ext_type)
    out = _append_bytes_eb(out, ext_len)
    out = _append_bytes_eb(out, client_shares)
    out

fn _build_ext_key_share_dual_eb(x25519_pub: [u8], p256_pub: [u8]) -> [u8]:
    if p256_pub.len() == 0:
        return _build_ext_key_share_single_eb(x25519_pub)
    val entry_x = _build_key_share_entry_eb(_EB_GROUP_X25519, x25519_pub)
    val entry_p = _build_key_share_entry_eb(_EB_GROUP_SECP256R1, p256_pub)
    var entries: [u8] = _byte_buf_eb(entry_x.len() + entry_p.len())
    entries = _append_bytes_eb(entries, entry_x)
    entries = _append_bytes_eb(entries, entry_p)
    val list_len = _put_u16_be_eb(entries.len().to_u16())
    var client_shares: [u8] = _byte_buf_eb(entries.len() + 2)
    client_shares = _append_bytes_eb(client_shares, list_len)
    client_shares = _append_bytes_eb(client_shares, entries)
    val ext_type = _put_u16_be_eb(_EB_EXT_KEY_SHARE)
    val ext_len = _put_u16_be_eb(client_shares.len().to_u16())
    var out: [u8] = _byte_buf_eb(client_shares.len() + 4)
    out = _append_bytes_eb(out, ext_type)
    out = _append_bytes_eb(out, ext_len)
    out = _append_bytes_eb(out, client_shares)
    out

fn _build_ext_sni_eb(host: text) -> [u8]:
    val host_bytes = _text_to_bytes_eb(host)
    val host_len = _put_u16_be_eb(host_bytes.len().to_u16())
    var sn_entry: [u8] = _byte_buf_eb(host_bytes.len() + 3)
    sn_entry = _push_byte_eb(sn_entry, 0x00)
    sn_entry = _append_bytes_eb(sn_entry, host_len)
    sn_entry = _append_bytes_eb(sn_entry, host_bytes)
    val list_len = _put_u16_be_eb(sn_entry.len().to_u16())
    var sn_list: [u8] = _byte_buf_eb(sn_entry.len() + 2)
    sn_list = _append_bytes_eb(sn_list, list_len)
    sn_list = _append_bytes_eb(sn_list, sn_entry)
    val ext_type = _put_u16_be_eb(_EB_EXT_SNI)
    val ext_len = _put_u16_be_eb(sn_list.len().to_u16())
    var out: [u8] = _byte_buf_eb(sn_list.len() + 4)
    out = _append_bytes_eb(out, ext_type)
    out = _append_bytes_eb(out, ext_len)
    out = _append_bytes_eb(out, sn_list)
    out

fn _build_ext_sig_algs_eb() -> [u8]:
    var alg_bytes: [u8] = []
    alg_bytes = _append_bytes_eb(alg_bytes, _put_u16_be_eb(_EB_SIG_ED25519))
    alg_bytes = _append_bytes_eb(alg_bytes, _put_u16_be_eb(_EB_SIG_ECDSA_SECP384R1_SHA384))
    alg_bytes = _append_bytes_eb(alg_bytes, _put_u16_be_eb(_EB_SIG_ECDSA_SECP521R1_SHA512))
    val list_len = _put_u16_be_eb(alg_bytes.len().to_u16())
    var alg_list: [u8] = _byte_buf_eb(alg_bytes.len() + 2)
    alg_list = _append_bytes_eb(alg_list, list_len)
    alg_list = _append_bytes_eb(alg_list, alg_bytes)
    val ext_type = _put_u16_be_eb(_EB_EXT_SIG_ALGS)
    val ext_len = _put_u16_be_eb(alg_list.len().to_u16())
    var out: [u8] = _byte_buf_eb(alg_list.len() + 4)
    out = _append_bytes_eb(out, ext_type)
    out = _append_bytes_eb(out, ext_len)
    out = _append_bytes_eb(out, alg_list)
    out

fn _build_ext_supported_groups_eb() -> [u8]:
    val x25519_be = _put_u16_be_eb(_EB_GROUP_X25519)
    val p256_be = _put_u16_be_eb(_EB_GROUP_SECP256R1)
    var groups: [u8] = _byte_buf_eb(4)
    groups = _append_bytes_eb(groups, x25519_be)
    groups = _append_bytes_eb(groups, p256_be)
    val list_len = _put_u16_be_eb(groups.len().to_u16())
    var group_list: [u8] = _byte_buf_eb(groups.len() + 2)
    group_list = _append_bytes_eb(group_list, list_len)
    group_list = _append_bytes_eb(group_list, groups)
    val ext_type = _put_u16_be_eb(_EB_EXT_SUPPORTED_GROUPS)
    val ext_len = _put_u16_be_eb(group_list.len().to_u16())
    var out: [u8] = _byte_buf_eb(group_list.len() + 4)
    out = _append_bytes_eb(out, ext_type)
    out = _append_bytes_eb(out, ext_len)
    out = _append_bytes_eb(out, group_list)
    out

# ============================================================================
# Public: Build ClientHello bytes
# ============================================================================

fn build_client_hello_bytes(random: [u8], x25519_pub: [u8], sni_host: text) -> [u8]:
    """Encode a minimal TLS 1.3 ClientHello message (X25519 only)."""
    build_client_hello_bytes_with_p256(random, x25519_pub, [], sni_host)

fn build_client_hello_bytes_with_p256(random: [u8], x25519_pub: [u8], p256_pub: [u8], sni_host: text) -> [u8]:
    """Encode a minimal TLS 1.3 ClientHello message (X25519 + secp256r1)."""
    var body: [u8] = _byte_buf_eb(192)
    body = _push_byte_eb(body, 0x03)
    body = _push_byte_eb(body, 0x03)
    body = _append_bytes_eb(body, random)

    body = _push_byte_eb(body, 0x20)
    var i: u64 = 0
    while i < 32:
        body = _push_byte_eb(body, 0x00)
        i = i + 1

    body = _push_byte_eb(body, 0x00)
    body = _push_byte_eb(body, 0x06)
    body = _push_byte_eb(body, 0x13)
    body = _push_byte_eb(body, 0x01)
    body = _push_byte_eb(body, 0x13)
    body = _push_byte_eb(body, 0x02)
    body = _push_byte_eb(body, 0x13)
    body = _push_byte_eb(body, 0x03)

    body = _push_byte_eb(body, 0x01)
    body = _push_byte_eb(body, 0x00)

    var exts: [u8] = _byte_buf_eb(160)
    exts = _append_bytes_eb(exts, _build_ext_supported_versions_eb())
    exts = _append_bytes_eb(exts, _build_ext_key_share_dual_eb(x25519_pub, p256_pub))
    exts = _append_bytes_eb(exts, _build_ext_sni_eb(sni_host))
    exts = _append_bytes_eb(exts, _build_ext_sig_algs_eb())
    exts = _append_bytes_eb(exts, _build_ext_supported_groups_eb())

    val exts_len_bytes = _put_u16_be_eb(exts.len().to_u16())
    body = _append_bytes_eb(body, exts_len_bytes)
    body = _append_bytes_eb(body, exts)

    val body_len = _put_u24_be_eb(body.len().to_u64())
    var out: [u8] = _byte_buf_eb(body.len() + 4)
    out = _push_byte_eb(out, _EB_HS_CLIENT_HELLO)
    out = _append_bytes_eb(out, body_len)
    out = _append_bytes_eb(out, body)
    out
