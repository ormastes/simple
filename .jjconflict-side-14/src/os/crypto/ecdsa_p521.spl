# ECDSA P-521 Signing and Verification — Pure Simple
#
# Self-contained module providing:
#   - 521-bit field arithmetic (mod p) using BigNat ([i64] base-2^30)
#   - 521-bit scalar arithmetic (mod n)
#   - Affine + Jacobian point operations (double, add, scalar_mult)
#   - ECDSA sign/verify with RFC 6979 deterministic nonce (SHA-512 HMAC)
#
# No SFFI — all arithmetic is in pure Simple via std.math.bignum.bignat.
#
# Curve: y^2 = x^3 - 3x + b  (mod p)
# p = 2^521 - 1  (Mersenne prime, FIPS 186-5 §D.1.2.5)
# n = order of base point G
#
# Key format:
#   - Signing:      raw 66-byte big-endian private scalar
#   - Verification: 133-byte uncompressed SEC1 public key (0x04 || X || Y)
#
# Signature format:
#   - fixed132: 132-byte r||s (66 bytes each, big-endian, 521-bit values
#     left-padded into 528-bit/66-byte buffers per RFC 8446 §4.2.3).
#
# Performance note: BigNat-based P-521 scalar multiplication is multi-second
# in interpreter mode due to the 521-bit field width. This implementation is
# correct and pure-Simple; a faster custom-limb version following p384.spl's
# pattern is tracked as Path B in the feature request.
#
# References:
#   * FIPS 186-5 §D.1.2.5 (P-521 parameters)
#   * RFC 6979 (Deterministic Usage of DSA and ECDSA)
#   * RFC 8446 §4.2.3 (TLS 1.3 ECDSA-P-521 signature encoding)
#   * SEC1 v2.0 §2.7.2 (uncompressed point encoding)

use os.crypto.sha512.{sha512, sha512_hmac}
use std.math.bignum.bignat.{
    bn_zero, bn_one, bn_from_i64, is_zero, cmp, add, sub, mul, modulo,
    from_bytes_be, to_bytes_be, mod_exp, bit_length, get_bit, div_mod
}

# ============================================================================
# P-521 curve constants (big-endian bytes -> BigNat at module init)
# ============================================================================

fn _p521_p_bytes() -> [u8]:
    """P-521 prime p = 2^521 - 1 as 66 big-endian bytes."""
    [
        0x01u8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8,
        0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8,
        0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8,
        0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8,
        0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8,
        0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8,
        0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8,
        0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8,
        0xFFu8, 0xFFu8
    ]

fn _p521_n_bytes() -> [u8]:
    """P-521 group order n as 66 big-endian bytes.
    n = 0x01FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFA51868783BF2F966B7FCC0148F709A5D03BB5C9B8899C47AEBB6FB71E91386409
    (FIPS 186-4 §D.1.2.5 / SEC2 v2.0 §2.6.1)"""
    [
        0x01u8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8,
        0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8,
        0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8,
        0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8, 0xFFu8,
        0xFFu8, 0xFAu8, 0x51u8, 0x86u8, 0x87u8, 0x83u8, 0xBFu8, 0x2Fu8,
        0x96u8, 0x6Bu8, 0x7Fu8, 0xCCu8, 0x01u8, 0x48u8, 0xF7u8, 0x09u8,
        0xA5u8, 0xD0u8, 0x3Bu8, 0xB5u8, 0xC9u8, 0xB8u8, 0x89u8, 0x9Cu8,
        0x47u8, 0xAEu8, 0xBBu8, 0x6Fu8, 0xB7u8, 0x1Eu8, 0x91u8, 0x38u8,
        0x64u8, 0x09u8
    ]

fn _p521_b_bytes() -> [u8]:
    """P-521 curve coefficient b as 66 big-endian bytes."""
    [
        0x00u8, 0x51u8, 0x95u8, 0x3Eu8, 0xB9u8, 0x61u8, 0x8Eu8, 0x1Cu8,
        0x9Au8, 0x1Fu8, 0x92u8, 0x9Au8, 0x21u8, 0xA0u8, 0xB6u8, 0x85u8,
        0x40u8, 0xEEu8, 0xA2u8, 0xDAu8, 0x72u8, 0x5Bu8, 0x99u8, 0xB3u8,
        0x15u8, 0xF3u8, 0xB8u8, 0xB4u8, 0x89u8, 0x91u8, 0x8Eu8, 0xF1u8,
        0x09u8, 0xE1u8, 0x56u8, 0x19u8, 0x39u8, 0x51u8, 0xECu8, 0x7Eu8,
        0x93u8, 0x7Bu8, 0x16u8, 0x52u8, 0xC0u8, 0xBDu8, 0x3Bu8, 0xB1u8,
        0xBFu8, 0x07u8, 0x35u8, 0x73u8, 0xDFu8, 0x88u8, 0x3Du8, 0x2Cu8,
        0x34u8, 0xF1u8, 0xEFu8, 0x45u8, 0x1Fu8, 0xD4u8, 0x6Bu8, 0x50u8,
        0x3Fu8, 0x00u8
    ]

fn _p521_gx_bytes() -> [u8]:
    """P-521 generator x-coordinate as 66 big-endian bytes."""
    [
        0x00u8, 0xC6u8, 0x85u8, 0x8Eu8, 0x06u8, 0xB7u8, 0x04u8, 0x04u8,
        0xE9u8, 0xCDu8, 0x9Eu8, 0x3Eu8, 0xCBu8, 0x66u8, 0x23u8, 0x95u8,
