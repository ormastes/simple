"""
SOSIX I/O compatibility helpers.

Re-exports the canonical SOSIX I/O state constants under the shorter legacy
names used by callers that pre-date the io_state split.
"""

use os.sosix.io_state.{
    SOSIX_ASYNC_FREE,
    SOSIX_ASYNC_PENDING,
    SOSIX_ASYNC_COMPLETE,
    SOSIX_ASYNC_ERROR,
    SOSIX_IO_BACKEND_INVALID,
    SOSIX_IO_BACKEND_SERIAL,
    SOSIX_IO_BACKEND_VFS,
    SOSIX_MAX_ASYNC_REQUESTS,
    sosix_io_init,
    sosix_async_alloc_request,
    sosix_async_free_request,
    sosix_async_is_complete,
    sosix_async_get_result
}

# Shorter aliases for legacy callers.
val IO_COMPAT_FREE: u8 = SOSIX_ASYNC_FREE
val IO_COMPAT_PENDING: u8 = SOSIX_ASYNC_PENDING
val IO_COMPAT_COMPLETE: u8 = SOSIX_ASYNC_COMPLETE
val IO_COMPAT_ERROR: u8 = SOSIX_ASYNC_ERROR
val IO_COMPAT_MAX_REQUESTS: u64 = SOSIX_MAX_ASYNC_REQUESTS

fn io_compat_init():
    """Initialise SOSIX I/O state for legacy callers."""
    sosix_io_init()

fn io_compat_alloc() -> u64:
    """Allocate a request slot via the canonical SOSIX API."""
    sosix_async_alloc_request()

fn io_compat_free(req_id: u64):
    """Free a request slot via the canonical SOSIX API."""
    sosix_async_free_request(req_id)

fn io_compat_is_complete(req_id: u64) -> bool:
    """Check completion via the canonical SOSIX API."""
    sosix_async_is_complete(req_id)

fn io_compat_result(req_id: u64) -> i64:
    """Retrieve the result via the canonical SOSIX API."""
    sosix_async_get_result(req_id)
