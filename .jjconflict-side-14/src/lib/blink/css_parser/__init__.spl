# Blink CSS parser — tokenizer stage.
#
# This package will eventually host the CSS parser proper (selector +
# declaration-block builder) and cascade/matching logic. Today it exports
# only the CSS Syntax Level 3 tokenizer, which the parser will call as
# its first pipeline stage.
#
# Consumer contract:
#   - `tokenize_css(source: String) -> [CssToken]`
#       Returns a token list terminated by a single CssToken(Eof, ...).
#       Whitespace is skipped; comments are emitted as Comment tokens.
#
# Exports mirror the Skia `sksl` package layout for consistency across
# Blink/Skia frontends.

# tokenizer.spl re-exports
export CssTokenKind, CssToken
export tokenize_css
