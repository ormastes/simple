# STM32U5 Target Definition
# Wraps ArmCortexMTarget with STM32U585-specific configuration.
# MCU: STM32U585, Cortex-M33, 160 MHz, 2 MB flash, 786 KB SRAM.

use std.nogc_sync_mut.debug.remote.target.arm_cortex_m.ArmCortexMTarget

class Stm32U5Target:
    core: ArmCortexMTarget
    probe_cfg: text
    openocd_cfg: text
    gdb_port: i32

impl Stm32U5Target:
    static fn default() -> Stm32U5Target:
        Stm32U5Target(
            core: ArmCortexMTarget.cortex_m33(),
            probe_cfg: "interface/stlink.cfg",
            openocd_cfg: "target/stm32u5x.cfg",
            gdb_port: 27333
        )

    static fn with_probe(p_cfg: text) -> Stm32U5Target:
        Stm32U5Target(
            core: ArmCortexMTarget.cortex_m33(),
            probe_cfg: p_cfg,
            openocd_cfg: "target/stm32u5x.cfg",
            gdb_port: 27333
        )

    fn name() -> text:
        "STM32U5 (Cortex-M33)"

    fn core_name() -> text:
        self.core.core_name()

    fn register_count() -> i32:
        self.core.register_count()

    fn register_name(index: i32) -> text:
        self.core.register_name(index)

    fn register_index(n: text) -> i32:
        self.core.register_index(n)

    fn hw_breakpoint_count() -> i32:
        self.core.hw_breakpoint_count()

    fn hw_watchpoint_count() -> i32:
        self.core.hw_watchpoint_count()

    fn breakpoint_instruction() -> [i32]:
        self.core.breakpoint_instruction()

    fn word_size() -> i32:
        self.core.word_size()

    # Flash base address for STM32U585
    fn flash_base() -> i64:
        val _ = self.core.word_size()
        0x08000000

    # SRAM base address
    fn sram_base() -> i64:
        val _ = self.core.word_size()
        0x20000000

    # SRAM size in bytes (786 KB total for U585)
    fn sram_size() -> i64:
        val _ = self.core.word_size()
        786432
