# ============================================================================
# Spec: RISC-V CSR Module — Address Registry, Bitfield Helpers, Cause Codes
# ============================================================================

use std.nogc_async_mut_noalloc.baremetal.riscv.csr.{
    CSR_MSTATUS, CSR_MISA, CSR_MEDELEG, CSR_MIDELEG,
    CSR_MIE, CSR_MTVEC, CSR_MCOUNTEREN,
    CSR_MSCRATCH, CSR_MEPC, CSR_MCAUSE, CSR_MTVAL, CSR_MIP,
    CSR_MHARTID, CSR_MVENDORID, CSR_MARCHID, CSR_MIMPID,
    CSR_SSTATUS, CSR_SIE, CSR_STVEC, CSR_SCOUNTEREN,
    CSR_SSCRATCH, CSR_SEPC, CSR_SCAUSE, CSR_STVAL, CSR_SIP, CSR_SATP,
    CSR_PMPCFG0, CSR_PMPADDR0,
    CSR_CYCLE, CSR_TIME, CSR_INSTRET,
    CSR_MCYCLE, CSR_MINSTRET,
    MSTATUS_MIE, MSTATUS_MPIE, MSTATUS_SIE, MSTATUS_SPIE,
    MSTATUS_MPP_MASK, MSTATUS_MPP_U, MSTATUS_MPP_S, MSTATUS_MPP_M,
    MSTATUS_SPP, MSTATUS_MPRV, MSTATUS_SUM, MSTATUS_MXR,
    MIE_SSIE, MIE_MSIE, MIE_STIE, MIE_MTIE, MIE_SEIE, MIE_MEIE,
    MTVEC_MODE_DIRECT, MTVEC_MODE_VECTORED,
    CAUSE_INTERRUPT_BIT,
    CAUSE_M_SOFTWARE_INTERRUPT, CAUSE_M_TIMER_INTERRUPT, CAUSE_M_EXTERNAL_INTERRUPT,
    CAUSE_S_SOFTWARE_INTERRUPT, CAUSE_S_TIMER_INTERRUPT, CAUSE_S_EXTERNAL_INTERRUPT,
    CAUSE_INSN_MISALIGNED, CAUSE_ILLEGAL_INSN, CAUSE_BREAKPOINT,
    CAUSE_ECALL_U, CAUSE_ECALL_S, CAUSE_ECALL_M,
    CAUSE_INSN_PAGE_FAULT, CAUSE_LOAD_PAGE_FAULT, CAUSE_STORE_PAGE_FAULT,
    csr_read, csr_write, csr_set_bits, csr_clear_bits, csr_read_write,
    mstatus_get_mpp, mstatus_set_mpp, mstatus_get_spp, mstatus_set_spp,
    mtvec_encode, mtvec_base, mtvec_mode,
    mcause_is_interrupt, mcause_code,
    csr_is_readonly, csr_privilege_level
}

describe "CSR Machine Trap Setup Addresses":
    it "has correct M-mode trap setup addresses":
        expect CSR_MSTATUS == 0x300
        expect CSR_MISA == 0x301
        expect CSR_MEDELEG == 0x302
        expect CSR_MIDELEG == 0x303
        expect CSR_MIE == 0x304
        expect CSR_MTVEC == 0x305
        expect CSR_MCOUNTEREN == 0x306

    it "has correct M-mode trap handling addresses":
        expect CSR_MSCRATCH == 0x340
        expect CSR_MEPC == 0x341
        expect CSR_MCAUSE == 0x342
        expect CSR_MTVAL == 0x343
        expect CSR_MIP == 0x344

    it "has correct M-mode information addresses":
        expect CSR_MVENDORID == 0xF11
        expect CSR_MARCHID == 0xF12
        expect CSR_MIMPID == 0xF13
        expect CSR_MHARTID == 0xF14

describe "CSR Supervisor Addresses":
    it "has correct S-mode trap setup addresses":
        expect CSR_SSTATUS == 0x100
        expect CSR_SIE == 0x104
        expect CSR_STVEC == 0x105
        expect CSR_SCOUNTEREN == 0x106

    it "has correct S-mode trap handling addresses":
        expect CSR_SSCRATCH == 0x140
        expect CSR_SEPC == 0x141
        expect CSR_SCAUSE == 0x142
        expect CSR_STVAL == 0x143
        expect CSR_SIP == 0x144

    it "has correct SATP address":
        expect CSR_SATP == 0x180

describe "CSR PMP Addresses":
    it "has correct PMP config base":
        expect CSR_PMPCFG0 == 0x3A0

    it "has correct PMP address base":
        expect CSR_PMPADDR0 == 0x3B0

describe "CSR User and Counter Addresses":
    it "has correct user counter addresses":
        expect CSR_CYCLE == 0xC00
        expect CSR_TIME == 0xC01
        expect CSR_INSTRET == 0xC02

    it "has correct machine counter addresses":
        expect CSR_MCYCLE == 0xB00
        expect CSR_MINSTRET == 0xB02

describe "MSTATUS Bit Fields":
    it "SIE is bit 1":
        expect MSTATUS_SIE == 2

    it "MIE is bit 3":
        expect MSTATUS_MIE == 8

    it "SPIE is bit 5":
        expect MSTATUS_SPIE == 32

    it "MPIE is bit 7":
        expect MSTATUS_MPIE == 128

    it "SPP is bit 8":
        expect MSTATUS_SPP == 256

    it "MPP mask covers bits 12 and 11":
        expect MSTATUS_MPP_MASK == 0x1800

    it "MPP values encode privilege levels":
        expect MSTATUS_MPP_U == 0
        expect MSTATUS_MPP_S == 0x800
        expect MSTATUS_MPP_M == 0x1800

    it "MPRV is bit 17":
        expect MSTATUS_MPRV == 0x20000

    it "SUM is bit 18":
        expect MSTATUS_SUM == 0x40000

    it "MXR is bit 19":
        expect MSTATUS_MXR == 0x80000

describe "MIE Bit Fields":
    it "SSIE is bit 1":
        expect MIE_SSIE == 2

    it "MSIE is bit 3":
        expect MIE_MSIE == 8

    it "STIE is bit 5":
        expect MIE_STIE == 32

    it "MTIE is bit 7":
        expect MIE_MTIE == 128

    it "SEIE is bit 9":
        expect MIE_SEIE == 512

    it "MEIE is bit 11":
        expect MIE_MEIE == 2048

describe "MTVEC Mode Constants":
    it "Direct is 0":
        expect MTVEC_MODE_DIRECT == 0

    it "Vectored is 1":
        expect MTVEC_MODE_VECTORED == 1

describe "Exception Cause Codes":
    it "has correct synchronous exception codes":
        expect CAUSE_INSN_MISALIGNED == 0
        expect CAUSE_ILLEGAL_INSN == 2
        expect CAUSE_BREAKPOINT == 3
        expect CAUSE_ECALL_U == 8
        expect CAUSE_ECALL_S == 9
        expect CAUSE_ECALL_M == 11

    it "has correct page fault codes":
        expect CAUSE_INSN_PAGE_FAULT == 12
        expect CAUSE_LOAD_PAGE_FAULT == 13
        expect CAUSE_STORE_PAGE_FAULT == 15

    it "interrupt causes have MSB set":
        expect (CAUSE_M_SOFTWARE_INTERRUPT & CAUSE_INTERRUPT_BIT) != 0
        expect (CAUSE_M_TIMER_INTERRUPT & CAUSE_INTERRUPT_BIT) != 0
        expect (CAUSE_M_EXTERNAL_INTERRUPT & CAUSE_INTERRUPT_BIT) != 0
        expect (CAUSE_S_SOFTWARE_INTERRUPT & CAUSE_INTERRUPT_BIT) != 0
        expect (CAUSE_S_TIMER_INTERRUPT & CAUSE_INTERRUPT_BIT) != 0
        expect (CAUSE_S_EXTERNAL_INTERRUPT & CAUSE_INTERRUPT_BIT) != 0

describe "MSTATUS Bitfield Helpers":
    it "extracts MPP from mstatus":
        val status_m = 0x1800  # MPP = Machine
        expect mstatus_get_mpp(status_m) == 3

        val status_s = 0x0800  # MPP = Supervisor
        expect mstatus_get_mpp(status_s) == 1

        val status_u = 0x0000  # MPP = User
        expect mstatus_get_mpp(status_u) == 0

    it "sets MPP in mstatus":
        val result = mstatus_set_mpp(0, 3)
        expect mstatus_get_mpp(result) == 3

        val result2 = mstatus_set_mpp(0x1800, 1)
        expect mstatus_get_mpp(result2) == 1

    it "extracts SPP from mstatus":
        val status = 0x100  # SPP = 1 (Supervisor)
        expect mstatus_get_spp(status) == 1

        expect mstatus_get_spp(0) == 0

    it "sets SPP in mstatus":
        val result = mstatus_set_spp(0, 1)
        expect mstatus_get_spp(result) == 1

describe "MTVEC Helpers":
    it "encodes base and mode":
        val mtvec = mtvec_encode(0x80000100, MTVEC_MODE_VECTORED)
        expect mtvec_base(mtvec) == 0x80000100
        expect mtvec_mode(mtvec) == 1

    it "clears mode bits from base":
        val mtvec = mtvec_encode(0x80000100, MTVEC_MODE_DIRECT)
        expect mtvec_base(mtvec) == 0x80000100
        expect mtvec_mode(mtvec) == 0

describe "MCAUSE Helpers":
    it "detects interrupts":
        expect mcause_is_interrupt(CAUSE_M_TIMER_INTERRUPT) == true
        expect mcause_is_interrupt(CAUSE_ILLEGAL_INSN) == false

    it "extracts cause code":
        expect mcause_code(CAUSE_M_TIMER_INTERRUPT) == 7
        expect mcause_code(CAUSE_M_EXTERNAL_INTERRUPT) == 11
        expect mcause_code(CAUSE_ILLEGAL_INSN) == 2

describe "CSR Address Classification":
    it "detects read-only CSRs":
        expect csr_is_readonly(CSR_MVENDORID) == true
        expect csr_is_readonly(CSR_MHARTID) == true
        expect csr_is_readonly(CSR_CYCLE) == true

    it "detects read-write CSRs":
        expect csr_is_readonly(CSR_MSTATUS) == false
        expect csr_is_readonly(CSR_MEPC) == false
        expect csr_is_readonly(CSR_SATP) == false

    it "extracts privilege level":
        expect csr_privilege_level(CSR_MSTATUS) == 3   # Machine (0x300 bits 9:8 = 11)
        expect csr_privilege_level(CSR_SSTATUS) == 1   # Supervisor (0x100 bits 9:8 = 01)
        expect csr_privilege_level(CSR_CYCLE) == 0     # User (0xC00 bits 9:8 = 00)

describe "CSR Read Write Stubs":
    it "read returns zero in interpreter mode":
        expect csr_read(CSR_MSTATUS) == 0

    it "read_write returns zero in interpreter mode":
        expect csr_read_write(CSR_MSTATUS, 0xFF) == 0
