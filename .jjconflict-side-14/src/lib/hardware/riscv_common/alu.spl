# ============================================================================
# RISC-V ALU Operations
# ============================================================================
#
# Defines ALU operation codes and a pure-function evaluator that works for
# both RV32I and RV64I.  The caller supplies an XlenConfig so that results
# are truncated/sign-extended to the correct width.
# ============================================================================

use std.hardware.riscv_common.xlen.XlenConfig

# ============================================================================
# ALU operation codes
# ============================================================================

val ALU_ADD: i64  = 0
val ALU_SUB: i64  = 1
val ALU_SLL: i64  = 2
val ALU_SLT: i64  = 3
val ALU_SLTU: i64 = 4
val ALU_XOR: i64  = 5
val ALU_SRL: i64  = 6
val ALU_SRA: i64  = 7
val ALU_OR: i64   = 8
val ALU_AND: i64  = 9

# RV64I word-width ops (operate on low 32 bits, sign-extend result)
val ALU_ADDW: i64 = 10
val ALU_SUBW: i64 = 11
val ALU_SLLW: i64 = 12
val ALU_SRLW: i64 = 13
val ALU_SRAW: i64 = 14

# ============================================================================
# ALU operation name for debug / trace
# ============================================================================

fn alu_op_name(op: i64) -> text:
    """Return a human-readable name for an ALU operation code."""
    if op == ALU_ADD:  return "ADD"
    if op == ALU_SUB:  return "SUB"
    if op == ALU_SLL:  return "SLL"
    if op == ALU_SLT:  return "SLT"
    if op == ALU_SLTU: return "SLTU"
    if op == ALU_XOR:  return "XOR"
    if op == ALU_SRL:  return "SRL"
    if op == ALU_SRA:  return "SRA"
    if op == ALU_OR:   return "OR"
    if op == ALU_AND:  return "AND"
    if op == ALU_ADDW: return "ADDW"
    if op == ALU_SUBW: return "SUBW"
    if op == ALU_SLLW: return "SLLW"
    if op == ALU_SRLW: return "SRLW"
    if op == ALU_SRAW: return "SRAW"
    return "???"

# ============================================================================
# Shift amount mask — 5 bits for RV32, 6 bits for RV64
# ============================================================================

fn shift_mask(cfg: XlenConfig) -> i64:
    """Return the shift-amount mask (0x1F for RV32, 0x3F for RV64)."""
    if cfg.is_rv32():
        0x1F
    else:
        0x3F

# ============================================================================
# ALU evaluate — pure function, no side effects
# ============================================================================

fn alu_eval(cfg: XlenConfig, op: i64, a: i64, b: i64) -> i64:
    """Evaluate an ALU operation on operands a and b, returning the result
    truncated to XLEN bits."""

    var result: i64 = 0

    if op == ALU_ADD:
        result = a + b

    else if op == ALU_SUB:
        result = a - b

    else if op == ALU_SLL:
        val shamt = b & shift_mask(cfg)
        result = a << shamt

    else if op == ALU_SLT:
        # Signed comparison — both operands are sign-extended XLEN values
        if a < b:
            result = 1
        else:
            result = 0

    else if op == ALU_SLTU:
        # Unsigned comparison — mask to XLEN, then compare
        val ua = cfg.truncate(a)
        val ub = cfg.truncate(b)
        # For unsigned comparison on signed i64, convert via mask
        if cfg.is_rv32():
            val ua32 = ua & 0xFFFFFFFF
            val ub32 = ub & 0xFFFFFFFF
            if ua32 < ub32:
                result = 1
            else:
                result = 0
        else:
            # Full 64-bit unsigned comparison trick:
            # XOR sign bits then compare
            val sign_flip = 0x8000000000000000
            val flipped_a = a ^ sign_flip
            val flipped_b = b ^ sign_flip
            if flipped_a < flipped_b:
                result = 1
            else:
                result = 0

    else if op == ALU_XOR:
        result = a ^ b

    else if op == ALU_SRL:
        val shamt = b & shift_mask(cfg)
        val masked_a = cfg.truncate(a)
        result = masked_a >> shamt

    else if op == ALU_SRA:
        val shamt = b & shift_mask(cfg)
        # Arithmetic right shift — sign-extend first
        if cfg.is_rv32():
            val sign_extended = cfg.sign_extend_32(a)
            result = sign_extended >> shamt
        else:
            result = a >> shamt

    else if op == ALU_OR:
        result = a | b

    else if op == ALU_AND:
        result = a & b

    # RV64I word-width operations (result is sign-extended 32-bit)
    else if op == ALU_ADDW:
        val r32 = (a + b) & 0xFFFFFFFF
        result = cfg.sign_extend_32(r32)

    else if op == ALU_SUBW:
        val r32 = (a - b) & 0xFFFFFFFF
        result = cfg.sign_extend_32(r32)

    else if op == ALU_SLLW:
        val shamt = b & 0x1F
        val r32 = (a << shamt) & 0xFFFFFFFF
        result = cfg.sign_extend_32(r32)

    else if op == ALU_SRLW:
        val shamt = b & 0x1F
        val r32 = (a & 0xFFFFFFFF) >> shamt
        result = cfg.sign_extend_32(r32)

    else if op == ALU_SRAW:
        val shamt = b & 0x1F
        val sign_extended = cfg.sign_extend_32(a)
        val r32 = (sign_extended >> shamt) & 0xFFFFFFFF
        result = cfg.sign_extend_32(r32)

    cfg.truncate(result)
