# Primitive-API Lint (arena AST) — reliable-mode R2
#
# Flags bare numeric/bool primitive types (i8..i64, u8..u64, f32, f64, bool) used as
# function parameter or return types, on ALL visibility levels (internal + public). The
# higher-fidelity sibling `primitive_api.spl` operates on a typed-Node AST the live lint
# pipeline never builds; this one works on the arena AST that `module_get_decls()` yields,
# mirroring `argument_count.spl`, so it can run in the query/LSP/build path.
#
# Exempts pure-math helpers where every parameter and the return share one primitive type
# (e.g. `fn abs(x: f64) -> f64`, `fn max(a: i64, b: i64) -> i64`).
#
# Emitted code: `primitive_api` (tier-governed by the strictness profile).

use compiler.core.ast.{decl_tag, decl_name, decl_get_param_names, decl_get_param_types, decl_get_ret_type, DECL_FN, type_tag_name, TYPE_NAMED_BASE}

# Resolve a type tag to a name, safely. Named/custom types (tag >= TYPE_NAMED_BASE=1000)
# are never bare primitives, and `type_tag_name` indexes the named-type table for them —
# which can fault on a minimal standalone parse — so short-circuit those to "".
fn _safe_type_name(tag: i64) -> text:
    if tag >= TYPE_NAMED_BASE:
        return ""
    type_tag_name(tag)

struct PrimApiWarning:
    fn_name: text
    target: text       # parameter name, or "return"
    type_name: text

    fn message() -> text:
        if self.target == "return":
            "bare primitive '{self.type_name}' return type of '{self.fn_name}' — wrap in a domain type"
        else:
            "bare primitive '{self.type_name}' in parameter '{self.target}' of '{self.fn_name}' — wrap in a domain type"

fn _is_bare_primitive_type_name(n: text) -> bool:
    (n == "i8" or n == "i16" or n == "i32" or n == "i64"
     or n == "u8" or n == "u16" or n == "u32" or n == "u64"
     or n == "f32" or n == "f64" or n == "bool")

fn check_primitive_api_arena(decl_indices: [i64]) -> [PrimApiWarning]:
    var warnings: [PrimApiWarning] = []
    for idx in decl_indices:
        if decl_tag[idx] != DECL_FN:
            continue
        val fname = decl_name[idx]
        val ptypes = decl_get_param_types(idx)
        val pnames = decl_get_param_names(idx)
        val rtype = decl_get_ret_type(idx)
        val rtname = _safe_type_name(rtype)
        # Pure-math exemption: every param and the return are the same bare primitive.
        var all_same_prim = _is_bare_primitive_type_name(rtname)
        var k = 0
        while k < ptypes.len():
            val tn = _safe_type_name(ptypes[k])
            if tn != rtname or not _is_bare_primitive_type_name(tn):
                all_same_prim = false
            k = k + 1
        if all_same_prim and ptypes.len() > 0:
            continue
        var pi = 0
        while pi < ptypes.len():
            val tname = _safe_type_name(ptypes[pi])
            var pname = "?"
            if pi < pnames.len():
                pname = pnames[pi]
            if pname != "self" and _is_bare_primitive_type_name(tname):
                warnings.push(PrimApiWarning(fn_name: fname, target: pname, type_name: tname))
            pi = pi + 1
        if _is_bare_primitive_type_name(rtname):
            warnings.push(PrimApiWarning(fn_name: fname, target: "return", type_name: rtname))
    warnings

export PrimApiWarning, check_primitive_api_arena