# This package (renamed from `driver/` to avoid colliding with the sibling
# `driver.spl` file, which shadowed it in the interpreter — see
# doc/08_tracking/bug/selfhost_bootstrap_unresolved_symbols_2026-06-24.md).
# It owns the incremental/parallel build submodules only; CompilerDriver and the
# driver entry fns live in driver.spl (reachable now as compiler.driver.driver).
export use compiler.common.driver_core_types.{CompileMode, CompileOptions, CompileResult, OutputFormat}

# Re-exported from incremental.spl
export use .incremental.{FileFingerprint, DependencyEntry, BuildCache, IncrementalCompiler, IncrChangeSet, ChangeKind}

# Re-exported from parallel.spl
export use .parallel.{ParallelBuildConfig, BuildUnit, BuildGraph, BuildResult, ParallelBuilder, BuildStats}
