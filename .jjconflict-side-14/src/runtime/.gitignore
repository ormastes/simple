# git-filter-branch rewrite artifacts
.git-rewrite/

# MCP config exceptions (keep plugin-internal configs)
!tools/claude-plugin/simple-mcp/.mcp.json
!tools/claude-plugin/marketplace/plugins/simple-mcp/.mcp.json

# MCP registry npm package artifacts
/tools/mcp-registry/node_modules/
/tools/mcp-registry/native/
/tools/mcp-registry/*.tgz

# Build artifacts (consolidated under build/)
/build/
.simple_eval_*.spl

# Local TRACE32 MCP native/debug artifacts
/artifacts/local/t32_mcp_*

# Platform symlinks and launchers (created by scripts/setup.sh, never tracked)
/bin/simple
/bin/simple.exe
/bin/release/simple
/bin/release/simple.exe
/bin/simple_mcp_server
/bin/simple_lsp_mcp_server
/bin/simple_lsp_server
/bin/t32_mcp_server
/bin/t32_lsp_mcp_server

# Bootstrap compiler (Rust-built binary, too large for git)
/bin/bootstrap/compiler-rust/simple
/bin/simple-stub
/bootstrap_freebsd/

# Mold linker (auto-downloaded by simple mold-setup)
/bin/mold/

# QEMU resources (downloads and build artifacts)
/resources/qemu/

# Object files and native libraries
*.o
*.a
*.so
*.dylib
*.dll

# Rust build artifacts (all under src/compiler_rust/target/ or build/)
/rust/
**/target/
**/*.rs.bk
*.pdb

# Rust compiler binary output (large binaries)
src/compiler_rust/bin/

# Cargo.lock is typically committed for binaries, uncomment to ignore
# Cargo.lock

# IDE and editor files
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/

# OS-specific files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Python bytecode
__pycache__/
*.pyc

# Cache files
**/*cache*.json
**/simple_watch_cache.json

# Claude Code local settings and worktrees
.claude/settings.local.json
.claude/worktrees/

# Local config overrides (not shared)
*.local.sdn

# jscpd report output
/report/

# Temporary files
/tmp/
.fileio_temp*/
*.tmp
*.temp
*.bak
*.backup
*.sdn.lock
*.deleted
*.bak2
*.bak3

# Build directories (cmake/ninja output)
build/cross-*/

# Windows reserved device names
NUL
# Large runtime binaries removed - use bin/release/simple only

# Experimental run data now in build/experiments/

# Debug files
*.log
/debug/
!src/app/debug/

# Generated SMF files (Simple Module Format)
*.smf
.simple/
# .simple logs now in build/logs/

# Obsolete test formats (keep only .spl)
test/**/*.py
test/**/*.sdt

# Coverage output (now in build/coverage/)
lcov.info
*.profraw
*.profdata
htmlcov/

# Node.js (for jscpd)
node_modules/
src/app/vscode_extension/node_modules/
src/app/vscode_extension/.vscode-test/
*.vsix

# Backup and original files
*.orig

# Lean 4 build artifacts
src/verification/**/.lake/
src/verification/**/lake-manifest.json
**/.lake/

# Jujutsu version control
.jj/

# Release binaries — platform dirs contain large native binaries
# Keep README.md only; MCP launcher scripts are auto-generated by setup.sh
bin/release/*
!bin/release/README.md
bin/srt2

# Legacy directories removed from tracking
bin/bootstrap/native/
bin/alt_release/
bin/freebsd/
*.spk

# Bootstrap stage binaries (build/bootstrap/stage{1,2,3}/<triple>/...)
build/bootstrap/

# Stale flat-layout stage binaries
bin/simple_bootstrap
bin/simple_stage2
bin/simple_stage2.exe
bin/simple_stage3
bin/simple_native
bin/simple_native.exe
bin/simple_stage4
bin/simple_stage4.exe
bin/simple_mac
bin/libflush_stdout.so
bin/libunbuf.so

# Package build artifacts
package_tmp/
*.tar.gz
*.zip
*.deb

# Stale root dirs (runtime bug artifacts, old build output)
/nil/
/bootstrap/
/pkg-deb/

# Test runner artifact directories (belong in build/test-artifacts/, not root)
# Generated by a bug in artifact_dir_for_test() when given absolute paths.
/unit/
/integration/
/system/
/feature/
/app/
/lib/
/js/
/shared/
/specs/
/perf/
/fuzz/
/fixtures/
/qemu/

# Release artifacts now in build/release/

# Play session artifacts (generated by simple play, never tracked)
doc/08_tracking/test/play/
/tmp/simple-play/

# Auto-generated test checkpoints
tmp/.simple-test-checkpoint.sdn
.simple-test-checkpoint.sdn
bin/simple.bak.linux
tools/tauri-shell/src-tauri/target/
tools/electron-shell/node_modules/
tools/tauri-shell/node_modules/
tools/tauri-shell/dist/

# FPGA generated binaries (large, regenerate via scripts)
examples/09_embedded/fpga_riscv/test/test_c_runtime.pkg.vhd

