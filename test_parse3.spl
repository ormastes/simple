use common.ui.parse.sdn.{parse_to_flat}

extern fn rt_file_read_text(path: text) -> text

fn unwrap_opt(v: any) -> any:
    match v:
        case Some(s):
            return s
        case _:
            return v

fn main():
    val raw = rt_file_read_text("examples/ui/demo.ui.sdn")
    val source = unwrap_opt(raw)
    print "Calling parse_to_flat..."
    val flat = parse_to_flat(source)
    print "Done! Keys: {flat.len()}"
