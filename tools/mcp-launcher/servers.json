{
  "servers": {
    "simple-mcp": {
      "entry": "src/app/mcp/main.spl",
      "simpleLib": "src",
      "compile": false,
      "nativeBinary": null,
      "env": {
        "SIMPLE_LOG": "error",
        "RUST_LOG": "error"
      },
      "extraEnv": {}
    },
    "simple-lsp-mcp": {
      "entry": "src/app/simple_lsp_mcp/main.spl",
      "simpleLib": "src",
      "compile": false,
      "nativeBinary": null,
      "env": {
        "SIMPLE_LOG": "error",
        "RUST_LOG": "error"
      },
      "extraEnv": {
        "SIMPLE_BINARY": "${RUNTIME}"
      }
    },
    "t32-mcp": {
      "entry": "examples/10_tooling/trace32_tools/t32_mcp/main.spl",
      "simpleLib": "examples/10_tooling/trace32_tools",
      "compile": {
        "enabled": true,
        "cacheDir": ".simple/cache/t32_mcp",
        "variants": {
          "full": "examples/10_tooling/trace32_tools/t32_mcp/main.spl",
          "cold": "examples/10_tooling/trace32_tools/t32_mcp/frontend_cold.spl"
        },
        "defaultVariant": "full",
        "minCacheBytes": 512,
        "timeoutMs": 30000
      },
      "nativeBinary": "bin/release/t32_mcp_native",
      "env": {
        "SIMPLE_LOG": "error",
        "SIMPLE_TIMEOUT_SECONDS": "86400",
        "SIMPLE_MEMORY_LIMIT_MB": "100"
      },
      "extraEnv": {}
    },
    "t32-lsp-mcp": {
      "_migrateNote": "TODO: switch to src/app/t32_lsp_mcp/main.spl once cmm_lsp symlink is in src/lib/",
      "entry": "examples/10_tooling/trace32_tools/t32_lsp_mcp/claude_frontend.spl",
      "simpleLib": "examples/10_tooling/trace32_tools",
      "compile": false,
      "nativeBinary": null,
      "env": {
        "SIMPLE_LOG": "error",
        "SIMPLE_TIMEOUT_SECONDS": "86400",
        "SIMPLE_MEMORY_LIMIT_MB": "512"
      },
      "extraEnv": {
        "T32_LSP_MCP_TOOL_RUNNER": "examples/10_tooling/trace32_tools/t32_lsp_mcp/tool_runner.spl",
        "T32_LSP_MCP_TOOL_RUNNER_BIN": "${REPO_ROOT}/bin/release/t32_lsp_mcp_tool_runner",
        "T32_LSP_MCP_TOOL_DAEMON": "examples/10_tooling/trace32_tools/cmm_lsp/mcp_daemon.spl",
        "T32_LSP_MCP_TOOL_DAEMON_DIR": "/tmp/t32_lsp_mcp_shared_${WORKSPACE_SUFFIX}"
      }
    }
  }
}
