#!/usr/bin/env bash
# mail — Shell-based email client (IMAP/SMTP via curl)
# Mirrors the gh/jira CLI interface pattern.
#
# Supports: Gmail, Outlook/365, Yahoo, ProtonMail (Bridge), Fastmail, any IMAP/SMTP
#
# CORE COMMANDS
#   auth       Configure email accounts
#   inbox      List inbox messages
#   read <uid> Read a message
#   send       Compose and send
#   reply      Reply to a message
#   forward    Forward a message
#   search     Search messages
#
# ADDITIONAL COMMANDS
#   folder     Manage folders/labels
#   star       Star/flag a message
#   archive    Archive a message
#   delete     Delete a message
#   move       Move to folder
#   draft      Draft management
#   config     Manage settings

set -euo pipefail

VERSION="0.1.0"

# Resolve script directory (follow symlinks)
SELF="$0"
while [ -L "$SELF" ]; do
  DIR="$(cd "$(dirname "$SELF")" && pwd)"
  SELF="$(readlink "$SELF")"
  case "$SELF" in /*) ;; *) SELF="${DIR}/${SELF}" ;; esac
done
BIN_DIR="$(cd "$(dirname "$SELF")" && pwd)"
LIB_DIR="$(cd "${BIN_DIR}/../lib" && pwd)"

# Global account override (set by --account flag)
MAIL_ACCOUNT=""

# Source library modules
. "${LIB_DIR}/config.shs"
. "${LIB_DIR}/format.shs"
. "${LIB_DIR}/imap.shs"
. "${LIB_DIR}/smtp.shs"
. "${LIB_DIR}/auth.shs"
. "${LIB_DIR}/inbox.shs"
. "${LIB_DIR}/send.shs"
. "${LIB_DIR}/folder.shs"
. "${LIB_DIR}/draft.shs"

check_deps() {
  for cmd in curl jq base64; do
    if ! command -v "$cmd" >/dev/null 2>&1; then
      echo "error: '${cmd}' is required but not installed." >&2
      echo "  Install: brew install ${cmd}" >&2
      exit 1
    fi
  done
  # Verify curl has IMAP/SMTP support
  if ! curl --version | grep -q 'imaps'; then
    echo "error: curl does not support IMAP. Rebuild curl with IMAP support." >&2
    exit 1
  fi
}

cmd_config() {
  local subcmd="${1:-}"
  shift 2>/dev/null || true

  case "$subcmd" in
    set)
      if [ $# -lt 2 ]; then
        echo "Usage: mail config set <key> <value>" >&2; return 1
      fi
      mail_config_init
      local tmp="${MAIL_CONFIG_FILE}.tmp"
      jq --arg k "$1" --arg v "$2" '.[$k] = $v' "$MAIL_CONFIG_FILE" > "$tmp" && mv "$tmp" "$MAIL_CONFIG_FILE"
      chmod 600 "$MAIL_CONFIG_FILE"
      echo "✓ Set ${1}"
      ;;
    get)
      [ $# -lt 1 ] && { echo "Usage: mail config get <key>" >&2; return 1; }
      jq -r ".${1} // empty" "$MAIL_CONFIG_FILE" 2>/dev/null
      ;;
    list)
      mail_config_init
      jq '.' "$MAIL_CONFIG_FILE" 2>/dev/null
      ;;
    *)
      echo "Manage mail-cli configuration"
      echo ""
      echo "COMMANDS"
      echo "  set <key> <value>   Set a config value"
      echo "  get <key>           Get a config value"
      echo "  list                List all config"
      ;;
  esac
}

cmd_version() {
  echo "mail-cli version ${VERSION} (Simple Language Project)"
  echo "  Config: ${MAIL_CONFIG_FILE}"
  local accounts
  accounts=$(mail_config_list_accounts 2>/dev/null)
  if [ -n "$accounts" ]; then
    local count
    count=$(echo "$accounts" | wc -l | tr -d ' ')
    echo "  Accounts: ${count} configured"
  else
    echo "  Accounts: none"
  fi
  echo ""
  echo "  Supported: Gmail, Outlook/365, Yahoo, ProtonMail, Fastmail, any IMAP/SMTP"
}

cmd_help() {
  echo "mail — Shell-based email client (IMAP/SMTP via curl)"
  echo "Mirrors the gh/jira CLI interface."
  echo ""
  echo "USAGE"
  echo "  mail <command> [flags]"
  echo ""
  echo "CORE COMMANDS"
  echo "  auth        Configure email accounts"
  echo "  inbox       List inbox messages"
  echo "  read <uid>  Read a message"
  echo "  send        Compose and send email"
  echo "  reply <uid> Reply to a message"
  echo "  forward     Forward a message"
  echo "  search      Search messages"
  echo ""
  echo "ADDITIONAL COMMANDS"
  echo "  folder      Manage folders/labels"
  echo "  star <uid>  Star/flag a message"
  echo "  archive     Archive a message"
  echo "  delete      Delete a message"
  echo "  move        Move to folder"
  echo "  draft       Draft management"
  echo "  config      Manage settings"
  echo "  version     Show version"
  echo "  help        Show this help"
  echo ""
  echo "GLOBAL FLAGS"
  echo "  --account NAME   Use specific account (overrides default)"
  echo "  --json           Output as JSON"
  echo ""
  echo "PROVIDERS"
  echo "  Gmail         App Password required (myaccount.google.com/apppasswords)"
  echo "  Outlook/365   Password or App Password"
  echo "  Yahoo         App Password"
  echo "  ProtonMail    Via ProtonMail Bridge (local proxy)"
  echo "  Fastmail      App Password"
  echo "  Other         Any standard IMAP/SMTP server"
  echo ""
  echo "EXAMPLES"
  echo "  mail auth login --provider gmail         # Setup Gmail"
  echo "  mail auth status                         # Check accounts"
  echo "  mail inbox                               # List inbox"
  echo "  mail inbox --unread                      # Unread only"
  echo "  mail read 123                            # Read message"
  echo "  mail send --to a@b.com --subject Hi      # Send email"
  echo "  mail reply 123 --body 'Thanks!'          # Reply"
  echo "  mail search 'pull request'               # Search"
  echo "  mail folder list                         # List folders"
  echo "  mail star 123                            # Star message"
  echo "  mail archive 123                         # Archive"
  echo "  mail move 123 'Work'                     # Move to folder"
  echo ""
  echo "CONFIG"
  echo "  Credentials: ~/.config/mail-cli/config.json"
}

main() {
  check_deps

  local command="${1:-help}"
  shift 2>/dev/null || true

  case "$command" in
    auth)    cmd_auth "$@" ;;
    inbox)   cmd_inbox "$@" ;;
    read)    cmd_read "$@" ;;
    send)    cmd_send "$@" ;;
    reply)   cmd_reply "$@" ;;
    forward) cmd_forward "$@" ;;
    search)  cmd_search "$@" ;;
    folder)  cmd_folder "$@" ;;
    star)    cmd_star "$@" ;;
    archive) cmd_archive "$@" ;;
    delete)  cmd_delete "$@" ;;
    move)    cmd_move "$@" ;;
    draft)   cmd_draft "$@" ;;
    config)  cmd_config "$@" ;;
    version|--version|-v) cmd_version ;;
    help|--help|-h)       cmd_help ;;
    *)
      echo "error: unknown command '${command}'" >&2
      echo "Run 'mail help' for usage." >&2
      exit 1
      ;;
  esac
}

main "$@"
