#!/bin/bash
# mail-cli SMTP operations via curl
# Depends on: config.shs (sourced by main entry point)

# Send email via SMTP
mail_smtp_send() {
  local from="$1" to="$2" message_file="$3"
  mail_resolve_account || return 1

  local smtp_url
  local -a extra_args=()

  case "$MAIL_ACCT_TLS" in
    none|plain)
      smtp_url="smtp://${MAIL_ACCT_SMTP_SERVER}:${MAIL_ACCT_SMTP_PORT}"
      ;;
    starttls)
      smtp_url="smtp://${MAIL_ACCT_SMTP_SERVER}:${MAIL_ACCT_SMTP_PORT}"
      extra_args+=(--ssl-reqd)
      ;;
    implicit|*)
      smtp_url="smtps://${MAIL_ACCT_SMTP_SERVER}:${MAIL_ACCT_SMTP_PORT}"
      ;;
  esac

  # Parse multiple recipients (comma-separated)
  local -a rcpt_args=()
  local IFS=','
  for addr in $to; do
    addr=$(echo "$addr" | xargs) # trim whitespace
    [ -n "$addr" ] && rcpt_args+=(--mail-rcpt "$addr")
  done
  IFS=' '

  curl -s --url "$smtp_url" \
    --user "${MAIL_ACCT_EMAIL}:${MAIL_ACCT_PASSWORD}" \
    --mail-from "$from" \
    "${rcpt_args[@]}" \
    --upload-file "$message_file" \
    "${extra_args[@]}" 2>/dev/null

  return $?
}
