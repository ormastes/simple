#!/bin/bash
# mail-cli auth subcommands
# Depends on: config.shs, imap.shs (sourced by main entry point)

cmd_auth() {
  local subcmd="${1:-}"
  shift 2>/dev/null || true

  case "$subcmd" in
    login)   cmd_auth_login "$@" ;;
    logout)  cmd_auth_logout "$@" ;;
    status)  cmd_auth_status "$@" ;;
    *)
      echo "Configure email accounts"
      echo ""
      echo "USAGE"
      echo "  mail auth <command> [flags]"
      echo ""
      echo "COMMANDS"
      echo "  login     Add or update an email account"
      echo "  logout    Remove an email account"
      echo "  status    Show account status"
      echo ""
      echo "FLAGS"
      echo "  --account NAME      Account name (default: 'default')"
      echo "  --provider PRESET   gmail, outlook, yahoo, protonmail, fastmail, other"
      ;;
  esac
}

cmd_auth_login() {
  local account_name="default" provider=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --account)  account_name="$2"; shift 2 ;;
      --provider) provider="$2"; shift 2 ;;
      *) shift ;;
    esac
  done

  mail_config_init

  # Select provider
  if [ -z "$provider" ]; then
    echo "? Email provider:"
    echo "  1) Gmail"
    echo "  2) Outlook / Office 365"
    echo "  3) Yahoo"
    echo "  4) ProtonMail (via Bridge)"
    echo "  5) Fastmail"
    echo "  6) Other (custom IMAP/SMTP)"
    printf "  > "
    read -r choice
    case "$choice" in
      1|gmail)      provider="gmail" ;;
      2|outlook)    provider="outlook" ;;
      3|yahoo)      provider="yahoo" ;;
      4|protonmail) provider="protonmail" ;;
      5|fastmail)   provider="fastmail" ;;
      6|other|*)    provider="other" ;;
    esac
  fi

  # Get email
  echo "? Email address:"
  printf "  > "
  read -r email

  echo "? Display name (optional):"
  printf "  > "
  read -r display_name
  [ -z "$display_name" ] && display_name="$email"

  # Resolve server settings from preset or ask
  local imap_server imap_port smtp_server smtp_port tls_mode

  if [ "$provider" != "other" ]; then
    imap_server=$(mail_preset "$provider" "imap")
    imap_port=$(mail_preset "$provider" "imap_port")
    smtp_server=$(mail_preset "$provider" "smtp")
    smtp_port=$(mail_preset "$provider" "smtp_port")
    tls_mode=$(mail_preset "$provider" "tls")
    echo "  Using ${provider} preset: IMAP=${imap_server}:${imap_port}, SMTP=${smtp_server}:${smtp_port}"
  else
    echo "? IMAP server:"
    printf "  > "
    read -r imap_server
    echo "? IMAP port (default: 993):"
    printf "  > "
    read -r imap_port
    [ -z "$imap_port" ] && imap_port="993"
    echo "? SMTP server:"
    printf "  > "
    read -r smtp_server
    echo "? SMTP port (default: 465):"
    printf "  > "
    read -r smtp_port
    [ -z "$smtp_port" ] && smtp_port="465"
    echo "? TLS mode (implicit/starttls, default: implicit):"
    printf "  > "
    read -r tls_mode
    [ -z "$tls_mode" ] && tls_mode="implicit"
  fi

  # Get password/app-password
  case "$provider" in
    gmail)
      echo ""
      echo "Gmail requires an App Password (not your regular password)."
      echo "Create one at: https://myaccount.google.com/apppasswords"
      echo "(Requires 2-Step Verification enabled)"
      ;;
    outlook)
      echo ""
      echo "Use your Outlook password or an App Password."
      ;;
    protonmail)
      echo ""
      echo "Use the ProtonMail Bridge password (not your account password)."
      echo "Find it in the ProtonMail Bridge app settings."
      ;;
  esac

  echo "? Password / App Password:"
  printf "  > "
  if [ -t 0 ]; then
    stty -echo 2>/dev/null || true
    read -r password
    stty echo 2>/dev/null || true
    echo ""
  else
    read -r password
  fi

  # Test IMAP connection
  printf "- Testing IMAP connection..."
  local test_result
  test_result=$(curl -s --url "imaps://${imap_server}:${imap_port}/" \
    --user "${email}:${password}" \
    --request "NOOP" -o /dev/null -w "%{http_code}" 2>&1)
  local test_exit=$?

  if [ $test_exit -ne 0 ]; then
    echo " FAILED"
    echo "error: could not connect to IMAP server (exit code: ${test_exit})" >&2
    echo "  Check your server, email, and password." >&2
    return 1
  fi
  echo " OK"

  # Save account
  local account_json
  account_json=$(jq -n \
    --arg provider "$provider" \
    --arg email "$email" \
    --arg display "$display_name" \
    --arg imap "$imap_server" \
    --arg iport "$imap_port" \
    --arg smtp "$smtp_server" \
    --arg sport "$smtp_port" \
    --arg pass "$password" \
    --arg tls "$tls_mode" \
    '{
      provider: $provider,
      email: $email,
      display_name: $display,
      imap_server: $imap,
      imap_port: ($iport | tonumber),
      smtp_server: $smtp,
      smtp_port: ($sport | tonumber),
      password: $pass,
      tls: $tls
    }')

  mail_config_set_account "$account_name" "$account_json"

  # Set as default if first account
  local current_default
  current_default=$(mail_config_get_default)
  if [ -z "$current_default" ]; then
    mail_config_set_default "$account_name"
  fi

  echo ""
  echo "✓ Account '${account_name}' configured (${email} via ${provider})"
  [ "$(mail_config_get_default)" = "$account_name" ] && echo "  Set as default account"
}

cmd_auth_logout() {
  local account_name=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --account) account_name="$2"; shift 2 ;;
      *) account_name="$1"; shift ;;
    esac
  done

  if [ -z "$account_name" ]; then
    account_name=$(mail_config_get_default)
  fi

  if [ -z "$account_name" ]; then
    echo "error: specify account to remove" >&2; return 1
  fi

  local acc
  acc=$(mail_config_get_account "$account_name")
  if [ -z "$acc" ]; then
    echo "error: account '${account_name}' not found" >&2; return 1
  fi

  local email
  email=$(echo "$acc" | jq -r '.email')
  mail_config_delete_account "$account_name"

  # Clear default if this was it
  if [ "$(mail_config_get_default)" = "$account_name" ]; then
    mail_config_set_default ""
  fi

  echo "✓ Account '${account_name}' (${email}) removed"
}

cmd_auth_status() {
  mail_config_init

  local accounts
  accounts=$(mail_config_list_accounts)
  local default_acc
  default_acc=$(mail_config_get_default)

  if [ -z "$accounts" ]; then
    echo "No accounts configured. Run 'mail auth login' to add one." >&2
    return 1
  fi

  echo "$accounts" | while read -r name; do
    local acc
    acc=$(mail_config_get_account "$name")
    local email provider
    email=$(echo "$acc" | jq -r '.email')
    provider=$(echo "$acc" | jq -r '.provider')
    local imap_server imap_port
    imap_server=$(echo "$acc" | jq -r '.imap_server')
    imap_port=$(echo "$acc" | jq -r '.imap_port')

    local default_mark=""
    [ "$name" = "$default_acc" ] && default_mark=" (default)"

    echo "${name}${default_mark}"
    echo "  ✓ ${email} (${provider})"
    echo "  - IMAP: ${imap_server}:${imap_port}"

    # Quick connection test
    local test_exit
    curl -s --url "imaps://${imap_server}:${imap_port}/" \
      --user "${email}:$(echo "$acc" | jq -r '.password')" \
      --request "NOOP" -o /dev/null 2>/dev/null
    test_exit=$?
    if [ $test_exit -eq 0 ]; then
      echo "  ✓ Connection OK"
    else
      echo "  ✗ Connection failed"
    fi
  done
}
