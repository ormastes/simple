{
  "name": "Simple Language MCP Server",
  "description": "68 tools for Simple Language development: code intelligence, debugging (DAP), build, test, VCS (jj), code search, and analysis. Native binary, no Node.js runtime needed.",
  "repository": "https://github.com/ormastes/simple",
  "homepage": "https://github.com/ormastes/simple",
  "categories": ["development", "debugging", "testing"],
  "tools": [
    {"name": "simple_read", "description": "Read Simple source with diagnostics"},
    {"name": "simple_edit", "description": "Edit Simple source with validation"},
    {"name": "simple_multi_edit", "description": "Multi-file editing"},
    {"name": "simple_check", "description": "Check source for errors"},
    {"name": "simple_build", "description": "Build project (debug/release)"},
    {"name": "simple_test", "description": "Run test suite"},
    {"name": "simple_search", "description": "Language-aware code search"},
    {"name": "simple_status", "description": "Project status overview"},
    {"name": "simple_diff", "description": "Show file diff (jj VCS)"},
    {"name": "simple_commit", "description": "Commit changes (jj VCS)"},
    {"name": "debug_create_session", "description": "Create DAP debug session"},
    {"name": "debug_set_breakpoint", "description": "Set debugger breakpoint"},
    {"name": "debug_step", "description": "Step through code"},
    {"name": "debug_variables", "description": "Inspect variables"}
  ],
  "transports": ["stdio"],
  "install": {
    "npm": "@ormastes/simple-mcp-server"
  }
}
