# Temporary probe: hello-world page whose visible content is COMPUTED by the
# real JS engine (run_page_scripts), bridged into placeholders (the engine's
# JS<->DOM bridge is not wired yet — bridge is explicit here), then rendered.
use std.gc_async_mut.gpu.browser_engine.script.script_runner.{run_page_scripts}
use std.gc_async_mut.gpu.browser_engine.html_tree_builder.{html_tree_builder_build_with_scripts}
use std.gc_async_mut.gpu.browser_engine.simple_web_html_layout_renderer.{
    simple_web_layout_render_html_software_pixels}
extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_write_text(path: text, content: text) -> bool

val dir = "/private/tmp/claude-501/-Users-ormastes-simple/f10f352f-2184-46d2-bf71-444e5c96b02f/scratchpad"
val html = rt_file_read_text(dir + "/hello_js.html")
val tree = html_tree_builder_build_with_scripts(html)
print("scripts=" + tree.scripts.len().to_text())
val outs = run_page_scripts(tree.scripts)
var i = 0
var final_html = html
while i < outs.len():
    print("JS[" + i.to_text() + "] -> " + outs[i])
    final_html = final_html.replace("%%JS" + i.to_text() + "%%", outs[i])
    i = i + 1
val _ = rt_file_write_text(dir + "/hello_js_final.html", final_html)
val px = simple_web_layout_render_html_software_pixels(final_html, 480, 240)
var sb = "{\"format\":\"argb-u32\",\"pixels\":["
i = 0
while i < px.len():
    if i > 0:
        sb = sb + ","
    sb = sb + px[i].to_text()
    i = i + 1
sb = sb + "]}"
val _ = rt_file_write_text(dir + "/hello_js.argb.json", sb)
print("HELLO-JS-PROBE: rendered " + px.len().to_text() + " px")
