# Bisect: raw JsRuntime two evals + the script_runner module graph LOADED
# (imported but unused for eval) to test class-collision interference.
use std.gc_async_mut.gpu.browser_engine.script.script_runner.{ScriptRunner}
use std.js.engine.runtime.{JsRuntime}
use std.js.engine.js_error.{Logger, LogLevel}

var rt = JsRuntime.new(Logger.new("p7", LogLevel.Error))
match rt.eval("var a = 2; var b = 3; a + b"):
    Ok(v): print("P7-E1 ok")
    Err(e): print("P7-E1 err: " + e.message)
match rt.eval("a * 10"):
    Ok(v): print("P7-E2 ok")
    Err(e): print("P7-E2 err: " + e.message)
