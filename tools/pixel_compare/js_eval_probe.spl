use std.js.engine.runtime.{JsRuntime, js_runtime_with_default_logger}
extern fn rt_file_read_text(path: text) -> text
extern fn rt_env_get(name: text) -> text

val path = rt_env_get("JS_FILE")
val src = if path.len() > 0: rt_file_read_text(path) else: rt_env_get("JS_SRC")
var rt = js_runtime_with_default_logger("eval-probe")
match rt.eval(src):
    Ok(v):
        print("EVAL ok len=" + src.len().to_text())
    Err(e):
        print("EVAL js-error len=" + src.len().to_text())
