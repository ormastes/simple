# Temporary probe (not committed): fetch a URL via FetchEngine and save body.
use std.gc_async_mut.gpu.browser_engine.net.fetch.{FetchEngine}
use std.gc_async_mut.gpu.browser_engine.net.entity.request_types.{FetchRequest, RequestMode, RequestCredentials}
use std.gc_async_mut.gpu.browser_engine.net.entity.url_types.{Url}
use std.gc_async_mut.gpu.browser_engine.shared.logging.{Logger, LogLevel}

extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_env_get(key: text) -> text

val url_str = rt_env_get("FETCH_URL")
val out_path = rt_env_get("FETCH_OUT")

val engine = FetchEngine.new(Logger.new("fetch-probe", LogLevel.Warn))
val req = FetchRequest(
    method: "GET",
    url: Url.parse(url_str),
    headers: "User-Agent: Mozilla/5.0 (Macintosh) SimpleBrowser/0.1\r\nAccept: text/html\r\n",
    body: [],
    mode: RequestMode.NoCors,
    credentials: RequestCredentials.Omit)
val result = engine.fetch(req)
var html = ""
match result:
    Ok(resp):
        html = resp.body_text()
        print("FETCH: status=" + resp.status.to_text() + " bytes=" + html.len().to_text())
    Err(e):
        print("FETCH: FAIL " + e.message)
if html.len() > 0:
    val _ = rt_file_write_text(out_path, html)
    print("FETCH: saved " + out_path)
