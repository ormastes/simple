# Temporary probe (not committed): numeric-entity decode through the real
# render path — paints text nodes containing &#NNNN; / &#xHHHH; references and
# verifies the render completes; the pixel diff vs the literal form proves the
# decode changed painted output.
use std.gc_async_mut.gpu.browser_engine.simple_web_html_layout_renderer.{
    simple_web_layout_render_html_software_pixels}

val html_entities = "<html><body><p>A&#66;C &#x44;E korean:&#51060;&#48120;&#51648;</p></body></html>"
val html_expected = "<html><body><p>ABC DE korean:이미지</p></body></html>"
val html_literal = "<html><body><p>A&amp;#66;C</p></body></html>"
val w = 240
val h = 60
val px1 = simple_web_layout_render_html_software_pixels(html_entities, w, h)
val px2 = simple_web_layout_render_html_software_pixels(html_expected, w, h)
val px3 = simple_web_layout_render_html_software_pixels(html_literal, w, h)
var same12 = true
var i = 0
while i < px1.len():
    if px1[i] != px2[i]:
        same12 = false
        break
    i = i + 1
var same13 = true
i = 0
while i < px1.len():
    if px1[i] != px3[i]:
        same13 = false
        break
    i = i + 1
print("decoded_matches_expected=" + same12.to_text() + " (must be true)")
print("decoded_differs_from_literal=" + (not same13).to_text() + " (must be true)")
if same12 and not same13:
    print("ENTITY-PROBE: PASS")
else:
    print("ENTITY-PROBE: FAIL")
