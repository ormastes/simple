use std.js.engine.runtime.{JsRuntime}
use std.js.engine.js_error.{Logger, LogLevel}

var rt = JsRuntime.new(Logger.new("js-probe", LogLevel.Error))
match rt.eval("var a = 2; var b = 3; a + b"):
    Ok(v): print("E1 ok")
    Err(e): print("E1 err: " + e.message)
match rt.eval("a * 10"):
    Ok(v): print("E2 ok")
    Err(e): print("E2 err: " + e.message)
var rt2 = JsRuntime.new(Logger.new("js-probe", LogLevel.Error))
match rt2.eval("let s = 'hi'; s + ' there'"):
    Ok(v): print("E3 ok")
    Err(e): print("E3 err: " + e.message)
