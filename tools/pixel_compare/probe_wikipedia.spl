use std.gc_async_mut.gpu.browser_engine.html_tree_builder.{html_tree_builder_build_with_scripts, TreeBuilderResult}
use std.gc_async_mut.gpu.browser_engine.script.script_runner.{run_page_scripts}
extern fn rt_file_read_text(path: text) -> text

val html = rt_file_read_text("/private/tmp/claude-501/-Users-ormastes-simple/f10f352f-2184-46d2-bf71-444e5c96b02f/scratchpad/wikipedia_live.html")
print("html bytes: " + html.len().to_text())
val tree = html_tree_builder_build_with_scripts(html)
print("script count: " + tree.scripts.len().to_text())
val results = run_page_scripts(tree.scripts)
var errs = 0
var oks = 0
var i = 0
while i < results.len():
    val r = results[i]
    if r.starts_with("js-error"):
        errs = errs + 1
        if errs <= 8:
            var head = r
            if head.len() > 160:
                head = head.slice(0, 160)
            print("ERR[" + i.to_text() + "] " + head)
    else:
        oks = oks + 1
    i = i + 1
print("TOTAL ok=" + oks.to_text() + " err=" + errs.to_text())
