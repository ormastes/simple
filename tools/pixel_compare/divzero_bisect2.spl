use std.gc_async_mut.gpu.browser_engine.script.script_runner.{run_page_scripts}
extern fn rt_env_get(name: text) -> text
val which = rt_env_get("WHICH")
var src = ""
if which == "a":
    src = "var a = 1; var b = 1; var i = 0; while (i < 10) { var t = a + b; a = b; b = t; i = i + 1; } 'fib(12) = ' + b"
elif which == "b":
    src = "var i = 0; while (i < 3) { i = i + 1; } i"
elif which == "c":
    src = "var t = 1 + 2; t"
val outs = run_page_scripts([src])
print("R[" + which + "]: " + outs[0])
