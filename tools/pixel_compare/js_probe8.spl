use std.gc_async_mut.gpu.browser_engine.script.script_runner.{
    ScriptRunner, run_script_with_type, run_page_scripts}
use std.gc_async_mut.gpu.browser_engine.html_tree_builder.{html_tree_builder_build_with_scripts}
use app.io.mod.{file_read_text}

var runner = ScriptRunner.new()
val o1 = run_script_with_type(runner, "var a = 2; var b = 3; a + b", "text/javascript")
print("P8-EXPR: [" + o1 + "] (want 5)")
val o4 = run_script_with_type(runner, "function f(x){ return x*x } f(7)", "text/javascript")
print("P8-FUNC: [" + o4 + "] (want 49)")
val o5 = run_script_with_type(runner, "syntax error ((", "text/javascript")
print("P8-ERR: [" + (if o5.starts_with("js-error"): "surfaced" else: "SILENT") + "]")

# shared globals across tags via run_page_scripts
val outs = run_page_scripts(["var g = 11;", "g * 2"])
print("P8-PAGE-SHARED: [" + outs[1] + "] (want 22)")

# google's 11 scripts on one page engine
val html = file_read_text("/private/tmp/claude-501/-Users-ormastes-simple/f10f352f-2184-46d2-bf71-444e5c96b02f/scratchpad/google_live.html")
val tree = html_tree_builder_build_with_scripts(html)
val gouts = run_page_scripts(tree.scripts)
var errs = 0
var i = 0
while i < gouts.len():
    if gouts[i].starts_with("js-error"):
        errs = errs + 1
        if errs <= 4:
            val msg = gouts[i]
            print("P8-GOOGLE[" + i.to_text() + "]: " + msg.substring(0, if msg.len() < 110: msg.len() else: 110))
    i = i + 1
print("P8-GOOGLE: scripts=" + gouts.len().to_text() + " errors=" + errs.to_text())
