use std.gc_async_mut.gpu.browser_engine.script.script_runner.{run_page_scripts}
use std.gc_async_mut.gpu.browser_engine.html_tree_builder.{html_tree_builder_build_with_scripts}
extern fn rt_rt_file_read_text(path: text) -> text
extern fn rt_file_write_text(path: text, content: text) -> bool

val html = rt_file_read_text("/private/tmp/claude-501/-Users-ormastes-simple/f10f352f-2184-46d2-bf71-444e5c96b02f/scratchpad/google_live.html")
val tree = html_tree_builder_build_with_scripts(html)
val outs = run_page_scripts(tree.scripts)
var errs = 0
var report = ""
var i = 0
while i < outs.len():
    val o = outs[i]
    if o.starts_with("js-error"):
        errs = errs + 1
        report = report + "[" + i.to_text() + "] " + o.substring(0, if o.len() < 160: o.len() else: 160) + "\n"
    i = i + 1
val _ = rt_file_write_text("/private/tmp/claude-501/-Users-ormastes-simple/f10f352f-2184-46d2-bf71-444e5c96b02f/scratchpad/google_js_report.txt", report)
print("GOOGLE-JS-FINAL: scripts=" + outs.len().to_text() + " errors=" + errs.to_text())
