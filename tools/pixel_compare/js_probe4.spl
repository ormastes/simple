use std.gc_async_mut.gpu.browser_engine.script.script_runner.{
    ScriptRunner, run_script_with_type, reset_js_runtime}
use std.gc_async_mut.gpu.browser_engine.html_tree_builder.{html_tree_builder_build_with_scripts}
use app.io.mod.{file_read_text}

var runner = ScriptRunner.new()
val o1 = run_script_with_type(runner, "var a = 2; var b = 3; a + b", "text/javascript")
print("JS-EXPR: [" + o1 + "] (want 5)")
val o2 = run_script_with_type(runner, "a * 10", "text/javascript")
print("JS-SHARED-GLOBALS: [" + o2 + "] (want 20)")
val o3 = run_script_with_type(runner, "let s = 'hi'; s + ' there'", "text/javascript")
print("JS-STRING: [" + o3 + "] (want hi there)")
val o4 = run_script_with_type(runner, "function f(x){ return x*x } f(7)", "text/javascript")
print("JS-FUNC: [" + o4 + "] (want 49)")
val o5 = run_script_with_type(runner, "syntax error here ((", "text/javascript")
print("JS-ERR-SURFACED: [" + o5.substring(0, if o5.len() < 60: o5.len() else: 60) + "] (want js-error...)")

reset_js_runtime()
val html = file_read_text("/private/tmp/claude-501/-Users-ormastes-simple/f10f352f-2184-46d2-bf71-444e5c96b02f/scratchpad/google_live.html")
val tree = html_tree_builder_build_with_scripts(html)
var i = 0
var errs = 0
var oks = 0
while i < tree.scripts.len():
    val o = run_script_with_type(runner, tree.scripts[i], "text/javascript")
    if o.starts_with("js-error"):
        errs = errs + 1
        if errs <= 3:
            print("GOOGLE-JS[" + i.to_text() + "]: " + o.substring(0, if o.len() < 120: o.len() else: 120))
    else:
        oks = oks + 1
    i = i + 1
print("GOOGLE-JS: ok=" + oks.to_text() + " errors=" + errs.to_text() + " of " + tree.scripts.len().to_text())
