use std.gc_async_mut.gpu.browser_engine.html_tree_builder.{html_tree_builder_build_with_scripts}
use std.js.engine.parser.{js_source_delimiters_balanced}
extern fn rt_file_read_text(path: text) -> text
extern fn rt_env_get(name: text) -> text

val idx = rt_env_get("JS_IDX").parse_int() ?? 1
val html = rt_file_read_text("/private/tmp/claude-501/-Users-ormastes-simple/f10f352f-2184-46d2-bf71-444e5c96b02f/scratchpad/google_live.html")
val tree = html_tree_builder_build_with_scripts(html)
val src = tree.scripts[idx]
val b = js_source_delimiters_balanced(src)
print("BALANCE[" + idx.to_text() + "] len=" + src.len().to_text() + " balanced=" + (if b: "true" else: "false"))
val neg = js_source_delimiters_balanced("syntax error ((")
print("NEG balanced=" + (if neg: "true" else: "false") + " (expect false)")
