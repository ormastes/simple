use std.gc_async_mut.gpu.browser_engine.simple_web_html_layout_renderer.{
    simple_web_layout_render_html_software_pixels}

val ob = "{"
val cb = "}"
val h2 = "<html><head><style>:root" + ob + "--c:#ff0000" + cb + "p" + ob + "color:var(--c,#00ff00)" + cb + "</style></head><body><p>X</p></body></html>"
val p2 = simple_web_layout_render_html_software_pixels(h2, 60, 30)
var red = 0
var green = 0
var i = 0
while i < p2.len():
    if p2[i] == 0xFFFF0000:
        red = red + 1
    elif p2[i] == 0xFF00FF00:
        green = green + 1
    i = i + 1
print("defined_var_red=" + red.to_text() + " green=" + green.to_text() + " (want red>0, green==0)")
