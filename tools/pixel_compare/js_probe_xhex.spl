use std.js.engine.runtime.{JsRuntime}
use std.js.engine.js_error.{Logger, LogLevel}
use std.js.types.js_types.JsValue

fn main():
    var rt = JsRuntime.new(Logger.new("p", LogLevel.Error))
    match rt.eval("var s='\\x41\\x42'; s"):
        Ok(v):
            match v:
                JsValue.String(sv):
                    print("case1 s=" + sv)
                _:
                    print("case1 non-string")
        Err(e):
            print("case1 err=" + e.message)
    match rt.eval("JSON.parse('{\\x22a\\x22:1}').a"):
        Ok(v):
            match v:
                JsValue.Number(n):
                    print("case2 =" + n.to_text())
                _:
                    print("case2 non-number")
        Err(e):
            print("case2 err=" + e.message)
