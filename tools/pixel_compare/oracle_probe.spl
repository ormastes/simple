# Deterministic oracle for the CSS length/margin fixes. Renders through the same
# software layout path the budget spec asserts against and prints exact pixels.
use std.gc_async_mut.gpu.browser_engine.simple_web_html_layout_renderer.{
    simple_web_layout_render_html_software_pixels, simple_web_layout_last_render_degraded}

extern fn rt_env_get(key: text) -> text
extern fn rt_file_read_text(path: text) -> text

val W = 200
val H = 120

fn px_at(pixels: [u32], x: i32, y: i32) -> u32:
    pixels[y * W + x]

# margin:0 auto centering of an explicit-width block + 2em font-size.
val html = "<html><body style=\"margin:0\">" +
    "<div style=\"width:100px;height:40px;margin:0 auto;background:#3050a0\"></div>" +
    "</body></html>"
val pixels = simple_web_layout_render_html_software_pixels(html, W, H)
print("len=" + pixels.len().to_text())
# Centered 100px block in 200px viewport => x in [50,149]. Sample center + gaps.
val center = px_at(pixels, 100, 20)
val left_gap = px_at(pixels, 20, 20)
val right_gap = px_at(pixels, 180, 20)
print("center(100,20)=" + center.to_text() + " expect=" + (0xFF3050A0u32).to_text())
print("left_gap(20,20)=" + left_gap.to_text() + " expect_white=" + (0xFFFFFFFFu32).to_text())
print("right_gap(180,20)=" + right_gap.to_text() + " expect_white=" + (0xFFFFFFFFu32).to_text())
var ok = true
if center != 0xFF3050A0u32:
    ok = false
if left_gap != 0xFFFFFFFFu32:
    ok = false
if right_gap != 0xFFFFFFFFu32:
    ok = false
print("CENTERING_ORACLE=" + (if ok: "PASS" else: "FAIL"))

# vw width: 50vw of a 200px viewport => 100px block, left-aligned (no margin).
val html2 = "<html><body style=\"margin:0\">" +
    "<div style=\"width:50vw;height:20px;background:#20c040\"></div>" +
    "</body></html>"
val pixels2 = simple_web_layout_render_html_software_pixels(html2, W, H)
val vw_in = px_at(pixels2, 50, 10)
val vw_out = px_at(pixels2, 150, 10)
print("vw_in(50,10)=" + vw_in.to_text() + " expect=" + (0xFF20C040u32).to_text())
print("vw_out(150,10)=" + vw_out.to_text() + " expect_white=" + (0xFFFFFFFFu32).to_text())
val vw_ok = vw_in == 0xFF20C040u32 and vw_out == 0xFFFFFFFFu32
print("VW_ORACLE=" + (if vw_ok: "PASS" else: "FAIL"))

# vh margin: 50vh of a 120px viewport => 60px top margin.
val html3 = "<html><body style=\"margin:0\">" +
    "<div style=\"width:100px;height:20px;margin-top:50vh;background:#d04030\"></div>" +
    "</body></html>"
val pixels3 = simple_web_layout_render_html_software_pixels(html3, W, H)
val vh_in = px_at(pixels3, 50, 70)
val vh_out = px_at(pixels3, 50, 30)
print("vh_in(50,70)=" + vh_in.to_text() + " expect=" + (0xFFD04030u32).to_text())
print("vh_out(50,30)=" + vh_out.to_text() + " expect_white=" + (0xFFFFFFFFu32).to_text())
val vh_ok = vh_in == 0xFFD04030u32 and vh_out == 0xFFFFFFFFu32
print("VH_ORACLE=" + (if vh_ok: "PASS" else: "FAIL"))

# Unstyled <a> UA default: link-blue (#0000EE) glyphs + underline, no page CSS.
val html4 = "<html><body style=\"margin:0\"><a href=\"/x\">link</a></body></html>"
val pixels4 = simple_web_layout_render_html_software_pixels(html4, W, H)
var link_blue_count = 0
var i4 = 0
while i4 < pixels4.len():
    if pixels4[i4] == 0xFF0000EEu32:
        link_blue_count = link_blue_count + 1
    i4 = i4 + 1
print("link_blue_count=" + link_blue_count.to_text())
val link_ok = link_blue_count > 20
print("LINK_ORACLE=" + (if link_ok: "PASS" else: "FAIL"))

# ul/li UA default: ~40px start padding (Chrome UA padding-inline-start:40px).
val html5 = "<html><body style=\"margin:0\"><ul><li>item</li></ul></body></html>"
val pixels5 = simple_web_layout_render_html_software_pixels(html5, W, H)
var list_min_x = -1
var i5 = 0
while i5 < pixels5.len():
    if pixels5[i5] != 0xFFFFFFFFu32:
        val x5 = i5 % W
        if list_min_x < 0 or x5 < list_min_x:
            list_min_x = x5
    i5 = i5 + 1
print("list_min_x=" + list_min_x.to_text())

# Control: <div> has no start padding, so its leftmost non-white pixel should be < 10.
val html6 = "<html><body style=\"margin:0\"><div>item</div></body></html>"
val pixels6 = simple_web_layout_render_html_software_pixels(html6, W, H)
var div_min_x = -1
var i6 = 0
while i6 < pixels6.len():
    if pixels6[i6] != 0xFFFFFFFFu32:
        val x6 = i6 % W
        if div_min_x < 0 or x6 < div_min_x:
            div_min_x = x6
    i6 = i6 + 1
print("div_min_x=" + div_min_x.to_text())

val list_ok = list_min_x >= 40 and div_min_x >= 0 and div_min_x < 10
print("LIST_ORACLE=" + (if list_ok: "PASS" else: "FAIL"))

# HTML presentational attributes: bgcolor, width, height, align (legacy but valid HTML5).
# These have LOWEST CSS priority: matched rules and inline style override them.
val html7 = "<html><body style=\"margin:0\"><table bgcolor=\"#ff6600\" width=\"200\" height=\"30\"><tr><td>x</td></tr></table><div bgcolor=\"#00ff00\" style=\"background-color:#0000ff;width:50px;height:10px\"></div></body></html>"
val pixels7 = simple_web_layout_render_html_software_pixels(html7, W, H)
# Table bgcolor should paint at row 15 (half of 30px height), column 100 (center).
val table_bgcolor = px_at(pixels7, 100, 15)
print("table_bgcolor(100,15)=" + table_bgcolor.to_text() + " expect=" + (0xFFFF6600u32).to_text())
# Div starts after table (at y=30+) with inline style background-color:#0000ff overriding bgcolor.
# Scan y=35 at x=10 to find a pixel in the div.
var div_inline_color = px_at(pixels7, 10, 35)
var pres_y = 30
while pres_y < 50:
    val pix = px_at(pixels7, 10, pres_y)
    if pix != 0xFFFFFFFFu32:
        div_inline_color = pix
        break
    pres_y = pres_y + 1
print("div_inline(10,?)=" + div_inline_color.to_text() + " expect=" + (0xFF0000FFu32).to_text())

# Page-CSS RULE precedence: a selector-matched rule (td{background-color})
# must beat the td's own bgcolor attribute — attributes sit BELOW rules in
# the cascade, not just below inline style.
val html8 = "<html><head><style>td{background-color:#00aa00}</style></head>" +
    "<body style=\"margin:0\"><table bgcolor=\"#ff6600\" width=\"200\" height=\"30\">" +
    "<tr><td bgcolor=\"#ff6600\" style=\"width:200px;height:30px\">x</td></tr></table></body></html>"
val pixels8 = simple_web_layout_render_html_software_pixels(html8, W, H)
val td_rule_color = px_at(pixels8, 100, 15)
print("td_rule(100,15)=" + td_rule_color.to_text() + " expect=" + (0xFF00AA00u32).to_text())

val pres_ok = table_bgcolor == 0xFFFF6600u32 and div_inline_color == 0xFF0000FFu32 and td_rule_color == 0xFF00AA00u32
print("PRESENTATIONAL_ORACLE=" + (if pres_ok: "PASS" else: "FAIL"))

# CENTER tag: guards against regression where <center> (or ancestor handling)
# becomes inline. An inline parent constrains a block child's box to intrinsic
# text width, collapsing painted backgrounds (span-wrapped vs block: 80px vs 2544).
val center_html = "<html><body style=\"margin:0\"><center><table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"85%\" bgcolor=\"#f6f6ef\"><tr><td bgcolor=\"#ff6600\"><table border=\"0\" width=\"100%\"><tr><td>Hacker News</td></tr></table></td></tr></table></center></body></html>"
val center_pixels = simple_web_layout_render_html_software_pixels(center_html, 200, 80)
var center_orange_count = 0
var ci = 0
while ci < center_pixels.len():
    if center_pixels[ci] == 0xFFFF6600u32:
        center_orange_count = center_orange_count + 1
    ci = ci + 1
print("center_orange_count=" + center_orange_count.to_text())
val center_ok = center_orange_count > 500
print("CENTER_TAG_ORACLE=" + (if center_ok: "PASS" else: "FAIL"))

# WIKI oracle: a real, large (~250KB) Wikipedia page rendered under the
# DEFAULT (10s) budget must trip the budget guard (degraded=true) but must
# NOT come back as a fully blank framebuffer — a degraded render is honest
# partial content, not silence. See doc/08_tracking/bug/
# browser_engine_wikipedia_render_perf_2026-07-11.md for the root cause and
# the stage-local budget partition that fixes this. Optional: only runs when
# WEB_ORACLE_WIKI_HTML points at a fetched page, so this stays skippable in
# environments (e.g. CI) without that fixture checked out.
val wiki_path = rt_env_get("WEB_ORACLE_WIKI_HTML") ?? ""
if wiki_path.len() > 0:
    val wiki_html = rt_file_read_text(wiki_path)
    if wiki_html.len() > 0:
        val wiki_pixels = simple_web_layout_render_html_software_pixels(wiki_html, 480, 360)
        val wiki_degraded = simple_web_layout_last_render_degraded()
        var wiki_nonwhite = 0
        var iw = 0
        while iw < wiki_pixels.len():
            if wiki_pixels[iw] != 0xFFFFFFFFu32:
                wiki_nonwhite = wiki_nonwhite + 1
            iw = iw + 1
        print("wiki_degraded=" + wiki_degraded.to_text() + " wiki_nonwhite=" + wiki_nonwhite.to_text())
        val wiki_ok = wiki_degraded and wiki_nonwhite > 0
        print("WIKI_ORACLE=" + (if wiki_ok: "PASS" else: "FAIL"))
    else:
        print("WIKI_ORACLE=SKIP (empty file at WEB_ORACLE_WIKI_HTML)")
else:
    print("WIKI_ORACLE=SKIP (set WEB_ORACLE_WIKI_HTML to run)")
