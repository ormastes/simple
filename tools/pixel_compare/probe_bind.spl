use std.gc_async_mut.gpu.browser_engine.dom.{BeDomNode}
use std.gc_async_mut.gpu.browser_engine.script.dom_api.*

fn ok(name: text, cond: bool):
    if cond: print("PASS " + name)
    else: print("FAIL " + name)

# G: recursive accumulator persists
fn gather(node: BeDomNode, sink: [BeDomNode]):
    sink.push(node)
    var i = 0
    while i < node.children.len():
        gather(node.children[i], sink)
        i = i + 1

var root2 = BeDomNode.element("div")
root2.add_child(BeDomNode.element("span"))
var acc: [BeDomNode] = []
gather(root2, acc)
ok("recursive accumulator count=2", acc.len() == 2)

# I: mutate node extracted from a nested child array element
var p = BeDomNode.element("div")
var kid = BeDomNode.element("span")
p.add_child(kid)
var extracted = p.children[0]
extracted.set_attr("k", "v")
ok("mutate extracted-from-array copy same var", extracted.get_attr("k") == "v")

# J: through dom_api node_set_attribute on extracted
var p2 = BeDomNode.element("div")
p2.add_child(BeDomNode.element("span"))
var ex2 = p2.children[0]
node_set_attribute(ex2, "k", "v")
match node_get_attribute(ex2, "k"):
    Some(v): ok("dom_api set/get on extracted", v == "v")
    _: ok("dom_api set/get on extracted", false)
print("BIND DONE")
