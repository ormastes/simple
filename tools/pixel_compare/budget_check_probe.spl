# Temporary probe: does the 10s default budget degrade the google render?
use std.gc_async_mut.gpu.browser_engine.simple_web_html_layout_renderer.{
    simple_web_layout_render_html_software_pixels,
    simple_web_layout_last_render_degraded}
use app.io.mod.{file_read_text}

val html = file_read_text("/private/tmp/claude-501/-Users-ormastes-simple/f10f352f-2184-46d2-bf71-444e5c96b02f/scratchpad/google_live.html")
val px_default = simple_web_layout_render_html_software_pixels(html, 480, 360)
print("default_budget_degraded=" + simple_web_layout_last_render_degraded().to_text() + " px=" + px_default.len().to_text())
val px_wide = simple_web_layout_render_html_software_pixels(html, 480, 360, 300000)
print("wide_budget_degraded=" + simple_web_layout_last_render_degraded().to_text() + " px=" + px_wide.len().to_text())
var diff = 0
var i = 0
while i < px_default.len():
    if px_default[i] != px_wide[i]:
        diff = diff + 1
    i = i + 1
print("pixels_differing_default_vs_wide=" + diff.to_text())
