use std.env.variables.{env_get_or}
use std.nogc_sync_mut.env.variables.{env_get_i64}
use std.nogc_sync_mut.io.file_ops.{file_read_text, file_write_text_at}
use std.gc_async_mut.gpu.browser_engine.simple_web_renderer.{
    simple_web_resolved_engine2d_backend_name}
use std.gc_async_mut.gpu.browser_engine.simple_web_html_layout_renderer.{
    simple_web_layout_render_html_draw_ir}
use std.gc_async_mut.gpu.engine2d.engine.{Engine2D}
use std.gc_async_mut.gpu.engine2d.draw_ir_adv.{engine2d_draw_ir_adv_composition}
use std.gc_async_mut.gpu.engine2d.backend.{ReadbackSource, readback_source_from_text}

# Renders an HTML fixture through the CORE Simple web renderer (HTML/CSS
# parse -> layout -> paint, src/lib/gc_async_mut/gpu/browser_engine/
# simple_web_html_layout_renderer.spl) and presents the composed pixels on
# the requested Engine2D backend (metal on macOS), then writes an ARGB JSON
# artifact in the same {width,height,format:"argb-u32",producer,pixels}
# shape produced by tools/chrome-live-bitmap/capture_html_argb.js so the
# macOS Metal browser-backing evidence gate can diff simple/chrome/electron
# pairwise.
#
# Env contract (set by scripts/check/check-macos-metal-browser-backing-evidence.shs):
#   PIXEL_HTML     - path to the HTML fixture to render
#   PIXEL_W        - viewport width in pixels (default 320)
#   PIXEL_H        - viewport height in pixels (default 240)
#   PIXEL_BACKEND  - requested Engine2D backend name (default "metal")
#   PIXEL_OUT      - output path for the ARGB JSON artifact

fn _json_escape(s: text) -> text:
    val backslash_escaped = s.replace("\\", "\\\\")
    backslash_escaped.replace("\"", "\\\"")

fn _write_pixels_json(path: text, prefix: text, pixels: [u32]) -> bool:
    # Keep native text/file ABI calls bounded. A full 320x240 frame contains
    # 76,800 decimal strings; materializing and passing one giant text value
    # can exhaust or corrupt the native boundary before the file body is
    # written. Fixed-size joined chunks preserve the exact JSON schema.
    print "[render_simple_html] stage=json-header-start bytes={prefix.len()}"
    val header = prefix + "["
    var offset = file_write_text_at(path, 0, header)
    print "[render_simple_html] stage=json-header-returned bytes={offset}"
    if offset != header.len():
        return false
    val chunk_capacity = 1024
    val n = pixels.len()
    var start = 0
    while start < n:
        val remaining = n - start
        val count = if remaining < chunk_capacity: remaining else: chunk_capacity
        var parts: [text] = [""; count]
        var i = 0
        while i < count:
            parts[i] = pixels[start + i].to_i64().to_text()
            i = i + 1
        val separator = if start == 0: "" else: ","
        val chunk = separator + parts.join(",")
        val written = file_write_text_at(path, offset, chunk)
        if written != chunk.len():
            return false
        offset = offset + written
        start = start + count
    file_write_text_at(path, offset, "]}") == 2

fn _nonblank_count(pixels: [u32]) -> i64:
    var count: i64 = 0
    var i = 0
    val n = pixels.len()
    while i < n:
        if pixels[i] != 0u32:
            count = count + 1
        i = i + 1
    count

fn main() -> i64:
    val html_path = env_get_or("PIXEL_HTML", "test/fixtures/pixel_compare/css_boxes.html")
    val width = env_get_i64("PIXEL_W", 320).to_i32()
    val height = env_get_i64("PIXEL_H", 240).to_i32()
    val requested_backend = env_get_or("PIXEL_BACKEND", "metal")
    val out_path = env_get_or("PIXEL_OUT", "build/macos-metal-browser-backing/simple.argb.json")

    if width <= 0 or height <= 0:
        print "[render_simple_html] invalid viewport {width}x{height}"
        return 2
    print "[render_simple_html] stage=viewport-ready width={width} height={height}"

    val html = file_read_text(html_path)
    if html == "":
        print "[render_simple_html] empty or unreadable html: {html_path}"
        return 2
    print "[render_simple_html] stage=html-ready bytes={html.len()}"

    val resolved_backend = simple_web_resolved_engine2d_backend_name(width, height, requested_backend)
    print "[render_simple_html] stage=backend-resolved backend={resolved_backend}"

    # Exercises the CORE web renderer path: simple_web_render_html_to_readback_with_engine2d_backend
    # -> simple_web_engine2d_render_html_readback -> (selector-css HTML like
    # this fixture routes to) simple_web_layout_render_html_pixels, the real
    # HTML/CSS parse+layout+paint renderer, then presents on Engine2D with
    # the requested backend (metal) and reports the genuine readback source.
    val ir = simple_web_layout_render_html_draw_ir(html, width, height)
    var command_count = 0
    for batch in ir.batches:
        command_count = command_count + batch.commands.len()
        for command in batch.commands:
            print "[render_simple_html] command kind={command.kind} is_rect={command.kind == \"rect\"} x={command.x} y={command.y} width={command.width} height={command.height} color={command.color.to_i64()} styles={command.computed_style.len()}"
    print "[render_simple_html] stage=draw-ir-ready batches={ir.batches.len()} commands={command_count}"
    var engine = Engine2D.create_with_backend_fast(width, height, requested_backend)
    print "[render_simple_html] stage=engine-ready"
    engine.clear(0u32)
    print "[render_simple_html] stage=engine-cleared"
    val render_result = engine2d_draw_ir_adv_composition(engine, ir, true)
    print "[render_simple_html] stage=composition-returned rendered={render_result.rendered_command_count} skipped={render_result.skipped_command_count} fallback={render_result.fallback_required} reason={render_result.fallback_reason}"
    engine.shutdown()
    print "[render_simple_html] stage=engine-shutdown"
    # The Draw IR executor already returns the canonical readback fields. Keep
    # that result intact instead of constructing a second readback object,
    # which adds no ownership or validation and can erase projected array/text
    # representation in native bootstrap builds.
    val readback_source = render_result.readback_source
    val readback_kind = readback_source_from_text(readback_source)
    print "[render_simple_html] stage=render-returned source={readback_source}"
    val pixels = render_result.pixels
    print "[render_simple_html] stage=pixels-ready count={pixels.len()}"

    if pixels.len() != width * height:
        print "[render_simple_html] bad pixel count: {pixels.len()} expected {width * height}"
        return 2

    # readback.source is the honest signal: "device_readback" means the pixels
    # were actually read back from the GPU device buffer; "cpu_mirror" /
    # "cpu_fallback" mean the requested backend did not (or could not) supply
    # a real GPU framebuffer for this frame and the CPU-composited mirror was
    # used instead. Do not claim metal when the source says otherwise.
    val gpu_backed = resolved_backend == "metal" and readback_kind == ReadbackSource.DeviceReadback
    val producer = if gpu_backed:
        "simple-web-core-renderer-metal-gpu-readback"
    else:
        "simple-web-core-renderer-cpu-fallback"

    val nonblank = _nonblank_count(pixels)
    print "[render_simple_html] stage=nonblank-ready count={nonblank}"

    val json_prefix = "{\"width\":" + width.to_string() + ",\"height\":" + height.to_string() +
        ",\"format\":\"argb-u32\"" +
        ",\"producer\":\"" + _json_escape(producer) + "\"" +
        ",\"requested_backend\":\"" + _json_escape(requested_backend) + "\"" +
        ",\"resolved_backend\":\"" + _json_escape(resolved_backend) + "\"" +
        ",\"engine2d_readback_source\":\"" + _json_escape(readback_source) + "\"" +
        ",\"gpu_backend_used\":" + (if gpu_backed: "true" else: "false") +
        ",\"pixels\":"
    print "[render_simple_html] stage=json-prefix-ready bytes={json_prefix.len()}"

    if not _write_pixels_json(out_path, json_prefix, pixels):
        print "[render_simple_html] failed to write argb json: {out_path}"
        return 2

    print "[render_simple_html] wrote {out_path} width={width} height={height} nonblank={nonblank} requested_backend={requested_backend} resolved_backend={resolved_backend} engine2d_readback_source={readback_source} gpu_backend_used={gpu_backed}"
    0
