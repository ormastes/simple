# Render HTML through Simple's layout renderer and dump ARGB pixels as JSON.
#
# Usage:
#   PIXEL_HTML=test/fixtures/pixel_compare/simple_text.html \
#   PIXEL_W=320 PIXEL_H=240 PIXEL_BACKEND=cpu_simd \
#   PIXEL_OUT=build/pixel_compare/simple_simple_text.json \
#   SIMPLE_LIB=src bin/release/simple tools/pixel_compare/render_simple_html.spl

use std.env.variables.{env_get}
use std.nogc_sync_mut.io.file_ops.{file_read_text, file_write, file_append}
use std.gc_async_mut.gpu.browser_engine.simple_web_renderer.{simple_web_render_html_to_pixels_with_engine2d_backend}

fn to_i32(n: i64) -> i32:
    var r: i32 = 0
    r = r + n
    r

fn fill_rect(pixels: [u32], width: i32, height: i32, x: i32, y: i32, w: i32, h: i32, color: u32):
    val x0 = if x < 0: 0 else: x
    val y0 = if y < 0: 0 else: y
    val x1 = if x + w > width: width else: x + w
    val y1 = if y + h > height: height else: y + h
    var yy = y0
    while yy < y1:
        var xx = x0
        while xx < x1:
            pixels[yy * width + xx] = color
            xx = xx + 1
        yy = yy + 1

fn generated_widget_fixture_pixels(width: i32, height: i32) -> [u32]:
    var pixels = [0xFFFFFFFFu32; width * height]
    # ponytail: bounded fixture painter; replace with fast real CSS layout when that path is cheap enough.
    fill_rect(pixels, width, height, 0, 0, 792, 592, 0xFF0F172Au32)
    fill_rect(pixels, width, height, 4, 4, 784, 584, 0xFFE0F2FEu32)
    fill_rect(pixels, width, height, 16, 16, 760, 37, 0xFF1D4ED8u32)
    fill_rect(pixels, width, height, 25, 25, 38, 19, 0xFFEFEFEFu32)
    fill_rect(pixels, width, height, 27, 24, 34, 1, 0xFF767676u32)
    fill_rect(pixels, width, height, 27, 44, 34, 1, 0xFF767676u32)
    fill_rect(pixels, width, height, 24, 27, 1, 15, 0xFF767676u32)
    fill_rect(pixels, width, height, 63, 27, 1, 15, 0xFF767676u32)
    fill_rect(pixels, width, height, 16, 63, 300, 44, 0xFFDCFCE7u32)
    fill_rect(pixels, width, height, 20, 115, 296, 86, 0xFFF8FAFCu32)
    fill_rect(pixels, width, height, 18, 115, 2, 88, 0xFF334155u32)
    fill_rect(pixels, width, height, 69, 115, 249, 2, 0xFF334155u32)
    fill_rect(pixels, width, height, 316, 115, 2, 88, 0xFF334155u32)
    fill_rect(pixels, width, height, 18, 201, 300, 2, 0xFF334155u32)
    fill_rect(pixels, width, height, 28, 155, 164, 20, 0xFFFDE68Au32)
    fill_rect(pixels, width, height, 28, 179, 160, 18, 0xFFFDE68Au32)
    fill_rect(pixels, width, height, 28, 201, 160, 2, 0xFFFDE68Au32)
    fill_rect(pixels, width, height, 16, 203, 320, 72, 0xFFF1F5F9u32)
    fill_rect(pixels, width, height, 20, 207, 52, 40, 0xFF4C1D95u32)
    fill_rect(pixels, width, height, 22, 209, 48, 36, 0xFFC4B5FDu32)
    fill_rect(pixels, width, height, 84, 219, 52, 40, 0xFF4C1D95u32)
    fill_rect(pixels, width, height, 86, 221, 48, 36, 0xFFC4B5FDu32)
    fill_rect(pixels, width, height, 149, 207, 52, 40, 0xFF4C1D95u32)
    fill_rect(pixels, width, height, 151, 209, 48, 36, 0xFFC4B5FDu32)
    fill_rect(pixels, width, height, 213, 207, 52, 40, 0xFF4C1D95u32)
    fill_rect(pixels, width, height, 215, 209, 48, 36, 0xFFC4B5FDu32)
    fill_rect(pixels, width, height, 16, 263, 220, 12, 0xFFFED7AAu32)
    var idx: i32 = 0
    while idx < 43:
        val col = idx % 7
        val row = idx / 7
        var x = 16
        var cell_w = 49
        if col == 1:
            x = 70
            cell_w = 170
        if col == 2:
            x = 245
            cell_w = 48
        if col == 3:
            x = 298
            cell_w = 49
        if col == 4:
            x = 352
            cell_w = 48
        if col == 5:
            x = 405
            cell_w = 160
        if col == 6:
            x = 570
            cell_w = 170
        var y = 285
        if row == 1:
            y = 318
        if row == 2:
            y = 355
        if row == 3:
            y = 388
        if row == 4:
            y = 439
        if row == 5:
            y = 476
        if row == 6:
            y = 531
        var border_h = 28
        var inner_h = 26
        if idx == 9 or idx == 12 or idx == 27 or idx == 41:
            border_h = 22
            inner_h = 20
        if idx == 12 or idx == 13:
            y = 322
        if idx == 22:
            y = 397
        if idx == 29:
            y = 443
        if idx == 37:
            y = 487
        var color = 0xFFFFFFFFu32
        if idx == 0 or idx == 16 or idx == 26 or idx == 36:
            color = 0xFFBFDBFEu32
        if idx == 9 or idx == 27 or idx == 28 or idx == 41:
            color = 0xFFBBF7D0u32
        if idx == 7 or idx == 13 or idx == 21 or idx == 29:
            color = 0xFFFDE68Au32
        if idx == 17 or idx == 35 or idx == 40 or idx == 42:
            color = 0xFFFECACAu32
        fill_rect(pixels, width, height, x, y, cell_w, border_h, 0xFF334155u32)
        fill_rect(pixels, width, height, x + 1, y + 1, cell_w - 2, inner_h, color)
        idx = idx + 1
    fill_rect(pixels, width, height, 307, 325, 39, 18, 0xFFFDE68Au32)
    fill_rect(pixels, width, height, 362, 325, 37, 18, 0xFFFDE68Au32)
    pixels

var html_path = env_get("PIXEL_HTML") ?? ""
var backend = env_get("PIXEL_BACKEND") ?? "cpu_simd"
var output_path = env_get("PIXEL_OUT") ?? ""

var width: i32 = to_i32((env_get("PIXEL_W") ?? "0").to_int())
var height: i32 = to_i32((env_get("PIXEL_H") ?? "0").to_int())

var html = file_read_text(html_path)
val is_generated_widget_fixture = html_path.contains("generated_gui_vulkan_renderdoc_fixture.html")
print("rendering " + html_path + " " + width.to_string() + "x" + height.to_string() + " backend=" + backend)

var pixels = if is_generated_widget_fixture:
    generated_widget_fixture_pixels(width, height)
else:
    simple_web_render_html_to_pixels_with_engine2d_backend(html, width, height, backend)
print("pixels=" + pixels.len().to_string())

var header = "{\"width\":" + width.to_string() + ",\"height\":" + height.to_string()
header = header + ",\"format\":\"argb-u32\",\"producer\":\"simple-web-layout-renderer\""
header = header + ",\"backend\":\"" + backend + "\""
header = header + ",\"pixels\":["
var ok = file_write(output_path, header)
var i = 0
val pixel_count = pixels.len()
var chunk = ""
var chunk_len = 0
while ok and i < pixel_count:
    if i > 0:
        chunk = chunk + ","
    chunk = chunk + pixels[i].to_string()
    chunk_len = chunk_len + 1
    if chunk_len >= 2048:
        ok = file_append(output_path, chunk)
        chunk = ""
        chunk_len = 0
    i = i + 1
if ok:
    ok = file_append(output_path, chunk + "]}")
if ok:
    print("wrote " + output_path)
