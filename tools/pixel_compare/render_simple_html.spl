use std.env.variables.{env_get_or}
use std.nogc_sync_mut.io.file_ops.{file_read_text}
use std.nogc_sync_mut.sffi.io.{file_write_text}
use std.gc_async_mut.gpu.browser_engine.simple_web_renderer.{
    simple_web_render_html_to_readback_with_engine2d_backend,
    simple_web_resolved_engine2d_backend_name}

# Renders an HTML fixture through the CORE Simple web renderer (HTML/CSS
# parse -> layout -> paint, src/lib/gc_async_mut/gpu/browser_engine/
# simple_web_html_layout_renderer.spl) and presents the composed pixels on
# the requested Engine2D backend (metal on macOS), then writes an ARGB JSON
# artifact in the same {width,height,format:"argb-u32",producer,pixels}
# shape produced by tools/chrome-live-bitmap/capture_html_argb.js so the
# macOS Metal browser-backing evidence gate can diff simple/chrome/electron
# pairwise.
#
# Env contract (set by scripts/check/check-macos-metal-browser-backing-evidence.shs):
#   PIXEL_HTML     - path to the HTML fixture to render
#   PIXEL_W        - viewport width in pixels (default 320)
#   PIXEL_H        - viewport height in pixels (default 240)
#   PIXEL_BACKEND  - requested Engine2D backend name (default "metal")
#   PIXEL_OUT      - output path for the ARGB JSON artifact

fn _json_escape(s: text) -> text:
    val backslash_escaped = s.replace("\\", "\\\\")
    backslash_escaped.replace("\"", "\\\"")

fn _pixels_json(pixels: [u32]) -> text:
    # Pre-sized index-assign + one join, NOT per-element StringBuilder.push.
    # Under the tree-walking interpreter, pushing 76,800+ elements onto a
    # growing array field costs O(n^2) (each push clones the array) — a
    # 320x240 frame's JSON never finished in >90s. Index-assign into a
    # pre-allocated array is O(1) per element (measured: ~170ms for 76,800).
    val n = pixels.len()
    var parts: [text] = [""; n]
    var i = 0
    while i < n:
        parts[i] = pixels[i].to_i64().to_text()
        i = i + 1
    "[" + parts.join(",") + "]"

fn _nonblank_count(pixels: [u32]) -> i64:
    var count: i64 = 0
    var i = 0
    val n = pixels.len()
    while i < n:
        if pixels[i] != 0u32:
            count = count + 1
        i = i + 1
    count

fn main() -> i64:
    val html_path = env_get_or("PIXEL_HTML", "test/fixtures/pixel_compare/css_boxes.html")
    val width = env_get_or("PIXEL_W", "320").to_i32()
    val height = env_get_or("PIXEL_H", "240").to_i32()
    val requested_backend = env_get_or("PIXEL_BACKEND", "metal")
    val out_path = env_get_or("PIXEL_OUT", "build/macos-metal-browser-backing/simple.argb.json")

    if width <= 0 or height <= 0:
        print "[render_simple_html] invalid viewport {width}x{height}"
        return 2

    val html = file_read_text(html_path)
    if html == "":
        print "[render_simple_html] empty or unreadable html: {html_path}"
        return 2

    val resolved_backend = simple_web_resolved_engine2d_backend_name(width, height, requested_backend)

    # Exercises the CORE web renderer path: simple_web_render_html_to_readback_with_engine2d_backend
    # -> simple_web_engine2d_render_html_readback -> (selector-css HTML like
    # this fixture routes to) simple_web_layout_render_html_pixels, the real
    # HTML/CSS parse+layout+paint renderer, then presents on Engine2D with
    # the requested backend (metal) and reports the genuine readback source.
    val readback = simple_web_render_html_to_readback_with_engine2d_backend(html, width, height, requested_backend)
    val pixels = readback.pixels

    if pixels.len() != width * height:
        print "[render_simple_html] bad pixel count: {pixels.len()} expected {width * height}"
        return 2

    # readback.source is the honest signal: "device_readback" means the pixels
    # were actually read back from the GPU device buffer; "cpu_mirror" /
    # "cpu_fallback" mean the requested backend did not (or could not) supply
    # a real GPU framebuffer for this frame and the CPU-composited mirror was
    # used instead. Do not claim metal when the source says otherwise.
    val gpu_backed = resolved_backend == "metal" and readback.source == "device_readback"
    val producer = if gpu_backed:
        "simple-web-core-renderer-metal-gpu-readback"
    else:
        "simple-web-core-renderer-cpu-fallback"

    val nonblank = _nonblank_count(pixels)

    val json = "{\"width\":" + width.to_string() + ",\"height\":" + height.to_string() +
        ",\"format\":\"argb-u32\"" +
        ",\"producer\":\"" + _json_escape(producer) + "\"" +
        ",\"requested_backend\":\"" + _json_escape(requested_backend) + "\"" +
        ",\"resolved_backend\":\"" + _json_escape(resolved_backend) + "\"" +
        ",\"engine2d_readback_source\":\"" + _json_escape(readback.source) + "\"" +
        ",\"gpu_backend_used\":" + (if gpu_backed: "true" else: "false") +
        ",\"pixels\":" + _pixels_json(pixels) + "}"

    if not file_write_text(out_path, json):
        print "[render_simple_html] failed to write argb json: {out_path}"
        return 2

    print "[render_simple_html] wrote {out_path} width={width} height={height} nonblank={nonblank} requested_backend={requested_backend} resolved_backend={resolved_backend} engine2d_readback_source={readback.source} gpu_backend_used={gpu_backed}"
    0
