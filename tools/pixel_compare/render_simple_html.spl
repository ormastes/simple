# Render HTML through Simple's web engine 2D renderer and dump ARGB pixels.
#
# Usage:
#   SIMPLE_LIB=src bin/release/simple run tools/pixel_compare/render_simple_html.spl \
#     test/fixtures/pixel_compare/simple_text.html 320 240 cpu_simd \
#     build/pixel_compare/simple_simple_text.json

use std.gc_async_mut.gpu.browser_engine.simple_web_engine2d_renderer.{
    simple_web_engine2d_render_html_pixels
}

extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_args() -> [text]

fn main():
    val args = rt_args()
    if args.len() < 5:
        print("Usage: render_simple_html.spl <html_path> <width> <height> <backend> <output_json>")
        return

    val html_path = args[0]
    val width = args[1].to_i32()
    val height = args[2].to_i32()
    val backend = args[3]
    val output_path = args[4]

    val html = rt_file_read_text(html_path)
    if html.len() == 0:
        print("ERROR: empty or missing HTML file: " + html_path)
        return

    print("rendering " + html_path + " at " + width.to_text() + "x" + height.to_text() + " backend=" + backend)
    val pixels = simple_web_engine2d_render_html_pixels(html, width, height, backend)
    print("pixels=" + pixels.len().to_text())

    # Build JSON output
    var json = "{\"width\":" + width.to_text() + ",\"height\":" + height.to_text()
    json = json + ",\"format\":\"argb-u32\",\"producer\":\"simple-web-engine2d\""
    json = json + ",\"backend\":\"" + backend + "\""
    json = json + ",\"pixels\":["
    var i = 0
    while i < pixels.len():
        if i > 0:
            json = json + ","
        json = json + pixels[i].to_text()
        i = i + 1
    json = json + "]}"

    val ok = rt_file_write_text(output_path, json)
    if ok:
        print("wrote " + output_path)
    else:
        print("ERROR: failed to write " + output_path)

main()
