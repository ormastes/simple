use std.gc_async_mut.gpu.browser_engine.script.storage_api.*
use std.gc_async_mut.gpu.browser_engine.script.console_buffer.{ConsoleBuffer}
use std.gc_async_mut.gpu.browser_engine.script.console_api.*

var s = BrowserStorage.new()
storage_set_item(s, "k", "v")
match storage_get_item(s, "k"):
    Some(v): print("storage: " + v)
    _: print("storage: NIL (cross-module mutation lost)")

var c = ConsoleBuffer.new()
console_log(c, "hi")
print("console entries: " + c.entries().len().to_text())
