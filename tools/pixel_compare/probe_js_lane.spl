use std.gc_async_mut.gpu.browser_engine.script.script_runner.{run_page_scripts}

# Famous-page JS DOM patterns through the real JS engine lane
val scripts: [text] = [
    "var x = 1 + 2; x",
    "document.getElementById('foo')",
    "document.querySelector('.nav')",
    "var el = document.createElement('div'); el.tagName",
    "[1,2,3].forEach(function(n){ return n; }); 'done'",
    "'abc'.replace(/b/, 'X')",
    "localStorage.setItem('k','v'); localStorage.getItem('k')",
    "console.log('hi'); 'logged'",
    "navigator.userAgent",
    "window.location.href",
    "setTimeout(function(){}, 10); 'scheduled'"
]
val results = run_page_scripts(scripts)
var i = 0
while i < results.len():
    print("[" + i.to_text() + "] " + results[i])
    i = i + 1
