# Shell Tools — Module Root
# MDSOC: feature dimension, shell layer
#
# Coreutils-style tools for SimpleOS shell.
# Each tool is a standalone function returning an i32 exit code.

# Extracted from shell_app.spl
use os.tools.shell.cat.cat_tool.{tool_cat}
use os.tools.shell.ls.ls_tool.{tool_ls}
use os.tools.shell.echo.echo_tool.{tool_echo}
use os.tools.shell.grep.grep_tool.{tool_grep}
use os.tools.shell.find.find_tool.{tool_find}

# Text processing
use os.tools.shell.cut.cut_tool.{tool_cut}
use os.tools.shell.tr.tr_tool.{tool_tr}
use os.tools.shell.sed.sed_tool.{tool_sed}

# Path utilities
use os.tools.shell.basename.basename_tool.{tool_basename}
use os.tools.shell.dirname.dirname_tool.{tool_dirname}
use os.tools.shell.readlink.readlink_tool.{tool_readlink}

# Shell scripting support
use os.tools.shell.sleep.sleep_tool.{tool_sleep}
use os.tools.shell.seq.seq_tool.{tool_seq}
use os.tools.shell.expr.expr_tool.{tool_expr}
use os.tools.shell.test.test_tool.{tool_test}
use os.tools.shell.xargs.xargs_tool.{tool_xargs}
use os.tools.shell.yes.yes_tool.{tool_yes}
use os.tools.shell.env.env_tool.{tool_env, tool_printenv}
use os.tools.shell.mktemp.mktemp_tool.{tool_mktemp}

# File inspection
use os.tools.shell.diff.diff_tool.{tool_diff}
use os.tools.shell.patch.patch_tool.{tool_patch}
use os.tools.shell.file.file_tool.{tool_file}
use os.tools.shell.strings.strings_tool.{tool_strings}
use os.tools.shell.hexdump.hexdump_tool.{tool_hexdump}
use os.tools.shell.base64.base64_tool.{tool_base64}
use os.tools.shell.checksum.checksum_tool.{tool_md5sum, tool_sha256sum}

# Registration
use os.tools.shell.register_tools.{register_shell_tools}
