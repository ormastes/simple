# tr — Translate or delete characters
# MDSOC: feature dimension, shell layer

use os.apps.terminal.terminal.{Terminal}
use os.services.vfs.vfs.{VfsManager}
use os.tools.shell.shell_helpers.{resolve_path, write_line, write_error}

fn tool_tr(vfs: VfsManager?, cwd: text, args: [text], terminal: Terminal) -> i32:
    """Translate or delete characters from file content.

    Usage: tr SET1 SET2 FILE     (translate SET1 chars to SET2)
           tr -d SET1 FILE       (delete SET1 chars)
           tr -s SET1 FILE       (squeeze repeated SET1 chars)
    """
    var delete_mode = false
    var squeeze_mode = false
    var positional: [text] = []

    for arg in args:
        if arg == "-d":
            delete_mode = true
        elif arg == "-s":
            squeeze_mode = true
        else:
            positional = positional.push(arg)

    if delete_mode:
        if positional.len() < 2:
            write_error(terminal, "tr: missing operand")
            return 1
        val set1 = positional[0]
        val file_path = positional[1]
        return _tr_delete(vfs, cwd, set1, file_path, terminal)

    if squeeze_mode:
        if positional.len() < 2:
            write_error(terminal, "tr: missing operand")
            return 1
        val set1 = positional[0]
        val file_path = positional[1]
        return _tr_squeeze(vfs, cwd, set1, file_path, terminal)

    if positional.len() < 3:
        write_error(terminal, "tr: missing operand")
        return 1
    val set1 = positional[0]
    val set2 = positional[1]
    val file_path = positional[2]
    return _tr_translate(vfs, cwd, set1, set2, file_path, terminal)

fn _tr_translate(vfs: VfsManager?, cwd: text, set1: text, set2: text, file_path: text, terminal: Terminal) -> i32:
    """Translate characters in set1 to corresponding characters in set2."""
    if vfs == nil:
        write_error(terminal, "tr: no filesystem mounted")
        return 1
    val path = resolve_path(cwd, file_path)
    val result = vfs.read_text(path)
    if result.is_err():
        write_error(terminal, "tr: {path}: {result.unwrap_err()}")
        return 1
    val content = result.unwrap()
    var output = ""
    for ch in content:
        var replaced = false
        var j = 0
        for s1ch in set1:
            if ch == s1ch and j < set2.len():
                # Get character at position j in set2
                var k = 0
                for s2ch in set2:
                    if k == j:
                        output = "{output}{s2ch}"
                        replaced = true
                    k = k + 1
            j = j + 1
        if not replaced:
            output = "{output}{ch}"
    write_line(terminal, output)
    return 0

fn _tr_delete(vfs: VfsManager?, cwd: text, set1: text, file_path: text, terminal: Terminal) -> i32:
    """Delete characters in set1."""
    if vfs == nil:
        write_error(terminal, "tr: no filesystem mounted")
        return 1
    val path = resolve_path(cwd, file_path)
    val result = vfs.read_text(path)
    if result.is_err():
        write_error(terminal, "tr: {path}: {result.unwrap_err()}")
        return 1
    val content = result.unwrap()
    var output = ""
    for ch in content:
        var found = false
        for s1ch in set1:
            if ch == s1ch:
                found = true
        if not found:
            output = "{output}{ch}"
    write_line(terminal, output)
    return 0

fn _tr_squeeze(vfs: VfsManager?, cwd: text, set1: text, file_path: text, terminal: Terminal) -> i32:
    """Squeeze repeated characters in set1."""
    if vfs == nil:
        write_error(terminal, "tr: no filesystem mounted")
        return 1
    val path = resolve_path(cwd, file_path)
    val result = vfs.read_text(path)
    if result.is_err():
        write_error(terminal, "tr: {path}: {result.unwrap_err()}")
        return 1
    val content = result.unwrap()
    var output = ""
    var prev = ""
    for ch in content:
        var in_set = false
        for s1ch in set1:
            if ch == s1ch:
                in_set = true
        if in_set and ch == prev:
            pass_dn
        else:
            output = "{output}{ch}"
        prev = ch
    write_line(terminal, output)
    return 0
