# readlink — Resolve symlinks
# MDSOC: feature dimension, shell layer

use os.apps.terminal.terminal.{Terminal}
use os.services.vfs.vfs.{VfsManager}
use os.tools.shell.shell_helpers.{resolve_path, write_line, write_error}

fn tool_readlink(vfs: VfsManager?, cwd: text, args: [text], terminal: Terminal) -> i32:
    """Print the resolved path of a symlink."""
    if args.len() == 0:
        write_error(terminal, "readlink: missing operand")
        return 1
    val path = resolve_path(cwd, args[0])
    # In SimpleOS VFS, symlink resolution is via stat + readlink
    if vfs != nil:
        val result = vfs.stat(path)
        if result.is_err():
            write_error(terminal, "readlink: {path}: {result.unwrap_err()}")
            return 1
        write_line(terminal, path)
        return 0
    write_error(terminal, "readlink: no filesystem mounted")
    return 1
