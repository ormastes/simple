# seq — Print number sequence
# MDSOC: feature dimension, shell layer

use os.apps.terminal.terminal.{Terminal}
use os.tools.shell.shell_helpers.{write_line, write_error}

fn tool_seq(args: [text], terminal: Terminal) -> i32:
    """Print a sequence of numbers. Usage: seq [FIRST] LAST or seq FIRST INCREMENT LAST."""
    if args.len() == 0:
        write_error(terminal, "seq: missing operand")
        return 1

    var first: i64 = 1
    var increment: i64 = 1
    var last: i64 = 0

    if args.len() == 1:
        last = _parse_i64(args[0])
    elif args.len() == 2:
        first = _parse_i64(args[0])
        last = _parse_i64(args[1])
    else:
        first = _parse_i64(args[0])
        increment = _parse_i64(args[1])
        last = _parse_i64(args[2])

    if increment == 0:
        write_error(terminal, "seq: zero increment")
        return 1

    var current = first
    if increment > 0:
        while current <= last:
            write_line(terminal, "{current}")
            current = current + increment
    else:
        while current >= last:
            write_line(terminal, "{current}")
            current = current + increment
    return 0

fn _parse_i64(s: text) -> i64:
    """Parse text to i64, returns 0 on failure."""
    var result: i64 = 0
    var neg = false
    var started = false
    for ch in s:
        if ch == "-" and not started:
            neg = true
            started = true
        elif ch >= "0" and ch <= "9":
            result = result * 10 + (ch.to_i32() - "0".to_i32())
            started = true
        else:
            return 0
    if neg:
        return -result
    return result
