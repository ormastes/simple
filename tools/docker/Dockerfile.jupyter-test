# Dockerfile for Simple Language Jupyter Kernel E2E Testing
#
# Runs a real Jupyter notebook server inside the container, starts a Simple
# kernel, executes hello-world cells via HTTP/ZMQ, and verifies output.
#
# Build:
#   docker build -t simple-jupyter-test:latest -f tools/docker/Dockerfile.jupyter-test .
#
# Run:
#   docker run --rm simple-jupyter-test:latest
#
# What happens inside:
#   1. Jupyter notebook server starts on localhost:18889
#   2. Simple kernel is registered in JUPYTER_DATA_DIR
#   3. test/system/jupyter/helpers/run_server_check.py executes:
#      - GET /api/status
#      - GET /api/kernelspecs (verify "simple" listed)
#      - POST /api/sessions (start Simple kernel)
#      - Execute `print "Hello from Simple!"` via jupyter_client ZMQ
#      - Verify output contains "Hello from Simple!"
#      - Execute `val x = 42\nprint x`, verify output "42"
#   4. Exit 0 if all checks pass

FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

# System packages
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 \
    python3-pip \
    python3-venv \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Python venv + Jupyter packages
# 'notebook' pulls in jupyter_server, jupyter_client, nbconvert, etc.
RUN python3 -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

RUN pip install --no-cache-dir \
    notebook \
    jupyter_client \
    nbconvert \
    ipykernel \
    pyzmq

# Non-root test user
RUN useradd -m -u 1001 testuser

WORKDIR /workspace

# Copy Simple binary
COPY bin/release/simple /usr/local/bin/simple
RUN chmod +x /usr/local/bin/simple

# Copy project source needed by kernel
COPY src/app/jupyter_kernel/ /workspace/src/app/jupyter_kernel/

# Copy kernel wrapper + install script
COPY tools/jupyter/ /workspace/tools/jupyter/

# Copy test files
COPY test/system/jupyter/ /workspace/test/system/jupyter/

# Copy notebook fixtures
COPY test/system/jupyter/fixtures/ /workspace/test/system/jupyter/fixtures/

# Make bin/ available (kernel_wrapper.py searches for bin/release/simple)
RUN mkdir -p /workspace/bin/release && \
    ln -s /usr/local/bin/simple /workspace/bin/release/simple

# Fix ownership
RUN chown -R testuser:testuser /workspace /home/testuser

USER testuser

# Healthcheck
HEALTHCHECK --interval=30s --timeout=5s --retries=3 \
    CMD simple --version && jupyter --version

# Run the E2E test: start server, execute cells, verify output
ENTRYPOINT ["python3"]
CMD ["test/system/jupyter/helpers/run_server_check.py"]
