# Test Isolation Container
#
# Provides a minimal, secure environment for running Simple compiler tests.
# Used by containerized-tests.yml and test-isolation.yml workflows.
#
# Build:  docker build -t simple-test-isolation -f tools/docker/Dockerfile.test-isolation .
# Run:    docker run --rm simple-test-isolation test test/unit/
#
# Security: runs as non-root, supports --read-only, --cap-drop=ALL

FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

# System packages needed by the Simple compiler and tests
RUN apt-get update && apt-get install -y --no-install-recommends \
    clang \
    lld \
    llvm \
    gcc \
    libc6-dev \
    libm-dev \
    binutils \
    make \
    qemu-user-static \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Create non-root user
RUN useradd -m -s /bin/bash testuser

WORKDIR /home/testuser/simple

# Copy the compiled Simple binary
COPY bin/release/simple bin/release/simple
RUN chmod +x bin/release/simple

# Copy source (needed for compilation tests and test runner)
COPY src/ src/
COPY test/ test/

# Copy runtime library if present
COPY src/runtime/ src/runtime/

# Ensure testuser owns everything
RUN chown -R testuser:testuser /home/testuser/simple

# Create writable directories for build artifacts
RUN mkdir -p /tmp/simple-build && chown testuser:testuser /tmp/simple-build

USER testuser

# Default: show version. Override with test commands.
ENTRYPOINT ["bin/release/simple"]
CMD ["--version"]
