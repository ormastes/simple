FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

# Minimal deps for running the Simple binary
RUN apt-get update && apt-get install -y \
    ca-certificates \
    libstdc++6 \
    && rm -rf /var/lib/apt/lists/*

# Create non-root user
RUN groupadd -g 1001 testuser && \
    useradd -u 1001 -g 1001 -m -s /bin/bash testuser

# Copy the Simple binary
COPY bin/release/linux-x86_64/simple /usr/local/bin/simple
RUN chmod +x /usr/local/bin/simple

# Working directory
WORKDIR /workspace

# Default to non-root
USER testuser

# Verify binary works
RUN simple --version

ENTRYPOINT ["simple"]
CMD ["test"]
