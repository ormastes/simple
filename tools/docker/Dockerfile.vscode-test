# VSCode Extension Test Environment
#
# Headless container for running VSCode extension tests.
# Provides Xvfb + Electron dependencies for headless GUI testing.
#
# Build: docker build -t simple-vscode-test -f tools/docker/Dockerfile.vscode-test .
# Run:   docker run --rm simple-vscode-test

FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

# System dependencies for Electron/VSCode
RUN apt-get update && apt-get install -y \
    curl \
    git \
    xvfb \
    dbus \
    dbus-x11 \
    libgtk-3-0 \
    libgbm1 \
    libnss3 \
    libxss1 \
    libasound2t64 \
    libx11-xcb1 \
    libxcb-dri3-0 \
    libdrm2 \
    libatk1.0-0 \
    libatk-bridge2.0-0 \
    libatspi2.0-0 \
    libcups2 \
    libxcomposite1 \
    libxdamage1 \
    libxrandr2 \
    libpango-1.0-0 \
    fonts-liberation \
    xdg-utils \
    && rm -rf /var/lib/apt/lists/*

# Node.js 20 LTS
RUN curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace

# Copy extension source
COPY src/app/vscode_extension/package*.json ./src/app/vscode_extension/
RUN cd src/app/vscode_extension && npm ci

COPY src/app/vscode_extension/ ./src/app/vscode_extension/

# Environment for headless testing
ENV DISPLAY=:99
ENV DBUS_SESSION_BUS_ADDRESS=autolaunch:

ENTRYPOINT ["xvfb-run", "--auto-servernum", "--server-args=-screen 0 1024x768x24"]
CMD ["sh", "-c", "cd src/app/vscode_extension && npm test"]
