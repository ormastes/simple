#!/usr/bin/env bash
# jira — Atlassian Jira + Confluence CLI
# Mirrors the GitHub CLI (gh) interface for Jira Cloud and Confluence.
#
# Usage: jira <command> [subcommand] [flags]
#
# CORE COMMANDS
#   auth       Authenticate with Atlassian Cloud
#   issue      Work with Jira issues
#   project    Work with Jira projects
#   sprint     Work with Jira sprints
#   wiki       Work with Confluence wiki pages
#   api        Make authenticated Atlassian API requests
#   me         Show current user info
#
# ADDITIONAL COMMANDS
#   config     Manage configuration
#   version    Show version info
#   help       Show help

set -euo pipefail

VERSION="0.1.0"

# Resolve script directory (follow symlinks)
SELF="$0"
while [ -L "$SELF" ]; do
  DIR="$(cd "$(dirname "$SELF")" && pwd)"
  SELF="$(readlink "$SELF")"
  case "$SELF" in /*) ;; *) SELF="${DIR}/${SELF}" ;; esac
done
BIN_DIR="$(cd "$(dirname "$SELF")" && pwd)"
LIB_DIR="$(cd "${BIN_DIR}/../lib" && pwd)"

# Source library modules
. "${LIB_DIR}/config.shs"
. "${LIB_DIR}/api.shs"
. "${LIB_DIR}/auth.shs"
. "${LIB_DIR}/issue.shs"
. "${LIB_DIR}/project.shs"
. "${LIB_DIR}/sprint.shs"
. "${LIB_DIR}/wiki.shs"

# Check dependencies
check_deps() {
  for cmd in curl jq; do
    if ! command -v "$cmd" >/dev/null 2>&1; then
      echo "error: '${cmd}' is required but not installed." >&2
      case "$cmd" in
        curl) echo "  Install: brew install curl" >&2 ;;
        jq)   echo "  Install: brew install jq" >&2 ;;
      esac
      exit 1
    fi
  done
}

# Main dispatch
cmd_me() {
  jira_load_auth || return 1
  local auth_val
  auth_val=$(jira_auth_header)
  local response
  response=$(curl -s \
    -H "Authorization: Basic ${auth_val}" \
    -H "Accept: application/json" \
    "${JIRA_SERVER}/rest/api/3/myself" 2>/dev/null)

  echo "$response" | jq -r '
    "Account:  \(.displayName)",
    "Email:    \(.emailAddress)",
    "ID:       \(.accountId)",
    "Active:   \(.active)",
    "Timezone: \(.timeZone // "N/A")"'
}

cmd_config() {
  local subcmd="${1:-}"
  shift 2>/dev/null || true

  case "$subcmd" in
    set)
      if [ $# -lt 2 ]; then
        echo "Usage: jira config set <key> <value>" >&2; return 1
      fi
      jira_config_set "$1" "$2"
      echo "✓ Set ${1} = ${2}"
      ;;
    get)
      if [ $# -lt 1 ]; then
        echo "Usage: jira config get <key>" >&2; return 1
      fi
      jira_config_get "$1"
      ;;
    list)
      jira_config_list
      ;;
    *)
      echo "Manage jira-cli configuration"
      echo ""
      echo "USAGE"
      echo "  jira config <command>"
      echo ""
      echo "COMMANDS"
      echo "  set <key> <value>   Set a config value"
      echo "  get <key>           Get a config value"
      echo "  list                List all config values"
      ;;
  esac
}

cmd_version() {
  echo "jira-cli version ${VERSION} (Simple Language Project)"
  echo "  Config: ${CONFIG_FILE}"
  echo "  Lib:    ${LIB_DIR}"
}

cmd_help() {
  echo "jira — Atlassian Jira + Confluence CLI"
  echo "Mirrors the GitHub CLI (gh) interface."
  echo ""
  echo "USAGE"
  echo "  jira <command> [subcommand] [flags]"
  echo ""
  echo "CORE COMMANDS"
  echo "  auth       Authenticate with Atlassian Cloud"
  echo "  issue      Work with Jira issues"
  echo "  project    Work with Jira projects"
  echo "  sprint     Work with Jira sprints"
  echo "  wiki       Work with Confluence wiki pages"
  echo ""
  echo "UTILITY COMMANDS"
  echo "  api        Make authenticated Atlassian API requests"
  echo "  me         Show current user info"
  echo "  config     Manage configuration"
  echo "  version    Show version info"
  echo "  help       Show this help"
  echo ""
  echo "EXAMPLES"
  echo "  jira auth login                         # Log in to Atlassian"
  echo "  jira auth status                        # Check auth status"
  echo "  jira issue list                         # List issues"
  echo "  jira issue create -t Story -s 'Title'   # Create issue"
  echo "  jira issue view PROJ-123                # View issue"
  echo "  jira issue comment PROJ-123 -b 'text'   # Add comment"
  echo "  jira issue move PROJ-123 'In Progress'  # Transition issue"
  echo "  jira wiki create -t 'Page' -b 'body'    # Create wiki page"
  echo "  jira wiki list                          # List wiki pages"
  echo "  jira api issue/PROJ-123                 # Raw API call"
  echo "  jira api issue/PROJ-123 --jq .fields.summary"
  echo ""
  echo "CONFIG"
  echo "  Credentials: ~/.config/jira-cli/config.json"
  echo "  Env overrides: JIRA_SERVER_OVERRIDE, JIRA_EMAIL_OVERRIDE, JIRA_TOKEN_OVERRIDE"
  echo ""
  echo "LEARN MORE"
  echo "  Jira REST API:       https://developer.atlassian.com/cloud/jira/platform/rest/v3/"
  echo "  Confluence REST API: https://developer.atlassian.com/cloud/confluence/rest/v2/"
}

# Main entry point
main() {
  check_deps

  local command="${1:-help}"
  shift 2>/dev/null || true

  case "$command" in
    auth)     cmd_auth "$@" ;;
    issue)    cmd_issue "$@" ;;
    project)  cmd_project "$@" ;;
    sprint)   cmd_sprint "$@" ;;
    wiki)     cmd_wiki "$@" ;;
    api)      jira_api "$@" ;;
    me)       cmd_me "$@" ;;
    config)   cmd_config "$@" ;;
    version|--version|-v)  cmd_version ;;
    help|--help|-h)        cmd_help ;;
    *)
      echo "error: unknown command '${command}'" >&2
      echo "Run 'jira help' for usage." >&2
      exit 1
      ;;
  esac
}

main "$@"
