# Benchmark Data Generator
#
# Generate test corpus files for tool benchmarks.

use app.io.mod (file_write, dir_create_all, file_exists)

fn generate_line(n: i64) -> text:
    """Generate a deterministic text line."""
    val words = ["the", "quick", "brown", "fox", "jumps", "over", "lazy", "dog", "simple", "language"]
    var line = ""
    var i = 0
    while i < 8:
        val idx = (n + i) % words.len()
        if i > 0:
            line = line + " "
        line = line + words[idx]
        i = i + 1
    line

fn generate_file(path: text, num_lines: i64):
    """Generate a test file with given number of lines."""
    var content = ""
    var i = 0
    while i < num_lines:
        content = content + generate_line(i) + "\n"
        i = i + 1
    file_write(path, content)
    print "Generated {path} ({num_lines} lines)"

fn main() -> i64:
    dir_create_all("test/benchmarks/tools/data")

    # ~1KB file (~15 lines)
    generate_file("test/benchmarks/tools/data/small.txt", 15)

    # ~100KB file (~1500 lines)
    generate_file("test/benchmarks/tools/data/medium.txt", 1500)

    # ~10MB file (~150000 lines)
    generate_file("test/benchmarks/tools/data/large.txt", 150000)

    print ""
    print "Benchmark data generated."
    0
