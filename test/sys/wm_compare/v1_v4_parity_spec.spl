#![allow(unnamed_duplicate_typed_args)]
# @tag: sys, wm_compare, parity, v1, v4, electron
# @cover src/app/wm_compare/v1_v2_parity.spl 0%
# @cover src/os/compositor/electron_capture.spl 0%
#
# wm_compare V1/V4 Parity — Row 6 of the GUI drawing-layer matrix
#
# Locks the contract that the same drawing scene rendered through V1
# (`FramebufferDriver.from_buffer`, the fb_backend code path) and V4 (the
# Electron dev-preview reference pipeline — `electron_capture` forwarding
# to `BrowserCompositorBackend` via `render_scene_to_backend`) stays
# within the ≤1% perceptual budget that Row 2 already locked for V1/V2.
#
# Scenes are the exact `ParityScene` set Row 2 uses — scene_solid_fill,
# scene_fill_rect_row_edge, scene_text_with_bg, scene_glass_blend — so a
# failing spec is guaranteed to be a real V1↔V4 divergence, not a new
# scene pulling V4 off its baseline.
#
# V4 is dev-preview-only per
# `doc/01_research/domain/v4_electron_packaging_2026-04-14.md`: no live
# Electron runtime is spun up inside the interpreter. The V4 render path
# drives the same `BrowserCompositorBackend` trait surface that
# `electron_capture.capture_electron_scene` forwards to in production, so
# the ParityOp sequence reaches the exact compositor V4 would use.
#
# Plan: doc/03_plan/gui_drawing_layer_variations.md §Row 6

use std.spec.{describe, context, it, expect}
use app.wm_compare.v1_v2_parity.{
    run_parity_v4, render_v1, render_v4, diff_buffers,
    scene_solid_fill, scene_fill_rect_row_edge, scene_text_with_bg, scene_glass_blend,
}

describe "wm_compare V1/V4 parity (Row 6 — Electron dev-preview reference)":

    context "solid fill — V4 Electron reference clear() matches fb_driver":

        it "stays within the ≤1% perceptual budget":
            val r = run_parity_v4(scene_solid_fill())
            expect(r.pass_perceptual).to_be_true()

    context "fill_rect row edge — exercises [x,x+w) half-open contract on V4":

        it "stays within the ≤1% perceptual budget":
            val r = run_parity_v4(scene_fill_rect_row_edge())
            expect(r.pass_perceptual).to_be_true()

    context "text + bg — V4 Electron reference draw_char_8x16 bg cells":

        it "stays within the ≤1% perceptual budget":
            val r = run_parity_v4(scene_text_with_bg())
            expect(r.pass_perceptual).to_be_true()

    context "glass blend — CompositorGlassCapable.blend_rect on V4":

        it "stays within the ≤1% perceptual budget":
            val r = run_parity_v4(scene_glass_blend())
            expect(r.pass_perceptual).to_be_true()

    context "V4 render harness self-check":

        it "returns a buffer of the expected length":
            val v4 = render_v4(scene_solid_fill())
            expect(v4.len() == 32 * 16).to_be_true()

        it "diffs identical V4 buffers as exact":
            val a = render_v4(scene_solid_fill())
            val b = render_v4(scene_solid_fill())
            val r = diff_buffers("v4_self_check", 32u32, 16u32, a, b)
            expect(r.pass_exact).to_be_true()
