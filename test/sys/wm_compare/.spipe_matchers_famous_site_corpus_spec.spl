        it "summarizes all corpus comparison reports for target selection":
            val samples = build_famous_site_sample_corpus()
            val expected_stale = _stale_report_count(samples, 10000)
            val tool_path = "tools/electron-shell/summarize_famous_site_corpus_reports.js"
            expect rt_file_exists(tool_path) == true
            val result = rt_process_run_timeout("node", [tool_path, "--limit=3"], 10000)
            expect result.2 == 0
            expect (result.0).contains("\"reportCount\": 132")
            expect (result.0).contains("\"exact\": 0")
            expect (result.0).contains("\"accepted\": 0")
            expect (result.0).contains("\"divergent\": 132")
            expect (result.0).contains("\"staleSuspectThreshold\": 10000")
            expect (result.0).contains("\"staleSuspectCount\": " + expected_stale.to_string())
            expect expected_stale == 0
            expect (result.0).contains("\"staleSuspects\": []")
