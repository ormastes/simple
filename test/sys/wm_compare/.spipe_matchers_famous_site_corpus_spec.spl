# @tag: sys, wm_compare, html_compat, corpus

use std.spec.{describe, context, it, expect}
use app.wm_compare.site_corpus.{build_famous_site_sample_corpus}
use std.gc_async_mut.gpu.browser_engine.simple_web_renderer.{simple_web_render_html_to_pixels}

fn _count_non_white(pixels: [u32]) -> i32:
    var count: i32 = 0
    var idx: i32 = 0
    while idx < pixels.len():
        if pixels[idx] != 0xFFFFFFFF:
            count = count + 1
        idx = idx + 1
    count

describe "famous-site renderer compatibility corpus":

    context "offline sample manifest":

        it "contains more than 100 deterministic site-inspired pages":
            val samples = build_famous_site_sample_corpus()
            expect samples.len() > 100

        it "uses complete HTML documents with stable ids":
            val samples = build_famous_site_sample_corpus()
            expect (samples[0].id).starts_with("site_0_")
            expect (samples[0].html).starts_with("<html>")
            expect (samples[0].html).contains("</html>")
            expect (samples[0].html).contains("Deterministic compatibility fixture")

    context "Simple Web Renderer smoke coverage":

        it "renders representative corpus pages to non-empty pixels":
            val samples = build_famous_site_sample_corpus()
            val first = simple_web_render_html_to_pixels(samples[0].html, 160, 120)
            val last = simple_web_render_html_to_pixels(samples[samples.len() - 1].html, 160, 120)
            expect first.len() == 160 * 120
            expect last.len() == 160 * 120
            expect _count_non_white(first) > 0
            expect _count_non_white(last) > 0