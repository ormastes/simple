# @tag: sys, wm_compare, html_compat, corpus

use std.spec.{describe, context, it, expect}
use app.wm_compare.site_corpus.{
    build_famous_site_sample_corpus, build_famous_site_sample_manifest_sdn,
    famous_site_font_families,
    famous_site_sample_html_path, famous_site_sample_baseline_dir,
    famous_site_sample_chrome_ppm_path, famous_site_sample_chrome_metrics_path,
    famous_site_sample_simple_ppm_path, famous_site_sample_report_sdn_path}
use app.wm_compare.site_corpus_compat.{parse_site_corpus_compat_opts}
use std.gc_async_mut.gpu.browser_engine.simple_web_renderer.{SimpleWebRenderer, simple_web_render_html_to_pixels}
use std.gc_async_mut.gpu.browser_engine.browser_renderer.{
    br_famous_site_corpus_layout_lines, br_famous_site_corpus_layout_line_widths_sdn,
    br_famous_site_corpus_layout_lines_sdn}

extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_read_bytes(path: text) -> [u8]?
extern fn rt_process_run_timeout(cmd: text, args: [text], timeout_ms: i64) -> (text, text, i32)

fn _count_non_white(pixels: [u32]) -> i32:
    var count: i32 = 0
    var idx: i32 = 0
    while idx < pixels.len():
        if pixels[idx] != 0xFFFFFFFF:
            count = count + 1
        idx = idx + 1
    count

fn _count_gray_non_white_from_y(pixels: [u32], width: i32, start_y: i32) -> i32:
    var count: i32 = 0
    var idx: i32 = 0
    while idx < pixels.len():
        val y = idx / width
        if y >= start_y:
            val pixel = pixels[idx]
            val r = (pixel >> 16) & 0xFF
            val g = (pixel >> 8) & 0xFF
            val b = pixel & 0xFF
            if r == g and g == b and r < 255:
                count = count + 1
        idx = idx + 1
    count

fn _pixels_equal(a: [u32], b: [u32]) -> bool:
    if a.len() != b.len():
        return false
    var idx: i32 = 0
    while idx < a.len():
        if a[idx] != b[idx]:
            return false
        idx = idx + 1
    true

fn _load_p6_ppm_pixels(path: text, width: i32, height: i32) -> [u32]:
    val data = rt_file_read_bytes(path) ?? []
    val header_len = 15
    val expected_len = header_len + width * height * 3
    if data.len() < expected_len:
        return []
    if data[0] != 80u8 or data[1] != 54u8 or data[2] != 10u8:
        return []
    var pixels: [u32] = []
    var idx = header_len
    while idx + 2 < expected_len:
        val r = data[idx].to_u32()
        val g = data[idx + 1].to_u32()
        val b = data[idx + 2].to_u32()
        pixels.push(0xFF000000u32 | (r << 16) | (g << 8) | b)
        idx = idx + 3
    pixels

fn _has_duplicate_ids(samples) -> bool:
    var i: i32 = 0
    while i < samples.len():
        var j: i32 = i + 1
        while j < samples.len():
            if samples[i].id == samples[j].id:
                return true
            j = j + 1
        i = i + 1
    false

fn _has_category(samples, category: text) -> bool:
    for sample in samples:
        if sample.category == category:
            return true
    false

fn _all_fixture_files_exist(samples) -> bool:
    for sample in samples:
        if not rt_file_exists(famous_site_sample_html_path(sample.id)):
            return false
    true

fn _all_fixture_html_matches(samples) -> bool:
    for sample in samples:
        if rt_file_read_text(famous_site_sample_html_path(sample.id)) != sample.html:
            return false
    true

fn _all_baseline_artifacts_exist(samples) -> bool:
    for sample in samples:
        if not rt_file_exists(famous_site_sample_chrome_ppm_path(sample.id)):
            return false
        if not _ppm_file_has_header_and_payload(famous_site_sample_chrome_ppm_path(sample.id)):
            return false
        if not rt_file_exists(famous_site_sample_chrome_metrics_path(sample.id)):
            return false
        if not rt_file_exists(famous_site_sample_simple_ppm_path(sample.id)):
            return false
        if not _ppm_file_has_header_and_payload(famous_site_sample_simple_ppm_path(sample.id)):
            return false
        if not rt_file_exists(famous_site_sample_report_sdn_path(sample.id)):
            return false
    true

fn _ppm_file_has_header_and_payload(path: text) -> bool:
    val bytes = rt_file_read_bytes(path) ?? []
    if bytes.len() < 16:
        return false
    val is_p6 = bytes[0] == 80u8 and bytes[1] == 54u8
    val is_p3 = bytes[0] == 80u8 and bytes[1] == 51u8
    if not is_p6 and not is_p3:
        return false
    var newline_count = 0
    var idx = 0
    while idx < bytes.len() and idx < 128:
        if bytes[idx] == 10u8:
            newline_count = newline_count + 1
        idx = idx + 1
    newline_count >= 3

fn _all_chrome_metrics_valid(samples) -> bool:
    for sample in samples:
        val path = famous_site_sample_chrome_metrics_path(sample.id)
        if not rt_file_exists(path):
            return false
        val metrics = rt_file_read_text(path)
        if not metrics.contains("\"sample\": \"" + sample.id + "\""):
            return false
        if not metrics.contains("\"width\": 160"):
            return false
        if not metrics.contains("\"height\": 120"):
            return false
        if not metrics.contains("\"body\""):
            return false
        if not metrics.contains("\"div\""):
            return false
        if not metrics.contains("\"fontFamily\""):
            return false
        if not metrics.contains(_font_family_metric_anchor(sample.font_family)):
            return false
        if not metrics.contains("\"fontSize\": \"16px\""):
            return false
        if not metrics.contains("\"textClientRects\""):
            return false
        if not metrics.contains("\"textLines\""):
            return false
        if not metrics.contains("\"canvasTextMetrics\""):
            return false
        if not metrics.contains("\"actualBoundingBoxAscent\""):
            return false
        if not metrics.contains("deterministic compatibility fixture"):
            return false
    true

fn _font_family_metric_anchor(font_family: text) -> text:
    val comma_idx = font_family.index_of(",")
    val first = if comma_idx == -1: font_family else: font_family.substring(0, comma_idx)
    first.replace("\"", "")

fn _all_samples_render_non_empty(samples) -> bool:
    for sample in samples:
        val pixels = simple_web_render_html_to_pixels(sample.html, 40, 30)
        if pixels.len() != 40 * 30:
            return false
        if _count_non_white(pixels) == 0:
            return false
    true

fn _first_simple_layout_line_missing_from_chrome_metrics(samples, layout_width: i32) -> text:
    for sample in samples:
        val metrics_path = famous_site_sample_chrome_metrics_path(sample.id)
        if not rt_file_exists(metrics_path):
            return sample.id + ": missing metrics"
        val metrics = rt_file_read_text(metrics_path)
        val simple_lines = br_famous_site_corpus_layout_lines(sample.html, 16, layout_width)
        if simple_lines.len() == 0:
            return sample.id + ": no Simple lines"
        for line in simple_lines:
            if not metrics.contains("\"text\": \"" + line + "\""):
                return sample.id + ": missing line " + line
    ""

fn _report_different_pixels(report: text) -> i64:
    val marker = "different_pixels: "
    val idx = report.index_of(marker)
    if idx == -1:
        return 0
    val rest = report.substring(idx + marker.len())
    var end = 0
    while end < rest.len():
        val c = rest.char_at(end)
        if c < "0" or c > "9":
            break
        end = end + 1
    if end == 0:
        return 0
    rest.substring(0, end).parse_int() ?? 0

fn _stale_report_count(samples, threshold: i64) -> i32:
    var count = 0
    for sample in samples:
        val path = famous_site_sample_report_sdn_path(sample.id)
        if not rt_file_exists(path):
            count = count + 1
        elif _report_different_pixels(rt_file_read_text(path) ?? "") > threshold:
            count = count + 1
    count

describe "famous-site renderer compatibility corpus":

    context "offline sample manifest":

        it "contains more than 100 deterministic site-inspired pages":
            val samples = build_famous_site_sample_corpus()
            expect samples.len() > 100

        it "uses complete HTML documents with stable ids":
            val samples = build_famous_site_sample_corpus()
            expect (samples[0].id).starts_with("site_0_")
            expect (samples[0].html).starts_with("<html>")
            expect (samples[0].html).contains("</html>")
            expect (samples[0].html).contains("Deterministic compatibility fixture")
            expect (samples[0].html).contains("data-font-corpus=\"known-site-fonts\"")
            expect (samples[0].html).contains("font-family: " + samples[0].font_family)

        it "covers a deterministic common-site font stack matrix":
            val fonts = famous_site_font_families()
            val samples = build_famous_site_sample_corpus()
            expect fonts.len() > 20
            expect samples[0].font_family == fonts[0]
            expect samples[fonts.len()].font_family == fonts[0]
            expect (samples[fonts.len() - 1].html).contains("font-family: " + fonts[fonts.len() - 1])

        it "uses unique ids for every sample":
            val samples = build_famous_site_sample_corpus()
            expect _has_duplicate_ids(samples) == false

        it "covers the expected page categories":
            val samples = build_famous_site_sample_corpus()
            expect _has_category(samples, "search") == true
            expect _has_category(samples, "video") == true
            expect _has_category(samples, "social") == true
            expect _has_category(samples, "commerce") == true
            expect _has_category(samples, "news") == true
            expect _has_category(samples, "productivity") == true
            expect _has_category(samples, "finance") == true
            expect _has_category(samples, "travel") == true
            expect _has_category(samples, "education") == true
            expect _has_category(samples, "developer") == true
            expect _has_category(samples, "cloud") == true
            expect _has_category(samples, "media") == true

        it "exports a stable SDN manifest for future Chrome oracle jobs":
            val samples = build_famous_site_sample_corpus()
            val manifest = build_famous_site_sample_manifest_sdn()
            expect (manifest).starts_with("(famous_site_sample_corpus")
            expect (manifest).contains("count: " + samples.len().to_string())
            expect (manifest).contains("id: \"" + samples[0].id + "\"")
            expect (manifest).contains("id: \"" + samples[samples.len() - 1].id + "\"")
            expect (manifest).contains("font_family: \"" + samples[0].font_family + "\"")
            expect (manifest).contains("html_path: \"" + famous_site_sample_html_path(samples[0].id) + "\"")
            expect (manifest).contains("baseline_dir: \"" + famous_site_sample_baseline_dir(samples[0].id) + "\"")
            expect (manifest).contains("chrome_ppm: \"" + famous_site_sample_chrome_ppm_path(samples[0].id) + "\"")
            expect (manifest).contains("chrome_metrics: \"" + famous_site_sample_chrome_metrics_path(samples[0].id) + "\"")
            expect (manifest).contains("simple_ppm: \"" + famous_site_sample_simple_ppm_path(samples[0].id) + "\"")
            expect (manifest).contains("report_sdn: \"" + famous_site_sample_report_sdn_path(samples[0].id) + "\"")

        it "uses deterministic future artifact paths":
            val samples = build_famous_site_sample_corpus()
            expect (famous_site_sample_html_path(samples[0].id)).starts_with("test/fixtures/famous_site_corpus/")
            expect (famous_site_sample_html_path(samples[0].id)).ends_with(".html")
            expect (famous_site_sample_baseline_dir(samples[0].id)).starts_with("test/baselines/famous_site_corpus/")
            expect (famous_site_sample_chrome_ppm_path(samples[0].id)).ends_with("/chrome.ppm")
            expect (famous_site_sample_chrome_metrics_path(samples[0].id)).ends_with("/chrome_metrics.json")
            expect (famous_site_sample_simple_ppm_path(samples[0].id)).ends_with("/simple.ppm")
            expect (famous_site_sample_report_sdn_path(samples[0].id)).ends_with("/report.sdn")

        it "has every exported HTML fixture and manifest on disk":
            val samples = build_famous_site_sample_corpus()
            expect rt_file_exists("test/fixtures/famous_site_corpus/manifest.sdn") == true
            expect _all_fixture_files_exist(samples) == true
            expect _all_fixture_html_matches(samples) == true
            expect rt_file_read_text("test/fixtures/famous_site_corpus/manifest.sdn") == build_famous_site_sample_manifest_sdn()

        it "has every Chrome baseline, Simple capture, and comparison report on disk":
            val samples = build_famous_site_sample_corpus()
            expect _all_baseline_artifacts_exist(samples) == true

        it "has valid Chrome DOM metrics for every oracle sample":
            val samples = build_famous_site_sample_corpus()
            expect _all_chrome_metrics_valid(samples) == true

        it "has focused Chrome DOM metrics for the first failing oracle sample":
            val metrics_path = famous_site_sample_chrome_metrics_path("site_0_google")
            expect rt_file_exists(metrics_path) == true
            val metrics = rt_file_read_text(metrics_path)
            expect (metrics).contains("\"fontFamily\": \"\\\"Times New Roman\\\"\"")
            expect (metrics).contains("\"marginTop\": \"8px\"")
            expect (metrics).contains("\"textClientRects\"")
            expect (metrics).contains("\"width\": 91.96875")
            expect (metrics).contains("\"textLines\"")
            expect (metrics).contains("\"text\": \"Google search\"")
            expect (metrics).contains("\"text\": \"deterministic\"")
            expect (metrics).contains("\"text\": \"compatibility\"")
            expect (metrics).contains("\"text\": \"fixture\"")
            expect (metrics).contains("\"canvasTextMetrics\"")
            expect (metrics).contains("\"actualBoundingBoxAscent\": 12")
            expect (metrics).contains("\"fontBoundingBoxAscent\": 14")

        it "renders the first corpus page through the bounded child worker":
            val result = rt_process_run_timeout("bin/simple", [
                "run",
                "src/app/wm_compare/simple_html_capture_worker.spl",
                "--html=test/fixtures/famous_site_corpus/site_0_google.html",
                "--out=/tmp/famous_site_worker_google.ppm",
                "--width=160",
                "--height=120"
            ], 20000)
            expect result.2 == 0
            expect (result.0).contains("wrote /tmp/famous_site_worker_google.ppm pixels=19200")
            expect rt_file_exists("/tmp/famous_site_worker_google.ppm") == true

