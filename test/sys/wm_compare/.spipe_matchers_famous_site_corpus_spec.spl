    context "Simple Web Renderer smoke coverage":

        it "renders every corpus page to non-empty pixels":
            val samples = build_famous_site_sample_corpus()
            expect _all_samples_render_non_empty(samples) == true

        it "keeps the normal system font corpus capture pixel-aligned with Chrome":
            val sample = build_famous_site_sample_corpus()[0]
            val pixels = simple_web_render_html_to_pixels(sample.html, 160, 120)
            val chrome = _load_p6_ppm_pixels(famous_site_sample_chrome_ppm_path(sample.id), 160, 120)
            expect chrome.len() == 160 * 120
            expect _pixels_equal(pixels, chrome) == true

        it "exposes Simple wrapped text lines for Chrome TextMetrics comparison":
            val sample = build_famous_site_sample_corpus()[0]
            val lines = br_famous_site_corpus_layout_lines_sdn(sample.html, 16, 120)
            expect (lines).contains("count: 4")
            expect (lines).contains("text: \"Google search\"")
            expect (lines).contains("text: \"deterministic\"")
            expect (lines).contains("text: \"compatibility\"")
            expect (lines).contains("text: \"fixture\"")

        it "documents the first mixed-font wrapped-line boundary":
            val samples = build_famous_site_sample_corpus()
            expect _first_simple_layout_line_missing_from_chrome_metrics(samples, 122) == "site_25_google_calendar: missing line Google Calendar"

        it "exposes Simple wrapped line widths for the old boundary mismatch":
            val sample = build_famous_site_sample_corpus()[28]
            expect sample.id == "site_28_google_translate"
            val widths = br_famous_site_corpus_layout_line_widths_sdn(sample.html, 16, 120)
            expect (widths).contains("text: \"Google\"")
            expect (widths).contains("text: \"Translate news\"")
            expect (widths).contains("width:")
            expect (widths).contains("count: 5")

        it "keeps Engine2D software backend deterministic for corpus pages":
            val sample = build_famous_site_sample_corpus()[0]
            val default_pixels = simple_web_render_html_to_pixels(sample.html, 160, 120)
            val engine_renderer = SimpleWebRenderer.create_with_backend(160, 120, "software")
            val engine_pixels = engine_renderer.render_html_to_pixels(sample.html)
            expect engine_renderer.backend_name == "software"
            expect engine_pixels.len() == 160 * 120
            expect _pixels_equal(default_pixels, engine_pixels) == true

    context "Chrome oracle runner options":

        it "defaults to the corpus screenshot viewport":
            val opts = parse_site_corpus_compat_opts([])
            expect opts.width == 160
            expect opts.height == 120
            expect opts.limit == 0
            expect opts.from_id == ""
            expect opts.simple_timeout_ms == 60000
            expect opts.update_baseline == false
            expect opts.skip_simple_watchdog == false

        it "parses bounded corpus comparison options":
            val opts = parse_site_corpus_compat_opts([
                "--only=site_0_google",
                "--from=site_28_google_translate",
                "--limit=1",
                "--width=200",
                "--height=150",
                "--simple-timeout-ms=3210",
                "--update-baseline",
                "--skip-simple",
                "--skip-simple-watchdog",
                "--stale-only",
                "--continue-on-fail"
            ])
            expect opts.only == "site_0_google"
            expect opts.from_id == "site_28_google_translate"
            expect opts.limit == 1
            expect opts.width == 200
            expect opts.height == 150
            expect opts.simple_timeout_ms == 3210
            expect opts.update_baseline == true
            expect opts.skip_simple == true
            expect opts.skip_simple_watchdog == true
            expect opts.stale_only == true
            expect opts.continue_on_fail == true