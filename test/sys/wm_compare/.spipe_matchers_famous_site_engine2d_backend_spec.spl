# @tag: sys, wm_compare, html_compat, corpus, engine2d

use std.spec.{describe, it, expect}
use app.wm_compare.html_compat.{compare_exact}
use app.wm_compare.site_corpus.{build_famous_site_sample_corpus}
use std.gc_async_mut.gpu.browser_engine.simple_web_renderer.{SimpleWebRenderer, simple_web_render_html_to_pixels}

fn _engine_backend_matches_default_for_sample(sample, width: i32, height: i32) -> bool:
    val default_pixels = simple_web_render_html_to_pixels(sample.html, width, height)
    val engine_renderer = SimpleWebRenderer.create_with_backend(width, height, "software")
    val engine_pixels = engine_renderer.render_html_to_pixels(sample.html)
    if engine_renderer.backend_name != "software":
        return false
    if engine_pixels.len() != width * height:
        return false
    val cmp = compare_exact(default_pixels, engine_pixels, width, height)
    cmp.different_pixels == 0 and cmp.match_percentage == 10000

fn _all_engine_backend_samples_match_default(width: i32, height: i32) -> bool:
    val samples = build_famous_site_sample_corpus()
    for sample in samples:
        if not _engine_backend_matches_default_for_sample(sample, width, height):
            return false
    true

describe "famous-site Engine2D backend coverage":

    it "matches default Simple Web Renderer pixels for every corpus page":
        expect _all_engine_backend_samples_match_default(40, 30) == true

    it "matches default Simple Web Renderer pixels for representative full-size corpus pages":
        val samples = build_famous_site_sample_corpus()
        expect _engine_backend_matches_default_for_sample(samples[0], 160, 120) == true
        expect _engine_backend_matches_default_for_sample(samples[44], 160, 120) == true
        expect _engine_backend_matches_default_for_sample(samples[99], 160, 120) == true