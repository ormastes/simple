# @tag: sys, wm_compare, emulated, screenshot, bitwise

use std.spec.{describe, context, it, expect}
use app.wm_compare.emulated_capture.{
    capture_simple_web_emulated,
    capture_engine2d_software_emulated,
    compare_emulated_screenshots_exact}
use app.wm_compare.site_corpus.{build_famous_site_sample_corpus}

describe "wm_compare emulated screenshot capture":

    context "Simple Web Renderer capture":

        it "returns a screenshot-shaped pixel buffer for a corpus sample":
            val sample = build_famous_site_sample_corpus()[0]
            val result = capture_simple_web_emulated(sample.html, 160, 120)
            expect(result.success).to_equal(true)
            expect(result.width).to_equal(160)
            expect(result.height).to_equal(120)
            expect(result.pixels.len()).to_equal(160 * 120)

    context "Engine2D software capture":

        it "returns the deterministic software backend result":
            val sample = build_famous_site_sample_corpus()[44]
            val result = capture_engine2d_software_emulated(sample.html, 40, 30)
            expect(result.success).to_equal(true)
            expect(result.backend_name).to_equal("engine2d_software_emulated")
            expect(result.pixels.len()).to_equal(40 * 30)

    context "bitwise comparison":

        it "compares Simple and Engine2D emulated screenshots exactly":
            val sample = build_famous_site_sample_corpus()[99]
            val cmp = compare_emulated_screenshots_exact(sample.html, 40, 30)
            expect(cmp.different_pixels).to_equal(0)
            expect(cmp.match_percentage).to_equal(10000)
