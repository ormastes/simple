#![allow(unnamed_duplicate_typed_args)]
# @tag: sys, wm_compare, html_compat, chromium

use std.spec.{describe, context, it, expect}
use app.wm_compare.html_compat.{
    Fixture, build_catalog, load_combined_html, load_chrome_golden,
}

fn _catalog_has(id: text) -> bool:
    val catalog = build_catalog()
    for fixture in catalog:
        if fixture.id == id:
            return true
    false

describe "wm_compare HTML Chromium compatibility manifest":

    context "v1 widget scene manifest":

        it "lists the fixed 320x240 widget scenes":
            expect(_catalog_has("00_text_only")).to_be_true()
            expect(_catalog_has("02_block_boxes")).to_be_true()
            expect(_catalog_has("03_list")).to_be_true()
            expect(_catalog_has("04_button")).to_be_true()
            expect(_catalog_has("05_text_input")).to_be_true()
            expect(_catalog_has("06_card_panel")).to_be_true()
            expect(_catalog_has("07_scrollable_list")).to_be_true()
            expect(_catalog_has("10_colors")).to_be_true()
            expect(_catalog_has("12_padding")).to_be_true()
            expect(_catalog_has("13_margin")).to_be_true()

        it "resolves scene HTML from the fixture tree":
            val fixture = Fixture(
                id: "04_button",
                html_path: "test/fixtures/html_compat/04_button.html",
                css_path: "",
                strict: false
            )
            val html = load_combined_html(fixture)
            expect(html).to_contain("<button")

    context "Chromium golden loading":

        it "loads checked-in Chromium PPMs at the canonical viewport":
            val fixture = Fixture(
                id: "04_button",
                html_path: "test/fixtures/html_compat/04_button.html",
                css_path: "",
                strict: false
            )
            val golden = load_chrome_golden(fixture, 320, 240)
            expect(golden.success).to_be_true()
            expect(golden.pixels.len()).to_equal(320 * 240)

        it "fails clearly when the viewport does not match the golden":
            val fixture = Fixture(
                id: "04_button",
                html_path: "test/fixtures/html_compat/04_button.html",
                css_path: "",
                strict: false
            )
            val golden = load_chrome_golden(fixture, 160, 120)
            expect(golden.success).to_be_false()
            expect(golden.error).to_contain("viewport mismatch")
