# @tag: sys, wm_compare, html_compat, chromium

use std.spec.{describe, context, it, expect}
use app.wm_compare.html_compat.{
    Fixture, build_catalog, load_combined_html, load_chrome_golden, parse_opts,
    compare_exact,
}

fn _catalog_has(id: text) -> bool:
    val catalog = build_catalog()
    for fixture in catalog:
        if fixture.id == id:
            return true
    false

describe "wm_compare HTML Chromium compatibility manifest":

    context "v1 widget scene manifest":

        it "lists the fixed 320x240 widget scenes":
            val catalog = build_catalog()
            expect(catalog.len()).to_equal(16)
            expect(_catalog_has("00_text_only")).to_be_true()
            expect(_catalog_has("01_inline_text")).to_be_true()
            expect(_catalog_has("02_block_boxes")).to_be_true()
            expect(_catalog_has("03_list")).to_be_true()
            expect(_catalog_has("04_button")).to_be_true()
            expect(_catalog_has("05_text_input")).to_be_true()
            expect(_catalog_has("06_card_panel")).to_be_true()
            expect(_catalog_has("07_scrollable_list")).to_be_true()
            expect(_catalog_has("10_colors")).to_be_true()
            expect(_catalog_has("11_font_size")).to_be_true()
            expect(_catalog_has("12_padding")).to_be_true()
            expect(_catalog_has("13_margin")).to_be_true()
            expect(_catalog_has("14_border")).to_be_true()
            expect(_catalog_has("15_background")).to_be_true()
            expect(_catalog_has("16_flex_row")).to_be_true()
            expect(_catalog_has("17_flex_col")).to_be_true()

        it "uses text-tolerant matching for antialiased text scenes":
            val catalog = build_catalog()
            var strict = true
            for fixture in catalog:
                if fixture.id == "00_text_only":
                    strict = fixture.strict
            expect(strict).to_equal(false)

        it "uses perceptual matching for Chrome edge-antialiased block boxes":
            val catalog = build_catalog()
            var strict = true
            for fixture in catalog:
                if fixture.id == "02_block_boxes":
                    strict = fixture.strict
            expect(strict).to_equal(false)

        it "uses perceptual matching for Chrome edge-antialiased list rows":
            val catalog = build_catalog()
            var strict = true
            for fixture in catalog:
                if fixture.id == "03_list":
                    strict = fixture.strict
            expect(strict).to_equal(false)

        it "resolves scene HTML from the fixture tree":
            val fixture = Fixture(
                id: "04_button",
                html_path: "test/fixtures/html_compat/04_button.html",
                css_path: "",
                strict: false
            )
            val html = load_combined_html(fixture)
            expect(html).to_contain("<button")

    context "Chromium golden loading":

        it "loads checked-in Chromium PPMs at the canonical viewport":
            val fixture = Fixture(
                id: "04_button",
                html_path: "test/fixtures/html_compat/04_button.html",
                css_path: "",
                strict: false
            )
            val golden = load_chrome_golden(fixture, 320, 240)
            expect(golden.success).to_be_true()
            expect(golden.pixels.len()).to_equal(320 * 240)

        it "fails clearly when the viewport does not match the golden":
            val fixture = Fixture(
                id: "04_button",
                html_path: "test/fixtures/html_compat/04_button.html",
                css_path: "",
                strict: false
            )
            val golden = load_chrome_golden(fixture, 160, 120)
            expect(golden.success).to_be_false()
            expect(golden.error).to_contain("viewport mismatch")

    context "Simple child-process timeout options":

        it "defaults Simple source-B timeout to 20 seconds":
            val opts = parse_opts([])
            expect(opts.simple_timeout_ms).to_equal(20000)

        it "parses explicit Simple source-B timeout":
            val opts = parse_opts(["--simple-timeout-ms=3210"])
            expect(opts.simple_timeout_ms).to_equal(3210)

    context "bitwise pixel comparison":

        it "reports exact match for identical pixel buffers":
            val result = compare_exact(
                [0xFF000000u32, 0xFFFFFFFFu32],
                [0xFF000000u32, 0xFFFFFFFFu32],
                2, 1
            )
            expect(result.different_pixels).to_equal(0)
            expect(result.match_percentage).to_equal(10000)
            expect(result.max_channel_diff).to_equal(0)

        it "reports changed pixels and maximum channel drift":
            val result = compare_exact(
                [0xFF000000u32, 0xFFFFFFFFu32],
                [0xFF000000u32, 0xFF00FFFFu32],
                2, 1
            )
            expect(result.different_pixels).to_equal(1)
            expect(result.match_percentage).to_equal(5000)
            expect(result.max_channel_diff).to_equal(255)
