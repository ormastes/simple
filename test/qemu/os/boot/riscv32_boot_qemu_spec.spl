# RISC-V 32 Boot QEMU Tests — Architecture-Specific
#
# Detailed RV32 boot verification: SBI, CLINT, PLIC, UART.
#
# @platform: baremetal(riscv32)
# @tag: os,qemu,boot,riscv32

use os.qemu_runner.{get_target, build_qemu_command}
use os.kernel.arch.arch_context.{Architecture}

extern fn rt_process_run_timeout(cmd: text, args: [text], timeout_ms: i64) -> (text, text, i32)
extern fn rt_file_exists(path: text) -> bool

val TIMEOUT_MS: i64 = 10000
val ARCH = Architecture.Riscv32

fn _can_run() -> bool:
    val target = get_target(ARCH)
    val qemu_check = rt_process_run_timeout("which", [target.qemu_system], 5000)
    if qemu_check[2] != 0:
        print "SKIP: {target.qemu_system} not found"
        return false
    if not rt_file_exists(target.output):
        print "SKIP: Kernel not built: {target.output}"
        return false
    true

fn _run_qemu() -> text:
    val target = get_target(ARCH)
    val cmd_parts = build_qemu_command(target)
    val qemu_bin = cmd_parts[0]
    var args: [text] = []
    for i in 1..cmd_parts.len():
        args.push(cmd_parts[i])
    val result = rt_process_run_timeout(qemu_bin, args, TIMEOUT_MS)
    result[0] + result[1]

describe "RISC-V 32 Architecture Boot":
    slow_it "binds the canonical RV32 boot artifact contract":
        val target = get_target(ARCH)
        expect(target.arch).to_equal(Architecture.Riscv32)
        expect(target.entry).to_equal("src/os/kernel/arch/riscv32/boot.spl")
        expect(target.linker_script).to_equal("src/os/kernel/arch/riscv32/linker.ld")
        expect(target.target_triple).to_equal("riscv32-unknown-none")
        expect(target.output).to_equal("build/os/simpleos_riscv32.elf")
        expect(target.qemu_system).to_equal("qemu-system-riscv32")
        expect(target.qemu_machine).to_equal("virt")
        expect(target.qemu_cpu).to_equal("rv32")
        expect(target.qemu_memory).to_equal("128M")
        expect(target.qemu_bios).to_equal("default")
        expect(target.qemu_extra.len()).to_equal(0)
        expect(rt_file_exists(target.output)).to_equal(true)

    slow_it "UART initialized via SBI":
        if _can_run():
            val output = _run_qemu()
            expect(output).to_contain("UART")

    slow_it "prints RISC-V 32 architecture identifier":
        if _can_run():
            val output = _run_qemu()
            expect(output).to_contain("RISC-V 32")

    slow_it "memory map parsed":
        if _can_run():
            val output = _run_qemu()
            expect(output).to_contain("Memory map")

    slow_it "RAM at 0x80000000":
        if _can_run():
            val output = _run_qemu()
            expect(output).to_contain("0x80000000")

    slow_it "boot sequence completes":
        if _can_run():
            val output = _run_qemu()
            expect(output).to_contain("boot complete")
