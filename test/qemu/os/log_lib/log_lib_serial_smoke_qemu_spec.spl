# Log-Lib Serial Smoke QEMU Spec — x86_64
#
# Post-migration smoke test: verifies SimpleOS kernel boot messages
# actually reach the QEMU serial port THROUGH the log lib
# (src/lib/nogc_async_mut_noalloc/log/*), not the old ad-hoc
# serial_println path.
#
# After the Phase 5 sweep, all kernel boot log lines travel via either
# log_info (prefixed "[INFO]") or log_raw_println (bare markers).
# This spec asserts that the captured serial output contains both shapes
# on x86_64 QEMU — proving the runtime hook, the profile config, and the
# migration all flow end-to-end.
#
# arm64 / riscv64 profiles populate the new serial-config fields too but
# their smoke runs are out of scope for this PR (see state.md Phase 1).
#
# @platform: baremetal(x86_64)
# @tag: os,qemu,log,smoke,slow

use os.qemu_runner.{get_target, arch_display_name, build_qemu_command}
use os.kernel.arch.arch_context.{Architecture}

extern fn rt_process_run_timeout(cmd: text, args: [text], timeout_ms: i64) -> (text, text, i32)
extern fn rt_file_exists(path: text) -> bool

val TIMEOUT_MS: i64 = 15000

fn qemu_available(qemu_bin: text) -> bool:
    val result = rt_process_run_timeout("which", [qemu_bin], 5000)
    result[2] == 0

fn run_qemu_for_arch(arch: Architecture) -> text:
    val target = get_target(arch)
    val cmd_parts = build_qemu_command(target)
    val qemu_bin = cmd_parts[0]
    var args: [text] = []
    for i in 1..cmd_parts.len():
        args.push(cmd_parts[i])
    val result = rt_process_run_timeout(qemu_bin, args, TIMEOUT_MS)
    result[0] + result[1]

fn _can_run(arch: Architecture) -> bool:
    val target = get_target(arch)
    if not qemu_available(target.qemu_system):
        print "SKIP: {target.qemu_system} not found"
        return false
    if not rt_file_exists(target.output):
        print "SKIP: Kernel not built: {target.output}"
        return false
    true

# ===========================================================================
# x86_64 Log-Lib Serial Smoke
# ===========================================================================

describe "x86_64 log-lib serial smoke (post-migration)":
    """End-to-end check: SimpleOS boot output reaches QEMU's serial console
    through the new log-lib pipeline (rt_log_target_device_write_bytes +
    log_set_device_from_profile pointing at COM1 @ 0x3F8)."""

    slow_it "boots and emits SimpleOS banner via log lib":
        if _can_run(Architecture.X86_64):
            val output = run_qemu_for_arch(Architecture.X86_64)
            expect(output).to_contain("SimpleOS")

    slow_it "emits at least one [INFO]-prefixed line (log_info routed)":
        if _can_run(Architecture.X86_64):
            val output = run_qemu_for_arch(Architecture.X86_64)
            expect(output).to_contain("[INFO]")

    slow_it "emits bare [BOOT] marker (log_raw_println preserves wire bytes)":
        if _can_run(Architecture.X86_64):
            val output = run_qemu_for_arch(Architecture.X86_64)
            # The forbidden double-prefix shape ('[INFO] [BOOT]') is checked
            # in test/os/kernel/log/marker_wire_format_spec.spl as a unit
            # test. Here we just confirm the marker reaches serial.
            expect(output).to_contain("[BOOT]")

    slow_it "config-driven serial: banner reaches COM1":
        if _can_run(Architecture.X86_64):
            val output = run_qemu_for_arch(Architecture.X86_64)
            # If log_set_device_from_profile never wired COM1, or if the
            # runtime hook returned false, no output reaches the serial
            # stream (interpreter fallback doesn't run under QEMU).
            expect(output).to_contain("SimpleOS")
