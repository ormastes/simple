# RV64 User-Mode Execution QEMU Tests
#
# End-to-end verification of the RV64 user-mode execution path:
# - Trap vector installation
# - User task spawn via spawn_binary
# - U-mode entry via sret
# - ecall trap into kernel (debug_write, getpid, exit)
# - Clean task exit
#
# @platform: baremetal(riscv64)
# @tag: os,qemu,usermode,riscv64
# @cover src/os/kernel/arch/riscv64/trap_vector.S 80%

use os.qemu_runner.{get_target, build_qemu_command}
use os.kernel.arch.arch_context.{Architecture}

extern fn rt_process_run_timeout(cmd: text, args: [text], timeout_ms: i64) -> (text, text, i32)
extern fn rt_file_exists(path: text) -> bool

val TIMEOUT_MS: i64 = 15000
val ARCH = Architecture.Riscv64

fn _can_run() -> bool:
    val target = get_target(ARCH)
    val qemu_check = rt_process_run_timeout("which", [target.qemu_system], 5000)
    if qemu_check[2] != 0:
        print "SKIP: {target.qemu_system} not found"
        return false
    if not rt_file_exists(target.output):
        print "SKIP: Kernel not built: {target.output}"
        return false
    true

fn _run_qemu() -> text:
    val target = get_target(ARCH)
    val cmd_parts = build_qemu_command(target)
    val qemu_bin = cmd_parts[0]
    var args: [text] = []
    for i in 1..cmd_parts.len():
        args.push(cmd_parts[i])
    val result = rt_process_run_timeout(qemu_bin, args, TIMEOUT_MS)
    result[0] + result[1]

describe "RV64 User-Mode Execution":
    slow_it "trap vector installed":
        if _can_run():
            val output = _run_qemu()
            expect(output).to_contain("trap vector installed")

    slow_it "trap runtime installed":
        if _can_run():
            val output = _run_qemu()
            expect(output).to_contain("trap runtime installed")

    slow_it "user task spawned from proof binary":
        if _can_run():
            val output = _run_qemu()
            expect(output).to_contain("spawned user task")

    slow_it "entering U-mode at correct entry point":
        if _can_run():
            val output = _run_qemu()
            expect(output).to_contain("entering U-mode")

    slow_it "user debug_write syscall produces serial output":
        if _can_run():
            val output = _run_qemu()
            expect(output).to_contain("P")

    slow_it "boot sequence completes after user task":
        if _can_run():
            val output = _run_qemu()
            expect(output).to_contain("boot complete")
