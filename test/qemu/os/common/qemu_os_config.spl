# QEMU OS Test Configuration — Per-Architecture Target Table
#
# Centralizes QEMU launch configs for all 4 target architectures.
# Reuses OsTarget definitions from src/os/qemu_runner.spl.
#
# Used by: qemu_os_harness.spl, all test spec files

use os.qemu_runner.{OsTarget, get_target, arch_from_name, arch_display_name, build_qemu_command}
use os.kernel.arch.arch_context.{Architecture}

# ===========================================================================
# Supported Test Architectures (4 targets)
# ===========================================================================

fn get_test_architectures() -> [Architecture]:
    """Return the 4 architectures under test."""
    [
        Architecture.Arm64,
        Architecture.X86_64,
        Architecture.Riscv32,
        Architecture.Riscv64
    ]

fn get_test_targets() -> [OsTarget]:
    """Return OsTarget configs for all 4 test architectures."""
    var targets: [OsTarget] = []
    for arch in get_test_architectures():
        targets.push(get_target(arch))
    targets

# ===========================================================================
# Timeout Defaults (milliseconds)
# ===========================================================================

fn timeout_boot() -> i64:
    """Timeout for boot tests — 10 seconds."""
    10000

fn timeout_memory() -> i64:
    """Timeout for memory management tests — 15 seconds."""
    15000

fn timeout_interrupts() -> i64:
    """Timeout for interrupt handling tests — 20 seconds."""
    20000

fn timeout_ipc() -> i64:
    """Timeout for IPC tests — 20 seconds."""
    20000

fn timeout_scheduler() -> i64:
    """Timeout for scheduler tests — 30 seconds."""
    30000

fn timeout_io() -> i64:
    """Timeout for I/O tests — 15 seconds."""
    15000

fn timeout_stress() -> i64:
    """Timeout for stress tests — 60 seconds."""
    60000

# ===========================================================================
# Exit Code Interpretation
# ===========================================================================

fn is_qemu_success(target: OsTarget, exit_code: i32) -> bool:
    """Interpret QEMU exit code based on architecture.

    x86/x86_64 with isa-debug-exit: guest writes 0 → QEMU exits (0<<1)|1 = 1
    ARM64/RISC-V with semihosting: exit code 0 = success
    """
    match target.arch:
        Architecture.X86_64: exit_code == 1
        Architecture.X86: exit_code == 1
        _: exit_code == 0

# ===========================================================================
# QEMU Availability Check
# ===========================================================================

extern fn rt_process_run_timeout(cmd: text, args: [text], timeout_ms: i64) -> (text, text, i32)

fn qemu_available(qemu_bin: text) -> bool:
    """Check if a QEMU system binary is on PATH."""
    val result = rt_process_run_timeout("which", [qemu_bin], 5000)
    result[2] == 0

fn qemu_available_for(arch: Architecture) -> bool:
    """Check if QEMU is available for the given architecture."""
    val target = get_target(arch)
    qemu_available(target.qemu_system)
