# QEMU OS Test Harness — Host-Side Launch, Capture, Parse
#
# Provides helper functions for QEMU-based OS tests:
# - Launch QEMU with a kernel ELF, capture serial output
# - Parse [PASS]/[FAIL]/[SKIP] markers from serial output
# - Check test prerequisites (QEMU binary + kernel ELF exist)
#
# Test Pattern:
#   1. Check prerequisites: qemu_available() + file_exists(binary)
#   2. Launch QEMU: run_os_qemu(arch, timeout)
#   3. Assert: expect(output).to_contain("[PASS] test_name")

use os.qemu_runner.{OsTarget, QemuScenario, get_target, arch_display_name, build_qemu_command}
use os.kernel.arch.arch_context.{Architecture}

extern fn rt_process_run_timeout(cmd: text, args: [text], timeout_ms: i64) -> (text, text, i32)
extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_process_spawn_async(cmd: text, args: [text]) -> i64
extern fn rt_process_wait(pid: i64, timeout_ms: i64) -> i64
extern fn rt_process_is_running(pid: i64) -> bool
extern fn rt_process_kill(pid: i64) -> bool
extern fn rt_process_spawn_async_redirect(cmd: text, args: [text], stdout_path: text, stderr_path: text) -> i64
extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_delete(path: text) -> bool
extern fn rt_file_exists(path: text) -> bool
extern fn rt_thread_sleep(ms: i64)

class QemuGuestHandle:
    pid: i64
    qmp_socket: text
    serial_log: text
    qemu_bin: text

    static fn create(pid: i64, qmp_socket: text, serial_log: text, qemu_bin: text) -> QemuGuestHandle:
        QemuGuestHandle(
            pid: pid,
            qmp_socket: qmp_socket,
            serial_log: serial_log,
            qemu_bin: qemu_bin
        )

# ===========================================================================
# Prerequisites
# ===========================================================================

fn can_run_test(arch: Architecture) -> bool:
    """Check if QEMU test can run for the given architecture.

    Verifies both QEMU binary availability and kernel ELF existence.
    """
    val target = get_target(arch)

    # Check QEMU binary
    if not qemu_available(target.qemu_system):
        print "SKIP: {target.qemu_system} not found on PATH"
        return false

    # Check kernel ELF
    if not rt_file_exists(target.output):
        print "SKIP: Kernel not built: {target.output}"
        return false

    true

fn file_exists(path: text) -> bool:
    """Check if a file exists at the given path."""
    rt_file_exists(path)

fn qemu_available(qemu_system: text) -> bool:
    val qemu_check = rt_process_run_timeout("which", [qemu_system], 5000)
    qemu_check[2] == 0

fn can_run_target(target: OsTarget) -> bool:
    if not qemu_available(target.qemu_system):
        print "SKIP: {target.qemu_system} not found on PATH"
        return false
    if not rt_file_exists(target.output):
        print "SKIP: Kernel not built: {target.output}"
        return false
    true

# ===========================================================================
# QEMU Execution
# ===========================================================================

fn run_os_qemu(arch: Architecture, timeout_ms: i64) -> (text, text, i32):
    """Launch QEMU with the OS kernel and capture output.

    Returns (stdout, stderr, exit_code).
    """
    val target = get_target(arch)
    val cmd_parts = build_qemu_command(target)

    # First element is the QEMU binary, rest are args
    val qemu_bin = cmd_parts[0]
    var args: [text] = []
    for i in 1..cmd_parts.len():
        args.push(cmd_parts[i])

    rt_process_run_timeout(qemu_bin, args, timeout_ms)

fn run_os_qemu_output(arch: Architecture, timeout_ms: i64) -> text:
    """Launch QEMU and return combined stdout+stderr as serial output."""
    val result = run_os_qemu(arch, timeout_ms)
    val stdout = result[0]
    val stderr = result[1]
    stdout + stderr

fn run_os_qemu_with_target(target: OsTarget, timeout_ms: i64) -> (text, text, i32):
    """Launch QEMU with explicit target config."""
    val cmd_parts = build_qemu_command(target)
    val shell_cmd = _shell_command(cmd_parts)
    rt_process_run_timeout("/bin/sh", ["-c", shell_cmd], timeout_ms)

fn run_os_qemu_with_target_via_timeout(target: OsTarget, guest_timeout: text, timeout_ms: i64) -> (text, text, i32):
    """Launch QEMU via host shell timeout, preserving serial stdout markers.

    The interpreter's timeout helper becomes a second supervisor around the
    inner `timeout ...` shell pipeline, which can kill the wrong process
    boundary while QEMU is exiting. Use a single timeout owner here: the host
    shell command itself.
    """
    val cmd_parts = build_qemu_command(target)
    val shell_cmd = "timeout {_shell_quote(guest_timeout)} {_shell_command(cmd_parts)} 2>&1 | tr -d '\\000'"
    val result = rt_process_run("/bin/sh", ["-c", shell_cmd])
    (result[0], result[1], result[2].to_i32())

fn spawn_guest_with_qmp(target: OsTarget, qmp_socket: text, serial_log: text) -> Result<QemuGuestHandle, text>:
    """Spawn a QEMU guest using only the target's own qemu_extra.

    Backward-compatible entry point for callers that do not need any
    scenario-specific extras (empty list of scenario extras).
    """
    val no_extras: [text] = []
    _spawn_guest_with_qmp_extras(
        target,
        qmp_socket: qmp_socket,
        serial_log: serial_log,
        scenario_extras: no_extras)

fn spawn_guest_with_qmp_scenario(
    target: OsTarget,
    scenario: QemuScenario,
    qmp_socket: text,
    serial_log: text
) -> Result<QemuGuestHandle, text>:
    """Spawn a QEMU guest merging target.qemu_extra followed by
    scenario.qemu_extra.

    Merge rule: target extras are placed first (they typically carry
    baseline device wiring for the kernel), then scenario extras are
    appended so scenario-specific arguments (e.g. -drive for SYS-GUI-007)
    reach QEMU. The QMP socket args are appended last by
    _target_with_qmp so they always land at the end of the command line.
    """
    _spawn_guest_with_qmp_extras(
        target,
        qmp_socket: qmp_socket,
        serial_log: serial_log,
        scenario_extras: scenario.qemu_extra)

fn _spawn_guest_with_qmp_extras(
    target: OsTarget,
    qmp_socket: text,
    serial_log: text,
    scenario_extras: [text]
) -> Result<QemuGuestHandle, text>:
    if rt_file_exists(qmp_socket):
        rt_file_delete(qmp_socket)
    if rt_file_exists(serial_log):
        rt_file_delete(serial_log)

    val target_with_extras = _target_with_merged_extras(target, scenario_extras)
    val target_with_qmp = _target_with_qmp(target_with_extras, qmp_socket)
    val cmd_parts = build_qemu_command(target_with_qmp)
    val qemu_bin = cmd_parts[0]
    val qemu_args = _args_with_serial_file(cmd_parts.slice(1), serial_log)
    val null_sink = "/dev/null"
    val pid = rt_process_spawn_async_redirect(qemu_bin, qemu_args, null_sink, null_sink)
    if pid <= 0:
        return Err("failed to spawn {qemu_bin}")
    if not wait_for_qmp_socket(qmp_socket, 10000):
        rt_process_kill(pid)
        rt_process_wait(pid, 2000)
        return Err("QMP socket did not appear at {qmp_socket}")
    Ok(QemuGuestHandle.create(pid, qmp_socket, serial_log, qemu_bin))

fn _target_with_merged_extras(target: OsTarget, scenario_extras: [text]) -> OsTarget:
    """Return a target whose qemu_extra = target.qemu_extra ++ scenario_extras.

    Preserves backward compat for scenarios with empty qemu_extra —
    in that case the returned target is effectively unchanged.
    """
    if scenario_extras.len() == 0:
        return target
    var merged = target.qemu_extra
    var idx = 0
    while idx < scenario_extras.len():
        merged.push(scenario_extras[idx])
        idx = idx + 1
    OsTarget(
        arch: target.arch,
        entry: target.entry,
        linker_script: target.linker_script,
        target_triple: target.target_triple,
        output: target.output,
        qemu_system: target.qemu_system,
        qemu_machine: target.qemu_machine,
        qemu_cpu: target.qemu_cpu,
        qemu_memory: target.qemu_memory,
        qemu_bios: target.qemu_bios,
        qemu_extra: merged,
        gui_mode: target.gui_mode
    )

fn wait_for_serial_marker(handle: QemuGuestHandle, marker: text, timeout_ms: i64) -> bool:
    var waited = 0
    while waited <= timeout_ms:
        val serial_output = read_serial_log(handle)
        if serial_output.contains(marker):
            return true
        if not rt_process_is_running(handle.pid):
            return serial_output.contains(marker)
        rt_thread_sleep(100)
        waited = waited + 100
    read_serial_log(handle).contains(marker)

fn read_serial_log(handle: QemuGuestHandle) -> text:
    if not rt_file_exists(handle.serial_log):
        return ""
    rt_file_read_text(handle.serial_log) ?? ""

fn stop_guest(handle: QemuGuestHandle) -> bool:
    var stopped = true
    if handle.pid > 0 and rt_process_is_running(handle.pid):
        stopped = rt_process_kill(handle.pid)
        rt_process_wait(handle.pid, 2000)
    if rt_file_exists(handle.qmp_socket):
        rt_file_delete(handle.qmp_socket)
    if rt_file_exists(handle.serial_log):
        rt_file_delete(handle.serial_log)
    stopped

fn _args_with_serial_file(args: [text], serial_log: text) -> [text]:
    var rewritten: [text] = []
    var idx = 0
    while idx < args.len():
        val arg = args[idx]
        if arg == "-serial" and idx + 1 < args.len():
            rewritten.push("-serial")
            rewritten.push("file:{serial_log}")
            idx = idx + 2
            continue
        rewritten.push(arg)
        idx = idx + 1
    rewritten

# ===========================================================================
# Output Parsing
# ===========================================================================

fn count_passes(output: text) -> u64:
    """Count [PASS] markers in QEMU serial output."""
    var count: u64 = 0
    var pos: i64 = 0
    while true:
        val idx = output.index_of("[PASS]", pos)
        if idx < 0:
            break
        count = count + 1
        pos = idx + 6
    count

fn count_failures(output: text) -> u64:
    """Count [FAIL] markers in QEMU serial output."""
    var count: u64 = 0
    var pos: i64 = 0
    while true:
        val idx = output.index_of("[FAIL]", pos)
        if idx < 0:
            break
        count = count + 1
        pos = idx + 6
    count

fn has_test_marker(output: text, marker: text) -> bool:
    """Check if output contains a specific test marker string."""
    output.contains(marker)

# ===========================================================================
# Cross-Architecture Test Runner
# ===========================================================================

fn run_cross_arch_test(test_name: text, timeout_ms: i64, check_fn: fn(text) -> bool) -> (u64, u64, u64):
    """Run a test across all 4 architectures.

    Returns (passed, failed, skipped) counts.
    """
    val arches: [Architecture] = [
        Architecture.Arm64,
        Architecture.X86_64,
        Architecture.Riscv32,
        Architecture.Riscv64
    ]

    var passed: u64 = 0
    var failed: u64 = 0
    var skipped: u64 = 0

    for arch in arches:
        val name = arch_display_name(arch)
        if not can_run_test(arch):
            skipped = skipped + 1
            continue

        val output = run_os_qemu_output(arch, timeout_ms)
        if check_fn(output):
            print "[PASS] {test_name} on {name}"
            passed = passed + 1
        else:
            print "[FAIL] {test_name} on {name}"
            print "  Output: {output}"
            failed = failed + 1

    (passed, failed, skipped)

fn wait_for_qmp_socket(socket_path: text, timeout_ms: i64) -> bool:
    var waited = 0
    while waited <= timeout_ms:
        if rt_file_exists(socket_path):
            return true
        rt_thread_sleep(100)
        waited = waited + 100
    false

fn _target_with_qmp(target: OsTarget, qmp_socket: text) -> OsTarget:
    var extras = target.qemu_extra
    extras.push("-qmp")
    extras.push("unix:{qmp_socket},server,nowait")
    OsTarget(
        arch: target.arch,
        entry: target.entry,
        linker_script: target.linker_script,
        target_triple: target.target_triple,
        output: target.output,
        qemu_system: target.qemu_system,
        qemu_machine: target.qemu_machine,
        qemu_cpu: target.qemu_cpu,
        qemu_memory: target.qemu_memory,
        qemu_bios: target.qemu_bios,
        qemu_extra: extras,
        gui_mode: target.gui_mode
    )

fn _shell_command_with_redirect(cmd_parts: [text], serial_log: text) -> text:
    var shell_cmd = ""
    var idx = 0
    while idx < cmd_parts.len():
        if idx > 0:
            shell_cmd = shell_cmd + " "
        shell_cmd = shell_cmd + _shell_quote(cmd_parts[idx])
        idx = idx + 1
    "{shell_cmd} > {_shell_quote(serial_log)} 2>&1"

fn _shell_command(cmd_parts: [text]) -> text:
    var shell_cmd = ""
    var idx = 0
    while idx < cmd_parts.len():
        if idx > 0:
            shell_cmd = shell_cmd + " "
        shell_cmd = shell_cmd + _shell_quote(cmd_parts[idx])
        idx = idx + 1
    shell_cmd

fn _shell_quote(value: text) -> text:
    val escaped = value.replace("'", "'\"'\"'")
    "'{escaped}'"
