# Render2dX86Session Tests
#
# Verifies backend selection, x86_32 typed diagnostic, session handle metadata,
# and ManagedShared retain behaviour for the unified x86 2D rendering session.
#
# No imports — types are replicated at module level to avoid interpreter
# timeout issues (same pattern as session_mode_separation_spec.spl).
# Mirrors render_2d_x86_session.spl exactly.

# ============================================================================
# Replicated enums
# ============================================================================

enum BackendSessionMode:
    LegacyNoSession
    ManagedShared
    PerfExclusive

enum BackendSessionKind:
    Cpu
    Cuda
    Vulkan
    Metal
    WebGpu

enum Render2dX86InitError:
    None
    Arch32GpuUnavailable
    CudaInitFailed
    VulkanInitFailed
    NeitherBackendFound

# ============================================================================
# Replicated BackendSessionHandle
# ============================================================================

class BackendSessionHandle:
    id: i64
    kind: BackendSessionKind
    mode: BackendSessionMode
    device_name: text
    generation: i64

    fn is_null() -> bool:
        self.id == 0

# ============================================================================
# Replicated Render2dX86Handle
# ============================================================================

class Render2dX86Handle:
    base: BackendSessionHandle
    target_arch: text
    target_bits: i64
    error: Render2dX86InitError

    fn is_null() -> bool:
        self.base.is_null()

    fn is_ok() -> bool:
        self.error == Render2dX86InitError.None and not self.base.is_null()

# ============================================================================
# Replicated Render2dX86Session (minimal fields for testing)
# ============================================================================

class Render2dX86Session:
    active_kind: BackendSessionKind
    mode: BackendSessionMode
    ref_count: i64
    is_initialized: bool
    generation: i64
    target_arch: text
    target_bits: i64
    host_buf: [u32]
    buf_w: i32
    buf_h: i32

    me retain():
        self.ref_count = self.ref_count + 1

    me release():
        if self.ref_count <= 0:
            return
        self.ref_count = self.ref_count - 1

    fn is_valid() -> bool:
        self.is_initialized and self.ref_count > 0

    me fill(color: u32):
        if not self.is_initialized:
            return
        if self.buf_w > 0 and self.buf_h > 0:
            val total = self.buf_w * self.buf_h
            var idx = 0
            while idx < total:
                self.host_buf[idx] = color
                idx = idx + 1

    me sync_readback() -> i64:
        if not self.is_initialized:
            return 1
        0

# ============================================================================
# Module-level factory helpers — avoids var-rebind issues inside it-blocks
# ============================================================================

fn make_null_base_handle() -> BackendSessionHandle:
    BackendSessionHandle(
        id: 0,
        kind: BackendSessionKind.Cpu,
        mode: BackendSessionMode.LegacyNoSession,
        device_name: "",
        generation: 0
    )

fn make_cuda_base_handle() -> BackendSessionHandle:
    BackendSessionHandle(
        id: 100,
        kind: BackendSessionKind.Cuda,
        mode: BackendSessionMode.ManagedShared,
        device_name: "cuda:0",
        generation: 0
    )

fn make_vulkan_base_handle() -> BackendSessionHandle:
    BackendSessionHandle(
        id: 200,
        kind: BackendSessionKind.Vulkan,
        mode: BackendSessionMode.ManagedShared,
        device_name: "vulkan:0",
        generation: 0
    )

fn make_cuda_handle_x86_64() -> Render2dX86Handle:
    """Simulates a successful CUDA session open on x86_64."""
    Render2dX86Handle(
        base: make_cuda_base_handle(),
        target_arch: "x86_64",
        target_bits: 64,
        error: Render2dX86InitError.None
    )

fn make_vulkan_handle_x86_64() -> Render2dX86Handle:
    """Simulates a successful Vulkan session open on x86_64."""
    Render2dX86Handle(
        base: make_vulkan_base_handle(),
        target_arch: "x86_64",
        target_bits: 64,
        error: Render2dX86InitError.None
    )

fn make_x86_32_diagnostic() -> Render2dX86Handle:
    """Simulates the typed diagnostic returned for x86_32 with no GPU support."""
    Render2dX86Handle(
        base: make_null_base_handle(),
        target_arch: "i686",
        target_bits: 32,
        error: Render2dX86InitError.Arch32GpuUnavailable
    )

fn make_neither_diagnostic() -> Render2dX86Handle:
    """Simulates the typed diagnostic when neither CUDA nor Vulkan is available."""
    Render2dX86Handle(
        base: make_null_base_handle(),
        target_arch: "x86_64",
        target_bits: 64,
        error: Render2dX86InitError.NeitherBackendFound
    )

fn make_cuda_session_managed() -> Render2dX86Session:
    """Simulates an initialized CUDA session in ManagedShared mode."""
    Render2dX86Session(
        active_kind: BackendSessionKind.Cuda,
        mode: BackendSessionMode.ManagedShared,
        ref_count: 1,
        is_initialized: true,
        generation: 1,
        target_arch: "x86_64",
        target_bits: 64,
        host_buf: [],
        buf_w: 0,
        buf_h: 0
    )

fn make_session_with_buf() -> Render2dX86Session:
    """Simulates an initialized session that owns a small host framebuffer."""
    val pixels: [u32] = [0u32; 4]
    Render2dX86Session(
        active_kind: BackendSessionKind.Cuda,
        mode: BackendSessionMode.ManagedShared,
        ref_count: 1,
        is_initialized: true,
        generation: 1,
        target_arch: "x86_64",
        target_bits: 64,
        host_buf: pixels,
        buf_w: 2,
        buf_h: 2
    )

fn make_uninitialized_session() -> Render2dX86Session:
    """Simulates an uninitialised session (open() not yet called or failed)."""
    Render2dX86Session(
        active_kind: BackendSessionKind.Cpu,
        mode: BackendSessionMode.LegacyNoSession,
        ref_count: 0,
        is_initialized: false,
        generation: 0,
        target_arch: "",
        target_bits: 0,
        host_buf: [],
        buf_w: 0,
        buf_h: 0
    )

fn handle_retain_gen(h: BackendSessionHandle) -> BackendSessionHandle:
    """Return a copy of h with generation incremented."""
    BackendSessionHandle(
        id: h.id,
        kind: h.kind,
        mode: h.mode,
        device_name: h.device_name,
        generation: h.generation + 1
    )

# ============================================================================
# Tests
# ============================================================================

describe "Render2dX86Session":

    it "x86_64 CUDA handle is_ok reports true":
        val h = make_cuda_handle_x86_64()
        expect(h.is_ok()).to_equal(true)
        expect(h.target_arch).to_equal("x86_64")
        expect(h.target_bits).to_equal(64)
        expect(h.error).to_equal(Render2dX86InitError.None)

    it "x86_64 CUDA handle carries Cuda backend kind":
        val h = make_cuda_handle_x86_64()
        expect(h.base.kind).to_equal(BackendSessionKind.Cuda)
        expect(h.base.device_name).to_equal("cuda:0")

    it "x86_64 Vulkan handle is_ok reports true":
        val h = make_vulkan_handle_x86_64()
        expect(h.is_ok()).to_equal(true)
        expect(h.target_bits).to_equal(64)
        expect(h.error).to_equal(Render2dX86InitError.None)

    it "x86_64 Vulkan handle carries Vulkan backend kind":
        val h = make_vulkan_handle_x86_64()
        expect(h.base.kind).to_equal(BackendSessionKind.Vulkan)
        expect(h.base.device_name).to_equal("vulkan:0")

    it "x86_32 returns Arch32GpuUnavailable diagnostic":
        val h = make_x86_32_diagnostic()
        expect(h.is_ok()).to_equal(false)
        expect(h.is_null()).to_equal(true)
        expect(h.error).to_equal(Render2dX86InitError.Arch32GpuUnavailable)
        expect(h.target_bits).to_equal(32)
        expect(h.target_arch).to_equal("i686")

    it "x86_32 diagnostic has null base handle":
        val h = make_x86_32_diagnostic()
        expect(h.base.id).to_equal(0)
        expect(h.base.is_null()).to_equal(true)

    it "NeitherBackendFound diagnostic is not ok":
        val h = make_neither_diagnostic()
        expect(h.is_ok()).to_equal(false)
        expect(h.error).to_equal(Render2dX86InitError.NeitherBackendFound)
        expect(h.target_bits).to_equal(64)

    it "ManagedShared session initialises with ref_count 1":
        val s = make_cuda_session_managed()
        expect(s.ref_count).to_equal(1)
        expect(s.is_initialized).to_equal(true)
        expect(s.mode).to_equal(BackendSessionMode.ManagedShared)

    it "ManagedShared retain increments ref_count":
        val s = make_cuda_session_managed()
        s.retain()
        expect(s.ref_count).to_equal(2)

    it "ManagedShared retain twice then release once leaves ref_count at 2":
        val s = make_cuda_session_managed()
        s.retain()
        s.retain()
        expect(s.ref_count).to_equal(3)
        s.release()
        expect(s.ref_count).to_equal(2)

    it "ManagedShared session stays valid across multiple retains":
        val s = make_cuda_session_managed()
        s.retain()
        s.retain()
        expect(s.is_valid()).to_equal(true)
        expect(s.ref_count).to_equal(3)

    it "release to zero makes session invalid":
        val s = make_cuda_session_managed()
        s.release()
        expect(s.ref_count).to_equal(0)
        expect(s.is_valid()).to_equal(false)

    it "uninitialised session is not valid":
        val s = make_uninitialized_session()
        expect(s.is_valid()).to_equal(false)
        expect(s.is_initialized).to_equal(false)

    it "sync_readback on uninitialised session returns 1":
        val s = make_uninitialized_session()
        val rc = s.sync_readback()
        expect(rc).to_equal(1)

    it "sync_readback on initialised session returns 0":
        val s = make_cuda_session_managed()
        val rc = s.sync_readback()
        expect(rc).to_equal(0)

    it "fill on session with host buf writes color to all pixels":
        val s = make_session_with_buf()
        s.fill(0xFF0000FFu32)
        expect(s.host_buf[0]).to_equal(0xFF0000FFu32)
        expect(s.host_buf[3]).to_equal(0xFF0000FFu32)

    it "fill on uninitialised session is a no-op":
        val s = make_uninitialized_session()
        s.fill(0xFFFFFFFFu32)
        expect(s.buf_w).to_equal(0)

    it "session reports target_arch and target_bits":
        val s = make_cuda_session_managed()
        expect(s.target_arch).to_equal("x86_64")
        expect(s.target_bits).to_equal(64)

    it "session generation starts at 1 after init":
        val s = make_cuda_session_managed()
        expect(s.generation).to_equal(1)

    it "handle retain preserves mode and increments generation":
        val h = make_cuda_base_handle()
        val h2 = handle_retain_gen(h)
        expect(h2.mode).to_equal(BackendSessionMode.ManagedShared)
        expect(h2.generation).to_equal(1)
        expect(h2.id).to_equal(100)

    it "CUDA and Vulkan handles have distinct backend kinds":
        val ch = make_cuda_handle_x86_64()
        val vh = make_vulkan_handle_x86_64()
        expect(ch.base.kind).to_equal(BackendSessionKind.Cuda)
        expect(vh.base.kind).to_equal(BackendSessionKind.Vulkan)
        expect(ch.base.kind).to_not_equal(vh.base.kind)
