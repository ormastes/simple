use std.io

class SessionHandle:
    id: i64
    kind: text
    mode: text
    active: bool
    generation: i64

    static fn create(id: i64, kind: text, mode: text) -> SessionHandle:
        return SessionHandle(id: id, kind: kind, mode: mode, active: true, generation: 1)

    me retain() -> text:
        if self.mode == "perf_exclusive":
            if self.active == true:
                return "error:mode_conflict"
        self.active = true
        return "ok"

    me release() -> text:
        self.active = false
        return "released"

class SessionPolicy:
    mode: text
    allow_fallback: bool
    strict_backend: text
    allow_readback: bool

    static fn managed(kind: text) -> SessionPolicy:
        return SessionPolicy(mode: "managed", allow_fallback: true, strict_backend: kind, allow_readback: false)

    static fn perf(kind: text) -> SessionPolicy:
        return SessionPolicy(mode: "perf_exclusive", allow_fallback: false, strict_backend: kind, allow_readback: false)

    static fn legacy() -> SessionPolicy:
        return SessionPolicy(mode: "legacy", allow_fallback: true, strict_backend: "any", allow_readback: true)

class WmSession:
    mode: text
    session_id: i64
    active: bool

    static fn create(sid: i64) -> WmSession:
        return WmSession(mode: "wm", session_id: sid, active: true)

    me retain_for_child(child_mode: text) -> text:
        if child_mode == "perf_exclusive":
            return "error:rejected"
        return "ok"

fn test_legacy_create():
    var s = SessionHandle.create(id: 1, kind: "cpu", mode: "legacy")
    if s.active == true:
        print("PASS: test_legacy_create")
    else:
        print("FAIL: test_legacy_create")

fn test_legacy_no_session_compat():
    var p = SessionPolicy.legacy()
    if p.mode == "legacy":
        print("PASS: test_legacy_no_session_compat")
    else:
        print("FAIL: test_legacy_no_session_compat")

fn test_managed_create():
    var s = SessionHandle.create(id: 2, kind: "vulkan", mode: "managed")
    if s.active == true:
        print("PASS: test_managed_create")
    else:
        print("FAIL: test_managed_create")

fn test_managed_retain_release():
    var s = SessionHandle.create(id: 3, kind: "vulkan", mode: "managed")
    var r = s.release()
    if r == "released":
        print("PASS: test_managed_retain_release")
    else:
        print("FAIL: test_managed_retain_release")

fn test_managed_sharing():
    var s = SessionHandle.create(id: 4, kind: "vulkan", mode: "managed")
    var r = s.retain()
    if r == "ok":
        print("PASS: test_managed_sharing")
    else:
        print("FAIL: test_managed_sharing")

fn test_perf_create():
    var s = SessionHandle.create(id: 5, kind: "metal", mode: "perf_exclusive")
    if s.active == true:
        print("PASS: test_perf_create")
    else:
        print("FAIL: test_perf_create")

fn test_perf_double_retain_conflict():
    var s = SessionHandle.create(id: 6, kind: "metal", mode: "perf_exclusive")
    var r = s.retain()
    if r == "error:mode_conflict":
        print("PASS: test_perf_double_retain_conflict")
    else:
        print("FAIL: test_perf_double_retain_conflict")

fn test_perf_cannot_mix_managed():
    var p = SessionPolicy.perf("metal")
    if p.allow_fallback == false:
        print("PASS: test_perf_cannot_mix_managed")
    else:
        print("FAIL: test_perf_cannot_mix_managed")

fn test_mode_immutable():
    var s = SessionHandle.create(id: 7, kind: "vulkan", mode: "managed")
    var original = s.mode
    s.mode = "perf_exclusive"
    if original == "managed":
        print("PASS: test_mode_immutable")
    else:
        print("FAIL: test_mode_immutable")

fn test_strict_no_fallback():
    var p = SessionPolicy.perf("vulkan")
    if p.allow_fallback == false:
        print("PASS: test_strict_no_fallback")
    else:
        print("FAIL: test_strict_no_fallback")

fn test_fallback_allowed():
    var p = SessionPolicy.managed("cpu")
    if p.allow_fallback == true:
        print("PASS: test_fallback_allowed")
    else:
        print("FAIL: test_fallback_allowed")

fn test_readback_explicit():
    var p = SessionPolicy.legacy()
    if p.allow_readback == true:
        print("PASS: test_readback_explicit")
    else:
        print("FAIL: test_readback_explicit")

fn test_wm_rejects_perf():
    var w = WmSession.create(10)
    var r = w.retain_for_child("perf_exclusive")
    if r == "error:rejected":
        print("PASS: test_wm_rejects_perf")
    else:
        print("FAIL: test_wm_rejects_perf")

fn test_wm_accepts_managed():
    var w = WmSession.create(11)
    var r = w.retain_for_child("managed")
    if r == "ok":
        print("PASS: test_wm_accepts_managed")
    else:
        print("FAIL: test_wm_accepts_managed")

fn test_wm_accepts_legacy():
    var w = WmSession.create(12)
    var r = w.retain_for_child("legacy")
    if r == "ok":
        print("PASS: test_wm_accepts_legacy")
    else:
        print("FAIL: test_wm_accepts_legacy")

fn test_generation_check():
    var s = SessionHandle.create(id: 13, kind: "vulkan", mode: "managed")
    var stale_gen: i64 = 0
    if s.generation != stale_gen:
        print("PASS: test_generation_check")
    else:
        print("FAIL: test_generation_check")

fn test_cpu_session_always_available():
    var s = SessionHandle.create(id: 14, kind: "cpu", mode: "legacy")
    if s.active == true:
        print("PASS: test_cpu_session_always_available")
    else:
        print("FAIL: test_cpu_session_always_available")

fn test_arm32_scalar_session():
    var s = SessionHandle.create(id: 15, kind: "arm32_scalar", mode: "legacy")
    if s.kind == "arm32_scalar":
        print("PASS: test_arm32_scalar_session")
    else:
        print("FAIL: test_arm32_scalar_session")

fn test_riscv64_session():
    var s = SessionHandle.create(id: 16, kind: "riscv64", mode: "managed")
    if s.kind == "riscv64":
        print("PASS: test_riscv64_session")
    else:
        print("FAIL: test_riscv64_session")

fn test_frame_cannot_cross_sessions():
    var a = SessionHandle.create(id: 17, kind: "vulkan", mode: "managed")
    var b = SessionHandle.create(id: 18, kind: "metal", mode: "managed")
    if a.id != b.id:
        print("PASS: test_frame_cannot_cross_sessions")
    else:
        print("FAIL: test_frame_cannot_cross_sessions")

fn main():
    test_legacy_create()
    test_legacy_no_session_compat()
    test_managed_create()
    test_managed_retain_release()
    test_managed_sharing()
    test_perf_create()
    test_perf_double_retain_conflict()
    test_perf_cannot_mix_managed()
    test_mode_immutable()
    test_strict_no_fallback()
    test_fallback_allowed()
    test_readback_explicit()
    test_wm_rejects_perf()
    test_wm_accepts_managed()
    test_wm_accepts_legacy()
    test_generation_check()
    test_cpu_session_always_available()
    test_arm32_scalar_session()
    test_riscv64_session()
    test_frame_cannot_cross_sessions()
    print("DONE")
