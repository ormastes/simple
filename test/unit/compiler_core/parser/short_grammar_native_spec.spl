fn native_short_double(x: i64) -> i64: x * 2
fn native_short_add(a: i64, b: i64) -> i64: a + b

describe "Short grammar native":
    it "compiles expression-bodied functions":
        expect(native_short_double(21)).to_equal(42)

    it "compiles list comprehensions without pipe dispatch":
        val squares = [for x in 0..5: x * x]
        expect(squares).to_equal([0, 1, 4, 9, 16])

    it "compiles filtered comprehensions without pipe dispatch":
        val evens = [for x in 0..7 if x % 2 == 0: x]
        expect(evens).to_equal([0, 2, 4, 6])

    it "compiles placeholders inside inline if expressions":
        val values = [1, 2, 3, 4].map(if _1 % 2 == 0: _1 * 10 else: 0)
        expect(values).to_equal([0, 20, 0, 40])

    it "compiles nil coalescing":
        val maybe: Option<i64> = nil
        expect(maybe ?? 9).to_equal(9)

    it "uses regular calls where native pipe is unavailable":
        expect(native_short_add(native_short_double(3), 1)).to_equal(7)
