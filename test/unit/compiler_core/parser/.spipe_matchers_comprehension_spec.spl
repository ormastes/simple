describe "List comprehension":
    it "for-first basic":
        val result = [for x in [1, 2, 3]: x * 2]
        expect result == [2, 4, 6]

    it "for-first with filter":
        val result = [for x in [1, 2, 3, 4, 5] if x > 3: x]
        expect result == [4, 5]

    it "for-first with range":
        val result = [for i in 0..5: i * i]
        expect result == [0, 1, 4, 9, 16]

    it "for-first with range and filter":
        val result = [for i in 0..10 if i % 2 == 0: i]
        expect result == [0, 2, 4, 6, 8]

    it "for-last basic":
        val result = [x * 2 for x in [1, 2, 3]]
        expect result == [2, 4, 6]

    it "for-last with filter":
        val result = [x for x in [1, 2, 3, 4, 5] if x > 3]
        expect result == [4, 5]

    it "empty result from filter":
        val result = [for x in [1, 2, 3] if x > 10: x]
        expect result == []

    it "empty source array":
        var empty: [i64] = []
        val result = [for x in empty: x * 2]
        expect result == []