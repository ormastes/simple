fn double(x: i64) -> i64: x * 2
fn triple(x: i64) -> i64: x * 3
fn add1(x: i64) -> i64: x + 1
fn square(x: i64) -> i64: x * x

describe "Short grammar combined":
    it "pipe into composed function":
        val f = double >> add1
        val result = 3 |> f
        expect result == 7

    it "comprehension piped to function":
        val nums = [for i in 0..5: i * i]
        expect nums == [0, 1, 4, 9, 16]

    it "pipe chain with multiple functions":
        val result = 2 |> double |> triple |> add1
        expect result == 13

    it "compose chain then pipe":
        val transform = add1 >> double >> triple
        val result = 1 |> transform
        expect result == 12

    it "comprehension with filter":
        val evens = [for x in [1, 2, 3, 4, 5, 6] if x % 2 == 0: x * 10]
        expect evens == [20, 40, 60]