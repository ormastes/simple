fn sg_double(x: i64) -> i64: x * 2
fn sg_add1(x: i64) -> i64: x + 1
fn sg_len_plus(value: text, extra: i64) -> i64:
    value.len() + extra

struct SgRow:
    name: text
    count: i64

describe "Short grammar interpreter":
    it "combines placeholder lambda with map":
        val result = [1, 2, 3].map(_ * 3)
        expect(result).to_equal([3, 6, 9])

    it "combines numbered placeholder with filter":
        val result = [1, 2, 3, 4, 5].filter(_1 > 2)
        expect(result).to_equal([3, 4, 5])

    it "keeps placeholder lambdas around nested calls":
        val result = ["2", "5"].map(int(_1))
        expect(result).to_equal([2, 5])

    it "keeps placeholder lambdas around multi-argument calls":
        val result = [1, 2, 3].map(sg_len_plus("abcd", _1))
        expect(result).to_equal([5, 6, 7])

    it "combines method reference with placeholder":
        val lengths = ["a", "abcd", "xy"].map(&:len)
        val result = lengths.filter(_ > 1)
        expect(result).to_equal([4, 2])

    it "uses placeholder field predicates":
        val rows = [
            SgRow(name: "old", count: 1),
            SgRow(name: "new", count: 3)
        ]
        val result = rows.filter(_1.name == "new" and _1.count > 2)
        expect(result.len()).to_equal(1)
        expect(result[0].name).to_equal("new")

    it "pipes through composed function":
        val transform = sg_double >> sg_add1
        expect(4 |> transform).to_equal(9)

    it "pipes comprehension result into lambda":
        val result = [for x in 0..4 if x % 2 == 0: x * x] |> \items: items.len()
        expect(result).to_equal(2)

    it "uses nil coalescing after option value":
        val maybe: Option<i64> = nil
        expect(maybe ?? 17).to_equal(17)

    it "keeps explicit lambda readable for multiple arguments":
        val result = sg_len_plus("abcd", 3)
        expect(result).to_equal(7)
