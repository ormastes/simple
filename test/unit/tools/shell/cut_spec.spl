# Test: cut tool
# Feature: TOOL-CUT - Remove sections from lines
# @cover tools/shell/cut/cut_tool.spl

describe "cut tool":
    context "field extraction":
        it "extracts fields by delimiter":
            val line = "one:two:three:four"
            val parts = line.split(":")
            expect(parts.len()).to_equal(4)
            expect(parts[0]).to_equal("one")
            expect(parts[2]).to_equal("three")

        it "handles tab delimiter":
            val line = "a\tb\tc"
            val parts = line.split("\t")
            expect(parts.len()).to_equal(3)

    context "character extraction":
        it "extracts characters by position":
            val line = "abcdef"
            expect(line.char_at(0)).to_equal("a")
            expect(line.char_at(2)).to_equal("c")

    context "field list parsing":
        it "parses comma-separated field numbers":
            val spec = "1,3,5"
            val parts = spec.split(",")
            expect(parts.len()).to_equal(3)
            expect(parts[0]).to_equal("1")
