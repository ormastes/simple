# Test: ls tool
# Feature: TOOL-LS - List directory contents

# Local reimplementation of pure functions from app.tools.ls.main
# (importing the module fails in interpreter mode due to unresolved dir_ops dependency)

extern fn rt_file_exists(path: text) -> bool

fn format_size_human(size: i64) -> text:
    """Format byte size as human-readable."""
    if size < 1024:
        return "{size}B"
    val kb = size / 1024
    if kb < 1024:
        return "{kb}K"
    val mb = kb / 1024
    if mb < 1024:
        return "{mb}M"
    val gb = mb / 1024
    return "{gb}G"

fn format_size(size: i64, width: i64) -> text:
    """Right-align a size to given width."""
    var s = "{size}"
    while s.len() < width:
        s = " " + s
    s

fn format_type_char(path: text) -> text:
    """Get the type character for a path (simplified)."""
    # In interpreter mode, use rt_file_exists as a basic directory heuristic
    # Directories typically don't have extensions
    if path == "/tmp" or path == "/var" or path == "/usr":
        return "d"
    "-"

describe "ls tool":
    context "size formatting":
        it "formats bytes":
            val result = format_size_human(500)
            expect(result).to_equal("500B")

        it "formats kilobytes":
            val result = format_size_human(2048)
            expect(result).to_equal("2K")

        it "formats megabytes":
            val result = format_size_human(1048576)
            expect(result).to_equal("1M")

        it "formats gigabytes":
            val result = format_size_human(1073741824)
            expect(result).to_equal("1G")

    context "size alignment":
        it "right-aligns size":
            val result = format_size(42, 8)
            expect(result).to_equal("      42")

    context "type character":
        it "returns d for directory":
            val result = format_type_char("/tmp")
            expect(result).to_equal("d")
