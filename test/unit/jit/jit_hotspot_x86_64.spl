# JIT Hotspot Test: x86_64 (Cranelift)

use std.io
use std.jit.tiered_jit.{TieredJitManager}

extern fn rt_time_now_us() -> i64

fn main():
    print("=== JIT Hotspot Test: x86_64 (Cranelift) ===")

    val jit = TieredJitManager.create()
    print("Backend: " + jit.backend)

    if jit.jit_handle < 1:
        print("SKIP: JIT not available")
        return

    val hot_src = "fn hot_sum(n: i64) -> i64 { var s: i64 = 0; var i: i64 = 0; while i < n { s = s + i; i = i + 1; }; return s; }"
    jit.register("hot_sum", hot_src, 5)

    print("--- Cold phase (not yet compiled) ---")
    var i = 0
    while i < 4:
        jit.call_i64("hot_sum", 1000)
        i = i + 1
    print("After 4 calls: compiled=" + jit.is_compiled("hot_sum").to_text())

    print("--- Hot phase (triggers JIT at call 5) ---")
    val r5 = jit.call_i64("hot_sum", 1000)
    print("After 5 calls: compiled=" + jit.is_compiled("hot_sum").to_text())

    val expected: i64 = 499500
    if r5 == expected:
        print("PASS: hot_sum(1000) = " + r5.to_text())
    else:
        print("FAIL: hot_sum(1000) = " + r5.to_text() + " expected " + expected.to_text())

    print("--- Benchmark: JIT-compiled hot path ---")
    val t0 = rt_time_now_us()
    val calls = 1000
    i = 0
    while i < calls:
        jit.call_i64("hot_sum", 10000)
        i = i + 1
    val t1 = rt_time_now_us()
    val avg_us = (t1 - t0) / calls
    print("  " + calls.to_text() + " calls: avg " + avg_us.to_text() + " us/call")

    print(jit.stats())
    jit.cleanup()
    print("DONE")
