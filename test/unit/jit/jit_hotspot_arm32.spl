# JIT Hotspot Test: ARM32 (LLVM)

use std.io_runtime
use std.jit.tiered_jit.{TieredJitManager}

fn main():
    println("=== JIT Hotspot Test: ARM32 (LLVM) ===")

    val jit = TieredJitManager.create_for_target("arm32")
    println("Backend: " + jit.backend)
    println("Handle: " + jit.jit_handle.to_text())

    if jit.jit_handle < 1:
        println("SKIP: arm32 JIT not available (need --features llvm)")
        return

    val src = "fn triple(n: i64) -> i64 { return n * 3; }"
    jit.register("triple", src, 2)

    jit.call_i64("triple", 10)
    jit.call_i64("triple", 10)

    val result = jit.call_i64("triple", 10)
    val expected: i64 = 30
    if result == expected:
        println("PASS: triple(10) = " + result.to_text())
    else:
        println("FAIL: triple(10) = " + result.to_text() + " expected " + expected.to_text())

    println(jit.stats())
    jit.cleanup()
    println("DONE")
