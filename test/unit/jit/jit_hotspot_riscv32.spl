# JIT Hotspot Test: RISC-V 32 (LLVM)

use std.io_runtime
use std.jit.tiered_jit.{TieredJitManager}

fn main():
    println("=== JIT Hotspot Test: RISC-V 32 (LLVM) ===")

    val jit = TieredJitManager.create_for_target("riscv32")
    println("Backend: " + jit.backend)
    println("Handle: " + jit.jit_handle.to_text())

    if jit.jit_handle < 1:
        println("SKIP: riscv32 JIT not available (need --features llvm)")
        return

    val src = "fn square(n: i64) -> i64 { return n * n; }"
    jit.register("square", src, 2)

    jit.call_i64("square", 7)
    jit.call_i64("square", 7)

    val result = jit.call_i64("square", 7)
    val expected: i64 = 49
    if result == expected:
        println("PASS: square(7) = " + result.to_text())
    else:
        println("FAIL: square(7) = " + result.to_text() + " expected " + expected.to_text())

    println(jit.stats())
    jit.cleanup()
    println("DONE")
