# JIT Hotspot Test: x86_32 (LLVM)

use std.io_runtime
use std.jit.tiered_jit.{TieredJitManager}

fn main():
    println("=== JIT Hotspot Test: x86_32 (LLVM) ===")

    val jit = TieredJitManager.create_for_target("x86_32")
    println("Backend: " + jit.backend)
    println("Handle: " + jit.jit_handle.to_text())

    if jit.jit_handle < 1:
        println("SKIP: x86_32 JIT not available (need --features llvm)")
        return

    val src = "fn add_mul(n: i64) -> i64 { return (n + 10) * 2; }"
    jit.register("add_mul", src, 3)

    var i = 0
    while i < 3:
        jit.call_i64("add_mul", 5)
        i = i + 1
    println("Compiled: " + jit.is_compiled("add_mul").to_text())

    val result = jit.call_i64("add_mul", 5)
    val expected: i64 = 30
    if result == expected:
        println("PASS: add_mul(5) = " + result.to_text())
    else:
        println("FAIL: add_mul(5) = " + result.to_text() + " expected " + expected.to_text())

    println(jit.stats())
    jit.cleanup()
    println("DONE")
