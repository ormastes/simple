# JIT Hotspot Test: RISC-V 64

use std.io_runtime
use std.jit.tiered_jit.{TieredJitManager}

fn main():
    println("=== JIT Hotspot Test: RISC-V 64 ===")

    val jit = TieredJitManager.create_for_target("riscv64")
    println("Backend: " + jit.backend)
    println("Handle: " + jit.jit_handle.to_text())

    if jit.jit_handle < 1:
        println("SKIP: riscv64 JIT not available")
        println("NOTE: Cranelift JIT uses host triple — cross-target needs native host or LLVM")
        return

    val src = "fn fib_iter(n: i64) -> i64 { var a: i64 = 0; var b: i64 = 1; var i: i64 = 0; while i < n { var t: i64 = b; b = a + b; a = t; i = i + 1; }; return a; }"
    jit.register("fib_iter", src, 3)

    var i = 0
    while i < 3:
        jit.call_i64("fib_iter", 10)
        i = i + 1

    val result = jit.call_i64("fib_iter", 10)
    val expected: i64 = 55
    if result == expected:
        println("PASS: fib_iter(10) = " + result.to_text())
    else:
        println("FAIL: fib_iter(10) = " + result.to_text() + " expected " + expected.to_text())

    println(jit.stats())
    jit.cleanup()
    println("DONE")
