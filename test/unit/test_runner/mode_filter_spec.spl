# Unit tests for mode-specific test filtering logic
# Self-contained: re-implements filtering functions to avoid import issues
# with extern-dependent modules (test_runner_files, test_manifest_scanner)

# --- Inline extract_mode_tags (mirrors test_manifest_scanner.extract_mode_tags) ---
fn _extract_mode_tags(content: text) -> text:
    var tags: [text] = []
    val lines = content.split("\n")
    for line in lines:
        val trimmed = line.trim()
        if trimmed.starts_with("# @mode:"):
            val tag = trimmed[8:].trim()
            if tag != "":
                val parts = tag.split(",")
                for part in parts:
                    val p = part.trim()
                    if p != "":
                        tags.push(p)
        elif trimmed.starts_with("# skip-marker-removed_mode:"):
            val tag = trimmed[13:].trim()
            if tag != "":
                val parts = tag.split(",")
                for part in parts:
                    val p = part.trim()
                    if p != "":
                        tags.push("!{p}")
    tags.join(",")

# --- Inline file_mode_matches (mirrors test_runner_files.file_mode_matches) ---
fn _file_mode_matches(mode_tags: text, mode_name: text) -> bool:
    if mode_tags == "":
        return true
    if mode_name == "all-modes":
        return true
    val tags = mode_tags.split(",")
    var has_positive = false
    var has_skip = false
    for tag in tags:
        val t = tag.trim()
        if t == "":
            continue
        if t.starts_with("!"):
            val skip_name = t[1:]
            if skip_name == mode_name:
                return false
            has_skip = true
        else:
            has_positive = true
            if t == mode_name:
                return true
    if has_skip and not has_positive:
        return true
    if has_positive:
        return false
    true

# --- Inline file_get_mode_tags (mirrors test_runner_files.file_get_mode_tags) ---
fn _file_get_mode_tags(content: text) -> [text]:
    val lines = content.split("\n")
    var tags: [text] = []
    for line in lines:
        val trimmed = line.trim()
        if trimmed.starts_with("# @mode:"):
            val tag = trimmed[8:].trim()
            if tag != "":
                val parts = tag.split(",")
                for part in parts:
                    val p = part.trim()
                    if p != "":
                        tags.push(p)
        elif trimmed.starts_with("# skip-marker-removed_mode:"):
            val tag = trimmed[13:].trim()
            if tag != "":
                val parts = tag.split(",")
                for part in parts:
                    val p = part.trim()
                    if p != "":
                        tags.push("!{p}")
    tags

describe "extract_mode_tags":
    it "returns empty for no annotations":
        val content = "# just a comment\ndescribe \"foo\":\n    pass_do_nothing\n"
        expect(_extract_mode_tags(content)).to_equal("")

    it "extracts single mode tag":
        val content = "# @mode: interpreter\ndescribe \"foo\":\n    pass_do_nothing\n"
        expect(_extract_mode_tags(content)).to_equal("interpreter")

    it "extracts multi-mode tag":
        val content = "# @mode: interpreter, native\ndescribe \"foo\":\n    pass_do_nothing\n"
        expect(_extract_mode_tags(content)).to_equal("interpreter,native")

    it "extracts skip_mode as negated":
        val content = "# skip-marker-removed_mode: native\ndescribe \"foo\":\n    pass_do_nothing\n"
        expect(_extract_mode_tags(content)).to_equal("!native")

    it "extracts skip_mode with multiple modes":
        val content = "# skip-marker-removed_mode: native, smf\ndescribe \"foo\":\n    pass_do_nothing\n"
        expect(_extract_mode_tags(content)).to_equal("!native,!smf")

describe "file_mode_matches":
    it "empty tags match everything":
        expect(_file_mode_matches("", "interpreter")).to_equal(true)
        expect(_file_mode_matches("", "native")).to_equal(true)
        expect(_file_mode_matches("", "smf")).to_equal(true)

    it "AllModes always matches":
        expect(_file_mode_matches("interpreter", "all-modes")).to_equal(true)
        expect(_file_mode_matches("!native", "all-modes")).to_equal(true)

    it "positive tag matches correct mode":
        expect(_file_mode_matches("interpreter", "interpreter")).to_equal(true)
        expect(_file_mode_matches("interpreter", "native")).to_equal(false)

    it "multi-positive tags match any listed mode":
        expect(_file_mode_matches("interpreter,native", "interpreter")).to_equal(true)
        expect(_file_mode_matches("interpreter,native", "native")).to_equal(true)
        expect(_file_mode_matches("interpreter,native", "smf")).to_equal(false)

    it "skip tag excludes matching mode":
        expect(_file_mode_matches("!native", "native")).to_equal(false)
        expect(_file_mode_matches("!native", "interpreter")).to_equal(true)
        expect(_file_mode_matches("!native", "smf")).to_equal(true)

    it "multiple skip tags exclude all listed":
        expect(_file_mode_matches("!native,!smf", "native")).to_equal(false)
        expect(_file_mode_matches("!native,!smf", "smf")).to_equal(false)
        expect(_file_mode_matches("!native,!smf", "interpreter")).to_equal(true)

describe "file_get_mode_tags":
    it "returns empty list for no annotations":
        val content = "# nothing here\n"
        val tags = _file_get_mode_tags(content)
        expect(tags.len()).to_equal(0)

    it "extracts mode tags as list":
        val content = "# @mode: interpreter\n"
        val tags = _file_get_mode_tags(content)
        expect(tags.len()).to_equal(1)
        expect(tags[0]).to_equal("interpreter")

    it "extracts skip_mode tags with ! prefix":
        val content = "# skip-marker-removed_mode: native\n"
        val tags = _file_get_mode_tags(content)
        expect(tags.len()).to_equal(1)
        expect(tags[0]).to_equal("!native")
