# Unit tests for unified tag/directive parsing from # comments and """ docstrings
# Self-contained: re-implements extract_directive_lines + extract_tags locally

# --- Inline extract_directive_lines (mirrors test_manifest_scanner) ---
fn _extract_directive_lines(content: text) -> [text]:
    var result: [text] = []
    var in_docstring = false
    val lines = content.split("\n")
    for line in lines:
        val trimmed = line.trim()
        if trimmed.starts_with("\"\"\""):
            in_docstring = not in_docstring
            continue
        if in_docstring:
            if trimmed.starts_with("# @") or trimmed.starts_with("@"):
                result.push(trimmed)
        elif trimmed.starts_with("#"):
            result.push(trimmed)
    result

# --- Inline extract_tags (mirrors test_manifest_scanner) ---
fn _extract_tags(content: text) -> text:
    var tags: [text] = []
    val dlines = _extract_directive_lines(content)
    for trimmed in dlines:
        var rest = ""
        if trimmed.starts_with("# @tag:"):
            rest = trimmed[7:].trim()
        elif trimmed.starts_with("@tag:"):
            rest = trimmed[5:].trim()
        else:
            continue
        val parts = rest.split(",")
        for part in parts:
            val tag = part.trim()
            var inner = tag
            if inner.starts_with("["):
                inner = inner[1:]
            if inner.ends_with("]"):
                inner = inner[0:inner.len() - 1]
            if inner.len() >= 2:
                val first = inner[0:1]
                if first == "\"" or first == "'":
                    inner = inner[1:inner.len() - 1]
            if inner != "" and inner != "skip" and inner != "pending":
                var already = false
                for t in tags:
                    if t == inner:
                        already = true
                if not already:
                    tags.push(inner)
    tags.join(",")

# --- Inline extract_mode_tags (mirrors test_manifest_scanner) ---
fn _extract_mode_tags(content: text) -> text:
    var tags: [text] = []
    val dlines = _extract_directive_lines(content)
    for trimmed in dlines:
        var rest = ""
        var is_skip = false
        if trimmed.starts_with("# @mode:"):
            rest = trimmed[8:].trim()
        elif trimmed.starts_with("@mode:"):
            rest = trimmed[6:].trim()
        elif trimmed.starts_with("# @skip_mode:"):
            rest = trimmed[13:].trim()
            is_skip = true
        elif trimmed.starts_with("@skip_mode:"):
            rest = trimmed[11:].trim()
            is_skip = true
        else:
            continue
        if rest != "":
            val parts = rest.split(",")
            for part in parts:
                val p = part.trim()
                if p != "":
                    if is_skip:
                        tags.push("!{p}")
                    else:
                        tags.push(p)
    tags.join(",")

# ============================================================================
# Tests: extract_directive_lines
# ============================================================================

describe "extract_directive_lines":
    it "extracts # comment lines":
        val content = "# @tag:system\nuse std.spec\n# @mode:native"
        val lines = _extract_directive_lines(content)
        expect(lines.length).to_equal(2)
        expect(lines[0]).to_equal("# @tag:system")
        expect(lines[1]).to_equal("# @mode:native")

    it "extracts directives from inside docstrings":
        val content = "\"\"\"\n# @tag:api\n@mode:interpreter\nSome text\n\"\"\"\n# @tag:system"
        val lines = _extract_directive_lines(content)
        expect(lines.length).to_equal(3)
        expect(lines[0]).to_equal("# @tag:api")
        expect(lines[1]).to_equal("@mode:interpreter")
        expect(lines[2]).to_equal("# @tag:system")

    it "ignores non-directive lines in docstrings":
        val content = "\"\"\"\nSome doc text\n**Category:** Tooling\n\"\"\""
        val lines = _extract_directive_lines(content)
        expect(lines.length).to_equal(0)

    it "handles empty content":
        val lines = _extract_directive_lines("")
        expect(lines.length).to_equal(0)

# ============================================================================
# Tests: extract_tags
# ============================================================================

describe "extract_tags":
    it "parses single tag from comment":
        expect(_extract_tags("# @tag:system")).to_equal("system")

    it "parses comma-separated tags":
        expect(_extract_tags("# @tag:slow,system")).to_equal("slow,system")

    it "parses tag with spaces after comma":
        expect(_extract_tags("# @tag:slow, system")).to_equal("slow,system")

    it "parses tag from inside docstring":
        val content = "\"\"\"\n@tag:api\n\"\"\""
        expect(_extract_tags(content)).to_equal("api")

    it "parses tags from both comment and docstring":
        val content = "# @tag:system\n\"\"\"\n@tag:internal\n\"\"\""
        expect(_extract_tags(content)).to_equal("system,internal")

    it "strips quotes from tag values":
        expect(_extract_tags("# @tag:\"only-compiled\"")).to_equal("only-compiled")

    it "strips brackets and quotes":
        expect(_extract_tags("# @tag:[\"only-compiled\"]")).to_equal("only-compiled")

    it "excludes skip and pending":
        expect(_extract_tags("# @tag:skip")).to_equal("")
        expect(_extract_tags("# @tag:pending")).to_equal("")

    it "deduplicates tags":
        val content = "# @tag:system\n# @tag:system"
        expect(_extract_tags(content)).to_equal("system")

# ============================================================================
# Tests: extract_mode_tags
# ============================================================================

describe "extract_mode_tags":
    it "parses mode from comment":
        expect(_extract_mode_tags("# @mode:interpreter")).to_equal("interpreter")

    it "parses mode from docstring":
        val content = "\"\"\"\n@mode:native\n\"\"\""
        expect(_extract_mode_tags(content)).to_equal("native")

    it "parses skip_mode with ! prefix":
        expect(_extract_mode_tags("# @skip_mode:native")).to_equal("!native")

    it "parses comma-separated modes":
        expect(_extract_mode_tags("# @mode:interpreter,native")).to_equal("interpreter,native")

    it "handles mixed comment and docstring":
        val content = "# @mode:interpreter\n\"\"\"\n@skip_mode:native\n\"\"\""
        expect(_extract_mode_tags(content)).to_equal("interpreter,!native")
