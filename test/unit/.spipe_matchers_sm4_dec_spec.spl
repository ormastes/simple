use std.spec.*
use os.crypto.sm4.{sm4_encrypt_block, sm4_decrypt_block, sm4_key_expand}

fn _make_key() -> [u8]:
    var b: [u8] = []
    var x: u8 = 0x01
    b.push(x)
    x = 0x23
    b.push(x)
    x = 0x45
    b.push(x)
    x = 0x67
    b.push(x)
    x = 0x89
    b.push(x)
    x = 0xAB
    b.push(x)
    x = 0xCD
    b.push(x)
    x = 0xEF
    b.push(x)
    x = 0xFE
    b.push(x)
    x = 0xDC
    b.push(x)
    x = 0xBA
    b.push(x)
    x = 0x98
    b.push(x)
    x = 0x76
    b.push(x)
    x = 0x54
    b.push(x)
    x = 0x32
    b.push(x)
    x = 0x10
    b.push(x)
    b

describe "sm4 all":
    it "encrypt returns 16":
        val ct = sm4_encrypt_block(_make_key(), _make_key())
        expect ct.len() == 16
    it "decrypt returns 16":
        val pt = sm4_decrypt_block(_make_key(), _make_key())
        expect pt.len() == 16
    it "key_expand returns 32":
        val rk = sm4_key_expand(_make_key())
        expect rk.len() == 32