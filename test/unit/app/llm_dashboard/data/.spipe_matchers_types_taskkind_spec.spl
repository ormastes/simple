# TaskKind.Job Variant Spec
#
# Tests that TaskKind.Job exists and task_kind_name returns "job".

use app.llm_dashboard.data.types (TaskKind, task_kind_name, ManagedTask)

describe "TaskKind.Job variant":
    it "task_kind_name returns job for TaskKind.Job":
        val name = task_kind_name(TaskKind.Job)
        expect name == "job"

    it "existing Loop variant still works":
        expect task_kind_name(TaskKind.Loop) == "loop"

    it "existing Schedule variant still works":
        expect task_kind_name(TaskKind.Schedule) == "schedule"

    it "existing Daemon variant still works":
        expect task_kind_name(TaskKind.Daemon) == "daemon"

    it "existing RemoteControl variant still works":
        expect task_kind_name(TaskKind.RemoteControl) == "remote"

    it "ManagedTask can be constructed with kind Job":
        val task = ManagedTask.new("id1", TaskKind.Job, "test job", "bin/simple test")
        expect task_kind_name(task.kind) == "job"
        expect task.id == "id1"