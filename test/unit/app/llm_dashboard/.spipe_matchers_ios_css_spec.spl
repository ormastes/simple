use app.llm_dashboard.gui.ios_css.{ios_css_overrides}

describe "ios_css":
    describe "ios_css_overrides":
        it "AC-5: returns a non-empty CSS string":
            val css = ios_css_overrides()
            expect css.len() > 0

        it "AC-5: contains -webkit-overflow-scrolling for touch scroll":
            val css = ios_css_overrides()
            expect (css).contains("-webkit-overflow-scrolling")

        it "AC-5: contains iOS accent color #007AFF":
            val css = ios_css_overrides()
            expect (css).contains("#007AFF")

        it "AC-5: contains 44px touch target min-height":
            val css = ios_css_overrides()
            expect (css).contains("min-height: 44px")