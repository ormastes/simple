use app.web_dashboard.server.{DashboardServer}

describe "ios_mode":
    describe "DashboardServer.new_ios":
        it "AC-3: new_ios constructor sets is_ios to true":
            val server = DashboardServer.new_ios(3099, "")
            expect(server.is_ios).to_equal(true)

        it "AC-3: new_ios constructor records the port":
            val server = DashboardServer.new_ios(3099, "")
            expect(server.port).to_equal(3099)

        it "AC-3: new (non-iOS) constructor keeps is_ios false":
            val server = DashboardServer.new(3099)
            expect(server.is_ios).to_equal(false)

        it "AC-3: new_with_agent_dir constructor keeps is_ios false":
            val server = DashboardServer.new_with_agent_dir(3099, "/tmp/agents")
            expect(server.is_ios).to_equal(false)
