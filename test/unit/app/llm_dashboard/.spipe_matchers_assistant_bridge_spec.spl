use app.dashboard.assistant_bridge.{
    AssistantBridgeSnapshot,
    assistant_bridge_default_policy,
    assistant_bridge_projection_from_empty,
    assistant_bridge_projection_from_snapshot,
    assistant_bridge_route_action
}

describe "assistant dashboard bridge":
    fn make_snapshot(session_id: text, source_of_truth: text, loaded_at_micros: i64, captured_at_micros: i64, live_attachable: bool) -> AssistantBridgeSnapshot:
        AssistantBridgeSnapshot(
            snapshot_id: "snapshot-{session_id}",
            session_id: session_id,
            source_of_truth: source_of_truth,
            revision: 7,
            objective: "Bridge objective",
            status: "running",
            mode: "live",
            timeline_count: 3,
            task_count: 2,
            notification_count: 1,
            digest_checkpoint_id: "digest-{session_id}",
            captured_at_micros: captured_at_micros,
            loaded_at_micros: loaded_at_micros,
            live_attachable: live_attachable
        )

    fn control_action_kind() -> text:
        "spawn_task"

    it "keeps replay-only projections read-only and blocks control routing":
        val policy = assistant_bridge_default_policy()
        val projection = assistant_bridge_projection_from_empty("session-replay", policy, 1_000_000_000)
        val decision = assistant_bridge_route_action(projection, control_action_kind())

        expect projection.read_only == true
        expect projection.freshness.state == "replay"
        expect projection.live_controls_enabled == false
        expect decision.allowed == false
        expect decision.route_target == "blocked"
        expect decision.policy_state == "replay"

    it "routes fresh live projections back to the assistant core":
        val policy = assistant_bridge_default_policy()
        val snapshot = make_snapshot("session-live", policy.source_of_truth, 2_000_000_000, 2_000_000_000, true)
        val projection = assistant_bridge_projection_from_snapshot(snapshot, policy, 2_000_000_100)
        val decision = assistant_bridge_route_action(projection, control_action_kind())

        expect projection.read_only == false
        expect projection.freshness.state == "fresh"
        expect projection.live_controls_enabled == true
        expect projection.freshness.can_route_actions == true
        expect decision.allowed == true
        expect decision.route_target == "assistant_core"
        expect decision.policy_state == "live"

    it "keeps stale and degraded projections blocked until refreshed":
        val policy = assistant_bridge_default_policy()
        val stale_snapshot = make_snapshot("session-stale", policy.source_of_truth, 900_000_000, 900_000_000, true)
        val stale_projection = assistant_bridge_projection_from_snapshot(stale_snapshot, policy, 940_000_000)
        val stale_decision = assistant_bridge_route_action(stale_projection, control_action_kind())

        expect stale_projection.freshness.state == "stale"
        expect stale_projection.read_only == true
        expect stale_projection.freshness.should_refresh == true
        expect stale_decision.allowed == false
        expect stale_decision.route_target == "blocked"
        expect stale_decision.should_refresh == true

        val degraded_snapshot = make_snapshot("session-degraded", policy.source_of_truth, 700_000_000, 700_000_000, true)
        val degraded_projection = assistant_bridge_projection_from_snapshot(degraded_snapshot, policy, 830_000_000)
        val degraded_decision = assistant_bridge_route_action(degraded_projection, control_action_kind())

        expect degraded_projection.freshness.state == "degraded"
        expect degraded_projection.freshness.is_degraded == true
        expect degraded_projection.read_only == true
        expect degraded_projection.freshness.should_refresh == true
        expect degraded_decision.allowed == false
        expect degraded_decision.route_target == "blocked"
        expect degraded_decision.should_refresh == true