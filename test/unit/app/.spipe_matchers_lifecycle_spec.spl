use std.spec.*
use nogc_sync_mut.src.app.config.{AppConfig}
use nogc_sync_mut.src.app.lifecycle.{AppState}
use nogc_sync_mut.src.app.runner.{run_oneshot, run_simple}

# ============================================================================
# AppConfig Tests
# ============================================================================

describe "AppConfig":
    context "from_env":
        it "creates config with detected platform":
            val config = AppConfig.from_env("test-app", "1.0.0")
            expect config.name == "test-app"
            expect config.version == "1.0.0"
            expect config.platform.len() > 0
            expect config.arch.len() > 0

    context "create":
        it "creates config with explicit values":
            val config = AppConfig.create(
                name: "my-app",
                version: "2.0.0",
                args: ["--verbose", "file.txt"],
                platform: "linux",
                arch: "x86_64"
            )
            expect config.name == "my-app"
            expect config.version == "2.0.0"
            expect config.platform == "linux"
            expect config.arch == "x86_64"

    context "platform predicates":
        it "is_desktop returns true for linux":
            val config = AppConfig.create(
                name: "t", version: "0", args: [],
                platform: "linux", arch: "x86_64"
            )
            expect config.is_desktop() == true
            expect config.is_mobile() == false

        it "is_mobile returns true for ios":
            val config = AppConfig.create(
                name: "t", version: "0", args: [],
                platform: "ios", arch: "aarch64"
            )
            expect config.is_mobile() == true
            expect config.is_desktop() == false

        it "is_mobile returns true for android":
            val config = AppConfig.create(
                name: "t", version: "0", args: [],
                platform: "android", arch: "aarch64"
            )
            expect config.is_mobile() == true

        it "is_wasm returns true for wasm32":
            val config = AppConfig.create(
                name: "t", version: "0", args: [],
                platform: "wasi", arch: "wasm32"
            )
            expect config.is_wasm() == true

        it "is_baremetal returns true for none platform":
            val config = AppConfig.create(
                name: "t", version: "0", args: [],
                platform: "none", arch: "riscv32"
            )
            expect config.is_baremetal() == true

        it "is_64bit returns true for x86_64":
            val config = AppConfig.create(
                name: "t", version: "0", args: [],
                platform: "linux", arch: "x86_64"
            )
            expect config.is_64bit() == true

        it "is_64bit returns false for wasm32":
            val config = AppConfig.create(
                name: "t", version: "0", args: [],
                platform: "wasi", arch: "wasm32"
            )
            expect config.is_64bit() == false

# ============================================================================
# AppState Tests
# ============================================================================

describe "AppState":
    it "Created is not running":
        val state = AppState.Created
        expect state.is_running() == false
        expect state.is_stopped() == false

    it "Running is running":
        val state = AppState.Running
        expect state.is_running() == true
        expect state.is_stopped() == false

    it "Stopped is stopped":
        val state = AppState.Stopped
        expect state.is_running() == false
        expect state.is_stopped() == true

# ============================================================================
# run_oneshot Tests
# ============================================================================

describe "run_oneshot":
    it "runs init, run, shutdown in order":
        var log = []

        fn test_init(config: AppConfig):
            log.push("init")

        fn test_run(config: AppConfig) -> i32:
            log.push("run")
            0

        fn test_shutdown():
            log.push("shutdown")

        val code = run_oneshot("test", "1.0", test_init, test_run, test_shutdown)
        expect code == 0

# ============================================================================
# run_simple Tests
# ============================================================================

describe "run_simple":
    it "passes args to main function":
        fn test_main(args: [text]) -> i32:
            42

        val code = run_simple("test", test_main)
        expect code == 42