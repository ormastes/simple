# MCP T32 State Diff spec — tests state capture and comparison

# --- Inlined state types and helpers ---

class TestStepState:
    session_id: text
    window_snapshots: [text]  # "window_key|content_hash"
    register_pc: text
    register_sp: text
    register_lr: text

fn diff_find_char(s: text, ch: text) -> i64:
    var i = 0
    while i < s.len():
        if s[i] == ch:
            return i
        i = i + 1
    -1

fn diff_states(before: TestStepState, after: TestStepState) -> [text]:
    # Returns list of changed items as descriptions
    var changes: [text] = []

    # Compare window snapshots
    for a_snap in after.window_snapshots:
        val pipe_pos = diff_find_char(a_snap, "|")
        if pipe_pos <= 0:
            continue
        val a_key = a_snap.slice(0, pipe_pos)
        val a_hash = a_snap.slice(pipe_pos + 1, a_snap.len())

        var b_hash = ""
        for b_snap in before.window_snapshots:
            val bp = diff_find_char(b_snap, "|")
            if bp > 0:
                val b_key = b_snap.slice(0, bp)
                if b_key == a_key:
                    b_hash = b_snap.slice(bp + 1, b_snap.len())

        if b_hash != a_hash:
            changes.push("window:" + a_key)

    # Compare registers
    if before.register_pc != after.register_pc:
        changes.push("reg:PC")
    if before.register_sp != after.register_sp:
        changes.push("reg:SP")
    if before.register_lr != after.register_lr:
        changes.push("reg:LR")

    changes

fn simple_hash(content: text) -> text:
    var hash: i64 = 0
    var i = 0
    while i < content.len():
        hash = hash * 31 + content[i].bytes()[0]
        i = i + 1
    str(hash)

# --- Tests ---

describe "T32 MCP State Diff":

    context "identical states":
        it "returns empty diff for identical states":
            val state1 = TestStepState(
                session_id: "t32_1",
                window_snapshots: ["register_view|12345", "break_list|67890"],
                register_pc: "0x08001234",
                register_sp: "0x20001000",
                register_lr: "0x08000100"
            )
            val state2 = TestStepState(
                session_id: "t32_1",
                window_snapshots: ["register_view|12345", "break_list|67890"],
                register_pc: "0x08001234",
                register_sp: "0x20001000",
                register_lr: "0x08000100"
            )
            val changes = diff_states(state1, state2)
            expect(changes.len()).to_equal(0)

    context "changed states":
        it "detects changed register_view window":
            val before = TestStepState(
                session_id: "t32_1",
                window_snapshots: ["register_view|111"],
                register_pc: "0x08001234",
                register_sp: "0x20001000",
                register_lr: "0x08000100"
            )
            val after = TestStepState(
                session_id: "t32_1",
                window_snapshots: ["register_view|222"],
                register_pc: "0x08001234",
                register_sp: "0x20001000",
                register_lr: "0x08000100"
            )
            val changes = diff_states(before, after)
            expect(changes.len()).to_equal(1)
            expect(changes[0]).to_equal("window:register_view")

        it "detects changed PC register":
            val before = TestStepState(
                session_id: "t32_1",
                window_snapshots: [],
                register_pc: "0x08001234",
                register_sp: "0x20001000",
                register_lr: "0x08000100"
            )
            val after = TestStepState(
                session_id: "t32_1",
                window_snapshots: [],
                register_pc: "0x08001238",
                register_sp: "0x20001000",
                register_lr: "0x08000100"
            )
            val changes = diff_states(before, after)
            expect(changes.len()).to_equal(1)
            expect(changes[0]).to_equal("reg:PC")

        it "detects multiple changes":
            val before = TestStepState(
                session_id: "t32_1",
                window_snapshots: ["register_view|111", "break_list|222"],
                register_pc: "0x08001234",
                register_sp: "0x20001000",
                register_lr: "0x08000100"
            )
            val after = TestStepState(
                session_id: "t32_1",
                window_snapshots: ["register_view|999", "break_list|222"],
                register_pc: "0x08001238",
                register_sp: "0x20001000",
                register_lr: "0x08000200"
            )
            val changes = diff_states(before, after)
            expect(changes.len()).to_equal(3)

    context "missing snapshots":
        it "treats missing before as changed":
            val before = TestStepState(
                session_id: "t32_1",
                window_snapshots: [],
                register_pc: "0x08001234",
                register_sp: "0x20001000",
                register_lr: "0x08000100"
            )
            val after = TestStepState(
                session_id: "t32_1",
                window_snapshots: ["register_view|111"],
                register_pc: "0x08001234",
                register_sp: "0x20001000",
                register_lr: "0x08000100"
            )
            val changes = diff_states(before, after)
            expect(changes.len()).to_equal(1)
            expect(changes[0]).to_equal("window:register_view")

    context "simple hash":
        it "produces consistent hash for same content":
            val h1 = simple_hash("hello")
            val h2 = simple_hash("hello")
            expect(h1).to_equal(h2)

        it "produces different hash for different content":
            val h1 = simple_hash("hello")
            val h2 = simple_hash("world")
            expect(h1 == h2).to_equal(false)

    context "step history capping":
        it "history array caps at limit":
            var history: [TestStepState] = []
            var i = 0
            while i < 55:
                val state = TestStepState(
                    session_id: "t32_1",
                    window_snapshots: [],
                    register_pc: str(i),
                    register_sp: "0",
                    register_lr: "0"
                )
                history.push(state)
                i = i + 1
            # Cap at 50 by trimming from 25
            if history.len() > 50:
                history = history[25..]
            expect(history.len()).to_equal(30)
            expect(history[0].register_pc).to_equal("25")
