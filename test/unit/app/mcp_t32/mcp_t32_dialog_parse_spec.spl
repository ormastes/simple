# MCP T32 Dialog Parse spec — tests dialog element extraction from CMM source

# --- Helpers ---

fn find_colon_pos(s: text) -> i64:
    var i = 0
    while i < s.len():
        if s.substring(i, i + 1) == ":":
            return i
        i = i + 1
    -1

class DialogElement:
    element_type: text
    label: text

fn extract_dialog_elements(source: text) -> [DialogElement]:
    val lines = source.split("\n")
    var elements: [DialogElement] = []
    var in_dialog = false
    for line in lines:
        val trimmed = line.trim()
        if trimmed == "":
            continue
        if trimmed.starts_with(";"):
            continue
        val upper = trimmed.to_upper()
        if upper.starts_with("DIALOG"):
            in_dialog = true
            continue
        if trimmed == "(":
            continue
        if trimmed == ")":
            in_dialog = false
            continue
        if not in_dialog:
            continue
        # Check for labeled widget: NAME: WIDGET
        val colon_pos = find_colon_pos(trimmed)
        if colon_pos > 0:
            val maybe_label = trimmed.substring(0, colon_pos).trim()
            val after_colon = colon_pos + 1
            if after_colon < trimmed.len():
                val rest = trimmed.substring(after_colon, trimmed.len()).trim()
                val rest_upper = rest.to_upper()
                if rest_upper.starts_with("EDIT"):
                    elements.push(DialogElement(element_type: "edit", label: maybe_label))
                    continue
                if rest_upper.starts_with("BUTTON"):
                    elements.push(DialogElement(element_type: "button", label: maybe_label))
                    continue
                if rest_upper.starts_with("DEFBUTTON"):
                    elements.push(DialogElement(element_type: "defbutton", label: maybe_label))
                    continue
                if rest_upper.starts_with("CHECKBOX"):
                    elements.push(DialogElement(element_type: "checkbox", label: maybe_label))
                    continue
                if rest_upper.starts_with("CHOOSEBOX"):
                    elements.push(DialogElement(element_type: "choosebox", label: maybe_label))
                    continue
                if rest_upper.starts_with("PULLDOWN"):
                    elements.push(DialogElement(element_type: "pulldown", label: maybe_label))
                    continue
        # Unlabeled items
        if upper.starts_with("HEADER"):
            elements.push(DialogElement(element_type: "header", label: ""))
            continue
        if upper.starts_with("TEXT"):
            elements.push(DialogElement(element_type: "text", label: ""))
            continue
        if upper.starts_with("LINE"):
            elements.push(DialogElement(element_type: "line", label: ""))
            continue
        if upper.starts_with("CLOSE"):
            elements.push(DialogElement(element_type: "close", label: ""))
            continue
        if upper.starts_with("POS"):
            elements.push(DialogElement(element_type: "pos", label: ""))
            continue
        if upper.starts_with("DEFBUTTON"):
            elements.push(DialogElement(element_type: "defbutton", label: ""))
            continue
        if upper.starts_with("BUTTON"):
            elements.push(DialogElement(element_type: "button", label: ""))
            continue
    elements

fn extract_labels(elements: [DialogElement]) -> [text]:
    var labels: [text] = []
    for e in elements:
        if e.label != "":
            labels.push(e.label)
    labels

fn has_type(elements: [DialogElement], t: text) -> bool:
    for e in elements:
        if e.element_type == t:
            return true
    false

fn has_label(elements: [DialogElement], l: text) -> bool:
    for e in elements:
        if e.label == l:
            return true
    false

fn count_dialog_blocks(source: text) -> i64:
    val lines = source.split("\n")
    var count: i64 = 0
    for line in lines:
        if line.trim().to_upper().starts_with("DIALOG"):
            count = count + 1
    count

# --- Sample CMM sources ---

fn sample_dialog_cmm() -> text:
    var s = "DIALOG\n"
    s = s + "(\n"
    s = s + "  HEADER \"Test Config\"\n"
    s = s + "  POS 0. 0. 30.\n"
    s = s + "  TEXT \"Enter name:\"\n"
    s = s + "  myname: EDIT \"default\" \"\"\n"
    s = s + "  mycheck: CHECKBOX \"Enable\" \"\"\n"
    s = s + "  ok_btn: DEFBUTTON \"OK\" \"gosub ok\"\n"
    s = s + "  cancel_btn: BUTTON \"Cancel\" \"DIALOG.END\"\n"
    s = s + "  LINE \"Options\"\n"
    s = s + "  mypull: PULLDOWN \"a,b,c\" \"\"\n"
    s = s + "  CLOSE \"gosub cleanup\"\n"
    s = s + ")"
    s

fn empty_cmm() -> text:
    "; No dialog\nPRINT \"Hello\"\nENDDO"

fn multi_dialog_cmm() -> text:
    var s = "DIALOG\n(\n"
    s = s + "  name1: EDIT \"v\" \"\"\n"
    s = s + ")\n"
    s = s + "DIALOG\n(\n"
    s = s + "  name2: CHECKBOX \"o\" \"\"\n"
    s = s + ")"
    s

# --- SSpec tests ---

describe "T32 Dialog Parse":
    context "single dialog block":
        it "extracts multiple dialog elements":
            val elements = extract_dialog_elements(sample_dialog_cmm())
            expect(elements.len()).to_be_greater_than(5)

        it "finds header element":
            val elements = extract_dialog_elements(sample_dialog_cmm())
            expect(has_type(elements, "header")).to_equal(true)

        it "finds labeled edit widget":
            val elements = extract_dialog_elements(sample_dialog_cmm())
            expect(has_label(elements, "myname")).to_equal(true)

        it "finds labeled checkbox widget":
            val elements = extract_dialog_elements(sample_dialog_cmm())
            expect(has_label(elements, "mycheck")).to_equal(true)

        it "finds labeled defbutton widget":
            val elements = extract_dialog_elements(sample_dialog_cmm())
            expect(has_label(elements, "ok_btn")).to_equal(true)

        it "finds labeled button widget":
            val elements = extract_dialog_elements(sample_dialog_cmm())
            expect(has_label(elements, "cancel_btn")).to_equal(true)

        it "finds labeled pulldown widget":
            val elements = extract_dialog_elements(sample_dialog_cmm())
            expect(has_label(elements, "mypull")).to_equal(true)

        it "finds line element":
            val elements = extract_dialog_elements(sample_dialog_cmm())
            expect(has_type(elements, "line")).to_equal(true)

        it "finds close element":
            val elements = extract_dialog_elements(sample_dialog_cmm())
            expect(has_type(elements, "close")).to_equal(true)

        it "finds pos element":
            val elements = extract_dialog_elements(sample_dialog_cmm())
            expect(has_type(elements, "pos")).to_equal(true)

        it "finds text element":
            val elements = extract_dialog_elements(sample_dialog_cmm())
            expect(has_type(elements, "text")).to_equal(true)

    context "label extraction":
        it "collects all labeled widgets":
            val elements = extract_dialog_elements(sample_dialog_cmm())
            val labels = extract_labels(elements)
            expect(labels.len()).to_equal(5)

        it "contains myname label":
            val elements = extract_dialog_elements(sample_dialog_cmm())
            val labels = extract_labels(elements)
            expect(labels).to_contain("myname")

        it "contains ok_btn label":
            val elements = extract_dialog_elements(sample_dialog_cmm())
            val labels = extract_labels(elements)
            expect(labels).to_contain("ok_btn")

    context "no dialog blocks":
        it "returns empty elements for non-dialog CMM":
            val elements = extract_dialog_elements(empty_cmm())
            expect(elements.len()).to_equal(0)

        it "returns empty labels for non-dialog CMM":
            val elements = extract_dialog_elements(empty_cmm())
            val labels = extract_labels(elements)
            expect(labels.len()).to_equal(0)

        it "counts zero dialog blocks":
            val count = count_dialog_blocks(empty_cmm())
            expect(count).to_equal(0)

    context "multiple dialog blocks":
        it "extracts elements from both dialogs":
            val elements = extract_dialog_elements(multi_dialog_cmm())
            expect(elements.len()).to_equal(2)

        it "collects labels from both dialogs":
            val elements = extract_dialog_elements(multi_dialog_cmm())
            val labels = extract_labels(elements)
            expect(labels).to_contain("name1")
            expect(labels).to_contain("name2")

    context "empty source":
        it "returns empty elements for empty string":
            val elements = extract_dialog_elements("")
            expect(elements.len()).to_equal(0)

    context "dialog block count":
        it "counts one for single dialog":
            val count = count_dialog_blocks(sample_dialog_cmm())
            expect(count).to_equal(1)
