# MCP T32 JSON Parse Fix spec — bugs 2, 3, 4
# Self-contained: all helper functions inlined (no t32_mcp imports)

use std.spipe.*

# --- Inline helpers (copied from frontend_cold.spl fixed versions) ---

fn Q() -> text:
    "\""

fn LB() -> text:
    "{"

fn RB() -> text:
    "}"

fn SB_L() -> text:
    "["

fn SB_R() -> text:
    "]"

fn _char_at(s: text, i: i64) -> text:
    s.substring(i, i + 1)

fn _is_ws(ch: text) -> bool:
    ch == " " or ch == "\n" or ch == "\r" or ch == "\t"

fn _find_json_value_start(json: text, key: text) -> i64:
    val search = Q() + key + Q()
    var offset = 0
    while offset + search.len() <= json.len():
        var matches = true
        var j = 0
        while j < search.len():
            if json.substring(offset + j, offset + j + 1) != search.substring(j, j + 1):
                matches = false
                break
            j = j + 1
        if not matches:
            offset = offset + 1
            continue
        var value_start = offset + search.len()
        while value_start < json.len() and _is_ws(_char_at(json, value_start)):
            value_start = value_start + 1
        if value_start < json.len() and _char_at(json, value_start) == ":":
            value_start = value_start + 1
            while value_start < json.len() and _is_ws(_char_at(json, value_start)):
                value_start = value_start + 1
            return value_start
        offset = offset + search.len()
    return -1

# Bug 2: fixed t32_find_substring using index_of
fn t32_find_substring(haystack: text, needle: text) -> i64:
    if needle == "":
        return 0
    val found = haystack.index_of(needle)
    match found:
        Some(i):
            return i
        nil:
            return -1

# Bug 3: fixed t32_json_string_after_key with whitespace-tolerant colon handling
fn t32_json_string_after_key(body: text, key: text) -> text:
    val start = _find_json_value_start(body, key)
    if start < 0 or start >= body.len():
        return ""
    if _char_at(body, start) != Q():
        return ""
    var i = start + 1
    var out = ""
    var escaped = false
    while i < body.len():
        val ch = body.substring(i, i + 1)
        if escaped:
            if ch == "n":
                out = out + "\n"
            elif ch == "r":
                out = out + "\r"
            elif ch == "t":
                out = out + "\t"
            elif ch == "\"":
                out = out + "\""
            elif ch == "\\":
                out = out + "\\"
            else:
                out = out + ch
            escaped = false
        elif ch == "\\":
            escaped = true
        elif ch == "\"":
            return out
        else:
            out = out + ch
        i = i + 1
    return ""

# Bug 3: fixed t32_request_raw_field with whitespace-tolerant colon handling
fn t32_request_raw_field(body: text, key: text) -> text:
    val start = _find_json_value_start(body, key)
    if start < 0 or start >= body.len():
        return "null"
    val first = _char_at(body, start)
    if first == Q():
        var i2 = start + 1
        var escaped = false
        while i2 < body.len():
            val ch = _char_at(body, i2)
            if escaped:
                escaped = false
            elif ch == "\\":
                escaped = true
            elif ch == Q():
                return body.substring(start, i2 + 1)
            i2 = i2 + 1
        return "null"
    if first == LB() or first == SB_L():
        var depth = 0
        var i3 = start
        var in_str = false
        var esc = false
        while i3 < body.len():
            val ch = _char_at(body, i3)
            if in_str:
                if esc:
                    esc = false
                elif ch == "\\":
                    esc = true
                elif ch == Q():
                    in_str = false
            else:
                if ch == Q():
                    in_str = true
                elif ch == LB() or ch == SB_L():
                    depth = depth + 1
                elif ch == RB() or ch == SB_R():
                    depth = depth - 1
                    if depth == 0:
                        return body.substring(start, i3 + 1)
            i3 = i3 + 1
        return "null"
    var end = start
    while end < body.len():
        val ch = _char_at(body, end)
        if ch == "," or ch == RB() or ch == SB_R() or _is_ws(ch):
            break
        end = end + 1
    val raw = body.substring(start, end)
    if raw == "":
        return "null"
    return raw

# Bug 4: fixed extract_field_raw (used by t32_request_id_text)
fn extract_field_raw(json: text, key: text) -> text:
    val start = _find_json_value_start(json, key)
    if start < 0 or start >= json.len():
        return "null"
    val first = _char_at(json, start)
    if first == Q():
        var i2 = start + 1
        var escaped = false
        while i2 < json.len():
            val ch = _char_at(json, i2)
            if escaped:
                escaped = false
            elif ch == "\\":
                escaped = true
            elif ch == Q():
                return json.substring(start, i2 + 1)
            i2 = i2 + 1
        return "null"
    if first == LB() or first == SB_L():
        var depth = 0
        var i3 = start
        var in_str = false
        var esc = false
        while i3 < json.len():
            val ch = _char_at(json, i3)
            if in_str:
                if esc:
                    esc = false
                elif ch == "\\":
                    esc = true
                elif ch == Q():
                    in_str = false
            else:
                if ch == Q():
                    in_str = true
                elif ch == LB() or ch == SB_L():
                    depth = depth + 1
                elif ch == RB() or ch == SB_R():
                    depth = depth - 1
                    if depth == 0:
                        return json.substring(start, i3 + 1)
            i3 = i3 + 1
        return "null"
    var end = start
    while end < json.len():
        val ch = _char_at(json, end)
        if ch == "," or ch == RB() or ch == SB_R() or _is_ws(ch):
            break
        end = end + 1
    val raw = json.substring(start, end)
    if raw == "":
        return "null"
    return raw

# Bug 4: fixed t32_request_id_text
fn t32_request_id_text(body: text) -> text:
    extract_field_raw(body, "id")

# --- Tests ---

describe "Bug 2 - t32_find_substring":
    it "finds needle at start":
        val result = t32_find_substring("hello world", "hello")
        expect(result).to_equal(0)

    it "finds needle in middle":
        val result = t32_find_substring("hello world", "world")
        expect(result).to_equal(6)

    it "returns -1 when not found":
        val result = t32_find_substring("hello world", "xyz")
        expect(result).to_equal(-1)

    it "returns 0 for empty needle":
        val result = t32_find_substring("hello", "")
        expect(result).to_equal(0)

    it "handles needle longer than haystack":
        val result = t32_find_substring("hi", "hello world")
        expect(result).to_equal(-1)

    it "finds JSON key pattern":
        val result = t32_find_substring("{\"method\":\"initialize\"}", "\"method\"")
        expect(result).to_equal(1)

    it "returns -1 for empty haystack with non-empty needle":
        val result = t32_find_substring("", "abc")
        expect(result).to_equal(-1)

    it "returns 0 for both empty":
        val result = t32_find_substring("", "")
        expect(result).to_equal(0)

describe "Bug 3 - t32_json_string_after_key":
    context "compact JSON (no spaces)":
        it "extracts string value from compact JSON":
            val json = "{\"key\":\"value\"}"
            val result = t32_json_string_after_key(json, "key")
            expect(result).to_equal("value")

        it "extracts from multi-field compact JSON":
            val json = "{\"a\":\"1\",\"b\":\"2\"}"
            val result_a = t32_json_string_after_key(json, "a")
            val result_b = t32_json_string_after_key(json, "b")
            expect(result_a).to_equal("1")
            expect(result_b).to_equal("2")

    context "space after colon":
        it "extracts string value with space after colon":
            val json = "{\"key\": \"value\"}"
            val result = t32_json_string_after_key(json, "key")
            expect(result).to_equal("value")

        it "extracts from multi-field JSON with spaces after colons":
            val json = "{\"method\": \"initialize\", \"id\": \"req-1\"}"
            val result = t32_json_string_after_key(json, "method")
            expect(result).to_equal("initialize")

    context "space before and after colon":
        it "extracts string value with spaces around colon":
            val json = "{\"key\" : \"value\"}"
            val result = t32_json_string_after_key(json, "key")
            expect(result).to_equal("value")

    context "escaped strings":
        it "handles escaped quotes in value":
            val json = "{\"key\":\"val\\\"ue\"}"
            val result = t32_json_string_after_key(json, "key")
            expect(result).to_equal("val\"ue")

        it "handles newlines in value":
            val json = "{\"key\":\"line1\\nline2\"}"
            val result = t32_json_string_after_key(json, "key")
            expect(result).to_equal("line1\nline2")

        it "handles backslash in value":
            val json = "{\"key\":\"path\\\\dir\"}"
            val result = t32_json_string_after_key(json, "key")
            expect(result).to_equal("path\\dir")

    context "edge cases":
        it "returns empty string for missing key":
            val json = "{\"a\":\"1\"}"
            val result = t32_json_string_after_key(json, "nonexistent")
            expect(result).to_equal("")

        it "returns empty string for non-string value":
            val json = "{\"key\":42}"
            val result = t32_json_string_after_key(json, "key")
            expect(result).to_equal("")

describe "Bug 3 - t32_request_raw_field":
    context "objects":
        it "extracts nested object with compact colon":
            val json = "{\"key\":{\"a\":1}}"
            val result = t32_request_raw_field(json, "key")
            expect(result).to_equal("{\"a\":1}")

        it "extracts nested object with space-colon":
            val json = "{\"key\" : {\"a\":1}}"
            val result = t32_request_raw_field(json, "key")
            expect(result).to_equal("{\"a\":1}")

    context "arrays":
        it "extracts array with compact colon":
            val json = "{\"key\":[1,2,3]}"
            val result = t32_request_raw_field(json, "key")
            expect(result).to_equal("[1,2,3]")

        it "extracts array with space-colon":
            val json = "{\"key\" : [1,2,3]}"
            val result = t32_request_raw_field(json, "key")
            expect(result).to_equal("[1,2,3]")

    context "scalars":
        it "extracts number with compact colon":
            val json = "{\"key\":42}"
            val result = t32_request_raw_field(json, "key")
            expect(result).to_equal("42")

        it "extracts number with space-colon":
            val json = "{\"key\" : 42}"
            val result = t32_request_raw_field(json, "key")
            expect(result).to_equal("42")

        it "extracts boolean true":
            val json = "{\"key\":true}"
            val result = t32_request_raw_field(json, "key")
            expect(result).to_equal("true")

        it "extracts boolean false":
            val json = "{\"key\":false}"
            val result = t32_request_raw_field(json, "key")
            expect(result).to_equal("false")

        it "extracts null":
            val json = "{\"key\":null}"
            val result = t32_request_raw_field(json, "key")
            expect(result).to_equal("null")

    context "missing":
        it "returns null for missing key":
            val json = "{\"a\":1}"
            val result = t32_request_raw_field(json, "nonexistent")
            expect(result).to_equal("null")

    context "strings":
        it "extracts quoted string raw":
            val json = "{\"key\":\"hello\"}"
            val result = t32_request_raw_field(json, "key")
            expect(result).to_equal("\"hello\"")

describe "Bug 4 - t32_request_id_text":
    it "extracts numeric id":
        val json = "{\"id\":1,\"method\":\"initialize\"}"
        val result = t32_request_id_text(json)
        expect(result).to_equal("1")

    it "extracts string id":
        val json = "{\"id\":\"req-1\",\"method\":\"test\"}"
        val result = t32_request_id_text(json)
        expect(result).to_equal("\"req-1\"")

    it "extracts id with space after colon":
        val json = "{\"id\": 1, \"method\": \"test\"}"
        val result = t32_request_id_text(json)
        expect(result).to_equal("1")

    it "extracts id with spaces around colon":
        val json = "{\"id\" : 1, \"method\" : \"test\"}"
        val result = t32_request_id_text(json)
        expect(result).to_equal("1")

    it "returns null for missing id":
        val json = "{\"method\":\"notifications/initialized\"}"
        val result = t32_request_id_text(json)
        expect(result).to_equal("null")

    it "extracts id when not first field":
        val json = "{\"jsonrpc\":\"2.0\",\"id\":42,\"method\":\"test\"}"
        val result = t32_request_id_text(json)
        expect(result).to_equal("42")

    it "handles id in presence of session_id":
        val json = "{\"params\":{\"arguments\":{\"session_id\":\"x\"}},\"id\":5}"
        val result = t32_request_id_text(json)
        expect(result).to_equal("5")

    it "extracts null id":
        val json = "{\"id\":null,\"method\":\"test\"}"
        val result = t32_request_id_text(json)
        expect(result).to_equal("null")

    it "extracts string id with space after colon":
        val json = "{\"id\": \"req-42\", \"method\": \"test\"}"
        val result = t32_request_id_text(json)
        expect(result).to_equal("\"req-42\"")

    it "extracts large numeric id":
        val json = "{\"jsonrpc\":\"2.0\",\"id\":999999,\"method\":\"initialize\"}"
        val result = t32_request_id_text(json)
        expect(result).to_equal("999999")
