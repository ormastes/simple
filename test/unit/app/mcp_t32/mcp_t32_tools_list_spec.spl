# MCP T32 tools/list fix spec — bug 5: omit "required":[] when empty
# Self-contained: all helpers inlined, no imports from t32_mcp.* or t32_lsp_mcp.*

use std.sspec.*

# ── JSON building helpers (mirrored from t32_lsp_mcp/json_helpers.spl) ──

fn Q() -> text:
    return "\""

fn LB() -> text:
    return "{"

fn RB() -> text:
    return "}"

fn SB_L() -> text:
    return "["

fn SB_R() -> text:
    return "]"

fn escape_json(s: text) -> text:
    var out = s
    out = out.replace("\\", "\\\\")
    out = out.replace("\"", "\\\"")
    out = out.replace("\n", "\\n")
    out = out.replace("\r", "\\r")
    out = out.replace("\t", "\\t")
    return out

fn js(value: text) -> text:
    return Q() + escape_json(value) + Q()

fn jp(key: text, value: text) -> text:
    return Q() + key + Q() + ":" + value

fn jo1(p1: text) -> text:
    return LB() + p1 + RB()

fn jo2(p1: text, p2: text) -> text:
    return LB() + p1 + "," + p2 + RB()

fn jo3(p1: text, p2: text, p3: text) -> text:
    return LB() + p1 + "," + p2 + "," + p3 + RB()

# ── Simplified make_tool_schema (mirrors fixed protocol.spl logic) ──

fn make_tool_schema(name: text, description: text) -> text:
    var props = LB() + RB()
    var req = "[]"

    if name == "t32_sessions_list":
        props = LB() + RB()
    elif name == "t32_session_open":
        var p = LB()
        p = p + jp("host", jo2(jp("type", js("string")), jp("description", js("TRACE32 host"))))
        p = p + "," + jp("port", jo2(jp("type", js("string")), jp("description", js("TRACE32 API port"))))
        p = p + RB()
        props = p
        req = "[" + js("host") + "," + js("port") + "]"
    elif name == "t32_session_close":
        props = jo1(jp("session_id", jo2(jp("type", js("string")), jp("description", js("Session ID to close")))))
        req = "[" + js("session_id") + "]"
    elif name == "t32_cmd_run":
        var p = LB()
        p = p + jp("command", jo2(jp("type", js("string")), jp("description", js("PRACTICE command to execute"))))
        p = p + "," + jp("session_id", jo2(jp("type", js("string")), jp("description", js("Session ID (optional)"))))
        p = p + RB()
        props = p
        req = "[" + js("command") + "]"
    elif name == "t32_cmm_run":
        var p = LB()
        p = p + jp("script", jo2(jp("type", js("string")), jp("description", js("CMM script path or inline"))))
        p = p + "," + jp("session_id", jo2(jp("type", js("string")), jp("description", js("Session ID (optional)"))))
        p = p + RB()
        props = p
        req = "[" + js("script") + "]"
    elif name == "t32_eval":
        var p = LB()
        p = p + jp("expression", jo2(jp("type", js("string")), jp("description", js("TRACE32 expression"))))
        p = p + "," + jp("session_id", jo2(jp("type", js("string")), jp("description", js("Session ID (optional)"))))
        p = p + RB()
        props = p
        req = "[" + js("expression") + "]"
    elif name == "t32_error_check":
        props = LB() + RB()
    elif name == "t32_field_get":
        var p = LB()
        p = p + jp("field_key", jo2(jp("type", js("string")), jp("description", js("Field key to get"))))
        p = p + RB()
        props = p
        req = "[" + js("field_key") + "]"
    elif name == "t32_window_list":
        props = LB() + RB()
    elif name == "t32_status_snapshot":
        props = LB() + RB()

    # Build inputSchema — KEY FIX: omit "required" when empty
    var schema = LB()
    schema = schema + jp("type", js("object"))
    schema = schema + "," + jp("properties", props)
    if req != "[]":
        schema = schema + "," + jp("required", req)
    schema = schema + RB()

    # Annotations
    var read_only = "false"
    var destructive = "false"
    var idempotent = "true"
    if (name == "t32_sessions_list" or name == "t32_field_get" or
        name == "t32_eval" or name == "t32_window_list" or
        name == "t32_error_check" or name == "t32_status_snapshot"):
        read_only = "true"
    if name == "t32_session_close":
        destructive = "true"
    if name == "t32_cmd_run" or name == "t32_cmm_run":
        idempotent = "false"

    var annotations = LB()
    annotations = annotations + jp("readOnlyHint", read_only)
    annotations = annotations + "," + jp("destructiveHint", destructive)
    annotations = annotations + "," + jp("idempotentHint", idempotent)
    annotations = annotations + "," + jp("openWorldHint", "false")
    annotations = annotations + RB()

    var tool_obj = jo3(
        jp("name", js(name)),
        jp("description", js(description)),
        jp("inputSchema", schema)
    )
    # Append annotations by replacing trailing } with ,annotations}
    tool_obj = tool_obj.substring(0, tool_obj.len() - 1) + "," + jp("annotations", annotations) + RB()
    tool_obj

# ── Helper: build a complete tools/list response array ──

fn build_tools_list() -> text:
    var parts: [text] = []
    parts.push(make_tool_schema("t32_sessions_list", "List active T32 sessions"))
    parts.push(make_tool_schema("t32_session_open", "Open a new T32 session"))
    parts.push(make_tool_schema("t32_session_close", "Close a T32 session"))
    parts.push(make_tool_schema("t32_cmd_run", "Run a PRACTICE command"))
    parts.push(make_tool_schema("t32_cmm_run", "Run a CMM script"))
    parts.push(make_tool_schema("t32_eval", "Evaluate a TRACE32 expression"))
    parts.push(make_tool_schema("t32_error_check", "Check TRACE32 error state"))
    parts.push(make_tool_schema("t32_field_get", "Get field value"))
    parts.push(make_tool_schema("t32_window_list", "List available windows"))
    parts.push(make_tool_schema("t32_status_snapshot", "Get status snapshot"))
    SB_L() + parts.join(",") + SB_R()

# ── Helper: count occurrences of a substring ──

fn count_occurrences(haystack: text, needle: text) -> i64:
    var count = 0
    var pos = 0
    while pos < haystack.len():
        val idx = haystack.index_of_from(needle, pos)
        match idx:
            Some(i):
                count = count + 1
                pos = i + 1
            nil:
                break
    count

# ── Helper: count matching braces ──

fn braces_balanced(s: text) -> bool:
    var open_curly = 0
    var open_square = 0
    var i = 0
    while i < s.len():
        if s[i] == "{":
            open_curly = open_curly + 1
        elif s[i] == "}":
            open_curly = open_curly - 1
        elif s[i] == "[":
            open_square = open_square + 1
        elif s[i] == "]":
            open_square = open_square - 1
        i = i + 1
    open_curly == 0 and open_square == 0

# ── Tests ──

describe "T32 MCP tools/list schema":

    context "schema structure":

        it "generates valid schema with type object":
            val schema = make_tool_schema("t32_cmd_run", "Run command")
            expect(schema).to_contain("\"type\":\"object\"")

        it "includes properties field":
            val schema = make_tool_schema("t32_cmd_run", "Run command")
            expect(schema).to_contain("\"properties\":")

        it "omits required when empty array":
            # This is the KEY FIX for bug 5: tools with no required params
            # must NOT emit "required":[] — that causes MCP client validation errors
            val schema = make_tool_schema("t32_sessions_list", "List sessions")
            expect(schema).to_not_contain("\"required\"")

        it "includes required when non-empty":
            val schema = make_tool_schema("t32_cmd_run", "Run command")
            expect(schema).to_contain("\"required\":")

        it "required contains correct param names":
            val schema = make_tool_schema("t32_session_open", "Open session")
            expect(schema).to_contain("\"required\":[\"host\",\"port\"]")

    context "tool object structure":

        it "includes name field":
            val tool = make_tool_schema("t32_eval", "Evaluate expression")
            expect(tool).to_contain("\"name\":\"t32_eval\"")

        it "includes description field":
            val tool = make_tool_schema("t32_eval", "Evaluate expression")
            expect(tool).to_contain("\"description\":\"Evaluate expression\"")

        it "includes inputSchema field":
            val tool = make_tool_schema("t32_eval", "Evaluate expression")
            expect(tool).to_contain("\"inputSchema\":")

        it "includes annotations field":
            val tool = make_tool_schema("t32_eval", "Evaluate expression")
            expect(tool).to_contain("\"annotations\":")

    context "annotations correctness":

        it "read-only tools have readOnlyHint true":
            val read_only_tools = ["t32_sessions_list", "t32_field_get", "t32_eval", "t32_window_list", "t32_error_check", "t32_status_snapshot"]
            for tool_name in read_only_tools:
                val tool = make_tool_schema(tool_name, "desc")
                expect(tool).to_contain("\"readOnlyHint\":true")

        it "destructive tools have destructiveHint true":
            val tool = make_tool_schema("t32_session_close", "Close session")
            expect(tool).to_contain("\"destructiveHint\":true")

        it "non-idempotent tools have idempotentHint false":
            val non_idempotent = ["t32_cmd_run", "t32_cmm_run"]
            for tool_name in non_idempotent:
                val tool = make_tool_schema(tool_name, "desc")
                expect(tool).to_contain("\"idempotentHint\":false")

    context "specific tool schemas":

        it "t32_sessions_list has empty properties":
            val tool = make_tool_schema("t32_sessions_list", "List sessions")
            expect(tool).to_contain("\"properties\":{}")

        it "t32_session_open requires host and port":
            val tool = make_tool_schema("t32_session_open", "Open session")
            expect(tool).to_contain("\"host\":")
            expect(tool).to_contain("\"port\":")
            expect(tool).to_contain("\"required\":[\"host\",\"port\"]")

        it "t32_cmd_run requires command":
            val tool = make_tool_schema("t32_cmd_run", "Run command")
            expect(tool).to_contain("\"command\":")
            expect(tool).to_contain("\"required\":[\"command\"]")

        it "t32_eval requires expression":
            val tool = make_tool_schema("t32_eval", "Evaluate")
            expect(tool).to_contain("\"expression\":")
            expect(tool).to_contain("\"required\":[\"expression\"]")

        it "t32_error_check has empty properties and no required":
            val tool = make_tool_schema("t32_error_check", "Check errors")
            expect(tool).to_contain("\"properties\":{}")
            expect(tool).to_not_contain("\"required\"")

        it "t32_window_list has empty properties and no required":
            val tool = make_tool_schema("t32_window_list", "List windows")
            expect(tool).to_contain("\"properties\":{}")
            expect(tool).to_not_contain("\"required\"")

        it "t32_status_snapshot has empty properties and no required":
            val tool = make_tool_schema("t32_status_snapshot", "Status")
            expect(tool).to_contain("\"properties\":{}")
            expect(tool).to_not_contain("\"required\"")

    context "JSON validity":

        it "tool schema has matching braces":
            val tool = make_tool_schema("t32_cmd_run", "Run command")
            expect(braces_balanced(tool)).to_equal(true)

        it "tool schema has no trailing comma":
            val tool = make_tool_schema("t32_eval", "Evaluate")
            expect(tool).to_not_contain(",}")
            expect(tool).to_not_contain(",]")

        it "complete tools list wraps in array":
            val list = build_tools_list()
            expect(list).to_start_with("[")
            expect(list).to_end_with("]")
            expect(braces_balanced(list)).to_equal(true)

        it "tools list contains all registered tools":
            val list = build_tools_list()
            expect(list).to_contain("t32_sessions_list")
            expect(list).to_contain("t32_session_open")
            expect(list).to_contain("t32_session_close")
            expect(list).to_contain("t32_cmd_run")
            expect(list).to_contain("t32_cmm_run")
            expect(list).to_contain("t32_eval")
            expect(list).to_contain("t32_error_check")
            expect(list).to_contain("t32_field_get")
            expect(list).to_contain("t32_window_list")
            expect(list).to_contain("t32_status_snapshot")
