# @cover examples/10_tooling/trace32_tools/t32_mcp/wsl_python3.sh 80%
# @cover bin/release/t32_mcp_server 80%
"""
# T32 MCP WSL Bridge & Wrapper Frontend Routing Specification

**Feature IDs:** #BUG-001, #BUG-006
**Category:** Tooling
**Difficulty:** 2/5
**Status:** Implemented
**Requirements:** N/A
**Plan:** N/A
**Design:** N/A
**Research:** N/A

## Overview

Tests the logic encoded in the WSL bridge script (wsl_python3.sh) and the
wrapper script frontend routing (bin/release/t32_mcp_server lines 176-246).

Since shell scripts cannot be directly executed from SSpec, this spec
re-implements the key decision logic as pure Simple functions and verifies
their correctness with unit tests.

## Key Concepts

| Concept | Description |
|---------|-------------|
| WSL detection | Checks /proc/version for "Microsoft" or "WSL" substring |
| TCP protocol | WSL forces NETTCP protocol for cross-boundary RCL |
| Host IP | Extracted from resolv.conf nameserver line |
| Frontend routing | T32_MCP_FRONTEND env var selects full (36 tools) or cold (13 tools) |

## Behavior

- WSL detection scans /proc/version for case-insensitive "Microsoft" or "WSL"
- TCP protocol is always NETTCP in WSL environments
- Host IP is parsed from "nameserver <IP>" lines in resolv.conf
- Frontend defaults to "full" mode (not "cold")
- Full mode routes to src/app/t32_mcp_server/main.spl (36 tools)
- Cold mode routes to examples/.../frontend_cold.spl (13 tools)
"""

use std.sspec.*


# ============================================================================
# Inline helper functions — simulate shell script logic in pure Simple
# ============================================================================

# Detect WSL by checking if proc_version contains "Microsoft" or "WSL"
# Mirrors: grep -qiE 'Microsoft|WSL' /proc/version
fn detect_wsl(proc_version: text) -> bool:
    val lower = proc_version.lower()
    if lower.contains("microsoft"):
        return true
    if lower.contains("wsl"):
        return true
    false

# Resolve RCL protocol based on WSL detection
# Mirrors: export T32_RCL_PROTOCOL="NETTCP" (line 46 of wsl_python3.sh)
fn resolve_protocol(is_wsl: bool) -> text:
    # WSL always uses NETTCP; default also NETTCP for cross-boundary safety
    "NETTCP"

# Parse nameserver IP from a resolv.conf line
# Mirrors: grep -m1 '^nameserver' /etc/resolv.conf | awk '{print $2}'
fn parse_nameserver(line: text) -> text:
    val trimmed = line.trim()
    if not trimmed.starts_with("nameserver"):
        return ""
    # Split on whitespace — extract second field
    val parts = trimmed.split(" ")
    if parts.len() < 2:
        return ""
    # Find first non-empty part after "nameserver"
    var found_keyword = false
    for part in parts:
        if part == "":
            pass_dn
        else if found_keyword:
            return part.trim()
        else if part == "nameserver":
            found_keyword = true
    ""

# Resolve Windows host IP from resolv.conf content (multi-line)
# Mirrors lines 32-38 of wsl_python3.sh
fn resolve_host_ip(resolv_conf: text) -> text:
    val lines = resolv_conf.split("\n")
    for line in lines:
        val ip = parse_nameserver(line)
        if ip != "":
            return ip
    # Fallback: localhost
    "127.0.0.1"

# Determine frontend mode from env var value
# Mirrors lines 176, 230-239 of bin/release/t32_mcp_server
fn resolve_frontend(env_value: text) -> text:
    if env_value == "":
        return "full"
    env_value

# Determine source artifact path from frontend mode
# Mirrors the case statement at lines 231-239
fn resolve_source_artifact(frontend: text, repo_root: text) -> text:
    match frontend:
        "full": repo_root + "/src/app/t32_mcp_server/main.spl"
        _: repo_root + "/examples/10_tooling/trace32_tools/t32_mcp/frontend_cold.spl"

# Full mode tool list (36 tools)
fn full_mode_tools() -> List<text>:
    [
        "t32_sessions_list", "t32_session_open", "t32_session_resume", "t32_session_close",
        "t32_core_list", "t32_core_select",
        "t32_cmd_run", "t32_cmm_run", "t32_eval",
        "t32_window_list", "t32_window_open", "t32_window_capture", "t32_window_describe",
        "t32_screenshot",
        "t32_action_invoke",
        "t32_field_get", "t32_field_set",
        "t32_history_tail",
        "t32_resources_list", "t32_resource_read",
        "t32_setup_headless",
        "t32_area_read",
        "t32_cmm_commands",
        "t32_job_list", "t32_job_status", "t32_job_cancel",
        "t32_error_check",
        "t32_dialog_parse", "t32_dialog_get", "t32_dialog_set", "t32_dialog_click",
        "t32_state_diff", "t32_status_bar",
        "t32_window_snapshot",
        "t32_practice_macro",
        "t32_breakpoint_list"
    ]

# Cold mode tool list (13 tools — subset available without session)
fn cold_mode_tools() -> List<text>:
    [
        "t32_sessions_list",
        "t32_job_list",
        "t32_cmm_commands",
        "t32_field_get", "t32_field_set",
        "t32_history_tail",
        "t32_dialog_parse", "t32_dialog_get", "t32_dialog_set", "t32_dialog_click",
        "t32_error_check",
        "t32_resources_list", "t32_resource_read"
    ]


# ============================================================================
# Test Group 1: WSL Detection and TCP Config
# ============================================================================

describe "WSL detection and TCP config":
    """
    ## WSL Environment Detection

    Tests the logic from wsl_python3.sh lines 6-14 that detect whether the
    environment is running under WSL by scanning /proc/version for
    "Microsoft" or "WSL" substrings (case-insensitive).
    """

    context "WSL environment detection":
        """
        ### Scenario: Detecting WSL from /proc/version

        The bridge script greps /proc/version for Microsoft|WSL.
        """

        it "detects WSL from proc version containing Microsoft":
            val proc_v = "Linux version 5.15.146.1-microsoft-standard-WSL2 (root@host) (gcc)"
            expect(detect_wsl(proc_v)).to_equal(true)

        it "detects WSL from proc version containing WSL":
            val proc_v = "Linux version 5.15.0 (WSL custom build)"
            expect(detect_wsl(proc_v)).to_equal(true)

        it "detects WSL case-insensitively":
            val proc_v = "Linux version 5.15.0-MICROSOFT-custom"
            expect(detect_wsl(proc_v)).to_equal(true)

        it "non-WSL returns false":
            val proc_v = "Linux version 6.8.0-106-generic (buildd@lcy02-amd64-115)"
            expect(detect_wsl(proc_v)).to_equal(false)

        it "empty proc version returns false":
            expect(detect_wsl("")).to_equal(false)

    context "TCP protocol config":
        """
        ### Scenario: Protocol selection

        WSL forces NETTCP protocol for cross-boundary RCL communication.
        The default protocol is also NETTCP.
        """

        it "WSL forces NETTCP protocol":
            expect(resolve_protocol(true)).to_equal("NETTCP")

        it "default protocol is NETTCP":
            expect(resolve_protocol(false)).to_equal("NETTCP")

        it "protocol string is exactly NETTCP":
            val protocol = resolve_protocol(true)
            expect(protocol).to_equal("NETTCP")
            expect(protocol.len()).to_equal(6)

    context "host IP resolution":
        """
        ### Scenario: Parsing Windows host IP from resolv.conf

        The WSL bridge extracts the first nameserver IP from /etc/resolv.conf
        to find the Windows host address.
        """

        it "resolves nameserver from resolv.conf format":
            val resolv = "# This is auto-generated\nnameserver 172.28.160.1\nsearch localdomain"
            expect(resolve_host_ip(resolv)).to_equal("172.28.160.1")

        it "falls back to localhost when no nameserver":
            val resolv = "# Empty resolv.conf\nsearch localdomain"
            expect(resolve_host_ip(resolv)).to_equal("127.0.0.1")

        it "parses nameserver line correctly":
            expect(parse_nameserver("nameserver 10.0.0.1")).to_equal("10.0.0.1")
            expect(parse_nameserver("nameserver 192.168.1.1")).to_equal("192.168.1.1")

        it "ignores comment lines":
            expect(parse_nameserver("# nameserver 1.2.3.4")).to_equal("")

        it "handles extra whitespace":
            expect(parse_nameserver("  nameserver  172.16.0.1  ")).to_equal("172.16.0.1")

        it "returns empty for non-nameserver lines":
            expect(parse_nameserver("search localdomain")).to_equal("")
            expect(parse_nameserver("domain example.com")).to_equal("")
            expect(parse_nameserver("")).to_equal("")


# ============================================================================
# Test Group 2: Wrapper Frontend Routing
# ============================================================================

describe "wrapper frontend routing":
    """
    ## Frontend Selection Logic

    Tests the routing logic from bin/release/t32_mcp_server lines 176-246.
    The T32_MCP_FRONTEND env var selects which entrypoint the wrapper uses:
    - "full" (default) -> src/app/t32_mcp_server/main.spl (36 tools)
    - "cold" -> examples/.../frontend_cold.spl (13 tools)
    """

    context "frontend selection":
        """
        ### Scenario: Default and explicit frontend modes

        The wrapper defaults to "full" mode when T32_MCP_FRONTEND is unset.
        """

        it "default frontend is full":
            expect(resolve_frontend("")).to_equal("full")

        it "full frontend uses t32_mcp_server main.spl":
            val root = "/home/user/simple"
            val artifact = resolve_source_artifact("full", root)
            expect(artifact).to_equal("/home/user/simple/src/app/t32_mcp_server/main.spl")

        it "cold frontend uses frontend_cold.spl":
            val root = "/home/user/simple"
            val artifact = resolve_source_artifact("cold", root)
            expect(artifact).to_equal("/home/user/simple/examples/10_tooling/trace32_tools/t32_mcp/frontend_cold.spl")

        it "env var overrides default":
            expect(resolve_frontend("cold")).to_equal("cold")
            expect(resolve_frontend("full")).to_equal("full")

        it "unknown frontend falls back to cold entrypoint":
            val root = "/repo"
            val artifact = resolve_source_artifact("unknown_value", root)
            expect(artifact).to_contain("frontend_cold.spl")

    context "full vs cold tool availability":
        """
        ### Scenario: Tool count and membership differences

        Full mode exposes 36 tools including session management.
        Cold mode exposes 13 tools — a safe subset that works without an
        active T32 session.
        """

        it "full mode supports 36 tools":
            expect(full_mode_tools().len()).to_equal(36)

        it "cold mode supports 13 tools":
            expect(cold_mode_tools().len()).to_equal(13)

        it "full mode includes session_open":
            val tools = full_mode_tools()
            expect(tools.contains("t32_session_open")).to_equal(true)

        it "full mode includes cmd_run":
            val tools = full_mode_tools()
            expect(tools.contains("t32_cmd_run")).to_equal(true)

        it "cold mode excludes session_open":
            val tools = cold_mode_tools()
            expect(tools.contains("t32_session_open")).to_equal(false)

        it "cold mode excludes cmd_run":
            val tools = cold_mode_tools()
            expect(tools.contains("t32_cmd_run")).to_equal(false)

        it "cold tools are a subset of full tools":
            val full = full_mode_tools()
            val cold = cold_mode_tools()
            var all_found = true
            for tool in cold:
                if not full.contains(tool):
                    all_found = false
            expect(all_found).to_equal(true)

        it "full mode includes window and screenshot tools":
            val tools = full_mode_tools()
            expect(tools.contains("t32_window_capture")).to_equal(true)
            expect(tools.contains("t32_screenshot")).to_equal(true)
            expect(tools.contains("t32_window_snapshot")).to_equal(true)

        it "cold mode includes dialog tools":
            val tools = cold_mode_tools()
            expect(tools.contains("t32_dialog_parse")).to_equal(true)
            expect(tools.contains("t32_dialog_get")).to_equal(true)
            expect(tools.contains("t32_dialog_set")).to_equal(true)
            expect(tools.contains("t32_dialog_click")).to_equal(true)
