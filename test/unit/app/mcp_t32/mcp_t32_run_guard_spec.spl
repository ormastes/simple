# MCP T32 Run Guard spec — tests guard allowlist, timeout config, error format

# --- Inlined guard logic (avoid import issues) ---

fn guard_is_always_allowed(tool_name: text) -> bool:
    if tool_name == "t32_sessions_list":
        return true
    if tool_name == "t32_session_open":
        return true
    if tool_name == "t32_session_resume":
        return true
    if tool_name == "t32_session_close":
        return true
    if tool_name == "t32_window_list":
        return true
    if tool_name == "t32_window_describe":
        return true
    if tool_name == "t32_history_tail":
        return true
    if tool_name == "t32_resources_list":
        return true
    if tool_name == "t32_resource_read":
        return true
    if tool_name == "t32_cmm_commands":
        return true
    false

fn guard_is_safe_cmd(command: text) -> bool:
    val cmd_lower = command.to_lower()
    if cmd_lower.starts_with("break"):
        return true
    false

fn guard_is_safe_eval(expression: text) -> bool:
    val expr_lower = expression.to_lower()
    if expr_lower.starts_with("state."):
        return true
    if expr_lower.starts_with("practice."):
        return true
    false

fn guard_err_target_running(tool_name: text) -> text:
    "T4100: Target is running — '{tool_name}' requires a halted CPU.\n  Use 't32_cmd_run(command: \"Break\")' to halt the target first."

fn guard_err_command_timeout(tool_name: text, elapsed_ms: i64) -> text:
    "T4101: Command '{tool_name}' timed out after {elapsed_ms}ms.\n  The target may be unresponsive. Check connection and target state."

# --- Inlined timeout config ---

fn guard_find_char(s: text, ch: text) -> i64:
    var i = 0
    for c in s:
        if c == ch:
            return i
        i = i + 1
    -1

fn guard_substr(s: text, start: i64, end: i64) -> text:
    var buf: [text] = []
    var i = 0
    for ch in s:
        if i >= start and i < end:
            buf.push(ch)
        i = i + 1
    buf.join("")

fn guard_get_timeout(tool_name: text) -> i64:
    val timeouts = [
        "t32_cmm_run|60000",
        "t32_eval|3000",
        "t32_window_capture|5000",
        "t32_cmd_run|10000",
        "t32_screenshot|10000"
    ]
    for entry in timeouts:
        val pipe_pos = guard_find_char(entry, "|")
        if pipe_pos > 0:
            val name = guard_substr(entry, 0, pipe_pos)
            if name == tool_name and pipe_pos + 1 < entry.len():
                val ms_str = guard_substr(entry, pipe_pos + 1, entry.len())
                return int(ms_str)
    10000

# --- Tests ---

describe "T32 MCP Run Guard":

    context "always-allowed tools":
        it "allows sessions_list while running":
            expect(guard_is_always_allowed("t32_sessions_list")).to_equal(true)

        it "allows session_open while running":
            expect(guard_is_always_allowed("t32_session_open")).to_equal(true)

        it "allows window_list while running":
            expect(guard_is_always_allowed("t32_window_list")).to_equal(true)

        it "allows history_tail while running":
            expect(guard_is_always_allowed("t32_history_tail")).to_equal(true)

        it "allows cmm_commands while running":
            expect(guard_is_always_allowed("t32_cmm_commands")).to_equal(true)

    context "blocked tools":
        it "blocks window_capture while running":
            expect(guard_is_always_allowed("t32_window_capture")).to_equal(false)

        it "blocks screenshot while running":
            expect(guard_is_always_allowed("t32_screenshot")).to_equal(false)

        it "blocks field_set while running":
            expect(guard_is_always_allowed("t32_field_set")).to_equal(false)

    context "safe cmd_run commands":
        it "allows Break command":
            expect(guard_is_safe_cmd("Break")).to_equal(true)

        it "allows Break.Set command":
            expect(guard_is_safe_cmd("Break.Set main")).to_equal(true)

        it "allows Break.Delete command":
            expect(guard_is_safe_cmd("Break.Delete /ALL")).to_equal(true)

        it "blocks Data.dump command":
            expect(guard_is_safe_cmd("Data.dump")).to_equal(false)

    context "safe eval expressions":
        it "allows STATE.RUN()":
            expect(guard_is_safe_eval("STATE.RUN()")).to_equal(true)

        it "allows PRACTICE.STATE()":
            expect(guard_is_safe_eval("PRACTICE.STATE()")).to_equal(true)

        it "blocks Register(PC)":
            expect(guard_is_safe_eval("Register(PC)")).to_equal(false)

    context "timeout configuration":
        it "returns cmm_run timeout":
            expect(guard_get_timeout("t32_cmm_run")).to_equal(60000)

        it "returns eval timeout":
            expect(guard_get_timeout("t32_eval")).to_equal(3000)

        it "returns default for unknown tool":
            expect(guard_get_timeout("t32_unknown_tool")).to_equal(10000)

    context "error message format":
        it "T4100 includes tool name":
            val msg = guard_err_target_running("t32_window_capture")
            expect(msg).to_start_with("T4100")
            expect(msg).to_contain("t32_window_capture")
            expect(msg).to_contain("halted CPU")

        it "T4101 includes timeout":
            val msg = guard_err_command_timeout("t32_eval", 3000)
            expect(msg).to_start_with("T4101")
            expect(msg).to_contain("3000")

        it "T4100 suggests Break command":
            val msg = guard_err_target_running("t32_field_set")
            expect(msg).to_contain("Break")
