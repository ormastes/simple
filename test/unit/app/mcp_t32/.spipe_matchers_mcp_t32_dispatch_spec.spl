# MCP T32 Dispatch spec — tests tool name routing for all 20 tools

fn mock_dispatch(tool_name: text) -> text:
    match tool_name:
        "t32_sessions_list": "sessions_list"
        "t32_session_open": "session_open"
        "t32_session_resume": "session_resume"
        "t32_session_close": "session_close"
        "t32_core_list": "core_list"
        "t32_core_select": "core_select"
        "t32_cmd_run": "cmd_run"
        "t32_cmm_run": "cmm_run"
        "t32_eval": "eval"
        "t32_window_list": "window_list"
        "t32_window_open": "window_open"
        "t32_window_capture": "window_capture"
        "t32_window_describe": "window_describe"
        "t32_screenshot": "screenshot"
        "t32_action_invoke": "action_invoke"
        "t32_field_get": "field_get"
        "t32_field_set": "field_set"
        "t32_history_tail": "history_tail"
        "t32_resources_list": "resources_list"
        "t32_resource_read": "resource_read"
        "t32_setup_headless": "setup_headless"
        "t32_area_read": "area_read"
        "t32_cmm_commands": "cmm_commands"
        _: "unknown"

describe "T32 MCP Tool Dispatch":
    it "routes session tools (4 tools)":
        expect mock_dispatch("t32_sessions_list") == "sessions_list"
        expect mock_dispatch("t32_session_open") == "session_open"
        expect mock_dispatch("t32_session_resume") == "session_resume"
        expect mock_dispatch("t32_session_close") == "session_close"

    it "routes core tools (2 tools)":
        expect mock_dispatch("t32_core_list") == "core_list"
        expect mock_dispatch("t32_core_select") == "core_select"

    it "routes command tools (3 tools)":
        expect mock_dispatch("t32_cmd_run") == "cmd_run"
        expect mock_dispatch("t32_cmm_run") == "cmm_run"
        expect mock_dispatch("t32_eval") == "eval"

    it "routes window tools (4 tools)":
        expect mock_dispatch("t32_window_list") == "window_list"
        expect mock_dispatch("t32_window_open") == "window_open"
        expect mock_dispatch("t32_window_capture") == "window_capture"
        expect mock_dispatch("t32_window_describe") == "window_describe"

    it "routes screenshot tool":
        expect mock_dispatch("t32_screenshot") == "screenshot"

    it "routes action/field tools (3 tools)":
        expect mock_dispatch("t32_action_invoke") == "action_invoke"
        expect mock_dispatch("t32_field_get") == "field_get"
        expect mock_dispatch("t32_field_set") == "field_set"

    it "routes history tool":
        expect mock_dispatch("t32_history_tail") == "history_tail"

    it "routes resource tools (2 tools)":
        expect mock_dispatch("t32_resources_list") == "resources_list"
        expect mock_dispatch("t32_resource_read") == "resource_read"

    it "routes headless tools (3 tools)":
        expect mock_dispatch("t32_setup_headless") == "setup_headless"
        expect mock_dispatch("t32_area_read") == "area_read"
        expect mock_dispatch("t32_cmm_commands") == "cmm_commands"

    it "handles unknown tool":
        expect mock_dispatch("nonexistent") == "unknown"
        expect mock_dispatch("") == "unknown"
        expect mock_dispatch("t32_bogus") == "unknown"

    it "covers all 23 tools":
        val all_tools = [
            "t32_sessions_list", "t32_session_open", "t32_session_resume", "t32_session_close",
            "t32_core_list", "t32_core_select",
            "t32_cmd_run", "t32_cmm_run", "t32_eval",
            "t32_window_list", "t32_window_open", "t32_window_capture", "t32_window_describe",
            "t32_screenshot",
            "t32_action_invoke", "t32_field_get", "t32_field_set",
            "t32_history_tail",
            "t32_resources_list", "t32_resource_read",
            "t32_setup_headless", "t32_area_read", "t32_cmm_commands"
        ]
        expect all_tools.len() == 23
        for tool in all_tools:
            val result = mock_dispatch(tool)
            expect(result).to_not_equal("unknown")