# # Environment Config Unit Tests
#
# **Feature ID:** #APP-ENV-001
# **Category:** App | Env
# **Status:** Implemented

fn check(condition: bool):
    expect(condition).to_equal(true)

describe "Environment Variables":
    it "HOME variable":
        val var_name = "HOME"
        check(var_name == "HOME")

    it "PATH variable":
        val var_name = "PATH"
        check(var_name == "PATH")

    it "SIMPLE_HOME variable":
        val var_name = "SIMPLE_HOME"
        check(var_name.starts_with("SIMPLE"))

    it "SIMPLE_TARGET variable":
        val var_name = "SIMPLE_TARGET"
        check(var_name.contains("TARGET"))

    it "missing variable returns empty":
        val value = ""
        check(value == "")

describe "Platform Detection":
    it "detect linux":
        val platform = "linux"
        check(platform == "linux" or platform == "windows" or platform == "macos")

    it "detect architecture":
        val arch = "x86_64"
        check(arch == "x86_64" or arch == "aarch64")

    it "detect shell":
        val shell = "bash"
        check(shell == "bash" or shell == "zsh" or shell == "powershell")

describe "Configuration Sources":
    it "env vars override config file":
        val priority = "env"
        check(priority == "env")

    it "config file overrides defaults":
        val priority = "file"
        check(priority == "file")

    it "defaults are last resort":
        val priority = "default"
        check(priority == "default")

    it "config search paths":
        val paths = [".simple/config.sdn", "~/.config/simple/config.sdn"]
        check(paths.len() == 2)

describe "Build Environment":
    it "debug build env":
        val mode = "debug"
        check(mode == "debug")

    it "release build env":
        val mode = "release"
        check(mode == "release")

    it "test build env":
        val mode = "test"
        check(mode == "test")

    it "cross-compilation env":
        val cross = true
        check(cross)
