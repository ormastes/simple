        val _mkdir = rt_process_run_timeout("/bin/sh", ["-c", "mkdir -p \"" + fake_sysfs_a + "/device\" \"" + fake_sysfs_b + "/device\" \"$(dirname \"" + fake_dev_a + "\")\""], 5000)
