# ============================================================================
# 3. Expected Count Guards
# ============================================================================

describe "Expected Count Guards":
    """
    ## Count Sentinels

    Hardcoded counts that must be bumped whenever the inventory grows.
    These are the tripwire: if you add a command/tool, bump the count or
    the test fails.
    """

    context "when verifying CLI expected count":
        it "CLI expected count matches classified count":
            val expected = 70
            val classified = 68
            # This will fail until surface_alignment is updated to include
            # all 70 dispatch commands. The delta reveals which commands
            # are missing from classification.
            expect(classified).to_equal(expected)

    context "when verifying MCP expected count":
        it "MCP expected count matches classified count":
            val expected = 99
            val classified = 99
            expect(classified).to_equal(expected)

    context "when verifying MCP category count":
        it "MCP has exactly 8 categories":
            val categories = [
                "debug", "debug-log", "diagnostics", "vcs",
                "cli", "query", "task", "test-daemon"
            ]
            expect(categories.len()).to_equal(8)
