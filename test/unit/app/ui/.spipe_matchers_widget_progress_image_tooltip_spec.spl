# Per-Widget SPipe Tests: Progress, Image, Tooltip
#
# Comprehensive tests for three UI widgets covering:
# - Builder creation (kind, props, children)
# - HTML rendering (classes, tags, attributes, content)

use common.ui.widget.{WidgetNode, UITree, UIState}
use common.ui.builder.{progress, image, tooltip, column}
use common.ui.state.{init_state}
use app.ui.render.widgets.{render_html_widget}


# ============================================================================
# Progress Widget - Builder
# ============================================================================

describe "Progress widget builder":
    context "creation":
        it "creates widget with kind progress":
            val p = progress("prog_create_1", 75)
            expect p.kind == "progress"

        it "assigns the correct id":
            val p = progress("prog_create_2", 50)
            expect p.id == "prog_create_2"

    context "value property":
        it "stores value as string prop":
            val p = progress("prog_val_1", 75)
            expect p.get_prop("value") == "75"

        it "stores zero value":
            val p = progress("prog_val_2", 0)
            expect p.get_prop("value") == "0"

        it "stores full value":
            val p = progress("prog_val_3", 100)
            expect p.get_prop("value") == "100"

        it "stores small value":
            val p = progress("prog_val_4", 1)
            expect p.get_prop("value") == "1"

    context "children":
        it "has no children":
            val p = progress("prog_child_1", 60)
            expect p.child_count() == 0

    context "visibility":
        it "is visible by default":
            val p = progress("prog_vis_1", 33)
            expect p.visible == true

    context "layout":
        it "has default vbox layout":
            val p = progress("prog_lay_1", 50)
            expect p.layout == "vbox"


# ============================================================================
# Progress Widget - HTML Rendering
# ============================================================================

describe "Progress widget HTML rendering":
    context "structure":
        it "contains widget-progress class":
            val node = progress("prog_html_1", 75)
            val tree = UITree.new(node)
            val state = init_state(tree)
            val html = render_html_widget(node, state)
            expect (html).contains("widget-progress")

        it "starts with div tag":
            val node = progress("prog_html_2", 50)
            val tree = UITree.new(node)
            val state = init_state(tree)
            val html = render_html_widget(node, state)
            expect (html).starts_with("<div")

        it "contains progress-bar inner div":
            val node = progress("prog_html_3", 40)
            val tree = UITree.new(node)
            val state = init_state(tree)
            val html = render_html_widget(node, state)
            expect (html).contains("progress-bar")

    context "percentage display":
        it "contains percentage text for 75":
            val node = progress("prog_pct_1", 75)
            val tree = UITree.new(node)
            val state = init_state(tree)
            val html = render_html_widget(node, state)
            expect (html).contains("75%")

        it "contains percentage text for 0":
            val node = progress("prog_pct_2", 0)
            val tree = UITree.new(node)
            val state = init_state(tree)
            val html = render_html_widget(node, state)
            expect (html).contains("0%")

        it "contains percentage text for 100":
            val node = progress("prog_pct_3", 100)
            val tree = UITree.new(node)
            val state = init_state(tree)
            val html = render_html_widget(node, state)
            expect (html).contains("100%")

    context "style width":
        it "contains width style for 75":
            val node = progress("prog_sty_1", 75)
            val tree = UITree.new(node)
            val state = init_state(tree)
            val html = render_html_widget(node, state)
            expect (html).contains("width: 75%")

        it "contains width style for 0":
            val node = progress("prog_sty_2", 0)
            val tree = UITree.new(node)
            val state = init_state(tree)
            val html = render_html_widget(node, state)
            expect (html).contains("width: 0%")

        it "contains width style for 100":
            val node = progress("prog_sty_3", 100)
            val tree = UITree.new(node)
            val state = init_state(tree)
            val html = render_html_widget(node, state)
            expect (html).contains("width: 100%")

    context "id attribute":
        it "contains the widget id in the output":
            val node = progress("prog_id_1", 55)
            val tree = UITree.new(node)
            val state = init_state(tree)
            val html = render_html_widget(node, state)
            expect (html).contains("prog_id_1")


# ============================================================================
# Image Widget - Builder
# ============================================================================

describe "Image widget builder":
    context "creation":
        it "creates widget with kind image":
            val img = image("img_create_1", "photo.png", "A photo")
            expect img.kind == "image"

        it "assigns the correct id":
            val img = image("img_create_2", "pic.jpg", "Picture")
            expect img.id == "img_create_2"

    context "src property":
        it "stores src prop":
            val img = image("img_src_1", "photo.png", "A photo")
            expect img.get_prop("src") == "photo.png"

        it "stores url src":
            val img = image("img_src_2", "https://example.com/img.png", "Remote")
            expect img.get_prop("src") == "https://example.com/img.png"

        it "stores empty src":
            val img = image("img_src_3", "", "No image")
            expect img.get_prop("src") == ""

    context "alt property":
        it "stores alt prop":
            val img = image("img_alt_1", "photo.png", "A photo")
            expect img.get_prop("alt") == "A photo"

        it "stores empty alt":
            val img = image("img_alt_2", "pic.jpg", "")
            expect img.get_prop("alt") == ""

        it "stores alt with spaces":
            val img = image("img_alt_3", "logo.svg", "Company Logo Image")
            expect img.get_prop("alt") == "Company Logo Image"

    context "children":
        it "has no children":
            val img = image("img_child_1", "a.png", "alt")
            expect img.child_count() == 0

    context "visibility":
        it "is visible by default":
            val img = image("img_vis_1", "b.png", "alt")
            expect img.visible == true

    context "has_prop":
        it "reports src exists":
            val img = image("img_has_1", "c.png", "alt")
            expect img.has_prop("src") == true

        it "reports alt exists":
            val img = image("img_has_2", "d.png", "alt text")
            expect img.has_prop("alt") == true

        it "reports missing prop as false":
            val img = image("img_has_3", "e.png", "alt")
            expect img.has_prop("nonexistent") == false


# ============================================================================
# Image Widget - HTML Rendering
# ============================================================================

describe "Image widget HTML rendering":
    context "structure":
        it "contains widget-image class":
            val node = image("img_html_1", "photo.png", "A photo")
            val tree = UITree.new(node)
            val state = init_state(tree)
            val html = render_html_widget(node, state)
            expect (html).contains("widget-image")

        it "starts with img tag":
            val node = image("img_html_2", "pic.jpg", "Picture")
            val tree = UITree.new(node)
            val state = init_state(tree)
            val html = render_html_widget(node, state)
            expect (html).starts_with("<img")

        it "is a self-closing tag":
            val node = image("img_html_3", "icon.svg", "Icon")
            val tree = UITree.new(node)
            val state = init_state(tree)
            val html = render_html_widget(node, state)
            expect (html).ends_with("/>")

    context "src attribute":
        it "contains src attribute with value":
            val node = image("img_src_html_1", "photo.png", "Photo")
            val tree = UITree.new(node)
            val state = init_state(tree)
            val html = render_html_widget(node, state)
            expect (html).contains("src=\"photo.png\"")

        it "contains src for url":
            val node = image("img_src_html_2", "https://cdn.example.com/img.jpg", "Remote")
            val tree = UITree.new(node)
            val state = init_state(tree)
            val html = render_html_widget(node, state)
            expect (html).contains("src=\"https://cdn.example.com/img.jpg\"")

        it "contains empty src attribute":
            val node = image("img_src_html_3", "", "Empty src")
            val tree = UITree.new(node)
            val state = init_state(tree)
            val html = render_html_widget(node, state)
            expect (html).contains("src=\"\"")

    context "alt attribute":
        it "contains alt attribute with value":
            val node = image("img_alt_html_1", "photo.png", "A photo")
            val tree = UITree.new(node)
            val state = init_state(tree)
            val html = render_html_widget(node, state)
            expect (html).contains("alt=\"A photo\"")

        it "contains alt for multi-word text":
            val node = image("img_alt_html_2", "banner.png", "Welcome Banner Image")
            val tree = UITree.new(node)
            val state = init_state(tree)
            val html = render_html_widget(node, state)
            expect (html).contains("alt=\"Welcome Banner Image\"")

        it "contains empty alt attribute":
            val node = image("img_alt_html_3", "decorative.png", "")
            val tree = UITree.new(node)
            val state = init_state(tree)
            val html = render_html_widget(node, state)
            expect (html).contains("alt=\"\"")

    context "id attribute":
        it "contains the widget id":
            val node = image("img_id_html_1", "x.png", "X")
            val tree = UITree.new(node)
            val state = init_state(tree)
            val html = render_html_widget(node, state)
            expect (html).contains("img_id_html_1")


# ============================================================================
# Tooltip Widget - Builder
# ============================================================================

describe "Tooltip widget builder":
    context "creation":
        it "creates widget with kind tooltip":
            val tt = tooltip("tt_create_1", "Help text", "target_btn")
            expect tt.kind == "tooltip"

        it "assigns the correct id":
            val tt = tooltip("tt_create_2", "Info", "some_target")
            expect tt.id == "tt_create_2"

    context "content property":
        it "stores content prop":
            val tt = tooltip("tt_content_1", "Help text", "target_btn")
            expect tt.get_prop("content") == "Help text"

        it "stores empty content":
            val tt = tooltip("tt_content_2", "", "btn")
            expect tt.get_prop("content") == ""

        it "stores content with special characters":
            val tt = tooltip("tt_content_3", "Press Ctrl+S to save", "save_btn")
            expect tt.get_prop("content") == "Press Ctrl+S to save"

    context "target property":
        it "stores target prop":
            val tt = tooltip("tt_target_1", "Help text", "target_btn")
            expect tt.get_prop("target") == "target_btn"

        it "stores different target id":
            val tt = tooltip("tt_target_2", "Click here", "submit_button")
            expect tt.get_prop("target") == "submit_button"

    context "children":
        it "has no children":
            val tt = tooltip("tt_child_1", "tip", "tgt")
            expect tt.child_count() == 0

    context "visibility":
        it "is visible by default":
            val tt = tooltip("tt_vis_1", "tip", "tgt")
            expect tt.visible == true

    context "has_prop":
        it "reports content exists":
            val tt = tooltip("tt_has_1", "text", "tgt")
            expect tt.has_prop("content") == true

        it "reports target exists":
            val tt = tooltip("tt_has_2", "text", "tgt")
            expect tt.has_prop("target") == true

        it "reports missing prop as false":
            val tt = tooltip("tt_has_3", "text", "tgt")
            expect tt.has_prop("label") == false


# ============================================================================
# Tooltip Widget - HTML Rendering
# ============================================================================

describe "Tooltip widget HTML rendering":
    context "structure":
        it "contains widget-tooltip class":
            val node = tooltip("tt_html_1", "Help text", "target_btn")
            val tree = UITree.new(node)
            val state = init_state(tree)
            val html = render_html_widget(node, state)
            expect (html).contains("widget-tooltip")

        it "starts with div tag":
            val node = tooltip("tt_html_2", "Tip", "btn")
            val tree = UITree.new(node)
            val state = init_state(tree)
            val html = render_html_widget(node, state)
            expect (html).starts_with("<div")

        it "ends with closing div tag":
            val node = tooltip("tt_html_3", "Info", "link")
            val tree = UITree.new(node)
            val state = init_state(tree)
            val html = render_html_widget(node, state)
            expect (html).ends_with("</div>")

    context "data-target attribute":
        it "contains data-target attribute":
            val node = tooltip("tt_tgt_html_1", "Help", "target_btn")
            val tree = UITree.new(node)
            val state = init_state(tree)
            val html = render_html_widget(node, state)
            expect (html).contains("data-target")

        it "contains target id value in data-target":
            val node = tooltip("tt_tgt_html_2", "Hint", "my_button")
            val tree = UITree.new(node)
            val state = init_state(tree)
            val html = render_html_widget(node, state)
            expect (html).contains("data-target=\"my_button\"")

        it "contains different target id":
            val node = tooltip("tt_tgt_html_3", "Note", "save_icon")
            val tree = UITree.new(node)
            val state = init_state(tree)
            val html = render_html_widget(node, state)
            expect (html).contains("data-target=\"save_icon\"")

    context "content text":
        it "contains tooltip content":
            val node = tooltip("tt_cnt_html_1", "Help text", "btn")
            val tree = UITree.new(node)
            val state = init_state(tree)
            val html = render_html_widget(node, state)
            expect (html).contains("Help text")

        it "contains multi-word content":
            val node = tooltip("tt_cnt_html_2", "Click this button to submit", "submit_btn")
            val tree = UITree.new(node)
            val state = init_state(tree)
            val html = render_html_widget(node, state)
            expect (html).contains("Click this button to submit")

        it "renders empty content without error":
            val node = tooltip("tt_cnt_html_3", "", "btn")
            val tree = UITree.new(node)
            val state = init_state(tree)
            val html = render_html_widget(node, state)
            expect (html).contains("widget-tooltip")

    context "id attribute":
        it "contains the widget id":
            val node = tooltip("tt_id_html_1", "Tip", "tgt")
            val tree = UITree.new(node)
            val state = init_state(tree)
            val html = render_html_widget(node, state)
            expect (html).contains("tt_id_html_1")


# ============================================================================
# Cross-Widget Integration
# ============================================================================

describe "Progress, Image, Tooltip integration":
    context "as children in a container":
        it "progress can be a child of a column":
            val p = progress("integ_prog_1", 80)
            val col = column("integ_col_1", [p])
            expect col.child_count() == 1

        it "image can be a child of a column":
            val img = image("integ_img_1", "pic.png", "Pic")
            val col = column("integ_col_2", [img])
            expect col.child_count() == 1

        it "all three widgets in one container":
            val p = progress("integ_prog_2", 50)
            val img = image("integ_img_2", "logo.png", "Logo")
            val tt = tooltip("integ_tt_1", "Help", "integ_prog_2")
            val col = column("integ_col_3", [p, img, tt])
            expect col.child_count() == 3

    context "prop isolation":
        it "progress and image have independent props":
            val p = progress("iso_prog_1", 42)
            val img = image("iso_img_1", "file.png", "File")
            expect p.get_prop("value") == "42"
            expect img.get_prop("src") == "file.png"
            expect p.get_prop("src") == ""
            expect img.get_prop("value") == ""

        it "tooltip and progress have independent props":
            val tt = tooltip("iso_tt_1", "Tip text", "target")
            val p = progress("iso_prog_2", 99)
            expect tt.get_prop("content") == "Tip text"
            expect p.get_prop("value") == "99"
            expect tt.get_prop("value") == ""
            expect p.get_prop("content") == ""