# @cover app.ui.tauri.backend
# @gui: headless


use app.ui.tauri.backend.{TauriBackend}
use common.ui.capability.{Capability, has_capability}

describe "TauriBackend":
    it "creates successfully":
        val result = TauriBackend.new(3000)
        match result:
            Ok(backend) =>
                expect backend.backend_name() == "tauri"
            Err(e) =>
                expect false == true

    it "reports correct capabilities":
        val result = TauriBackend.new(3000)
        match result:
            Ok(backend) =>
                val caps = backend.capabilities()
                expect has_capability(caps, Capability.Mouse) == true
                expect has_capability(caps, Capability.Color) == true
                expect has_capability(caps, Capability.Images) == true
                expect has_capability(caps, Capability.NativeDialogs) == true
                expect has_capability(caps, Capability.Notification) == true
                expect has_capability(caps, Capability.Touch) == false
            Err(_) =>
                expect false == true

    it "has correct viewport":
        val result = TauriBackend.new(3000)
        match result:
            Ok(backend) =>
                expect backend.viewport_width() == 1280
                expect backend.viewport_height() == 720
            Err(_) =>
                expect false == true

    it "initializes and shuts down":
        val result = TauriBackend.new(3000)
        match result:
            Ok(backend) =>
                val init_result = backend.init()
                match init_result:
                    Ok(ok) =>
                        expect ok == true
                    Err(_) =>
                        expect false == true
                backend.shutdown()
            Err(_) =>
                expect false == true