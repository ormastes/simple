# Feature: Headless Application for UI Testing
# Category: UI Components
# Status: Implemented

use std.spec.*

use app.ui.none.app.{HeadlessApp}
use common.ui.widget.{UIEvent, UIMode}


# ============================================================================
# Test Group 1: Loading
# ============================================================================

describe "HeadlessApp Loading":

    it "loads a valid .ui.sdn file":
        val result = HeadlessApp.new("examples/ui/minimal.ui.sdn")
        match result:
            Ok(app) =>
                expect true == true
            Err(e) =>
                expect false == true

    it "returns error for nonexistent file":
        val result = HeadlessApp.new("nonexistent/path.ui.sdn")
        match result:
            Ok(app) =>
                expect false == true
            Err(e) =>
                expect true == true


# ============================================================================
# Test Group 2: Running
# ============================================================================

describe "HeadlessApp Running":

    it "performs initial render on run":
        val result = HeadlessApp.new("examples/ui/minimal.ui.sdn")
        match result:
            Ok(app) =>
                val run_result = app.run()
                match run_result:
                    Ok(_) =>
                        expect app.render_count() > 0
                    Err(e) =>
                        expect false == true
            Err(e) =>
                expect false == true

    it "stops on Quit event":
        val result = HeadlessApp.new("examples/ui/minimal.ui.sdn")
        match result:
            Ok(app) =>
                app.inject_event(UIEvent.Quit)
                val run_result = app.run()
                match run_result:
                    Ok(_) =>
                        expect true == true
                    Err(e) =>
                        expect false == true
            Err(e) =>
                expect false == true


# ============================================================================
# Test Group 3: State Transitions
# ============================================================================

describe "HeadlessApp State Transitions":

    it "returns current state":
        val result = HeadlessApp.new("examples/ui/minimal.ui.sdn")
        match result:
            Ok(app) =>
                val state = app.current_state()
                expect state.tree.title == "Minimal"
            Err(e) =>
                expect false == true

    it "processes FocusNext event":
        val result = HeadlessApp.new("examples/ui/minimal.ui.sdn")
        match result:
            Ok(app) =>
                val new_state = app.run_single_event(UIEvent.FocusNext)
                expect new_state.tree.title == "Minimal"
            Err(e) =>
                expect false == true

    it "processes CommandMode event":
        val result = HeadlessApp.new("examples/ui/minimal.ui.sdn")
        match result:
            Ok(app) =>
                val new_state = app.run_single_event(UIEvent.CommandMode)
                expect app.render_count() > 0
            Err(e) =>
                expect false == true


# ============================================================================
# Test Group 4: Render Capture
# ============================================================================

describe "HeadlessApp Render Capture":

    it "captures rendered HTML":
        val result = HeadlessApp.new("examples/ui/minimal.ui.sdn")
        match result:
            Ok(app) =>
                app.run()
                val html = app.last_html()
                expect html.len() > 0
            Err(e) =>
                expect false == true