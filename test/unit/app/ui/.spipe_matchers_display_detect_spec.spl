# @cover common.test_runner.display_detect
# @gui: headless


use common.test_runner.display_detect.{detect_display, has_any_display, can_show_gui,
    display_kind_name, DISPLAY_NONE, DISPLAY_X11, DISPLAY_WAYLAND, DISPLAY_MACOS, DISPLAY_XVFB}

describe "Display Detection":
    it "returns a DisplayInfo struct":
        val info = detect_display()
        # Just verify it returns without crashing
        val name = display_kind_name(info.kind)
        expect name == "").to_equal(false

    it "has_any_display returns a boolean":
        val result = has_any_display()
        # On any system this should return true or false
        expect result == true or result == false == true

    it "can_show_gui returns a boolean":
        val result = can_show_gui()
        expect result == true or result == false == true

    describe "display_kind_name":
        it "names all display types":
            expect display_kind_name(DISPLAY_NONE) == "none"
            expect display_kind_name(DISPLAY_X11) == "X11"
            expect display_kind_name(DISPLAY_WAYLAND) == "Wayland"
            expect display_kind_name(DISPLAY_MACOS) == "macOS"
            expect display_kind_name(DISPLAY_XVFB) == "Xvfb"

        it "handles unknown values":
            expect display_kind_name(99) == "unknown"