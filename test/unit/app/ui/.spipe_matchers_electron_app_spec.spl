# Feature: Electron Backend IPC and Rendering
# Category: UI Components
# Status: Implemented

use std.spec.*

use app.ui.electron.backend.{ElectronBackend}
use common.ui.widget.{UIEvent}


# ============================================================================
# Test Group 1: Electron Backend Creation
# ============================================================================

describe "Electron Backend Creation":

    it "creates successfully":
        val result = ElectronBackend.new(3000)
        match result:
            Ok(backend) =>
                expect backend.backend_name() == "electron"
                expect backend.viewport_width() == 1280
                expect backend.viewport_height() == 720
            Err(e) =>
                expect "ElectronBackend.new failed: {e}" == ""

    it "reports backend name":
        val result = ElectronBackend.new(3000)
        match result:
            Ok(backend) =>
                expect backend.backend_name() == "electron"
            Err(e) =>
                expect "ElectronBackend.new failed: {e}" == ""


# ============================================================================
# Test Group 2: Lifecycle
# ============================================================================

describe "Electron Backend Lifecycle":

    it "initializes successfully":
        val result = ElectronBackend.new(3000)
        match result:
            Ok(backend) =>
                val init_result = backend.init()
                match init_result:
                    Ok(initialized) =>
                        expect initialized == true
                    Err(e) =>
                        expect "ElectronBackend.init failed: {e}" == ""
            Err(e) =>
                expect "ElectronBackend.new failed: {e}" == ""

    it "shuts down cleanly":
        val result = ElectronBackend.new(3000)
        match result:
            Ok(backend) =>
                val init_result = backend.init()
                match init_result:
                    Ok(initialized) =>
                        expect initialized == true
                    Err(e) =>
                        expect "ElectronBackend.init failed: {e}" == ""
                backend.shutdown()
                expect backend.backend_name() == "electron"
                expect backend.supports_touch() == false
            Err(e) =>
                expect "ElectronBackend.new failed: {e}" == ""


# ============================================================================
# Test Group 3: Capabilities
# ============================================================================

describe "Electron Backend Capabilities":

    it "supports mouse and color and images":
        val result = ElectronBackend.new(3000)
        match result:
            Ok(backend) =>
                expect backend.supports_mouse() == true
                expect backend.supports_color() == true
                expect backend.supports_images() == true
            Err(e) =>
                expect "ElectronBackend.new failed: {e}" == ""

    it "does not support touch":
        val result = ElectronBackend.new(3000)
        match result:
            Ok(backend) =>
                expect backend.supports_touch() == false
            Err(e) =>
                expect "ElectronBackend.new failed: {e}" == ""


# ============================================================================
# Test Group 4: Viewport
# ============================================================================

describe "Electron Backend Viewport":

    it "has default viewport 1280x720":
        val result = ElectronBackend.new(3000)
        match result:
            Ok(backend) =>
                expect backend.viewport_width() == 1280
                expect backend.viewport_height() == 720
            Err(e) =>
                expect "ElectronBackend.new failed: {e}" == ""