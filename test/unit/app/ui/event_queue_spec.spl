# Feature: Event Queue for Headless UI Testing
# Category: UI Components
# Status: Implemented

import std.spec

use app.ui.none.event_queue.{EventQueue}
use common.ui.widget.{UIEvent}


# ============================================================================
# Test Group 1: Basic Operations
# ============================================================================

describe "EventQueue Basic Operations":

    it "starts empty":
        val q = EventQueue.new()
        expect(q.is_empty()).to_equal(true)
        expect(q.len()).to_equal(0)

    it "returns nil when popping from empty queue":
        val q = EventQueue.new()
        val event = q.pop()
        expect(event == nil).to_equal(true)

    it "pushes and pops a single event":
        var q = EventQueue.new()
        q.push(UIEvent.Quit)
        expect(q.is_empty()).to_equal(false)
        expect(q.len()).to_equal(1)
        val event = q.pop()
        expect(event != nil).to_equal(true)

    it "maintains FIFO order":
        var q = EventQueue.new()
        q.push(UIEvent.KeyPress(key: "a"))
        q.push(UIEvent.KeyPress(key: "b"))
        q.push(UIEvent.KeyPress(key: "c"))

        expect(q.len()).to_equal(3)

        val e1 = q.pop()
        val e2 = q.pop()
        val e3 = q.pop()
        val e4 = q.pop()

        expect(e1 != nil).to_equal(true)
        expect(e2 != nil).to_equal(true)
        expect(e3 != nil).to_equal(true)
        expect(e4 == nil).to_equal(true)


# ============================================================================
# Test Group 2: Batch Operations
# ============================================================================

describe "EventQueue Batch Operations":

    it "push_all adds multiple events":
        var q = EventQueue.new()
        val events = [UIEvent.KeyPress(key: "x"), UIEvent.KeyPress(key: "y"), UIEvent.Quit]
        q.push_all(events)
        expect(q.len()).to_equal(3)

    it "clear removes all events":
        var q = EventQueue.new()
        q.push(UIEvent.Quit)
        q.push(UIEvent.Quit)
        expect(q.len()).to_equal(2)
        q.clear()
        expect(q.is_empty()).to_equal(true)
        expect(q.len()).to_equal(0)
