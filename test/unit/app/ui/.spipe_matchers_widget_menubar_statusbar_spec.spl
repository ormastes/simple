# MenuBar and StatusBar Widget Specification
#
# Per-widget SPipe tests for menubar and statusbar widgets.
# Covers creation, properties, children, layout, HTML rendering,
# and template expansion.

use common.ui.widget.{WidgetNode, UITree, UIState, UIMode, WidgetRect}
use common.ui.builder.{menubar, statusbar, column, build_tree, build_tree_with_title}
use common.ui.layout.{compute_layout, get_fixed_height}
use common.ui.state.{init_state}
use app.ui.render.widgets.{render_html_widget, render_html_menubar, render_html_statusbar, expand_template}


# ============================================================================
# MenuBar — Creation
# ============================================================================

describe "MenuBar creation":
    it "creates a menubar with correct kind":
        val bar = menubar("menu_create_1", ["File", "Edit", "View"])
        expect bar.kind == "menubar"

    it "creates a menubar with correct id":
        val bar = menubar("menu_create_2", ["File", "Edit", "View"])
        expect bar.id == "menu_create_2"

    it "defaults visible to true":
        val bar = menubar("menu_create_3", ["File"])
        expect bar.visible == true

    it "defaults focused to false":
        val bar = menubar("menu_create_4", ["File"])
        expect bar.focused == false


# ============================================================================
# MenuBar — Children
# ============================================================================

describe "MenuBar children":
    it "has correct child count for three items":
        val bar = menubar("menu_child_1", ["File", "Edit", "View"])
        expect bar.child_count() == 3

    it "first child has label File":
        val bar = menubar("menu_child_2", ["File", "Edit", "View"])
        val first = bar.child_at(0)
        expect first != nil == true
        expect first.get_prop("label") == "File"

    it "second child has label Edit":
        val bar = menubar("menu_child_3", ["File", "Edit", "View"])
        val second = bar.child_at(1)
        expect second != nil == true
        expect second.get_prop("label") == "Edit"

    it "third child has label View":
        val bar = menubar("menu_child_4", ["File", "Edit", "View"])
        val third = bar.child_at(2)
        expect third != nil == true
        expect third.get_prop("label") == "View"

    it "children are text widgets":
        val bar = menubar("menu_child_5", ["File", "Edit"])
        val first = bar.child_at(0)
        expect first.kind == "text"

    it "child ids follow naming convention":
        val bar = menubar("menu_child_6", ["File", "Edit"])
        val first = bar.child_at(0)
        expect first.id == "menu_child_6_menu_0"

    it "second child id has index 1":
        val bar = menubar("menu_child_7", ["File", "Edit"])
        val second = bar.child_at(1)
        expect second.id == "menu_child_7_menu_1"

    it "empty menubar has zero children":
        val bar = menubar("menu_child_8", [])
        expect bar.child_count() == 0

    it "single item menubar has one child":
        val bar = menubar("menu_child_9", ["Help"])
        expect bar.child_count() == 1

    it "single item child has correct label":
        val bar = menubar("menu_child_10", ["Help"])
        val first = bar.child_at(0)
        expect first.get_prop("label") == "Help"

    it "children list matches child_count":
        val bar = menubar("menu_child_11", ["A", "B", "C", "D"])
        val kids = bar.children()
        expect kids.len() == 4

    it "child_at out of range returns nil":
        val bar = menubar("menu_child_12", ["File"])
        val oob = bar.child_at(5)
        expect oob to_be_nil


# ============================================================================
# MenuBar — Layout
# ============================================================================

describe "MenuBar layout":
    it "gets fixed height of 1 by default":
        val bar = menubar("menu_layout_1", ["File", "Edit"])
        val h = get_fixed_height(bar)
        expect h == 1

    it "compute_layout assigns correct rect":
        val bar = menubar("menu_layout_2", ["File"])
        val rects = compute_layout(bar, 0, 0, 80, 1)
        expect rects.len() to_be_greater_than 0
        val first_rect = rects[0]
        expect first_rect.id == "menu_layout_2"
        expect first_rect.x == 0
        expect first_rect.y == 0
        expect first_rect.w == 80
        expect first_rect.h == 1

    it "menubar height consumed in vbox layout":
        val bar = menubar("menu_layout_3", ["File"])
        val content = WidgetNode.new("menu_layout_3_content", "panel")
        val root = column("menu_layout_3_root", [bar, content])
        val rects = compute_layout(root, 0, 0, 80, 24)
        # menubar should be at y=0 with h=1
        var bar_rect: WidgetRect? = nil
        for rect in rects:
            if rect.id == "menu_layout_3":
                bar_rect = rect
        expect bar_rect != nil == true
        expect bar_rect.h == 1


# ============================================================================
# MenuBar — HTML Rendering
# ============================================================================

describe "MenuBar HTML rendering":
    it "output contains widget-menubar class":
        val bar = menubar("menu_html_1", ["File", "Edit"])
        val tree = build_tree(bar)
        val state = init_state(tree)
        val html = render_html_widget(bar, state)
        expect (html).contains("widget-menubar")

    it "output contains the menubar id":
        val bar = menubar("menu_html_2", ["File"])
        val tree = build_tree(bar)
        val state = init_state(tree)
        val html = render_html_widget(bar, state)
        expect (html).contains("menu_html_2")

    it "output contains menu-item span for each item":
        val bar = menubar("menu_html_3", ["File", "Edit", "View"])
        val tree = build_tree(bar)
        val state = init_state(tree)
        val html = render_html_widget(bar, state)
        expect (html).contains("menu-item")

    it "output contains label text File":
        val bar = menubar("menu_html_4", ["File", "Edit"])
        val tree = build_tree(bar)
        val state = init_state(tree)
        val html = render_html_widget(bar, state)
        expect (html).contains("File")

    it "output contains label text Edit":
        val bar = menubar("menu_html_5", ["File", "Edit"])
        val tree = build_tree(bar)
        val state = init_state(tree)
        val html = render_html_widget(bar, state)
        expect (html).contains("Edit")

    it "output is a div element":
        val bar = menubar("menu_html_6", ["File"])
        val tree = build_tree(bar)
        val state = init_state(tree)
        val html = render_html_widget(bar, state)
        expect (html).starts_with("<div")
        expect (html).ends_with("</div>")

    it "empty menubar renders with no menu-item spans":
        val bar = menubar("menu_html_7", [])
        val tree = build_tree(bar)
        val state = init_state(tree)
        val html = render_html_widget(bar, state)
        expect (html).contains("widget-menubar")

    it "renders span elements for each menu item":
        val bar = menubar("menu_html_8", ["Help"])
        val tree = build_tree(bar)
        val state = init_state(tree)
        val html = render_html_widget(bar, state)
        expect (html).contains("<span class=\"menu-item\">")
        expect (html).contains("Help")
        expect (html).contains("</span>")


# ============================================================================
# StatusBar — Creation
# ============================================================================

describe "StatusBar creation":
    it "creates a statusbar with correct kind":
        val bar = statusbar("status_create_1", "MODE: Normal", "My App")
        expect bar.kind == "statusbar"

    it "creates a statusbar with correct id":
        val bar = statusbar("status_create_2", "left text", "right text")
        expect bar.id == "status_create_2"

    it "defaults visible to true":
        val bar = statusbar("status_create_3", "left", "right")
        expect bar.visible == true

    it "defaults focused to false":
        val bar = statusbar("status_create_4", "left", "right")
        expect bar.focused == false


# ============================================================================
# StatusBar — Properties
# ============================================================================

describe "StatusBar properties":
    it "left prop returns left text":
        val bar = statusbar("status_prop_1", "MODE: Normal", "My App")
        expect bar.get_prop("left") == "MODE: Normal"

    it "right prop returns right text":
        val bar = statusbar("status_prop_2", "MODE: Normal", "My App")
        expect bar.get_prop("right") == "My App"

    it "empty left is preserved":
        val bar = statusbar("status_prop_3", "", "right side")
        expect bar.get_prop("left") == ""

    it "empty right is preserved":
        val bar = statusbar("status_prop_4", "left side", "")
        expect bar.get_prop("right") == ""

    it "both empty strings are valid":
        val bar = statusbar("status_prop_5", "", "")
        expect bar.get_prop("left") == ""
        expect bar.get_prop("right") == ""

    it "has_prop returns true for left":
        val bar = statusbar("status_prop_6", "L", "R")
        expect bar.has_prop("left") == true

    it "has_prop returns true for right":
        val bar = statusbar("status_prop_7", "L", "R")
        expect bar.has_prop("right") == true

    it "has_prop returns false for unknown key":
        val bar = statusbar("status_prop_8", "L", "R")
        expect bar.has_prop("center") == false

    it "statusbar has no children":
        val bar = statusbar("status_prop_9", "left", "right")
        expect bar.child_count() == 0


# ============================================================================
# StatusBar — Layout
# ============================================================================

describe "StatusBar layout":
    it "gets fixed height of 1 by default":
        val bar = statusbar("status_layout_1", "left", "right")
        val h = get_fixed_height(bar)
        expect h == 1

    it "compute_layout assigns correct rect":
        val bar = statusbar("status_layout_2", "left", "right")
        val rects = compute_layout(bar, 0, 23, 80, 1)
        expect rects.len() to_be_greater_than 0
        val first_rect = rects[0]
        expect first_rect.id == "status_layout_2"
        expect first_rect.x == 0
        expect first_rect.y == 23
        expect first_rect.w == 80
        expect first_rect.h == 1

    it "statusbar height consumed in vbox layout":
        val content = WidgetNode.new("status_layout_3_content", "panel")
        val bar = statusbar("status_layout_3", "left", "right")
        val root = column("status_layout_3_root", [content, bar])
        val rects = compute_layout(root, 0, 0, 80, 24)
        var bar_rect: WidgetRect? = nil
        for rect in rects:
            if rect.id == "status_layout_3":
                bar_rect = rect
        expect bar_rect != nil == true
        expect bar_rect.h == 1


# ============================================================================
# StatusBar — HTML Rendering
# ============================================================================

describe "StatusBar HTML rendering":
    it "output contains widget-statusbar class":
        val bar = statusbar("status_html_1", "Left", "Right")
        val tree = build_tree(bar)
        val state = init_state(tree)
        val html = render_html_widget(bar, state)
        expect (html).contains("widget-statusbar")

    it "output contains the statusbar id":
        val bar = statusbar("status_html_2", "Left", "Right")
        val tree = build_tree(bar)
        val state = init_state(tree)
        val html = render_html_widget(bar, state)
        expect (html).contains("status_html_2")

    it "output contains status-left span":
        val bar = statusbar("status_html_3", "Left Text", "Right Text")
        val tree = build_tree(bar)
        val state = init_state(tree)
        val html = render_html_widget(bar, state)
        expect (html).contains("status-left")

    it "output contains status-right span":
        val bar = statusbar("status_html_4", "Left Text", "Right Text")
        val tree = build_tree(bar)
        val state = init_state(tree)
        val html = render_html_widget(bar, state)
        expect (html).contains("status-right")

    it "output contains left text content":
        val bar = statusbar("status_html_5", "MODE: Normal", "My App")
        val tree = build_tree(bar)
        val state = init_state(tree)
        val html = render_html_widget(bar, state)
        expect (html).contains("MODE: Normal")

    it "output contains right text content":
        val bar = statusbar("status_html_6", "MODE: Normal", "My App")
        val tree = build_tree(bar)
        val state = init_state(tree)
        val html = render_html_widget(bar, state)
        expect (html).contains("My App")

    it "output is a div element":
        val bar = statusbar("status_html_7", "left", "right")
        val tree = build_tree(bar)
        val state = init_state(tree)
        val html = render_html_widget(bar, state)
        expect (html).starts_with("<div")
        expect (html).ends_with("</div>")

    it "renders both span elements":
        val bar = statusbar("status_html_8", "L", "R")
        val tree = build_tree(bar)
        val state = init_state(tree)
        val html = render_html_widget(bar, state)
        expect (html).contains("<span class=\"status-left\">")
        expect (html).contains("<span class=\"status-right\">")


# ============================================================================
# StatusBar — Template Expansion
# ============================================================================

describe "StatusBar template expansion":
    it "expands app.mode to NORMAL in left text":
        val ph_mode = "{" + "app.mode" + "}"
        val bar = statusbar("status_tpl_1", ph_mode, "Title")
        val tree = build_tree(bar)
        val state = init_state(tree)
        val html = render_html_widget(bar, state)
        expect (html).contains("NORMAL")

    it "expands app.title to tree title in right text":
        val ph_title = "{" + "app.title" + "}"
        val bar = statusbar("status_tpl_2", "Mode", ph_title)
        val root = bar
        val tree = build_tree_with_title(root, "My Editor", "dark")
        val state = init_state(tree)
        val html = render_html_widget(bar, state)
        expect (html).contains("My Editor")

    it "expands both placeholders simultaneously":
        val ph_mode = "{" + "app.mode" + "}"
        val ph_title = "{" + "app.title" + "}"
        val bar = statusbar("status_tpl_3", ph_mode, ph_title)
        val tree = build_tree_with_title(bar, "Test App", "dark")
        val state = init_state(tree)
        val html = render_html_widget(bar, state)
        expect (html).contains("NORMAL")
        expect (html).contains("Test App")

    it "leaves plain text unchanged":
        val bar = statusbar("status_tpl_4", "static left", "static right")
        val tree = build_tree(bar)
        val state = init_state(tree)
        val html = render_html_widget(bar, state)
        expect (html).contains("static left")
        expect (html).contains("static right")

    it "expand_template returns NORMAL for app.mode":
        val ph_mode = "{" + "app.mode" + "}"
        val bar = statusbar("status_tpl_5", "x", "y")
        val tree = build_tree(bar)
        val state = init_state(tree)
        val result = expand_template(ph_mode, state)
        expect result == "NORMAL"

    it "expand_template returns tree title for app.title":
        val ph_title = "{" + "app.title" + "}"
        val bar = statusbar("status_tpl_6", "x", "y")
        val tree = build_tree_with_title(bar, "Code Editor", "dark")
        val state = init_state(tree)
        val result = expand_template(ph_title, state)
        expect result == "Code Editor"

    it "expand_template returns empty string for empty input":
        val bar = statusbar("status_tpl_7", "x", "y")
        val tree = build_tree(bar)
        val state = init_state(tree)
        val result = expand_template("", state)
        expect result == ""

    it "expand_template preserves text without placeholders":
        val bar = statusbar("status_tpl_8", "x", "y")
        val tree = build_tree(bar)
        val state = init_state(tree)
        val result = expand_template("hello world", state)
        expect result == "hello world"

    it "renders expanded mode in status-left span":
        val ph_mode = "{" + "app.mode" + "}"
        val bar = statusbar("status_tpl_9", ph_mode, "right")
        val tree = build_tree(bar)
        val state = init_state(tree)
        val html = render_html_widget(bar, state)
        expect (html).contains("<span class=\"status-left\">NORMAL</span>")

    it "renders expanded title in status-right span":
        val ph_title = "{" + "app.title" + "}"
        val bar = statusbar("status_tpl_10", "left", ph_title)
        val tree = build_tree_with_title(bar, "My Title", "dark")
        val state = init_state(tree)
        val html = render_html_widget(bar, state)
        expect (html).contains("<span class=\"status-right\">My Title</span>")


# ============================================================================
# Combined — MenuBar + StatusBar in a tree
# ============================================================================

describe "MenuBar and StatusBar combined":
    it "both widgets coexist in a column layout":
        val menu = menubar("combined_menu_1", ["File", "Edit"])
        val content = WidgetNode.new("combined_content_1", "panel")
        val status = statusbar("combined_status_1", "NORMAL", "App")
        val root = column("combined_root_1", [menu, content, status])
        val rects = compute_layout(root, 0, 0, 80, 24)
        var menu_rect: WidgetRect? = nil
        var status_rect: WidgetRect? = nil
        for rect in rects:
            if rect.id == "combined_menu_1":
                menu_rect = rect
            if rect.id == "combined_status_1":
                status_rect = rect
        expect menu_rect != nil == true
        expect status_rect != nil == true
        expect menu_rect.h == 1
        expect status_rect.h == 1

    it "menubar is above statusbar in vbox order":
        val menu = menubar("combined_menu_2", ["File"])
        val content = WidgetNode.new("combined_content_2", "panel")
        val status = statusbar("combined_status_2", "L", "R")
        val root = column("combined_root_2", [menu, content, status])
        val rects = compute_layout(root, 0, 0, 80, 24)
        var menu_y = -1
        var status_y = -1
        for rect in rects:
            if rect.id == "combined_menu_2":
                menu_y = rect.y
            if rect.id == "combined_status_2":
                status_y = rect.y
        expect menu_y to_be_less_than status_y

    it "tree finds both widgets by id":
        val menu = menubar("combined_menu_3", ["File"])
        val status = statusbar("combined_status_3", "L", "R")
        val root = column("combined_root_3", [menu, status])
        val tree = build_tree(root)
        val found_menu = tree.find_widget("combined_menu_3")
        val found_status = tree.find_widget("combined_status_3")
        expect found_menu != nil == true
        expect found_status != nil == true
        expect found_menu.kind == "menubar"
        expect found_status.kind == "statusbar"