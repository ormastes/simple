# Async IPC Specification
#
# Tests the channel-based async IPC handler: reader pushes parsed events
# to a channel, writer sends render messages, quit terminates the reader,
# invalid JSON is handled gracefully, and channel close stops the reader.

use std.nogc_async_mut.concurrent.channel.{Channel, channel_new}
use std.nogc_async_mut.concurrent.thread.{thread_spawn, thread_sleep}
use common.ui.widget.{UIEvent}
use app.ui.ipc.protocol.{parse_ipc_message, build_ipc_render}


# ============================================================================
# parse_ipc_message integration (channel push)
# ============================================================================

describe "IPC reader pushes parsed events to channel":
    it "sends KeyPress event parsed from JSON to channel":
        val ch = channel_new()
        val json = "{\"type\":\"keypress\",\"key\":\"a\"}"
        val event = parse_ipc_message(json)
        if event != nil:
            ch.send(event)
        val received = ch.try_recv()
        expect received != nil == true

    it "sends Quit event parsed from JSON to channel":
        val ch = channel_new()
        val json = "{\"type\":\"quit\"}"
        val event = parse_ipc_message(json)
        if event != nil:
            ch.send(event)
        val received = ch.try_recv()
        expect received != nil == true

    it "sends Action event parsed from JSON to channel":
        val ch = channel_new()
        val json = "{\"type\":\"action\",\"name\":\"save\"}"
        val event = parse_ipc_message(json)
        if event != nil:
            ch.send(event)
        val received = ch.try_recv()
        expect received != nil == true


# ============================================================================
# IPC writer sends render messages
# ============================================================================

describe "IPC writer sends render messages":
    it "build_ipc_render wraps html in render JSON":
        val html = "<div>Hello Async</div>"
        val msg = build_ipc_render(html)
        expect (msg).contains("\"type\":\"render\"")
        expect (msg).contains("Hello Async")

    it "render channel can queue multiple messages":
        val ch = channel_new()
        ch.send("<p>First</p>")
        ch.send("<p>Second</p>")
        val first = ch.try_recv()
        val second = ch.try_recv()
        expect first == "<p>First</p>"
        expect second == "<p>Second</p>"


# ============================================================================
# Quit message stops reader
# ============================================================================

describe "Quit message stops reader":
    it "quit event is recognized by parse_ipc_message":
        val json = "{\"type\":\"quit\"}"
        val event = parse_ipc_message(json)
        expect event != nil == true

    it "channel receives quit then reader can stop":
        val ch = channel_new()
        val json = "{\"type\":\"quit\"}"
        val event = parse_ipc_message(json)
        if event != nil:
            ch.send(event)
        # Simulate reader checking for quit
        val received = ch.try_recv()
        expect received != nil == true


# ============================================================================
# Invalid JSON handled gracefully
# ============================================================================

describe "Invalid JSON handled gracefully":
    it "returns nil for garbage input":
        val event = parse_ipc_message("not json at all")
        expect event == nil

    it "returns nil for empty string":
        val event = parse_ipc_message("")
        expect event == nil

    it "returns nil for unknown type":
        val json = "{\"type\":\"foobar\",\"data\":\"xyz\"}"
        val event = parse_ipc_message(json)
        expect event == nil

    it "returns nil for partial JSON":
        val event = parse_ipc_message("{\"type\":")
        expect event == nil

    it "does not push nil events to channel":
        val ch = channel_new()
        val event = parse_ipc_message("garbage")
        if event != nil:
            ch.send(event)
        val received = ch.try_recv()
        expect received == nil


# ============================================================================
# Channel close stops reader
# ============================================================================

describe "Channel close stops reader":
    it "closed channel reports is_closed true":
        val ch = channel_new()
        ch.close()
        expect ch.is_closed() == true

    it "can try_recv before close returns nil when empty":
        val ch = channel_new()
        val received = ch.try_recv()
        expect received == nil

    it "can try_recv buffered message before close":
        val ch = channel_new()
        ch.send("buffered")
        val received = ch.try_recv()
        expect received == "buffered"

    it "closed channel is_closed returns true":
        val ch = channel_new()
        val before = ch.is_closed()
        expect before == false
        ch.close()
        val after = ch.is_closed()
        expect after == true