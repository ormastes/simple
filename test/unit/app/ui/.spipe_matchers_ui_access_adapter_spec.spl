# UI access adapter contract tests
#
# Verifies additive source metadata, issue handling, snapshot envelopes, and
# the working null adapter / registry contract layer.

use std.spec.{describe, it, expect}
use common.ui.access.{ui_access_empty_snapshot}
use common.ui.access_source.{UiAccessSourceMeta, UiAccessAdapterTarget, ui_access_source_meta, ui_access_source_meta_empty, ui_access_issue_error, ui_access_issue_warning, ui_access_issue_is_error, ui_access_issue_is_warning, ui_access_adapter_target, ui_access_adapter_target_for_snapshot, ui_access_snapshot_envelope, ui_access_snapshot_envelope_empty}
use common.ui.access_adapter.{UiAccessAdapterRegistry, ui_access_null_adapter_new, ui_access_adapter_registry_new}

fn _source() -> UiAccessSourceMeta:
    return ui_access_source_meta("session", "main", "Main Session", "session://main", "1")

fn _target() -> UiAccessAdapterTarget:
    return ui_access_adapter_target(
        _source(),
        "snapshot",
        "NORMAL",
        "main",
        "",
        "",
        "",
        "",
        false,
        0
    )

describe "UiAccess adapter contracts":
    it "constructs additive source metadata, issues, and envelopes":
        val source = _source()
        expect source.source_kind == "session"
        expect source.source_id == "main"
        expect source.source_name == "Main Session"
        expect source.source_uri == "session://main"
        expect source.source_version == "1"

        val issue = ui_access_issue_error("missing_surface", "surface not found", "main", "snapshot", "no active surface")
        expect ui_access_issue_is_error(issue) == true
        expect ui_access_issue_is_warning(issue) == false
        expect issue.code == "missing_surface"
        expect issue.subject == "snapshot"
        expect issue.detail == "no active surface"

        val warning = ui_access_issue_warning("adapter.disabled", "adapter disabled", "main", "snapshot", "registry entry disabled")
        expect ui_access_issue_is_warning(warning) == true

        val snapshot = ui_access_empty_snapshot("NORMAL", "main", [])
        val target = _target()
        val envelope = ui_access_snapshot_envelope(source, target, snapshot, [issue, warning])
        expect envelope.source.source_id == "main"
        expect envelope.target.operation == "snapshot"
        expect envelope.snapshot.mode == "NORMAL"
        expect envelope.snapshot.active_surface == "main"
        expect envelope.issues.len() == 2

    it "creates an empty envelope from a target without modifying the snapshot contract":
        val source = ui_access_source_meta_empty("session", "main")
        val target = ui_access_adapter_target_for_snapshot(source, "NORMAL", "main")
        val envelope = ui_access_snapshot_envelope_empty(target)
        expect envelope.source.source_id == "main"
        expect envelope.snapshot.protocol_version == 1
        expect envelope.snapshot.mode == "NORMAL"
        expect envelope.snapshot.active_surface == "main"
        expect envelope.snapshot.surfaces.len() == 0
        expect envelope.snapshot.nodes.len() == 0
        expect envelope.issues.len() == 0

    it "returns an empty snapshot envelope from the null adapter":
        val adapter = ui_access_null_adapter_new()
        expect adapter.name() == "ui_access_null_adapter"
        expect adapter.adapter_kind() == "null"
        val target = ui_access_adapter_target(_source(), "snapshot", "NORMAL", "main", "", "", "", "", false, 0)
        expect adapter.supports(target) == true
        expect adapter.describe_target(target) == "snapshot:session/main"
        val envelope = adapter.adapt(target)
        expect envelope.snapshot.protocol_version == 1
        expect envelope.snapshot.mode == "NORMAL"
        expect envelope.snapshot.active_surface == "main"
        expect envelope.snapshot.surfaces.len() == 0
        expect envelope.snapshot.nodes.len() == 0
        expect envelope.issues.len() == 0

    it "registers and resolves adapter targets in the registry":
        var registry = ui_access_adapter_registry_new()
        val target = ui_access_adapter_target(_source(), "snapshot", "NORMAL", "main", "", "", "", "", false, 0)
        expect registry.entry_count() == 0
        expect registry.has_target(target) == false

        registry.register_target(target, "null", "ui_access_null_adapter", true)
        expect registry.entry_count() == 1
        expect registry.has_target(target) == true
        expect registry.adapter_name_for(target) == "ui_access_null_adapter"
        expect registry.adapter_kind_for(target) == "null"

        val resolved = registry.resolve_target(target)
        expect resolved != nil == true
        expect resolved.target.source.source_id == "main"
        expect resolved.adapter_name == "ui_access_null_adapter"
        expect resolved.enabled == true

        val envelope = registry.adapt(target)
        expect envelope.snapshot.protocol_version == 1
        expect envelope.issues.len() == 0

    it "replaces an existing registry entry for the same source and operation":
        var registry = UiAccessAdapterRegistry.new()
        val target = ui_access_adapter_target(_source(), "snapshot", "NORMAL", "main", "", "", "", "", false, 0)
        registry.register_target(target, "null", "ui_access_null_adapter", true)
        registry.register_target(target, "null", "ui_access_null_adapter_v2", false)
        expect registry.entry_count() == 1
        expect registry.adapter_name_for(target) == "ui_access_null_adapter_v2"
        expect registry.adapter_kind_for(target) == "null"
        val envelope = registry.adapt(target)
        expect envelope.snapshot.mode == "NORMAL"
        expect envelope.issues.len() == 1
        expect envelope.issues[0].code == "adapter.disabled"