# Responsive Widget Modifier Tests (Phase 6 UI Typed Core RFC)
#
# Covers: with_responsive_layout, with_responsive_columns,
#         with_show_when_at_most, with_show_when_at_least,
#         with_show_when_orientation, SizeClass.to_wire(), Orientation.to_wire(),
#         and the mirrored WidgetNode methods.

use std.spec.{describe, it, expect}
use common.ui.profile.{Orientation, SizeClass}
use common.ui.widget.{WidgetNode}
use common.ui.builder.{
    text_widget,
    with_responsive_layout, with_responsive_columns,
    with_show_when_at_most, with_show_when_at_least,
    with_show_when_orientation
}

# =========================================================================
# SizeClass.to_wire() — stable lowercase strings
# =========================================================================

describe "SizeClass.to_wire":
    it "compact serializes to lowercase compact":
        expect SizeClass.Compact.to_wire() == "compact"

    it "regular serializes to lowercase regular":
        expect SizeClass.Regular.to_wire() == "regular"

    it "expanded serializes to lowercase expanded":
        expect SizeClass.Expanded.to_wire() == "expanded"

# =========================================================================
# Orientation.to_wire() — stable lowercase strings
# =========================================================================

describe "Orientation.to_wire":
    it "landscape serializes to lowercase landscape":
        expect Orientation.Landscape.to_wire() == "landscape"

    it "portrait serializes to lowercase portrait":
        expect Orientation.Portrait.to_wire() == "portrait"

    it "square serializes to lowercase square":
        expect Orientation.Square.to_wire() == "square"

# =========================================================================
# with_responsive_layout (free function)
# =========================================================================

describe "with_responsive_layout":
    it "stores compact layout prop":
        val node = text_widget("w1", "hello")
        val n = with_responsive_layout(node, "vbox", "hbox", "grid")
        expect n.get_prop("responsive_compact") == "vbox"

    it "stores regular layout prop":
        val node = text_widget("w2", "hello")
        val n = with_responsive_layout(node, "vbox", "hbox", "grid")
        expect n.get_prop("responsive_regular") == "hbox"

    it "stores expanded layout prop":
        val node = text_widget("w3", "hello")
        val n = with_responsive_layout(node, "vbox", "hbox", "grid")
        expect n.get_prop("responsive_expanded") == "grid"

# =========================================================================
# with_responsive_columns (free function)
# =========================================================================

describe "with_responsive_columns":
    it "stores compact column count":
        val node = text_widget("g1", "x")
        val n = with_responsive_columns(node, 1, 2, 4)
        expect n.get_prop("responsive_cols_compact") == "1"

    it "stores regular column count":
        val node = text_widget("g2", "x")
        val n = with_responsive_columns(node, 1, 2, 4)
        expect n.get_prop("responsive_cols_regular") == "2"

    it "stores expanded column count":
        val node = text_widget("g3", "x")
        val n = with_responsive_columns(node, 1, 2, 4)
        expect n.get_prop("responsive_cols_expanded") == "4"

# =========================================================================
# with_show_when_at_most (free function)
# =========================================================================

describe "with_show_when_at_most":
    it "stores compact threshold":
        val node = text_widget("sm1", "x")
        val n = with_show_when_at_most(node, SizeClass.Compact)
        expect n.get_prop("show_when_at_most") == "compact"

    it "stores regular threshold":
        val node = text_widget("sm2", "x")
        val n = with_show_when_at_most(node, SizeClass.Regular)
        expect n.get_prop("show_when_at_most") == "regular"

# =========================================================================
# with_show_when_at_least (free function)
# =========================================================================

describe "with_show_when_at_least":
    it "stores expanded threshold":
        val node = text_widget("sl1", "x")
        val n = with_show_when_at_least(node, SizeClass.Expanded)
        expect n.get_prop("show_when_at_least") == "expanded"

# =========================================================================
# with_show_when_orientation (free function)
# =========================================================================

describe "with_show_when_orientation":
    it "stores portrait orientation":
        val node = text_widget("so1", "x")
        val n = with_show_when_orientation(node, Orientation.Portrait)
        expect n.get_prop("show_when_orientation") == "portrait"

    it "stores landscape orientation":
        val node = text_widget("so2", "x")
        val n = with_show_when_orientation(node, Orientation.Landscape)
        expect n.get_prop("show_when_orientation") == "landscape"

# =========================================================================
# WidgetNode method mirrors
# =========================================================================

describe "WidgetNode.responsive_columns":
    it "stores all three column counts via method":
        var node = text_widget("mn1", "x")
        node = node.responsive_columns(1, 2, 4)
        expect node.get_prop("responsive_cols_compact") == "1"
        expect node.get_prop("responsive_cols_regular") == "2"
        expect node.get_prop("responsive_cols_expanded") == "4"

describe "WidgetNode.responsive_layout":
    it "stores all three layout names via method":
        var node = text_widget("mn2", "x")
        node = node.responsive_layout("vbox", "hbox", "grid")
        expect node.get_prop("responsive_compact") == "vbox"
        expect node.get_prop("responsive_regular") == "hbox"
        expect node.get_prop("responsive_expanded") == "grid"

describe "WidgetNode.show_when_at_most":
    it "stores threshold via method":
        var node = text_widget("mn3", "x")
        node = node.show_when_at_most(SizeClass.Compact)
        expect node.get_prop("show_when_at_most") == "compact"

describe "WidgetNode.show_when_at_least":
    it "stores threshold via method":
        var node = text_widget("mn4", "x")
        node = node.show_when_at_least(SizeClass.Regular)
        expect node.get_prop("show_when_at_least") == "regular"

describe "WidgetNode.show_when_orientation":
    it "stores orientation via method":
        var node = text_widget("mn5", "x")
        node = node.show_when_orientation(Orientation.Portrait)
        expect node.get_prop("show_when_orientation") == "portrait"