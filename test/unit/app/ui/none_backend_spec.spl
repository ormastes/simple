# Feature: None/Headless Render Backend
# Category: UI Components
# Status: Implemented

use std.spec.*

use app.ui.none.backend.{NoneBackend}
use common.ui.widget.{UIEvent}


# ============================================================================
# Test Group 1: Lifecycle
# ============================================================================

describe "NoneBackend Lifecycle":

    it "creates successfully":
        val result = NoneBackend.new()
        match result:
            Ok(backend) =>
                expect(true).to_equal(true)
            Err(e) =>
                expect(false).to_equal(true)

    it "initializes and shuts down":
        val result = NoneBackend.new()
        match result:
            Ok(backend) =>
                val init_result = backend.init()
                backend.shutdown()
                expect(true).to_equal(true)
            Err(e) =>
                expect(false).to_equal(true)


# ============================================================================
# Test Group 2: Event Injection
# ============================================================================

describe "NoneBackend Event Injection":

    it "returns nil when no events queued":
        val result = NoneBackend.new()
        match result:
            Ok(backend) =>
                val event = backend.poll_event(100)
                expect(event == nil).to_equal(true)
            Err(e) =>
                expect(false).to_equal(true)

    it "injects and polls a single event":
        val result = NoneBackend.new()
        match result:
            Ok(backend) =>
                backend.inject_event(UIEvent.Quit)
                val event = backend.poll_event(0)
                expect(event != nil).to_equal(true)
            Err(e) =>
                expect(false).to_equal(true)

    it "injects multiple events":
        val result = NoneBackend.new()
        match result:
            Ok(backend) =>
                val events = [UIEvent.KeyPress(key: "a"), UIEvent.KeyPress(key: "b")]
                backend.inject_events(events)
                val e1 = backend.poll_event(0)
                val e2 = backend.poll_event(0)
                val e3 = backend.poll_event(0)
                expect(e1 != nil).to_equal(true)
                expect(e2 != nil).to_equal(true)
                expect(e3 == nil).to_equal(true)
            Err(e) =>
                expect(false).to_equal(true)


# ============================================================================
# Test Group 3: Render Capture
# ============================================================================

describe "NoneBackend Render Capture":

    it "starts with zero render count":
        val result = NoneBackend.new()
        match result:
            Ok(backend) =>
                expect(backend.render_count()).to_equal(0)
            Err(e) =>
                expect(false).to_equal(true)

    it "starts with empty last_html":
        val result = NoneBackend.new()
        match result:
            Ok(backend) =>
                expect(backend.last_html()).to_equal("")
            Err(e) =>
                expect(false).to_equal(true)

    it "html_at returns empty for out of bounds":
        val result = NoneBackend.new()
        match result:
            Ok(backend) =>
                expect(backend.html_at(-1)).to_equal("")
                expect(backend.html_at(0)).to_equal("")
                expect(backend.html_at(100)).to_equal("")
            Err(e) =>
                expect(false).to_equal(true)


# ============================================================================
# Test Group 4: Viewport
# ============================================================================

describe "NoneBackend Viewport":

    it "has default viewport 80x24":
        val result = NoneBackend.new()
        match result:
            Ok(backend) =>
                expect(backend.viewport_width()).to_equal(80)
                expect(backend.viewport_height()).to_equal(24)
            Err(e) =>
                expect(false).to_equal(true)

    it "allows setting custom viewport":
        val result = NoneBackend.new()
        match result:
            Ok(backend) =>
                backend.set_viewport(120, 40)
                expect(backend.viewport_width()).to_equal(120)
                expect(backend.viewport_height()).to_equal(40)
            Err(e) =>
                expect(false).to_equal(true)


# ============================================================================
# Test Group 5: Capabilities
# ============================================================================

describe "NoneBackend Capabilities":

    it "reports all capabilities as false":
        val result = NoneBackend.new()
        match result:
            Ok(backend) =>
                expect(backend.supports_mouse()).to_equal(false)
                expect(backend.supports_color()).to_equal(false)
                expect(backend.supports_images()).to_equal(false)
                expect(backend.supports_touch()).to_equal(false)
            Err(e) =>
                expect(false).to_equal(true)

    it "reports backend name as none":
        val result = NoneBackend.new()
        match result:
            Ok(backend) =>
                expect(backend.backend_name()).to_equal("none")
            Err(e) =>
                expect(false).to_equal(true)
