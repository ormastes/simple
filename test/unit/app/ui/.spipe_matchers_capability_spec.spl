# @cover common.ui.capability
# @cover common.ui.backend


use common.ui.capability.{Capability, NotSupported, capability_name, has_capability}

describe "Capability":
    it "names each capability":
        expect capability_name(Capability.Mouse) == "mouse input"
        expect capability_name(Capability.Color) == "color output"
        expect capability_name(Capability.Images) == "image rendering"
        expect capability_name(Capability.Touch) == "touch input"
        expect capability_name(Capability.NativeDialogs) == "native dialogs"
        expect capability_name(Capability.Clipboard) == "clipboard access"
        expect capability_name(Capability.Notification) == "notifications"

    it "checks capability membership":
        val caps = [Capability.Mouse, Capability.Color]
        expect has_capability(caps, Capability.Mouse) == true
        expect has_capability(caps, Capability.Color) == true
        expect has_capability(caps, Capability.Images) == false
        expect has_capability(caps, Capability.Touch) == false

describe "NotSupported":
    it "creates with basic constructor":
        val ns = NotSupported.new(Capability.Images, "tui")
        expect ns.backend_name == "tui"
        expect (ns.message()).contains("tui")
        expect (ns.message()).contains("image rendering")

    it "creates with hint":
        val ns = NotSupported.with_hint(Capability.Clipboard, "tauri", "not yet wired")
        expect (ns.message()).contains("not yet wired")
        expect (ns.message()).contains("clipboard access")
        expect ns.fallback_hint == "not yet wired"

    it "forces callers to handle Result":
        val result: Result<bool, NotSupported> = Err(NotSupported.new(Capability.Images, "tui"))
        match result:
            Ok(_) =>
                expect false == true
            Err(ns) =>
                expect ns.backend_name == "tui"