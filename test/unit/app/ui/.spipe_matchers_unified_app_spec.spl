# @cover common.ui.app
# @cover common.ui.backend_factory

use common.ui.app.{UnifiedApp, AppConfig}
use common.ui.backend_factory.{create_backend}

describe "AppConfig":
    it "creates default config":
        val config = AppConfig.default_config()
        expect config.poll_timeout_ms == 100
        expect config.hot_reload == true

    it "creates headless config":
        val config = AppConfig.headless()
        expect config.poll_timeout_ms == 0
        expect config.hot_reload == false

    it "creates web config":
        val config = AppConfig.web_config()
        expect config.poll_timeout_ms == 0
        expect config.hot_reload == true

describe "create_backend":
    it "creates none backend":
        val result = create_backend("none", 3000)
        match result:
            Ok(backend) =>
                expect backend.backend_name() == "none"
            Err(e) =>
                expect false == true

    it "creates headless backend":
        val result = create_backend("headless", 3000)
        match result:
            Ok(backend) =>
                expect backend.backend_name() == "none"
            Err(e) =>
                expect false == true

    it "rejects unknown mode":
        val result = create_backend("nonexistent", 3000)
        match result:
            Ok(_) =>
                expect false == true
            Err(e) =>
                expect (e).contains("Unknown backend mode")