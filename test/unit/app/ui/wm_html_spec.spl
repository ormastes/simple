# @cover src/app/ui.web/html.spl 80%
# @tag: unit, ui, web, wm

use app.ui.web.html.{generate_wm_js}

describe "generate_wm_js route":
    it "connects the WM boot script to the routed UI websocket":
        val js = generate_wm_js(3333)
        expect(js).to_contain("ws://localhost:")
        expect(js).to_contain("3333")
        expect(js).to_contain("/ui/ws")
        expect(js).to_contain("new SimpleWindowManager()")
