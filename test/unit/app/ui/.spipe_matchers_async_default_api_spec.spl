# @cover common.ui.__init__
# @cover common.ui.backend_factory
# @cover common.ui.sync_adapter
# @cover common.ui.async_app

use common.ui.{App, AppConfig, create_backend, create_sync_backend}
use common.ui.{build_tree, label, init_state}

describe "common.ui async-default API":
    it "create_backend returns an async-default backend":
        val result = create_backend("none", 3000)
        match result:
            Ok(backend) =>
                expect backend.backend_name() == "none"
            Err(e) =>
                expect false == true

    it "exports async-first app config aliases at the root":
        val async_config = AppConfig.headless()
        expect async_config.event_timeout_ms == 0
        expect async_config.hot_reload == false

    it "exports App as the async-first app alias":
        val backend_result = create_backend("none", 3000)
        match backend_result:
            Ok(backend) =>
                val state = init_state(build_tree(label("hello")))
                val app = App.from_state(state, backend)
                expect app.is_running() == true
                expect app.current_state().tree.root.kind.name() == "Text"
            Err(e) =>
                expect false == true

    it "keeps sync factory available for legacy callers":
        val result = create_sync_backend("none", 3000)
        match result:
            Ok(backend) =>
                expect backend.backend_name() == "none"
            Err(e) =>
                expect false == true