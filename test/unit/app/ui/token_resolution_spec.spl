    it "Radius.None wire is 'none'":
        expect(Radius.None.to_wire()).to_equal("none")

    it "Radius.Sm wire is 'sm'":
        expect(Radius.Sm.to_wire()).to_equal("sm")

    it "Radius.Md wire is 'md'":
        expect(Radius.Md.to_wire()).to_equal("md")

    it "Radius.Lg wire is 'lg'":
        expect(Radius.Lg.to_wire()).to_equal("lg")

    it "Radius.Pill wire is 'pill'":
        expect(Radius.Pill.to_wire()).to_equal("pill")


