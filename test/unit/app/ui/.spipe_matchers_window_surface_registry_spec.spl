# Window-surface registry specification
#
# Covers the runtime-only authoritative mapping between top-level windows
# and UI access surfaces.

use std.spec.{describe, it, expect}
use common.ui.window_surface_registry.{
    UI_SURFACE_KIND_LEGACY,
    UI_SURFACE_KIND_SIMPLE_WEB,
    UI_SURFACE_KIND_ELECTRON,
    UI_SURFACE_KIND_HEADLESS,
    ui_surface_kind_is_native_host,
    ui_surface_kind_supports_embedded_surface,
    ui_surface_kind_supports_headless_session,
    UiWindowSurfaceRegistry
}

describe "UiWindowSurfaceRegistry":
    it "defines canonical surface kind constants":
        expect UI_SURFACE_KIND_LEGACY == "Legacy"
        expect UI_SURFACE_KIND_SIMPLE_WEB == "SimpleWeb"
        expect UI_SURFACE_KIND_ELECTRON == "Electron"
        expect UI_SURFACE_KIND_HEADLESS == "Headless"

    it "classifies surface kind capabilities":
        expect ui_surface_kind_is_native_host(UI_SURFACE_KIND_ELECTRON) == true
        expect ui_surface_kind_is_native_host(UI_SURFACE_KIND_SIMPLE_WEB) == false
        expect ui_surface_kind_supports_embedded_surface(UI_SURFACE_KIND_SIMPLE_WEB) == true
        expect ui_surface_kind_supports_embedded_surface(UI_SURFACE_KIND_ELECTRON) == false
        expect ui_surface_kind_supports_headless_session(UI_SURFACE_KIND_HEADLESS) == true

    it "binds windows to surfaces and supports one-to-one replacement":
        var registry = UiWindowSurfaceRegistry.new()
        registry.bind("1", "main", 101, "app.main", "Main")
        expect registry.len() == 1
        expect registry.window_id_for_surface("main") == "1"

        registry.bind("2", "main", 202, "app.main", "Main 2")
        expect registry.len() == 1
        expect registry.window_id_for_surface("main") == "2"

        registry.bind("2", "popup", 202, "app.popup", "Popup")
        expect registry.len() == 1
        expect registry.window_id_for_surface("popup") == "2"
        expect registry.window_id_for_surface("main") == ""

    it "clears bindings by surface and by window":
        var registry = UiWindowSurfaceRegistry.new()
        registry.bind("3", "main", 303, "app.main", "Main")
        registry.bind("4", "popup", 404, "app.popup", "Popup")
        registry.clear_surface("main")
        expect registry.window_id_for_surface("main") == ""
        expect registry.window_id_for_surface("popup") == "4"
        registry.clear_window("4")
        expect registry.window_id_for_surface("popup") == ""