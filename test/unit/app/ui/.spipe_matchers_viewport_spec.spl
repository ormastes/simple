# Viewport Specification
#
# Tests Viewport creation (default and custom), area computation,
# active state detection, and describe formatting.

use std.spec.{describe, it, expect}
use common.ui.viewport.{Viewport, default_viewport, new_viewport}

describe "Viewport":
    it "creates default viewport":
        val vp = default_viewport()
        expect vp.width == 80
        expect vp.height == 24
        expect vp.active_backend == "none"

    it "creates custom viewport":
        val vp = new_viewport(1920, 1080, "tauri")
        expect vp.width == 1920
        expect vp.height == 1080
        expect vp.active_backend == "tauri"

    it "computes area":
        val vp = new_viewport(80, 24, "tui")
        expect vp.area() == 1920

    it "detects active state":
        val vp1 = default_viewport()
        expect vp1.is_active() == false
        val vp2 = new_viewport(80, 24, "tui")
        expect vp2.is_active() == true

    it "describes itself":
        val vp = new_viewport(120, 40, "electron")
        expect vp.describe() == "120x40 (electron)"