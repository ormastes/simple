# @cover src/lib/common/ui/color.spl 90%
"""
# UI Color Codec Specification

**Feature IDs:** N/A
**Category:** Stdlib
**Difficulty:** 1/5
**Status:** Implemented
**Requirements:** N/A
**Plan:** N/A
**Design:** doc/05_design/ui_typed_core_rfc.md

## Overview

Round-trip tests for `Color.from_hex()` / `to_hex()` codec.
Verifies byte-identical round-trips for every hex literal that appears
in the iOS and Glass theme files, plus style.spl dark/light constants.

Case preservation: from_hex("#1e1e2e").to_hex() == "#1e1e2e" (lowercase
preserved); from_hex("#007AFF").to_hex() == "#007AFF" (uppercase preserved).

Wire stability: rgba() strings with decimal alpha are intentionally
NOT tested here — they cannot be represented as Color (u8 alpha is lossy).
"""

use std.spec.*
use common.ui.color.{Color}

# =========================================================================
# Parsing: basic correctness
# =========================================================================

describe "Color.from_hex — basic parsing":

    it "parses 6-digit uppercase hex components":
        val c = Color.from_hex("#007AFF")
        expect(c.r).to_equal(0)
        expect(c.g).to_equal(122)
        expect(c.b).to_equal(255)
        expect(c.a).to_equal(255)

    it "parses 6-digit lowercase hex components":
        val c = Color.from_hex("#1e1e2e")
        expect(c.r).to_equal(30)
        expect(c.g).to_equal(30)
        expect(c.b).to_equal(46)
        expect(c.a).to_equal(255)

    it "parses 8-digit hex with alpha channel":
        val c = Color.from_hex("#007AFF80")
        expect(c.r).to_equal(0)
        expect(c.g).to_equal(122)
        expect(c.b).to_equal(255)
        expect(c.a).to_equal(128)

    it "returns black/opaque for unrecognised format":
        val c = Color.from_hex("notahex")
        expect(c.r).to_equal(0)
        expect(c.g).to_equal(0)
        expect(c.b).to_equal(0)
        expect(c.a).to_equal(255)

# =========================================================================
# Output format
# =========================================================================

describe "Color.to_hex — output format":

    it "emits 6-char hex with # prefix when alpha is 255":
        val c = Color(r: 10, g: 132, b: 255, a: 255, case_lower: false)
        expect(c.to_hex()).to_equal("#0A84FF")

    it "emits 8-char hex with # prefix when alpha is not 255":
        val c = Color(r: 0, g: 0, b: 0, a: 128, case_lower: false)
        expect(c.to_hex()).to_equal("#00000080")

    it "emits leading zero for single-nibble values":
        val c = Color(r: 0, g: 10, b: 15, a: 255, case_lower: false)
        expect(c.to_hex()).to_equal("#000A0F")

    it "emits lowercase a-f when case_lower is true":
        val c = Color(r: 171, g: 205, b: 239, a: 255, case_lower: true)
        expect(c.to_hex()).to_equal("#abcdef")

    it "emits uppercase A-F when case_lower is false":
        val c = Color(r: 171, g: 205, b: 239, a: 255, case_lower: false)
        expect(c.to_hex()).to_equal("#ABCDEF")

# =========================================================================
# Case preservation
# =========================================================================

describe "Color — case preservation":

    it "preserves uppercase case through round-trip":
        val orig = "#007AFF"
        val c = Color.from_hex(orig)
        expect(c.to_hex()).to_equal(orig)

    it "preserves lowercase case through round-trip":
        val orig = "#1e1e2e"
        val c = Color.from_hex(orig)
        expect(c.to_hex()).to_equal(orig)

    it "preserves uppercase when all digits are 0-9 (no letter ambiguity)":
        val orig = "#F0F0F5"
        val c = Color.from_hex(orig)
        expect(c.to_hex()).to_equal(orig)

