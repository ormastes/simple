# IPC Protocol Specification
#
# Tests parse_ipc_message, build_ipc_render, extract_json_field, and
# escape_ipc_json from app.ui.ipc.protocol.

use common.ui.widget.{UIEvent}
use app.ui.ipc.protocol.{parse_ipc_message, build_ipc_render, extract_json_field, escape_ipc_json}


# ============================================================================
# extract_json_field
# ============================================================================

describe "extract_json_field":
    it "extracts type field from JSON":
        val json = "{\"type\":\"keypress\",\"key\":\"a\"}"
        val result = extract_json_field(json, "type")
        expect result to_equal "keypress"

    it "extracts key field from JSON":
        val json = "{\"type\":\"keypress\",\"key\":\"a\"}"
        val result = extract_json_field(json, "key")
        expect result to_equal "a"

    it "returns empty string for missing field":
        val json = "{\"type\":\"keypress\",\"key\":\"a\"}"
        val result = extract_json_field(json, "missing")
        expect result to_equal ""

    it "handles JSON with spaces around colon":
        val json = "{\"type\": \"action\", \"name\": \"save\"}"
        val result = extract_json_field(json, "name")
        expect result to_equal "save"

    it "returns empty string for empty input":
        val result = extract_json_field("", "type")
        expect result to_equal ""


# ============================================================================
# parse_ipc_message
# ============================================================================

describe "parse_ipc_message":
    it "parses keypress message into UIEvent.KeyPress":
        val json = "{\"type\":\"keypress\",\"key\":\"q\"}"
        val event = parse_ipc_message(json)
        expect event != nil to_equal true
        match event:
            UIEvent.KeyPress(key) =>
                expect key to_equal "q"
            _ =>
                expect false to_equal true

    it "parses quit message into UIEvent.Quit":
        val json = "{\"type\":\"quit\"}"
        val event = parse_ipc_message(json)
        expect event != nil to_equal true

    it "returns nil for empty string":
        val event = parse_ipc_message("")
        expect event to_be_nil

    it "returns nil for unrecognized message type":
        val json = "{\"type\":\"unknown\",\"data\":\"test\"}"
        val event = parse_ipc_message(json)
        expect event to_be_nil

    it "parses action message":
        val json = "{\"type\":\"action\",\"name\":\"open_file\"}"
        val event = parse_ipc_message(json)
        expect event != nil to_equal true
        match event:
            UIEvent.Action(name) =>
                expect name to_equal "open_file"
            _ =>
                expect false to_equal true

    it "parses resize message":
        val json = "{\"type\":\"resize\",\"width\":\"120\",\"height\":\"40\"}"
        val event = parse_ipc_message(json)
        expect event != nil to_equal true


# ============================================================================
# build_ipc_render
# ============================================================================

describe "build_ipc_render":
    it "wraps html in JSON with type render":
        val html = "<div>Hello</div>"
        val result = build_ipc_render(html)
        expect result to_contain "\"type\":\"render\""

    it "includes html content in output":
        val html = "<p>Test</p>"
        val result = build_ipc_render(html)
        expect result to_contain "Test"

    it "produces valid JSON structure":
        val html = "<span>Hi</span>"
        val result = build_ipc_render(html)
        expect result to_start_with "{"
        expect result to_end_with "}"


# ============================================================================
# escape_ipc_json
# ============================================================================

describe "escape_ipc_json":
    it "escapes double quotes":
        val result = escape_ipc_json("say \"hello\"")
        expect result to_contain "\\\""

    it "escapes backslashes":
        val result = escape_ipc_json("path\\to\\file")
        expect result to_contain "\\\\"

    it "escapes newlines":
        val result = escape_ipc_json("line1\nline2")
        expect result to_contain "\\n"

    it "passes plain text unchanged":
        val result = escape_ipc_json("hello world")
        expect result to_equal "hello world"

    it "handles empty string":
        val result = escape_ipc_json("")
        expect result to_equal ""
