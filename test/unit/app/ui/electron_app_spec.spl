# Feature: Electron Backend IPC and Rendering
# Category: UI Components
# Status: Implemented

use std.spec.*

use app.ui.electron.backend.{ElectronBackend}
use common.ui.widget.{UIEvent}


# ============================================================================
# Test Group 1: Electron Backend Creation
# ============================================================================

describe "Electron Backend Creation":

    it "creates successfully":
        val result = ElectronBackend.new(3000)
        match result:
            Ok(backend) =>
                expect(true).to_equal(true)
            Err(e) =>
                expect(false).to_equal(true)

    it "reports backend name":
        val result = ElectronBackend.new(3000)
        match result:
            Ok(backend) =>
                expect(backend.backend_name()).to_equal("electron")
            Err(e) =>
                expect(false).to_equal(true)


# ============================================================================
# Test Group 2: Lifecycle
# ============================================================================

describe "Electron Backend Lifecycle":

    it "initializes successfully":
        val result = ElectronBackend.new(3000)
        match result:
            Ok(backend) =>
                val init_result = backend.init()
                expect(true).to_equal(true)
            Err(e) =>
                expect(false).to_equal(true)

    it "shuts down cleanly":
        val result = ElectronBackend.new(3000)
        match result:
            Ok(backend) =>
                backend.init()
                backend.shutdown()
                expect(true).to_equal(true)
            Err(e) =>
                expect(false).to_equal(true)


# ============================================================================
# Test Group 3: Capabilities
# ============================================================================

describe "Electron Backend Capabilities":

    it "supports mouse and color and images":
        val result = ElectronBackend.new(3000)
        match result:
            Ok(backend) =>
                expect(backend.supports_mouse()).to_equal(true)
                expect(backend.supports_color()).to_equal(true)
                expect(backend.supports_images()).to_equal(true)
            Err(e) =>
                expect(false).to_equal(true)

    it "does not support touch":
        val result = ElectronBackend.new(3000)
        match result:
            Ok(backend) =>
                expect(backend.supports_touch()).to_equal(false)
            Err(e) =>
                expect(false).to_equal(true)


# ============================================================================
# Test Group 4: Viewport
# ============================================================================

describe "Electron Backend Viewport":

    it "has default viewport 1280x720":
        val result = ElectronBackend.new(3000)
        match result:
            Ok(backend) =>
                expect(backend.viewport_width()).to_equal(1280)
                expect(backend.viewport_height()).to_equal(720)
            Err(e) =>
                expect(false).to_equal(true)
