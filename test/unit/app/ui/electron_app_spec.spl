# Feature: Electron Backend IPC and Rendering
# Category: UI Components
# Status: Implemented

import std.spec

use app.ui.electron.ipc.{parse_ipc_message, build_ipc_render}
use app.ui.electron.backend.{ElectronBackend}
use common.ui.widget.{UIEvent}


# ============================================================================
# Test Group 1: IPC Message Parsing
# ============================================================================

describe "Electron IPC Parsing":

    it "parses keypress message":
        val json = "{\"type\":\"keypress\",\"key\":\"a\"}"
        val event = parse_ipc_message(json)
        expect(event != nil).to_equal(true)

    it "parses quit message":
        val json = "{\"type\":\"quit\"}"
        val event = parse_ipc_message(json)
        expect(event != nil).to_equal(true)

    it "parses resize message":
        val json = "{\"type\":\"resize\",\"width\":\"1920\",\"height\":\"1080\"}"
        val event = parse_ipc_message(json)
        expect(event != nil).to_equal(true)

    it "parses action message":
        val json = "{\"type\":\"action\",\"name\":\"save\"}"
        val event = parse_ipc_message(json)
        expect(event != nil).to_equal(true)

    it "returns nil for unknown message":
        val json = "{\"type\":\"unknown\"}"
        val event = parse_ipc_message(json)
        expect(event == nil).to_equal(true)

    it "returns nil for empty string":
        val event = parse_ipc_message("")
        expect(event == nil).to_equal(true)

    it "parses keypress with spaces in JSON":
        val json = "{\"type\": \"keypress\", \"key\": \"Enter\"}"
        val event = parse_ipc_message(json)
        expect(event != nil).to_equal(true)


# ============================================================================
# Test Group 2: IPC Message Building
# ============================================================================

describe "Electron IPC Building":

    it "builds render message":
        val html = "<div>Hello</div>"
        val msg = build_ipc_render(html)
        expect(msg).to_contain("render")
        expect(msg).to_contain("Hello")

    it "builds render message with JSON structure":
        val msg = build_ipc_render("test")
        expect(msg).to_start_with("{")
        expect(msg).to_end_with("}")
        expect(msg).to_contain("\"type\":\"render\"")


# ============================================================================
# Test Group 3: Electron Backend
# ============================================================================

describe "Electron Backend":

    it "creates with port":
        val backend = ElectronBackend.new(3000)
        expect(backend.backend_name()).to_equal("electron")

    it "initializes successfully":
        var backend = ElectronBackend.new(3000)
        val result = backend.init()
        expect(result.is_ok()).to_equal(true)

    it "reports capabilities":
        val backend = ElectronBackend.new(3000)
        expect(backend.supports_mouse()).to_equal(true)
        expect(backend.supports_color()).to_equal(true)
        expect(backend.supports_images()).to_equal(true)
        expect(backend.supports_touch()).to_equal(false)

    it "has default viewport":
        val backend = ElectronBackend.new(3000)
        expect(backend.viewport_width()).to_equal(1280)
        expect(backend.viewport_height()).to_equal(720)
