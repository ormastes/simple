use app.spipe_docgen.parser.{extract_test_structure, extract_test_structure_with_path}
use app.spipe_docgen.parser.{parse_spipe_file, extract_metadata}
use app.spipe_docgen.generator.{generate_feature_doc}
use app.spipe_docgen.common.{SspecDoc, FeatureMetadata}
use app.io.mod (file_write)
use std.io_runtime.{read_file}

describe "spipe docgen scenario body extraction":

    it "renders scenario bodies as dedented Simple code fences":
        val source = "describe \"Math Block Arithmetic\":\n" +
            "    it \"evaluates addition\":\n" +
            "        val result = m{ 2 + 3 }\n" +
            "        expect(result).to_equal(5)\n"
        val structure = extract_test_structure(source)
        expect(structure == "x").to_equal(false)
        expect(structure).to_contain("#### evaluates addition")
        expect(structure.contains("### evaluates addition")).to_equal(false)
        expect(structure).to_contain("val result = m{ 2 + 3 }")
        expect(structure).to_contain("expect(result).to_equal(5)")
        expect(structure).to_contain("<summary>Rendered scenario source</summary>")
        expect(structure).to_contain("> val result = $2 + 3$<br>\n> expect(result).to_equal(5)")
        expect(structure.contains("Rendered `m{...}`")).to_equal(false)
        expect(structure.contains("**Plain text**")).to_equal(false)
        expect(structure.contains("<summary>Raw scenario source</summary>")).to_equal(false)
        expect(structure.contains("```latex")).to_equal(false)

    it "strips leading scenario docstrings from rendered code":
        val source = "describe \"Docstring bodies\":\n" +
            "    it \"keeps runnable code only\":\n" +
            "        \"\"\"\n" +
            "        Explains the scenario.\n" +
            "        \"\"\"\n" +
            "        val result = 1\n" +
            "        expect(result).to_equal(1)\n"
        val structure = extract_test_structure(source)
        expect(structure).to_contain("#### keeps runnable code only")
        expect(structure).to_contain("```simple\nval result = 1\nexpect(result).to_equal(1)\n```")
        expect(structure.contains("Explains the scenario.")).to_equal(false)

    it "does not emit a code fence for single-line pass scenarios":
        val source = "describe \"Empty bodies\":\n" +
            "    it \"has no multiline body\": pass\n"
        val structure = extract_test_structure(source)
        expect(structure).to_contain("#### has no multiline body")
        expect(structure.contains("```simple")).to_equal(false)
        expect(structure.contains("Raw scenario source")).to_equal(false)

    it "renders skip_it scenarios with skipped marker and body":
        val source = "describe \"Skipped scenarios\":\n" +
            "    skip_it \"documents underscore skipped scenarios\":\n" +
            "        expect(\"reason\").to_equal(\"reason\")\n"
        val structure = extract_test_structure(source)
        expect(structure).to_contain("#### documents underscore skipped scenarios _(skipped)_")
        expect(structure).to_contain("```simple\nexpect(\"reason\").to_equal(\"reason\")\n```")

    it "folds scenarios marked as advanced manual content":
        val source = "describe \"Manual visibility\":\n" +
            "    # @manual: folded\n" +
            "    it \"documents an edge case without dominating the manual\":\n" +
            "        expect(\"edge\").to_equal(\"edge\")\n"
        val structure = extract_test_structure(source)
        expect(structure).to_contain("<details>")
        expect(structure).to_contain("<summary>Advanced: documents an edge case without dominating the manual</summary>")
        expect(structure).to_contain("#### documents an edge case without dominating the manual")
        expect(structure).to_contain("```simple\nexpect(\"edge\").to_equal(\"edge\")\n```")

    it "skips scenarios marked as hidden manual content":
        val source = "describe \"Manual visibility\":\n" +
            "    # @manual: skip\n" +
            "    it \"keeps helper-only checks out of the manual\":\n" +
            "        expect(\"helper\").to_equal(\"helper\")\n" +
            "    it \"keeps primary scenario visible\":\n" +
            "        expect(\"primary\").to_equal(\"primary\")\n"
        val structure = extract_test_structure(source)
        expect(structure.contains("keeps helper-only checks out of the manual")).to_equal(false)
        expect(structure.contains("expect(\"helper\").to_equal(\"helper\")")).to_equal(false)
        expect(structure).to_contain("#### keeps primary scenario visible")

    it "folds all scenarios when file manual metadata is folded":
        val source = "# @manual-file: folded\n" +
            "describe \"Manual visibility\":\n" +
            "    it \"keeps detailed file collapsed\":\n" +
            "        expect(\"detail\").to_equal(\"detail\")\n"
        val structure = extract_test_structure(source)
        expect(structure).to_contain("<summary>Advanced: keeps detailed file collapsed</summary>")
        expect(structure).to_contain("#### keeps detailed file collapsed")

    it "skips all scenarios when file manual metadata is skip":
        val source = "# @manual-file: skip\n" +
            "describe \"Manual visibility\":\n" +
            "    it \"keeps generated helper file out of the manual\":\n" +
            "        expect(\"helper\").to_equal(\"helper\")\n"
        val structure = extract_test_structure(source)
        expect(structure.contains("keeps generated helper file out of the manual")).to_equal(false)
        expect(structure.contains("expect(\"helper\").to_equal(\"helper\")")).to_equal(false)

    it "lets scenario manual metadata override folded file default":
        val source = "# @manual-file: folded\n" +
            "describe \"Manual visibility\":\n" +
            "    # @manual: show\n" +
            "    it \"shows the primary flow in a detailed file\":\n" +
            "        expect(\"primary\").to_equal(\"primary\")\n"
        val structure = extract_test_structure(source)
        expect(structure).to_contain("#### shows the primary flow in a detailed file")
        expect(structure.contains("<summary>Advanced: shows the primary flow in a detailed file</summary>")).to_equal(false)

    it "folds scenarios from folder manual config":
        file_write("build/sspec-manual.sdn", "manual: folded\n")
        val source = "describe \"Folder visibility\":\n" +
            "    it \"keeps folder detail collapsed\":\n" +
            "        expect(\"folder\").to_equal(\"folder\")\n"
        val structure = extract_test_structure_with_path(source, "build/folder_visibility_spec.spl")
        expect(structure).to_contain("#### keeps folder detail collapsed")
        expect(structure).to_contain("<summary>Advanced: keeps folder detail collapsed</summary>")

    it "hides inline setup scenarios from top-level manual output":
        val source = "describe \"Inline setup\":\n" +
            "    # @inline\n" +
            "    it \"app is open\":\n" +
            "        expect(\"open\").to_equal(\"open\")\n" +
            "    it \"user continues from setup\":\n" +
            "        expect(\"continue\").to_equal(\"continue\")\n"
        val structure = extract_test_structure(source)
        expect(structure.contains("app is open")).to_equal(false)
        expect(structure.contains("expect(\"open\").to_equal(\"open\")")).to_equal(false)
        expect(structure).to_contain("#### user continues from setup")

    it "expands prev inline setup without rendering Previous label":
        val source = "describe \"Inline setup\":\n" +
            "    # @inline\n" +
            "    it \"app is open\":\n" +
            "        user.open_app()\n" +
            "    # @prev(\"app is open\")\n" +
            "    it \"user logs in\":\n" +
            "        user.enter_login(\"demo\")\n"
        val structure = extract_test_structure(source)
        expect(structure.contains("#### app is open")).to_equal(false)
        expect(structure).to_contain("#### user logs in")
        expect(structure).to_contain("```simple\nuser.open_app()\nuser.enter_login(\"demo\")\n```")
        expect(structure.contains("Previous:")).to_equal(false)

    it "expands bare prev from the nearest previous scenario":
        val source = "describe \"Previous setup\":\n" +
            "    # @inline\n" +
            "    it \"server is running\":\n" +
            "        admin.start_server()\n" +
            "    # @prev\n" +
            "    it \"operator sends request\":\n" +
            "        operator.send_request()\n"
        val structure = extract_test_structure(source)
        expect(structure.contains("#### server is running")).to_equal(false)
        expect(structure).to_contain("#### operator sends request")
        expect(structure).to_contain("```simple\nadmin.start_server()\noperator.send_request()\n```")

    it "expands include scenario body at the call site":
        val source = "describe \"Inline include\":\n" +
            "    # @inline\n" +
            "    it \"user confirms dialog\":\n" +
            "        user.confirm_dialog()\n" +
            "    it \"user completes checkout\":\n" +
            "        user.add_item()\n" +
            "        # @include(\"user confirms dialog\")\n" +
            "        user.finish_checkout()\n"
        val structure = extract_test_structure(source)
        expect(structure.contains("#### user confirms dialog")).to_equal(false)
        expect(structure).to_contain("#### user completes checkout")
        expect(structure).to_contain("```simple\nuser.add_item()\nuser.confirm_dialog()\nuser.finish_checkout()\n```")
        expect(structure.contains("# @include")).to_equal(false)

    it "renders warning for missing prev scenario target":
        val source = "describe \"Missing previous\":\n" +
            "    # @prev(\"app is open\")\n" +
            "    it \"user logs in\":\n" +
            "        user.enter_login(\"demo\")\n"
        val structure = extract_test_structure(source)
        expect(structure).to_contain("**Manual warnings:**\n- missing prev scenario: app is open")
        expect(structure.contains("# @manual-warning")).to_equal(false)

    it "renders warning for missing include target and removes metadata from source":
        val source = "describe \"Missing include\":\n" +
            "    it \"user finishes flow\":\n" +
            "        user.start_flow()\n" +
            "        # @include(\"dialog confirmed\")\n" +
            "        user.finish_flow()\n"
        val structure = extract_test_structure(source)
        expect(structure).to_contain("**Manual warnings:**\n- missing include scenario: dialog confirmed")
        expect(structure).to_contain("```simple\nuser.start_flow()\nuser.finish_flow()\n```")
        expect(structure.contains("# @include")).to_equal(false)

    it "folds slow scenarios by default but allows manual show override":
        val source = "describe \"Slow manual visibility\":\n" +
            "    slow_it \"keeps stress detail folded\":\n" +
            "        expect(\"stress\").to_equal(\"stress\")\n" +
            "    # @manual: show\n" +
            "    slow_it \"shows important slow operator flow\":\n" +
            "        expect(\"operator\").to_equal(\"operator\")\n"
        val structure = extract_test_structure(source)
        expect(structure).to_contain("<summary>Advanced: keeps stress detail folded</summary>")
        expect(structure).to_contain("#### keeps stress detail folded _(slow)_")
        expect(structure).to_contain("#### shows important slow operator flow _(slow)_")
        expect(structure.contains("<summary>Advanced: shows important slow operator flow</summary>")).to_equal(false)

    it "renders bare capture as after step tui scenario evidence":
        val source = "describe \"Capture policy\":\n" +
            "    # @capture\n" +
            "    it \"captures app after every step\":\n" +
            "        user.open_app()\n" +
            "        expect(\"open\").to_equal(\"open\")\n"
        val structure = extract_test_structure(source)
        expect(structure).to_contain("#### captures app after every step")
        expect(structure).to_contain("**Scenario capture:** tui after_step")
        expect(structure).to_contain("```simple\nuser.open_app()\nexpect(\"open\").to_equal(\"open\")\n```")

    it "renders explicit capture kind and mode from enum-like metadata":
        val source = "describe \"Capture policy\":\n" +
            "    # @capture(after_scenario, gui)\n" +
            "    it \"captures the final rendered window\":\n" +
            "        user.finish_flow()\n" +
            "        expect(\"done\").to_equal(\"done\")\n"
        val structure = extract_test_structure(source)
        expect(structure).to_contain("**Scenario capture:** gui after_scenario")

    it "renders step capture metadata without keeping metadata in source code":
        val source = "describe \"Capture policy\":\n" +
            "    it \"captures request evidence for submit\":\n" +
            "        user.open_app()\n" +
            "        # @capture(api)\n" +
            "        user.submit_login()\n" +
            "        expect(\"ok\").to_equal(\"ok\")\n"
        val structure = extract_test_structure(source)
        expect(structure).to_contain("**Step captures:**\n- api after_step before `user.submit_login()`")
        expect(structure).to_contain("```simple\nuser.open_app()\nuser.submit_login()\nexpect(\"ok\").to_equal(\"ok\")\n```")
        expect(structure.contains("# @capture(api)")).to_equal(false)

    it "captures the math_blocks golden scenario body":
        val source = read_file("test/feature/usage/math_blocks_spec.spl")
        val structure = extract_test_structure(source)
        expect(structure).to_contain("#### evaluates addition")
        expect(structure).to_contain("```simple\nval result = m{ 2 + 3 }\nexpect(result).to_equal(5)\n```")
        expect(structure).to_contain("#### evaluates sqrt of 16")
        expect(structure).to_contain("sqrt")

    it "generates through the pure Simple generator path":
        val parsed_result = parse_spipe_file("test/feature/usage/math_blocks_spec.spl")
        match parsed_result:
            case Err(e):
                expect(e).to_equal("")
            case Ok(parsed):
                val metadata = extract_metadata(parsed)
                val doc = SspecDoc(
                    file_path: parsed.file_path,
                    raw_content: parsed.raw_content,
                    doc_blocks: parsed.doc_blocks,
                    feature_title: parsed.feature_title,
                    feature_ids: parsed.feature_ids,
                    metadata: metadata
                )
                val result = generate_feature_doc(doc, "/tmp")
                match result:
                    case Err(e):
                        expect(e).to_equal("")
                    case Ok(path):
                        expect(path).to_contain("/feature/usage/math_blocks_spec.md")

    it "mirrors the source spec folder under the output directory":
        val parsed_result = parse_spipe_file("test/feature/usage/math_blocks_spec.spl")
        match parsed_result:
            case Err(e):
                expect(e).to_equal("")
            case Ok(parsed):
                val metadata = extract_metadata(parsed)
                val doc = SspecDoc(
                    file_path: parsed.file_path,
                    raw_content: parsed.raw_content,
                    doc_blocks: parsed.doc_blocks,
                    feature_title: parsed.feature_title,
                    feature_ids: parsed.feature_ids,
                    metadata: metadata
                )
                val result = generate_feature_doc(doc, "/tmp")
                match result:
                    case Err(e):
                        expect(e).to_equal("")
                    case Ok(path):
                        expect(path).to_equal("/tmp/feature/usage/math_blocks_spec.md")

    it "embeds screenshot and TUI capture evidence in generated docs":
        val tui_path = "/tmp/spipe_docgen_ui_capture.txt"
        file_write(tui_path, "Simple UI\n[OK] Ready\n")
        val metadata = FeatureMetadata(
            id: "ui.capture",
            category: "Application",
            difficulty: "Medium",
            status: "Active",
            doc_type: "SSPEC",
            source_doc: "",
            requirement: "N/A",
            plan: "N/A",
            design: "N/A",
            research: "N/A",
            related: [],
            dependencies: [],
            artifacts: [],
            screenshots: ["doc/06_spec/image/feature/app/ui_capture_spec/main.png", "N/A"],
            tui_captures: [tui_path, "doc/06_spec/image/feature/app/ui_capture_spec/tui.png"],
            logs: []
        )
        val doc = SspecDoc(
            file_path: "test/feature/app/ui_capture_spec.spl",
            raw_content: "describe \"UI Capture\":\n    it \"captures the visible state\":\n        expect(true).to_equal(true)\n",
            doc_blocks: [],
            feature_title: "UI Capture",
            feature_ids: ["ui.capture"],
            metadata: metadata
        )
        val result = generate_feature_doc(doc, "/tmp")
        match result:
            case Err(e):
                expect(e).to_equal("")
            case Ok(path):
                val generated = read_file(path)
                expect(generated).to_contain("![Screenshots: main.png](doc/06_spec/image/feature/app/ui_capture_spec/main.png)")
                expect(generated).to_contain("![TUI Captures: tui.png](doc/06_spec/image/feature/app/ui_capture_spec/tui.png)")
                expect(generated).to_contain("<summary>spipe_docgen_ui_capture.txt</summary>")
                expect(generated).to_contain("Simple UI")
                expect(generated.contains("`N/A`")).to_equal(false)
