"""
# Traceability Checker Specification

**Feature IDs:** #TRC-001
**Category:** Tooling
**Status:** Draft
**Requirements:** N/A
**Plan:** N/A
**Design:** N/A
**Research:** N/A
"""

use app.traceability.core.{
    TraceabilityConfig, TraceabilityWarning, default_traceability_config,
    make_virtual_file, analyze_virtual_files,
    normalize_slug, map_source_to_unit_candidates, map_source_dir_to_integration_candidates,
    extract_relative_paths, extract_trace_ids
}

fn count_by_code(warnings: [TraceabilityWarning], code: text) -> i64:
    var count = 0
    for warning in warnings:
        if warning.code == code:
            count = count + 1
    count

describe "traceability helpers":
    it "normalizes date suffixed slugs":
        expect(normalize_slug("security_aop_architecture_2026-03-28")).to_equal("security_aop_architecture")

    it "extracts relative paths from markdown and plain text":
        val content = """
**Requirements:** [Req](doc/plan/requirement/security_aop.md)
Related test: doc/spec/security_aop_spec.md
"""
        val paths = extract_relative_paths(content)
        expect(paths).to_contain("doc/plan/requirement/security_aop.md")
        expect(paths).to_contain("doc/spec/security_aop_spec.md")

    it "extracts REQ and NFR identifiers":
        val ids = extract_trace_ids("REQ-SEC-001 NFR-PERF-001")
        expect(ids).to_contain("REQ-SEC-001")
        expect(ids).to_contain("NFR-PERF-001")

describe "source test mapping":
    it "maps compiler sources to unit candidates":
        val candidates = map_source_to_unit_candidates("src/compiler/85.mdsoc/layer_checker.spl")
        expect(candidates).to_contain("test/unit/compiler/mdsoc/layer_checker_spec.spl")

    it "maps lib sources to unit candidates":
        val candidates = map_source_to_unit_candidates("src/lib/common/security/sanitize.spl")
        expect(candidates).to_contain("test/unit/lib/security/sanitize_spec.spl")

    it "maps source directories to integration candidates":
        val candidates = map_source_dir_to_integration_candidates("src/compiler/85.mdsoc")
        expect(candidates).to_contain("test/integration/compiler/mdsoc/module_spec.spl")

describe "traceability analysis":
    it "warns when a requirement identifier is not covered":
        val cfg = default_traceability_config()
        val files = [
            make_virtual_file(
                "doc/plan/requirement/security_aop.md",
                "# Security AOP\n\nREQ-SEC-001:\nThe system shall ...\nREQ-SEC-002:\nThe system shall ...\n"
            ),
            make_virtual_file(
                "doc/plan/security_aop.md",
                "# Plan\n\n**Requirements:** doc/plan/requirement/security_aop.md\n"
            ),
            make_virtual_file(
                "doc/design/security_aop.md",
                "# Design\n\n**Requirements:** doc/plan/requirement/security_aop.md\n"
            ),
            make_virtual_file(
                "doc/research/security_aop.md",
                "# Research\n\n**Requirements:** doc/plan/requirement/security_aop.md\n"
            ),
            make_virtual_file(
                "test/system/security_aop_spec.spl",
                """
**Requirements:** doc/plan/requirement/security_aop.md
**Plan:** doc/plan/security_aop.md
**Design:** doc/design/security_aop.md
**Research:** doc/research/security_aop.md

# @req REQ-SEC-001
"""
            )
        ]
        val report = analyze_virtual_files(files, "all", cfg, false)
        expect(count_by_code(report.warnings, "TRC401")).to_equal(1)

    it "warns on legacy requirement roots in specs":
        val cfg = default_traceability_config()
        val files = [
            make_virtual_file("doc/plan/requirement/foo.md", "# Foo\nREQ-FOO-001:\n"),
            make_virtual_file("doc/plan/foo.md", "# Foo Plan\n"),
            make_virtual_file("doc/design/foo.md", "# Foo Design\n"),
            make_virtual_file("doc/research/foo.md", "# Foo Research\n"),
            make_virtual_file(
                "test/feature/foo_spec.spl",
                """
**Requirements:** doc/requirement/foo.md
**Plan:** doc/plan/foo.md
**Design:** doc/design/foo.md
**Research:** doc/research/foo.md

# @req REQ-FOO-001
"""
            )
        ]
        val report = analyze_virtual_files(files, "spec", cfg, false)
        expect(count_by_code(report.warnings, "TRC211")).to_equal(1)

    it "warns when docs point to raw specs":
        val cfg = default_traceability_config()
        val files = [
            make_virtual_file("doc/plan/requirement/foo.md", "# Foo\nREQ-FOO-001:\n"),
            make_virtual_file(
                "doc/research/foo.md",
                "# Research\n\n**Requirements:** doc/plan/requirement/foo.md\nSee test/foo_spec.spl for details.\n"
            )
        ]
        val report = analyze_virtual_files(files, "doc", cfg, false)
        expect(count_by_code(report.warnings, "TRC205")).to_equal(1)

    it "warns for opted-in source roots without unit tests":
        val cfg = TraceabilityConfig(
            generated_spec_root: "doc/spec",
            legacy_requirement_root: "doc/requirement",
            warn_source_roots: ["src/compiler/85.mdsoc"]
        )
        val files = [
            make_virtual_file("src/compiler/85.mdsoc/__init__.spl", "export foo"),
            make_virtual_file("src/compiler/85.mdsoc/layer_checker.spl", "fn check():\n    1\n")
        ]
        val report = analyze_virtual_files(files, "src", cfg, true)
        expect(count_by_code(report.warnings, "TRC101")).to_equal(1)
        expect(count_by_code(report.warnings, "TRC111")).to_equal(1)
