"""
# Canonical Evidence Layout Specification

**Feature IDs:** #EVIDENCE-001
**Category:** Tooling
**Difficulty:** 1/5
**Status:** Implemented
**Requirements:** N/A
**Plan:** N/A
**Design:** N/A
**Research:** N/A

## Overview

Documents the canonical evidence layout used by `sspec-docgen` auto-discovery.
Screenshots live under `doc/spec/image/<spec-relative-path>/` and non-image
artifacts live under `build/test-artifacts/<spec-relative-path>/`.

## Key Concepts

| Concept | Description |
|---------|-------------|
| Screenshot root | `doc/spec/image` |
| Artifact root | `build/test-artifacts` |
| Spec-relative path | Path derived from `test/.../*_spec.spl` without suffix |

## Behavior

- `doc/spec/image/<spec-relative-path>/` is the canonical screenshot tree
- `build/test-artifacts/<spec-relative-path>/` is the canonical non-image evidence tree
- Evidence paths are grouped by spec-relative directory, not by tool name
- Generated docs can auto-discover these paths when docblock metadata is absent
"""

use std.spec

fn strip_test_suffix(stem: text) -> text:
    if stem.ends_with("_spec"):
        return stem[0:stem.len() - 5]
    if stem.ends_with("_test"):
        return stem[0:stem.len() - 5]
    stem

fn spec_relative_path(spec_path: text) -> text:
    var relative = spec_path
    if relative.starts_with("test/"):
        relative = relative[5:]
    elif relative.starts_with("simple/std_lib/test/"):
        relative = relative[20:]

    if relative.ends_with(".spl"):
        relative = relative[0:relative.len() - 4]

    val parts = relative.split("/")
    var mapped = []
    var i = 0
    while i < parts.len():
        if i == parts.len() - 1:
            mapped.push(strip_test_suffix(parts[i]))
        else:
            mapped.push(parts[i])
        i = i + 1
    mapped.join("/")

fn screenshot_dir_for_spec(spec_path: text) -> text:
    "doc/spec/image/{spec_relative_path(spec_path)}"

fn artifact_dir_for_spec(spec_path: text) -> text:
    "build/test-artifacts/{spec_relative_path(spec_path)}"

fn classify_evidence(path: text) -> text:
    if path.ends_with(".png") or path.ends_with(".jpg") or path.ends_with(".jpeg") or path.ends_with(".webp"):
        return "screenshot"
    if path.ends_with(".ansi"):
        return "tui"
    if path.ends_with(".log"):
        return "log"
    if path.ends_with(".json") or path.ends_with(".txt") or path.ends_with(".html") or path.ends_with(".svg"):
        return "artifact"
    "unknown"

describe "Canonical evidence layout":
    context "when mapping spec paths to evidence roots":
        it "uses doc/spec/image for screenshots":
            val full_path = screenshot_dir_for_spec("test/app/web_dashboard/tmux_rest_api_spec.spl")
            expect(full_path).to_equal("doc/spec/image/app/web_dashboard/tmux_rest_api")

        it "uses build/test-artifacts for logs and text artifacts":
            val full_path = artifact_dir_for_spec("test/app/web_dashboard/tmux_rest_api_spec.spl")
            expect(full_path).to_equal("build/test-artifacts/app/web_dashboard/tmux_rest_api")

        it "keeps evidence grouped by spec-relative path":
            val screenshot_path = "{screenshot_dir_for_spec(\"test/app/web_dashboard/tmux_rest_api_spec.spl\")}/after.png"
            val artifact_path = "{artifact_dir_for_spec(\"test/app/web_dashboard/tmux_rest_api_spec.spl\")}/run.log"
            expect(screenshot_path.contains("app/web_dashboard/tmux_rest_api")).to_equal(true)
            expect(artifact_path.contains("app/web_dashboard/tmux_rest_api")).to_equal(true)

        it "strips the test suffix from the final path segment":
            expect(spec_relative_path("test/unit/app/tooling/command_dispatch_spec.spl")).to_equal("unit/app/tooling/command_dispatch")
            expect(spec_relative_path("test/unit/app/tooling/runner_test.spl")).to_equal("unit/app/tooling/runner")

        it "classifies evidence by its canonical extension":
            expect(classify_evidence("doc/spec/image/app/demo/after.png")).to_equal("screenshot")
            expect(classify_evidence("build/test-artifacts/app/demo/transcript.ansi")).to_equal("tui")
            expect(classify_evidence("build/test-artifacts/app/demo/run.log")).to_equal("log")
            expect(classify_evidence("build/test-artifacts/app/demo/result.json")).to_equal("artifact")

        it "keeps stdlib test roots aligned with the same relative layout":
            expect(screenshot_dir_for_spec("simple/std_lib/test/spec/screenshot_ffi_spec.spl")).to_equal("doc/spec/image/spec/screenshot_ffi")
            expect(artifact_dir_for_spec("simple/std_lib/test/spec/screenshot_ffi_spec.spl")).to_equal("build/test-artifacts/spec/screenshot_ffi")
