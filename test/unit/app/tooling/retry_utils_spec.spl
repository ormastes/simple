fn _retry_delay_ms(attempt: i64, base_ms: i64, max_ms: i64) -> i64:
    var delay = base_ms
    var i = 0
    while i < attempt:
        delay = delay * 2
        i = i + 1
    if delay > max_ms:
        return max_ms
    delay

fn _should_retry(attempt: i64, max_attempts: i64, status: text) -> bool:
    if attempt >= max_attempts:
        return false
    status == "timeout" or status == "temporary"

describe "RetryUtils":
    it "computes exponential delay":
        expect _retry_delay_ms(0, 25, 1000) == 25
        expect _retry_delay_ms(3, 25, 1000) == 200

    it "caps exponential delay":
        expect _retry_delay_ms(8, 25, 500) == 500

    it "retries transient statuses":
        expect _should_retry(1, 3, "timeout") == true
        expect _should_retry(1, 3, "temporary") == true

    it "stops on permanent status or exhausted attempts":
        expect _should_retry(1, 3, "permanent") == false
        expect _should_retry(3, 3, "timeout") == false
