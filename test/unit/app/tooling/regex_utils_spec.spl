use std.nogc_sync_mut.src.tooling.regex_utils.{extract_numbers, is_valid_email, is_valid_ipv4, regex_find, regex_is_match, regex_replace_all, regex_split}

describe "Regex Utils":
    it "matches digit patterns":
        expect regex_is_match(r"\d+", "build 42 passed") == true
        expect regex_is_match(r"^\d+$", "42x") == false

    it "finds the first number with range metadata":
        val found = regex_find(r"\d+", "run 128 ms")
        match found:
            Some(m):
                expect m.text == "128"
                expect m.start == 4
                expect m.end == 7
            nil:
                expect false

    it "replaces all numeric runs":
        val replaced = regex_replace_all(r"\d+", "p50=12 p95=48", "N")
        expect replaced == "pN=N pN=N"

    it "splits comma separated text and trims spacing":
        val parts = regex_split(r",\s*", "alpha, beta,gamma")
        expect parts.len() == 3
        expect parts[1] == "beta"

    it "validates common email and ipv4 shapes":
        expect is_valid_email("dev@example.com") == true
        expect is_valid_email("@example.com") == false
        expect is_valid_ipv4("192.168.0.1") == true
        expect is_valid_ipv4("999.168.0.1") == false

    it "extracts numeric strings in order":
        val nums = extract_numbers("x=7 y=11 z=19")
        expect nums.len() == 3
        expect nums[0] == "7"
        expect nums[2] == "19"
