"""
Tests for app.spipe_process_harness and std.nogc_async_mut.spipe_process_harness.

Covers provider normalization, gate semantics, HUD rendering, deploy snippets,
hook path helpers, and event JSONL formatting.
"""

use std.spipe.*
use std.nogc_async_mut.spipe_process_harness.types.{
    HarnessOptions, GateDecision, HudSnapshot, HookDeploySnippet
}
use std.nogc_async_mut.spipe_process_harness.core.{
    normalize_provider, state_path, event_log_path, provider_hook_events,
    hook_command, hook_jsonl, gate_from_state, render_hud,
    deploy_snippets
}

fn make_approved_state() -> text:
    "# SPipe State: test\n\n## Harness\n- User Approved: true\n- Prevent: allow\n"

fn make_blocked_state() -> text:
    "# SPipe State: test\n\n## Harness\n- User Approved: true\n- Prevent: block\n"

fn make_unapproved_state() -> text:
    "# SPipe State: test\n\n## Harness\n- User Approved: false\n- Prevent: allow\n"

fn make_hud_snapshot() -> HudSnapshot:
    HudSnapshot(
        model: "claude-sonnet-4-6",
        jj_worktree: "clean",
        commit_id: "abc123 feat: harness",
        hours_remaining: "4",
        week_remaining: "2",
        goal: "ship harness"
    )

# =========================================================================
# Tests
# =========================================================================

describe "SPipe Process Harness":

    describe "normalize_provider":

        it "normalizes claude":
            val p = normalize_provider("claude")
            expect(p).to_equal("claude")

        it "normalizes Claude (capitalized)":
            val p = normalize_provider("Claude")
            expect(p).to_equal("claude")

        it "normalizes codex":
            val p = normalize_provider("codex")
            expect(p).to_equal("codex")

        it "normalizes openai as codex":
            val p = normalize_provider("openai")
            expect(p).to_equal("codex")

        it "normalizes gpt as codex":
            val p = normalize_provider("gpt-4o")
            expect(p).to_equal("codex")

        it "normalizes gemini":
            val p = normalize_provider("gemini")
            expect(p).to_equal("gemini")

        it "normalizes google as gemini":
            val p = normalize_provider("google")
            expect(p).to_equal("gemini")

        it "returns unknown for empty string":
            val p = normalize_provider("")
            expect(p).to_equal("unknown")

        it "passes through unknown provider":
            val p = normalize_provider("llama")
            expect(p).to_equal("llama")

    describe "state_path and event_log_path":

        it "state_path uses feature name":
            val path = state_path("my-feature")
            expect(path).to_equal(".spipe/my-feature/state.md")

        it "state_path defaults when empty":
            val path = state_path("")
            expect(path).to_equal(".spipe/spipe-process-harness/state.md")

        it "event_log_path uses feature name":
            val path = event_log_path("my-feature")
            expect(path).to_equal(".spipe/my-feature/events.jsonl")

    describe "gate_from_state":

        it "blocks on empty state":
            val gate = gate_from_state("", false)
            expect(gate.allowed).to_equal(false)

        it "blocks on empty state with exit code 2":
            val gate = gate_from_state("", false)
            expect(gate.exit_code).to_equal(2)

        it "allows approved state":
            val state = make_approved_state()
            val gate = gate_from_state(state, true)
            expect(gate.allowed).to_equal(true)

        it "blocks when approval required but missing":
            val state = make_unapproved_state()
            val gate = gate_from_state(state, true)
            expect(gate.allowed).to_equal(false)

        it "allows when approval not required even without approval marker":
            val state = make_unapproved_state()
            val gate = gate_from_state(state, false)
            expect(gate.allowed).to_equal(true)

        it "blocks when Prevent: block in state":
            val state = make_blocked_state()
            val gate = gate_from_state(state, false)
            expect(gate.allowed).to_equal(false)

    describe "render_hud":

        it "contains model name":
            val snap = make_hud_snapshot()
            val hud = render_hud(snap)
            expect(hud).to_contain("claude-sonnet-4-6")

        it "contains jj worktree":
            val snap = make_hud_snapshot()
            val hud = render_hud(snap)
            expect(hud).to_contain("clean")

        it "contains hours remaining":
            val snap = make_hud_snapshot()
            val hud = render_hud(snap)
            expect(hud).to_contain("hr=4")

        it "contains goal":
            val snap = make_hud_snapshot()
            val hud = render_hud(snap)
            expect(hud).to_contain("ship harness")

    describe "deploy_snippets":

        it "returns 3 snippets":
            val snippets = deploy_snippets()
            expect(snippets.len()).to_equal(3)

        it "first snippet is for claude":
            val snippets = deploy_snippets()
            expect(snippets[0].provider).to_equal("claude")

        it "second snippet is for codex":
            val snippets = deploy_snippets()
            expect(snippets[1].provider).to_equal("codex")

        it "third snippet is for gemini":
            val snippets = deploy_snippets()
            expect(snippets[2].provider).to_equal("gemini")

        it "claude snippet path contains claude-settings-hooks":
            val snippets = deploy_snippets()
            expect(snippets[0].path).to_contain("claude-settings-hooks")

    describe "provider_hook_events":

        it "claude has 9 events":
            val events = provider_hook_events("claude")
            expect(events.len()).to_equal(9)

        it "codex has 5 events":
            val events = provider_hook_events("codex")
            expect(events.len()).to_equal(5)

        it "gemini has 5 events":
            val events = provider_hook_events("gemini")
            expect(events.len()).to_equal(5)

        it "claude events contain PreToolUse":
            val events = provider_hook_events("claude")
            expect(events[0]).to_equal("PreToolUse")

        it "codex events contain session_start":
            val events = provider_hook_events("codex")
            expect(events[0]).to_equal("session_start")

    describe "hook_command":

        it "returns bin/simple command for claude":
            val cmd = hook_command("claude")
            expect(cmd).to_contain("bin/simple")

        it "includes provider name in command":
            val cmd = hook_command("gemini")
            expect(cmd).to_contain("gemini")

    describe "hook_jsonl":

        it "produces valid json with provider field":
            val j = hook_jsonl("claude", "PreToolUse", "sess-1", "sonnet", "{}")
            expect(j).to_contain("\"provider\":\"claude\"")

        it "includes event field":
            val j = hook_jsonl("codex", "tool_start", "sess-2", "gpt-4o", "{}")
            expect(j).to_contain("\"event\":\"tool_start\"")

        it "includes type field":
            val j = hook_jsonl("gemini", "session_start", "sess-3", "gemini-pro", "{}")
            expect(j).to_contain("\"type\":\"spipe_hook\"")
