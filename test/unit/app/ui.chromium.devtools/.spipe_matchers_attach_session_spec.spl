# Feature: Chromium Shell DevTools Attach (V3, Row 5 — M10)
# Category: UI Components
# Status: Implemented
#
# Compile-only smoke spec for the M10 DevTools attach session. Exercises
# the detach → attach → snapshot → rendering FSM plus the DOM mirror and
# the CSS inspector read paths so the devtools panel has a supported
# data source against a live DesktopShell window.

use app.ui.chromium.devtools.dom_mirror.{DevToolsDomMirror, DevToolsDomNode}
use app.ui.chromium.devtools.css_inspector.{DevToolsCssInspector, DevToolsComputedStyle}
use app.ui.chromium.devtools.attach_session.{
    DevToolsAttachSession,
    DevToolsAttachStatus,
    DEVTOOLS_STATUS_DETACHED,
    DEVTOOLS_STATUS_ATTACHED,
    DEVTOOLS_STATUS_RENDERING
}

# =========================================================================
# Test Group 1: DevToolsDomMirror — push / find / flatten
# =========================================================================

describe "Chromium DevTools DOM mirror — basics":
    """Live DOM mirror surfaced by M10 — push / find / flatten semantics."""

    it "starts empty with root id -1":
        """A fresh mirror has zero nodes and a sentinel root id."""
        val mirror = DevToolsDomMirror.new()
        expect mirror.is_empty()
        expect mirror.count() == 0
        expect mirror.root_id_of() == -1

    it "push_element makes the first node the root":
        var mirror = DevToolsDomMirror.new()
        val html_id = mirror.push_element("html", 0)
        expect mirror.count() == 1
        expect mirror.root_id_of() == html_id
        expect mirror.has_node(html_id)

    it "attach_child records parent/child links in order":
        var mirror = DevToolsDomMirror.new()
        val root = mirror.push_element("html", 0)
        val body = mirror.push_element("body", 1)
        val div  = mirror.push_element("div", 2)
        val ok1 = mirror.attach_child(root, body)
        val ok2 = mirror.attach_child(body, div)
        expect ok1
        expect ok2
        val root_idx = mirror.find_by_id(root)
        expect root_idx == 0
        val root_node = mirror.node_at(root_idx)
        expect root_node.child_count() == 1

    it "push_text stores a text-node marker":
        var mirror = DevToolsDomMirror.new()
        mirror.push_element("p", 0)
        val tid = mirror.push_text("hello", 1)
        expect mirror.has_node(tid)
        val idx = mirror.find_by_id(tid)
        val n = mirror.node_at(idx)
        expect n.is_text()

    it "max_depth reports the deepest depth":
        var mirror = DevToolsDomMirror.new()
        mirror.push_element("html", 0)
        mirror.push_element("body", 1)
        mirror.push_element("div", 2)
        mirror.push_element("span", 3)
        expect mirror.max_depth() == 3

    it "flattened_labels returns one label per node":
        var mirror = DevToolsDomMirror.new()
        mirror.push_element("html", 0)
        mirror.push_element("body", 1)
        val labels = mirror.flattened_labels()
        expect labels.len() == 2

    it "clear resets the mirror to empty":
        var mirror = DevToolsDomMirror.new()
        mirror.push_element("html", 0)
        mirror.push_element("body", 1)
        mirror.clear()
        expect mirror.is_empty()
        expect mirror.root_id_of() == -1

# =========================================================================
# Test Group 2: DevToolsCssInspector — property map + selection
# =========================================================================

describe "Chromium DevTools CSS inspector — computed styles":

    it "starts empty with no selection":
        val css = DevToolsCssInspector.new()
        expect css.is_empty()
        expect not css.has_selection()
        expect css.selected_id_of() == -1

    it "set_property lazily creates a block and stores the value":
        var css = DevToolsCssInspector.new()
        css.set_property(7, "color", "rgb(255,0,0)")
        expect css.has_block(7)
        val block = css.block_for(7)
        expect block.count() == 1
        expect block.value_of("color") == "rgb(255,0,0)"

    it "set_property keeps insertion order when updating":
        var css = DevToolsCssInspector.new()
        css.set_property(1, "color", "red")
        css.set_property(1, "background", "blue")
        css.set_property(1, "color", "green")
        val block = css.block_for(1)
        expect block.count() == 2
        expect block.value_of("color") == "green"
        expect block.value_of("background") == "blue"

    it "select returns false for nodes without a block":
        var css = DevToolsCssInspector.new()
        val ok = css.select(42)
        expect not ok
        expect not css.has_selection()

    it "selected_lines returns the formatted property list":
        var css = DevToolsCssInspector.new()
        css.set_property(3, "color", "red")
        css.set_property(3, "margin", "4px")
        val ok = css.select(3)
        expect ok
        val lines = css.selected_lines()
        expect lines.len() == 2

    it "clear drops blocks and selection":
        var css = DevToolsCssInspector.new()
        css.set_property(1, "color", "red")
        css.select(1)
        css.clear()
        expect css.is_empty()
        expect not css.has_selection()

# =========================================================================
# Test Group 3: DevToolsAttachSession — FSM and forwarding
# =========================================================================

describe "Chromium DevTools attach session — FSM":

    it "starts detached with no window":
        val s = DevToolsAttachSession.new()
        expect s.is_detached()
        expect s.window_id_of() == -1
        expect s.snapshot_epoch_of() == 0

    it "attach flips the status to ATTACHED":
        var s = DevToolsAttachSession.new()
        val ok = s.attach(11)
        expect ok
        expect s.is_attached()
        expect s.window_id_of() == 11
        expect s.status().code() == DEVTOOLS_STATUS_ATTACHED

    it "attach rejects negative window ids":
        var s = DevToolsAttachSession.new()
        val ok = s.attach(-5)
        expect not ok
        expect s.is_detached()

    it "begin_snapshot + end_snapshot bumps the epoch":
        var s = DevToolsAttachSession.new()
        s.attach(3)
        s.begin_snapshot()
        s.push_element("html", 0)
        val done = s.end_snapshot()
        expect done
        expect s.is_rendering()
        expect s.snapshot_epoch_of() == 1

    it "detach clears the DOM mirror and CSS view":
        var s = DevToolsAttachSession.new()
        s.attach(5)
        s.begin_snapshot()
        s.push_element("html", 0)
        s.set_style_property(1, "color", "red")
        s.end_snapshot()
        s.detach()
        expect s.is_detached()
        expect s.dom_node_count() == 0
        expect s.css().is_empty()

    it "push_element on a detached session returns -1":
        var s = DevToolsAttachSession.new()
        val id = s.push_element("html", 0)
        expect id == -1

    it "begin_snapshot on a detached session returns false":
        var s = DevToolsAttachSession.new()
        val ok = s.begin_snapshot()
        expect not ok

# =========================================================================
# Test Group 4: DevToolsAttachSession — panel read path
# =========================================================================

describe "Chromium DevTools attach session — panel read path":

    it "dom_labels exposes one label per pushed node":
        var s = DevToolsAttachSession.new()
        s.attach(1)
        s.begin_snapshot()
        s.push_element("html", 0)
        s.push_element("body", 1)
        s.push_text("hi", 2)
        s.end_snapshot()
        val labels = s.dom_labels()
        expect labels.len() == 3
        expect s.dom_root_id() > 0

    it "set_style_property + select_node feeds the inspector":
        var s = DevToolsAttachSession.new()
        s.attach(1)
        s.begin_snapshot()
        val root = s.push_element("div", 0)
        s.set_style_property(root, "color", "red")
        s.set_style_property(root, "margin", "2px")
        s.end_snapshot()
        val picked = s.select_node(root)
        expect picked
        val lines = s.selected_style_lines()
        expect lines.len() == 2

    it "status label reports the current FSM state":
        var s = DevToolsAttachSession.new()
        expect s.status().label() == "detached"
        s.attach(2)
        expect s.status().label() == "attached"
        s.begin_snapshot()
        s.push_element("html", 0)
        s.end_snapshot()
        expect s.status().label() == "rendering"

    it "DevToolsAttachStatus exposes rendering / attached / detached":
        val d = DevToolsAttachStatus.detached()
        val a = DevToolsAttachStatus.attached()
        val r = DevToolsAttachStatus.rendering()
        expect d.is_detached()
        expect a.is_attached()
        expect r.is_rendering()