# @cover src/app/cli_debug/format.spl 80%
# Tests for cli_debug format.spl — GDB-style output formatting functions.

use std.spec.*
use app.cli_debug.format.{
    fmt_bold, fmt_dim, fmt_red, fmt_green, fmt_yellow, fmt_blue, fmt_cyan,
    fmt_breakpoint_set, fmt_breakpoint_hit, fmt_breakpoint_deleted,
    fmt_breakpoint_list_header, fmt_breakpoint_entry,
    fmt_frame, fmt_frame_selected,
    fmt_variable, fmt_variable_typed,
    fmt_source_line,
    fmt_program_started, fmt_program_exited, fmt_program_stopped,
    fmt_session_created, fmt_session_closed,
    fmt_error, fmt_warning, fmt_info,
    fmt_thread_entry,
    fmt_help_main, fmt_help_break, fmt_help_print, fmt_help_info
}

describe "cli_debug format":

    describe "ANSI color helpers":
        it "AC-4: fmt_bold wraps text with ANSI escape sequences":
            val result = fmt_bold("hello")
            expect(result).to_contain("hello")
            expect(result).to_start_with("\x1b[")

        it "AC-4: fmt_cyan wraps text with ANSI escape sequences":
            val result = fmt_cyan("(sdb) ")
            expect(result).to_contain("(sdb) ")
            expect(result).to_start_with("\x1b[")

        it "AC-4: fmt_red wraps text with ANSI escape sequences":
            val result = fmt_red("error")
            expect(result).to_contain("error")
            expect(result).to_start_with("\x1b[")

        it "fmt_dim wraps text with ANSI escape sequences":
            val result = fmt_dim("42")
            expect(result).to_contain("42")
            expect(result).to_start_with("\x1b[")

    describe "breakpoint formatting":
        it "AC-4: fmt_breakpoint_set contains Breakpoint keyword":
            val result = fmt_breakpoint_set(1, "main.spl", 42)
            expect(result).to_contain("Breakpoint")

        it "AC-4: fmt_breakpoint_set contains breakpoint number":
            val result = fmt_breakpoint_set(1, "main.spl", 42)
            expect(result).to_contain("1")

        it "AC-4: fmt_breakpoint_set contains file name":
            val result = fmt_breakpoint_set(1, "main.spl", 42)
            expect(result).to_contain("main.spl")

        it "AC-4: fmt_breakpoint_set contains line number":
            val result = fmt_breakpoint_set(1, "main.spl", 42)
            expect(result).to_contain("42")

        it "AC-4: fmt_breakpoint_hit contains Breakpoint keyword":
            val result = fmt_breakpoint_hit(1, "main", "main.spl", 10)
            expect(result).to_contain("Breakpoint")

        it "AC-4: fmt_breakpoint_hit contains function name":
            val result = fmt_breakpoint_hit(1, "main", "main.spl", 10)
            expect(result).to_contain("main")

        it "fmt_breakpoint_deleted mentions the breakpoint number":
            val result = fmt_breakpoint_deleted(3)
            expect(result).to_contain("3")

        it "fmt_breakpoint_list_header is non-empty":
            val result = fmt_breakpoint_list_header()
            expect(result).to_contain("Num")

        it "fmt_breakpoint_entry contains enabled state y":
            val result = fmt_breakpoint_entry(1, true, "file.spl", 10)
            expect(result).to_contain("y")

        it "fmt_breakpoint_entry contains disabled state n":
            val result = fmt_breakpoint_entry(1, false, "file.spl", 10)
            expect(result).to_contain("n")

    describe "stack frame formatting":
        it "AC-4: fmt_frame contains # prefix":
            val result = fmt_frame(0, "main", "", "main.spl", 42)
            expect(result).to_start_with("#0")

        it "AC-4: fmt_frame contains function name":
            val result = fmt_frame(0, "my_func", "x=1", "file.spl", 10)
            expect(result).to_contain("my_func")

        it "AC-4: fmt_frame contains file and line":
            val result = fmt_frame(0, "fn", "", "file.spl", 99)
            expect(result).to_contain("file.spl")
            expect(result).to_contain("99")

        it "fmt_frame_selected contains # prefix":
            val result = fmt_frame_selected(2, "foo", "foo.spl", 7)
            expect(result).to_start_with("#2")

    describe "variable formatting":
        it "AC-3: fmt_variable contains variable name":
            val result = fmt_variable("my_var", "42")
            expect(result).to_contain("my_var")

        it "AC-3: fmt_variable contains value":
            val result = fmt_variable("x", "100")
            expect(result).to_contain("100")

        it "fmt_variable_typed contains type name":
            val result = fmt_variable_typed("x", "i64", "42")
            expect(result).to_contain("i64")

    describe "source listing":
        it "fmt_source_line contains the line number":
            val result = fmt_source_line(5, "fn main():", false)
            expect(result).to_contain("5")

        it "fmt_source_line current line has => marker":
            val result = fmt_source_line(5, "fn main():", true)
            expect(result).to_contain("=>")

    describe "status messages":
        it "AC-4: fmt_program_started contains program name":
            val result = fmt_program_started("my_app.spl")
            expect(result).to_contain("my_app.spl")

        it "fmt_program_exited code 0 shows normal":
            val result = fmt_program_exited(0)
            expect(result).to_contain("exited normally")

        it "fmt_program_exited nonzero shows code":
            val result = fmt_program_exited(1)
            expect(result).to_contain("1")

        it "fmt_session_created contains session id":
            val result = fmt_session_created("s1", "gdb")
            expect(result).to_contain("s1")

        it "fmt_session_closed contains session id":
            val result = fmt_session_closed("s1")
            expect(result).to_contain("s1")

        it "fmt_error contains Error prefix":
            val result = fmt_error("something broke")
            expect(result).to_contain("Error")

        it "fmt_error contains the message":
            val result = fmt_error("something broke")
            expect(result).to_contain("something broke")

        it "fmt_info returns the message unchanged":
            val result = fmt_info("hello")
            expect(result).to_equal("hello")

    describe "help text":
        it "AC-6: fmt_help_main contains quit":
            val result = fmt_help_main()
            expect(result).to_contain("quit")

        it "AC-6: fmt_help_main contains break":
            val result = fmt_help_main()
            expect(result).to_contain("break")

        it "AC-6: fmt_help_main contains List of commands":
            val result = fmt_help_main()
            expect(result).to_contain("List of commands")

        it "AC-6: fmt_help_break contains Usage":
            val result = fmt_help_break()
            expect(result).to_contain("Usage")

        it "AC-6: fmt_help_print contains EXPRESSION":
            val result = fmt_help_print()
            expect(result).to_contain("EXPRESSION")

        it "AC-6: fmt_help_info contains Usage":
            val result = fmt_help_info()
            expect(result).to_contain("Usage")
