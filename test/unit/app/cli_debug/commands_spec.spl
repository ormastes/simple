# @cover src/app/cli_debug/commands.spl 80%
# Tests for cli_debug commands.spl — command dispatch and alias mapping.
#
# Note: Most command handlers require a live debug session (sdb_ensure_session
# returns false without one). We test what is purely testable:
#   - dispatch_command("quit"/"q"/"exit") returns true
#   - dispatch_command of any other known command returns false (not quit)
#   - extract_json_field parses JSON output fields
#   - sdb_detect_backend auto-detects from file extensions

use std.spec.*
use app.cli_debug.commands.{dispatch_command, extract_json_field, sdb_detect_backend}

describe "cli_debug commands":

    describe "dispatch_command — quit aliases":
        it "AC-2: 'quit' command returns true (signals exit)":
            val result = dispatch_command("quit")
            expect(result).to_equal(true)

        it "AC-2: 'q' alias returns true":
            val result = dispatch_command("q")
            expect(result).to_equal(true)

        it "AC-2: 'exit' alias returns true":
            val result = dispatch_command("exit")
            expect(result).to_equal(true)

    describe "dispatch_command — non-quit commands return false":
        it "AC-2: 'help' returns false":
            val result = dispatch_command("help")
            expect(result).to_equal(false)

        it "AC-2: 'h' (help alias) returns false":
            val result = dispatch_command("h")
            expect(result).to_equal(false)

        it "AC-2: 'run' returns false":
            val result = dispatch_command("run")
            expect(result).to_equal(false)

        it "AC-2: 'r' (run alias) returns false":
            val result = dispatch_command("r")
            expect(result).to_equal(false)

        it "AC-2: 'continue' returns false":
            val result = dispatch_command("continue")
            expect(result).to_equal(false)

        it "AC-2: 'c' (continue alias) returns false":
            val result = dispatch_command("c")
            expect(result).to_equal(false)

        it "AC-2: 'next' returns false":
            val result = dispatch_command("next")
            expect(result).to_equal(false)

        it "AC-2: 'n' (next alias) returns false":
            val result = dispatch_command("n")
            expect(result).to_equal(false)

        it "AC-2: 'step' returns false":
            val result = dispatch_command("step")
            expect(result).to_equal(false)

        it "AC-2: 's' (step alias) returns false":
            val result = dispatch_command("s")
            expect(result).to_equal(false)

        it "AC-2: 'finish' returns false":
            val result = dispatch_command("finish")
            expect(result).to_equal(false)

        it "AC-2: 'break' returns false":
            val result = dispatch_command("break")
            expect(result).to_equal(false)

        it "AC-2: 'b' (break alias) returns false":
            val result = dispatch_command("b")
            expect(result).to_equal(false)

        it "AC-3: 'print' returns false":
            val result = dispatch_command("print")
            expect(result).to_equal(false)

        it "AC-3: 'p' (print alias) returns false":
            val result = dispatch_command("p")
            expect(result).to_equal(false)

        it "AC-3: 'backtrace' returns false":
            val result = dispatch_command("backtrace")
            expect(result).to_equal(false)

        it "AC-3: 'bt' (backtrace alias) returns false":
            val result = dispatch_command("bt")
            expect(result).to_equal(false)

        it "AC-3: 'frame' returns false":
            val result = dispatch_command("frame")
            expect(result).to_equal(false)

        it "AC-3: 'f' (frame alias) returns false":
            val result = dispatch_command("f")
            expect(result).to_equal(false)

        it "AC-3: 'list' returns false":
            val result = dispatch_command("list")
            expect(result).to_equal(false)

        it "AC-3: 'l' (list alias) returns false":
            val result = dispatch_command("l")
            expect(result).to_equal(false)

        it "AC-3: 'info' returns false":
            val result = dispatch_command("info")
            expect(result).to_equal(false)

        it "AC-3: 'i' (info alias) returns false":
            val result = dispatch_command("i")
            expect(result).to_equal(false)

        it "empty string returns false":
            val result = dispatch_command("")
            expect(result).to_equal(false)

        it "unknown command returns false (passed to backend)":
            val result = dispatch_command("some_unknown_cmd_xyz")
            expect(result).to_equal(false)

    describe "extract_json_field":
        it "extracts string field from JSON":
            val json = "{\"status\":\"ok\",\"output\":\"hello world\"}"
            val result = extract_json_field(json, "output")
            expect(result).to_equal("hello world")

        it "extracts status field":
            val json = "{\"status\":\"error\",\"message\":\"not found\"}"
            val result = extract_json_field(json, "status")
            expect(result).to_equal("error")

        it "extracts message field":
            val json = "{\"status\":\"error\",\"message\":\"not found\"}"
            val result = extract_json_field(json, "message")
            expect(result).to_equal("not found")

        it "returns empty for missing field":
            val json = "{\"status\":\"ok\"}"
            val result = extract_json_field(json, "output")
            expect(result).to_equal("")

        it "returns empty for non-JSON input":
            val result = extract_json_field("plain text", "output")
            expect(result).to_equal("")

        it "handles escaped quotes in value":
            val json = "{\"output\":\"say \\\"hello\\\"\"}"
            val result = extract_json_field(json, "output")
            expect(result).to_contain("hello")

        it "handles escaped newlines in value":
            val json = "{\"output\":\"line1\\nline2\"}"
            val result = extract_json_field(json, "output")
            expect(result).to_contain("line1")

    describe "sdb_detect_backend":
        it "AC-2: .spl extension maps to interpreter backend":
            val result = sdb_detect_backend("app.spl")
            expect(result).to_equal("interpreter")

        it "AC-2: .smf extension maps to smf backend":
            val result = sdb_detect_backend("app.smf")
            expect(result).to_equal("smf")

        it "AC-2: native binary defaults to gdb backend":
            val result = sdb_detect_backend("./my_binary")
            expect(result).to_equal("gdb")

        it "AC-2: no extension defaults to gdb backend":
            val result = sdb_detect_backend("my_app")
            expect(result).to_equal("gdb")
