use std.spec.{describe, it, expect}
use app.test_runner_new.test_runner_resources.{
    default_resource_limits,
    resource_limits_for_slow_tests,
    resource_limits_disabled,
    format_violation_alert,
    has_violations,
    format_resource_metrics,
    append_resource_info_to_output
}
use std.resource_tracker.{ResourceUsageRecord}

fn sample_resource_record(violations: text, sample_count: i64) -> ResourceUsageRecord:
    ResourceUsageRecord(
        test_file: "test/example_spec.spl",
        timestamp_ms: 1000,
        duration_ms: 500,
        max_cpu_percent: 250.0,
        max_memory_mb: 1024,
        avg_cpu_percent: 200.0,
        avg_memory_mb: 900,
        max_open_fds: 42,
        max_threads: 4,
        sample_count: sample_count,
        violations: violations
    )

describe "Test Runner Resources":
    it "builds default, slow, and disabled limits":
        val default_limits = default_resource_limits()
        val slow_limits = resource_limits_for_slow_tests()
        val disabled_limits = resource_limits_disabled()

        expect default_limits.cpu_percent_limit == 200.0
        expect default_limits.memory_mb_limit == 512
        expect default_limits.fd_limit == 1024
        expect default_limits.enabled == true

        expect slow_limits.cpu_percent_limit == 400.0
        expect slow_limits.memory_mb_limit == 1024
        expect slow_limits.fd_limit == 2048
        expect slow_limits.enabled == true

        expect disabled_limits.cpu_percent_limit == 0.0
        expect disabled_limits.memory_mb_limit == 0
        expect disabled_limits.fd_limit == 0
        expect disabled_limits.enabled == false

    it "formats violation alerts only when violations exist":
        val alert = format_violation_alert("test/example_spec.spl", sample_resource_record("cpu,memory,fds", 1))
        val empty = format_violation_alert("test/example_spec.spl", sample_resource_record("", 1))

        expect (alert).contains("[RESOURCE VIOLATION]")
        expect (alert).contains("CPU")
        expect (alert).contains("Memory")
        expect (alert).contains("File Descriptors")
        expect empty == ""

    it "detects violations and formats metrics":
        val violating = sample_resource_record("cpu", 1)
        val clean = sample_resource_record("", 1)
        val formatted = format_resource_metrics(violating)

        expect has_violations(violating) == true
        expect has_violations(clean) == false
        expect (formatted).contains("CPU: 250")
        expect (formatted).contains("Mem: 1024")
        expect (formatted).contains("FDs: 42")

    it "appends resource information only when samples exist":
        val output = "Test output"
        val appended = append_resource_info_to_output("test/example_spec.spl", sample_resource_record("cpu", 3), output)
        val untouched = append_resource_info_to_output("test/example_spec.spl", sample_resource_record("", 0), output)

        expect (appended).contains("Test output")
        expect (appended).contains("Resource Usage")
        expect (appended).contains("Resource violations: cpu")
        expect untouched == output