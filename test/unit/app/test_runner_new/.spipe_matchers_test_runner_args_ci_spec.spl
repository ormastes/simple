use std.spec.{describe, it, expect}
use app.test_runner_new.test_runner_args.{parse_test_args}

describe "Test Runner Args Ci":
    it "enables ci mode defaults":
        val options = parse_test_args(["--ci"])

        expect options.ci_mode == true
        expect options.run_all == true
        expect options.fail_fast == false

    it "keeps other flags when ci mode is enabled":
        val options = parse_test_args(["--ci", "--verbose", "test/unit/"])

        expect options.ci_mode == true
        expect options.verbose == true
        expect options.path == "test/unit/"

    it "leaves ci mode disabled by default":
        val options = parse_test_args([])

        expect options.ci_mode == false
        expect options.run_all == false

    it "preserves sdoctest behavior":
        val options = parse_test_args(["--sdoctest"])

        expect options.sdoctest == true