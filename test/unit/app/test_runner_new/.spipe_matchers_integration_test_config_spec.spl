use std.spec.{describe, it, expect, after_each}
use app.test_runner_new.test_config.{TestConfig, find_config_file, CONFIG_FILENAME}
use app.io.env_ops.{env_set, env_get}

val integration_config_original_ci = env_get("CI") ?? ""

fn restore_integration_ci():
    env_set("CI", integration_config_original_ci)

describe "Integration Test Config":
    after_each:
        restore_integration_ci()

    it "loads live values from config/simple.test.sdn":
        env_set("CI", "")
        val config = TestConfig.load()

        expect find_config_file().ends_with(CONFIG_FILENAME) == true
        expect config.parallel == false
        expect config.timeout_seconds == 120
        expect config.cpu_threshold == 70.0
        expect config.memory_threshold == 70.0
        expect config.throttle_enabled == true
        expect config.run_spec_tests == true
        expect config.run_sdoctests == true
        expect config.run_slow_tests == false

    it "applies ci overrides after loading file config":
        env_set("CI", "true")
        val config = TestConfig.load()

        expect config.ci_mode == true
        expect config.run_slow_tests == true
        expect config.fail_fast == false