use std.spec.{describe, it, expect, after_each}
use app.test_runner_new.process_tracker.{
    tracker_register_pid,
    tracker_get_pids,
    tracker_unregister_pid,
    tracker_register_container,
    tracker_get_containers,
    tracker_unregister_container,
    tracker_clear,
    tracker_kill_all_children,
    tracker_stop_all_containers,
    is_docker_available,
    get_running_containers,
    tracker_check_heartbeat_alive
}

describe "Process Tracker":
    after_each:
        tracker_clear()

    it "tracks pid registration and unregister":
        tracker_register_pid(101)
        tracker_register_pid(202)

        expect tracker_get_pids().len() == 2

        tracker_unregister_pid(101)
        val pids = tracker_get_pids()
        expect pids.len() == 1
        expect pids[0] == 202

    it "tracks container registration and unregister":
        tracker_register_container("ctr-a")
        tracker_register_container("ctr-b")

        expect tracker_get_containers().len() == 2

        tracker_unregister_container("ctr-a")
        val containers = tracker_get_containers()
        expect containers.len() == 1
        expect containers[0] == "ctr-b"

    it "clears tracked state and handles empty cleanup":
        tracker_register_pid(303)
        tracker_register_container("ctr-c")
        tracker_clear()

        expect tracker_get_pids().len() == 0
        expect tracker_get_containers().len() == 0
        expect tracker_kill_all_children() == 0
        expect tracker_stop_all_containers() == 0

    it "exposes safe runtime probes":
        val docker_available = is_docker_available()
        val containers = get_running_containers()

        expect docker_available == true or docker_available == false == true
        expect containers.len() >= 0 == true
        expect tracker_check_heartbeat_alive(1000) == true