# MCP Content Types Specification
# Feature: MCP Multi-Modal Content
# Category: MCP, Content
# Status: Complete

use std.common.mcp_helpers.{LB, RB, jp, js, make_image_content, make_audio_content, make_resource_link_content, make_embedded_resource_content, make_content_annotations, make_tool_result}

describe "MCP Image Content":
    slow_it "builds with data and MIME type":
        val content = make_image_content("base64data==", "image/png")
        expect content.contains("\"type\":\"image\"") == true
        expect content.contains("\"data\":\"base64data==\"") == true
        expect content.contains("\"mimeType\":\"image/png\"") == true

describe "MCP Audio Content":
    slow_it "builds with data and MIME type":
        val content = make_audio_content("audiodata==", "audio/wav")
        expect content.contains("\"type\":\"audio\"") == true
        expect content.contains("\"mimeType\":\"audio/wav\"") == true

describe "MCP Resource Link Content":
    slow_it "builds with URI and name":
        val content = make_resource_link_content("file:///test.spl", "test.spl")
        expect content.contains("\"type\":\"resource_link\"") == true
        expect content.contains("\"uri\":\"file:///test.spl\"") == true
        expect content.contains("\"name\":\"test.spl\"") == true

describe "MCP Embedded Resource Content":
    slow_it "builds with URI and text content":
        val content = make_embedded_resource_content("file:///test.spl", "fn main(): pass", "text/x-simple")
        expect content.contains("\"type\":\"resource\"") == true
        expect content.contains("fn main(): pass") == true

describe "MCP Content Annotations":
    slow_it "builds with audience and priority":
        val annot = make_content_annotations(["user"], "0.8", "")
        expect annot.contains("\"audience\"") == true
        expect annot.contains("\"priority\":0.8") == true

describe "MCP Tool Result":
    slow_it "wraps text content in proper structure":
        val result = make_tool_result("1", "Hello world")
        expect result.contains("\"content\"") == true
        expect result.contains("\"type\":\"text\"") == true
        expect result.contains("Hello world") == true