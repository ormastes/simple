# MCP Resources and Prompts Specification
# Feature: MCP Resource and Prompt Management
# Category: MCP, Resources, Prompts
# Status: Complete

use std.common.mcp_helpers.{LB, RB, Q, jp, js, jo1, jo2, jo3, extract_json_string, make_result_response, make_error_response, detect_mime_type}

describe "MCP Resource Management":
    context "when building resource URIs":
        it "builds file URI correctly":
            val uri = "file:///path/to/file.spl"
            expect (uri).starts_with("file://")
            expect (uri).ends_with(".spl")

        it "builds symbol URI correctly":
            val uri = "symbol:///MyClass"
            expect (uri).starts_with("symbol://")

        it "detects MIME type for resources":
            expect detect_mime_type("code.spl") == "text/x-simple"
            expect detect_mime_type("data.json") == "application/json"
            expect detect_mime_type("doc.md") == "text/markdown"

    context "when building resource list response":
        it "formats resource as JSON":
            val resource = jo3(
                jp("uri", js("file:///test.spl")),
                jp("name", js("test.spl")),
                jp("mimeType", js("text/x-simple"))
            )
            expect resource.contains("\"uri\"") == true
            expect resource.contains("\"name\"") == true
            expect resource.contains("\"mimeType\"") == true

    context "when handling missing resources":
        it "builds error response for missing resource":
            val response = make_error_response("1", -32602, "Resource not found")
            expect response.contains("-32602") == true
            expect response.contains("Resource not found") == true

describe "MCP Prompt Management":
    context "when building prompt list":
        it "formats prompt info as JSON":
            val prompt = jo2(jp("name", js("refactor-rename")), jp("description", js("Rename a symbol")))
            expect prompt.contains("refactor-rename") == true
            expect prompt.contains("Rename a symbol") == true

        it "formats prompt argument as JSON":
            val arg = jo3(jp("name", js("old_name")), jp("description", js("Current name")), jp("required", "true"))
            expect arg.contains("old_name") == true
            expect arg.contains("\"required\":true") == true

    context "when building prompt messages":
        it "formats user message":
            val msg = jo2(jp("role", js("user")), jp("content", js("Rename foo to bar")))
            expect msg.contains("\"role\":\"user\"") == true
            expect msg.contains("Rename foo to bar") == true

describe "MCP Resource URI Handling":
    context "when parsing file URIs":
        it "extracts URI from JSON":
            val json = jo1(jp("uri", js("file:///test.spl")))
            val uri = extract_json_string(json, "uri")
            expect uri == "file:///test.spl"

    context "when building resource content":
        it "formats resource content response":
            val content = jo2(jp("uri", js("file:///test.spl")), jp("text", js("fn main(): pass")))
            val result = jo1(jp("contents", "[" + content + "]"))
            val response = make_result_response("1", result)
            expect response.contains("\"contents\"") == true