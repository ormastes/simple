use app.mcp.dap_bridge.{dap_create_session, dap_close_session}

describe "MCP debug session bridge":
    it "captures RTL remote_bitbang bootstrap metadata in session creation":
        val session = dap_create_session(
            "build/rtl.elf",
            "openocd",
            "openocd_remote_bitbang",
            "riscv32",
            "rtl_sim",
            "generic",
            "",
            "",
            "localhost",
            "3333",
            "",
            "",
            "127.0.0.1",
            "5555",
            "",
            "true"
        )
        expect session.transport == "openocd_remote_bitbang"
        expect session.exec_mode == "rtl_sim"
        expect session.state == "bootstrap_ready"
        expect (session.bootstrap_launch_command).contains("remote_bitbang")
        expect (session.capabilities).contains("virtual_jtag")
        dap_close_session(session.id)

    it "captures Intel jtagd discovery metadata in session creation":
        val session = dap_create_session(
            "build/hw.elf",
            "intel_jtagd",
            "intel_jtagd",
            "riscv32",
            "hw",
            "intel",
            "",
            "",
            "localhost",
            "1309",
            "",
            "",
            "",
            "",
            "@1:10",
            "true"
        )
        expect session.backend_id == "intel_jtagd"
        expect session.bootstrap_discovery_command == "jtagconfig --enum"
        expect (session.bootstrap_attach_target).contains("@1:10")
        expect session.persistent_session == true
        dap_close_session(session.id)