# # MCP Debug Eval Intensive Specification
#
# Covers expression tokenization, parsing, and evaluation branches
# in `src/app/mcp/debug_eval.spl`.

use std.nogc_async_mut.mcp.debug_eval.{
    eval_is_digit,
    eval_is_alpha,
    eval_is_alnum,
    eval_tokenize,
    eval_peek,
    eval_lookup,
    eval_get_type,
    eval_get_value,
    eval_arith,
    eval_compare,
    eval_primary,
    eval_mul,
    eval_add,
    eval_expr,
    eval_expression
}

describe "MCP Debug Eval - Classification":
    it "detects digits":
        expect eval_is_digit('0') == true
        expect eval_is_digit('9') == true
        expect eval_is_digit('a') == false

    it "detects alpha and underscore":
        expect eval_is_alpha('a') == true
        expect eval_is_alpha('Z') == true
        expect eval_is_alpha('_') == true
        expect eval_is_alpha('7') == false

    it "detects alnum":
        expect eval_is_alnum('3') == true
        expect eval_is_alnum('q') == true
        expect eval_is_alnum('_') == true
        expect eval_is_alnum('-') == false


describe "MCP Debug Eval - Tokenization":
    it "tokenizes numbers, identifiers, strings, and operators":
        val tokens = eval_tokenize("foo 12 3.5 \"hi\" 'ok' == != <= >= < > + - * / % ( ) , ! =")
        expect tokens.contains("foo") == true
        expect tokens.contains("12") == true
        expect tokens.contains("3.5") == true
        expect tokens.contains("Q:hi") == true
        expect tokens.contains("Q:ok") == true
        expect tokens.contains("==") == true
        expect tokens.contains("!=" ) == true
        expect tokens.contains("<=") == true
        expect tokens.contains(">=") == true
        expect tokens.contains("<") == true
        expect tokens.contains(">") == true
        expect tokens.contains("+" ) == true
        expect tokens.contains("-" ) == true
        expect tokens.contains("*" ) == true
        expect tokens.contains("/" ) == true
        expect tokens.contains("%" ) == true
        expect(tokens.contains("(" )).to_equal(true)
        expect(tokens.contains(")" )).to_equal(true)
        expect tokens.contains("," ) == true
        expect tokens.contains("!" ) == true
        expect tokens.contains("=" ) == true

    it "skips unknown characters":
        val tokens = eval_tokenize("1 $ 2")
        expect tokens.contains("$") == false
        expect tokens.contains("1") == true
        expect tokens.contains("2") == true


describe "MCP Debug Eval - Lookup and Types":
    it "parses typed variable entries":
        val vars = [
            "x = 10 : Int",
            "f = 2.5 : Float",
            "b = true : Bool",
            "s = hello : String",
            "u = 99"
        ]
        expect eval_lookup("x", vars) == "i:10"
        expect eval_lookup("f", vars) == "f:2.5"
        expect eval_lookup("b", vars) == "b:true"
        expect eval_lookup("s", vars) == "s:hello"
        expect eval_lookup("u", vars) == "s:99"

    it "returns error for unknown variable":
        val vars = ["x = 1 : Int"]
        val result = eval_lookup("missing", vars)
        expect result.starts_with("e:undefined variable") == true

    it "extracts type and value prefixes":
        expect eval_get_type("i:1") == "int"
        expect eval_get_type("f:1.5") == "float"
        expect eval_get_type("s:hi") == "string"
        expect eval_get_type("b:true") == "bool"
        expect eval_get_type("n:") == "nil"
        expect eval_get_type("oops") == "error"
        expect eval_get_value("i:42") == "42"
        expect eval_get_value("x") == "x"


describe "MCP Debug Eval - Arithmetic and Comparison":
    it "handles integer arithmetic and errors":
        expect eval_arith("i:5", "+", "i:3") == "i:8"
        expect eval_arith("i:5", "-", "i:3") == "i:2"
        expect eval_arith("i:5", "*", "i:3") == "i:15"
        expect eval_arith("i:6", "/", "i:3") == "i:2"
        expect eval_arith("i:6", "%", "i:4") == "i:2"
        expect eval_arith("i:1", "/", "i:0") == "e:division by zero"
        expect eval_arith("i:1", "%", "i:0") == "e:modulo by zero"

    it "handles string concatenation and type errors":
        expect eval_arith("s:hi", "+", "s:there") == "s:hithere"
        val err = eval_arith("i:1", "+", "s:two")
        expect err.starts_with("e:cannot apply") == true

    it "handles comparisons":
        expect eval_compare("i:1", "==", "i:1") == "b:true"
        expect eval_compare("i:1", "!=", "i:2") == "b:true"
        expect eval_compare("i:1", "<", "i:2") == "b:true"
        expect eval_compare("i:2", ">", "i:1") == "b:true"
        expect eval_compare("i:1", "<=", "i:1") == "b:true"
        expect eval_compare("i:2", ">=", "i:2") == "b:true"
        expect eval_compare("s:a", "==", "s:a") == "b:true"
        expect eval_compare("s:a", "!=", "s:b") == "b:true"
        val err = eval_compare("s:a", "<", "s:b")
        expect err.starts_with("e:cannot compare") == true


describe "MCP Debug Eval - Primary and Expression":
    it "parses primary literals and builtins":
        val vars = ["x = 7 : Int"]
        val t1 = eval_primary(["(", "1", "+", "2", ")"], 0, vars)
        expect t1.value == "i:3"
        val t2 = eval_primary(["-", "5"], 0, vars)
        expect t2.value == "i:-5"
        val t3 = eval_primary(["not", "true"], 0, vars)
        expect t3.value == "b:false"
        val t4 = eval_primary(["3.14"], 0, vars)
        expect t4.value == "f:3.14"
        val t5 = eval_primary(["Q:hi"], 0, vars)
        expect t5.value == "s:hi"
        val t6 = eval_primary(["true"], 0, vars)
        expect t6.value == "b:true"
        val t7 = eval_primary(["nil"], 0, vars)
        expect t7.value == "n:"
        val t8 = eval_primary(["type", "(", "1", ")"], 0, vars)
        expect t8.value == "s:int"
        val t9 = eval_primary(["len", "(", "Q:abc", ")"], 0, vars)
        expect t9.value == "i:3"
        val t10 = eval_primary(["str", "(", "1", ")"], 0, vars)
        expect t10.value == "s:1"
        val t11 = eval_primary(["x"], 0, vars)
        expect t11.value == "i:7"

    it "reports primary errors":
        val vars = []
        val err1 = eval_primary([], 0, vars)
        expect err1.value.starts_with("e:unexpected end") == true
        val err2 = eval_primary(["-", "Q:hi"], 0, vars)
        expect err2.value.starts_with("e:cannot negate") == true
        val err3 = eval_primary(["not", "1"], 0, vars)
        expect err3.value.starts_with("e:cannot apply 'not'") == true
        val err4 = eval_primary(["len", "(", "1", ")"], 0, vars)
        expect err4.value.starts_with("e:len() requires") == true

    it "evaluates expressions with precedence and logic":
        expect eval_expression("1 + 2 * 3", []) == "i:7"
        expect eval_expression("(1 + 2) * 3", []) == "i:9"
        expect eval_expression("\"a\" + \"b\"", []) == "s:ab"
        expect eval_expression("1 / 0", []) == "e:division by zero"
        expect eval_expression("5 % 0", []) == "e:modulo by zero"
        expect eval_expression("1 == 1", []) == "b:true"
        expect eval_expression("1 != 2", []) == "b:true"
        expect eval_expression("1 <= 2", []) == "b:true"
        expect eval_expression("2 >= 2", []) == "b:true"
        expect eval_expression("true and false", []) == "b:false"
        expect eval_expression("true or false", []) == "b:true"
        expect eval_expression("not false", []) == "b:true"

    it "handles empty expressions":
        expect eval_expression("", []) == "e:empty expression"
        expect eval_expression("   ", []) == "e:empty expression"