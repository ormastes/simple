use app.mcp.tool_table.{get_tool_table}

describe "Assistant MCP Surface":
    fn tool_names() -> [text]:
        var names: [text] = []
        for entry in get_tool_table():
            if entry.name.starts_with("assistant_"):
                names.push(entry.name)
        names

    fn has_tool(names: [text], needle: text) -> bool:
        for name in names:
            if name == needle:
                return true
        false

    it "publishes the core assistant tools":
        val names = tool_names()
        expect has_tool(names, "assistant_start") == true
        expect has_tool(names, "assistant_spawn_task") == true
        expect has_tool(names, "assistant_pause") == true
        expect has_tool(names, "assistant_resume") == true
        expect has_tool(names, "assistant_brief") == true
        expect has_tool(names, "assistant_list_sessions") == true
        expect has_tool(names, "assistant_get_session") == true
        expect has_tool(names, "assistant_get_timeline") == true
        expect has_tool(names, "assistant_push_signal") == true
        expect has_tool(names, "assistant_list_tasks") == true
        expect has_tool(names, "assistant_get_notifications") == true

    it "marks assistant tools as in-process handlers":
        for entry in get_tool_table():
            if entry.name.starts_with("assistant_"):
                expect entry.handler_kind == "in_process"