# MCP Hardware Debug Tool Handler Tests
# Tests all 6 new hardware debug handlers: missing params, session validation, type checks.
# Uses logic-only assertions (no real I/O).

# --- Local helpers ---

fn validate_session_type(session_type: text, required: [text]) -> bool:
    for r in required:
        if session_type == r:
            return true
    false

# --- Tests ---

describe "debug_trace_capture handler":
    it "requires session_id parameter":
        val session_id = ""
        val has_error = session_id == ""
        expect has_error == true

    it "requires T32 session type":
        val valid = validate_session_type("t32", ["t32", "t32_gdb"])
        expect valid == true

    it "rejects interpreter session type":
        val valid = validate_session_type("interpreter", ["t32", "t32_gdb"])
        expect valid == false

    it "defaults duration to 1000ms":
        var duration = 1000
        val duration_str = ""
        if duration_str != "":
            duration = 500
        expect duration == 1000

describe "debug_coverage_collect handler":
    it "requires session_id and module":
        val session_id = ""
        val module = ""
        val missing = session_id == "" or module == ""
        expect missing == true

    it "requires T32 session type":
        val valid = validate_session_type("t32_gdb", ["t32", "t32_gdb"])
        expect valid == true

    it "rejects openocd session type":
        val valid = validate_session_type("openocd", ["t32", "t32_gdb"])
        expect valid == false

describe "debug_flash_program handler":
    it "requires session_id and elf_path":
        val session_id = "session_1"
        val elf_path = ""
        val missing = session_id == "" or elf_path == ""
        expect missing == true

    it "accepts T32 session type":
        val valid = validate_session_type("t32", ["t32", "t32_gdb", "openocd", "intel_jtagd"])
        expect valid == true

    it "accepts OpenOCD session type":
        val valid = validate_session_type("openocd", ["t32", "t32_gdb", "openocd", "intel_jtagd"])
        expect valid == true

    it "accepts Intel jtagd session type":
        val valid = validate_session_type("intel_jtagd", ["t32", "t32_gdb", "openocd", "intel_jtagd"])
        expect valid == true

    it "rejects interpreter session type":
        val valid = validate_session_type("interpreter", ["t32", "t32_gdb", "openocd"])
        expect valid == false

describe "debug_system_reset handler":
    it "requires session_id":
        val session_id = ""
        expect session_id == "" == true

    it "accepts hardware session types":
        val valid_t32 = validate_session_type("t32", ["t32", "t32_gdb", "openocd", "intel_jtagd"])
        val valid_ocd = validate_session_type("openocd", ["t32", "t32_gdb", "openocd", "intel_jtagd"])
        val valid_intel = validate_session_type("intel_jtagd", ["t32", "t32_gdb", "openocd", "intel_jtagd"])
        expect valid_t32 == true
        expect valid_ocd == true
        expect valid_intel == true

describe "debug_practice_script handler":
    it "requires session_id and script":
        val session_id = "session_1"
        val script = ""
        val missing = session_id == "" or script == ""
        expect missing == true

    it "requires T32 session type only":
        val valid = validate_session_type("t32", ["t32", "t32_gdb"])
        expect valid == true

    it "rejects non-T32 session type":
        val valid = validate_session_type("openocd", ["t32", "t32_gdb"])
        expect valid == false

describe "debug_openocd_monitor handler":
    it "requires session_id and command":
        val session_id = "session_1"
        val command = ""
        val missing = session_id == "" or command == ""
        expect missing == true

    it "requires OpenOCD session type only":
        val valid = validate_session_type("openocd", ["openocd"])
        expect valid == true

    it "rejects T32 session type":
        val valid = validate_session_type("t32", ["openocd"])
        expect valid == false

    it "rejects interpreter session type":
        val valid = validate_session_type("interpreter", ["openocd"])
        expect valid == false