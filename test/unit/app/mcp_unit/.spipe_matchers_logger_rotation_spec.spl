# Logger File Rotation Tests
# Tests file rotation logic and global logger initialization

use std.common.mcp_helpers.{make_log_notification, log_level_to_int}

describe "Logger File Rotation":
    describe "File Size Check":
        it "triggers rotation when size exceeds max":
            val current_size = 11000000
            val max_file_size = 10000000
            expect current_size > max_file_size == true

        it "does not rotate when size is below max":
            val current_size = 5000000
            val max_file_size = 10000000
            expect current_size <= max_file_size == true

    describe "Global Logger Initialization":
        it "handles initialization error":
            val notif = make_log_notification("error", "Logger init failed", "mcp")
            expect notif.contains("Logger init failed") == true

        it "initializes successfully":
            val notif = make_log_notification("info", "Logger initialized", "mcp")
            expect notif.contains("Logger initialized") == true

    describe "Flush Logs":
        it "handles flush when logger is nil":
            val logger_available = false
            val should_flush = logger_available
            expect should_flush == false

        it "flushes when logger exists":
            val logger_available = true
            val should_flush = logger_available
            expect should_flush == true

    describe "Rotation Logic":
        it "archives old log file":
            val old_path = "/tmp/mcp.log"
            val archive_path = "/tmp/mcp.log.1"
            expect archive_path.contains("log.1") == true

        it "creates new log file after rotation":
            val new_path = "/tmp/mcp.log"
            val size_after_creation = 0
            expect size_after_creation == 0

        it "resets size counter after rotation":
            var size_after_rotation = 10000000
            size_after_rotation = 0
            expect size_after_rotation == 0