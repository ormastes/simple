# Unit tests for MCP structured diagnostic formatting
#
# Tests the <new-diagnostics> block format used by simple_read, simple_edit, simple_multi_edit

# @cover src/app/mcp/main_lazy_diag_tools.spl 60%

# NOTE: These test the format helpers directly. The helpers are defined in
# main_lazy_diag_tools.spl and imported via the MCP server module path.

describe "MCP Diagnostic Format":
    """Tests for structured diagnostic formatting in MCP tool results"""

    context "severity_label":
        """Maps LSP severity integers to human-readable labels"""

        it "maps 1 to Error":
            expect(severity_label(1)).to_equal("Error")

        it "maps 2 to Warning":
            expect(severity_label(2)).to_equal("Warning")

        it "maps 3 to Information":
            expect(severity_label(3)).to_equal("Information")

        it "maps 4 to Hint":
            expect(severity_label(4)).to_equal("Hint")

        it "maps 0 to Unknown":
            expect(severity_label(0)).to_equal("Unknown")

        it "maps 5 to Unknown":
            expect(severity_label(5)).to_equal("Unknown")

    context "format_diag_line":
        """Parses JSON diagnostic line into formatted string"""

        it "formats error diagnostic":
            val json = "{\"severity\":\"1\",\"code\":\"E0001\",\"message\":\"undeclared variable\",\"line\":\"10\",\"col\":\"5\",\"source\":\"simple\"}"
            val result = format_diag_line(json)
            expect(result).to_contain("Error")
            expect(result).to_contain("line 10")
            expect(result).to_contain("col 5")
            expect(result).to_contain("undeclared variable")
            expect(result).to_contain("[E0001]")
            expect(result).to_contain("(simple)")

        it "formats warning diagnostic":
            val json = "{\"severity\":\"2\",\"code\":\"W0012\",\"message\":\"unused import\",\"line\":\"20\",\"col\":\"1\",\"source\":\"simple\"}"
            val result = format_diag_line(json)
            expect(result).to_contain("Warning")
            expect(result).to_contain("unused import")
            expect(result).to_contain("[W0012]")

        it "handles empty code":
            val json = "{\"severity\":\"1\",\"code\":\"\",\"message\":\"parse error\",\"line\":\"1\",\"col\":\"1\",\"source\":\"simple\"}"
            val result = format_diag_line(json)
            expect(result).to_contain("Error")
            expect(result).to_contain("parse error")

        it "handles empty source":
            val json = "{\"severity\":\"4\",\"code\":\"H001\",\"message\":\"consider val\",\"line\":\"5\",\"col\":\"1\",\"source\":\"\"}"
            val result = format_diag_line(json)
            expect(result).to_contain("Hint")
            expect(result).to_contain("consider val")

    context "format_new_diagnostics_block":
        """Produces <new-diagnostics> XML block from JSON output"""

        it "returns empty for no diagnostics":
            val result = format_new_diagnostics_block("test.spl", "")
            expect(result).to_equal("")

        it "returns empty for non-diagnostic output":
            val result = format_new_diagnostics_block("test.spl", "some plain text\nwith no JSON")
            expect(result).to_equal("")

        it "wraps single diagnostic in block":
            val json = "{\"severity\":\"1\",\"code\":\"E0001\",\"message\":\"error msg\",\"line\":\"10\",\"col\":\"5\",\"source\":\"simple\"}"
            val result = format_new_diagnostics_block("src/test.spl", json)
            expect(result).to_contain("<new-diagnostics>")
            expect(result).to_contain("</new-diagnostics>")
            expect(result).to_contain("src/test.spl:")
            expect(result).to_contain("Error (line 10, col 5): error msg")

        it "wraps multiple diagnostics in block":
            val line1 = "{\"severity\":\"1\",\"code\":\"E0001\",\"message\":\"error\",\"line\":\"10\",\"col\":\"1\",\"source\":\"simple\"}"
            val line2 = "{\"severity\":\"2\",\"code\":\"W0001\",\"message\":\"warning\",\"line\":\"20\",\"col\":\"1\",\"source\":\"simple\"}"
            val json = line1 + "\n" + line2
            val result = format_new_diagnostics_block("test.spl", json)
            expect(result).to_contain("Error (line 10")
            expect(result).to_contain("Warning (line 20")

        it "skips non-diagnostic lines in mixed output":
            val json = "Loading file...\n{\"severity\":\"1\",\"code\":\"E0001\",\"message\":\"err\",\"line\":\"5\",\"col\":\"1\",\"source\":\"simple\"}\nDone."
            val result = format_new_diagnostics_block("test.spl", json)
            expect(result).to_contain("<new-diagnostics>")
            expect(result).to_contain("Error (line 5")

    context "LSP MCP format":
        """Simple LSP MCP diagnostics block format"""

        it "lsp_severity_label maps correctly":
            expect(lsp_severity_label(1)).to_equal("Error")
            expect(lsp_severity_label(2)).to_equal("Warning")
            expect(lsp_severity_label(3)).to_equal("Information")
            expect(lsp_severity_label(4)).to_equal("Hint")
