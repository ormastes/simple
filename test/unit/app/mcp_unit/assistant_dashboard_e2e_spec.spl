use app.dashboard.assistant_collectors.{collect_assistant_snapshot, collect_assistant_timeline}
use app.io.mod.{file_delete}
use app.mcp.main_lazy_assistant.{handle_assistant_start, handle_assistant_list_sessions}
use std.common.mcp_helpers.{extract_json_string, jo1, jo2, jp, js}

extern fn rt_getpid() -> i64

val ASSISTANT_STORE_ROOT = ".build/llm_dashboard/assistant"

fn assistant_session_path(session_id: text) -> text:
    "{ASSISTANT_STORE_ROOT}/sessions/{session_id}.json"

fn assistant_timeline_path(session_id: text) -> text:
    "{ASSISTANT_STORE_ROOT}/timelines/{session_id}.jsonl"

fn assistant_notifications_path(session_id: text) -> text:
    "{ASSISTANT_STORE_ROOT}/notifications/{session_id}.jsonl"

fn start_assistant(token: text) -> text:
    val body = jo2(
        jp("name", js("E2E {token}")),
        jp("prompt", js("Verify assistant store bridge {token}"))
    )
    handle_assistant_start("1", body)

fn read_started_session_id(response: text) -> text:
    val content = extract_json_string(response, "content")
    val entry = extract_json_string(content, "text")
    extract_json_string(entry, "session_id")

describe "assistant MCP to dashboard e2e":
    it "starts a session, lists it, and the dashboard reads the stored timeline":
        val token = "assistant_e2e_{rt_getpid()}"
        val start_resp = start_assistant(token)
        val session_id = read_started_session_id(start_resp)

        expect(session_id != "").to_equal(true)
        expect(start_resp.contains(token)).to_equal(true)

        val list_resp = handle_assistant_list_sessions("2", jo1(""))
        expect(list_resp.contains(session_id)).to_equal(true)
        expect(list_resp.contains(token)).to_equal(true)

        val snapshot = collect_assistant_snapshot()
        var matched = false
        for session in snapshot.sessions:
            if session.session_id == session_id:
                matched = true
        expect(matched).to_equal(true)
        expect(snapshot.total_sessions).to_be_greater_than(0)

        val timeline = collect_assistant_timeline(session_id)
        expect(timeline.len()).to_be_greater_than(0)

        file_delete(assistant_session_path(session_id))
        file_delete(assistant_timeline_path(session_id))
        file_delete(assistant_notifications_path(session_id))
