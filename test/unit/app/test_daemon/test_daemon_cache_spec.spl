# Test Daemon Cache Specification
#
# Tests change detection and result caching: freshness checks,
# recording results, invalidation, and persistence.
#
# **Feature IDs:** #TDMN-011 to #TDMN-020
# **Category:** Infrastructure

# ============================================================================
# Module-level mock cache state
# ============================================================================

var cache_keys: [text] = []
var cache_test_hashes: [i64] = []
var cache_statuses: [i64] = []
var cache_passed: [i64] = []
var cache_failed: [i64] = []
var cache_durations: [i64] = []

# Mock source hashes (simulate file content tracking)
var src_paths: [text] = []
var src_hashes: [i64] = []

fn cache_reset():
    cache_keys = []
    cache_test_hashes = []
    cache_statuses = []
    cache_passed = []
    cache_failed = []
    cache_durations = []
    src_paths = []
    src_hashes = []

fn cache_find(key: text) -> i64:
    var i = 0
    while i < cache_keys.len():
        if cache_keys[i] == key:
            return i
        i = i + 1
    -1

fn src_set_hash(path: text, hash: i64):
    var i = 0
    while i < src_paths.len():
        if src_paths[i] == path:
            src_hashes[i] = hash
            return
        i = i + 1
    src_paths = src_paths + [path]
    src_hashes = src_hashes + [hash]

fn src_get_hash(path: text) -> i64:
    var i = 0
    while i < src_paths.len():
        if src_paths[i] == path:
            return src_hashes[i]
        i = i + 1
    0

fn cache_record(test_path: text, test_hash: i64, status: i64, passed: i64, failed: i64, duration: i64):
    val idx = cache_find(test_path)
    if idx >= 0:
        cache_test_hashes[idx] = test_hash
        cache_statuses[idx] = status
        cache_passed[idx] = passed
        cache_failed[idx] = failed
        cache_durations[idx] = duration
    else:
        cache_keys = cache_keys + [test_path]
        cache_test_hashes = cache_test_hashes + [test_hash]
        cache_statuses = cache_statuses + [status]
        cache_passed = cache_passed + [passed]
        cache_failed = cache_failed + [failed]
        cache_durations = cache_durations + [duration]

fn cache_check_freshness(test_path: text) -> bool:
    val idx = cache_find(test_path)
    if idx < 0:
        return false
    val cached_hash = cache_test_hashes[idx]
    val current_hash = src_get_hash(test_path)
    cached_hash == current_hash and current_hash > 0

fn cache_invalidate_all():
    cache_keys = []
    cache_test_hashes = []
    cache_statuses = []
    cache_passed = []
    cache_failed = []
    cache_durations = []

# Getters
fn cache_count() -> i64:
    cache_keys.len()
fn cache_get_status(test_path: text) -> i64:
    val idx = cache_find(test_path)
    if idx >= 0:
        return cache_statuses[idx]
    -1
fn cache_get_passed(test_path: text) -> i64:
    val idx = cache_find(test_path)
    if idx >= 0:
        return cache_passed[idx]
    0
fn cache_get_failed(test_path: text) -> i64:
    val idx = cache_find(test_path)
    if idx >= 0:
        return cache_failed[idx]
    0
fn cache_get_duration(test_path: text) -> i64:
    val idx = cache_find(test_path)
    if idx >= 0:
        return cache_durations[idx]
    0

# ============================================================================
# Tests
# ============================================================================

describe "TestResultCache":
    describe "recording results":
        it "stores test result":
            cache_reset()
            cache_record("test/foo_spec.spl", 12345, 2, 10, 0, 500)
            expect(cache_count()).to_equal(1)
            expect(cache_get_status("test/foo_spec.spl")).to_equal(2)
            expect(cache_get_passed("test/foo_spec.spl")).to_equal(10)

        it "stores multiple results":
            cache_reset()
            cache_record("test/a_spec.spl", 111, 2, 5, 0, 200)
            cache_record("test/b_spec.spl", 222, 3, 3, 2, 800)
            expect(cache_count()).to_equal(2)
            expect(cache_get_passed("test/a_spec.spl")).to_equal(5)
            expect(cache_get_failed("test/b_spec.spl")).to_equal(2)

        it "updates existing entry":
            cache_reset()
            cache_record("test/x_spec.spl", 100, 3, 0, 1, 100)
            cache_record("test/x_spec.spl", 200, 2, 5, 0, 300)
            expect(cache_count()).to_equal(1)
            expect(cache_get_status("test/x_spec.spl")).to_equal(2)
            expect(cache_get_passed("test/x_spec.spl")).to_equal(5)

    describe "freshness checking":
        it "returns fresh when hash matches":
            cache_reset()
            src_set_hash("test/foo_spec.spl", 12345)
            cache_record("test/foo_spec.spl", 12345, 2, 10, 0, 500)
            expect(cache_check_freshness("test/foo_spec.spl")).to_equal(true)

        it "returns stale when hash differs":
            cache_reset()
            src_set_hash("test/foo_spec.spl", 99999)
            cache_record("test/foo_spec.spl", 12345, 2, 10, 0, 500)
            expect(cache_check_freshness("test/foo_spec.spl")).to_equal(false)

        it "returns stale for uncached test":
            cache_reset()
            src_set_hash("test/new_spec.spl", 11111)
            expect(cache_check_freshness("test/new_spec.spl")).to_equal(false)

        it "returns stale when no source hash":
            cache_reset()
            cache_record("test/foo_spec.spl", 12345, 2, 10, 0, 500)
            expect(cache_check_freshness("test/foo_spec.spl")).to_equal(false)

    describe "invalidation":
        it "clears all entries":
            cache_reset()
            cache_record("test/a_spec.spl", 111, 2, 5, 0, 200)
            cache_record("test/b_spec.spl", 222, 2, 3, 0, 100)
            expect(cache_count()).to_equal(2)
            cache_invalidate_all()
            expect(cache_count()).to_equal(0)

        it "freshness returns stale after invalidation":
            cache_reset()
            src_set_hash("test/foo_spec.spl", 12345)
            cache_record("test/foo_spec.spl", 12345, 2, 10, 0, 500)
            cache_invalidate_all()
            expect(cache_check_freshness("test/foo_spec.spl")).to_equal(false)

    describe "duration tracking":
        it "records test duration":
            cache_reset()
            cache_record("test/slow_spec.spl", 100, 2, 1, 0, 5000)
            expect(cache_get_duration("test/slow_spec.spl")).to_equal(5000)

        it "returns 0 for unknown test":
            cache_reset()
            expect(cache_get_duration("test/unknown_spec.spl")).to_equal(0)
