# Test Daemon Execution Session Specification
#
# Tests execution session management: local vs remote targets,
# GDB-backed execution, multi-target coordination, config factory
# methods, and execution result tracking.
#
# **Feature IDs:** #TDMN-071 to #TDMN-090
# **Category:** Infrastructure

# ============================================================================
# Module-level mock state — simulates ExecutionConfig/TestExecutor
# ============================================================================

val EXEC_LOCAL: i64 = 0
val EXEC_QEMU_RV32: i64 = 1
val EXEC_QEMU_RV64: i64 = 2
val EXEC_QEMU_ARM64: i64 = 3
val EXEC_QEMU_X86: i64 = 4
val EXEC_REMOTE: i64 = 5

val EXEC_UNINIT: i64 = 0
val EXEC_READY: i64 = 1
val EXEC_EXECUTING: i64 = 2
val EXEC_DONE: i64 = 3
val EXEC_FAILED: i64 = 4

var ex_ids: [text] = []
var ex_targets: [i64] = []
var ex_programs: [text] = []
var ex_states: [i64] = []
var ex_clear_context: [bool] = []
var ex_reload_program: [bool] = []
var ex_timeout_ms: [i64] = []
var ex_gdb_ports: [i64] = []
var ex_exec_counts: [i64] = []
var ex_reset_counts: [i64] = []
var ex_results_success: [bool] = []
var ex_results_exit_code: [i64] = []
var ex_results_duration: [i64] = []
var ex_next_id: i64 = 1

fn ex_reset_all():
    ex_ids = []
    ex_targets = []
    ex_programs = []
    ex_states = []
    ex_clear_context = []
    ex_reload_program = []
    ex_timeout_ms = []
    ex_gdb_ports = []
    ex_exec_counts = []
    ex_reset_counts = []
    ex_results_success = []
    ex_results_exit_code = []
    ex_results_duration = []
    ex_next_id = 1

fn ex_find(id: text) -> i64:
    val ids = ex_ids
    var i = 0
    while i < ids.len():
        if ids[i] == id:
            return i
        i = i + 1
    -1

fn ex_create_local(program: text) -> text:
    val id = "exec_{ex_next_id}"
    ex_next_id = ex_next_id + 1
    ex_ids = ex_ids + [id]
    ex_targets = ex_targets + [EXEC_LOCAL]
    ex_programs = ex_programs + [program]
    ex_states = ex_states + [EXEC_UNINIT]
    ex_clear_context = ex_clear_context + [true]
    ex_reload_program = ex_reload_program + [false]
    ex_timeout_ms = ex_timeout_ms + [30000]
    ex_gdb_ports = ex_gdb_ports + [0]
    ex_exec_counts = ex_exec_counts + [0]
    ex_reset_counts = ex_reset_counts + [0]
    ex_results_success = ex_results_success + [false]
    ex_results_exit_code = ex_results_exit_code + [0]
    ex_results_duration = ex_results_duration + [0]
    id

fn ex_create_qemu(target: i64, program: text, gdb_port: i64) -> text:
    val id = "exec_{ex_next_id}"
    ex_next_id = ex_next_id + 1
    ex_ids = ex_ids + [id]
    ex_targets = ex_targets + [target]
    ex_programs = ex_programs + [program]
    ex_states = ex_states + [EXEC_UNINIT]
    ex_clear_context = ex_clear_context + [false]
    ex_reload_program = ex_reload_program + [true]
    ex_timeout_ms = ex_timeout_ms + [60000]
    ex_gdb_ports = ex_gdb_ports + [gdb_port]
    ex_exec_counts = ex_exec_counts + [0]
    ex_reset_counts = ex_reset_counts + [0]
    ex_results_success = ex_results_success + [false]
    ex_results_exit_code = ex_results_exit_code + [0]
    ex_results_duration = ex_results_duration + [0]
    id

fn ex_initialize(id: text) -> bool:
    val idx = ex_find(id)
    if idx < 0:
        return false
    val states = ex_states
    if states[idx] != EXEC_UNINIT:
        return false
    ex_states[idx] = EXEC_READY
    true

fn ex_execute(id: text, success: bool, exit_code: i64, duration: i64) -> bool:
    val idx = ex_find(id)
    if idx < 0:
        return false
    val states = ex_states
    if states[idx] != EXEC_READY:
        return false
    ex_states[idx] = EXEC_EXECUTING
    val counts = ex_exec_counts
    ex_exec_counts[idx] = counts[idx] + 1
    ex_results_success[idx] = success
    ex_results_exit_code[idx] = exit_code
    ex_results_duration[idx] = duration
    ex_states[idx] = EXEC_DONE
    true

fn ex_reset_session(id: text) -> bool:
    val idx = ex_find(id)
    if idx < 0:
        return false
    val clr = ex_clear_context
    if clr[idx]:
        val rc = ex_reset_counts
        ex_reset_counts[idx] = rc[idx] + 1
    ex_states[idx] = EXEC_READY
    true

fn ex_cleanup(id: text) -> bool:
    val idx = ex_find(id)
    if idx < 0:
        return false
    ex_states[idx] = EXEC_UNINIT  # write only — OK
    true

# Getters
fn ex_count() -> i64:
    val ids = ex_ids
    ids.len()

fn ex_get_target(id: text) -> i64:
    val idx = ex_find(id)
    if idx >= 0:
        val tgts = ex_targets
        return tgts[idx]
    -1

fn ex_get_state(id: text) -> i64:
    val idx = ex_find(id)
    if idx >= 0:
        val sts = ex_states
        return sts[idx]
    -1

fn ex_get_exec_count(id: text) -> i64:
    val idx = ex_find(id)
    if idx >= 0:
        val ec = ex_exec_counts
        return ec[idx]
    0

fn ex_get_reset_count(id: text) -> i64:
    val idx = ex_find(id)
    if idx >= 0:
        val rc = ex_reset_counts
        return rc[idx]
    0

fn ex_get_timeout(id: text) -> i64:
    val idx = ex_find(id)
    if idx >= 0:
        val tm = ex_timeout_ms
        return tm[idx]
    0

fn ex_get_gdb_port(id: text) -> i64:
    val idx = ex_find(id)
    if idx >= 0:
        val gp = ex_gdb_ports
        return gp[idx]
    0

fn ex_get_result_success(id: text) -> bool:
    val idx = ex_find(id)
    if idx >= 0:
        val rs = ex_results_success
        return rs[idx]
    false

fn ex_get_result_exit_code(id: text) -> i64:
    val idx = ex_find(id)
    if idx >= 0:
        val rec = ex_results_exit_code
        return rec[idx]
    -1

fn ex_is_clear_context(id: text) -> bool:
    val idx = ex_find(id)
    if idx >= 0:
        val cc = ex_clear_context
        return cc[idx]
    false

fn ex_is_reload_program(id: text) -> bool:
    val idx = ex_find(id)
    if idx >= 0:
        val rp = ex_reload_program
        return rp[idx]
    false

# ============================================================================
# Helper functions
# ============================================================================

fn ex_init_and_execute(id: text, success: bool, exit_code: i64, duration: i64) -> bool:
    val init_ok = ex_initialize(id)
    if not init_ok:
        return false
    ex_execute(id, success, exit_code, duration)

fn ex_run_n_tests_local(id: text, n: i64) -> i64:
    var passed: i64 = 0
    var i: i64 = 0
    while i < n:
        val ok = ex_execute(id, true, 0, 100)
        if ok:
            passed = passed + 1
        ex_reset_session(id)
        i = i + 1
    passed

fn ex_create_multi_target_sessions() -> [text]:
    var ids: [text] = []
    ids = ids + [ex_create_local("/tmp/test_local")]
    ids = ids + [ex_create_qemu(EXEC_QEMU_RV32, "/tmp/test_rv32.elf", 1234)]
    ids = ids + [ex_create_qemu(EXEC_QEMU_ARM64, "/tmp/test_arm64.elf", 1235)]
    ids = ids + [ex_create_qemu(EXEC_QEMU_X86, "/tmp/test_x86.elf", 1236)]
    ids

fn ex_initialize_all(ids: [text]) -> i64:
    var ok_count: i64 = 0
    var i = 0
    while i < ids.len():
        if ex_initialize(ids[i]):
            ok_count = ok_count + 1
        i = i + 1
    ok_count

fn ex_cleanup_all(ids: [text]):
    var i = 0
    while i < ids.len():
        ex_cleanup(ids[i])
        i = i + 1

fn ex_execute_on_all(ids: [text]) -> i64:
    var ok_count: i64 = 0
    var i = 0
    while i < ids.len():
        if ex_execute(ids[i], true, 0, 50 + i * 10):
            ok_count = ok_count + 1
        i = i + 1
    ok_count

# ============================================================================
# Execution strategy helpers
# ============================================================================

fn categorize_test_file(path: text) -> text:
    if path.contains("/qemu/") or path.contains("/emulator/"):
        return "qemu"
    if path.contains("/baremetal/") or path.contains("/kernel/"):
        return "baremetal"
    if path.contains("/database/"):
        return "database"
    if path.contains("/integration/"):
        return "integration"
    if path.contains("/unit/"):
        return "unit"
    if path.contains("/system/"):
        return "system"
    "other"

fn strategy_timeout_for_category(category: text) -> i64:
    if category == "qemu":
        return 1800
    if category == "baremetal":
        return 1800
    if category == "database":
        return 600
    if category == "integration":
        return 300
    if category == "unit":
        return 60
    if category == "system":
        return 600
    300

fn strategy_memory_mb_for_category(category: text) -> i64:
    if category == "qemu":
        return 2048
    if category == "baremetal":
        return 2048
    if category == "database":
        return 512
    if category == "unit":
        return 256
    if category == "system":
        return 1024
    512

# ============================================================================
# Tests
# ============================================================================

describe "Execution Sessions":
    describe "local execution":
        it "creates local executor with defaults":
            ex_reset_all()
            val id = ex_create_local("/tmp/test_binary")
            expect(ex_get_target(id)).to_equal(EXEC_LOCAL)
            expect(ex_get_timeout(id)).to_equal(30000)
            expect(ex_is_clear_context(id)).to_equal(true)
            expect(ex_is_reload_program(id)).to_equal(false)

        it "initializes and executes":
            ex_reset_all()
            val id = ex_create_local("/tmp/test_binary")
            expect(ex_init_and_execute(id, true, 0, 150)).to_equal(true)
            expect(ex_get_state(id)).to_equal(EXEC_DONE)
            expect(ex_get_result_success(id)).to_equal(true)

        it "runs multiple tests with reset":
            ex_reset_all()
            val id = ex_create_local("/tmp/test_binary")
            ex_initialize(id)
            val passed = ex_run_n_tests_local(id, 5)
            expect(passed).to_equal(5)
            expect(ex_get_exec_count(id)).to_equal(5)
            expect(ex_get_reset_count(id)).to_equal(5)

    describe "QEMU execution":
        it "creates QEMU RV32 executor with correct defaults":
            ex_reset_all()
            val id = ex_create_qemu(EXEC_QEMU_RV32, "/tmp/test.elf", 1234)
            expect(ex_get_target(id)).to_equal(EXEC_QEMU_RV32)
            expect(ex_get_timeout(id)).to_equal(60000)
            expect(ex_is_clear_context(id)).to_equal(false)
            expect(ex_is_reload_program(id)).to_equal(true)
            expect(ex_get_gdb_port(id)).to_equal(1234)

        it "creates QEMU ARM64 executor":
            ex_reset_all()
            val id = ex_create_qemu(EXEC_QEMU_ARM64, "/tmp/arm_test.elf", 1235)
            expect(ex_get_target(id)).to_equal(EXEC_QEMU_ARM64)
            expect(ex_get_gdb_port(id)).to_equal(1235)

        it "handles execution failure":
            ex_reset_all()
            val id = ex_create_qemu(EXEC_QEMU_RV32, "/tmp/test.elf", 1234)
            ex_initialize(id)
            ex_execute(id, false, 3, 500)
            expect(ex_get_result_success(id)).to_equal(false)
            expect(ex_get_result_exit_code(id)).to_equal(3)

    describe "multi-target coordination":
        it "creates sessions for 4 different targets":
            ex_reset_all()
            val ids = ex_create_multi_target_sessions()
            expect(ex_count()).to_equal(4)

        it "initializes all sessions":
            ex_reset_all()
            val ids = ex_create_multi_target_sessions()
            val ok = ex_initialize_all(ids)
            expect(ok).to_equal(4)

        it "executes on all targets":
            ex_reset_all()
            val ids = ex_create_multi_target_sessions()
            ex_initialize_all(ids)
            val ok = ex_execute_on_all(ids)
            expect(ok).to_equal(4)

        it "cleans up all sessions":
            ex_reset_all()
            val ids = ex_create_multi_target_sessions()
            ex_initialize_all(ids)
            ex_execute_on_all(ids)
            ex_cleanup_all(ids)
            expect(ex_get_state(ids[0])).to_equal(EXEC_UNINIT)
            expect(ex_get_state(ids[3])).to_equal(EXEC_UNINIT)

    describe "state transitions":
        it "enforces UNINIT -> READY -> EXECUTING -> DONE":
            ex_reset_all()
            val id = ex_create_local("/tmp/test")
            expect(ex_get_state(id)).to_equal(EXEC_UNINIT)
            ex_initialize(id)
            expect(ex_get_state(id)).to_equal(EXEC_READY)
            ex_execute(id, true, 0, 100)
            expect(ex_get_state(id)).to_equal(EXEC_DONE)

        it "cannot execute without initialize":
            ex_reset_all()
            val id = ex_create_local("/tmp/test")
            expect(ex_execute(id, true, 0, 100)).to_equal(false)

        it "cannot initialize twice":
            ex_reset_all()
            val id = ex_create_local("/tmp/test")
            expect(ex_initialize(id)).to_equal(true)
            expect(ex_initialize(id)).to_equal(false)

        it "reset returns to READY":
            ex_reset_all()
            val id = ex_create_local("/tmp/test")
            ex_initialize(id)
            ex_execute(id, true, 0, 100)
            ex_reset_session(id)
            expect(ex_get_state(id)).to_equal(EXEC_READY)

    describe "execution strategy":
        it "categorizes QEMU test files":
            expect(categorize_test_file("test/unit/lib/qemu/boot_spec.spl")).to_equal("qemu")
            expect(categorize_test_file("test/emulator/arm64_spec.spl")).to_equal("qemu")

        it "categorizes baremetal test files":
            expect(categorize_test_file("test/baremetal/kernel_init_spec.spl")).to_equal("baremetal")
            expect(categorize_test_file("test/kernel/boot_spec.spl")).to_equal("baremetal")

        it "categorizes standard test files":
            expect(categorize_test_file("test/unit/parser/lexer_spec.spl")).to_equal("unit")
            expect(categorize_test_file("test/integration/api_spec.spl")).to_equal("integration")
            expect(categorize_test_file("test/system/daemon_spec.spl")).to_equal("system")

        it "assigns correct timeouts per category":
            expect(strategy_timeout_for_category("qemu")).to_equal(1800)
            expect(strategy_timeout_for_category("baremetal")).to_equal(1800)
            expect(strategy_timeout_for_category("unit")).to_equal(60)
            expect(strategy_timeout_for_category("system")).to_equal(600)

        it "assigns correct memory per category":
            expect(strategy_memory_mb_for_category("qemu")).to_equal(2048)
            expect(strategy_memory_mb_for_category("unit")).to_equal(256)
            expect(strategy_memory_mb_for_category("system")).to_equal(1024)
