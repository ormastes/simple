# Test Daemon QEMU Broker Specification
#
# Tests QEMU session pooling: acquisition, release,
# idle cleanup, and session limits.
#
# **Feature IDs:** #TDMN-021 to #TDMN-030
# **Category:** Infrastructure

# ============================================================================
# Module-level mock state
# ============================================================================

val Q_IDLE: i64 = 0
val Q_IN_USE: i64 = 1
val Q_STALE: i64 = 2

var q_keys: [text] = []
var q_archs: [text] = []
var q_statuses: [i64] = []
var q_test_counts: [i64] = []
var q_last_used: [i64] = []
var q_max_sessions: i64 = 4
var q_time: i64 = 1000000

fn q_reset():
    q_keys = []
    q_archs = []
    q_statuses = []
    q_test_counts = []
    q_last_used = []
    q_max_sessions = 4
    q_time = 1000000

fn q_find(key: text) -> i64:
    var i = 0
    while i < q_keys.len():
        if q_keys[i] == key:
            return i
        i = i + 1
    -1

fn q_find_idle(key: text) -> i64:
    var i = 0
    while i < q_keys.len():
        if q_keys[i] == key and q_statuses[i] == Q_IDLE:
            return i
        i = i + 1
    -1

fn q_acquire(arch: text, binary_hash: i64) -> text:
    val key = "{arch}_{binary_hash}"
    # Check for existing idle
    val idx = q_find_idle(key)
    if idx >= 0:
        q_statuses[idx] = Q_IN_USE
        q_test_counts[idx] = q_test_counts[idx] + 1
        q_last_used[idx] = q_time
        return key

    # Create new (evict if at limit)
    if q_keys.len() >= q_max_sessions:
        q_evict_oldest_idle()

    q_keys = q_keys + [key]
    q_archs = q_archs + [arch]
    q_statuses = q_statuses + [Q_IN_USE]
    q_test_counts = q_test_counts + [1]
    q_last_used = q_last_used + [q_time]
    key

fn q_release(key: text):
    val idx = q_find(key)
    if idx >= 0:
        q_statuses[idx] = Q_IDLE
        q_last_used[idx] = q_time

fn q_cleanup_idle(timeout: i64):
    var nk: [text] = []
    var na: [text] = []
    var ns: [i64] = []
    var nt: [i64] = []
    var nl: [i64] = []
    var i = 0
    while i < q_keys.len():
        if q_statuses[i] != Q_IDLE or (q_time - q_last_used[i]) <= timeout:
            nk = nk + [q_keys[i]]
            na = na + [q_archs[i]]
            ns = ns + [q_statuses[i]]
            nt = nt + [q_test_counts[i]]
            nl = nl + [q_last_used[i]]
        i = i + 1
    q_keys = nk
    q_archs = na
    q_statuses = ns
    q_test_counts = nt
    q_last_used = nl

fn q_shutdown_all():
    q_keys = []
    q_archs = []
    q_statuses = []
    q_test_counts = []
    q_last_used = []

fn q_evict_oldest_idle():
    var oldest_idx = -1
    var oldest_time: i64 = 9999999999
    var i = 0
    while i < q_keys.len():
        if q_statuses[i] == Q_IDLE and q_last_used[i] < oldest_time:
            oldest_idx = i
            oldest_time = q_last_used[i]
        i = i + 1
    if oldest_idx >= 0:
        var nk: [text] = []
        var na: [text] = []
        var ns: [i64] = []
        var nt: [i64] = []
        var nl: [i64] = []
        var j = 0
        while j < q_keys.len():
            if j != oldest_idx:
                nk = nk + [q_keys[j]]
                na = na + [q_archs[j]]
                ns = ns + [q_statuses[j]]
                nt = nt + [q_test_counts[j]]
                nl = nl + [q_last_used[j]]
            j = j + 1
        q_keys = nk
        q_archs = na
        q_statuses = ns
        q_test_counts = nt
        q_last_used = nl

# Getters
fn q_count() -> i64:
    q_keys.len()
fn q_active_count() -> i64:
    var c: i64 = 0
    var i = 0
    while i < q_statuses.len():
        if q_statuses[i] == Q_IN_USE:
            c = c + 1
        i = i + 1
    c
fn q_idle_count() -> i64:
    var c: i64 = 0
    var i = 0
    while i < q_statuses.len():
        if q_statuses[i] == Q_IDLE:
            c = c + 1
        i = i + 1
    c
fn q_get_test_count(key: text) -> i64:
    val idx = q_find(key)
    if idx >= 0:
        return q_test_counts[idx]
    0
fn q_get_status(key: text) -> i64:
    val idx = q_find(key)
    if idx >= 0:
        return q_statuses[idx]
    -1

fn q_set_max_sessions(n: i64):
    q_max_sessions = n

fn q_set_time(t: i64):
    q_time = t

# ============================================================================
# Tests
# ============================================================================

describe "QemuBroker":
    describe "acquisition":
        it "creates new session":
            q_reset()
            val key = q_acquire("arm64", 12345)
            expect(key).to_equal("arm64_12345")
            expect(q_count()).to_equal(1)
            expect(q_get_status(key)).to_equal(Q_IN_USE)

        it "reuses idle session with same key":
            q_reset()
            val key1 = q_acquire("arm64", 12345)
            q_release(key1)
            val key2 = q_acquire("arm64", 12345)
            expect(key2).to_equal(key1)
            expect(q_count()).to_equal(1)
            expect(q_get_test_count(key2)).to_equal(2)

        it "creates separate sessions for different archs":
            q_reset()
            val k1 = q_acquire("arm64", 111)
            val k2 = q_acquire("riscv64", 222)
            expect(q_count()).to_equal(2)
            expect(k1 != k2).to_equal(true)

        it "creates separate sessions for different binaries":
            q_reset()
            val k1 = q_acquire("arm64", 111)
            val k2 = q_acquire("arm64", 222)
            expect(q_count()).to_equal(2)

    describe "release":
        it "marks session as idle":
            q_reset()
            val key = q_acquire("arm64", 100)
            expect(q_get_status(key)).to_equal(Q_IN_USE)
            q_release(key)
            expect(q_get_status(key)).to_equal(Q_IDLE)

        it "tracks active vs idle count":
            q_reset()
            val k1 = q_acquire("arm64", 100)
            val k2 = q_acquire("riscv64", 200)
            expect(q_active_count()).to_equal(2)
            expect(q_idle_count()).to_equal(0)
            q_release(k1)
            expect(q_active_count()).to_equal(1)
            expect(q_idle_count()).to_equal(1)

    describe "session limits":
        it "evicts oldest idle when at limit":
            q_reset()
            q_set_max_sessions(2)
            q_set_time(1000)
            val k1 = q_acquire("a", 1)
            q_release(k1)
            q_set_time(2000)
            val k2 = q_acquire("b", 2)
            q_release(k2)
            q_set_time(3000)
            # This should evict k1 (oldest idle)
            val k3 = q_acquire("c", 3)
            expect(q_count()).to_equal(2)
            expect(q_find(k1)).to_equal(-1)

    describe "idle cleanup":
        it "removes sessions idle beyond timeout":
            q_reset()
            q_set_time(1000)
            val k1 = q_acquire("arm64", 100)
            q_release(k1)
            q_set_time(5000)
            q_cleanup_idle(2000)
            expect(q_count()).to_equal(0)

        it "keeps sessions within timeout":
            q_reset()
            q_set_time(1000)
            val k1 = q_acquire("arm64", 100)
            q_release(k1)
            q_set_time(1500)
            q_cleanup_idle(2000)
            expect(q_count()).to_equal(1)

        it "keeps active sessions regardless of time":
            q_reset()
            q_set_time(1000)
            val k1 = q_acquire("arm64", 100)
            q_set_time(9999)
            q_cleanup_idle(1000)
            expect(q_count()).to_equal(1)
            expect(q_get_status(k1)).to_equal(Q_IN_USE)

    describe "shutdown":
        it "removes all sessions":
            q_reset()
            q_acquire("a", 1)
            q_acquire("b", 2)
            q_acquire("c", 3)
            expect(q_count()).to_equal(3)
            q_shutdown_all()
            expect(q_count()).to_equal(0)
