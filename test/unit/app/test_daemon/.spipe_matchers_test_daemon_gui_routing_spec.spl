# Test Daemon GUI Routing Specification
#
# Verifies GUI test path classification, session key mapping,
# mode normalization, and QEMU architecture inference using the
# actual gui_adapter implementation.
#
# **Feature IDs:** #TDMN-GUI-01 to #TDMN-GUI-15
# **Category:** Infrastructure

use std.spec.{describe, it, expect}
use std.io_runtime

use app.test_daemon.adapters.gui_adapter.{
    is_gui_test_path, gui_session_key_for_path, normalize_gui_mode,
    infer_qemu_arch
}

describe "TestDaemon GUI routing":
    describe "GUI path detection":
        it "treats system gui specs as GUI tests":
            expect is_gui_test_path("test/system/gui/widget_rendering_spec.spl") == true

        it "treats unit app ui specs as GUI tests":
            expect is_gui_test_path("test/unit/app/ui/unified_app_spec.spl") == true

        it "treats .ui.sdn files as GUI targets":
            expect is_gui_test_path("examples/ui/minimal.ui.sdn") == true

        it "treats app/ui paths as GUI tests":
            expect is_gui_test_path("src/app/ui/main_window.spl") == true

        it "does not treat non-gui specs as GUI tests":
            expect is_gui_test_path("test/system/test_daemon/test_daemon_flow_system_spec.spl") == false

        it "does not treat plain spl files as GUI tests":
            expect is_gui_test_path("test/unit/parser/lexer_spec.spl") == false

    describe "session key mapping":
        it "maps system gui tests to shared system key":
            val key = gui_session_key_for_path("test/system/gui/unified_app_spec.spl")
            expect key == "system_gui"

        it "maps unit app ui tests to shared unit key":
            val key = gui_session_key_for_path("test/unit/app/ui/theme_spec.spl")
            expect key == "unit_ui"

        it "falls back to path for unknown gui locations":
            val path = "tmp/custom/gui_like_spec.spl"
            val key = gui_session_key_for_path(path)
            expect key == path

    describe "mode normalization":
        it "accepts container mode":
            expect normalize_gui_mode("container") == "container"

        it "maps headed/native to native":
            expect normalize_gui_mode("headed") == "native"
            expect normalize_gui_mode("native") == "native"

        it "maps none/headless/any to headless":
            expect normalize_gui_mode("none") == "headless"
            expect normalize_gui_mode("headless") == "headless"
            expect normalize_gui_mode("any") == "headless"

        it "returns empty for unknown mode":
            expect normalize_gui_mode("weird_mode") == ""

    describe "QEMU arch inference":
        it "infers riscv64 from path":
            expect infer_qemu_arch("test/feature/baremetal/riscv64_boot_spec.spl") == "riscv64"

        it "infers riscv32 from path":
            expect infer_qemu_arch("test/feature/baremetal/riscv32_blink_spec.spl") == "riscv32"

        it "infers arm64 from path":
            expect infer_qemu_arch("test/feature/baremetal/arm64_boot_spec.spl") == "arm64"

        it "infers aarch64 as arm64":
            expect infer_qemu_arch("test/feature/baremetal/aarch64_uart_spec.spl") == "arm64"

        it "infers x86_64 from path":
            expect infer_qemu_arch("test/unit/compiler/native/x86_64_simd_spec.spl") == "x86_64"

        it "infers amd64 as x86_64":
            expect infer_qemu_arch("test/feature/baremetal/amd64_paging_spec.spl") == "x86_64"

        it "defaults to x86_64 when no arch detected":
            expect infer_qemu_arch("test/unit/parser/lexer_spec.spl") == "x86_64"