use app.cli.dispatch.{find_command}
use app.cli.dispatch.table.{get_command_table}

describe "CLI traceability-check command":
    it "is registered in the dispatch table":
        val table = get_command_table()
        var found = false
        for entry in table:
            if entry.name == "traceability-check":
                found = true
        expect(found).to_equal(true)

    it "routes to the traceability app":
        val result = find_command("traceability-check")
        var app_path = ""
        if val entry = result:
            app_path = entry.app_path
        expect(app_path).to_equal("src/app/traceability/main.spl")

    it "has a Simple implementation instead of a placeholder":
        val result = find_command("traceability-check")
        var has_simple_impl = false
        if val entry = result:
            has_simple_impl = entry.has_simple_impl()
        expect(has_simple_impl).to_equal(true)
