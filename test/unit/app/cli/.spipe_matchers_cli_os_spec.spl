use std.spec
use app.cli.main.{handle_os_inline}
use app.io.env_ops.{env_get, env_set}

describe "Top-level SimpleOS CLI wrapper":
    it "dispatches os targets successfully":
        expect handle_os_inline(["targets"]) == 0

    it "accepts os help aliases":
        expect handle_os_inline(["help"]) == 0
        expect handle_os_inline(["--help"]) == 0

    it "rejects unknown os subcommands with a non-zero exit code":
        expect handle_os_inline(["unknown-subcommand"]) == 1

    it "keeps the last valid --log occurrence across mixed forms":
        val prior = env_get("SIMPLE_OS_LOG_MODE")
        val before = if prior == nil: "" else: prior
        expect handle_os_inline(["build", "--log=off", "--log", "on", "--arch=bogus"]) == 1
        expect env_get("SIMPLE_OS_LOG_MODE") ?? "" == before