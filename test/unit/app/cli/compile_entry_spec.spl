# CLI compile entry argument normalization tests

use app.cli.compile_entry.{normalize_compile_args}

describe "compile_entry normalize_compile_args":
    it "keeps the compile token and subcommand args after the wrapper paths":
        val raw_args = [
            "bin/simple",
            "src/app/cli/compile_entry.spl",
            "compile",
            "src/app/hosted_apps/smux_client.spl",
            "--target",
            "x86_64-unknown-none",
            "-o",
            "/tmp/smux.smf"
        ]

        val args = normalize_compile_args(raw_args)

        expect args.len() == 6
        expect args[0] == "compile"
        expect args[1] == "src/app/hosted_apps/smux_client.spl"
        expect args[2] == "--target"
        expect args[3] == "x86_64-unknown-none"
        expect args[4] == "-o"
        expect args[5] == "/tmp/smux.smf"

    it "returns an empty list when argv is missing":
        val args = normalize_compile_args(nil)
        expect args.len() == 0

    it "returns an empty list when only wrapper metadata is present":
        val args = normalize_compile_args(["bin/simple", "src/app/cli/compile_entry.spl"])
        expect args.len() == 0
