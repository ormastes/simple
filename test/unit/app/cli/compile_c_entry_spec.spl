use app.cli.compile_c_entry.{normalize_compile_c_args}

describe "compile_c_entry normalize_compile_c_args":
    it "keeps source and output after the run launcher sentinel":
        val args = normalize_compile_c_args([
            "bin/simple",
            "run",
            "src/app/cli/compile_c_entry.spl",
            "src/main.spl",
            "build/main.cpp"
        ])

        expect(args).to_equal(["src/main.spl", "build/main.cpp"])

    it "preserves already-normalized source and output":
        val args = normalize_compile_c_args(["src/main.spl", "build/main.cpp"])
        expect(args).to_equal(["src/main.spl", "build/main.cpp"])
