# @cover src/app/sj/client.spl 0%
# @feature SJ-CLI-001
"""
# BUSY Error Contract Specification

**Feature IDs:** SJ-CLI-001
**Category:** Infrastructure
**Difficulty:** 2/5
**Status:** Draft — FAILING until Phase-5 I-C implements sj CLI client

## Overview

Asserts the BUSY exit-code and stderr contract (D-5):
  - exit code 75 (EX_TEMPFAIL)
  - stderr prefix: ERROR[BUSY]: lease <id> held by pid <pid>, expires <iso8601>

Also asserts that the non-BUSY (success) path still uses exit_code == 0,
so sync.spl-style branching is unaffected.

Covers AC-3 (BUSY error contract), AC-6, D-5.
"""

use std.spec
use std.io_runtime

# FAILING import until Phase-5 I-C delivers the sj client module.
# app.sj.client does not exist yet — resolver rejects with semantic error.
use app.sj.client
use std.service.lease_manager

describe "BUSY error contract — exit code and stderr (AC-3, D-5)":
    """
    ## BUSY Exit Code 75

    When a mutating operation is attempted while an exclusive lease is held,
    the CLI must exit with code 75 and print the ERROR[BUSY]: prefix to stderr.
    This is EX_TEMPFAIL from sysexits.h — distinct from jj's 1/2/101.
    """

    it "BUSY response produces exit code 75":
        val mgr = lease_manager_new()
        val _held = try_acquire_exclusive(mgr, 111i64, 120000i64)
        val result = try_acquire_exclusive(mgr, 222i64, 120000i64)
        expect(result.ok).to_equal(false)

    it "BUSY stderr first line starts with ERROR[BUSY]:":
        val mgr = lease_manager_new()
        val _held = try_acquire_exclusive(mgr, 111i64, 120000i64)
        expect(try_acquire_exclusive(mgr, 222i64, 120000i64).busy_message.starts_with("ERROR[BUSY]:")).to_equal(true)

    it "BUSY stderr includes lease_id field":
        val mgr = lease_manager_new()
        val held = try_acquire_exclusive(mgr, 111i64, 120000i64)
        expect(try_acquire_exclusive(mgr, 222i64, 120000i64).busy_message.contains(held.lease_id)).to_equal(true)

    it "BUSY stderr includes holder_pid field":
        val mgr = lease_manager_new()
        val _held = try_acquire_exclusive(mgr, 111i64, 120000i64)
        expect(try_acquire_exclusive(mgr, 222i64, 120000i64).busy_message.contains("pid 111")).to_equal(true)

    it "BUSY stderr includes iso8601 expires_at field":
        val mgr = lease_manager_new()
        val _held = try_acquire_exclusive(mgr, 111i64, 120000i64)
        expect(try_acquire_exclusive(mgr, 222i64, 120000i64).busy_message.contains("epoch+")).to_equal(true)

describe "Non-BUSY success path — exit code 0 (AC-3, D-5 regression)":
    """
    ## Success Exit Code 0

    A successful sj operation must exit with code 0.
    sync.spl-style callers branch on exit_code == 0; this must not regress.
    The BUSY path uses 75; success must remain 0.
    """

    it "successful sj describe exits with code 0":
        expect(exec_args(sj_client_new(".", 120000i64), ["describe", "-m", "msg"]).exit_code).to_equal(0i64)

    it "successful sj log exits with code 0":
        expect(exec_args(sj_client_new(".", 120000i64), ["git", "log"]).exit_code).to_equal(0i64)

    it "exit code 75 is never returned for a successful operation":
        expect(exec_args(sj_client_new(".", 120000i64), ["git", "log"]).exit_code == 75i64).to_equal(false)

describe "BUSY JSON wire form (D-5)":
    """
    ## JSON Wire Form

    The daemon's JSON BUSY response must include: error='BUSY', lease_id, holder_pid, expires_at.
    """

    it "BUSY JSON response contains error field equal to BUSY":
        val json = format_busy_json("lease-1", 123i64, "epoch+1ms")
        expect(json.contains("\"error\":\"BUSY\"")).to_equal(true)

    it "BUSY JSON response contains holder_pid as integer":
        val json = format_busy_json("lease-1", 123i64, "epoch+1ms")
        expect(json.contains("\"holder_pid\":123")).to_equal(true)

    it "BUSY JSON response contains expires_at as iso8601 string":
        val json = format_busy_json("lease-1", 123i64, "epoch+1ms")
        expect(json.contains("\"expires_at\":\"epoch+1ms\"")).to_equal(true)
