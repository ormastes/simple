# @cover src/app/sj/translator.spl 0%
# @feature SJ-TRANS-002
"""
# Multi-Step Translation Specification

**Feature IDs:** SJ-TRANS-002
**Category:** Infrastructure
**Difficulty:** 3/5
**Status:** Draft — FAILING until Phase-5 I-C implements translator module

## Overview

Tests multi-step translations where one git verb maps to two or more
sequential jj calls within the same exclusive lease.

Representative cases (3-6 per recipe item 2):
  sj git commit -m X    → jj describe -m X && jj new
  sj git checkout -b foo → jj new && jj bookmark create foo
  sj git pull           → jj git fetch && jj rebase -d main@origin

Covers AC-4, R-D multi-step rows.
"""

use std.spec
use std.io_runtime

# FAILING import until Phase-5 I-C delivers translator module.
# app.sj.translator does not exist yet — resolver rejects with semantic error.
use app.sj.translator

describe "Multi-step translation (AC-4, R-D)":
    """
    ## Two-or-More jj Calls Per Git Verb

    The translator must produce an ordered list of jj argv sequences.
    All steps share one exclusive lease (held until the last step completes).
    """

    it "sj git commit -m 'msg' translates to [jj describe -m msg, jj new]":
        val plan = translate(["git", "commit", "-m", "msg"])
        expect(plan.commands[0i64]).to_equal("jj describe -m msg")
        expect(plan.commands[1i64]).to_equal("jj new")

    it "sj git checkout -b foo translates to [jj new, jj bookmark create foo -r @]":
        val plan = translate(["git", "checkout", "-b", "foo"])
        expect(plan.commands[0i64]).to_equal("jj new")
        expect(plan.commands[1i64]).to_equal("jj bookmark create foo -r @")

    it "sj git checkout -b foo main translates to [jj new main, jj bookmark create foo -r @]":
        val plan = translate(["git", "checkout", "-b", "foo", "main"])
        expect(plan.commands[0i64]).to_equal("jj new main")
        expect(plan.commands[1i64]).to_equal("jj bookmark create foo -r @")

    it "sj git pull translates to [jj git fetch, jj rebase -d main@origin]":
        val plan = translate(["git", "pull"])
        expect(plan.commands[0i64]).to_equal("jj git fetch")
        expect(plan.commands[1i64]).to_equal("jj rebase -d main@origin")

    it "sj git commit --amend translates to single jj describe (direct, not multi-step)":
        val plan = translate(["git", "commit", "--amend"])
        expect(plan.classification).to_equal("direct_jj")

    it "multi-step steps share a single exclusive lease (not released between steps)":
        expect(translate(["git", "commit", "-m", "msg"]).lease_kind).to_equal(0i64)
