# @cover src/app/sj/jj_exec.spl 0%
# @feature SJ-BYPASS-001
"""
# Read-Bypass --ignore-working-copy Injection Specification

**Feature IDs:** SJ-BYPASS-001
**Category:** Infrastructure
**Difficulty:** 2/5
**Status:** Draft — FAILING until Phase-5 I-C implements jj_exec injection

## Overview

Asserts that every read-bypass-lane verb injects
  --ignore-working-copy --no-pager --color never
into the jj invocation.

Canonical verb list (D-3, exhaustive):
  log, status, diff, show, op log, op show, evolog,
  file annotate, file list, file show, bookmark list, config list

Covers AC-2 (read-only verbs bypass queue), D-3.
"""

use std.spec
use std.io_runtime

# FAILING import until Phase-5 I-C delivers jj_exec module.
# app.sj.jj_exec does not exist yet — resolver rejects with semantic error.
use app.sj.jj_exec

describe "Read-bypass injection — single-word verbs (AC-2, D-3)":
    """
    ## Single-Word Read-Bypass Verbs

    For each verb in the canonical read list, verify the constructed
    jj command includes all three injected flags.
    """

    it "jj log invocation includes --ignore-working-copy":
        expect(build_command(["jj", "log"]).contains("--ignore-working-copy")).to_equal(true)

    it "jj status invocation includes --ignore-working-copy":
        expect(build_command(["jj", "status"]).contains("--ignore-working-copy")).to_equal(true)

    it "jj diff invocation includes --ignore-working-copy":
        expect(build_command(["jj", "diff"]).contains("--ignore-working-copy")).to_equal(true)

    it "jj show invocation includes --ignore-working-copy":
        expect(build_command(["jj", "show"]).contains("--ignore-working-copy")).to_equal(true)

describe "Read-bypass injection — multi-word verbs (AC-2, D-3)":
    """
    ## Multi-Word Read-Bypass Verbs

    op log, op show, evolog, file annotate, file list, file show,
    bookmark list, config list all inject the same three flags.
    """

    it "jj op log invocation includes --ignore-working-copy":
        expect(build_command(["jj", "op", "log"]).contains("--ignore-working-copy")).to_equal(true)

    it "jj op show invocation includes --ignore-working-copy":
        expect(build_command(["jj", "op", "show"]).contains("--ignore-working-copy")).to_equal(true)

    it "jj evolog invocation includes --ignore-working-copy":
        expect(build_command(["jj", "evolog"]).contains("--ignore-working-copy")).to_equal(true)

    it "jj file annotate invocation includes --ignore-working-copy":
        expect(build_command(["jj", "file", "annotate", "a.spl"]).contains("--ignore-working-copy")).to_equal(true)

    it "jj file list invocation includes --ignore-working-copy":
        expect(build_command(["jj", "file", "list"]).contains("--ignore-working-copy")).to_equal(true)

    it "jj file show invocation includes --ignore-working-copy":
        expect(build_command(["jj", "file", "show", "a.spl"]).contains("--ignore-working-copy")).to_equal(true)

    it "jj bookmark list invocation includes --ignore-working-copy":
        expect(build_command(["jj", "bookmark", "list"]).contains("--ignore-working-copy")).to_equal(true)

    it "jj config list invocation includes --ignore-working-copy":
        expect(build_command(["jj", "config", "list"]).contains("--ignore-working-copy")).to_equal(true)

describe "Read-bypass injection — no-pager and color flags (D-3)":
    """
    ## No-Pager and Color=Never

    All three flags must be injected together:
    --ignore-working-copy --no-pager --color never
    """

    it "jj log invocation includes --no-pager":
        expect(build_command(["jj", "log"]).contains("--no-pager")).to_equal(true)

    it "jj log invocation includes --color never":
        expect(build_command(["jj", "log"]).contains("--color never")).to_equal(true)

describe "Mutating verbs do NOT get read-bypass injection (D-3 negative)":
    """
    ## Mutating Verbs Are Not Bypassed

    The describe, new, commit verbs must NOT receive --ignore-working-copy,
    as they need to observe the working copy.
    """

    it "jj describe invocation does NOT include --ignore-working-copy":
        expect(build_command(["jj", "describe"]).contains("--ignore-working-copy")).to_equal(false)

    it "jj new invocation does NOT include --ignore-working-copy":
        expect(build_command(["jj", "new"]).contains("--ignore-working-copy")).to_equal(false)
