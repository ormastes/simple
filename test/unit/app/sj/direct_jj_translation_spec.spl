"""
# Direct JJ Translation Specification
#
# Tests the git-to-jj verb translation table for direct (1:1) mappings.
"""

use std.io_runtime

# --- Inline constants ---
val LEASE_EXCLUSIVE: i64 = 0i64
val LEASE_SHARED: i64 = 1i64

# --- Inline translation types ---

struct TranslationPlan:
    classification: text
    lease_kind: i64
    commands: [text]
    warning: text

fn _tail(argv: [text], start: i64) -> [text]:
    var out: [text] = []
    var i = start
    while i < argv.len():
        out.push(argv[i])
        i = i + 1i64
    out

fn _join(argv: [text]) -> text:
    argv.join(" ")

fn _direct(command: text, lease_kind: i64) -> TranslationPlan:
    TranslationPlan(classification: "direct_jj", lease_kind: lease_kind, commands: [command], warning: "")

fn _raw(command: text, lease_kind: i64, warning: text) -> TranslationPlan:
    TranslationPlan(classification: "raw_passthrough", lease_kind: lease_kind, commands: [command], warning: warning)

fn translate(argv: [text]) -> TranslationPlan:
    if argv.len() == 0i64:
        return _direct("jj", LEASE_SHARED)
    if argv[0i64] == "raw" and argv.len() > 2i64:
        val lease_kind = if argv[1i64] == "jj":
            LEASE_SHARED
        else:
            LEASE_EXCLUSIVE
        return _raw(_join(_tail(argv, 1i64)), lease_kind, "")
    if argv[0i64] != "git":
        return _direct("jj " + _join(argv), LEASE_EXCLUSIVE)
    val verb = argv[1i64]
    if verb == "status":
        return _direct("jj status", LEASE_SHARED)
    if verb == "log":
        return _direct("jj " + _join(_tail(argv, 1i64)), LEASE_SHARED)
    if verb == "diff":
        return _direct("jj diff", LEASE_SHARED)
    if verb == "blame" and argv.len() > 2i64:
        return _direct("jj file annotate " + _join(_tail(argv, 2i64)), LEASE_SHARED)
    if verb == "branch" and argv.len() > 2i64 and argv[2i64] == "--list":
        return _direct("jj bookmark list", LEASE_SHARED)
    if verb == "checkout" and argv.len() > 2i64 and argv[2i64] != "-b":
        return _direct("jj new " + _join(_tail(argv, 2i64)), LEASE_EXCLUSIVE)
    _direct("jj " + _join(argv), LEASE_EXCLUSIVE)

# ============================================================================
# Tests
# ============================================================================

describe "Direct JJ Translation - Read Verbs":
    it "translates git status to jj status":
        val plan = translate(["git", "status"])
        expect(plan.commands[0i64]).to_equal("jj status")
        expect(plan.lease_kind).to_equal(LEASE_SHARED)
        expect(plan.classification).to_equal("direct_jj")

    it "translates git log to jj log":
        val plan = translate(["git", "log"])
        expect(plan.commands[0i64]).to_equal("jj log")
        expect(plan.lease_kind).to_equal(LEASE_SHARED)

    it "translates git diff to jj diff":
        val plan = translate(["git", "diff"])
        expect(plan.commands[0i64]).to_equal("jj diff")
        expect(plan.lease_kind).to_equal(LEASE_SHARED)

    it "translates git blame to jj file annotate":
        val plan = translate(["git", "blame", "src/main.spl"])
        expect(plan.commands[0i64]).to_equal("jj file annotate src/main.spl")
        expect(plan.lease_kind).to_equal(LEASE_SHARED)

    it "translates git branch --list to jj bookmark list":
        val plan = translate(["git", "branch", "--list"])
        expect(plan.commands[0i64]).to_equal("jj bookmark list")
        expect(plan.lease_kind).to_equal(LEASE_SHARED)

describe "Direct JJ Translation - Mutating Verbs":
    it "translates git checkout <rev> to jj new <rev>":
        val plan = translate(["git", "checkout", "abc123"])
        expect(plan.commands[0i64]).to_equal("jj new abc123")
        expect(plan.lease_kind).to_equal(LEASE_EXCLUSIVE)

    it "passes through jj-native verbs with exclusive lease":
        val plan = translate(["describe", "-m", "test message"])
        expect(plan.commands[0i64]).to_equal("jj describe -m test message")
        expect(plan.lease_kind).to_equal(LEASE_EXCLUSIVE)
        expect(plan.classification).to_equal("direct_jj")
