# @cover src/app/sj/translator.spl 0%
# @feature SJ-TRANS-001
"""
# Direct jj Translation Specification

**Feature IDs:** SJ-TRANS-001
**Category:** Infrastructure
**Difficulty:** 2/5
**Status:** Draft — FAILING until Phase-5 I-C implements translator module

## Overview

Tests the direct_jj category of translations from git verbs to jj verbs.
One verb → one jj call, no multi-step orchestration.

Representative cases (3-6 per recipe item 2):
  sj git status    → jj status
  sj git log       → jj log
  sj git diff      → jj diff
  sj git blame foo → jj file annotate foo
  sj git branch --list → jj bookmark list
  sj git checkout <rev> → jj new <rev>

Covers AC-4, R-D direct_jj rows.
"""

use std.spec
use std.io_runtime

# FAILING import until Phase-5 I-C delivers translator module.
# app.sj.translator does not exist yet — resolver rejects with semantic error.
use app.sj.translator

describe "Direct jj translation (AC-4, R-D)":
    """
    ## Direct Single-Verb Translations

    Each sj git <verb> maps to exactly one jj <verb> with no side effects.
    The translator must produce the correct jj argv without executing it
    (execution is the jj_exec layer's job).
    """

    it "sj git status translates to jj status":
        expect(translate(["git", "status"]).commands[0i64]).to_equal("jj status")

    it "sj git log translates to jj log":
        expect(translate(["git", "log"]).commands[0i64]).to_equal("jj log")

    it "sj git diff translates to jj diff":
        expect(translate(["git", "diff"]).commands[0i64]).to_equal("jj diff")

    it "sj git blame foo.spl translates to jj file annotate foo.spl":
        expect(translate(["git", "blame", "foo.spl"]).commands[0i64]).to_equal("jj file annotate foo.spl")

    it "sj git branch --list translates to jj bookmark list":
        expect(translate(["git", "branch", "--list"]).commands[0i64]).to_equal("jj bookmark list")

    it "sj git checkout <rev> translates to jj new <rev> (explicit rev, not bare)":
        expect(translate(["git", "checkout", "abc123"]).commands[0i64]).to_equal("jj new abc123")

    it "direct translation preserves extra flags passed by user":
        expect(translate(["git", "log", "--limit=5"]).commands[0i64]).to_equal("jj log --limit=5")
