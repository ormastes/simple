# @cover src/app/sj/policy.spl 0%
# @feature SJ-POLICY-001
"""
# Forbidden Verbs Specification

**Feature IDs:** SJ-POLICY-001
**Category:** Infrastructure
**Difficulty:** 2/5
**Status:** Draft — FAILING until Phase-5 I-C implements policy module

## Overview

Asserts ERROR[FORBIDDEN] with the correct educational messages for each
forbidden verb. Forbidden verbs never enter the queue (pre-queue check).

Forbidden verbs:
  - sj git rebase -i       (D-1: no interactive TUI in jj 0.32.0)
  - sj git push            (bare, no remote/bookmark — ambiguous)
  - sj git push --force    (dangerous history rewrite)
  - sj git checkout        (bare, no args — ambiguous)
  - sj git filter-branch   (history rewrite, dangerous)
  - sj git stash           (D-11 dropped: redirect to jj new -m wip-<topic>)

Covers AC-4, D-1, D-11 (dropped → forbidden with redirect).
"""

use std.spec
use std.io_runtime

# FAILING import until Phase-5 I-C delivers policy module.
# app.sj.policy does not exist yet — resolver rejects with semantic error.
use app.sj.policy

describe "Forbidden verb — git rebase -i (D-1)":
    """
    ## git rebase -i is FORBIDDEN

    jj 0.32.0 has no interactive TUI equivalent of git rebase -i.
    The correct action is to compose sj split / sj squash --into / sj rebase --onto.
    Returning a wrong translation is worse than honest refusal (D-1 rationale).
    """

    it "sj git rebase -i returns ERROR[FORBIDDEN]":
        val result = check_forbidden(["git", "rebase", "-i"])
        expect(result.allowed).to_equal(false)
        expect(result.message.starts_with("ERROR[FORBIDDEN]:")).to_equal(true)

    it "sj git rebase -i message references sj split / sj squash --into / sj rebase --onto":
        val result = check_forbidden(["git", "rebase", "-i"])
        expect(result.message.contains("sj split")).to_equal(true)
        expect(result.message.contains("sj squash --into")).to_equal(true)
        expect(result.message.contains("sj rebase --onto")).to_equal(true)

    it "sj git rebase -i exits with code 1 (not 75)":
        expect(check_forbidden(["git", "rebase", "-i"]).exit_code).to_equal(1i64)

describe "Forbidden verb — bare git push (AC-5)":
    """
    ## Bare git push is FORBIDDEN

    sj git push without a remote or bookmark spec is ambiguous in jj's model.
    The correct form is: jj bookmark set main -r @- && jj git push --bookmark main
    """

    it "sj git push (bare) returns ERROR[FORBIDDEN]":
        expect(check_forbidden(["git", "push"]).allowed).to_equal(false)

    it "sj git push message references the bookmark-set + git-push pattern":
        val result = check_forbidden(["git", "push"])
        expect(result.message.contains("jj bookmark set main -r @-")).to_equal(true)

describe "Forbidden verb — git push --force":
    """
    ## git push --force is FORBIDDEN

    Force-push rewrites remote history. This is explicitly blocked.
    The message must explain the danger and suggest jj's safer alternatives.
    """

    it "sj git push --force returns ERROR[FORBIDDEN]":
        expect(check_forbidden(["git", "push", "--force"]).allowed).to_equal(false)

    it "sj git push --force exits with code 1":
        expect(check_forbidden(["git", "push", "--force"]).exit_code).to_equal(1i64)

describe "Forbidden verb — bare git checkout":
    """
    ## Bare git checkout (no args) is FORBIDDEN

    git checkout with no args is ambiguous. With -b or <rev> it is translated.
    """

    it "sj git checkout (bare, no args) returns ERROR[FORBIDDEN]":
        expect(check_forbidden(["git", "checkout"]).allowed).to_equal(false)

describe "Forbidden verb — git filter-branch":
    """
    ## git filter-branch is FORBIDDEN

    History rewrite. No jj equivalent. Dangerous.
    """

    it "sj git filter-branch returns ERROR[FORBIDDEN]":
        expect(check_forbidden(["git", "filter-branch"]).allowed).to_equal(false)

describe "Forbidden verb — git stash (D-11 dropped)":
    """
    ## git stash is FORBIDDEN (D-11 dropped from v1)

    D-11 (stash translation to jj new @-) is DROPPED from v1.
    sj git stash returns ERROR[FORBIDDEN] with a redirect message pointing
    to 'jj new -m wip-<topic>' as the idiomatic jj equivalent.
    This is the correct per-RESUME_PLAN.md §11a behavior.
    """

    it "sj git stash returns ERROR[FORBIDDEN]":
        expect(check_forbidden(["git", "stash"]).allowed).to_equal(false)

    it "sj git stash FORBIDDEN message says: use jj new -m wip-<topic> instead":
        expect(check_forbidden(["git", "stash"]).message.contains("jj new -m wip-<topic>")).to_equal(true)

    it "sj git stash pop also returns ERROR[FORBIDDEN]":
        expect(check_forbidden(["git", "stash", "pop"]).allowed).to_equal(false)

    it "sj git stash exits with code 1 (not 75)":
        expect(check_forbidden(["git", "stash"]).exit_code).to_equal(1i64)

describe "Non-forbidden verbs are NOT blocked by policy (D-1 negative)":
    """
    ## Non-Forbidden Verbs Pass Through

    Regression: the policy pre-check must not over-block.
    sj git rebase --onto (without -i) is a valid translation, not forbidden.
    """

    it "sj git rebase --onto is NOT forbidden":
        expect(check_forbidden(["git", "rebase", "--onto", "main"]).allowed).to_equal(true)

    it "sj git push --bookmark main is NOT forbidden":
        expect(check_forbidden(["git", "push", "--bookmark", "main"]).allowed).to_equal(true)
