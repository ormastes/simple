use std.spec
use app.io.cli_compile.{cli_compile, cli_native_build}

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

fn run_cli(args: [text]) -> (text, text, i64):
    rt_process_run("bin/simple", args)

describe "cli compile optimization surface":
    it "compile accepts named opt-level forms without rejecting them before file validation":
        val levels = ["none", "basic", "standard", "aggressive"]
        for level in levels:
            val result = cli_compile(["compile", "--backend=vhdl", "--opt-level=" + level, "missing_input.spl"])
            expect result == 1

    it "compile accepts split named opt-level forms on the in-process path":
        val levels = ["none", "basic", "standard", "aggressive"]
        for level in levels:
            val result = cli_compile(["compile", "--backend=vhdl", "--opt-level", level, "missing_input.spl"])
            expect result == 1

    it "compile delegated cli path rejects invalid named opt-levels before missing-file handling":
        val result = run_cli(["compile", "--opt-level=bogus", "missing_input.spl"])
        expect result.2 == 1
        expect (result.1).contains("Unknown optimization level: bogus")

    it "native-build accepts the same named opt-level forms on llvm-lib path":
        val levels = ["none", "basic", "standard", "aggressive"]
        for level in levels:
            val result = cli_native_build(["native-build", "--backend=llvm-lib", "--opt-level=" + level, "--entry", "missing_input.spl"])
            expect result == 1

    it "native-build llvm-lib path accepts split named opt-level forms":
        val levels = ["none", "basic", "standard", "aggressive"]
        for level in levels:
            val result = cli_native_build(["native-build", "--backend=llvm-lib", "--opt-level", level, "--entry", "missing_input.spl"])
            expect result == 1

    it "native-build delegated cli path accepts the same named opt-level forms":
        val levels = ["none", "basic", "standard", "aggressive"]
        for level in levels:
            val result = run_cli(["native-build", "--opt-level=" + level, "--entry", "missing_input.spl"])
            expect result.2 != 0 == true
            expect result.0.contains("invalid --opt-level") == false
            expect result.1.contains("invalid --opt-level") == false

    it "native-build delegated cli path rejects invalid runtime-bundle values before build work":
        val result = run_cli(["native-build", "--runtime-bundle=bogus", "--entry", "missing_input.spl"])
        expect result.2 != 0 == true
        expect result.0.contains("missing_input.spl") == false
        expect result.1.contains("missing_input.spl") == false

    it "native-build delegated cli path accepts stable delegated runtime-bundle aliases":
        val aliases = ["core-c", "runtime", "rust-hosted", "hosted", "all"]
        for lane in aliases:
            val result = run_cli(["native-build", "--runtime-bundle=" + lane, "--entry", "missing_input.spl"])
            expect result.2 != 0 == true
            expect result.1.contains("invalid --runtime-bundle") == false

    it "list-optimizations shares the same optimization inventory lines":
        val compile_output = run_cli(["compile", "--list-optimizations"])
        val native_output = run_cli(["native-build", "--list-optimizations"])

        expect compile_output.2 == 0
        expect native_output.2 == 0
        expect (compile_output.0).contains("Simple optimization guide")
        expect (native_output.0).contains("Simple optimization guide")
        expect (compile_output.0).contains("Native executable default profile: aggressive")
        expect (native_output.0).contains("Native executable default profile: aggressive")
        expect (compile_output.0).contains("Release MIR/self-hosted builds normalize to standard unless --opt-level overrides it.")
        expect native_output.0.contains("Release MIR/self-hosted builds normalize to standard unless --opt-level overrides it.") == false

        val shared_lines = [
            "  - [syntax] async desugar (basic, inventory-only)",
            "  - [syntax] placeholder lambda rewrite (basic, inventory-only)",
            "  - [syntax] collection pattern desugar (basic, inventory-only)",
            "  - [native] release build mode (basic, native-default)",
            "  - [native] 4KB layout optimization (aggressive, native-default)"
        ]
        for line in shared_lines:
            expect (compile_output.0).contains(line)
            expect (native_output.0).contains(line)