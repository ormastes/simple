use compiler.tools.fix.rules.{check_short_grammar_refactor}
use compiler.tools.fix.main.{FixApplicator, collect_fixes_from_source}
use std.tooling.easy_fix.{easyfix_replacements}

describe "short grammar easy fix":
    it "rewrites explicit method-call lambda to method reference":
        val source = "fn sample():\n    val lengths = words.map(\\w: w.len())\n"
        val fixes = check_short_grammar_refactor(source, "sample.spl")
        expect(fixes.len()).to_equal(1)
        val reps = easyfix_replacements(fixes[0])
        expect(reps[0].new_text).to_equal("&:len")

    it "applies method reference replacement in memory":
        val source = "fn sample():\n    val lengths = words.map(\\w: w.len())\n"
        val fixes = check_short_grammar_refactor(source, "sample.spl")
        var sources: Dict<text, text> = {}
        sources["sample.spl"] = source
        val result = FixApplicator.apply(fixes, sources)
        match result:
            case Ok(updated):
                expect(updated["sample.spl"]).to_contain("words.map(&:len)")
            case Err(e):
                expect(e).to_equal("")

    it "rewrites no-arg receiver method expressions to placeholder grammar":
        val source = "fn sample():\n    val adjusted = words.map(\\w: w.len() + 1)\n"
        val fixes = check_short_grammar_refactor(source, "sample.spl")
        expect(fixes.len()).to_equal(1)
        val reps = easyfix_replacements(fixes[0])
        expect(reps[0].new_text).to_equal("_.len() + 1")

    it "rewrites arithmetic lambdas to placeholder grammar":
        val source = "fn sample():\n    val doubled = nums.map(\\x: x * 2)\n"
        val fixes = check_short_grammar_refactor(source, "sample.spl")
        expect(fixes.len()).to_equal(1)
        val reps = easyfix_replacements(fixes[0])
        expect(reps[0].new_text).to_equal("_ * 2")

    it "rewrites predicate lambdas to placeholder grammar":
        val source = "fn sample():\n    val evens = nums.filter(\\x: x % 2 == 0)\n"
        val fixes = check_short_grammar_refactor(source, "sample.spl")
        expect(fixes.len()).to_equal(1)
        val reps = easyfix_replacements(fixes[0])
        expect(reps[0].new_text).to_equal("_ % 2 == 0")

    it "is registered in all fix rules":
        val source = "fn sample():\n    val trimmed = parts.map(\\p: p.trim())\n"
        val fixes = collect_fixes_from_source("sample.spl", source)
        var found = false
        for fix in fixes:
            val reps = easyfix_replacements(fix)
            if reps.len() > 0 and reps[0].new_text == "&:trim":
                found = true
        expect(found).to_equal(true)

    it "registers placeholder rewrites in all fix rules":
        val source = "fn sample():\n    val doubled = nums.map(\\x: x * 2)\n"
        val fixes = collect_fixes_from_source("sample.spl", source)
        var found = false
        for fix in fixes:
            val reps = easyfix_replacements(fix)
            if reps.len() > 0 and reps[0].new_text == "_ * 2":
                found = true
        expect(found).to_equal(true)

    it "rewrites receiver method predicates to placeholder grammar":
        val source = "fn sample():\n    val evens = values.filter(\\x: x.parse_int() % 2 == 0)\n"
        val fixes = check_short_grammar_refactor(source, "sample.spl")
        expect(fixes.len()).to_equal(1)
        val reps = easyfix_replacements(fixes[0])
        expect(reps[0].new_text).to_equal("_.parse_int() % 2 == 0")

    it "rewrites free function predicates to placeholder grammar":
        val source = "fn sample():\n    val evens = values.filter(\\x: int(x) % 2 == 0)\n"
        val fixes = check_short_grammar_refactor(source, "sample.spl")
        expect(fixes.len()).to_equal(1)
        val reps = easyfix_replacements(fixes[0])
        expect(reps[0].new_text).to_equal("int(_) % 2 == 0")

    it "rewrites single argument free function transforms to placeholder grammar":
        val source = "fn sample():\n    val doubled = values.map(\\x: double(x))\n"
        val fixes = check_short_grammar_refactor(source, "sample.spl")
        expect(fixes.len()).to_equal(1)
        val reps = easyfix_replacements(fixes[0])
        expect(reps[0].new_text).to_equal("double(_)")

    it "does not rewrite calls with explicit arguments":
        val source = "fn sample():\n    val values = items.map(\\x: x.adjust(1) + 1)\n"
        val fixes = check_short_grammar_refactor(source, "sample.spl")
        expect(fixes.len()).to_equal(0)

    it "does not rewrite free function calls with additional arguments":
        val source = "fn sample():\n    val values = items.map(\\x: add(x, 1))\n"
        val fixes = check_short_grammar_refactor(source, "sample.spl")
        expect(fixes.len()).to_equal(0)

    it "applies replacements after non-ascii text":
        val source = "# unicode before fix — keeps text offsets honest\nfn sample():\n    val values = items.map(\\x: x.trim())\n"
        val fixes = check_short_grammar_refactor(source, "sample.spl")
        var sources: Dict<text, text> = {}
        sources["sample.spl"] = source
        val result = FixApplicator.apply(fixes, sources)
        match result:
            case Ok(updated):
                expect(updated["sample.spl"]).to_contain("items.map(&:trim)")
                expect(updated["sample.spl"]).to_contain("# unicode before fix — keeps text offsets honest")
            case Err(e):
                expect(e).to_equal("")
