# Feature: Electron Main/Renderer Split (V4, Row 6)
# Category: UI Components
# Status: Implemented
#
# Compile-only smoke spec. Electron is dev-preview-only — this spec does
# NOT spawn a real Electron process. It verifies that `ElectronMain`
# instantiates, reports the electron backend, and wires the compositor
# backend during `start()`.

use app.ui.electron.main.{ElectronMain, run_electron_main}

# =========================================================================
# Test Group 1: ElectronMain instantiation
# =========================================================================

describe "Electron Main Creation":

    it "creates successfully":
        val result = ElectronMain.new(1280, 720, "Dev Preview", 3333)
        match result:
            Ok(app):
                expect(true).to_be_true()
            Err(e):
                expect(false).to_be_true()

    it "reports the electron backend":
        val result = ElectronMain.new(1280, 720, "Dev Preview", 3333)
        match result:
            Ok(app):
                expect(app.backend_name() == "electron").to_be_true()
            Err(e):
                expect(false).to_be_true()

# =========================================================================
# Test Group 2: Compositor backend wire-up
# =========================================================================

describe "Electron Main Compositor Wire-up":

    it "wires the compositor backend on start":
        val result = ElectronMain.new(320, 240, "wm_compare", 3333)
        match result:
            Ok(app):
                val started = app.start()
                match started:
                    Ok(wired):
                        expect(wired).to_be_true()
                        expect(app.is_compositor_wired()).to_be_true()
                        app.stop()
                    Err(e):
                        expect(false).to_be_true()
            Err(e):
                expect(false).to_be_true()
