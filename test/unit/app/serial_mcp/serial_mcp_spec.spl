# Serial MCP — Unit Specifications
# Feature: SSH over serial + raw serial port MCP tools
# Category: MCP, Serial
# Status: Implemented
# @tag: unit, serial, mcp
#
# SAFETY: serial_open / ssh_serial_connect touch real /dev/ttyUSB* devices.
# A USB disconnect (e.g. ESP32 replug) causes SIGSEGV in simple-main,
# which cascaded into systemd exit.target teardown killing the entire
# tmux session on 2026-05-30.  Hardware-touching tests require SIMPLE_HW_TEST=1.
# Set SIMPLE_HW_TEST=1 only when a SIGSEGV guard is in place.
# (see bug serial_usb_sigsegv_cascade)

use std.nogc_sync_mut.io.serial_ffi.{SerialPort, serial_open, serial_write, serial_read, serial_close}
use std.nogc_sync_mut.io.ssh_serial.{SshSerialSession, SshSerialExecResult, ssh_serial_connect, ssh_serial_connect_native, ssh_serial_exec, ssh_serial_run}
use app.serial_mcp.tools.{detect_tool_name, get_arg, get_arg_int}
use app.serial_mcp.protocol.{make_tool_serial_open, make_tool_ssh_serial_exec}
use std.common.test_env_gate.{test_env_require, test_env_hardware_available, test_env_gate_reason}

describe "SerialPort":
    describe "serial_open":
        it "BLOCKED: AC-4: returns is_valid=false for non-existent device (needs SIGSEGV guard)":
            if test_env_hardware_available():
                val port = serial_open("/dev/ttyUSB0", 115200)
                expect(port.is_valid).to_equal(false)
            else:
                expect(test_env_require("SIMPLE_HW_TEST")).to_equal("blocked:SIMPLE_HW_TEST")

        it "BLOCKED: AC-4: sets device and baud fields (needs SIGSEGV guard)":
            if test_env_hardware_available():
                val port = serial_open("/dev/ttyUSB0", 115200)
                expect(port.device).to_equal("/dev/ttyUSB0")
            else:
                expect(test_env_require("SIMPLE_HW_TEST")).to_equal("blocked:SIMPLE_HW_TEST")

        it "BLOCKED: AC-4: is_valid is false when handle is zero (needs SIGSEGV guard)":
            if test_env_hardware_available():
                val port = serial_open("", 0)
                expect(port.is_valid).to_equal(false)
            else:
                expect(test_env_require("SIMPLE_HW_TEST")).to_equal("blocked:SIMPLE_HW_TEST")

describe "SshSerialSession":
    describe "ssh_serial_connect (socat path)":
        it "BLOCKED: AC-1: returns is_valid=true for non-empty device and user (needs SIGSEGV guard)":
            if test_env_hardware_available():
                val sess = ssh_serial_connect("/dev/ttyUSB0", 115200, "root")
                expect(sess.is_valid).to_equal(true)
            else:
                expect(test_env_require("SIMPLE_HW_TEST")).to_equal("blocked:SIMPLE_HW_TEST")

        it "BLOCKED: AC-1: stores device, baud, user (needs SIGSEGV guard)":
            if test_env_hardware_available():
                val sess = ssh_serial_connect("/dev/ttyUSB0", 115200, "root")
                expect(sess.device).to_equal("/dev/ttyUSB0")
            else:
                expect(test_env_require("SIMPLE_HW_TEST")).to_equal("blocked:SIMPLE_HW_TEST")

        it "AC-1: returns is_valid=false for empty device":
            val sess = ssh_serial_connect("", 115200, "root")
            expect(sess.is_valid).to_equal(false)

        it "AC-1: returns is_valid=false for empty user":
            val sess = ssh_serial_connect("/dev/ttyUSB0", 115200, "")
            expect(sess.is_valid).to_equal(false)

    describe "ssh_serial_connect_native":
        it "BLOCKED: AC-2: returns is_valid=true for valid params (needs SIGSEGV guard)":
            if test_env_hardware_available():
                val sess = ssh_serial_connect_native("/dev/ttyUSB0", 115200, "root")
                expect(sess.is_valid).to_equal(true)
            else:
                expect(test_env_require("SIMPLE_HW_TEST")).to_equal("blocked:SIMPLE_HW_TEST")

        it "BLOCKED: AC-2: sets device and user fields (needs SIGSEGV guard)":
            if test_env_hardware_available():
                val sess = ssh_serial_connect_native("/dev/ttyUSB0", 115200, "root")
                expect(sess.device).to_equal("/dev/ttyUSB0")
            else:
                expect(test_env_require("SIMPLE_HW_TEST")).to_equal("blocked:SIMPLE_HW_TEST")

describe "SshSerialExecResult":
    describe "ssh_serial_exec invalid session":
        it "AC-3: returns exit_code=-1 for invalid session":
            val sess = ssh_serial_connect("", 0, "")
            val result = ssh_serial_exec(sess, "uname")
            expect(result.exit_code).to_equal(-1)

        it "AC-3: returns error in stderr for invalid session":
            val sess = SshSerialSession(device: "", baud: 0, user: "", is_valid: false)
            val result = ssh_serial_exec(sess, "ls")
            expect(result.stderr).to_equal("Invalid session")

describe "MCP Tool Dispatch":
    describe "detect_tool_name":
        it "AC-5: extracts tool name from tools/call body":
            val body = "{\"params\":{\"name\":\"ssh_serial_exec\",\"arguments\":{}}}"
            expect(detect_tool_name(body)).to_equal("ssh_serial_exec")

        it "AC-5: extracts serial_open from body":
            val body = "{\"params\":{\"name\":\"serial_open\",\"arguments\":{}}}"
            expect(detect_tool_name(body)).to_equal("serial_open")

    describe "get_arg":
        it "AC-5: extracts string argument from body":
            val body = "{\"params\":{\"name\":\"t\",\"arguments\":{\"device\":\"/dev/ttyUSB0\"}}}"
            expect(get_arg(body, "device")).to_equal("/dev/ttyUSB0")

    describe "get_arg_int":
        it "AC-5: extracts integer argument with default":
            val body = "{\"params\":{\"name\":\"t\",\"arguments\":{\"baud\":\"115200\"}}}"
            expect(get_arg_int(body, "baud", 9600)).to_equal(115200)

        it "AC-5: returns default when argument missing":
            val body = "{\"params\":{\"name\":\"t\",\"arguments\":{}}}"
            expect(get_arg_int(body, "baud", 9600)).to_equal(9600)

describe "MCP Protocol":
    describe "make_tool_serial_open schema":
        it "AC-5: schema contains tool name":
            val schema = make_tool_serial_open()
            expect(schema.contains("serial_open")).to_equal(true)

        it "AC-5: schema contains device property":
            val schema = make_tool_serial_open()
            expect(schema.contains("device")).to_equal(true)

        it "AC-5: schema contains baud property":
            val schema = make_tool_serial_open()
            expect(schema.contains("baud")).to_equal(true)

    describe "make_tool_ssh_serial_exec schema":
        it "AC-5: schema contains cmd property":
            val schema = make_tool_ssh_serial_exec()
            expect(schema.contains("cmd")).to_equal(true)
