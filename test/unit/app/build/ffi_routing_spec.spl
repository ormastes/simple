"""
# FFI Routing and Build Config Specification

Validates the new routing helpers and FFI build config parser used by the
`ffi-gen` command path.
"""

use std.spec
use app.io.cli_commands.{ffi_gen_entry_path, ffi_gen_force_args}
use app.io.mod.{file_read}
use app.build.config.{default_ffi_build_config, parse_ffi_build_args}

describe "FFI Routing":
    it "routes ffi-gen to the real generator entrypoint":
        expect(ffi_gen_entry_path()).to_equal("src/compiler/90.tools/ffi_gen/main.spl")

    it "serializes forced args for interpreter handoff":
        val args = ["--verbose", "src/my_lib.spl", "--gen-workspace"]
        expect(ffi_gen_force_args(args)).to_equal("--verbose src/my_lib.spl --gen-workspace")

    it "registers ffi-gen in the Rust driver command table and help text":
        val driver_main = file_read("src/compiler_rust/driver/src/main.rs")
        val help_source = file_read("src/compiler_rust/driver/src/cli/help.rs")
        expect(driver_main.contains("name: \"ffi-gen\"")).to_equal(true)
        expect(driver_main.contains("src/compiler/90.tools/ffi_gen/main.spl")).to_equal(true)
        expect(help_source.contains("simple ffi-gen <file.spl> [options]")).to_equal(true)

describe "FFI Build Config":
    it "defaults to enabled and uses the generated workspace output dir":
        val config = default_ffi_build_config()
        expect(config.enabled).to_equal(true)
        expect(config.output_dir).to_equal("build/rust/ffi_gen")
        expect(config.use_lto).to_equal(false)
        expect(config.sources.len()).to_equal(0)

    it "parses FFI flags independently from the core build config":
        val config = parse_ffi_build_args([
            "--no-ffi",
            "--ffi-output=build/custom/ffi",
            "--ffi-lang=rust",
            "--ffi-clean",
            "--ffi-gen-all",
            "--ffi-gen-workspace",
            "--ffi-verify",
            "--ffi-lto",
            "src/lib.spl"
        ])

        expect(config.enabled).to_equal(false)
        expect(config.output_dir).to_equal("build/custom/ffi")
        expect(config.lang_filter).to_equal("rust")
        expect(config.clean).to_equal(true)
        expect(config.gen_all).to_equal(true)
        expect(config.gen_workspace).to_equal(true)
        expect(config.verify).to_equal(true)
        expect(config.use_lto).to_equal(true)
        expect(config.sources.len()).to_equal(1)
        expect(config.sources[0]).to_equal("src/lib.spl")
