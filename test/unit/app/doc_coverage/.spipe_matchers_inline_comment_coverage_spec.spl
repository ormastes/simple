# Inline Comment Coverage Analysis Tests

use app.doc_coverage.analysis.inline_comment_coverage.*
use app.io.mod (file_write, file_exists, shell)
use std.string.{NL}

describe "Inline Comment Coverage Analysis":
    describe "InlineCommentResult creation":
        it "creates a result with default values":
            val result = InlineCommentResult.create("test_fn", "function", "test.spl", 10)
            expect result.item_name == "test_fn"
            expect result.item_kind == "function"
            expect result.file_path == "test.spl"
            expect result.line == 10
            expect result.has_inline_comment == false
            expect result.has_docstring == false
            expect result.has_sdoctest == false
            expect result.warning_level == "none"

    describe "compute_inline_comment_coverage":
        it "analyzes file with documented function":
            # Create test file
            val test_file = "/tmp/test_doc_fn.spl"
            val content = "# This is a comment\nfn documented_function():\n    pass\n"
            file_write(test_file, content)

            var files: [text] = []
            files.push(test_file)

            val results = compute_inline_comment_coverage(files)
            expect results.len() > 0

            # Check first result
            val first = results[0]
            expect first.item_name == "documented_function"
            expect first.item_kind == "function"
            expect first.has_inline_comment == true

            # Cleanup
            shell("rm -f {test_file}")

        it "analyzes file with undocumented function":
            val test_file = "/tmp/test_undoc_fn.spl"
            val content = "fn undocumented_function():\n    pass\n"
            file_write(test_file, content)

            var files: [text] = []
            files.push(test_file)

            val results = compute_inline_comment_coverage(files)
            expect results.len() > 0

            val first = results[0]
            expect first.item_name == "undocumented_function"
            expect first.has_inline_comment == false

            shell("rm -f {test_file}")

        it "analyzes file with docstring":
            val test_file = "/tmp/test_docstring_fn.spl"
            val lines = [
                "fn with_docstring():",
                "    \"\"\"This is a docstring\"\"\"",
                "    pass"
            ]
            val content = lines.join(NL)
            file_write(test_file, content)

            var files: [text] = []
            files.push(test_file)

            val results = compute_inline_comment_coverage(files)
            expect results.len() > 0

            val first = results[0]
            expect first.item_name == "with_docstring"
            expect first.has_docstring == true

            shell("rm -f {test_file}")

        it "analyzes file with class declaration":
            val test_file = "/tmp/test_class.spl"
            val content = "# Class comment\nclass TestClass:\n    pass\n"
            file_write(test_file, content)

            var files: [text] = []
            files.push(test_file)

            val results = compute_inline_comment_coverage(files)
            expect results.len() > 0

            val first = results[0]
            expect first.item_name == "TestClass"
            expect first.item_kind == "class"
            expect first.has_inline_comment == true

            shell("rm -f {test_file}")

        it "analyzes file with struct declaration":
            val test_file = "/tmp/test_struct.spl"
            val content = "# Struct comment\nstruct Point:\n    x: i64\n"
            file_write(test_file, content)

            var files: [text] = []
            files.push(test_file)

            val results = compute_inline_comment_coverage(files)
            expect results.len() > 0

            val first = results[0]
            expect first.item_name == "Point"
            expect first.item_kind == "struct"
            expect first.has_inline_comment == true

            shell("rm -f {test_file}")

        it "analyzes file with enum declaration":
            val test_file = "/tmp/test_enum.spl"
            val content = "# Enum comment\nenum Status:\n    Active\n"
            file_write(test_file, content)

            var files: [text] = []
            files.push(test_file)

            val results = compute_inline_comment_coverage(files)
            expect results.len() > 0

            val first = results[0]
            expect first.item_name == "Status"
            expect first.item_kind == "enum"
            expect first.has_inline_comment == true

            shell("rm -f {test_file}")

        it "handles non-existent file":
            var files: [text] = []
            files.push("/tmp/does_not_exist_12345.spl")

            val results = compute_inline_comment_coverage(files)
            expect results.len() == 0

        it "analyzes multiple items in one file":
            val test_file = "/tmp/test_multi.spl"
            val lines = [
                "# Function 1",
                "fn func1():",
                "    pass",
                "",
                "fn func2():",
                "    pass",
                "",
                "# Class 1",
                "class MyClass:",
                "    pass"
            ]
            val content = lines.join(NL)
            file_write(test_file, content)

            var files: [text] = []
            files.push(test_file)

            val results = compute_inline_comment_coverage(files)
            expect results.len() == 3

            shell("rm -f {test_file}")

    describe "emit_missing_comment_warnings":
        it "generates warnings for missing docs":
            var results: [InlineCommentResult] = []

            var r1 = InlineCommentResult.create("undocumented_fn", "function", "test.spl", 10)
            r1 = InlineCommentResult(
                item_name: r1.item_name,
                item_kind: r1.item_kind,
                file_path: r1.file_path,
                line: r1.line,
                has_inline_comment: false,
                has_docstring: false,
                has_sdoctest: false,
                warning_level: "error"
            )
            results.push(r1)

            val warnings = emit_missing_comment_warnings(results)
            expect warnings.len() == 1
            expect (warnings[0]).contains("ERROR")
            expect (warnings[0]).contains("undocumented_fn")

        it "does not generate warnings for documented items":
            var results: [InlineCommentResult] = []

            var r1 = InlineCommentResult.create("documented_fn", "function", "test.spl", 10)
            r1 = InlineCommentResult(
                item_name: r1.item_name,
                item_kind: r1.item_kind,
                file_path: r1.file_path,
                line: r1.line,
                has_inline_comment: true,
                has_docstring: true,
                has_sdoctest: false,
                warning_level: "none"
            )
            results.push(r1)

            val warnings = emit_missing_comment_warnings(results)
            expect warnings.len() == 0

    describe "generate_coverage_report":
        it "generates report with summary statistics":
            var results: [InlineCommentResult] = []

            var r1 = InlineCommentResult.create("fn1", "function", "test.spl", 1)
            r1 = InlineCommentResult(
                item_name: r1.item_name,
                item_kind: r1.item_kind,
                file_path: r1.file_path,
                line: r1.line,
                has_inline_comment: true,
                has_docstring: true,
                has_sdoctest: false,
                warning_level: "none"
            )
            results.push(r1)

            var r2 = InlineCommentResult.create("fn2", "function", "test.spl", 2)
            r2 = InlineCommentResult(
                item_name: r2.item_name,
                item_kind: r2.item_kind,
                file_path: r2.file_path,
                line: r2.line,
                has_inline_comment: false,
                has_docstring: false,
                has_sdoctest: false,
                warning_level: "error"
            )
            results.push(r2)

            val report = generate_coverage_report(results)
            expect (report).contains("# Inline Comment Coverage Report")
            expect (report).contains("Total Items:")
            expect (report).contains("With Inline Comments:")
            expect (report).contains("With Docstrings:")
            expect (report).contains("With Both:")
            expect (report).contains("With Neither:")

        it "includes details by warning level":
            var results: [InlineCommentResult] = []

            var r1 = InlineCommentResult.create("error_fn", "function", "test.spl", 1)
            r1 = InlineCommentResult(
                item_name: r1.item_name,
                item_kind: r1.item_kind,
                file_path: r1.file_path,
                line: r1.line,
                has_inline_comment: false,
                has_docstring: false,
                has_sdoctest: false,
                warning_level: "error"
            )
            results.push(r1)

            var r2 = InlineCommentResult.create("warn_fn", "function", "src/std/test.spl", 2)
            r2 = InlineCommentResult(
                item_name: r2.item_name,
                item_kind: r2.item_kind,
                file_path: r2.file_path,
                line: r2.line,
                has_inline_comment: true,
                has_docstring: false,
                has_sdoctest: false,
                warning_level: "warn"
            )
            results.push(r2)

            val report = generate_coverage_report(results)
            expect (report).contains("### Errors")
            expect (report).contains("### Warnings")
            expect (report).contains("error_fn")
            expect (report).contains("warn_fn")

        it "calculates percentages correctly":
            var results: [InlineCommentResult] = []

            # Add 4 items: 3 with inline, 2 with docstring, 1 with both, 1 with neither
            var r1 = InlineCommentResult.create("fn1", "function", "test.spl", 1)
            r1 = InlineCommentResult(
                item_name: r1.item_name,
                item_kind: r1.item_kind,
                file_path: r1.file_path,
                line: r1.line,
                has_inline_comment: true,
                has_docstring: true,
                has_sdoctest: false,
                warning_level: "none"
            )
            results.push(r1)

            var r2 = InlineCommentResult.create("fn2", "function", "test.spl", 2)
            r2 = InlineCommentResult(
                item_name: r2.item_name,
                item_kind: r2.item_kind,
                file_path: r2.file_path,
                line: r2.line,
                has_inline_comment: true,
                has_docstring: false,
                has_sdoctest: false,
                warning_level: "warn"
            )
            results.push(r2)

            var r3 = InlineCommentResult.create("fn3", "function", "test.spl", 3)
            r3 = InlineCommentResult(
                item_name: r3.item_name,
                item_kind: r3.item_kind,
                file_path: r3.file_path,
                line: r3.line,
                has_inline_comment: true,
                has_docstring: false,
                has_sdoctest: false,
                warning_level: "warn"
            )
            results.push(r3)

            var r4 = InlineCommentResult.create("fn4", "function", "test.spl", 4)
            r4 = InlineCommentResult(
                item_name: r4.item_name,
                item_kind: r4.item_kind,
                file_path: r4.file_path,
                line: r4.line,
                has_inline_comment: false,
                has_docstring: false,
                has_sdoctest: false,
                warning_level: "error"
            )
            results.push(r4)

            val report = generate_coverage_report(results)
            # 3 out of 4 = 75% inline
            # 1 out of 4 = 25% docstring
            expect (report).contains("With Inline Comments:** 3")
            expect (report).contains("With Docstrings:** 1")