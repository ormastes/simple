# Doc Coverage Threshold System Tests

use app.io.mod.{file_write, file_delete}
use app.doc_coverage.thresholds.types.{
    threshold_config_default,
    threshold_config_get,
    scope_coverage_create
}
use app.doc_coverage.thresholds.config_parser.{parse_threshold_config}
use app.doc_coverage.thresholds.calculator.{calculate_scope_coverage}
use app.doc_coverage.thresholds.validator.{
    validate_thresholds,
    generate_threshold_report,
    get_overall_coverage
}

describe "Threshold Types":
    it "creates default config":
        val config = threshold_config_default()
        expect config.default_threshold == 70
        expect config.enforce == false
        expect config.fail_on_below == false
        expect config.scope_names.len() == 0

    it "gets scope threshold with match":
        var config = threshold_config_default()
        config.scope_names = ["src/std/"]
        config.scope_values = [90]

        val threshold = threshold_config_get(config, "src/std/string.spl")
        expect threshold == 90

    it "gets default threshold when no match":
        var config = threshold_config_default()
        config.default_threshold = 75
        config.scope_names = ["src/std/"]
        config.scope_values = [90]

        val threshold = threshold_config_get(config, "src/core/lexer.spl")
        expect threshold == 75

    it "creates scope coverage":
        val cov = scope_coverage_create("src/std/", 80, 100, 85, [])
        expect cov.scope == "src/std/"
        expect cov.threshold == 80
        expect cov.actual == 85
        expect cov.passed == true
        expect cov.total_items == 100
        expect cov.covered_items == 85

    it "marks failed coverage":
        val cov = scope_coverage_create("src/app/", 70, 100, 60, [])
        expect cov.actual == 60
        expect cov.passed == false

describe "Config Parser":
    it "parses default config when file missing":
        val config = parse_threshold_config("nonexistent.sdn")
        expect config.default_threshold == 70

    it "parses basic config":
        val content = "doc_coverage {\n    default_threshold 85\n    enforce true\n    fail_on_below_threshold true\n}"
        file_write("test_threshold.sdn", content)

        val config = parse_threshold_config("test_threshold.sdn")
        expect config.default_threshold == 85
        expect config.enforce == true
        expect config.fail_on_below == true

        file_delete("test_threshold.sdn")

    it "parses thresholds section":
        val content = "doc_coverage {\n    thresholds {\n        \"src/std/\" 90\n        \"src/core/\" 75\n    }\n}"
        file_write("test_threshold2.sdn", content)

        val config = parse_threshold_config("test_threshold2.sdn")
        expect config.scope_names.len() == 2
        expect config.scope_names[0] == "src/std/"
        expect config.scope_values[0] == 90
        expect config.scope_names[1] == "src/core/"
        expect config.scope_values[1] == 75

        file_delete("test_threshold2.sdn")

    it "parses exclusions":
        val content = "doc_coverage {\n    exclude [\n        \"test/**\"\n        \"examples/**\"\n    ]\n}"
        file_write("test_threshold3.sdn", content)

        val config = parse_threshold_config("test_threshold3.sdn")
        expect config.exclusions.len() == 2
        expect config.exclusions[0] == "test/**"
        expect config.exclusions[1] == "examples/**"

        file_delete("test_threshold3.sdn")

describe "Coverage Calculator":
    it "calculates coverage for single scope":
        var config = threshold_config_default()
        config.scope_names = ["src/std/"]
        config.scope_values = [80]

        val all_files = ["src/std/string.spl", "src/std/array.spl", "src/std/math.spl"]
        val covered = ["src/std/string.spl", "src/std/array.spl"]

        val results = calculate_scope_coverage(all_files, covered, config)
        expect results.len() == 1

        val cov = results[0]
        expect cov.scope == "src/std/"
        expect cov.total_items == 3
        expect cov.covered_items == 2
        expect cov.actual == 66
        expect cov.passed == false

    it "calculates coverage for multiple scopes":
        var config = threshold_config_default()
        config.scope_names = ["src/std/", "src/core/"]
        config.scope_values = [80, 70]

        val all_files = [
            "src/std/string.spl",
            "src/std/array.spl",
            "src/core/lexer.spl",
            "src/core/parser.spl"
        ]
        val covered = [
            "src/std/string.spl",
            "src/std/array.spl",
            "src/core/lexer.spl"
        ]

        val results = calculate_scope_coverage(all_files, covered, config)
        expect results.len() == 2

    it "tracks missing items":
        var config = threshold_config_default()
        val all_files = ["src/std/a.spl", "src/std/b.spl", "src/std/c.spl"]
        val covered = ["src/std/a.spl"]

        val results = calculate_scope_coverage(all_files, covered, config)
        val cov = results[0]
        expect cov.missing_items.len() == 2
        expect cov.missing_items[0] == "src/std/b.spl"
        expect cov.missing_items[1] == "src/std/c.spl"

describe "Threshold Validator":
    it "validates all passing thresholds":
        val cov1 = scope_coverage_create("src/std/", 80, 100, 85, [])
        val cov2 = scope_coverage_create("src/core/", 70, 100, 75, [])
        val coverages = [cov1, cov2]

        val result = validate_thresholds(coverages)
        val all_passed = result.0
        val failed = result.1

        expect all_passed == true
        expect failed.len() == 0

    it "validates with failures":
        val cov1 = scope_coverage_create("src/std/", 80, 100, 85, [])
        val cov2 = scope_coverage_create("src/app/", 70, 100, 60, [])
        val coverages = [cov1, cov2]

        val result = validate_thresholds(coverages)
        val all_passed = result.0
        val failed = result.1

        expect all_passed == false
        expect failed.len() == 1
        expect failed[0] == "src/app/"

    it "generates threshold report":
        val cov1 = scope_coverage_create("src/std/", 80, 100, 85, [])
        val cov2 = scope_coverage_create("src/app/", 70, 100, 60, ["src/app/a.spl"])
        val coverages = [cov1, cov2]

        val result = validate_thresholds(coverages)
        val all_passed = result.0
        val failed = result.1

        val report = generate_threshold_report(coverages, all_passed, failed)
        expect report.contains("Doc Coverage Threshold Report") == true
        expect report.contains("PASS") == true
        expect report.contains("FAIL") == true
        expect report.contains("src/app/a.spl") == true

    it "calculates overall coverage":
        val cov1 = scope_coverage_create("src/std/", 80, 100, 80, [])
        val cov2 = scope_coverage_create("src/core/", 70, 50, 40, [])
        val coverages = [cov1, cov2]

        val overall = get_overall_coverage(coverages)
        expect overall == 80

    it "handles zero total items":
        val coverages = []
        val overall = get_overall_coverage(coverages)
        expect overall == 0