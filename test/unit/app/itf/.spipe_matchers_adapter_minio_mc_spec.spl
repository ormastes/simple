# MinIO `mc` adapter specs.
#
# Feature: MinIO `mc` CLI delegator - argv builders, NDJSON parsing, error mapping.
# Category: App | ITF | adapter_minio_mc
# Status: Implementation
#
# These specs cover pure functions only (no live `mc` invocation):
#   1. argv builders for each `mc` subcommand
#   2. NDJSON line splitter / per-line json_parse
#   3. McEntry/McStat/share-URL extraction from parsed JSON
#   4. mc exit-code success mapping (0=ok, 1/2=fail)
#   5. _format_expire conversion seconds -> ##h##m##s
#   6. _qualify_path alias prefixing

use app.itf.adapter_minio_mc.{
    McClient, McEntry, McStat, McServerInfo,
    _argv_alias_set, _argv_alias_remove, _argv_alias_list,
    _argv_ls, _argv_stat, _argv_cp_get, _argv_cp_put,
    _argv_share_download, _argv_admin_info, _argv_health,
    _format_expire, _qualify_path,
    _parse_ndjson_lines, _entry_from_obj, _stat_from_obj,
    _share_url_from_obj, _server_info_from_obj,
    _mc_success
}


describe "MinIO mc adapter":

    context "argv builders":

        it "alias set produces positional ALIAS URL ACCESSKEY SECRETKEY":
            val argv = _argv_alias_set("myaistor", "https://x:9000", "AKIA", "SECRET")
            expect argv.len() == 7
            expect argv[0] == "--json"
            expect argv[1] == "alias"
            expect argv[2] == "set"
            expect argv[3] == "myaistor"
            expect argv[4] == "https://x:9000"
            expect argv[5] == "AKIA"
            expect argv[6] == "SECRET"

        it "alias remove takes a single alias arg":
            val argv = _argv_alias_remove("myaistor")
            expect argv == ["--json", "alias", "remove", "myaistor"]

        it "alias list takes no extra args":
            val argv = _argv_alias_list()
            expect argv == ["--json", "alias", "list"]

        it "ls without recursive omits -r":
            val argv = _argv_ls("a", "bucket/prefix/", false)
            expect argv == ["--json", "ls", "a/bucket/prefix/"]

        it "ls with recursive emits --recursive":
            val argv = _argv_ls("a", "bucket/", true)
            expect argv == ["--json", "ls", "--recursive", "a/bucket/"]

        it "stat qualifies bucket-relative path":
            val argv = _argv_stat("a", "bucket/key.bin")
            expect argv == ["--json", "stat", "a/bucket/key.bin"]

        it "cp download orders ALIAS/remote then LOCAL":
            val argv = _argv_cp_get("a", "bucket/k.bin", "/tmp/out")
            expect argv == ["--json", "cp", "a/bucket/k.bin", "/tmp/out"]

        it "cp upload orders LOCAL then ALIAS/remote":
            val argv = _argv_cp_put("a", "/tmp/in", "bucket/k.bin")
            expect argv == ["--json", "cp", "/tmp/in", "a/bucket/k.bin"]

        it "share download includes --expire=<duration>":
            val argv = _argv_share_download("a", "bucket/k", 3600)
            expect argv == ["--json", "share", "download", "--expire", "1h", "a/bucket/k"]

        it "admin info passes alias as TARGET":
            val argv = _argv_admin_info("myaistor")
            expect argv == ["--json", "admin", "info", "myaistor"]

        it "health curl probes /minio/health/ready":
            val argv = _argv_health("https://minio.corp:9000")
            expect argv[0] == "-s"
            expect argv[5] == "https://minio.corp:9000/minio/health/ready"

        it "health curl strips trailing slash from url":
            val argv = _argv_health("https://x/")
            expect argv[5] == "https://x/minio/health/ready"

    context "_qualify_path":

        it "concatenates alias and bucket path":
            expect _qualify_path("a", "bucket/key") == "a/bucket/key"

        it "strips a leading slash from path":
            expect _qualify_path("a", "/bucket/key") == "a/bucket/key"

    context "_format_expire":

        it "1 hour -> 1h":
            expect _format_expire(3600) == "1h"

        it "1 hour 30 minutes -> 1h30m":
            expect _format_expire(5400) == "1h30m"

        it "45 seconds -> 45s":
            expect _format_expire(45) == "45s"

        it "12h34m56s mixed":
            expect _format_expire(12 * 3600 + 34 * 60 + 56) == "12h34m56s"

        it "zero -> 0s":
            expect _format_expire(0) == "0s"

    context "exit code mapping":

        it "0 is success":
            expect _mc_success(0) == true

        it "1 (generic failure) is not success":
            expect _mc_success(1) == false

        it "2 (invalid args) is not success":
            expect _mc_success(2) == false

    context "NDJSON parsing":

        it "splits lines and parses each as JSON":
            val ndjson = "{\"alias\":\"a\"}\n{\"alias\":\"b\"}\n"
            val lines = _parse_ndjson_lines(ndjson)
            expect lines.len() == 2

        it "skips empty lines":
            val ndjson = "\n{\"alias\":\"a\"}\n\n"
            val lines = _parse_ndjson_lines(ndjson)
            expect lines.len() == 1

        it "skips invalid JSON lines":
            val ndjson = "not json\n{\"alias\":\"ok\"}\n"
            val lines = _parse_ndjson_lines(ndjson)
            expect lines.len() == 1

    context "ls entry parsing":

        it "extracts key + size + lastModified + etag":
            val ndjson = "{\"key\":\"zynq/v1/fw.bin\",\"type\":\"file\",\"size\":1048576,\"lastModified\":\"2026-04-01T10:00:00Z\",\"etag\":\"abc\"}"
            val lines = _parse_ndjson_lines(ndjson)
            expect lines.len() == 1
            val entry = _entry_from_obj(lines[0])
            expect entry.key == "zynq/v1/fw.bin"
            expect entry.type == "file"
            expect entry.size == 1048576
            expect entry.last_modified == "2026-04-01T10:00:00Z"
            expect entry.etag == "abc"

    context "stat parsing":

        it "extracts name + size + lastModified":
            val ndjson = "{\"name\":\"a/b/key.bin\",\"type\":\"object\",\"size\":42,\"lastModified\":\"2026-04-25T00:00:00Z\",\"etag\":\"xyz\"}"
            val lines = _parse_ndjson_lines(ndjson)
            val s = _stat_from_obj(lines[0])
            expect s.name == "a/b/key.bin"
            expect s.size == 42
            expect s.etag == "xyz"

    context "share URL extraction":

        it "reads `share` field":
            val ndjson = "{\"status\":\"success\",\"share\":\"https://x/y?X-Amz-Signature=abc\"}"
            val lines = _parse_ndjson_lines(ndjson)
            val url = _share_url_from_obj(lines[0])
            expect url.starts_with("https://x/y?") == true
            expect url.contains("X-Amz-Signature=") == true

        it "falls back to `url` field":
            val ndjson = "{\"status\":\"success\",\"url\":\"https://fallback/path\"}"
            val lines = _parse_ndjson_lines(ndjson)
            expect _share_url_from_obj(lines[0]) == "https://fallback/path"

    context "admin info parsing":

        it "extracts mode and version from top object":
            val ndjson = "{\"mode\":\"online\",\"version\":\"2025-01-01T00-00-00Z\",\"region\":\"us-east-1\",\"deploymentID\":\"d-1\"}"
            val lines = _parse_ndjson_lines(ndjson)
            val info = _server_info_from_obj(lines[0])
            expect info.mode == "online"
            expect info.version == "2025-01-01T00-00-00Z"
            expect info.region == "us-east-1"
            expect info.deployment_id == "d-1"

    context "McClient defaults":

        it "default mc_path is `mc`":
            val client = McClient.default("myaistor")
            expect client.mc_path == "mc"
            expect client.alias_name == "myaistor"