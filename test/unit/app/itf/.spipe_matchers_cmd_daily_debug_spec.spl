# cmd_daily_debug_spec
"""Unit tests for `cmd_daily_debug.spl` — issue #10 Agent E.

Covers:
- Jira-key regex extractor
- MinIO URL regex extractor
- Triage classifier on a sample list of filenames
- Watermark roundtrip (parse + render)
- `--dry-run` produces zero side effects
"""

use std.spec
use app.itf.cmd_daily_debug.{
    extract_jira_keys,
    extract_minio_urls,
    triage_kind,
    triage_all,
    parse_watermark,
    render_watermark,
    run_daily_debug,
}

describe "extract_jira_keys (issue #10 step 3)":

    it "extracts a single ABC-123 style key":
        val keys = extract_jira_keys("Please look at ABC-123 today.")
        expect keys.len() == 1
        expect keys[0] == "ABC-123"

    it "extracts multiple keys from one body":
        val body = "ABC-1, DEF12-9999 and the closed ABC-2."
        val keys = extract_jira_keys(body)
        expect keys.len() == 3
        expect keys[0] == "ABC-1"
        expect keys[1] == "DEF12-9999"
        expect keys[2] == "ABC-2"

    it "ignores lowercase tokens":
        val keys = extract_jira_keys("foo-12 is not a key but FOO-12 is.")
        expect keys.len() == 1
        expect keys[0] == "FOO-12"

describe "extract_minio_urls (issue #10 step 3)":

    it "extracts a single https URL":
        val urls = extract_minio_urls("Get https://minio.example.com/bug/abc-123/fw.bin please.")
        expect urls.len() == 1
        expect urls[0] == "https://minio.example.com/bug/abc-123/fw.bin"

    it "extracts multiple URLs":
        val body = "http://a.com/x/y.elf and https://b.io/p/q.dmp"
        val urls = extract_minio_urls(body)
        expect urls.len() == 2

describe "triage_kind (issue #10 step 4)":

    it "classifies firmware extensions":
        expect triage_kind("https://h/p/fw.bin") == "fw"
        expect triage_kind("https://h/p/fw.elf") == "fw"
        expect triage_kind("https://h/p/fw.HEX") == "fw"

    it "classifies dump extensions":
        expect triage_kind("https://h/p/c.dmp") == "dump"
        expect triage_kind("https://h/p/c.core") == "dump"
        expect triage_kind("https://h/p/c.crash") == "dump"

    it "classifies note extensions":
        expect triage_kind("https://h/p/n.log") == "note"
        expect triage_kind("https://h/p/n.txt") == "note"
        expect triage_kind("https://h/p/readme.md") == "note"

    it "returns unknown for unrecognised extensions":
        expect triage_kind("https://h/p/x.zip") == "unknown"
        expect triage_kind("https://h/p/no-ext") == "unknown"

    it "triage_all preserves the order of inputs":
        val urls = [
            "https://h/p/a.bin",
            "https://h/p/b.dmp",
            "https://h/p/c.txt",
            "https://h/p/d.zip",
        ]
        val out = triage_all(urls)
        expect out.len() == 4
        expect out[0].kind == "fw"
        expect out[1].kind == "dump"
        expect out[2].kind == "note"
        expect out[3].kind == "unknown"

describe "watermark roundtrip (issue #10 steps 1+6)":

    it "parses a freshly rendered watermark":
        val rendered = render_watermark("2026-04-26T12:00:00Z")
        val parsed = parse_watermark(rendered)
        expect parsed == "2026-04-26T12:00:00Z"

    it "ignores comments and blank lines":
        val body = "# header\n\nlast_run: \"2026-04-26T00:00:00Z\"\n"
        expect parse_watermark(body) == "2026-04-26T00:00:00Z"

    it "returns empty when key absent":
        expect parse_watermark("# nothing useful here\n") == ""

describe "run_daily_debug --dry-run (issue #10 AC4)":

    it "exits 0 with --dry-run and writes no files":
        # In --dry-run mode the driver must not call file_write_text on
        # either the digest or the watermark. The outlook adapter is gated
        # by `outlook_available = false` so step 2 returns []. The test
        # verifies the exit code only; the absence of file writes is
        # guaranteed structurally by the single `if not dry_run` gate
        # around each `file_write_text` call.
        val rc = run_daily_debug(["--dry-run", "--quiet"])
        expect rc == 0

    it "exits 0 with --dry-run alone":
        val rc = run_daily_debug(["--dry-run"])
        expect rc == 0