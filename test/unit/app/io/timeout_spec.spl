# Process Timeout Tests
# Tests for process_run_timeout() -- the shared spawn/wait plumbing used by
# native_build_main.spl to launch the native-build worker (see
# doc/08_tracking/bug/native_build_worker_zombie_parent_hang_2026-07-03.md).
# The regression case below reproduces the exact bug: a direct child that
# backgrounds a grandchild (simulating a leaked helper process) and exits
# immediately must not make process_run_timeout block past the direct
# child's own exit.

use std.spec.{describe, it, expect}
use app.io.process_ops.{process_run_timeout}
use app.io.time_ops.{current_time_ms}

describe "process_run_timeout":
    it "completes fast commands successfully":
        val (stdout, stderr, code) = process_run_timeout("echo", ["hello"], 5000)
        expect(code).to_equal(0)
        expect(stdout.trim()).to_contain("hello")

    it "uses default timeout when timeout_ms <= 0":
        val (stdout, stderr, code) = process_run_timeout("echo", ["test"], 0)
        expect(code).to_equal(0)
        expect(stdout.trim()).to_contain("test")

    it "captures stdout correctly":
        val (stdout, stderr, code) = process_run_timeout("echo", ["output test"], 5000)
        expect(code).to_equal(0)
        expect(stdout).to_contain("output")

    it "returns the child's non-zero exit code promptly":
        val (stdout, stderr, code) = process_run_timeout("sh", ["-c", "exit 7"], 5000)
        expect(code).to_equal(7)

    it "returns a timeout marker (not an indefinite block) when the child never exits":
        val (stdout, stderr, code) = process_run_timeout("sleep", ["5"], 200)
        expect(code).to_equal(-1)
        expect(stderr).to_contain("TIMEOUT")

    it "does not block on an orphaned grandchild holding output open (native-build worker hang regression)":
        val t0 = current_time_ms()
        val (stdout, stderr, code) = process_run_timeout("sh", ["-c", "(sleep 5 &) ; echo done; exit 0"], 5000)
        val elapsed_ms = current_time_ms() - t0
        expect(code).to_equal(0)
        expect(stdout.trim()).to_contain("done")
        expect(elapsed_ms).to_be_less_than(3000)
