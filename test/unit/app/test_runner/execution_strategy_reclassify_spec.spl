# Test: Execution strategy reclassification
#
# Verifies QEMU/baremetal tests use process mode with reduced timeout,
# and system tests use standard profile with reduced timeout.
# Uses mock implementations (imports from app modules don't work in test runner).

# ============================================================================
# Mock categorize_test_file
# ============================================================================

fn mock_categorize(test_file: text) -> text:
    if test_file.contains("/qemu/"):
        return "qemu"
    if test_file.contains("/emulator/"):
        return "qemu"
    if test_file.contains("/baremetal/"):
        return "baremetal"
    if test_file.contains("/kernel/"):
        return "baremetal"
    if test_file.contains("/database/"):
        return "database"
    if test_file.contains("/integration/"):
        return "integration"
    if test_file.contains("/unit/"):
        return "unit"
    if test_file.contains("/system/"):
        return "system"
    "other"

# Mock strategy: returns (mode, profile, timeout_sec)
fn mock_strategy_select(test_file: text) -> (text, text, i64):
    val category = mock_categorize(test_file)
    if category == "qemu":
        return ("process", "standard", 120)
    if category == "baremetal":
        return ("process", "standard", 120)
    if category == "system":
        return ("safe", "standard", 300)
    if category == "unit":
        return ("native", "fast", 60)
    if category == "database":
        return ("process", "slow", 600)
    if category == "integration":
        return ("safe", "standard", 300)
    ("process", "standard", 300)

# ============================================================================
# Tests
# ============================================================================

describe "Test file categorization":
    it "categorizes qemu test files":
        expect(mock_categorize("test/unit/qemu/riscv32_spec.spl")).to_equal("qemu")

    it "categorizes emulator test files as qemu":
        expect(mock_categorize("test/unit/emulator/test_spec.spl")).to_equal("qemu")

    it "categorizes baremetal test files":
        expect(mock_categorize("test/unit/baremetal/hello_spec.spl")).to_equal("baremetal")

    it "categorizes kernel test files as baremetal":
        expect(mock_categorize("test/unit/kernel/test_spec.spl")).to_equal("baremetal")

    it "categorizes system test files":
        expect(mock_categorize("test/system/integration_spec.spl")).to_equal("system")

    it "categorizes unit test files":
        expect(mock_categorize("test/unit/parser/basic_spec.spl")).to_equal("unit")

describe "QEMU uses process mode with 120s timeout":
    it "selects process mode for qemu":
        val (mode, profile, timeout) = mock_strategy_select("test/unit/qemu/test_spec.spl")
        expect(mode).to_equal("process")
        expect(profile).to_equal("standard")
        expect(timeout).to_equal(120)

describe "Baremetal uses process mode with 120s timeout":
    it "selects process mode for baremetal":
        val (mode, profile, timeout) = mock_strategy_select("test/unit/baremetal/test_spec.spl")
        expect(mode).to_equal("process")
        expect(profile).to_equal("standard")
        expect(timeout).to_equal(120)

describe "System tests use standard profile with 300s timeout":
    it "selects safe mode for system tests":
        val (mode, profile, timeout) = mock_strategy_select("test/system/daemon_spec.spl")
        expect(mode).to_equal("safe")
        expect(profile).to_equal("standard")
        expect(timeout).to_equal(300)

describe "Unit tests use native mode with 60s timeout":
    it "selects native mode for unit tests":
        val (mode, profile, timeout) = mock_strategy_select("test/unit/parser/basic_spec.spl")
        expect(mode).to_equal("native")
        expect(profile).to_equal("fast")
        expect(timeout).to_equal(60)
