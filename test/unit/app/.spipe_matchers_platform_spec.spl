use std.spec.*
use nogc_sync_mut.src.app.config.{AppConfig}

# ============================================================================
# Platform Detection Tests
#
# Tests AppConfig platform/arch detection and predicates.
# Compiler-internal enum tests (Platform, Arch, target presets) are tested
# via integration tests that can import compiler modules.
# ============================================================================

describe "AppConfig platform detection":
    context "from_env detects current platform":
        it "detects a known platform":
            val config = AppConfig.from_env("test", "1.0")
            val p = config.platform
            # Must be one of the known platforms
            val known = p == "linux" or p == "macos" or p == "windows" or p == "freebsd"
            expect known == true

        it "detects a known architecture":
            val config = AppConfig.from_env("test", "1.0")
            val a = config.arch
            val known = a == "x86_64" or a == "aarch64" or a == "riscv64" or a == "i686"
            expect known == true

    context "desktop platforms":
        it "linux is desktop":
            val c = AppConfig.create(name: "t", version: "0", args: [], platform: "linux", arch: "x86_64")
            expect c.is_desktop() == true

        it "macos is desktop":
            val c = AppConfig.create(name: "t", version: "0", args: [], platform: "macos", arch: "aarch64")
            expect c.is_desktop() == true

        it "windows is desktop":
            val c = AppConfig.create(name: "t", version: "0", args: [], platform: "windows", arch: "x86_64")
            expect c.is_desktop() == true

        it "freebsd is desktop":
            val c = AppConfig.create(name: "t", version: "0", args: [], platform: "freebsd", arch: "x86_64")
            expect c.is_desktop() == true

    context "mobile platforms":
        it "ios is mobile":
            val c = AppConfig.create(name: "t", version: "0", args: [], platform: "ios", arch: "aarch64")
            expect c.is_mobile() == true
            expect c.is_desktop() == false

        it "android is mobile":
            val c = AppConfig.create(name: "t", version: "0", args: [], platform: "android", arch: "aarch64")
            expect c.is_mobile() == true
            expect c.is_desktop() == false

    context "wasm platforms":
        it "wasm32 is wasm":
            val c = AppConfig.create(name: "t", version: "0", args: [], platform: "wasi", arch: "wasm32")
            expect c.is_wasm() == true
            expect c.is_desktop() == false

        it "wasm64 is wasm":
            val c = AppConfig.create(name: "t", version: "0", args: [], platform: "wasi", arch: "wasm64")
            expect c.is_wasm() == true

    context "bare-metal":
        it "none platform is baremetal":
            val c = AppConfig.create(name: "t", version: "0", args: [], platform: "none", arch: "riscv32")
            expect c.is_baremetal() == true
            expect c.is_desktop() == false

    context "bitness":
        it "x86_64 is 64-bit":
            val c = AppConfig.create(name: "t", version: "0", args: [], platform: "linux", arch: "x86_64")
            expect c.is_64bit() == true

        it "aarch64 is 64-bit":
            val c = AppConfig.create(name: "t", version: "0", args: [], platform: "ios", arch: "aarch64")
            expect c.is_64bit() == true

        it "riscv64 is 64-bit":
            val c = AppConfig.create(name: "t", version: "0", args: [], platform: "linux", arch: "riscv64")
            expect c.is_64bit() == true

        it "wasm32 is not 64-bit":
            val c = AppConfig.create(name: "t", version: "0", args: [], platform: "wasi", arch: "wasm32")
            expect c.is_64bit() == false

        it "riscv32 is not 64-bit":
            val c = AppConfig.create(name: "t", version: "0", args: [], platform: "none", arch: "riscv32")
            expect c.is_64bit() == false

    context "platform exclusivity":
        it "desktop is not mobile, wasm, or baremetal":
            val c = AppConfig.create(name: "t", version: "0", args: [], platform: "linux", arch: "x86_64")
            expect c.is_desktop() == true
            expect c.is_mobile() == false
            expect c.is_wasm() == false
            expect c.is_baremetal() == false

        it "mobile is not desktop, wasm, or baremetal":
            val c = AppConfig.create(name: "t", version: "0", args: [], platform: "android", arch: "aarch64")
            expect c.is_mobile() == true
            expect c.is_desktop() == false
            expect c.is_wasm() == false
            expect c.is_baremetal() == false