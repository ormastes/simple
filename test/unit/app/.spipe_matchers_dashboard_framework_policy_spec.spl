use std.spipe.*
use app.dashboard.framework_policy.{
    FRAMEWORK_WORKER_FLAG, FRAMEWORK_PROFILE_PREFIX,
    strip_framework_flags, is_framework_worker, args_request_gui,
    should_isolate_dashboard_command, dashboard_command_launch,
    build_dashboard_worker_args, classify_worker_exit,
    _trim_restart_history, _restart_backoff_millis, build_worker_shell_command
}

describe "Dashboard framework policy":
    it "detects and strips internal worker flags":
        val args = ["agents", "--gui", FRAMEWORK_WORKER_FLAG, FRAMEWORK_PROFILE_PREFIX + "llm_worker"]
        expect is_framework_worker(args) == true
        expect strip_framework_flags(args) == ["agents", "--gui"]

    it "isolates only heavy dashboard commands":
        expect should_isolate_dashboard_command("status", []) == false
        expect should_isolate_dashboard_command("collect", []) == true
        expect should_isolate_dashboard_command("serve", []) == true
        expect should_isolate_dashboard_command("agents", ["--gui"]) == true
        expect should_isolate_dashboard_command("agents", []) == false

    it "recognizes gui request flags":
        expect args_request_gui(["--gui"]) == true
        expect args_request_gui(["--web"]) == true
        expect args_request_gui(["--tui"]) == false

    it "builds worker args with internal profile markers":
        val launch = dashboard_command_launch("collect", [])
        val args = build_dashboard_worker_args("collect", ["--mode=full"], launch)
        expect args[0] == "dashboard"
        expect args[1] == "collect"
        expect args.contains(FRAMEWORK_WORKER_FLAG) == true
        expect args.contains("--mode=full") == true

    it "exports watchdog memory and timeout budgets to worker shells":
        val launch = dashboard_command_launch("collect", [])
        val shell_cmd = build_worker_shell_command(["dashboard", "collect"], launch)
        expect (shell_cmd).contains("export SIMPLE_MEMORY_LIMIT_MB='8192'; ")
        expect (shell_cmd).contains("export SIMPLE_TIMEOUT_SECONDS='30'; ")
        expect (shell_cmd).contains("export SIMPLE_BINARY=")
        expect (shell_cmd).contains("export SIMPLE_THREAD_BUDGET=")

    it "classifies limit failures ahead of exit code mapping":
        expect classify_worker_exit(137, true, "memory") == "memory"
        expect classify_worker_exit(101, false, "") == "panic"

    it "does not inject timeout wrapper for long running dashboard workers":
        val launch = dashboard_command_launch("serve", [])
        val shell_cmd = build_worker_shell_command(["dashboard", "serve"], launch)
        expect shell_cmd.contains("timeout --kill-after") == false
        expect shell_cmd.contains("SIMPLE_THREAD_BUDGET") == true

    it "trims restart history by the configured window":
        val trimmed = _trim_restart_history([1, 5_000_000, 70_000_000], 80_000_000, 60_000_000)
        expect trimmed == [70_000_000]

    it "uses escalating restart backoff":
        expect _restart_backoff_millis(1) == 250
        expect _restart_backoff_millis(2) == 1000
        expect _restart_backoff_millis(3) == 5000