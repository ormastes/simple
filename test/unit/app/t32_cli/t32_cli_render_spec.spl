# T32 CLI Render spec — tests output rendering for T32BridgeResult types

# ---------------------------------------------------------------------------
# Inline render helpers (mirror render.spl logic for interpreter-mode testing)
# ---------------------------------------------------------------------------

fn pad_right(s: text, width: i64) -> text:
    var result = s
    while result.len() < width:
        result = result + " "
    result

fn extract_json_value(json: text, key: text) -> text:
    val search = "\"" + key + "\""
    var pos = 0
    while pos < json.len():
        val idx = json.index_of(search, pos)
        if idx < 0:
            return ""
        var ci = idx + search.len()
        while ci < json.len() and (json[ci] == ' ' or json[ci] == ':'):
            ci = ci + 1
        if ci >= json.len():
            return ""
        if json[ci] == '"':
            val start = ci + 1
            var ei = start
            while ei < json.len() and json[ei] != '"':
                ei = ei + 1
            return json.slice(start, ei)
        val start = ci
        var ei = ci
        while ei < json.len() and json[ei] != ',' and json[ei] != '}' and json[ei] != ' ':
            ei = ei + 1
        return json.slice(start, ei)
    ""

# Minimal BridgeResult-like structure for testing
class TestResult:
    kind: text
    title: text
    rows: [[text]]
    kv_pairs: [[text]]
    scalar_value: text
    gui_status: text
    raw_output: text
    items: [text]

fn render_result(result: TestResult) -> text:
    var body = ""
    match result.kind:
        "scalar": body = render_scalar(result)
        "table": body = render_table(result)
        "kv": body = render_kv(result)
        "list": body = render_list(result)
        "status": body = render_kv(result)
        _: body = render_scalar(result)
    if result.gui_status != "":
        val footer = render_gui_status(result.gui_status)
        if footer != "":
            body = body + "\n" + footer
    body

fn render_scalar(result: TestResult) -> text:
    if result.raw_output != "":
        if result.title != "":
            return "{result.title}:\n{result.raw_output}"
        return result.raw_output
    if result.title != "":
        return "{result.title}: {result.scalar_value}"
    result.scalar_value

fn render_kv(result: TestResult) -> text:
    var out = ""
    if result.title != "":
        out = "{result.title}:\n"
    var max_key_len = 0
    for pair in result.kv_pairs:
        if pair.len() >= 1:
            val klen = pair[0].len()
            if klen > max_key_len:
                max_key_len = klen
    for pair in result.kv_pairs:
        if pair.len() >= 2:
            val key = pair[0]
            val value = pair[1]
            val padding = pad_right(key, max_key_len + 1)
            out = out + "  {padding}: {value}\n"
        elif pair.len() == 1:
            out = out + "  {pair[0]}\n"
    if out.len() > 0 and out.ends_with("\n"):
        out = out.slice(0, out.len() - 1)
    out

fn render_table(result: TestResult) -> text:
    if result.rows.len() == 0:
        if result.title != "":
            return "{result.title}: (empty)"
        return "(empty)"
    var col_widths: [i64] = []
    for row in result.rows:
        var ci = 0
        while ci < row.len():
            val cell_len = row[ci].len()
            if ci >= col_widths.len():
                col_widths.push(cell_len)
            elif cell_len > col_widths[ci]:
                col_widths[ci] = cell_len
            ci = ci + 1
    var out = ""
    if result.title != "":
        out = "{result.title}:\n"
    var ri = 0
    for row in result.rows:
        var line = ""
        var ci = 0
        while ci < row.len():
            val cell = row[ci]
            var width = cell.len()
            if ci < col_widths.len():
                width = col_widths[ci]
            val padded = pad_right(cell, width)
            if ci > 0:
                line = line + "  "
            line = line + padded
            ci = ci + 1
        if ri == 0 and result.rows.len() > 1:
            out = out + "  {line}\n"
            var sep = ""
            var si = 0
            while si < line.len():
                sep = sep + "-"
                si = si + 1
            out = out + "  {sep}\n"
        else:
            out = out + "  {line}\n"
        ri = ri + 1
    if out.len() > 0 and out.ends_with("\n"):
        out = out.slice(0, out.len() - 1)
    out

fn render_list(result: TestResult) -> text:
    var out = ""
    if result.title != "":
        out = "{result.title}:\n"
    for item in result.items:
        out = out + "  - {item}\n"
    if out.len() > 0 and out.ends_with("\n"):
        out = out.slice(0, out.len() - 1)
    out

fn render_gui_status(gui_json: text) -> text:
    if gui_json == "" or gui_json == "{}":
        return ""
    var parts: [text] = []
    val cpu_state = extract_json_value(gui_json, "cpu_state")
    if cpu_state != "":
        parts.push("CPU: {cpu_state}")
    val practice_state = extract_json_value(gui_json, "practice_state")
    if practice_state != "":
        parts.push("PRACTICE: {practice_state}")
    val system_state = extract_json_value(gui_json, "system_state")
    if system_state != "":
        parts.push("System: {system_state}")
    if parts.len() == 0:
        return ""
    var out = "[" + parts[0]
    var i = 1
    while i < parts.len():
        out = out + " | " + parts[i]
        i = i + 1
    out + "]"

fn render_error(message: text) -> text:
    "Error: {message}"

# ---------------------------------------------------------------------------
# Test helpers — construct TestResult variants
# ---------------------------------------------------------------------------

fn make_scalar(value: text) -> TestResult:
    TestResult(kind: "scalar", title: "", rows: [], kv_pairs: [],
        scalar_value: value, gui_status: "", raw_output: "", items: [])

fn make_scalar_titled(title: text, value: text) -> TestResult:
    TestResult(kind: "scalar", title: title, rows: [], kv_pairs: [],
        scalar_value: value, gui_status: "", raw_output: "", items: [])

fn make_table(title: text, rows: [[text]]) -> TestResult:
    TestResult(kind: "table", title: title, rows: rows, kv_pairs: [],
        scalar_value: "", gui_status: "", raw_output: "", items: [])

fn make_kv(title: text, pairs: [[text]]) -> TestResult:
    TestResult(kind: "kv", title: title, rows: [], kv_pairs: pairs,
        scalar_value: "", gui_status: "", raw_output: "", items: [])

fn make_list(title: text, items: [text]) -> TestResult:
    TestResult(kind: "list", title: title, rows: [], kv_pairs: [],
        scalar_value: "", gui_status: "", raw_output: "", items: items)

fn make_raw(output: text) -> TestResult:
    TestResult(kind: "scalar", title: "", rows: [], kv_pairs: [],
        scalar_value: "", gui_status: "", raw_output: output, items: [])

# ===========================================================================
# Tests
# ===========================================================================

describe "T32 CLI Render":
    context "scalar results":
        it "renders scalar value":
            val result = make_scalar("42")
            val output = render_result(result)
            expect(output).to_equal("42")

        it "renders scalar with title":
            val result = make_scalar_titled("Register PC", "0x08001000")
            val output = render_result(result)
            expect(output).to_equal("Register PC: 0x08001000")

    context "table results":
        it "renders table with header and separator":
            val rows: [[text]] = [["Name", "Value"], ["PC", "0x1000"], ["SP", "0x2000"]]
            val result = make_table("Registers", rows)
            val output = render_result(result)
            expect(output).to_contain("Registers:")
            expect(output).to_contain("Name")
            expect(output).to_contain("Value")
            expect(output).to_contain("PC")
            expect(output).to_contain("SP")
            # Header separator line of dashes should be present
            expect(output).to_contain("----")

        it "renders empty table as (empty)":
            val result = make_table("Empty", [])
            val output = render_result(result)
            expect(output).to_equal("Empty: (empty)")

    context "kv results":
        it "renders aligned key-value pairs":
            val pairs: [[text]] = [["host", "localhost"], ["port", "20000"]]
            val result = make_kv("Session", pairs)
            val output = render_result(result)
            expect(output).to_start_with("Session:")
            expect(output).to_contain("host")
            expect(output).to_contain("localhost")
            expect(output).to_contain("port")
            expect(output).to_contain("20000")

    context "list results":
        it "renders bulleted items":
            val items: [text] = ["alpha", "beta", "gamma"]
            val result = make_list("Items", items)
            val output = render_result(result)
            expect(output).to_start_with("Items:")
            expect(output).to_contain("  - alpha")
            expect(output).to_contain("  - beta")
            expect(output).to_contain("  - gamma")

    context "raw output":
        it "passes through raw text":
            val result = make_raw("some raw output\nline two")
            val output = render_result(result)
            expect(output).to_equal("some raw output\nline two")

    context "error formatting":
        it "formats error message":
            val output = render_error("Connection lost")
            expect(output).to_equal("Error: Connection lost")

        it "formats empty error":
            val output = render_error("")
            expect(output).to_equal("Error: ")

    context "gui_status footer":
        it "appends gui status footer to scalar":
            var result = make_scalar("ok")
            result.gui_status = "{\"cpu_state\":\"stopped\",\"practice_state\":\"idle\"}"
            val output = render_result(result)
            expect(output).to_contain("ok")
            expect(output).to_contain("[CPU: stopped | PRACTICE: idle]")

        it "skips empty gui status":
            var result = make_scalar("ok")
            result.gui_status = ""
            val output = render_result(result)
            expect(output).to_equal("ok")

        it "skips empty object gui status":
            var result = make_scalar("ok")
            result.gui_status = "{}"
            val output = render_result(result)
            expect(output).to_equal("ok")
