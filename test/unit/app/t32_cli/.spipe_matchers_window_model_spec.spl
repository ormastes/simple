# Window Model spec — tests window listing and describe

describe "T32 Window Model":
    it "lists windows by key":
        var keys: [text] = ["break_list", "register_view", "var_local"]
        expect keys.len() == 3
        expect keys[0] == "break_list"

    it "finds window by key":
        var keys: [text] = ["break_list", "register_view", "var_local"]
        var found = ""
        for k in keys:
            if k == "register_view":
                found = k
        expect found == "register_view"

    it "describes window actions":
        var actions: [text] = ["set_break", "clear_break", "go"]
        expect actions.len() == 3
        expect actions[0] == "set_break"

    it "describes window fields":
        var fields: [text] = ["symbol", "address"]
        expect fields.len() == 2