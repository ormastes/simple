# T32 CLI command registry spec — tests all_cli_commands, find, top-level, subcmds, shell verbs

use app.t32_cli.commands.{all_cli_commands, all_mcp_tool_names, find_cli_command, all_top_level_names, subcmds_for, all_shell_verbs}

describe "T32 CLI Commands — all_cli_commands":
    it "returns exactly 36 entries":
        val cmds = all_cli_commands()
        expect(cmds.len()).to_equal(36)

    it "every command has non-empty name":
        val cmds = all_cli_commands()
        for cmd in cmds:
            expect(cmd.name.len() > 0).to_equal(true)

    it "every command has non-empty mcp_tool":
        val cmds = all_cli_commands()
        for cmd in cmds:
            expect(cmd.mcp_tool.len() > 0).to_equal(true)

    it "every command has non-empty usage text":
        val cmds = all_cli_commands()
        for cmd in cmds:
            expect(cmd.usage.len() > 0).to_equal(true)

describe "T32 CLI Commands — all_mcp_tool_names":
    it "returns 36 unique names":
        val names = all_mcp_tool_names()
        expect(names.len()).to_equal(36)

    it "contains t32_cmd_run":
        val names = all_mcp_tool_names()
        expect(names).to_contain("t32_cmd_run")

    it "contains t32_sessions_list":
        val names = all_mcp_tool_names()
        expect(names).to_contain("t32_sessions_list")

describe "T32 CLI Commands — find_cli_command":
    it "finds cmd/run":
        val result = find_cli_command("cmd", "run")
        expect(result.?).to_equal(true)
        val cmd = result!
        expect(cmd.mcp_tool).to_equal("t32_cmd_run")

    it "finds sessions/open":
        val result = find_cli_command("sessions", "open")
        expect(result.?).to_equal(true)
        val cmd = result!
        expect(cmd.mcp_tool).to_equal("t32_session_open")

    it "finds sessions with no subcmd":
        val result = find_cli_command("sessions", "")
        expect(result.?).to_equal(true)
        val cmd = result!
        expect(cmd.mcp_tool).to_equal("t32_sessions_list")

    it "finds eval with no subcmd":
        val result = find_cli_command("eval", "")
        expect(result.?).to_equal(true)
        val cmd = result!
        expect(cmd.mcp_tool).to_equal("t32_eval")

    it "finds jobs/list":
        val result = find_cli_command("jobs", "list")
        expect(result.?).to_equal(true)
        val cmd = result!
        expect(cmd.mcp_tool).to_equal("t32_job_list")

    it "finds dialog/parse":
        val result = find_cli_command("dialog", "parse")
        expect(result.?).to_equal(true)
        val cmd = result!
        expect(cmd.mcp_tool).to_equal("t32_dialog_parse")

    it "returns nil for unknown command":
        val result = find_cli_command("nonexistent", "")
        expect(result.?).to_equal(false)

    it "returns nil for unknown subcmd of valid command":
        val result = find_cli_command("sessions", "nonexistent")
        # Falls back to top-level (sessions with subcmd="")
        val cmd = result!
        expect(cmd.mcp_tool).to_equal("t32_sessions_list")

describe "T32 CLI Commands — all_top_level_names":
    it "includes sessions":
        val names = all_top_level_names()
        expect(names).to_contain("sessions")

    it "includes cores":
        val names = all_top_level_names()
        expect(names).to_contain("cores")

    it "includes cmd":
        val names = all_top_level_names()
        expect(names).to_contain("cmd")

    it "includes eval":
        val names = all_top_level_names()
        expect(names).to_contain("eval")

    it "includes jobs":
        val names = all_top_level_names()
        expect(names).to_contain("jobs")

    it "includes dialog":
        val names = all_top_level_names()
        expect(names).to_contain("dialog")

    it "includes windows":
        val names = all_top_level_names()
        expect(names).to_contain("windows")

    it "includes status":
        val names = all_top_level_names()
        expect(names).to_contain("status")

describe "T32 CLI Commands — subcmds_for":
    it "sessions has open close use info":
        val subs = subcmds_for("sessions")
        expect(subs).to_contain("open")
        expect(subs).to_contain("close")
        expect(subs).to_contain("use")
        expect(subs).to_contain("info")
        expect(subs.len()).to_equal(4)

    it "jobs has list get cancel result":
        val subs = subcmds_for("jobs")
        expect(subs).to_contain("list")
        expect(subs).to_contain("get")
        expect(subs).to_contain("cancel")
        expect(subs).to_contain("result")
        expect(subs.len()).to_equal(4)

    it "dialog has parse get set click":
        val subs = subcmds_for("dialog")
        expect(subs).to_contain("parse")
        expect(subs).to_contain("get")
        expect(subs).to_contain("set")
        expect(subs).to_contain("click")
        expect(subs.len()).to_equal(4)

    it "cores has select":
        val subs = subcmds_for("cores")
        expect(subs).to_contain("select")
        expect(subs.len()).to_equal(1)

    it "eval has no subcommands":
        val subs = subcmds_for("eval")
        expect(subs.len()).to_equal(0)

