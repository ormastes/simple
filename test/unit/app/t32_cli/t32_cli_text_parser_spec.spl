# T32 CLI Text Parser spec — tests the 5 window-specific parsers
# All parsers inlined to avoid import path issues with the test runner

# --- Inlined helpers ---

fn ws_split(input: text) -> [text]:
    var parts: [text] = []
    var buf: [text] = []
    var in_word = false
    for ch in input:
        if ch == " " or ch == "\t":
            if in_word:
                parts.push(buf.join(""))
                buf = []
                in_word = false
        else:
            buf.push(ch)
            in_word = true
    if in_word:
        parts.push(buf.join(""))
    parts

fn ws_find_char(s: text, ch: text) -> i64:
    var i = 0
    while i < s.len():
        if s.slice(i, i + 1) == ch:
            return i
        i = i + 1
    -1

# --- parse_break_list_output ---
fn parse_break_list(raw: text) -> [Dict<text, text>]:
    var rows: [Dict<text, text>] = []
    val lines = raw.split("\n")
    for line in lines:
        val trimmed = line.trim()
        if trimmed == "" or trimmed.starts_with("#") or trimmed.starts_with("-") or trimmed.starts_with("enabled"):
            continue
        val tokens = ws_split(trimmed)
        if tokens.len() >= 4:
            var row: Dict<text, text> = {}
            row["enabled"] = tokens[0]
            row["address"] = tokens[1]
            row["symbol"] = tokens[2]
            row["type"] = tokens[3]
            if tokens.len() > 4:
                row["condition"] = tokens[4]
            else:
                row["condition"] = ""
            rows.push(row)
    rows

# --- parse_register_output ---
fn parse_register_out(raw: text) -> [Dict<text, text>]:
    var rows: [Dict<text, text>] = []
    val lines = raw.split("\n")
    for line in lines:
        val trimmed = line.trim()
        if trimmed == "" or trimmed.starts_with("#"):
            continue
        val tokens = ws_split(trimmed)
        for token in tokens:
            val eq_pos = ws_find_char(token, "=")
            if eq_pos > 0:
                var row: Dict<text, text> = {}
                val name = token.slice(0, eq_pos)
                var value = ""
                if eq_pos + 1 < token.len():
                    value = token.slice(eq_pos + 1, token.len())
                row["name"] = name
                row["value"] = value
                rows.push(row)
    rows

# --- parse_var_watch_output ---
fn parse_var_watch(raw: text) -> [Dict<text, text>]:
    var rows: [Dict<text, text>] = []
    val lines = raw.split("\n")
    for line in lines:
        val trimmed = line.trim()
        if trimmed == "" or trimmed.starts_with("#") or trimmed.starts_with("-") or trimmed.starts_with("name"):
            continue
        val tokens = ws_split(trimmed)
        if tokens.len() >= 3:
            var row: Dict<text, text> = {}
            row["name"] = tokens[0]
            row["type"] = tokens[1]
            var value = tokens[2]
            var vi = 3
            while vi < tokens.len():
                value = value + " " + tokens[vi]
                vi = vi + 1
            row["value"] = value
            rows.push(row)
    rows

# --- parse_trace_list_output ---
fn parse_trace_list(raw: text) -> [Dict<text, text>]:
    var rows: [Dict<text, text>] = []
    val lines = raw.split("\n")
    for line in lines:
        val trimmed = line.trim()
        if trimmed == "" or trimmed.starts_with("#") or trimmed.starts_with("-") or trimmed.starts_with("cycle"):
            continue
        val tokens = ws_split(trimmed)
        if tokens.len() >= 4:
            var row: Dict<text, text> = {}
            row["cycle"] = tokens[0]
            row["address"] = tokens[1]
            row["data"] = tokens[2]
            row["type"] = tokens[3]
            rows.push(row)
    rows

# --- parse_task_list_output ---
fn parse_task_list(raw: text) -> [Dict<text, text>]:
    var rows: [Dict<text, text>] = []
    val lines = raw.split("\n")
    for line in lines:
        val trimmed = line.trim()
        if trimmed == "" or trimmed.starts_with("#") or trimmed.starts_with("-") or trimmed.starts_with("id"):
            continue
        val tokens = ws_split(trimmed)
        if tokens.len() >= 4:
            var row: Dict<text, text> = {}
            row["id"] = tokens[0]
            row["name"] = tokens[1]
            row["state"] = tokens[2]
            row["priority"] = tokens[3]
            rows.push(row)
    rows

# --- Tests ---

describe "T32 CLI Text Parsers":

    context "parse_break_list_output":
        it "parses breakpoint entries":
            val raw = "enabled  address     symbol  type\n--------  ----------  ------  ------\nE:  0x08001234  main  Program\nE:  0x08002000  irq_handler  Program"
            val rows = parse_break_list(raw)
            expect(rows.len()).to_equal(2)
            expect(rows[0]["enabled"]).to_equal("E:")
            expect(rows[0]["address"]).to_equal("0x08001234")
            expect(rows[0]["symbol"]).to_equal("main")
            expect(rows[0]["type"]).to_equal("Program")

        it "handles breakpoint with condition":
            val raw = "E:  0x08001234  main  Program  i>10"
            val rows = parse_break_list(raw)
            expect(rows.len()).to_equal(1)
            expect(rows[0]["condition"]).to_equal("i>10")

        it "returns empty for empty input":
            val rows = parse_break_list("")
            expect(rows.len()).to_equal(0)

    context "parse_register_output":
        it "parses name=value pairs":
            val raw = "R0=0x00000000  R1=0x12345678  R2=0xFF"
            val rows = parse_register_out(raw)
            expect(rows.len()).to_equal(3)
            expect(rows[0]["name"]).to_equal("R0")
            expect(rows[0]["value"]).to_equal("0x00000000")
            expect(rows[1]["name"]).to_equal("R1")
            expect(rows[1]["value"]).to_equal("0x12345678")

        it "handles multiline":
            val raw = "R0=0x00  R1=0x01\nR2=0x02"
            val rows = parse_register_out(raw)
            expect(rows.len()).to_equal(3)

        it "returns empty for empty input":
            val rows = parse_register_out("")
            expect(rows.len()).to_equal(0)

    context "parse_var_watch_output":
        it "parses name type value":
            val raw = "counter  int  42\nptr  char*  hello world"
            val rows = parse_var_watch(raw)
            expect(rows.len()).to_equal(2)
            expect(rows[0]["name"]).to_equal("counter")
            expect(rows[0]["type"]).to_equal("int")
            expect(rows[0]["value"]).to_equal("42")
            expect(rows[1]["value"]).to_equal("hello world")

        it "skips header and separator lines":
            val raw = "name  type  value\n---  ---  ---\ncounter  int  42"
            val rows = parse_var_watch(raw)
            expect(rows.len()).to_equal(1)
            expect(rows[0]["name"]).to_equal("counter")

        it "returns empty for empty input":
            val rows = parse_var_watch("")
            expect(rows.len()).to_equal(0)

    context "parse_trace_list_output":
        it "parses cycle address data type":
            val raw = "cycle  address     data  type\n-----  ----------  ----  ----\n1000  0x08001234  0xAB  read\n1001  0x08001238  0xCD  write"
            val rows = parse_trace_list(raw)
            expect(rows.len()).to_equal(2)
            expect(rows[0]["cycle"]).to_equal("1000")
            expect(rows[0]["address"]).to_equal("0x08001234")
            expect(rows[0]["data"]).to_equal("0xAB")
            expect(rows[0]["type"]).to_equal("read")

        it "returns empty for empty input":
            val rows = parse_trace_list("")
            expect(rows.len()).to_equal(0)

    context "parse_task_list_output":
        it "parses id name state priority":
            val raw = "id  name  state  priority\n--  ----  -----  --------\n1  main_task  RUNNING  10\n2  idle  READY  0\n3  uart_rx  BLOCKED  5"
            val rows = parse_task_list(raw)
            expect(rows.len()).to_equal(3)
            expect(rows[0]["id"]).to_equal("1")
            expect(rows[0]["name"]).to_equal("main_task")
            expect(rows[0]["state"]).to_equal("RUNNING")
            expect(rows[0]["priority"]).to_equal("10")
            expect(rows[2]["name"]).to_equal("uart_rx")
            expect(rows[2]["state"]).to_equal("BLOCKED")

        it "returns empty for empty input":
            val rows = parse_task_list("")
            expect(rows.len()).to_equal(0)
