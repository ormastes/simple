# Session CLI spec — tests session management

describe "T32 Session CLI":
    it "formats session list":
        var ids: [text] = ["amp0", "amp1"]
        var lines: [text] = []
        for id in ids:
            lines.push("  {id}")
        val output = lines.join("\n")
        expect (output).contains("amp0")
        expect (output).contains("amp1")

    it "tracks current session":
        var current = ""
        current = "amp0"
        expect current == "amp0"
        current = "amp1"
        expect current == "amp1"

    it "validates session id exists":
        var ids: [text] = ["s1", "s2"]
        var found = false
        val target = "s2"
        for id in ids:
            if id == target:
                found = true
        expect found == true

    it "rejects unknown session":
        var ids: [text] = ["s1", "s2"]
        var found = false
        val target = "s99"
        for id in ids:
            if id == target:
                found = true
        expect found == false