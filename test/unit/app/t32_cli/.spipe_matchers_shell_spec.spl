# Shell spec — tests interactive shell command parsing

fn parse_shell_cmd(line: text) -> [text]:
    var parts: [text] = []
    var buf: [text] = []
    var in_word = false
    for ch in line:
        if ch == " ":
            if in_word:
                parts.push(buf.join(""))
                buf = []
                in_word = false
        else:
            buf.push(ch)
            in_word = true
    if in_word:
        parts.push(buf.join(""))
    parts

describe "T32 Shell":
    it "parses simple command":
        val parts = parse_shell_cmd("windows")
        expect parts.len() == 1
        expect parts[0] == "windows"

    it "parses command with argument":
        val parts = parse_shell_cmd("show break_list")
        expect parts.len() == 2
        expect parts[0] == "show"
        expect parts[1] == "break_list"

    it "parses set command":
        val parts = parse_shell_cmd("set symbol main")
        expect parts.len() == 3
        expect parts[0] == "set"
        expect parts[1] == "symbol"
        expect parts[2] == "main"

    it "parses use command":
        val parts = parse_shell_cmd("use amp0")
        expect parts[0] == "use"
        expect parts[1] == "amp0"

    it "parses core command":
        val parts = parse_shell_cmd("core a53_2")
        expect parts[0] == "core"
        expect parts[1] == "a53_2"

    it "formats prompt":
        val session = "amp0"
        val core = "a53_2"
        val prompt = "{session}:{core}> "
        expect prompt == "amp0:a53_2> "