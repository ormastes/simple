# T32 CLI command registry spec — tests all_cli_commands, find, top-level, subcmds, shell verbs

use app.t32_cli.commands.{all_cli_commands, all_mcp_tool_names, find_cli_command, all_top_level_names, subcmds_for, all_shell_verbs}

describe "T32 CLI Commands — all_cli_commands":
    it "returns exactly 36 entries":
        val cmds = all_cli_commands()
        expect cmds.len() == 36

    it "every command has non-empty name":
        val cmds = all_cli_commands()
        for cmd in cmds:
            expect cmd.name.len() > 0 == true

    it "every command has non-empty mcp_tool":
        val cmds = all_cli_commands()
        for cmd in cmds:
            expect cmd.mcp_tool.len() > 0 == true

    it "every command has non-empty usage text":
        val cmds = all_cli_commands()
        for cmd in cmds:
            expect cmd.usage.len() > 0 == true

describe "T32 CLI Commands — all_mcp_tool_names":
    it "returns 36 unique names":
        val names = all_mcp_tool_names()
        expect names.len() == 36

    it "contains t32_cmd_run":
        val names = all_mcp_tool_names()
        expect (names).contains("t32_cmd_run")

    it "contains t32_sessions_list":
        val names = all_mcp_tool_names()
        expect (names).contains("t32_sessions_list")

describe "T32 CLI Commands — find_cli_command":
    it "finds cmd/run":
        val result = find_cli_command("cmd", "run")
        var tool = ""
        if val cmd = result:
            tool = cmd.mcp_tool
        expect tool == "t32_cmd_run"

    it "finds sessions/open":
        val result = find_cli_command("sessions", "open")
        var tool = ""
        if val cmd = result:
            tool = cmd.mcp_tool
        expect tool == "t32_session_open"

    it "finds sessions with no subcmd":
        val result = find_cli_command("sessions", "")
        var tool = ""
        if val cmd = result:
            tool = cmd.mcp_tool
        expect tool == "t32_sessions_list"

    it "finds eval with no subcmd":
        val result = find_cli_command("eval", "")
        var tool = ""
        if val cmd = result:
            tool = cmd.mcp_tool
        expect tool == "t32_eval"

    it "finds jobs/list":
        val result = find_cli_command("jobs", "list")
        var tool = ""
        if val cmd = result:
            tool = cmd.mcp_tool
        expect tool == "t32_job_list"

    it "finds dialog/parse":
        val result = find_cli_command("dialog", "parse")
        var tool = ""
        if val cmd = result:
            tool = cmd.mcp_tool
        expect tool == "t32_dialog_parse"

    it "returns nil for unknown command":
        val result = find_cli_command("nonexistent", "")
        var found = false
        if val cmd = result:
            found = true
        expect found == false

    it "falls back to top-level for unknown subcmd":
        val result = find_cli_command("sessions", "nonexistent")
        var tool = ""
        if val cmd = result:
            tool = cmd.mcp_tool
        expect tool == "t32_sessions_list"

describe "T32 CLI Commands — all_top_level_names":
    it "includes sessions":
        val names = all_top_level_names()
        expect (names).contains("sessions")

    it "includes cores":
        val names = all_top_level_names()
        expect (names).contains("cores")

    it "includes cmd":
        val names = all_top_level_names()
        expect (names).contains("cmd")

    it "includes eval":
        val names = all_top_level_names()
        expect (names).contains("eval")

    it "includes jobs":
        val names = all_top_level_names()
        expect (names).contains("jobs")

    it "includes dialog":
        val names = all_top_level_names()
        expect (names).contains("dialog")

    it "includes windows":
        val names = all_top_level_names()
        expect (names).contains("windows")

    it "includes status":
        val names = all_top_level_names()
        expect (names).contains("status")

describe "T32 CLI Commands — subcmds_for":
    it "sessions has open close use info":
        val subs = subcmds_for("sessions")
        expect (subs).contains("open")
        expect (subs).contains("close")
        expect (subs).contains("use")
        expect (subs).contains("info")
        expect subs.len() == 4

    it "jobs has list get cancel result":
        val subs = subcmds_for("jobs")
        expect (subs).contains("list")
        expect (subs).contains("get")
        expect (subs).contains("cancel")
        expect (subs).contains("result")
        expect subs.len() == 4

    it "dialog has parse get set click":
        val subs = subcmds_for("dialog")
        expect (subs).contains("parse")
        expect (subs).contains("get")
        expect (subs).contains("set")
        expect (subs).contains("click")
        expect subs.len() == 4

    it "cores has select":
        val subs = subcmds_for("cores")
        expect (subs).contains("select")
        expect subs.len() == 1

    it "eval has no subcommands":
        val subs = subcmds_for("eval")
        expect subs.len() == 0

