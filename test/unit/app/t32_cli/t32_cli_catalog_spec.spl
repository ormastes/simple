# T32 CLI Catalog Loader spec — tests SDN catalog loading with real files
# Uses the existing catalog_loader_spec's SDN parser (proven working)

extern fn rt_file_read_text(path: text) -> text

# --- Inlined SDN parser (matches catalog_loader_spec.spl approach) ---

fn sdn_find_colon(s: text) -> i64:
    var i = 0
    while i < s.len():
        if s.slice(i, i + 1) == ":":
            return i
        i = i + 1
    -1

fn sdn_parse_block(content: text, keyword: text) -> [Dict<text, text>]:
    var entries: [Dict<text, text>] = []
    var current: Dict<text, text> = {}
    var in_entry = false
    val lines = content.split("\n")
    for line in lines:
        val trimmed = line.trim()
        if trimmed.len() == 0 or trimmed.starts_with("#"):
            continue
        if trimmed.starts_with(keyword + " "):
            if in_entry:
                entries.push(current)
            current = {}
            val after = keyword.len() + 1
            val key = trimmed.slice(after, trimmed.len()).trim()
            current["_key"] = key
            in_entry = true
        else if in_entry:
            val idx = sdn_find_colon(trimmed)
            if idx > 0:
                val prop = trimmed.slice(0, idx).trim()
                val after = idx + 1
                val value = trimmed.slice(after, trimmed.len()).trim()
                current[prop] = value
    if in_entry:
        entries.push(current)
    entries

# --- Tests ---

describe "T32 Catalog Loader (real SDN files)":

    context "windows.sdn":
        it "loads window entries from real catalog file":
            val content = rt_file_read_text("config/t32/catalogs/windows.sdn") ?? ""
            val entries = sdn_parse_block(content, "window")
            expect(entries.len()).to_be_greater_than(0)

        it "has at least 11 windows":
            val content = rt_file_read_text("config/t32/catalogs/windows.sdn") ?? ""
            val entries = sdn_parse_block(content, "window")
            expect(entries.len()).to_be_greater_than(10)

        it "contains break_list window":
            val content = rt_file_read_text("config/t32/catalogs/windows.sdn") ?? ""
            val entries = sdn_parse_block(content, "window")
            var found = false
            for e in entries:
                val key = e["_key"] ?? ""
                if key == "break_list":
                    found = true
                    expect(e["title"] ?? "").to_equal("Breakpoint List")
                    expect(e["kind"] ?? "").to_equal("built_in")
            expect(found).to_equal(true)

        it "contains register_view window":
            val content = rt_file_read_text("config/t32/catalogs/windows.sdn") ?? ""
            val entries = sdn_parse_block(content, "window")
            var found = false
            for e in entries:
                val key = e["_key"] ?? ""
                if key == "register_view":
                    found = true
                    expect(e["title"] ?? "").to_equal("CPU Registers")
            expect(found).to_equal(true)

        it "each window has open_command":
            val content = rt_file_read_text("config/t32/catalogs/windows.sdn") ?? ""
            val entries = sdn_parse_block(content, "window")
            for e in entries:
                val open_cmd = e["open_command"] ?? ""
                expect(open_cmd.len()).to_be_greater_than(0)

    context "actions.sdn":
        it "loads action entries from real catalog file":
            val content = rt_file_read_text("config/t32/catalogs/actions.sdn") ?? ""
            val entries = sdn_parse_block(content, "action")
            expect(entries.len()).to_be_greater_than(0)

        it "has at least 10 actions":
            val content = rt_file_read_text("config/t32/catalogs/actions.sdn") ?? ""
            val entries = sdn_parse_block(content, "action")
            expect(entries.len()).to_be_greater_than(9)

        it "contains set_break action with correct fields":
            val content = rt_file_read_text("config/t32/catalogs/actions.sdn") ?? ""
            val entries = sdn_parse_block(content, "action")
            var found = false
            for e in entries:
                val key = e["_key"] ?? ""
                if key == "set_break":
                    found = true
                    expect(e["label"] ?? "").to_equal("Set Breakpoint")
                    expect(e["type"] ?? "").to_equal("execute")
            expect(found).to_equal(true)

    context "fields.sdn":
        it "loads field entries from real catalog file":
            val content = rt_file_read_text("config/t32/catalogs/fields.sdn") ?? ""
            val entries = sdn_parse_block(content, "field")
            expect(entries.len()).to_be_greater_than(0)

        it "has at least 10 fields":
            val content = rt_file_read_text("config/t32/catalogs/fields.sdn") ?? ""
            val entries = sdn_parse_block(content, "field")
            expect(entries.len()).to_be_greater_than(9)

        it "contains symbol field with correct properties":
            val content = rt_file_read_text("config/t32/catalogs/fields.sdn") ?? ""
            val entries = sdn_parse_block(content, "field")
            var found = false
            for e in entries:
                val key = e["_key"] ?? ""
                if key == "symbol":
                    found = true
                    expect(e["label"] ?? "").to_equal("Symbol Name")
                    expect(e["type"] ?? "").to_equal("string")
                    expect(e["scope"] ?? "").to_equal("window")
            expect(found).to_equal(true)

    context "lookup by key":
        it "finds window by key":
            val content = rt_file_read_text("config/t32/catalogs/windows.sdn") ?? ""
            val entries = sdn_parse_block(content, "window")
            var found_title = ""
            for e in entries:
                if (e["_key"] ?? "") == "trace_list":
                    found_title = e["title"] ?? ""
            expect(found_title).to_equal("Trace List")

        it "finds action by key":
            val content = rt_file_read_text("config/t32/catalogs/actions.sdn") ?? ""
            val entries = sdn_parse_block(content, "action")
            var found_label = ""
            for e in entries:
                if (e["_key"] ?? "") == "go":
                    found_label = e["label"] ?? ""
            expect(found_label).to_equal("Resume Execution")

        it "finds field by key":
            val content = rt_file_read_text("config/t32/catalogs/fields.sdn") ?? ""
            val entries = sdn_parse_block(content, "field")
            var found_label = ""
            for e in entries:
                if (e["_key"] ?? "") == "elf_path":
                    found_label = e["label"] ?? ""
            expect(found_label).to_equal("ELF Binary Path")
