# Window Model spec — tests window listing and describe

describe "T32 Window Model":
    it "lists windows by key":
        var keys = ["break_list", "register_view", "var_local"]
        expect(keys.len()).to_equal(3)
        expect(keys[0]).to_equal("break_list")

    it "finds window by key":
        var keys = ["break_list", "register_view", "var_local"]
        var found = ""
        for k in keys:
            if k == "register_view":
                found = k
        expect(found).to_equal("register_view")

    it "describes window actions":
        var actions = ["set_break", "clear_break", "go"]
        expect(actions.len()).to_equal(3)
        expect(actions[0]).to_equal("set_break")

    it "describes window fields":
        var fields = ["symbol", "address"]
        expect(fields.len()).to_equal(2)
