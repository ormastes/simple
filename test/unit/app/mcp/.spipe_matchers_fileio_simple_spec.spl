# # MCP FileIO Simple Intensive Specification
#
# Covers protection logic and basic read/write handlers
# in `src/app/mcp/fileio_simple.spl`.

use std.spec
use app.io.mod.{shell}
use app.io.file_ops.{file_write, file_read, file_exists}
use app.mcp.fileio_simple

fn read_text(path: text) -> text:
    file_read(path) ?? ""


describe "FileIO Simple - Protection Rules":
    it "protects critical files":
        expect (check_protection("CLAUDE.md", "write")).contains("DENIED")
        expect check_protection("CLAUDE.md", "read") == "ALLOWED"

    it "redirects test files and shell scripts":
        expect (check_protection("test_file.txt", "write")).contains("REDIRECT")
        expect (check_protection("mcp_test_output.txt", "write")).contains("REDIRECT")
        expect (check_protection("script.sh", "write")).contains("REDIRECT")

    it "denies version control and lock files":
        expect (check_protection(".git/config", "write")).contains("DENIED")
        expect (check_protection(".jj/abc", "write")).contains("DENIED")
        expect (check_protection("cache.lock", "write")).contains("DENIED")

    it "requires atomic writes for sdn":
        expect (check_protection("data.sdn", "write")).contains("ATOMIC")

    it "allows build and tmp directories":
        expect check_protection("build/output.txt", "write") == "ALLOWED"
        expect check_protection("tmp/output.txt", "write") == "ALLOWED"
        expect check_protection("tmp/fileio_temp/output.txt", "write") == "ALLOWED"

    it "denies root-level files by default":
        expect (check_protection("root.txt", "write")).contains("DENIED")

    it "allows subdirectories by default":
        expect check_protection("src/file.txt", "write") == "ALLOWED"


describe "FileIO Simple - Handlers":
    it "handles safe_write in each mode":
        shell("mkdir -p tmp/fileio_temp")
        val allowed = handle_safe_write("tmp/mcp_simple_allowed.txt", "ok")
        expect allowed.starts_with("OK:" ) == true
        val denied = handle_safe_write("CLAUDE.md", "x")
        expect denied.starts_with("ERROR:" ) == true
        val atomic = handle_safe_write("data.sdn", "x")
        expect atomic.contains("Atomic write required") == true
        val redirected = handle_safe_write("test_file.txt", "x")
        expect redirected.contains("temp" ) == true
        expect file_exists("tmp/fileio_temp/test_file.txt") == true

    it "handles safe_read":
        val path = "/tmp/mcp_simple_read.txt"
        file_write(path, "read")
        val ok = handle_safe_read(path)
        expect ok.starts_with("OK:" ) == true
        val missing = handle_safe_read("/tmp/mcp_simple_missing.txt")
        expect missing.contains("File not found") == true
        val denied = handle_safe_read("README.md")
        expect denied.starts_with("ERROR:" ) == true

    it "handles check_protection handler":
        val resp = handle_check_protection("data.sdn")
        expect resp.contains("PROTECTION:" ) == true