use std.spec.{describe, it, expect}
use std.gc_async_mut.gpu.browser_engine.dom.{BeDomNode}
use std.gc_async_mut.gpu.browser_engine.css.{be_default_style}
use std.gc_async_mut.gpu.browser_engine.layout.{BeLayoutBox, layout_node, layout_get_height}
use std.gc_async_mut.gpu.browser_engine.paint.{paint_layout_box}
use std.gc_async_mut.gpu.browser_engine.browser_renderer.{BrowserRenderer}
use common.text_layout.font_renderer.{CachedGlyph, FontRenderer, browser_serif_font_candidates}

fn _chrome_test_font_renderer() -> FontRenderer:
    FontRenderer.browser_serif_default()

fn _container(content_width: i32, content_height: i32) -> BeLayoutBox:
    BeLayoutBox(
        x: 0, y: 0, width: content_width, height: content_height,
        content_x: 0, content_y: 0,
        content_width: content_width, content_height: content_height,
        node: BeDomNode.element("div"),
        children: []
    )

describe "browser text metrics":
    it "cached glyphs carry neutral bearing defaults":
        val glyph = CachedGlyph.empty(65, 16)
        expect glyph.bearing_x == 0
        expect glyph.bearing_y == 0

    it "prefers Chrome-compatible serif font before host and provided fallbacks":
        val candidates = browser_serif_font_candidates()
        expect candidates.len() > 2
        expect candidates[0] == "/usr/share/fonts/truetype/liberation/LiberationSerif-Regular.ttf"
        expect candidates[1] == "examples/simple_os/fonts/serif/NotoSerif-Regular.ttf"
        expect candidates[2] == "examples/simple_os/fonts/serif/NotoSerifSC-Regular.otf"

    it "uses the Chrome-compatible text pixel path only for normal system font fixtures":
        val renderer = BrowserRenderer.create(160, 120)
        val normal_html = "<div style=\"width: 120px; height: 40px; background-color: #e0f2fe; font-family: system\">Google search deterministic compatibility fixture</div>"
        val mono_html = "<div style=\"width: 120px; height: 40px; background-color: #e0f2fe; font-family: monospace\">Google search deterministic compatibility fixture</div>"

        val normal_result = renderer.render_html_to_pixels(normal_html)
        val mono_result = renderer.render_html_to_pixels(mono_html)

        expect (normal_result.warnings).contains("html_fast_famous_site_corpus_pixel_path")
        expect (mono_result.warnings).contains("html_fast_fill_pixel_path")

    it "SFFI TTF renderer exposes horizontal line metrics":
        var renderer = _chrome_test_font_renderer()

        expect renderer.horizontal_line_metric(16, 0) > 0
        expect renderer.horizontal_line_metric(16, 1) < 0
        expect renderer.horizontal_line_metric(16, 3) > 0
        expect renderer.horizontal_line_metric(0, 0) == 0

    it "SFFI TTF renderer exposes wrapped glyph layout positions":
        var renderer = _chrome_test_font_renderer()

        val glyphs = renderer.layout_text("Google search deterministic compatibility fixture", 16, 112)
        expect glyphs.len() > 40
        expect glyphs[0].codepoint == 71
        expect glyphs[0].x == 0
        expect glyphs[0].y == 4
        expect glyphs[14].x == 0
        expect glyphs[14].y > glyphs[0].y

    it "SFFI TTF glyph bearing_y exposes hinted bitmap bottom offset":
        var renderer = _chrome_test_font_renderer()

        val glyph = renderer.get_glyph(71, 16)
        expect glyph.width > 0
        expect glyph.height > 0
        expect glyph.bearing_x == 0
        expect glyph.bearing_y == 0

    it "SFFI TTF renderer exposes RGB subpixel glyph coverage":
        var renderer = _chrome_test_font_renderer()

        val glyph = renderer.rasterize_subpixel(71, 16)
        expect glyph != nil == true
        if glyph != nil:
            expect glyph.width > 0
            expect glyph.height > 0
            expect glyph.pixels.len() == glyph.width * glyph.height * 3

    it "documents the current corpus line-width mismatch against Chrome metrics":
        var renderer = _chrome_test_font_renderer()

        expect renderer.measure_text_width("Google search", 16) < 121
        expect renderer.measure_text_width("Google Translate", 16) > 100
        expect renderer.measure_text_width("Google Translate", 16) < 121
        expect renderer.measure_text_width("Quora productivity", 16) > 100
        expect renderer.measure_text_width("Quora productivity", 16) < 121

    it "layout_text increases height when narrow width forces wrapping":
        val parent_style = be_default_style()
        parent_style.font_size = 16
        val node = BeDomNode.text("hello world")

        val wide = layout_node(node, _container(200, 40), parent_style)
        val narrow = layout_node(node, _container(24, 40), parent_style)

        expect layout_get_height(narrow) > layout_get_height(wide) == true

    it "paint_layout_box uses line width for text decoration fallback":
        val node = BeDomNode.text("iii")
        node.set_style("font-size", "16px")
        node.set_style("text-decoration", "underline")
        node.set_style("color", "#FFFFFFFF")

        val box = BeLayoutBox(
            x: 0, y: 0, width: 0, height: 16,
            content_x: 0, content_y: 0,
            content_width: 0, content_height: 16,
            node: node, children: []
        )

        val cmds = paint_layout_box(box, [])
        expect cmds.len() == 2

        expect cmds[1].width == 24

    it "paint_layout_box emits multiple text commands for wrapped text":
        val node = BeDomNode.text("hello world")
        node.set_style("font-size", "16px")
        node.set_style("color", "#FFFFFFFF")

        val box = BeLayoutBox(
            x: 0, y: 0, width: 24, height: 32,
            content_x: 0, content_y: 0,
            content_width: 24, content_height: 32,
            node: node, children: []
        )

        val cmds = paint_layout_box(box, [])
        expect cmds.len() > 1 == true
        expect cmds[0].kind == "text"
        expect cmds[1].kind == "text"
        expect cmds[1].y > cmds[0].y == true

    it "paint_layout_box emits text decoration per wrapped line":
        val node = BeDomNode.text("hello world")
        node.set_style("font-size", "16px")
        node.set_style("text-decoration", "underline")
        node.set_style("color", "#FFFFFFFF")

        val box = BeLayoutBox(
            x: 0, y: 0, width: 24, height: 32,
            content_x: 0, content_y: 0,
            content_width: 24, content_height: 32,
            node: node, children: []
        )

        val cmds = paint_layout_box(box, [])
        expect cmds.len() > 3 == true
        expect cmds[0].kind == "text"
        expect cmds[1].kind == "rect"
        expect cmds[2].kind == "text"
        expect cmds[3].kind == "rect"

    it "paint_layout_box emits separate text commands for explicit newlines":
        val node = BeDomNode.text("alpha\nbeta")
        node.set_style("font-size", "16px")
        node.set_style("color", "#FFFFFFFF")

        val box = BeLayoutBox(
            x: 0, y: 0, width: 160, height: 40,
            content_x: 0, content_y: 0,
            content_width: 160, content_height: 40,
            node: node, children: []
        )

        val cmds = paint_layout_box(box, [])
        expect cmds.len() == 2
        expect cmds[0].kind == "text"
        expect cmds[0].text_val == "alpha"
        expect cmds[1].kind == "text"
        expect cmds[1].text_val == "beta"
        expect cmds[1].y > cmds[0].y == true