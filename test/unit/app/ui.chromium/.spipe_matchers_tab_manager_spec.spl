# Feature: Chromium Shell Tab Manager (V3, Row 5 — M6)
# Category: UI Components
# Status: Implemented
#
# Compile-only smoke spec. Verifies the `TabManager` data structure
# (multi-window / tabs support) can create, count, switch between, and
# close tabs without panicking. No winit / FFI / compositor bring-up —
# the manager is a pure in-memory collection.

use app.ui.chromium.tab_manager.{
    BrowserTab,
    TabManager,
    DEFAULT_TAB_WIDTH,
    DEFAULT_TAB_HEIGHT
}

# =========================================================================
# Test Group 1: Construction and new_tab
# =========================================================================

describe "Chromium TabManager — construction":

    it "starts empty with no active tab":
        var mgr = TabManager.new()
        expect mgr.is_empty()
        expect mgr.count() == 0
        expect mgr.active_index_of() == -1

    it "new_tab assigns monotonically increasing ids":
        var mgr = TabManager.new()
        val id_a = mgr.new_tab("about:blank")
        val id_b = mgr.new_tab("about:home")
        expect id_a < id_b
        expect mgr.count() == 2

    it "new_tab promotes the freshly created tab to active":
        var mgr = TabManager.new()
        mgr.new_tab("first")
        mgr.new_tab("second")
        expect mgr.active_index_of() == 1
        expect mgr.active_tab().title == "second"

    it "new_tab uses the default render target size":
        var mgr = TabManager.new()
        mgr.new_tab("sized")
        val t = mgr.active_tab()
        expect t.width == DEFAULT_TAB_WIDTH
        expect t.height == DEFAULT_TAB_HEIGHT
        expect t.pixel_count() == DEFAULT_TAB_WIDTH * DEFAULT_TAB_HEIGHT

# =========================================================================
# Test Group 2: switch_to / switch_to_id
# =========================================================================

describe "Chromium TabManager — switching":

    it "switch_to changes the active index":
        var mgr = TabManager.new()
        mgr.new_tab("a")
        mgr.new_tab("b")
        mgr.new_tab("c")
        val ok = mgr.switch_to(0)
        expect ok
        expect mgr.active_index_of() == 0
        expect mgr.active_tab().title == "a"

    it "switch_to rejects out-of-range indices":
        var mgr = TabManager.new()
        mgr.new_tab("only")
        val ok = mgr.switch_to(5)
        expect not ok
        expect mgr.active_index_of() == 0

    it "switch_to_id focuses the tab with the given id":
        var mgr = TabManager.new()
        val id_a = mgr.new_tab("a")
        val id_b = mgr.new_tab("b")
        val ok = mgr.switch_to_id(id_a)
        expect ok
        expect mgr.active_tab().id == id_a

# =========================================================================
# Test Group 3: close_tab
# =========================================================================

describe "Chromium TabManager — closing":

    it "close_tab removes a tab and leaves siblings intact":
        var mgr = TabManager.new()
        mgr.new_tab("a")
        mgr.new_tab("b")
        mgr.new_tab("c")
        val ok = mgr.close_tab(1)
        expect ok
        expect mgr.count() == 2
        expect mgr.tab_at(0).title == "a"
        expect mgr.tab_at(1).title == "c"

    it "closing a tab before the active index shifts active down":
        var mgr = TabManager.new()
        mgr.new_tab("a")
        mgr.new_tab("b")
        mgr.new_tab("c")
        mgr.switch_to(2)
        expect mgr.active_index_of() == 2
        mgr.close_tab(0)
        expect mgr.active_index_of() == 1
        expect mgr.active_tab().title == "c"

    it "closing the active last tab falls back to the previous one":
        var mgr = TabManager.new()
        mgr.new_tab("a")
        mgr.new_tab("b")
        mgr.close_tab(1)
        expect mgr.count() == 1
        expect mgr.active_index_of() == 0
        expect mgr.active_tab().title == "a"

    it "closing the sole remaining tab clears the active index":
        var mgr = TabManager.new()
        mgr.new_tab("a")
        mgr.close_tab(0)
        expect mgr.is_empty()
        expect mgr.active_index_of() == -1

    it "close_all empties the manager":
        var mgr = TabManager.new()
        mgr.new_tab("a")
        mgr.new_tab("b")
        mgr.new_tab("c")
        mgr.close_all()
        expect mgr.is_empty()
        expect mgr.count() == 0
        expect mgr.active_index_of() == -1

# =========================================================================
# Test Group 4: BrowserTab state
# =========================================================================

describe "Chromium BrowserTab — per-tab state":

    it "tab starts dirty and clear_dirty resets the flag":
        val tab = BrowserTab.new(42, "fresh", 64, 48)
        expect tab.dirty
        tab.clear_dirty()
        expect not tab.dirty
        tab.mark_dirty()
        expect tab.dirty

    it "set_title updates the visible title":
        val tab = BrowserTab.new(1, "old", 32, 16)
        tab.set_title("new")
        expect tab.title == "new"

    it "set_z_order records the stacking value":
        val tab = BrowserTab.new(1, "z", 32, 16)
        tab.set_z_order(7)
        expect tab.z_order == 7

    it "close flips the closed flag without removing siblings":
        var mgr = TabManager.new()
        mgr.new_tab("a")
        mgr.new_tab("b")
        val t = mgr.tab_at(0)
        t.close()
        expect t.is_closed()
        expect mgr.count() == 2