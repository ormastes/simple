# MDSOC Statistics Integration Tests
# Tests coverage statistics for MDSOC CapsuleVisibility.Public exports

use app.doc.public_check.statistics.{
    MdsocCoverageStats,
    calculate_mdsoc_coverage,
    format_mdsoc_report,
    mdsoc_stats_to_json
}

describe "MDSOC Coverage Statistics":
    it "calculates coverage for Public exports":
        val public_exports = ["sort", "map", "filter"]
        val documented = ["sort", "map"]
        val violations = ["filter: missing documentation"]

        val stats = calculate_mdsoc_coverage(
            "array_capsule",
            public_exports,
            documented,
            violations
        )

        expect stats.capsule_name == "array_capsule"
        expect stats.total_public_exports == 3
        expect stats.documented_public_exports == 2
        expect stats.undocumented_public_exports == 1

        # Coverage should be 66.6% (2/3)
        expect stats.coverage_percentage > 66.0
        expect stats.coverage_percentage < 67.0

    it "handles 100% coverage":
        val public_exports = ["sort", "map"]
        val documented = ["sort", "map"]
        val violations: [text] = []

        val stats = calculate_mdsoc_coverage(
            "perfect_capsule",
            public_exports,
            documented,
            violations
        )

        expect stats.coverage_percentage == 100.0
        expect stats.undocumented_public_exports == 0
        expect stats.doc_violations.len() == 0

    it "handles 0% coverage":
        val public_exports = ["sort", "map", "filter"]
        val documented: [text] = []
        val violations = [
            "sort: missing documentation",
            "map: missing documentation",
            "filter: missing documentation"
        ]

        val stats = calculate_mdsoc_coverage(
            "bad_capsule",
            public_exports,
            documented,
            violations
        )

        expect stats.coverage_percentage == 0.0
        expect stats.undocumented_public_exports == 3
        expect stats.doc_violations.len() == 3

    it "handles empty capsule":
        val public_exports: [text] = []
        val documented: [text] = []
        val violations: [text] = []

        val stats = calculate_mdsoc_coverage(
            "empty_capsule",
            public_exports,
            documented,
            violations
        )

        expect stats.total_public_exports == 0
        expect stats.coverage_percentage == 0.0

    it "formats MDSOC report":
        val public_exports = ["sort", "map"]
        val documented = ["sort"]
        val violations = ["map: missing documentation at src/array/mod.spl:42"]

        val stats = calculate_mdsoc_coverage(
            "array_capsule",
            public_exports,
            documented,
            violations
        )

        val report = format_mdsoc_report(stats)

        expect (report).contains("array_capsule")
        expect (report).contains("Public exports:")
        expect (report).contains("2")
        expect (report).contains("Documented:")
        expect (report).contains("1")
        expect (report).contains("Undocumented:")
        expect (report).contains("1")
        expect (report).contains("Documentation Violations:")
        expect (report).contains("map: missing documentation")

    it "converts MDSOC stats to JSON":
        val public_exports = ["sort"]
        val documented = ["sort"]
        val violations: [text] = []

        val stats = calculate_mdsoc_coverage(
            "test_capsule",
            public_exports,
            documented,
            violations
        )

        val json = mdsoc_stats_to_json(stats)

        expect (json).contains("capsule_name")
        expect (json).contains("test_capsule")
        expect (json).contains("total_public_exports")
        expect (json).contains("1")
        expect (json).contains("coverage_percentage")
        expect (json).contains("100")
        expect (json).contains("violations")

    it "includes violations in JSON":
        val public_exports = ["a", "b"]
        val documented: [text] = []
        val violations = ["a: missing docs", "b: missing docs"]

        val stats = calculate_mdsoc_coverage(
            "test",
            public_exports,
            documented,
            violations
        )

        val json = mdsoc_stats_to_json(stats)

        expect (json).contains("a: missing docs")
        expect (json).contains("b: missing docs")