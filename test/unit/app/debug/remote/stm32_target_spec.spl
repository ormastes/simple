# STM32 Target Tests
# Tests Stm32H7Target and Stm32WbTarget defaults, serials, ports.
# Uses local copies to avoid import issues.
# STM32 boards connect via their built-in ST-LINKs, not T32.

# --- Local copies ---

class Stm32H7Target:
    stlink_serial: text
    openocd_cfg: text
    gdb_port: i32
    core_name: text
    hw_bp: i32

impl Stm32H7Target:
    static fn default() -> Stm32H7Target:
        Stm32H7Target(
            stlink_serial: "002600213137510833333639",
            openocd_cfg: "board/stm32h7x3i_eval.cfg",
            gdb_port: 3333,
            core_name: "Cortex-M7",
            hw_bp: 6
        )

    fn name() -> text:
        "STM32H7 (Cortex-M7)"

class Stm32WbTarget:
    stlink_serial: text
    openocd_cfg: text
    gdb_port: i32
    core_name: text
    hw_bp: i32

impl Stm32WbTarget:
    static fn default() -> Stm32WbTarget:
        Stm32WbTarget(
            stlink_serial: "0671FF555755846687041216",
            openocd_cfg: "board/stm32wb5x_nucleo.cfg",
            gdb_port: 3334,
            core_name: "Cortex-M4",
            hw_bp: 4
        )

    fn name() -> text:
        "STM32WB (Cortex-M4)"

# --- Tests ---

describe "Stm32H7Target defaults":
    it "has correct name":
        val t = Stm32H7Target.default()
        expect(t.name()).to_equal("STM32H7 (Cortex-M7)")

    it "has correct ST-LINK serial":
        val t = Stm32H7Target.default()
        expect(t.stlink_serial).to_equal("002600213137510833333639")

    it "has correct OpenOCD config":
        val t = Stm32H7Target.default()
        expect(t.openocd_cfg).to_equal("board/stm32h7x3i_eval.cfg")

    it "has GDB port 3333":
        val t = Stm32H7Target.default()
        expect(t.gdb_port).to_equal(3333)

describe "Stm32WbTarget defaults":
    it "has correct name":
        val t = Stm32WbTarget.default()
        expect(t.name()).to_equal("STM32WB (Cortex-M4)")

    it "has correct ST-LINK serial":
        val t = Stm32WbTarget.default()
        expect(t.stlink_serial).to_equal("0671FF555755846687041216")

    it "has correct OpenOCD config":
        val t = Stm32WbTarget.default()
        expect(t.openocd_cfg).to_equal("board/stm32wb5x_nucleo.cfg")

    it "has GDB port 3334":
        val t = Stm32WbTarget.default()
        expect(t.gdb_port).to_equal(3334)
