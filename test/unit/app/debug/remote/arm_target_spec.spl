# ARM Cortex-M Target Tests
# Tests ArmCortexMTarget register layout, HW breakpoint counts, and thumb BKPT.
# Uses local copy to avoid import issues in interpreter mode.

# --- Local copies ---

class ArmCortexMTarget:
    _registers: [text]
    _hw_bp_count: i32
    _hw_wp_count: i32
    _core_name: text

impl ArmCortexMTarget:
    static fn cortex_m7() -> ArmCortexMTarget:
        ArmCortexMTarget(
            _registers: arm_regs(),
            _hw_bp_count: 6,
            _hw_wp_count: 4,
            _core_name: "Cortex-M7"
        )

    static fn cortex_m4() -> ArmCortexMTarget:
        ArmCortexMTarget(
            _registers: arm_regs(),
            _hw_bp_count: 4,
            _hw_wp_count: 4,
            _core_name: "Cortex-M4"
        )

    fn name() -> text:
        "ARM {self._core_name}"

    fn core_name() -> text:
        self._core_name

    fn register_count() -> i32:
        val regs = self._registers
        regs.len()

    fn register_name(index: i32) -> text:
        val regs = self._registers
        if index >= 0 and index < regs.len():
            regs[index]
        else:
            "unknown"

    fn register_index(name: text) -> i32:
        val regs = self._registers
        var i = 0
        while i < regs.len():
            if regs[i] == name:
                return i
            i = i + 1
        -1

    fn register_size(index: i32) -> i32:
        4

    fn arg_registers() -> [i32]:
        [0, 1, 2, 3]

    fn callee_saved_registers() -> [i32]:
        [4, 5, 6, 7, 8, 9, 10, 11]

    fn pc_register_index() -> i32:
        15

    fn sp_register_index() -> i32:
        13

    fn fp_register_index() -> i32:
        11

    fn return_register_index() -> i32:
        0

    fn hw_breakpoint_count() -> i32:
        self._hw_bp_count

    fn hw_watchpoint_count() -> i32:
        self._hw_wp_count

    fn supports_single_step() -> bool:
        true

    fn breakpoint_instruction() -> [i32]:
        [0x00, 0xBE]

    fn word_size() -> i32:
        4

fn arm_regs() -> [text]:
    [
        "r0", "r1", "r2", "r3", "r4", "r5", "r6", "r7",
        "r8", "r9", "r10", "r11", "r12", "sp", "lr", "pc",
        "xPSR", "CONTROL", "PRIMASK", "FAULTMASK", "BASEPRI"
    ]

# --- Tests ---

describe "ArmCortexMTarget Cortex-M7":
    it "has correct name":
        val t = ArmCortexMTarget.cortex_m7()
        expect(t.name()).to_equal("ARM Cortex-M7")

    it "has correct core name":
        val t = ArmCortexMTarget.cortex_m7()
        expect(t.core_name()).to_equal("Cortex-M7")

    it "has 21 registers":
        val t = ArmCortexMTarget.cortex_m7()
        expect(t.register_count()).to_equal(21)

    it "has 6 HW breakpoints for M7":
        val t = ArmCortexMTarget.cortex_m7()
        expect(t.hw_breakpoint_count()).to_equal(6)

    it "has 4 HW watchpoints":
        val t = ArmCortexMTarget.cortex_m7()
        expect(t.hw_watchpoint_count()).to_equal(4)

describe "ArmCortexMTarget Cortex-M4":
    it "has correct name":
        val t = ArmCortexMTarget.cortex_m4()
        expect(t.name()).to_equal("ARM Cortex-M4")

    it "has 4 HW breakpoints for M4":
        val t = ArmCortexMTarget.cortex_m4()
        expect(t.hw_breakpoint_count()).to_equal(4)

describe "ArmCortexMTarget register lookups":
    it "r0 is index 0":
        val t = ArmCortexMTarget.cortex_m7()
        expect(t.register_index("r0")).to_equal(0)

    it "pc is index 15":
        val t = ArmCortexMTarget.cortex_m7()
        expect(t.register_index("pc")).to_equal(15)

    it "sp is index 13":
        val t = ArmCortexMTarget.cortex_m7()
        expect(t.register_index("sp")).to_equal(13)

    it "xPSR is index 16":
        val t = ArmCortexMTarget.cortex_m7()
        expect(t.register_index("xPSR")).to_equal(16)

    it "unknown register returns -1":
        val t = ArmCortexMTarget.cortex_m7()
        expect(t.register_index("nonexistent")).to_equal(-1)

    it "register_name at 0 is r0":
        val t = ArmCortexMTarget.cortex_m7()
        expect(t.register_name(0)).to_equal("r0")

    it "register_name out of bounds is unknown":
        val t = ArmCortexMTarget.cortex_m7()
        expect(t.register_name(100)).to_equal("unknown")

describe "ArmCortexMTarget breakpoint":
    it "thumb BKPT instruction is 0x00 0xBE":
        val t = ArmCortexMTarget.cortex_m7()
        val bkpt = t.breakpoint_instruction()
        expect(bkpt.len()).to_equal(2)
        expect(bkpt[0]).to_equal(0)
        expect(bkpt[1]).to_equal(190)

    it "word size is 4":
        val t = ArmCortexMTarget.cortex_m7()
        expect(t.word_size()).to_equal(4)

    it "supports single step":
        val t = ArmCortexMTarget.cortex_m7()
        expect(t.supports_single_step()).to_equal(true)
