# Remote ARM Backend Tests
# Tests RemoteArmBackend factory methods, target architecture.

# --- Local copies ---

class ArmBackendInfo:
    name: text
    target_core: text
    has_gdb: bool
    has_t32: bool
    has_openocd: bool
    has_t32_gdb: bool

impl ArmBackendInfo:
    static fn openocd_stm32h7() -> ArmBackendInfo:
        ArmBackendInfo(name: "remote-arm", target_core: "Cortex-M7", has_gdb: false, has_t32: false, has_openocd: true, has_t32_gdb: false)

    static fn openocd_stm32wb() -> ArmBackendInfo:
        ArmBackendInfo(name: "remote-arm", target_core: "Cortex-M4", has_gdb: false, has_t32: false, has_openocd: true, has_t32_gdb: false)

    static fn trace32_native() -> ArmBackendInfo:
        ArmBackendInfo(name: "remote-arm", target_core: "Cortex-M7", has_gdb: false, has_t32: true, has_openocd: false, has_t32_gdb: false)

    static fn trace32_gdb_bridge() -> ArmBackendInfo:
        ArmBackendInfo(name: "remote-arm", target_core: "Cortex-M7", has_gdb: false, has_t32: false, has_openocd: false, has_t32_gdb: true)

    static fn gdb_only() -> ArmBackendInfo:
        ArmBackendInfo(name: "remote-arm", target_core: "Cortex-M4", has_gdb: true, has_t32: false, has_openocd: false, has_t32_gdb: false)

# --- Tests ---

describe "RemoteArmBackend factory methods":
    it "openocd_stm32h7 has openocd connection":
        val info = ArmBackendInfo.openocd_stm32h7()
        expect(info.has_openocd).to_equal(true)
        expect(info.has_gdb).to_equal(false)
        expect(info.has_t32).to_equal(false)

    it "openocd_stm32h7 targets Cortex-M7":
        val info = ArmBackendInfo.openocd_stm32h7()
        expect(info.target_core).to_equal("Cortex-M7")

    it "openocd_stm32wb targets Cortex-M4":
        val info = ArmBackendInfo.openocd_stm32wb()
        expect(info.target_core).to_equal("Cortex-M4")

    it "trace32_native has t32 connection":
        val info = ArmBackendInfo.trace32_native()
        expect(info.has_t32).to_equal(true)
        expect(info.has_openocd).to_equal(false)

    it "trace32_gdb_bridge has t32_gdb connection":
        val info = ArmBackendInfo.trace32_gdb_bridge()
        expect(info.has_t32_gdb).to_equal(true)
        expect(info.has_t32).to_equal(false)

    it "gdb_only has gdb connection":
        val info = ArmBackendInfo.gdb_only()
        expect(info.has_gdb).to_equal(true)
        expect(info.has_openocd).to_equal(false)

describe "RemoteArmBackend naming":
    it "all backends report remote-arm name":
        expect(ArmBackendInfo.openocd_stm32h7().name).to_equal("remote-arm")
        expect(ArmBackendInfo.trace32_native().name).to_equal("remote-arm")
        expect(ArmBackendInfo.gdb_only().name).to_equal("remote-arm")

    it "backend name is distinct from remote-riscv32":
        val arm_name = "remote-arm"
        val rv_name = "remote-riscv32"
        expect(arm_name != rv_name).to_equal(true)
