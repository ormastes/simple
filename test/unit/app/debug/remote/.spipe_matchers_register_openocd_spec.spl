# OpenOCD Feature Registration Tests
# Tests that OpenOCD features are registered at correct ranks.

# --- Local copies ---

class FeatureRank:
    static fn NATIVE() -> i32:
        0
    static fn BRIDGE() -> i32:
        1
    static fn EXTERNAL() -> i32:
        3
    static fn EMULATED() -> i32:
        4

class FeatureEntry:
    name: text
    rank: i32
    backend: text

# Simulates what register_openocd_features would register
fn openocd_registered_features() -> [FeatureEntry]:
    [
        FeatureEntry(name: "Halt", rank: 0, backend: "openocd"),
        FeatureEntry(name: "Resume", rank: 0, backend: "openocd"),
        FeatureEntry(name: "SingleStep", rank: 0, backend: "openocd"),
        FeatureEntry(name: "ReadMemory", rank: 0, backend: "openocd"),
        FeatureEntry(name: "SetBreakpoint", rank: 0, backend: "openocd"),
        FeatureEntry(name: "FlashProgram", rank: 0, backend: "openocd"),
        FeatureEntry(name: "SystemReset", rank: 0, backend: "openocd"),
        FeatureEntry(name: "OpenocdMonitor", rank: 0, backend: "openocd")
    ]

# --- Tests ---

describe "OpenOCD feature registration":
    it "registers execution control at rank NATIVE":
        val features = openocd_registered_features()
        val halt = features[0]
        expect halt.name == "Halt"
        expect halt.rank == FeatureRank.NATIVE()

    it "registers memory ops at rank NATIVE":
        val features = openocd_registered_features()
        val mem = features[3]
        expect mem.name == "ReadMemory"
        expect mem.rank == 0

    it "registers FlashProgram at rank NATIVE":
        val features = openocd_registered_features()
        val flash = features[5]
        expect flash.name == "FlashProgram"
        expect flash.rank == 0

    it "registers SystemReset at rank NATIVE":
        val features = openocd_registered_features()
        val reset = features[6]
        expect reset.name == "SystemReset"
        expect reset.rank == 0

    it "registers OpenocdMonitor at rank NATIVE":
        val features = openocd_registered_features()
        val mon = features[7]
        expect mon.name == "OpenocdMonitor"
        expect mon.rank == 0

    it "all features use openocd backend name":
        val features = openocd_registered_features()
        for f in features:
            expect f.backend == "openocd"