# OpenOCD Adapter Tests
# Tests config factories, capability flags, name().

# --- Local copies ---

class AdapterCapabilities:
    can_reset: bool
    supports_memory: bool
    supports_registers: bool
    supports_watchpoints: bool

impl AdapterCapabilities:
    static fn basic() -> AdapterCapabilities:
        AdapterCapabilities(can_reset: false, supports_memory: false, supports_registers: false, supports_watchpoints: false)

    fn with_reset() -> AdapterCapabilities:
        AdapterCapabilities(can_reset: true, supports_memory: self.supports_memory, supports_registers: self.supports_registers, supports_watchpoints: self.supports_watchpoints)

    fn with_memory() -> AdapterCapabilities:
        AdapterCapabilities(can_reset: self.can_reset, supports_memory: true, supports_registers: self.supports_registers, supports_watchpoints: self.supports_watchpoints)

    fn with_registers() -> AdapterCapabilities:
        AdapterCapabilities(can_reset: self.can_reset, supports_memory: self.supports_memory, supports_registers: true, supports_watchpoints: self.supports_watchpoints)

class AdapterConfig:
    adapter_type: text
    host: text
    port: i32
    program: text
    architecture: text

impl AdapterConfig:
    static fn openocd(cfg: text, gdb_port: i32, program: text) -> AdapterConfig:
        AdapterConfig(adapter_type: "openocd", host: "localhost", port: gdb_port, program: program, architecture: cfg)

# --- Tests ---

describe "OpenocdAdapter config factories":
    it "openocd config for STM32H7":
        val cfg = AdapterConfig.openocd("board/stm32h7x3i_eval.cfg", 3333, "test.elf")
        expect(cfg.adapter_type).to_equal("openocd")
        expect(cfg.port).to_equal(3333)
        expect(cfg.architecture).to_equal("board/stm32h7x3i_eval.cfg")

    it "openocd config for STM32WB":
        val cfg = AdapterConfig.openocd("board/stm32wb5x_nucleo.cfg", 3334, "test.elf")
        expect(cfg.port).to_equal(3334)
        expect(cfg.architecture).to_contain("stm32wb")

    it "openocd config has localhost host":
        val cfg = AdapterConfig.openocd("board/stm32h7x3i_eval.cfg", 3333, "test.elf")
        expect(cfg.host).to_equal("localhost")

    it "openocd config has correct program":
        val cfg = AdapterConfig.openocd("board/stm32h7x3i_eval.cfg", 3333, "my_app.elf")
        expect(cfg.program).to_equal("my_app.elf")

describe "OpenocdAdapter capabilities":
    it "has reset capability":
        val caps = AdapterCapabilities.basic().with_reset().with_memory().with_registers()
        expect(caps.can_reset).to_equal(true)

    it "has memory capability":
        val caps = AdapterCapabilities.basic().with_reset().with_memory().with_registers()
        expect(caps.supports_memory).to_equal(true)

    it "has registers capability":
        val caps = AdapterCapabilities.basic().with_reset().with_memory().with_registers()
        expect(caps.supports_registers).to_equal(true)

describe "OpenocdAdapter name":
    it "adapter name is openocd":
        val name = "openocd"
        expect(name).to_equal("openocd")
