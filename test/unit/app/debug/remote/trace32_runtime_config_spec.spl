use app.debug.remote.protocol.trace32.{Trace32Client}

describe "Trace32 runtime command config":
    it "builds basic t32rem arguments without protocol":
        val args = Trace32Client.command_args("localhost", 20000, "", "PING")
        expect(args).to_equal(["localhost", "port=20000", "PING"])

    it "includes protocol override when provided":
        val args = Trace32Client.command_args("localhost", 20000, "NETASSIST", "PING")
        expect(args).to_equal(["localhost", "port=20000", "protocol=NETASSIST", "PING"])

    it "keeps hostile values in separate argv elements":
        val args = Trace32Client.command_args(
            "host; touch /tmp/pwned", 20000, "NETTCP && false",
            "SETUP.API.GDB.Enable /PORT 2331; false"
        )
        expect(args).to_equal([
            "host; touch /tmp/pwned", "port=20000", "protocol=NETTCP && false",
            "SETUP.API.GDB.Enable /PORT 2331; false"
        ])

describe "Trace32 wait timing":
    it "uses at least one second for zero timeout":
        expect(Trace32Client.wait_seconds(0)).to_equal(1)

    it "rounds sub-second waits up to one second":
        expect(Trace32Client.wait_seconds(500)).to_equal(1)

    it "uses whole seconds for larger waits":
        expect(Trace32Client.wait_seconds(5000)).to_equal(5)
