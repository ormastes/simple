# T32 GDB Feature Registration Tests
# Tests that T32 GDB bridge features are registered at correct ranks.

# --- Local copies ---

class FeatureEntry:
    name: text
    rank: i32
    backend: text

fn t32gdb_registered_features() -> [FeatureEntry]:
    [
        FeatureEntry(name: "Halt", rank: 0, backend: "t32-gdb"),
        FeatureEntry(name: "Resume", rank: 0, backend: "t32-gdb"),
        FeatureEntry(name: "SingleStep", rank: 0, backend: "t32-gdb"),
        FeatureEntry(name: "ReadMemory", rank: 0, backend: "t32-gdb"),
        FeatureEntry(name: "SetBreakpoint", rank: 0, backend: "t32-gdb"),
        FeatureEntry(name: "FlashProgram", rank: 0, backend: "t32-gdb"),
        FeatureEntry(name: "SystemReset", rank: 0, backend: "t32-gdb"),
        FeatureEntry(name: "TraceCapture", rank: 0, backend: "t32-gdb"),
        FeatureEntry(name: "CoverageCollect", rank: 0, backend: "t32-gdb"),
        FeatureEntry(name: "PracticeScript", rank: 0, backend: "t32-gdb")
    ]

# --- Tests ---

describe "T32 GDB feature registration":
    it "registers execution control at rank NATIVE":
        val features = t32gdb_registered_features()
        expect(features[0].name).to_equal("Halt")
        expect(features[0].rank).to_equal(0)

    it "registers TraceCapture at rank NATIVE":
        val features = t32gdb_registered_features()
        expect(features[7].name).to_equal("TraceCapture")
        expect(features[7].rank).to_equal(0)

    it "registers CoverageCollect at rank NATIVE":
        val features = t32gdb_registered_features()
        expect(features[8].name).to_equal("CoverageCollect")
        expect(features[8].rank).to_equal(0)

    it "registers PracticeScript at rank NATIVE":
        val features = t32gdb_registered_features()
        expect(features[9].name).to_equal("PracticeScript")
        expect(features[9].rank).to_equal(0)

    it "all features use t32-gdb backend name":
        val features = t32gdb_registered_features()
        for f in features:
            expect(f.backend).to_equal("t32-gdb")

    it "has 10 registered features":
        val features = t32gdb_registered_features()
        expect(features.len()).to_equal(10)
