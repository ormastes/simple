# Tests for LSP JSON helpers (lsp_json.spl)

use app.lsp.lsp_json.{extract_field, extract_id, extract_nested, make_json_result, escape_json, js, jp, jo1, jo2, Q, LB, RB, SB_L, SB_R}

describe "LSP JSON helpers":
    describe "escape_json":
        it "escapes quotes":
            val result = escape_json("hello \"world\"")
            expect (result).contains("\\\"")

        it "escapes newlines":
            val result = escape_json("line1\nline2")
            expect (result).contains("\\n")

        it "passes through plain text":
            val result = escape_json("hello world")
            expect result == "hello world"

    describe "extract_field":
        it "extracts string field":
            val json = "{\"name\":\"Alice\",\"age\":30}"
            val result = extract_field(json, "name")
            expect result == "Alice"

        it "extracts numeric field":
            val json = "{\"name\":\"Alice\",\"age\":30}"
            val result = extract_field(json, "age")
            expect result == "30"

        it "returns empty for missing field":
            val json = "{\"name\":\"Alice\"}"
            val result = extract_field(json, "missing")
            expect result == ""

    describe "extract_id":
        it "extracts numeric id":
            val json = "{\"jsonrpc\":\"2.0\",\"id\":42,\"method\":\"initialize\"}"
            val result = extract_id(json)
            expect result == "42"

        it "extracts string id":
            val json = "{\"jsonrpc\":\"2.0\",\"id\":\"abc\",\"method\":\"test\"}"
            val result = extract_id(json)
            expect result == "\"abc\""

    describe "extract_nested":
        it "extracts field from params":
            val json = "{\"method\":\"hover\",\"params\":{\"textDocument\":{\"uri\":\"file:///test.spl\"},\"position\":{\"line\":5}}}"
            val result = extract_nested(json, "line")
            expect result == "5"

    describe "make_json_result":
        it "creates valid JSON-RPC response":
            val result = make_json_result("1", "null")
            expect (result).contains("jsonrpc")
            expect (result).contains("2.0")
            expect (result).contains("\"id\":1")
            expect (result).contains("\"result\":null")

    describe "JSON builders":
        it "js wraps in quotes":
            val result = js("hello")
            expect result == "\"hello\""

        it "jp creates key-value pair":
            val result = jp("name", js("Alice"))
            expect result == "\"name\":\"Alice\""

        it "jo1 wraps single property":
            val result = jo1(jp("x", "1"))
            expect result == "{\"x\":1}"