# Editor extension discovery contract.

use std.spec

extern fn rt_file_read_text(path: text) -> text

fn read_text(path: text) -> text:
    rt_file_read_text(path) ?? ""

describe "editor extension discovery contract":

    it "walks configured roots and indexes extension manifests":
        val host = read_text("src/lib/editor/extensions/host.spl")
        expect(host.contains("me discover_extensions(roots: [text]) -> i64")).to_equal(true)
        expect(host.contains("rt_dir_walk(root)")).to_equal(true)
        expect(host.contains("file.ends_with(\"/extension.sdn\")")).to_equal(true)
        expect(host.contains("file.slice(0, file.len() - 14)")).to_equal(true)
        expect(host.contains("me.index_extension(extension_dir)")).to_equal(true)

    it "keeps built-in extension modules in the canonical extension tree":
        val graph = read_text("src/lib/editor/extensions/builtin/graph_language.spl")
        expect(graph.contains("fn graph_language_manifest() -> ExtensionManifest")).to_equal(true)
        expect(graph.contains("sdn-graph-language")).to_equal(true)

    it "loads extension roots during editor controller startup":
        val controller = read_text("src/app/editor/editor_controller.spl")
        val roots = read_text("src/app/editor/editor_extension_roots.spl")
        expect(controller.contains("host.discover_extensions(editor_extension_roots())")).to_equal(true)
        expect(roots.contains("SIMPLE_EDITOR_EXTENSION_PATH")).to_equal(true)
        expect(roots.contains(".simple/editor/extensions")).to_equal(true)
        expect(roots.contains("/usr/share/simple/editor/extensions")).to_equal(true)
