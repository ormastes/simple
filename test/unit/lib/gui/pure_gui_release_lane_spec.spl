# Pure GUI release-lane dependency guard

use std.spipe.*

extern fn rt_file_read_text(path: text) -> text

fn _source(path: text) -> text:
    rt_file_read_text(path)

fn _has_forbidden_release_dependency(source: text) -> bool:
    source.contains("rt_gui") or
        source.contains("rt_winit") or
        source.contains("rt_sdl") or
        source.contains("rt_cocoa") or
        source.contains("HostCompositor") or
        source.contains("SimpleWebRenderer") or
        source.contains("WebRenderRequest")

describe "pure GUI release lane":
    it "keeps std.gui public surface free of WM, web renderer, and native GUI runtime deps":
        val source = _source("src/lib/gui/__init__.spl")
        expect(_has_forbidden_release_dependency(source)).to_equal(false)

    it "keeps pure GUI command boundary free of WM, web renderer, and native GUI runtime deps":
        val source = _source("src/lib/gui/pure_core.spl")
        expect(_has_forbidden_release_dependency(source)).to_equal(false)

    it "keeps pure GUI SMF dynlib perf contract free of WM, web renderer, and native GUI runtime deps":
        val source = _source("src/lib/gui/pure_smf_dynlib_perf.spl")
        expect(_has_forbidden_release_dependency(source)).to_equal(false)

    it "keeps BrowserWindow entity free of native GUI runtime deps":
        val source = _source("src/lib/gui/entity/browser_window.spl")
        expect(_has_forbidden_release_dependency(source)).to_equal(false)

    it "keeps Menu entity free of native GUI runtime deps":
        val source = _source("src/lib/gui/entity/menu.spl")
        expect(_has_forbidden_release_dependency(source)).to_equal(false)

    it "keeps IME entity free of native GUI runtime deps":
        val source = _source("src/lib/gui/entity/ime.spl")
        expect(_has_forbidden_release_dependency(source)).to_equal(false)

    it "keeps Printing entity free of native GUI runtime deps":
        val source = _source("src/lib/gui/entity/printing.spl")
        expect(_has_forbidden_release_dependency(source)).to_equal(false)
