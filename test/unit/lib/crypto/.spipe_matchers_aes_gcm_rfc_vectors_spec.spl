    [0xb5u8, 0x2cu8, 0x50u8, 0x5au8, 0x37u8, 0xd7u8, 0x8eu8, 0xdau8,
     0x5du8, 0xd3u8, 0x4fu8, 0x20u8, 0xc2u8, 0x25u8, 0x40u8, 0xeau8,
     0x1bu8, 0x58u8, 0x96u8, 0x3cu8, 0xf8u8, 0xe5u8, 0xbfu8, 0x8fu8,
     0xfau8, 0x85u8, 0xf9u8, 0xf2u8, 0x49u8, 0x25u8, 0x05u8, 0xb4u8]

fn _v1_nonce() -> [u8]:
    [0x51u8, 0x6cu8, 0x33u8, 0x92u8, 0x9du8, 0xf5u8, 0xa3u8, 0x28u8,
     0x4fu8, 0xf4u8, 0x63u8, 0xd7u8]

fn _v1_expected_tag() -> [u8]:
    [0xbdu8, 0xc1u8, 0xacu8, 0x88u8, 0x4du8, 0x33u8, 0x24u8, 0x57u8,
     0xa1u8, 0xd2u8, 0x66u8, 0x4fu8, 0x16u8, 0x8cu8, 0x76u8, 0xf0u8]

