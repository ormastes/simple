fn _v2_expected_tag() -> [u8]:
    [0x3eu8, 0x5du8, 0x48u8, 0x6au8, 0xa2u8, 0xe3u8, 0x0bu8, 0x22u8,
     0xe0u8, 0x40u8, 0xb8u8, 0x57u8, 0x23u8, 0xa0u8, 0x6eu8, 0x76u8]

# --- Vector V3: 16-byte plaintext, empty AAD ---
# Key:   31bdadd96698c204aa9ce1448ea94ae1fb4a9a0b3c9d773b51bb1822666b8f22
# Nonce: 0d18e06c7c725ac9e362e1ce
# PT:    2db5168e932556f8089a0622981d017d
# AAD:   (empty)
# CT:    fa4362189661d163fcd6a56d8bf0405a
# Tag:   d636ac1bbedd5cc3ee727dc2ab4a9489

fn _v3_key() -> [u8]:
    [0x31u8, 0xbdu8, 0xadu8, 0xd9u8, 0x66u8, 0x98u8, 0xc2u8, 0x04u8,
     0xaau8, 0x9cu8, 0xe1u8, 0x44u8, 0x8eu8, 0xa9u8, 0x4au8, 0xe1u8,
     0xfbu8, 0x4au8, 0x9au8, 0x0bu8, 0x3cu8, 0x9du8, 0x77u8, 0x3bu8,
     0x51u8, 0xbbu8, 0x18u8, 0x22u8, 0x66u8, 0x66u8, 0xb8u8, 0xf2u8]

fn _v3_nonce() -> [u8]:
    [0x0du8, 0x18u8, 0xe0u8, 0x6cu8, 0x7cu8, 0x72u8, 0x5au8, 0xc9u8,
     0xe3u8, 0x62u8, 0xe1u8, 0xceu8]

fn _v3_plaintext() -> [u8]:
    [0x2du8, 0xb5u8, 0x16u8, 0x8eu8, 0x93u8, 0x25u8, 0x56u8, 0xf8u8,
     0x08u8, 0x9au8, 0x06u8, 0x22u8, 0x98u8, 0x1du8, 0x01u8, 0x7du8]

fn _v3_expected_ct() -> [u8]:
    [0xfau8, 0x43u8, 0x62u8, 0x18u8, 0x96u8, 0x61u8, 0xd1u8, 0x63u8,
     0xfcu8, 0xd6u8, 0xa5u8, 0x6du8, 0x8bu8, 0xf0u8, 0x40u8, 0x5au8]

fn _v3_expected_tag() -> [u8]:
    [0xd6u8, 0x36u8, 0xacu8, 0x1bu8, 0xbeu8, 0xddu8, 0x5cu8, 0xc3u8,
     0xeeu8, 0x72u8, 0x7du8, 0xc2u8, 0xabu8, 0x4au8, 0x94u8, 0x89u8]

# --- Vector V4: 16-byte plaintext, 16-byte AAD ---
# Key:   a359b9584beec189527f8842dda6b6d4c6a5db2f889635715fa3bcd7967c0a71
# Nonce: 8616c4cde11b34a944caba32
# PT:    33a46b7539d64c6e1bdb91ba221e3007
# AAD:   e1796fca20cb3d3ab0ade69b2a18891e
# CT:    b0d316e95f3f3390ba10d0274965c62b
# Tag:   aeaedcf8a012cc32ef25a62790e9334c

fn _v4_key() -> [u8]:
    [0xa3u8, 0x59u8, 0xb9u8, 0x58u8, 0x4bu8, 0xeeu8, 0xc1u8, 0x89u8,
     0x52u8, 0x7fu8, 0x88u8, 0x42u8, 0xddu8, 0xa6u8, 0xb6u8, 0xd4u8,
     0xc6u8, 0xa5u8, 0xdbu8, 0x2fu8, 0x88u8, 0x96u8, 0x35u8, 0x71u8,
     0x5fu8, 0xa3u8, 0xbcu8, 0xd7u8, 0x96u8, 0x7cu8, 0x0au8, 0x71u8]

fn _v4_nonce() -> [u8]:
    [0x86u8, 0x16u8, 0xc4u8, 0xcdu8, 0xe1u8, 0x1bu8, 0x34u8, 0xa9u8,
     0x44u8, 0xcau8, 0xbau8, 0x32u8]

fn _v4_plaintext() -> [u8]:
    [0x33u8, 0xa4u8, 0x6bu8, 0x75u8, 0x39u8, 0xd6u8, 0x4cu8, 0x6eu8,
     0x1bu8, 0xdbu8, 0x91u8, 0xbau8, 0x22u8, 0x1eu8, 0x30u8, 0x07u8]

fn _v4_aad() -> [u8]:
    [0xe1u8, 0x79u8, 0x6fu8, 0xcau8, 0x20u8, 0xcbu8, 0x3du8, 0x3au8,
     0xb0u8, 0xadu8, 0xe6u8, 0x9bu8, 0x2au8, 0x18u8, 0x89u8, 0x1eu8]

fn _v4_expected_ct() -> [u8]:
    [0xb0u8, 0xd3u8, 0x16u8, 0xe9u8, 0x5fu8, 0x3fu8, 0x33u8, 0x90u8,
     0xbau8, 0x10u8, 0xd0u8, 0x27u8, 0x49u8, 0x65u8, 0xc6u8, 0x2bu8]

fn _v4_expected_tag() -> [u8]:
    [0xaeu8, 0xaeu8, 0xdcu8, 0xf8u8, 0xa0u8, 0x12u8, 0xccu8, 0x32u8,
     0xefu8, 0x25u8, 0xa6u8, 0x27u8, 0x90u8, 0xe9u8, 0x33u8, 0x4cu8]

# Helpers to split encrypt output into (ciphertext, tag)
fn _split_ct(buf: [u8], ct_len: i64) -> [u8]:
    var out: [u8] = []
    var i: i64 = 0
    while i < ct_len:
        out.push(buf[i])
        i = i + 1
    out

fn _split_tag(buf: [u8], ct_len: i64) -> [u8]:
    var out: [u8] = []
    var i: i64 = ct_len
    while i < buf.len():
        out.push(buf[i])
        i = i + 1
    out

fn _corrupt_last_byte(tag: [u8]) -> [u8]:
    var out: [u8] = []
    var i: i64 = 0
    while i < tag.len():
        if i == tag.len() - 1:
            out.push(tag[i] ^ 0xFFu8)
        else:
            out.push(tag[i])
        i = i + 1
    out

# ============================================================================
# Specs
# ============================================================================

describe "AES-256-GCM NIST CAVS gcmEncryptExtIV256 vectors":

    it "V1 encrypt: empty PT + empty AAD — tag matches NIST CAVS":
        val empty: [u8] = []
        val out = aes256_gcm_encrypt(_v1_key(), _v1_nonce(), empty, empty)
        val ct = _split_ct(out, 0)
        val tag = _split_tag(out, 0)
        expect ct.len() == 0
        expect tag == _v1_expected_tag()

    it "V1 decrypt: correct tag succeeds with empty plaintext":
        val empty: [u8] = []
        val result = aes256_gcm_decrypt(_v1_key(), _v1_nonce(), empty, empty, _v1_expected_tag())
        match result:
            AesGcmResult.Ok(pt):
                expect pt.len() == 0
            AesGcmResult.Err(msg):
                expect false == true

    it "V1 decrypt: corrupted tag is rejected":
        val empty: [u8] = []
        val bad_tag = _corrupt_last_byte(_v1_expected_tag())
        val result = aes256_gcm_decrypt(_v1_key(), _v1_nonce(), empty, empty, bad_tag)
        match result:
            AesGcmResult.Ok(pt):
                expect false == true
            AesGcmResult.Err(msg):
                expect true == true

    it "V2 encrypt: empty PT + 16-byte AAD — tag matches NIST CAVS":
        val empty: [u8] = []
        val out = aes256_gcm_encrypt(_v2_key(), _v2_nonce(), empty, _v2_aad())
        val ct = _split_ct(out, 0)
        val tag = _split_tag(out, 0)
        expect ct.len() == 0
        expect tag == _v2_expected_tag()

    it "V2 decrypt: correct tag succeeds, wrong AAD is rejected":
        val empty: [u8] = []
        val ok = aes256_gcm_decrypt(_v2_key(), _v2_nonce(), empty, _v2_aad(), _v2_expected_tag())
        match ok:
            AesGcmResult.Ok(pt):
                expect pt.len() == 0
            AesGcmResult.Err(msg):
                expect false == true
        # wrong AAD must fail
        val wrong_aad = _v1_nonce()  # reuse any 12-byte slice as wrong 12-byte AAD (length mismatch -> tag mismatch)
        val bad = aes256_gcm_decrypt(_v2_key(), _v2_nonce(), empty, wrong_aad, _v2_expected_tag())
        match bad:
            AesGcmResult.Ok(pt):
                expect false == true
            AesGcmResult.Err(msg):
                expect true == true

    it "V3 encrypt: 16-byte PT, empty AAD — ciphertext and tag match NIST CAVS":
        val empty: [u8] = []
        val out = aes256_gcm_encrypt(_v3_key(), _v3_nonce(), _v3_plaintext(), empty)
        val ct = _split_ct(out, 16)
        val tag = _split_tag(out, 16)
        expect ct == _v3_expected_ct()
        expect tag == _v3_expected_tag()

    it "V3 decrypt: correct tag returns original plaintext":
        val empty: [u8] = []
        val result = aes256_gcm_decrypt(_v3_key(), _v3_nonce(), _v3_expected_ct(), empty, _v3_expected_tag())
        match result:
            AesGcmResult.Ok(pt):
                expect pt == _v3_plaintext()
            AesGcmResult.Err(msg):
                expect false == true

    it "V3 decrypt: corrupted tag is rejected":
        val empty: [u8] = []
        val bad_tag = _corrupt_last_byte(_v3_expected_tag())
        val result = aes256_gcm_decrypt(_v3_key(), _v3_nonce(), _v3_expected_ct(), empty, bad_tag)
        match result:
            AesGcmResult.Ok(pt):
                expect false == true
            AesGcmResult.Err(msg):
                expect true == true

    it "V4 encrypt: 16-byte PT + 16-byte AAD — ciphertext and tag match NIST CAVS":
        val out = aes256_gcm_encrypt(_v4_key(), _v4_nonce(), _v4_plaintext(), _v4_aad())
        val ct = _split_ct(out, 16)
        val tag = _split_tag(out, 16)
        expect ct == _v4_expected_ct()
        expect tag == _v4_expected_tag()

    it "V4 decrypt: correct tag returns original plaintext":
        val result = aes256_gcm_decrypt(_v4_key(), _v4_nonce(), _v4_expected_ct(), _v4_aad(), _v4_expected_tag())
        match result:
            AesGcmResult.Ok(pt):
                expect pt == _v4_plaintext()
            AesGcmResult.Err(msg):
                expect false == true

    it "V4 decrypt: corrupted tag is rejected":
        val bad_tag = _corrupt_last_byte(_v4_expected_tag())
        val result = aes256_gcm_decrypt(_v4_key(), _v4_nonce(), _v4_expected_ct(), _v4_aad(), bad_tag)
        match result:
            AesGcmResult.Ok(pt):
                expect false == true
            AesGcmResult.Err(msg):
                expect true == true