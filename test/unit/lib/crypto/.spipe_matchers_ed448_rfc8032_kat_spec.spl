# ============================================================================
# Helper — flip one byte at idx (single-bit corruption for negative path).
# Module-level fn: it-block var rebinds do not persist across loops in the
# interpreter (per `feedback_it_block_var_mutation`).
# ============================================================================

fn _flip_byte(bytes: [u8], idx: i64) -> [u8]:
    var out: [u8] = []
    var i: i64 = 0
    while i < bytes.len().to_i64():
        if i == idx:
            out.push((bytes[i.to_u64()].to_i64() ^ 0x01).to_u8())
        else:
            out.push(bytes[i.to_u64()])
        i = i + 1
    out

# ============================================================================
# Specs
# ============================================================================

describe "Ed448 RFC 8032 §7.4 test vectors":

    # -------------------------------------------------------------------------
    # T1 — "Blank" (empty message, empty context)
    # -------------------------------------------------------------------------

    it "T1: derived public key matches RFC 8032 §7.4 Blank vector":
        val kp = ed448_keygen(SEED_T1)
        expect kp.1 == PUB_T1

    it "T1: sign(empty) byte-matches RFC 8032 §7.4 expected signature":
        val kp = ed448_keygen(SEED_T1)
        val sig = ed448_sign(kp.0, kp.1, [], [])
        expect sig == SIG_T1

    it "T1: signature verifies under the correct public key":
        expect ed448_verify(PUB_T1, [], SIG_T1, []) == true

    it "T1: signature is rejected when the S half is bit-flipped":
        # Flip a bit inside S (offset 57 = first byte of S half) — more
        # sensitive than R-flips, which can collide with a different valid R.
        val bad_sig = _flip_byte(SIG_T1, 57)
        expect ed448_verify(PUB_T1, [], bad_sig, []) == false

    # -------------------------------------------------------------------------
    # T2 — single-byte message 0x03 (empty context)
    # -------------------------------------------------------------------------

    it "T2: derived public key matches RFC 8032 §7.4 1-octet vector":
        val kp = ed448_keygen(SEED_T2)
        expect kp.1 == PUB_T2

    it "T2: sign(0x03) byte-matches RFC 8032 §7.4 expected signature":
        val kp = ed448_keygen(SEED_T2)
        val sig = ed448_sign(kp.0, kp.1, MSG_T2, [])
        expect sig == SIG_T2

    it "T2: signature verifies under the correct public key":
        expect ed448_verify(PUB_T2, MSG_T2, SIG_T2, []) == true

    it "T2: signature is rejected under a different public key":
        expect ed448_verify(PUB_T1, MSG_T2, SIG_T2, []) == false