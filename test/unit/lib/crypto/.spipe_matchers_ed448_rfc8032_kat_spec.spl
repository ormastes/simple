# Ed448 RFC 8032 §7.4 Test Vector KAT Spec (W14-F)
#
# Exercises the pure-Simple `os.crypto.ed448` against the canonical RFC 8032
# §7.4 reference values. Two vectors:
#   T1 — "Blank" test (empty message, empty context)
#   T2 — single-byte message 0x03 (empty context)
#
# Each vector covers:
#   - public-key derivation matches the RFC byte-for-byte
#   - sign() byte-matches the RFC signature
#   - verify() accepts the valid signature
#   - verify() rejects a single-bit corruption of the signature (negative path)
#
# Larger §7.4 vectors (length 11/12/64/256/1023 octets) are intentionally
# omitted — interpreter-mode KAT throughput is dominated by point-scalar-mul
# over 30-bit bigint limbs, and longer messages add no additional algorithm
# coverage. If perf in interpreter mode blocks even these two vectors at
# byte-match assertion time, file a feature request for dedicated 16-limb
# 28-bit Ed448 field arithmetic; do NOT swallow per `feedback_no_coverups.md`.
#
# Function signatures (os.crypto.ed448):
#   ed448_keygen(seed: [u8]) -> ([u8], [u8])         # (seed, pubkey)
#   ed448_sign(seed, pub, msg, ctx) -> [u8]          # 114-byte sig
#   ed448_verify(pub, msg, sig, ctx) -> bool

use std.spipe.*
use os.crypto.ed448.{ed448_keygen, ed448_sign, ed448_verify}

# ============================================================================
# RFC 8032 §7.4 — Test 1 ("Blank" — empty message, empty context)
# ============================================================================

