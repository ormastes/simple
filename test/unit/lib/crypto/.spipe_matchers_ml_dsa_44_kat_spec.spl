# =============================================================================
# ML-DSA-44 (FIPS 204) — KAT spec (W15-A)
#
# Parameter set ML-DSA-44 (NIST security category 2, FIPS 204 §4 Table 1):
#   k = 4, l = 4, eta = 2, tau = 39, beta = 78,
#   gamma1 = 2^17 = 131072, gamma2 = (q-1)/88 = 95232, omega = 80
#   pk = 1312 B, sk = 2560 B, sig = 2420 B
#
# Coverage:
#   1. KeyGen sizes (pk = 1312, sk = 2560 — FIPS 204 §B Table 2)
#   2. Sign(sk, m) → σ; Verify(pk, m, σ) == true (positive round-trip)
#   3. Verify rejects bit-flipped message (negative path)
#   4. Verify rejects bit-flipped signature (negative path)
#
# Per `feedback_compile_mode_false_greens.md`, run via direct invocation:
#   bin/simple test/unit/lib/crypto/ml_dsa_44_kat_spec.spl
# Per `feedback_it_block_var_mutation.md`, payloads are built in module-level
# fn helpers so each `it` body sees a single `val` already populated.
# =============================================================================

use std.spipe.*
use os.crypto.ml_dsa_sample.{pk_size_44, sk_size_44, sig_size_44}
use os.crypto.ml_dsa.{ml_dsa_keygen_44, ml_dsa_sign_44, ml_dsa_verify_44}

# ----- module-level helpers ---------------------------------------------

fn _xi() -> list:
    var v = []
    var i = 0
    while i < 32:
        v.push(i & 0xff)
        i = i + 1
    v

fn _msg() -> list:
    var v = []
    var i = 0
    while i < 16:
        v.push(0x42)
        i = i + 1
    v

fn _rnd() -> list:
    var v = []
    var i = 0
    while i < 32:
        v.push(0)
        i = i + 1
    v

fn _keygen_pk_len() -> i64:
    val pair = ml_dsa_keygen_44(_xi())
    pair[0].len()

fn _keygen_sk_len() -> i64:
    val pair = ml_dsa_keygen_44(_xi())
    pair[1].len()

fn _sign_verify_round_trip() -> bool:
    val kp = ml_dsa_keygen_44(_xi())
    val pk = kp[0]
    val sk = kp[1]
    val sig = ml_dsa_sign_44(sk, _msg(), _rnd())
    if sig.len() == 0:
        return false
    ml_dsa_verify_44(pk, _msg(), sig)

fn _verify_rejects_tampered_msg() -> bool:
    val kp = ml_dsa_keygen_44(_xi())
    val pk = kp[0]
    val sk = kp[1]
    val sig = ml_dsa_sign_44(sk, _msg(), _rnd())
    if sig.len() == 0:
        return false
    var bad = []
    val m = _msg()
    var i = 0
    while i < m.len():
        bad.push(m.get(i))
        i = i + 1
    bad[0] = bad.get(0) ^ 0x01
    not ml_dsa_verify_44(pk, bad, sig)

fn _verify_rejects_tampered_sig() -> bool:
    val kp = ml_dsa_keygen_44(_xi())
    val pk = kp[0]
    val sk = kp[1]
    val sig = ml_dsa_sign_44(sk, _msg(), _rnd())
    if sig.len() == 0:
        return false
    var bad_sig = []
    var i = 0
    while i < sig.len():
        bad_sig.push(sig.get(i))
        i = i + 1
    # Flip a bit in c_tilde (first 32 bytes of signature).
    bad_sig[0] = bad_sig.get(0) ^ 0x01
    not ml_dsa_verify_44(pk, _msg(), bad_sig)

# ----- specs -------------------------------------------------------------

describe "ML-DSA-44 KeyGen sizes":

    it "ml_dsa_keygen_44 produces pk of size 1312 bytes (FIPS 204 §B Table 2)":
        expect _keygen_pk_len() == 1312
        expect _keygen_pk_len() == pk_size_44()

    it "ml_dsa_keygen_44 produces sk of size 2560 bytes (FIPS 204 §B Table 2)":
        expect _keygen_sk_len() == 2560
        expect _keygen_sk_len() == sk_size_44()


describe "ML-DSA-44 end-to-end Sign + Verify":

    # Negative-path tests are non-negotiable companions to the positive case
    # — they prove Verify is not a reject-everything (or accept-everything)
    # stub. Per W13-D discipline (`feedback_no_coverups.md`).

    it "Sign(sk, m) → σ; Verify(pk, m, σ) == true":
        expect _sign_verify_round_trip() == true

    it "Verify rejects bit-flipped message":
        expect _verify_rejects_tampered_msg() == true

    it "Verify rejects bit-flipped signature (c_tilde)":
        expect _verify_rejects_tampered_sig() == true