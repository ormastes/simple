# ChaCha20-Poly1305 AEAD — RFC 7539 §2.8.2 Known-Answer Tests
#
# Tests cover:
#   §2.8.2  Canonical AEAD vector (key=80..9f, 12-byte AAD, 114-byte PT)
#           — ciphertext byte-exact, tag byte-exact
#   Round-trip: seal then open recovers original plaintext
#   Auth failure: tampered ciphertext → open returns nil
#   Auth failure: tampered AAD → open returns nil
#   Auth failure: tampered tag → open returns nil
#   Empty AAD: seal + open with zero-length AAD
#   Empty plaintext: seal + open with zero-length plaintext (AAD-only auth)
#   Tag length invariant: seal always returns 16-byte tag
#
# Execution note: it-block bodies are verified in compiled mode. Structure and
# imports are validated by the interpreter on every test run.
# All RFC vectors must match byte-exact — no "close enough".

use std.spipe.*
use std.crypto.chacha20_poly1305.{chacha20_poly1305_seal, chacha20_poly1305_open}

# ============================================================================
# RFC 7539 §2.8.2 test vector data
#
# Key:   80 81 82 83 84 85 86 87 88 89 8a 8b 8c 8d 8e 8f
#        90 91 92 93 94 95 96 97 98 99 9a 9b 9c 9d 9e 9f
# Nonce: 07 00 00 00  40 41 42 43  44 45 46 47
# AAD:   50 51 52 53  c0 c1 c2 c3  c4 c5 c6 c7  (12 bytes)
# PT:    "Ladies and Gentlemen of the class of '99: ..." (114 bytes)
# ============================================================================

fn _key_2_8_2() -> [u8]:
    [0x80u8, 0x81u8, 0x82u8, 0x83u8, 0x84u8, 0x85u8, 0x86u8, 0x87u8,
     0x88u8, 0x89u8, 0x8au8, 0x8bu8, 0x8cu8, 0x8du8, 0x8eu8, 0x8fu8,
     0x90u8, 0x91u8, 0x92u8, 0x93u8, 0x94u8, 0x95u8, 0x96u8, 0x97u8,
     0x98u8, 0x99u8, 0x9au8, 0x9bu8, 0x9cu8, 0x9du8, 0x9eu8, 0x9fu8]

fn _nonce_2_8_2() -> [u8]:
    [0x07u8, 0x00u8, 0x00u8, 0x00u8, 0x40u8, 0x41u8, 0x42u8, 0x43u8,
     0x44u8, 0x45u8, 0x46u8, 0x47u8]

fn _aad_2_8_2() -> [u8]:
    [0x50u8, 0x51u8, 0x52u8, 0x53u8, 0xc0u8, 0xc1u8, 0xc2u8, 0xc3u8,
     0xc4u8, 0xc5u8, 0xc6u8, 0xc7u8]

fn _pt_2_8_2() -> [u8]:
    # "Ladies and Gentlemen of the class of '99: If I could offer you only
    #  one tip for the future, sunscreen would be it."
    [0x4cu8, 0x61u8, 0x64u8, 0x69u8, 0x65u8, 0x73u8, 0x20u8, 0x61u8,
     0x6eu8, 0x64u8, 0x20u8, 0x47u8, 0x65u8, 0x6eu8, 0x74u8, 0x6cu8,
     0x65u8, 0x6du8, 0x65u8, 0x6eu8, 0x20u8, 0x6fu8, 0x66u8, 0x20u8,
     0x74u8, 0x68u8, 0x65u8, 0x20u8, 0x63u8, 0x6cu8, 0x61u8, 0x73u8,
     0x73u8, 0x20u8, 0x6fu8, 0x66u8, 0x20u8, 0x27u8, 0x39u8, 0x39u8,
     0x3au8, 0x20u8, 0x49u8, 0x66u8, 0x20u8, 0x49u8, 0x20u8, 0x63u8,
     0x6fu8, 0x75u8, 0x6cu8, 0x64u8, 0x20u8, 0x6fu8, 0x66u8, 0x66u8,
     0x65u8, 0x72u8, 0x20u8, 0x79u8, 0x6fu8, 0x75u8, 0x20u8, 0x6fu8,
     0x6eu8, 0x6cu8, 0x79u8, 0x20u8, 0x6fu8, 0x6eu8, 0x65u8, 0x20u8,
     0x74u8, 0x69u8, 0x70u8, 0x20u8, 0x66u8, 0x6fu8, 0x72u8, 0x20u8,
     0x74u8, 0x68u8, 0x65u8, 0x20u8, 0x66u8, 0x75u8, 0x74u8, 0x75u8,
     0x72u8, 0x65u8, 0x2cu8, 0x20u8, 0x73u8, 0x75u8, 0x6eu8, 0x73u8,
     0x63u8, 0x72u8, 0x65u8, 0x65u8, 0x6eu8, 0x20u8, 0x77u8, 0x6fu8,
     0x75u8, 0x6cu8, 0x64u8, 0x20u8, 0x62u8, 0x65u8, 0x20u8, 0x69u8,
     0x74u8, 0x2eu8]

fn _expected_ct_2_8_2() -> [u8]:
    # RFC 7539 §2.8.2 canonical ciphertext (114 bytes)
    [0xd3u8, 0x1au8, 0x8du8, 0x34u8, 0x64u8, 0x8eu8, 0x60u8, 0xdbu8,
     0x7bu8, 0x86u8, 0xafu8, 0xbcu8, 0x53u8, 0xefu8, 0x7eu8, 0xc2u8,
     0xa4u8, 0xadu8, 0xedu8, 0x51u8, 0x29u8, 0x6eu8, 0x08u8, 0xfeu8,
     0xa9u8, 0xe2u8, 0xb5u8, 0xa7u8, 0x36u8, 0xeeu8, 0x62u8, 0xd6u8,
     0x3du8, 0xbeu8, 0xa4u8, 0x5eu8, 0x8cu8, 0xa9u8, 0x67u8, 0x12u8,
     0x82u8, 0xfau8, 0xfbu8, 0x69u8, 0xdau8, 0x92u8, 0x72u8, 0x8bu8,
     0x1au8, 0x71u8, 0xdeu8, 0x0au8, 0x9eu8, 0x06u8, 0x0bu8, 0x29u8,
     0x05u8, 0xd6u8, 0xa5u8, 0xb6u8, 0x7eu8, 0xcdu8, 0x3bu8, 0x36u8,
     0x92u8, 0xddu8, 0xbdu8, 0x7fu8, 0x2du8, 0x77u8, 0x8bu8, 0x8cu8,
     0x98u8, 0x03u8, 0xaeu8, 0xe3u8, 0x28u8, 0x09u8, 0x1bu8, 0x58u8,
     0xfau8, 0xb3u8, 0x24u8, 0xe4u8, 0xfau8, 0xd6u8, 0x75u8, 0x94u8,
     0x55u8, 0x85u8, 0x80u8, 0x8bu8, 0x48u8, 0x31u8, 0xd7u8, 0xbcu8,
     0x3fu8, 0xf4u8, 0xdeu8, 0xf0u8, 0x8eu8, 0x4bu8, 0x7au8, 0x9du8,
     0xe5u8, 0x76u8, 0xd2u8, 0x65u8, 0x86u8, 0xceu8, 0xc6u8, 0x4bu8,
     0x61u8, 0x16u8]

fn _expected_tag_2_8_2() -> [u8]:
    # RFC 7539 §2.8.2 canonical Poly1305 tag (16 bytes)
    [0x1au8, 0xe1u8, 0x0bu8, 0x59u8, 0x4fu8, 0x09u8, 0xe2u8, 0x6au8,
     0x7eu8, 0x90u8, 0x2eu8, 0xcbu8, 0xd0u8, 0x60u8, 0x06u8, 0x91u8]

# ============================================================================
# Helpers
# ============================================================================

fn _bytes_eq(a: [u8], b: [u8]) -> bool:
    """Return true iff two byte arrays are identical in length and content."""
    if a.len() != b.len():
        return false
    var i: u64 = 0u64
    while i < a.len():
        if a[i] != b[i]:
            return false
        i = i + 1u64
    true

fn _corrupt(bytes: [u8], idx: u64) -> [u8]:
    """Return a copy of bytes with bytes[idx] XOR 0x01 (one-bit flip)."""
    var out: [u8] = []
    var i: u64 = 0u64
    while i < bytes.len():
        if i == idx:
            out.push(bytes[i] ^ 0x01u8)
        else:
            out.push(bytes[i])
        i = i + 1u64
    out

fn _open_eq(key: [u8], nonce: [u8], aad: [u8], ct: [u8], tag: [u8], expected: [u8]) -> bool:
    """Return true if open succeeds and decrypted plaintext equals expected."""
    if val Some(pt) = chacha20_poly1305_open(key, nonce, aad, ct, tag):
        _bytes_eq(pt, expected)
    else:
        false

fn _open_len(key: [u8], nonce: [u8], aad: [u8], ct: [u8], tag: [u8]) -> u64:
    """Return plaintext length from open, or 0xFFFFFFFFFFFFFFFF on failure."""
    if val Some(pt) = chacha20_poly1305_open(key, nonce, aad, ct, tag):
        pt.len()
    else:
        0xFFFFFFFFFFFFFFFFu64

fn _open_is_nil(key: [u8], nonce: [u8], aad: [u8], ct: [u8], tag: [u8]) -> bool:
    """Return true if chacha20_poly1305_open returns nil (auth failure)."""
    val result = chacha20_poly1305_open(key, nonce, aad, ct, tag)
    result == nil

# ============================================================================
# §2.8.2 — Canonical AEAD known-answer vector
# ============================================================================

describe "ChaCha20-Poly1305 stdlib RFC 7539 §2.8.2 — ciphertext":

    it "seal produces canonical §2.8.2 ciphertext byte-exact":
        val (ct, _tag) = chacha20_poly1305_seal(_key_2_8_2(), _nonce_2_8_2(), _aad_2_8_2(), _pt_2_8_2())
        expect(_bytes_eq(ct, _expected_ct_2_8_2())).to_equal(true)

    it "ciphertext length equals plaintext length (114 bytes)":
        val (ct, _tag) = chacha20_poly1305_seal(_key_2_8_2(), _nonce_2_8_2(), _aad_2_8_2(), _pt_2_8_2())
        expect(ct.len()).to_equal(114u64)

describe "ChaCha20-Poly1305 stdlib RFC 7539 §2.8.2 — tag":

    it "seal produces canonical §2.8.2 Poly1305 tag byte-exact":
        val (_ct, tag) = chacha20_poly1305_seal(_key_2_8_2(), _nonce_2_8_2(), _aad_2_8_2(), _pt_2_8_2())
        expect(_bytes_eq(tag, _expected_tag_2_8_2())).to_equal(true)

    it "tag length is always 16 bytes":
        val (_ct, tag) = chacha20_poly1305_seal(_key_2_8_2(), _nonce_2_8_2(), _aad_2_8_2(), _pt_2_8_2())
        expect(tag.len()).to_equal(16u64)

# ============================================================================
# Round-trip: seal then open
# ============================================================================

describe "ChaCha20-Poly1305 stdlib RFC 7539 §2.8.2 — round-trip":

    it "open(seal(pt)) recovers original plaintext":
        val (ct, tag) = chacha20_poly1305_seal(_key_2_8_2(), _nonce_2_8_2(), _aad_2_8_2(), _pt_2_8_2())
        expect(_open_eq(_key_2_8_2(), _nonce_2_8_2(), _aad_2_8_2(), ct, tag, _pt_2_8_2())).to_equal(true)

    it "open with canonical ct+tag recovers plaintext":
        expect(_open_eq(
            _key_2_8_2(), _nonce_2_8_2(), _aad_2_8_2(),
            _expected_ct_2_8_2(), _expected_tag_2_8_2(),
            _pt_2_8_2())).to_equal(true)

# ============================================================================
# Authentication failure tests
# ============================================================================

describe "ChaCha20-Poly1305 stdlib — authentication failure":

    it "tampered ciphertext (byte 0 flipped) causes open to return nil":
        val bad_ct = _corrupt(_expected_ct_2_8_2(), 0u64)
        expect(_open_is_nil(_key_2_8_2(), _nonce_2_8_2(), _aad_2_8_2(),
            bad_ct, _expected_tag_2_8_2())).to_equal(true)

    it "tampered AAD (byte 0 flipped) causes open to return nil":
        val bad_aad = _corrupt(_aad_2_8_2(), 0u64)
        expect(_open_is_nil(_key_2_8_2(), _nonce_2_8_2(), bad_aad,
            _expected_ct_2_8_2(), _expected_tag_2_8_2())).to_equal(true)

    it "tampered tag (byte 0 flipped) causes open to return nil":
        val bad_tag = _corrupt(_expected_tag_2_8_2(), 0u64)
        expect(_open_is_nil(_key_2_8_2(), _nonce_2_8_2(), _aad_2_8_2(),
            _expected_ct_2_8_2(), bad_tag)).to_equal(true)

# ============================================================================
# Edge cases: empty AAD and empty plaintext
# ============================================================================

describe "ChaCha20-Poly1305 stdlib — empty AAD":

    it "seal with empty AAD produces correct ciphertext length":
        val empty_aad: [u8] = []
        val (ct, tag) = chacha20_poly1305_seal(
            _key_2_8_2(), _nonce_2_8_2(), empty_aad, _pt_2_8_2())
        expect(ct.len()).to_equal(114u64)
        expect(tag.len()).to_equal(16u64)

    it "round-trip with empty AAD recovers plaintext":
        val empty_aad: [u8] = []
        val (ct, tag) = chacha20_poly1305_seal(
            _key_2_8_2(), _nonce_2_8_2(), empty_aad, _pt_2_8_2())
        expect(_open_eq(_key_2_8_2(), _nonce_2_8_2(), empty_aad, ct, tag, _pt_2_8_2())).to_equal(true)

describe "ChaCha20-Poly1305 stdlib — empty plaintext":

    it "seal with empty plaintext produces empty ciphertext and 16-byte tag":
        val empty_pt: [u8] = []
        val (ct, tag) = chacha20_poly1305_seal(
            _key_2_8_2(), _nonce_2_8_2(), _aad_2_8_2(), empty_pt)
        expect(ct.len()).to_equal(0u64)
        expect(tag.len()).to_equal(16u64)

    it "round-trip with empty plaintext recovers empty plaintext":
        val empty_pt: [u8] = []
        val (ct, tag) = chacha20_poly1305_seal(
            _key_2_8_2(), _nonce_2_8_2(), _aad_2_8_2(), empty_pt)
        expect(_open_len(_key_2_8_2(), _nonce_2_8_2(), _aad_2_8_2(), ct, tag)).to_equal(0u64)
