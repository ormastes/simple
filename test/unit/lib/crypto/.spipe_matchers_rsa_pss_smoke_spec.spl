# RSA-PSS Smoke — verifies module loads and basic API is callable.
# Full KAT lives in rsa_pss_sha256_kat_spec.spl.
#
# tag: unit, crypto, rsa, pss, smoke

use std.spipe.*
use os.crypto.rsa_pss.{
    rsa_pss_sha256_sign,
    rsa_pss_sha256_verify,
    rsa_pss_parse_spki,
    rsa_pss_parse_pkcs8
}

fn _empty() -> [u8]:
    []

describe "RSA-PSS module smoke":

    it "rejects empty SPKI for verify":
        expect rsa_pss_sha256_verify(_empty(), _empty(), _empty()) == false

    it "rejects empty PKCS8 for sign (returns empty signature)":
        expect rsa_pss_sha256_sign(_empty(), _empty(), _empty()).len().to_i64() == 0