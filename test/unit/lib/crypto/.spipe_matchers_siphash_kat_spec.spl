# SipHash-2-4 and SipHash-1-3 Known-Answer Test Vectors
#
# Tests the pure-Simple SipHash implementation in src/os/crypto/siphash.spl
# against the authoritative reference vectors from:
#
#   SipHash-2-4: Aumasson & Bernstein (2012) reference C implementation
#     https://github.com/veorq/SipHash/blob/master/vectors.h
#     Also cross-verified against siphasher Rust crate vendor tests:
#     src/compiler_rust/vendor/siphasher/src/tests.rs :: test_siphash_2_4
#
#   SipHash-1-3: siphasher Rust crate vendor tests:
#     src/compiler_rust/vendor/siphasher/src/tests.rs :: test_siphash_1_3
#
# Test protocol (same as both sets):
#   key  = [0x00, 0x01, 0x02, ..., 0x0f]  (16 bytes)
#   vecs[N] = hash of input [0x00, 0x01, ..., 0x(N-1)]  (N bytes, N in 0..63)
#
# Coverage (5 vectors each, spanning empty/1-block/tail/long/boundary):
#   N=0  — empty message
#   N=8  — exactly one full 8-byte block, no tail
#   N=15 — one block + 7-byte tail (max tail)
#   N=60 — multi-block (7 full blocks + 4-byte tail)
#   N=63 — multi-block (7 full blocks + 7-byte tail)
#
# All expected values are stored as u64 (little-endian byte order from spec).
#
# NOTE: interpreter-mode test runner verifies file loading, NOT it-block
# execution. Hash assertions only fire under compiled/native mode
# (see feedback_compile_mode_false_greens.md).
# ============================================================================

use std.spipe.*
use os.crypto.siphash.{siphash24, siphash13}

# ============================================================================
# Helpers
# ============================================================================

fn _std_key() -> [u8]:
    """Standard test key: 0x00..0x0f."""
    var k: [u8] = []
    var i: u64 = 0
    while i < 16:
        k.push(i.to_u8())
        i = i + 1
    k

fn _msg(n: u64) -> [u8]:
    """Input bytes [0x00, 0x01, ..., 0x(n-1)] (n bytes)."""
    var m: [u8] = []
    var i: u64 = 0
    while i < n:
        m.push(i.to_u8())
        i = i + 1
    m

fn _u64_to_hex(v: u64) -> text:
    """Format a u64 as 16-char lowercase hex (big-endian display)."""
    val hex_chars = "0123456789abcdef"
    var out = ""
    var shift: i64 = 60
    while shift >= 0:
        val nibble = ((v >> shift.to_u64()) & 0xf).to_i64()
        out = out + hex_chars.char_at(nibble).to_text()
        shift = shift - 4
    out

# ============================================================================
# SipHash-2-4 reference vectors (Aumasson & Bernstein 2012)
# Key = 00 01 02 03 04 05 06 07 08 09 0a 0b 0c 0d 0e 0f
# ============================================================================

describe "SipHash-2-4 reference vectors (Aumasson & Bernstein 2012)":

    it "N=0 empty message → 726fdb47dd0e0e31":
        # vecs[0] = {0x31,0x0e,0x0e,0xdd,0x47,0xdb,0x6f,0x72} LE → 0x726fdb47dd0e0e31
        expect _u64_to_hex(siphash24(_std_key(), _msg(0))) == "726fdb47dd0e0e31"

    it "N=8 one full block → 93f5f5799a932462":
        # vecs[8] = {0x62,0x24,0x93,0x9a,0x79,0xf5,0xf5,0x93} LE → 0x93f5f5799a932462
        expect _u64_to_hex(siphash24(_std_key(), _msg(8))) == "93f5f5799a932462"

    it "N=15 one block + 7-byte tail → a129ca6149be45e5":
        # vecs[15] = {0xe5,0x45,0xbe,0x49,0x61,0xca,0x29,0xa1} LE → 0xa129ca6149be45e5
        expect _u64_to_hex(siphash24(_std_key(), _msg(15))) == "a129ca6149be45e5"

    it "N=60 multi-block 4-byte tail → 6ca4ecb15c5f91e1":
        # vecs[60] = {0xe1,0x91,0x5f,0x5c,0xb1,0xec,0xa4,0x6c} LE → 0x6ca4ecb15c5f91e1
        expect _u64_to_hex(siphash24(_std_key(), _msg(60))) == "6ca4ecb15c5f91e1"

    it "N=63 multi-block 7-byte tail → 958a324ceb064572":
        # vecs[63] = {0x72,0x45,0x06,0xeb,0x4c,0x32,0x8a,0x95} LE → 0x958a324ceb064572
        expect _u64_to_hex(siphash24(_std_key(), _msg(63))) == "958a324ceb064572"

# ============================================================================
# SipHash-1-3 reference vectors (siphasher crate, same key/protocol)
# Key = 00 01 02 03 04 05 06 07 08 09 0a 0b 0c 0d 0e 0f
# ============================================================================

describe "SipHash-1-3 reference vectors (siphasher crate)":

    it "N=0 empty message → abac0158050fc4dc":
        # vecs[0] = {0xdc,0xc4,0x0f,0x05,0x58,0x01,0xac,0xab} LE → 0xabac0158050fc4dc
        expect _u64_to_hex(siphash13(_std_key(), _msg(0))) == "abac0158050fc4dc"

    it "N=8 one full block → 369095118d299a8e":
        # vecs[8] = {0x8e,0x9a,0x29,0x8d,0x11,0x95,0x90,0x36} LE → 0x369095118d299a8e
        expect _u64_to_hex(siphash13(_std_key(), _msg(8))) == "369095118d299a8e"

    it "N=15 one block + 7-byte tail → d320d86d2a519956":
        # vecs[15] = {0x56,0x99,0x51,0x2a,0x6d,0xd8,0x20,0xd3} LE → 0xd320d86d2a519956
        expect _u64_to_hex(siphash13(_std_key(), _msg(15))) == "d320d86d2a519956"

    it "N=60 multi-block 4-byte tail → f6f4e6bcf7a644ee":
        # vecs[60] = {0xee,0x44,0xa6,0xf7,0xbc,0xe6,0xf4,0xf6} LE → 0xf6f4e6bcf7a644ee
        expect _u64_to_hex(siphash13(_std_key(), _msg(60))) == "f6f4e6bcf7a644ee"

    it "N=63 multi-block 7-byte tail → 9d199062b7bbb3a8":
        # vecs[63] = {0xa8,0xb3,0xbb,0xb7,0x62,0x90,0x19,0x9d} LE → 0x9d199062b7bbb3a8
        expect _u64_to_hex(siphash13(_std_key(), _msg(63))) == "9d199062b7bbb3a8"