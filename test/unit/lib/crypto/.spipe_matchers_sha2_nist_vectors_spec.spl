# SHA-256 + SHA-512 NIST FIPS 180-4 Test Vectors
#
# Tests the pure-Simple implementations in src/lib/common/crypto/sha256.spl
# and src/lib/common/crypto/sha512.spl against canonical NIST reference values
# from FIPS 180-4 and RFC 6234.
#
# NOTE: src/os/crypto/{sha256,sha512}.spl share the same FIPS contract but rely
# on baremetal externs (rt_tls13_sha256, rt_sha512_hash) that are not registered
# in the host test runner. The pure-Simple lib/common impls have no externs and
# run in interpreter mode.
#
# NOTE: interpreter-mode test runner verifies file loading, NOT it-block
# execution. Digest assertions only fire under compiled/native mode.

use std.spipe.*
use std.crypto.sha256.{sha256_hex, sha256_bytes}
use std.crypto.sha512.{sha512_hex, sha512_bytes}
use std.crypto.types.{bytes_to_hex}

# ============================================================================
# Multi-block 'a' input builder — DEVIATION from FIPS 180-4 §B.3/§C.3 (1M bytes).
# 1M-byte push loop is too slow in interpreter mode. Using 1024 bytes (16 SHA-256
# blocks / 8 SHA-512 blocks) to verify multi-block accumulation without hitting
# the interpreter timeout. Spec coverage for multi-block boundary is retained.
# Reference digest verified via: python3 -c "import hashlib; print(hashlib.sha256(b'a'*1024).hexdigest())"
# ============================================================================

fn _make_1024_a() -> list:
    var out = []
    var i = 0
    while i < 1024:
        out.push(0x61)
        i = i + 1
    out

# ============================================================================
# SHA-256 NIST FIPS 180-4 test vectors
# ============================================================================

describe "SHA-256 NIST FIPS 180-4 test vectors":

    it "FIPS 180-4 §B.0 empty string digest":
        # Expected: e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855
        expect sha256_hex("") == "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855"

    it "FIPS 180-4 §B.1 'abc' (canary) digest":
        # Expected: ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad
        expect sha256_hex("abc") == "ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad"

    it "FIPS 180-4 §B.2 56-byte string digest":
        # Input: "abcdbcdecdefdefgefghfghighijhijkijkljklmklmnlmnomnopnopq"
        # Expected: 248d6a61d20638b8e5c026930c3e6039a33ce45964ff2167f6ecedd419db06c1
        expect sha256_hex("abcdbcdecdefdefgefghfghighijhijkijkljklmklmnlmnomnopnopq") == "248d6a61d20638b8e5c026930c3e6039a33ce45964ff2167f6ecedd419db06c1"

    it "multi-block: 1024 bytes of 0x61 ('a') — 16 SHA-256 blocks":
        # DEVIATION: FIPS §B.3 specifies 1M 'a' bytes (cdc76e5c...); replaced with
        # 1024 bytes to stay within interpreter timeout. Multi-block boundary covered.
        # Reference: python3 => 2edc986847e209b4016e141a6dc8716d3207350f416969382d431539bf292e4a
        val input = _make_1024_a()
        expect bytes_to_hex(sha256_bytes(input)) == "2edc986847e209b4016e141a6dc8716d3207350f416969382d431539bf292e4a"

# ============================================================================
# SHA-512 NIST FIPS 180-4 test vectors
# ============================================================================

describe "SHA-512 NIST FIPS 180-4 test vectors":

    it "FIPS 180-4 §C.0 empty string digest":
        # Expected: cf83e1357eefb8bdf1542850d66d8007d620e4050b5715dc83f4a921d36ce9ce
        #           47d0d13c5d85f2b0ff8318d2877eec2f63b931bd47417a81a538327af927da3e
        expect sha512_hex("") == "cf83e1357eefb8bdf1542850d66d8007d620e4050b5715dc83f4a921d36ce9ce47d0d13c5d85f2b0ff8318d2877eec2f63b931bd47417a81a538327af927da3e"

    it "FIPS 180-4 §C.1 'abc' (canary) digest":
        # Expected: ddaf35a193617abacc417349ae20413112e6fa4e89a97ea20a9eeee64b55d39a
        #           2192992a274fc1a836ba3c23a3feebbd454d4423643ce80e2a9ac94fa54ca49f
        expect sha512_hex("abc") == "ddaf35a193617abacc417349ae20413112e6fa4e89a97ea20a9eeee64b55d39a2192992a274fc1a836ba3c23a3feebbd454d4423643ce80e2a9ac94fa54ca49f"

    it "FIPS 180-4 §C.2 112-byte string digest":
        # Input: "abcdefghbcdefghicdefghijdefghijkefghijklfghijklmghijklmn
        #         hijklmnoijklmnopjklmnopqklmnopqrlmnopqrsmnopqrstnopqrstu"
        # Expected: 8e959b75dae313da8cf4f72814fc143f8f7779c6eb9f7fa17299aeadb6889018
        #           501d289e4900f7e4331b99dec4b5433ac7d329eeb6dd26545e96e55b874be909
        expect sha512_hex("abcdefghbcdefghicdefghijdefghijkefghijklfghijklmghijklmnhijklmnoijklmnopjklmnopqklmnopqrlmnopqrsmnopqrstnopqrstu") == "8e959b75dae313da8cf4f72814fc143f8f7779c6eb9f7fa17299aeadb6889018501d289e4900f7e4331b99dec4b5433ac7d329eeb6dd26545e96e55b874be909"

    it "multi-block: 1024 bytes of 0x61 ('a') — 8 SHA-512 blocks":
        # DEVIATION: FIPS §C.3 specifies 1M 'a' bytes; reduced to 1024.
        # Reference: python3 => 74b22492e3b9a86a9c93c23a69f821ebafa429302c1f4054b4bc37356a4bae05
        #                        6d9ccbc6f24093a25704faaa72bd21a5f337ca9ec92f32369d24e6b9fae954d8
        val input = _make_1024_a()
        expect bytes_to_hex(sha512_bytes(input)) == "74b22492e3b9a86a9c93c23a69f821ebafa429302c1f4054b4bc37356a4bae056d9ccbc6f24093a25704faaa72bd21a5f337ca9ec92f32369d24e6b9fae954d8"