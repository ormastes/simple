# Salsa20/20 + HSalsa20 + XSalsa20 — Known-Answer Test spec
#
# Exercises src/os/crypto/salsa20.spl against canonical DJB / NaCl test vectors.
#
# References:
#   DJB, "Salsa20 specification" (2005) — https://cr.yp.to/snuffle/spec.pdf
#     Set 1 vector 0: key=80 00..00 (32 B), nonce=00..00 (8 B), ctr=0
#     Set 2 vector 0: key=00..00 (32 B), nonce=80 00..00 (8 B), ctr=0
#     Set 0 vector 0: key=00..00 (32 B), nonce=00..00 (8 B), ctr=0
#   NaCl crypto_core/hsalsa20/ref/test.c — DJB's canonical HSalsa20 vector
#   XSalsa20 — computed byte vector (key from NaCl test, 24-byte nonce) + round-trip
#
# Execution note: the unit test runner (interpreter mode) verifies file loading
# and syntax, but does NOT execute it-block bodies. Assertions are structurally
# correct; they become live regression gates under compiled mode.

use std.spipe.*
use os.crypto.salsa20.{salsa20_20_block, salsa20_20_xor, hsalsa20, xsalsa20_xor}

# ============================================================================
# Module-level helpers — avoids it-block var mutation drop in interpreter mode
# (per .claude/memory/feedback_it_block_var_mutation.md)
# ============================================================================

fn _bytes_hex(b: [u8]) -> text:
    var s = ""
    var i: u64 = 0
    val n = b.len()
    while i < n:
        val byte = b[i].to_i64()
        val hi = (byte >> 4) & 0xF
        val lo = byte & 0xF
        val hc: text = if hi == 0: "0" else: if hi == 1: "1" else: if hi == 2: "2"
                       else: if hi == 3: "3" else: if hi == 4: "4" else: if hi == 5: "5"
                       else: if hi == 6: "6" else: if hi == 7: "7" else: if hi == 8: "8"
                       else: if hi == 9: "9" else: if hi == 10: "a" else: if hi == 11: "b"
                       else: if hi == 12: "c" else: if hi == 13: "d" else: if hi == 14: "e"
                       else: "f"
        val lc: text = if lo == 0: "0" else: if lo == 1: "1" else: if lo == 2: "2"
                       else: if lo == 3: "3" else: if lo == 4: "4" else: if lo == 5: "5"
                       else: if lo == 6: "6" else: if lo == 7: "7" else: if lo == 8: "8"
                       else: if lo == 9: "9" else: if lo == 10: "a" else: if lo == 11: "b"
                       else: if lo == 12: "c" else: if lo == 13: "d" else: if lo == 14: "e"
                       else: "f"
        s = s + hc + lc
        i = i + 1
    s

fn _make_key_0x80() -> [u8]:
    """32-byte key: first byte 0x80, rest 0x00."""
    var k: [u8] = []
    k.push(0x80u8)
    var i: u64 = 1
    while i < 32:
        k.push(0x00u8)
        i = i + 1
    k

fn _make_key_zeros() -> [u8]:
    var k: [u8] = []
    var i: u64 = 0
    while i < 32:
        k.push(0x00u8)
        i = i + 1
    k

fn _make_nonce_zeros_8() -> [u8]:
    var n: [u8] = []
    var i: u64 = 0
    while i < 8:
        n.push(0x00u8)
        i = i + 1
    n

fn _make_nonce_0x80() -> [u8]:
    """8-byte nonce: first byte 0x80, rest 0x00."""
    var n: [u8] = []
    n.push(0x80u8)
    var i: u64 = 1
    while i < 8:
        n.push(0x00u8)
        i = i + 1
    n

# ============================================================================
# DJB spec Set 1 vector 0 — expected 64-byte keystream
# key = 80 00..00 (32 bytes), nonce = 00..00 (8 bytes), counter = 0
# Source: https://cr.yp.to/snuffle/spec.pdf §8, confirmed by Python impl
# ============================================================================

fn _expected_set1_v0() -> [u8]:
    [
        0xe3u8, 0xbeu8, 0x8fu8, 0xddu8, 0x8bu8, 0xecu8, 0xa2u8, 0xe3u8,
        0xeau8, 0x8eu8, 0xf9u8, 0x47u8, 0x5bu8, 0x29u8, 0xa6u8, 0xe7u8,
        0x00u8, 0x39u8, 0x51u8, 0xe1u8, 0x09u8, 0x7au8, 0x5cu8, 0x38u8,
        0xd2u8, 0x3bu8, 0x7au8, 0x5fu8, 0xadu8, 0x9fu8, 0x68u8, 0x44u8,
        0xb2u8, 0x2cu8, 0x97u8, 0x55u8, 0x9eu8, 0x27u8, 0x23u8, 0xc7u8,
        0xcbu8, 0xbdu8, 0x3fu8, 0xe4u8, 0xfcu8, 0x8du8, 0x9au8, 0x07u8,
        0x44u8, 0x65u8, 0x2au8, 0x83u8, 0xe7u8, 0x2au8, 0x9cu8, 0x46u8,
        0x18u8, 0x76u8, 0xafu8, 0x4du8, 0x7eu8, 0xf1u8, 0xa1u8, 0x17u8
    ]

# ============================================================================
# DJB spec Set 2 vector 0 — expected 64-byte keystream
# key = 00..00 (32 bytes), nonce = 80 00..00 (8 bytes), counter = 0
# ============================================================================

