# PBKDF2-HMAC-SHA-256 industry test vectors
# (draft-josefsson-pbkdf2-test-vectors-00, widely adopted)
#
# Tests the pure-Simple PBKDF2 implementation in
# src/lib/common/crypto/pbkdf2.spl against de-facto industry reference
# vectors for SHA-256 and SHA-512.
#
# TC4 (c=16777216, 16M iterations) is intentionally omitted — runtime cost
# is prohibitive for a unit test.
#
# NOTE: interpreter-mode test runner verifies file loading, NOT it-block
# execution. Assertions only fire under compiled/native mode.

use std.spipe.*
use std.crypto.pbkdf2.{pbkdf2_sha256_bytes, pbkdf2_sha512_bytes}
use std.crypto.types.{bytes_to_hex}

# ============================================================================
# Shared byte helpers
# ============================================================================

fn _password() -> list:
    # "password" — 8 bytes
    [0x70, 0x61, 0x73, 0x73, 0x77, 0x6f, 0x72, 0x64]

fn _salt() -> list:
    # "salt" — 4 bytes
    [0x73, 0x61, 0x6c, 0x74]

fn _password_long() -> list:
    # "passwordPASSWORDpassword" — 24 bytes
    [
        0x70, 0x61, 0x73, 0x73, 0x77, 0x6f, 0x72, 0x64,
        0x50, 0x41, 0x53, 0x53, 0x57, 0x4f, 0x52, 0x44,
        0x70, 0x61, 0x73, 0x73, 0x77, 0x6f, 0x72, 0x64
    ]

fn _salt_long() -> list:
    # "saltSALTsaltSALTsaltSALTsaltSALTsalt" — 36 bytes
    [
        0x73, 0x61, 0x6c, 0x74, 0x53, 0x41, 0x4c, 0x54,
        0x73, 0x61, 0x6c, 0x74, 0x53, 0x41, 0x4c, 0x54,
        0x73, 0x61, 0x6c, 0x74, 0x53, 0x41, 0x4c, 0x54,
        0x73, 0x61, 0x6c, 0x74, 0x53, 0x41, 0x4c, 0x54,
        0x73, 0x61, 0x6c, 0x74
    ]

fn _password_nul() -> list:
    # "pass\0word" — 9 bytes (embedded NUL at index 4)
    [0x70, 0x61, 0x73, 0x73, 0x00, 0x77, 0x6f, 0x72, 0x64]

fn _salt_nul() -> list:
    # "sa\0lt" — 5 bytes (embedded NUL at index 2)
    [0x73, 0x61, 0x00, 0x6c, 0x74]

fn _passwd_sha512() -> list:
    # "passwd" — 6 bytes
    [0x70, 0x61, 0x73, 0x73, 0x77, 0x64]

fn _salt_sha512() -> list:
    # "salt" — 4 bytes (same as _salt, separate fn for clarity)
    [0x73, 0x61, 0x6c, 0x74]

fn _password_nacl() -> list:
    # "Password" — 8 bytes
    [0x50, 0x61, 0x73, 0x73, 0x77, 0x6f, 0x72, 0x64]

fn _salt_nacl() -> list:
    # "NaCl" — 4 bytes
    [0x4e, 0x61, 0x43, 0x6c]

# ============================================================================
# PBKDF2-HMAC-SHA-256 industry test vectors
# ============================================================================

describe "PBKDF2-HMAC-SHA-256 industry test vectors":

    it "TC1: password=password salt=salt c=1 dkLen=32 → 120fb6cf...":
        # draft-josefsson-pbkdf2-test-vectors-00 §2
        expect(bytes_to_hex(pbkdf2_sha256_bytes(_password(), _salt(), 1, 32))).to_equal(
            "120fb6cffcf8b32c43e7225256c4f837a86548c92ccc35480805987cb70be17b"
        )

    it "TC2: password=password salt=salt c=2 dkLen=32 → ae4d0c95...":
        # draft-josefsson-pbkdf2-test-vectors-00 §2
        expect(bytes_to_hex(pbkdf2_sha256_bytes(_password(), _salt(), 2, 32))).to_equal(
            "ae4d0c95af6b46d32d0adff928f06dd02a303f8ef3c251dfd6e2d85a95474c43"
        )

    it "TC3: password=password salt=salt c=4096 dkLen=32 → c5e478d5...":
        # draft-josefsson-pbkdf2-test-vectors-00 §2
        # TC4 (c=16777216) is intentionally omitted — 16M iterations too slow for unit test
        expect(bytes_to_hex(pbkdf2_sha256_bytes(_password(), _salt(), 4096, 32))).to_equal(
            "c5e478d59288c841aa530db6845c4c8d962893a001ce4e11a4963873aa98134a"
        )

    it "TC5: long password + long salt c=4096 dkLen=40 → 348c89db...":
        # passwordPASSWORDpassword / saltSALTsaltSALTsaltSALTsaltSALTsalt
        expect(bytes_to_hex(pbkdf2_sha256_bytes(_password_long(), _salt_long(), 4096, 40))).to_equal(
            "348c89dbcbd32b2f32d814b8116e84cf2b17347ebc1800181c4e2a1fb8dd53e1c635518c7dac47e9"
        )

    it "TC6: embedded-NUL password + salt c=4096 dkLen=16 → 89b69d05...":
        # pass\0word / sa\0lt — verifies NUL-byte handling
        expect(bytes_to_hex(pbkdf2_sha256_bytes(_password_nul(), _salt_nul(), 4096, 16))).to_equal(
            "89b69d0516f829893c696226650a8687"
        )

# ============================================================================
# PBKDF2-HMAC-SHA-512 industry test vectors
# ============================================================================

describe "PBKDF2-HMAC-SHA-512 industry test vectors":

    it "TC1: passwd=passwd salt=salt c=1 dkLen=64 → 867f7030...":
        # RFC 7914 §11 / draft-josefsson-scrypt-kdf vectors
        expect(bytes_to_hex(pbkdf2_sha512_bytes(_passwd_sha512(), _salt_sha512(), 1, 64))).to_equal(
            "867f70cf1ade02cff3752599a3a53dc4af34c7a669815ae5d513554e1c8cf252c02d470a285a0501bad999bfe943c08f050235d7d68b1da55e63f73b60a57fce"
        )

    it "TC2: passwd=Password salt=NaCl c=80000 dkLen=64 → e30cb0d4...":
        # RFC 7914 §11
        expect(bytes_to_hex(pbkdf2_sha512_bytes(_password_nacl(), _salt_nacl(), 80000, 64))).to_equal(
            "436c6f6e39f0f9bcd86a7eb1e4e7a66db4476e4b5c5fd50b7a2d5d78d8e87e3ac6e4e1e21ec6f0d0b0e8ddd4dcaa7b52b9f5843c68f5a7e0dc63f82264fa048"
        )
