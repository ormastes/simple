# =============================================================================
# ML-DSA-65 (FIPS 204) — round-trip + invariant spec
#
# Algebraic invariants verified in interpreter mode (per
# feedback_compile_mode_false_greens.md, since `--mode=native` and `--mode=smf`
# both swallow runtime errors / no-op unresolved externs):
#
#   1. NTT(NTT⁻¹(p)) == p  for non-trivial polynomials over Z_q (q=8380417)
#   2. NTT([1, 0, ..., 0]) == [1; 256]  (validates the BitRev8 zetas table)
#   3. NTT-domain pointwise multiplication followed by INTT equals direct
#      polynomial multiplication in Z_q[X]/(X^256 + 1)
#   4. Power2Round / Decompose round-trips
#   5. MakeHint / UseHint property: UseHint(MakeHint(z, r), r+z) == HighBits(r)
#   6. SimpleBitPack / SimpleBitUnpack round-trip at 4-bit and 10-bit widths
#   7. SHAKE-128("") and SHAKE-256("") match NIST FIPS 202 KAT first-16 bytes
#   8. ml_dsa_keygen_65(seed) → (pk, sk) of expected sizes (1952B, 4032B)
#   9. SampleInBall produces exactly tau=49 nonzero coefficients in {-1, 0, +1}
#  10. Sign(sk, m) → σ; Verify(pk, m, σ) == true  (W13-D, 2026-05-02)
#  11. Verify rejects bit-flipped message and bit-flipped signature
#       (negative-path correctness).
#
# Run via:  bin/simple test/unit/lib/crypto/ml_dsa_65_spec.spl
# (Direct invocation per feedback_compile_mode_false_greens.md.)
# =============================================================================

use std.spipe.*
use os.crypto.ml_dsa_ntt.{ntt, intt, ntt_multiply, modq, ml_dsa_q, ml_dsa_n, power2round_int, decompose_int, high_bits_int, make_hint_int, use_hint_int, ml_dsa_gamma2_65}
use os.crypto.ml_dsa_sample.{shake128, shake256, simple_bit_pack, simple_bit_unpack, sample_in_ball, pk_size_65, sk_size_65, sig_size_65}
use os.crypto.ml_dsa.{ml_dsa_keygen_65, ml_dsa_sign_65, ml_dsa_verify_65}

# ----- module-level helpers ----------------------------------------------
# Per feedback_it_block_var_mutation.md, push-loops inside `it` blocks lose
# their mutations under the interpreter; we build payloads in module-level
# fn helpers so each `it` body sees a single `val` already populated.

fn _hex(bytes: list, n: i64) -> text:
    var s = ""
    val hex = "0123456789abcdef"
    var i = 0
    while i < n:
        val b = bytes.get(i)
        s = s + hex.char_at((b >> 4) & 0x0f) + hex.char_at(b & 0x0f)
        i = i + 1
    s

fn _seed32(start: i64) -> list:
    var v = []
    var i = 0
    while i < 32:
        v.push((start + i) & 0xff)
        i = i + 1
    v

fn _zero_poly() -> list:
    var p = []
    var i = 0
    while i < 256:
        p.push(0)
        i = i + 1
    p

fn _coeff_pmul(a: list, b: list) -> list:
    val q = ml_dsa_q()
    var c = _zero_poly()
    var ii = 0
    while ii < 256:
        var jj = 0
        while jj < 256:
            val k = ii + jj
            val prod = (a.get(ii) * b.get(jj)) % q
            if k < 256:
                c[k] = modq(c.get(k) + prod)
            else:
                c[k - 256] = modq(c.get(k - 256) - prod)
            jj = jj + 1
        ii = ii + 1
    c

fn _build_seq_mod(modulus: i64) -> list:
    var p = []
    var i = 0
    while i < 256:
        p.push(i % modulus)
        i = i + 1
    p

# Build a non-trivial Z_q poly with values that exercise reduction.
fn _build_test_poly() -> list:
    var p = []
    var i = 0
    while i < 256:
        p.push((i * 1009 + 17) % ml_dsa_q())
        i = i + 1
    p

fn _ntt_round_trip_ok() -> bool:
    val p = _build_test_poly()
    val r = intt(ntt(p))
    var ok = true
    var k = 0
    while k < 256:
        if r.get(k) != p.get(k):
            ok = false
        k = k + 1
    ok

fn _ntt_constant_poly_ok() -> bool:
    var p = _zero_poly()
    p[0] = 1
    val n = ntt(p)
    var ok = true
    var k = 0
    while k < 256:
        if n.get(k) != 1:
            ok = false
        k = k + 1
    ok

fn _ntt_pointwise_matches_direct_ok() -> bool:
    var a = _zero_poly()
    var b = _zero_poly()
    a[1] = 1
    b[1] = 1
    val direct = _coeff_pmul(a, b)
    val via_ntt = intt(ntt_multiply(ntt(a), ntt(b)))
    var ok = true
    var k = 0
    while k < 256:
        if direct.get(k) != via_ntt.get(k):
            ok = false
        k = k + 1
    ok

fn _ntt_negacyclic_boundary() -> i64:
    var a = _zero_poly()
    var b = _zero_poly()
    a[255] = 1
    b[1] = 1
    val via_ntt = intt(ntt_multiply(ntt(a), ntt(b)))
    via_ntt.get(0)

fn _decompose_r1_max() -> i64:
    var max_r1 = -1
    var i = 0
    while i < 200:
        val r = (i * 41737 + 7) % ml_dsa_q()
        val pair = decompose_int(r)
        if pair[0] > max_r1:
            max_r1 = pair[0]
        i = i + 1
    max_r1

fn _decompose_r1_min() -> i64:
    var min_r1 = 999
    var i = 0
    while i < 200:
        val r = (i * 41737 + 7) % ml_dsa_q()
        val pair = decompose_int(r)
        if pair[0] < min_r1:
            min_r1 = pair[0]
        i = i + 1
    min_r1

fn _make_use_hint_failures() -> i64:
    var fails = 0
    var k = 0
    while k < 50:
        val r = (k * 73 + 12345) % ml_dsa_q()
        val z = (k * 17 + 100) % ml_dsa_q()
        val h = make_hint_int(z, r)
        val w1 = use_hint_int(h, modq(r + z))
        val expected = high_bits_int(r)
        if w1 != expected:
            fails = fails + 1
        k = k + 1
    fails

fn _bitpack_size(bitlen: i64) -> i64:
    val packed = simple_bit_pack(_build_seq_mod(1 << bitlen), bitlen)
    packed.len()

fn _bitpack_roundtrip_ok(bitlen: i64) -> bool:
    val src = _build_seq_mod(1 << bitlen)
    val packed = simple_bit_pack(src, bitlen)
    val unpacked = simple_bit_unpack(packed, bitlen, 256)
    var ok = true
    var k = 0
    while k < 256:
        if unpacked.get(k) != src.get(k):
            ok = false
        k = k + 1
    ok

fn _sample_in_ball_nonzero_count(tau: i64) -> i64:
    val c = sample_in_ball(_seed32(1), tau)
    var nonzeros = 0
    var i = 0
    while i < 256:
        if c.get(i) != 0:
            nonzeros = nonzeros + 1
        i = i + 1
    nonzeros

fn _sample_in_ball_only_pm1(tau: i64) -> bool:
    val c = sample_in_ball(_seed32(1), tau)
    var bad = false
    var i = 0
    while i < 256:
        val v = c.get(i)
        if v != 0 and v != 1 and v != -1:
            bad = true
        i = i + 1
    not bad

fn _keygen_pk_len() -> i64:
    val xi = _seed32(0)
    val kp = ml_dsa_keygen_65(xi)
    val pk = kp[0]
    pk.len()

fn _keygen_sk_len() -> i64:
    val xi = _seed32(0)
    val kp = ml_dsa_keygen_65(xi)
    val sk = kp[1]
    sk.len()

fn _build_msg() -> list:
    var msg = []
    var m = 0
    while m < 16:
        msg.push(0x42)
        m = m + 1
    msg

fn _zero_rnd() -> list:
    var r = []
    var i = 0
    while i < 32:
        r.push(0)
        i = i + 1
    r

# End-to-end Sign + Verify round-trip.  Fixed in W13-D (2026-05-02): _z_pack
# was bit-packing z values in their [0, q) representation rather than the
# centered representation, so q-aliased negatives encoded to garbage and
# Verify could not reconstruct the same w1.  See bug doc.
fn _sign_verify_round_trip() -> bool:
    val xi = _seed32(0)
    val kp = ml_dsa_keygen_65(xi)
    val pk = kp[0]
    val sk = kp[1]
    val msg = _build_msg()
    val rnd = _zero_rnd()
    val sig = ml_dsa_sign_65(sk, msg, rnd)
    if sig.len() == 0:
        false
    else:
        ml_dsa_verify_65(pk, msg, sig)

# Negative path: tampered message must fail verification.  Critical companion
# to the positive-case test (per W13-D discipline note: a verify-everything
# implementation would pass the positive test for the wrong reason).
fn _verify_rejects_tampered_msg() -> bool:
    val xi = _seed32(0)
    val kp = ml_dsa_keygen_65(xi)
    val pk = kp[0]
    val sk = kp[1]
    val msg = _build_msg()
    val rnd = _zero_rnd()
    val sig = ml_dsa_sign_65(sk, msg, rnd)
    var msg2 = []
    var i = 0
    while i < msg.len():
        msg2.push(msg.get(i))
        i = i + 1
    msg2[0] = msg2.get(0) ^ 1
    not ml_dsa_verify_65(pk, msg2, sig)

# Negative path: bit-flip in c_tilde (sig prefix) must fail verification.
fn _verify_rejects_tampered_sig() -> bool:
    val xi = _seed32(0)
    val kp = ml_dsa_keygen_65(xi)
    val pk = kp[0]
    val sk = kp[1]
    val msg = _build_msg()
    val rnd = _zero_rnd()
    val sig = ml_dsa_sign_65(sk, msg, rnd)
    var sig2 = []
    var i = 0
    while i < sig.len():
        sig2.push(sig.get(i))
        i = i + 1
    sig2[0] = sig2.get(0) ^ 1
    not ml_dsa_verify_65(pk, msg, sig2)

# ----- specs -------------------------------------------------------------

describe "ML-DSA-65 NTT and ring primitives":

    it "NTT round-trip preserves coefficient-domain polynomial":
        expect _ntt_round_trip_ok() == true

    it "NTT([1, 0, ..., 0]) == [1; 256] (zetas table validation)":
        expect _ntt_constant_poly_ok() == true

    it "NTT pointwise multiplication equals coefficient-domain convolution":
        expect _ntt_pointwise_matches_direct_ok() == true

    it "X^255 * X = -1 mod (X^256 + 1) via NTT":
        expect _ntt_negacyclic_boundary() == ml_dsa_q() - 1


describe "ML-DSA-65 Power2Round + Decompose":

    it "Power2Round(r) recovers r1 * 2^13 + r0 == r":
        val pair = power2round_int(1234567)
        expect pair[0] * 8192 + pair[1] == 1234567

    it "Decompose(r) reconstructs r mod q":
        val pair = decompose_int(1234567)
        expect modq(pair[0] * 2 * ml_dsa_gamma2_65() + pair[1]) == 1234567

    it "Decompose r1 lies in [0, 16) for q=8380417 over 200 samples":
        expect _decompose_r1_min() >= 0 == true
        expect _decompose_r1_max() <= 15 == true


describe "ML-DSA-65 MakeHint / UseHint":

    it "UseHint(MakeHint(z, r), r+z) recovers HighBits(r) for 50 samples":
        expect _make_use_hint_failures() == 0


describe "ML-DSA-65 BitPack round-trip":

    it "SimpleBitPack at 10 bits packs 256 coefficients to 320 bytes":
        expect _bitpack_size(10) == 320

    it "SimpleBitPack at 10 bits round-trips":
        expect _bitpack_roundtrip_ok(10) == true

    it "SimpleBitPack at 4 bits packs 256 coefficients to 128 bytes":
        expect _bitpack_size(4) == 128

    it "SimpleBitPack at 4 bits round-trips":
        expect _bitpack_roundtrip_ok(4) == true


describe "ML-DSA-65 SHAKE NIST KAT":

    it "SHAKE-128(\"\")[0..16] matches FIPS 202 reference":
        val out = shake128([], 16)
        expect _hex(out, 16) == "7f9c2ba4e88f827d616045507605853e"

    it "SHAKE-256(\"\")[0..16] matches FIPS 202 reference":
        val out = shake256([], 16)
        expect _hex(out, 16) == "46b9dd2b0ba88d13233b3feb743eeb24"


describe "ML-DSA-65 SampleInBall":

    it "produces exactly tau=49 nonzero coefficients":
        expect _sample_in_ball_nonzero_count(49) == 49

    it "all nonzero coefficients are in {-1, +1}":
        expect _sample_in_ball_only_pm1(49) == true


describe "ML-DSA-65 KeyGen sizes":

    it "ml_dsa_keygen_65 produces pk of size 1952 bytes (FIPS 204 §B)":
        expect _keygen_pk_len() == 1952
        expect _keygen_pk_len() == pk_size_65()

    it "ml_dsa_keygen_65 produces sk of size 4032 bytes (FIPS 204 §B)":
        expect _keygen_sk_len() == 4032
        expect _keygen_sk_len() == sk_size_65()


describe "ML-DSA-65 end-to-end Sign + Verify":

    # W13-D, 2026-05-02: fixed by centering z before _z_pack (see ml_dsa.spl).
    # Bug doc:  doc/08_tracking/bug/ml_dsa_sign_verify_pipeline_2026-05-02.md.
    # Negative-path tests below are NON-NEGOTIABLE companions to the positive
    # case — they prove Verify is not a reject-everything (or accept-everything)
    # stub.

    it "Sign(sk, m) → σ; Verify(pk, m, σ) == true":
        expect _sign_verify_round_trip() == true

    it "Verify rejects bit-flipped message":
        expect _verify_rejects_tampered_msg() == true

    it "Verify rejects bit-flipped signature (c_tilde)":
        expect _verify_rejects_tampered_sig() == true