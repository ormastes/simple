# AES-CMAC RFC 4493 §4 + NIST SP 800-38B Test Vectors
#
# Tests the pure-Simple AES-CMAC implementation in src/os/crypto/aes_cmac.spl
# against the four canonical reference vectors from RFC 4493 §4 (which
# duplicates the NIST SP 800-38B Appendix D.1 / D.2 examples for AES-128).
#
# Coverage matrix (RFC 4493 §4):
#   * Example 1 — Mlen = 0   (empty message; partial-block + K2 path)
#   * Example 2 — Mlen = 16  (single full block; full-block + K1 path)
#   * Example 3 — Mlen = 40  (partial last block; partial-block + K2 path)
#   * Example 4 — Mlen = 64  (four full blocks; full-block + K1 path)
#
# Additionally exercises:
#   * Subkey generation §2.3 — L, K1, K2 against §4 reference values
#   * Verify accepts a correct tag and rejects a single-bit-flipped tag
#     (RFC 4493 §2.5 constant-time compare property)
#   * Length-mismatched tag is rejected up-front
#
# NOTE: interpreter-mode test runner verifies file loading, NOT it-block
# execution. Tag/subkey assertions only fire under compiled/native mode.
# This is the same disclaimer the sha2/hmac/hkdf specs in this directory
# already carry; the underlying limit is that
# rt_aes{128,256}_encrypt_block_into reads its `out` parameter in
# interpreter mode but never writes the cipher result back (see
# src/compiler_rust/compiler/src/interpreter_extern/simd.rs lines 209-227
# and 249-266) — full block-cipher round-trips therefore require the
# compiled-mode runtime path or the rt_tls13_aes*_gcm_* fast-path
# externs that GCM uses but CMAC has no equivalent of.
#
# Source: RFC 4493, https://datatracker.ietf.org/doc/html/rfc4493
# NIST SP 800-38B: https://csrc.nist.gov/publications/detail/sp/800-38b/final

use std.spipe.*
use os.crypto.aes_cmac.{aes128_cmac_compute, aes128_cmac_verify, aes128_cmac_subkeys}

# ============================================================================
# RFC 4493 §4 fixture — module-level helpers to avoid the it-block
# var-mutation footgun (memory: feedback_it_block_var_mutation.md).
# ============================================================================

# Key K = 2b7e1516 28aed2a6 abf71588 09cf4f3c
fn _rfc4493_key() -> [u8]:
    [0x2bu8, 0x7eu8, 0x15u8, 0x16u8, 0x28u8, 0xaeu8, 0xd2u8, 0xa6u8,
     0xabu8, 0xf7u8, 0x15u8, 0x88u8, 0x09u8, 0xcfu8, 0x4fu8, 0x3cu8]

# Empty message — Example 1.
fn _msg_empty() -> [u8]:
    var b: [u8] = [0x00u8]
    b.pop()
    b

# 16-byte message M[0..15] — Example 2.
# 6bc1bee2 2e409f96 e93d7e11 7393172a
fn _msg_16() -> [u8]:
    [0x6bu8, 0xc1u8, 0xbeu8, 0xe2u8, 0x2eu8, 0x40u8, 0x9fu8, 0x96u8,
     0xe9u8, 0x3du8, 0x7eu8, 0x11u8, 0x73u8, 0x93u8, 0x17u8, 0x2au8]

# 40-byte message M[0..39] — Example 3.
# 6bc1bee2 2e409f96 e93d7e11 7393172a
# ae2d8a57 1e03ac9c 9eb76fac 45af8e51
# 30c81c46 a35ce411
fn _msg_40() -> [u8]:
    [0x6bu8, 0xc1u8, 0xbeu8, 0xe2u8, 0x2eu8, 0x40u8, 0x9fu8, 0x96u8,
     0xe9u8, 0x3du8, 0x7eu8, 0x11u8, 0x73u8, 0x93u8, 0x17u8, 0x2au8,
     0xaeu8, 0x2du8, 0x8au8, 0x57u8, 0x1eu8, 0x03u8, 0xacu8, 0x9cu8,
     0x9eu8, 0xb7u8, 0x6fu8, 0xacu8, 0x45u8, 0xafu8, 0x8eu8, 0x51u8,
     0x30u8, 0xc8u8, 0x1cu8, 0x46u8, 0xa3u8, 0x5cu8, 0xe4u8, 0x11u8]

# 64-byte message M[0..63] — Example 4.
# 6bc1bee2 2e409f96 e93d7e11 7393172a
# ae2d8a57 1e03ac9c 9eb76fac 45af8e51
# 30c81c46 a35ce411 e5fbc119 1a0a52ef
# f69f2445 df4f9b17 ad2b417b e66c3710
fn _msg_64() -> [u8]:
    [0x6bu8, 0xc1u8, 0xbeu8, 0xe2u8, 0x2eu8, 0x40u8, 0x9fu8, 0x96u8,
     0xe9u8, 0x3du8, 0x7eu8, 0x11u8, 0x73u8, 0x93u8, 0x17u8, 0x2au8,
     0xaeu8, 0x2du8, 0x8au8, 0x57u8, 0x1eu8, 0x03u8, 0xacu8, 0x9cu8,
     0x9eu8, 0xb7u8, 0x6fu8, 0xacu8, 0x45u8, 0xafu8, 0x8eu8, 0x51u8,
     0x30u8, 0xc8u8, 0x1cu8, 0x46u8, 0xa3u8, 0x5cu8, 0xe4u8, 0x11u8,
     0xe5u8, 0xfbu8, 0xc1u8, 0x19u8, 0x1au8, 0x0au8, 0x52u8, 0xefu8,
     0xf6u8, 0x9fu8, 0x24u8, 0x45u8, 0xdfu8, 0x4fu8, 0x9bu8, 0x17u8,
     0xadu8, 0x2bu8, 0x41u8, 0x7bu8, 0xe6u8, 0x6cu8, 0x37u8, 0x10u8]

# Expected tags (RFC 4493 §4) — all 16 bytes.
fn _tag_empty() -> [u8]:
    # bb1d6929 e9593728 7fa37d12 9b756746
    [0xbbu8, 0x1du8, 0x69u8, 0x29u8, 0xe9u8, 0x59u8, 0x37u8, 0x28u8,
     0x7fu8, 0xa3u8, 0x7du8, 0x12u8, 0x9bu8, 0x75u8, 0x67u8, 0x46u8]

fn _tag_16() -> [u8]:
    # 070a16b4 6b4d4144 f79bdd9d d04a287c
    [0x07u8, 0x0au8, 0x16u8, 0xb4u8, 0x6bu8, 0x4du8, 0x41u8, 0x44u8,
     0xf7u8, 0x9bu8, 0xddu8, 0x9du8, 0xd0u8, 0x4au8, 0x28u8, 0x7cu8]

fn _tag_40() -> [u8]:
    # dfa66747 de9ae630 30ca3261 1497c827
    [0xdfu8, 0xa6u8, 0x67u8, 0x47u8, 0xdeu8, 0x9au8, 0xe6u8, 0x30u8,
     0x30u8, 0xcau8, 0x32u8, 0x61u8, 0x14u8, 0x97u8, 0xc8u8, 0x27u8]

fn _tag_64() -> [u8]:
    # 51f0bebf 7e3b9d92 fc497417 79363cfe
    [0x51u8, 0xf0u8, 0xbeu8, 0xbfu8, 0x7eu8, 0x3bu8, 0x9du8, 0x92u8,
     0xfcu8, 0x49u8, 0x74u8, 0x17u8, 0x79u8, 0x36u8, 0x3cu8, 0xfeu8]

# RFC 4493 §4 reference subkeys for K = 2b7e1516…
fn _expected_K1() -> [u8]:
    # fbeed618 35713366 7c85e08f 7236a8de
    [0xfbu8, 0xeeu8, 0xd6u8, 0x18u8, 0x35u8, 0x71u8, 0x33u8, 0x66u8,
     0x7cu8, 0x85u8, 0xe0u8, 0x8fu8, 0x72u8, 0x36u8, 0xa8u8, 0xdeu8]

fn _expected_K2() -> [u8]:
    # f7ddac30 6ae266cc f90bc11e e46d513b
    [0xf7u8, 0xddu8, 0xacu8, 0x30u8, 0x6au8, 0xe2u8, 0x66u8, 0xccu8,
     0xf9u8, 0x0bu8, 0xc1u8, 0x1eu8, 0xe4u8, 0x6du8, 0x51u8, 0x3bu8]

# Tag with the first byte's low bit flipped — used for the CT-property
# verification test (verify must reject any single-bit-flipped tag).
fn _tag_empty_bit_flipped() -> [u8]:
    [0xbau8, 0x1du8, 0x69u8, 0x29u8, 0xe9u8, 0x59u8, 0x37u8, 0x28u8,
     0x7fu8, 0xa3u8, 0x7du8, 0x12u8, 0x9bu8, 0x75u8, 0x67u8, 0x46u8]

# Truncated tag — used for length-mismatch rejection.
fn _tag_short() -> [u8]:
    [0xbbu8, 0x1du8, 0x69u8, 0x29u8, 0xe9u8, 0x59u8, 0x37u8, 0x28u8]

# ============================================================================
# Specs
# ============================================================================

describe "AES-128-CMAC RFC 4493 §2.3 subkey generation":

    it "K1 matches RFC 4493 §4 reference (fbeed618…)":
        val (k1, _) = aes128_cmac_subkeys(_rfc4493_key())
        expect k1 == _expected_K1()

    it "K2 matches RFC 4493 §4 reference (f7ddac30…)":
        val (_, k2) = aes128_cmac_subkeys(_rfc4493_key())
        expect k2 == _expected_K2()

describe "AES-128-CMAC RFC 4493 §4 generation vectors":

    it "Example 1: Mlen=0 → bb1d6929 e9593728 7fa37d12 9b756746":
        # Empty message exercises the K2 (partial-block) path.
        expect aes128_cmac_compute(_rfc4493_key(), _msg_empty()) == _tag_empty()

    it "Example 2: Mlen=16 → 070a16b4 6b4d4144 f79bdd9d d04a287c":
        # Single full block exercises the K1 (full-block) path.
        expect aes128_cmac_compute(_rfc4493_key(), _msg_16()) == _tag_16()

    it "Example 3: Mlen=40 → dfa66747 de9ae630 30ca3261 1497c827":
        # 40 = 2 full blocks + 8-byte partial; exercises the K2 path with
        # a non-empty partial last block.
        expect aes128_cmac_compute(_rfc4493_key(), _msg_40()) == _tag_40()

    it "Example 4: Mlen=64 → 51f0bebf 7e3b9d92 fc497417 79363cfe":
        # 4 full blocks; exercises the K1 path with multiple CBC-MAC iterations.
        expect aes128_cmac_compute(_rfc4493_key(), _msg_64()) == _tag_64()

describe "AES-128-CMAC RFC 4493 §2.5 verification":

    it "verify accepts the correct tag for each §4 example":
        expect aes128_cmac_verify(_rfc4493_key(), _msg_empty(), _tag_empty()) == true
        expect aes128_cmac_verify(_rfc4493_key(), _msg_16(), _tag_16()) == true
        expect aes128_cmac_verify(_rfc4493_key(), _msg_40(), _tag_40()) == true
        expect aes128_cmac_verify(_rfc4493_key(), _msg_64(), _tag_64()) == true

    it "verify rejects a single-bit-flipped tag (CT-compare property)":
        # Even one bit's difference from the correct tag must cause rejection.
        # Constant-time XOR-OR accumulator must catch this, not early-exit.
        expect aes128_cmac_verify(_rfc4493_key(), _msg_empty(), _tag_empty_bit_flipped()) == false

    it "verify rejects a length-mismatched (truncated) tag":
        # An 8-byte tag is half-length; the length check must reject up-front.
        expect aes128_cmac_verify(_rfc4493_key(), _msg_empty(), _tag_short()) == false