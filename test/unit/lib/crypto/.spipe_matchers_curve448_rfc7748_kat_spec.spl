# ============================================================================
# Tests
# ============================================================================

describe "Curve448 RFC 7748 §5.2 single scalar-mult test vectors":
    it "TV1: scalar 3d262fdd... × u 06fce640... → ce3e4ff9...":
        expect x448_scalar_mult(SCALAR_TV1, U_TV1) == EXPECTED_TV1

    it "TV2: scalar 203d4944... × u 0fbcc2f9... → 884a0257...":
        expect x448_scalar_mult(SCALAR_TV2, U_TV2) == EXPECTED_TV2

describe "Curve448 RFC 7748 §5.2 iterated scalar-mult (1 iteration)":
    it "after 1 iteration from BASE_POINT: 3f482c8a...":
        expect x448_scalar_mult(BASE_POINT_448, BASE_POINT_448) == EXPECTED_ITER1

describe "Curve448 RFC 7748 §6.2 ECDH key exchange":
    it "Alice public key: x448_keygen(alice_priv)[1] == alice_pub":
        val kp = x448_keygen(ALICE_PRIV_448)
        expect kp[1] == ALICE_PUB_448

    it "Bob public key: x448_keygen(bob_priv)[1] == bob_pub":
        val kp = x448_keygen(BOB_PRIV_448)
        expect kp[1] == BOB_PUB_448

    it "Alice computes shared secret: x448_dh(alice_priv, bob_pub) == shared":
        expect x448_dh(ALICE_PRIV_448, BOB_PUB_448) == SHARED_SECRET_448

    it "Bob computes shared secret: x448_dh(bob_priv, alice_pub) == shared":
        expect x448_dh(BOB_PRIV_448, ALICE_PUB_448) == SHARED_SECRET_448