# =============================================================================
# P-256 Constant-Time Property Spec
# =============================================================================
#
# Companion spec to `test/unit/os/tls13/p256_named_group_spec.spl`, focused on
# the constant-time discipline on the secret-scalar code path. Filed against
# the fix for
# `doc/08_tracking/feature_request/p256_scalar_mult_constant_time_2026-05-01.md`.
#
# Mirrors `test/unit/lib/crypto/ed25519_ct_property_spec.spl` (W5-A).
#
# Three checks:
#
# 1. Determinism — same scalar, same public key. Confirms the rewritten
#    always-add-and-select loop in `_scalar_mul_affine` has no nondeterminism.
#
# 2. Single-bit-flip distinguishes — two scalars differing in one bit must
#    produce distinct `p256_keypair_pub` outputs (correctness). The always-add
#    path must still propagate the bit selection.
#
# 3. Structural CT inspection — read the live source of
#    `src/os/crypto/ecdh_p256.spl`, locate the body of `fn _scalar_mul_affine`,
#    and assert the body contains NO `if` branch on the scalar byte/bit. The
#    previous leaky form was `if (byte & mask) != 0u8:`. None of those
#    fingerprints may survive. Positive sanity: the body MUST mention
#    `p256_point_cselect`.
#
# A wall-time timing test would be unreliable in interpreter mode (per the FR
# itself); the structural property test is the hard guarantee.
#
# Per `feedback_no_coverups.md`: no skip(), no relaxed assertions.
# =============================================================================

use std.spipe.*
use os.crypto.ecdh_p256.{p256_keypair_pub}

# -----------------------------------------------------------------------------
# Helpers
# -----------------------------------------------------------------------------

extern fn rt_file_read_text(path: text) -> text

fn _bytes_equal(a: [u8], b: [u8]) -> bool:
    if a.len() != b.len():
        return false
    var i: i64 = 0
    while i < a.len():
        if a[i] != b[i]:
            return false
        i = i + 1
    true

fn _scalar_filled(byte_val: u8) -> [u8]:
    """A 32-byte scalar where every byte equals `byte_val`."""
    var out: [u8] = []
    var i: i64 = 0
    while i < 32:
        out.push(byte_val)
        i = i + 1
    out

fn _scalar_one() -> [u8]:
    """The scalar k=1 (big-endian). Multiplying G by 1 returns G itself."""
    var out: [u8] = []
    var i: i64 = 0
    while i < 31:
        out.push(0x00u8)
        i = i + 1
    out.push(0x01u8)
    out

fn _scalar_two() -> [u8]:
    """The scalar k=2 (big-endian). Differs from k=1 in exactly one bit."""
    var out: [u8] = []
    var i: i64 = 0
    while i < 31:
        out.push(0x00u8)
        i = i + 1
    out.push(0x02u8)
    out

# -----------------------------------------------------------------------------
# Specs
# -----------------------------------------------------------------------------

describe("P-256 constant-time discipline on secret-scalar path"):

    it("derives the same public key when called twice on the same scalar (determinism)"):
        val scalar = _scalar_filled(0x42u8)
        val key_a = p256_keypair_pub(scalar)
        val key_b = p256_keypair_pub(scalar)
        expect(_bytes_equal(a: key_a, b: key_b)).to_be(true)
        expect(key_a.len()).to_be(65)

    it("two scalars differing in one bit produce distinct public keys (k=1 vs k=2)"):
        val s1 = _scalar_one()
        val s2 = _scalar_two()
        val key1 = p256_keypair_pub(s1)
        val key2 = p256_keypair_pub(s2)
        expect(key1.len()).to_be(65)
        expect(key2.len()).to_be(65)
        expect(_bytes_equal(a: key1, b: key2)).to_be(false)

    it("low-Hamming-weight scalar (0x00..0x01) produces a valid 65-byte SEC1 point"):
        val scalar = _scalar_one()
        val key = p256_keypair_pub(scalar)
        expect(key.len()).to_be(65)
        expect(key[0]).to_equal(0x04u8)

    it("high-Hamming-weight scalar (0xFF * 32) produces a valid 65-byte SEC1 point"):
        val scalar = _scalar_filled(0xFFu8)
        val key = p256_keypair_pub(scalar)
        expect(key.len()).to_be(65)
        expect(key[0]).to_equal(0x04u8)

    it("structural CT: _scalar_mul_affine body contains no `if` branch on a scalar bit"):
        val src = rt_file_read_text("src/os/crypto/ecdh_p256.spl")

        # Locate the function header.
        val hdr = "fn _scalar_mul_affine(scalar: [u8], ax: FeP256, ay: FeP256) -> JacP256:"
        val start_opt = src.find(hdr)
        val start: i64 = start_opt ?? (-1).to_i64()
        expect(start >= 0).to_be(true)

        # The body ends at the next top-level `\nfn ` after the header.
        val after_hdr: u64 = (start.to_u64()) + hdr.len()
        val rest = src.substring(after_hdr, src.len())
        val next_fn_opt = rest.find("\nfn ")
        var body_end: u64 = src.len()
        val nfo: i64 = next_fn_opt ?? (-1).to_i64()
        if nfo >= 0:
            body_end = after_hdr + nfo.to_u64()

        val body = src.substring(after_hdr, body_end)

        # OLD branchful form fingerprints. None of these may survive.
        val has_byte_mask_branch = (body.find("if (byte & mask)") ?? (-1).to_i64()) >= 0
        val has_byte_amp_branch = (body.find("if (byte &") ?? (-1).to_i64()) >= 0
        val has_scalar_idx_branch = (body.find("if scalar[") ?? (-1).to_i64()) >= 0
        val has_neq_zero = (body.find("!= 0u8") ?? (-1).to_i64()) >= 0

        expect(has_byte_mask_branch).to_be(false)
        expect(has_byte_amp_branch).to_be(false)
        expect(has_scalar_idx_branch).to_be(false)
        expect(has_neq_zero).to_be(false)

        # Positive sanity: the new body MUST call the constant-time helper.
        val cselect_idx: i64 = body.find("p256_point_cselect") ?? (-1).to_i64()
        expect(cselect_idx >= 0).to_be(true)
