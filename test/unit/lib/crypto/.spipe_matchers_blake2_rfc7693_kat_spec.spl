# BLAKE2b + BLAKE2s RFC 7693 Known-Answer Test Vectors
#
# Tests the pure-Simple BLAKE2 implementations in
#   src/os/crypto/blake2b.spl  (RFC 7693 §3, 64-bit variant)
#   src/os/crypto/blake2s.spl  (RFC 7693 §3, 32-bit variant)
# against the canonical reference values from RFC 7693 Appendix A/B and
# the upstream BLAKE2 reference test vector set
# (https://github.com/BLAKE2/BLAKE2/blob/master/testvectors/blake2-kat.json).
#
# Coverage (8 vectors total):
#   Unkeyed:
#     - BLAKE2b("abc", out=64)              [RFC 7693 Appendix A]
#     - BLAKE2s("abc", out=32)              [RFC 7693 Appendix B]
#     - BLAKE2b("a"*128, out=64)            [multi-block boundary]
#     - BLAKE2s("a"*64, out=32)             [multi-block boundary]
#   Keyed (key = 00 01 02 ... (kk-1), in = ""):
#     - BLAKE2b(key=00..3f, in="", out=64)  [blake2-kat.json]
#     - BLAKE2s(key=00..1f, in="", out=32)  [blake2-kat.json]
#   Keyed (key = 00 01 .. 07, in = "Hi There"):
#     - BLAKE2b(key=00..07, in="Hi There", out=64)
#     - BLAKE2s(key=00..07, in="Hi There", out=32)
#
# Reference values cross-verified with Python hashlib.blake2b/blake2s.
#
# NOTE: interpreter-mode test runner verifies file loading, NOT it-block
# execution. Digest assertions only fire under compiled/native mode
# (see feedback_compile_mode_false_greens.md).

use std.spipe.*
use os.crypto.blake2b.{blake2b}
use os.crypto.blake2s.{blake2s}

# ============================================================================
# Helpers
# ============================================================================

fn _bytes_to_hex(bytes: [u8]) -> text:
    """Convert a byte list to lowercase hex without separators."""
    val hex_chars = "0123456789abcdef"
    var out = ""
    var i: i64 = 0
    val n = bytes.len()
    while i < n:
        val b = bytes[i].to_i64()
        out = out + hex_chars.char_at((b >> 4) & 0xF).to_text()
        out = out + hex_chars.char_at(b & 0xF).to_text()
        i = i + 1
    out

fn _abc_bytes() -> [u8]:
    """ASCII bytes for "abc"."""
    var out: [u8] = []
    out.push(0x61)
    out.push(0x62)
    out.push(0x63)
    out

fn _hi_there_bytes() -> [u8]:
    """ASCII bytes for "Hi There"."""
    var out: [u8] = []
    out.push(0x48)
    out.push(0x69)
    out.push(0x20)
    out.push(0x54)
    out.push(0x68)
    out.push(0x65)
    out.push(0x72)
    out.push(0x65)
    out

fn _empty_bytes() -> [u8]:
    val out: [u8] = []
    out

fn _range_bytes(n: i64) -> [u8]:
    """[0, 1, 2, ..., n-1] as a byte list."""
    var out: [u8] = []
    var i: i64 = 0
    while i < n:
        out.push(i.to_u8())
        i = i + 1
    out

fn _repeat_bytes(byte: i64, n: i64) -> [u8]:
    var out: [u8] = []
    var i: i64 = 0
    while i < n:
        out.push(byte.to_u8())
        i = i + 1
    out

# ============================================================================
# BLAKE2b RFC 7693 Appendix A — "abc" canary
# ============================================================================

describe "BLAKE2b RFC 7693 Appendix A test vectors":

    it "Appendix A 'abc' unkeyed digest (64 bytes)":
        # Expected: ba80a53f981c4d0d6a2797b69f12f6e94c212f14685ac4b74b12bb6fdbffa2d1
        #           7d87c5392aab792dc252d5de4533cc9518d38aa8dbf1925ab92386edd4009923
        val msg = _abc_bytes()
        val key = _empty_bytes()
        val digest = blake2b(key, msg, 64)
        expect _bytes_to_hex(digest) == "ba80a53f981c4d0d6a2797b69f12f6e94c212f14685ac4b74b12bb6fdbffa2d17d87c5392aab792dc252d5de4533cc9518d38aa8dbf1925ab92386edd4009923"

    it "multi-block: 128 bytes of 'a' unkeyed (1 full block, 64-byte digest)":
        # 128 bytes = exactly one BLAKE2b block; exercises the all-block-is-final path.
        # Reference (Python hashlib.blake2b):
        #   fc6c71f688f43ea7d60817478808f3cac753e61571865c95adbc2d9122c943a7
        #   6b92c2cb1047ef3fe7bf6e436ec1d0a99a9e5b216780bf7fed9d7ca91d3a8f3b
        val msg = _repeat_bytes(0x61, 128)
        val key = _empty_bytes()
        val digest = blake2b(key, msg, 64)
        expect _bytes_to_hex(digest) == "fc6c71f688f43ea7d60817478808f3cac753e61571865c95adbc2d9122c943a76b92c2cb1047ef3fe7bf6e436ec1d0a99a9e5b216780bf7fed9d7ca91d3a8f3b"

# ============================================================================
# BLAKE2s RFC 7693 Appendix B — "abc" canary
# ============================================================================

describe "BLAKE2s RFC 7693 Appendix B test vectors":

    it "Appendix B 'abc' unkeyed digest (32 bytes)":
        # Expected: 508c5e8c327c14e2e1a72ba34eeb452f37458b209ed63a294d999b4c86675982
        val msg = _abc_bytes()
        val key = _empty_bytes()
        val digest = blake2s(key, msg, 32)
        expect _bytes_to_hex(digest) == "508c5e8c327c14e2e1a72ba34eeb452f37458b209ed63a294d999b4c86675982"

    it "multi-block: 64 bytes of 'a' unkeyed (1 full block, 32-byte digest)":
        # Reference (Python hashlib.blake2s):
        #   651d2f5f20952eacaea2fba2f2af2bcd633e511ea2d2e4c9ae2ac0d9ffb7b252
        val msg = _repeat_bytes(0x61, 64)
        val key = _empty_bytes()
        val digest = blake2s(key, msg, 32)
        expect _bytes_to_hex(digest) == "651d2f5f20952eacaea2fba2f2af2bcd633e511ea2d2e4c9ae2ac0d9ffb7b252"

# ============================================================================
# Keyed-mode KATs from BLAKE2 reference test vector set
# (https://github.com/BLAKE2/BLAKE2/blob/master/testvectors/blake2-kat.json)
# ============================================================================

describe "BLAKE2 keyed-mode KATs (blake2-kat.json)":

    it "BLAKE2b key=00..3f in='' out=64 (blake2-kat.json kk=64 in='')":
        # Expected: 10ebb67700b1868efb4417987acf4690ae9d972fb7a590c2f02871799aaa4786
        #           b5e996e8f0f4eb981fc214b005f42d2ff4233499391653df7aefcbc13fc51568
        val key = _range_bytes(64)
        val msg = _empty_bytes()
        val digest = blake2b(key, msg, 64)
        expect _bytes_to_hex(digest) == "10ebb67700b1868efb4417987acf4690ae9d972fb7a590c2f02871799aaa4786b5e996e8f0f4eb981fc214b005f42d2ff4233499391653df7aefcbc13fc51568"

    it "BLAKE2s key=00..1f in='' out=32 (blake2-kat.json kk=32 in='')":
        # Expected: 48a8997da407876b3d79c0d92325ad3b89cbb754d86ab71aee047ad345fd2c49
        val key = _range_bytes(32)
        val msg = _empty_bytes()
        val digest = blake2s(key, msg, 32)
        expect _bytes_to_hex(digest) == "48a8997da407876b3d79c0d92325ad3b89cbb754d86ab71aee047ad345fd2c49"

    it "BLAKE2b key=00..07 in='Hi There' out=64":
        # Reference (Python hashlib.blake2b, key=bytes(range(8))):
        #   0f3623fb9296d25e4ebf6d11139e105a6265ad20bb38060e393fe43c9643718d
        #   565d8c82d089265102171de74ff8dcdff7cd299f06d69d467a9be55c5d26cc95
        val key = _range_bytes(8)
        val msg = _hi_there_bytes()
        val digest = blake2b(key, msg, 64)
        expect _bytes_to_hex(digest) == "0f3623fb9296d25e4ebf6d11139e105a6265ad20bb38060e393fe43c9643718d565d8c82d089265102171de74ff8dcdff7cd299f06d69d467a9be55c5d26cc95"

    it "BLAKE2s key=00..07 in='Hi There' out=32":
        # Reference (Python hashlib.blake2s, key=bytes(range(8))):
        #   fff44698fee4d219540d95f0f56d41888f344bf0924cef3f6d6a036a4c2aa747
        val key = _range_bytes(8)
        val msg = _hi_there_bytes()
        val digest = blake2s(key, msg, 32)
        expect _bytes_to_hex(digest) == "fff44698fee4d219540d95f0f56d41888f344bf0924cef3f6d6a036a4c2aa747"