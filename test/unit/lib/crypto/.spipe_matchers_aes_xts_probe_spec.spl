# Probe: does the i64.to_u8() workaround pass the expect_byte_array check?
use std.spipe.*
use os.crypto.aes_xts.{aes128_xts_encrypt_sector}

extern fn rt_array_new_with_cap(cap: i64) -> [u8]

fn _k1() -> [u8]:
    var b: [u8] = rt_array_new_with_cap(16)
    b.push((0x00i64).to_u8())
    b.push((0x00i64).to_u8())
    b.push((0x00i64).to_u8())
    b.push((0x00i64).to_u8())
