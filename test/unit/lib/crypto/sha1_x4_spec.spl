# SHA-1 x4 SIMD — Known-Answer Tests (NIST FIPS 180-4 + RFC 3174)
#
# Tests the vertical 4-block parallel Vec4i implementation added to
# src/lib/common/crypto/sha1.spl. Each Vec4i lane holds one independent
# message block; all 4 lanes are processed simultaneously.
#
# Test vectors:
#   FIPS 180-4 §B.0: empty string  → da39a3ee5e6b4b0d3255bfef95601890afd80709
#   FIPS 180-4 §B.1: "abc"         → a9993e364706816aba3e25717850c26c9cd0d89d
#   FIPS 180-4 §B.2: 56-byte input → 84983e441c3bd26ebaae4aa1f95129e5e54670f1
#
# Execution note: it-block bodies are verified in compiled mode. Structure and
# imports are validated by the interpreter on every test run.

use std.spipe.*
use std.crypto.sha1.{sha1_bytes, sha1_x4_message, sha1_digest_to_hex}
use std.crypto.types.{bytes_to_hex}

# ============================================================================
# Helpers
# ============================================================================

fn _list_eq(a: list, b: list) -> bool:
    """Return true if two lists have identical length and contents."""
    if a.len() != b.len():
        return false
    var i = 0
    while i < a.len():
        if a.get(i) != b.get(i):
            return false
        i = i + 1
    true

fn _str_to_bytes(s: text) -> list:
    """Convert a text string to a list of ASCII byte values."""
    var out = []
    var i = 0
    while i < s.len():
        out.push(s.char_at(i))
        i = i + 1
    out

fn _make_repeat(byte: i64, n: i64) -> list:
    """Build a list of n copies of byte."""
    var out = []
    var i = 0
    while i < n:
        out.push(byte)
        i = i + 1
    out

# The 56-byte NIST input for FIPS 180-4 §B.2.
fn _nist_56_byte() -> list:
    # "abcdbcdecdefdefgefghfghighijhijkijkljklmklmnlmnomnopnopq"
    val chars = [
        0x61, 0x62, 0x63, 0x64, 0x62, 0x63, 0x64, 0x65,  # abcdbcde
        0x63, 0x64, 0x65, 0x66, 0x64, 0x65, 0x66, 0x67,  # cdefdefg
        0x65, 0x66, 0x67, 0x68, 0x66, 0x67, 0x68, 0x69,  # efghfghi
        0x67, 0x68, 0x69, 0x6a, 0x68, 0x69, 0x6a, 0x6b,  # ghijhijk
        0x69, 0x6a, 0x6b, 0x6c, 0x6a, 0x6b, 0x6c, 0x6d,  # ijkljklm
        0x6b, 0x6c, 0x6d, 0x6e, 0x6c, 0x6d, 0x6e, 0x6f,  # klmnlmno
        0x6d, 0x6e, 0x6f, 0x70, 0x6e, 0x6f, 0x70, 0x71   # mnopnopq
    ]
    var out = []
    for c in chars:
        out.push(c)
    out

# ============================================================================
# Test 1: NIST FIPS 180-4 §B.0 — empty string in all 4 lanes
# ============================================================================

describe "sha1_x4 FIPS 180-4 §B.0 — empty string, 4 lanes":

    it "all 4 lanes of empty input produce da39a3ee...":
        val empty: list = []
        val result = sha1_x4_message(empty, empty, empty, empty)
        val d0 = result.get(0)
        val d1 = result.get(1)
        val d2 = result.get(2)
        val d3 = result.get(3)
        expect(sha1_digest_to_hex(d0)).to_equal("da39a3ee5e6b4b0d3255bfef95601890afd80709")
        expect(sha1_digest_to_hex(d1)).to_equal("da39a3ee5e6b4b0d3255bfef95601890afd80709")
        expect(sha1_digest_to_hex(d2)).to_equal("da39a3ee5e6b4b0d3255bfef95601890afd80709")
        expect(sha1_digest_to_hex(d3)).to_equal("da39a3ee5e6b4b0d3255bfef95601890afd80709")

# ============================================================================
# Test 2: NIST FIPS 180-4 §B.1 — "abc" in all 4 lanes
# ============================================================================

describe "sha1_x4 FIPS 180-4 §B.1 — 'abc', 4 lanes":

    it "all 4 lanes of 'abc' produce a9993e36...":
        val abc = [0x61, 0x62, 0x63]
        val result = sha1_x4_message(abc, abc, abc, abc)
        val d0 = result.get(0)
        val d1 = result.get(1)
        val d2 = result.get(2)
        val d3 = result.get(3)
        expect(sha1_digest_to_hex(d0)).to_equal("a9993e364706816aba3e25717850c26c9cd0d89d")
        expect(sha1_digest_to_hex(d1)).to_equal("a9993e364706816aba3e25717850c26c9cd0d89d")
        expect(sha1_digest_to_hex(d2)).to_equal("a9993e364706816aba3e25717850c26c9cd0d89d")
        expect(sha1_digest_to_hex(d3)).to_equal("a9993e364706816aba3e25717850c26c9cd0d89d")

# ============================================================================
# Test 3: NIST FIPS 180-4 §B.2 — 56-byte input (2-block message)
# ============================================================================

describe "sha1_x4 FIPS 180-4 §B.2 — 56-byte input, 4 lanes":

    it "all 4 lanes of 56-byte NIST input produce 84983e44...":
        val m = _nist_56_byte()
        val result = sha1_x4_message(m, m, m, m)
        val d0 = result.get(0)
        val d1 = result.get(1)
        val d2 = result.get(2)
        val d3 = result.get(3)
        expect(sha1_digest_to_hex(d0)).to_equal("84983e441c3bd26ebaae4aa1f95129e5e54670f1")
        expect(sha1_digest_to_hex(d1)).to_equal("84983e441c3bd26ebaae4aa1f95129e5e54670f1")
        expect(sha1_digest_to_hex(d2)).to_equal("84983e441c3bd26ebaae4aa1f95129e5e54670f1")
        expect(sha1_digest_to_hex(d3)).to_equal("84983e441c3bd26ebaae4aa1f95129e5e54670f1")

# ============================================================================
# Test 4: Lane independence — 4 different inputs produce 4 different digests
# ============================================================================

describe "sha1_x4 lane independence — 4 different inputs":

    it "4 distinct inputs produce 4 distinct digests":
        val m0: list = []                         # empty
        val m1 = [0x61, 0x62, 0x63]              # "abc"
        val m2 = [0x61]                           # "a"
        val m3 = [0x62, 0x63]                     # "bc"
        val result = sha1_x4_message(m0, m1, m2, m3)
        val d0 = sha1_digest_to_hex(result.get(0))
        val d1 = sha1_digest_to_hex(result.get(1))
        val d2 = sha1_digest_to_hex(result.get(2))
        val d3 = sha1_digest_to_hex(result.get(3))
        # All four digests must differ (lane independence)
        expect(d0 != d1).to_equal(true)
        expect(d0 != d2).to_equal(true)
        expect(d0 != d3).to_equal(true)
        expect(d1 != d2).to_equal(true)
        expect(d1 != d3).to_equal(true)
        expect(d2 != d3).to_equal(true)

# ============================================================================
# Test 5: Regression vs scalar sha1_bytes — 4 independent messages
# ============================================================================

describe "sha1_x4 regression vs scalar sha1_bytes":

    it "x4 lane results match sha1_bytes scalar for same 4 inputs":
        val m0: list = []
        val m1 = [0x61, 0x62, 0x63]
        val m2 = [0x61]
        val m3 = [0x62, 0x63]
        val result = sha1_x4_message(m0, m1, m2, m3)
        val s0 = sha1_bytes(m0)
        val s1 = sha1_bytes(m1)
        val s2 = sha1_bytes(m2)
        val s3 = sha1_bytes(m3)
        expect(_list_eq(result.get(0), s0)).to_equal(true)
        expect(_list_eq(result.get(1), s1)).to_equal(true)
        expect(_list_eq(result.get(2), s2)).to_equal(true)
        expect(_list_eq(result.get(3), s3)).to_equal(true)

# ============================================================================
# Test 6: Zero block + 3 other inputs — lane 0 matches sha1(zero), others independent
# ============================================================================

describe "sha1_x4 zero-block first lane":

    it "lane 0 matches sha1_bytes of zero-block; others match scalar independently":
        val zero_block = _make_repeat(0, 10)   # 10 zero bytes
        val m1 = [0x61, 0x62, 0x63]            # "abc"
        val m2 = [0x64, 0x65, 0x66]            # "def"
        val m3 = [0x67, 0x68, 0x69]            # "ghi"
        val result = sha1_x4_message(zero_block, m1, m2, m3)
        val expected0 = sha1_bytes(zero_block)
        val expected1 = sha1_bytes(m1)
        val expected2 = sha1_bytes(m2)
        val expected3 = sha1_bytes(m3)
        expect(_list_eq(result.get(0), expected0)).to_equal(true)
        expect(_list_eq(result.get(1), expected1)).to_equal(true)
        expect(_list_eq(result.get(2), expected2)).to_equal(true)
        expect(_list_eq(result.get(3), expected3)).to_equal(true)
