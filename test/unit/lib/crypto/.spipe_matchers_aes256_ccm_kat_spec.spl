#![allow(unnamed_duplicate_typed_args)]

# ============================================================================
# AES-256-CCM NIST CAVP Known-Answer-Test Spec
#
# Tests aes256_ccm_encrypt / aes256_ccm_decrypt against byte-exact NIST CAVP
# vectors from VADT256.rsp (pyca/cryptography mirror of NIST CAVP CCM files).
#
# Source: NIST CAVS 11.0 "CCM-VADT" AES Keylen=256
#   https://github.com/pyca/cryptography/tree/main/vectors/cryptography_vectors/ciphers/AES/CCM/VADT256.rsp
#   Mirror of: https://csrc.nist.gov/projects/cryptographic-algorithm-validation-program
#
# Parameters used:  Plen=24, Nlen=13, Tlen=16
#   CAVP Count=0  — Alen=0  (no AAD)
#   CAVP Count=320 — Alen=32 (32-byte AAD)
#
# Plus two round-trip tests (no external KAT needed — self-consistency):
#   V3: shorter plaintext, 12-byte AAD, M=8
#   V4: empty plaintext, empty AAD, M=8 (tag-only mode)
#
# Discipline: feedback_no_coverups.md — byte-exact CAVP matches for V1/V2;
# no weakened assertions, no skip(), no TODO→NOTE.
# ============================================================================

use std.spec.*
use os.crypto.aes256_ccm.{aes256_ccm_encrypt, aes256_ccm_decrypt, Aes256CcmResult}

# ============================================================================
# Hex decode helper (inlined — avoids test-system dependency)
# ============================================================================

extern fn rt_bytes_u8_at(arr: [u8], idx: i64) -> i64
extern fn rt_array_new_with_cap(cap: i64) -> [u8]

fn _hex_digit(c: text) -> i64:
    if c == "0": return 0
    if c == "1": return 1
    if c == "2": return 2
    if c == "3": return 3
    if c == "4": return 4
    if c == "5": return 5
    if c == "6": return 6
    if c == "7": return 7
    if c == "8": return 8
    if c == "9": return 9
    if c == "a": return 10
    if c == "A": return 10
    if c == "b": return 11
    if c == "B": return 11
    if c == "c": return 12
    if c == "C": return 12
    if c == "d": return 13
    if c == "D": return 13
    if c == "e": return 14
    if c == "E": return 14
    if c == "f": return 15
    if c == "F": return 15
    -1

fn _hex_to_bytes(s: text) -> [u8]:
    if (s.len() % 2) != 0:
        return []
    var out: [u8] = []
    var i: u64 = 0
    while i < s.len():
        val hi = _hex_digit(s[i])
        val lo = _hex_digit(s[i + 1])
        if hi < 0 or lo < 0:
            return []
        out.push((hi * 16 + lo).to_u8())
        i = i + 2
    out

fn _u8_at(buf: [u8], idx: u64) -> u8:
    rt_bytes_u8_at(buf, idx.to_i64()).to_u8()

# ============================================================================
# Vector helpers — module-level (avoid feedback_it_block_var_mutation footgun)
# ============================================================================

# ---------------------------------------------------------------------------
# NIST CAVP VADT256.rsp — Plen=24, Nlen=13, Tlen=16
# Count=0  [Alen=0]  (no additional data)
#
# Key   = 26511fb51fcfa75cb4b44da75a6e5a0eb8d9c8f3b906f886df3ba3e6da3a1389
# Nonce = 72a60f345a1978fb40f28a2fa4
# Adata = (none; Alen=0, CAVP file shows "00" as placeholder)
# PT    = 30d56ff2a25b83fee791110fcaea48e41db7c7f098a81000
# CT    = 55f068c0bbba8b598013dd1841fd740fda2902322148ab5e  (24 bytes)
# Tag   = 935753e601b79db4ae730b6ae3500731                 (16 bytes)
# Full CAVP CT field = CT || Tag (40 bytes total)
# ---------------------------------------------------------------------------

fn _v1_key() -> [u8]:
    _hex_to_bytes("26511fb51fcfa75cb4b44da75a6e5a0eb8d9c8f3b906f886df3ba3e6da3a1389")

fn _v1_nonce() -> [u8]:
    _hex_to_bytes("72a60f345a1978fb40f28a2fa4")

fn _v1_plaintext() -> [u8]:
    _hex_to_bytes("30d56ff2a25b83fee791110fcaea48e41db7c7f098a81000")

fn _v1_expected_ct() -> [u8]:
    _hex_to_bytes("55f068c0bbba8b598013dd1841fd740fda2902322148ab5e")

fn _v1_expected_tag() -> [u8]:
    _hex_to_bytes("935753e601b79db4ae730b6ae3500731")

# ---------------------------------------------------------------------------
# NIST CAVP VADT256.rsp — Plen=24, Nlen=13, Tlen=16
# Count=320  [Alen=32]  (32-byte additional data)
#
# Key   = 2e6e34070caf1b8820ed39edfa83459abe1c15a1827f1c39f7ac316c4c27910f
# Nonce = c49ccef869bb86d21932cb443b
# Adata = d37e35d7cdccd9824a1ae4c787819735e4af798a3beb49d4705336d6496853ad
# PT    = 771a7baa9cf83aa253349f6475d5e74dba4525307b022ba7
# CT    = eebac2475004970071dfa2cfb855c4e78b1add8dcbccfc0b  (24 bytes)
# Tag   = d6b14027324b657a56263df148665393                  (16 bytes)
# Full CAVP CT field = CT || Tag (40 bytes total)
# ---------------------------------------------------------------------------

fn _v2_key() -> [u8]:
    _hex_to_bytes("2e6e34070caf1b8820ed39edfa83459abe1c15a1827f1c39f7ac316c4c27910f")

fn _v2_nonce() -> [u8]:
    _hex_to_bytes("c49ccef869bb86d21932cb443b")

fn _v2_aad() -> [u8]:
    _hex_to_bytes("d37e35d7cdccd9824a1ae4c787819735e4af798a3beb49d4705336d6496853ad")

fn _v2_plaintext() -> [u8]:
    _hex_to_bytes("771a7baa9cf83aa253349f6475d5e74dba4525307b022ba7")

fn _v2_expected_ct() -> [u8]:
    _hex_to_bytes("eebac2475004970071dfa2cfb855c4e78b1add8dcbccfc0b")

fn _v2_expected_tag() -> [u8]:
    _hex_to_bytes("d6b14027324b657a56263df148665393")

# ---------------------------------------------------------------------------
# Round-trip V3: different nonce, 12-byte AAD, 19-byte PT, M=8
# (No external KAT — self-consistent round-trip)
# ---------------------------------------------------------------------------

fn _v3_key() -> [u8]:
    _hex_to_bytes("26511fb51fcfa75cb4b44da75a6e5a0eb8d9c8f3b906f886df3ba3e6da3a1389")

fn _v3_nonce() -> [u8]:
    _hex_to_bytes("72a60f345a1978fb40f28a2fa5")

fn _v3_aad() -> [u8]:
    _hex_to_bytes("000102030405060708090A0B")

fn _v3_plaintext() -> [u8]:
    _hex_to_bytes("0C0D0E0F101112131415161718191A1B1C1D1E")

# ---------------------------------------------------------------------------
# Round-trip V4: empty plaintext, empty AAD, M=8 (tag-only mode)
# ---------------------------------------------------------------------------

fn _v4_key() -> [u8]:
    _hex_to_bytes("2e6e34070caf1b8820ed39edfa83459abe1c15a1827f1c39f7ac316c4c27910f")

fn _v4_nonce() -> [u8]:
    _hex_to_bytes("c49ccef869bb86d21932cb443c")

# ============================================================================
# Output split helpers (encrypt returns ct||tag concatenated)
# ============================================================================

fn _split_ct(buf: [u8], ct_len: u64) -> [u8]:
    """Extract the ciphertext portion (first ct_len bytes) from encrypt output."""
    var out: [u8] = rt_array_new_with_cap(ct_len.to_i64())
    var i: u64 = 0
    while i < ct_len:
        out.push(_u8_at(buf, i))
        i = i + 1
    out

fn _split_tag(buf: [u8], ct_len: u64, tag_len: u64) -> [u8]:
    """Extract the tag portion (last tag_len bytes) from encrypt output."""
    var out: [u8] = rt_array_new_with_cap(tag_len.to_i64())
    var i: u64 = 0
    while i < tag_len:
        out.push(_u8_at(buf, ct_len + i))
        i = i + 1
    out

# ============================================================================
# Specs
# ============================================================================

describe "AES-256-CCM NIST CAVP VADT256 byte-exact vectors":

    it "V1 encrypt (Alen=0): CT matches NIST CAVP Count=0 Plen=24 Nlen=13 Tlen=16":
        val out = aes256_ccm_encrypt(_v1_key(), _v1_nonce(), [], _v1_plaintext(), 16)
        expect out.len() == 40
        val ct = _split_ct(out, 24)
        val tag = _split_tag(out, 24, 16)
        expect ct == _v1_expected_ct()
        expect tag == _v1_expected_tag()

    it "V1 decrypt (Alen=0): correct tag returns original plaintext":
        val result = aes256_ccm_decrypt(_v1_key(), _v1_nonce(), [],
                                        _v1_expected_ct(), _v1_expected_tag())
        match result:
            Aes256CcmResult.Ok(data):
                expect data == _v1_plaintext()
            Aes256CcmResult.Err(msg):
                expect msg == ""

    it "V1 decrypt: corrupted tag is rejected":
        # All-FF tag guaranteed != real tag; no XOR/indexing to avoid Value::U8 push pitfall
        val bad_tag = _hex_to_bytes("ffffffffffffffffffffffffffffffff")
        val result = aes256_ccm_decrypt(_v1_key(), _v1_nonce(), [],
                                        _v1_expected_ct(), bad_tag)
        match result:
            Aes256CcmResult.Ok(data):
                expect data.len() == 99999
            Aes256CcmResult.Err(msg):
                expect msg.contains("tag mismatch") == true

    it "V2 encrypt (Alen=32): CT matches NIST CAVP Count=320 Plen=24 Nlen=13 Tlen=16":
        val out = aes256_ccm_encrypt(_v2_key(), _v2_nonce(), _v2_aad(), _v2_plaintext(), 16)
        expect out.len() == 40
        val ct = _split_ct(out, 24)
        val tag = _split_tag(out, 24, 16)
        expect ct == _v2_expected_ct()
        expect tag == _v2_expected_tag()

    it "V2 decrypt (Alen=32): correct tag returns original plaintext":
        val result = aes256_ccm_decrypt(_v2_key(), _v2_nonce(), _v2_aad(),
                                        _v2_expected_ct(), _v2_expected_tag())
        match result:
            Aes256CcmResult.Ok(data):
                expect data == _v2_plaintext()
            Aes256CcmResult.Err(msg):
                expect msg == ""

    it "V2 decrypt: modified AAD is rejected":
        var bad_aad: [u8] = rt_array_new_with_cap(32)
        var i: u64 = 0
        while i < 32:
            bad_aad.push(0xFF)
            i = i + 1
        val result = aes256_ccm_decrypt(_v2_key(), _v2_nonce(), bad_aad,
                                        _v2_expected_ct(), _v2_expected_tag())
        match result:
            Aes256CcmResult.Ok(data):
                expect data.len() == 99999
            Aes256CcmResult.Err(msg):
                expect msg.contains("tag mismatch") == true

describe "AES-256-CCM encrypt→decrypt round-trip":

    it "V3 round-trip: 12-byte AAD, 19-byte PT, M=8":
        val out = aes256_ccm_encrypt(_v3_key(), _v3_nonce(), _v3_aad(), _v3_plaintext(), 8)
        expect out.len() == 27
        val ct = _split_ct(out, 19)
        val tag = _split_tag(out, 19, 8)
        val result = aes256_ccm_decrypt(_v3_key(), _v3_nonce(), _v3_aad(), ct, tag)
        match result:
            Aes256CcmResult.Ok(data):
                expect data == _v3_plaintext()
            Aes256CcmResult.Err(msg):
                expect msg == ""

    it "V3 round-trip: corrupted tag is rejected":
        val out = aes256_ccm_encrypt(_v3_key(), _v3_nonce(), _v3_aad(), _v3_plaintext(), 8)
        val ct = _split_ct(out, 19)
        # All-FF 8-byte tag guaranteed != real tag; avoids Value::U8 push pitfall
        val bad_tag = _hex_to_bytes("ffffffffffffffff")
        val result = aes256_ccm_decrypt(_v3_key(), _v3_nonce(), _v3_aad(), ct, bad_tag)
        match result:
            Aes256CcmResult.Ok(data):
                expect data.len() == 99999
            Aes256CcmResult.Err(msg):
                expect msg.contains("tag mismatch") == true

    it "V4 round-trip: empty plaintext, empty AAD, M=8 (tag-only)":
        val out = aes256_ccm_encrypt(_v4_key(), _v4_nonce(), [], [], 8)
        expect out.len() == 8
        val ct = _split_ct(out, 0)
        val tag = _split_tag(out, 0, 8)
        val result = aes256_ccm_decrypt(_v4_key(), _v4_nonce(), [], ct, tag)
        match result:
            Aes256CcmResult.Ok(data):
                expect data.len() == 0
            Aes256CcmResult.Err(msg):
                expect msg == ""

describe "AES-256-CCM parameter validation":

    it "wrong key length (16 bytes instead of 32) returns empty":
        val bad_key = _hex_to_bytes("26511fb51fcfa75cb4b44da75a6e5a0e")
        val out = aes256_ccm_encrypt(bad_key, _v1_nonce(), [], _v1_plaintext(), 16)
        expect out.len() == 0

    it "wrong nonce length (11 bytes instead of 13) returns empty":
        val bad_nonce = _hex_to_bytes("72a60f345a1978fb40f28a")
        val out = aes256_ccm_encrypt(_v1_key(), bad_nonce, [], _v1_plaintext(), 16)
        expect out.len() == 0

    it "odd tag length returns empty":
        val out = aes256_ccm_encrypt(_v1_key(), _v1_nonce(), [], _v1_plaintext(), 7)
        expect out.len() == 0

    it "decrypt wrong key length returns Err with message":
        val bad_key = _hex_to_bytes("26511fb51fcfa75cb4b44da75a6e5a0e")
        val result = aes256_ccm_decrypt(bad_key, _v1_nonce(), [],
                                        _v1_expected_ct(), _v1_expected_tag())
        match result:
            Aes256CcmResult.Ok(data):
                expect data.len() == 99999
            Aes256CcmResult.Err(msg):
                expect msg.contains("32 bytes") == true