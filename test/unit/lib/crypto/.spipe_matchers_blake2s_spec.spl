# BLAKE2s — RFC 7693 Known-Answer Tests
#
# Tests the pure-Simple BLAKE2s implementation in
#   src/lib/common/crypto/blake2s.spl
# against RFC 7693 Appendix B and the BLAKE2 reference test vector set
# (https://github.com/BLAKE2/BLAKE2/blob/master/testvectors/blake2-kat.json).
#
# Coverage (9 tests):
#   - Empty input unkeyed (RFC 7693 §B, canonical empty-input digest)
#   - "abc" unkeyed 32-byte digest (RFC 7693 Appendix B)
#   - 64-byte input (one full block boundary)
#   - 65-byte input (one full block + 1-byte residual)
#   - Keyed: key=00..1f, msg="" (blake2-kat.json kk=32 in='')
#   - Keyed: key=00..07, msg="Hi There"
#   - Variable output length: 16-byte digest of "abc"
#   - Streaming: chunked update matches single-call hash
#   - blake2s_hash convenience wrapper matches init/update/final chain
#
# Reference values cross-verified with Python hashlib.blake2s.
#
# NOTE: interpreter-mode test runner verifies file loading, NOT it-block
# execution. Digest assertions only fire under compiled/native mode
# (see feedback_compile_mode_false_greens.md).

use std.spipe.*
use std.crypto.blake2s.{blake2s_hash, blake2s_init, blake2s_update, blake2s_final}

# ============================================================================
# Helpers
# ============================================================================

fn _bytes_to_hex(bs: [u8]) -> text:
    """Convert a byte slice to a lowercase hex string."""
    val hex_chars = "0123456789abcdef"
    var s: text = ""
    var i: u64 = 0
    while i < bs.len():
        val b = bs[i].to_u64()
        s = s + hex_chars.char_at((b >> 4).to_u64())
        s = s + hex_chars.char_at((b & 0xF).to_u64())
        i = i + 1
    s

fn _empty_bytes() -> [u8]:
    """Return an empty byte slice."""
    var b: [u8] = []
    b

fn _abc_bytes() -> [u8]:
    """Return bytes for the ASCII string 'abc'."""
    var b: [u8] = []
    b.push(0x61u8)
    b.push(0x62u8)
    b.push(0x63u8)
    b

fn _repeat_bytes(byte_val: u8, count: u64) -> [u8]:
    """Return a byte slice of `count` copies of `byte_val`."""
    var b: [u8] = []
    var i: u64 = 0
    while i < count:
        b.push(byte_val)
        i = i + 1
    b

fn _range_bytes(count: u64) -> [u8]:
    """Return bytes [0x00, 0x01, ..., count-1]."""
    var b: [u8] = []
    var i: u64 = 0
    while i < count:
        b.push(i.to_u8())
        i = i + 1
    b

fn _hi_there_bytes() -> [u8]:
    """Return bytes for the ASCII string 'Hi There'."""
    var b: [u8] = []
    b.push(0x48u8); b.push(0x69u8); b.push(0x20u8)
    b.push(0x54u8); b.push(0x68u8); b.push(0x65u8)
    b.push(0x72u8); b.push(0x65u8)
    b

fn _quick_brown_fox_bytes() -> [u8]:
    """Return bytes for 'The quick brown fox jumps over the lazy dog'."""
    val s = "The quick brown fox jumps over the lazy dog"
    var b: [u8] = []
    var i: u64 = 0
    while i < s.len():
        b.push(s.char_at(i).to_u8())
        i = i + 1
    b

# ============================================================================
# Unkeyed tests
# ============================================================================

describe "BLAKE2s RFC 7693 unkeyed test vectors":

    it "empty input unkeyed 32-byte digest":
        # RFC 7693: BLAKE2s("") =
        #   69217a3079908094e11121d042354a7c1f55b6482ca1a51e1b250dfd1ed0eef9
        val digest = blake2s_hash(_empty_bytes(), 32u32, _empty_bytes())
        expect _bytes_to_hex(digest) == "69217a3079908094e11121d042354a7c1f55b6482ca1a51e1b250dfd1ed0eef9"

    it "Appendix B 'abc' unkeyed 32-byte digest (RFC 7693 §B)":
        # RFC 7693 Appendix B:
        #   508c5e8c327c14e2e1a72ba34eeb452f37458b209ed63a294d999b4c86675982
        val digest = blake2s_hash(_empty_bytes(), 32u32, _abc_bytes())
        expect _bytes_to_hex(digest) == "508c5e8c327c14e2e1a72ba34eeb452f37458b209ed63a294d999b4c86675982"

    it "64-byte input (one full block boundary) 32-byte digest":
        # Python: hashlib.blake2s(b'a'*64).hexdigest()
        #   651d2f5f20952eacaea2fba2f2af2bcd633e511ea2d2e4c9ae2ac0d9ffb7b252
        val msg = _repeat_bytes(0x61u8, 64)
        val digest = blake2s_hash(_empty_bytes(), 32u32, msg)
        expect _bytes_to_hex(digest) == "651d2f5f20952eacaea2fba2f2af2bcd633e511ea2d2e4c9ae2ac0d9ffb7b252"

    it "65-byte input (one full block + 1 residual byte) 32-byte digest":
        # Python: hashlib.blake2s(b'a'*65).hexdigest()
        #   b4ee6ca1ad2ff2a4a8b45b51e01a7a3e5a77a55aae54e9fd0baad0f20c6bb2db
        val msg = _repeat_bytes(0x61u8, 65)
        val digest = blake2s_hash(_empty_bytes(), 32u32, msg)
        expect _bytes_to_hex(digest) == "b4ee6ca1ad2ff2a4a8b45b51e01a7a3e5a77a55aae54e9fd0baad0f20c6bb2db"

    it "variable output length: 16-byte digest of 'abc'":
        # Python: hashlib.blake2s(b'abc', digest_size=16).hexdigest()
        #   aa4938119b1dc7b87cbad0ffd200d0ae
        val digest = blake2s_hash(_empty_bytes(), 16u32, _abc_bytes())
        expect _bytes_to_hex(digest) == "aa4938119b1dc7b87cbad0ffd200d0ae"

# ============================================================================
# Keyed tests
# ============================================================================

describe "BLAKE2s keyed-mode test vectors (blake2-kat.json)":

    it "BLAKE2s key=00..1f in='' out=32 (blake2-kat.json kk=32 in='')":
        # Python: hashlib.blake2s(b'', key=bytes(range(32))).hexdigest()
        #   48a8997da407876b3d79c0d92325ad3b89cbb754d86ab71aee047ad345fd2c49
        val key = _range_bytes(32)
        val digest = blake2s_hash(key, 32u32, _empty_bytes())
        expect _bytes_to_hex(digest) == "48a8997da407876b3d79c0d92325ad3b89cbb754d86ab71aee047ad345fd2c49"

    it "BLAKE2s key=00..07 in='Hi There' out=32":
        # Python: hashlib.blake2s(b'Hi There', key=bytes(range(8))).hexdigest()
        #   fff44698fee4d219540d95f0f56d41888f344bf0924cef3f6d6a036a4c2aa747
        val key = _range_bytes(8)
        val digest = blake2s_hash(key, 32u32, _hi_there_bytes())
        expect _bytes_to_hex(digest) == "fff44698fee4d219540d95f0f56d41888f344bf0924cef3f6d6a036a4c2aa747"

# ============================================================================
# Streaming API tests
# ============================================================================

describe "BLAKE2s streaming update API":

    it "streaming 3-chunk update matches single-call hash for 'abc'":
        # Feed "a", "b", "c" separately; must equal blake2s_hash([], 32, "abc")
        var st = blake2s_init(_empty_bytes(), 32u32)
        var chunk_a: [u8] = []
        chunk_a.push(0x61u8)
        st = blake2s_update(st, chunk_a)
        var chunk_b: [u8] = []
        chunk_b.push(0x62u8)
        st = blake2s_update(st, chunk_b)
        var chunk_c: [u8] = []
        chunk_c.push(0x63u8)
        st = blake2s_update(st, chunk_c)
        val digest = blake2s_final(st)
        expect _bytes_to_hex(digest) == "508c5e8c327c14e2e1a72ba34eeb452f37458b209ed63a294d999b4c86675982"

    it "streaming 65-byte message in 1+64 chunks matches single-call hash":
        # Chunk 1: 1 byte 'a', Chunk 2: 64 bytes 'a'
        # Exercises the buffer-flush boundary during update.
        var st = blake2s_init(_empty_bytes(), 32u32)
        var first_chunk: [u8] = []
        first_chunk.push(0x61u8)
        st = blake2s_update(st, first_chunk)
        val rest = _repeat_bytes(0x61u8, 64)
        st = blake2s_update(st, rest)
        val streaming_digest = blake2s_final(st)
        val onecall_digest = blake2s_hash(_empty_bytes(), 32u32, _repeat_bytes(0x61u8, 65))
        expect _bytes_to_hex(streaming_digest) == _bytes_to_hex(onecall_digest)