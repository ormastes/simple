use generated.simpleos_log_config.{simpleos_log_compile_mode_name}
use lib.nogc_async_mut_noalloc.log.{
    LOG_DEBUG, LOG_INFO, LOG_WARN, LOG_FATAL, LOG_OFF,
    log_level_name, log_parse_targets, simple_log_c_enabled,
    _log_policy_allows, _normalize_prefixed_message
}

describe "nogc_async_mut_noalloc logger compile control":
    it "keeps normal logging enabled by default":
        expect(simple_log_c_enabled(LOG_INFO.to_i64())).to_equal(1)
        expect(simpleos_log_compile_mode_name()).to_equal("on")

    it "keeps the public fatal/off boundary aligned with the helper policy":
        expect(simple_log_c_enabled(LOG_FATAL.to_i64())).to_equal(1)
        expect(simple_log_c_enabled(LOG_OFF.to_i64())).to_equal(0)

    it "uses info as the default runtime minimum level":
        expect(simple_log_c_enabled(LOG_DEBUG.to_i64())).to_equal(0)
        expect(simple_log_c_enabled(LOG_INFO.to_i64())).to_equal(1)

describe "nogc_async_mut_noalloc logger formatting helpers":
    it "keeps canonical level names":
        expect(log_level_name(LOG_DEBUG)).to_equal("DEBUG")
        expect(log_level_name(LOG_FATAL)).to_equal("FATAL")

    it "parses combined target bitmasks":
        expect(log_parse_targets("serial,semihost,file")).to_equal(7)

    it "applies the shared level policy helper":
        expect(_log_policy_allows(LOG_INFO, LOG_DEBUG)).to_equal(false)
        expect(_log_policy_allows(LOG_INFO, LOG_INFO)).to_equal(true)
        expect(_log_policy_allows(LOG_WARN, LOG_INFO)).to_equal(false)
        expect(_log_policy_allows(LOG_OFF, LOG_INFO)).to_equal(false)
        expect(_log_policy_allows(LOG_WARN, LOG_FATAL)).to_equal(true)
        expect(_log_policy_allows(LOG_INFO, LOG_OFF)).to_equal(false)
        expect(_log_policy_allows(LOG_OFF, LOG_FATAL)).to_equal(true)

    it "normalizes chained facility prefixes only":
        expect(_normalize_prefixed_message("[virtio] [net] link up")).to_equal("[virtio.net] link up")
        expect(_normalize_prefixed_message("[virtio] still original")).to_equal("[virtio] still original")
        expect(_normalize_prefixed_message("[virtio] [net]")).to_equal("[virtio.net]")
        expect(_normalize_prefixed_message("[WARN] [net] keep original")).to_equal("[WARN] [net] keep original")
        expect(_normalize_prefixed_message("[.] [net] keep original")).to_equal("[.] [net] keep original")
