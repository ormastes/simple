# Regression coverage for the GC sync immutable compatibility family.

use std.gc_sync_immut.{Atom, VersionedSnapshot, pfilter, nogc_async_immut_version}

describe "gc_sync_immut facade resolution":
    it "resolves persistent helpers through the GC async immutable facade":
        expect(pfilter([1, 2, 3, 4], \x: x > 2)).to_equal([3, 4])
        expect(nogc_async_immut_version()).to_equal("0.1.0")

    it "preserves root coordination type behavior through the sync GC facade":
        var atom = Atom.new(11)
        atom.reset(12)
        expect(atom.deref()).to_equal(12)

        var snapshot = VersionedSnapshot.new("left")
        snapshot.update("right")
        expect(snapshot.current()).to_equal("right")
