# Native-safe behavior coverage for the GC sync immutable facade.

use std.gc_sync_immut.combinators.{pmap, pfold}

describe "gc_sync_immut native combinators":
    it "runs pure combinators through the sync GC facade chain":
        expect(pmap([2, 4], _1 + 5)).to_equal([7, 9])
        expect(pfold([1, 2, 3, 4], 0, \acc, x: acc + x)).to_equal(10)
