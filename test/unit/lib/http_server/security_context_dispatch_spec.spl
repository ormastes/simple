# HTTP transport security context dispatch coverage.

use std.http_server.types.{HttpRequestData, HttpResponseData, LocationConfig, default_response_data}
use std.http_server.security_context.{dispatch_handler_with_remote_security_context, dispatch_handler_with_task_security_context, dispatch_handler_with_validated_remote_security_context}
use std.security.auth.context_propagation.{current_security_context, current_task_security_context}
use std.security.types.{sign_remote_security_token}

fn observed_security_context_handler(request: HttpRequestData, location: LocationConfig) -> HttpResponseData:
    val ctx = current_security_context()
    default_response_data(
        200,
        "OK",
        ctx.peer_addr + "|" + ctx.session_id + "|" + ctx.is_authenticated().to_string()
    )

fn observed_task_security_context_handler(request: HttpRequestData, location: LocationConfig) -> HttpResponseData:
    val ctx = current_task_security_context("task-http")
    default_response_data(
        200,
        "OK",
        ctx.peer_addr + "|" + ctx.session_id + "|" + ctx.is_authenticated().to_string()
    )

fn test_location() -> LocationConfig:
    LocationConfig(
        pattern: "/secure",
        match_type: "exact",
        handler_type: "observe-security",
        root: "",
        proxy_pass: "",
        middlewares: []
    )

fn test_request() -> HttpRequestData:
    HttpRequestData(
        method: "GET",
        path: "/secure",
        query: "",
        version: "HTTP/1.1",
        headers: [
            ("Authorization", "Bearer token"),
            ("X-Simple-Session-Id", "session-transport"),
            ("X-Simple-Policy-Version", "42"),
            ("X-Simple-User-Role", "admin")
        ],
        body: "",
        params: {},
        peer_addr: "198.51.100.30"
    )

describe "http security context dispatch":
    it "scopes remote SecurityContext around handler dispatch only":
        val response = dispatch_handler_with_remote_security_context(observed_security_context_handler, test_location(), test_request())
        expect(response.status).to_equal(200)
        expect(response.body).to_equal("198.51.100.30|session-transport|false")
        expect(current_security_context().is_authenticated()).to_equal(false)

    it "authenticates handler dispatch only with a validated remote token":
        val token = sign_remote_security_token("server-secret", "session-transport", "user-1", 2000, ["user.profile.write"])
        val request = HttpRequestData(
            method: "GET",
            path: "/secure",
            query: "",
            version: "HTTP/1.1",
            headers: [
                ("Authorization", "Bearer {token}"),
                ("X-Simple-Session-Id", "session-transport")
            ],
            body: "",
            params: {},
            peer_addr: "198.51.100.30"
        )
        val response = dispatch_handler_with_validated_remote_security_context(observed_security_context_handler, test_location(), request, "server-secret", 1999)
        expect(response.status).to_equal(200)
        expect(response.body).to_equal("198.51.100.30|session-transport|true")
        expect(current_security_context().is_authenticated()).to_equal(false)

    it "keeps validated dispatch anonymous when token validation fails":
        val request = test_request()
        val response = dispatch_handler_with_validated_remote_security_context(observed_security_context_handler, test_location(), request, "server-secret", 1999)
        expect(response.status).to_equal(200)
        expect(response.body).to_equal("198.51.100.30|session-transport|false")

    it "scopes remote context to an explicit HTTP task id":
        val response = dispatch_handler_with_task_security_context("task-http", observed_task_security_context_handler, test_location(), test_request())
        expect(response.status).to_equal(200)
        expect(response.body).to_equal("198.51.100.30|session-transport|false")
        expect(current_task_security_context("task-http").is_authenticated()).to_equal(false)
        expect(current_security_context().is_authenticated()).to_equal(false)
