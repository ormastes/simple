use std.spec.*
use std.io.net_backend.{portable_net_backend_capabilities, net_backend_capabilities}
use std.http_server.response.{build_file_response, build_ok}
use std.http_server.worker.{worker_static_file_route}

describe "HTTP worker static-file routing":
    it "uses portable body sends for normal responses":
        val caps = portable_net_backend_capabilities()
        val resp = build_ok("hello", "text/plain")

        expect(worker_static_file_route(caps, resp)).to_equal("body")

    it "falls back to portable reads when sendfile is unsupported":
        val caps = portable_net_backend_capabilities()
        val resp = build_file_response("/tmp/large.bin", "application/octet-stream", 131072)

        expect(worker_static_file_route(caps, resp)).to_equal("portable-read")

    it "uses sendfile only when the backend reports support":
        val caps = net_backend_capabilities("sendfile-test", true, true, true, false)
        val resp = build_file_response("/tmp/large.bin", "application/octet-stream", 131072)

        expect(worker_static_file_route(caps, resp)).to_equal("sendfile")
