# Rate Limiting Specification
#
# **Feature IDs:** #SEC-012
# **Category:** HTTP Server Security
# **Difficulty:** 2/5
# **Status:** Implemented
#
# ## Overview
# Tests for rate limiting configuration, defaults, and peer tracking.
# Validates that request limits and time windows are correct.

use std.http_server.rate_limit.{RateLimitConfig, default_rate_limit_config, RateLimitStore, new_rate_limit_store, check_rate_limit}

# ============================================================================
# Test Group 1: Configuration defaults
# ============================================================================

describe "RateLimitConfig defaults":
    it "defaults to 100 requests":
        val config = default_rate_limit_config()
        expect config.max_requests == 100

    it "defaults to 60000ms window":
        val config = default_rate_limit_config()
        expect config.window_ms == 60000

    it "has enabled set to true by default":
        val config = default_rate_limit_config()
        expect config.enabled == true

# ============================================================================
# Test Group 2: Rate limit checking
# ============================================================================

describe "Rate limit checking":
    it "allows requests within limit":
        val config = default_rate_limit_config()
        var store = new_rate_limit_store()
        val result = check_rate_limit(store, config, "192.168.1.1")
        expect result == true

    it "tracks peer request count":
        val config = default_rate_limit_config()
        var store = new_rate_limit_store()
        val first = check_rate_limit(store, config, "10.0.0.1")
        val second = check_rate_limit(store, config, "10.0.0.1")
        expect first == true
        expect second == true

    it "tracks different peers independently":
        val config = default_rate_limit_config()
        var store = new_rate_limit_store()
        val result_a = check_rate_limit(store, config, "10.0.0.1")
        val result_b = check_rate_limit(store, config, "10.0.0.2")
        expect result_a == true
        expect result_b == true