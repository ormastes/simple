# CLI Output Log Writer Specification
#
# Tests for log file creation, line writing with ANSI stripping,
# and latest.log symlink management.

use std.cli_output.{log_open, log_line, log_close, log_show}
use app.io.file_ops.{file_exists, file_read}

describe "cli_output.log_writer":
    it "should create log file with correct path prefix":
        val log_path = log_open("test")
        expect(log_path).to_start_with("build/log/test/")
        expect(log_path).to_end_with(".log")
        expect(file_exists(log_path)).to_equal(true)

    it "should append lines to log file":
        val log_path = log_open("test")
        log_line(log_path, "  PASS  test/a_spec.spl (3 passed, 42ms)")
        log_line(log_path, "  FAIL  test/b_spec.spl (1 passed, 1 failed, 38ms)")
        val content = file_read(log_path)
        expect(content).to_contain("PASS")
        expect(content).to_contain("FAIL")
        expect(content).to_contain("a_spec.spl")
        expect(content).to_contain("b_spec.spl")

    it "should strip ANSI codes from logged lines":
        val log_path = log_open("test")
        log_line(log_path, "\u{001b}[32m  PASS\u{001b}[0m  test.spl")
        val content = file_read(log_path)
        expect(content).to_contain("PASS")
        # ANSI codes should be stripped — clean text only
        expect(content).to_contain("  PASS  test.spl")

    it "should create latest.log symlink on close":
        val log_path = log_open("test")
        log_line(log_path, "test line")
        log_close(log_path, "test")
        expect(file_exists("build/log/test/latest.log")).to_equal(true)
