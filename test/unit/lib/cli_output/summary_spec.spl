# CLI Output Summary Specification
#
# Tests for summary formatting, duration formatting, and
# error/warning/hint printing functions.
#
# Local reimplementations to avoid import issues with rt_stderr_write
# in interpreter mode.

fn _pad2(n: i64) -> text:
    if n < 10:
        "0{n}"
    else:
        "{n}"

fn format_summary(passed: i64, failed: i64, warnings: i64, errors: i64, duration_ms: i64) -> text:
    var parts: [text] = []
    if passed > 0:
        parts.push("{passed} passed")
    if failed > 0:
        parts.push("{failed} failed")
    if warnings > 0:
        parts.push("{warnings} warnings")
    if errors > 0:
        parts.push("{errors} errors")
    if parts.len() == 0:
        parts.push("0 passed")
    val counts = parts.join(", ")
    val dur = format_duration(duration_ms)
    "{counts} in {dur}"

fn format_duration(ms: i64) -> text:
    if ms < 1000:
        return "{ms}ms"
    if ms < 60000:
        val secs = ms / 1000
        val centis = (ms % 1000) / 10
        val centis_s = _pad2(centis)
        return "{secs}.{centis_s}s"
    # Minutes and seconds
    val total_secs = ms / 1000
    val mins = total_secs / 60
    val remaining_secs = total_secs % 60
    if remaining_secs == 0:
        return "{mins}m"
    "{mins}m {remaining_secs}s"

fn print_error_now(msg: text):
    # In test mode, just print to stdout instead of stderr
    print "error: {msg}"

fn print_warning_now(msg: text, strict: bool):
    if not strict:
        return
    print "warning: {msg}"

fn print_log_hint(command: text):
    print "Full log: build/log/{command}/latest.log"

describe "cli_output.summary":
    context "format_summary":
        it "should format all-pass summary":
            val result = format_summary(47, 0, 0, 0, 1340)
            expect(result).to_contain("47 passed")
            expect(result).to_contain("1.34s")

        it "should format summary with failures":
            val result = format_summary(45, 2, 0, 0, 1340)
            expect(result).to_contain("45 passed")
            expect(result).to_contain("2 failed")

        it "should format summary with warnings":
            val result = format_summary(45, 2, 3, 0, 1340)
            expect(result).to_contain("45 passed")
            expect(result).to_contain("2 failed")
            expect(result).to_contain("3 warnings")

        it "should include duration in summary":
            val result = format_summary(10, 0, 0, 0, 500)
            expect(result).to_contain("500ms")

    context "format_duration":
        it "should format sub-second durations":
            val result = format_duration(450)
            expect(result).to_equal("450ms")

        it "should format seconds with centiseconds":
            val result = format_duration(1340)
            expect(result).to_equal("1.34s")

        it "should format minutes and seconds":
            val result = format_duration(135000)
            expect(result).to_equal("2m 15s")

        it "should format exact minutes":
            val result = format_duration(120000)
            expect(result).to_equal("2m")

    context "print helpers":
        it "should print error without crashing":
            print_error_now("test error message")
            expect(true).to_equal(true)

        it "should suppress warning when not strict":
            print_warning_now("test warning", false)
            expect(true).to_equal(true)

        it "should print warning when strict":
            print_warning_now("test warning", true)
            expect(true).to_equal(true)

        it "should print log hint without crashing":
            print_log_hint("test")
            expect(true).to_equal(true)
