# CLI Output Progress Specification
#
# Tests for the progress display module. Since progress functions write
# to stderr (side effects), these tests verify they execute without
# crashing and that the module-level state is usable.

use std.cli_output.{progress_start, progress_update, progress_finish, progress_erase}

describe "cli_output.progress":
    it "should start progress with total count":
        # progress_start initializes state — just ensure no crash
        progress_start(10, "Testing...")
        expect(true).to_equal(true)

    it "should update progress without error":
        progress_start(5, "Tests")
        progress_update(1, "test/a_spec.spl")
        progress_update(2, "test/b_spec.spl")
        expect(true).to_equal(true)

    it "should finish progress without error":
        progress_start(3, "Running")
        progress_update(1, "a.spl")
        progress_update(2, "b.spl")
        progress_update(3, "c.spl")
        progress_finish("3 passed")
        expect(true).to_equal(true)

    it "should erase progress line without error":
        progress_start(2, "Tests")
        progress_update(1, "file.spl")
        progress_erase()
        expect(true).to_equal(true)
