# Daemon SDK Types Specification
#
# Tests core types: DaemonConfig, DaemonState, DaemonRequest, DaemonResponse.
#
# **Feature IDs:** #DSDK-001 to #DSDK-010
# **Category:** Infrastructure

# ============================================================================
# Module-level mock state
# ============================================================================

val IDLE: i64 = 0
val POLLING: i64 = 1
val PROCESSING: i64 = 2
val SHUTTING_DOWN: i64 = 3

# Mock config
var cfg_lock: text = ""
var cfg_req_dir: text = ""
var cfg_resp_dir: text = ""
var cfg_poll_ms: i64 = 0
var cfg_timeout_ms: i64 = 0
var cfg_max_conc: i64 = 0

fn cfg_reset():
    cfg_lock = ".build/test/daemon.lock"
    cfg_req_dir = ".build/test/requests"
    cfg_resp_dir = ".build/test/responses"
    cfg_poll_ms = 500
    cfg_timeout_ms = 30000
    cfg_max_conc = 50

fn cfg_get_lock() -> text:
    cfg_lock
fn cfg_get_poll() -> i64:
    cfg_poll_ms
fn cfg_get_timeout() -> i64:
    cfg_timeout_ms
fn cfg_get_max() -> i64:
    cfg_max_conc

# Mock state
var st_status: i64 = 0
var st_last_poll: i64 = 0
var st_items: i64 = 0
var st_errors: i64 = 0
var st_cycles: i64 = 0

fn st_reset():
    st_status = IDLE
    st_last_poll = 0
    st_items = 0
    st_errors = 0
    st_cycles = 0

fn st_get_status() -> i64:
    st_status
fn st_get_items() -> i64:
    st_items
fn st_get_cycles() -> i64:
    st_cycles
fn st_is_idle() -> bool:
    st_status == IDLE
fn st_is_running() -> bool:
    st_status == POLLING or st_status == PROCESSING
fn st_status_text() -> text:
    match st_status:
        case 0: "idle"
        case 1: "polling"
        case 2: "processing"
        case 3: "shutting_down"
        case _: "unknown"

fn st_set_status(s: i64):
    st_status = s

fn st_set_cycles(c: i64):
    st_cycles = c

fn st_set_items(n: i64):
    st_items = n

# Mock request
var req_id: text = ""
var req_kind: i64 = 0
var req_ts: i64 = 0
var req_fields_keys: [text] = []
var req_fields_vals: [text] = []

fn req_reset():
    req_id = ""
    req_kind = 0
    req_ts = 0
    req_fields_keys = []
    req_fields_vals = []

fn req_create(kind: i64):
    req_id = "123_456"
    req_kind = kind
    req_ts = 1000000

fn req_set_field(key: text, value: text):
    req_fields_keys = req_fields_keys + [key]
    req_fields_vals = req_fields_vals + [value]

fn req_get_field(key: text) -> text:
    var i = 0
    while i < req_fields_keys.len():
        if req_fields_keys[i] == key:
            return req_fields_vals[i]
        i = i + 1
    ""

fn req_get_id() -> text:
    req_id
fn req_get_kind() -> i64:
    req_kind
fn req_field_count() -> i64:
    req_fields_keys.len()

# Mock response
var resp_req_id: text = ""
var resp_status: i64 = 0
var resp_ts: i64 = 0
var resp_fields_keys: [text] = []
var resp_fields_vals: [text] = []

fn resp_reset():
    resp_req_id = ""
    resp_status = 0
    resp_ts = 0
    resp_fields_keys = []
    resp_fields_vals = []

fn resp_create(request_id: text, status: i64):
    resp_req_id = request_id
    resp_status = status
    resp_ts = 2000000

fn resp_set_field(key: text, value: text):
    resp_fields_keys = resp_fields_keys + [key]
    resp_fields_vals = resp_fields_vals + [value]

fn resp_get_field(key: text) -> text:
    var i = 0
    while i < resp_fields_keys.len():
        if resp_fields_keys[i] == key:
            return resp_fields_vals[i]
        i = i + 1
    ""

fn resp_get_req_id() -> text:
    resp_req_id
fn resp_get_status() -> i64:
    resp_status
fn resp_field_count() -> i64:
    resp_fields_keys.len()

# ============================================================================
# Tests
# ============================================================================

describe "DaemonConfig":
    it "stores lock path":
        cfg_reset()
        expect(cfg_get_lock()).to_equal(".build/test/daemon.lock")

    it "has default poll interval":
        cfg_reset()
        expect(cfg_get_poll()).to_equal(500)

    it "has default timeout":
        cfg_reset()
        expect(cfg_get_timeout()).to_equal(30000)

    it "has default max concurrent":
        cfg_reset()
        expect(cfg_get_max()).to_equal(50)

describe "DaemonState":
    it "starts idle":
        st_reset()
        expect(st_is_idle()).to_equal(true)

    it "tracks status transitions":
        st_reset()
        st_set_status(POLLING)
        expect(st_is_running()).to_equal(true)
        st_set_status(PROCESSING)
        expect(st_is_running()).to_equal(true)
        st_set_status(IDLE)
        expect(st_is_idle()).to_equal(true)

    it "provides status text":
        st_reset()
        expect(st_status_text()).to_equal("idle")
        st_set_status(POLLING)
        expect(st_status_text()).to_equal("polling")
        st_set_status(PROCESSING)
        expect(st_status_text()).to_equal("processing")
        st_set_status(SHUTTING_DOWN)
        expect(st_status_text()).to_equal("shutting_down")

    it "tracks cycle count":
        st_reset()
        st_set_cycles(5)
        expect(st_get_cycles()).to_equal(5)

    it "tracks items processed":
        st_reset()
        st_set_items(42)
        expect(st_get_items()).to_equal(42)

describe "DaemonRequest":
    it "creates with id and kind":
        req_reset()
        req_create(1)
        expect(req_get_id()).to_equal("123_456")
        expect(req_get_kind()).to_equal(1)

    it "supports arbitrary fields":
        req_reset()
        req_create(2)
        req_set_field("test_path", "test/foo_spec.spl")
        req_set_field("filter", "unit")
        expect(req_get_field("test_path")).to_equal("test/foo_spec.spl")
        expect(req_get_field("filter")).to_equal("unit")
        expect(req_field_count()).to_equal(2)

    it "returns empty for missing field":
        req_reset()
        req_create(1)
        expect(req_get_field("nonexistent")).to_equal("")

describe "DaemonResponse":
    it "creates with request_id and status":
        resp_reset()
        resp_create("123_456", 2)
        expect(resp_get_req_id()).to_equal("123_456")
        expect(resp_get_status()).to_equal(2)

    it "supports arbitrary fields":
        resp_reset()
        resp_create("req_1", 0)
        resp_set_field("passed", "5")
        resp_set_field("failed", "1")
        expect(resp_get_field("passed")).to_equal("5")
        expect(resp_get_field("failed")).to_equal("1")
        expect(resp_field_count()).to_equal(2)

    it "returns empty for missing field":
        resp_reset()
        resp_create("req_1", 0)
        expect(resp_get_field("missing")).to_equal("")
