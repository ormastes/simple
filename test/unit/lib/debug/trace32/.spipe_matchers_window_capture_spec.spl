# Window Capture spec — tests T32 output text parsing

fn split_ws(input: text) -> [text]:
    var result: [text] = []
    var buf: [text] = []
    var in_word = false
    for ch in input:
        if ch == " " or ch == "\t":
            if in_word:
                result.push(buf.join(""))
                buf = []
                in_word = false
        else:
            buf.push(ch)
            in_word = true
    if in_word:
        result.push(buf.join(""))
    result

describe "T32 Window Text Parsing":
    it "parses break list output":
        val raw = "E: 0x08001234  main          Program  Exec\nE: 0x08005678  task_handler  Program  Exec"
        val lines = raw.split("\n")
        expect lines.len() == 2
        val parts = split_ws(lines[0])
        expect parts.len() > 2
        expect parts[0] == "E:"
        expect parts[1] == "0x08001234"
        expect parts[2] == "main"

    it "parses register view output":
        val raw = "R0=0x00000000  R1=0x20001000  R2=0xDEADBEEF  R3=0x00000001"
        val tokens = split_ws(raw)
        expect tokens.len() == 4
        val pair = tokens[0].split("=")
        expect pair[0] == "R0"
        expect pair[1] == "0x00000000"

    it "parses var watch output":
        val raw = "count    int    42\nname     char*  \"hello\"\nflag     bool   true"
        val lines = raw.split("\n")
        expect lines.len() == 3
        val parts = split_ws(lines[0])
        expect parts[0] == "count"
        expect parts[1] == "int"
        expect parts[2] == "42"

    it "handles empty output":
        val raw = ""
        val lines = raw.split("\n")
        # empty string split gives 1 empty element
        expect lines[0] == ""

    it "parses tabular with header":
        val raw = "Name     Type     Value\n---      ----     -----\ncount    int      42\nflag     bool     true"
        val lines = raw.split("\n")
        expect lines.len() == 4
        # Skip header and separator
        val data_line = lines[2]
        val parts = split_ws(data_line)
        expect parts[0] == "count"

    it "parses multi-line register dump":
        val raw = "R0=0x00  R1=0x01  R2=0x02\nR3=0x03  R4=0x04  R5=0x05"
        val lines = raw.split("\n")
        expect lines.len() == 2
        val line1_tokens = split_ws(lines[0])
        expect line1_tokens.len() == 3