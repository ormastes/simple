# Unit tests for T32 type definitions and error code mappings

use std.debug.remote.t32_ffi.t32_types.{
    T32_OK, T32_ERR_COM_RECEIVE_FAIL, T32_ERR_COM_TRANSMIT_FAIL,
    T32_ERR_COM_RECEIVE_TIMEOUT, T32_ERR_FAIL, T32_ERR_ATTACH_FAIL,
    T32_ERR_NOMEMORY, T32_ERR_EXECUTECOMMAND_FAIL, T32_ERR_APILOCK_FAIL,
    T32Error, make_t32_error, t32_error_message,
    T32_STATE_DOWN, T32_STATE_HALTED, T32_STATE_RUNNING,
    T32_DEV_ICD, T32_REG_OBJ_R32, T32_REG_OBJ_R64,
    T32_GROUP_CORE, T32_GROUP_EXECUTE
}
use std.spec.{describe, it, expect}

describe "T32 Error Codes":
    it "T32_OK is zero":
        expect T32_OK == 0

    it "COM errors are negative":
        expect T32_ERR_COM_RECEIVE_FAIL < 0
        expect T32_ERR_COM_TRANSMIT_FAIL < 0
        expect T32_ERR_COM_RECEIVE_TIMEOUT < 0

    it "general errors are positive":
        expect T32_ERR_FAIL > 0
        expect T32_ERR_ATTACH_FAIL > 0

describe "t32_error_message":
    it "maps OK to OK":
        expect t32_error_message(T32_OK) == "OK"

    it "maps COM receive fail":
        expect (t32_error_message(T32_ERR_COM_RECEIVE_FAIL)).contains("receive")

    it "maps general failure":
        expect (t32_error_message(T32_ERR_FAIL)).contains("failure")

    it "maps unknown codes":
        expect (t32_error_message(9999)).contains("Unknown")

describe "make_t32_error":
    it "creates error with code and message":
        val err = make_t32_error(T32_ERR_NOMEMORY)
        expect err.code == T32_ERR_NOMEMORY
        expect (err.message).contains("memory")

describe "T32 Constants":
    it "state constants are distinct":
        expect T32_STATE_DOWN != T32_STATE_HALTED == true
        expect T32_STATE_HALTED != T32_STATE_RUNNING == true

    it "device type ICD is 1":
        expect T32_DEV_ICD == 1

    it "register object sizes are correct":
        expect T32_REG_OBJ_R32 == 32
        expect T32_REG_OBJ_R64 == 64

    it "group names are non-empty":
        expect T32_GROUP_CORE == "core"
        expect T32_GROUP_EXECUTE == "execute"