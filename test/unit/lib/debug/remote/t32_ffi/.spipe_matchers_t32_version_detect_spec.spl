# Unit tests for T32 API version detection logic

use std.debug.remote.t32_ffi.t32_version_detect.{list_has, T32ApiInfo}
use std.debug.remote.t32_ffi.t32_core.{t32_core_function_names}
use std.debug.remote.t32_ffi.t32_execute.{t32_execute_function_names}
use std.debug.remote.t32_ffi.t32_memory.{t32_memory_function_names}
use std.debug.remote.t32_ffi.t32_register.{t32_register_function_names}
use std.debug.remote.t32_ffi.t32_breakpoint.{t32_breakpoint_function_names}
use std.debug.remote.t32_ffi.t32_trace.{t32_trace_function_names}
use std.debug.remote.t32_ffi.t32_fdx.{t32_fdx_function_names}
use std.debug.remote.t32_ffi.t32_notify.{t32_notify_function_names}
use std.debug.remote.t32_ffi.t32_direct.{t32_direct_function_names}
use std.spec.{describe, it, expect}

describe "list_has utility":
    it "finds present item":
        val items = ["core", "execute", "object"]
        expect list_has(items, "core") == true
        expect list_has(items, "execute") == true

    it "returns false for missing item":
        val items = ["core", "execute"]
        expect list_has(items, "fdx") == false

    it "handles empty list":
        val items: [text] = []
        expect list_has(items, "anything") == false

describe "Function name lists":
    it "core has 16 functions":
        val names = t32_core_function_names()
        expect names.len() == 16

    it "execute has 7 functions":
        val names = t32_execute_function_names()
        expect names.len() == 7

    it "memory has 16 functions":
        val names = t32_memory_function_names()
        expect names.len() == 16

    it "register has 13 functions":
        val names = t32_register_function_names()
        expect names.len() == 13

    it "breakpoint has 3 functions":
        val names = t32_breakpoint_function_names()
        expect names.len() == 3

    it "trace has 2 functions":
        val names = t32_trace_function_names()
        expect names.len() == 2

    it "fdx has 7 functions":
        val names = t32_fdx_function_names()
        expect names.len() == 7

    it "notify has 4 functions":
        val names = t32_notify_function_names()
        expect names.len() == 4

    it "direct has 17 functions":
        val names = t32_direct_function_names()
        expect names.len() == 17

    it "total function count covers all API groups":
        val total = (t32_core_function_names().len()
            + t32_execute_function_names().len()
            + t32_memory_function_names().len()
            + t32_register_function_names().len()
            + t32_breakpoint_function_names().len()
            + t32_trace_function_names().len()
            + t32_fdx_function_names().len()
            + t32_notify_function_names().len()
            + t32_direct_function_names().len())
        # 16+7+16+13+3+2+7+4+17 = 85 bound symbols across modules
        # (Object API handles are in the Object module, not counted here)
        expect total > 80

describe "T32ApiInfo struct":
    it "creates with all fields":
        val info = T32ApiInfo(
            revision: 0,
            has_core: true,
            has_execute_api: false,
            has_object_api: false,
            has_notify_api: false,
            has_fdx_api: false,
            has_direct_api: false,
            supported_groups: ["core"]
        )
        expect info.revision == 0
        expect info.has_core == true
        expect info.has_execute_api == false
        expect info.supported_groups.len() == 1