# @cover src/lib/nogc_sync_mut/jit/jit_types.spl 90%
"""
# JIT Shared Types Specification

**Feature IDs:** #F9
**Category:** Infrastructure
**Status:** In Progress
**Requirements:** N/A
**Plan:** doc/03_plan/jit_unified_local_remote_refactor_plan_2026-03-23.md

## Overview

Validates the shared JIT types that are used by all backends:
JitBackendKind, JitMemoryLimits, JitBinary, JitLayoutPlan, JitExecResult.
These types form the structural contract between the orchestration layer
and the backend implementations.
"""

use std.nogc_sync_mut.jit.jit_types.{
    JitBackendKind, JitMemoryLimits, JitBinary, JitLayoutPlan, JitExecResult
}
use std.nogc_sync_mut.debug.remote.types.{Architecture}

# ============================================================================
# JitBackendKind
# ============================================================================

describe "JitBackendKind enum":
    """## Backend Kind -- All variants and their properties."""

    it "Local is the only local variant":
        expect JitBackendKind.Local.is_local() == true

    it "all remote variants are remote":
        expect JitBackendKind.RemoteOpenOCD.is_remote() == true
        expect JitBackendKind.RemoteGDB.is_remote() == true
        expect JitBackendKind.RemoteWLink.is_remote() == true
        expect JitBackendKind.QemuArm.is_remote() == true
        expect JitBackendKind.QemuRiscV32.is_remote() == true

    it "to_string returns distinct non-empty names":
        expect JitBackendKind.Local.to_string().len() > 0
        expect JitBackendKind.RemoteOpenOCD.to_string().len() > 0
        expect JitBackendKind.RemoteGDB.to_string().len() > 0
        expect JitBackendKind.RemoteWLink.to_string().len() > 0
        expect JitBackendKind.QemuArm.to_string().len() > 0
        expect JitBackendKind.QemuRiscV32.to_string().len() > 0

# ============================================================================
# JitMemoryLimits
# ============================================================================

describe "JitMemoryLimits factory methods":
    """## Memory Limits -- Factory methods for known targets."""

    it "local has expandable limits":
        val l = JitMemoryLimits.local()
        expect l.allow_expand == true
        expect l.code_capacity > 0

    it "stm32h7_remote matches known SRAM layout":
        val l = JitMemoryLimits.stm32h7_remote()
        expect l.code_start == 0x24010000
        expect l.code_capacity == 0x00070000
        expect l.data_start == 0x24080000
        expect l.data_capacity == 0x00040000
        expect l.stack_top == 0x240C0000
        expect l.allow_expand == false

    it "qemu_rv32 matches known QEMU layout":
        val l = JitMemoryLimits.qemu_rv32()
        expect l.code_start == 0x80010000
        expect l.code_capacity == 0x000F0000

    it "qemu_arm matches known QEMU layout":
        val l = JitMemoryLimits.qemu_arm()
        expect l.code_start == 0x40010000

    it "ch32v307 matches known SRAM layout":
        val l = JitMemoryLimits.ch32v307()
        expect l.code_start == 0x20002000
        expect l.code_capacity == 0x00006000

describe "JitMemoryLimits fits_binary":
    """## fits_binary -- Checks whether a binary fits in the code region."""

    it "always fits when expandable":
        val l = JitMemoryLimits.local()
        expect l.fits_binary(0) == true
        expect l.fits_binary(999999999) == true

    it "fits when equal to capacity":
        val l = JitMemoryLimits.stm32h7_remote()
        expect l.fits_binary(l.code_capacity) == true

    it "does not fit when one byte over capacity":
        val l = JitMemoryLimits.stm32h7_remote()
        expect l.fits_binary(l.code_capacity + 1) == false

    it "fits when zero":
        val l = JitMemoryLimits.ch32v307()
        expect l.fits_binary(0) == true

describe "JitMemoryLimits computed addresses":
    """## Computed addresses -- code_end and data_end."""

    it "code_end equals code_start + code_capacity":
        val l = JitMemoryLimits.stm32h7_remote()
        expect l.code_end() == l.code_start + l.code_capacity

    it "data_end equals data_start + data_capacity":
        val l = JitMemoryLimits.stm32h7_remote()
        expect l.data_end() == l.data_start + l.data_capacity

# ============================================================================
# JitBinary
# ============================================================================

describe "JitBinary":
    """## Binary -- Compiled bytes wrapper."""

    it "size returns byte count":
        val b = JitBinary(
            name: "test",
            bytes: [1, 2, 3],
            entry_offset: 0,
            stack_bytes: 128,
            arch: Architecture.Arm32
        )
        expect b.size() == 3

    it "empty binary has zero size":
        val b = JitBinary.empty(Architecture.RiscV32)
        expect b.size() == 0

    it "empty binary preserves architecture":
        val b = JitBinary.empty(Architecture.Arm32)
        expect b.arch == Architecture.Arm32

# ============================================================================
# JitLayoutPlan
# ============================================================================

describe "JitLayoutPlan":
    """## Layout Plan -- Computed placement."""

    it "end_addr equals code_base + code_size":
        val p = JitLayoutPlan(
            code_base: 0x24010000,
            code_size: 256,
            entry_point: 0x24010000,
            halt_addr: 0x240100FE,
            stack_top: 0x240C0000,
            can_expand: false
        )
        expect p.end_addr() == 0x24010100

# ============================================================================
# JitExecResult
# ============================================================================

describe "JitExecResult":
    """## Execution Result -- Success and failure construction."""

    it "success has empty error":
        val r = JitExecResult.success(0, 0, "halt")
        expect r.error == ""
        expect r.is_ok() == true

    it "failure has non-empty error":
        val r = JitExecResult.failure("some error")
        expect r.error == "some error"
        expect r.is_ok() == false

    it "success preserves all fields":
        val r = JitExecResult.success(99, 500, "breakpoint")
        expect r.return_value == 99
        expect r.duration_ms == 500
        expect r.halt_reason == "breakpoint"

    it "failure has zero return value":
        val r = JitExecResult.failure("err")
        expect r.return_value == 0
        expect r.duration_ms == 0