# @cover src/lib/hardware/fpga_linux/_SocVhdlGen/top_testbench.spl 0%
# @cover src/lib/hardware/fpga_linux/riscv_fpga_linux.spl 0%
"""
# RV64GC VHDL Generation Pipeline Specification

**Feature IDs:** rv64-fpga-linux-boot
**Category:** Infrastructure
**Difficulty:** 4/5
**Status:** Draft
**Requirements:** REQ-6, REQ-10, REQ-11
**Research:** doc/01_research/domain/vhdl_backend_linux_rtl.md
**Artifacts:** N/A

## Overview

Tests for VHDL generation pipeline producing valid RV64GC SoC VHDL.
Verifies that generated VHDL text contains the correct entity names,
port declarations, peripheral instantiations, and does NOT reference
the old rv32i_core entity.

Covers: AC-2 (VHDL generation pipeline produces valid VHDL files
that GHDL can analyze without errors)

## Compiled-Mode Notes

Text-pattern checks on generated VHDL are interpreter-safe. Actual
GHDL analysis validation requires compiled mode with GHDL installed.
"""

use std.spipe.*
use lib.hardware.fpga_linux._SocVhdlGen.top_testbench.{generate_soc_top_vhdl_rv64}
use lib.hardware.fpga_linux.riscv_fpga_linux.{compile_to_vhdl_module}


# ============================================================================
# AC-2: VHDL Generation — RV64GC Entity (REQ-10)
# ============================================================================

describe "VHDL Gen RV64 Entity":
    it "AC-2: generate_soc_top_vhdl_rv64 returns non-empty text":
        val vhdl = generate_soc_top_vhdl_rv64()
        val len = vhdl.length()
        expect(len).to_be_greater_than(0)

    it "AC-2: generated VHDL contains rv64gc_core entity reference":
        val vhdl = generate_soc_top_vhdl_rv64()
        expect(vhdl).to_contain("rv64gc_core")

    it "AC-2: generated VHDL does NOT contain rv32i_core entity":
        val vhdl = generate_soc_top_vhdl_rv64()
        val has_rv32 = vhdl.contains("rv32i_core")
        expect(has_rv32).to_equal(false)

    it "AC-2: generated VHDL contains entity declaration":
        val vhdl = generate_soc_top_vhdl_rv64()
        expect(vhdl).to_contain("entity")

    it "AC-2: generated VHDL contains architecture declaration":
        val vhdl = generate_soc_top_vhdl_rv64()
        expect(vhdl).to_contain("architecture")


# ============================================================================
# AC-2: VHDL Generation — Peripheral Instantiation
# ============================================================================

describe "VHDL Gen Peripheral Instantiation":
    it "AC-2: generated VHDL instantiates CLINT":
        val vhdl = generate_soc_top_vhdl_rv64()
        expect(vhdl).to_contain("clint")

    it "AC-2: generated VHDL instantiates PLIC":
        val vhdl = generate_soc_top_vhdl_rv64()
        expect(vhdl).to_contain("plic")

    it "AC-2: generated VHDL instantiates UART16550":
        val vhdl = generate_soc_top_vhdl_rv64()
        expect(vhdl).to_contain("uart")

    it "AC-2: generated VHDL instantiates RAM":
        val vhdl = generate_soc_top_vhdl_rv64()
        expect(vhdl).to_contain("ram")

    it "AC-2: generated VHDL instantiates bootrom":
        val vhdl = generate_soc_top_vhdl_rv64()
        expect(vhdl).to_contain("bootrom")

    it "AC-2: generated VHDL instantiates wishbone interconnect":
        val vhdl = generate_soc_top_vhdl_rv64()
        expect(vhdl).to_contain("wb")


# ============================================================================
# AC-2: VHDL Generation — Port Widths for 64-bit
# ============================================================================

describe "VHDL Gen 64-bit Port Widths":
    it "AC-2: generated VHDL uses 64-bit data bus width":
        val vhdl = generate_soc_top_vhdl_rv64()
        expect(vhdl).to_contain("63 downto 0")

    it "AC-2: generated VHDL contains clock port":
        val vhdl = generate_soc_top_vhdl_rv64()
        expect(vhdl).to_contain("clk")

    it "AC-2: generated VHDL contains reset port":
        val vhdl = generate_soc_top_vhdl_rv64()
        expect(vhdl).to_contain("rst")


# ============================================================================
# AC-2: VHDL Backend Compilation of RTL Modules (REQ-6)
# ============================================================================

describe "VHDL Backend RTL Module Compilation":
    it "AC-2: VHDL backend produces output for core.spl (compiled mode + GHDL)":
        # This test requires compiled mode: run VHDL backend against core.spl
        # and verify GHDL analysis passes. Interpreter-safe check: function exists.
        val vhdl = compile_to_vhdl_module("src/lib/hardware/rv64gc_rtl/core.spl")
        val len = vhdl.length()
        expect(len).to_be_greater_than(0)

    it "AC-2: VHDL backend produces output for alu.spl (compiled mode + GHDL)":
        val vhdl = compile_to_vhdl_module("src/lib/hardware/rv64gc_rtl/alu.spl")
        val len = vhdl.length()
        expect(len).to_be_greater_than(0)

    it "AC-2: VHDL backend produces output for decode.spl (compiled mode + GHDL)":
        val vhdl = compile_to_vhdl_module("src/lib/hardware/rv64gc_rtl/decode.spl")
        val len = vhdl.length()
        expect(len).to_be_greater_than(0)
