# @cover src/lib/hardware/rv64gc_rtl/csr_s.spl 0%
# @cover src/lib/hardware/rv64gc_rtl/decode.spl 0%
# @cover src/lib/hardware/rv64gc_rtl/lsu.spl 0%
# @cover src/lib/hardware/rv64gc_rtl/mmu_sv39.spl 0%
