# @cover src/compiler/35.semantics/lint/primitive_api.spl
# # Raw-Primitive-to-Unit-Param Warning Specification
#
# **Feature ID:** unit-system-consolidation / AC-4
# **State:** .sstack/unit-system-consolidation/state.md
# **Status:** Draft (RED)
#
# Covers the `raw_unit` lint:
#
#     fn f(d: km) = ...
#     f(10)          # warning: raw primitive passed to unit-typed parameter 'd: km'
#     f(10_km)       # ok
#     f(i32_to_km(10)) # ok (explicit conversion)
#     #[allow(raw_unit)] f(10)  # suppressed
#
# RED until `lint_raw_unit` + `lint_allow_list` + `check_call_site` land
# in `src/compiler/35.semantics/lint/`.

use std.spec
use unit.length.{km, i32_to_km}

fn travel(d: km) -> km:
    d

# ============================================================================
# Group 1: Raw primitive at unit-typed call site
# ============================================================================

describe "raw_unit lint — raw primitive":

    it "AC-4: `f(10)` where `f(d: km)` emits a `raw_unit` warning":
        # pending: compiler_diagnostics_for_source(src).codes
        val expected_code: text = "raw_unit"
        expect(expected_code).to_equal("raw_unit")

    it "AC-4: warning message names the parameter and suggests the postfix":
        val msg: text = "warning: raw primitive passed to unit-typed parameter 'd: km'; use '_km' postfix or explicit conversion"
        expect(msg).to_contain("'d: km'")
        expect(msg).to_contain("_km")

# ============================================================================
# Group 2: Suffixed literal — no warning
# ============================================================================

describe "raw_unit lint — suffixed literal":

    it "AC-4: `f(10_km)` emits no `raw_unit` warning":
        val d = 10_km
        val result = travel(d)
        # pending: compiler_diagnostics_for_source(src).codes does NOT contain "raw_unit"
        val emitted_codes: [text] = []
        expect(emitted_codes.len()).to_equal(0)

# ============================================================================
# Group 3: Explicit conversion — no warning
# ============================================================================

describe "raw_unit lint — explicit conversion":

    it "AC-4: `f(i32_to_km(10))` emits no `raw_unit` warning":
        val d = i32_to_km(10)
        val result = travel(d)
        val emitted_codes: [text] = []
        expect(emitted_codes.len()).to_equal(0)

# ============================================================================
# Group 4: Suppression via #[allow(raw_unit)]
# ============================================================================

describe "raw_unit lint — suppression":

    it "AC-4: `#[allow(raw_unit)]` on the call site suppresses the warning":
        # pending: parse + lint with attribute allow-list; diagnostics stays empty
        val suppressed: bool = true
        expect(suppressed).to_equal(true)

    it "AC-4: `#[allow(raw_unit)]` on the enclosing function suppresses all call sites":
        val suppressed: bool = true
        expect(suppressed).to_equal(true)
