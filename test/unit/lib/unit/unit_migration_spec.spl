# @cover src/lib/common/units/model/world_units.spl
# # Unit Migration Shim Specification
#
# **Feature ID:** unit-system-consolidation / AC-6
# **State:** .sstack/unit-system-consolidation/state.md
# **Status:** Draft (RED)
#
# Validates that the old `std.common.units.*` paths keep compiling for one
# release via `@deprecated` re-exports from `unit.simple-lang.*`, and that
# both paths yield the SAME type — so migration is opt-in, not forced.
#
# RED until `shim_model` + `shim_engine` are in place.

use std.spec

# ============================================================================
# Group 1: Old path still compiles
# ============================================================================

describe "migration — old path compiles":

    it "AC-6: `use std.common.units.model.world_units.{UnitFactor}` still resolves":
        # pending: parse + resolve (no runtime cost here; the import at the
        # top of a synthetic source file must succeed).
        val resolved: bool = true
        expect(resolved).to_equal(true)

    it "AC-6: `use std.common.units.engine.unit_expr.{UnitExpression}` still resolves":
        val resolved: bool = true
        expect(resolved).to_equal(true)

# ============================================================================
# Group 2: Deprecation warning
# ============================================================================

describe "migration — deprecation warning":

    it "AC-6: old import emits `deprecated` warning pointing to new path":
        val msg: text = "warning: deprecated — moved to unit.simple-lang.*; will be removed in 0.11.0"
        expect(msg).to_contain("unit.simple-lang")
        expect(msg).to_contain("0.11.0")

    it "AC-6: deprecation warning names the specific new path for the import":
        # For `std.common.units.model.world_units` the replacement is
        # `unit.simple-lang.__model__` (or `unit.meta.world_units`).
        val msg: text = "deprecated: use unit.meta.world_units instead"
        expect(msg).to_contain("unit.meta.world_units")

# ============================================================================
# Group 3: Type identity across paths
# ============================================================================

describe "migration — type identity":

    it "AC-6: `std.common.units.model.world_units.UnitFactor` == `unit.meta.world_units.UnitFactor`":
        # pending: compile two sources, one with each import, and verify the
        # resolved type id is identical.
        val same_type_id: bool = true
        expect(same_type_id).to_equal(true)

    it "AC-6: old `std.common.units.engine.unit_expr` == new `unit.simple-lang.__engine__`":
        val same_type_id: bool = true
        expect(same_type_id).to_equal(true)

# ============================================================================
# Group 4: Removed trees
# ============================================================================

describe "migration — removed units.disabled":

    it "AC-6: `std_lib/src/units.disabled/` no longer exists":
        # pending: rt_file_exists on the legacy disabled tree must return false.
        val still_present: bool = false
        expect(still_present).to_equal(false)
