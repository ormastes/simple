# Integration Tests — Cross-module interaction for nogc_async_immut
#
# Tests that verify different persistent data structure modules work
# together correctly: maps with sets, vectors with lists, combinators
# with collections, atoms wrapping persistent structures, versioned
# snapshots, pipelines, and trie vs sorted map comparisons.

use std.persistent_map.{PersistentMap, PersistentMap__empty, PersistentMap__from_entries}
use std.persistent_set.{PersistentSet, PersistentSet__empty, PersistentSet__from_array}
use std.persistent_vec.{PersistentVec, PersistentVec__empty, PersistentVec__from_array}
use std.persistent_list.{PersistentList, PersistentList__from_array}
use std.combinators.{pmap, pfilter, pfold}
use std.combinators.pipeline.{Pipeline, Pipeline__new}
use std.atom.{Atom, Atom__new}
use std.versioned.{VersionedSnapshot__new}
use std.persistent_trie.{PersistentTrie, PersistentTrie__empty}
use std.persistent_sorted_map.{PersistentSortedMap, PersistentSortedMap__of_text}

describe "Cross-module integration":

    describe "Map + Set interaction":
        it "map keys can populate a set":
            val m = PersistentMap__empty().set("a", 1).set("b", 2).set("c", 3)
            val keys = m.keys()
            val s = PersistentSet__from_array(keys)
            expect(s.len()).to_equal(3)
            expect(s.contains("a")).to_equal(true)
            expect(s.contains("b")).to_equal(true)
            expect(s.contains("c")).to_equal(true)

        it "set difference identifies missing map keys":
            val m1 = PersistentMap__empty().set("x", 1).set("y", 2)
            val m2 = PersistentMap__empty().set("y", 20).set("z", 30)
            val s1 = PersistentSet__from_array(m1.keys())
            val s2 = PersistentSet__from_array(m2.keys())
            val only_in_m1 = s1.difference(s2)
            expect(only_in_m1.contains("x")).to_equal(true)
            expect(only_in_m1.contains("y")).to_equal(false)

        it "set intersection finds common keys between maps":
            val m1 = PersistentMap__empty().set("a", 1).set("b", 2).set("c", 3)
            val m2 = PersistentMap__empty().set("b", 20).set("c", 30).set("d", 40)
            val s1 = PersistentSet__from_array(m1.keys())
            val s2 = PersistentSet__from_array(m2.keys())
            val common = s1.intersection(s2)
            expect(common.len()).to_equal(2)
            expect(common.contains("b")).to_equal(true)
            expect(common.contains("c")).to_equal(true)

    describe "Vec + List conversion":
        it "vec to_array feeds into list creation":
            val v = PersistentVec__empty().push(10).push(20).push(30)
            val arr = v.to_array()
            val lst = PersistentList__from_array(arr)
            expect(lst.len()).to_equal(3)
            expect(lst.head()).to_equal(10)

        it "list to_array feeds into vec creation":
            val lst = PersistentList__from_array([5, 10, 15])
            val arr = lst.to_array()
            val v = PersistentVec__from_array(arr)
            expect(v.len()).to_equal(3)
            expect(v.get(0)).to_equal(5)
            expect(v.get(2)).to_equal(15)

        it "round-trip preserves data":
            val original = [100, 200, 300]
            val v = PersistentVec__from_array(original)
            val lst = PersistentList__from_array(v.to_array())
            val result = lst.to_array()
            expect(result).to_equal(original)

    describe "Combinators with persistent collections":
        it "pmap on vec to_array output":
            val v = PersistentVec__empty().push(1).push(2).push(3)
            val doubled = pmap(v.to_array(), \x: x * 2)
            expect(doubled).to_equal([2, 4, 6])

        it "pfilter on map entries":
            val m = PersistentMap__empty().set("a", 10).set("b", 5).set("c", 20)
            val entries = m.entries()
            val big = pfilter(entries, \e: e[1] > 8)
            expect(big.len()).to_equal(2)

        it "pfold on list to_array":
            val lst = PersistentList__from_array([1, 2, 3, 4, 5])
            val total = pfold(lst.to_array(), 0, \acc, x: acc + x)
            expect(total).to_equal(15)

    describe "Atom holding persistent map":
        it "atom wraps a persistent map":
            var atm = Atom__new(PersistentMap__empty())
            expect(atm.deref().len()).to_equal(0)

        it "swap adds entries to the map":
            var atm = Atom__new(PersistentMap__empty())
            atm.swap(\m: m.set("name", "Alice"))
            expect(atm.deref().get("name")).to_equal("Alice")
            expect(atm.deref().len()).to_equal(1)

        it "multiple swaps accumulate entries":
            var atm = Atom__new(PersistentMap__empty())
            atm.swap(\m: m.set("x", 1))
            atm.swap(\m: m.set("y", 2))
            expect(atm.deref().len()).to_equal(2)
            expect(atm.deref().get("x")).to_equal(1)
            expect(atm.deref().get("y")).to_equal(2)
            expect(atm.version()).to_equal(2)

    describe "VersionedSnapshot of persistent vec":
        it "tracks version history of a vector":
            var vs = VersionedSnapshot__new(PersistentVec__empty())
            vs.update(PersistentVec__empty().push(1))
            vs.update(PersistentVec__empty().push(1).push(2))
            expect(vs.version()).to_equal(2)
            val current_vec = vs.current()
            expect(current_vec.len()).to_equal(2)

        it "snapshot captures vec at point in time":
            var vs = VersionedSnapshot__new(PersistentVec__empty().push(10))
            val snap = vs.snapshot()
            vs.update(PersistentVec__empty().push(10).push(20))
            expect(snap.get().len()).to_equal(1)
            expect(vs.current().len()).to_equal(2)

        it "at_version retrieves historical vec state":
            var vs = VersionedSnapshot__new(PersistentVec__empty())
            vs.update(PersistentVec__empty().push(100))
            vs.update(PersistentVec__empty().push(100).push(200))
            val v0 = vs.at_version(0)
            val v1 = vs.at_version(1)
            expect(v0.len()).to_equal(0)
            expect(v1.len()).to_equal(1)

    describe "Pipeline on map entries":
        it "pipeline filters and maps entries":
            val m = PersistentMap__empty().set("a", 1).set("b", 2).set("c", 3)
            val p = Pipeline__new().filter(\e: e[1] > 1).map(\e: e[0])
            val result = p.run(m.entries())
            expect(result.len()).to_equal(2)

        it "pipeline take limits results":
            val m = PersistentMap__empty().set("x", 10).set("y", 20).set("z", 30)
            val p = Pipeline__new().take(2)
            val result = p.run(m.entries())
            expect(result.len()).to_equal(2)

    describe "Trie + SortedMap comparison":
        it "same data in both produces same lookups":
            val trie = PersistentTrie__empty().set("alpha", 1).set("beta", 2).set("gamma", 3)
            val sm = PersistentSortedMap__of_text().set("alpha", 1).set("beta", 2).set("gamma", 3)
            expect(trie.get("alpha")).to_equal(sm.get("alpha"))
            expect(trie.get("beta")).to_equal(sm.get("beta"))
            expect(trie.get("gamma")).to_equal(sm.get("gamma"))

        it "both have same size":
            val trie = PersistentTrie__empty().set("a", 1).set("b", 2)
            val sm = PersistentSortedMap__of_text().set("a", 1).set("b", 2)
            expect(trie.len()).to_equal(sm.len())

        it "sorted map provides ordered keys while trie does not guarantee order":
            val sm = PersistentSortedMap__of_text().set("cherry", 3).set("apple", 1).set("banana", 2)
            val sorted_keys = sm.keys()
            expect(sorted_keys).to_equal(["apple", "banana", "cherry"])
