# PersistentVecBuilder and PersistentMapBuilder Specification
#
# Tests for the transient builder types from nogc_async_immut.
# Builders provide mutable batch construction that freezes into
# immutable collections via .build(). After freeze, mutations
# are silently ignored.

use std.persistent_vec.transient.{
    PersistentVecBuilder, PersistentVecBuilder__new, PersistentVecBuilder__from
}
use std.persistent_map.transient.{
    PersistentMapBuilder, PersistentMapBuilder__new, PersistentMapBuilder__from_entries
}

describe "PersistentVecBuilder":

    describe "creation":
        it "starts empty":
            val b = PersistentVecBuilder.new()
            expect(b.len()).to_equal(0)
            expect(b.is_empty()).to_equal(true)

        it "starts not frozen":
            val b = PersistentVecBuilder.new()
            expect(b.is_frozen()).to_equal(false)

    describe "from factory":
        it "pre-populates with items":
            val b = PersistentVecBuilder.from([10, 20, 30])
            expect(b.len()).to_equal(3)
            expect(b.get(0)).to_equal(10)
            expect(b.get(2)).to_equal(30)

        it "is not frozen after creation":
            val b = PersistentVecBuilder.from([1, 2])
            expect(b.is_frozen()).to_equal(false)

        it "empty array gives empty builder":
            val b = PersistentVecBuilder.from([])
            expect(b.len()).to_equal(0)
            expect(b.is_empty()).to_equal(true)

    describe "push":
        it "adds single element":
            var b = PersistentVecBuilder.new()
            b.push(42)
            expect(b.len()).to_equal(1)
            expect(b.get(0)).to_equal(42)

        it "adds multiple elements in order":
            var b = PersistentVecBuilder.new()
            b.push(1)
            b.push(2)
            b.push(3)
            expect(b.len()).to_equal(3)
            expect(b.get(0)).to_equal(1)
            expect(b.get(1)).to_equal(2)
            expect(b.get(2)).to_equal(3)

        it "is no longer empty after push":
            var b = PersistentVecBuilder.new()
            b.push(99)
            expect(b.is_empty()).to_equal(false)

    describe "push_all":
        it "adds all items from array":
            var b = PersistentVecBuilder.new()
            b.push_all([10, 20, 30])
            expect(b.len()).to_equal(3)
            expect(b.get(0)).to_equal(10)
            expect(b.get(2)).to_equal(30)

        it "appends to existing items":
            var b = PersistentVecBuilder.new()
            b.push(1)
            b.push_all([2, 3, 4])
            expect(b.len()).to_equal(4)
            expect(b.get(0)).to_equal(1)
            expect(b.get(3)).to_equal(4)

        it "empty array is no-op":
            var b = PersistentVecBuilder.new()
            b.push(1)
            b.push_all([])
            expect(b.len()).to_equal(1)

    describe "set_at":
        it "replaces element at index":
            var b = PersistentVecBuilder.from([10, 20, 30])
            b.set_at(1, 99)
            expect(b.get(1)).to_equal(99)

        it "preserves other elements":
            var b = PersistentVecBuilder.from([1, 2, 3])
            b.set_at(0, 99)
            expect(b.get(0)).to_equal(99)
            expect(b.get(1)).to_equal(2)
            expect(b.get(2)).to_equal(3)

        it "ignores negative index":
            var b = PersistentVecBuilder.from([1, 2, 3])
            b.set_at(-1, 99)
            expect(b.get(0)).to_equal(1)
            expect(b.get(1)).to_equal(2)
            expect(b.get(2)).to_equal(3)

        it "ignores out of bounds index":
            var b = PersistentVecBuilder.from([1, 2])
            b.set_at(10, 99)
            expect(b.len()).to_equal(2)

    describe "pop":
        it "removes last element":
            var b = PersistentVecBuilder.from([1, 2, 3])
            b.pop()
            expect(b.len()).to_equal(2)
            expect(b.get(0)).to_equal(1)
            expect(b.get(1)).to_equal(2)

    describe "clear":
        it "removes all elements":
            var b = PersistentVecBuilder.from([1, 2, 3])
            b.clear()
            expect(b.len()).to_equal(0)
            expect(b.is_empty()).to_equal(true)

        it "allows push after clear":
            var b = PersistentVecBuilder.from([1, 2])
            b.clear()
            b.push(99)
            expect(b.len()).to_equal(1)
            expect(b.get(0)).to_equal(99)

    describe "get":
        it "returns element at index":
            val b = PersistentVecBuilder.from([10, 20, 30])
            expect(b.get(0)).to_equal(10)
            expect(b.get(1)).to_equal(20)
            expect(b.get(2)).to_equal(30)

        it "returns nil for out of bounds":
            val b = PersistentVecBuilder.from([1, 2])
            expect(b.get(5)).to_be_nil()

        it "returns nil for negative index":
            val b = PersistentVecBuilder.from([1, 2])
            expect(b.get(-1)).to_be_nil()

    describe "to_array":
        it "returns copy of items":
            var b = PersistentVecBuilder.new()
            b.push(1)
            b.push(2)
            b.push(3)
            val arr = b.to_array()
            expect(arr.len()).to_equal(3)
            expect(arr[0]).to_equal(1)
            expect(arr[2]).to_equal(3)

        it "empty builder returns empty array":
            val b = PersistentVecBuilder.new()
            val arr = b.to_array()
            expect(arr.len()).to_equal(0)

    describe "build and freeze":
        it "returns items as array":
            var b = PersistentVecBuilder.new()
            b.push(10)
            b.push(20)
            b.push(30)
            val items = b.build()
            expect(items.len()).to_equal(3)
            expect(items[0]).to_equal(10)
            expect(items[2]).to_equal(30)

        it "marks builder as frozen":
            var b = PersistentVecBuilder.new()
            b.push(1)
            b.build()
            expect(b.is_frozen()).to_equal(true)

        it "push is no-op after freeze":
            var b = PersistentVecBuilder.new()
            b.push(1)
            b.push(2)
            b.build()
            b.push(3)
            expect(b.len()).to_equal(2)

        it "push_all is no-op after freeze":
            var b = PersistentVecBuilder.new()
            b.push(1)
            b.build()
            b.push_all([2, 3, 4])
            expect(b.len()).to_equal(1)

        it "set_at is no-op after freeze":
            var b = PersistentVecBuilder.from([10, 20])
            b.build()
            b.set_at(0, 99)
            expect(b.get(0)).to_equal(10)

        it "clear is no-op after freeze":
            var b = PersistentVecBuilder.from([1, 2, 3])
            b.build()
            b.clear()
            expect(b.len()).to_equal(3)

        it "reads still work after freeze":
            var b = PersistentVecBuilder.new()
            b.push(10)
            b.push(20)
            b.build()
            expect(b.len()).to_equal(2)
            expect(b.get(0)).to_equal(10)
            expect(b.get(1)).to_equal(20)
            expect(b.is_empty()).to_equal(false)

describe "PersistentMapBuilder":

    describe "creation":
        it "starts empty":
            val b = PersistentMapBuilder.new()
            expect(b.len()).to_equal(0)
            expect(b.is_empty()).to_equal(true)

        it "starts not frozen":
            val b = PersistentMapBuilder.new()
            expect(b.is_frozen()).to_equal(false)

    describe "from_entries factory":
        it "pre-populates with entries":
            val b = PersistentMapBuilder.from_entries([["a", 1], ["b", 2]])
            expect(b.len()).to_equal(2)
            expect(b.get("a")).to_equal(1)
            expect(b.get("b")).to_equal(2)

        it "is not frozen after creation":
            val b = PersistentMapBuilder.from_entries([["x", 10]])
            expect(b.is_frozen()).to_equal(false)

        it "empty entries gives empty builder":
            val b = PersistentMapBuilder.from_entries([])
            expect(b.len()).to_equal(0)
            expect(b.is_empty()).to_equal(true)

        it "handles duplicate keys in entries":
            val b = PersistentMapBuilder.from_entries([["a", 1], ["a", 2]])
            expect(b.len()).to_equal(1)
            expect(b.get("a")).to_equal(2)

    describe "set and get":
        it "stores and retrieves a value":
            var b = PersistentMapBuilder.new()
            b.set("name", "Alice")
            expect(b.get("name")).to_equal("Alice")

        it "stores multiple key-value pairs":
            var b = PersistentMapBuilder.new()
            b.set("a", 1)
            b.set("b", 2)
            b.set("c", 3)
            expect(b.len()).to_equal(3)
            expect(b.get("a")).to_equal(1)
            expect(b.get("b")).to_equal(2)
            expect(b.get("c")).to_equal(3)

        it "overwrites existing key":
            var b = PersistentMapBuilder.new()
            b.set("key", "old")
            b.set("key", "new")
            expect(b.get("key")).to_equal("new")
            expect(b.len()).to_equal(1)

        it "returns nil for missing key":
            val b = PersistentMapBuilder.new()
            expect(b.get("nothing")).to_be_nil()

        it "stores integer keys":
            var b = PersistentMapBuilder.new()
            b.set(1, "one")
            b.set(2, "two")
            expect(b.get(1)).to_equal("one")
            expect(b.get(2)).to_equal("two")

    describe "set_all":
        it "adds multiple entries":
            var b = PersistentMapBuilder.new()
            b.set_all([["x", 10], ["y", 20], ["z", 30]])
            expect(b.len()).to_equal(3)
            expect(b.get("x")).to_equal(10)
            expect(b.get("z")).to_equal(30)

        it "appends to existing entries":
            var b = PersistentMapBuilder.new()
            b.set("a", 1)
            b.set_all([["b", 2], ["c", 3]])
            expect(b.len()).to_equal(3)

    describe "contains":
        it "returns true for existing key":
            var b = PersistentMapBuilder.new()
            b.set("x", 42)
            expect(b.contains("x")).to_equal(true)

        it "returns false for missing key":
            var b = PersistentMapBuilder.new()
            b.set("x", 42)
            expect(b.contains("y")).to_equal(false)

        it "returns false for empty builder":
            val b = PersistentMapBuilder.new()
            expect(b.contains("anything")).to_equal(false)

    describe "remove":
        it "removes an existing key":
            var b = PersistentMapBuilder.new()
            b.set("a", 1)
            b.set("b", 2)
            b.remove("a")
            expect(b.get("a")).to_be_nil()
            expect(b.contains("a")).to_equal(false)
            expect(b.len()).to_equal(1)

        it "preserves other entries":
            var b = PersistentMapBuilder.new()
            b.set("a", 1)
            b.set("b", 2)
            b.set("c", 3)
            b.remove("b")
            expect(b.get("a")).to_equal(1)
            expect(b.get("c")).to_equal(3)
            expect(b.len()).to_equal(2)

        it "remove non-existent key is safe":
            var b = PersistentMapBuilder.new()
            b.set("a", 1)
            b.remove("zzz")
            expect(b.len()).to_equal(1)

    describe "clear":
        it "removes all entries":
            var b = PersistentMapBuilder.new()
            b.set("a", 1)
            b.set("b", 2)
            b.clear()
            expect(b.len()).to_equal(0)
            expect(b.is_empty()).to_equal(true)

        it "allows set after clear":
            var b = PersistentMapBuilder.new()
            b.set("a", 1)
            b.clear()
            b.set("b", 2)
            expect(b.len()).to_equal(1)
            expect(b.get("b")).to_equal(2)
            expect(b.get("a")).to_be_nil()

    describe "keys and values":
        it "returns correct keys":
            var b = PersistentMapBuilder.new()
            b.set("x", 10)
            b.set("y", 20)
            val k = b.keys()
            expect(k.len()).to_equal(2)

        it "returns correct values":
            var b = PersistentMapBuilder.new()
            b.set("x", 10)
            b.set("y", 20)
            val v = b.values()
            expect(v.len()).to_equal(2)

        it "empty builder has empty keys and values":
            val b = PersistentMapBuilder.new()
            expect(b.keys().len()).to_equal(0)
            expect(b.values().len()).to_equal(0)

    describe "to_entries":
        it "returns key-value pairs":
            var b = PersistentMapBuilder.new()
            b.set("a", 1)
            b.set("b", 2)
            val entries = b.to_entries()
            expect(entries.len()).to_equal(2)
            val first = entries[0]
            expect(first[0]).to_equal("a")
            expect(first[1]).to_equal(1)

        it "empty builder returns empty entries":
            val b = PersistentMapBuilder.new()
            val entries = b.to_entries()
            expect(entries.len()).to_equal(0)

    describe "build and freeze":
        it "returns entries as array of pairs":
            var b = PersistentMapBuilder.new()
            b.set("name", "Alice")
            b.set("age", 30)
            val entries = b.build()
            expect(entries.len()).to_equal(2)

        it "marks builder as frozen":
            var b = PersistentMapBuilder.new()
            b.set("x", 1)
            b.build()
            expect(b.is_frozen()).to_equal(true)

        it "set is no-op after freeze":
            var b = PersistentMapBuilder.new()
            b.set("a", 1)
            b.build()
            b.set("b", 2)
            expect(b.len()).to_equal(1)
            expect(b.get("b")).to_be_nil()

        it "set_all is no-op after freeze":
            var b = PersistentMapBuilder.new()
            b.set("a", 1)
            b.build()
            b.set_all([["b", 2], ["c", 3]])
            expect(b.len()).to_equal(1)

        it "remove is no-op after freeze":
            var b = PersistentMapBuilder.new()
            b.set("a", 1)
            b.set("b", 2)
            b.build()
            b.remove("a")
            expect(b.len()).to_equal(2)
            expect(b.get("a")).to_equal(1)

        it "clear is no-op after freeze":
            var b = PersistentMapBuilder.new()
            b.set("a", 1)
            b.build()
            b.clear()
            expect(b.len()).to_equal(1)

        it "reads still work after freeze":
            var b = PersistentMapBuilder.new()
            b.set("x", 42)
            b.set("y", 99)
            b.build()
            expect(b.len()).to_equal(2)
            expect(b.get("x")).to_equal(42)
            expect(b.contains("y")).to_equal(true)
            expect(b.is_empty()).to_equal(false)

        it "build returns well-formed entries":
            var b = PersistentMapBuilder.new()
            b.set("key", "value")
            val entries = b.build()
            expect(entries.len()).to_equal(1)
            val pair = entries[0]
            expect(pair[0]).to_equal("key")
            expect(pair[1]).to_equal("value")

    describe "edge cases":
        it "empty key string":
            var b = PersistentMapBuilder.new()
            b.set("", "empty_key")
            expect(b.get("")).to_equal("empty_key")
            expect(b.len()).to_equal(1)

        it "nil value stored and retrieved":
            var b = PersistentMapBuilder.new()
            b.set("nil_val", nil)
            expect(b.len()).to_equal(1)

        it "overwrite then remove":
            var b = PersistentMapBuilder.new()
            b.set("a", 1)
            b.set("a", 2)
            b.remove("a")
            expect(b.len()).to_equal(0)
            expect(b.get("a")).to_be_nil()
