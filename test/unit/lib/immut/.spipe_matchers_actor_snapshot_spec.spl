# ActorSnapshot + ActorState Tests
#
# Tests for the actor_snapshot module from nogc_async_immut.
# ActorSnapshot provides immutable frozen captures of actor state.
# ActorState provides mutable versioned state with snapshot creation.

use std.actor_snapshot.{ActorSnapshot, ActorSnapshot__new, ActorState, ActorState__new, ActorState__named}

describe "ActorSnapshot":

    describe "creation":
        it "creates with ActorSnapshot__new":
            val snap = ActorSnapshot.new("hello", 1, 100, "src-1")
            expect snap.state() == "hello"

        it "state() returns the correct value":
            val snap = ActorSnapshot.new(42, 0, 0, "worker")
            expect snap.state() == 42

        it "version() returns version number":
            val snap = ActorSnapshot.new("data", 5, 10, "node-a")
            expect snap.version() == 5

        it "timestamp() returns timestamp":
            val snap = ActorSnapshot.new("data", 3, 77, "node-b")
            expect snap.timestamp() == 77

        it "source() returns source identifier":
            val snap = ActorSnapshot.new("val", 0, 0, "worker-7")
            expect snap.source() == "worker-7"

    describe "is_from":
        it "returns true for matching source":
            val snap = ActorSnapshot.new(nil, 0, 0, "origin-1")
            expect snap.is_from("origin-1") == true

        it "returns false for non-matching source":
            val snap = ActorSnapshot.new(nil, 0, 0, "origin-1")
            expect snap.is_from("origin-2") == false

    describe "metadata":
        it "with_metadata returns new snapshot with metadata":
            val snap = ActorSnapshot.new("st", 0, 0, "s1")
            val snap2 = snap.with_metadata("key", "value")
            expect snap2.metadata("key") == "value"

        it "original snapshot unchanged after with_metadata":
            val snap = ActorSnapshot.new("st", 0, 0, "s1")
            val snap2 = snap.with_metadata("key", "value")
            expect snap.has_metadata("key") == false

        it "has_metadata returns true for existing key":
            val snap = ActorSnapshot.new("st", 0, 0, "s1")
            val snap2 = snap.with_metadata("color", "red")
            expect snap2.has_metadata("color") == true

        it "has_metadata returns false for missing key":
            val snap = ActorSnapshot.new("st", 0, 0, "s1")
            expect snap.has_metadata("missing") == false

        it "metadata returns nil for missing key":
            val snap = ActorSnapshot.new("data", 0, 0, "s1")
            expect snap.metadata("nope") == nil

        it "with_metadata preserves other fields":
            val snap = ActorSnapshot.new("payload", 3, 99, "src-x")
            val snap2 = snap.with_metadata("tag", "v1")
            expect snap2.state() == "payload"
            expect snap2.version() == 3
            expect snap2.timestamp() == 99
            expect snap2.source() == "src-x"

        it "multiple metadata entries":
            val snap = ActorSnapshot.new("d", 0, 0, "s")
            val s2 = snap.with_metadata("a", 1)
            val s3 = s2.with_metadata("b", 2)
            expect s3.metadata("a") == 1
            expect s3.metadata("b") == 2

    describe "snapshot with nil state":
        it "handles nil state":
            val snap = ActorSnapshot.new(nil, 0, 0, "s1")
            expect snap.state() == nil

        it "handles array state":
            val snap = ActorSnapshot.new([1, 2, 3], 1, 5, "arr-src")
            expect snap.state() == [1, 2, 3]

describe "ActorState":

    describe "creation":
        it "creates with initial state":
            var st = ActorState.new("initial", "worker-1")
            expect st.current() == "initial"

        it "version starts at 0":
            var st = ActorState.new(100, "w1")
            expect st.version() == 0

        it "source returns identifier":
            var st = ActorState.new(nil, "my-actor")
            expect st.source() == "my-actor"

        it "ActorState__named creates with nil initial":
            var st = ActorState.named("lazy-actor")
            expect st.current() == nil
            expect st.source() == "lazy-actor"
            expect st.version() == 0

    describe "update":
        it "update replaces state":
            var st = ActorState.new("old", "w")
            st.update("new")
            expect st.current() == "new"

        it "update increments version":
            var st = ActorState.new(0, "w")
            st.update(1)
            expect st.version() == 1

        it "multiple updates increment version correctly":
            var st = ActorState.new("a", "w")
            st.update("b")
            st.update("c")
            st.update("d")
            expect st.version() == 3
            expect st.current() == "d"

    describe "update_with":
        it "applies function to current state":
            var st = ActorState.new(10, "calc")
            st.update_with(\x: x * 2)
            expect st.current() == 20

        it "increments version":
            var st = ActorState.new(5, "calc")
            st.update_with(\x: x + 1)
            expect st.version() == 1

    describe "snapshot":
        it "creates snapshot of current state":
            var st = ActorState.new("data", "w-1")
            val snap = st.snapshot()
            expect snap.state() == "data"
            expect snap.version() == 0
            expect snap.source() == "w-1"

        it "snapshot isolated from subsequent updates":
            var st = ActorState.new("before", "w")
            val snap = st.snapshot()
            st.update("after")
            expect snap.state() == "before"
            expect snap.version() == 0
            expect st.current() == "after"

        it "snapshot_with uses custom state":
            var st = ActorState.new([1, 2, 3], "w")
            val snap = st.snapshot_with("custom-view")
            expect snap.state() == "custom-view"
            expect snap.version() == 0
            expect snap.source() == "w"

    describe "metadata":
        it "set_metadata propagates to snapshots":
            var st = ActorState.new("data", "w")
            st.set_metadata("env", "production")
            val snap = st.snapshot()
            expect snap.has_metadata("env") == true
            expect snap.metadata("env") == "production"

        it "set_metadata overwrites existing key":
            var st = ActorState.new("d", "w")
            st.set_metadata("key", "v1")
            st.set_metadata("key", "v2")
            val snap = st.snapshot()
            expect snap.metadata("key") == "v2"

    describe "multiple updates and snapshots":
        it "snapshots at different versions":
            var st = ActorState.new(0, "counter")
            val snap0 = st.snapshot()
            st.update(10)
            val snap1 = st.snapshot()
            st.update(20)
            val snap2 = st.snapshot()
            expect snap0.state() == 0
            expect snap0.version() == 0
            expect snap1.state() == 10
            expect snap1.version() == 1
            expect snap2.state() == 20
            expect snap2.version() == 2