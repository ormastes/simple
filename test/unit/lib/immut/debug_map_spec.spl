# Debug PersistentMap entries

use std.persistent_map.hamt_node.{hamt_leaf, hamt_node_entries, HAMT_LEAF}
use std.persistent_map.{PersistentMap, PersistentMap__empty}

describe "Debug PersistentMap":
    it "hamt_node_entries returns entries from leaf":
        val node = hamt_leaf(42, "key", "value")
        val entries = hamt_node_entries(node)
        expect(entries.len()).to_equal(1)

    it "PersistentMap entries works":
        val m = PersistentMap__empty()
        val m2 = m.set("a", 1)
        val e = m2.entries()
        expect(e.len()).to_equal(1)

    it "PersistentMap keys works":
        val m = PersistentMap__empty()
        val m2 = m.set("a", 1).set("b", 2)
        val k = m2.keys()
        expect(k.len()).to_equal(2)
