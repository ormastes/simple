# Debug from_dict

use std.persistent_map.{PersistentMap, PersistentMap__empty, PersistentMap__from_entries}

fn dict_to_entries(d):
    var result = []
    for k in d:
        result.push([k, d[k]])
    result

describe "Debug from_dict":
    it "dict_to_entries check":
        var d = {}
        d["x"] = 10
        d["y"] = 20
        val entries = dict_to_entries(d)
        expect(entries.len()).to_equal(2)

    it "dict_to_entries build map":
        var d = {}
        d["x"] = 10
        d["y"] = 20
        val entries = dict_to_entries(d)
        val m = PersistentMap.from_entries(entries)
        expect(m.len()).to_equal(2)
        expect(m.get("x")).to_equal(10)
        expect(m.get("y")).to_equal(20)
