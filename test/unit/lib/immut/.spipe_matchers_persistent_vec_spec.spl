# PersistentVec Specification
#
# Comprehensive tests for the RRB-tree based immutable PersistentVec.
# Covers construction, element access, immutable updates, slicing,
# higher-order operations, search, conversion, persistence guarantees,
# and stress tests with many elements.

use std.persistent_vec.{
    PersistentVec, PersistentVec__empty, PersistentVec__from_array,
    PersistentVec__of, PersistentVec__repeat, PersistentVec__range
}

describe "PersistentVec":

    describe "empty vector":
        it "has zero length":
            val v = PersistentVec.empty()
            expect v.len() == 0

        it "is empty":
            val v = PersistentVec.empty()
            expect v.is_empty() == true

        it "get returns nil for any index":
            val v = PersistentVec.empty()
            expect v.get(0) == nil
            expect v.get(5) == nil

        it "first returns nil":
            val v = PersistentVec.empty()
            expect v.first() == nil

        it "last returns nil":
            val v = PersistentVec.empty()
            expect v.last() == nil

        it "to_array returns empty array":
            val v = PersistentVec.empty()
            val arr = v.to_array()
            expect arr.len() == 0

        it "pop returns empty":
            val v = PersistentVec.empty()
            val v2 = v.pop()
            expect v2.len() == 0
            expect v2.is_empty() == true

    describe "push":
        it "adds single element":
            val v = PersistentVec.empty().push(42)
            expect v.len() == 1
            expect v.get(0) == 42

        it "adds multiple elements in order":
            val v = PersistentVec.empty().push(10).push(20).push(30)
            expect v.len() == 3
            expect v.get(0) == 10
            expect v.get(1) == 20
            expect v.get(2) == 30

        it "is no longer empty after push":
            val v = PersistentVec.empty().push(1)
            expect v.is_empty() == false

        it "supports mixed types":
            val v = PersistentVec.empty().push(1).push("two").push(nil)
            expect v.len() == 3
            expect v.get(0) == 1
            expect v.get(1) == "two"
            expect v.get(2) == nil

    describe "get":
        it "retrieves element at valid index":
            val v = PersistentVec.from_array([10, 20, 30, 40, 50])
            expect v.get(0) == 10
            expect v.get(2) == 30
            expect v.get(4) == 50

        it "returns nil for index beyond length":
            val v = PersistentVec.from_array([1, 2, 3])
            expect v.get(3) == nil
            expect v.get(100) == nil

        it "supports negative indexing":
            val v = PersistentVec.from_array([10, 20, 30, 40])
            expect v.get(-1) == 40
            expect v.get(-2) == 30
            expect v.get(-4) == 10

        it "returns nil for negative index beyond bounds":
            val v = PersistentVec.from_array([1, 2])
            expect v.get(-3) == nil
            expect v.get(-10) == nil

    describe "set":
        it "replaces element at index":
            val v = PersistentVec.from_array([1, 2, 3])
            val v2 = v.set(1, 99)
            expect v2.get(1) == 99

        it "returns new vector - original unchanged":
            val v1 = PersistentVec.from_array([10, 20, 30])
            val v2 = v1.set(0, 99)
            expect v1.get(0) == 10
            expect v2.get(0) == 99

        it "preserves other elements":
            val v = PersistentVec.from_array([1, 2, 3, 4, 5])
            val v2 = v.set(2, 99)
            expect v2.get(0) == 1
            expect v2.get(1) == 2
            expect v2.get(2) == 99
            expect v2.get(3) == 4
            expect v2.get(4) == 5

        it "supports negative indexing":
            val v = PersistentVec.from_array([1, 2, 3])
            val v2 = v.set(-1, 99)
            expect v2.get(2) == 99

        it "returns self for out of bounds index":
            val v = PersistentVec.from_array([1, 2, 3])
            val v2 = v.set(10, 99)
            expect v2.len() == 3
            expect v2.get(0) == 1

    describe "pop":
        it "removes last element":
            val v = PersistentVec.from_array([1, 2, 3])
            val v2 = v.pop()
            expect v2.len() == 2
            expect v2.get(0) == 1
            expect v2.get(1) == 2

        it "does not modify original":
            val v1 = PersistentVec.from_array([10, 20, 30])
            val v2 = v1.pop()
            expect v1.len() == 3
            expect v1.get(2) == 30
            expect v2.len() == 2

        it "pop to single element":
            val v = PersistentVec.from_array([1, 2]).pop()
            expect v.len() == 1
            expect v.get(0) == 1

        it "pop to empty":
            val v = PersistentVec.from_array([42]).pop()
            expect v.len() == 0
            expect v.is_empty() == true

    describe "first and last":
        it "first returns element at index 0":
            val v = PersistentVec.from_array([5, 10, 15])
            expect v.first() == 5

        it "last returns element at last index":
            val v = PersistentVec.from_array([5, 10, 15])
            expect v.last() == 15

        it "first and last are same for single element":
            val v = PersistentVec.from_array([42])
            expect v.first() == 42
            expect v.last() == 42

    describe "from_array":
        it "builds from array preserving order":
            val v = PersistentVec.from_array([10, 20, 30])
            expect v.len() == 3
            expect v.get(0) == 10
            expect v.get(1) == 20
            expect v.get(2) == 30

        it "handles empty array":
            val v = PersistentVec.from_array([])
            expect v.len() == 0
            expect v.is_empty() == true

        it "handles single element":
            val v = PersistentVec.from_array([99])
            expect v.len() == 1
            expect v.get(0) == 99

    describe "of":
        it "is alias for from_array":
            val v = PersistentVec.of([5, 10, 15])
            expect v.len() == 3
            expect v.get(0) == 5
            expect v.get(2) == 15

    describe "repeat":
        it "creates vector with repeated value":
            val v = PersistentVec.repeat(7, 5)
            expect v.len() == 5
            expect v.get(0) == 7
            expect v.get(4) == 7

        it "repeat zero gives empty":
            val v = PersistentVec.repeat(99, 0)
            expect v.len() == 0
            expect v.is_empty() == true

    describe "range":
        it "creates integer range":
            val v = PersistentVec.range(0, 5)
            expect v.len() == 5
            expect v.get(0) == 0
            expect v.get(4) == 4

        it "creates non-zero start range":
            val v = PersistentVec.range(3, 7)
            expect v.len() == 4
            expect v.get(0) == 3
            expect v.get(3) == 6

        it "empty range when start equals end":
            val v = PersistentVec.range(5, 5)
            expect v.len() == 0
            expect v.is_empty() == true

    describe "persistence":
        it "original unchanged after push":
            val v0 = PersistentVec.empty()
            val v1 = v0.push(1)
            val v2 = v1.push(2)
            val v3 = v2.push(3)
            expect v0.len() == 0
            expect v1.len() == 1
            expect v2.len() == 2
            expect v3.len() == 3

        it "branches share structure":
            val base = PersistentVec.from_array([1, 2, 3])
            val branch_a = base.push(40)
            val branch_b = base.push(50)
            expect base.len() == 3
            expect branch_a.len() == 4
            expect branch_b.len() == 4
            expect branch_a.get(3) == 40
            expect branch_b.get(3) == 50
            # Base elements identical in both branches
            expect branch_a.get(0) == 1
            expect branch_b.get(0) == 1

        it "set does not modify original":
            val v1 = PersistentVec.from_array([10, 20, 30])
            val v2 = v1.set(1, 99)
            expect v1.get(1) == 20
            expect v2.get(1) == 99

        it "pop does not modify original":
            val v1 = PersistentVec.from_array([1, 2, 3])
            val v2 = v1.pop()
            expect v1.len() == 3
            expect v1.get(2) == 3
            expect v2.len() == 2

    describe "slice":
        it "takes a slice from the middle":
            val v = PersistentVec.from_array([10, 20, 30, 40, 50])
            val s = v.slice(1, 4)
            expect s.len() == 3
            expect s.get(0) == 20
            expect s.get(1) == 30
            expect s.get(2) == 40

        it "full range returns all elements":
            val v = PersistentVec.from_array([1, 2, 3])
            val s = v.slice(0, 3)
            expect s.len() == 3
            expect s.get(0) == 1
            expect s.get(2) == 3

        it "empty slice when start equals end":
            val v = PersistentVec.from_array([1, 2, 3])
            val s = v.slice(2, 2)
            expect s.len() == 0

        it "clamps end to size":
            val v = PersistentVec.from_array([1, 2, 3])
            val s = v.slice(1, 100)
            expect s.len() == 2
            expect s.get(0) == 2

    describe "concat":
        it "concatenates two vectors":
            val a = PersistentVec.from_array([1, 2])
            val b = PersistentVec.from_array([3, 4])
            val c = a.concat(b)
            expect c.len() == 4
            expect c.get(0) == 1
            expect c.get(1) == 2
            expect c.get(2) == 3
            expect c.get(3) == 4

        it "concat with empty returns same content":
            val v = PersistentVec.from_array([1, 2, 3])
            val empty = PersistentVec.empty()
            val c = v.concat(empty)
            expect c.len() == 3
            expect c.get(0) == 1

        it "empty concat with other returns other":
            val empty = PersistentVec.empty()
            val v = PersistentVec.from_array([10, 20])
            val c = empty.concat(v)
            expect c.len() == 2
            expect c.get(0) == 10

        it "does not modify originals":
            val a = PersistentVec.from_array([1])
            val b = PersistentVec.from_array([2])
            val c = a.concat(b)
            expect a.len() == 1
            expect b.len() == 1
            expect c.len() == 2

    describe "map":
        it "applies function to each element":
            val v = PersistentVec.from_array([1, 2, 3])
            val doubled = v.map(\x: x * 2)
            expect doubled.len() == 3
            expect doubled.get(0) == 2
            expect doubled.get(1) == 4
            expect doubled.get(2) == 6

        it "preserves length":
            val v = PersistentVec.from_array([10, 20, 30])
            val result = v.map(\x: x + 1)
            expect result.len() == 3

        it "empty vector map is empty":
            val v = PersistentVec.empty()
            val result = v.map(\x: x * 2)
            expect result.len() == 0

        it "does not modify original":
            val v = PersistentVec.from_array([1, 2, 3])
            val v2 = v.map(\x: x * 10)
            expect v.get(0) == 1
            expect v2.get(0) == 10

    describe "filter":
        it "keeps matching elements":
            val v = PersistentVec.from_array([1, 2, 3, 4, 5, 6])
            val evens = v.filter(\x: x % 2 == 0)
            expect evens.len() == 3
            expect evens.get(0) == 2
            expect evens.get(1) == 4
            expect evens.get(2) == 6

        it "returns empty when nothing matches":
            val v = PersistentVec.from_array([1, 3, 5])
            val evens = v.filter(\x: x % 2 == 0)
            expect evens.len() == 0

        it "returns all when everything matches":
            val v = PersistentVec.from_array([2, 4, 6])
            val evens = v.filter(\x: x % 2 == 0)
            expect evens.len() == 3

    describe "fold":
        it "accumulates sum":
            val v = PersistentVec.from_array([1, 2, 3, 4])
            val sum = v.fold(0, \acc, x: acc + x)
            expect sum == 10

        it "accumulates product":
            val v = PersistentVec.from_array([1, 2, 3, 4])
            val product = v.fold(1, \acc, x: acc * x)
            expect product == 24

        it "returns init for empty vector":
            val v = PersistentVec.empty()
            val result = v.fold(42, \acc, x: acc + x)
            expect result == 42

        it "single element":
            val v = PersistentVec.from_array([5])
            val result = v.fold(0, \acc, x: acc + x)
            expect result == 5

    describe "take":
        it "takes first n elements":
            val v = PersistentVec.from_array([10, 20, 30, 40, 50])
            val t = v.take(3)
            expect t.len() == 3
            expect t.get(0) == 10
            expect t.get(2) == 30

        it "takes zero returns empty":
            val v = PersistentVec.from_array([1, 2, 3])
            val t = v.take(0)
            expect t.len() == 0

        it "takes more than length returns all":
            val v = PersistentVec.from_array([1, 2])
            val t = v.take(10)
            expect t.len() == 2

    describe "drop":
        it "drops first n elements":
            val v = PersistentVec.from_array([10, 20, 30, 40, 50])
            val d = v.drop(2)
            expect d.len() == 3
            expect d.get(0) == 30
            expect d.get(2) == 50

        it "drops zero returns all":
            val v = PersistentVec.from_array([1, 2, 3])
            val d = v.drop(0)
            expect d.len() == 3

        it "drops more than length returns empty":
            val v = PersistentVec.from_array([1, 2])
            val d = v.drop(10)
            expect d.len() == 0

    describe "contains":
        it "finds existing element":
            val v = PersistentVec.from_array([10, 20, 30])
            expect v.contains(20) == true

        it "returns false for missing element":
            val v = PersistentVec.from_array([10, 20, 30])
            expect v.contains(99) == false

        it "returns false for empty vector":
            val v = PersistentVec.empty()
            expect v.contains(1) == false

        it "finds string elements":
            val v = PersistentVec.from_array(["a", "b", "c"])
            expect v.contains("b") == true
            expect v.contains("z") == false

    describe "index_of":
        it "finds index of existing element":
            val v = PersistentVec.from_array([10, 20, 30, 40])
            expect v.index_of(30) == 2

        it "returns -1 for missing element":
            val v = PersistentVec.from_array([10, 20, 30])
            expect v.index_of(99) == -1

        it "returns first occurrence":
            val v = PersistentVec.from_array([5, 10, 5, 10])
            expect v.index_of(10) == 1

        it "returns -1 for empty vector":
            val v = PersistentVec.empty()
            expect v.index_of(1) == -1

    describe "reverse":
        it "reverses the vector":
            val v = PersistentVec.from_array([1, 2, 3])
            val r = v.reverse()
            expect r.get(0) == 3
            expect r.get(1) == 2
            expect r.get(2) == 1

        it "preserves length":
            val v = PersistentVec.from_array([1, 2, 3, 4])
            val r = v.reverse()
            expect r.len() == 4

        it "reverse of single element is same":
            val v = PersistentVec.from_array([42])
            val r = v.reverse()
            expect r.get(0) == 42
            expect r.len() == 1

        it "reverse of empty is empty":
            val v = PersistentVec.empty()
            val r = v.reverse()
            expect r.len() == 0

        it "does not modify original":
            val v = PersistentVec.from_array([1, 2, 3])
            val r = v.reverse()
            expect v.get(0) == 1
            expect r.get(0) == 3

    describe "to_array":
        it "converts to array in order":
            val v = PersistentVec.from_array([10, 20, 30])
            val arr = v.to_array()
            expect arr.len() == 3
            expect arr[0] == 10
            expect arr[1] == 20
            expect arr[2] == 30

        it "empty vector gives empty array":
            val v = PersistentVec.empty()
            val arr = v.to_array()
            expect arr.len() == 0

        it "round-trips through array":
            val original = [5, 10, 15, 20]
            val v = PersistentVec.from_array(original)
            val arr = v.to_array()
            expect arr.len() == 4
            expect arr[0] == 5
            expect arr[3] == 20

    describe "each":
        it "visits all elements":
            val v = PersistentVec.from_array([1, 2, 3])
            # Note: each uses closures; nested closures cannot modify
            # captured vars in interpreter mode. We just test it runs.
            v.each(\x: x)
            expect v.len() == 3

    describe "stress test":
        it "push and get many elements via helper fn":
            fn run_push_stress() -> i64:
                var v = PersistentVec.empty()
                var i = 0
                while i < 200:
                    v = v.push(i)
                    i = i + 1
                v.len()
            expect run_push_stress() == 200

        it "verify elements after many pushes":
            fn run_verify_stress() -> i64:
                var v = PersistentVec.empty()
                var i = 0
                while i < 100:
                    v = v.push(i * 10)
                    i = i + 1
                var ok_count = 0
                i = 0
                while i < 100:
                    if v.get(i) == i * 10:
                        ok_count = ok_count + 1
                    i = i + 1
                ok_count
            expect run_verify_stress() == 100

        it "push then pop many elements":
            fn run_pop_stress() -> i64:
                var v = PersistentVec.empty()
                var i = 0
                while i < 50:
                    v = v.push(i)
                    i = i + 1
                i = 0
                while i < 25:
                    v = v.pop()
                    i = i + 1
                v.len()
            expect run_pop_stress() == 25

        it "range creates correct elements":
            fn run_range_stress() -> i64:
                val v = PersistentVec.range(0, 100)
                var ok_count = 0
                var i = 0
                while i < 100:
                    if v.get(i) == i:
                        ok_count = ok_count + 1
                    i = i + 1
                ok_count
            expect run_range_stress() == 100

    describe "edge cases":
        it "set same value returns equivalent vector":
            val v = PersistentVec.from_array([1, 2, 3])
            val v2 = v.set(1, 2)
            expect v2.get(1) == 2
            expect v2.len() == 3

        it "nil value stored and retrieved":
            val v = PersistentVec.empty().push(nil)
            expect v.len() == 1
            expect v.get(0) == nil

        it "push after pop restores length":
            val v = PersistentVec.from_array([1, 2, 3])
            val v2 = v.pop().push(99)
            expect v2.len() == 3
            expect v2.get(2) == 99

        it "concat two empties is empty":
            val a = PersistentVec.empty()
            val b = PersistentVec.empty()
            val c = a.concat(b)
            expect c.len() == 0
            expect c.is_empty() == true

        it "filter then map":
            val v = PersistentVec.from_array([1, 2, 3, 4, 5, 6])
            val result = v.filter(\x: x % 2 == 0).map(\x: x * 10)
            expect result.len() == 3
            expect result.get(0) == 20
            expect result.get(1) == 40
            expect result.get(2) == 60

        it "take and drop partition the vector":
            val v = PersistentVec.from_array([1, 2, 3, 4, 5])
            val head = v.take(3)
            val tail = v.drop(3)
            expect head.len() == 3
            expect tail.len() == 2
            expect head.get(0) == 1
            expect tail.get(0) == 4