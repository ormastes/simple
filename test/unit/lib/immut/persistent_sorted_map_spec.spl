# PersistentSortedMap Specification
#
# Comprehensive tests for the LLRB-based immutable sorted map.
# Covers construction, lookup, mutation (returns new map), removal,
# persistence guarantees, min/max, range queries, floor/ceiling,
# ordered iteration, merge, filter, fold, and conversion.

use std.persistent_sorted_map.{PersistentSortedMap, PersistentSortedMap__empty, PersistentSortedMap__of_ints, PersistentSortedMap__of_text, PersistentSortedMap__from_entries, compare_ints, compare_text}

describe "PersistentSortedMap":

    # ==================================================================
    # Empty map
    # ==================================================================
    describe "empty map":
        it "has zero length":
            val m = PersistentSortedMap__of_ints()
            expect(m.len()).to_equal(0)

        it "is empty":
            val m = PersistentSortedMap__of_ints()
            expect(m.is_empty()).to_equal(true)

        it "get returns nil for any key":
            val m = PersistentSortedMap__of_ints()
            expect(m.get(1)).to_be_nil()
            expect(m.get(999)).to_be_nil()

        it "get_or returns default for any key":
            val m = PersistentSortedMap__of_ints()
            expect(m.get_or(1, 42)).to_equal(42)

        it "contains returns false for any key":
            val m = PersistentSortedMap__of_ints()
            expect(m.contains(1)).to_equal(false)

        it "min_key returns nil":
            val m = PersistentSortedMap__of_ints()
            expect(m.min_key()).to_be_nil()

        it "max_key returns nil":
            val m = PersistentSortedMap__of_ints()
            expect(m.max_key()).to_be_nil()

        it "min_entry returns nil":
            val m = PersistentSortedMap__of_ints()
            expect(m.min_entry()).to_be_nil()

        it "max_entry returns nil":
            val m = PersistentSortedMap__of_ints()
            expect(m.max_entry()).to_be_nil()

        it "keys returns empty array":
            val m = PersistentSortedMap__of_ints()
            expect(m.keys().len()).to_equal(0)

        it "values returns empty array":
            val m = PersistentSortedMap__of_ints()
            expect(m.values().len()).to_equal(0)

        it "entries returns empty array":
            val m = PersistentSortedMap__of_ints()
            expect(m.entries().len()).to_equal(0)

    # ==================================================================
    # set and get
    # ==================================================================
    describe "set and get":
        it "stores and retrieves a single value":
            val m = PersistentSortedMap__of_ints().set(5, "five")
            expect(m.get(5)).to_equal("five")
            expect(m.len()).to_equal(1)

        it "returns new map on set - original unchanged":
            val m1 = PersistentSortedMap__of_ints()
            val m2 = m1.set(1, "one")
            expect(m1.len()).to_equal(0)
            expect(m1.get(1)).to_be_nil()
            expect(m2.len()).to_equal(1)
            expect(m2.get(1)).to_equal("one")

        it "overwrites existing key":
            val m1 = PersistentSortedMap__of_ints().set(1, "old")
            val m2 = m1.set(1, "new")
            expect(m2.get(1)).to_equal("new")
            expect(m2.len()).to_equal(1)

        it "handles two keys":
            val m = PersistentSortedMap__of_ints().set(1, "one").set(2, "two")
            expect(m.get(1)).to_equal("one")
            expect(m.get(2)).to_equal("two")
            expect(m.len()).to_equal(2)

        it "handles three keys":
            val m = PersistentSortedMap__of_ints().set(3, "c").set(1, "a").set(2, "b")
            expect(m.get(1)).to_equal("a")
            expect(m.get(2)).to_equal("b")
            expect(m.get(3)).to_equal("c")
            expect(m.len()).to_equal(3)

        it "returns nil for missing key":
            val m = PersistentSortedMap__of_ints().set(1, "one")
            expect(m.get(99)).to_be_nil()

        it "is no longer empty after set":
            val m = PersistentSortedMap__of_ints().set(1, "x")
            expect(m.is_empty()).to_equal(false)

    # ==================================================================
    # set and get with text keys
    # ==================================================================
    describe "text keys":
        it "stores and retrieves text keys":
            val m = PersistentSortedMap__of_text().set("apple", 1).set("banana", 2)
            expect(m.get("apple")).to_equal(1)
            expect(m.get("banana")).to_equal(2)
            expect(m.len()).to_equal(2)

        it "maintains lexicographic order for text keys":
            val m = PersistentSortedMap__of_text().set("cherry", 3).set("apple", 1).set("banana", 2)
            val k = m.keys()
            expect(k[0]).to_equal("apple")
            expect(k[1]).to_equal("banana")
            expect(k[2]).to_equal("cherry")

    # ==================================================================
    # contains
    # ==================================================================
    describe "contains":
        it "returns true for existing key":
            val m = PersistentSortedMap__of_ints().set(10, "ten")
            expect(m.contains(10)).to_equal(true)

        it "returns false for missing key":
            val m = PersistentSortedMap__of_ints().set(10, "ten")
            expect(m.contains(20)).to_equal(false)

        it "returns false after removal":
            val m = PersistentSortedMap__of_ints().set(10, "ten").remove(10)
            expect(m.contains(10)).to_equal(false)

    # ==================================================================
    # get_or
    # ==================================================================
    describe "get_or":
        it "returns value for existing key":
            val m = PersistentSortedMap__of_ints().set(1, "one")
            expect(m.get_or(1, "default")).to_equal("one")

        it "returns default for missing key":
            val m = PersistentSortedMap__of_ints()
            expect(m.get_or(1, "default")).to_equal("default")

        it "returns default with numeric fallback":
            val m = PersistentSortedMap__of_ints()
            expect(m.get_or(99, -1)).to_equal(-1)

    # ==================================================================
    # Persistence (old versions unchanged)
    # ==================================================================
    describe "persistence":
        it "preserves snapshots across multiple sets":
            val m0 = PersistentSortedMap__of_ints()
            val m1 = m0.set(1, "a")
            val m2 = m1.set(2, "b")
            val m3 = m2.set(3, "c")
            expect(m0.len()).to_equal(0)
            expect(m1.len()).to_equal(1)
            expect(m2.len()).to_equal(2)
            expect(m3.len()).to_equal(3)
            expect(m1.get(2)).to_be_nil()
            expect(m2.get(3)).to_be_nil()

        it "overwrite does not affect earlier version":
            val m1 = PersistentSortedMap__of_ints().set(1, "old")
            val m2 = m1.set(1, "new")
            expect(m1.get(1)).to_equal("old")
            expect(m2.get(1)).to_equal("new")

        it "remove does not affect earlier version":
            val m1 = PersistentSortedMap__of_ints().set(1, "a").set(2, "b")
            val m2 = m1.remove(1)
            expect(m1.get(1)).to_equal("a")
            expect(m1.len()).to_equal(2)
            expect(m2.get(1)).to_be_nil()
            expect(m2.len()).to_equal(1)

    # ==================================================================
    # remove
    # ==================================================================
    describe "remove":
        it "removes an existing key":
            val m = PersistentSortedMap__of_ints().set(1, "a").set(2, "b")
            val m2 = m.remove(1)
            expect(m2.get(1)).to_be_nil()
            expect(m2.get(2)).to_equal("b")
            expect(m2.len()).to_equal(1)

        it "handles removing non-existent key":
            val m = PersistentSortedMap__of_ints().set(1, "a")
            val m2 = m.remove(99)
            expect(m2.len()).to_equal(1)
            expect(m2.get(1)).to_equal("a")

        it "removes last key to get empty map":
            val m = PersistentSortedMap__of_ints().set(1, "only")
            val m2 = m.remove(1)
            expect(m2.len()).to_equal(0)
            expect(m2.is_empty()).to_equal(true)

        it "removes from multi-key map":
            val m = PersistentSortedMap__of_ints().set(1, "a").set(2, "b").set(3, "c")
            val m2 = m.remove(2)
            expect(m2.len()).to_equal(2)
            expect(m2.get(1)).to_equal("a")
            expect(m2.get(2)).to_be_nil()
            expect(m2.get(3)).to_equal("c")

        it "remove from empty map returns same empty map":
            val m = PersistentSortedMap__of_ints()
            val m2 = m.remove(1)
            expect(m2.len()).to_equal(0)

    # ==================================================================
    # min / max
    # ==================================================================
    describe "min and max":
        it "min_key returns smallest key":
            val m = PersistentSortedMap__of_ints().set(5, "e").set(1, "a").set(9, "i")
            expect(m.min_key()).to_equal(1)

        it "max_key returns largest key":
            val m = PersistentSortedMap__of_ints().set(5, "e").set(1, "a").set(9, "i")
            expect(m.max_key()).to_equal(9)

        it "min_entry returns key-value pair for smallest key":
            val m = PersistentSortedMap__of_ints().set(5, "five").set(1, "one").set(9, "nine")
            val entry = m.min_entry()
            expect(entry[0]).to_equal(1)
            expect(entry[1]).to_equal("one")

        it "max_entry returns key-value pair for largest key":
            val m = PersistentSortedMap__of_ints().set(5, "five").set(1, "one").set(9, "nine")
            val entry = m.max_entry()
            expect(entry[0]).to_equal(9)
            expect(entry[1]).to_equal("nine")

        it "single element map has same min and max":
            val m = PersistentSortedMap__of_ints().set(42, "answer")
            expect(m.min_key()).to_equal(42)
            expect(m.max_key()).to_equal(42)

    # ==================================================================
    # range queries
    # ==================================================================
    describe "range":
        it "returns entries within range inclusive":
            val m = PersistentSortedMap__of_ints().set(1, "a").set(3, "c").set(5, "e").set(7, "g").set(9, "i")
            val r = m.range(3, 7)
            expect(r.len()).to_equal(3)
            expect(r[0][0]).to_equal(3)
            expect(r[1][0]).to_equal(5)
            expect(r[2][0]).to_equal(7)

        it "returns empty for range with no matches":
            val m = PersistentSortedMap__of_ints().set(1, "a").set(10, "j")
            val r = m.range(3, 7)
            expect(r.len()).to_equal(0)

        it "returns single entry when from equals to":
            val m = PersistentSortedMap__of_ints().set(1, "a").set(3, "c").set(5, "e")
            val r = m.range(3, 3)
            expect(r.len()).to_equal(1)
            expect(r[0][0]).to_equal(3)

        it "range on empty map returns empty":
            val m = PersistentSortedMap__of_ints()
            val r = m.range(1, 10)
            expect(r.len()).to_equal(0)

        it "returns all entries when range covers entire map":
            val m = PersistentSortedMap__of_ints().set(2, "b").set(4, "d").set(6, "f")
            val r = m.range(1, 10)
            expect(r.len()).to_equal(3)

    # ==================================================================
    # floor and ceiling
    # ==================================================================
    describe "floor":
        it "returns exact match":
            val m = PersistentSortedMap__of_ints().set(1, "a").set(3, "c").set(5, "e")
            val f = m.floor(3)
            expect(f[0]).to_equal(3)
            expect(f[1]).to_equal("c")

        it "returns greatest key less than target":
            val m = PersistentSortedMap__of_ints().set(1, "a").set(3, "c").set(5, "e")
            val f = m.floor(4)
            expect(f[0]).to_equal(3)
            expect(f[1]).to_equal("c")

        it "returns nil when no key is less or equal":
            val m = PersistentSortedMap__of_ints().set(5, "e").set(10, "j")
            val f = m.floor(3)
            expect(f).to_be_nil()

        it "floor on empty map returns nil":
            val m = PersistentSortedMap__of_ints()
            expect(m.floor(5)).to_be_nil()

    describe "ceiling":
        it "returns exact match":
            val m = PersistentSortedMap__of_ints().set(1, "a").set(3, "c").set(5, "e")
            val c = m.ceiling(3)
            expect(c[0]).to_equal(3)
            expect(c[1]).to_equal("c")

        it "returns smallest key greater than target":
            val m = PersistentSortedMap__of_ints().set(1, "a").set(3, "c").set(5, "e")
            val c = m.ceiling(2)
            expect(c[0]).to_equal(3)
            expect(c[1]).to_equal("c")

        it "returns nil when no key is greater or equal":
            val m = PersistentSortedMap__of_ints().set(1, "a").set(3, "c")
            val c = m.ceiling(10)
            expect(c).to_be_nil()

        it "ceiling on empty map returns nil":
            val m = PersistentSortedMap__of_ints()
            expect(m.ceiling(5)).to_be_nil()

    # ==================================================================
    # ordered keys/values/entries
    # ==================================================================
    describe "ordered iteration":
        it "keys are in sorted order":
            val m = PersistentSortedMap__of_ints().set(5, "e").set(1, "a").set(9, "i").set(3, "c")
            val k = m.keys()
            expect(k.len()).to_equal(4)
            expect(k[0]).to_equal(1)
            expect(k[1]).to_equal(3)
            expect(k[2]).to_equal(5)
            expect(k[3]).to_equal(9)

        it "values are in key-sorted order":
            val m = PersistentSortedMap__of_ints().set(3, "c").set(1, "a").set(2, "b")
            val v = m.values()
            expect(v[0]).to_equal("a")
            expect(v[1]).to_equal("b")
            expect(v[2]).to_equal("c")

        it "entries are in key-sorted order":
            val m = PersistentSortedMap__of_ints().set(20, "x").set(10, "y").set(30, "z")
            val e = m.entries()
            expect(e.len()).to_equal(3)
            expect(e[0][0]).to_equal(10)
            expect(e[1][0]).to_equal(20)
            expect(e[2][0]).to_equal(30)

    # ==================================================================
    # merge
    # ==================================================================
    describe "merge":
        it "merges two disjoint maps":
            val m1 = PersistentSortedMap__of_ints().set(1, "a").set(3, "c")
            val m2 = PersistentSortedMap__of_ints().set(2, "b").set(4, "d")
            val merged = m1.merge(m2)
            expect(merged.len()).to_equal(4)
            expect(merged.get(1)).to_equal("a")
            expect(merged.get(2)).to_equal("b")
            expect(merged.get(3)).to_equal("c")
            expect(merged.get(4)).to_equal("d")

        it "other takes precedence on conflict":
            val m1 = PersistentSortedMap__of_ints().set(1, "old")
            val m2 = PersistentSortedMap__of_ints().set(1, "new")
            val merged = m1.merge(m2)
            expect(merged.get(1)).to_equal("new")
            expect(merged.len()).to_equal(1)

        it "merge with empty returns self":
            val m1 = PersistentSortedMap__of_ints().set(1, "a")
            val m2 = PersistentSortedMap__of_ints()
            val merged = m1.merge(m2)
            expect(merged.get(1)).to_equal("a")
            expect(merged.len()).to_equal(1)

        it "empty merge with other returns other":
            val m1 = PersistentSortedMap__of_ints()
            val m2 = PersistentSortedMap__of_ints().set(2, "b")
            val merged = m1.merge(m2)
            expect(merged.get(2)).to_equal("b")
            expect(merged.len()).to_equal(1)

        it "does not modify originals":
            val m1 = PersistentSortedMap__of_ints().set(1, "a")
            val m2 = PersistentSortedMap__of_ints().set(2, "b")
            val merged = m1.merge(m2)
            expect(m1.len()).to_equal(1)
            expect(m2.len()).to_equal(1)
            expect(merged.len()).to_equal(2)

        it "merged map maintains sorted order":
            val m1 = PersistentSortedMap__of_ints().set(5, "e").set(1, "a")
            val m2 = PersistentSortedMap__of_ints().set(3, "c").set(7, "g")
            val merged = m1.merge(m2)
            val k = merged.keys()
            expect(k[0]).to_equal(1)
            expect(k[1]).to_equal(3)
            expect(k[2]).to_equal(5)
            expect(k[3]).to_equal(7)

    # ==================================================================
    # filter
    # ==================================================================
    describe "filter":
        it "keeps entries matching predicate":
            val m = PersistentSortedMap__of_ints().set(1, 10).set(2, 20).set(3, 30)
            val filtered = m.filter(fn(k, v): v > 15)
            expect(filtered.len()).to_equal(2)
            expect(filtered.get(1)).to_be_nil()
            expect(filtered.get(2)).to_equal(20)
            expect(filtered.get(3)).to_equal(30)

        it "returns empty when nothing matches":
            val m = PersistentSortedMap__of_ints().set(1, 10).set(2, 20)
            val filtered = m.filter(fn(k, v): v > 100)
            expect(filtered.len()).to_equal(0)
            expect(filtered.is_empty()).to_equal(true)

        it "returns all when everything matches":
            val m = PersistentSortedMap__of_ints().set(1, 10).set(2, 20)
            val filtered = m.filter(fn(k, v): v > 0)
            expect(filtered.len()).to_equal(2)

        it "filter by key":
            val m = PersistentSortedMap__of_ints().set(1, "a").set(2, "b").set(3, "c")
            val filtered = m.filter(fn(k, v): k > 1)
            expect(filtered.len()).to_equal(2)
            expect(filtered.contains(1)).to_equal(false)
            expect(filtered.contains(2)).to_equal(true)

        it "does not modify original":
            val m = PersistentSortedMap__of_ints().set(1, 10).set(2, 20)
            val filtered = m.filter(fn(k, v): v > 15)
            expect(m.len()).to_equal(2)
            expect(filtered.len()).to_equal(1)

    # ==================================================================
    # fold
    # ==================================================================
    describe "fold":
        it "sums all values":
            val m = PersistentSortedMap__of_ints().set(1, 10).set(2, 20).set(3, 30)
            val total = m.fold(0, fn(acc, k, v): acc + v)
            expect(total).to_equal(60)

        it "fold over empty returns init":
            val m = PersistentSortedMap__of_ints()
            val result = m.fold(42, fn(acc, k, v): acc + v)
            expect(result).to_equal(42)

        it "fold processes keys in sorted order":
            val m = PersistentSortedMap__of_ints().set(3, "c").set(1, "a").set(2, "b")
            val result = m.fold("", fn(acc, k, v): acc + v)
            expect(result).to_equal("abc")

        it "fold counts entries":
            val m = PersistentSortedMap__of_ints().set(1, "a").set(2, "b").set(3, "c")
            val count = m.fold(0, fn(acc, k, v): acc + 1)
            expect(count).to_equal(3)

    # ==================================================================
    # from_entries
    # ==================================================================
    describe "from_entries":
        it "builds from key-value pairs":
            val m = PersistentSortedMap__from_entries([[1, "one"], [2, "two"]], compare_ints)
            expect(m.get(1)).to_equal("one")
            expect(m.get(2)).to_equal("two")
            expect(m.len()).to_equal(2)

        it "handles empty entries":
            val m = PersistentSortedMap__from_entries([], compare_ints)
            expect(m.len()).to_equal(0)
            expect(m.is_empty()).to_equal(true)

        it "handles single entry":
            val m = PersistentSortedMap__from_entries([[42, "answer"]], compare_ints)
            expect(m.get(42)).to_equal("answer")
            expect(m.len()).to_equal(1)

        it "last value wins for duplicate keys":
            val m = PersistentSortedMap__from_entries([[1, "first"], [1, "second"]], compare_ints)
            expect(m.get(1)).to_equal("second")
            expect(m.len()).to_equal(1)

        it "maintains sorted order from entries":
            val m = PersistentSortedMap__from_entries([[5, "e"], [1, "a"], [3, "c"]], compare_ints)
            val k = m.keys()
            expect(k[0]).to_equal(1)
            expect(k[1]).to_equal(3)
            expect(k[2]).to_equal(5)

    # ==================================================================
    # to_dict
    # ==================================================================
    describe "to_dict":
        it "converts to mutable dict":
            val m = PersistentSortedMap__of_ints().set(1, "one").set(2, "two")
            val d = m.to_dict()
            expect(d[1]).to_equal("one")
            expect(d[2]).to_equal("two")

        it "empty map converts to empty dict":
            val m = PersistentSortedMap__of_ints()
            val d = m.to_dict()
            expect(d.len()).to_equal(0)

    # ==================================================================
    # factory functions
    # ==================================================================
    describe "factory functions":
        it "of_ints creates empty int map":
            val m = PersistentSortedMap__of_ints()
            expect(m.len()).to_equal(0)
            val m2 = m.set(1, "one")
            expect(m2.get(1)).to_equal("one")

        it "of_text creates empty text map":
            val m = PersistentSortedMap__of_text()
            expect(m.len()).to_equal(0)
            val m2 = m.set("hello", 1)
            expect(m2.get("hello")).to_equal(1)

        it "empty with custom comparator":
            val m = PersistentSortedMap__empty(compare_ints)
            val m2 = m.set(3, "c").set(1, "a").set(2, "b")
            val k = m2.keys()
            expect(k[0]).to_equal(1)
            expect(k[1]).to_equal(2)
            expect(k[2]).to_equal(3)

    # ==================================================================
    # stress tests
    # ==================================================================
    describe "stress test":
        it "handles many insertions via helper fn":
            fn run_insert_stress() -> i64:
                var m = PersistentSortedMap__of_ints()
                var i = 0
                while i < 100:
                    m = m.set(i, i * 10)
                    i = i + 1
                m.len()
            expect(run_insert_stress()).to_equal(100)

        it "set and get many elements":
            fn run_get_stress() -> i64:
                var m = PersistentSortedMap__of_ints()
                var i = 0
                while i < 50:
                    m = m.set(i, i * 10)
                    i = i + 1
                var ok_count = 0
                i = 0
                while i < 50:
                    val v = m.get(i)
                    if v == i * 10:
                        ok_count = ok_count + 1
                    i = i + 1
                ok_count
            expect(run_get_stress()).to_equal(50)

        it "remove many elements":
            fn run_remove_stress() -> i64:
                var m = PersistentSortedMap__of_ints()
                var i = 0
                while i < 30:
                    m = m.set(i, i)
                    i = i + 1
                i = 0
                while i < 15:
                    m = m.remove(i)
                    i = i + 1
                m.len()
            expect(run_remove_stress()).to_equal(15)

        it "keys stay sorted after many random-order inserts":
            fn run_order_stress() -> bool:
                var m = PersistentSortedMap__of_ints()
                # Insert in non-sequential order
                m = m.set(50, "a")
                m = m.set(10, "b")
                m = m.set(90, "c")
                m = m.set(30, "d")
                m = m.set(70, "e")
                m = m.set(20, "f")
                m = m.set(80, "g")
                m = m.set(40, "h")
                m = m.set(60, "i")
                val k = m.keys()
                var sorted = true
                var idx = 1
                while idx < k.len():
                    if k[idx] < k[idx - 1]:
                        sorted = false
                    idx = idx + 1
                sorted
            expect(run_order_stress()).to_equal(true)

    # ==================================================================
    # edge cases
    # ==================================================================
    describe "edge cases":
        it "set same key same value returns equivalent map":
            val m = PersistentSortedMap__of_ints().set(1, "a")
            val m2 = m.set(1, "a")
            expect(m2.get(1)).to_equal("a")
            expect(m2.len()).to_equal(1)

        it "single entry map operations":
            val m = PersistentSortedMap__of_ints().set(42, "answer")
            expect(m.len()).to_equal(1)
            expect(m.min_key()).to_equal(42)
            expect(m.max_key()).to_equal(42)
            val r = m.range(1, 100)
            expect(r.len()).to_equal(1)
            val f = m.floor(42)
            expect(f[0]).to_equal(42)
            val c = m.ceiling(42)
            expect(c[0]).to_equal(42)

        it "negative integer keys":
            val m = PersistentSortedMap__of_ints().set(-5, "neg5").set(0, "zero").set(5, "pos5")
            expect(m.get(-5)).to_equal("neg5")
            expect(m.min_key()).to_equal(-5)
            expect(m.max_key()).to_equal(5)
            val k = m.keys()
            expect(k[0]).to_equal(-5)
            expect(k[1]).to_equal(0)
            expect(k[2]).to_equal(5)
