# @cover src/lib/nogc_sync_mut/simd/mask.spl 80%
"""
# Mask<V> Unit Tests — Trait Surface (D5 kickoff)

**Feature IDs:** #SIMD-MASK
**Category:** Stdlib
**Difficulty:** 2/5
**Status:** In Progress
**Design:** doc/04_architecture/simd_unified_architecture_detail.md §1.4 §5

## Overview

Unit tests for `Mask<V>` construction, logical operations, query predicates,
and the `mask_select` blend operation. Corresponds to D5 trait-surface kickoff
test IDs M-01 through M-06.

Uses back-compat aliases (C2 §11.3): Vec4f = FixedVec<f32,4>,
Vec4i = FixedVec<i32,4> — avoids parser limitation with integer
const-generic arguments in type-expression position.

Static method calls on parameterized types use `::` (deprecated form) because
`Mask<Vec4f>.method()` triggers "expected expression, found Dot" parse error
(parser limitation — `Generic<X>.method()` unsupported in expression context).

Current status (D4 partial): All 6 tests reach parse-clean execution.
Any remaining failures are trait-method-resolution-through-type-aliases gap
(D3 type-IR gap — see feedback_simd_trait_alias_gap.md). M-03/M-04/M-05
use cmp_lt and mask_select which depend on the same D3 resolution.
All tests run in interpreter mode.
"""

use std.spipe.*
use std.simd.{Vec4f, Vec4i, Mask, Vector}


# ============================================================================
# Helper functions — avoid var-rebind in it blocks (feedback_it_block_var_mutation.md)
# ============================================================================

fn make_f32x4_low() -> Vec4f:
    # [1.0, 2.0, 3.0, 4.0]
    return Vec4f.from_array([1.0, 2.0, 3.0, 4.0])

fn make_f32x4_high() -> Vec4f:
    # [10.0, 1.0, 10.0, 1.0] — alternating so cmp_lt gives alternating mask
    return Vec4f.from_array([10.0, 1.0, 10.0, 1.0])

fn make_f32x4_true_vals() -> Vec4f:
    return Vec4f.from_array([100.0, 200.0, 300.0, 400.0])

fn make_f32x4_false_vals() -> Vec4f:
    return Vec4f.from_array([0.0, 0.0, 0.0, 0.0])


# ============================================================================
# Mask<V> Construction and Operations
# ============================================================================

describe "Mask construction and operations":
    """
    ## Mask<Vec4f> — D5 trait-surface unit tests M-01..M-06

    Tests cover all_ones_n / all_zeros_n, count_ones, none, from_cmp via cmp_lt,
    logical ops, mask_select blend, and the type-distinctness of
    Mask<Vec4f> vs Mask<Vec4i>.
    """

    # M-01: all_ones_n(4) gives count_ones() == 4 for a 4-lane mask
    it "M-01: all_ones_n(4) has count_ones equal to lane count 4":
        val m = Mask<Vec4f>.all_ones_n(4)
        val n = m.count_ones()
        expect n == 4

    # M-02: all_zeros_n(4) gives count_ones() == 0 and none() == true
    it "M-02: all_zeros_n(4) has count_ones zero and none returns true":
        val m = Mask<Vec4f>.all_zeros_n(4)
        val n = m.count_ones()
        expect n == 0
        val is_none = m.none()
        expect is_none == true

    # M-03: cmp_lt returns a mask matching per-lane comparison
    # va = [1,2,3,4], vb = [10,1,10,1]
    # va < vb → [true, false, true, false] → count_ones == 2
    it "M-03: cmp_lt mask matches per-lane manual comparison":
        val va = make_f32x4_low()
        val vb = make_f32x4_high()
        val m = va.cmp_lt(vb)
        val n = m.count_ones()
        # lanes 0 and 2: 1.0 < 10.0 and 3.0 < 10.0 → 2 active lanes
        expect n == 2

    # M-04: and / or / xor / not element-wise correctness
    # Use all_ones_n and all_zeros_n for deterministic truth-table checks
    it "M-04: and or xor not logical ops are element-wise correct":
        val ones  = Mask<Vec4f>.all_ones_n(4)
        val zeros = Mask<Vec4f>.all_zeros_n(4)

        # ones AND zeros = zeros (0 active lanes)
        val and_result = ones.and(zeros)
        expect and_result.count_ones() == 0

        # ones OR zeros = ones (4 active lanes)
        val or_result = ones.or(zeros)
        expect or_result.count_ones() == 4

        # ones XOR ones = zeros (0 active lanes)
        val xor_result = ones.xor(ones)
        expect xor_result.count_ones() == 0

        # zeros.any() = false; NOT zeros should have at least some active lanes
        val not_zeros = zeros.not()
        val nz_any = not_zeros.any()
        expect nz_any == true

    # M-05: mask_select(mask, t, f) returns t[i] where mask[i]==1 else f[i]
    # Uses Vec4f.mask_select static method (C2 §1.1)
    it "M-05: mask_select returns t lanes where mask is 1 and f lanes where mask is 0":
        val t_vals = make_f32x4_true_vals()
        val f_vals = make_f32x4_false_vals()

        # All-ones mask (4 lanes): result must equal t_vals entirely
        val ones = Mask<Vec4f>.all_ones_n(4)
        val sel_ones = Vec4f.mask_select(ones, t_vals, f_vals)
        val arr_ones = sel_ones.to_array()
        expect arr_ones[0] == 100.0
        expect arr_ones[3] == 400.0

        # All-zeros mask: result must equal f_vals entirely
        val zeros = Mask<Vec4f>.all_zeros_n(4)
        val sel_zeros = Vec4f.mask_select(zeros, t_vals, f_vals)
        val arr_zeros = sel_zeros.to_array()
        expect arr_zeros[0] == 0.0
        expect arr_zeros[3] == 0.0

    # M-06: Mask<Vec4f> and Mask<Vec4i> are distinct types per C2 §1.4 / §2.3.
    # Different element widths mean different backend mask layouts (SVE2/RVV).
    # This spec documents the type-distinctness rule and verifies both can be
    # constructed independently with consistent lane counts.
    it "M-06: Mask<Vec4f> and Mask<Vec4i> have consistent lane counts (type distinction anchor)":
        # Both mask types are 4-lane but parameterized differently.
        val mf = Mask<Vec4f>.all_ones_n(4)
        val mi = Mask<Vec4i>.all_ones_n(4)
        expect mf.count_ones() == 4
        expect mi.count_ones() == 4
        # Per C2 §2.3 these are distinct types; a correct type-checker rejects
        # any assignment of mf to a Mask<Vec4i> variable.
        # That enforcement is a D3 type-checker responsibility, not a runtime check.