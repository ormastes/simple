# @cover src/lib/nogc_sync_mut/simd/scalable.spl 80%
"""
# ScalableVec<T> Unit Tests — Trait Surface (D5 kickoff)

**Feature IDs:** #SIMD-SCALABLE
**Category:** Stdlib
**Difficulty:** 3/5
**Status:** In Progress
**Design:** doc/04_architecture/simd_unified_architecture_detail.md §1.3 §4

## Overview

Unit test for `ScalableVec<T>` splat and runtime lane-count query in
interpreter mode. Corresponds to D5 trait-surface kickoff test ID S-01.

All tests run in interpreter mode. Expected result before D4 lands:
0 passing (import resolution fails). After D4 lands: 1/1 passing,
provided D3 wires the interpreter fallback to `ScalableVec::min_lanes()`.
"""

use std.spipe.*
use std.simd.{ScalableVec}


# ============================================================================
# ScalableVec Construction
# ============================================================================

describe "ScalableVec construction":
    """
    ## ScalableVec<T> — D5 trait-surface unit test S-01

    Tests that `ScalableVec<f32>::splat(1.0)` constructs successfully in
    interpreter mode and that `lanes()` returns at least `min_lanes()`.

    The interpreter uses a compile-time fallback for `vlenb`/`svcntw` ABI
    (D3 §7 parity rules). The exact returned value is target-defined but must
    be >= `ScalableVec<f32>::min_lanes()` (which is 4 per C2 §4 for f32).
    """

    # S-01: ScalableVec<f32>::splat(1.0) in interpreter mode
    # lanes() must be >= min_lanes() (at least 4 for f32)
    it "S-01: ScalableVec<f32>::splat(1.0) constructs and lanes() >= min_lanes()":
        val v = ScalableVec<f32>::splat(1.0)
        val n = v.lanes()
        val min_n = ScalableVec<f32>::min_lanes()
        # Runtime lane count must be at least the architectural minimum
        expect(n).to_be_greater_than(min_n - 1)
