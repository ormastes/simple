use std.spipe.*
use std.simd.{SimdTier, detect_profile, profile_name, simd_width}

fn tier_name(tier: SimdTier) -> text:
    match tier:
        SimdTier.scalar: "scalar"
        SimdTier.x86_64_sse2: "x86_64_sse2"
        SimdTier.x86_64_avx2: "x86_64_avx2"
        SimdTier.x86_64_avx512: "x86_64_avx512"
        SimdTier.aarch64_neon: "aarch64_neon"
        SimdTier.aarch64_sve: "aarch64_sve"
        SimdTier.aarch64_sve2: "aarch64_sve2"
        SimdTier.riscv64_rvv: "riscv64_rvv"
        SimdTier.wasm128: "wasm128"

fn tier_width_bits(tier: SimdTier) -> i64:
    match tier:
        SimdTier.x86_64_avx512: 512
        SimdTier.x86_64_avx2: 256
        SimdTier.x86_64_sse2: 128
        SimdTier.aarch64_neon: 128
        SimdTier.aarch64_sve: 128
        SimdTier.aarch64_sve2: 128
        SimdTier.riscv64_rvv: 128
        SimdTier.wasm128: 128
        SimdTier.scalar: 0

fn main():

    describe "std.simd profile detection":
        it "keeps detect_profile aligned with the runtime profile name":
            val tier = detect_profile()
            expect profile_name() == tier_name(tier)

        it "reports a width coherent with the detected runtime tier":
            val tier = detect_profile()
            expect simd_width() == tier_width_bits(tier)