# @cover src/lib/nogc_sync_mut/simd/fixed.spl 60%
"""
# FixedVec<f32,4> Cross-Target Equivalence Tests — M0

**Feature IDs:** #SIMD-CROSS-TARGET
**Category:** Stdlib
**Difficulty:** 2/5
**Status:** Active
**Design:** doc/05_design/simd_test_catalog.md §6 (T3 — Cross-Target Equivalence)

## Overview

Proves that `FixedVec<f32,4>` arithmetic (add, mul, fma, max, min, sub, neg,
reduce_min) produces bit-identical results to a scalar reference implementation.

## f32 Equality Policy

All test inputs are exact-representation f32 values (integers and dyadic fractions
with |value| < 2^24).  For such inputs, bit-equality holds unconditionally across
backends because:
- add/sub/mul/max/min: IEEE 754 requires identical rounding for operands whose
  mathematical result is also exactly representable.
- fma: single-rounded FMA equals double-rounded (a*b + c) iff the intermediate
  product a*b is exactly representable.  All FMA inputs here satisfy |a*b| < 2^24,
  so both rounding modes agree bit-for-bit.

No `to_be_close` or ULP tolerance is needed or used.

## Cross-Target Reuse

This file may be run verbatim on any host (x86, ARM, RISC-V).  Each test computes
expected values via per-element scalar arithmetic in Simple — no arch-specific
constants.  When a different backend is selected, the assertions remain identical.

## Construction Note

Uses `vec4f_from_array` wrapper function (C2 §11.3).  Direct
`Vec4f` alias form is inert until D3/E2 lands — see aliases.spl.

## Test input vectors (shared across all tests)

    a = [1.0, 2.0, 4.0, 0.25]   — dyadic fractions, exact f32
    b = [3.0, 0.5, 2.0, 8.0]    — dyadic fractions, exact f32
    c = [0.25, 1.0, -3.5, 2.0]  — mixed sign, exact f32 (vc[2] negative for abs/neg tests)
"""

use std.spipe.*
use std.simd.aliases.{vec4f_from_array}


# ============================================================================
# Helper vector constructors — avoids var-rebind in it blocks
# (feedback_it_block_var_mutation.md)
# ============================================================================

fn make_va() -> FixedVec<f32>:
    return vec4f_from_array([1.0, 2.0, 4.0, 0.25])

fn make_vb() -> FixedVec<f32>:
    return vec4f_from_array([3.0, 0.5, 2.0, 8.0])

fn make_vc() -> FixedVec<f32>:
    return vec4f_from_array([0.25, 1.0, -3.5, 2.0])


# ============================================================================
# CT-01: add
# a=[1,2,4,0.25] + b=[3,0.5,2,8] = [4, 2.5, 6, 8.25]
# All sums are exact f32.
# Reference: scalar addition per lane.
# ============================================================================

describe "FixedVec<f32,4> cross-target equivalence — add":
    """
    CT-01: add — FixedVec result matches scalar reference lane-by-lane.
    """

    it "CT-01: add matches scalar reference for all four lanes":
        val va = make_va()
        val vb = make_vb()
        val result = va.add(vb)
        val got = result.to_array()
        # Scalar reference (double-checked): 1+3=4, 2+0.5=2.5, 4+2=6, 0.25+8=8.25
        expect(got[0]).to_equal(4.0)
        expect(got[1]).to_equal(2.5)
        expect(got[2]).to_equal(6.0)
        expect(got[3]).to_equal(8.25)


# ============================================================================
# CT-02: mul
# a=[1,2,4,0.25] * b=[3,0.5,2,8] = [3, 1, 8, 2]
# All products are exact f32 (|a[i]*b[i]| < 2^24).
# Reference: scalar multiplication per lane.
# ============================================================================

describe "FixedVec<f32,4> cross-target equivalence — mul":
    """
    CT-02: mul — FixedVec result matches scalar reference lane-by-lane.
    """

    it "CT-02: mul matches scalar reference for all four lanes":
        val va = make_va()
        val vb = make_vb()
        val result = va.mul(vb)
        val got = result.to_array()
        # Scalar reference: 1*3=3, 2*0.5=1, 4*2=8, 0.25*8=2
        expect(got[0]).to_equal(3.0)
        expect(got[1]).to_equal(1.0)
        expect(got[2]).to_equal(8.0)
        expect(got[3]).to_equal(2.0)


# ============================================================================
# CT-03: fma
# fma(b, c) = a*b + c lane-wise
# a=[1,2,4,0.25], b=[3,0.5,2,8], c=[0.25,1,-3.5,2]
# Products a*b: [3, 1, 8, 2] — all exactly representable f32
# Results: 3+0.25=3.25, 1+1=2, 8+(-3.5)=4.5, 2+2=4
# FMA rounding note: single-rounded and double-rounded agree because all
# products a[i]*b[i] are exactly representable (|a*b| < 2^24).
# Reference: scalar a*b + c per lane.
# ============================================================================

describe "FixedVec<f32,4> cross-target equivalence — fma":
    """
    CT-03: fma — FixedVec result matches scalar reference lane-by-lane.
    """

    it "CT-03: fma matches scalar reference for all four lanes":
        val va = make_va()
        val vb = make_vb()
        val vc = make_vc()
        val result = va.fma(vb, vc)
        val got = result.to_array()
        # Scalar reference: 1*3+0.25=3.25, 2*0.5+1=2, 4*2+(-3.5)=4.5, 0.25*8+2=4
        expect(got[0]).to_equal(3.25)
        expect(got[1]).to_equal(2.0)
        expect(got[2]).to_equal(4.5)
        expect(got[3]).to_equal(4.0)


# ============================================================================
# CT-04: max
# element-wise max(a, b): [max(1,3), max(2,0.5), max(4,2), max(0.25,8)]
#                       = [3, 2, 4, 8]
# NaN-propagation is target-defined (C1 §9); test uses finite values only.
# Reference: per-lane conditional max.
# ============================================================================

describe "FixedVec<f32,4> cross-target equivalence — max":
    """
    CT-04: max — element-wise maximum, finite inputs only.
    """

    it "CT-04: max matches scalar reference for all four lanes":
        val va = make_va()
        val vb = make_vb()
        val result = va.max(vb)
        val got = result.to_array()
        # Scalar reference: max(1,3)=3, max(2,0.5)=2, max(4,2)=4, max(0.25,8)=8
        expect(got[0]).to_equal(3.0)
        expect(got[1]).to_equal(2.0)
        expect(got[2]).to_equal(4.0)
        expect(got[3]).to_equal(8.0)


# ============================================================================
# CT-05: min
# element-wise min(a, b): [min(1,3), min(2,0.5), min(4,2), min(0.25,8)]
#                       = [1, 0.5, 2, 0.25]
# Reference: per-lane conditional min.
# ============================================================================

describe "FixedVec<f32,4> cross-target equivalence — min":
    """
    CT-05: min — element-wise minimum, finite inputs only.
    """

    it "CT-05: min matches scalar reference for all four lanes":
        val va = make_va()
        val vb = make_vb()
        val result = va.min(vb)
        val got = result.to_array()
        # Scalar reference: min(1,3)=1, min(2,0.5)=0.5, min(4,2)=2, min(0.25,8)=0.25
        expect(got[0]).to_equal(1.0)
        expect(got[1]).to_equal(0.5)
        expect(got[2]).to_equal(2.0)
        expect(got[3]).to_equal(0.25)


# ============================================================================
# CT-06: abs
# c=[0.25, 1.0, -3.5, 2.0] abs = [0.25, 1.0, 3.5, 2.0]
# Reference: scalar absolute value per lane.
# ============================================================================

describe "FixedVec<f32,4> cross-target equivalence — abs":
    """
    CT-06: abs — element-wise absolute value matches scalar reference.
    """

    it "CT-06: abs matches scalar reference for all four lanes":
        val vc = make_vc()
        val result = vc.abs()
        val got = result.to_array()
        expect(got[0]).to_equal(0.25)
        expect(got[1]).to_equal(1.0)
        expect(got[2]).to_equal(3.5)
        expect(got[3]).to_equal(2.0)


# ============================================================================
# CT-07: reduce_min
# input a=[1.0, 2.0, 4.0, 0.25] — minimum lane is 0.25
# Reference: scalar min across all lanes.
# ============================================================================

describe "FixedVec<f32,4> cross-target equivalence — reduce_min":
    """
    CT-07: reduce_min — horizontal minimum matches scalar reference.
    Input: a=[1.0, 2.0, 4.0, 0.25]. Scalar min = 0.25.
    """

    it "CT-07: reduce_min matches scalar reference minimum":
        val va = make_va()
        val result = va.reduce_min()
        expect(result).to_equal(0.25)


# ============================================================================
# CT-08: sub
# a=[1,2,4,0.25] - b=[3,0.5,2,8] = [-2, 1.5, 2, -7.75]
# All differences are exact f32.
# Reference: scalar subtraction per lane.
# ============================================================================

describe "FixedVec<f32,4> cross-target equivalence — sub":
    """
    CT-08: sub — element-wise subtraction.
    """

    it "CT-08: sub matches scalar reference for all four lanes":
        val va = make_va()
        val vb = make_vb()
        val result = va.sub(vb)
        val got = result.to_array()
        # Scalar reference: 1-3=-2, 2-0.5=1.5, 4-2=2, 0.25-8=-7.75
        expect(got[0]).to_equal(-2.0)
        expect(got[1]).to_equal(1.5)
        expect(got[2]).to_equal(2.0)
        expect(got[3]).to_equal(-7.75)


# ============================================================================
# CT-09: neg
# a=[1,2,4,0.25] neg = [-1, -2, -4, -0.25]
# neg flips the IEEE 754 sign bit; exact for all finite values.
# Reference: scalar unary negation per lane.
# ============================================================================

describe "FixedVec<f32,4> cross-target equivalence — neg":
    """
    CT-09: neg — element-wise sign flip.
    """

    it "CT-09: neg matches scalar reference for all four lanes":
        val va = make_va()
        val result = va.neg()
        val got = result.to_array()
        # Scalar reference: -1, -2, -4, -0.25
        expect(got[0]).to_equal(-1.0)
        expect(got[1]).to_equal(-2.0)
        expect(got[2]).to_equal(-4.0)
        expect(got[3]).to_equal(-0.25)
