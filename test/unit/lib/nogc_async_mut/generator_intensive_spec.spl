"""
# Generator Intensive Tests

**Feature IDs:** #RT-020
**Category:** Runtime
**Difficulty:** 2/5
**Status:** In Progress
**Requirements:** doc/requirement/async_promise_intensive_tests.md

## Overview
Intensive tests for generator patterns: yield/next iteration, stateful generators,
finite and infinite (bounded) generators, and GeneratorState transitions.
"""

# ─── GeneratorState ───────────────────────────────────────────

enum GeneratorState:
    Yielded(value: i64)
    Completed

impl GeneratorState:
    fn is_yielded() -> bool:
        if val GeneratorState.Yielded(_) = self:
            return true
        return false

    fn is_completed() -> bool:
        if val GeneratorState.Completed = self:
            return true
        return false

    fn get_value() -> i64:
        if val GeneratorState.Yielded(v) = self:
            return v
        return 0

# ─── CountingGenerator ───────────────────────────────────────

class CountingGenerator:
    current: i64
    limit: i64
    done: bool

    static fn new(start: i64, limit: i64) -> CountingGenerator:
        return CountingGenerator(current: start, limit: limit, done: false)

    me next() -> GeneratorState:
        if self.done:
            return GeneratorState.Completed
        self.current = self.current + 1
        if self.current >= self.limit:
            self.done = true
        return GeneratorState.Yielded(value: self.current)

    fn is_complete() -> bool:
        return self.done

fn collect_counting(cg: CountingGenerator, max_items: i64) -> [i64]:
    var results: [i64] = []
    var count = 0
    while count < max_items and not cg.is_complete():
        var state = cg.next()
        if val GeneratorState.Yielded(v) = state:
            results = results + [v]
        count = count + 1
    return results

# ─── Fibonacci Generator ─────────────────────────────────────

class FibGenerator:
    prev: i64
    curr: i64
    remaining: i64

    static fn new(count: i64) -> FibGenerator:
        return FibGenerator(prev: 0, curr: 1, remaining: count)

    me next() -> GeneratorState:
        if self.remaining <= 0:
            return GeneratorState.Completed
        var value = self.curr
        var next_curr = self.prev + self.curr
        self.prev = self.curr
        self.curr = next_curr
        self.remaining = self.remaining - 1
        return GeneratorState.Yielded(value: value)

    fn is_complete() -> bool:
        return self.remaining <= 0

fn collect_fib(fg: FibGenerator, max_items: i64) -> [i64]:
    var results: [i64] = []
    var count = 0
    while count < max_items and not fg.is_complete():
        var state = fg.next()
        if val GeneratorState.Yielded(v) = state:
            results = results + [v]
        count = count + 1
    return results

# ─── RangeGenerator ──────────────────────────────────────────

class RangeGenerator:
    current: i64
    end_val: i64
    done: bool

    static fn new(start: i64, end_val: i64) -> RangeGenerator:
        return RangeGenerator(current: start - 1, end_val: end_val, done: false)

    me next() -> GeneratorState:
        if self.done:
            return GeneratorState.Completed
        self.current = self.current + 1
        if self.current >= self.end_val - 1:
            self.done = true
        return GeneratorState.Yielded(value: self.current)

    fn is_complete() -> bool:
        return self.done

fn collect_range(rg: RangeGenerator, max_items: i64) -> [i64]:
    var results: [i64] = []
    var count = 0
    while count < max_items and not rg.is_complete():
        var state = rg.next()
        if val GeneratorState.Yielded(v) = state:
            results = results + [v]
        count = count + 1
    return results

# ─── SingleValueGenerator ────────────────────────────────────

class SingleValueGenerator:
    val_data: i64
    done: bool

    static fn new(value: i64) -> SingleValueGenerator:
        return SingleValueGenerator(val_data: value, done: false)

    me next() -> GeneratorState:
        if self.done:
            return GeneratorState.Completed
        self.done = true
        return GeneratorState.Yielded(value: self.val_data)

    fn is_complete() -> bool:
        return self.done

fn collect_single(sg: SingleValueGenerator, max_items: i64) -> [i64]:
    var results: [i64] = []
    var count = 0
    while count < max_items and not sg.is_complete():
        var state = sg.next()
        if val GeneratorState.Yielded(v) = state:
            results = results + [v]
        count = count + 1
    return results

# ─── EmptyGenerator ──────────────────────────────────────────

class EmptyGenerator:
    done: bool

    static fn new() -> EmptyGenerator:
        return EmptyGenerator(done: true)

    fn next() -> GeneratorState:
        return GeneratorState.Completed

    fn is_complete() -> bool:
        return true

# ─── StepGenerator ───────────────────────────────────────────

class StepGenerator:
    current: i64
    step: i64
    limit: i64
    done: bool

    static fn new(start: i64, step: i64, limit: i64) -> StepGenerator:
        return StepGenerator(current: start, step: step, limit: limit, done: false)

    me next() -> GeneratorState:
        if self.done:
            return GeneratorState.Completed
        self.current = self.current + self.step
        if self.current >= self.limit:
            self.done = true
        return GeneratorState.Yielded(value: self.current)

    fn is_complete() -> bool:
        return self.done

fn collect_step(sg: StepGenerator, max_items: i64) -> [i64]:
    var results: [i64] = []
    var count = 0
    while count < max_items and not sg.is_complete():
        var state = sg.next()
        if val GeneratorState.Yielded(v) = state:
            results = results + [v]
        count = count + 1
    return results

# ─── DoublingGenerator (replaces TransformGenerator) ─────────

class DoublingGenerator:
    source: CountingGenerator

    static fn new(source: CountingGenerator) -> DoublingGenerator:
        return DoublingGenerator(source: source)

    me next() -> GeneratorState:
        var state = self.source.next()
        if val GeneratorState.Yielded(v) = state:
            return GeneratorState.Yielded(value: v * 2)
        return GeneratorState.Completed

    fn is_complete() -> bool:
        return self.source.is_complete()

fn collect_doubling(dg: DoublingGenerator, max_items: i64) -> [i64]:
    var results: [i64] = []
    var count = 0
    while count < max_items and not dg.is_complete():
        var state = dg.next()
        if val GeneratorState.Yielded(v) = state:
            results = results + [v]
        count = count + 1
    return results

# ─── IdentityGenerator (identity transform) ──────────────────

class IdentityGenerator:
    source: CountingGenerator

    static fn new(source: CountingGenerator) -> IdentityGenerator:
        return IdentityGenerator(source: source)

    me next() -> GeneratorState:
        var state = self.source.next()
        if val GeneratorState.Yielded(v) = state:
            return GeneratorState.Yielded(value: v)
        return GeneratorState.Completed

    fn is_complete() -> bool:
        return self.source.is_complete()

fn collect_identity(ig: IdentityGenerator, max_items: i64) -> [i64]:
    var results: [i64] = []
    var count = 0
    while count < max_items and not ig.is_complete():
        var state = ig.next()
        if val GeneratorState.Yielded(v) = state:
            results = results + [v]
        count = count + 1
    return results

# ─── EvenFilterGenerator (replaces FilterGenerator) ──────────

class EvenFilterGenerator:
    source: CountingGenerator

    static fn new(source: CountingGenerator) -> EvenFilterGenerator:
        return EvenFilterGenerator(source: source)

    me next() -> GeneratorState:
        while not self.source.is_complete():
            var state = self.source.next()
            if val GeneratorState.Yielded(v) = state:
                if v % 2 == 0:
                    return GeneratorState.Yielded(value: v)
        return GeneratorState.Completed

    fn is_complete() -> bool:
        return self.source.is_complete()

fn collect_even_filter(ef: EvenFilterGenerator, max_items: i64) -> [i64]:
    var results: [i64] = []
    var count = 0
    while count < max_items and not ef.is_complete():
        var state = ef.next()
        if val GeneratorState.Yielded(v) = state:
            results = results + [v]
        count = count + 1
    return results

# ─── PassAllFilterGenerator (keeps all values) ───────────────

class PassAllFilterGenerator:
    source: CountingGenerator

    static fn new(source: CountingGenerator) -> PassAllFilterGenerator:
        return PassAllFilterGenerator(source: source)

    me next() -> GeneratorState:
        var state = self.source.next()
        if val GeneratorState.Yielded(v) = state:
            return GeneratorState.Yielded(value: v)
        return GeneratorState.Completed

    fn is_complete() -> bool:
        return self.source.is_complete()

fn collect_pass_all(pf: PassAllFilterGenerator, max_items: i64) -> [i64]:
    var results: [i64] = []
    var count = 0
    while count < max_items and not pf.is_complete():
        var state = pf.next()
        if val GeneratorState.Yielded(v) = state:
            results = results + [v]
        count = count + 1
    return results

# ===========================================================================
# Tests
# ===========================================================================

describe "Generator Creation":

    it "creates a generator with initial state":
        var g =CountingGenerator.new(0, 5)
        expect(g.is_complete()).to_equal(false)
        expect(g.done).to_equal(false)

    it "new generator has correct initial current value":
        var g =CountingGenerator.new(42, 100)
        expect(g.current).to_equal(42)
        expect(g.done).to_equal(false)

describe "Generator Next":

    it "first next yields a value":
        var g =CountingGenerator.new(0, 5)
        var state = g.next()
        expect(state.is_yielded()).to_equal(true)
        expect(state.get_value()).to_equal(1)

    it "subsequent nexts yield incremented values":
        var g =CountingGenerator.new(0, 10)
        var s1 = g.next()
        var s2 = g.next()
        var s3 = g.next()
        expect(s1.get_value()).to_equal(1)
        expect(s2.get_value()).to_equal(2)
        expect(s3.get_value()).to_equal(3)

describe "Counting Generator":

    it "counts from 1 up to N then completes":
        var g =CountingGenerator.new(0, 4)
        var vals = collect_counting(g, 100)
        expect(vals.len()).to_equal(4)
        expect(vals[0]).to_equal(1)
        expect(vals[1]).to_equal(2)
        expect(vals[2]).to_equal(3)
        expect(vals[3]).to_equal(4)

    it "is_complete returns true after exhaustion":
        var g =CountingGenerator.new(0, 2)
        var v1 = g.next()
        var v2 = g.next()
        expect(g.is_complete()).to_equal(true)

describe "Fibonacci Generator":

    it "yields fibonacci sequence":
        var fib = FibGenerator.new(7)
        var vals = collect_fib(fib, 100)
        expect(vals.len()).to_equal(7)
        expect(vals[0]).to_equal(1)
        expect(vals[1]).to_equal(1)
        expect(vals[2]).to_equal(2)
        expect(vals[3]).to_equal(3)
        expect(vals[4]).to_equal(5)
        expect(vals[5]).to_equal(8)
        expect(vals[6]).to_equal(13)

    it "fibonacci generator completes after requested count":
        var fib = FibGenerator.new(3)
        var v1 = fib.next()
        var v2 = fib.next()
        var v3 = fib.next()
        expect(fib.is_complete()).to_equal(true)
        var v4 = fib.next()
        expect(v4.is_completed()).to_equal(true)

describe "Range Generator":

    it "yields values in range [start, end)":
        var g =RangeGenerator.new(3, 7)
        var vals = collect_range(g, 100)
        expect(vals.len()).to_equal(4)
        expect(vals[0]).to_equal(3)
        expect(vals[1]).to_equal(4)
        expect(vals[2]).to_equal(5)
        expect(vals[3]).to_equal(6)

describe "Single Value Generator":

    it "yields one value then completes":
        var g =SingleValueGenerator.new(99)
        var state = g.next()
        expect(state.is_yielded()).to_equal(true)
        expect(state.get_value()).to_equal(99)
        expect(g.is_complete()).to_equal(true)

    it "next after single value returns Completed":
        var g =SingleValueGenerator.new(42)
        var s1 = g.next()
        var s2 = g.next()
        expect(s1.is_yielded()).to_equal(true)
        expect(s2.is_completed()).to_equal(true)

describe "Empty Generator":

    it "is immediately complete":
        var g =EmptyGenerator.new()
        expect(g.is_complete()).to_equal(true)

    it "next on empty generator returns Completed":
        var g =EmptyGenerator.new()
        var state = g.next()
        expect(state.is_completed()).to_equal(true)

describe "GeneratorState":

    it "Yielded state has a value":
        var state = GeneratorState.Yielded(value: 10)
        expect(state.is_yielded()).to_equal(true)
        expect(state.get_value()).to_equal(10)

    it "Completed state has no value":
        var state = GeneratorState.Completed
        expect(state.is_completed()).to_equal(true)
        expect(state.get_value()).to_equal(0)

    it "is_yielded returns false for Completed":
        var state = GeneratorState.Completed
        expect(state.is_yielded()).to_equal(false)

    it "is_completed returns false for Yielded":
        var state = GeneratorState.Yielded(value: 5)
        expect(state.is_completed()).to_equal(false)

describe "Collect Helper":

    it "collects all values from generator into list":
        var g =CountingGenerator.new(0, 3)
        var vals = collect_counting(g, 100)
        expect(vals.len()).to_equal(3)
        expect(vals[0]).to_equal(1)
        expect(vals[1]).to_equal(2)
        expect(vals[2]).to_equal(3)

    it "respects max_items limit":
        var g =CountingGenerator.new(0, 100)
        var vals = collect_counting(g, 5)
        expect(vals.len()).to_equal(5)

describe "Generator After Completion":

    it "next after complete returns Completed":
        var g =SingleValueGenerator.new(7)
        var s1 = g.next()
        var s2 = g.next()
        var s3 = g.next()
        expect(s1.is_yielded()).to_equal(true)
        expect(s2.is_completed()).to_equal(true)
        expect(s3.is_completed()).to_equal(true)

    it "calling next many times after completion is safe":
        var g =EmptyGenerator.new()
        var i = 0
        while i < 20:
            var state = g.next()
            expect(state.is_completed()).to_equal(true)
            i = i + 1
        expect(g.is_complete()).to_equal(true)

describe "Transform Generator":

    it "multiplies each yielded value":
        var source = CountingGenerator.new(0, 4)
        var doubled = DoublingGenerator.new(source)
        var vals = collect_doubling(doubled, 100)
        expect(vals.len()).to_equal(4)
        expect(vals[0]).to_equal(2)
        expect(vals[1]).to_equal(4)
        expect(vals[2]).to_equal(6)
        expect(vals[3]).to_equal(8)

    it "applies identity transform preserving values":
        var source = CountingGenerator.new(0, 3)
        var identity = IdentityGenerator.new(source)
        var vals = collect_identity(identity, 100)
        expect(vals[0]).to_equal(1)
        expect(vals[1]).to_equal(2)
        expect(vals[2]).to_equal(3)

describe "Filter Generator":

    it "skips values not matching predicate":
        var source = CountingGenerator.new(0, 10)
        var evens = EvenFilterGenerator.new(source)
        var vals = collect_even_filter(evens, 100)
        # Values 1..10, evens are 2, 4, 6, 8, 10
        expect(vals.len()).to_equal(5)
        expect(vals[0]).to_equal(2)
        expect(vals[1]).to_equal(4)
        expect(vals[2]).to_equal(6)
        expect(vals[3]).to_equal(8)
        expect(vals[4]).to_equal(10)

    it "filter with always-true predicate keeps all values":
        var source = CountingGenerator.new(0, 3)
        var all = PassAllFilterGenerator.new(source)
        var vals = collect_pass_all(all, 100)
        expect(vals.len()).to_equal(3)

describe "Step Generator":

    it "yields values with custom step size":
        var g =StepGenerator.new(0, 5, 20)
        var vals = collect_step(g, 100)
        expect(vals.len()).to_equal(4)
        expect(vals[0]).to_equal(5)
        expect(vals[1]).to_equal(10)
        expect(vals[2]).to_equal(15)
        expect(vals[3]).to_equal(20)
