use std.spec
use std.nogc_async_mut.mcp_sdk.transport.stdio.{set_json_lines_mode, is_json_lines_mode, is_framing_detected, content_length_header}

describe "nogc_async_mut mcp sdk transport facade":

    it "re-exports stdio framing state and content-length helpers":
        set_json_lines_mode(true)
        expect(is_json_lines_mode()).to_equal(true)
        expect(is_framing_detected()).to_equal(true)
        set_json_lines_mode(false)
        expect(is_json_lines_mode()).to_equal(false)
        expect(content_length_header("{}")).to_equal("Content-Length: 2\r\n\r\n")
