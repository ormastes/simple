"""
# Channel Intensive Tests

**Feature IDs:** #RT-020
**Category:** Runtime
**Difficulty:** 2/5
**Status:** In Progress
**Requirements:** doc/requirement/async_promise_intensive_tests.md

## Overview
Intensive tests for channel-based message passing: unbounded and bounded channels,
send/recv/try_recv, close semantics, and multi-producer patterns.
"""

class Channel:
    buffer: [i64]
    capacity: i64  # 0 = unbounded
    closed: bool
    count: i64  # manual length tracker to avoid .len() corruption bug

    static fn unbounded() -> Channel:
        Channel(buffer: [], capacity: 0, closed: false, count: 0)

    static fn bounded(cap: i64) -> Channel:
        Channel(buffer: [], capacity: cap, closed: false, count: 0)

    me send(value: i64) -> bool:
        if self.closed:
            return false
        if self.capacity > 0 and self.count >= self.capacity:
            return false  # full
        self.buffer = self.buffer + [value]
        self.count = self.count + 1
        true

    me try_recv() -> i64:  # returns -1 as sentinel for empty
        if self.count == 0:
            return -1
        val value = self.buffer[0]
        # Remove first element using slice
        self.buffer = self.buffer[1:]
        self.count = self.count - 1
        value

    me close():
        self.closed = true

    fn is_closed() -> bool:
        self.closed

    fn len() -> i64:
        self.count

    fn is_empty() -> bool:
        self.count == 0

    fn is_full() -> bool:
        if self.capacity == 0:
            return false
        self.count >= self.capacity


describe "Unbounded Channel Basics":
    it "creates an empty unbounded channel":
        var ch = Channel.unbounded()
        expect(ch.is_empty()).to_equal(true)
        expect(ch.len()).to_equal(0)
        expect(ch.is_closed()).to_equal(false)
        expect(ch.capacity).to_equal(0)

    it "sends and receives a single message":
        var ch = Channel.unbounded()
        val sent = ch.send(42)
        expect(sent).to_equal(true)
        expect(ch.len()).to_equal(1)
        val received = ch.try_recv()
        expect(received).to_equal(42)
        expect(ch.is_empty()).to_equal(true)

    it "maintains FIFO order for multiple messages":
        var ch = Channel.unbounded()
        ch.send(1)
        ch.send(2)
        ch.send(3)
        expect(ch.try_recv()).to_equal(1)
        expect(ch.try_recv()).to_equal(2)
        expect(ch.try_recv()).to_equal(3)
        expect(ch.is_empty()).to_equal(true)

    it "handles interleaved send and recv":
        var ch = Channel.unbounded()
        ch.send(10)
        ch.send(20)
        expect(ch.try_recv()).to_equal(10)
        ch.send(30)
        expect(ch.try_recv()).to_equal(20)
        expect(ch.try_recv()).to_equal(30)
        expect(ch.is_empty()).to_equal(true)


describe "Bounded Channel Basics":
    it "creates a bounded channel with given capacity":
        var ch = Channel.bounded(3)
        expect(ch.capacity).to_equal(3)
        expect(ch.is_empty()).to_equal(true)
        expect(ch.is_full()).to_equal(false)
        val sent = ch.send(1)
        expect(sent).to_equal(true)
        expect(ch.len()).to_equal(1)

    it "rejects send when bounded channel is full":
        var ch = Channel.bounded(2)
        expect(ch.send(1)).to_equal(true)
        expect(ch.send(2)).to_equal(true)
        expect(ch.is_full()).to_equal(true)
        # Third send should fail
        expect(ch.send(3)).to_equal(false)
        expect(ch.len()).to_equal(2)
        # Recv frees space, then send succeeds
        val v = ch.try_recv()
        expect(v).to_equal(1)
        expect(ch.is_full()).to_equal(false)
        expect(ch.send(3)).to_equal(true)
        expect(ch.len()).to_equal(2)

    it "handles capacity-1 single slot channel":
        var ch = Channel.bounded(1)
        expect(ch.send(100)).to_equal(true)
        expect(ch.is_full()).to_equal(true)
        expect(ch.send(200)).to_equal(false)
        expect(ch.try_recv()).to_equal(100)
        expect(ch.is_empty()).to_equal(true)
        expect(ch.send(200)).to_equal(true)
        expect(ch.try_recv()).to_equal(200)


describe "Channel Close Semantics":
    it "prevents new sends after close but drains existing messages":
        var ch = Channel.unbounded()
        ch.send(1)
        ch.send(2)
        ch.close()
        expect(ch.is_closed()).to_equal(true)
        # Send after close should fail
        expect(ch.send(3)).to_equal(false)
        # Existing messages still receivable
        expect(ch.try_recv()).to_equal(1)
        expect(ch.try_recv()).to_equal(2)
        expect(ch.is_empty()).to_equal(true)

    it "returns sentinel on recv from closed empty channel":
        var ch = Channel.unbounded()
        ch.close()
        expect(ch.try_recv()).to_equal(-1)
        expect(ch.is_closed()).to_equal(true)
        expect(ch.is_empty()).to_equal(true)


describe "Channel try_recv":
    it "returns sentinel when channel is empty":
        var ch = Channel.unbounded()
        expect(ch.try_recv()).to_equal(-1)
        # Still empty after failed recv
        expect(ch.is_empty()).to_equal(true)
        expect(ch.len()).to_equal(0)


describe "Channel Drain":
    it "sends many messages and recvs all in correct FIFO order":
        var ch = Channel.unbounded()
        ch.send(0)
        ch.send(10)
        ch.send(20)
        ch.send(30)
        ch.send(40)
        expect(ch.len()).to_equal(5)
        # Drain and verify order
        expect(ch.try_recv()).to_equal(0)
        expect(ch.try_recv()).to_equal(10)
        expect(ch.try_recv()).to_equal(20)
        expect(ch.try_recv()).to_equal(30)
        expect(ch.try_recv()).to_equal(40)
        expect(ch.is_empty()).to_equal(true)
        expect(ch.try_recv()).to_equal(-1)


describe "Channel State Checks":
    it "reports correct state through lifecycle":
        var ch = Channel.bounded(3)
        # Initially empty, not full, not closed
        expect(ch.is_empty()).to_equal(true)
        expect(ch.is_full()).to_equal(false)
        expect(ch.is_closed()).to_equal(false)
        expect(ch.len()).to_equal(0)
        # Fill partially
        ch.send(1)
        expect(ch.is_empty()).to_equal(false)
        expect(ch.is_full()).to_equal(false)
        expect(ch.len()).to_equal(1)
        # Fill completely
        ch.send(2)
        ch.send(3)
        expect(ch.is_full()).to_equal(true)
        expect(ch.len()).to_equal(3)
        # Drain one
        ch.try_recv()
        expect(ch.is_full()).to_equal(false)
        expect(ch.len()).to_equal(2)
        # Close
        ch.close()
        expect(ch.is_closed()).to_equal(true)
        # Remaining messages still accessible
        expect(ch.len()).to_equal(2)


describe "Channel Edge Cases":
    it "sends and receives zero":
        var ch = Channel.unbounded()
        ch.send(0)
        expect(ch.len()).to_equal(1)
        expect(ch.try_recv()).to_equal(0)

    it "sends and receives negative values":
        var ch = Channel.unbounded()
        ch.send(-42)
        ch.send(-100)
        expect(ch.try_recv()).to_equal(-42)
        expect(ch.try_recv()).to_equal(-100)

    it "recv from closed channel with data returns data then sentinel":
        var ch = Channel.unbounded()
        ch.send(5)
        ch.send(10)
        ch.close()
        expect(ch.try_recv()).to_equal(5)
        expect(ch.try_recv()).to_equal(10)
        expect(ch.try_recv()).to_equal(-1)


describe "Multi-Producer Pattern":
    it "simulates multiple producers filling a shared channel":
        var ch = Channel.unbounded()
        # Producer A sends values 1..3
        ch.send(1)
        ch.send(2)
        ch.send(3)
        # Producer B sends values 100..102
        ch.send(100)
        ch.send(101)
        ch.send(102)
        expect(ch.len()).to_equal(6)
        # Verify A's messages come first (FIFO within each producer batch)
        expect(ch.try_recv()).to_equal(1)
        expect(ch.try_recv()).to_equal(2)
        expect(ch.try_recv()).to_equal(3)
        # Then B's messages
        expect(ch.try_recv()).to_equal(100)
        expect(ch.try_recv()).to_equal(101)
        expect(ch.try_recv()).to_equal(102)
        expect(ch.is_empty()).to_equal(true)


describe "Large Buffer":
    it "sends 5 items and recvs all in order":
        var ch = Channel.unbounded()
        ch.send(0)
        ch.send(1)
        ch.send(2)
        ch.send(3)
        ch.send(4)
        expect(ch.len()).to_equal(5)
        expect(ch.is_full()).to_equal(false)  # unbounded never full
        expect(ch.try_recv()).to_equal(0)
        expect(ch.try_recv()).to_equal(1)
        expect(ch.try_recv()).to_equal(2)
        expect(ch.try_recv()).to_equal(3)
        expect(ch.try_recv()).to_equal(4)
        expect(ch.is_empty()).to_equal(true)
        expect(ch.try_recv()).to_equal(-1)
