"""
# Executor & Scheduler Intensive Tests

**Feature IDs:** #RT-020
**Category:** Runtime
**Difficulty:** 3/5
**Status:** In Progress
**Requirements:** doc/requirement/async_promise_intensive_tests.md

## Overview
Intensive tests for the single-threaded Executor, priority-based Scheduler,
Task lifecycle, and Runtime global functions.
"""

# ─── Task States ───────────────────────────────────────────────

enum TaskState:
    Pending
    Running
    Completed
    Failed

# ─── Task ──────────────────────────────────────────────────────

class Task:
    id: i64
    priority: i64
    state: TaskState
    result: i64
    poll_fn: fn() -> i64

    static fn new(poll_fn: fn() -> i64) -> Task:
        var tid = next_task_id()
        return Task(id: tid, priority: 0, state: TaskState.Pending, result: 0, poll_fn: poll_fn)

    static fn with_priority(poll_fn: fn() -> i64, priority: i64) -> Task:
        var tid = next_task_id()
        return Task(id: tid, priority: priority, state: TaskState.Pending, result: 0, poll_fn: poll_fn)

    fn is_complete() -> bool:
        return self.state == TaskState.Completed

    fn is_failed() -> bool:
        return self.state == TaskState.Failed

    me execute():
        self.state = TaskState.Running
        var poll = self.poll_fn
        var res = poll()
        if res < 0:
            self.state = TaskState.Failed
            self.result = res
        else:
            self.state = TaskState.Completed
            self.result = res

# ─── Executor ──────────────────────────────────────────────────

class Executor:
    tasks: [Task]
    completed_count: i64
    running: bool

    static fn new() -> Executor:
        return Executor(tasks: [], completed_count: 0, running: false)

    me spawn(task: Task):
        self.tasks.push(task)

    me run():
        self.running = true
        var i = 0
        var count = self.tasks.length()
        while i < count:
            var t = self.tasks[i]
            if t.state == TaskState.Pending:
                t.execute()
                if t.is_complete():
                    self.completed_count = self.completed_count + 1
            i = i + 1
        self.running = false

    me run_one() -> bool:
        var i = 0
        var count = self.tasks.length()
        while i < count:
            var t = self.tasks[i]
            if t.state == TaskState.Pending:
                t.execute()
                if t.is_complete():
                    self.completed_count = self.completed_count + 1
                return true
            i = i + 1
        return false

    fn task_count() -> i64:
        return self.tasks.length()

    fn completed_count() -> i64:
        return self.completed_count

    fn is_idle() -> bool:
        return self.tasks.length() == 0

    me block_on(poll_fn: fn() -> i64) -> i64:
        var task = Task.new(poll_fn)
        self.spawn(task)
        self.run()
        return task.result

# ─── Scheduler ─────────────────────────────────────────────────

class Scheduler:
    high: [Task]
    normal: [Task]
    low: [Task]
    executor: Executor
    run_order: [i64]

    static fn new() -> Scheduler:
        return Scheduler(high: [], normal: [], low: [], executor: Executor.new(), run_order: [])

    me schedule(task: Task):
        if task.priority > 0:
            self.high.push(task)
        else if task.priority < 0:
            self.low.push(task)
        else:
            self.normal.push(task)

    me run():
        # Run high priority first
        var i = 0
        var count = self.high.length()
        while i < count:
            var t = self.high[i]
            if t.state == TaskState.Pending:
                t.execute()
                self.run_order.push(t.id)
            i = i + 1

        # Then normal priority
        i = 0
        count = self.normal.length()
        while i < count:
            var t = self.normal[i]
            if t.state == TaskState.Pending:
                t.execute()
                self.run_order.push(t.id)
            i = i + 1

        # Then low priority
        i = 0
        count = self.low.length()
        while i < count:
            var t = self.low[i]
            if t.state == TaskState.Pending:
                t.execute()
                self.run_order.push(t.id)
            i = i + 1

    fn has_runnable() -> bool:
        var i = 0
        var count = self.high.length()
        while i < count:
            if self.high[i].state == TaskState.Pending:
                return true
            i = i + 1
        i = 0
        count = self.normal.length()
        while i < count:
            if self.normal[i].state == TaskState.Pending:
                return true
            i = i + 1
        i = 0
        count = self.low.length()
        while i < count:
            if self.low[i].state == TaskState.Pending:
                return true
            i = i + 1
        return false

    fn total_tasks() -> i64:
        return self.high.length() + self.normal.length() + self.low.length()

# ─── Global Runtime ────────────────────────────────────────────

var global_task_id: i64 = 0

fn next_task_id() -> i64:
    global_task_id = global_task_id + 1
    return global_task_id

var global_executor: Executor = Executor.new()

fn runtime_spawn(poll_fn: fn() -> i64):
    var task = Task.new(poll_fn)
    global_executor.spawn(task)

fn runtime_run():
    global_executor.run()

# ─── Helper poll functions ─────────────────────────────────────

fn poll_returns_42() -> i64:
    return 42

fn poll_returns_100() -> i64:
    return 100

fn poll_returns_7() -> i64:
    return 7

fn poll_returns_0() -> i64:
    return 0

fn poll_returns_negative() -> i64:
    return -1

fn poll_adds_10_20() -> i64:
    return 10 + 20

fn poll_multiplies_6_7() -> i64:
    return 6 * 7

fn poll_returns_1() -> i64:
    return 1

fn poll_returns_99() -> i64:
    return 99

fn poll_returns_5() -> i64:
    return 5

fn poll_returns_200() -> i64:
    return 200

fn poll_returns_300() -> i64:
    return 300

# ═══════════════════════════════════════════════════════════════
# TESTS
# ═══════════════════════════════════════════════════════════════

describe "Task Creation":
    it "creates a task with default priority 0":
        var task = Task.new(poll_returns_42)
        expect(task.priority).to_equal(0)

    it "creates a task in Pending state":
        var task = Task.new(poll_returns_42)
        expect(task.state == TaskState.Pending).to_equal(true)

    it "creates a task with specified priority":
        var task = Task.with_priority(poll_returns_42, 5)
        expect(task.priority).to_equal(5)

    it "assigns unique IDs to each task":
        var id_before = global_task_id
        var t1 = Task.new(poll_returns_42)
        var t2 = Task.new(poll_returns_100)
        expect(t2.id > t1.id).to_equal(true)

describe "Task State Transitions":
    it "transitions from Pending to Completed on successful execute":
        var task = Task.new(poll_returns_42)
        expect(task.state == TaskState.Pending).to_equal(true)
        task.execute()
        expect(task.state == TaskState.Completed).to_equal(true)

    it "stores the result after execution":
        var task = Task.new(poll_returns_42)
        task.execute()
        expect(task.result).to_equal(42)

    it "transitions to Failed when poll returns negative":
        var task = Task.new(poll_returns_negative)
        task.execute()
        expect(task.state == TaskState.Failed).to_equal(true)

    it "reports is_complete correctly":
        var task = Task.new(poll_returns_100)
        expect(task.is_complete()).to_equal(false)
        task.execute()
        expect(task.is_complete()).to_equal(true)

    it "reports is_failed correctly":
        var task = Task.new(poll_returns_negative)
        expect(task.is_failed()).to_equal(false)
        task.execute()
        expect(task.is_failed()).to_equal(true)

describe "Executor Basics":
    it "creates an empty executor":
        var exec = Executor.new()
        expect(exec.task_count()).to_equal(0)

    it "is idle when no tasks are spawned":
        var exec = Executor.new()
        expect(exec.is_idle()).to_equal(true)

    it "tracks task count after spawn":
        var exec = Executor.new()
        var t1 = Task.new(poll_returns_42)
        exec.spawn(t1)
        expect(exec.task_count()).to_equal(1)

    it "is not idle after spawning a task":
        var exec = Executor.new()
        exec.spawn(Task.new(poll_returns_42))
        expect(exec.is_idle()).to_equal(false)

describe "Executor Run":
    it "runs with no tasks without error":
        var exec = Executor.new()
        exec.run()
        expect(exec.completed_count()).to_equal(0)

    it "executes a single task to completion":
        var exec = Executor.new()
        var task = Task.new(poll_returns_42)
        exec.spawn(task)
        exec.run()
        expect(task.is_complete()).to_equal(true)
        expect(task.result).to_equal(42)

    it "executes multiple tasks and completes all":
        var exec = Executor.new()
        var t1 = Task.new(poll_returns_42)
        var t2 = Task.new(poll_returns_100)
        var t3 = Task.new(poll_returns_7)
        exec.spawn(t1)
        exec.spawn(t2)
        exec.spawn(t3)
        exec.run()
        expect(exec.completed_count()).to_equal(3)

    it "tracks completed count correctly":
        var exec = Executor.new()
        exec.spawn(Task.new(poll_returns_42))
        exec.spawn(Task.new(poll_returns_100))
        exec.run()
        expect(exec.completed_count()).to_equal(2)

describe "Executor Run One":
    it "returns false when no tasks exist":
        var exec = Executor.new()
        var found = exec.run_one()
        expect(found).to_equal(false)

    it "processes exactly one pending task":
        var exec = Executor.new()
        var t1 = Task.new(poll_returns_42)
        var t2 = Task.new(poll_returns_100)
        exec.spawn(t1)
        exec.spawn(t2)
        var found = exec.run_one()
        expect(found).to_equal(true)
        expect(t1.is_complete()).to_equal(true)
        expect(t2.state == TaskState.Pending).to_equal(true)

    it "returns false after all tasks are completed":
        var exec = Executor.new()
        exec.spawn(Task.new(poll_returns_42))
        exec.run()
        var found = exec.run_one()
        expect(found).to_equal(false)

describe "Executor Block On":
    it "blocks and returns the task result":
        var exec = Executor.new()
        var result = exec.block_on(poll_returns_42)
        expect(result).to_equal(42)

    it "blocks on a computation and returns correct value":
        var exec = Executor.new()
        var result = exec.block_on(poll_adds_10_20)
        expect(result).to_equal(30)

describe "Scheduler Priority":
    it "runs high priority tasks before normal":
        var sched = Scheduler.new()
        var high_task = Task.with_priority(poll_returns_1, 1)
        var normal_task = Task.with_priority(poll_returns_99, 0)
        sched.schedule(high_task)
        sched.schedule(normal_task)
        sched.run()
        # high_task id should appear before normal_task id in run_order
        expect(sched.run_order[0]).to_equal(high_task.id)
        expect(sched.run_order[1]).to_equal(normal_task.id)

    it "runs normal priority tasks before low":
        var sched = Scheduler.new()
        var normal_task = Task.with_priority(poll_returns_5, 0)
        var low_task = Task.with_priority(poll_returns_1, -1)
        sched.schedule(normal_task)
        sched.schedule(low_task)
        sched.run()
        expect(sched.run_order[0]).to_equal(normal_task.id)
        expect(sched.run_order[1]).to_equal(low_task.id)

    it "runs all three priority levels in correct order":
        var sched = Scheduler.new()
        var low_task = Task.with_priority(poll_returns_1, -1)
        var high_task = Task.with_priority(poll_returns_200, 2)
        var normal_task = Task.with_priority(poll_returns_5, 0)
        # Schedule in reverse order to prove ordering works
        sched.schedule(low_task)
        sched.schedule(normal_task)
        sched.schedule(high_task)
        sched.run()
        expect(sched.run_order[0]).to_equal(high_task.id)
        expect(sched.run_order[1]).to_equal(normal_task.id)
        expect(sched.run_order[2]).to_equal(low_task.id)

describe "Scheduler Mixed":
    it "handles multiple tasks at each priority level":
        var sched = Scheduler.new()
        var h1 = Task.with_priority(poll_returns_1, 1)
        var h2 = Task.with_priority(poll_returns_5, 3)
        var n1 = Task.with_priority(poll_returns_42, 0)
        var l1 = Task.with_priority(poll_returns_7, -1)
        var l2 = Task.with_priority(poll_returns_99, -2)
        sched.schedule(l1)
        sched.schedule(h1)
        sched.schedule(n1)
        sched.schedule(l2)
        sched.schedule(h2)
        sched.run()
        # All 5 tasks should have run
        expect(sched.run_order.length()).to_equal(5)
        # First two should be h1 and h2 (high priority)
        expect(sched.run_order[0]).to_equal(h1.id)
        expect(sched.run_order[1]).to_equal(h2.id)

    it "completes all scheduled tasks eventually":
        var sched = Scheduler.new()
        sched.schedule(Task.with_priority(poll_returns_42, 1))
        sched.schedule(Task.with_priority(poll_returns_100, 0))
        sched.schedule(Task.with_priority(poll_returns_7, -1))
        sched.run()
        expect(sched.has_runnable()).to_equal(false)

describe "Scheduler Empty":
    it "runs on empty scheduler without error":
        var sched = Scheduler.new()
        sched.run()
        expect(sched.total_tasks()).to_equal(0)

    it "has no runnable tasks when empty":
        var sched = Scheduler.new()
        expect(sched.has_runnable()).to_equal(false)

describe "Runtime Global IDs":
    it "increments global task IDs":
        var id1 = next_task_id()
        var id2 = next_task_id()
        expect(id2).to_equal(id1 + 1)

    it "produces unique IDs across tasks":
        var t1 = Task.new(poll_returns_42)
        var t2 = Task.new(poll_returns_100)
        var t3 = Task.new(poll_returns_7)
        expect(t1.id != t2.id).to_equal(true)
        expect(t2.id != t3.id).to_equal(true)
        expect(t1.id != t3.id).to_equal(true)

describe "Edge Cases":
    it "handles zero-result tasks correctly":
        var task = Task.new(poll_returns_0)
        task.execute()
        expect(task.is_complete()).to_equal(true)
        expect(task.result).to_equal(0)

    it "handles negative priority tasks in scheduler":
        var sched = Scheduler.new()
        var task = Task.with_priority(poll_returns_42, -5)
        sched.schedule(task)
        expect(sched.low.length()).to_equal(1)

    it "handles very high priority tasks in scheduler":
        var sched = Scheduler.new()
        var task = Task.with_priority(poll_returns_42, 999)
        sched.schedule(task)
        expect(sched.high.length()).to_equal(1)

    it "executor handles mix of successful and failed tasks":
        var exec = Executor.new()
        var good = Task.new(poll_returns_42)
        var bad = Task.new(poll_returns_negative)
        exec.spawn(good)
        exec.spawn(bad)
        exec.run()
        expect(good.is_complete()).to_equal(true)
        expect(bad.is_failed()).to_equal(true)
        # Only successful tasks count as completed
        expect(exec.completed_count()).to_equal(1)

    it "scheduler total_tasks counts all priorities":
        var sched = Scheduler.new()
        sched.schedule(Task.with_priority(poll_returns_1, 1))
        sched.schedule(Task.with_priority(poll_returns_5, 0))
        sched.schedule(Task.with_priority(poll_returns_7, -1))
        expect(sched.total_tasks()).to_equal(3)

    it "block_on with multiply computation":
        var exec = Executor.new()
        var result = exec.block_on(poll_multiplies_6_7)
        expect(result).to_equal(42)
