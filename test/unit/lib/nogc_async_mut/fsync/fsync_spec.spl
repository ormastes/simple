# @cover src/lib/nogc_async_mut/fsync/fsync.spl

use std.spec
use std.nogc_async_mut.fsync.fsync.{
    fsync_mutex_lock,
    fsync_mutex_unlock
}

describe "fsync mutex/condvar":
    it "lock and unlock on address 0 complete without error":
        val addr: u32 = 0
        fsync_mutex_lock(addr)
        fsync_mutex_unlock(addr)
        expect(1).to_equal(1)

    it "lock and unlock on non-zero address complete without error":
        val addr: u32 = 42
        fsync_mutex_lock(addr)
        fsync_mutex_unlock(addr)
        expect(1).to_equal(1)

    it "multiple lock/unlock pairs on different addresses do not interfere":
        val a: u32 = 1
        val b: u32 = 2
        fsync_mutex_lock(a)
        fsync_mutex_lock(b)
        fsync_mutex_unlock(b)
        fsync_mutex_unlock(a)
        expect(1).to_equal(1)
