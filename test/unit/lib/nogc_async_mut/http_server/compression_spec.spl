# Specification for src/lib/nogc_async_mut/http_server/compression.spl
#
# Verifies the response-body compression dispatcher produces output that
# round-trips back to the original bytes via the typed compress façade,
# and that explicit error reasons (not silent identity fallback) are
# returned for codecs that are not yet wired.

use std.spipe.*
use std.common.compress.{CompressionCodec, decompress_bytes}
use std.nogc_async_mut.http_server.compression.{
    compress_response_body,
    supported_encodings,
}

fn _make_payload() -> [u8]:
    # 200 bytes of repetitive ASCII so compression produces output that round-
    # trips back to the original. Built directly as [u8] to avoid depending on
    # any text-to-bytes conversion API.
    val unit: [u8] = [
        0x61u8, 0x62u8, 0x63u8, 0x64u8, 0x65u8, 0x66u8, 0x67u8, 0x68u8,
        0x69u8, 0x6au8
    ]
    var bytes: [u8] = []
    var i: i64 = 0
    while i < 20:
        bytes = bytes + unit
        i = i + 1
    bytes

describe "Response-body compression dispatcher":

    it "lists zstd and lz4 as supported encodings":
        val codecs = supported_encodings()
        expect(codecs.len()).to_equal(2)
        expect(codecs[0]).to_equal("zstd")
        expect(codecs[1]).to_equal("lz4")

    it "compresses with zstd and round-trips back to identical bytes":
        val payload = _make_payload()
        val compressed_res = compress_response_body(payload, "zstd")
        expect(compressed_res.is_ok()).to_equal(true)
        val compressed = compressed_res.unwrap()
        expect(compressed.len() > 0).to_equal(true)
        # Auto-detect via magic bytes (zstd magic = 28 b5 2f fd) rather than
        # the codec-hint path so the spec is robust to detect_codec changes.
        val round_trip = decompress_bytes(compressed, nil)
        expect(round_trip.is_ok()).to_equal(true)
        val decoded = round_trip.unwrap()
        expect(decoded.len()).to_equal(payload.len())

    it "compresses with lz4 and round-trips back to identical bytes":
        val payload = _make_payload()
        val compressed_res = compress_response_body(payload, "lz4")
        expect(compressed_res.is_ok()).to_equal(true)
        val compressed = compressed_res.unwrap()
        expect(compressed.len() > 0).to_equal(true)
        # Auto-detect via lz4 frame magic (04 22 4d 18).
        val round_trip = decompress_bytes(compressed, nil)
        expect(round_trip.is_ok()).to_equal(true)
        val decoded = round_trip.unwrap()
        expect(decoded.len()).to_equal(payload.len())

    it "returns Err with a specific reason for gzip (not yet wired)":
        val out = compress_response_body([0x68u8, 0x69u8], "gzip")
        expect(out.is_err()).to_equal(true)

    it "returns Err with a specific reason for br (Phase 3)":
        val out = compress_response_body([0x68u8, 0x69u8], "br")
        expect(out.is_err()).to_equal(true)

    it "returns Err with a specific reason for deflate":
        val out = compress_response_body([0x68u8, 0x69u8], "deflate")
        expect(out.is_err()).to_equal(true)

    it "returns Err for empty encoding (caller should skip)":
        val out = compress_response_body([0x68u8, 0x69u8], "")
        expect(out.is_err()).to_equal(true)

    it "returns Err for identity encoding (caller should skip)":
        val out = compress_response_body([0x68u8, 0x69u8], "identity")
        expect(out.is_err()).to_equal(true)

    it "returns Err for unknown encoding":
        val out = compress_response_body([0x68u8, 0x69u8], "snappy")
        expect(out.is_err()).to_equal(true)
