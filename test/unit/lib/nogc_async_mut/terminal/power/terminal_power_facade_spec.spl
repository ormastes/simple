use std.spec
use std.terminal.types.{POWER_STATE_UNKNOWN, make_power_config_relay, make_power_config_host}
use std.nogc_async_mut.terminal.power.relay_power.{relay_power_on}
use std.nogc_async_mut.terminal.power.host_power.{host_power_on, send_wol_packet}

describe "nogc_async_mut terminal power facade":

    it "re-exports hosted-safe relay and host backend entry points":
        val relay = make_power_config_relay("relay", "", "", "", "", "", "", "", "", "", "", "", "", "", "")
        expect(relay_power_on(relay).state).to_equal(POWER_STATE_UNKNOWN)
        val host = make_power_config_host("host", "", 22, "user", "none", "", "", "")
        expect(host_power_on(host).state).to_equal(POWER_STATE_UNKNOWN)
        expect(send_wol_packet("not-a-mac")).to_equal(false)
