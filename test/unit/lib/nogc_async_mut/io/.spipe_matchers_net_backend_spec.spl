use std.spec.*
use std.io.net_backend.{
    portable_net_backend_capabilities,
    accelerated_net_backend_capabilities,
    packet_io_net_backend_capabilities,
    net_backend_acceleration_tier,
    net_backend_can_accelerate_static_files,
    net_backend_summary
}
use std.io.packet_io.{
    packet_io_disabled_capabilities,
    packet_io_opt_in_capabilities,
    packet_rx_lease,
    packet_tx_lease,
    packet_complete,
    packet_io_benchmark_report,
    packet_io_benchmark_line
}

describe "async net backend capabilities":
    it "uses portable defaults for QEMU and hosted CI":
        val caps = portable_net_backend_capabilities()
        expect caps.backend_name == "portable-socket"
        expect caps.supports_async == false
        expect net_backend_acceleration_tier(caps) == "portable"
        expect net_backend_can_accelerate_static_files(caps) == false

    it "reports RDMA as the strongest explicit acceleration tier":
        val caps = accelerated_net_backend_capabilities("rdma-test", true, true, true)
        expect caps.supports_packet_io == true
        expect caps.supports_sriov == true
        expect caps.supports_rdma == true
        expect net_backend_acceleration_tier(caps) == "rdma"
        expect net_backend_can_accelerate_static_files(caps) == true
        expect net_backend_summary(caps) == "rdma-test:rdma"

    it "keeps packet I/O disabled unless explicitly configured":
        val portable = portable_net_backend_capabilities()
        val accelerated = accelerated_net_backend_capabilities("uring", false, false, false)
        val packet = packet_io_net_backend_capabilities("xdp-test", false, false)

        expect portable.supports_packet_io == false
        expect accelerated.supports_packet_io == false
        expect packet.supports_packet_io == true
        expect net_backend_acceleration_tier(packet) == "zero-copy"

    it "models packet ring ownership and completion":
        val disabled = packet_io_disabled_capabilities()
        expect disabled.supports_packet_io == false

        val enabled = packet_io_opt_in_capabilities(1024u32, 1024u32, true)
        expect enabled.supports_packet_io == true
        expect enabled.zero_copy == true

        val rx = packet_rx_lease(1u64, 7u64, 1500u64)
        expect rx.direction == "rx"
        expect rx.owner == "application"
        expect rx.completed == false

        val tx = packet_tx_lease(1u64, 8u64, 64u64)
        val done = packet_complete(tx)
        expect done.direction == "tx"
        expect done.owner == "driver"
        expect done.completed == true

    it "renders comparable packet I/O benchmark output":
        val report = packet_io_benchmark_report("http-static-64k", 1000u64, 4000u64, 120u64, 40u64, "xdp-test:zero-copy")
        val line = packet_io_benchmark_line(report)
        expect (line).contains("portable_pps=1000")
        expect (line).contains("packet_io_pps=4000")
        expect (line).contains("backend=xdp-test:zero-copy")