# @cover src/lib/skia/feature/glyph/font_metrics.spl 80%
"""
# Skia Font Metrics Specification

**Feature IDs:** #SKI-FM-001
**Category:** Stdlib
**Difficulty:** 2/5
**Status:** Implemented

## Overview

Tests for parse_hhea, parse_os2, parse_post — OpenType per-font metric
extractors used by the text layout engine for baseline alignment and
line spacing.
"""

use std.spipe.*
use std.skia.feature.glyph.font_metrics.{
    parse_hhea, parse_os2, parse_post,
    FontMetricsHhea, FontMetricsOs2, FontMetricsPost
}

# Allocate n zero bytes. Kept local to the spec.
fn _zeros(n: i64) -> [u8]:
    var buf: [u8] = []
    var i = 0
    while i < n:
        buf.push(0 as u8)
        i = i + 1
    buf

# Write a big-endian u16 into buf at offset.
fn _set_u16_be(buf: [u8], offset: i64, value: i64) -> void:
    val hi = ((value >> 8) & 0xFF) as u8
    val lo = (value & 0xFF) as u8
    buf[offset] = hi
    buf[offset + 1] = lo

# Write a big-endian signed 16-bit integer into buf at offset.
fn _set_i16_be(buf: [u8], offset: i64, value: i64) -> void:
    val encoded = if value < 0:
        value + 65536
    else:
        value
    _set_u16_be(buf, offset, encoded)

# Write a big-endian u32 into buf at offset.
fn _set_u32_be(buf: [u8], offset: i64, value: i64) -> void:
    buf[offset] = ((value >> 24) & 0xFF) as u8
    buf[offset + 1] = ((value >> 16) & 0xFF) as u8
    buf[offset + 2] = ((value >> 8) & 0xFF) as u8
    buf[offset + 3] = (value & 0xFF) as u8

describe "font_metrics":
    it "parse_hhea: empty blob returns None":
        val empty: [u8] = []
        val result = parse_hhea(empty)
        expect(result).to_be_nil()

    it "parse_hhea: 36-byte blob with ascent=1800, descent=-400, line_gap=200 parses correctly":
        val buf = _zeros(36)
        # version 0x00010000
        _set_u32_be(buf, 0, 65536)
        _set_i16_be(buf, 4, 1800)
        _set_i16_be(buf, 6, -400)
        _set_i16_be(buf, 8, 200)
        _set_u16_be(buf, 10, 2048)
        _set_u16_be(buf, 34, 512)
        val result = parse_hhea(buf)
        val metrics = result.unwrap()
        expect(metrics.ascent).to_equal(1800)
        expect(metrics.descent).to_equal(-400)
        expect(metrics.line_gap).to_equal(200)
        expect(metrics.advance_width_max).to_equal(2048)

    it "parse_hhea: num_long_hor_metrics read from offset 34":
        val buf = _zeros(36)
        _set_u32_be(buf, 0, 65536)
        _set_u16_be(buf, 34, 1337)
        val result = parse_hhea(buf)
        val metrics = result.unwrap()
        expect(metrics.num_long_hor_metrics).to_equal(1337)

    it "parse_os2: version 0 blob x_height = 0 (field not present)":
        val buf = _zeros(78)
        _set_u16_be(buf, 0, 0)
        _set_i16_be(buf, 68, 1600)
        _set_i16_be(buf, 70, -400)
        val result = parse_os2(buf)
        val metrics = result.unwrap()
        expect(metrics.x_height).to_equal(0)
        expect(metrics.cap_height).to_equal(0)
        expect(metrics.typo_ascent).to_equal(1600)

    it "parse_os2: version 2 blob with sxHeight=500 returns 500":
        val buf = _zeros(96)
        _set_u16_be(buf, 0, 2)
        _set_i16_be(buf, 86, 500)
        _set_i16_be(buf, 88, 700)
        val result = parse_os2(buf)
        val metrics = result.unwrap()
        expect(metrics.x_height).to_equal(500)
        expect(metrics.cap_height).to_equal(700)

    it "parse_post: reads italic_angle as Fixed 16.16":
        val buf = _zeros(32)
        # italic_angle = -12.0 => -12 * 65536 = -786432
        # Encoded as u32: 4294967296 - 786432 = 4294180864
        _set_u32_be(buf, 4, 4294180864)
        val result = parse_post(buf)
        val metrics = result.unwrap()
        val delta = metrics.italic_angle - (-12.0)
        val abs_delta = if delta < 0.0: -delta else: delta
        val close = abs_delta < 1e-6
        expect(close).to_equal(true)

    it "parse_post: is_fixed_pitch from offset 12":
        val buf = _zeros(32)
        _set_u32_be(buf, 12, 1)
        val result = parse_post(buf)
        val metrics = result.unwrap()
        expect(metrics.is_fixed_pitch).to_equal(true)

        val buf2 = _zeros(32)
        _set_u32_be(buf2, 12, 0)
        val result2 = parse_post(buf2)
        val metrics2 = result2.unwrap()
        expect(metrics2.is_fixed_pitch).to_equal(false)
