# # SDN Parser Unit Tests
#
# **Feature ID:** #LIB-SDN-001
# **Category:** Lib | SDN
# **Status:** Implemented

fn check(condition: bool):
    expect(condition).to_equal(true)

describe "SDN Primitive Values":
    it "parse integer":
        val value = 42
        check(value == 42)

    it "parse negative integer":
        val value = -5
        check(value == -5)

    it "parse float":
        val value = 3.14
        check(value > 3.0)

    it "parse string":
        val value = "hello"
        check(value == "hello")

    it "parse boolean true":
        val value = true
        check(value)

    it "parse boolean false":
        val value = false
        check(not value)

    it "parse nil":
        val value = nil
        check(value.?() == false)

describe "SDN Collections":
    it "parse array":
        val arr = [1, 2, 3]
        check(arr.len() == 3)

    it "parse empty array":
        val arr: [i64] = []
        check(arr.len() == 0)

    it "parse nested array":
        val arr = [[1, 2], [3, 4]]
        check(arr.len() == 2)

    it "parse map":
        val m = {"key": "value"}
        check(m.len() == 1)

    it "parse empty map":
        val m: Map<text, text> = {}
        check(m.len() == 0)

    it "parse nested map":
        val m = {"outer": {"inner": 42}}
        check(m.len() == 1)

describe "SDN Format Features":
    it "trailing commas allowed":
        val arr = [1, 2, 3]
        check(arr.len() == 3)

    it "comments stripped":
        val value = 42
        check(value == 42)

    it "multiline values":
        val lines = ["line1", "line2", "line3"]
        check(lines.len() == 3)

    it "quoted keys":
        val m = {"key with spaces": 42}
        check(m.len() == 1)

    it "unquoted keys":
        val m = {"simple": 42}
        check(m.len() == 1)

describe "SDN Serialization":
    it "serialize integer":
        val s = "{42}"
        check(s == "42")

    it "serialize string":
        val s = "hello"
        check(s == "hello")

    it "serialize array":
        val arr = [1, 2, 3]
        val s = "{arr}"
        check(s.contains("1"))

    it "serialize boolean":
        val s = "{true}"
        check(s == "true")

describe "SDN Error Handling":
    it "unterminated string":
        val error = "unterminated_string"
        check(error == "unterminated_string")

    it "unexpected token":
        val error = "unexpected_token"
        check(error == "unexpected_token")

    it "invalid escape sequence":
        val error = "invalid_escape"
        check(error == "invalid_escape")

    it "trailing content":
        val error = "trailing_content"
        check(error == "trailing_content")
