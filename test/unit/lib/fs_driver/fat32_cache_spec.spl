# Maps to: fat-faster-than-vfat REQ-1 through REQ-6
# Run: bin/simple test test/unit/lib/fs_driver/fat32_cache_spec.spl

"""
FAT32 Cache Specification

Validates three cache layers added to the FAT32 driver:
  - FatSectorCache: sector buffer cache (Dict<u64, [u8]>)
  - ChainCache: cluster-chain cache (Dict<u32, [u32]>)
  - PathCache: path-to-DirEntry cache (Dict<text, DirEntry>)
"""

use std.spipe.*
use std.fs_driver.fat32_cache.{FatSectorCache, ChainCache, PathCache}
use std.fs_driver.types.{DirEntry, Inode}

# ============================================================================
# FatSectorCache
# ============================================================================

describe "FatSectorCache":
    describe "get":
        it "AC-1: returns nil on cache miss":
            val c = FatSectorCache.new(8)
            val result = c.get(42)
            expect(result).to_be_nil()

        it "AC-1: returns cached sector on cache hit":
            var c = FatSectorCache.new(8)
            var data: [u8] = [1, 2, 3, 4]
            c.put(10, data)
            val result = c.get(10)
            val is_nil = result == nil
            expect(is_nil).to_equal(false)

    describe "put":
        it "AC-1: stored sector is retrievable via get":
            var c = FatSectorCache.new(8)
            var data: [u8] = [0xAB, 0xCD]
            c.put(99, data)
            val got = c.get(99)
            val is_nil = got == nil
            expect(is_nil).to_equal(false)

        it "AC-1: different sectors stored independently":
            var c = FatSectorCache.new(8)
            var d1: [u8] = [1]
            var d2: [u8] = [2]
            c.put(1, d1)
            c.put(2, d2)
            val r1 = c.get(1)
            val r2 = c.get(2)
            val r1_nil = r1 == nil
            val r2_nil = r2 == nil
            expect(r1_nil).to_equal(false)
            expect(r2_nil).to_equal(false)

    describe "invalidate":
        it "AC-4: invalidate removes specific sector from cache":
            var c = FatSectorCache.new(8)
            var data: [u8] = [0xFF]
            c.put(7, data)
            c.invalidate(7)
            val result = c.get(7)
            expect(result).to_be_nil()

        it "AC-4: invalidate does not affect other cached sectors":
            var c = FatSectorCache.new(8)
            var d1: [u8] = [1]
            var d2: [u8] = [2]
            c.put(3, d1)
            c.put(4, d2)
            c.invalidate(3)
            val r4 = c.get(4)
            val r4_nil = r4 == nil
            expect(r4_nil).to_equal(false)

# ============================================================================
# ChainCache
# ============================================================================

describe "ChainCache":
    describe "get_chain":
        it "AC-2: returns nil on cache miss":
            val c = ChainCache.new()
            val result = c.get_chain(5)
            expect(result).to_be_nil()

        it "AC-2: returns cached chain on hit":
            var c = ChainCache.new()
            var chain: [u32] = [5, 6, 7]
            c.put_chain(5, chain)
            val result = c.get_chain(5)
            val is_nil = result == nil
            expect(is_nil).to_equal(false)

    describe "put_chain":
        it "AC-2: stored chain is retrievable":
            var c = ChainCache.new()
            var chain: [u32] = [10, 11, 12]
            c.put_chain(10, chain)
            val got = c.get_chain(10)
            val is_nil = got == nil
            expect(is_nil).to_equal(false)

    describe "invalidate":
        it "AC-4: invalidation clears specific chain entry":
            var c = ChainCache.new()
            var chain: [u32] = [20, 21]
            c.put_chain(20, chain)
            c.invalidate(20)
            val result = c.get_chain(20)
            expect(result).to_be_nil()

        it "AC-4: invalidation does not affect other chains":
            var c = ChainCache.new()
            var c1: [u32] = [30, 31]
            var c2: [u32] = [40, 41]
            c.put_chain(30, c1)
            c.put_chain(40, c2)
            c.invalidate(30)
            val r40 = c.get_chain(40)
            val r40_nil = r40 == nil
            expect(r40_nil).to_equal(false)

# ============================================================================
# PathCache
# ============================================================================

describe "PathCache":
    describe "get":
        it "AC-3: returns nil on cache miss":
            val c = PathCache.new()
            val result = c.get("/foo/bar")
            expect(result).to_be_nil()

        it "AC-3: returns cached entry on hit":
            var c = PathCache.new()
            val entry = DirEntry(
                name: "bar",
                inode: Inode(id: 50),
                is_dir: false
            )
            c.put("/foo/bar", entry)
            val result = c.get("/foo/bar")
            val is_nil = result == nil
            expect(is_nil).to_equal(false)

    describe "put":
        it "AC-3: stored entry is retrievable":
            var c = PathCache.new()
            val entry = DirEntry(
                name: "baz",
                inode: Inode(id: 60),
                is_dir: true
            )
            c.put("/baz", entry)
            val got = c.get("/baz")
            val is_nil = got == nil
            expect(is_nil).to_equal(false)

    describe "invalidate_prefix":
        it "AC-6: clears entries matching prefix":
            var c = PathCache.new()
            val e1 = DirEntry(name: "a", inode: Inode(id: 1), is_dir: false)
            val e2 = DirEntry(name: "b", inode: Inode(id: 2), is_dir: false)
            c.put("/dir/a", e1)
            c.put("/dir/b", e2)
            c.invalidate_prefix("/dir")
            val r1 = c.get("/dir/a")
            val r2 = c.get("/dir/b")
            expect(r1).to_be_nil()
            expect(r2).to_be_nil()

        it "AC-6: does not clear entries with non-matching prefix":
            var c = PathCache.new()
            val e1 = DirEntry(name: "x", inode: Inode(id: 10), is_dir: false)
            val e2 = DirEntry(name: "y", inode: Inode(id: 20), is_dir: false)
            c.put("/other/x", e1)
            c.put("/dir/y", e2)
            c.invalidate_prefix("/dir")
            val r_other = c.get("/other/x")
            val r_other_nil = r_other == nil
            expect(r_other_nil).to_equal(false)
