# DB Hardening & Optimizer Integration Spec
#
# Tests: index maintenance on insert/update/delete, cache invalidation,
# planner-driven query dispatch, and optimizer CLI db-analyze mode.

use std.io_runtime
use std.db.db_persistence.{DbRow, DbTable, db_table_new, row_not_found}
use std.db.db_query.{
    QueryResult, query_result_empty,
    db_prefix_scan, db_range_scan, db_keys_matching, db_all_ids,
    db_table_prefix_scan, db_table_exact_match,
    db_table_contains_scan, db_table_range_scan, db_table_all_ids
}
use std.db.prefix_index.{prefix_index_size, prefix_index_lookup_prefix, prefix_index_lookup_exact}
use std.db.text_index.{text_index_size, text_index_search_prefix, text_index_search_contains, text_index_search_exact}
use std.db.query_planner.{
    choose_plan, predicate_prefix, predicate_eq,
    IndexDescriptor, IndexKind, index_descriptor_new,
    PlanNodeKind
}

# ============================================================================
# Test Group 1: Index Maintenance on Insert
# ============================================================================

describe "DbTable index maintenance on insert":
    it "builds indexes after first insert":
        var t = db_table_new("users")
        t.insert("user:alice", "payload_a")
        val ki = t.key_index()
        val ti = t.text_idx()
        expect(prefix_index_size(ki)).to_equal(1)
        expect(text_index_size(ti)).to_equal(1)

    it "indexes grow with each insert":
        var t = db_table_new("items")
        t.insert("item:one", "v1")
        t.insert("item:two", "v2")
        t.insert("item:three", "v3")
        val ki = t.key_index()
        expect(prefix_index_size(ki)).to_equal(3)

    it "marks indexes dirty after insert":
        var t = db_table_new("test")
        expect(t.indexes_dirty()).to_equal(false)
        t.insert("k1", "v1")
        expect(t.indexes_dirty()).to_equal(true)

# ============================================================================
# Test Group 2: Index Maintenance on Delete
# ============================================================================

describe "DbTable index maintenance on delete":
    it "removes entry from indexes after delete":
        var t = db_table_new("users")
        t.insert("user:alice", "a")
        t.insert("user:bob", "b")
        t.delete_by_key("user:alice")
        val ki = t.key_index()
        expect(prefix_index_size(ki)).to_equal(1)
        val hits = prefix_index_lookup_exact(ki, "user:alice")
        expect(hits.len()).to_equal(0)

    it "still finds remaining entries after delete":
        var t = db_table_new("users")
        t.insert("user:alice", "a")
        t.insert("user:bob", "b")
        t.delete_by_key("user:alice")
        val ki = t.key_index()
        val hits = prefix_index_lookup_exact(ki, "user:bob")
        expect(hits.len()).to_equal(1)

# ============================================================================
# Test Group 3: Index Maintenance on Update
# ============================================================================

describe "DbTable index maintenance on update":
    it "updates payload without changing index count":
        var t = db_table_new("users")
        t.insert("user:alice", "old_payload")
        t.update("user:alice", "new_payload")
        val ki = t.key_index()
        expect(prefix_index_size(ki)).to_equal(1)

    it "returns updated payload via get_by_id":
        var t = db_table_new("users")
        val id = t.insert("user:alice", "old")
        t.update("user:alice", "new")
        val payload = t.get_by_id(id)
        expect(payload).to_equal("new")

    it "returns false for non-existent key update":
        var t = db_table_new("users")
        val result = t.update("missing", "val")
        expect(result).to_equal(false)

# ============================================================================
# Test Group 4: Cache Invalidation — No Stale Reads
# ============================================================================

describe "cache invalidation after mutations":
    it "find_by_key returns not_found after delete":
        var t = db_table_new("test")
        t.insert("k1", "v1")
        val id_before = t.find_by_key("k1")
        expect(id_before >= 0).to_equal(true)
        t.delete_by_key("k1")
        val id_after = t.find_by_key("k1")
        expect(id_after).to_equal(row_not_found())

    it "prefix scan reflects inserts immediately":
        var t = db_table_new("log")
        t.insert("log:a", "1")
        val qr1 = db_table_prefix_scan(t, "log:")
        expect(qr1.count).to_equal(1)
        t.insert("log:b", "2")
        val qr2 = db_table_prefix_scan(t, "log:")
        expect(qr2.count).to_equal(2)

    it "exact match reflects delete":
        var t = db_table_new("test")
        t.insert("key1", "v1")
        t.insert("key2", "v2")
        val qr1 = db_table_exact_match(t, "key1")
        expect(qr1.count).to_equal(1)
        t.delete_by_key("key1")
        val qr2 = db_table_exact_match(t, "key1")
        expect(qr2.count).to_equal(0)

    it "contains scan reflects update":
        var t = db_table_new("test")
        t.insert("user:alice", "admin")
        val qr1 = db_table_contains_scan(t, "alice")
        expect(qr1.count).to_equal(1)
        t.delete_by_key("user:alice")
        t.insert("user:bob", "viewer")
        val qr2 = db_table_contains_scan(t, "alice")
        expect(qr2.count).to_equal(0)

# ============================================================================
# Test Group 5: Planner-Driven Query Dispatch
# ============================================================================

describe "planner-driven indexed queries":
    it "db_table_prefix_scan uses index for prefix":
        var t = db_table_new("data")
        t.insert("ns:a", "1")
        t.insert("ns:b", "2")
        t.insert("other:c", "3")
        val qr = db_table_prefix_scan(t, "ns:")
        expect(qr.count).to_equal(2)

    it "db_table_exact_match uses index for exact":
        var t = db_table_new("data")
        t.insert("key:one", "1")
        t.insert("key:two", "2")
        val qr = db_table_exact_match(t, "key:one")
        expect(qr.count).to_equal(1)

    it "db_table_contains_scan uses text index":
        var t = db_table_new("data")
        t.insert("hello_world", "1")
        t.insert("hello_there", "2")
        t.insert("goodbye", "3")
        val qr = db_table_contains_scan(t, "hello")
        expect(qr.count).to_equal(2)

    it "db_table_range_scan works on ids":
        var t = db_table_new("data")
        t.insert("a", "1")
        t.insert("b", "2")
        t.insert("c", "3")
        val qr = db_table_range_scan(t, 0, 1)
        expect(qr.count).to_equal(2)

    it "db_table_all_ids returns all":
        var t = db_table_new("data")
        t.insert("a", "1")
        t.insert("b", "2")
        val qr = db_table_all_ids(t)
        expect(qr.count).to_equal(2)

# ============================================================================
# Test Group 6: Legacy API Backward Compatibility
# ============================================================================

describe "legacy raw-row query backward compat":
    it "db_prefix_scan still works on raw rows":
        var t = db_table_new("log")
        t.insert("log:x", "1")
        t.insert("log:y", "2")
        t.insert("other:z", "3")
        val qr = db_prefix_scan(t.rows, "log:")
        expect(qr.count).to_equal(2)

    it "db_keys_matching still works on raw rows":
        var t = db_table_new("test")
        t.insert("k1", "v1")
        t.insert("k2", "v2")
        val qr = db_keys_matching(t.rows, "k1")
        expect(qr.count).to_equal(1)

    it "db_range_scan still works on raw rows":
        var t = db_table_new("test")
        t.insert("a", "1")
        t.insert("b", "2")
        t.insert("c", "3")
        val qr = db_range_scan(t.rows, 0, 1)
        expect(qr.count).to_equal(2)

    it "db_all_ids still works on raw rows":
        var t = db_table_new("test")
        t.insert("a", "1")
        val qr = db_all_ids(t.rows)
        expect(qr.count).to_equal(1)

# ============================================================================
# Test Group 7: Empty Table Edge Cases
# ============================================================================

describe "empty table queries":
    it "prefix scan on empty table returns 0":
        var t = db_table_new("empty")
        val qr = db_table_prefix_scan(t, "any:")
        expect(qr.count).to_equal(0)

    it "exact match on empty table returns 0":
        var t = db_table_new("empty")
        val qr = db_table_exact_match(t, "any")
        expect(qr.count).to_equal(0)

    it "contains scan on empty table returns 0":
        var t = db_table_new("empty")
        val qr = db_table_contains_scan(t, "x")
        expect(qr.count).to_equal(0)

    it "has_indexes returns false on empty table":
        var t = db_table_new("empty")
        expect(t.has_indexes()).to_equal(false)

# ============================================================================
# Test Group 8: Direct Planner Verification
# ============================================================================

describe "direct planner plan selection":
    it "choose_plan selects IndexPrefix with prefix index available":
        var descs: [IndexDescriptor] = []
        descs.push(index_descriptor_new("key_prefix", "key", IndexKind.Prefix))
        val pred = predicate_prefix("key", "ns:")
        val plan = choose_plan(pred, descs, 100)
        expect(plan.kind == PlanNodeKind.IndexPrefix).to_equal(true)

    it "choose_plan falls back to FullScan with no indexes":
        var descs: [IndexDescriptor] = []
        val pred = predicate_prefix("key", "ns:")
        val plan = choose_plan(pred, descs, 100)
        expect(plan.kind == PlanNodeKind.FullScan).to_equal(true)

    it "choose_plan selects IndexLookup for eq with hash index":
        var descs: [IndexDescriptor] = []
        descs.push(index_descriptor_new("key_hash", "key", IndexKind.Hash))
        val pred = predicate_eq("key", "user:alice")
        val plan = choose_plan(pred, descs, 100)
        expect(plan.kind == PlanNodeKind.IndexLookup).to_equal(true)

    it "choose_plan falls back to FullScan for eq with no indexes":
        var descs: [IndexDescriptor] = []
        val pred = predicate_eq("key", "user:alice")
        val plan = choose_plan(pred, descs, 100)
        expect(plan.kind == PlanNodeKind.FullScan).to_equal(true)
