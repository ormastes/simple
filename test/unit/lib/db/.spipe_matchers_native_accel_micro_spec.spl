use std.spipe.*
use std.db.accel.{
    RowBitmap, accel_capability_report,
    byte_span_find_delimiter, make_byte_span,
    text_contains_token, text_find_delimiter, text_starts_with_span
}

describe "native accel micro":
    it "mutates bitmap clear/get/count":
        val bitmap = RowBitmap.full(65)
        expect bitmap.count() == 65
        bitmap.clear(0)
        bitmap.clear(31)
        bitmap.clear(32)
        bitmap.clear(64)
        expect bitmap.get(0) == false
        expect bitmap.get(31) == false
        expect bitmap.get(32) == false
        expect bitmap.get(64) == false
        expect bitmap.count() == 61

    it "evaluates text predicate helpers":
        expect text_starts_with_span("alpha beta", "alpha") == true
        expect text_contains_token("alpha|beta,gamma", "beta") == true
        expect text_contains_token("alphabet soup", "alpha") == false

    it "evaluates delimiter helpers":
        val span = make_byte_span([("a" as u8), ("|" as u8), ("b" as u8)], 0, 3)
        expect byte_span_find_delimiter(span) == 1
        expect text_find_delimiter("path,tail") == 4

    it "reports simd capability coherently":
        val report = accel_capability_report()
        expect report.scalar_fallback == true
        expect report.tier_name.len() > 0
        expect report.simd_width_bits > -1
        expect report.simd_active == false