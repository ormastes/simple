use std.spipe.*
use std.db.accel.RowBitmap

fn build_lhs_bitmap() -> RowBitmap:
    val lhs = RowBitmap.empty(96)
    lhs.set(0)
    lhs.set(31)
    lhs.set(32)
    lhs.set(63)
    lhs.set(64)
    lhs.set(95)
    lhs

fn build_rhs_bitmap() -> RowBitmap:
    val rhs = RowBitmap.empty(70)
    rhs.set(0)
    rhs.set(32)
    rhs.set(62)
    rhs.set(63)
    rhs.set(64)
    rhs

fn main():

    describe "native bitmap parity probe":
        it "counts intersection bits":
            val lhs = build_lhs_bitmap()
            val rhs = build_rhs_bitmap()
            val both = lhs.and_with(rhs)
            val either = lhs.or_with(rhs)

            expect both.count() == 4
            expect either.count() == 7

        it "reads intersection bit 0":
            val both = build_lhs_bitmap().and_with(build_rhs_bitmap())
            expect both.get(0) == true

        it "reads intersection bit 31":
            val both = build_lhs_bitmap().and_with(build_rhs_bitmap())
            expect both.get(31) == false

        it "reads intersection bit 32":
            val both = build_lhs_bitmap().and_with(build_rhs_bitmap())
            expect both.get(32) == true

        it "reads intersection bit 62":
            val both = build_lhs_bitmap().and_with(build_rhs_bitmap())
            expect both.get(62) == false

        it "reads intersection bit 63":
            val both = build_lhs_bitmap().and_with(build_rhs_bitmap())
            expect both.get(63) == true

        it "reads intersection bit 64":
            val both = build_lhs_bitmap().and_with(build_rhs_bitmap())
            expect both.get(64) == true

        it "reads intersection bit 95":
            val both = build_lhs_bitmap().and_with(build_rhs_bitmap())
            expect both.get(95) == false

        it "reads union bit 0":
            val either = build_lhs_bitmap().or_with(build_rhs_bitmap())
            expect either.get(0) == true

        it "reads union bit 31":
            val either = build_lhs_bitmap().or_with(build_rhs_bitmap())
            expect either.get(31) == true

        it "reads union bit 32":
            val either = build_lhs_bitmap().or_with(build_rhs_bitmap())
            expect either.get(32) == true

        it "reads union bit 62":
            val either = build_lhs_bitmap().or_with(build_rhs_bitmap())
            expect either.get(62) == true

        it "reads union bit 63":
            val either = build_lhs_bitmap().or_with(build_rhs_bitmap())
            expect either.get(63) == true

        it "reads union bit 64":
            val either = build_lhs_bitmap().or_with(build_rhs_bitmap())
            expect either.get(64) == true

        it "reads union bit 95":
            val either = build_lhs_bitmap().or_with(build_rhs_bitmap())
            expect either.get(95) == true