# WebSocket Framing Round-Trip Specification (W16-E seed)
#
# **Feature IDs:** #WS-FRAME-001
# **Category:** Stdlib / WebSocket
# **Difficulty:** 3/5
# **Status:** Draft
#
# ## Overview
#
# Byte-exact round-trip tests for the WebSocket framing layer (RFC 6455 §5).
# For each frame variant + length variant + masking direction:
#
#   1. Construct WsFrame value
#   2. Serialize -> bytes1
#   3. Parse bytes1 -> reconstructed frame
#   4. Re-serialize -> bytes2
#   5. Assert bytes1 == bytes2 (byte-exact stability)
#   6. Assert key fields survive the round trip
#
# Length variants exercised:
#   - 7-bit  (payload <= 125)        — short text
#   - 16-bit (126 .. 65535)          — medium binary
#   - 64-bit (>= 65536)              — long binary
#
# Direction variants:
#   - server → client (unmasked)
#   - client → server (masked, with caller-supplied 4-byte key)
#
# Frame variants:
#   - Text, Binary, Continuation, Close, Ping, Pong
#
# Per the "text-only API byte cliffs" feedback (`feedback_text_only_byte_cliffs`)
# all payload fields are [u8]. Text frames carry raw UTF-8 bytes — UTF-8
# validation is a separate (caller-side) concern.

use std.spipe.*

use std.http.ws.ws_frame.{
    WsFrame, WsTextFrame, WsBinaryFrame, WsContinuationFrame,
    WsCloseFrame, WsPingFrame, WsPongFrame,
    WS_OPCODE_TEXT, WS_OPCODE_BINARY, WS_OPCODE_CLOSE,
    WS_OPCODE_PING, WS_OPCODE_PONG,
    WS_FIN_BIT, WS_MASK_BIT,
    WS_LEN_EXT_16, WS_LEN_EXT_64,
    WS_CLOSE_NORMAL, WS_CLOSE_GOING_AWAY,
    WS_MASK_KEY_LEN
}
use std.http.ws.ws_writer.{
    ws_write_frame, ws_write_frame_server, ws_write_frame_client
}
use std.http.ws.ws_parser.{
    ws_parse_frame, ws_parse_frame_header, ws_frame_wire_size
}

# ============================================================================
# Local helpers (no std byte_eq dependency to keep spec self-contained).
# ============================================================================

fn _bytes_eq(a: [u8], b: [u8]) -> bool:
    if a.len() != b.len():
        return false
    var i = 0
    loop:
        if i >= a.len():
            break
        if a[i] != b[i]:
            return false
        i = i + 1
    return true

fn _bytes_of_len(n: i64, seed: i64) -> [u8]:
    """Build a deterministic [u8] of length n, with each byte = (i + seed) mod 256."""
    var out: [u8] = []
    var i = 0
    loop:
        if i >= n:
            break
        out.push((i + seed) % 256)
        i = i + 1
    return out

fn _short_text_payload() -> [u8]:
    # "hello" = 5 bytes, fits in 7-bit length.
    var out: [u8] = []
    out.push(0x68)  # h
    out.push(0x65)  # e
    out.push(0x6c)  # l
    out.push(0x6c)  # l
    out.push(0x6f)  # o
    return out

fn _mask_key_abcd() -> [u8]:
    # 4-byte test masking key: 0x01 0x02 0x03 0x04
    var out: [u8] = []
    out.push(0x01)
    out.push(0x02)
    out.push(0x03)
    out.push(0x04)
    return out

fn _empty_bytes() -> [u8]:
    var out: [u8] = []
    return out

# ============================================================================
# Test Group 1: Short Text frame (7-bit payload length, server → client)
# ============================================================================

describe "WS Text frame round-trip — 7-bit length (RFC 6455 §5.6)":
    it "round-trips a 5-byte 'hello' text frame byte-exact":
        val original = WsFrame.Text(WsTextFrame(
            fin: true, rsv1: false, rsv2: false, rsv3: false,
            payload: _short_text_payload()
        ))
        val bytes1 = ws_write_frame_server(original)
        # 2-byte header + 5-byte payload, no mask, no ext-len
        expect bytes1.len() == 7
        # Byte 0: FIN | TEXT(0x1) = 0x81
        expect bytes1[0] == 0x81
        # Byte 1: MASK=0 | len=5
        expect bytes1[1] == 0x05
        val maybe_parsed = ws_parse_frame(bytes1, 0)
        expect maybe_parsed != nil == true
        val parsed = maybe_parsed ?? original
        val bytes2 = ws_write_frame_server(parsed)
        expect _bytes_eq(bytes1, bytes2) == true

    it "preserves text payload bytes across the round trip":
        val original = WsFrame.Text(WsTextFrame(
            fin: true, rsv1: false, rsv2: false, rsv3: false,
            payload: _short_text_payload()
        ))
        val bytes = ws_write_frame_server(original)
        val maybe_parsed = ws_parse_frame(bytes, 0)
        match maybe_parsed:
            case Some(frame):
                match frame:
                    case Text(t):
                        expect t.fin == true
                        expect _bytes_eq(t.payload, _short_text_payload()) == true
                    case _:
                        expect "wrong-variant" == "Text"
            case _:
                expect "nil-parse" == "Some(Text)"

# ============================================================================
# Test Group 2: Medium Binary frame (16-bit extended length)
# ============================================================================

describe "WS Binary frame round-trip — 16-bit extended length":
    it "round-trips a 200-byte binary frame with 16-bit ext length":
        val payload = _bytes_of_len(200, 0)
        val original = WsFrame.Binary(WsBinaryFrame(
            fin: true, rsv1: false, rsv2: false, rsv3: false,
            payload: payload
        ))
        val bytes1 = ws_write_frame_server(original)
        # 2-byte header + 2-byte ext-len + 200 payload = 204
        expect bytes1.len() == 204
        # Byte 0: FIN | BINARY(0x2) = 0x82
        expect bytes1[0] == 0x82
        # Byte 1: MASK=0 | len-marker=126
        expect bytes1[1] == WS_LEN_EXT_16
        # Bytes 2-3: big-endian 200 = 0x00 0xc8
        expect bytes1[2] == 0x00
        expect bytes1[3] == 0xc8
        val maybe_parsed = ws_parse_frame(bytes1, 0)
        expect maybe_parsed != nil == true
        val parsed = maybe_parsed ?? original
        val bytes2 = ws_write_frame_server(parsed)
        expect _bytes_eq(bytes1, bytes2) == true

    it "round-trips at 16-bit boundary (exactly 65535 bytes)":
        val payload = _bytes_of_len(65535, 7)
        val original = WsFrame.Binary(WsBinaryFrame(
            fin: true, rsv1: false, rsv2: false, rsv3: false,
            payload: payload
        ))
        val bytes1 = ws_write_frame_server(original)
        # 2 + 2 + 65535
        expect bytes1.len() == 65539
        expect bytes1[1] == WS_LEN_EXT_16
        expect bytes1[2] == 0xff
        expect bytes1[3] == 0xff
        val maybe_parsed = ws_parse_frame(bytes1, 0)
        expect maybe_parsed != nil == true
        val parsed = maybe_parsed ?? original
        val bytes2 = ws_write_frame_server(parsed)
        expect _bytes_eq(bytes1, bytes2) == true

# ============================================================================
# Test Group 3: Long Binary frame (64-bit extended length)
# ============================================================================

describe "WS Binary frame round-trip — 64-bit extended length":
    it "round-trips a 65536-byte binary frame with 64-bit ext length":
        val payload = _bytes_of_len(65536, 13)
        val original = WsFrame.Binary(WsBinaryFrame(
            fin: true, rsv1: false, rsv2: false, rsv3: false,
            payload: payload
        ))
        val bytes1 = ws_write_frame_server(original)
        # 2-byte header + 8-byte ext-len + 65536 payload = 65546
        expect bytes1.len() == 65546
        # Byte 1: MASK=0 | len-marker=127
        expect bytes1[1] == WS_LEN_EXT_64
        # Bytes 2-9: big-endian 65536 = 0x00 0x00 0x00 0x00 0x00 0x01 0x00 0x00
        expect bytes1[2] == 0x00
        expect bytes1[3] == 0x00
        expect bytes1[4] == 0x00
        expect bytes1[5] == 0x00
        expect bytes1[6] == 0x00
        expect bytes1[7] == 0x01
        expect bytes1[8] == 0x00
        expect bytes1[9] == 0x00
        val maybe_parsed = ws_parse_frame(bytes1, 0)
        expect maybe_parsed != nil == true
        val parsed = maybe_parsed ?? original
        val bytes2 = ws_write_frame_server(parsed)
        expect _bytes_eq(bytes1, bytes2) == true

# ============================================================================
# Test Group 4: Masked client→server frame (RFC 6455 §5.3)
# ============================================================================

describe "WS masked client → server frame (RFC 6455 §5.3)":
    it "round-trips a masked Text frame byte-exact":
        val key = _mask_key_abcd()
        val original = WsFrame.Text(WsTextFrame(
            fin: true, rsv1: false, rsv2: false, rsv3: false,
            payload: _short_text_payload()
        ))
        val bytes1 = ws_write_frame_client(original, key)
        # 2-byte header + 4-byte mask + 5-byte payload = 11
        expect bytes1.len() == 11
        # Byte 1: MASK=1 | len=5 → 0x85
        expect bytes1[1] == 0x85
        # Bytes 2-5: masking key
        expect bytes1[2] == 0x01
        expect bytes1[3] == 0x02
        expect bytes1[4] == 0x03
        expect bytes1[5] == 0x04
        # Payload bytes on the wire MUST be XORed with the key —
        # 'h' (0x68) XOR 0x01 = 0x69, 'e' (0x65) XOR 0x02 = 0x67, ...
        expect bytes1[6] == 0x69
        expect bytes1[7] == 0x67
        # Round-trip stability
        val maybe_parsed = ws_parse_frame(bytes1, 0)
        expect maybe_parsed != nil == true
        val parsed = maybe_parsed ?? original
        # Re-serialize with the SAME mask to compare bytes byte-exact.
        val bytes2 = ws_write_frame_client(parsed, key)
        expect _bytes_eq(bytes1, bytes2) == true

    it "parser unmasks payload back to original plaintext":
        val key = _mask_key_abcd()
        val original_payload = _short_text_payload()
        val original = WsFrame.Text(WsTextFrame(
            fin: true, rsv1: false, rsv2: false, rsv3: false,
            payload: original_payload
        ))
        val bytes = ws_write_frame_client(original, key)
        val maybe_parsed = ws_parse_frame(bytes, 0)
        match maybe_parsed:
            case Some(frame):
                match frame:
                    case Text(t):
                        # Parsed payload is the UNMASKED application bytes.
                        expect _bytes_eq(t.payload, original_payload) == true
                    case _:
                        expect "wrong-variant" == "Text"
            case _:
                expect "nil-parse" == "Some(Text)"

    it "exposes mask state via the parsed frame header":
        val key = _mask_key_abcd()
        val original = WsFrame.Binary(WsBinaryFrame(
            fin: true, rsv1: false, rsv2: false, rsv3: false,
            payload: _bytes_of_len(10, 0)
        ))
        val bytes = ws_write_frame_client(original, key)
        val maybe_header = ws_parse_frame_header(bytes, 0)
        match maybe_header:
            case Some(h):
                expect h.masked == true
                expect h.opcode == WS_OPCODE_BINARY
                expect h.payload_len == 10
                expect h.mask_key.len() == WS_MASK_KEY_LEN
            case _:
                expect "nil-header" == "Some(header)"

# ============================================================================
# Test Group 5: Ping / Pong control frames (RFC 6455 §5.5.2 / §5.5.3)
# ============================================================================

describe "WS Ping/Pong control frames":
    it "round-trips an empty Ping byte-exact":
        val original = WsFrame.Ping(WsPingFrame(fin: true, payload: _empty_bytes()))
        val bytes1 = ws_write_frame_server(original)
        # 2-byte header, zero payload
        expect bytes1.len() == 2
        # FIN | PING(0x9) = 0x89
        expect bytes1[0] == 0x89
        expect bytes1[1] == 0x00
        val maybe_parsed = ws_parse_frame(bytes1, 0)
        expect maybe_parsed != nil == true
        val parsed = maybe_parsed ?? original
        val bytes2 = ws_write_frame_server(parsed)
        expect _bytes_eq(bytes1, bytes2) == true

    it "round-trips a Pong with the same payload as the Ping":
        val ping_payload = _short_text_payload()
        val ping = WsFrame.Ping(WsPingFrame(fin: true, payload: ping_payload))
        val pong = WsFrame.Pong(WsPongFrame(fin: true, payload: ping_payload))
        val ping_bytes = ws_write_frame_server(ping)
        val pong_bytes = ws_write_frame_server(pong)
        # Headers differ in opcode only.
        expect ping_bytes[0] == 0x89
        expect pong_bytes[0] == 0x8a
        # Payloads match.
        var i = 2
        loop:
            if i >= ping_bytes.len():
                break
            expect ping_bytes[i] == pong_bytes[i]
            i = i + 1

    it "rejects control frames with > 125 byte payload":
        # Build a malformed Ping wire by hand: opcode=0x9, 16-bit ext len 200.
        var wire: [u8] = []
        wire.push(0x89)            # FIN | PING
        wire.push(WS_LEN_EXT_16)   # 16-bit ext marker
        wire.push(0x00)
        wire.push(0xc8)            # 200 big-endian
        var pad = 0
        loop:
            if pad >= 200:
                break
            wire.push(0x00)
            pad = pad + 1
        # Per RFC 6455 §5.5: control frame payload MUST be <= 125. Parser
        # surfaces this as nil so the connection layer can fail with 1002.
        val maybe = ws_parse_frame(wire, 0)
        expect maybe == nil == true

# ============================================================================
# Test Group 6: Close frame with status code (RFC 6455 §5.5.1)
# ============================================================================

describe "WS Close frame — status code + reason (RFC 6455 §5.5.1)":
    it "round-trips Close(1000, 'bye') byte-exact":
        var reason: [u8] = []
        reason.push(0x62)  # b
        reason.push(0x79)  # y
        reason.push(0x65)  # e
        val original = WsFrame.Close(WsCloseFrame(
            fin: true, has_status: true,
            code: WS_CLOSE_NORMAL, reason: reason
        ))
        val bytes1 = ws_write_frame_server(original)
        # 2-byte header + 2-byte code + 3-byte reason = 7
        expect bytes1.len() == 7
        # FIN | CLOSE(0x8) = 0x88
        expect bytes1[0] == 0x88
        expect bytes1[1] == 0x05
        # Bytes 2-3: 1000 big-endian = 0x03 0xe8
        expect bytes1[2] == 0x03
        expect bytes1[3] == 0xe8
        # Bytes 4-6: 'bye'
        expect bytes1[4] == 0x62
        expect bytes1[5] == 0x79
        expect bytes1[6] == 0x65
        val maybe_parsed = ws_parse_frame(bytes1, 0)
        expect maybe_parsed != nil == true
        val parsed = maybe_parsed ?? original
        val bytes2 = ws_write_frame_server(parsed)
        expect _bytes_eq(bytes1, bytes2) == true

    it "preserves Close code + reason bytes across the round trip":
        var reason: [u8] = []
        reason.push(0x67)  # g
        reason.push(0x6f)  # o
        val original = WsFrame.Close(WsCloseFrame(
            fin: true, has_status: true,
            code: WS_CLOSE_GOING_AWAY, reason: reason
        ))
        val bytes = ws_write_frame_server(original)
        val maybe_parsed = ws_parse_frame(bytes, 0)
        match maybe_parsed:
            case Some(frame):
                match frame:
                    case Close(c):
                        expect c.has_status == true
                        expect c.code == WS_CLOSE_GOING_AWAY
                        expect c.reason.len() == 2
                        expect c.reason[0] == 0x67
                        expect c.reason[1] == 0x6f
                    case _:
                        expect "wrong-variant" == "Close"
            case _:
                expect "nil-parse" == "Some(Close)"

    it "round-trips an empty Close payload as has_status=false":
        val original = WsFrame.Close(WsCloseFrame(
            fin: true, has_status: false, code: 0, reason: _empty_bytes()
        ))
        val bytes1 = ws_write_frame_server(original)
        # 2-byte header, zero payload
        expect bytes1.len() == 2
        expect bytes1[0] == 0x88
        expect bytes1[1] == 0x00
        val maybe_parsed = ws_parse_frame(bytes1, 0)
        match maybe_parsed:
            case Some(frame):
                match frame:
                    case Close(c):
                        expect c.has_status == false
                        expect c.code == 0
                    case _:
                        expect "wrong-variant" == "Close"
            case _:
                expect "nil-parse" == "Some(Close)"

# ============================================================================
# Test Group 7: Continuation frame (RFC 6455 §5.4) — fragment bookkeeping
# ============================================================================

describe "WS Continuation frame round-trip (RFC 6455 §5.4)":
    it "round-trips a non-final Continuation byte-exact":
        # First fragment: Text with FIN=0
        val first = WsFrame.Text(WsTextFrame(
            fin: false, rsv1: false, rsv2: false, rsv3: false,
            payload: _short_text_payload()
        ))
        # Second fragment: Continuation with FIN=1
        val second = WsFrame.Continuation(WsContinuationFrame(
            fin: true, rsv1: false, rsv2: false, rsv3: false,
            payload: _short_text_payload()
        ))
        val bytes1 = ws_write_frame_server(first)
        # FIN=0 | TEXT(0x1) = 0x01
        expect bytes1[0] == 0x01
        val bytes2 = ws_write_frame_server(second)
        # FIN=1 | CONT(0x0) = 0x80
        expect bytes2[0] == 0x80
        # Round-trip stability for both
        val maybe_a = ws_parse_frame(bytes1, 0)
        expect maybe_a != nil == true
        val maybe_b = ws_parse_frame(bytes2, 0)
        expect maybe_b != nil == true
        val parsed_a = maybe_a ?? first
        val parsed_b = maybe_b ?? second
        expect _bytes_eq(bytes1, ws_write_frame_server(parsed_a)) == true
        expect _bytes_eq(bytes2, ws_write_frame_server(parsed_b)) == true

# ============================================================================
# Test Group 8: ws_frame_wire_size matches actual emitted length
# ============================================================================

describe "WS wire-size predictor matches serializer output":
    it "predicts 7-bit wire size correctly":
        expect ws_frame_wire_size(5, false) == 7
        expect ws_frame_wire_size(5, true) == 11

    it "predicts 16-bit wire size correctly":
        expect ws_frame_wire_size(200, false) == 204
        expect ws_frame_wire_size(200, true) == 208

    it "predicts 64-bit wire size correctly":
        expect ws_frame_wire_size(65536, false) == 65546
        expect ws_frame_wire_size(65536, true) == 65550