# HTTP/2 Framing Round-Trip Specification (W15-F seed)
#
# **Feature IDs:** #HTTP2-FRAME-001
# **Category:** Stdlib / HTTP/2
# **Difficulty:** 3/5
# **Status:** Draft
#
# ## Overview
# Byte-exact round-trip tests for the H2 framing layer (RFC 9113 §4 + §6).
# Each frame type:
#   1. Construct H2Frame value
#   2. Serialize -> bytes1
#   3. Parse bytes1 -> reconstructed frame
#   4. Re-serialize -> bytes2
#   5. Assert bytes1 == bytes2 (byte-exact stability)
#   6. Assert key fields match across the round-trip
#
# Plus:
#   - R-bit (reserved) parser masking — a frame whose stream_id has the top bit
#     set MUST be parsed with R-bit ignored and stream_id = bottom 31 bits.
#   - Connection preface 24-byte literal compare.
#   - SETTINGS ACK (empty payload) and PING ACK flag combos.
#
# Out-of-scope sanity (these MUST be parser-rejected, not silently accepted):
#   - DATA on stream 0 (§6.1)
#   - SETTINGS on non-zero stream id (§6.5)
#   - PING with payload != 8 bytes (§6.7)
#   - SETTINGS payload length not multiple of 6 (§6.5)

use std.spipe.*

use std.http.h2.h2_frame.{
    H2Frame, H2DataFrame, H2HeadersFrame, H2RstStreamFrame,
    H2SettingsFrame, H2Setting, H2PingFrame, H2GoawayFrame,
    H2WindowUpdateFrame, H2PriorityFrame, H2PushPromiseFrame,
    H2ContinuationFrame,
    H2_FLAG_END_STREAM, H2_FLAG_END_HEADERS, H2_FLAG_ACK,
    H2_FRAME_HEADER_LEN,
    H2_SETTINGS_MAX_CONCURRENT_STREAMS, H2_SETTINGS_INITIAL_WINDOW_SIZE,
    H2_ERR_NO_ERROR, H2_ERR_PROTOCOL_ERROR
}
use std.http.h2.h2_writer.{h2_write_frame}
use std.http.h2.h2_parser.{h2_parse_frame, h2_parse_frame_header}
use std.http.h2.h2_preface.{h2_connection_preface_bytes, h2_validate_preface, H2_CONNECTION_PREFACE_LEN}

# ============================================================================
# Local helpers (no std byte_eq dependency to keep spec self-contained).
# ============================================================================

fn _bytes_eq(a: [u8], b: [u8]) -> bool:
    if a.len() != b.len():
        return false
    var i = 0
    loop:
        if i >= a.len():
            break
        if a[i] != b[i]:
            return false
        i = i + 1
    return true

fn _payload_three() -> [u8]:
    var p: [u8] = []
    p.push(0x68)   # 'h'
    p.push(0x69)   # 'i'
    p.push(0x21)   # '!'
    return p

fn _opaque_eight() -> [u8]:
    var p: [u8] = []
    p.push(0x01)
    p.push(0x02)
    p.push(0x03)
    p.push(0x04)
    p.push(0xfe)
    p.push(0xfd)
    p.push(0xfc)
    p.push(0xfb)
    return p

# ============================================================================
# Test Group 1: Connection preface
# ============================================================================

describe "H2 connection preface (RFC 9113 §3.4)":
    it "preface bytes are exactly 24 bytes long":
        val p = h2_connection_preface_bytes()
        expect p.len() == 24

    it "preface starts with 'PRI'":
        val p = h2_connection_preface_bytes()
        expect p[0] == 0x50
        expect p[1] == 0x52
        expect p[2] == 0x49

    it "preface ends with \\r\\n\\r\\n":
        val p = h2_connection_preface_bytes()
        expect p[20] == 0x0d
        expect p[21] == 0x0a
        expect p[22] == 0x0d
        expect p[23] == 0x0a

    it "validates a correct preface":
        val p = h2_connection_preface_bytes()
        expect h2_validate_preface(p) == true

    it "rejects a too-short buffer":
        var short: [u8] = []
        short.push(0x50)
        short.push(0x52)
        expect h2_validate_preface(short) == false

    it "rejects a corrupted preface":
        var bad = h2_connection_preface_bytes()
        # Corrupt one byte in the middle.
        bad[10] = 0x00
        expect h2_validate_preface(bad) == false


# ============================================================================
# Test Group 2: Frame header layout (RFC 9113 §4.1)
# ============================================================================

describe "H2 frame header byte layout":
    it "writes a 9-byte header for a zero-length payload":
        val empty: [u8] = []
        val ping_ack = H2Frame.Ping(H2PingFrame(flags: H2_FLAG_ACK, opaque_data: _opaque_eight()))
        val bytes = h2_write_frame(ping_ack)
        # 9 header + 8 PING payload
        expect bytes.len() == H2_FRAME_HEADER_LEN + 8

    it "encodes type byte at offset 3":
        val data_frame = H2Frame.Data(H2DataFrame(stream_id: 1, flags: 0, data: _payload_three()))
        val bytes = h2_write_frame(data_frame)
        expect bytes[3] == 0x0

    it "encodes length big-endian in first 3 bytes":
        val data_frame = H2Frame.Data(H2DataFrame(stream_id: 1, flags: 0, data: _payload_three()))
        val bytes = h2_write_frame(data_frame)
        expect bytes[0] == 0
        expect bytes[1] == 0
        expect bytes[2] == 3

    it "always writes R-bit as 0":
        # stream_id with top bit set in i64 — writer must mask it before
        # emitting the 31-bit field.
        val data_frame = H2Frame.Data(H2DataFrame(stream_id: 0xffffffff, flags: 0, data: _payload_three()))
        val bytes = h2_write_frame(data_frame)
        # byte 5 is the high byte of the 32-bit stream-id word; top bit MUST be 0.
        val top_bit = bytes[5] & 0x80
        expect top_bit == 0


# ============================================================================
# Test Group 3: Round-trip — DATA
# ============================================================================

describe "H2 DATA frame round-trip (RFC 9113 §6.1)":
    it "round-trips DATA(stream_id=1, END_STREAM, payload='hi!') byte-exact":
        val original = H2Frame.Data(H2DataFrame(
            stream_id: 1,
            flags: H2_FLAG_END_STREAM,
            data: _payload_three()
        ))
        val bytes1 = h2_write_frame(original)
        val maybe_parsed = h2_parse_frame(bytes1, 0)
        expect maybe_parsed != nil == true
        val parsed = maybe_parsed ?? H2Frame.Data(H2DataFrame(stream_id: 0, flags: 0, data: []))
        val bytes2 = h2_write_frame(parsed)
        expect _bytes_eq(bytes1, bytes2) == true

    it "preserves flags and payload across parse":
        val original = H2Frame.Data(H2DataFrame(
            stream_id: 7,
            flags: H2_FLAG_END_STREAM,
            data: _payload_three()
        ))
        val bytes1 = h2_write_frame(original)
        val maybe_parsed = h2_parse_frame(bytes1, 0)
        match maybe_parsed:
            case Some(frame):
                match frame:
                    case Data(d):
                        expect d.stream_id == 7
                        expect d.flags == H2_FLAG_END_STREAM
                        expect d.data.len() == 3
                        expect d.data[0] == 0x68
                    case _:
                        expect "wrong-variant" == "Data"
            case _:
                expect "nil-parse" == "Some(Data)"

    it "rejects DATA on stream 0 (RFC 9113 §6.1)":
        # Manually build a DATA frame on stream 0 and confirm parser refuses.
        var bytes: [u8] = []
        bytes.push(0)       # length hi
        bytes.push(0)
        bytes.push(3)       # length=3
        bytes.push(0x0)     # type=DATA
        bytes.push(0)       # flags
        bytes.push(0)       # stream id all zero
        bytes.push(0)
        bytes.push(0)
        bytes.push(0)
        bytes.push(0x68)
        bytes.push(0x69)
        bytes.push(0x21)
        val parsed = h2_parse_frame(bytes, 0)
        expect parsed == nil == true


# ============================================================================
# Test Group 4: Round-trip — HEADERS
# ============================================================================

describe "H2 HEADERS frame round-trip (RFC 9113 §6.2)":
    it "round-trips HEADERS(END_STREAM | END_HEADERS, opaque header_block) byte-exact":
        # Header block stays opaque — HPACK is W16+.
        var hb: [u8] = []
        hb.push(0x82)   # would be HPACK static-index for :method GET
        hb.push(0x86)   # would be HPACK static-index for :scheme http
        val original = H2Frame.Headers(H2HeadersFrame(
            stream_id: 3,
            flags: H2_FLAG_END_STREAM | H2_FLAG_END_HEADERS,
            header_block: hb
        ))
        val bytes1 = h2_write_frame(original)
        val maybe_parsed = h2_parse_frame(bytes1, 0)
        expect maybe_parsed != nil == true
        val parsed = maybe_parsed ?? original
        val bytes2 = h2_write_frame(parsed)
        expect _bytes_eq(bytes1, bytes2) == true


# ============================================================================
# Test Group 5: Round-trip — SETTINGS (and ACK form)
# ============================================================================

describe "H2 SETTINGS frame round-trip (RFC 9113 §6.5)":
    it "round-trips SETTINGS with two parameters byte-exact":
        var settings: [H2Setting] = []
        settings.push(H2Setting(identifier: H2_SETTINGS_MAX_CONCURRENT_STREAMS, value: 100))
        settings.push(H2Setting(identifier: H2_SETTINGS_INITIAL_WINDOW_SIZE, value: 65535))
        val original = H2Frame.Settings(H2SettingsFrame(
            flags: 0,
            settings: settings
        ))
        val bytes1 = h2_write_frame(original)
        # 9 header + 2*6 payload = 21
        expect bytes1.len() == 21
        val maybe_parsed = h2_parse_frame(bytes1, 0)
        expect maybe_parsed != nil == true
        val parsed = maybe_parsed ?? original
        val bytes2 = h2_write_frame(parsed)
        expect _bytes_eq(bytes1, bytes2) == true

    it "round-trips SETTINGS-ACK (empty payload) byte-exact":
        var empty: [H2Setting] = []
        val ack = H2Frame.Settings(H2SettingsFrame(
            flags: H2_FLAG_ACK,
            settings: empty
        ))
        val bytes1 = h2_write_frame(ack)
        # 9 header + 0 payload
        expect bytes1.len() == 9
        val maybe_parsed = h2_parse_frame(bytes1, 0)
        expect maybe_parsed != nil == true
        val parsed = maybe_parsed ?? ack
        val bytes2 = h2_write_frame(parsed)
        expect _bytes_eq(bytes1, bytes2) == true

    it "preserves setting identifier and value across parse":
        var settings: [H2Setting] = []
        settings.push(H2Setting(identifier: H2_SETTINGS_MAX_CONCURRENT_STREAMS, value: 250))
        val original = H2Frame.Settings(H2SettingsFrame(flags: 0, settings: settings))
        val bytes1 = h2_write_frame(original)
        val maybe_parsed = h2_parse_frame(bytes1, 0)
        match maybe_parsed:
            case Some(frame):
                match frame:
                    case Settings(s):
                        expect s.settings.len() == 1
                        expect s.settings[0].identifier == H2_SETTINGS_MAX_CONCURRENT_STREAMS
                        expect s.settings[0].value == 250
                    case _:
                        expect "wrong-variant" == "Settings"
            case _:
                expect "nil-parse" == "Some(Settings)"

    it "rejects SETTINGS on non-zero stream id":
        # Build a SETTINGS frame manually with stream_id=1 — illegal per §6.5.
        var bytes: [u8] = []
        bytes.push(0)
        bytes.push(0)
        bytes.push(0)       # length=0
        bytes.push(0x4)     # type=SETTINGS
        bytes.push(0)       # flags
        bytes.push(0)
        bytes.push(0)
        bytes.push(0)
        bytes.push(1)       # stream_id=1
        val parsed = h2_parse_frame(bytes, 0)
        expect parsed == nil == true

    it "rejects non-ACK SETTINGS with payload length not multiple of 6":
        var bytes: [u8] = []
        bytes.push(0)
        bytes.push(0)
        bytes.push(5)       # length=5 (not multiple of 6)
        bytes.push(0x4)     # type=SETTINGS
        bytes.push(0)       # flags=0 (not ACK)
        bytes.push(0)       # stream_id=0
        bytes.push(0)
        bytes.push(0)
        bytes.push(0)
        bytes.push(0)
        bytes.push(0)
        bytes.push(0)
        bytes.push(0)
        bytes.push(0)
        val parsed = h2_parse_frame(bytes, 0)
        expect parsed == nil == true


# ============================================================================
# Test Group 6: Round-trip — PING (and ACK form)
# ============================================================================

describe "H2 PING frame round-trip (RFC 9113 §6.7)":
    it "round-trips PING with 8-byte opaque payload byte-exact":
        val original = H2Frame.Ping(H2PingFrame(
            flags: 0,
            opaque_data: _opaque_eight()
        ))
        val bytes1 = h2_write_frame(original)
        # 9 header + 8 payload
        expect bytes1.len() == 17
        val maybe_parsed = h2_parse_frame(bytes1, 0)
        expect maybe_parsed != nil == true
        val parsed = maybe_parsed ?? original
        val bytes2 = h2_write_frame(parsed)
        expect _bytes_eq(bytes1, bytes2) == true

    it "round-trips PING-ACK byte-exact":
        val ack = H2Frame.Ping(H2PingFrame(
            flags: H2_FLAG_ACK,
            opaque_data: _opaque_eight()
        ))
        val bytes1 = h2_write_frame(ack)
        val maybe_parsed = h2_parse_frame(bytes1, 0)
        expect maybe_parsed != nil == true
        val parsed = maybe_parsed ?? ack
        val bytes2 = h2_write_frame(parsed)
        expect _bytes_eq(bytes1, bytes2) == true

    it "rejects PING with payload length != 8":
        var bytes: [u8] = []
        bytes.push(0)
        bytes.push(0)
        bytes.push(4)       # length=4 (illegal, must be exactly 8)
        bytes.push(0x6)     # type=PING
        bytes.push(0)       # flags
        bytes.push(0)       # stream_id=0
        bytes.push(0)
        bytes.push(0)
        bytes.push(0)
        bytes.push(0xaa)
        bytes.push(0xbb)
        bytes.push(0xcc)
        bytes.push(0xdd)
        val parsed = h2_parse_frame(bytes, 0)
        expect parsed == nil == true


# ============================================================================
# Test Group 7: Round-trip — GOAWAY
# ============================================================================

describe "H2 GOAWAY frame round-trip (RFC 9113 §6.8)":
    it "round-trips GOAWAY with non-empty debug_data byte-exact":
        var debug: [u8] = []
        debug.push(0x42)
        debug.push(0x55)
        debug.push(0x47)   # 'B', 'U', 'G'
        val original = H2Frame.Goaway(H2GoawayFrame(
            last_stream_id: 5,
            error_code: H2_ERR_PROTOCOL_ERROR,
            debug_data: debug
        ))
        val bytes1 = h2_write_frame(original)
        val maybe_parsed = h2_parse_frame(bytes1, 0)
        expect maybe_parsed != nil == true
        val parsed = maybe_parsed ?? original
        val bytes2 = h2_write_frame(parsed)
        expect _bytes_eq(bytes1, bytes2) == true

    it "round-trips GOAWAY with empty debug_data byte-exact":
        var empty: [u8] = []
        val original = H2Frame.Goaway(H2GoawayFrame(
            last_stream_id: 0,
            error_code: H2_ERR_NO_ERROR,
            debug_data: empty
        ))
        val bytes1 = h2_write_frame(original)
        # 9 header + 8 mandatory payload
        expect bytes1.len() == 17
        val maybe_parsed = h2_parse_frame(bytes1, 0)
        expect maybe_parsed != nil == true
        val parsed = maybe_parsed ?? original
        val bytes2 = h2_write_frame(parsed)
        expect _bytes_eq(bytes1, bytes2) == true

    it "preserves last_stream_id and error_code":
        var empty: [u8] = []
        val original = H2Frame.Goaway(H2GoawayFrame(
            last_stream_id: 99,
            error_code: H2_ERR_PROTOCOL_ERROR,
            debug_data: empty
        ))
        val bytes1 = h2_write_frame(original)
        val maybe_parsed = h2_parse_frame(bytes1, 0)
        match maybe_parsed:
            case Some(frame):
                match frame:
                    case Goaway(g):
                        expect g.last_stream_id == 99
                        expect g.error_code == H2_ERR_PROTOCOL_ERROR
                    case _:
                        expect "wrong-variant" == "Goaway"
            case _:
                expect "nil-parse" == "Some(Goaway)"


# ============================================================================
# Test Group 8: Round-trip — RST_STREAM, WINDOW_UPDATE
# ============================================================================

describe "H2 RST_STREAM and WINDOW_UPDATE round-trip (§6.4 / §6.9)":
    it "round-trips RST_STREAM byte-exact":
        val original = H2Frame.RstStream(H2RstStreamFrame(
            stream_id: 11,
            error_code: H2_ERR_PROTOCOL_ERROR
        ))
        val bytes1 = h2_write_frame(original)
        # 9 + 4
        expect bytes1.len() == 13
        val maybe_parsed = h2_parse_frame(bytes1, 0)
        val parsed = maybe_parsed ?? original
        val bytes2 = h2_write_frame(parsed)
        expect _bytes_eq(bytes1, bytes2) == true

    it "round-trips connection-level WINDOW_UPDATE byte-exact":
        val original = H2Frame.WindowUpdate(H2WindowUpdateFrame(
            stream_id: 0,
            increment: 65535
        ))
        val bytes1 = h2_write_frame(original)
        expect bytes1.len() == 13
        val maybe_parsed = h2_parse_frame(bytes1, 0)
        val parsed = maybe_parsed ?? original
        val bytes2 = h2_write_frame(parsed)
        expect _bytes_eq(bytes1, bytes2) == true


# ============================================================================
# Test Group 9: R-bit masking on read (RFC 9113 §4.1)
# ============================================================================

describe "H2 frame header R-bit masking (RFC 9113 §4.1)":
    it "parses stream_id ignoring R-bit set in incoming bytes":
        # Hand-craft a WINDOW_UPDATE on stream_id=1 with the R-bit set in the
        # raw 32-bit stream-id word (top bit). Parser MUST mask it off.
        var bytes: [u8] = []
        bytes.push(0)
        bytes.push(0)
        bytes.push(4)        # length=4
        bytes.push(0x8)      # type=WINDOW_UPDATE
        bytes.push(0)        # flags
        bytes.push(0x80)     # stream_id top byte with R-bit set
        bytes.push(0)
        bytes.push(0)
        bytes.push(1)        # stream_id low = 1, full word = 0x80000001
        bytes.push(0)
        bytes.push(0)
        bytes.push(0)
        bytes.push(10)       # increment=10
        val maybe_header = h2_parse_frame_header(bytes, 0)
        match maybe_header:
            case Some(h):
                expect h.stream_id == 1
                expect h.frame_type == 0x8
                expect h.length == 4
            case _:
                expect "nil-header" == "Some(header)"

    it "round-trips a WINDOW_UPDATE whose raw bytes had R-bit set":
        # After parsing, re-serialization MUST emit R=0 (per writer) — the
        # second-pass bytes will differ from the first only in the R-bit, so
        # we compare stream_id field instead of byte-exact.
        var bytes: [u8] = []
        bytes.push(0)
        bytes.push(0)
        bytes.push(4)
        bytes.push(0x8)
        bytes.push(0)
        bytes.push(0x80)     # R-bit set
        bytes.push(0)
        bytes.push(0)
        bytes.push(2)
        bytes.push(0)
        bytes.push(0)
        bytes.push(0)
        bytes.push(20)
        val maybe_parsed = h2_parse_frame(bytes, 0)
        match maybe_parsed:
            case Some(frame):
                match frame:
                    case WindowUpdate(w):
                        expect w.stream_id == 2
                        expect w.increment == 20
                        # Re-serialize and verify R-bit is now zero.
                        val out = h2_write_frame(frame)
                        val top = out[5] & 0x80
                        expect top == 0
                    case _:
                        expect "wrong-variant" == "WindowUpdate"
            case _:
                expect "nil-parse" == "Some(WindowUpdate)"