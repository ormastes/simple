# @cover src/lib/common/encoding/utf8.spl

use std.spec.*
use std.lib.common.encoding.utf8

describe "UTF-8 Validation":
    """
    # UTF-8 Validation Specification (AC-1)
    Tests for UTF-8 byte sequence validation, encoding/decoding invariants,
    overlong sequences, lone surrogates, and out-of-range codepoints.

    NOTE: trait header conformance `class X: Encoding` fails to parse (2026-04-26 bug).
    These tests use top-level function calls (utf8_is_valid, utf8_encode_one, etc.)
    rather than trait-dispatch. Phase 5 will wire SIMD path; Phase 7 will verify parity.
    """
    describe "valid sequences — 1-byte (ASCII)":
        """Verifies single-byte ASCII codepoints (U+0000..U+007F) validate correctly."""
        it "AC-1: single ASCII byte 0x41 ('A') is valid":
            val bytes: [i64] = [65]
            expect(utf8_is_valid(bytes)).to_equal(true)

        it "AC-1: NUL byte 0x00 is valid UTF-8":
            val bytes: [i64] = [0]
            expect(utf8_is_valid(bytes)).to_equal(true)

        it "AC-1: DEL byte 0x7F is valid UTF-8 (max 1-byte)":
            val bytes: [i64] = [127]
            expect(utf8_is_valid(bytes)).to_equal(true)

    describe "valid sequences — 2-byte":
        it "AC-1: U+00E9 (é) encodes to 2 bytes 0xC3 0xA9":
            val cp: i64 = 0xE9
            val encoded = utf8_encode_one(cp)
            expect(encoded.len()).to_equal(2)
            expect(utf8_is_valid(encoded)).to_equal(true)

        it "AC-1: U+0080 (minimum 2-byte) is valid":
            val bytes: [i64] = [0xC2, 0x80]
            expect(utf8_is_valid(bytes)).to_equal(true)

        it "AC-1: U+07FF (maximum 2-byte) is valid":
            val bytes: [i64] = [0xDF, 0xBF]
            expect(utf8_is_valid(bytes)).to_equal(true)

    describe "valid sequences — 3-byte":
        it "AC-1: U+D55C (한) encodes to 3 bytes":
            val cp: i64 = 0xD55C
            val encoded = utf8_encode_one(cp)
            expect(encoded.len()).to_equal(3)
            expect(utf8_is_valid(encoded)).to_equal(true)

        it "AC-1: U+AC00 (가, Hangul syllable base) is valid":
            val cp: i64 = 0xAC00
            val encoded = utf8_encode_one(cp)
            expect(encoded.len()).to_equal(3)
            expect(utf8_is_valid(encoded)).to_equal(true)

        it "AC-1: U+4E2D (中) encodes to 3 bytes":
            val cp: i64 = 0x4E2D
            val encoded = utf8_encode_one(cp)
            expect(encoded.len()).to_equal(3)
            expect(utf8_is_valid(encoded)).to_equal(true)

    describe "valid sequences — 4-byte":
        it "AC-1: U+1F600 (emoji) encodes to 4 bytes":
            val cp: i64 = 0x1F600
            val encoded = utf8_encode_one(cp)
            expect(encoded.len()).to_equal(4)
            expect(utf8_is_valid(encoded)).to_equal(true)

        it "AC-1: U+10000 (minimum 4-byte) is valid":
            val bytes: [i64] = [0xF0, 0x90, 0x80, 0x80]
            expect(utf8_is_valid(bytes)).to_equal(true)

        it "AC-1: U+10FFFF (maximum valid codepoint) is valid":
            val bytes: [i64] = [0xF4, 0x8F, 0xBF, 0xBF]
            expect(utf8_is_valid(bytes)).to_equal(true)

    describe "invalid: overlong sequences":
        it "AC-1: overlong NUL (0xC0 0x80) is invalid":
            val bytes: [i64] = [0xC0, 0x80]
            expect(utf8_is_valid(bytes)).to_equal(false)

        it "AC-1: overlong 0xE0 0x80 0x80 is invalid":
            val bytes: [i64] = [0xE0, 0x80, 0x80]
            expect(utf8_is_valid(bytes)).to_equal(false)

        it "AC-1: overlong 0xF0 0x80 0x80 0x80 is invalid":
            val bytes: [i64] = [0xF0, 0x80, 0x80, 0x80]
            expect(utf8_is_valid(bytes)).to_equal(false)

    describe "invalid: lone surrogates":
        it "AC-1: U+D800 (low surrogate as 3-byte UTF-8) is invalid":
            # 0xED 0xA0 0x80 encodes U+D800 — lone surrogate
            val bytes: [i64] = [0xED, 0xA0, 0x80]
            expect(utf8_is_valid(bytes)).to_equal(false)

        it "AC-1: U+DFFF (high surrogate as 3-byte UTF-8) is invalid":
            # 0xED 0xBF 0xBF encodes U+DFFF
            val bytes: [i64] = [0xED, 0xBF, 0xBF]
            expect(utf8_is_valid(bytes)).to_equal(false)

    describe "invalid: codepoints beyond U+10FFFF":
        it "AC-1: 0xF4 0x90 0x80 0x80 (U+110000) is invalid":
            val bytes: [i64] = [0xF4, 0x90, 0x80, 0x80]
            expect(utf8_is_valid(bytes)).to_equal(false)

    describe "invalid: truncated sequences":
        it "AC-1: lone continuation byte 0x80 is invalid":
            val bytes: [i64] = [0x80]
            expect(utf8_is_valid(bytes)).to_equal(false)

        it "AC-1: 2-byte lead with no continuation is invalid":
            val bytes: [i64] = [0xC3]
            expect(utf8_is_valid(bytes)).to_equal(false)

    describe "BOM handling":
        it "AC-1: UTF-8 BOM sequence 0xEF 0xBB 0xBF is valid UTF-8 bytes":
            # BOM is codepoint U+FEFF encoded as 3 bytes — valid UTF-8
            val bytes: [i64] = [0xEF, 0xBB, 0xBF]
            expect(utf8_is_valid(bytes)).to_equal(true)

    describe "round-trip encode/decode":
        it "AC-1: encode then decode U+D55C (한) returns same codepoint":
            val cp: i64 = 0xD55C
            val encoded = utf8_encode_one(cp)
            val decoded = utf8_decode_one(encoded, 0)
            expect(decoded[0]).to_equal(cp)

        it "AC-1: encode then decode U+1F600 (emoji) returns same codepoint":
            val cp: i64 = 0x1F600
            val encoded = utf8_encode_one(cp)
            val decoded = utf8_decode_one(encoded, 0)
            expect(decoded[0]).to_equal(cp)

        it "AC-1: text_codepoint_len matches utf8_count_codepoints for ASCII":
            val s = "hello"
            expect(text_codepoint_len(s)).to_equal(5)

        it "AC-1: text_byte_len returns 3 for single Hangul syllable 한":
            val s = "한"
            expect(text_byte_len(s)).to_equal(3)

        it "AC-1: text_codepoint_len returns 1 for single Hangul syllable 한":
            val s = "한"
            expect(text_codepoint_len(s)).to_equal(1)
