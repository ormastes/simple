use std.spec
use std.gc_sync_mut.{gc_make_rc, gc_make_arc}

describe "gc_sync_mut rc":
    it "gc rc stores and clones value":
        val r1 = gc_make_rc(41)
        val r2 = r1.clone()
        expect r1.borrow() == 41
        expect r2.borrow() == 41
        expect r1.strong_count() == 1
        expect r1.weak_count() == 0

    it "gc arc downgrade upgrades successfully":
        val a = gc_make_arc(77)
        val w = a.downgrade()
        expect w.upgrade() == Some(77)
        expect w.strong_count() == 1
        expect w.weak_count() == 0