use std.spec

use std.gc_sync_mut.ptr.{
    unique_new as gc_unique_new_std, unique_get as gc_unique_get_std, unique_move as gc_unique_move_std, unique_reset as gc_unique_reset_std,
    unique_invalidate as gc_unique_invalidate_std, unique_into_inner as gc_unique_into_inner_std, unique_is_valid as gc_unique_is_valid_std,
    weak_register as gc_weak_register, weak_create as gc_weak_create, weak_upgrade as gc_weak_upgrade, weak_invalidate as gc_weak_invalidate, weak_reset as gc_weak_reset,
    weak_is_alive as gc_weak_is_alive, weak_add_strong as gc_weak_add_strong, weak_remove_strong as gc_weak_remove_strong, weak_strong_count as gc_weak_strong_count,
    handle_pool_new as gc_handle_pool_new, handle_alloc as gc_handle_alloc, handle_deref as gc_handle_deref, handle_free as gc_handle_free,
    handle_pool_size as gc_handle_pool_size, handle_pool_capacity as gc_handle_pool_capacity,
    ptr_state_valid as gc_ptr_state_valid, ptr_state_moved as gc_ptr_state_moved, ptr_state_expired as gc_ptr_state_expired
}

use std.nogc_sync_mut.ptr.{
    unique_new as ngs_unique_new, unique_get as ngs_unique_get, unique_move as ngs_unique_move, unique_reset as ngs_unique_reset,
    unique_invalidate as ngs_unique_invalidate, unique_into_inner as ngs_unique_into_inner, unique_is_valid as ngs_unique_is_valid,
    weak_register as ngs_weak_register, weak_create as ngs_weak_create, weak_upgrade as ngs_weak_upgrade, weak_invalidate as ngs_weak_invalidate, weak_reset as ngs_weak_reset,
    weak_is_alive as ngs_weak_is_alive, weak_add_strong as ngs_weak_add_strong, weak_remove_strong as ngs_weak_remove_strong, weak_strong_count as ngs_weak_strong_count,
    handle_pool_new as ngs_handle_pool_new, handle_alloc as ngs_handle_alloc, handle_deref as ngs_handle_deref, handle_free as ngs_handle_free,
    handle_pool_size as ngs_handle_pool_size, handle_pool_capacity as ngs_handle_pool_capacity,
    ptr_state_valid as ngs_ptr_state_valid, ptr_state_moved as ngs_ptr_state_moved, ptr_state_expired as ngs_ptr_state_expired
}

use std.nogc_async_mut.ptr.{
    unique_new as nga_unique_new, unique_get as nga_unique_get, unique_move as nga_unique_move, unique_reset as nga_unique_reset,
    unique_invalidate as nga_unique_invalidate, unique_into_inner as nga_unique_into_inner, unique_is_valid as nga_unique_is_valid,
    weak_register as nga_weak_register, weak_create as nga_weak_create, weak_upgrade as nga_weak_upgrade, weak_invalidate as nga_weak_invalidate, weak_reset as nga_weak_reset,
    weak_is_alive as nga_weak_is_alive, weak_add_strong as nga_weak_add_strong, weak_remove_strong as nga_weak_remove_strong, weak_strong_count as nga_weak_strong_count,
    handle_pool_new as nga_handle_pool_new, handle_alloc as nga_handle_alloc, handle_deref as nga_handle_deref, handle_free as nga_handle_free,
    handle_pool_size as nga_handle_pool_size, handle_pool_capacity as nga_handle_pool_capacity,
    ptr_state_valid as nga_ptr_state_valid, ptr_state_moved as nga_ptr_state_moved, ptr_state_expired as nga_ptr_state_expired
}

use std.gc_sync_mut.{gc_make_rc}

describe "gc_sync_mut ptr parity":
    it "unique pointer move semantics match across all three variants":
        gc_unique_reset_std()
        val p_gc = gc_unique_new_std(123, "x")
        val p2_gc = gc_unique_move_std(p_gc)
        expect gc_unique_get_std(p_gc) == -1
        expect gc_unique_get_std(p2_gc) == 123

        ngs_unique_reset()
        val p_ngs = ngs_unique_new(123, "x")
        val p2_ngs = ngs_unique_move(p_ngs)
        expect ngs_unique_get(p_ngs) == -1
        expect ngs_unique_get(p2_ngs) == 123

        nga_unique_reset()
        val p_nga = nga_unique_new(123, "x")
        val p2_nga = nga_unique_move(p_nga)
        expect nga_unique_get(p_nga) == -1
        expect nga_unique_get(p2_nga) == 123

    it "weak references expire the same way across all three variants":
        gc_weak_reset()
        val id_gc = gc_weak_register(55)
        val w_gc = gc_weak_create(id_gc)
        expect gc_weak_upgrade(w_gc) == 55
        gc_weak_invalidate(id_gc)
        expect gc_weak_upgrade(w_gc) == -1

        ngs_weak_reset()
        val id_ngs = ngs_weak_register(55)
        val w_ngs = ngs_weak_create(id_ngs)
        expect ngs_weak_upgrade(w_ngs) == 55
        ngs_weak_invalidate(id_ngs)
        expect ngs_weak_upgrade(w_ngs) == -1

        nga_weak_reset()
        val id_nga = nga_weak_register(55)
        val w_nga = nga_weak_create(id_nga)
        expect nga_weak_upgrade(w_nga) == 55
        nga_weak_invalidate(id_nga)
        expect nga_weak_upgrade(w_nga) == -1

    it "handle stale-reference behavior matches across all three variants":
        gc_handle_pool_new(8)
        val h_gc = gc_handle_alloc(9)
        expect gc_handle_deref(h_gc) == 9
        expect gc_handle_free(h_gc) == true
        expect gc_handle_deref(h_gc) == -1

        ngs_handle_pool_new(8)
        val h_ngs = ngs_handle_alloc(9)
        expect ngs_handle_deref(h_ngs) == 9
        expect ngs_handle_free(h_ngs) == true
        expect ngs_handle_deref(h_ngs) == -1

        nga_handle_pool_new(8)
        val h_nga = nga_handle_alloc(9)
        expect nga_handle_deref(h_nga) == 9
        expect nga_handle_free(h_nga) == true
        expect nga_handle_deref(h_nga) == -1

    it "covers remaining shared ptr api contracts":
        # ptr_state helpers
        val st_g_v = gc_ptr_state_valid()
        val st_s_v = ngs_ptr_state_valid()
        val st_a_v = nga_ptr_state_valid()
        expect st_g_v.valid == st_s_v.valid
        expect st_g_v.valid == st_a_v.valid

        val st_g_m = gc_ptr_state_moved()
        val st_s_m = ngs_ptr_state_moved()
        val st_a_m = nga_ptr_state_moved()
        expect st_g_m.moved == st_s_m.moved
        expect st_g_m.moved == st_a_m.moved

        val st_g_e = gc_ptr_state_expired()
        val st_s_e = ngs_ptr_state_expired()
        val st_a_e = nga_ptr_state_expired()
        expect st_g_e.expired == st_s_e.expired
        expect st_g_e.expired == st_a_e.expired

        # unique helpers
        gc_unique_reset_std()
        val ug = gc_unique_new_std(10, "u")
        expect gc_unique_is_valid_std(ug) == true
        gc_unique_invalidate_std(ug.id)
        expect gc_unique_is_valid_std(ug) == false

        ngs_unique_reset()
        val us = ngs_unique_new(10, "u")
        expect ngs_unique_is_valid(us) == true
        ngs_unique_invalidate(us.id)
        expect ngs_unique_is_valid(us) == false

        nga_unique_reset()
        val ua = nga_unique_new(10, "u")
        expect nga_unique_is_valid(ua) == true
        nga_unique_invalidate(ua.id)
        expect nga_unique_is_valid(ua) == false

        gc_unique_reset_std()
        val ug2 = gc_unique_new_std(77, "u2")
        expect gc_unique_into_inner_std(ug2) == 77
        expect gc_unique_get_std(ug2) == -1

        ngs_unique_reset()
        val us2 = ngs_unique_new(77, "u2")
        expect ngs_unique_into_inner(us2) == 77
        expect ngs_unique_get(us2) == -1

        nga_unique_reset()
        val ua2 = nga_unique_new(77, "u2")
        expect nga_unique_into_inner(ua2) == 77
        expect nga_unique_get(ua2) == -1

        # weak strong-count helpers
        gc_weak_reset()
        val wg_id = gc_weak_register(5)
        val wg = gc_weak_create(wg_id)
        expect gc_weak_is_alive(wg) == true
        expect gc_weak_strong_count(wg_id) == 1
        gc_weak_add_strong(wg_id)
        expect gc_weak_strong_count(wg_id) == 2
        gc_weak_remove_strong(wg_id)
        expect gc_weak_strong_count(wg_id) == 1

        ngs_weak_reset()
        val ws_id = ngs_weak_register(5)
        val ws = ngs_weak_create(ws_id)
        expect ngs_weak_is_alive(ws) == true
        expect ngs_weak_strong_count(ws_id) == 1
        ngs_weak_add_strong(ws_id)
        expect ngs_weak_strong_count(ws_id) == 2
        ngs_weak_remove_strong(ws_id)
        expect ngs_weak_strong_count(ws_id) == 1

        nga_weak_reset()
        val wa_id = nga_weak_register(5)
        val wa = nga_weak_create(wa_id)
        expect nga_weak_is_alive(wa) == true
        expect nga_weak_strong_count(wa_id) == 1
        nga_weak_add_strong(wa_id)
        expect nga_weak_strong_count(wa_id) == 2
        nga_weak_remove_strong(wa_id)
        expect nga_weak_strong_count(wa_id) == 1

        # handle pool size/capacity
        gc_handle_pool_new(3)
        expect gc_handle_pool_capacity() == 3
        val h0g = gc_handle_alloc(1)
        expect gc_handle_pool_size() == 1
        gc_handle_free(h0g)
        expect gc_handle_pool_size() == 0

        ngs_handle_pool_new(3)
        expect ngs_handle_pool_capacity() == 3
        val h0s = ngs_handle_alloc(1)
        expect ngs_handle_pool_size() == 1
        ngs_handle_free(h0s)
        expect ngs_handle_pool_size() == 0

        nga_handle_pool_new(3)
        expect nga_handle_pool_capacity() == 3
        val h0a = nga_handle_alloc(1)
        expect nga_handle_pool_size() == 1
        nga_handle_free(h0a)
        expect nga_handle_pool_size() == 0

describe "gc_sync_mut rc contract":
    it "gc_make_rc provides no-op reference-count wrapper semantics":
        val r = gc_make_rc(7)
        expect r.borrow() == 7
        expect r.strong_count() == 1
        expect r.weak_count() == 0