# GPU Graphics Context Tests
# Tests graphics type construction and method dispatch with None backend

use std.spec.{describe, it, expect}
use std.gpu.graphics.{GpuFormat, GpuTextureUsage, GpuTextureDesc, GpuTexture, GpuRenderPassDesc, GpuRenderPass, GpuLoadOp, GpuStoreOp, GpuBlendMode, GpuTopology, GpuVertexFormat, GpuVertexAttribute, GpuVertexLayout, GpuShaderStage, GpuShader, GpuPipelineDesc, GpuGraphicsPipeline, GpuSwapchainDesc, GpuSwapchain, GpuFramebuffer}
use std.common.gpu.device.{GpuBackend, preferred_graphics_backend}

describe "GpuFormat":
    it "reports bytes per pixel":
        val rgba = GpuFormat.RGBA8
        expect rgba.bytes_per_pixel() == 4
        val r8 = GpuFormat.R8
        expect r8.bytes_per_pixel() == 1
        val rgb = GpuFormat.RGB8
        expect rgb.bytes_per_pixel() == 3

    it "identifies depth formats":
        val d32 = GpuFormat.Depth32F
        expect d32.is_depth() == true
        val rgba = GpuFormat.RGBA8
        expect rgba.is_depth() == false

    it "converts to text":
        expect GpuFormat.BGRA8.to_text() == "BGRA8"
        expect GpuFormat.Depth24Stencil8.to_text() == "Depth24Stencil8"

describe "GpuTexture":
    it "creates with descriptor fields":
        val tex = GpuTexture(handle: 1, width: 256, height: 256, format: GpuFormat.RGBA8)
        expect tex.is_valid() == true
        expect tex.size_bytes() == 262144

    it "invalid when handle is zero":
        val tex = GpuTexture(handle: 0, width: 0, height: 0, format: GpuFormat.RGBA8)
        expect tex.is_valid() == false

describe "GpuRenderPass":
    it "validates handle":
        val rp = GpuRenderPass(handle: 42)
        expect rp.is_valid() == true
        val bad = GpuRenderPass(handle: 0)
        expect bad.is_valid() == false

describe "GpuBlendMode":
    it "converts to text":
        expect GpuBlendMode.AlphaBlend.to_text() == "AlphaBlend"
        expect GpuBlendMode.Additive.to_text() == "Additive"

describe "GpuTopology":
    it "converts to text":
        expect GpuTopology.TriangleList.to_text() == "TriangleList"
        expect GpuTopology.LineStrip.to_text() == "LineStrip"

describe "GpuVertexFormat":
    it "reports size in bytes":
        expect GpuVertexFormat.Float2.size_bytes() == 8
        expect GpuVertexFormat.Float3.size_bytes() == 12
        expect GpuVertexFormat.Float4.size_bytes() == 16
        expect GpuVertexFormat.UByte4.size_bytes() == 4

describe "GpuShader":
    it "validates handle":
        val vs = GpuShader(handle: 1, stage: GpuShaderStage.Vertex)
        expect vs.is_valid() == true
        expect vs.stage.to_text() == "Vertex"

describe "GpuGraphicsPipeline":
    it "validates handle":
        val pipe = GpuGraphicsPipeline(handle: 5)
        expect pipe.is_valid() == true

describe "GpuSwapchain":
    it "validates and stores dimensions":
        val sc = GpuSwapchain(handle: 1, width: 1920, height: 1080, format: GpuFormat.BGRA8)
        expect sc.is_valid() == true
        expect sc.width == 1920

describe "GpuFramebuffer":
    it "reports pixel count":
        val fb = GpuFramebuffer(handle: 1, width: 800, height: 600)
        expect fb.size_pixels() == 480000

describe "preferred_graphics_backend":
    it "returns a valid backend":
        val backend = preferred_graphics_backend()
        # Should return Vulkan as default
        expect backend.to_text() == "Vulkan"