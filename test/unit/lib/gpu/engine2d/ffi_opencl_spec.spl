# @cover src/lib/gc_async_mut/gpu/engine2d/sffi_opencl.spl 50%
# @tag: unit, gpu, engine2d, opencl, ffi

use std.spec.{describe, it, expect}
use std.gpu.engine2d.sffi_dispatch.{GpuFfiMode}
use std.gpu.engine2d.sffi_opencl.{OpenClFfi}

describe "OpenClFfi":

    it "exposes a static generic ICD wrapper":
        val ffi = OpenClFfi.create_static()
        expect(ffi.mode() == GpuFfiMode.Static).to_equal(true)

    it "fails closed instead of dispatching a name-only OpenCL kernel":
        val ffi = OpenClFfi.create_static()
        expect(ffi.launch_kernel("simple_2d_fill_u32", 1, 1, 1, 1, 1, 1)).to_equal(false)

    it "fails closed for lifecycle calls until a native OpenCL runtime owns handles":
        val ffi = OpenClFfi.create_static()
        val context = ffi.create_context(1)
        val queue = ffi.create_queue(context)
        val program = ffi.create_program(context, "__kernel void simple_2d_fill_u32() {}")
        val kernel = ffi.create_kernel(program, "simple_2d_fill_u32")

        expect(context).to_equal(0)
        expect(queue).to_equal(0)
        expect(program).to_equal(0)
        expect(ffi.build_program(program)).to_equal(false)
        expect(kernel).to_equal(0)
        expect(ffi.enqueue_ndrange(queue, kernel, 1, 1, 1, 1, 1, 1)).to_equal(false)
        expect(ffi.finish(queue)).to_equal(false)
