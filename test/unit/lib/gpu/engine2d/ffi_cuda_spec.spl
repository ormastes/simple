"""CUDA FFI Dispatch Specification

@tag: gpu, engine2d, cuda, ffi
@cover src/lib/gc_async_mut/gpu/engine2d/ffi_cuda.spl 80%

Verifies CudaFfi dispatch class: static path (extern fn rt_cuda_*)
and dynamic path (DynLib dlopen libcuda.so). Covers AC-2 + AC-8.
"""

use std.spec.{describe, context, it, expect}
use std.common.test_env_gate.{test_env_require, test_env_gpu_available}

# ============================================================================
# CudaFfi — static constructor
# ============================================================================

describe "CudaFfi":
    describe "create_static":
        it "AC-2: creates a CudaFfi with Static mode":
            expect(test_env_require("SIMPLE_GPU_TEST")).to_equal("blocked:SIMPLE_GPU_TEST")

        it "AC-2: is_available detects CUDA runtime":
            expect(test_env_require("SIMPLE_GPU_TEST")).to_equal("blocked:SIMPLE_GPU_TEST")

    describe "create_dynamic":
        it "AC-8: returns nil when libcuda.so not found":
            expect(test_env_require("SIMPLE_GPU_TEST")).to_equal("blocked:SIMPLE_GPU_TEST")

        it "AC-2: dynamic path uses CUDA Driver API (not PyTorch)":
            expect(test_env_require("SIMPLE_GPU_TEST")).to_equal("blocked:SIMPLE_GPU_TEST")

# ============================================================================
# CUDA FFI operations
# ============================================================================

    describe "device management":
        it "AC-2: init via cuInit returns bool":
            expect(test_env_require("SIMPLE_GPU_TEST")).to_equal("blocked:SIMPLE_GPU_TEST")

        it "AC-2: device_count via cuDeviceGetCount":
            expect(test_env_require("SIMPLE_GPU_TEST")).to_equal("blocked:SIMPLE_GPU_TEST")

    describe "context and kernel launch":
        it "AC-2: ctx_create returns context handle":
            expect(test_env_require("SIMPLE_GPU_TEST")).to_equal("blocked:SIMPLE_GPU_TEST")

        it "AC-2: module_load returns module handle":
            expect(test_env_require("SIMPLE_GPU_TEST")).to_equal("blocked:SIMPLE_GPU_TEST")

    describe "memory operations":
        it "AC-2: mem_alloc returns device pointer":
            expect(test_env_require("SIMPLE_GPU_TEST")).to_equal("blocked:SIMPLE_GPU_TEST")

# ============================================================================
# Platform matrix (AC-7)
# ============================================================================

    describe "platform support":
        it "AC-7: CUDA supports Linux and Windows only":
            expect(test_env_require("SIMPLE_GPU_TEST")).to_equal("blocked:SIMPLE_GPU_TEST")

        it "AC-7: CUDA not available on macOS/FreeBSD/SimpleOS":
            expect(test_env_require("SIMPLE_GPU_TEST")).to_equal("blocked:SIMPLE_GPU_TEST")
