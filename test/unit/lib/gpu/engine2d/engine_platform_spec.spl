"""Engine2D Platform-Aware Backend Selection Specification

@tag: gpu, engine2d, engine, platform, priority
@cover src/lib/gc_async_mut/gpu/engine2d/engine.spl 60%

Verifies Engine2D platform-aware backend selection, Qualcomm backend
integration, and FFI dispatch mode passing. Covers AC-7, AC-8.
"""

use std.spec.{describe, context, it, expect}
use std.common.test_env_gate.{test_env_require, test_env_gpu_available}

# ============================================================================
# Engine2D platform-aware creation
# ============================================================================

describe "Engine2D":
    describe "create (updated)":
        it "AC-7: uses platform-aware detection":
            expect(test_env_require("SIMPLE_GPU_TEST")).to_equal("blocked:SIMPLE_GPU_TEST")

        it "AC-8: accepts optional FfiMode":
            expect(test_env_require("SIMPLE_GPU_TEST")).to_equal("blocked:SIMPLE_GPU_TEST")

    describe "create_with_backend (updated)":
        it "AC-5: supports qualcomm backend name":
            expect(test_env_require("SIMPLE_GPU_TEST")).to_equal("blocked:SIMPLE_GPU_TEST")

        it "AC-1: vulkan backend still selectable":
            expect(test_env_require("SIMPLE_GPU_TEST")).to_equal("blocked:SIMPLE_GPU_TEST")

        it "AC-2: cuda backend still selectable":
            expect(test_env_require("SIMPLE_GPU_TEST")).to_equal("blocked:SIMPLE_GPU_TEST")

        it "AC-3: rocm backend selectable":
            expect(test_env_require("SIMPLE_GPU_TEST")).to_equal("blocked:SIMPLE_GPU_TEST")

        it "AC-4: intel backend selectable":
            expect(test_env_require("SIMPLE_GPU_TEST")).to_equal("blocked:SIMPLE_GPU_TEST")

# ============================================================================
# FFI dispatch integration
# ============================================================================

    describe "FFI dispatch mode":
        it "AC-8: dynamic mode tries dlopen first":
            expect(test_env_require("SIMPLE_GPU_TEST")).to_equal("blocked:SIMPLE_GPU_TEST")

        it "AC-8: static mode uses extern fn":
            expect(test_env_require("SIMPLE_GPU_TEST")).to_equal("blocked:SIMPLE_GPU_TEST")

        it "AC-8: fallback to CPU when no GPU backend available":
            expect(test_env_require("SIMPLE_GPU_TEST")).to_equal("blocked:SIMPLE_GPU_TEST")
