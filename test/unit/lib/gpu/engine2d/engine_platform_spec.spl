"""Engine2D Platform-Aware Backend Selection Specification

@tag: gpu, engine2d, engine, platform, priority
@cover src/lib/gc_async_mut/gpu/engine2d/engine.spl 60%

Verifies Engine2D platform-aware backend selection, Qualcomm backend
integration, and FFI dispatch mode passing. Covers AC-7, AC-8.
"""

use std.spec.{describe, context, it, expect}

# ============================================================================
# Engine2D platform-aware creation
# ============================================================================

describe "Engine2D":
    describe "create (updated)":
        it "AC-7: uses platform-aware detection":
            val engine = Engine2D.create(64, 64)
            val name = engine.backend_name()
            expect(name.len()).to_be_greater_than(0)
            engine.shutdown()

        it "AC-8: accepts optional FfiMode":
            val engine = Engine2D.create_with_ffi_mode(64, 64, GpuFfiMode.Dynamic)
            val name = engine.backend_name()
            expect(name.len()).to_be_greater_than(0)
            engine.shutdown()

    describe "create_with_backend (updated)":
        it "AC-5: supports qualcomm backend name":
            val engine = Engine2D.create_with_backend(64, 64, "qualcomm")
            val name = engine.backend_name()
            val valid = name == "qualcomm" or name == "vulkan" or name == "cpu"
            expect(valid).to_equal(true)
            engine.shutdown()

        it "AC-1: vulkan backend still selectable":
            val engine = Engine2D.create_with_backend(64, 64, "vulkan")
            val name = engine.backend_name()
            val valid = name == "vulkan" or name == "cpu"
            expect(valid).to_equal(true)
            engine.shutdown()

        it "AC-2: cuda backend still selectable":
            val engine = Engine2D.create_with_backend(64, 64, "cuda")
            val name = engine.backend_name()
            val valid = name == "cuda" or name == "cpu"
            expect(valid).to_equal(true)
            engine.shutdown()

        it "AC-3: rocm backend selectable":
            val engine = Engine2D.create_with_backend(64, 64, "rocm")
            val name = engine.backend_name()
            val valid = name == "rocm" or name == "cpu"
            expect(valid).to_equal(true)
            engine.shutdown()

        it "AC-4: intel backend selectable":
            val engine = Engine2D.create_with_backend(64, 64, "intel")
            val name = engine.backend_name()
            val valid = name == "intel" or name == "cpu"
            expect(valid).to_equal(true)
            engine.shutdown()

# ============================================================================
# FFI dispatch integration
# ============================================================================

    describe "FFI dispatch mode":
        it "AC-8: dynamic mode tries dlopen first":
            val engine = Engine2D.create_with_ffi_mode(64, 64, GpuFfiMode.Dynamic)
            val name = engine.backend_name()
            expect(name.len()).to_be_greater_than(0)
            engine.shutdown()

        it "AC-8: static mode uses extern fn":
            val engine = Engine2D.create_with_ffi_mode(64, 64, GpuFfiMode.Static)
            val name = engine.backend_name()
            expect(name.len()).to_be_greater_than(0)
            engine.shutdown()

        it "AC-8: fallback to CPU when no GPU backend available":
            val engine = Engine2D.create_with_ffi_mode(64, 64, GpuFfiMode.Dynamic)
            val name = engine.backend_name()
            val valid = name == "software" or name == "cpu" or name.len() > 0
            expect(valid).to_equal(true)
            engine.shutdown()
