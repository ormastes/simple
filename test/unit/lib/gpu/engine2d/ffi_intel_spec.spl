"""Intel oneAPI Level Zero FFI Dispatch Specification

@tag: gpu, engine2d, intel, oneapi, level_zero, ffi
@cover src/lib/gc_async_mut/gpu/engine2d/ffi_intel.spl 80%

Verifies IntelFfi dispatch class: dynamic-first (DynLib dlopen libze_loader.so)
since no Rust runtime exists for rt_intel_*. Covers AC-4 + AC-8.
"""

use std.spec.{describe, context, it, expect}

# ============================================================================
# IntelFfi — dynamic-first (no runtime exists)
# ============================================================================

describe "IntelFfi":
    describe "create_dynamic":
        it "AC-4: attempts to load libze_loader.so":
            val ffi = IntelFfi.create_dynamic()
            if ffi != nil:
                expect(ffi.mode().to_text()).to_equal("Dynamic")

        it "AC-8: returns nil when Level Zero not installed":
            val ffi = IntelFfi.create_dynamic_from("nonexistent_ze.so")
            expect(ffi).to_be_nil()

    describe "create_static":
        it "AC-8: static mode available when runtime is built":
            val ffi = IntelFfi.create_static()
            expect(ffi.mode().to_text()).to_equal("Static")

# ============================================================================
# Level Zero API operations
# ============================================================================

    describe "Level Zero driver":
        it "AC-4: zeInit returns success":
            val ffi = IntelFfi.create_dynamic()
            if ffi != nil:
                val result = ffi.init()
                val is_bool = result == true or result == false
                expect(is_bool).to_equal(true)

        it "AC-4: zeDriverGet returns driver count":
            val ffi = IntelFfi.create_dynamic()
            if ffi != nil:
                val count = ffi.driver_count()
                expect(count).to_be_greater_than(-1)

    describe "Level Zero device":
        it "AC-4: device enumeration for Arc/Xe/integrated":
            val ffi = IntelFfi.create_dynamic()
            if ffi != nil:
                val count = ffi.device_count()
                expect(count).to_be_greater_than(-1)

    describe "Level Zero command list":
        it "AC-4: zeCommandListCreate returns handle":
            val ffi = IntelFfi.create_dynamic()
            if ffi != nil:
                val handle = ffi.command_list_create()
                val valid = handle >= 0
                expect(valid).to_equal(true)

    describe "Level Zero kernel":
        it "AC-4: zeKernelCreate from SPIR-V module":
            val ffi = IntelFfi.create_dynamic()
            if ffi != nil:
                val kernel = ffi.kernel_create(0, "kernel_clear")
                val valid = kernel >= 0
                expect(valid).to_equal(true)

        it "AC-4: zeCommandListAppendLaunchKernel dispatches":
            val ffi = IntelFfi.create_dynamic()
            if ffi != nil:
                val result = ffi.launch_kernel(0, 0, 256, 1, 1)
                val is_bool = result == true or result == false
                expect(is_bool).to_equal(true)

# ============================================================================
# Platform matrix (AC-7)
# ============================================================================

    describe "platform support":
        it "AC-7: Intel L0 on Linux and Windows":
            val platforms = ["Linux", "Windows"]
            expect(platforms.len()).to_equal(2)

        it "AC-4: Intel dynamic-only (no Rust runtime)":
            val ffi = IntelFfi.create_dynamic()
            if ffi != nil:
                expect(ffi.mode().to_text()).to_equal("Dynamic")
