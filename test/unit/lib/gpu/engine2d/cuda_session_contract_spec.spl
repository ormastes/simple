# @cover src/lib/gc_async_mut/gpu/engine2d/cuda_session.spl 60%
# @tag: unit, gpu, engine2d, cuda, session, compute

use std.gc_async_mut.cuda.{cuda_available}
use std.gc_async_mut.gpu.engine2d.backend_session.{BackendSessionKind}
use std.gc_async_mut.gpu.engine2d.cuda_session.{CudaSession}

describe "CudaSession compute contract":

    it "reports CUDA kind and availability without initializing hardware":
        val session = CudaSession.create()

        expect(session.kind() == BackendSessionKind.Cuda).to_equal(true)
        expect(session.is_available()).to_equal(cuda_available())
        expect(session.is_valid()).to_equal(false)

    it "fails closed when launching without a loaded module":
        val session = CudaSession.create()

        expect(session.launch_kernel("kernel_clear", 1, 1, 1, 1)).to_equal(1)

    it "shutdown is safe on an uninitialized session":
        var session = CudaSession.create()

        session.shutdown()
        expect(session.is_valid()).to_equal(false)
        expect(session.ref_count).to_equal(0)
