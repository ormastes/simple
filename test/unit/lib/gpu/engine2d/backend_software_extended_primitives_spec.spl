"""Software Backend Extended Primitive Rendering Specification

@tag: gpu, engine2d, software, rendering
@cover src/lib/gc_async_mut/gpu/engine2d/backend_software.spl 20%

Regression guard for extended SoftwareBackend methods that previously
delegated to missing/free `emu_*` helpers.
"""

use std.spec.{describe, it, expect}
use std.gc_async_mut.gpu.engine2d.backend_software.{SoftwareBackend}

val BG: u32 = 0xFF000000u32

fn count_non_bg(pixels: [u32]) -> i32:
    var count = 0
    var i = 0
    while i < pixels.len():
        if pixels[i] != BG:
            count = count + 1
        i = i + 1
    count

describe "SoftwareBackend extended primitive rendering":
    it "draws extended primitives without missing emu helpers":
        var b = SoftwareBackend.create()
        if b.init(48, 48):
            b.clear(BG)
            b.draw_ellipse(12, 12, 6, 4, 0xFFFF0000u32)
            b.draw_ellipse_filled(30, 12, 6, 4, 0xFF00FF00u32)
            b.draw_rect_thick(2, 24, 12, 10, 0xFF0000FFu32, 3)
            b.draw_circle_thick(28, 30, 6, 0xFFFFFF00u32, 2)
            b.draw_gradient_rect_h(4, 38, 24, 6, 0xFFFF00FFu32, 0xFF00FFFFu32)
            val p = b.read_pixels()
            expect(count_non_bg(p) > 100).to_equal(true)
            b.shutdown()
