# @cover src/lib/gc_async_mut/gpu/engine2d/compute_dispatch.spl 70%
# @tag: unit, gpu, engine2d, compute, dispatch

use std.spec.{describe, it, expect}
use std.gpu.engine2d.backend_probe.{BackendStatus}
use std.gpu.engine2d.compute_dispatch.{ComputeDispatch, compute_dispatch_auto}

fn _valid_dispatch_name(name: text) -> bool:
    name == "cuda" or name == "rocm" or name == "opencl" or name == "cpu_simd_x86" or name == "cpu_simd_arm" or name == "cpu_simd_riscv" or name == "cpu"

describe "ComputeDispatch":

    it "selects the best available compute backend in policy order":
        val result = ComputeDispatch.auto()

        expect(_valid_dispatch_name(result.selected_name)).to_equal(true)
        expect(result.probe.has_compute).to_equal(true)
        expect(result.probe.status == BackendStatus.Initialized).to_equal(true)

    it "module helper returns the same available dispatch shape":
        val result = compute_dispatch_auto()

        expect(_valid_dispatch_name(result.selected_name)).to_equal(true)
        expect(result.is_available()).to_equal(true)

    it "records launch and frame synchronization counters":
        var result = ComputeDispatch.auto()

        result.record_launch()
        expect(result.synchronize_frame()).to_equal(true)
        expect(result.hits.kernel_launches).to_equal(1)
        expect(result.hits.synchronize_calls).to_equal(1)
        expect(result.summary()).to_contain("dispatch selected=")
