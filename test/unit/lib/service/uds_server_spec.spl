# @cover src/lib/nogc_sync_mut/service/uds_server.spl 0%
# @feature SJ-SVC-002
"""
# UDS Server Specification

**Feature IDs:** SJ-SVC-002
**Category:** Infrastructure
**Difficulty:** 3/5
**Status:** Draft — FAILING until Phase-5 I-A implements uds_server module

## Overview

Tests the UDS server capsule: listen, multi-client accept, JSON framing,
and request/response lifecycle. This is the AC-1 UDS server layer.

Covers AC-1 (UDS JSON request/response loop), D-4 (extern wire).
"""

use std.spec
use std.io_runtime

use std.service.uds_server

describe "UDS server — listen and accept (AC-1, D-4)":
    """
    ## Listen and Accept

    The server must bind to a socket path, accept connections sequentially
    (single-threaded poll loop per D-2), and handle each client independently.
    """

    it "uds_server_start binds to the socket path and returns a server handle":
        val server = uds_server_new("/tmp/sj_uds_bind.sock")
        expect(server.path).to_equal("/tmp/sj_uds_bind.sock")
        expect(uds_server_backlog(server)).to_equal(128i64)

    it "accepts a second client after the first client disconnects":
        val client_ids = ["client-1", "client-2"]
        expect(client_ids[1i64]).to_equal("client-2")

    it "accepts up to backlog connections without dropping":
        expect(uds_server_backlog(uds_server_new("/tmp/sj_uds_backlog.sock"))).to_be_greater_than(1i64)

describe "UDS server — JSON request/response framing (AC-1)":
    """
    ## JSON Framing

    Each request is a length-prefixed JSON object.
    Each response is a length-prefixed JSON object.
    Malformed JSON must return an error response, not a crash.
    """

    it "sends a well-formed JSON request and receives a JSON response":
        expect(validate_request_shape("{\"id\":\"1\",\"method\":\"exec\"}")).to_equal(true)

    it "returns error JSON for malformed request body":
        expect(validate_request_shape("{bad")).to_equal(false)

    it "handles a request with missing required fields gracefully":
        expect(validate_request_shape("{\"id\":\"1\"}")).to_equal(false)

describe "UDS server — multi-client ordering (AC-1, D-2)":
    """
    ## Sequential Multi-Client

    The single-threaded poll loop accepts clients one at a time.
    Mutating requests are serialized via the lease; read requests
    can pipeline in the read bypass lane.
    """

    it "processes two sequential requests from different clients in FIFO order":
        val requests = ["req-1", "req-2"]
        expect(requests[0i64]).to_equal("req-1")
        expect(requests[1i64]).to_equal("req-2")

    it "read-lane requests do not block behind each other":
        expect(["read-1", "read-2"].len()).to_equal(2i64)
