use std.gc_async_mut.svllm.model_executor.model_loader.manifest.{parse_manifest, build_tensor_pack}
use std.gc_async_mut.svllm.model_executor.model_loader.loader.{LoaderError, load_model_from_manifest_text, load_model_from_pack}

fn empty_manifest() -> text:
    "{\"schema_version\":0,\"model_id\":\"tiny\",\"revision\":\"r1\",\"preferred_chunk_bytes\":4096,\"digest_algo\":\"sha256\",\"chunks\":[],\"tensors\":[]}"

fn one_tensor_manifest() -> text:

    one_tensor_manifest_with_chunk("data-000.bin")

fn one_tensor_manifest_with_chunk(relative_path: text) -> text:
    "{\"schema_version\":0,\"model_id\":\"tiny\",\"revision\":\"r1\",\"preferred_chunk_bytes\":4096,\"digest_algo\":\"sha256\",\"chunks\":[{\"id\":0,\"relative_path\":\"" + relative_path + "\",\"byte_len\":16,\"digest_hex\":\"9f9f5111f7b27a781f1f1ddde5ebc2dd2b796bfc7365c9c28b548e564176929f\"}],\"tensors\":[{\"name\":\"tok_embeddings.weight\",\"dtype\":\"F32\",\"shape\":[2,2],\"chunk_id\":0,\"offset_in_chunk\":0,\"byte_len\":16}]}"

fn bad_chunk_manifest() -> text:
    "{\"schema_version\":0,\"model_id\":\"tiny\",\"revision\":\"r1\",\"preferred_chunk_bytes\":4096,\"digest_algo\":\"sha256\",\"chunks\":[{\"id\":0,\"relative_path\":\"data-000.bin\",\"byte_len\":16,\"digest_hex\":\"9f9f5111f7b27a781f1f1ddde5ebc2dd2b796bfc7365c9c28b548e564176929f\"}],\"tensors\":[{\"name\":\"tok_embeddings.weight\",\"dtype\":\"F32\",\"shape\":[2,2],\"chunk_id\":7,\"offset_in_chunk\":0,\"byte_len\":16}]}"

fn bad_digest_manifest() -> text:
    "{\"schema_version\":0,\"model_id\":\"tiny\",\"revision\":\"r1\",\"preferred_chunk_bytes\":4096,\"digest_algo\":\"sha256\",\"chunks\":[{\"id\":0,\"relative_path\":\"data-000.bin\",\"byte_len\":16,\"digest_hex\":\"abc123\"}],\"tensors\":[{\"name\":\"tok_embeddings.weight\",\"dtype\":\"F32\",\"shape\":[2,2],\"chunk_id\":0,\"offset_in_chunk\":0,\"byte_len\":16}]}"

fn manifest_status(text: text) -> text:
    match parse_manifest(text):
        Ok(_) => "ok"
        Err(_) => "error"

fn manifest_model_id(text: text) -> text:
    match parse_manifest(text):
        Ok(m) => m.model_id
        Err(_) => "error"

fn manifest_counts(text: text) -> text:
    match parse_manifest(text):
        Ok(m) => m.chunk_count.to_text() + ":" + m.tensor_count.to_text()
        Err(_) => "error"

fn pack_summary(root: text, text: text) -> text:
    match load_model_from_manifest_text(root, text):
        Ok(result) =>
            val tensor = result.pack.find_tensor("tok_embeddings.weight")
            result.pack.model_id + ":" + result.pack.chunk_count().to_text() + ":" + result.pack.tensor_count().to_text() + ":" + tensor.byte_len.to_text()
        Err(_) => "error"

fn load_status(root: text, text: text) -> text:
    match load_model_from_manifest_text(root, text):
        Ok(_) => "ok"
        Err(_) => "error"

fn pack_load_status(root: text) -> text:
    match load_model_from_pack(root):
        Ok(_) => "ok"
        Err(_) => "error"

fn pack_load_detail(root: text) -> text:
    match load_model_from_pack(root):
        Ok(_) => "ok"
        Err(e) =>
            match e:
                LoaderError.PackRootNotFound => "missing_root"
                LoaderError.ManifestInvalid => "invalid_manifest"
                LoaderError.ChunkOpenFailed => "chunk_error"
                LoaderError.NvfsUnavailable => "nvfs_unavailable"
                LoaderError.Unimplemented => "unimplemented"

describe "svLLM tensor-pack manifest loader":
    it "parses canonical empty v0 manifest text":
        expect(manifest_status(empty_manifest())).to_equal("ok")
        expect(manifest_model_id(empty_manifest())).to_equal("tiny")
        expect(manifest_counts(empty_manifest())).to_equal("0:0")

    it "rejects malformed and unsupported manifests":
        expect(manifest_status("not a manifest")).to_equal("error")
        expect(manifest_status("{\"schema_version\":1,\"model_id\":\"tiny\",\"revision\":\"r1\",\"preferred_chunk_bytes\":4096,\"chunks\":[],\"tensors\":[]}")).to_equal("error")

    it "loads an already-read empty manifest without throwing":
        expect(load_status("/tmp/pack", empty_manifest())).to_equal("ok")
        expect(load_status("", empty_manifest())).to_equal("error")
        expect(pack_load_status("/tmp/pack")).to_equal("error")

    it "materializes canonical non-empty tensor and chunk metadata":
        expect(manifest_status(one_tensor_manifest())).to_equal("ok")
        expect(manifest_counts(one_tensor_manifest())).to_equal("1:1")
        expect(pack_summary("/tmp/pack", one_tensor_manifest())).to_equal("tiny:1:1:16")
        expect(manifest_status(bad_chunk_manifest())).to_equal("error")
        expect(manifest_status(bad_digest_manifest())).to_equal("error")

    it "loads manifest.sdn from a pack root":
        expect(pack_load_status("test/fixtures/svllm/valid_pack")).to_equal("ok")

    it "rejects missing chunk files from a pack root":
        expect(pack_load_detail("test/fixtures/svllm/missing_chunk_pack")).to_equal("chunk_error")

    it "rejects mismatched chunk files from a pack root":
        expect(pack_load_detail("test/fixtures/svllm/wrong_chunk_pack")).to_equal("chunk_error")
