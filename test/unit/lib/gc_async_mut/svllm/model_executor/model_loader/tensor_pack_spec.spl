# svllm tensor_pack — data type surface

use std.gc_async_mut.svllm.model_executor.model_loader.tensor_pack.{TensorPack, TensorInfo, ChunkInfo}
use std.gc_async_mut.svllm.model_executor.model_loader.weight_utils.{Dtype}

describe "TensorPack.empty":
    it "has the supplied pack_root":
        val pack = TensorPack.empty("/models/llama3-8b")
        expect(pack.pack_root).to_equal("/models/llama3-8b")

    it "has zero tensors and chunks":
        val pack = TensorPack.empty("/x")
        expect(pack.tensor_count()).to_equal(0)
        expect(pack.chunk_count()).to_equal(0)

    it "has empty model_id and revision":
        val pack = TensorPack.empty("/x")
        expect(pack.model_id).to_equal("")
        expect(pack.revision).to_equal("")

describe "TensorPack.find_tensor":
    it "returns empty-named TensorInfo when missing":
        val pack = TensorPack.empty("/x")
        val t = pack.find_tensor("missing")
        expect(t.name).to_equal("")

    it "finds a tensor that is present":
        var pack = TensorPack.empty("/x")
        val shape: [i64] = [4, 8]
        pack.tensors.push(TensorInfo(
            name: "w0",
            shape: shape,
            dtype: Dtype.F16,
            chunk_id: 0,
            offset_in_chunk: 0,
            byte_len: 64
        ))
        val t = pack.find_tensor("w0")
        expect(t.name).to_equal("w0")
        expect(t.byte_len).to_equal(64)

describe "ChunkInfo":
    it "stores relative path and digest":
        val c = ChunkInfo(
            id: 0,
            relative_path: "data-000.bin",
            byte_len: 2097152,
            digest_hex: "0011aabb"
        )
        expect(c.relative_path).to_equal("data-000.bin")
        expect(c.digest_hex).to_equal("0011aabb")
