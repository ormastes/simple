# game2d Camera2D Tests

use std.game2d.camera.{Camera2D, Rect}

describe "Camera2D":
    describe "create":
        it "stores viewport dimensions":
            val cam = Camera2D.create(0.0, 0.0, 800.0, 600.0)
            expect cam.viewport_w == 800.0
            expect cam.viewport_h == 600.0

        it "defaults zoom to 1.0":
            val cam = Camera2D.create(0.0, 0.0, 800.0, 600.0)
            expect cam.zoom == 1.0

    describe "world_to_screen / screen_to_world round-trip":
        it "round-trips the origin at identity":
            val cam = Camera2D.create(0.0, 0.0, 800.0, 600.0)
            val (sx, sy) = cam.world_to_screen(0.0, 0.0)
            val (wx, wy) = cam.screen_to_world(sx, sy)
            expect wx == 0.0
            expect wy == 0.0

        it "maps world origin to viewport centre":
            val cam = Camera2D.create(0.0, 0.0, 800.0, 600.0)
            val (sx, sy) = cam.world_to_screen(0.0, 0.0)
            expect sx == 400.0
            expect sy == 300.0

        it "round-trips an off-centre point":
            val cam = Camera2D.create(0.0, 0.0, 800.0, 600.0)
            val world_x = 123.0
            val world_y = -45.0
            val (sx, sy) = cam.world_to_screen(world_x, world_y)
            val (wx, wy) = cam.screen_to_world(sx, sy)
            expect wx == world_x
            expect wy == world_y

    describe "zoom":
        it "zoom=2 doubles distance from centre":
            var cam = Camera2D.create(0.0, 0.0, 800.0, 600.0)
            cam.set_zoom(2.0)
            val (sx1, _) = cam.world_to_screen(10.0, 0.0)
            # centre is 400; offset should be 10*2=20 so sx=420
            expect sx1 == 420.0

        it "round-trip holds at zoom=2":
            var cam = Camera2D.create(0.0, 0.0, 800.0, 600.0)
            cam.set_zoom(2.0)
            val (sx, sy) = cam.world_to_screen(50.0, -30.0)
            val (wx, wy) = cam.screen_to_world(sx, sy)
            expect wx == 50.0
            expect wy == -30.0

describe "Rect":
    describe "create":
        it "stores all fields":
            val r = Rect.create(10.0, 20.0, 100.0, 50.0)
            expect r.x == 10.0
            expect r.y == 20.0
            expect r.w == 100.0
            expect r.h == 50.0