# game2d TileMap Tests

use std.game2d.tilemap.{TileMap}
use std.game2d.camera.{Camera2D}
use std.gpu.engine2d.engine.{Engine2D}

describe "TileMap":
    describe "create":
        it "stores tileset texture id":
            val grid: [[i32]] = [[0, 1], [2, 3]]
            val tm = TileMap.create(5, 16, 16, grid)
            expect(tm.tileset_texture_id).to_equal(5)

        it "stores tile dimensions":
            val grid: [[i32]] = [[0]]
            val tm = TileMap.create(1, 32, 24, grid)
            expect(tm.tile_w).to_equal(32)
            expect(tm.tile_h).to_equal(24)

        it "computes row count from grid":
            val grid: [[i32]] = [[0, 1, 2], [3, 4, 5], [6, 7, 8]]
            val tm = TileMap.create(1, 16, 16, grid)
            expect(tm.rows).to_equal(3)

        it "computes col count from first row":
            val grid: [[i32]] = [[0, 1, 2], [3, 4, 5]]
            val tm = TileMap.create(1, 16, 16, grid)
            expect(tm.cols).to_equal(3)

    describe "tile_at":
        it "returns tile index for valid position":
            val grid: [[i32]] = [[0, 1, 2], [3, 4, 5]]
            val tm = TileMap.create(1, 16, 16, grid)
            expect(tm.tile_at(0, 1)).to_equal(1)
            expect(tm.tile_at(1, 2)).to_equal(5)

        it "returns -1 for out-of-bounds row":
            val grid: [[i32]] = [[0, 1]]
            val tm = TileMap.create(1, 16, 16, grid)
            expect(tm.tile_at(5, 0)).to_equal(-1)

        it "returns -1 for out-of-bounds col":
            val grid: [[i32]] = [[0, 1]]
            val tm = TileMap.create(1, 16, 16, grid)
            expect(tm.tile_at(0, 5)).to_equal(-1)

        it "respects -1 empty tile in grid":
            val grid: [[i32]] = [[-1, 2], [3, -1]]
            val tm = TileMap.create(1, 8, 8, grid)
            expect(tm.tile_at(0, 0)).to_equal(-1)
            expect(tm.tile_at(1, 1)).to_equal(-1)

    describe "render_tilemap":
        it "renders a 3x3 grid without error":
            val grid: [[i32]] = [[0, 1, 2], [3, 4, 5], [6, 7, 8]]
            val tm = TileMap.create(1, 8, 8, grid)
            var engine = Engine2D.create_with_backend(128, 128, "cpu")
            engine.clear(0xFF000000)
            val cam = Camera2D.create(0.0, 0.0, 128.0, 128.0)
            tm.render_tilemap(engine, cam, 0.0, 0.0)
            engine.present()
            val pixels = engine.read_pixels()
            expect(pixels.len()).to_equal(128 * 128)

        it "skips empty (-1) tiles leaving background unchanged":
            # Single empty tile — nothing should be drawn over black background
            val grid: [[i32]] = [[-1]]
            val tm = TileMap.create(1, 8, 8, grid)
            var engine = Engine2D.create_with_backend(32, 32, "cpu")
            engine.clear(0xFF000000)
            val cam = Camera2D.create(0.0, 0.0, 32.0, 32.0)
            tm.render_tilemap(engine, cam, 0.0, 0.0)
            engine.present()
            val pixels = engine.read_pixels()
            var all_black = true
            var i = 0
            while i < pixels.len():
                if pixels[i] != 0xFF000000:
                    all_black = false
                i = i + 1
            expect(all_black).to_equal(true)

        it "draws non-zero tile index leaving at least one non-black pixel":
            val grid: [[i32]] = [[1]]
            val tm = TileMap.create(1, 8, 8, grid)
            var engine = Engine2D.create_with_backend(64, 64, "cpu")
            engine.clear(0xFF000000)
            val cam = Camera2D.create(0.0, 0.0, 64.0, 64.0)
            tm.render_tilemap(engine, cam, -32.0, -32.0)
            engine.present()
            val pixels = engine.read_pixels()
            var found_non_black = false
            var i = 0
            while i < pixels.len():
                if pixels[i] != 0xFF000000:
                    found_non_black = true
                i = i + 1
            expect(found_non_black).to_equal(true)
