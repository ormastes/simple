# game2d TileMap executable behavior tests.

use std.spec

class TestTileMap:
    tileset_texture_id: i64
    tile_w: i64
    tile_h: i64
    cells: [[i64]]
    cols: i64
    rows: i64

    static fn create(tid: i64, tw: i64, th: i64, cells: [[i64]]) -> TestTileMap:
        val r = cells.len()
        val c = if r > 0: cells[0].len() else: 0
        TestTileMap(
            tileset_texture_id: tid,
            tile_w: tw,
            tile_h: th,
            cells: cells,
            cols: c,
            rows: r
        )

    fn tile_at(row: i64, col: i64) -> i64:
        if row < 0 or row >= self.rows:
            return -1
        if col < 0 or col >= self.cols:
            return -1
        self.cells[row][col]

    fn rendered_tiles() -> i64:
        var count = 0
        var row = 0
        while row < self.rows:
            var col = 0
            while col < self.cols:
                if self.tile_at(row, col) >= 0:
                    count = count + 1
                col = col + 1
            row = row + 1
        count

describe "TileMap":
    describe "create":
        it "stores tileset texture id":
            val cells = [[0, 1], [2, 3]]
            val tm = TestTileMap.create(tid: 5, tw: 16, th: 16, cells: cells)
            expect(tm.tileset_texture_id).to_equal(5)

        it "stores tile dimensions":
            val cells = [[0]]
            val tm = TestTileMap.create(tid: 1, tw: 32, th: 24, cells: cells)
            expect(tm.tile_w).to_equal(32)
            expect(tm.tile_h).to_equal(24)

        it "computes row and column counts":
            val cells = [[0, 1, 2], [3, 4, 5], [6, 7, 8]]
            val tm = TestTileMap.create(tid: 1, tw: 16, th: 16, cells: cells)
            expect(tm.rows).to_equal(3)
            expect(tm.cols).to_equal(3)

    describe "tile_at":
        it "returns tile index for valid position":
            val cells = [[0, 1, 2], [3, 4, 5]]
            val tm = TestTileMap.create(tid: 1, tw: 16, th: 16, cells: cells)
            expect(tm.tile_at(0, 1)).to_equal(1)
            expect(tm.tile_at(1, 2)).to_equal(5)

        it "returns -1 for out-of-bounds positions":
            val cells = [[0, 1]]
            val tm = TestTileMap.create(tid: 1, tw: 16, th: 16, cells: cells)
            expect(tm.tile_at(5, 0)).to_equal(-1)
            expect(tm.tile_at(0, 5)).to_equal(-1)

        it "respects -1 empty tile in cells":
            val cells = [[-1, 2], [3, -1]]
            val tm = TestTileMap.create(tid: 1, tw: 8, th: 8, cells: cells)
            expect(tm.tile_at(0, 0)).to_equal(-1)
            expect(tm.tile_at(1, 1)).to_equal(-1)

    describe "render_tilemap":
        it "counts non-empty tiles":
            val cells = [[0, 1, -1], [3, -1, 5]]
            val tm = TestTileMap.create(tid: 1, tw: 8, th: 8, cells: cells)
            expect(tm.rendered_tiles()).to_equal(4)
