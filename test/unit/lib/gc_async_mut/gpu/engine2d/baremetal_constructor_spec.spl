# @tag: engine2d, baremetal
# @cover src/lib/gc_async_mut/gpu/engine2d/engine.spl 20%
# @cover src/lib/gc_async_mut/gpu/engine2d/backend_baremetal.spl 15%

use std.spec.{describe, it, expect}
use std.gc_async_mut.gpu.engine2d.engine.{Engine2D}
use std.gc_async_mut.gpu.engine2d.backend_baremetal.{BaremetalBackend}
use os.drivers.framebuffer.fb_driver.{FramebufferDriver}

describe "Engine2D baremetal constructor":

    it "preserves explicit dimensions on the sized baremetal path":
        val fb = FramebufferDriver.from_buffer(8, 6)
        val backend = BaremetalBackend.create(fb)

        val engine = Engine2D.create_with_baremetal_backend_dims(8, 6, backend)

        expect(engine.backend_name()).to_equal("baremetal")
        expect(engine.width()).to_equal(8)
        expect(engine.height()).to_equal(6)

    it "keeps the legacy baremetal constructor contract":
        val fb = FramebufferDriver.from_buffer(11, 7)
        val backend = BaremetalBackend.create(fb)

        val engine = Engine2D.create_with_baremetal_backend(backend)

        expect(engine.backend_name()).to_equal("baremetal")
        expect(engine.width()).to_equal(11)
        expect(engine.height()).to_equal(7)
