use std.spec.*

use std.gc_async_mut.gpu.browser_engine.browser_renderer.{BrowserRenderer}
use std.gc_async_mut.gpu.browser_engine.browser_engine2d_bridge.{
    create_gpu_browser_renderer, create_gpu_browser_renderer_with_backend, create_software_browser_renderer}

val TEST_WIDTH: i32 = 24
val TEST_HEIGHT: i32 = 16

describe "Browser Engine2D bridge backend routing":
    it "defaults GPU browser rendering to Metal while preserving explicit software":
        val gpu_renderer = create_gpu_browser_renderer(TEST_WIDTH, TEST_HEIGHT)
        val software_renderer = create_software_browser_renderer(TEST_WIDTH, TEST_HEIGHT)
        expect(gpu_renderer.engine.?).to_equal(true)
        expect(software_renderer.engine.?).to_equal(true)
        expect(gpu_renderer.backend_name()).to_equal("metal")
        expect(software_renderer.backend_name()).to_equal("software")

    it "preserves explicit backend names for Engine2D renderers":
        val metal_renderer = BrowserRenderer.create_with_backend(TEST_WIDTH, TEST_HEIGHT, "metal")
        val cpu_renderer = BrowserRenderer.create_with_backend(TEST_WIDTH, TEST_HEIGHT, "cpu")
        val software_renderer = create_gpu_browser_renderer_with_backend(TEST_WIDTH, TEST_HEIGHT, "software")
        val unknown_renderer = BrowserRenderer.create_with_backend(TEST_WIDTH, TEST_HEIGHT, "not-a-backend")
        expect(metal_renderer.backend_name()).to_equal("metal")
        expect(cpu_renderer.backend_name()).to_equal("cpu")
        expect(software_renderer.backend_name()).to_equal("software")
        expect(unknown_renderer.backend_name()).to_equal("software")
        expect(unknown_renderer.engine.?).to_equal(false)
