use std.gc_async_mut.gpu.browser_engine.simple_web_renderer.{SimpleWebRenderer, simple_web_render_html_to_pixels, simple_web_render_html_to_scene}
use std.gc_async_mut.gpu.browser_engine.browser_renderer.{BrowserRenderer}

fn count_color(pixels: [u32], color: u32) -> i32:
    var count: i32 = 0
    var idx: i32 = 0
    while idx < pixels.len():
        if pixels[idx] == color:
            count = count + 1
        idx = idx + 1
    count

fn pixel_body(html: text) -> u32:
    val pixels = simple_web_render_html_to_pixels(html, 8, 220)
    pixels[7 + 210 * 8]

fn pixels_equal(a: [u32], b: [u32]) -> bool:
    if a.len() != b.len():
        return false
    var idx = 0
    while idx < a.len():
        if a[idx] != b[idx]:
            return false
        idx = idx + 1
    true

fn main():
    val html1 = "<html><body style='background-color: rebeccapurple; background: #0f8'>Simple Web Renderer</body></html>"
    print("later-background=" + pixel_body(html1).to_text())
    val html2 = "<html><body style='background: #0f8; background-color: rebeccapurple'>Simple Web Renderer</body></html>"
    print("later-background-color=" + pixel_body(html2).to_text())
    val html3 = "<html><head><style>body { margin: 0; background-color: #ffffff; } [data-card] { width: 12px; height: 8px; background-color: #0e7490; }</style></head><body><div data-card='true'></div></body></html>"
    print("presence=" + count_color(simple_web_render_html_to_pixels(html3, 64, 64), 0xFF0E7490u32).to_text())
    val html4 = "<html><head><style>body { margin: 0; background-color: #ffffff; } div[data-state='active'] { width: 12px; height: 8px; background-color: #4d7c0f; }</style></head><body><div data-state='inactive'></div></body></html>"
    print("exact-reject=" + count_color(simple_web_render_html_to_pixels(html4, 64, 64), 0xFF4D7C0Fu32).to_text())
    val html5 = "<html><head><style>body { margin: 0; background-color: #ffffff; } div[data-route^='/app'] { width: 12px; height: 8px; background-color: #0f5e9c; }</style></head><body><div data-route='/app/home'></div></body></html>"
    print("prefix=" + count_color(simple_web_render_html_to_pixels(html5, 64, 64), 0xFF0F5E9Cu32).to_text())
    val html6 = "<html><head><style>body { margin: 0; background-color: #ffffff; } div[data-route$='/settings'] { width: 12px; height: 8px; background-color: #065f46; }</style></head><body><div data-route='/app/settings/profile'></div></body></html>"
    print("suffix-reject=" + count_color(simple_web_render_html_to_pixels(html6, 64, 64), 0xFF065F46u32).to_text())
    val html7 = "<html><body><div style='width: 80px; height: 40px; background-color: #2050a0'></div></body></html>"
    print("scene-basic=" + simple_web_render_html_to_scene(html7, 120, 80).commands[0].color.to_text())
    val html8 = "<html><body><div style='width: 80px; height: 40px; background: url(hero.png) #0f8 no-repeat'></div></body></html>"
    print("scene-inline-url=" + simple_web_render_html_to_scene(html8, 120, 80).commands[0].color.to_text())
    val html9 = "<html><head><style>.card { width: 80px; height: 40px; background: url(hero.png) #0f8 no-repeat; }</style></head><body><div class='card'></div></body></html>"
    print("scene-style-url=" + simple_web_render_html_to_scene(html9, 120, 80).commands[0].color.to_text())
    val renderer = BrowserRenderer.create(48, 32)
    val result = renderer.render_html_to_pixels("<html><body><div style='width:24px; height:16px; background-color:#2563eb'></div></body></html>")
    print("browser-non-bg=" + count_color(result.pixel_data, 0xFFFFFFFFu32).to_text())
    val html10 = "<html><body><div style='width: 72px; height: 32px; background-color: #44aa22'></div><span style='color:#ffffff'>Simple</span></body></html>"
    val simple = SimpleWebRenderer.create(120, 80)
    val browser = BrowserRenderer.create_with_backend(120, 80, "software")
    print("simple-backend=" + simple.backend_name)
    print("simple-browser-equal=" + pixels_equal(simple.render_html_to_pixels(html10), browser.render_html_to_pixels(html10).pixel_data).to_text())
    print("rgb=" + pixel_body("<html><body style='background-color: rgb(5, 150, 105)'>Simple Web Renderer</body></html>").to_text())
    print("rgba=" + pixel_body("<html><body style='background-color: rgba(0, 0, 0, 0.5)'>Simple Web Renderer</body></html>").to_text())
    print("hex3=" + pixel_body("<html><body style='background-color: #0f8'>Simple Web Renderer</body></html>").to_text())
    print("hex4=" + pixel_body("<html><body style='background-color: #0008'>Simple Web Renderer</body></html>").to_text())
    print("named=" + pixel_body("<html><body style='background-color: rebeccapurple'>Simple Web Renderer</body></html>").to_text())
    print("transparent=" + pixel_body("<html><body style='background-color: transparent'>Simple Web Renderer</body></html>").to_text())
    print("hsl=" + pixel_body("<html><body style='background-color: hsl(120, 100%, 25%)'>Simple Web Renderer</body></html>").to_text())
    print("current-color-bgcolor=" + pixel_body("<html><body style='background-color: currentColor; color: #456789'>Simple Web Renderer</body></html>").to_text())
    print("named-shorthand=" + pixel_body("<html><body style='background: rebeccapurple no-repeat'>Simple Web Renderer</body></html>").to_text())
    print("rgb-shorthand=" + pixel_body("<html><body style='background: rgb(5, 150, 105) no-repeat'>Simple Web Renderer</body></html>").to_text())
    print("url-shorthand=" + pixel_body("<html><body style='background: url(hero.png) #0f8 no-repeat'>Simple Web Renderer</body></html>").to_text())
    print("current-color-shorthand=" + pixel_body("<html><body style='background: currentColor no-repeat; color: #345678'>Simple Web Renderer</body></html>").to_text())
