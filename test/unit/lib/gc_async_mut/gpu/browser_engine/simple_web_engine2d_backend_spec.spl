use std.spec.{describe, it, expect}
use std.gc_async_mut.gpu.browser_engine.simple_web_renderer.{
    SimpleWebRenderer,
    simple_web_render_html_to_pixels_with_engine2d_backend,
    simple_web_resolved_engine2d_backend_name}
use std.gc_async_mut.gpu.engine2d.engine.{Engine2D}
use std.gc_async_mut.gpu.engine2d.backend_probe.{BackendStatus}
use std.nogc_sync_mut.env.platform.{is_macos}

fn _pixels_equal(a: [u32], b: [u32]) -> bool:
    if a.len() != b.len():
        return false
    var i = 0
    while i < a.len():
        if a[i] != b[i]:
            return false
        i = i + 1
    true

describe "Simple Web Engine2D backend routing":
    it "renders deterministic pixels through explicit CPU and Metal requests":
        val html = "<html><body style='background-color: #44aa22'><div class='wm-app-titlebar'>Simple Web</div></body></html>"
        val cpu = simple_web_render_html_to_pixels_with_engine2d_backend(html, 32, 24, "cpu")
        val metal = simple_web_render_html_to_pixels_with_engine2d_backend(html, 32, 24, "metal")
        expect(cpu.len()).to_equal(32 * 24)
        expect(metal.len()).to_equal(32 * 24)
        expect(_pixels_equal(cpu, metal)).to_equal(true)

    it "keeps the requested Metal renderer name while exposing the resolved Engine2D backend":
        val renderer = SimpleWebRenderer.create_with_backend(32, 24, "metal")
        expect(renderer.backend_name).to_equal("metal")
        val resolved = simple_web_resolved_engine2d_backend_name(32, 24, "metal")
        if is_macos():
            val probe = Engine2D.probe_backend(32, 24, "metal")
            if probe.status == BackendStatus.Initialized:
                expect(resolved).to_equal("metal")
            else:
                expect(resolved).to_equal("cpu")
        else:
            expect(resolved).to_equal("cpu")
