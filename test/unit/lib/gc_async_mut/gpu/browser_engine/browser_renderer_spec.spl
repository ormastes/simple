use std.spec.*

use std.gc_async_mut.gpu.browser_engine.browser_renderer.{render_html_to_pixel_array}

val TEST_WIDTH: i32 = 160
val TEST_HEIGHT: i32 = 120
val WHITE_BG: u32 = 0xFFFFFFFF

fn _count_non_background(pixels: [u32], bg: u32) -> i32:
    var count: i32 = 0
    var idx: i32 = 0
    while idx < pixels.len():
        if pixels[idx] != bg:
            count = count + 1
        idx = idx + 1
    count

fn _pixel_signature(pixels: [u32]) -> text:
    if pixels.len() == 0:
        return "empty"
    val mid = pixels.len() / 2
    val last = pixels.len() - 1
    "{pixels[0]}|{pixels[mid]}|{pixels[last]}|{_count_non_background(pixels, WHITE_BG)}"

describe "BrowserRenderer HTML rendering":

    it "renders inline background blocks without producing a blank frame":
        val html = "<html><body><div style='width: 120px; height: 60px; background-color: #ff0000'></div></body></html>"
        val pixels = render_html_to_pixel_array(html, TEST_WIDTH, TEST_HEIGHT)
        expect(pixels.len()).to_equal(TEST_WIDTH * TEST_HEIGHT)
        expect(_count_non_background(pixels, WHITE_BG)).to_be_greater_than(0)

    it "renders style block CSS without hanging":
        val html = "<html><head><style>body { margin: 0; } .card { width: 100px; height: 50px; background-color: #0000ff; }</style></head><body><div class='card'></div></body></html>"
        val pixels = render_html_to_pixel_array(html, TEST_WIDTH, TEST_HEIGHT)
        expect(pixels.len()).to_equal(TEST_WIDTH * TEST_HEIGHT)
        expect(_count_non_background(pixels, WHITE_BG)).to_be_greater_than(0)

    it "renders the glass style body fixture":
        val html = "<html><head><style>body { margin: 0; background-color: #101820; color: #f3f4f6; } .panel { width: 120px; height: 70px; background-color: #1f2937; }</style></head><body><div class='panel'></div></body></html>"
        val pixels = render_html_to_pixel_array(html, TEST_WIDTH, TEST_HEIGHT)
        expect(pixels.len()).to_equal(TEST_WIDTH * TEST_HEIGHT)
        expect(_count_non_background(pixels, WHITE_BG)).to_be_greater_than(0)

    it "is deterministic for repeated renders of the same HTML":
        val html = "<html><body><div style='width: 90px; height: 40px; background-color: #22aa44'></div></body></html>"
        val first = render_html_to_pixel_array(html, TEST_WIDTH, TEST_HEIGHT)
        val second = render_html_to_pixel_array(html, TEST_WIDTH, TEST_HEIGHT)
        expect(_pixel_signature(first)).to_equal(_pixel_signature(second))
