# Audit Log Specification
#
# **Feature IDs:** #SEC-031
# **Category:** Security
# **Difficulty:** 2/5
# **Status:** Implemented
#
# ## Overview
# Tests for audit logging utilities.
# Validates entry formatting, value masking, severity mapping, and entry creation.

use std.security.types.{AuditEntry, AuditSeverity}
use std.security.audit_log.{format_audit_entry, mask_value, severity_for_event, new_audit_entry}

# ============================================================================
# Test Group 1: Audit entry formatting
# ============================================================================

describe "format_audit_entry":
    it "produces output containing event name":
        val entry = new_audit_entry("login_success", "user123", "info")
        val output = format_audit_entry(entry)
        expect(output).to_contain("login_success")

    it "produces output containing actor":
        val entry = new_audit_entry("login_success", "user123", "info")
        val output = format_audit_entry(entry)
        expect(output).to_contain("user123")

    it "produces output containing severity":
        val entry = new_audit_entry("login_failure", "unknown", "warning")
        val output = format_audit_entry(entry)
        expect(output).to_contain("warning")

    it "produces non-empty output":
        val entry = new_audit_entry("test_event", "system", "info")
        val output = format_audit_entry(entry)
        val is_non_empty = output.len() > 0
        expect(is_non_empty).to_equal(true)

# ============================================================================
# Test Group 2: Value masking
# ============================================================================

describe "mask_value":
    it "masks short values completely":
        val result = mask_value("abc")
        expect(result).to_equal("***")

    it "masks long values keeping partial prefix":
        val result = mask_value("secret_password_123")
        val starts_visible = result.len() > 0
        expect(starts_visible).to_equal(true)
        expect(result).to_contain("***")

    it "handles empty value":
        val result = mask_value("")
        expect(result).to_equal("***")

# ============================================================================
# Test Group 3: Severity mapping
# ============================================================================

describe "severity_for_event":
    it "returns info for login_success":
        val sev = severity_for_event("login_success")
        expect(sev).to_equal("info")

    it "returns warning for login_failure":
        val sev = severity_for_event("login_failure")
        expect(sev).to_equal("warning")

    it "returns critical for permission_escalation":
        val sev = severity_for_event("permission_escalation")
        expect(sev).to_equal("critical")

    it "returns info for unknown events":
        val sev = severity_for_event("some_unknown_event")
        expect(sev).to_equal("info")

# ============================================================================
# Test Group 4: AuditEntry creation
# ============================================================================

describe "new_audit_entry":
    it "creates entry with correct event":
        val entry = new_audit_entry("file_access", "admin", "info")
        expect(entry.event).to_equal("file_access")

    it "creates entry with correct actor":
        val entry = new_audit_entry("file_access", "admin", "info")
        expect(entry.actor).to_equal("admin")

    it "creates entry with non-empty timestamp":
        val entry = new_audit_entry("file_access", "admin", "info")
        val has_ts = entry.timestamp.len() > 0
        expect(has_ts).to_equal(true)
