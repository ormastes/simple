# Native-safe behavior coverage for the no-GC sync immutable facade.

use std.nogc_sync_immut.combinators.{pfilter, pfold}

describe "nogc_sync_immut native combinators":
    it "runs pure combinators through the no-GC sync facade chain":
        expect(pfilter([5, 6, 7, 8], _1 > 6)).to_equal([7, 8])
        expect(pfold([2, 3, 4], 1, \acc, x: acc * x)).to_equal(24)
