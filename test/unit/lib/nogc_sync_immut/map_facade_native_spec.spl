use std.nogc_sync_immut.{PersistentMap}

describe "nogc_sync_immut PersistentMap native backend":
    it "stores and retrieves a root-facade entry":
        val base = PersistentMap.empty()
        val first = base.set("a", 1)

        expect(base.len()).to_equal(0)
        expect(first.len()).to_equal(1)
        expect(first.get("a")).to_equal(1)
