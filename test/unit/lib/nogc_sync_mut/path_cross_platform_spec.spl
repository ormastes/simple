# Cross-Platform Path Handling Tests
#
# Tests for path_join, join2, is_absolute, normalize, and WSL conversion
# to verify correct behavior across Unix and Windows path conventions.
#
# Feature:
# Cross-platform path handling (double-slash prevention, backslash support, WSL)
#
# Category:
# Library/Path
#
# Status:
# Complete

use std.path.{
    path_join, join2, normalize, normalize_path,
    is_absolute, is_absolute_path, is_relative,
    basename, dirname, extension, stem,
    resolve, relative_to, split_path
}

describe "Cross-Platform Path Handling":

    describe "join2 double-slash prevention":
        it "does not produce double slash when base has trailing /":
            expect(join2("foo/", "bar")).to_equal("foo/bar")

        it "handles base without trailing slash":
            expect(join2("foo", "bar")).to_equal("foo/bar")

        it "handles empty base":
            expect(join2("", "bar")).to_equal("bar")

        it "handles empty segment":
            expect(join2("foo", "")).to_equal("foo")

        it "handles both empty":
            expect(join2("", "")).to_equal("")

        it "strips leading slash from segment":
            expect(join2("foo", "/bar")).to_equal("foo/bar")

        it "handles root base with trailing slash":
            expect(join2("/", "bar")).to_equal("/bar")

        it "does not produce double slash for absolute base with trailing /":
            expect(join2("/home/user/", "file.txt")).to_equal("/home/user/file.txt")

        it "handles multiple trailing slashes in base":
            expect(join2("/home/user//", "file.txt")).to_equal("/home/user//file.txt")

    describe "path_join double-slash prevention":
        it "handles multiple segments":
            expect(path_join(["a", "b", "c"])).to_equal("a/b/c")

        it "handles segments with trailing slashes":
            expect(path_join(["/home/", "user/", "file.txt"])).to_equal("/home/user/file.txt")

        it "handles segments with leading slashes":
            expect(path_join(["/home", "/user", "/file.txt"])).to_equal("/home/user/file.txt")

        it "skips empty segments":
            expect(path_join(["a", "", "b", "", "c"])).to_equal("a/b/c")

        it "handles single segment":
            expect(path_join(["/usr"])).to_equal("/usr")

        it "handles empty list":
            expect(path_join([])).to_equal("")

    describe "join2 with backslash separators":
        it "does not double-separate when base has trailing backslash":
            expect(join2("C:\\Users\\", "file.txt")).to_equal("C:\\Users\\file.txt")

        it "strips leading backslash from segment":
            expect(join2("C:\\Users", "\\file.txt")).to_equal("C:\\Users/file.txt")

    describe "path_join with backslash separators":
        it "handles backslash trailing separator":
            expect(path_join(["C:\\Users\\", "Documents"])).to_equal("C:\\Users\\Documents")

        it "handles mixed separators":
            expect(path_join(["/mnt/c", "Users\\foo"])).to_equal("/mnt/c/Users\\foo")

    describe "is_absolute with Windows drive letters":
        it "detects unix absolute path":
            expect(is_absolute("/usr/bin")).to_equal(true)

        it "detects root path":
            expect(is_absolute("/")).to_equal(true)

        it "detects windows drive letter with backslash":
            expect(is_absolute("C:\\Users")).to_equal(true)

        it "detects windows drive letter with forward slash":
            expect(is_absolute("C:/Users")).to_equal(true)

        it "detects lowercase drive letter":
            expect(is_absolute("d:\\data")).to_equal(true)

        it "rejects relative path":
            expect(is_absolute("src/lib")).to_equal(false)

        it "rejects empty string":
            expect(is_absolute("")).to_equal(false)

        it "rejects bare filename":
            expect(is_absolute("file.txt")).to_equal(false)

        it "rejects colon without drive letter pattern":
            expect(is_absolute(":foo")).to_equal(false)

        it "rejects short string with colon":
            expect(is_absolute("C:")).to_equal(false)

    describe "is_absolute_path (extended)":
        it "detects unix absolute":
            expect(is_absolute_path("/home/user")).to_equal(true)

        it "detects windows drive letter":
            expect(is_absolute_path("C:\\Users\\user")).to_equal(true)

        it "detects windows with forward slash":
            expect(is_absolute_path("D:/data/file.dat")).to_equal(true)

        it "rejects relative":
            expect(is_absolute_path("relative\\path")).to_equal(false)

        it "rejects empty":
            expect(is_absolute_path("")).to_equal(false)

    describe "normalize_path with backslashes":
        it "converts backslashes to forward slashes":
            expect(normalize_path("C:\\Users\\user\\file.txt")).to_equal("C:/Users/user/file.txt")

        it "normalizes path with backslashes and dots":
            expect(normalize_path("a\\b\\..\\c")).to_equal("a/c")

        it "preserves forward slashes":
            expect(normalize_path("/home/user/file.txt")).to_equal("/home/user/file.txt")

        it "handles mixed separators":
            expect(normalize_path("path\\to/file")).to_equal("path/to/file")

    describe "normalize edge cases":
        it "resolves dot segments":
            expect(normalize("a/./b/../c")).to_equal("a/c")

        it "preserves absolute prefix":
            expect(normalize("/a/b/../c")).to_equal("/a/c")

        it "handles root":
            expect(normalize("/")).to_equal("/")

        it "handles empty":
            expect(normalize("")).to_equal(".")

        it "handles complex nesting":
            expect(normalize("//a/b/./c//d/../e/f")).to_equal("/a/b/c/e/f")

        it "handles parent at root for relative":
            expect(normalize("../a/b")).to_equal("../a/b")

    describe "Real-world path construction scenarios":
        it "module path to file path":
            val module_name = "compiler.core.tokens"
            val rel_path = module_name.replace(".", "/")
            val full = join2("/project/src", rel_path + ".spl")
            expect(full).to_equal("/project/src/compiler/core/tokens.spl")

        it "module path to init path":
            val parts = ["src", "lib", "common"]
            val full = path_join(parts)
            val init = join2(full, "__init__.spl")
            expect(init).to_equal("src/lib/common/__init__.spl")

        it "output file from source":
            val source = "/home/user/project/src/main.spl"
            val dir = dirname(source)
            val name = stem(source)
            val output = join2(dir, name + ".o")
            expect(output).to_equal("/home/user/project/src/main.o")

        it "resolves relative import path":
            val cwd = "/home/user/project"
            val relative = "../lib/utils.spl"
            val absolute = normalize(join2(cwd, relative))
            expect(absolute).to_equal("/home/user/lib/utils.spl")

        it "builds release package path":
            val root = "/project"
            val release_dir = join2(root, "build/release")
            val pkg = join2(release_dir, "simple-0.1.0")
            expect(pkg).to_equal("/project/build/release/simple-0.1.0")

    describe "split_path":
        it "splits unix path":
            val parts = split_path("/home/user/documents/file.txt")
            expect(parts.len()).to_equal(4)
            expect(parts[0]).to_equal("home")
            expect(parts[3]).to_equal("file.txt")

        it "splits windows path after normalization":
            val parts = split_path("C:\\Users\\user\\file.txt")
            expect(parts.len()).to_be_greater_than(0)
            expect(parts).to_contain("Users")
            expect(parts).to_contain("file.txt")

        it "handles empty path":
            val parts = split_path("")
            expect(parts.len()).to_equal(0)
