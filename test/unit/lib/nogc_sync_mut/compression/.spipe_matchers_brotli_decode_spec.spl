# brotli_decode_spec.spl — RFC 7932 brotli decoder smoke tests
#
# Coverage level: uncompressed meta blocks (RFC 7932 §9.2, ISUNCOMPRESSED=1)
# plus stream framing (WBITS, ISLAST, ISLASTEMPTY).
#
# Test byte fixtures are hand-crafted per RFC 7932 and verified
# with the JavaScript bit-layout simulator in the commit notes.
#
# Byte layout (LSB-first packing):
#   Empty stream [0x06]:
#     bit0=0 (WBITS=16), bit1=1 (ISLAST=1), bit2=1 (ISLASTEMPTY=1)
#
#   Uncompressed "Hello" [0x40,0x00,0x10, 0x48,0x65,0x6c,0x6c,0x6f, 0x03]:
#     Byte 0 = 0x40: bit0=0 (WBITS=16), bit1=0 (ISLAST=0),
#              bit2-3=0b00 (MNIBBLES_code=0 -> 4 nibbles = 16-bit MLEN-1),
#              bit4-6=0b001 (MLEN-1 low bits: value 4, i.e., MLEN=5), bit7=0
#     Byte 1 = 0x00: MLEN-1 high byte (0)
#     Byte 2 = 0x10: bit0-3=0 (MLEN-1 nibble 3-4 = 0), bit4=1 (ISUNCOMPRESSED=1),
#              bits5-7=0 (padding to byte boundary)
#     Bytes 3-7: raw "Hello" = 0x48 0x65 0x6c 0x6c 0x6f
#     Byte 8 = 0x03: bit0=1 (ISLAST=1), bit1=1 (ISLASTEMPTY=1), bits2-7=0 (padding)

use std.spec.{describe, it, expect}
use std.nogc_sync_mut.compression.brotli.decoder.{brotli_decode}
use std.common.compress.types.{CompressionError}

# ---- fixture helpers (module-scope to avoid interpreter mutation issues) ----

fn _empty_brotli() -> [u8]:
    # [0x06] = WBITS=16, ISLAST=1, ISLASTEMPTY=1
    [0x06u8]

fn _uncompressed_hello_brotli() -> [u8]:
    # Hand-crafted uncompressed brotli stream containing "Hello" (5 bytes)
    # See file header for bit layout.
    [
        0x40u8,  # WBITS=16, ISLAST=0, MNIBBLES=0 (4 nibbles), MLEN-1 bits 0-2=001
        0x00u8,  # MLEN-1 bits 3-10 = 0
        0x10u8,  # MLEN-1 bits 11-15 = 0, ISUNCOMPRESSED=1, padding
        0x48u8,  # 'H'
        0x65u8,  # 'e'
        0x6cu8,  # 'l'
        0x6cu8,  # 'l'
        0x6fu8,  # 'o'
        0x03u8   # ISLAST=1, ISLASTEMPTY=1, padding
    ]

fn _uncompressed_hello_world_brotli() -> [u8]:
    # "Hello World" = 11 bytes, MLEN-1=10=0x000A
    # Byte 0: bit0=0(WBITS), bit1=0(ISLAST), bit2-3=0(MNIBBLES_code),
    #         bit4-7 = MLEN-1[0..3] = low nibble of 10 = 0b1010 => bits: 0,1,0,1
    # => byte0 = (0 | 0<<1 | 0<<2 | 0<<3 | 0<<4 | 1<<5 | 0<<6 | 1<<7) = 0b10100000 = 0xA0
    # Byte 1: MLEN-1[4..11] = 0 => 0x00
    # Byte 2: MLEN-1[12..15] = 0, ISUNCOMPRESSED=1, padding
    #         bits 0-3=0, bit4=1, bits5-7=0 => 0x10
    # Bytes 3-13: "Hello World" = 0x48 0x65 0x6c 0x6c 0x6f 0x20 0x57 0x6f 0x72 0x6c 0x64
    # Byte 14: 0x03 (final empty block)
    [
        0xA0u8,
        0x00u8,
        0x10u8,
        0x48u8,  # 'H'
        0x65u8,  # 'e'
        0x6cu8,  # 'l'
        0x6cu8,  # 'l'
        0x6fu8,  # 'o'
        0x20u8,  # ' '
        0x57u8,  # 'W'
        0x6fu8,  # 'o'
        0x72u8,  # 'r'
        0x6cu8,  # 'l'
        0x64u8,  # 'd'
        0x03u8
    ]

fn _truncated_stream() -> [u8]:
    # Starts valid (WBITS=16, ISLAST=0, MNIBBLES=4), then cuts off mid MLEN-1
    [0x40u8]

fn _aaaa_compressed_brotli() -> [u8]:
    # Literal-only compressed brotli stream for "AAAA" (4 x 0x41).
    # Generated by Python bit-emitter (brotli_emit.py scratch); verified 72 bits.
    # Stream: WBITS=16, MLEN=4, ISUNCOMPRESSED=0, all NBLTYPES=1, NTREESL=NTREESD=1,
    #   simple-prefix trees (NSYM=1): lit=0x41, ICP=32(insert4+copy2), dist=0.
    #   DATA=0 bits (all 1-symbol trees); 4 inserts fill MLEN; copy skipped.
    [
        0x30u8,  # WBITS=16, ISLAST=0, MNIBBLES_code=0, MLEN-1[0..3]=3
        0x00u8,  # MLEN-1[4..11]=0
        0x00u8,  # MLEN-1[12..15]=0, ISUNCOMPRESSED=0, NBLTYPESL=1, NBLTYPESI=1, NBLTYPESD=1
        0x00u8,  # NPOSTFIX=0, NDIRECT=0, CMODE[0]=0
        0x26u8,  # NTREESL=1, LitTree HSKIP=11 NSYM=00, sym 0x41 low5
        0x68u8,  # sym 0x41 high3, ICP HSKIP=11 NSYM=00, sym32 low2
        0x40u8,  # ICP sym32 bits 2..9
        0x30u8,  # NTREESD=1, Dist HSKIP=11 NSYM=00, sym0 low2
        0xC0u8   # Dist sym0 bits 2..5, ISLAST=1, ISLASTEMPTY=1
    ]

fn _copy_needed_brotli() -> [u8]:
    # Same structure as _aaaa_compressed_brotli() but MLEN=5 (MLEN-1=4).
    # After inserting 4 bytes, output.len()=4 < mlen=5 => copy command required.
    # Expects: Err(UnsupportedFeature("brotli copy command"))
    [
        0x40u8,  # WBITS=16, ISLAST=0, MNIBBLES_code=0, MLEN-1[0..3]=4
        0x00u8,
        0x00u8,
        0x00u8,
        0x26u8,
        0x68u8,
        0x40u8,
        0x30u8,
        0xC0u8
    ]

fn _nbltypesl2_brotli() -> [u8]:
    # Compressed block with NBLTYPESL=2 (VarLenUint8=1: bit0=1, n=0b000).
    # Stream: WBITS=16, ISLAST=0, MNIBBLES_code=0, MLEN=4, ISUNCOMPRESSED=0,
    #   NBLTYPESL=2 (4 bits: 1,0,0,0).
    # Decoder errors at NBLTYPESL check before reading any prefix trees.
    # Bits: 0(WBITS) 0(ISLAST) 00(MNIBBLES) 0000000000000011(MLEN-1=3) 0(ISU)
    #       1(VarLen b0) 000(VarLen n=0 -> value=1 -> NBLTYPESL=2)
    # = 4 bytes: 0x30 0x00 0x20 0x00
    [
        0x30u8,  # WBITS=16, ISLAST=0, MNIBBLES_code=0, MLEN-1[0..3]=3
        0x00u8,  # MLEN-1[4..11]=0
        0x20u8,  # MLEN-1[12..15]=0, ISUNCOMPRESSED=0, VarLen NBLTYPESL bit0=1
        0x00u8   # VarLen NBLTYPESL n=0 (bits 1-3 of byte2 = 000)
    ]

fn _expect_err_contains(result: Result<[u8], CompressionError>, kind: text, part: text):
    match result:
        Ok(_): expect(false).to_equal(true)
        Err(err):
            match err:
                CompressionError.TruncatedInput(message):
                    expect kind == "TruncatedInput"
                    expect (message).contains(part)
                CompressionError.InvalidHeader(message):
                    expect kind == "InvalidHeader"
                    expect (message).contains(part)
                CompressionError.UnsupportedFeature(message):
                    expect kind == "UnsupportedFeature"
                    expect (message).contains(part)
                CompressionError.CorruptStream(message):
                    expect kind == "CorruptStream"
                    expect (message).contains(part)
                CompressionError.ChecksumMismatch(message):
                    expect kind == "ChecksumMismatch"
                    expect (message).contains(part)
                CompressionError.SizeLimitExceeded(_):
                    expect kind == "SizeLimitExceeded"

fn _bytes_equal(a: [u8], b: [u8]) -> bool:
    if a.len() != b.len():
        return false
    var i = 0
    while i < a.len():
        if a[i] != b[i]:
            return false
        i = i + 1
    true

# ---- specs ----

describe("brotli_decode — empty stream"):
    it("decodes empty brotli stream to empty byte slice"):
        val result = brotli_decode(_empty_brotli())
        expect result.is_err() == false
        val out = result.unwrap()
        expect out.len() == 0

describe("brotli_decode — uncompressed meta blocks"):
    it("decodes uncompressed 'Hello' (5 bytes)"):
        val result = brotli_decode(_uncompressed_hello_brotli())
        expect result.is_err() == false
        val out = result.unwrap()
        expect out.len() == 5
        val expected: [u8] = [0x48u8, 0x65u8, 0x6cu8, 0x6cu8, 0x6fu8]
        expect _bytes_equal(out, expected) == true

    it("decodes uncompressed 'Hello World' (11 bytes)"):
        val result = brotli_decode(_uncompressed_hello_world_brotli())
        expect result.is_err() == false
        val out = result.unwrap()
        expect out.len() == 11
        val expected: [u8] = [
            0x48u8, 0x65u8, 0x6cu8, 0x6cu8, 0x6fu8,
            0x20u8,
            0x57u8, 0x6fu8, 0x72u8, 0x6cu8, 0x64u8
        ]
        expect _bytes_equal(out, expected) == true

describe("brotli_decode — error cases"):
    it("returns TruncatedInput for empty byte slice"):
        val result = brotli_decode([])
        _expect_err_contains(result, "TruncatedInput", "brotli empty input")

    it("returns TruncatedInput for truncated stream"):
        val result = brotli_decode(_truncated_stream())
        expect result.is_err() == true

    it("returns UnsupportedFeature for a compressed last meta block"):
        # Single-byte 0x02: bit0=0(WBITS=16), bit1=1(ISLAST=1), bit2=0(ISLASTEMPTY=0)
        # => ISLAST=1 but not empty => compressed last block => UnsupportedFeature
        val result = brotli_decode([0x02u8])
        _expect_err_contains(result, "UnsupportedFeature", "brotli compressed last meta block")

describe("brotli_decode — compressed meta blocks (literal-only tier)"):
    it("decodes literal-only compressed block 'AAAA' (4 bytes)"):
        # Hand-crafted brotli stream: WBITS=16, ISLAST=0, MNIBBLES_code=0 (4 nibbles),
        # MLEN=4, ISUNCOMPRESSED=0, NBLTYPESL/I/D=1, NPOSTFIX=0, NDIRECT=0,
        # CMODE[0]=0, NTREESL=1, Lit-tree(simple,NSYM=1,sym=0x41='A'),
        # ICP-tree(simple,NSYM=1,sym=32=insert4+copy2), NTREESD=1,
        # Dist-tree(simple,NSYM=1,sym=0), DATA=0bits (insert 4 x 'A', MLEN reached),
        # Final: ISLAST=1, ISLASTEMPTY=1.
        #
        # Generated by Python bit-emitter; verified bit-by-bit (72 bits = 9 bytes):
        #   B0=0x30: WBITS=16(0), ISLAST=0(0), MNIBBLES_code=00, MLEN-1[0..3]=0011(3)
        #   B1=0x00: MLEN-1[4..11]=0
        #   B2=0x00: MLEN-1[12..15]=0, ISUNCOMPRESSED=0, NBLTYPESL=1(0),
        #            NBLTYPESI=1(0), NBLTYPESD=1(0)
        #   B3=0x00: NPOSTFIX=00, NDIRECT=0000, CMODE[0]=00
        #   B4=0x26: NTREESL=1(0), LitTree: HSKIP=11, NSYM=00, sym[0..4]=00110(0x41 lo)
        #   B5=0x68: sym[5..7]=100, ICP: HSKIP=11, NSYM=00, sym[0..1]=00
        #   B6=0x40: ICP sym[2..9]=00100000 (sym=32 in 10 bits)
        #   B7=0x30: NTREESD=1(0), Dist: HSKIP=11, NSYM=00, sym[0..1]=00
        #   B8=0xC0: Dist sym[2..5]=0000, ISLAST=1, ISLASTEMPTY=1, padding
        val result = brotli_decode(_aaaa_compressed_brotli())
        expect result.is_err() == false
        val out = result.unwrap()
        expect out.len() == 4
        val expected: [u8] = [0x41u8, 0x41u8, 0x41u8, 0x41u8]
        expect _bytes_equal(out, expected) == true

    it("returns UnsupportedFeature when copy command is required (MLEN > insert)"):
        # Same structure as AAAA stream but MLEN=5 (MLEN-1=4=0x40 in low byte).
        # After inserting 4 bytes ('A' x 4), output.len()=4 < mlen=5 =>
        # a copy command is required => UnsupportedFeature("brotli copy command").
        val result = brotli_decode(_copy_needed_brotli())
        _expect_err_contains(result, "UnsupportedFeature", "brotli copy command")

    it("returns UnsupportedFeature for block type switching (NBLTYPESL > 1)"):
        # Stream with NBLTYPESL=2; decoder errors before reading any prefix trees.
        # Tier-3 fallback for RFC 7932 block-switch decoder (not yet implemented).
        val result = brotli_decode(_nbltypesl2_brotli())
        _expect_err_contains(result, "UnsupportedFeature", "NBLTYPESL > 1")