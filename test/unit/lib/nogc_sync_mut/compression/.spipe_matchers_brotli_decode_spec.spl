# brotli_decode_spec.spl — RFC 7932 brotli decoder smoke tests
#
# Coverage level: uncompressed meta blocks (RFC 7932 §9.2, ISUNCOMPRESSED=1)
# plus stream framing (WBITS, ISLAST, ISLASTEMPTY).
#
# Test byte fixtures are hand-crafted per RFC 7932 and verified
# with the JavaScript bit-layout simulator in the commit notes.
#
# Byte layout (LSB-first packing):
#   Empty stream [0x06]:
#     bit0=0 (WBITS=16), bit1=1 (ISLAST=1), bit2=1 (ISLASTEMPTY=1)
#
#   Uncompressed "Hello" [0x40,0x00,0x10, 0x48,0x65,0x6c,0x6c,0x6f, 0x03]:
#     Byte 0 = 0x40: bit0=0 (WBITS=16), bit1=0 (ISLAST=0),
#              bit2-3=0b00 (MNIBBLES_code=0 -> 4 nibbles = 16-bit MLEN-1),
#              bit4-6=0b001 (MLEN-1 low bits: value 4, i.e., MLEN=5), bit7=0
#     Byte 1 = 0x00: MLEN-1 high byte (0)
#     Byte 2 = 0x10: bit0-3=0 (MLEN-1 nibble 3-4 = 0), bit4=1 (ISUNCOMPRESSED=1),
#              bits5-7=0 (padding to byte boundary)
#     Bytes 3-7: raw "Hello" = 0x48 0x65 0x6c 0x6c 0x6f
#     Byte 8 = 0x03: bit0=1 (ISLAST=1), bit1=1 (ISLASTEMPTY=1), bits2-7=0 (padding)

use std.spec.{describe, it, expect}
use std.nogc_sync_mut.compression.brotli.decoder.{brotli_decode}
use std.common.compress.types.{CompressionError}

# ---- fixture helpers (module-scope to avoid interpreter mutation issues) ----

fn _empty_brotli() -> [u8]:
    # [0x06] = WBITS=16, ISLAST=1, ISLASTEMPTY=1
    [0x06u8]

fn _uncompressed_hello_brotli() -> [u8]:
    # Hand-crafted uncompressed brotli stream containing "Hello" (5 bytes)
    # See file header for bit layout.
    [
        0x40u8,  # WBITS=16, ISLAST=0, MNIBBLES=0 (4 nibbles), MLEN-1 bits 0-2=001
        0x00u8,  # MLEN-1 bits 3-10 = 0
        0x10u8,  # MLEN-1 bits 11-15 = 0, ISUNCOMPRESSED=1, padding
        0x48u8,  # 'H'
        0x65u8,  # 'e'
        0x6cu8,  # 'l'
        0x6cu8,  # 'l'
        0x6fu8,  # 'o'
        0x03u8   # ISLAST=1, ISLASTEMPTY=1, padding
    ]

fn _uncompressed_hello_world_brotli() -> [u8]:
    # "Hello World" = 11 bytes, MLEN-1=10=0x000A
    # Byte 0: bit0=0(WBITS), bit1=0(ISLAST), bit2-3=0(MNIBBLES_code),
    #         bit4-7 = MLEN-1[0..3] = low nibble of 10 = 0b1010 => bits: 0,1,0,1
    # => byte0 = (0 | 0<<1 | 0<<2 | 0<<3 | 0<<4 | 1<<5 | 0<<6 | 1<<7) = 0b10100000 = 0xA0
    # Byte 1: MLEN-1[4..11] = 0 => 0x00
    # Byte 2: MLEN-1[12..15] = 0, ISUNCOMPRESSED=1, padding
    #         bits 0-3=0, bit4=1, bits5-7=0 => 0x10
    # Bytes 3-13: "Hello World" = 0x48 0x65 0x6c 0x6c 0x6f 0x20 0x57 0x6f 0x72 0x6c 0x64
    # Byte 14: 0x03 (final empty block)
    [
        0xA0u8,
        0x00u8,
        0x10u8,
        0x48u8,  # 'H'
        0x65u8,  # 'e'
        0x6cu8,  # 'l'
        0x6cu8,  # 'l'
        0x6fu8,  # 'o'
        0x20u8,  # ' '
        0x57u8,  # 'W'
        0x6fu8,  # 'o'
        0x72u8,  # 'r'
        0x6cu8,  # 'l'
        0x64u8,  # 'd'
        0x03u8
    ]

fn _truncated_stream() -> [u8]:
    # Starts valid (WBITS=16, ISLAST=0, MNIBBLES=4), then cuts off mid MLEN-1
    [0x40u8]

fn _expect_err_contains(result: Result<[u8], CompressionError>, kind: text, part: text):
    match result:
        Ok(_): expect(false).to_equal(true)
        Err(err):
            match err:
                CompressionError.TruncatedInput(message):
                    expect kind == "TruncatedInput"
                    expect (message).contains(part)
                CompressionError.InvalidHeader(message):
                    expect kind == "InvalidHeader"
                    expect (message).contains(part)
                CompressionError.UnsupportedFeature(message):
                    expect kind == "UnsupportedFeature"
                    expect (message).contains(part)
                CompressionError.CorruptStream(message):
                    expect kind == "CorruptStream"
                    expect (message).contains(part)
                CompressionError.ChecksumMismatch(message):
                    expect kind == "ChecksumMismatch"
                    expect (message).contains(part)
                CompressionError.SizeLimitExceeded(_):
                    expect kind == "SizeLimitExceeded"

fn _bytes_equal(a: [u8], b: [u8]) -> bool:
    if a.len() != b.len():
        return false
    var i = 0
    while i < a.len():
        if a[i] != b[i]:
            return false
        i = i + 1
    true

# ---- specs ----

describe("brotli_decode — empty stream"):
    it("decodes empty brotli stream to empty byte slice"):
        val result = brotli_decode(_empty_brotli())
        expect result.is_err() == false
        val out = result.unwrap()
        expect out.len() == 0

describe("brotli_decode — uncompressed meta blocks"):
    it("decodes uncompressed 'Hello' (5 bytes)"):
        val result = brotli_decode(_uncompressed_hello_brotli())
        expect result.is_err() == false
        val out = result.unwrap()
        expect out.len() == 5
        val expected: [u8] = [0x48u8, 0x65u8, 0x6cu8, 0x6cu8, 0x6fu8]
        expect _bytes_equal(out, expected) == true

    it("decodes uncompressed 'Hello World' (11 bytes)"):
        val result = brotli_decode(_uncompressed_hello_world_brotli())
        expect result.is_err() == false
        val out = result.unwrap()
        expect out.len() == 11
        val expected: [u8] = [
            0x48u8, 0x65u8, 0x6cu8, 0x6cu8, 0x6fu8,
            0x20u8,
            0x57u8, 0x6fu8, 0x72u8, 0x6cu8, 0x64u8
        ]
        expect _bytes_equal(out, expected) == true

describe("brotli_decode — error cases"):
    it("returns TruncatedInput for empty byte slice"):
        val result = brotli_decode([])
        _expect_err_contains(result, "TruncatedInput", "brotli empty input")

    it("returns TruncatedInput for truncated stream"):
        val result = brotli_decode(_truncated_stream())
        expect result.is_err() == true

    it("returns UnsupportedFeature for a compressed meta block"):
        # Single-byte 0x02: bit0=0(WBITS=16), bit1=1(ISLAST=1), bit2=0(ISLASTEMPTY=0)
        # => ISLAST=1 but not empty => compressed last block => UnsupportedFeature
        val result = brotli_decode([0x02u8])
        _expect_err_contains(result, "UnsupportedFeature", "brotli compressed last meta block")