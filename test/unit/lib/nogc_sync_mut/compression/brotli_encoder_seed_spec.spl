# brotli_encoder_seed_spec.spl — RFC 7932 brotli encoder seed round-trip
#
# Seeds the pure-Simple brotli encoder.  Uncompressed meta blocks only
# (RFC 7932 §9.1 + §3.5).  Verification strategy: encode → decode → compare.
# The decoder is the existing landed reference (Wave 1, ssouypqzlupz).
#
# Coverage: empty, 1 byte, 100-byte ASCII, 1 KiB pseudo-random.
# Plus stream-header validation that output begins with WBITS=16 marker bit
# and (where applicable) ends with the ISLAST/ISLASTEMPTY terminator byte.

use std.spec.{describe, it, expect}
use std.nogc_sync_mut.compression.brotli.decoder.{brotli_decode}
use std.nogc_sync_mut.compression.brotli.encoder.{brotli_encode_uncompressed}
use std.common.compress.types.{CompressionError}

# ---- fixture helpers (module-scope to avoid interpreter mutation issues) ----

fn _bytes_equal(a: [u8], b: [u8]) -> bool:
    if a.len() != b.len():
        return false
    var i = 0
    while i < a.len():
        if a[i] != b[i]:
            return false
        i = i + 1
    true

fn _empty_payload() -> [u8]:
    val out: [u8] = []
    out

fn _one_byte_payload() -> [u8]:
    [0x5au8]

fn _ascii_100_payload() -> [u8]:
    # 100 ASCII bytes built deterministically: 'A' + (i mod 26).
    var out: [u8] = []
    var i = 0
    while i < 100:
        val ch = (0x41 + (i % 26)).to_u8()
        out.push(ch)
        i = i + 1
    out

fn _kib_payload() -> [u8]:
    # 1 KiB pseudo-random byte payload via a small LCG (deterministic so
    # any future regression is reproducible).  state * 1103515245 + 12345
    # mod 2^31, take low 8 bits per output byte.
    var out: [u8] = []
    var state: i64 = 0xC0FFEE
    var i = 0
    while i < 1024:
        state = (state * 1103515245 + 12345) & 0x7fffffff
        val byte_val = (state & 0xff).to_u8()
        out.push(byte_val)
        i = i + 1
    out

# Run encode → decode and assert the result matches `payload`.
fn _round_trip_ok(payload: [u8]) -> bool:
    val encoded = brotli_encode_uncompressed(payload)
    val decoded_res = brotli_decode(encoded)
    if decoded_res.is_err():
        return false
    val decoded = decoded_res.unwrap()
    _bytes_equal(decoded, payload)

# ---- specs ----

describe("brotli_encode_uncompressed — round trip via decoder"):

    it("encodes empty payload to canonical [0x06] and decodes back"):
        val payload = _empty_payload()
        val encoded = brotli_encode_uncompressed(payload)
        # Empty stream canonical form: WBITS=16 (1 bit 0) + ISLAST=1 +
        # ISLASTEMPTY=1, padded to one byte ⇒ 0b00000110 = 0x06
        expect(encoded.len()).to_equal(1)
        expect(encoded[0]).to_equal(0x06u8)
        val decoded_res = brotli_decode(encoded)
        expect(decoded_res.is_err()).to_equal(false)
        val decoded = decoded_res.unwrap()
        expect(decoded.len()).to_equal(0)

    it("encodes 1-byte payload and decodes back"):
        val payload = _one_byte_payload()
        expect(_round_trip_ok(payload)).to_equal(true)

    it("encodes 100-byte ASCII payload and decodes back"):
        val payload = _ascii_100_payload()
        expect(payload.len()).to_equal(100)
        expect(_round_trip_ok(payload)).to_equal(true)

    it("encodes 1 KiB pseudo-random payload and decodes back"):
        val payload = _kib_payload()
        expect(payload.len()).to_equal(1024)
        expect(_round_trip_ok(payload)).to_equal(true)

describe("brotli_encode_uncompressed — stream header"):

    it("non-empty stream begins with WBITS=16 (bit 0 of byte 0 is 0)"):
        # WBITS=16 prefix is single 0 bit.  Then ISLAST=0, MNIBBLES_code=0,
        # so the low 4 bits of byte 0 must all be zero for a non-empty
        # uncompressed-only stream.
        val payload = _ascii_100_payload()
        val encoded = brotli_encode_uncompressed(payload)
        expect(encoded.len() > 0).to_equal(true)
        val byte0 = encoded[0].to_i64()
        # bit 0: WBITS=16 ⇒ 0
        expect(byte0 & 0x01).to_equal(0)
        # bit 1: ISLAST=0 (first non-empty meta block is not last)
        expect(byte0 & 0x02).to_equal(0)
        # bits 2-3: MNIBBLES_code=0
        expect(byte0 & 0x0c).to_equal(0)
