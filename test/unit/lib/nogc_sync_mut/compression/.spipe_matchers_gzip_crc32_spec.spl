# Specification for src/lib/nogc_sync_mut/compression/gzip/crc.spl
#
# Verifies the CRC32 (IEEE 802.3) implementation against canonical
# reference values that any standard CRC32 tool (zlib, libcrc, etc.)
# would produce for the same inputs.

use std.spipe.*
use std.nogc_sync_mut.compression.gzip.crc.{
    crc32_table,
    crc32_calculate,
    crc32_update,
    crc32_finalize,
    crc32_chunked,
    crc32_verify,
}

fn _bytes(s: [u8]) -> [u8]:
    s

# Canonical inputs as ASCII byte literals.
fn _bytes_a() -> [u8]:
    [0x61u8]

fn _bytes_abc() -> [u8]:
    [0x61u8, 0x62u8, 0x63u8]

fn _bytes_alphabet() -> [u8]:
    [
        0x61u8, 0x62u8, 0x63u8, 0x64u8, 0x65u8, 0x66u8, 0x67u8, 0x68u8,
        0x69u8, 0x6au8, 0x6bu8, 0x6cu8, 0x6du8, 0x6eu8, 0x6fu8, 0x70u8,
        0x71u8, 0x72u8, 0x73u8, 0x74u8, 0x75u8, 0x76u8, 0x77u8, 0x78u8,
        0x79u8, 0x7au8
    ]

fn _bytes_123456789() -> [u8]:
    [0x31u8, 0x32u8, 0x33u8, 0x34u8, 0x35u8, 0x36u8, 0x37u8, 0x38u8, 0x39u8]

describe "CRC32 lookup table":

    it "has exactly 256 entries":
        val t = crc32_table()
        expect t.len() == 256

    it "table[0] is 0":
        val t = crc32_table()
        expect t[0] == 0

    it "table[1] is 0x77073096 (canonical CRC32 IEEE)":
        val t = crc32_table()
        expect t[1] == 0x77073096

    it "table[2] is 0xee0e612c":
        val t = crc32_table()
        expect t[2] == 0xee0e612c

    it "table[8] is 0x0edb8832":
        # Boundary between the original 16-entry table and the new entries.
        val t = crc32_table()
        expect t[8] == 0x0edb8832

    it "table[15] is 0x90bf1d91 (last entry of original truncated table)":
        val t = crc32_table()
        expect t[15] == 0x90bf1d91

    it "table[255] is 0x2d02ef8d (last entry of the canonical full table)":
        val t = crc32_table()
        expect t[255] == 0x2d02ef8d

describe "CRC32 calculation against canonical IEEE 802.3 reference values":

    it "empty data returns 0":
        # CRC32 of empty input is 0xffffffff XOR 0xffffffff = 0.
        expect crc32_calculate([]) == 0

    it "'a' (0x61) returns 0xe8b7be43":
        expect crc32_calculate(_bytes_a()) == 0xe8b7be43

    it "'abc' returns 0x352441c2":
        expect crc32_calculate(_bytes_abc()) == 0x352441c2

    it "lowercase alphabet 'abcdefghijklmnopqrstuvwxyz' returns 0x4c2750bd":
        expect crc32_calculate(_bytes_alphabet()) == 0x4c2750bd

    it "'123456789' (CRC32 standard test vector) returns 0xcbf43926":
        expect crc32_calculate(_bytes_123456789()) == 0xcbf43926

describe "CRC32 streaming and chunked":

    it "single-chunk streaming matches one-shot":
        var crc: i64 = 0xffffffff
        crc = crc32_update(crc, _bytes_abc())
        expect crc32_finalize(crc) == 0x352441c2

    it "multi-chunk streaming matches one-shot":
        var crc: i64 = 0xffffffff
        crc = crc32_update(crc, _bytes_a())
        crc = crc32_update(crc, [0x62u8])
        crc = crc32_update(crc, [0x63u8])
        expect crc32_finalize(crc) == 0x352441c2

    it "crc32_chunked over [a, b, c] matches one-shot 'abc'":
        val chunks: [[u8]] = [_bytes_a(), [0x62u8], [0x63u8]]
        expect crc32_chunked(chunks) == 0x352441c2

    it "crc32_chunked over empty list returns 0 (CRC32 of empty)":
        val empty_chunks: [[u8]] = []
        expect crc32_chunked(empty_chunks) == 0

describe "CRC32 verification":

    it "verifies a correct CRC":
        expect crc32_verify(_bytes_abc(), 0x352441c2) == true

    it "rejects a wrong CRC":
        expect crc32_verify(_bytes_abc(), 0xdeadbeef) == false