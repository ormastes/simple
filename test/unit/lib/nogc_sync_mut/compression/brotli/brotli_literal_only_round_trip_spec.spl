# brotli_literal_only_round_trip_spec.spl
#
# Round-trip tests for the literal-only compressed brotli path
# (RFC 7932 §9.2 last-copy-omitted, simple prefix codes NSYM<=4).
#
# The encoder picks the compressed path when distinct(input).len() <= 4,
# otherwise it falls back to uncompressed.  Both paths must round-trip
# byte-exactly through the decoder.

use std.spec.{describe, it, expect}
use std.nogc_sync_mut.compression.brotli.decoder.{brotli_decode}
use std.nogc_sync_mut.compression.brotli.encoder.{brotli_encode_uncompressed, brotli_encode}
use std.common.compress.types.{CompressionError}

# ---- helpers ----

fn _bytes_equal(a: [u8], b: [u8]) -> bool:
    if a.len() != b.len():
        return false
    var i = 0
    while i < a.len():
        if a[i] != b[i]:
            return false
        i = i + 1
    true

# 32 bytes of 'A' (NSYM=1 compressed path).
fn _all_a_32() -> [u8]:
    var out: [u8] = []
    var i = 0
    while i < 32:
        out.push(0x41u8)
        i = i + 1
    out

# 64 bytes alternating 'A','B' (NSYM=2 path).
fn _ab_alt_64() -> [u8]:
    var out: [u8] = []
    var i = 0
    while i < 64:
        if (i % 2) == 0:
            out.push(0x41u8)
        else:
            out.push(0x42u8)
        i = i + 1
    out

# 256 bytes cycling 'A','B','C' (NSYM=3 path).
fn _abc_cycle_256() -> [u8]:
    var out: [u8] = []
    var i = 0
    while i < 256:
        val r = i % 3
        if r == 0:
            out.push(0x41u8)
        elif r == 1:
            out.push(0x42u8)
        else:
            out.push(0x43u8)
        i = i + 1
    out

# 1024 bytes cycling 'A','B','C','D' (NSYM=4 path).
fn _abcd_cycle_1024() -> [u8]:
    var out: [u8] = []
    var i = 0
    while i < 1024:
        val r = i % 4
        if r == 0:
            out.push(0x41u8)
        elif r == 1:
            out.push(0x42u8)
        elif r == 2:
            out.push(0x43u8)
        else:
            out.push(0x44u8)
        i = i + 1
    out

# 4096 bytes pseudo-random (5+ distinct => uncompressed fallback).
fn _random_4096() -> [u8]:
    var out: [u8] = []
    var state: i64 = 0xC0FFEE
    var i = 0
    while i < 4096:
        state = (state * 1103515245 + 12345) & 0x7fffffff
        out.push((state & 0xff).to_u8())
        i = i + 1
    out

# Single byte (edge case: tiny meta block via compressed path, NSYM=1).
fn _one_byte() -> [u8]:
    [0x5au8]

fn _empty() -> [u8]:
    val out: [u8] = []
    out

# ---- specs ----

describe("brotli_encode (literal-only) — round-trip"):

    it("round-trips 32-byte all-'A' input via compressed NSYM=1 path"):
        val payload = _all_a_32()
        val encoded = brotli_encode(payload)
        val result = brotli_decode(encoded)
        expect(result.is_err()).to_equal(false)
        val out = result.unwrap()
        expect(_bytes_equal(out, payload)).to_equal(true)

    it("round-trips 64-byte 'ABAB...' input via compressed NSYM=2 path"):
        val payload = _ab_alt_64()
        val encoded = brotli_encode(payload)
        val result = brotli_decode(encoded)
        expect(result.is_err()).to_equal(false)
        val out = result.unwrap()
        expect(_bytes_equal(out, payload)).to_equal(true)

    it("round-trips 256-byte 'ABCABC...' input via compressed NSYM=3 path"):
        val payload = _abc_cycle_256()
        val encoded = brotli_encode(payload)
        val result = brotli_decode(encoded)
        expect(result.is_err()).to_equal(false)
        val out = result.unwrap()
        expect(_bytes_equal(out, payload)).to_equal(true)

    it("round-trips 1024-byte 'ABCDABCD...' input via compressed NSYM=4 path"):
        val payload = _abcd_cycle_1024()
        val encoded = brotli_encode(payload)
        val result = brotli_decode(encoded)
        expect(result.is_err()).to_equal(false)
        val out = result.unwrap()
        expect(_bytes_equal(out, payload)).to_equal(true)

    it("round-trips 4096-byte random input via uncompressed fallback"):
        val payload = _random_4096()
        val encoded = brotli_encode(payload)
        val result = brotli_decode(encoded)
        expect(result.is_err()).to_equal(false)
        val out = result.unwrap()
        expect(_bytes_equal(out, payload)).to_equal(true)

    it("round-trips empty input via ISLASTEMPTY=1 path"):
        val payload = _empty()
        val encoded = brotli_encode(payload)
        val result = brotli_decode(encoded)
        expect(result.is_err()).to_equal(false)
        val out = result.unwrap()
        expect(out.len()).to_equal(0)

    it("round-trips a single byte via tiny compressed meta block"):
        val payload = _one_byte()
        val encoded = brotli_encode(payload)
        val result = brotli_decode(encoded)
        expect(result.is_err()).to_equal(false)
        val out = result.unwrap()
        expect(_bytes_equal(out, payload)).to_equal(true)

describe("brotli_encode (literal-only) — size targets"):

    it("achieves >= 15% reduction on 1024-byte ABCDABCD payload"):
        # NSYM=4 path: each literal becomes a 2-bit codeword instead of
        # 8 raw bits.  Header overhead is ~50 bytes; payload 1024 raw bytes
        # vs 1024*2/8 = 256 compressed bytes -> ~70% reduction expected.
        val payload = _abcd_cycle_1024()
        val raw = brotli_encode_uncompressed(payload)
        val compressed = brotli_encode(payload)
        val reduction_num = (raw.len() - compressed.len()) * 100
        val reduction_pct = reduction_num / raw.len()
        expect(reduction_pct >= 15).to_equal(true)

    it("uncompressed fallback chosen when input is high-entropy random"):
        # 4096 random bytes have >4 distinct symbols -> compressed path
        # rejected by encoder; falls back to uncompressed.
        val payload = _random_4096()
        val raw = brotli_encode_uncompressed(payload)
        val out = brotli_encode(payload)
        expect(out.len() == raw.len()).to_equal(true)
