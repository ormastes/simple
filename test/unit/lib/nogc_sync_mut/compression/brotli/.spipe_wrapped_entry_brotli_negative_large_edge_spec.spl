use std.common.compress.types.{CompressionError}
use std.nogc_sync_mut.compression.brotli.decoder.{brotli_decode}
use std.nogc_sync_mut.compression.brotli.encoder.{brotli_encode_uncompressed}
use std.nogc_sync_mut.compression.brotli.bit_writer.{
    brotli_bits_writer_init,
    brotli_bits_write,
    brotli_bits_write_varlen_uint8,
    brotli_bits_write_simple_prefix,
    brotli_bits_writer_finish
}

fn _bytes_equal(a: [u8], b: [u8]) -> bool:
    if a.len() != b.len():
        return false
    var i = 0
    while i < a.len():
        if a[i] != b[i]:
            return false
        i = i + 1
    true

fn _patterned_payload(size: i64) -> [u8]:
    var out: [u8] = []
    var i = 0
    while i < size:
        out.push((((i * 17) + (i / 13) + 23) % 251).to_u8())
        i = i + 1
    out

fn _expect_compression_error(err: CompressionError, kind: text, message_part: text):
    match err:
        CompressionError.InvalidHeader(message):
            expect kind == "InvalidHeader"
            expect (message).contains(message_part)
        CompressionError.UnsupportedFeature(message):
            expect kind == "UnsupportedFeature"
            expect (message).contains(message_part)
        CompressionError.TruncatedInput(message):
            expect kind == "TruncatedInput"
            expect (message).contains(message_part)
        CompressionError.ChecksumMismatch(message):
            expect kind == "ChecksumMismatch"
            expect (message).contains(message_part)
        CompressionError.CorruptStream(message):
            expect kind == "CorruptStream"
            expect (message).contains(message_part)
        CompressionError.SizeLimitExceeded(limit):
            expect kind == "SizeLimitExceeded"
            expect limit >= 0 == true

fn _brotli_reserved_wbits_stream() -> [u8]:
    var w = brotli_bits_writer_init()
    w = brotli_bits_write(w, 1, 1)
    w = brotli_bits_write(w, 0, 3)
    w = brotli_bits_write(w, 0, 3)
    brotli_bits_writer_finish(w)

fn _brotli_last_metadata_stream() -> [u8]:
    var w = brotli_bits_writer_init()
    w = brotli_bits_write(w, 0, 1)
    w = brotli_bits_write(w, 1, 1)
    w = brotli_bits_write(w, 0, 1)
    w = brotli_bits_write(w, 3, 2)
    brotli_bits_writer_finish(w)

fn _brotli_complex_literal_prefix_stream() -> [u8]:
    var w = brotli_bits_writer_init()
    w = brotli_bits_write(w, 0, 1)
    w = brotli_bits_write(w, 1, 1)
    w = brotli_bits_write(w, 0, 1)
    w = brotli_bits_write(w, 0, 2)
    w = brotli_bits_write(w, 0, 16)
    w = brotli_bits_write_varlen_uint8(w, 0)
    w = brotli_bits_write_varlen_uint8(w, 0)
    w = brotli_bits_write_varlen_uint8(w, 0)
    w = brotli_bits_write(w, 0, 2)
    w = brotli_bits_write(w, 0, 4)
    w = brotli_bits_write(w, 0, 2)
    w = brotli_bits_write_varlen_uint8(w, 0)
    w = brotli_bits_write(w, 0, 2)
    brotli_bits_writer_finish(w)

fn _brotli_static_dictionary_distance_stream() -> [u8]:
    var w = brotli_bits_writer_init()
    w = brotli_bits_write(w, 0, 1)
    w = brotli_bits_write(w, 1, 1)
    w = brotli_bits_write(w, 0, 1)
    w = brotli_bits_write(w, 0, 2)
    w = brotli_bits_write(w, 2, 16)
    w = brotli_bits_write_varlen_uint8(w, 0)
    w = brotli_bits_write_varlen_uint8(w, 0)
    w = brotli_bits_write_varlen_uint8(w, 0)
    w = brotli_bits_write(w, 0, 2)
    w = brotli_bits_write(w, 0, 4)
    w = brotli_bits_write(w, 0, 2)
    w = brotli_bits_write_varlen_uint8(w, 0)
    w = brotli_bits_write_simple_prefix(w, 8, [0x41])
    w = brotli_bits_write_simple_prefix(w, 10, [257])
    w = brotli_bits_write_varlen_uint8(w, 0)
    w = brotli_bits_write_simple_prefix(w, 6, [0])
    brotli_bits_writer_finish(w)

fn main():

    describe("brotli_decode — malformed stream guards"):

        it("rejects the reserved all-zero extended WBITS code"):
            val decoded = brotli_decode(_brotli_reserved_wbits_stream())
            expect decoded.is_err() == true
            _expect_compression_error(decoded.unwrap_err(), "InvalidHeader", "reserved WBITS code")

        it("rejects metadata meta blocks in the last-block position"):
            val decoded = brotli_decode(_brotli_last_metadata_stream())
            expect decoded.is_err() == true
            _expect_compression_error(decoded.unwrap_err(), "UnsupportedFeature", "metadata meta block in last position")

        it("rejects compressed blocks that use a complex literal prefix code"):
            val decoded = brotli_decode(_brotli_complex_literal_prefix_stream())
            expect decoded.is_err() == true
            _expect_compression_error(decoded.unwrap_err(), "UnsupportedFeature", "complex prefix code")

        it("rejects copies that would fall into the unsupported static dictionary tier"):
            val decoded = brotli_decode(_brotli_static_dictionary_distance_stream())
            expect decoded.is_err() == true
            _expect_compression_error(decoded.unwrap_err(), "UnsupportedFeature", "static dictionary distance")

    describe("brotli_encode_uncompressed — large boundaries"):

        it("round-trips a 65536-byte payload in a single maximum uncompressed meta block"):
            val payload = _patterned_payload(65536)
            val encoded = brotli_encode_uncompressed(payload)
            val decoded = brotli_decode(encoded)
            expect decoded.is_err() == false
            expect _bytes_equal(decoded.unwrap(), payload) == true

        it("round-trips a 65537-byte payload across the uncompressed meta-block split"):
            val payload = _patterned_payload(65537)
            val encoded = brotli_encode_uncompressed(payload)
            val decoded = brotli_decode(encoded)
            expect decoded.is_err() == false
            expect _bytes_equal(decoded.unwrap(), payload) == true