# Specification for src/lib/nogc_sync_mut/compression/zlib.spl
#
# Verifies the RFC 1950 zlib wrapper: header framing, Adler-32 checksum,
# round-trip compress/decompress, and rejection of malformed input.

use std.spipe.*
use std.nogc_sync_mut.compression.zlib.{
    ZLIB_CMF,
    _adler32,
    _build_flg,
    zlib_compress,
    zlib_decompress,
}

# ---------------------------------------------------------------------------
# Module-scope payload builders — var mutation inside it blocks may not
# persist across loop iterations in interpreter mode; build here instead.
# ---------------------------------------------------------------------------

fn _make_256_bytes() -> [u8]:
    var out: [u8] = []
    var i = 0
    while i < 256:
        out.push(i % 256)
        i = i + 1
    out

fn _bytes_wikipedia() -> [u8]:
    # "Wikipedia" as ASCII bytes
    [0x57u8, 0x69u8, 0x6bu8, 0x69u8, 0x70u8, 0x65u8, 0x64u8, 0x69u8, 0x61u8]

fn _bytes_a() -> [u8]:
    [0x61u8]

fn _make_corrupt_adler(data: [u8]) -> [u8]:
    # Compress, then flip last byte to corrupt the Adler-32 trailer
    val compressed = zlib_compress(data, 6)
    val last = compressed.len() - 1
    var out: [u8] = []
    var i = 0
    while i < compressed.len():
        if i == last:
            out.push((compressed[i] + 1) % 256)
        else:
            out.push(compressed[i])
        i = i + 1
    out

fn _make_bad_cmf(data: [u8]) -> [u8]:
    # Compress then flip first byte (CMF) to 0x79
    val compressed = zlib_compress(data, 6)
    var out: [u8] = []
    out.push(0x79u8)
    var i = 1
    while i < compressed.len():
        out.push(compressed[i])
        i = i + 1
    out

fn _make_fdict_set(data: [u8]) -> [u8]:
    # Compress, then set FDICT bit (bit 5) in FLG and recompute check bits
    val compressed = zlib_compress(data, 6)
    val cmf_val: i64 = compressed[0]
    val old_flg: i64 = compressed[1]
    # Set FDICT bit (bit 5 = 32)
    val flg_with_fdict = old_flg + 32
    # Recompute check bits so header % 31 == 0
    val combined = cmf_val * 256 + flg_with_fdict
    val remainder = combined % 31
    var check: i64 = 0
    if remainder != 0:
        check = 31 - remainder
    val new_flg = flg_with_fdict + check
    var out: [u8] = []
    out.push(cmf_val)
    out.push(new_flg)
    var i = 2
    while i < compressed.len():
        out.push(compressed[i])
        i = i + 1
    out

# ---------------------------------------------------------------------------

describe "RFC 1950 zlib header":

    it "CMF constant is 0x78":
        expect ZLIB_CMF == 0x78

    it "header first byte is 0x78 for level 6":
        val compressed = zlib_compress([0x61u8], 6)
        expect compressed[0] == 0x78

    it "header check passes for level 0":
        val flg = _build_flg(0)
        val combined = ZLIB_CMF * 256 + flg
        expect combined % 31 == 0

    it "header check passes for level 1":
        val flg = _build_flg(1)
        val combined = ZLIB_CMF * 256 + flg
        expect combined % 31 == 0

    it "header check passes for level 6":
        val flg = _build_flg(6)
        val combined = ZLIB_CMF * 256 + flg
        expect combined % 31 == 0

    it "header check passes for level 9":
        val flg = _build_flg(9)
        val combined = ZLIB_CMF * 256 + flg
        expect combined % 31 == 0

describe "Adler-32 checksum":

    it "empty data returns 1":
        val empty: [u8] = []
        expect _adler32(empty) == 1

    it "single byte 'a' (0x61) returns 0x00620062":
        expect _adler32(_bytes_a()) == 0x00620062

    it "Wikipedia bytes return 0x11E60398":
        expect _adler32(_bytes_wikipedia()) == 0x11E60398

describe "zlib round-trip":

    it "empty payload round-trips to empty":
        val empty: [u8] = []
        val compressed = zlib_compress(empty, 6)
        val result = zlib_decompress(compressed)
        expect result == nil == false
        val out = result ?? []
        expect out.len() == 0

    it "256-byte payload round-trips correctly":
        val payload = _make_256_bytes()
        val compressed = zlib_compress(payload, 6)
        val result = zlib_decompress(compressed)
        expect result == nil == false
        val out = result ?? []
        expect out.len() == 256
        var i = 0
        var all_match = true
        while i < 256:
            if out[i] != payload[i]:
                all_match = false
            i = i + 1
        expect all_match == true

describe "zlib_decompress rejection":

    it "rejects stream shorter than 6 bytes":
        val short: [u8] = [0x78u8, 0x9cu8, 0x03u8, 0x00u8]
        val result = zlib_decompress(short)
        expect result == nil == true

    it "rejects stream with wrong CMF byte":
        val payload = [0x61u8]
        val bad = _make_bad_cmf(payload)
        val result = zlib_decompress(bad)
        expect result == nil == true

    it "rejects stream with corrupt Adler-32 trailer":
        val payload = [0x61u8, 0x62u8, 0x63u8]
        val bad = _make_corrupt_adler(payload)
        val result = zlib_decompress(bad)
        expect result == nil == true

    it "rejects stream with FDICT bit set":
        val payload = [0x61u8]
        val bad = _make_fdict_set(payload)
        val result = zlib_decompress(bad)
        expect result == nil == true