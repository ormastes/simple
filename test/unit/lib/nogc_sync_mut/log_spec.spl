# Log Module Tests
#
# Tests for std.log module (src/lib/nogc_sync_mut/log.spl)

use std.log.{LOG_OFF, LOG_FATAL, LOG_ERROR, LOG_WARN, LOG_INFO, LOG_DEBUG, LOG_TRACE, LOG_VERBOSE, LOG_ALL}
use std.log.{fatal, error, warn, info, debug, trace, verbose}
use std.log.{log_error, log_info, log_debug, log_verbose}
use std.log.{level_name, parse_level, set_level, get_global_level, is_enabled}
use std.log.{set_scope_level, clear_scopes}
# NOTE: log_fatal/log_warn/log_trace not importable in v0.4.0 — wrap locally
fn log_fatal(msg: text): fatal("app", msg)
fn log_warn(msg: text): warn("app", msg)
fn log_trace(msg: text): trace("app", msg)

describe "Log Levels":
    it "has correct level constants":
        expect(LOG_OFF).to_equal(0)
        expect(LOG_FATAL).to_equal(1)
        expect(LOG_ERROR).to_equal(2)
        expect(LOG_WARN).to_equal(3)
        expect(LOG_INFO).to_equal(4)
        expect(LOG_DEBUG).to_equal(5)
        expect(LOG_TRACE).to_equal(6)
        expect(LOG_VERBOSE).to_equal(7)
        expect(LOG_ALL).to_equal(10)

describe "Logging Functions":
    # Verify functions are callable without crashing

    it "fatal is callable":
        fatal("test", "fatal message")
        expect(true).to_equal(true)

    it "error is callable":
        error("test", "error message")
        expect(true).to_equal(true)

    it "warn is callable":
        warn("test", "warning message")
        expect(true).to_equal(true)

    it "info is callable":
        info("test", "info message")
        expect(true).to_equal(true)

    it "debug is callable":
        debug("test", "debug message")
        expect(true).to_equal(true)

    it "trace is callable":
        trace("test", "trace message")
        expect(true).to_equal(true)

    it "verbose is callable":
        verbose("test", "verbose message")
        expect(true).to_equal(true)

describe "Convenience Functions":
    it "log_info is callable":
        log_info("test message")
        expect(true).to_equal(true)

    it "log_error is callable":
        log_error("error message")
        expect(true).to_equal(true)

    it "log_debug is callable":
        log_debug("debug message")
        expect(true).to_equal(true)

    it "log_verbose is callable":
        log_verbose("verbose message")
        expect(true).to_equal(true)

    it "log_fatal is callable":
        log_fatal("fatal message")
        expect(true).to_equal(true)

    it "log_warn is callable":
        log_warn("warn message")
        expect(true).to_equal(true)

    it "log_trace is callable":
        log_trace("trace message")
        expect(true).to_equal(true)

describe "level_name":
    it "maps integer levels to name strings":
        expect(level_name(0)).to_equal("off")
        expect(level_name(1)).to_equal("fatal")
        expect(level_name(2)).to_equal("error")
        expect(level_name(3)).to_equal("warn")
        expect(level_name(4)).to_equal("info")
        expect(level_name(5)).to_equal("debug")
        expect(level_name(6)).to_equal("trace")
        expect(level_name(7)).to_equal("verbose")
        expect(level_name(10)).to_equal("all")

    it "returns unknown for invalid level":
        expect(level_name(99)).to_equal("unknown")

describe "parse_level":
    it "maps name strings to integer levels":
        expect(parse_level("off")).to_equal(0)
        expect(parse_level("fatal")).to_equal(1)
        expect(parse_level("error")).to_equal(2)
        expect(parse_level("warn")).to_equal(3)
        expect(parse_level("info")).to_equal(4)
        expect(parse_level("debug")).to_equal(5)
        expect(parse_level("trace")).to_equal(6)
        expect(parse_level("verbose")).to_equal(7)
        expect(parse_level("all")).to_equal(10)

    it "defaults to INFO for unknown":
        expect(parse_level("bogus")).to_equal(4)

describe "Level Configuration":
    it "sets and gets global log level":
        set_level(5)
        expect(get_global_level()).to_equal(5)
        set_level(0)
        expect(get_global_level()).to_equal(0)

describe "LogLevel enum construction":
    it "constructs LogLevel.Off variant":
        val lvl = LogLevel.Off
        expect(lvl.to_string()).to_equal("off")

    it "constructs LogLevel.Debug variant":
        val lvl = LogLevel.Debug
        expect(lvl.to_string()).to_equal("debug")

    it "constructs LogLevel.All variant":
        val lvl = LogLevel.All
        expect(lvl.to_string()).to_equal("all")

describe "LogLevel enum method dispatch":
    it "to_i64 on Off returns 0":
        val lvl = LogLevel.Off
        expect(lvl.to_i64()).to_equal(0)

    it "to_i64 on Debug returns 5":
        val lvl = LogLevel.Debug
        expect(lvl.to_i64()).to_equal(5)

    it "to_i64 on All returns 10":
        val lvl = LogLevel.All
        expect(lvl.to_i64()).to_equal(10)

    it "to_string on Off returns off":
        val lvl = LogLevel.Off
        expect(lvl.to_string()).to_equal("off")

    it "to_string on Debug returns debug":
        val lvl = LogLevel.Debug
        expect(lvl.to_string()).to_equal("debug")

    it "to_string on Verbose returns verbose":
        val lvl = LogLevel.Verbose
        expect(lvl.to_string()).to_equal("verbose")

describe "LogLevel static from_i64":
    it "from_i64(0) returns Off":
        val lvl = LogLevel.from_i64(0)
        expect(lvl.__tag).to_equal("Off")

    it "from_i64(5) returns Debug":
        val lvl = LogLevel.from_i64(5)
        expect(lvl.__tag).to_equal("Debug")

    it "from_i64(10) returns All":
        val lvl = LogLevel.from_i64(10)
        expect(lvl.__tag).to_equal("All")
