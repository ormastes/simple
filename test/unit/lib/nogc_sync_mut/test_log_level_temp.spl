enum TestEnum:
    A
    B
    C

    fn to_num() -> i64:
        match self:
            case A: 0
            case B: 1
            case C: 2

    fn to_str() -> text:
        match self:
            case A: "a"
            case B: "b"
            case C: "c"

val b = TestEnum.B
print b.to_num()
print b.to_str()
