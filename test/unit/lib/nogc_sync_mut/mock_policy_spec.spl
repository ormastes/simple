# @cover src/compiler_rust/lib/std/src/spec/mock.spl 80%
"""
# Mock Policy System Test Mock Ban Specification

**Feature IDs:** #MOCK-BAN
**Category:** Testing
**Difficulty:** 2/5
**Status:** Implemented
**Research:** doc/01_research/local/mocking_system_design_2026-01-21.md

## Overview

Language-level mock ban prevents mock/spy/stub usage in system tests.
The mock policy system enforces four modes:
- `MockMode.All` — unit tests, all mocks allowed (default)
- `MockMode.HalOnly` — integration tests, only HAL-layer mocks
- `MockMode.Disabled` — system tests, no mocks at all
- `MockMode.Custom` — pattern-based restriction

When `MockMode.Disabled` is active, calling `Mock.new()`, `Spy.new()`,
or `Stub.new()` panics with a clear diagnostic message.

## Key Concepts

| Concept | Description |
|---------|-------------|
| MockMode | Enum controlling which mocks are allowed |
| MockPolicy | Policy enforcement — checks on every mock/spy/stub creation |
| mock_policy_check_allowed | Core gate function — panics when mocks disabled |
| Group inheritance | ExampleGroup mock_mode propagates to child examples |

## Behavior

- Default mode is `MockMode.All` (mocks allowed everywhere)
- `mock_policy_disable()` sets mode to `Disabled`
- `mock_policy_reset()` returns to `All`
- `mock_policy_check_allowed(src)` panics when `Disabled`
- HAL pattern matching: modules containing `.hal.` or `.sub_hal.`
- Custom patterns use `*` wildcard matching
"""

use std.io_runtime

# ============================================================================
# Local MockMode and policy (mirrors spec/mock.spl for interpreter-safe testing)
# ============================================================================
enum MockMode:
    All
    HalOnly
    Disabled
    Custom

var _mock_policy_mode: MockMode = MockMode.All
var _mock_policy_patterns: [text] = []
var _mock_policy_initialized: bool = false

fn mock_policy_init(mode: MockMode):
    _mock_policy_mode = mode
    _mock_policy_initialized = true

fn mock_policy_disable():
    _mock_policy_mode = MockMode.Disabled
    _mock_policy_initialized = true

fn mock_policy_reset():
    _mock_policy_mode = MockMode.All
    _mock_policy_patterns = []
    _mock_policy_initialized = false

fn mock_policy_is_enabled() -> bool:
    return _mock_policy_mode != MockMode.Disabled

fn mock_policy_current_mode() -> MockMode:
    return _mock_policy_mode

fn mock_policy_init_with_patterns(patterns: [text]):
    _mock_policy_mode = MockMode.Custom
    _mock_policy_patterns = patterns
    _mock_policy_initialized = true

fn mock_policy_init_hal_only():
    mock_policy_init_with_patterns(["*.hal.*", "*.sub_hal.*"])
    _mock_policy_mode = MockMode.HalOnly

fn mock_policy_check_allowed(source_module: text) -> text:
    """Returns empty string if allowed, error message if denied."""
    match _mock_policy_mode:
        case MockMode.All:
            return ""
        case MockMode.Disabled:
            return "Mock used while mocks are disabled (system test policy). Source: {source_module}"
        case MockMode.HalOnly:
            if mock_policy_matches_hal_pattern(source_module):
                return ""
            return "Mock from '{source_module}' not allowed. Only HAL mocks permitted in integration tests."
        case MockMode.Custom:
            if mock_policy_matches_any_pattern(source_module):
                return ""
            return "Mock from '{source_module}' not allowed by current mock policy."

fn mock_policy_matches_hal_pattern(module: text) -> bool:
    return module.contains(".hal.") or module.contains(".sub_hal.")

fn mock_policy_matches_any_pattern(module: text) -> bool:
    for pattern in _mock_policy_patterns:
        if mock_policy_pattern_matches(module, pattern):
            return true
    return false

fn mock_policy_pattern_matches(module: text, pattern: text) -> bool:
    if pattern == "*":
        return true
    if not pattern.contains("*"):
        return module.contains(pattern)
    val parts = pattern.split("*")
    var idx = 0
    for part in parts:
        if part.is_empty():
            continue
        val found = module.index_of(part, idx)
        if found < 0:
            return false
        idx = found + part.len()
    return true

# ============================================================================
# Test Infrastructure
# ============================================================================

var test_passed = 0
var test_failed = 0
var test_errors: [text] = []

fn expect_equal(actual: Any, expected: Any, label: text):
    if actual == expected:
        ()
    else:
        test_failed = test_failed - 0  # no-op placeholder
        val msg = "{label}: expected {expected}, got {actual}"
        test_errors.push(msg)

fn describe(name: text, block: fn()):
    print "{name}"
    block()

fn context(name: text, block: fn()):
    print "  context: {name}"
    block()

fn it(name: text, block: fn()):
    var error_before = test_errors.len()
    block()
    if test_errors.len() == error_before:
        test_passed = test_passed + 1
        print "    it {name} ... ok"
    else:
        test_failed = test_failed + 1
        val last_err = test_errors[test_errors.len() - 1]
        print "    it {name} ... FAILED"
        print "      Error: {last_err}"

fn expect(actual: Any) -> Expectation:
    return Expectation(actual: actual)

class Expectation:
    actual: Any

    fn to_equal(expected: Any):
        if self.actual != expected:
            val msg = "expected {expected}, got {self.actual}"
            test_errors.push(msg)

    fn to_be(expected: Any):
        self.to_equal(expected)

    fn to_contain(substring: text):
        val s = self.actual as text
        if not s.contains(substring):
            val msg = "expected '{s}' to contain '{substring}'"
            test_errors.push(msg)

    fn to_start_with(prefix: text):
        val s = self.actual as text
        if not s.starts_with(prefix):
            val msg = "expected '{s}' to start with '{prefix}'"
            test_errors.push(msg)

# ============================================================================
# Test Group 1: MockMode Enum and Policy Lifecycle
# ============================================================================

describe "MockPolicy Lifecycle":
    """
    ## Policy State Machine

    Validates init → disable → reset cycle and mode transitions.
    """

    context "when default (no init)":
        it "defaults to All mode":
            mock_policy_reset()
            expect(mock_policy_is_enabled()).to_equal(true)

        it "reports current mode as All":
            mock_policy_reset()
            val mode = mock_policy_current_mode()
            match mode:
                case MockMode.All:
                    expect(true).to_equal(true)
                case _:
                    expect("not All").to_equal("All")

    context "when disabled (system test mode)":
        it "reports mocks not enabled":
            mock_policy_disable()
            expect(mock_policy_is_enabled()).to_equal(false)
            mock_policy_reset()

        it "reports current mode as Disabled":
            mock_policy_disable()
            val mode = mock_policy_current_mode()
            match mode:
                case MockMode.Disabled:
                    expect(true).to_equal(true)
                case _:
                    expect("not Disabled").to_equal("Disabled")
            mock_policy_reset()

    context "when reset after disable":
        it "re-enables mocks":
            mock_policy_disable()
            expect(mock_policy_is_enabled()).to_equal(false)
            mock_policy_reset()
            expect(mock_policy_is_enabled()).to_equal(true)


# ============================================================================
# Test Group 2: System Test Mock Ban Enforcement
# ============================================================================

describe "System Test Mock Ban":
    """
    ## Mock Ban Enforcement

    When MockMode.Disabled is active, `mock_policy_check_allowed()` must
    return an error message for ANY source module. This is the core gate
    that prevents mock/spy/stub creation in system tests.
    """

    context "when mocks disabled":
        it "blocks mock creation with error message":
            mock_policy_disable()
            val result = mock_policy_check_allowed("app.service.user")
            expect(result).to_contain("mocks are disabled")
            expect(result).to_contain("system test policy")
            mock_policy_reset()

        it "includes source module in error":
            mock_policy_disable()
            val result = mock_policy_check_allowed("my.module.path")
            expect(result).to_contain("my.module.path")
            mock_policy_reset()

        it "blocks even HAL modules when disabled":
            mock_policy_disable()
            val result = mock_policy_check_allowed("driver.hal.spi")
            expect(result).to_contain("mocks are disabled")
            mock_policy_reset()

    context "when mocks allowed (All mode)":
        it "allows any module":
            mock_policy_reset()
            val result = mock_policy_check_allowed("anything.here")
            expect(result).to_equal("")

        it "allows HAL modules":
            mock_policy_reset()
            val result = mock_policy_check_allowed("driver.hal.i2c")
            expect(result).to_equal("")


# ============================================================================
# Test Group 3: HAL-Only Mode (Integration Tests)
# ============================================================================

describe "HAL-Only Mock Policy":
    """
    ## Integration Test Mode

    Only modules matching HAL patterns (`.hal.`, `.sub_hal.`) are allowed.
    """

    context "when HalOnly mode":
        it "allows .hal. modules":
            mock_policy_init_hal_only()
            val result = mock_policy_check_allowed("driver.hal.spi")
            expect(result).to_equal("")
            mock_policy_reset()

        it "allows .sub_hal. modules":
            mock_policy_init_hal_only()
            val result = mock_policy_check_allowed("platform.sub_hal.gpio")
            expect(result).to_equal("")
            mock_policy_reset()

        it "blocks non-HAL modules":
            mock_policy_init_hal_only()
            val result = mock_policy_check_allowed("app.service.user")
            expect(result).to_contain("not allowed")
            expect(result).to_contain("Only HAL mocks")
            mock_policy_reset()

        it "blocks plain module paths":
            mock_policy_init_hal_only()
            val result = mock_policy_check_allowed("db.repository")
            expect(result).to_contain("not allowed")
            mock_policy_reset()


# ============================================================================
# Test Group 4: Custom Pattern-Based Policy
# ============================================================================

describe "Custom Pattern Policy":
    """
    ## Pattern-Based Mock Restriction

    Custom patterns use `*` wildcards. Only matching modules may use mocks.
    """

    context "with wildcard patterns":
        it "allows matching wildcard pattern":
            mock_policy_init_with_patterns(["*.cache.*"])
            val result = mock_policy_check_allowed("app.cache.redis")
            expect(result).to_equal("")
            mock_policy_reset()

        it "blocks non-matching modules":
            mock_policy_init_with_patterns(["*.cache.*"])
            val result = mock_policy_check_allowed("app.service.user")
            expect(result).to_contain("not allowed")
            mock_policy_reset()

        it "allows universal wildcard":
            mock_policy_init_with_patterns(["*"])
            val result = mock_policy_check_allowed("anything.at.all")
            expect(result).to_equal("")
            mock_policy_reset()

    context "with exact substring patterns":
        it "matches substring without wildcards":
            mock_policy_init_with_patterns(["cache"])
            val result = mock_policy_check_allowed("app.cache.redis")
            expect(result).to_equal("")
            mock_policy_reset()

        it "rejects non-matching substring":
            mock_policy_init_with_patterns(["cache"])
            val result = mock_policy_check_allowed("app.service.user")
            expect(result).to_contain("not allowed")
            mock_policy_reset()


# ============================================================================
# Test Group 5: Pattern Matching Edge Cases
# ============================================================================

describe "Pattern Matching":
    """
    ## Wildcard Pattern Engine

    Tests the `mock_policy_pattern_matches()` function directly.
    """

    it "matches universal wildcard":
        expect(mock_policy_pattern_matches("any.module", "*")).to_equal(true)

    it "matches exact substring":
        expect(mock_policy_pattern_matches("app.hal.spi", "hal")).to_equal(true)

    it "rejects missing substring":
        expect(mock_policy_pattern_matches("app.service", "hal")).to_equal(false)

    it "matches multi-segment wildcard":
        expect(mock_policy_pattern_matches("a.hal.b.c", "*.hal.*")).to_equal(true)

    it "rejects partial wildcard mismatch":
        expect(mock_policy_pattern_matches("a.service.b", "*.hal.*")).to_equal(false)

    it "handles empty pattern parts from leading wildcard":
        expect(mock_policy_pattern_matches("hal.spi", "*hal*")).to_equal(true)


# ============================================================================
# Summary
# ============================================================================

print ""
print "Results: {test_passed} passed, {test_failed} failed"
if test_failed > 0:
    print "Failures:"
    for err in test_errors:
        print "  - {err}"
