# Tests for std.platform module
# Covers exported functions from src/lib/platform.spl
# Platform-aware: works on both Linux and Windows

use std.platform.{is_windows, is_unix, is_macos, is_linux}
use std.platform.{get_host_os, get_host_arch}
use std.platform.{dir_sep, path_sep, exe_ext, lib_ext}
use std.platform.{normalize_path, is_absolute_path, join_path}

describe "std.platform":
    describe "OS detection":
        it "is_unix and is_windows are mutually exclusive":
            expect(is_unix() != is_windows()).to_equal(true)

        it "detects host OS correctly":
            if is_windows():
                expect(is_unix()).to_equal(false)
                expect(is_linux()).to_equal(false)
            else:
                expect(is_unix()).to_equal(true)

    describe "get_host_os":
        it "returns a known OS name":
            val os = get_host_os()
            expect(os.len()).to_be_greater_than(0)

    describe "get_host_arch":
        it "returns a known architecture":
            val arch = get_host_arch()
            expect(arch.len()).to_be_greater_than(0)

    describe "dir_sep":
        it "returns platform-appropriate separator":
            if is_windows():
                expect(dir_sep()).to_equal("\\")
            else:
                expect(dir_sep()).to_equal("/")

    describe "path_sep":
        it "returns platform-appropriate path separator":
            if is_windows():
                expect(path_sep()).to_equal(";")
            else:
                expect(path_sep()).to_equal(":")

    describe "exe_ext":
        it "returns platform-appropriate extension":
            if is_windows():
                expect(exe_ext()).to_equal(".exe")
            else:
                expect(exe_ext()).to_equal("")

    describe "lib_ext":
        it "returns platform-appropriate lib extension":
            if is_windows():
                expect(lib_ext()).to_equal(".dll")
            else:
                val ext = lib_ext()
                # .so on Linux, .dylib on macOS
                expect(ext.len()).to_be_greater_than(0)

    describe "normalize_path":
        it "handles path normalization":
            val result = normalize_path("usr/local/bin")
            expect(result.len()).to_be_greater_than(0)

    describe "is_absolute_path":
        it "detects absolute paths":
            if is_windows():
                expect(is_absolute_path("C:\\Users")).to_equal(true)
            else:
                expect(is_absolute_path("/usr/bin")).to_equal(true)

        it "detects relative paths":
            expect(is_absolute_path("usr/bin")).to_equal(false)

    describe "join_path":
        it "joins directory and file":
            val result = join_path("usr/local", "bin")
            expect(result).to_contain("bin")
            expect(result).to_contain("usr")

