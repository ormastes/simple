# @cover src/lib/nogc_sync_mut/game2d/ports/doomgeneric.spl 80%

use std.spec.{describe, it, expect}
use std.nogc_sync_mut.game2d.ports.doomgeneric as dg

describe "doomgeneric port proof":
    it "boots from a WAD-like byte buffer":
        val state = dg.DoomPortState.boot(dg.proof_wad())
        expect state.wad_bytes == 12
        expect state.tick == 0

    it "advances deterministic ticks and input movement":
        val s0 = dg.DoomPortState.boot(dg.proof_wad())
        val input = dg.DoomPortInput(forward: true, back: false, turn_left: false, turn_right: false, fire: true)
        val s1 = dg.doom_tick(s0, input)
        expect s1.tick == 1
        expect s1.shots == 1
        expect s1.x > s0.x == true

    it "turns without host APIs":
        val s0 = dg.DoomPortState.boot(dg.proof_wad())
        val input = dg.DoomPortInput(forward: false, back: false, turn_left: false, turn_right: true, fire: false)
        val s1 = dg.doom_tick(s0, input)
        expect s1.angle == 1

    it "renders deterministic non-black software frames":
        val state = dg.DoomPortState.boot(dg.proof_wad())
        val frame1 = dg.render_frame(state, 160, 100)
        val frame2 = dg.render_frame(state, 160, 100)
        expect frame1.non_black_count() == 160 * 100
        expect frame1.hash() == frame2.hash()