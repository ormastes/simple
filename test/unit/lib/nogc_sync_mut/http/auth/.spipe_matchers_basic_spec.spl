# HTTP Basic Authentication — RFC 7617 spec
#
# Tests for src/lib/nogc_sync_mut/http/auth/basic.spl
#
# Covers:
#   §2 round-trip encode/parse
#   §2 parse tamper-reject (missing prefix, bad base64, missing colon)
#   Constant-time verify: correct credentials accepted, wrong rejected

use std.spipe.*
use std.nogc_sync_mut.http.auth.basic.{http_basic_encode, http_basic_parse, http_basic_ct_verify}
use std.crypto.types.{text_to_bytes, bytes_to_text}

# ============================================================================
# Helpers — build byte lists in module-level fns to avoid it-block var
# mutation interpreter quirk (feedback_it_block_var_mutation.md).
# ============================================================================

# "Aladdin" as bytes
fn _user_aladdin() -> list:
    text_to_bytes("Aladdin")

# "open sesame" as bytes
fn _pw_open_sesame() -> list:
    text_to_bytes("open sesame")

# "user" as bytes
fn _user_user() -> list:
    text_to_bytes("user")

# "pass" as bytes
fn _pw_pass() -> list:
    text_to_bytes("pass")

# Encode "user:pass" manually — RFC 7617 §2 example
# base64("user:pass") = "dXNlcjpwYXNz"
fn _header_user_pass() -> list:
    text_to_bytes("Basic dXNlcjpwYXNz")

# ============================================================================
# RFC 7617 §2 — encode round-trip
# ============================================================================

describe "RFC 7617 Basic — encode":

    it "encodes Aladdin:open sesame to RFC 7617 §2 example value":
        # RFC 7617 §2: base64("Aladdin:open sesame") = "QWxhZGRpbjpvcGVuIHNlc2FtZQ=="
        val header = http_basic_encode(_user_aladdin(), text_to_bytes("open sesame"))
        expect bytes_to_text(header) == "Basic QWxhZGRpbjpvcGVuIHNlc2FtZQ=="

    it "encodes user:pass to known base64":
        val header = http_basic_encode(_user_user(), _pw_pass())
        expect bytes_to_text(header) == "Basic dXNlcjpwYXNz"

    it "encodes empty password":
        val header = http_basic_encode(text_to_bytes("alice"), text_to_bytes(""))
        # base64("alice:") = "YWxpY2U6"
        expect bytes_to_text(header) == "Basic YWxpY2U6"

# ============================================================================
# RFC 7617 §2 — parse round-trip
# ============================================================================

describe "RFC 7617 Basic — parse round-trip":

    it "parses user:pass header back to original bytes":
        val result = http_basic_parse(_header_user_pass())
        expect result == (_user_user(), _pw_pass())

    it "parse then encode round-trips to same header value":
        val original = http_basic_encode(_user_user(), _pw_pass())
        val parsed = http_basic_parse(original)
        val re_encoded = http_basic_encode(parsed.0, parsed.1)
        expect bytes_to_text(re_encoded) == bytes_to_text(original)

    it "parse extracts correct user bytes":
        val result = http_basic_parse(_header_user_pass())
        expect bytes_to_text(result.0) == "user"

    it "parse extracts correct password bytes":
        val result = http_basic_parse(_header_user_pass())
        expect bytes_to_text(result.1) == "pass"

# ============================================================================
# RFC 7617 §2 — parse tamper-reject
# ============================================================================

describe "RFC 7617 Basic — parse tamper-reject":

    it "rejects header without 'Basic ' prefix":
        val bad = text_to_bytes("Bearer dXNlcjpwYXNz")
        expect http_basic_parse(bad) == nil

    it "rejects header with malformed base64 (odd length)":
        # "Basic XYZ" — base64 payload "XYZ" is length 3, not multiple of 4
        val bad = text_to_bytes("Basic XYZ")
        expect http_basic_parse(bad) == nil

    it "rejects header where base64 decodes to no colon":
        # base64("nocolon") — no ':' in decoded bytes → must return nil
        # base64("nocolon") = "bm9jb2xvbg=="
        val bad = text_to_bytes("Basic bm9jb2xvbg==")
        expect http_basic_parse(bad) == nil

    it "rejects empty header":
        val bad = text_to_bytes("")
        expect http_basic_parse(bad) == nil

# ============================================================================
# Constant-time verify
# ============================================================================

describe "RFC 7617 Basic — constant-time verify":

    it "accepts correct user and password":
        expect(http_basic_ct_verify(
            _user_user(), _pw_pass(),
            _user_user(), _pw_pass()
        )).to_equal(true)

    it "rejects wrong password":
        expect(not http_basic_ct_verify(
            _user_user(), text_to_bytes("wrong"),
            _user_user(), _pw_pass()
        )).to_equal(true)

    it "rejects wrong user":
        expect(not http_basic_ct_verify(
            text_to_bytes("evil"), _pw_pass(),
            _user_user(), _pw_pass()
        )).to_equal(true)

    it "rejects both wrong":
        expect(not http_basic_ct_verify(
            text_to_bytes("evil"), text_to_bytes("wrong"),
            _user_user(), _pw_pass()
        )).to_equal(true)