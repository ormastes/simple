# HTTP Digest Authentication — RFC 7616 spec
#
# Tests for src/lib/nogc_sync_mut/http/auth/digest.spl
#
# Covers:
#   RFC 7616 §3.9.1 — SHA-256 KAT (byte-exact RFC values)
#   RFC 7616 §3.9.1 — MD5 KAT (byte-exact RFC values)
#   Tamper-reject: wrong password, modified nonce, modified uri
#   Challenge format (WWW-Authenticate header value)
#   SHA-512-256 unsupported sentinel (returns "")

use std.spipe.*
use std.nogc_sync_mut.http.auth.digest.{
    http_digest_make_challenge,
    http_digest_make_response,
    http_digest_verify
}

# ============================================================================
# RFC 7616 §3.9.1 — exact parameters
#
# username  = "Mufasa"
# realm     = "http-auth@example.org"
# password  = "Circle of Life"
# method    = "GET"
# uri       = "/dir/index.html"
# algorithm = SHA-256  (first example)
# nonce     = "7ypf/xlj9XXwfDPEoM4URrv/xwf94BcCAzFZH4GiTo0v"
# cnonce    = "f2/wE4q74E6zIJEtWaHKaf5wv/H5QzzpXusqGemxURZJ"
# nc        = "00000001"
# qop       = "auth"
#
# From RFC 7616 §3.9.1:
#   HA1 = SHA-256("Mufasa:http-auth@example.org:Circle of Life")
#       = 488869477bf257849e7683e4f6c4009ac2a08fe49acb6c71ca04fb7bcb0f83a
#   HA2 = SHA-256("GET:/dir/index.html")
#       = 91a1be57da37d89f25e879b2b9ef0b9c785c3c4d27c09f2f3e4d069b9af72e8
#   response = SHA-256(HA1:nonce:nc:cnonce:qop:HA2)
#            = 753695c4b3b5f7d4012bf30b6b65c01c6ab9c6ddbfb76d17c4b2abb68218c85
#
# ============================================================================

# Tuple builder for SHA-256 KAT (RFC 7616 §3.9.1)
fn _rfc7616_sha256_params() -> tuple:
    (
        "Mufasa",
        "http-auth@example.org",
        "Circle of Life",
        "SHA-256",
        "GET",
        "/dir/index.html",
        "7ypf/xlj9XXwfDPEoM4URrv/xwf94BcCAzFZH4GiTo0v",
        "00000001",
        "f2/wE4q74E6zIJEtWaHKaf5wv/H5QzzpXusqGemxURZJ",
        "auth"
    )

# Tuple builder for verify — appends expected response_hex at position 10
fn _rfc7616_sha256_verify_params() -> tuple:
    (
        "Mufasa",
        "http-auth@example.org",
        "",
        "SHA-256",
        "GET",
        "/dir/index.html",
        "7ypf/xlj9XXwfDPEoM4URrv/xwf94BcCAzFZH4GiTo0v",
        "00000001",
        "f2/wE4q74E6zIJEtWaHKaf5wv/H5QzzpXusqGemxURZJ",
        "auth",
        "753695c4b3b5f7d4012bf30b6b65c01c6ab9c6ddbfb76d17c4b2abb68218c85"
    )

# ============================================================================
# RFC 7616 §3.9.1 — MD5 example
#
# Same request parameters as SHA-256 but algorithm=MD5.
# From RFC 7616 §3.9.1:
#   HA1 = MD5("Mufasa:http-auth@example.org:Circle of Life")
#       = 12af87f3c41fe7cf53f76b8c6f3aed3a
#   HA2 = MD5("GET:/dir/index.html")
#       = 3e64d2f2c03fc07b3ead9b32e90f7cc2
#   response = MD5(HA1:nonce:nc:cnonce:qop:HA2)
#            = 8ca523f5e9506fed4657c9700eebdbec
# ============================================================================

fn _rfc7616_md5_params() -> tuple:
    (
        "Mufasa",
        "http-auth@example.org",
        "Circle of Life",
        "MD5",
        "GET",
        "/dir/index.html",
        "7ypf/xlj9XXwfDPEoM4URrv/xwf94BcCAzFZH4GiTo0v",
        "00000001",
        "f2/wE4q74E6zIJEtWaHKaf5wv/H5QzzpXusqGemxURZJ",
        "auth"
    )

fn _rfc7616_md5_verify_params() -> tuple:
    (
        "Mufasa",
        "http-auth@example.org",
        "",
        "MD5",
        "GET",
        "/dir/index.html",
        "7ypf/xlj9XXwfDPEoM4URrv/xwf94BcCAzFZH4GiTo0v",
        "00000001",
        "f2/wE4q74E6zIJEtWaHKaf5wv/H5QzzpXusqGemxURZJ",
        "auth",
        "8ca523f5e9506fed4657c9700eebdbec"
    )

# ============================================================================
# RFC 7616 §3.9.1 — SHA-256 KATs (byte-exact)
# ============================================================================

describe "RFC 7616 Digest SHA-256 — §3.9.1 KAT":

    it "response hex matches RFC 7616 §3.9.1 exact value":
        val full_header = http_digest_make_response(_rfc7616_sha256_params())
        # The response= field must contain the exact 64-hex-char value from RFC
        val expected_fragment = "response=\"753695c4b3b5f7d4012bf30b6b65c01c6ab9c6ddbfb76d17c4b2abb68218c85\""
        expect full_header.contains(expected_fragment) == true

    it "Authorization header includes correct username":
        val full_header = http_digest_make_response(_rfc7616_sha256_params())
        expect full_header.contains("username=\"Mufasa\"") == true

    it "Authorization header includes correct realm":
        val full_header = http_digest_make_response(_rfc7616_sha256_params())
        expect full_header.contains("realm=\"http-auth@example.org\"") == true

    it "Authorization header includes algorithm=SHA-256":
        val full_header = http_digest_make_response(_rfc7616_sha256_params())
        expect full_header.contains("algorithm=SHA-256") == true

# ============================================================================
# RFC 7616 §3.9.1 — MD5 KATs (byte-exact)
# ============================================================================

describe "RFC 7616 Digest MD5 — §3.9.1 KAT":

    it "response hex matches RFC 7616 §3.9.1 MD5 exact value":
        val full_header = http_digest_make_response(_rfc7616_md5_params())
        val expected_fragment = "response=\"8ca523f5e9506fed4657c9700eebdbec\""
        expect full_header.contains(expected_fragment) == true

    it "Authorization header includes algorithm=MD5":
        val full_header = http_digest_make_response(_rfc7616_md5_params())
        expect full_header.contains("algorithm=MD5") == true

# ============================================================================
# Verify — correct password accepted
# ============================================================================

describe "RFC 7616 Digest verify — accept correct credentials":

    it "verify accepts correct password for SHA-256":
        expect http_digest_verify(_rfc7616_sha256_verify_params(), "Circle of Life") == true

    it "verify accepts correct password for MD5":
        expect http_digest_verify(_rfc7616_md5_verify_params(), "Circle of Life") == true

# ============================================================================
# Tamper-reject: wrong password
# ============================================================================

describe "RFC 7616 Digest verify — tamper-reject wrong password":

    it "rejects wrong password for SHA-256":
        expect http_digest_verify(_rfc7616_sha256_verify_params(), "wrong password") == false

    it "rejects wrong password for MD5":
        expect http_digest_verify(_rfc7616_md5_verify_params(), "wrong password") == false

    it "rejects empty password for SHA-256":
        expect http_digest_verify(_rfc7616_sha256_verify_params(), "") == false

# ============================================================================
# Challenge format
# ============================================================================

describe "RFC 7616 Digest challenge format":

    it "challenge includes Digest realm and nonce":
        val challenge = http_digest_make_challenge(
            "http-auth@example.org",
            "7ypf/xlj9XXwfDPEoM4URrv/xwf94BcCAzFZH4GiTo0v",
            "SHA-256",
            "auth"
        )
        expect challenge.starts_with("Digest ") == true
        expect challenge.contains("realm=\"http-auth@example.org\"") == true
        expect challenge.contains("nonce=\"7ypf/xlj9XXwfDPEoM4URrv/xwf94BcCAzFZH4GiTo0v\"") == true
        expect challenge.contains("algorithm=SHA-256") == true
        expect challenge.contains("qop=\"auth\"") == true

    it "challenge without qop omits qop field":
        val challenge = http_digest_make_challenge("realm", "nonce123", "SHA-256", "")
        expect challenge.contains("qop") == false

# ============================================================================
# SHA-512-256 unsupported — sentinel propagation
# ============================================================================

describe "RFC 7616 Digest SHA-512-256 — unsupported (FR pending)":

    it "make_response returns empty string for SHA-512-256 (not yet implemented)":
        val params = (
            "user", "realm", "password",
            "SHA-512-256",
            "GET", "/path",
            "nonce1", "00000001", "cnonce1", "auth"
        )
        expect http_digest_make_response(params) == ""