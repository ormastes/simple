# permessage-deflate (RFC 7692) — unit tests
#
# Verifies ws_compress_message / ws_decompress_message against the known
# RFC 7692 §8.3.1 reference vector for "Hello", and round-trip correctness.

use std.spec.{describe, it, expect}
use std.http.ws.permessage_deflate.{
    ws_compress_message,
    ws_decompress_message,
    ws_pmce_rsv1_required,
    WS_PMCE_RSV1_BIT
}

# Build [u8] from a list of integer literals.
fn _bytes(vals: [i64]) -> [u8]:
    var buf: [u8] = []
    var i = 0
    while i < vals.len():
        var b: u8 = vals[i].to_u8()
        buf.push(b)
        i = i + 1
    buf

fn _make_hello() -> [u8]:
    # "Hello" = ASCII [72, 101, 108, 108, 111]
    _bytes([72, 101, 108, 108, 111])

fn _make_rfc7692_hello_compressed() -> [u8]:
    # RFC 7692 §8.3.1 known compressed form of "Hello" (no-context-takeover).
    # Hex: f2 48 cd c9 c9 07 00
    # = DEFLATE fixed-Huffman stream (BFINAL=0) + EOB + alignment byte,
    #   with the 4-byte sync-flush tail (00 00 ff ff) stripped.
    _bytes([0xf2, 0x48, 0xcd, 0xc9, 0xc9, 0x07, 0x00])

fn _make_hello_world() -> [u8]:
    # "Hello, World!" = [72,101,108,108,111,44,32,87,111,114,108,100,33]
    _bytes([72, 101, 108, 108, 111, 44, 32, 87, 111, 114, 108, 100, 33])

fn _make_repeated(count: i64) -> [u8]:
    # ABCDEFGH repeated to fill `count` bytes (compressible data)
    val pattern = [65, 66, 67, 68, 69, 70, 71, 72]
    var buf: [u8] = []
    var i = 0
    while i < count:
        var b: u8 = pattern[i % pattern.len()].to_u8()
        buf.push(b)
        i = i + 1
    buf

describe "permessage-deflate RFC 7692":
    it "RSV1 bit constant is 0x40":
        expect WS_PMCE_RSV1_BIT == 0x40

    it "ws_pmce_rsv1_required returns true":
        expect ws_pmce_rsv1_required() == true

    it "compress Hello matches RFC 7692 §8.3.1 known vector":
        val compressed = ws_compress_message(_make_hello())
        val expected = _make_rfc7692_hello_compressed()
        expect compressed.len() == 7
        expect compressed == expected

    it "decompress RFC 7692 Hello vector recovers Hello":
        val compressed = _make_rfc7692_hello_compressed()
        val decompressed = ws_decompress_message(compressed)
        val expected = _make_hello()
        expect decompressed.len() == 5
        expect decompressed == expected

    it "round-trips empty payload":
        var empty: [u8] = []
        val compressed = ws_compress_message(empty)
        val decompressed = ws_decompress_message(compressed)
        expect decompressed.len() == 0
        expect decompressed == empty

    it "round-trips Hello World":
        val input = _make_hello_world()
        val compressed = ws_compress_message(input)
        val decompressed = ws_decompress_message(compressed)
        expect decompressed.len() == input.len()
        expect decompressed == input

    it "round-trips 500 bytes of repeated pattern":
        val input = _make_repeated(500)
        val compressed = ws_compress_message(input)
        # Repeated data must compress
        expect compressed.len() < input.len() == true
        val decompressed = ws_decompress_message(compressed)
        expect decompressed.len() == input.len()
        expect decompressed == input

    it "compressed output does not end in 00 00 FF FF (tail was stripped)":
        val compressed = ws_compress_message(_make_hello())
        val n = compressed.len()
        # The 4-byte sync-flush tail must be absent
        var ends_with_tail = false
        if n >= 4:
            val b0 = compressed[n - 4].to_i64()
            val b1 = compressed[n - 3].to_i64()
            val b2 = compressed[n - 2].to_i64()
            val b3 = compressed[n - 1].to_i64()
            if b0 == 0 and b1 == 0 and b2 == 255 and b3 == 255:
                ends_with_tail = true
        expect ends_with_tail == false