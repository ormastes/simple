# Engine Units — Domain-specific custom type tests
#
# Tests all 16 unit types from std.common.engine.units:
# Seconds, Angle, Volume, ZIndex, KeyCode, MouseButtonId,
# GamepadButtonId, Distance, ZoomLevel, TileCoord, PixelSize,
# TileIndex, FrameIndex, Speed, Tolerance, RGBA8

use std.spec.{describe, it, expect}
use std.common.engine.units.{Seconds, Angle, Volume, ZIndex, KeyCode, MouseButtonId, GamepadButtonId, Distance, ZoomLevel, TileCoord, PixelSize, TileIndex, FrameIndex, Speed, Tolerance, RGBA8}

describe "Engine Units":
    describe "Seconds":
        it "creates with value":
            val s = Seconds(value: 1.5)
            expect s.value == 1.5

        it "converts to f64":
            val s = Seconds(value: 2.0)
            expect s.to_f64() == 2.0

        it "adds two Seconds":
            val a = Seconds(value: 1.0)
            val b = Seconds(value: 2.5)
            val result = a.add(b)
            expect result.value == 3.5

        it "subtracts two Seconds":
            val a = Seconds(value: 5.0)
            val b = Seconds(value: 1.5)
            val result = a.sub(b)
            expect result.value == 3.5

    describe "Angle":
        it "creates with radians":
            val a = Angle(radians: 3.14)
            expect a.radians == 3.14

        it "converts to radians":
            val a = Angle(radians: 1.0)
            expect a.to_radians() == 1.0

        it "converts to degrees":
            val a = Angle(radians: 1.0)
            val deg = a.to_degrees()
            expect deg > 57.0
            expect deg < 58.0

        it "adds two Angles":
            val a = Angle(radians: 1.0)
            val b = Angle(radians: 2.0)
            val result = a.add(b)
            expect result.radians == 3.0

        it "creates zero angle":
            val a = Angle.zero()
            expect a.radians == 0.0

    describe "Volume":
        it "creates with value":
            val v = Volume(value: 0.8)
            expect v.value == 0.8

        it "converts to f64":
            val v = Volume(value: 0.5)
            expect v.to_f64() == 0.5

        it "creates full volume":
            val v = Volume.full()
            expect v.value == 1.0

        it "creates muted volume":
            val v = Volume.mute_vol()
            expect v.value == 0.0

    describe "ZIndex":
        it "creates with value":
            val z = ZIndex(value: 5)
            expect z.value == 5

        it "converts to i64":
            val z = ZIndex(value: 10)
            expect z.to_i64() == 10

        it "creates zero ZIndex":
            val z = ZIndex.zero()
            expect z.value == 0

    describe "KeyCode":
        it "creates with code":
            val k = KeyCode(code: 65)
            expect k.code == 65

        it "converts to i64":
            val k = KeyCode(code: 32)
            expect k.to_i64() == 32

        it "compares equal KeyCodes":
            val a = KeyCode(code: 65)
            val b = KeyCode(code: 65)
            expect a.eq(b) == true

        it "compares different KeyCodes":
            val a = KeyCode(code: 65)
            val b = KeyCode(code: 66)
            expect a.eq(b) == false

    describe "MouseButtonId":
        it "creates with code":
            val m = MouseButtonId(code: 0)
            expect m.code == 0

        it "converts to i64":
            val m = MouseButtonId(code: 1)
            expect m.to_i64() == 1

    describe "GamepadButtonId":
        it "creates with code":
            val g = GamepadButtonId(code: 1)
            expect g.code == 1

    describe "Distance":
        it "creates with value":
            val d = Distance(value: 100.0)
            expect d.value == 100.0

        it "converts to f64":
            val d = Distance(value: 42.5)
            expect d.to_f64() == 42.5

    describe "ZoomLevel":
        it "creates with value":
            val z = ZoomLevel(value: 2.0)
            expect z.value == 2.0

        it "converts to f64":
            val z = ZoomLevel(value: 1.5)
            expect z.to_f64() == 1.5

        it "creates default zoom":
            val z = ZoomLevel.default_zoom()
            expect z.value == 1.0

    describe "TileCoord":
        it "creates with col and row":
            val t = TileCoord(col: 3, row: 7)
            expect t.col == 3
            expect t.row == 7

    describe "PixelSize":
        it "creates with width and height":
            val p = PixelSize(width: 1920, height: 1080)
            expect p.width == 1920
            expect p.height == 1080

    describe "TileIndex":
        it "creates with value":
            val t = TileIndex(value: 42)
            expect t.value == 42

        it "converts to i64":
            val t = TileIndex(value: 7)
            expect t.to_i64() == 7

        it "creates empty TileIndex":
            val t = TileIndex.empty()
            expect t.value == -1

    describe "FrameIndex":
        it "creates with value":
            val f = FrameIndex(value: 10)
            expect f.value == 10

        it "converts to i64":
            val f = FrameIndex(value: 99)
            expect f.to_i64() == 99

    describe "Speed":
        it "creates with value":
            val s = Speed(value: 5.5)
            expect s.value == 5.5

        it "converts to f64":
            val s = Speed(value: 3.0)
            expect s.to_f64() == 3.0

    describe "Tolerance":
        it "creates with value":
            val t = Tolerance(value: 0.001)
            expect t.value == 0.001

        it "converts to f64":
            val t = Tolerance(value: 0.01)
            expect t.to_f64() == 0.01

    describe "RGBA8":
        it "creates with components":
            val c = RGBA8(r: 255, g: 128, b: 0, a: 255)
            expect c.r == 255
            expect c.g == 128
            expect c.b == 0
            expect c.a == 255

        it "creates black color":
            val c = RGBA8(r: 0, g: 0, b: 0, a: 255)
            expect c.r == 0
            expect c.g == 0
            expect c.b == 0
            expect c.a == 255

        it "creates transparent color":
            val c = RGBA8(r: 0, g: 0, b: 0, a: 0)
            expect c.a == 0