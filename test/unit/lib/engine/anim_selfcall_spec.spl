use std.spec.{describe, it, expect}

# Test whether me method calling self.helper() in an imported impl block works
# when the class is defined in THIS file vs imported

class LocalFSM:
    x: i32
    count: i32

    static fn new() -> LocalFSM:
        LocalFSM(x: 0, count: 0)

    fn helper(self) -> i32:
        self.x + 1

    me bump():
        val h = self.helper()
        self.x = h

impl LocalFSM:
    fn find(self, v: i32) -> i32:
        if self.x == v:
            return 0
        -1

    me bump_with_find(v: i32) -> bool:
        val idx = self.find(v)
        if idx >= 0:
            self.count = self.count + 1
            return true
        false

describe "self call from me method":
    it "in-file class: me method calling self.helper() in class body":
        var obj = LocalFSM.new()
        obj.bump()
        expect(obj.x).to_equal(1)

    it "in-file class: me method calling self.find() in impl block":
        var obj = LocalFSM.new()
        val ok = obj.bump_with_find(0)
        expect(ok).to_equal(true)
        expect(obj.count).to_equal(1)
