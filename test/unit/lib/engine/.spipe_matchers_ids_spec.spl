"""
Engine ID System — Generational Handle Tests

Tests RawHandle, NodeId, TextureId type-safe wrappers.
"""

use std.spec.{describe, it, expect}
use std.common.engine.ids.{Generation, RawHandle, NodeId, TextureId, SpriteId}

describe "Engine IDs":
    describe "Generation":
        it "compares equal generations":
            val g1 = Generation(value: 5)
            val g2 = Generation(value: 5)
            expect g1.eq(g2) == true

        it "compares unequal generations":
            val g1 = Generation(value: 1)
            val g2 = Generation(value: 2)
            expect g1.eq(g2) == false

    describe "RawHandle":
        it "creates a valid handle with new":
            val h = RawHandle.new(0, 1)
            expect h.is_valid() == true
            expect h.to_index() == 0

        it "creates an invalid handle":
            val h = RawHandle.invalid()
            expect h.is_valid() == false

        it "compares equal handles":
            val h1 = RawHandle.new(3, 2)
            val h2 = RawHandle.new(3, 2)
            expect h1.eq(h2) == true

        it "compares different handles":
            val h1 = RawHandle.new(0, 1)
            val h2 = RawHandle.new(1, 1)
            expect h1.eq(h2) == false

        it "detects generation mismatch":
            val h1 = RawHandle.new(0, 1)
            val h2 = RawHandle.new(0, 2)
            expect h1.eq(h2) == false

    describe "NodeId":
        it "wraps a valid RawHandle":
            val raw = RawHandle.new(5, 1)
            val nid = NodeId(raw: raw)
            expect nid.is_valid() == true
            expect nid.to_index() == 5

        it "creates an invalid NodeId":
            val nid = NodeId.invalid()
            expect nid.is_valid() == false

        it "compares equal NodeIds":
            val a = NodeId(raw: RawHandle.new(2, 3))
            val b = NodeId(raw: RawHandle.new(2, 3))
            expect a.eq(b) == true

    describe "TextureId":
        it "wraps a valid RawHandle":
            val tid = TextureId(raw: RawHandle.new(0, 1))
            expect tid.is_valid() == true
            expect tid.to_index() == 0

        it "creates an invalid TextureId":
            val tid = TextureId.invalid()
            expect tid.is_valid() == false

    describe "SpriteId":
        it "wraps a valid RawHandle":
            val sid = SpriteId(raw: RawHandle.new(7, 2))
            expect sid.is_valid() == true
            expect sid.to_index() == 7