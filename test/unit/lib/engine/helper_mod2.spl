class HelperClass2:
    items: [i32]

impl HelperClass2:
    static fn new() -> HelperClass2:
        HelperClass2(items: [])

    fn find_index(self, v: i32, w: i32) -> i32:
        var i = 0
        while i < self.items.len():
            if self.items[i] == v:
                return i
            i = i + 1
        -1

    me search_and_add(v: i32, w: i32) -> bool:
        val idx = self.find_index(v, w)
        if idx >= 0:
            return true
        self.items = self.items.push(v)
        false
