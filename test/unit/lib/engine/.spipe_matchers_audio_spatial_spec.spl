"""
Engine Audio Spatial — AudioManager spatial audio and pure Simple logic tests

Tests active_sounds tracking, stop_sound removal, bus volume round-trip,
Listener3D default values, and set_listener_position_3d state updates.
"""

use std.spec.{describe, it, expect}
use std.common.engine.math3d.{Vec3}
use std.common.engine.units.{Volume, Distance}
use std.nogc_sync_mut.engine.audio.types.{
    AudioClip, AudioConfig, AudioBus, SoundHandle, Listener3D,
    default_audio_config, default_listener_3d
}
use std.nogc_sync_mut.engine.audio.audio_manager.{AudioManager}

describe "AudioManager spatial":
    it "active_sounds tracks played sounds":
        val config = default_audio_config()
        var mgr = AudioManager.create(config)
        val clip = mgr.load_clip("sfx/hit.wav")
        val h1 = mgr.play(clip, "sfx")
        val h2 = mgr.play(clip, "sfx")
        expect mgr.active_sounds.len() == 2
        mgr.destroy()

    it "stop_sound removes from active_sounds":
        val config = default_audio_config()
        var mgr = AudioManager.create(config)
        val clip = mgr.load_clip("sfx/hit.wav")
        val h1 = mgr.play(clip, "sfx")
        expect mgr.active_sounds.len() == 1
        mgr.stop_sound(h1)
        expect mgr.active_sounds.len() == 0
        mgr.destroy()

    it "set_bus_volume updates volume":
        val config = default_audio_config()
        var mgr = AudioManager.create(config)
        val ok = mgr.set_bus_volume("sfx", Volume(value: 0.42))
        expect ok == true
        val vol = mgr.get_bus_volume("sfx")
        val vol_i = vol.value * 1000.0
        expect vol_i > 419.0
        expect vol_i < 421.0
        mgr.destroy()

    it "Listener3D default values":
        val listener = default_listener_3d()
        # Position should be origin
        val px_i = listener.position.x * 1000.0
        val py_i = listener.position.y * 1000.0
        val pz_i = listener.position.z * 1000.0
        expect px_i > -1.0
        expect px_i < 1.0
        expect py_i > -1.0
        expect py_i < 1.0
        expect pz_i > -1.0
        expect pz_i < 1.0
        # Forward should be (0, 0, -1) or (0, 0, 1) depending on convention
        # Up should be (0, 1, 0)
        val uy_i = listener.up.y * 1000.0
        expect uy_i > 999.0
        expect uy_i < 1001.0

    it "set_listener_position_3d updates state":
        val config = default_audio_config()
        var mgr = AudioManager.create(config)
        mgr.set_listener_position_3d(Vec3(x: 10.0, y: 20.0, z: 30.0))
        # AudioManager tracks listener_x and listener_y
        val lx_i = mgr.listener_x * 100.0
        val ly_i = mgr.listener_y * 100.0
        expect lx_i > 999.0
        expect lx_i < 1001.0
        expect ly_i > 1999.0
        expect ly_i < 2001.0
        mgr.destroy()