use std.spec.{describe, it, expect}
use test.unit.lib.engine.helper_mod3.{HelperClass3}

describe "cross-module me method passing self.field as arg to self.fn":
    it "trigger(name) calls self.find_index(self.current, name)":
        var obj = HelperClass3.new()
        obj.set_current("idle")
        val ok = obj.trigger("idle")
        expect(ok).to_equal(true)
