"""
Engine Signal & EventBus Tests

Tests signal creation, connection, emission, disconnect, and one-shot.
Tests EventBus named signal management.
"""

use std.spec.{describe, it, expect}
use std.common.engine.signal.signal.{Signal}
use std.common.engine.signal.event_bus.{EventBus}

describe "Signal":
    it "creates a signal with a name":
        val sig = Signal.create("on_hit")
        expect(sig.name).to_equal("on_hit")
        expect(sig.enabled).to_equal(true)

    it "connects and emits to a listener":
        var received = ""
        var sig = Signal.create("test")
        val conn = sig.connect(\data: received = data)
        sig.emit("hello")
        expect(received).to_equal("hello")

    it "disconnects a listener":
        var count = 0
        var sig = Signal.create("test")
        val conn = sig.connect(\data: count = count + 1)
        sig.emit("a")
        expect(count).to_equal(1)
        val removed = sig.disconnect(conn)
        expect(removed).to_equal(true)
        sig.emit("b")
        # count should still be 1 after disconnect
        expect(count).to_equal(1)

    it "supports one-shot connections":
        var count = 0
        var sig = Signal.create("test")
        val conn = sig.connect_once(\data: count = count + 1)
        sig.emit("first")
        sig.emit("second")
        # connect_once fires only on first emit
        expect(count).to_equal(1)

    it "emits to multiple listeners":
        var a_val = ""
        var b_val = ""
        var sig = Signal.create("multi")
        val ca = sig.connect(\data: a_val = data)
        val cb = sig.connect(\data: b_val = data)
        sig.emit("msg")
        expect(a_val).to_equal("msg")
        expect(b_val).to_equal("msg")

describe "EventBus":
    it "registers and emits named signals":
        var result = ""
        var bus = EventBus.create()
        bus.register("damage")
        val conn = bus.connect("damage", \data: result = data)
        bus.emit("damage", "50")
        expect(result).to_equal("50")

    it "auto-registers on connect":
        var result = ""
        var bus = EventBus.create()
        # connect without explicit register
        val conn = bus.connect("score", \data: result = data)
        bus.emit("score", "100")
        expect(result).to_equal("100")

    it "does not cross-emit between different signals":
        var a_result = ""
        var b_result = ""
        var bus = EventBus.create()
        val ca = bus.connect("alpha", \data: a_result = data)
        val cb = bus.connect("beta", \data: b_result = data)
        bus.emit("alpha", "aaa")
        expect(a_result).to_equal("aaa")
        expect(b_result).to_equal("")
