use std.spec.{describe, it, expect}
use test.unit.lib.engine.helper_mod2.{HelperClass2}

describe "cross-module me method calling self.fn with multiple params":
    it "search_and_add (calls self.find_index(v, w)) works after import":
        var obj = HelperClass2.new()
        val found = obj.search_and_add(5, 10)
        expect(found).to_equal(false)
        val found2 = obj.search_and_add(5, 10)
        expect(found2).to_equal(true)
