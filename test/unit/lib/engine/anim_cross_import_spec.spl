use std.spec.{describe, it, expect}
use std.nogc_sync_mut.engine.render.animation_fsm.{AnimClip, AnimationFSM}

# Minimal test: imported class me method with self.fn() call
describe "AnimationFSM imported class self-call":
    it "add_state (me, modifies self.states) works":
        var fsm = AnimationFSM.new()
        fsm.add_state("idle", AnimClip.new("idle", 4, 0.25, true))
        expect(fsm.state_count()).to_equal(1)

    it "set_initial (me, sets self.field) works":
        var fsm = AnimationFSM.new()
        fsm.add_state("idle", AnimClip.new("idle", 4, 0.25, true))
        fsm.set_initial("idle")
        expect(fsm.get_current_state_name()).to_equal("idle")

    it "trigger_transition (me, calls self._find_transition_index) fails?":
        var fsm = AnimationFSM.new()
        fsm.add_state("idle", AnimClip.new("idle", 4, 0.25, true))
        fsm.add_state("run", AnimClip.new("run", 8, 0.1, true))
        fsm.add_transition("idle", "run", 0.3, false)
        fsm.set_initial("idle")
        val ok = fsm.trigger_transition("run")
        expect(ok).to_equal(true)
