class HelperClass3:
    current: text
    items: [text]

impl HelperClass3:
    static fn new() -> HelperClass3:
        HelperClass3(current: "", items: [])

    fn find_index(self, from_name: text, to_name: text) -> i32:
        var i = 0
        while i < self.items.len():
            if self.items[i] == from_name:
                return i
            i = i + 1
        -1

    me set_current(name: text):
        self.current = name
        self.items = self.items.push(name)

    me trigger(target_name: text) -> bool:
        # passes self.current (a field) as arg to self.find_index()
        val ti = self.find_index(self.current, target_name)
        if ti < 0:
            return false
        true
