"""
Engine Rect2 — Rectangle Tests

Tests constructors, edges, containment, intersection, merge, expand.
"""

use std.spec.{describe, it, expect}
use std.common.engine.rect.{Rect2}

describe "Rect2":
    describe "constructors":
        it "creates with new":
            val r = Rect2.new(10.0, 20.0, 100.0, 50.0)
            expect r.x == 10.0
            expect r.y == 20.0
            expect r.width == 100.0
            expect r.height == 50.0

        it "creates from center":
            val r = Rect2.from_center(50.0, 50.0, 20.0, 10.0)
            expect r.x == 40.0
            expect r.y == 45.0
            expect r.width == 20.0
            expect r.height == 10.0

    describe "edge accessors":
        it "returns correct edges":
            val r = Rect2.new(10.0, 20.0, 30.0, 40.0)
            expect r.left() == 10.0
            expect r.right() == 40.0
            expect r.top() == 20.0
            expect r.bottom() == 60.0

    describe "queries":
        it "contains interior point":
            val r = Rect2.new(0.0, 0.0, 100.0, 100.0)
            expect r.contains_point(50.0, 50.0) == true

        it "does not contain exterior point":
            val r = Rect2.new(0.0, 0.0, 100.0, 100.0)
            expect r.contains_point(150.0, 50.0) == false

        it "contains edge point":
            val r = Rect2.new(0.0, 0.0, 100.0, 100.0)
            expect r.contains_point(0.0, 0.0) == true
            expect r.contains_point(100.0, 100.0) == true

    describe "intersection":
        it "detects overlapping rects":
            val a = Rect2.new(0.0, 0.0, 10.0, 10.0)
            val b = Rect2.new(5.0, 5.0, 10.0, 10.0)
            expect a.intersects(b) == true

        it "detects non-overlapping rects":
            val a = Rect2.new(0.0, 0.0, 10.0, 10.0)
            val b = Rect2.new(20.0, 20.0, 10.0, 10.0)
            expect a.intersects(b) == false

    describe "merge and expand":
        it "merges two rects into bounding rect":
            val a = Rect2.new(0.0, 0.0, 10.0, 10.0)
            val b = Rect2.new(20.0, 20.0, 10.0, 10.0)
            val m = a.merge(b)
            expect m.x == 0.0
            expect m.y == 0.0
            expect m.right() == 30.0
            expect m.bottom() == 30.0

        it "expands rect by margin":
            val r = Rect2.new(10.0, 10.0, 20.0, 20.0)
            val e = r.expand(5.0)
            expect e.x == 5.0
            expect e.y == 5.0
            expect e.width == 30.0
            expect e.height == 30.0