use std.spec.{describe, it, expect}

# Test: class with separate impl block, me method calls self.fn
class SepClass:
    x: i32

impl SepClass:
    static fn new() -> SepClass:
        SepClass(x: 0)

    fn helper(self) -> i32:
        self.x + 1

    me bump():
        val h = self.helper()
        self.x = h

    fn find(self, v: i32) -> i32:
        if self.x == v:
            return 0
        -1

    me bump_with_find(v: i32) -> bool:
        val idx = self.find(v)
        if idx >= 0:
            self.x = self.x + 1
            return true
        false

describe "separate impl block self-calls":
    it "me method calling self.helper() in separate impl":
        var obj = SepClass.new()
        obj.bump()
        expect(obj.x).to_equal(1)

    it "me method calling self.find() in separate impl":
        var obj = SepClass.new()
        val ok = obj.bump_with_find(0)
        expect(ok).to_equal(true)
        expect(obj.x).to_equal(1)
