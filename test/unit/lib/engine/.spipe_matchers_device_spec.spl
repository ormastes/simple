# GPU Device — Backend enum and Gpu struct tests
#
# Tests GpuBackend enum variants, Gpu struct construction,
# constructor functions, and preferred_graphics_backend.

use std.spec.{describe, it, expect}
use std.common.gpu.device.{GpuBackend, Gpu, gpu_cuda, gpu_vulkan, gpu_rocm, gpu_oneapi, gpu_metal, gpu_none, preferred_graphics_backend}

describe "GPU Device":
    describe "GpuBackend":
        it "converts Cuda to text":
            val b = GpuBackend.Cuda
            expect b.to_text() == "CUDA"

        it "converts Vulkan to text":
            val b = GpuBackend.Vulkan
            expect b.to_text() == "Vulkan"

        it "converts Rocm to text":
            val b = GpuBackend.Rocm
            expect b.to_text() == "ROCm"

        it "converts OneApi to text":
            val b = GpuBackend.OneApi
            expect b.to_text() == "oneAPI"

        it "converts Metal to text":
            val b = GpuBackend.Metal
            expect b.to_text() == "Metal"

        it "converts None_ to text":
            val b = GpuBackend.None_
            expect b.to_text() == "None"

    describe "Gpu struct":
        it "creates a valid Gpu":
            val g = Gpu(backend: GpuBackend.Cuda, device_id: 0, is_initialized: true)
            expect g.is_valid() == true

        it "creates an uninitialized Gpu":
            val g = Gpu(backend: GpuBackend.Cuda, device_id: 0, is_initialized: false)
            expect g.is_valid() == false

        it "sync returns true":
            val g = Gpu(backend: GpuBackend.Vulkan, device_id: 0, is_initialized: true)
            expect g.sync() == true

    describe "Constructor functions":
        it "gpu_cuda creates CUDA device":
            val g = gpu_cuda(0)
            expect g.backend.to_text() == "CUDA"
            expect g.device_id == 0
            expect g.is_valid() == true

        it "gpu_vulkan creates Vulkan device":
            val g = gpu_vulkan(0)
            expect g.backend.to_text() == "Vulkan"
            expect g.is_valid() == true

        it "gpu_rocm creates ROCm device":
            val g = gpu_rocm(0)
            expect g.backend.to_text() == "ROCm"
            expect g.is_valid() == true

        it "gpu_oneapi creates oneAPI device":
            val g = gpu_oneapi(0)
            expect g.backend.to_text() == "oneAPI"
            expect g.is_valid() == true

        it "gpu_metal creates Metal device":
            val g = gpu_metal(0)
            expect g.backend.to_text() == "Metal"
            expect g.is_valid() == true

        it "gpu_none creates CPU fallback":
            val g = gpu_none()
            expect g.backend.to_text() == "None"
            expect g.device_id == -1
            expect g.is_valid() == true

        it "gpu_cuda with different device ids":
            val g0 = gpu_cuda(0)
            val g1 = gpu_cuda(1)
            expect g0.device_id == 0
            expect g1.device_id == 1

    describe "preferred_graphics_backend":
        it "returns Vulkan":
            val backend = preferred_graphics_backend()
            expect backend.to_text() == "Vulkan"