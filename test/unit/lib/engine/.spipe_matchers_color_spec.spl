"""
Engine Color — EngineColor Tests

Tests RGBA constructors, presets, lerp, to_rgba8, from_hex.
"""

use std.spec.{describe, it, expect}
use std.common.engine.color.{EngineColor}

describe "EngineColor":
    describe "constructors":
        it "creates RGBA color":
            val c = EngineColor.rgba(0.5, 0.6, 0.7, 0.8)
            expect c.r == 0.5
            expect c.g == 0.6
            expect c.b == 0.7
            expect c.a == 0.8

        it "creates RGB color with alpha 1.0":
            val c = EngineColor.rgb(0.1, 0.2, 0.3)
            expect c.a == 1.0

    describe "presets":
        it "creates white":
            val c = EngineColor.white()
            expect c.r == 1.0
            expect c.g == 1.0
            expect c.b == 1.0

        it "creates black":
            val c = EngineColor.black()
            expect c.r == 0.0
            expect c.g == 0.0
            expect c.b == 0.0

        it "creates red":
            val c = EngineColor.red()
            expect c.r == 1.0
            expect c.g == 0.0
            expect c.b == 0.0

    describe "operations":
        it "lerps between two colors at t=0.5":
            val a = EngineColor.black()
            val b = EngineColor.white()
            val mid = a.lerp(b, 0.5)
            # Each channel should be ~0.5
            val ri = mid.r * 1000.0
            expect ri > 499.0
            expect ri < 501.0

        it "converts to rgba8 struct":
            val c = EngineColor.rgba(1.0, 0.0, 0.5, 1.0)
            val rgba = c.to_rgba8()
            expect rgba.r == 255
            expect rgba.g == 0
            # 0.5 * 255 ~= 128
            expect rgba.b > 126
            expect rgba.b < 129
            expect rgba.a == 255

        it "creates from hex integer":
            # 0xFF0000 = red (255, 0, 0)
            val c = EngineColor.from_hex(16711680)
            expect c.r == 1.0
            expect c.g == 0.0
            expect c.b == 0.0

        it "creates color with modified alpha":
            val c = EngineColor.red()
            val faded = c.with_alpha(0.5)
            expect faded.r == 1.0
            expect faded.a == 0.5