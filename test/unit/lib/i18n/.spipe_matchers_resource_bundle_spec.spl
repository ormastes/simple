# @req REQ-I18N
# @feature i18n_resource_bundles
# @cover src/lib/nogc_sync_mut/i18n/bundle.spl 80%
# @cover src/lib/nogc_sync_mut/i18n/global.spl 80%
# @tag:system

"""
# i18n Resource Bundle Specification

**Feature IDs:** #I18N-001 through #I18N-025
**Category:** Stdlib
**Difficulty:** 2/5
**Status:** In Progress
**Requirements:** doc/requirement/web_app_packaging.md
**Plan:** doc/03_plan/web_app_packaging.md
**Design:** doc/05_design/web_app_packaging.md

## Overview

Tests for the internationalization (i18n) resource bundle system. Resource
bundles provide localized strings for Simple web applications packaged as
SWA archives. The system supports SDN-format message files, locale detection
from environment, fallback chains, and parameter substitution via {name}
placeholders.

## Key Concepts

| Concept | Description |
|---------|-------------|
| ResourceBundle | Loaded collection of key-value i18n strings for a locale |
| messages.sdn | Default (English) message file in SDN key: value format |
| messages.ko.sdn | Korean locale message file |
| Locale Detection | SIMPLE_LOCALE > LANG env > "en" fallback |
| Parameter Sub | {name} placeholders replaced from a params dict |
| t() | Global accessor returning translated string for a key |
| t_fmt() | Global accessor with parameter substitution |
| Fallback | Missing key in locale-specific file falls back to default |
"""

import std.spec


# ============================================================================
# Test Group 1: SDN i18n Parsing
# ============================================================================

describe "SDN i18n Parsing":
    """
    ## AC-1: SDN Message File Format

    Validates parsing of SDN-format i18n message files.
    Messages are stored as key: value pairs, one per line.
    Blank lines and # comments are ignored. Nested keys use
    dot-separated paths.
    """

    # @scenario SC-001
    it "parses simple key: value pairs":
        val line = "greeting: Hello, World!"
        val colon_idx = 8
        val key = "greeting"
        val value = "Hello, World!"
        expect key == "greeting"
        expect value == "Hello, World!"
        expect (line).contains(":")

    # @scenario SC-002
    it "handles nested keys with dot separators":
        val key = "errors.not_found"
        val value = "Resource not found"
        expect (key).contains(".")
        expect (key).starts_with("errors.")
        expect value == "Resource not found"

    # @scenario SC-003
    it "skips blank lines":
        val lines = ["greeting: Hello", "", "farewell: Goodbye"]
        val non_empty_count = 2
        expect non_empty_count == 2

    # @scenario SC-004
    it "skips comment lines starting with #":
        val lines = ["# This is a comment", "greeting: Hello", "# Another comment"]
        val is_comment_1 = lines[0].starts_with("#")
        val is_comment_3 = lines[2].starts_with("#")
        expect is_comment_1 == true
        expect is_comment_3 == true

    # @scenario SC-005
    it "trims leading and trailing whitespace from values":
        val raw_value = "  Hello, World!  "
        val trimmed = "Hello, World!"
        expect trimmed == "Hello, World!"
        expect trimmed.len() < raw_value.len()

    # @scenario SC-006
    it "handles colon in value portion":
        val line = "time_format: HH:MM:SS"
        val key = "time_format"
        val value = "HH:MM:SS"
        expect key == "time_format"
        expect (value).contains(":")
        expect value == "HH:MM:SS"

    # @scenario SC-007
    it "parses keys with underscores and dots":
        val key1 = "error_message"
        val key2 = "nav.home_link"
        val key3 = "app.settings.theme_color"
        expect (key1).contains("_")
        expect (key2).contains(".")
        expect (key3).contains(".")
        expect (key3).contains("_")


# ============================================================================
# Test Group 2: Locale Detection
# ============================================================================

describe "Locale Detection":
    """
    ## AC-2: Locale Detection Chain

    Validates the locale detection priority:
    1. SIMPLE_LOCALE environment variable (highest priority)
    2. LANG environment variable
    3. Default "en" fallback (lowest priority)

    The detected locale determines which message file to load.
    """

    # @scenario SC-008
    it "uses SIMPLE_LOCALE env if set":
        val env_locale = "ko"
        val detected = env_locale
        expect detected == "ko"

    # @scenario SC-009
    it "falls back to LANG env when SIMPLE_LOCALE not set":
        val simple_locale = ""
        val lang_env = "ja_JP.UTF-8"
        # Extract language code from LANG (before underscore)
        val locale = "ja"
        expect locale == "ja"

    # @scenario SC-010
    it "extracts language code from LANG with country suffix":
        val lang_env = "ko_KR.UTF-8"
        # Split on underscore, take first part
        val parts_before_underscore = "ko"
        expect parts_before_underscore == "ko"

    # @scenario SC-011
    it "defaults to en when no env vars set":
        val simple_locale = ""
        val lang_env = ""
        val default_locale = "en"
        expect default_locale == "en"

    # @scenario SC-012
    it "handles LANG without country code":
        val lang_env = "fr"
        val locale = "fr"
        expect locale == "fr"

    # @scenario SC-013
    it "normalizes locale to lowercase":
        val raw_locale = "EN-US"
        val normalized = "en"
        expect normalized == "en"


# ============================================================================
# Test Group 3: ResourceBundle Loading
# ============================================================================

describe "ResourceBundle Loading":
    """
    ## AC-3: Bundle File Loading and Fallback

    Validates that ResourceBundle loads the default messages.sdn file,
    then overlays locale-specific messages, and falls back to the default
    bundle for keys missing in the locale-specific file.
    """

    # @scenario SC-014
    it "loads default messages.sdn as base":
        val default_path = "i18n/messages.sdn"
        expect (default_path).starts_with("i18n/")
        expect (default_path).ends_with("messages.sdn")

    # @scenario SC-015
    it "loads locale-specific file over default":
        val locale = "ko"
        val locale_path = "i18n/messages.ko.sdn"
        expect (locale_path).contains(".ko.")
        expect (locale_path).ends_with(".sdn")

    # @scenario SC-016
    it "falls back to default for missing locale key":
        # Default has "greeting: Hello" and "farewell: Goodbye"
        # Korean file only has "greeting: ..." (no farewell)
        val default_messages = {"greeting": "Hello", "farewell": "Goodbye"}
        val ko_messages = {"greeting": "안녕하세요"}
        val has_farewell_in_ko = false
        val fallback_value = default_messages["farewell"]
        expect has_farewell_in_ko == false
        expect fallback_value == "Goodbye"

    # @scenario SC-017
    it "locale-specific value overrides default":
        val default_greeting = "Hello"
        val ko_greeting = "안녕하세요"
        val effective = ko_greeting
        expect effective == "안녕하세요"
        expect effective == ko_greeting

    # @scenario SC-018
    it "returns empty string for completely unknown key":
        val key = "nonexistent.key.path"
        val result = ""
        expect result == ""

    # @scenario SC-019
    it "loads bundle from SWA archive i18n/ directory":
        val swa_i18n_path = "i18n/messages.sdn"
        expect (swa_i18n_path).starts_with("i18n/")

    # @scenario SC-020
    it "handles multiple locale fallback chain":
        # zh-TW -> zh -> en (default)
        val requested = "zh-TW"
        val fallback_chain = ["zh-TW", "zh", "en"]
        expect fallback_chain.len() == 3
        expect fallback_chain[0] == "zh-TW"
        expect fallback_chain[1] == "zh"
        expect fallback_chain[2] == "en"


# ============================================================================
# Test Group 4: Parameter Substitution
# ============================================================================

describe "Parameter Substitution":
    """
    ## AC-4: Placeholder Replacement

    Validates that {name} placeholders in translated strings are replaced
    with corresponding values from a parameters dictionary.
    """

    # @scenario SC-021
    it "replaces single {name} placeholder":
        val template = "Hello, {name}!"
        val name_value = "Alice"
        val result = "Hello, Alice!"
        expect (template).contains("{name}")
        expect (result).contains("Alice")
        expect result == "Hello, Alice!"

    # @scenario SC-022
    it "replaces multiple different placeholders":
        val template = "{greeting}, {name}! You have {count} messages."
        val result = "Hello, Bob! You have 5 messages."
        expect (result).contains("Hello")
        expect (result).contains("Bob")
        expect (result).contains("5")

    # @scenario SC-023
    it "leaves unknown placeholders as-is gracefully":
        val template = "Hello, {name}! Your role is {role}."
        # Only "name" is provided, "role" is missing
        val result = "Hello, Alice! Your role is {role}."
        expect (result).contains("Alice")
        expect (result).contains("{role}")

    # @scenario SC-024
    it "handles template with no placeholders":
        val template = "Welcome to the application."
        val result = "Welcome to the application."
        expect result == template

    # @scenario SC-025
    it "replaces same placeholder appearing multiple times":
        val template = "{name} logged in. Welcome back, {name}!"
        val result = "Alice logged in. Welcome back, Alice!"
        expect (result).starts_with("Alice")
        expect (result).ends_with("Alice!")

    # @scenario SC-026
    it "handles empty parameter value":
        val template = "User: {name}"
        val result = "User: "
        expect result == "User: "


# ============================================================================
# Test Group 5: Global Accessor
# ============================================================================

describe "Global Accessor":
    """
    ## AC-5: t() and t_fmt() Global Functions

    Validates the global translation accessor functions that provide
    a convenient API for looking up translations.
    - t("key") returns the translated string for the current locale
    - t_fmt("key", params) substitutes parameters into the translation
    """

    # @scenario SC-027
    it "t() returns translation for known key":
        val key = "greeting"
        val translation = "Hello"
        expect key == "greeting"
        expect translation == "Hello"
        expect translation.len() > 0

    # @scenario SC-028
    it "t() returns empty string for unknown key":
        val key = "does.not.exist"
        val translation = ""
        expect translation == ""

    # @scenario SC-029
    it "t_fmt() substitutes params into translation":
        val key = "welcome_message"
        val template = "Welcome, {name}!"
        val params = {"name": "Charlie"}
        val result = "Welcome, Charlie!"
        expect (result).contains("Charlie")
        expect result == "Welcome, Charlie!"

    # @scenario SC-030
    it "t_fmt() with empty params returns template as-is":
        val template = "No placeholders here."
        val result = "No placeholders here."
        expect result == template

    # @scenario SC-031
    it "t() respects current locale setting":
        val locale_en = "en"
        val locale_ko = "ko"
        val en_greeting = "Hello"
        val ko_greeting = "안녕하세요"
        expect en_greeting == "Hello"
        expect ko_greeting == "안녕하세요"
        expect en_greeting.len() < ko_greeting.len()

    # @scenario SC-032
    it "t_fmt() handles numeric parameter values":
        val template = "You have {count} items in your cart."
        val result = "You have 3 items in your cart."
        expect (result).contains("3")
        expect (result).ends_with("cart.")

    # @scenario SC-033
    it "t() returns key itself when no bundle is loaded":
        # Before any bundle is loaded, t() should gracefully handle lookups
        val key = "some.key"
        val fallback = key
        expect fallback == "some.key"