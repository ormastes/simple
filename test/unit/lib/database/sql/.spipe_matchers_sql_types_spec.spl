"""
# SQL Types Specification

**Feature IDs:** #DB-001
**Category:** Stdlib
**Difficulty:** 2/5
**Status:** Implemented
**Requirements:** N/A
**Plan:** N/A
**Design:** N/A
**Research:** N/A

## Overview

Tests for the core SQL type system: DbValue construction and accessors,
DbRow column access, DbError message formatting.
"""

use std.database.sql.types.{DbValue, DbRow, DbError, DbType}

# ============================================================================
# DbValue — typed value container
# ============================================================================

describe "DbValue":
    """
    ## DbValue Construction and Accessors

    DbValue is an enum wrapping typed database values: Integer, Real, Text,
    Blob, Null, and Bool. Each variant provides typed accessors that return
    Option types.
    """

    context "Integer variant":
        it "constructs and extracts via as_int":
            val v = DbValue.Integer(value: 42)
            val result = v.as_int()
            expect result.? == true
            expect result? == 42

        it "returns nil for as_text on Integer":
            val v = DbValue.Integer(value: 10)
            val result = v.as_text()
            expect result.? == false

        it "returns nil for as_real on Integer":
            val v = DbValue.Integer(value: 10)
            val result = v.as_real()
            expect result.? == false

        it "is not null":
            val v = DbValue.Integer(value: 0)
            expect v.is_null() == false

        it "reports db_type as Integer":
            val v = DbValue.Integer(value: 5)
            val t = v.db_type()
            match t:
                DbType.Integer: expect(true).to_equal(true)
                _: expect(false).to_equal(true)

        it "converts to text representation":
            val v = DbValue.Integer(value: 99)
            expect v.to_text() == "99"

    context "Real variant":
        it "constructs and extracts via as_real":
            val v = DbValue.Real(value: 3.14)
            val result = v.as_real()
            expect result.? == true

        it "returns nil for as_int on Real":
            val v = DbValue.Real(value: 2.5)
            val result = v.as_int()
            expect result.? == false

    context "Text variant":
        it "constructs and extracts via as_text":
            val v = DbValue.Text(value: "hello")
            val result = v.as_text()
            expect result.? == true
            expect result? == "hello"

        it "returns nil for as_int on Text":
            val v = DbValue.Text(value: "abc")
            val result = v.as_int()
            expect result.? == false

        it "converts to text representation":
            val v = DbValue.Text(value: "world")
            expect v.to_text() == "world"

    context "Bool variant":
        it "constructs and extracts via as_bool":
            val v = DbValue.Bool(value: true)
            val result = v.as_bool()
            expect result.? == true
            expect result? == true

        it "extracts false via as_bool":
            val v = DbValue.Bool(value: false)
            val result = v.as_bool()
            expect result.? == true
            expect result? == false

        it "converts true Bool to int 1 via as_int":
            val v = DbValue.Bool(value: true)
            val result = v.as_int()
            expect result.? == true
            expect result? == 1

        it "converts false Bool to int 0 via as_int":
            val v = DbValue.Bool(value: false)
            val result = v.as_int()
            expect result.? == true
            expect result? == 0

        it "reports db_type as Integer for Bool":
            val v = DbValue.Bool(value: true)
            val t = v.db_type()
            match t:
                DbType.Integer: expect(true).to_equal(true)
                _: expect(false).to_equal(true)

    context "Null variant":
        it "is null":
            val v = DbValue.Null
            expect v.is_null() == true

        it "returns nil for all typed accessors":
            val v = DbValue.Null
            expect v.as_int().? == false
            expect v.as_real().? == false
            expect v.as_text().? == false
            expect v.as_bool().? == false

        it "converts to NULL text":
            val v = DbValue.Null
            expect v.to_text() == "NULL"

    context "Integer as_bool edge cases":
        it "converts integer 1 to true via as_bool":
            val v = DbValue.Integer(value: 1)
            val result = v.as_bool()
            expect result.? == true
            expect result? == true

        it "converts integer 0 to false via as_bool":
            val v = DbValue.Integer(value: 0)
            val result = v.as_bool()
            expect result.? == true
            expect result? == false

        it "returns nil for integer 2 via as_bool":
            val v = DbValue.Integer(value: 2)
            val result = v.as_bool()
            expect result.? == false

# ============================================================================
# DbRow — typed database row
# ============================================================================

describe "DbRow":
    """
    ## DbRow Column Access

    DbRow holds parallel arrays of column names and DbValue entries.
    Provides typed column access by name.
    """

    context "empty row":
        it "creates via static empty()":
            val row = DbRow.empty()
            expect row.column_count() == 0
            expect row.column_names().len() == 0

    context "populated row":
        it "gets value by column name":
            val row = DbRow(
                columns: ["id", "name"],
                values: [DbValue.Integer(value: 1), DbValue.Text(value: "Alice")]
            )
            val v = row.get("name")
            expect v.? == true

        it "returns nil for missing column":
            val row = DbRow(
                columns: ["id"],
                values: [DbValue.Integer(value: 1)]
            )
            val v = row.get("missing")
            expect v.? == false

        it "gets text by column name":
            val row = DbRow(
                columns: ["name"],
                values: [DbValue.Text(value: "Bob")]
            )
            val result = row.get_text("name")
            expect result.? == true
            expect result? == "Bob"

        it "gets int by column name":
            val row = DbRow(
                columns: ["age"],
                values: [DbValue.Integer(value: 30)]
            )
            val result = row.get_int("age")
            expect result.? == true
            expect result? == 30

        it "gets real by column name":
            val row = DbRow(
                columns: ["score"],
                values: [DbValue.Real(value: 9.5)]
            )
            val result = row.get_real("score")
            expect result.? == true

        it "gets bool by column name":
            val row = DbRow(
                columns: ["active"],
                values: [DbValue.Bool(value: true)]
            )
            val result = row.get_bool("active")
            expect result.? == true
            expect result? == true

        it "gets value by index":
            val row = DbRow(
                columns: ["a", "b"],
                values: [DbValue.Integer(value: 10), DbValue.Integer(value: 20)]
            )
            val v = row.get_at(1)
            expect v.? == true

        it "returns nil for out-of-bounds index":
            val row = DbRow(
                columns: ["a"],
                values: [DbValue.Integer(value: 1)]
            )
            val v = row.get_at(5)
            expect v.? == false

        it "returns nil for negative index":
            val row = DbRow(
                columns: ["a"],
                values: [DbValue.Integer(value: 1)]
            )
            val v = row.get_at(-1)
            expect v.? == false

    context "has_column":
        it "returns true for existing column":
            val row = DbRow(
                columns: ["id", "name"],
                values: [DbValue.Integer(value: 1), DbValue.Text(value: "X")]
            )
            expect row.has_column("id") == true
            expect row.has_column("name") == true

        it "returns false for missing column":
            val row = DbRow(
                columns: ["id"],
                values: [DbValue.Integer(value: 1)]
            )
            expect row.has_column("missing") == false

# ============================================================================
# DbError — error messages
# ============================================================================

describe "DbError":
    """
    ## DbError Message Formatting

    Each DbError variant produces a human-readable message via .message().
    """

    it "formats ConnectionFailed message":
        val err = DbError.ConnectionFailed(path: "/tmp/db.sqlite", message: "not found")
        expect (err.message()).contains("Connection failed")
        expect (err.message()).contains("/tmp/db.sqlite")

    it "formats QueryFailed message":
        val err = DbError.QueryFailed(sql: "SELECT *", message: "syntax error")
        expect (err.message()).contains("Query failed")
        expect (err.message()).contains("syntax error")

    it "formats BindFailed message":
        val err = DbError.BindFailed(index: 3, message: "type mismatch")
        expect (err.message()).contains("Bind failed")
        expect (err.message()).contains("3")

    it "formats TypeMismatch message":
        val err = DbError.TypeMismatch(column: "age", expected: "int", actual: "text")
        expect (err.message()).contains("Type mismatch")
        expect (err.message()).contains("age")

    it "formats NotFound message":
        val err = DbError.NotFound(description: "user 42")
        expect (err.message()).contains("Not found")
        expect (err.message()).contains("user 42")

    it "formats ConstraintViolation message":
        val err = DbError.ConstraintViolation(message: "UNIQUE constraint failed")
        expect (err.message()).contains("Constraint violation")

    it "formats MigrationFailed message":
        val err = DbError.MigrationFailed(id: "v002", reason: "column exists")
        expect (err.message()).contains("Migration")
        expect (err.message()).contains("v002")

    it "formats TransactionFailed message":
        val err = DbError.TransactionFailed(reason: "deadlock")
        expect (err.message()).contains("Transaction failed")

    it "formats Closed message":
        val err = DbError.Closed
        expect (err.message()).contains("closed")

    it "formats Other message":
        val err = DbError.Other(message: "unexpected")
        expect (err.message()).contains("unexpected")