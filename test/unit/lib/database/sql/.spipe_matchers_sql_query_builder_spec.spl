# SQL Query Builder Specification
#
# Tests SelectQuery, InsertQuery, UpdateQuery, DeleteQuery builders,
# expression helpers (sql_eq, sql_and, sql_or), and compile_expr output.

use std.database.sql.query_builder.{SelectQuery, InsertQuery, UpdateQuery, DeleteQuery, SqlOp, SqlOrder, SqlExpr, CompiledExpr, sql_eq, sql_ne, sql_and, sql_or, sql_not, sql_is_null, sql_is_not_null, sql_like, sql_in, sql_raw, compile_expr}
use std.database.sql.types.{DbValue}

describe "SelectQuery":
    context "basic select":
        it "builds SELECT * FROM table":
            var q = SelectQuery.from("users")
            val result = q.build()
            val sql = result.0
            val params = result.1
            expect (sql).starts_with("SELECT *")
            expect (sql).contains("users")
            expect params.len() == 0

        it "builds SELECT with specific columns":
            var q = SelectQuery.from("users")
            q = q.select(["name", "age"])
            val result = q.build()
            val sql = result.0
            expect (sql).contains("name")
            expect (sql).contains("age")

    context "with where_eq":
        it "builds SELECT with WHERE equality":
            var q = SelectQuery.from("users")
            q = q.where_eq("id", DbValue.Integer(value: 1))
            val result = q.build()
            val sql = result.0
            val params = result.1
            expect (sql).contains("WHERE")
            expect (sql).contains("id")
            expect params.len() == 1

        it "builds SELECT with multiple WHERE conditions":
            var q = SelectQuery.from("users")
            q = q.where_eq("name", DbValue.Text(value: "Alice"))
            q = q.where_eq("age", DbValue.Integer(value: 30))
            val result = q.build()
            val sql = result.0
            val params = result.1
            expect (sql).contains("AND")
            expect params.len() == 2

    context "with order":
        it "builds SELECT with ORDER BY ASC":
            var q = SelectQuery.from("users")
            q = q.order("name", SqlOrder.Asc)
            val result = q.build()
            val sql = result.0
            expect (sql).contains("ORDER BY")
            expect (sql).contains("ASC")

        it "builds SELECT with ORDER BY DESC":
            var q = SelectQuery.from("users")
            q = q.order("age", SqlOrder.Desc)
            val result = q.build()
            val sql = result.0
            expect (sql).contains("DESC")

        it "builds SELECT with multiple ORDER BY columns":
            var q = SelectQuery.from("users")
            q = q.order("name", SqlOrder.Asc)
            q = q.order("age", SqlOrder.Desc)
            val result = q.build()
            val sql = result.0
            expect (sql).contains("ASC")
            expect (sql).contains("DESC")

    context "with limit and offset":
        it "builds SELECT with LIMIT":
            var q = SelectQuery.from("users")
            q = q.limit(10)
            val result = q.build()
            val sql = result.0
            val params = result.1
            expect (sql).contains("LIMIT ?")
            expect params.len() == 1

        it "builds SELECT with LIMIT and OFFSET":
            var q = SelectQuery.from("users")
            q = q.limit(10)
            q = q.offset(20)
            val result = q.build()
            val sql = result.0
            val params = result.1
            expect (sql).contains("LIMIT ?")
            expect (sql).contains("OFFSET ?")
            expect params.len() == 2

    context "combined query":
        it "builds full SELECT with all clauses":
            var q = SelectQuery.from("users")
            q = q.select(["name", "age"])
            q = q.where_eq("active", DbValue.Integer(value: 1))
            q = q.order("name", SqlOrder.Asc)
            q = q.limit(10)
            q = q.offset(0)
            val result = q.build()
            val sql = result.0
            val params = result.1
            expect (sql).contains("SELECT")
            expect (sql).contains("WHERE")
            expect (sql).contains("ORDER BY")
            expect (sql).contains("LIMIT")
            expect (sql).contains("OFFSET")
            expect params.len() == 3

describe "InsertQuery":
    context "basic insert":
        it "builds INSERT INTO with columns and row":
            var q = InsertQuery.into("users")
            q = q.columns(["name", "age"])
            q = q.row([DbValue.Text(value: "Alice"), DbValue.Integer(value: 30)])
            val result = q.build()
            val sql = result.0
            val params = result.1
            expect (sql).starts_with("INSERT INTO")
            expect (sql).contains("users")
            expect (sql).contains("VALUES")
            expect (sql).contains("?")
            expect params.len() == 2

    context "batch insert":
        it "builds batch INSERT statements":
            var q = InsertQuery.into("users")
            q = q.columns(["name", "age"])
            q = q.row([DbValue.Text(value: "Alice"), DbValue.Integer(value: 30)])
            q = q.row([DbValue.Text(value: "Bob"), DbValue.Integer(value: 25)])
            val results = q.build_batch()
            expect results.len() == 2
            val first = results[0]
            expect (first.0).contains("INSERT INTO")
            expect first.1.len() == 2

describe "UpdateQuery":
    context "basic update":
        it "builds UPDATE with SET and WHERE":
            var q = UpdateQuery.table("users")
            q = q.set("name", DbValue.Text(value: "Bob"))
            q = q.where_eq("id", DbValue.Integer(value: 1))
            val result = q.build()
            val sql = result.0
            val params = result.1
            expect (sql).starts_with("UPDATE")
            expect (sql).contains("SET")
            expect (sql).contains("WHERE")
            expect params.len() == 2

        it "builds UPDATE with multiple SET columns":
            var q = UpdateQuery.table("users")
            q = q.set("name", DbValue.Text(value: "Bob"))
            q = q.set("age", DbValue.Integer(value: 31))
            q = q.where_eq("id", DbValue.Integer(value: 1))
            val result = q.build()
            val sql = result.0
            val params = result.1
            expect params.len() == 3

describe "DeleteQuery":
    context "basic delete":
        it "builds DELETE FROM with WHERE":
            var q = DeleteQuery.from("users")
            q = q.where_eq("id", DbValue.Integer(value: 1))
            val result = q.build()
            val sql = result.0
            val params = result.1
            expect (sql).starts_with("DELETE FROM")
            expect (sql).contains("WHERE")
            expect params.len() == 1

        it "builds DELETE FROM without WHERE":
            var q = DeleteQuery.from("users")
            val result = q.build()
            val sql = result.0
            val params = result.1
            expect (sql).starts_with("DELETE FROM")
            expect params.len() == 0

describe "Expression Helpers":
    context "sql_eq":
        it "creates equality expression":
            val expr = sql_eq("name", DbValue.Text(value: "Alice"))
            val compiled = compile_expr(expr)
            expect (compiled.sql).contains("=")
            expect (compiled.sql).contains("name")
            expect compiled.params.len() == 1

    context "sql_and":
        it "creates AND expression":
            val left = sql_eq("name", DbValue.Text(value: "Alice"))
            val right = sql_eq("age", DbValue.Integer(value: 30))
            val expr = sql_and(left, right)
            val compiled = compile_expr(expr)
            expect (compiled.sql).contains("AND")
            expect compiled.params.len() == 2

    context "sql_or":
        it "creates OR expression":
            val left = sql_eq("name", DbValue.Text(value: "Alice"))
            val right = sql_eq("name", DbValue.Text(value: "Bob"))
            val expr = sql_or(left, right)
            val compiled = compile_expr(expr)
            expect (compiled.sql).contains("OR")
            expect compiled.params.len() == 2

    context "sql_not":
        it "creates NOT expression":
            val inner = sql_eq("active", DbValue.Integer(value: 0))
            val expr = sql_not(inner)
            val compiled = compile_expr(expr)
            expect (compiled.sql).starts_with("NOT")
            expect compiled.params.len() == 1

    context "sql_is_null":
        it "creates IS NULL expression":
            val expr = sql_is_null("deleted_at")
            val compiled = compile_expr(expr)
            expect (compiled.sql).contains("IS NULL")
            expect compiled.params.len() == 0

    context "sql_is_not_null":
        it "creates IS NOT NULL expression":
            val expr = sql_is_not_null("email")
            val compiled = compile_expr(expr)
            expect (compiled.sql).contains("IS NOT NULL")
            expect compiled.params.len() == 0

    context "sql_like":
        it "creates LIKE expression":
            val expr = sql_like("name", "%Alice%")
            val compiled = compile_expr(expr)
            expect (compiled.sql).contains("LIKE")
            expect compiled.params.len() == 1

    context "sql_in":
        it "creates IN expression":
            val values = [DbValue.Integer(value: 1), DbValue.Integer(value: 2), DbValue.Integer(value: 3)]
            val expr = sql_in("id", values)
            val compiled = compile_expr(expr)
            expect (compiled.sql).contains("IN")
            expect compiled.params.len() == 3

    context "sql_raw":
        it "creates raw SQL expression":
            val expr = sql_raw("1 = 1")
            val compiled = compile_expr(expr)
            expect compiled.sql == "1 = 1"
            expect compiled.params.len() == 0

    context "compile_expr":
        it "compiles simple equality":
            val expr = sql_eq("id", DbValue.Integer(value: 42))
            val compiled = compile_expr(expr)
            expect (compiled.sql).contains("= ?")
            expect compiled.params.len() == 1

        it "compiles nested AND/OR":
            val a = sql_eq("x", DbValue.Integer(value: 1))
            val b = sql_eq("y", DbValue.Integer(value: 2))
            val c = sql_eq("z", DbValue.Integer(value: 3))
            val and_expr = sql_and(a, b)
            val or_expr = sql_or(and_expr, c)
            val compiled = compile_expr(or_expr)
            expect (compiled.sql).contains("AND")
            expect (compiled.sql).contains("OR")
            expect compiled.params.len() == 3