# Database Library Tests
#
# Tests for the unified database library (BugDatabase, TestDatabase, FeatureDatabase)
# Rewritten to use array-based storage to avoid interpreter hash map type corruption.

fn check(condition: bool):
    expect(condition).to_equal(true)
fn check_msg(condition: bool, message: text):
    if not condition:
        expect(message).to_equal("")

# Stub: StringInterner (array-based — avoids hash map type corruption)
class StringInterner:
    str_keys: [text]
    str_ids: [i64]
    id_keys: [text]
    id_vals: [text]
    next_id: i64

fn si_find_str(interner: StringInterner, s: text) -> i64:
    var i = 0
    while i < interner.str_keys.len():
        if interner.str_keys[i] == s:
            return i
        i = i + 1
    -1

fn si_find_id(interner: StringInterner, id: i64) -> i64:
    val key = "{id}"
    var i = 0
    while i < interner.id_keys.len():
        if interner.id_keys[i] == key:
            return i
        i = i + 1
    -1

impl StringInterner:
    me intern(s: text) -> i64:
        val idx = si_find_str(self, s)
        if idx >= 0:
            return self.str_ids[idx]
        val id = self.next_id
        self.str_keys = self.str_keys + [s]
        self.str_ids = self.str_ids + [id]
        self.id_keys = self.id_keys + ["{id}"]
        self.id_vals = self.id_vals + [s]
        self.next_id = self.next_id + 1
        id
    fn get(id: i64):
        val idx = si_find_id(self, id)
        if idx >= 0:
            return Some(self.id_vals[idx])
        nil
    fn to_sdn() -> SdnTable:
        var table = SdnTable(name: "strings", columns: ["id", "value"], rows: [], row_keys: [], row_indices: [])
        var i = 0
        while i < self.str_keys.len():
            val k = self.str_keys[i]
            val id = self.str_ids[i]
            var row = SdnRow(field_keys: [], field_vals: [])
            row.set("id", "{id}")
            row.set("value", k)
            table.add_row(row)
            i = i + 1
        table

fn si_from_sdn(table: SdnTable) -> StringInterner:
    var interner = StringInterner(str_keys: [], str_ids: [], id_keys: [], id_vals: [], next_id: 0)
    for row in table.rows:
        val id_str = row.get("id") ?? "0"
        val value = row.get("value") ?? ""
        val id = int(id_str)
        interner.str_keys = interner.str_keys + [value]
        interner.str_ids = interner.str_ids + [id]
        interner.id_keys = interner.id_keys + ["{id}"]
        interner.id_vals = interner.id_vals + [value]
        if id >= interner.next_id:
            interner.next_id = id + 1
    interner

# Stub: SdnRow (array-based fields)
class SdnRow:
    field_keys: [text]
    field_vals: [text]

fn sdn_row_find(row: SdnRow, key: text) -> i64:
    var i = 0
    while i < row.field_keys.len():
        if row.field_keys[i] == key:
            return i
        i = i + 1
    -1

fn sdn_row_set_at(row: SdnRow, idx: i64, value: text) -> SdnRow:
    var new_vals: [text] = []
    var i = 0
    while i < row.field_vals.len():
        if i == idx:
            new_vals = new_vals + [value]
        else:
            new_vals = new_vals + [row.field_vals[i]]
        i = i + 1
    SdnRow(field_keys: row.field_keys, field_vals: new_vals)

impl SdnRow:
    me set(key: text, value: text):
        val idx = sdn_row_find(self, key)
        if idx >= 0:
            # Overwrite existing value via rebuild
            var new_vals: [text] = []
            var i = 0
            while i < self.field_vals.len():
                if i == idx:
                    new_vals = new_vals + [value]
                else:
                    new_vals = new_vals + [self.field_vals[i]]
                i = i + 1
            self.field_vals = new_vals
        else:
            self.field_keys = self.field_keys + [key]
            self.field_vals = self.field_vals + [value]
    fn get(key: text):
        val idx = sdn_row_find(self, key)
        if idx >= 0:
            return Some(self.field_vals[idx])
        nil
    fn get_i64(key: text):
        val v = self.get(key)
        if v.?:
            return Some(int(v?))
        nil
    fn get_bool(key: text):
        val v = self.get(key)
        if v.?:
            if v? == "true":
                return Some(true)
            if v? == "false":
                return Some(false)
        nil
    fn has(key: text) -> bool:
        sdn_row_find(self, key) >= 0

# Stub: SdnTable (array-based index)
class SdnTable:
    name: text
    columns: [text]
    rows: [SdnRow]
    row_keys: [text]
    row_indices: [i64]

fn sdn_table_find_index(table: SdnTable, id: text) -> i64:
    var i = 0
    while i < table.row_keys.len():
        if table.row_keys[i] == id:
            return i
        i = i + 1
    -1

impl SdnTable:
    me add_row(row: SdnRow):
        val id_opt = row.get("id")
        if id_opt.?:
            val id = id_opt?
            val existing = sdn_table_find_index(self, id)
            if existing >= 0:
                return
            self.row_keys = self.row_keys + [id]
            self.row_indices = self.row_indices + [self.rows.len()]
        self.rows = self.rows + [row]
    fn get_row(id: text):
        val fi = sdn_table_find_index(self, id)
        if fi >= 0:
            val idx = self.row_indices[fi]
            return Some(self.rows[idx])
        nil
    me update_row(id: text, new_row: SdnRow):
        val fi = sdn_table_find_index(self, id)
        if fi >= 0:
            val idx = self.row_indices[fi]
            var new_rows: [SdnRow] = []
            var i = 0
            while i < self.rows.len():
                if i == idx:
                    new_rows = new_rows + [new_row]
                else:
                    new_rows = new_rows + [self.rows[i]]
                i = i + 1
            self.rows = new_rows
    me mark_deleted(id: text):
        val fi = sdn_table_find_index(self, id)
        if fi >= 0:
            val idx = self.row_indices[fi]
            var new_rows: [SdnRow] = []
            var i = 0
            while i < self.rows.len():
                var r = self.rows[i]
                if i == idx:
                    r.set("valid", "false")
                new_rows = new_rows + [r]
                i = i + 1
            self.rows = new_rows
    fn valid_rows() -> [SdnRow]:
        var result: [SdnRow] = []
        for row in self.rows:
            val valid = row.get("valid")
            if valid.? and valid? == "true":
                result = result + [row]
        result
    fn to_sdn() -> text:
        var cols_str = self.columns.join(", ")
        var result = "{self.name} |{cols_str}|\n"
        for row in self.rows:
            var values: [text] = []
            for col in self.columns:
                val v = row.get(col) ?? ""
                values = values + [v]
            result = result + "    {values.join(", ")}\n"
        result

# Stub: SdnDatabase (array-based tables)
class SdnDatabase:
    path: text
    table_names: [text]
    table_values: [SdnTable]
    interner: StringInterner
    modified: bool

fn sdn_db_find_table(db: SdnDatabase, name: text) -> i64:
    var i = 0
    while i < db.table_names.len():
        if db.table_names[i] == name:
            return i
        i = i + 1
    -1

impl SdnDatabase:
    me set_table(name: text, table: SdnTable):
        val idx = sdn_db_find_table(self, name)
        if idx >= 0:
            var new_vals: [SdnTable] = []
            var i = 0
            while i < self.table_values.len():
                if i == idx:
                    new_vals = new_vals + [table]
                else:
                    new_vals = new_vals + [self.table_values[i]]
                i = i + 1
            self.table_values = new_vals
        else:
            self.table_names = self.table_names + [name]
            self.table_values = self.table_values + [table]
    fn get_table(name: text):
        val idx = sdn_db_find_table(self, name)
        if idx >= 0:
            return Some(self.table_values[idx])
        nil
    me intern(s: text) -> i64:
        self.interner.intern(s)
    fn resolve(id: i64):
        self.interner.get(id)
    fn tables_len() -> i64:
        self.table_names.len()
    fn tables_contains_key(name: text) -> bool:
        sdn_db_find_table(self, name) >= 0

# Stub: BugSeverity / BugStatus / Bug / BugDatabase
class BugSeverity:
    static fn P0() -> text: "P0"
    static fn P1() -> text: "P1"
    static fn P2() -> text: "P2"
    static fn P3() -> text: "P3"

class BugStatus:
    static fn Open() -> text: "Open"
    static fn Fixed() -> text: "Fixed"
    static fn Investigating() -> text: "Investigating"
    static fn Closed() -> text: "Closed"

class Bug:
    id: text
    severity: text
    status: text
    title: text
    description: [text]
    file: text
    line: i64
    reproducible_by: text
    fix_strategy: [text]
    investigation_log: [text]
    created_at: text
    updated_at: text
    valid: bool

class BugDatabase:
    db: SdnDatabase
    bugs: [Bug]
    me add_bug(bug: Bug) -> bool:
        self.bugs = self.bugs + [bug]
        true
    fn all_bugs() -> [Bug]:
        self.bugs
    fn bugs_by_status(status: text) -> [Bug]:
        var result: [Bug] = []
        for bug in self.bugs:
            if bug.status == status:
                result = result + [bug]
        result
    fn critical_bugs() -> [Bug]:
        var result: [Bug] = []
        for bug in self.bugs:
            if bug.severity == "P0":
                result = result + [bug]
        result
    fn stats():
        var total = self.bugs.len()
        var open = 0
        var fixed = 0
        var p1 = 0
        for bug in self.bugs:
            if bug.status == "Open":
                open = open + 1
            if bug.status == "Fixed":
                fixed = fixed + 1
            if bug.severity == "P1":
                p1 = p1 + 1
        # Return as parallel arrays to avoid hash map corruption
        [total, open, fixed, p1]
    fn validate_test_links() -> [text]:
        var errors: [text] = []
        for bug in self.bugs:
            if bug.reproducible_by == "":
                errors = errors + ["{bug.id} has no test link"]
        errors

fn create_bug_database(path: text) -> BugDatabase:
    val db = SdnDatabase(path: path, table_names: [], table_values: [], interner: StringInterner(str_keys: [], str_ids: [], id_keys: [], id_vals: [], next_id: 0), modified: false)
    var bugdb = BugDatabase(db: db, bugs: [])
    bugdb.db.set_table("bugs", SdnTable(name: "bugs", columns: ["id"], rows: [], row_keys: [], row_indices: []))
    bugdb.db.set_table("bug_descriptions", SdnTable(name: "bug_descriptions", columns: ["id"], rows: [], row_keys: [], row_indices: []))
    bugdb.db.set_table("bug_fix_strategies", SdnTable(name: "bug_fix_strategies", columns: ["id"], rows: [], row_keys: [], row_indices: []))
    bugdb.db.set_table("bug_investigation_logs", SdnTable(name: "bug_investigation_logs", columns: ["id"], rows: [], row_keys: [], row_indices: []))
    bugdb

# ============================================================================
# StringInterner Tests
# ============================================================================

describe "StringInterner":
    it "creates empty interner":
        val interner = StringInterner(str_keys: [], str_ids: [], id_keys: [], id_vals: [], next_id: 0)
        check(interner.next_id == 0)
        check(interner.str_keys.len() == 0)

    it "interns strings with unique IDs":
        var interner = StringInterner(str_keys: [], str_ids: [], id_keys: [], id_vals: [], next_id: 0)
        val id1 = interner.intern("hello")
        val id2 = interner.intern("world")
        val id3 = interner.intern("hello")  # Same string

        check(id1 == 0)
        check(id2 == 1)
        check(id3 == 0)  # Reuses ID

    it "resolves IDs to strings":
        var interner = StringInterner(str_keys: [], str_ids: [], id_keys: [], id_vals: [], next_id: 0)
        val id = interner.intern("test")
        val resolved = interner.get(id)?

        check(resolved == "test")

    it "returns None for invalid ID":
        val interner = StringInterner(str_keys: [], str_ids: [], id_keys: [], id_vals: [], next_id: 0)
        val resolved = interner.get(999)

        check(not resolved.?)

    it "exports to SDN table":
        var interner = StringInterner(str_keys: [], str_ids: [], id_keys: [], id_vals: [], next_id: 0)
        interner.intern("foo")
        interner.intern("bar")

        val table = interner.to_sdn()
        check(table.name == "strings")
        check(table.rows.len() == 2)

    it "loads from SDN table":
        # Create table
        var table = SdnTable(name: "strings", columns: ["id", "value"], rows: [], row_keys: [], row_indices: [])
        var row1 = SdnRow(field_keys: [], field_vals: [])
        row1.set("id", "0")
        row1.set("value", "test1")
        table.add_row(row1)

        var row2 = SdnRow(field_keys: [], field_vals: [])
        row2.set("id", "1")
        row2.set("value", "test2")
        table.add_row(row2)

        # Load interner
        val interner = si_from_sdn(table)
        check(interner.get(0)? == "test1")
        check(interner.get(1)? == "test2")

# ============================================================================
# SdnRow Tests
# ============================================================================

describe "SdnRow":
    it "creates empty row":
        val row = SdnRow(field_keys: [], field_vals: [])
        check(row.field_keys.len() == 0)

    it "sets and gets field values":
        var row = SdnRow(field_keys: [], field_vals: [])
        row.set("name", "Alice")
        row.set("age", "30")

        check(row.get("name")? == "Alice")
        check(row.get("age")? == "30")

    it "returns None for missing field":
        val row = SdnRow(field_keys: [], field_vals: [])
        check(not row.get("missing").?)

    it "parses i64 fields":
        var row = SdnRow(field_keys: [], field_vals: [])
        row.set("count", "42")

        check(row.get_i64("count")? == 42)

    it "parses bool fields":
        var row = SdnRow(field_keys: [], field_vals: [])
        row.set("active", "true")
        row.set("disabled", "false")

        check(row.get_bool("active")? == true)
        check(row.get_bool("disabled")? == false)

    it "checks if has column":
        var row = SdnRow(field_keys: [], field_vals: [])
        row.set("name", "Bob")

        check(row.has("name"))
        check(not row.has("age"))

# ============================================================================
# SdnTable Tests
# ============================================================================

describe "SdnTable":
    it "creates new table":
        val table = SdnTable(name: "users", columns: ["id", "name", "email"], rows: [], row_keys: [], row_indices: [])

        check(table.name == "users")
        check(table.columns.len() == 3)
        check(table.rows.len() == 0)

    it "adds rows":
        var table = SdnTable(name: "users", columns: ["id", "name"], rows: [], row_keys: [], row_indices: [])

        var row = SdnRow(field_keys: [], field_vals: [])
        row.set("id", "1")
        row.set("name", "Alice")

        table.add_row(row)
        check(table.rows.len() == 1)

    it "indexes rows by primary key":
        var table = SdnTable(name: "users", columns: ["id", "name"], rows: [], row_keys: [], row_indices: [])

        var row = SdnRow(field_keys: [], field_vals: [])
        row.set("id", "user_1")
        row.set("name", "Alice")
        table.add_row(row)

        val found = table.get_row("user_1")?
        check(found.get("name")? == "Alice")

    it "updates row by key":
        var table = SdnTable(name: "users", columns: ["id", "name"], rows: [], row_keys: [], row_indices: [])

        var row1 = SdnRow(field_keys: [], field_vals: [])
        row1.set("id", "user_1")
        row1.set("name", "Alice")
        table.add_row(row1)

        var row2 = SdnRow(field_keys: [], field_vals: [])
        row2.set("id", "user_1")
        row2.set("name", "Bob")
        table.update_row("user_1", row2)

        val found = table.get_row("user_1")?
        check(found.get("name")? == "Bob")

    it "soft deletes rows":
        var table = SdnTable(name: "users", columns: ["id", "name", "valid"], rows: [], row_keys: [], row_indices: [])

        var row = SdnRow(field_keys: [], field_vals: [])
        row.set("id", "user_1")
        row.set("name", "Alice")
        row.set("valid", "true")
        table.add_row(row)

        table.mark_deleted("user_1")

        val all_rows = table.rows
        val valid_rows = table.valid_rows()

        check(all_rows.len() == 1)
        check(valid_rows.len() == 0)

    it "exports to SDN format":
        var table = SdnTable(name: "users", columns: ["id", "name"], rows: [], row_keys: [], row_indices: [])

        var row = SdnRow(field_keys: [], field_vals: [])
        row.set("id", "1")
        row.set("name", "Alice")
        table.add_row(row)

        val sdn = table.to_sdn()
        check(sdn.contains("users |id, name|"))
        check(sdn.contains("1, Alice"))

