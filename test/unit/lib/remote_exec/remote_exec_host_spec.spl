"""
# Remote JIT Execution Host-Side Specification

**Feature IDs:** #RJE-001 through #RJE-006
**Category:** Runtime
**Difficulty:** 3/5
**Status:** Implemented
**Design:** doc/design/remote_jit_impl.md
**Requirements:** N/A
**Plan:** N/A
**Research:** N/A

## Overview

Comprehensive host-side tests for the remote JIT execution pipeline.
These tests verify memory maps, allocators, register helpers, halt
instructions, compiler bridge, code uploader, ExecResult, and the
baremetal library workload -- all WITHOUT requiring hardware (no QEMU,
no OpenOCD, no TRACE32).

## Key Concepts

| Concept | Description |
|---------|-------------|
| MemoryMap | Target memory layout with code/data regions |
| TargetMemoryAllocator | Bump allocator within a MemoryMap |
| CodeUploader | Uploads machine code bytes via debug protocol |
| CompilerBridge | Compiles Simple source to target bytes |
| ExecResult | Execution outcome (success or failure) |
| ResultCollector | Reads return register after execution |
"""

use std.io_runtime
use std.nogc_sync_mut.debug.remote.types.{Architecture}
use std.nogc_sync_mut.debug.remote.exec.types.{
    MemoryMap, CodeInfo, ExecResult,
    EBREAK_RV32, BKPT_ARM,
    halt_instruction_for, halt_instruction_size,
    pc_register_index, sp_register_index, return_register_index, link_register_index,
    arg_register_indices, max_args,
    arm_reg_name, rv32_reg_name, reg_name_for_arch
}
use std.nogc_sync_mut.debug.remote.exec.memory_alloc.{TargetMemoryAllocator}
use std.nogc_sync_mut.debug.remote.exec.uploader.{CodeUploader}
use std.nogc_sync_mut.debug.remote.exec.compiler_bridge.{CompilerBridge, compile_remote_binary}
use std.nogc_sync_mut.debug.remote.exec.result_collector.{ResultCollector}
use test.feature.app.remote_baremetal.remote_baremetal_library_workload.{run_baremetal_library_workload}


# ============================================================================
# Test Group 1: MemoryMap Capacity Checks
# ============================================================================

describe "MemoryMap":
    """
    ## Memory Map Layouts

    Each target preset must have positive code and data capacity and
    stack_top >= data_end.  The stm32h7 and ch32v307 maps previously
    had zero data capacity -- these are key regression tests.
    """

    context "qemu_rv32":
        it "has positive code capacity":
            val m = MemoryMap.qemu_rv32()
            expect(m.code_capacity()).to_be_greater_than(0)

        it "has positive data capacity":
            val m = MemoryMap.qemu_rv32()
            expect(m.data_capacity()).to_be_greater_than(0)

        it "stack_top >= data_end":
            val m = MemoryMap.qemu_rv32()
            val ok = m.stack_top >= m.data_end
            expect(ok).to_equal(true)

    context "qemu_arm":
        it "has positive code capacity":
            val m = MemoryMap.qemu_arm()
            expect(m.code_capacity()).to_be_greater_than(0)

        it "has positive data capacity":
            val m = MemoryMap.qemu_arm()
            expect(m.data_capacity()).to_be_greater_than(0)

        it "stack_top >= data_end":
            val m = MemoryMap.qemu_arm()
            val ok = m.stack_top >= m.data_end
            expect(ok).to_equal(true)

    context "stm32h7 (regression)":
        """
        ### Regression: stm32h7 data_capacity was zero

        Previously stm32h7 had data_start == data_end, producing zero
        data capacity.  This test guards against that regression.
        """

        it "has positive code capacity":
            val m = MemoryMap.stm32h7()
            expect(m.code_capacity()).to_be_greater_than(0)

        it "has positive data capacity":
            val m = MemoryMap.stm32h7()
            expect(m.data_capacity()).to_be_greater_than(0)

        it "stack_top >= data_end":
            val m = MemoryMap.stm32h7()
            val ok = m.stack_top >= m.data_end
            expect(ok).to_equal(true)

    context "stm32wb":
        it "has positive code capacity":
            val m = MemoryMap.stm32wb()
            expect(m.code_capacity()).to_be_greater_than(0)

        it "has positive data capacity":
            val m = MemoryMap.stm32wb()
            expect(m.data_capacity()).to_be_greater_than(0)

        it "stack_top >= data_end":
            val m = MemoryMap.stm32wb()
            val ok = m.stack_top >= m.data_end
            expect(ok).to_equal(true)

    context "ch32v307 (regression)":
        """
        ### Regression: ch32v307 data_capacity was zero

        Previously ch32v307 had data_start == data_end, producing zero
        data capacity.  This test guards against that regression.
        """

        it "has positive code capacity":
            val m = MemoryMap.ch32v307()
            expect(m.code_capacity()).to_be_greater_than(0)

        it "has positive data capacity":
            val m = MemoryMap.ch32v307()
            expect(m.data_capacity()).to_be_greater_than(0)

        it "stack_top >= data_end":
            val m = MemoryMap.ch32v307()
            val ok = m.stack_top >= m.data_end
            expect(ok).to_equal(true)

    context "ghdl_rv32":
        it "has positive code capacity":
            val m = MemoryMap.ghdl_rv32()
            expect(m.code_capacity()).to_be_greater_than(0)

        it "has positive data capacity":
            val m = MemoryMap.ghdl_rv32()
            expect(m.data_capacity()).to_be_greater_than(0)

        it "stack_top >= data_end":
            val m = MemoryMap.ghdl_rv32()
            val ok = m.stack_top >= m.data_end
            expect(ok).to_equal(true)


# ============================================================================
# Test Group 2: TargetMemoryAllocator
# ============================================================================

describe "TargetMemoryAllocator":
    """
    ## Bump Allocator

    Validates that the target memory allocator correctly tracks bump
    offsets, respects alignment, and reports exhaustion.
    """

    context "allocation basics":
        it "returns address within code region":
            var alloc = TargetMemoryAllocator.new(MemoryMap.qemu_rv32())
            val result = alloc.allocate(64, 4)
            val addr = result.ok.unwrap()
            val m = MemoryMap.qemu_rv32()
            val in_range = addr >= m.code_start and addr < m.code_end
            expect(in_range).to_equal(true)

        it "respects alignment":
            var alloc = TargetMemoryAllocator.new(MemoryMap.qemu_rv32())
            val result = alloc.allocate(16, 16)
            val addr = result.ok.unwrap()
            val aligned = (addr % 16) == 0
            expect(aligned).to_equal(true)

        it "fails when memory exhausted":
            val small_map = MemoryMap(
                code_start: 0x1000,
                code_end: 0x1040,
                data_start: 0x1040,
                data_end: 0x1080,
                stack_top: 0x1080,
                allow_expand: false
            )
            var alloc = TargetMemoryAllocator.new(small_map)
            # Allocate all 64 bytes
            val first = alloc.allocate(64, 4)
            expect(first.is_ok()).to_equal(true)
            # Next allocation should fail
            val second = alloc.allocate(1, 1)
            expect(second.is_err()).to_equal(true)

    context "tracking":
        it "remaining decreases after allocation":
            var alloc = TargetMemoryAllocator.new(MemoryMap.qemu_rv32())
            val before = alloc.remaining()
            val result = alloc.allocate(256, 4)
            expect(result.is_ok()).to_equal(true)
            val after = alloc.remaining()
            expect(after).to_be_less_than(before)

        it "allocation_count tracks allocations":
            var alloc = TargetMemoryAllocator.new(MemoryMap.qemu_rv32())
            expect(alloc.allocation_count()).to_equal(0)
            val r1 = alloc.allocate(32, 4)
            expect(alloc.allocation_count()).to_equal(1)
            val r2 = alloc.allocate(32, 4)
            expect(alloc.allocation_count()).to_equal(2)

        it "reset frees all memory":
            var alloc = TargetMemoryAllocator.new(MemoryMap.qemu_rv32())
            val full_remaining = alloc.remaining()
            val r1 = alloc.allocate(128, 4)
            expect(alloc.remaining()).to_be_less_than(full_remaining)
            alloc.reset()
            expect(alloc.remaining()).to_equal(full_remaining)
            expect(alloc.allocation_count()).to_equal(0)


# ============================================================================
# Test Group 3: Register Name Functions
# ============================================================================

describe "Register Names":
    """
    ## Register Name Lookup

    Validates arm_reg_name, rv32_reg_name, and the dispatch function
    reg_name_for_arch for both ARM32 and RiscV32 architectures.
    """

    context "arm_reg_name":
        it "returns r0 for register 0":
            expect(arm_reg_name(0)).to_equal("r0")

        it "returns sp for register 13":
            expect(arm_reg_name(13)).to_equal("sp")

        it "returns lr for register 14":
            expect(arm_reg_name(14)).to_equal("lr")

        it "returns pc for register 15":
            expect(arm_reg_name(15)).to_equal("pc")

        it "covers mid-range registers":
            expect(arm_reg_name(7)).to_equal("r7")
            expect(arm_reg_name(12)).to_equal("r12")

    context "rv32_reg_name":
        it "returns zero for register 0":
            expect(rv32_reg_name(0)).to_equal("zero")

        it "returns ra for register 1":
            expect(rv32_reg_name(1)).to_equal("ra")

        it "returns sp for register 2":
            expect(rv32_reg_name(2)).to_equal("sp")

        it "returns a0 for register 10":
            expect(rv32_reg_name(10)).to_equal("a0")

        it "returns a7 for register 17":
            expect(rv32_reg_name(17)).to_equal("a7")

        it "returns t6 for register 31":
            expect(rv32_reg_name(31)).to_equal("t6")

        it "returns pc for register 32":
            expect(rv32_reg_name(32)).to_equal("pc")

        it "returns s0 for register 8":
            expect(rv32_reg_name(8)).to_equal("s0")

    context "reg_name_for_arch dispatch":
        it "dispatches ARM32 correctly":
            expect(reg_name_for_arch(13, Architecture.Arm32)).to_equal("sp")

        it "dispatches RiscV32 correctly":
            expect(reg_name_for_arch(10, Architecture.RiscV32)).to_equal("a0")

        it "returns rv32 name for unknown architecture":
            expect(reg_name_for_arch(2, Architecture.X86_64)).to_equal("sp")


# ============================================================================
# Test Group 4: Halt Instructions
# ============================================================================

describe "Halt Instructions":
    """
    ## Halt Instruction Constants and Lookup

    Verifies that halt_instruction_for returns the correct opcode for
    each architecture, and halt_instruction_size returns the correct
    byte count.
    """

    context "halt_instruction_for":
        it "returns EBREAK for RiscV32":
            expect(halt_instruction_for(Architecture.RiscV32)).to_equal(EBREAK_RV32)

        it "returns BKPT for Arm32":
            expect(halt_instruction_for(Architecture.Arm32)).to_equal(BKPT_ARM)

        it "EBREAK_RV32 is 0x00100073":
            expect(EBREAK_RV32).to_equal(0x00100073)

        it "BKPT_ARM is 0xBE00":
            expect(BKPT_ARM).to_equal(0xBE00)

    context "halt_instruction_size":
        it "Arm32 halt is 2 bytes":
            expect(halt_instruction_size(Architecture.Arm32)).to_equal(2)

        it "RiscV32 halt is 4 bytes":
            expect(halt_instruction_size(Architecture.RiscV32)).to_equal(4)


# ============================================================================
# Test Group 5: Register Indices
# ============================================================================

describe "Register Indices":
    """
    ## Architecture-Specific Register Index Lookup

    Validates pc, sp, return, and link register index functions for
    both ARM32 and RiscV32.
    """

    context "RiscV32":
        it "pc is register 32":
            expect(pc_register_index(Architecture.RiscV32)).to_equal(32)

        it "sp is register 2":
            expect(sp_register_index(Architecture.RiscV32)).to_equal(2)

        it "return register is a0 (10)":
            expect(return_register_index(Architecture.RiscV32)).to_equal(10)

        it "link register is ra (1)":
            expect(link_register_index(Architecture.RiscV32)).to_equal(1)

        it "has 8 argument registers":
            val args = arg_register_indices(Architecture.RiscV32)
            expect(args.len()).to_equal(8)

        it "max args is 8":
            expect(max_args(Architecture.RiscV32)).to_equal(8)

    context "Arm32":
        it "pc is register 15":
            expect(pc_register_index(Architecture.Arm32)).to_equal(15)

        it "sp is register 13":
            expect(sp_register_index(Architecture.Arm32)).to_equal(13)

        it "return register is r0 (0)":
            expect(return_register_index(Architecture.Arm32)).to_equal(0)

        it "link register is lr (14)":
            expect(link_register_index(Architecture.Arm32)).to_equal(14)

        it "has 4 argument registers":
            val args = arg_register_indices(Architecture.Arm32)
            expect(args.len()).to_equal(4)

        it "max args is 4":
            expect(max_args(Architecture.Arm32)).to_equal(4)


# ============================================================================
# Test Group 6: CompilerBridge
# ============================================================================

describe "CompilerBridge":
    """
    ## Compiler Bridge

    Tests that the compiler bridge produces bytes for supported
    architectures and errors for unsupported ones.
    """

    context "Arm32":
        it "returns Ok with bytes":
            val result = CompilerBridge.compile("val x = 0", Architecture.Arm32, 0x40010000)
            expect(result.is_ok()).to_equal(true)

        it "produces non-empty byte array":
            val result = CompilerBridge.compile("val x = 0", Architecture.Arm32, 0x40010000)
            val bytes = result.ok.unwrap()
            expect(bytes.len()).to_be_greater_than(0)

    context "RiscV32":
        it "returns Ok with bytes":
            val result = CompilerBridge.compile("val x = 0", Architecture.RiscV32, 0x80010000)
            expect(result.is_ok()).to_equal(true)

        it "produces non-empty byte array":
            val result = CompilerBridge.compile("val x = 0", Architecture.RiscV32, 0x80010000)
            val bytes = result.ok.unwrap()
            expect(bytes.len()).to_be_greater_than(0)

    context "unsupported architecture":
        it "returns Err for X86_64":
            val result = CompilerBridge.compile("val x = 0", Architecture.X86_64, 0x1000)
            expect(result.is_err()).to_equal(true)

    context "compile_remote_binary function":
        it "Arm32 returns Ok":
            val result = compile_remote_binary("val x = 0", Architecture.Arm32, 0x40010000)
            expect(result.is_ok()).to_equal(true)

        it "RiscV32 returns Ok":
            val result = compile_remote_binary("val x = 0", Architecture.RiscV32, 0x80010000)
            expect(result.is_ok()).to_equal(true)


# ============================================================================
# Test Group 7: CodeUploader with Mock Functions
# ============================================================================

describe "CodeUploader":
    """
    ## Code Uploader

    Tests the upload and verify paths using mock write/read functions
    to avoid any hardware dependency.
    """

    context "upload":
        it "rejects empty buffer":
            val empty_bytes: [i32] = []
            val result = CodeUploader.upload(
                "test",
                empty_bytes,
                0x80010000,
                mock_write_ok,
                mock_read_ok_factory([])
            )
            expect(result.is_err()).to_equal(true)

        it "succeeds with mock write and read":
            val bytes: [i32] = [0x13, 0x05, 0x00, 0x00]
            val result = CodeUploader.upload(
                "test_code",
                bytes,
                0x80010000,
                mock_write_ok,
                mock_read_ok_factory(bytes)
            )
            expect(result.is_ok()).to_equal(true)

        it "returns CodeInfo with correct name":
            val bytes: [i32] = [0x13, 0x05, 0x00, 0x00]
            val result = CodeUploader.upload(
                "my_func",
                bytes,
                0x80010000,
                mock_write_ok,
                mock_read_ok_factory(bytes)
            )
            val info = result.ok.unwrap()
            expect(info.name).to_equal("my_func")

        it "returns CodeInfo with correct address":
            val bytes: [i32] = [0x13, 0x05, 0x00, 0x00]
            val result = CodeUploader.upload(
                "my_func",
                bytes,
                0x80010000,
                mock_write_ok,
                mock_read_ok_factory(bytes)
            )
            val info = result.ok.unwrap()
            expect(info.addr).to_equal(0x80010000)

        it "returns CodeInfo with correct size":
            val bytes: [i32] = [0x13, 0x05, 0x00, 0x00]
            val result = CodeUploader.upload(
                "my_func",
                bytes,
                0x80010000,
                mock_write_ok,
                mock_read_ok_factory(bytes)
            )
            val info = result.ok.unwrap()
            expect(info.size).to_equal(4)

    context "verify":
        it "detects byte mismatch":
            val expected: [i32] = [0x13, 0x05, 0x00, 0x00]
            val corrupted: [i32] = [0x13, 0xFF, 0x00, 0x00]
            val result = CodeUploader.verify(
                0x80010000,
                expected,
                mock_read_ok_factory(corrupted)
            )
            expect(result.is_err()).to_equal(true)

        it "succeeds when bytes match":
            val bytes: [i32] = [0xAA, 0xBB, 0xCC, 0xDD]
            val result = CodeUploader.verify(
                0x80010000,
                bytes,
                mock_read_ok_factory(bytes)
            )
            expect(result.is_ok()).to_equal(true)

        it "fails when read returns error":
            val bytes: [i32] = [0x13, 0x05]
            val result = CodeUploader.verify(
                0x80010000,
                bytes,
                mock_read_err
            )
            expect(result.is_err()).to_equal(true)


# ============================================================================
# Test Group 8: ExecResult
# ============================================================================

describe "ExecResult":
    """
    ## Execution Result

    Validates the success/failure factory methods and is_ok() predicate.
    """

    context "success":
        it "is_ok returns true":
            val r = ExecResult.success(42, 100, "breakpoint")
            expect(r.is_ok()).to_equal(true)

        it "stores return value":
            val r = ExecResult.success(42, 100, "breakpoint")
            expect(r.return_value).to_equal(42)

        it "stores duration":
            val r = ExecResult.success(0, 250, "halt")
            expect(r.duration_ms).to_equal(250)

        it "stores halt reason":
            val r = ExecResult.success(0, 0, "breakpoint")
            expect(r.halt_reason).to_equal("breakpoint")

        it "has empty error":
            val r = ExecResult.success(0, 0, "halt")
            expect(r.error).to_equal("")

    context "failure":
        it "is_ok returns false":
            val r = ExecResult.failure("timeout")
            expect(r.is_ok()).to_equal(false)

        it "stores error message":
            val r = ExecResult.failure("connection lost")
            expect(r.error).to_equal("connection lost")

        it "has zero return value":
            val r = ExecResult.failure("error")
            expect(r.return_value).to_equal(0)


# ============================================================================
# Test Group 9: ResultCollector
# ============================================================================

describe "ResultCollector":
    """
    ## Result Collector

    Tests that ResultCollector correctly reads the return register
    value and builds ExecResult using mock register read functions.
    """

    context "collect with mock":
        it "reads return register and builds success":
            val collector = ResultCollector.new(
                Architecture.RiscV32,
                mock_read_register_42
            )
            val result = collector.collect("breakpoint", 50)
            expect(result.is_ok()).to_equal(true)
            val exec = result.ok.unwrap()
            expect(exec.return_value).to_equal(42)
            expect(exec.duration_ms).to_equal(50)

        it "propagates read error":
            val collector = ResultCollector.new(
                Architecture.Arm32,
                mock_read_register_err
            )
            val result = collector.collect("halt", 0)
            expect(result.is_err()).to_equal(true)


# ============================================================================
# Test Group 10: Baremetal Library Workload
# ============================================================================

describe "Baremetal Library Workload":
    """
    ## Host-Side Workload Execution

    Imports and runs the baremetal library workload on the host to
    verify it returns 0 (all checks pass) without any hardware.
    """

    context "host execution":
        it "returns 0 indicating all checks pass":
            val result = run_baremetal_library_workload()
            expect(result).to_equal(0)


# ============================================================================
# Helper Code: Mock Functions
# ============================================================================

fn mock_write_ok(addr: i64, data: [i32]) -> Result<text, text>:
    Ok("ok")

fn mock_read_ok_factory(expected: [i32]) -> fn(i64, i64) -> Result<[i32], text>:
    \addr, size: Ok(expected)

fn mock_read_err(addr: i64, size: i64) -> Result<[i32], text>:
    Err("mock read error")

fn mock_read_register_42(reg: i64) -> Result<i64, text>:
    Ok(42)

fn mock_read_register_err(reg: i64) -> Result<i64, text>:
    Err("mock register read error")
