# Integration test for the driver registry's tolerant init_all policy
# (FR-DRIVER-0006).
#
# Asserts:
#   1. Registering the GPU driver returns a non-negative index.
#   2. init_all on the shared static registry returns Ok(n) with n >= 1
#      even when the GPU adapter soft-fails on a CUDA-less host (the
#      null_block driver, registered alongside, still succeeds).
#   3. If CUDA is available, the GPU entry reports loaded=true via the
#      test-only `gpu_driver_is_cuda_available` helper; otherwise it
#      reports false. Either state is a valid PASS — the point is the
#      registry itself doesn't error the whole init path.
#
# The test intentionally does NOT assert `Ok(exact_count)` so it holds
# on both CUDA-present and CUDA-less hosts.

use std.driver.error.{DriverError}
use std.driver.static_table.{static_registry, register_static_driver}
use std.driver.types.{DriverContext}
use std.nogc_sync_mut.gpu_driver.driver_adapter.{register_gpu_driver,
                                                  gpu_driver_is_cuda_available}
use examples.simple_os.src.drivers.null_block.{register_null_block_driver}

fn test():
    describe "driver_registry_integration":

        it "register_gpu_driver returns a non-negative index":
            var idx: i32 = -1
            match register_gpu_driver():
                Result.Ok(i)  -> idx = i
                Result.Err(_) -> idx = -2
            var ok: i32 = 0
            if idx >= 0:
                ok = 1
            expect(ok).to_equal(1)

        it "null_block + gpu both register; init_all tolerates soft-failures":
            # Register null_block to guarantee at least one entry can come
            # up even if the GPU adapter soft-fails.
            var nb_idx: i32 = -1
            match register_null_block_driver():
                Result.Ok(i)  -> nb_idx = i
                Result.Err(_) -> nb_idx = -2
            var nb_ok: i32 = 0
            if nb_idx >= 0:
                nb_ok = 1
            expect(nb_ok).to_equal(1)

            # init_all must NOT return Err when at least one driver inits
            # successfully. The exact count is host-dependent (CUDA-less
            # hosts see GPU adapter mark itself loaded=false), so assert
            # initialized_count >= 1 rather than Ok(exact_count).
            var initialized: i32 = -1
            var reg = static_registry()
            match reg.init_all(DriverContext(opaque: 0)):
                Result.Ok(n)  -> initialized = n
                Result.Err(_) -> initialized = -1
            var at_least_one: i32 = 0
            if initialized >= 1:
                at_least_one = 1
            expect(at_least_one).to_equal(1)

        it "gpu adapter state matches host CUDA availability":
            # This is a soft assertion: the helper returns true iff the
            # most recent gpu_drv_init succeeded. Both branches are valid;
            # we only assert the helper is callable and returns a bool.
            var available: bool = gpu_driver_is_cuda_available()
            var seen: i32 = 0
            if available:
                seen = 1
            else:
                seen = 0
            # Either 0 or 1 is acceptable — just check it's one of them.
            var in_range: i32 = 0
            if seen == 0 or seen == 1:
                in_range = 1
            expect(in_range).to_equal(1)
