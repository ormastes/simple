# FR-DRIVER-0007: Fat32Core file I/O surface tests.
#
# Tests open, read, write, readdir, truncate on Fat32Core via the
# test-device registration helpers (same pattern as fat32_driver_adapter_test).

use std.spipe.*
use std.fs_driver.block_device.{BlockDevice}
use std.fs_driver.fat32_core.{fat32_register_test_device,
                              fat32_test_device_mount,
                              fat32_test_device_open,
                              fat32_test_device_close,
                              fat32_test_device_read,
                              fat32_test_device_write,
                              fat32_test_device_readdir,
                              fat32_test_device_truncate,
                              fat32_test_device_is_mounted}
use std.fs_driver.types.{FileHandle}

# --- Mock block device with a minimal FAT32 image ---
#
# Layout (512 bytes/sector, 1 sector/cluster):
#   sector 0:  BPB/boot sector
#   sector 32: FAT sector 0 (reserved_sectors = 32)
#   sector 33: FAT sector 1 (second FAT copy, num_fats = 2)
#   sector 34: data cluster 2 (root directory)
#   sector 35: data cluster 3 (file "hello.txt" data)
#
# data_start_sector = reserved_sectors + num_fats * fat_size = 32 + 2*1 = 34
# total_sectors = 4096
# total_clusters = (4096 - 34) / 1 = 4062

# Module-level storage for mock block device sectors.
# This works around interpreter limitation where trait fn (non-me) methods
# cannot mutate self fields.
var __mock_disk_banks: [[[u8]]] = []

fn _alloc_disk_bank() -> i32:
    var sectors: [[u8]] = []
    var s = 0
    while s < 40:
        var sector: [u8] = []
        var i = 0
        while i < 512:
            sector.push(0)
            i = i + 1
        sectors.push(sector)
        s = s + 1
    __mock_disk_banks.push(sectors)
    __mock_disk_banks.len() - 1

fn _mock_set_sector(bid: i32, sec: i32, data: [u8]):
    var bk = __mock_disk_banks[bid]
    bk[sec] = data
    __mock_disk_banks[bid] = bk

fn _mock_get_sector(bid: i32, sec: i32) -> [u8]:
    var bk = __mock_disk_banks[bid]
    bk[sec]

fn _init_fat32_image(bid: i32):
    var bpb = _mock_get_sector(bid, 0)
    bpb[11] = 0x00
    bpb[12] = 0x02
    bpb[13] = 0x01
    bpb[14] = 0x20
    bpb[15] = 0x00
    bpb[16] = 0x02
    bpb[32] = 0x00
    bpb[33] = 0x10
    bpb[34] = 0x00
    bpb[35] = 0x00
    bpb[36] = 0x01
    bpb[37] = 0x00
    bpb[38] = 0x00
    bpb[39] = 0x00
    bpb[44] = 0x02
    bpb[45] = 0x00
    bpb[46] = 0x00
    bpb[47] = 0x00
    bpb[510] = 0x55
    bpb[511] = 0xAA
    _mock_set_sector(bid, 0, bpb)

    var fat = _mock_get_sector(bid, 32)
    fat[0] = 0xF8
    fat[1] = 0xFF
    fat[2] = 0xFF
    fat[3] = 0x0F
    fat[4] = 0xFF
    fat[5] = 0xFF
    fat[6] = 0xFF
    fat[7] = 0x0F
    fat[8] = 0xF8
    fat[9] = 0xFF
    fat[10] = 0xFF
    fat[11] = 0x0F
    fat[12] = 0xF8
    fat[13] = 0xFF
    fat[14] = 0xFF
    fat[15] = 0x0F
    _mock_set_sector(bid, 32, fat)

    var root = _mock_get_sector(bid, 34)
    root[0] = 0x48
    root[1] = 0x45
    root[2] = 0x4C
    root[3] = 0x4C
    root[4] = 0x4F
    root[5] = 0x20
    root[6] = 0x20
    root[7] = 0x20
    root[8] = 0x54
    root[9] = 0x58
    root[10] = 0x54
    root[11] = 0x20
    root[20] = 0x00
    root[21] = 0x00
    root[26] = 0x03
    root[27] = 0x00
    root[28] = 0x05
    root[29] = 0x00
    root[30] = 0x00
    root[31] = 0x00
    root[32] = 0x53
    root[33] = 0x55
    root[34] = 0x42
    root[35] = 0x44
    root[36] = 0x49
    root[37] = 0x52
    root[38] = 0x20
    root[39] = 0x20
    root[40] = 0x20
    root[41] = 0x20
    root[42] = 0x20
    root[43] = 0x10
    root[52] = 0x00
    root[53] = 0x00
    root[58] = 0x04
    root[59] = 0x00
    root[60] = 0x00
    root[61] = 0x00
    root[62] = 0x00
    root[63] = 0x00
    _mock_set_sector(bid, 34, root)

    var fdata = _mock_get_sector(bid, 35)
    fdata[0] = 0x48
    fdata[1] = 0x65
    fdata[2] = 0x6C
    fdata[3] = 0x6C
    fdata[4] = 0x6F
    _mock_set_sector(bid, 35, fdata)

class FileMockBlockDevice:
    bank_id: i32

impl FileMockBlockDevice:
    static fn new() -> FileMockBlockDevice:
        val bid = _alloc_disk_bank()
        _init_fat32_image(bid)
        FileMockBlockDevice(bank_id: bid)

fn _mock_bank_sector_count(bid: i32) -> i32:
    var bk = __mock_disk_banks[bid]
    bk.len()

fn _mock_extend_bank(bid: i32, target: i32):
    var bk = __mock_disk_banks[bid]
    while bk.len() <= target:
        var empty: [u8] = []
        var i = 0
        while i < 512:
            empty.push(0)
            i = i + 1
        bk.push(empty)
    __mock_disk_banks[bid] = bk

impl BlockDevice for FileMockBlockDevice:
    fn read_sector(lba: u64, buffer: [u8]) -> Result<bool, text>:
        val bid = self.bank_id
        val idx = lba.to_i32()
        if idx < 0 or idx >= _mock_bank_sector_count(bid):
            var i = 0
            while i < buffer.len():
                buffer[i] = 0
                i = i + 1
            return Result.Ok(true)
        val src = _mock_get_sector(bid, idx)
        var i = 0
        while i < buffer.len() and i < src.len():
            buffer[i] = src[i]
            i = i + 1
        Result.Ok(true)

    fn write_sector(lba: u64, data: [u8]) -> Result<bool, text>:
        val bid = self.bank_id
        val idx = lba.to_i32()
        if idx < 0:
            return Result.Err("invalid sector")
        if idx >= _mock_bank_sector_count(bid):
            _mock_extend_bank(bid, idx)
        var dest = _mock_get_sector(bid, idx)
        var i = 0
        while i < data.len() and i < dest.len():
            dest[i] = data[i]
            i = i + 1
        _mock_set_sector(bid, idx, dest)
        Result.Ok(true)

    fn sector_size() -> u32:
        512


describe "fat32 file I/O (FR-DRIVER-0007)":
    it "open returns a valid handle for an existing file":
        val dev = fat32_register_test_device(FileMockBlockDevice.new())
        val mount_rc = fat32_test_device_mount(dev)
        expect(mount_rc.is_ok()).to_equal(true)
        expect(fat32_test_device_is_mounted(dev).unwrap()).to_equal(true)

        val open_rc = fat32_test_device_open(dev, "/hello.txt")
        expect(open_rc.is_ok()).to_equal(true)
        val handle = open_rc.unwrap()
        expect(handle.id).to_be_greater_than(0)

        val close_rc = fat32_test_device_close(dev, handle)
        expect(close_rc.is_ok()).to_equal(true)

    it "open returns error for non-existent file":
        val dev = fat32_register_test_device(FileMockBlockDevice.new())
        val mount_rc = fat32_test_device_mount(dev)
        expect(mount_rc.is_ok()).to_equal(true)

        val open_rc = fat32_test_device_open(dev, "/missing.txt")
        expect(open_rc.is_err()).to_equal(true)

    it "read returns file contents":
        val dev = fat32_register_test_device(FileMockBlockDevice.new())
        val mount_rc = fat32_test_device_mount(dev)
        expect(mount_rc.is_ok()).to_equal(true)

        val open_rc = fat32_test_device_open(dev, "/hello.txt")
        expect(open_rc.is_ok()).to_equal(true)
        val handle = open_rc.unwrap()

        var buf: [u8] = [0, 0, 0, 0, 0, 0, 0, 0]
        val read_rc = fat32_test_device_read(dev, handle, buf, 5)
        expect(read_rc.is_ok()).to_equal(true)
        expect(read_rc.unwrap()).to_equal(5)
        # "Hello" = H(0x48) e(0x65) l(0x6C) l(0x6C) o(0x6F)
        expect(buf[0]).to_equal(0x48)
        expect(buf[1]).to_equal(0x65)
        expect(buf[2]).to_equal(0x6C)
        expect(buf[3]).to_equal(0x6C)
        expect(buf[4]).to_equal(0x6F)

        val close_rc = fat32_test_device_close(dev, handle)
        expect(close_rc.is_ok()).to_equal(true)

    it "read past EOF returns 0 bytes":
        val dev = fat32_register_test_device(FileMockBlockDevice.new())
        val mount_rc = fat32_test_device_mount(dev)
        expect(mount_rc.is_ok()).to_equal(true)

        val handle = fat32_test_device_open(dev, "/hello.txt").unwrap()
        # Read the full file first
        var buf1: [u8] = [0, 0, 0, 0, 0, 0, 0, 0]
        val r1 = fat32_test_device_read(dev, handle, buf1, 8)
        expect(r1.unwrap()).to_equal(5)
        # Now read again — should return 0 (at EOF)
        var buf2: [u8] = [0, 0, 0, 0]
        val r2 = fat32_test_device_read(dev, handle, buf2, 4)
        expect(r2.unwrap()).to_equal(0)

        fat32_test_device_close(dev, handle)

    it "write stores data and read retrieves it":
        val dev = fat32_register_test_device(FileMockBlockDevice.new())
        val mount_rc = fat32_test_device_mount(dev)
        expect(mount_rc.is_ok()).to_equal(true)

        val handle = fat32_test_device_open(dev, "/hello.txt").unwrap()
        # Write "AB" at position 0 (after open, position is 0)
        var wbuf: [u8] = [0x41, 0x42]
        val write_rc = fat32_test_device_write(dev, handle, wbuf, 2)
        expect(write_rc.is_ok()).to_equal(true)
        expect(write_rc.unwrap()).to_equal(2)

        fat32_test_device_close(dev, handle)

        # Re-open and read back
        val handle2 = fat32_test_device_open(dev, "/hello.txt").unwrap()
        var rbuf: [u8] = [0, 0, 0, 0, 0, 0, 0, 0]
        val read_rc = fat32_test_device_read(dev, handle2, rbuf, 5)
        expect(read_rc.is_ok()).to_equal(true)
        # First two bytes should be overwritten
        expect(rbuf[0]).to_equal(0x41)
        expect(rbuf[1]).to_equal(0x42)
        # Remaining bytes from original "llo"
        expect(rbuf[2]).to_equal(0x6C)

        fat32_test_device_close(dev, handle2)

    it "readdir lists root directory entries":
        val dev = fat32_register_test_device(FileMockBlockDevice.new())
        val mount_rc = fat32_test_device_mount(dev)
        expect(mount_rc.is_ok()).to_equal(true)

        val dir_rc = fat32_test_device_readdir(dev, "/")
        expect(dir_rc.is_ok()).to_equal(true)
        val entries = dir_rc.unwrap()
        expect(entries.len()).to_equal(2)
        expect(entries[0].name).to_equal("hello.txt")
        expect(entries[0].is_dir).to_equal(false)
        expect(entries[1].name).to_equal("subdir")
        expect(entries[1].is_dir).to_equal(true)

    it "readdir on non-directory returns error":
        val dev = fat32_register_test_device(FileMockBlockDevice.new())
        val mount_rc = fat32_test_device_mount(dev)
        expect(mount_rc.is_ok()).to_equal(true)

        val dir_rc = fat32_test_device_readdir(dev, "/hello.txt")
        expect(dir_rc.is_err()).to_equal(true)

    it "truncate to zero clears file":
        val dev = fat32_register_test_device(FileMockBlockDevice.new())
        val mount_rc = fat32_test_device_mount(dev)
        expect(mount_rc.is_ok()).to_equal(true)

        val handle = fat32_test_device_open(dev, "/hello.txt").unwrap()
        val trunc_rc = fat32_test_device_truncate(dev, handle, 0)
        expect(trunc_rc.is_ok()).to_equal(true)

        # Read should return 0 after truncation
        var buf: [u8] = [0, 0, 0, 0]
        val read_rc = fat32_test_device_read(dev, handle, buf, 4)
        expect(read_rc.is_ok()).to_equal(true)
        expect(read_rc.unwrap()).to_equal(0)

        fat32_test_device_close(dev, handle)

    it "truncate to smaller size preserves prefix":
        val dev = fat32_register_test_device(FileMockBlockDevice.new())
        val mount_rc = fat32_test_device_mount(dev)
        expect(mount_rc.is_ok()).to_equal(true)

        val handle = fat32_test_device_open(dev, "/hello.txt").unwrap()
        # Truncate 5-byte file to 3 bytes
        val trunc_rc = fat32_test_device_truncate(dev, handle, 3)
        expect(trunc_rc.is_ok()).to_equal(true)

        # Read should only return 3 bytes
        var buf: [u8] = [0, 0, 0, 0, 0, 0, 0, 0]
        val read_rc = fat32_test_device_read(dev, handle, buf, 8)
        expect(read_rc.is_ok()).to_equal(true)
        expect(read_rc.unwrap()).to_equal(3)
        expect(buf[0]).to_equal(0x48)
        expect(buf[1]).to_equal(0x65)
        expect(buf[2]).to_equal(0x6C)

        fat32_test_device_close(dev, handle)

    it "close on invalid handle returns error":
        val dev = fat32_register_test_device(FileMockBlockDevice.new())
        val mount_rc = fat32_test_device_mount(dev)
        expect(mount_rc.is_ok()).to_equal(true)

        val close_rc = fat32_test_device_close(dev, FileHandle(id: 9999))
        expect(close_rc.is_err()).to_equal(true)
