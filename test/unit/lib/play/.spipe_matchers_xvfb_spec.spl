# Play Xvfb Unit Tests
#
# **Feature IDs:** #PLAY-004
# **Category:** Stdlib | Play
# **Difficulty:** 1/5
# **Status:** Implemented
#
# ## Overview
# Validates the xvfb module's platform detection and command wrapping
# functions. These are pure functions that can run on any platform.

use std.play.xvfb.{is_linux, is_macos, is_windows, wrap_cmd, maybe_wrap_cmd}

# ============================================================================
# Platform detection
# ============================================================================

describe "Play xvfb platform detection":
    it "reports at most one platform":
        var count = 0
        if is_linux(): count = count + 1
        if is_macos(): count = count + 1
        if is_windows(): count = count + 1
        expect count < 2

    it "reports at least one platform":
        val detected = is_linux() or is_macos() or is_windows()
        expect detected == true

# ============================================================================
# wrap_cmd
# ============================================================================

describe "Play xvfb wrap_cmd":
    it "returns the same command on macOS":
        if is_macos():
            val (cmd, args) = wrap_cmd("npm", ["test"])
            expect cmd == "npm"
            expect args[0] == "test"

    it "returns the same command on Windows":
        if is_windows():
            val (cmd, args) = wrap_cmd("npm", ["test"])
            expect cmd == "npm"

describe "Play xvfb maybe_wrap_cmd":
    it "does not wrap when force is false on macOS":
        if is_macos():
            val (cmd, args) = maybe_wrap_cmd("echo", ["hi"], false)
            expect cmd == "echo"