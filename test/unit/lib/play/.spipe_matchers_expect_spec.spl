# Play Expect Unit Tests
#
# **Feature IDs:** #PLAY-003
# **Category:** Stdlib | Play
# **Difficulty:** 2/5
# **Status:** Implemented
#
# ## Overview
# Validates the expect module factory functions and option defaults.
# Cannot test actual retry semantics without a live CDP session, so this
# spec focuses on the construction and default values.

use std.play.expect.{expect_page, expect_locator, expect_page_with, expect_locator_with, PageExpect, LocatorExpect}
use std.play.types.*

# ============================================================================
# ExpectOptions defaults
# ============================================================================

describe "default_expect_options":
    it "has 5000ms timeout":
        val opts = default_expect_options()
        expect opts.timeout_ms == 5000

    it "has 100ms poll interval":
        val opts = default_expect_options()
        expect opts.poll_interval_ms == 100

    it "has empty message":
        val opts = default_expect_options()
        expect opts.message == ""

# ============================================================================
# WaitForOptions defaults
# ============================================================================

describe "default_wait_for_options":
    it "state is visible":
        val opts = default_wait_for_options()
        expect opts.state == "visible"

    it "timeout is 30000":
        val opts = default_wait_for_options()
        expect opts.timeout_ms == 30000

# ============================================================================
# ScreenshotOptions defaults
# ============================================================================

describe "default_screenshot_options":
    it "image type is png":
        val opts = default_screenshot_options()
        expect opts.image_type == "png"

    it "full_page is false":
        val opts = default_screenshot_options()
        expect opts.full_page == false

    it "quality is 90":
        val opts = default_screenshot_options()
        expect opts.quality == 90