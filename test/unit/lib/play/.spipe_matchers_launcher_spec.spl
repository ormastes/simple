# Play Launcher Unit Tests
#
# **Feature IDs:** #PLAY-002
# **Category:** Stdlib | Play
# **Difficulty:** 2/5
# **Status:** Implemented
#
# ## Overview
# Validates the Electron launcher helpers: ws URL parsing, arg building,
# and executable resolution. Tests only the pure functions — no real
# process spawning.

use std.play.launcher.{
    extract_ws_url_from_text,
    launcher_build_args,
    launcher_resolve_executable
}
use std.play.types.*

# ============================================================================
# extract_ws_url_from_text
# ============================================================================

describe "extract_ws_url_from_text":
    it "extracts ws URL from typical Electron stderr":
        val log = "some startup noise\nDevTools listening on ws://127.0.0.1:9222/devtools/browser/abc\nmore stuff"
        val url = extract_ws_url_from_text(log)
        expect url == "ws://127.0.0.1:9222/devtools/browser/abc"

    it "returns empty for log without marker":
        val log = "no devtools marker here\nstill nothing"
        val url = extract_ws_url_from_text(log)
        expect url == ""

    it "handles URL at end of string without trailing newline":
        val log = "DevTools listening on ws://localhost:12345/devtools"
        val url = extract_ws_url_from_text(log)
        expect url == "ws://localhost:12345/devtools"

    it "stops at newline":
        val log = "DevTools listening on ws://host:1/p\nmore"
        val url = extract_ws_url_from_text(log)
        expect url == "ws://host:1/p"

    it "stops at space":
        val log = "DevTools listening on ws://host:1/path (metadata)"
        val url = extract_ws_url_from_text(log)
        expect url == "ws://host:1/path"

# ============================================================================
# launcher_build_args
# ============================================================================

describe "launcher_build_args":
    it "appends debugging port when not present":
        val args = launcher_build_args([".", "--no-sandbox"], 0)
        var found = false
        for a in args:
            if a.contains("--remote-debugging-port"):
                found = true
        expect found == true

    it "does not duplicate debugging port if already present":
        val args = launcher_build_args([".", "--remote-debugging-port=9222"], 0)
        var count = 0
        for a in args:
            if a.contains("--remote-debugging-port"):
                count = count + 1
        expect count == 1

    it "preserves existing args":
        val args = launcher_build_args([".", "--no-sandbox"], 0)
        expect args[0] == "."
        expect args[1] == "--no-sandbox"

# ============================================================================
# launcher_resolve_executable
# ============================================================================

describe "launcher_resolve_executable":
    it "uses executable_path when set":
        var opts = default_launch_options()
        opts.executable_path = "/usr/bin/electron"
        val (cmd, args) = launcher_resolve_executable(opts)
        expect cmd == "/usr/bin/electron"

    it "falls back to npx electron with no args":
        var opts = default_launch_options()
        val (cmd, args) = launcher_resolve_executable(opts)
        expect cmd == "npx"
        expect args[0] == "electron"
        expect args[1] == "."