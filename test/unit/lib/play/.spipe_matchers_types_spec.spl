# Play Types Unit Tests
#
# **Feature IDs:** #PLAY-001
# **Category:** Stdlib | Play
# **Difficulty:** 1/5
# **Status:** Implemented
#
# ## Overview
# Validates foundation types, constants, and factory functions for std.play.

use std.play.types.*

# ============================================================================
# Constants
# ============================================================================

describe "Play backend constants":
    it "defines BACKEND_CDP":
        expect BACKEND_CDP == "cdp"

    it "defines BACKEND_SDL2":
        expect BACKEND_SDL2 == "sdl2"

    it "defines BACKEND_WM":
        expect BACKEND_WM == "wm"

    it "defines BACKEND_ORCHESTRATOR":
        expect BACKEND_ORCHESTRATOR == "orchestrator"

describe "Play state constants":
    it "defines STATE_READY":
        expect STATE_READY == "ready"

    it "defines STATE_CLOSED":
        expect STATE_CLOSED == "closed"

    it "defines STATE_FAILED":
        expect STATE_FAILED == "failed"

describe "Play timeout defaults":
    it "expect timeout is 5000":
        expect DEFAULT_EXPECT_TIMEOUT_MS == 5000

    it "action timeout is 30000":
        expect DEFAULT_ACTION_TIMEOUT_MS == 30000

    it "poll interval is 100":
        expect DEFAULT_POLL_INTERVAL_MS == 100

# ============================================================================
# Factory functions
# ============================================================================

describe "default_launch_options":
    it "returns empty executable_path":
        val opts = default_launch_options()
        expect opts.executable_path == ""

    it "returns empty args":
        val opts = default_launch_options()
        expect opts.args.length() == 0

    it "has xvfb enabled by default":
        val opts = default_launch_options()
        expect opts.xvfb == true

    it "has headless false by default":
        val opts = default_launch_options()
        expect opts.headless == false

    it "has 30s launch timeout":
        val opts = default_launch_options()
        expect opts.timeout_ms == 30000

describe "default_click_options":
    it "defaults to left button":
        val opts = default_click_options()
        expect opts.button == "left"

    it "defaults to 1 click":
        val opts = default_click_options()
        expect opts.click_count == 1

    it "defaults to no force":
        val opts = default_click_options()
        expect opts.force == false

describe "empty_play_session":
    it "has empty id":
        val s = empty_play_session()
        expect s.id == ""

    it "has closed state":
        val s = empty_play_session()
        expect s.state == "closed"

    it "has pid -1":
        val s = empty_play_session()
        expect s.pid == -1

    it "has no windows":
        val s = empty_play_session()
        expect s.windows.length() == 0

describe "play_error":
    it "sets code and message":
        val e = play_error("TEST_ERR", "test message")
        expect e.code == "TEST_ERR"
        expect e.message == "test message"
        expect e.detail == ""

describe "play_error_with_detail":
    it "sets code message and detail":
        val e = play_error_with_detail("CODE", "msg", "extra")
        expect e.code == "CODE"
        expect e.message == "msg"
        expect e.detail == "extra"

# ============================================================================
# Locator constructors
# ============================================================================

describe "locator_css":
    it "creates css locator":
        val loc = locator_css("#button")
        expect loc.selector == "#button"
        expect loc.strategy == "css"
        expect loc.nth == -1

describe "locator_role":
    it "creates role locator":
        val loc = locator_role("button", "Submit")
        expect loc.selector == "button"
        expect loc.strategy == "role"
        expect loc.has_text == "Submit"

describe "locator_test_id":
    it "creates test-id locator":
        val loc = locator_test_id("my-btn")
        expect loc.selector == "my-btn"
        expect loc.strategy == "test-id"

describe "locator_text":
    it "creates text locator":
        val loc = locator_text("Click me")
        expect loc.selector == "Click me"
        expect loc.strategy == "text"