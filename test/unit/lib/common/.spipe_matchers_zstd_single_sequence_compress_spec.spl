val HOST_VALID_FRESH_TABLE_FRAME_HEX = "28b52ffd2486f5010032040d13c0251d002419b714084978bafdfa6b6bd73c010c5c31c51c36f4f52fe1e8a7a5477a055861bdd5241719acfc01c81cbae8222101000318688802bb599fc9"
val HOST_REJECTED_DIRECT_WEIGHT_FRAME_HEX = "28b52ffda00400000055000042800184432010800d00"
val TMP_ROOT = "/tmp/zstd_single_sequence_compress_spec"

extern fn rt_file_read_bytes(path: text) -> [u8]

fn _repeated_tail_payload() -> [u8]:
    [
        0x61u8, 0x62u8, 0x63u8,
        0x61u8, 0x62u8, 0x63u8,
        0x61u8, 0x62u8, 0x63u8,
        0x61u8, 0x62u8, 0x63u8
    ]

fn _fresh_table_payload() -> [u8]:
    [
        0x41u8, 0x41u8, 0x41u8, 0x41u8,
