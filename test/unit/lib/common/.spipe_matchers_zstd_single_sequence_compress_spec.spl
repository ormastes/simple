fn _with_level(base: CompressionOptions, level_value: i64) -> CompressionOptions:
    CompressionOptions(
        codec: base.codec,
        level: CompressionLevel(value: level_value),
        checksum: base.checksum,
        block_mode: base.block_mode,
        dictionary_bytes: base.dictionary_bytes,
        dictionary_id: base.dictionary_id,
        content_size: base.content_size
    )

fn _with_checksum(base: CompressionOptions, checksum: bool) -> CompressionOptions:
    CompressionOptions(
        codec: base.codec,
        level: base.level,
        checksum: checksum,
        block_mode: base.block_mode,
        dictionary_bytes: base.dictionary_bytes,
        dictionary_id: base.dictionary_id,
        content_size: base.content_size
    )

fn _compressed_block(payload: [u8]) -> [u8]:
    val header = 1 | (2 << 1) | (payload.len() << 3)
    [
        (header & 0xFF).to_u8(),
        ((header >> 8) & 0xFF).to_u8(),
        ((header >> 16) & 0xFF).to_u8()
    ] + payload

fn _host_rejected_direct_weight_frame() -> [u8]:
    [
        0x28u8, 0xB5u8, 0x2Fu8, 0xFDu8,
        0xA0u8,
        0x04u8, 0x00u8, 0x00u8, 0x00u8
    ] + _compressed_block([
        0x42u8, 0x80u8, 0x01u8,
        0x84u8, 0x43u8, 0x20u8, 0x10u8,
        0x80u8, 0x0Du8,
        0x00u8
    ])

fn _ensure_tmp_root():
    val result = shell("mkdir -p '" + TMP_ROOT + "'")
    expect result.exit_code == 0

fn _write_hex_file(path: text, hex: text):
    val run = shell("printf '%s' '" + hex + "' | xxd -r -p > '" + path + "'")
    expect run.exit_code == 0

fn _read_bytes(path: text) -> [u8]:
    rt_file_read_bytes(path) ?? []

fn _expect_compression_error(err: CompressionError, kind: text, message_part: text):
    match err:
        CompressionError.InvalidHeader(message):
            expect kind == "InvalidHeader"
            expect (message).contains(message_part)
        CompressionError.UnsupportedFeature(message):
            expect kind == "UnsupportedFeature"
            expect (message).contains(message_part)
        CompressionError.TruncatedInput(message):
            expect kind == "TruncatedInput"
            expect (message).contains(message_part)
        CompressionError.ChecksumMismatch(message):
            expect kind == "ChecksumMismatch"
            expect (message).contains(message_part)
        CompressionError.CorruptStream(message):
            expect kind == "CorruptStream"
            expect (message).contains(message_part)
        CompressionError.SizeLimitExceeded(limit):
            expect kind == "SizeLimitExceeded"
            expect limit >= 0 == true

describe "zstd repeated-tail encoder fallback":
    it "keeps the host-rejected direct-weight single-stream candidate on the raw-block path":
        val payload = _fresh_table_payload()
        val encoded = zstd_compress_frame(payload, default_compression_options(CompressionCodec.zstd))
        expect (encoded[6] & 0x07u8) == 0x01u8
        expect encoded.len() == 6 + 3 + payload.len()
        expect zstd_decompress_frame(encoded).unwrap() == payload

    it "keeps level 1 on the raw-block path for the bounded fresh-table lane":
        val payload = _fresh_table_payload()
        val options = _with_level(default_compression_options(CompressionCodec.zstd), 1)
        val encoded = zstd_compress_frame(payload, options)
        expect (encoded[6] & 0x07u8) == 0x01u8
        expect zstd_decompress_frame(encoded).unwrap() == payload

    it "keeps repeated tails on the raw-block path until a host-valid sequence encoder exists":
        val payload = _repeated_tail_payload()
        val encoded = zstd_compress_frame(payload, default_compression_options(CompressionCodec.zstd))
        expect (encoded[6] & 0x07u8) == 0x01u8
        expect encoded.len() == 6 + 3 + payload.len()
        expect zstd_decompress_frame(encoded).unwrap() == payload

    it "fails closed on an exact host-zstd fresh-table single-stream frame with one predefined-table sequence":
        expect HOST_VALID_FRESH_TABLE_FRAME[9] & 0x03u8 == 0x02u8
        expect (HOST_VALID_FRESH_TABLE_FRAME[9] >> 2u8) & 0x03u8 == 0x00u8
        expect HOST_VALID_FRESH_TABLE_FRAME[64] == 0x01u8
        val decoded = zstd_decompress_frame(HOST_VALID_FRESH_TABLE_FRAME)
        expect decoded.is_err() == true
        _expect_compression_error(decoded.unwrap_err(), "UnsupportedFeature", "fresh-table compressed literals")

    it "emits the exact raw-block frame bytes for repeated tails":
        val payload = _repeated_tail_payload()
        val encoded = zstd_compress_frame(payload, default_compression_options(CompressionCodec.zstd))
        expect(encoded).to_equal([
            0x28u8, 0xB5u8, 0x2Fu8, 0xFDu8,
            0x20u8,
            0x0Cu8,
            0x61u8, 0x00u8, 0x00u8,
            0x61u8, 0x62u8, 0x63u8,
            0x61u8, 0x62u8, 0x63u8,
            0x61u8, 0x62u8, 0x63u8,
            0x61u8, 0x62u8, 0x63u8
        ])

    it "keeps level 1 on the raw-block fallback":
        val payload = _repeated_tail_payload()
        val options = _with_level(default_compression_options(CompressionCodec.zstd), 1)
        val encoded = zstd_compress_frame(payload, options)
        expect (encoded[6] & 0x07u8) == 0x01u8
        expect zstd_decompress_frame(encoded).unwrap() == payload

    it "preserves checksum on the repeated-tail raw-block fallback":
        val payload = _repeated_tail_payload()
        val options = _with_checksum(default_compression_options(CompressionCodec.zstd), true)
        val encoded = zstd_compress_frame(payload, options)
        expect (encoded[6] & 0x07u8) == 0x01u8
        expect zstd_decompress_frame(encoded).unwrap() == payload

    it "fails closed on the host-rejected direct-weight single-stream candidate":
        val frame = _host_rejected_direct_weight_frame()
        val decoded = zstd_decompress_frame(frame)
        expect decoded.is_err() == true
        _expect_compression_error(decoded.unwrap_err(), "UnsupportedFeature", "fresh-table compressed literals")

    it "host zstd rejects the direct-weight candidate bytes":
        _ensure_tmp_root()
        val compressed_path = TMP_ROOT + "/direct_weight_candidate.zst"
        _write_hex_file(compressed_path, HOST_REJECTED_DIRECT_WEIGHT_FRAME_HEX)
        val run = shell("zstd -q -d -f '" + compressed_path + "' -o '" + compressed_path + ".out'")
        expect run.exit_code != 0 == true

    it "host zstd accepts the pinned fresh-table single-stream frame":
        _ensure_tmp_root()
        val compressed_path = TMP_ROOT + "/host_valid_fresh_table_frame.zst"
        val output_path = TMP_ROOT + "/host_valid_fresh_table_frame.out"
        _write_hex_file(compressed_path, HOST_VALID_FRESH_TABLE_FRAME_HEX)
        val run = shell("zstd -q -d -f '" + compressed_path + "' -o '" + output_path + "'")
        if run.exit_code != 0:
            print(run.stdout)
            print(run.stderr)
        expect run.exit_code == 0
        expect(_read_bytes(output_path)).to_equal([
            0x54u8, 0x68u8, 0x69u8, 0x73u8, 0x20u8, 0x69u8, 0x73u8, 0x20u8,
            0x61u8, 0x20u8, 0x73u8, 0x68u8, 0x6Fu8, 0x72u8, 0x74u8, 0x20u8,
            0x65u8, 0x6Eu8, 0x67u8, 0x6Cu8, 0x69u8, 0x73u8, 0x68u8, 0x20u8,
            0x73u8, 0x65u8, 0x6Eu8, 0x74u8, 0x65u8, 0x6Eu8, 0x63u8, 0x65u8,
            0x20u8, 0x77u8, 0x69u8, 0x74u8, 0x68u8, 0x20u8, 0x72u8, 0x65u8,
            0x70u8, 0x65u8, 0x61u8, 0x74u8, 0x65u8, 0x64u8, 0x20u8, 0x6Cu8,
            0x65u8, 0x74u8, 0x74u8, 0x65u8, 0x72u8, 0x73u8, 0x20u8, 0x61u8,
            0x6Eu8, 0x64u8, 0x20u8, 0x73u8, 0x70u8, 0x61u8, 0x63u8, 0x65u8,
            0x73u8, 0x2Eu8, 0x20u8, 0x54u8, 0x68u8, 0x69u8, 0x73u8, 0x20u8,
            0x69u8, 0x73u8, 0x20u8, 0x61u8, 0x20u8, 0x73u8, 0x68u8, 0x6Fu8,
            0x72u8, 0x74u8, 0x20u8, 0x65u8, 0x6Eu8, 0x67u8, 0x6Cu8, 0x69u8,
            0x73u8, 0x68u8, 0x20u8, 0x73u8, 0x65u8, 0x6Eu8, 0x74u8, 0x65u8,
            0x6Eu8, 0x63u8, 0x65u8, 0x20u8, 0x77u8, 0x69u8, 0x74u8, 0x68u8,
            0x20u8, 0x72u8, 0x65u8, 0x70u8, 0x65u8, 0x61u8, 0x74u8, 0x65u8,
            0x64u8, 0x20u8, 0x6Cu8, 0x65u8, 0x74u8, 0x74u8, 0x65u8, 0x72u8,
            0x73u8, 0x20u8, 0x61u8, 0x6Eu8, 0x64u8, 0x20u8, 0x73u8, 0x70u8,
            0x61u8, 0x63u8, 0x65u8, 0x73u8, 0x2Eu8, 0x20u8
        ])