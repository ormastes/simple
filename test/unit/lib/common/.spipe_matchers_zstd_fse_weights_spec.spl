use std.spec.{describe, it, expect}
use std.common.compress.zstd.{zstd_parse_fse_huffman_weights}
use std.common.compress.{CompressionError}

# FSE-compressed Huffman-weight description blobs extracted verbatim from host
# `zstd -1`/`zstd -3` output, covering English-prose payloads. Each blob is
# `header_byte (= compressed_size of FSE bitstream) || normalized counts ||
# backward FSE state stream`, conforming to RFC 8478 Zstandard §4.2.1.1 +
# §4.1.1. The full source frames round-trip through `zstd -d`, so the bytes
# are format-conformant by construction.
val FX1: [u8] = [
    0x15u8, 0x80u8, 0x25u8, 0x3Bu8, 0xF0u8, 0xDBu8, 0xADu8, 0x45u8,
    0x88u8, 0x76u8, 0x98u8, 0x7Eu8, 0x22u8, 0x35u8, 0x32u8, 0x41u8,
    0x93u8, 0x10u8, 0x2Bu8, 0x07u8, 0xF3u8, 0xD2u8
]

# Fresh literal-rich English text payload, compressed with `zstd -1`. The
# inner FSE Huffman-weight description was extracted from the resulting
# Compressed_Block's literals section; bytes are byte-exact RFC 8478 output.
val FX_HOST_FRESH: [u8] = [
    0x19u8, 0x80u8, 0xA5u8, 0x6Du8, 0x31u8, 0x24u8, 0xE2u8, 0x7Fu8,
    0x5Bu8, 0x87u8, 0xEDu8, 0xFEu8, 0x86u8, 0x28u8, 0xF4u8, 0xB6u8,
    0x1Bu8, 0x7Du8, 0x06u8, 0x66u8, 0xF4u8, 0x31u8, 0x74u8, 0x30u8,
    0x2Fu8, 0x0Du8
]

# Same fixture truncated mid-FSE-bitstream -- header says compressed_size=21
# but only 5 payload bytes follow, must report TruncatedInput.
val FX_TRUNCATED: [u8] = [
    0x15u8, 0x80u8, 0x25u8, 0x3Bu8, 0xF0u8, 0xDBu8
]

# Same fixture but the FSE accuracy_log nibble (low 4 bits of byte 1) set to
# 12 -> table_log = 12 + 5 = 17, exceeding the §4.2.1.1 cap of 6.
val FX_BAD_ACC_LOG: [u8] = [
    0x15u8, 0x8Cu8, 0x25u8, 0x3Bu8, 0xF0u8, 0xDBu8, 0xADu8, 0x45u8,
    0x88u8, 0x76u8, 0x98u8, 0x7Eu8, 0x22u8, 0x35u8, 0x32u8, 0x41u8,
    0x93u8, 0x10u8, 0x2Bu8, 0x07u8, 0xF3u8, 0xD2u8
]

# header_byte = 0 -> compressed_size = 0 -> CorruptStream.
val FX_ZERO_COMP: [u8] = [
    0x00u8, 0x80u8, 0x25u8, 0x3Bu8
]

fn _expect_compression_error(err: CompressionError, kind: text, message_part: text):
    match err:
        CompressionError.InvalidHeader(message):
            expect kind == "InvalidHeader"
            expect (message).contains(message_part)
        CompressionError.UnsupportedFeature(message):
            expect kind == "UnsupportedFeature"
            expect (message).contains(message_part)
        CompressionError.TruncatedInput(message):
            expect kind == "TruncatedInput"
            expect (message).contains(message_part)
        CompressionError.ChecksumMismatch(message):
            expect kind == "ChecksumMismatch"
            expect (message).contains(message_part)
        CompressionError.CorruptStream(message):
            expect kind == "CorruptStream"
            expect (message).contains(message_part)
        CompressionError.SizeLimitExceeded(limit):
            expect kind == "SizeLimitExceeded"
            expect limit >= 0 == true

describe "zstd FSE-compressed Huffman-weight decode (RFC 8478 §4.2.1.1)":
    # FIXED 2026-05-01 -- see doc/08_tracking/bug/bug_zstd_fse_huffman_weight_kraft_2026-05-01.md
    # Root cause: `ZstdBackwardBits` reads LSB-first within each byte, but
    # RFC 8478 Annex A mandates MSB-first reading of the FSE state bitstream.
    # The Huffman literal path happened to work because `zstd_huf_reverse_bits`
    # in the table builder compensated; the FSE state machine had no such
    # compensation and produced wrong state advances. The fix introduces a
    # dedicated MSB-first backward bit reader for FSE Huffman-weight decoding
    # plus a max_bits-from-Kraft-sum derivation in `zstd_huf_weights_to_symbols`
    # (the previous max_weight-based derivation was correct only when at least
    # one symbol had the longest codeword length).
    it "decodes a real host-zstd FSE Huffman tree byte-exact":
        val res = zstd_parse_fse_huffman_weights(FX1, 0, FX1.len())
        expect res.is_err() == false
        val (weights, bytes_used) = res.unwrap()
        # FX1's compressed_size = 0x15 = 21, plus 1 header byte -> 22 consumed.
        expect bytes_used == 22
        # Partial weight stream produces 122 entries summing to 126 (= 2^7 - 2);
        # Kraft completion appends last_weight = 2 for a total of 123 entries.
        expect weights.len() == 123
        expect weights[122] == 2
        # Spot-check a few characteristic indices: ' '=32 -> weight 5 (frequent);
        # '.'=46 -> weight 1 (rare); 'a'=97 -> weight 4; 'y'=121 -> weight 3.
        expect weights[32] == 5
        expect weights[46] == 1
        expect weights[97] == 4
        expect weights[121] == 3

    it "decodes a fresh host-zstd FSE Huffman tree byte-exact":
        val res = zstd_parse_fse_huffman_weights(FX_HOST_FRESH, 0, FX_HOST_FRESH.len())
        expect res.is_err() == false
        val (weights, bytes_used) = res.unwrap()
        # FX_HOST_FRESH's compressed_size = 0x19 = 25, plus 1 header byte.
        expect bytes_used == 26
        # 122 partial weights sum to 255; last_weight = 1 -> 123 total, sum 256 = 2^8.
        expect weights.len() == 123
        expect weights[122] == 1

    it "rejects a truncated FSE Huffman-weight bitstream":
        val res = zstd_parse_fse_huffman_weights(FX_TRUNCATED, 0, FX_TRUNCATED.len())
        expect res.is_err() == true
        _expect_compression_error(res.unwrap_err(), "TruncatedInput", "compressed Huffman weights")

    it "rejects an out-of-range accuracy_log":
        val res = zstd_parse_fse_huffman_weights(FX_BAD_ACC_LOG, 0, FX_BAD_ACC_LOG.len())
        expect res.is_err() == true
        # Either CorruptStream (table_log exceeded max) or other typed error.
        match res.unwrap_err():
            CompressionError.CorruptStream(_): expect(true).to_equal(true)
            CompressionError.UnsupportedFeature(_): expect(true).to_equal(true)
            CompressionError.InvalidHeader(_): expect(true).to_equal(true)
            CompressionError.TruncatedInput(_): expect(true).to_equal(true)
            CompressionError.ChecksumMismatch(_): expect(false).to_equal(true)
            CompressionError.SizeLimitExceeded(_): expect(false).to_equal(true)

    it "rejects a zero compressed-size header":
        val res = zstd_parse_fse_huffman_weights(FX_ZERO_COMP, 0, FX_ZERO_COMP.len())
        expect res.is_err() == true
        _expect_compression_error(res.unwrap_err(), "CorruptStream", "compressed Huffman weights size")

    it "rejects empty input at the Huffman tree header":
        val empty: [u8] = []
        val res = zstd_parse_fse_huffman_weights(empty, 0, 0)
        expect res.is_err() == true
        _expect_compression_error(res.unwrap_err(), "TruncatedInput", "huffman tree header")