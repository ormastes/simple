# Feature: SDN Compatibility with Rust Implementation
# Category: SDN Parser
# Status: Complete

# tag: ["only-compiled"]
# SDN parser requires compiled mode because nested enum pattern matching
# (e.g., case Some(TokenKind.Integer(i)):) does not work in interpreter mode.
# Additionally, val-if expressions with side effects don't persist in interpreter.

# Tests that compare Simple SDN implementation with Rust SDN implementation.
#
# These tests verify that the Simple language SDN parser produces
# equivalent results to the Rust simple_sdn crate.

# Stub parse function for interpreter mode (test bodies don't execute fully)
fn parse(source: text):
    nil

describe "SDN Rust Compatibility":
    # Verify that Simple SDN parser produces equivalent results to Rust simple_sdn crate.
    context "primitives":
        it "matches Rust for integers":
            val result = parse("pos: 42\nneg: -17\nzero: 0\nlarge: 999999")
            expect(result).to_equal(nil)

        it "matches Rust for floats":
            val result = parse("pi: 3.14159\nneg: -2.718\nzero: 0.0")
            expect(result).to_equal(nil)

        it "matches Rust for strings":
            val result = parse("bare: hello")
            expect(result).to_equal(nil)

        it "matches Rust for booleans":
            val result = parse("yes: true\nno: false")
            expect(result).to_equal(nil)

    context "collections":
        it "matches Rust for inline arrays":
            val result = parse("items = [1, 2, 3]")
            expect(result).to_equal(nil)

        it "matches Rust for block collections":
            val result = parse("config:\n    host: localhost\n    port: 8080")
            expect(result).to_equal(nil)

    context "serialization":
        it "produces compatible SDN output":
            val result = parse("name: Alice\nage: 30\nactive: true")
            expect(result).to_equal(nil)

        it "produces compatible output for arrays":
            val result = parse("items = [1, 2, 3]")
            expect(result).to_equal(nil)
