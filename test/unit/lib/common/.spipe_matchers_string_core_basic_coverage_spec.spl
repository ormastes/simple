# @covers src/lib/common/string_core.spl 80%
"""
# String Core Coverage Specification

**Feature IDs:** #LIB-STRING-CORE
**Category:** Stdlib
**Difficulty:** 3/5
**Status:** Implemented
**Requirements:** N/A
**Plan:** N/A
**Design:** N/A
**Research:** N/A

## Overview

Comprehensive branch-coverage tests for `src/lib/common/string_core.spl`.
Exercises every exported function with inputs that trigger BOTH sides of
every if/elif/else guard, targeting 90%+ branch coverage.

## Key Concepts

| Concept | Description |
|---------|-------------|
| Branch coverage | Every conditional evaluates to both true and false |
| Edge cases | Empty strings, single chars, boundary indices |
| ASCII helpers | char_code_inline / char_from_code_inline lookup tables |

## Behavior

- All functions are pure (no side-effects)
- Bounds-checking functions clamp or return empty on invalid input
- ASCII helpers return 0 / "" for unknown input
"""

use common.string_core.{str_len, str_concat, str_eq}
use common.string_core.{str_slice, str_char_at, str_safe_slice}
use common.string_core.{str_contains, str_starts_with, str_ends_with}
use common.string_core.{str_index_of, str_last_index_of}
use common.string_core.{is_whitespace_char, str_trim, str_trim_left, str_trim_right}
use common.string_core.{trim_whitespace, trim_left, trim_right, trim_field}
use common.string_core.{str_replace, str_replace_all}
use common.string_core.{str_split, str_join}
use common.string_core.{char_code_inline, char_from_code_inline}
use common.string_core.{is_alpha_char, is_digit_char, is_alnum_char}
use common.string_core.{str_to_lower, str_to_upper, str_capitalize}
use common.string_core.{str_reverse, str_repeat, str_truncate}
use common.string_core.{str_pad_left, str_pad_right, str_center}
use common.string_core.{char_code, char_from_code}


# ============================================================================
# Test Group 1: Basic String Operations
# ============================================================================

describe "string_core - Basic Operations":
    """
    ## Basic Operations

    Tests for str_len, str_concat, str_eq which delegate to built-ins.
    """

    context "str_len":
        it "returns length of normal string":
            expect str_len("hello") == 5

        it "returns 0 for empty string":
            expect str_len("") == 0

        it "returns 1 for single character":
            expect str_len("x") == 1

        it "counts spaces":
            expect str_len("a b") == 3

    context "str_concat":
        it "joins two non-empty strings":
            expect str_concat("hello", " world") == "hello world"

        it "joins empty with non-empty":
            expect str_concat("", "test") == "test"

        it "joins non-empty with empty":
            expect str_concat("test", "") == "test"

        it "joins two empty strings":
            expect str_concat("", "") == ""

    context "str_eq":
        it "returns true for equal strings":
            expect str_eq("hello", "hello") == true

        it "returns false for different strings":
            expect str_eq("hello", "world") == false

        it "returns true for two empty strings":
            expect str_eq("", "") == true

        it "returns false for empty vs non-empty":
            expect str_eq("", "a") == false

        it "is case-sensitive":
            expect str_eq("Hello", "hello") == false


# ============================================================================
# Test Group 2: Slicing and Character Access
# ============================================================================


describe "string_core - Slicing and Access":
    """
    ## Slicing and Character Access

    Tests for str_slice, str_char_at, str_safe_slice.
    Covers both valid ranges and out-of-bounds edge cases.
    """

    context "str_slice":
        it "extracts full string":
            expect str_slice("hello", 0, 5) == "hello"

        it "extracts middle portion":
            expect str_slice("hello", 1, 4) == "ell"

        it "extracts single character":
            expect str_slice("hello", 0, 1) == "h"

        it "extracts last character":
            expect str_slice("hello", 4, 5) == "o"

        it "returns empty for equal indices":
            expect str_slice("hello", 2, 2) == ""

    context "str_char_at":
        """
        ### Branch coverage for str_char_at

        - idx < 0 -> returns ""
        - idx >= s.len() -> returns ""
        - valid index -> returns character
        """

        it "returns character at valid index":
            expect str_char_at("hello", 0) == "h"

        it "returns last character":
            expect str_char_at("hello", 4) == "o"

        it "returns middle character":
            expect str_char_at("abcde", 2) == "c"

        it "returns empty for negative index":
            expect str_char_at("hello", -1) == ""

        it "returns empty for large negative index":
            expect str_char_at("hello", -100) == ""

        it "returns empty for index equal to length":
            expect str_char_at("hello", 5) == ""

        it "returns empty for index beyond length":
            expect str_char_at("hello", 10) == ""

        it "returns empty for empty string at index 0":
            expect str_char_at("", 0) == ""

        it "handles single-char string at index 0":
            expect str_char_at("x", 0) == "x"

        it "handles single-char string at index 1":
            expect str_char_at("x", 1) == ""

    context "str_safe_slice":
        """
        ### Branch coverage for str_safe_slice

        - s_val < 0 -> clamped to 0
        - e_val > s.len() -> clamped to s.len()
        - s_val >= e_val -> returns ""
        - normal case -> returns substring
        """

        it "returns full string for valid range":
            expect str_safe_slice("hello", 0, 5) == "hello"

        it "clamps negative start to 0":
            expect str_safe_slice("hello", -5, 3) == "hel"

        it "clamps end beyond length":
            expect str_safe_slice("hello", 0, 100) == "hello"

        it "clamps both start and end":
            expect str_safe_slice("hello", -10, 100) == "hello"

        it "returns empty when start equals end":
            expect str_safe_slice("hello", 3, 3) == ""

        it "returns empty when start exceeds end":
            expect str_safe_slice("hello", 4, 2) == ""

        it "extracts middle portion":
            expect str_safe_slice("hello", 1, 4) == "ell"

        it "handles empty string":
            expect str_safe_slice("", 0, 0) == ""

        it "handles empty string with out-of-bounds":
            expect str_safe_slice("", -1, 5) == ""

        it "handles start at 0 with end clamped":
            expect str_safe_slice("ab", 0, 10) == "ab"

        it "handles start negative with end at length":
            expect str_safe_slice("abc", -3, 3) == "abc"


# ============================================================================
# Test Group 3: Search Operations
# ============================================================================


describe "string_core - Search Operations":
    """
    ## Search Operations

    Tests for str_contains, str_starts_with, str_ends_with,
    str_index_of, str_last_index_of.
    """

    context "str_contains":
        it "finds substring present":
            expect str_contains("hello world", "world") == true

        it "returns false for missing substring":
            expect str_contains("hello world", "xyz") == false

        it "finds empty needle in any string":
            expect str_contains("hello", "") == true

        it "finds string in itself":
            expect str_contains("abc", "abc") == true

        it "handles empty haystack":
            expect str_contains("", "a") == false

    context "str_starts_with":
        it "returns true for matching prefix":
            expect str_starts_with("hello", "hel") == true

        it "returns false for non-matching prefix":
            expect str_starts_with("hello", "llo") == false

        it "returns true for empty prefix":
            expect str_starts_with("hello", "") == true

        it "returns true for exact match":
            expect str_starts_with("hello", "hello") == true

        it "returns false when prefix longer than string":
            expect str_starts_with("hi", "hello") == false

    context "str_ends_with":
        it "returns true for matching suffix":
            expect str_ends_with("hello", "llo") == true

        it "returns false for non-matching suffix":
            expect str_ends_with("hello", "hel") == false

        it "returns true for empty suffix":
            expect str_ends_with("hello", "") == true

        it "returns true for exact match":
            expect str_ends_with("hello", "hello") == true

    context "str_index_of":
        """
        ### Branch coverage for str_index_of

        - result == nil -> returns -1
        - result != nil -> returns index
        """

        it "finds first occurrence":
            expect str_index_of("hello", "l") == 2

        it "finds substring at start":
            expect str_index_of("hello", "hel") == 0

        it "finds substring at end":
            expect str_index_of("hello", "lo") == 3

        it "returns -1 for missing substring":
            expect str_index_of("hello", "xyz") == -1

        it "returns -1 for needle longer than haystack":
            expect str_index_of("hi", "hello") == -1

        it "finds empty needle at 0":
            expect str_index_of("hello", "") == 0

        it "returns -1 for empty haystack with non-empty needle":
            expect str_index_of("", "a") == -1

    context "str_last_index_of":
        """
        ### Branch coverage for str_last_index_of

        - while loop: search_start < s.len() (true and false)
        - pos == -1 -> break (needle not found in remaining)
        - pos != -1 -> update last_pos
        - returns last_pos (-1 if never found, else last position)
        """

        it "finds last occurrence with duplicates":
            expect str_last_index_of("hello", "l") == 3

        it "finds last occurrence at end":
            expect str_last_index_of("abcabc", "c") == 5

        it "finds last occurrence at start":
            expect str_last_index_of("aaa", "a") == 2

        it "returns -1 for missing substring":
            expect str_last_index_of("hello", "xyz") == -1

        it "finds single occurrence":
            expect str_last_index_of("hello", "o") == 4

        it "handles empty string":
            expect str_last_index_of("", "a") == -1

        it "finds multi-char pattern":
            expect str_last_index_of("abab", "ab") == 2

        it "finds pattern at very end":
            expect str_last_index_of("xyzabc", "abc") == 3


# ============================================================================
# Test Group 4: Whitespace Trimming
# ============================================================================


describe "string_core - Whitespace Trimming":
    """
    ## Whitespace Trimming

    Tests for is_whitespace_char, str_trim, str_trim_left, str_trim_right,
    trim_whitespace, trim_left, trim_right, trim_field.
    """

    context "is_whitespace_char":
        """
        ### Branch coverage for is_whitespace_char

        - c == " " -> true
        - c == "\t" -> true
        - c == "\n" -> true
        - c == "\r" -> true
        - any other char -> false
        """

        it "identifies space":
            expect is_whitespace_char(" ") == true

        it "identifies tab":
            expect is_whitespace_char("\t") == true

        it "identifies newline":
            expect is_whitespace_char("\n") == true

        it "identifies carriage return":
            expect is_whitespace_char("\r") == true

        it "rejects letter":
            expect is_whitespace_char("a") == false

        it "rejects digit":
            expect is_whitespace_char("0") == false

        it "rejects punctuation":
            expect is_whitespace_char(".") == false

    context "str_trim":
        it "removes both sides":
            expect str_trim("  hello  ") == "hello"

        it "removes tabs and newlines":
            expect str_trim("\thello\n") == "hello"

        it "returns same when no whitespace":
            expect str_trim("hello") == "hello"

        it "returns empty for whitespace-only":
            expect str_trim("   ") == ""

        it "returns empty for empty input":
            expect str_trim("") == ""

    context "str_trim_left":
        """
        ### Branch coverage for str_trim_left

        - while result.len() > 0 (true: has chars, false: empty result)
        - is_whitespace_char(result[0:1]) (true: leading ws, false: non-ws)
        """

        it "removes leading spaces":
            expect str_trim_left("  hello") == "hello"

        it "removes leading tab":
            expect str_trim_left("\thello") == "hello"

        it "removes mixed leading whitespace":
            expect str_trim_left(" \t\nhello") == "hello"

        it "preserves trailing whitespace":
            expect str_trim_left("hello  ") == "hello  "

        it "returns empty for whitespace-only":
            expect str_trim_left("   ") == ""

        it "returns empty for empty input":
            expect str_trim_left("") == ""

        it "returns same when no leading whitespace":
            expect str_trim_left("hello") == "hello"

        it "handles single whitespace char":
            expect str_trim_left(" ") == ""

        it "handles single non-whitespace char":
            expect str_trim_left("a") == "a"

    context "str_trim_right":
        """
        ### Branch coverage for str_trim_right

        - while result.len() > 0 (true/false)
        - ch != " " and ch != "\t" and ch != "\n" and ch != "\r" -> break
        - each whitespace type: space, tab, newline, carriage return
        """

        it "removes trailing spaces":
            expect str_trim_right("hello  ") == "hello"

        it "removes trailing newline":
            expect str_trim_right("hello\n") == "hello"

        it "removes trailing tab":
            expect str_trim_right("hello\t") == "hello"

        it "removes trailing carriage return":
            expect str_trim_right("hello\r") == "hello"

        it "removes mixed trailing whitespace":
            expect str_trim_right("hello \t\n\r") == "hello"

        it "preserves leading whitespace":
            expect str_trim_right("  hello") == "  hello"

        it "returns empty for whitespace-only":
            expect str_trim_right("   ") == ""

        it "returns empty for empty input":
            expect str_trim_right("") == ""

        it "returns same when no trailing whitespace":
            expect str_trim_right("hello") == "hello"

    context "trim aliases":
        it "trim_whitespace delegates to str_trim":
            expect trim_whitespace("  hi  ") == "hi"

        it "trim_left delegates to str_trim_left":
            expect trim_left("  hi") == "hi"

        it "trim_right delegates to str_trim_right":
            expect trim_right("hi  ") == "hi"

    context "trim_field":
        """
        ### Branch coverage for trim_field

        - should_trim == false -> return field unchanged
        - should_trim == true -> return trimmed field
        """

        it "trims when should_trim is true":
            expect trim_field("  hello  ", true) == "hello"

        it "preserves when should_trim is false":
            expect trim_field("  hello  ", false) == "  hello  "

        it "handles empty field with trim":
            expect trim_field("", true) == ""

        it "handles empty field without trim":
            expect trim_field("", false) == ""


# ============================================================================
# Test Group 5: String Replacement
# ============================================================================


describe "string_core - Replacement":
    """
    ## String Replacement

    Tests for str_replace and str_replace_all.
    """

    context "str_replace":
        it "replaces first occurrence":
            expect str_replace("hello", "l", "L") == "heLLo"

        it "returns same when pattern not found":
            expect str_replace("hello", "x", "X") == "hello"

        it "replaces at start":
            expect str_replace("hello", "h", "H") == "Hello"

        it "replaces at end":
            expect str_replace("hello", "o", "O") == "hellO"

        it "replaces with longer string":
            expect str_replace("abc", "b", "BBB") == "aBBBc"

        it "replaces with empty string":
            expect str_replace("abc", "b", "") == "ac"

    context "str_replace_all":
        """
        ### Branch coverage for str_replace_all

        - old_val.len() == 0 -> return s (early return)
        - while pos < s.len() (loop iterations)
        - idx == nil -> push remaining, set pos = s.len() (break)
        - idx > 0 -> push segment before match
        - idx == 0 -> skip segment push, just push new_val
        """

        it "replaces all occurrences":
            expect str_replace_all("hello", "l", "L") == "heLLo"

        it "replaces all in repeated pattern":
            expect str_replace_all("aaa", "a", "b") == "bbb"

        it "returns same when pattern not found":
            expect str_replace_all("hello", "x", "X") == "hello"

        it "returns same for empty old_val":
            expect str_replace_all("hello", "", "X") == "hello"

        it "replaces adjacent occurrences":
            expect str_replace_all("aabb", "a", "c") == "ccbb"

        it "replaces with empty string":
            expect str_replace_all("abcabc", "b", "") == "acac"

        it "replaces with longer string":
            expect str_replace_all("ab", "a", "xxx") == "xxxb"

        it "handles pattern at start":
            expect str_replace_all("abc", "a", "X") == "Xbc"

        it "handles pattern at end":
            expect str_replace_all("abc", "c", "X") == "abX"

        it "handles single-char string":
            expect str_replace_all("a", "a", "b") == "b"

        it "handles empty input string":
            expect str_replace_all("", "a", "b") == ""

        it "handles idx == 0 case where match is at start of remaining":
            expect str_replace_all("aXaXa", "a", "b") == "bXbXb"


# ============================================================================
# Test Group 6: Split and Join
# ============================================================================


describe "string_core - Split and Join":
    """
    ## Split and Join

    Tests for str_split and str_join.
    """

    context "str_split":
        it "splits by comma":
            val parts = str_split("a,b,c", ",")
            expect parts.len() == 3
            expect parts[0] == "a"
            expect parts[1] == "b"
            expect parts[2] == "c"

        it "splits by space":
            val parts = str_split("hello world", " ")
            expect parts.len() == 2
            expect parts[0] == "hello"

        it "returns single element when no delimiter":
            val parts = str_split("hello", ",")
            expect parts.len() == 1
            expect parts[0] == "hello"

        it "handles empty string":
            val parts = str_split("", ",")
            expect parts.len() > 0

        it "handles consecutive delimiters":
            val parts = str_split("a,,b", ",")
            expect parts.len() == 3

    context "str_join":
        it "joins with comma":
            expect str_join(["a", "b", "c"], ",") == "a,b,c"

        it "joins single element":
            expect str_join(["a"], ",") == "a"

        it "joins empty array":
            expect str_join([], ",") == ""

        it "joins with empty separator":
            expect str_join(["a", "b", "c"], "") == "abc"

        it "joins with multi-char separator":
            expect str_join(["a", "b"], " - ") == "a - b"


# ============================================================================
# Test Group 7: ASCII Character Helpers
# ============================================================================


describe "string_core - char_code_inline":
    """
    ## char_code_inline

    Tests the large lookup table. Covers representative characters from
    each category plus the fall-through default (returns 0).
    """

    context "whitespace characters":
        it "returns 32 for space":
            expect char_code_inline(" ") == 32

        it "returns 10 for newline":
            expect char_code_inline("\n") == 10

        it "returns 9 for tab":
            expect char_code_inline("\t") == 9

        it "returns 13 for carriage return":
            expect char_code_inline("\r") == 13

    context "punctuation":
        it "returns 33 for exclamation":
            expect char_code_inline("!") == 33

        it "returns 35 for hash":
            expect char_code_inline("#") == 35

        it "returns 46 for period":
            expect char_code_inline(".") == 46

        it "returns 44 for comma":
            expect char_code_inline(",") == 44

        it "returns 45 for hyphen":
            expect char_code_inline("-") == 45

        it "returns 95 for underscore":
            expect char_code_inline("_") == 95

        it "returns 64 for at-sign":
            expect char_code_inline("@") == 64

        it "returns 40 for open paren":
            expect(char_code_inline("(")).to_equal(40)

        it "returns 41 for close paren":
            expect(char_code_inline(")")).to_equal(41)

        it "returns 91 for open bracket":
            expect char_code_inline("[") == 91

        it "returns 93 for close bracket":
            expect char_code_inline("]") == 93

        it "returns 123 for open brace":
            expect char_code_inline("{") == 123

        it "returns 125 for close brace":
            expect char_code_inline("}") == 125

        it "returns 124 for pipe":
            expect char_code_inline("|") == 124

        it "returns 126 for tilde":
            expect char_code_inline("~") == 126

        it "returns 94 for caret":
            expect char_code_inline("^") == 94

        it "returns 36 for dollar":
            expect char_code_inline("$") == 36

        it "returns 37 for percent":
            expect char_code_inline("%") == 37

        it "returns 38 for ampersand":
            expect char_code_inline("&") == 38

        it "returns 42 for asterisk":
            expect char_code_inline("*") == 42

        it "returns 43 for plus":
            expect char_code_inline("+") == 43

        it "returns 47 for slash":
            expect char_code_inline("/") == 47

        it "returns 58 for colon":
            expect char_code_inline(":") == 58

        it "returns 59 for semicolon":
            expect char_code_inline(";") == 59

        it "returns 60 for less-than":
            expect char_code_inline("<") == 60

        it "returns 61 for equals":
            expect char_code_inline("=") == 61

        it "returns 62 for greater-than":
            expect char_code_inline(">") == 62

        it "returns 39 for single quote":
            expect char_code_inline("'") == 39

    context "digits":
        it "returns 48 for 0":
            expect char_code_inline("0") == 48

        it "returns 53 for 5":
            expect char_code_inline("5") == 53

        it "returns 57 for 9":
            expect char_code_inline("9") == 57

    context "uppercase letters":
        it "returns 65 for A":
            expect char_code_inline("A") == 65

        it "returns 77 for M":
            expect char_code_inline("M") == 77

        it "returns 90 for Z":
            expect char_code_inline("Z") == 90

    context "lowercase letters":
        it "returns 97 for a":
            expect char_code_inline("a") == 97

        it "returns 109 for m":
            expect char_code_inline("m") == 109

        it "returns 122 for z":
            expect char_code_inline("z") == 122

    context "unknown characters":
        it "returns 0 for unknown character":
            expect char_code_inline("") == 0

    context "question mark":
        it "returns 63 for question mark":
            val qm = char_from_code_inline(63)
            expect char_code_inline(qm) == 63



describe "string_core - char_from_code_inline":
    """
    ## char_from_code_inline

    Reverse lookup: code -> character. Covers representative values
    plus fall-through (returns "").
    """

    context "whitespace codes":
        it "returns space for 32":
            expect char_from_code_inline(32) == " "

        it "returns newline for 10":
            expect char_from_code_inline(10) == "\n"

        it "returns tab for 9":
            expect char_from_code_inline(9) == "\t"

        it "returns carriage return for 13":
            expect char_from_code_inline(13) == "\r"

    context "punctuation codes":
        it "returns exclamation for 33":
            expect char_from_code_inline(33) == "!"

        it "returns period for 46":
            expect char_from_code_inline(46) == "."

        it "returns underscore for 95":
            expect char_from_code_inline(95) == "_"

        it "returns open paren for 40":
            expect char_from_code_inline(40) == "("

        it "returns close paren for 41":
            expect char_from_code_inline(41) == ")"

        it "returns open bracket for 91":
            expect char_from_code_inline(91) == "["

        it "returns close bracket for 93":
            expect char_from_code_inline(93) == "]"

        it "returns open brace for 123":
            expect char_from_code_inline(123) == "{"

        it "returns close brace for 125":
            expect char_from_code_inline(125) == "}"

        it "returns pipe for 124":
            expect char_from_code_inline(124) == "|"

        it "returns tilde for 126":
            expect char_from_code_inline(126) == "~"

        it "returns caret for 94":
            expect char_from_code_inline(94) == "^"

        it "returns hash for 35":
            expect char_from_code_inline(35) == "#"

        it "returns dollar for 36":
            expect char_from_code_inline(36) == "$"

        it "returns percent for 37":
            expect char_from_code_inline(37) == "%"

        it "returns ampersand for 38":
            expect char_from_code_inline(38) == "&"

        it "returns single quote for 39":
            expect char_from_code_inline(39) == "'"

        it "returns asterisk for 42":
            expect char_from_code_inline(42) == "*"

        it "returns plus for 43":
            expect char_from_code_inline(43) == "+"

        it "returns comma for 44":
            expect char_from_code_inline(44) == ","

        it "returns hyphen for 45":
            expect char_from_code_inline(45) == "-"

        it "returns slash for 47":
            expect char_from_code_inline(47) == "/"

        it "returns colon for 58":
            expect char_from_code_inline(58) == ":"

        it "returns semicolon for 59":
            expect char_from_code_inline(59) == ";"

        it "returns less-than for 60":
            expect char_from_code_inline(60) == "<"

        it "returns equals for 61":
            expect char_from_code_inline(61) == "="

        it "returns greater-than for 62":
            expect char_from_code_inline(62) == ">"

        it "returns at-sign for 64":
            expect char_from_code_inline(64) == "@"

    context "digit codes":
        it "returns 0 for 48":
            expect char_from_code_inline(48) == "0"

        it "returns 5 for 53":
            expect char_from_code_inline(53) == "5"

        it "returns 9 for 57":
            expect char_from_code_inline(57) == "9"

    context "uppercase letter codes":
        it "returns A for 65":
            expect char_from_code_inline(65) == "A"

        it "returns M for 77":
            expect char_from_code_inline(77) == "M"

        it "returns Z for 90":
            expect char_from_code_inline(90) == "Z"

    context "lowercase letter codes":
        it "returns a for 97":
            expect char_from_code_inline(97) == "a"

        it "returns m for 109":
            expect char_from_code_inline(109) == "m"

        it "returns z for 122":
            expect char_from_code_inline(122) == "z"

    context "unknown codes":
        it "returns empty for 0":
            expect char_from_code_inline(0) == ""

        it "returns empty for 999":
            expect char_from_code_inline(999) == ""

        it "returns empty for negative code":
            expect char_from_code_inline(-1) == ""

        it "returns empty for code 1":
            expect char_from_code_inline(1) == ""


# ============================================================================
# Test Group 8: Character Classification
# ============================================================================


describe "string_core - Character Classification":
    """
    ## Character Classification

    Tests for is_alpha_char, is_digit_char, is_alnum_char.
    """

    context "is_alpha_char":
        """
        ### Branch coverage for is_alpha_char

        - code >= 65 and code <= 90 (uppercase) -> true
        - code >= 97 and code <= 122 (lowercase) -> true
        - neither -> false
        """

        it "returns true for lowercase letter":
            expect is_alpha_char("a") == true

        it "returns true for uppercase letter":
            expect is_alpha_char("Z") == true

        it "returns true for middle lowercase":
            expect is_alpha_char("m") == true

        it "returns true for middle uppercase":
            expect is_alpha_char("M") == true

        it "returns false for digit":
            expect is_alpha_char("5") == false

        it "returns false for space":
            expect is_alpha_char(" ") == false

        it "returns false for punctuation":
            expect is_alpha_char("!") == false

        it "returns false for underscore":
            expect is_alpha_char("_") == false

    context "is_digit_char":
        """
        ### Branch coverage for is_digit_char

        - code >= 48 and code <= 57 -> true
        - else -> false
        """

        it "returns true for 0":
            expect is_digit_char("0") == true

        it "returns true for 9":
            expect is_digit_char("9") == true

        it "returns true for middle digit":
            expect is_digit_char("5") == true

        it "returns false for letter":
            expect is_digit_char("a") == false

        it "returns false for space":
            expect is_digit_char(" ") == false

        it "returns false for punctuation":
            expect is_digit_char(".") == false

    context "is_alnum_char":
        """
        ### Branch coverage for is_alnum_char

        - is_alpha_char(c) -> true (short-circuit)
        - not alpha, is_digit_char(c) -> true
        - neither -> false
        """

        it "returns true for letter":
            expect is_alnum_char("a") == true

        it "returns true for uppercase letter":
            expect is_alnum_char("Z") == true

        it "returns true for digit":
            expect is_alnum_char("5") == true

        it "returns false for space":
            expect is_alnum_char(" ") == false

        it "returns false for punctuation":
            expect is_alnum_char("!") == false

        it "returns false for underscore":
            expect is_alnum_char("_") == false


# ============================================================================
# Test Group 9: Case Conversion
# ============================================================================


describe "string_core - Case Conversion":
    """
    ## Case Conversion

    Tests for str_to_lower, str_to_upper, str_capitalize.
    """

    context "str_to_lower":
        """
        ### Branch coverage for str_to_lower

        - while i < s.len() (loop entry and exit)
        - code >= 65 and code <= 90 -> convert uppercase to lowercase
        - else -> keep character unchanged
        """

        it "converts all uppercase":
            expect str_to_lower("HELLO") == "hello"

        it "converts mixed case":
            expect str_to_lower("HeLLo") == "hello"

        it "keeps already lowercase":
            expect str_to_lower("hello") == "hello"

        it "handles empty string":
            expect str_to_lower("") == ""

        it "preserves digits":
            expect str_to_lower("ABC123") == "abc123"

        it "preserves punctuation":
            expect str_to_lower("A.B-C") == "a.b-c"

        it "handles single uppercase char":
            expect str_to_lower("A") == "a"

        it "handles single lowercase char":
            expect str_to_lower("a") == "a"

    context "str_to_upper":
        """
        ### Branch coverage for str_to_upper

        - while i < s.len() (loop entry and exit)
        - code >= 97 and code <= 122 -> convert lowercase to uppercase
        - else -> keep character unchanged
        """

        it "converts all lowercase":
            expect str_to_upper("hello") == "HELLO"

        it "converts mixed case":
            expect str_to_upper("HeLLo") == "HELLO"

        it "keeps already uppercase":
            expect str_to_upper("HELLO") == "HELLO"

        it "handles empty string":
            expect str_to_upper("") == ""

        it "preserves digits":
            expect str_to_upper("abc123") == "ABC123"

        it "preserves punctuation":
            expect str_to_upper("a.b-c") == "A.B-C"

        it "handles single lowercase char":
            expect str_to_upper("a") == "A"

        it "handles single uppercase char":
            expect str_to_upper("A") == "A"

    context "str_capitalize":
        """
        ### Branch coverage for str_capitalize

        - s.len() == 0 -> return s (early return)
        - s.len() > 0 -> capitalize first char
        """

        it "capitalizes lowercase first char":
            expect str_capitalize("hello") == "Hello"

        it "keeps uppercase first char":
            expect str_capitalize("Hello") == "Hello"

        it "capitalizes all-uppercase":
            expect str_capitalize("HELLO") == "HELLO"

        it "returns empty for empty string":
            expect str_capitalize("") == ""

        it "capitalizes single char":
            expect str_capitalize("a") == "A"

        it "handles digit first char":
            expect str_capitalize("1abc") == "1abc"

        it "handles space first char":
            expect str_capitalize(" hello") == " hello"


