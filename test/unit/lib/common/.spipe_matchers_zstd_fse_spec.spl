use std.spec.{describe, it, expect}
use std.common.compress.zstd_fse.{
    ZstdFseDecodeTable,
    zstd_fse_validate_table_log,
    zstd_fse_parse_normalized_counts,
    zstd_fse_build_decode_table,
    zstd_fse_init_state,
    zstd_fse_get_entry
}
use std.common.compress.{CompressionError}

fn _expect_compression_error(err: CompressionError, kind: text, message_part: text):
    match err:
        CompressionError.InvalidHeader(message):
            expect kind == "InvalidHeader"
            expect (message).contains(message_part)
        CompressionError.UnsupportedFeature(message):
            expect kind == "UnsupportedFeature"
            expect (message).contains(message_part)
        CompressionError.TruncatedInput(message):
            expect kind == "TruncatedInput"
            expect (message).contains(message_part)
        CompressionError.ChecksumMismatch(message):
            expect kind == "ChecksumMismatch"
            expect (message).contains(message_part)
        CompressionError.CorruptStream(message):
            expect kind == "CorruptStream"
            expect (message).contains(message_part)
        CompressionError.SizeLimitExceeded(limit):
            expect kind == "SizeLimitExceeded"
            expect limit >= 0 == true

fn _count_symbol(table: ZstdFseDecodeTable, symbol: i64) -> i64:
    var count = 0
    var i = 0
    while i < table.entries.len():
        if table.entries[i].symbol == symbol:
            count = count + 1
        i = i + 1
    count

describe "zstd fse helpers":
    it "validates table log bounds explicitly":
        val ok = zstd_fse_validate_table_log(5, 9)
        expect ok.is_err() == false

        val low = zstd_fse_validate_table_log(4, 9)
        expect low.is_err() == true
        _expect_compression_error(low.unwrap_err(), "CorruptStream", "below minimum")

        val high = zstd_fse_validate_table_log(10, 9)
        expect high.is_err() == true
        _expect_compression_error(high.unwrap_err(), "CorruptStream", "caller maximum")

    it "parses normalized counts including zero repeats and less-than-one probabilities":
        val simple = zstd_fse_parse_normalized_counts([0x10u8, 0x3Fu8], 0, 2, 9, 8)
        expect simple.is_err() == false
        val simple_counts = simple.unwrap()
        expect simple_counts.table_log == 5
        expect simple_counts.counts == [16, 16]
        expect simple_counts.bytes_used == 2

        val repeated = zstd_fse_parse_normalized_counts([0x10u8, 0xA3u8, 0x0Fu8], 0, 3, 9, 8)
        expect repeated.is_err() == false
        val repeated_counts = repeated.unwrap()
        expect repeated_counts.counts == [16, 0, 0, 16]
        expect repeated_counts.max_symbol == 3

        val minus_one = zstd_fse_parse_normalized_counts([0x00u8, 0xE1u8, 0x03u8], 0, 3, 9, 8)
        expect minus_one.is_err() == false
        expect minus_one.unwrap().counts == [15, -1, 16]

    it "rejects truncated or out-of-range normalized count descriptions":
        val truncated = zstd_fse_parse_normalized_counts([0x00u8], 0, 1, 9, 8)
        expect truncated.is_err() == true
        _expect_compression_error(truncated.unwrap_err(), "TruncatedInput", "normalized counts")

        val too_many = zstd_fse_parse_normalized_counts([0x10u8, 0xA3u8, 0x0Fu8], 0, 3, 9, 2)
        expect too_many.is_err() == true
        _expect_compression_error(too_many.unwrap_err(), "CorruptStream", "caller maximum")

    it "builds decode tables from validated normalized counts":
        val table_res = zstd_fse_build_decode_table(5, [16, 16])
        expect table_res.is_err() == false
        val table = table_res.unwrap()
        expect table.entries.len() == 32
        expect _count_symbol(table, 0) == 16
        expect _count_symbol(table, 1) == 16
        var i = 0
        while i < table.entries.len():
            expect table.entries[i].bits == 1
            expect table.entries[i].baseline % 2 == 0
            i = i + 1

        val mixed_res = zstd_fse_build_decode_table(5, [15, -1, 16])
        expect mixed_res.is_err() == false
        val mixed = mixed_res.unwrap()
        expect _count_symbol(mixed, 1) == 1
        expect mixed.entries[31].symbol == 1
        expect mixed.entries[31].bits == 5
        expect mixed.entries[31].baseline == 0

    it "provides bounded state access for later decode wiring":
        val table_res = zstd_fse_build_decode_table(5, [16, 16])
        expect table_res.is_err() == false
        val table = table_res.unwrap()

        val init = zstd_fse_init_state(7, table)
        expect init.is_err() == false
        val entry = zstd_fse_get_entry(table, init.unwrap())
        expect entry.is_err() == false
        expect entry.unwrap().bits == 1

        val bad_state = zstd_fse_init_state(32, table)
        expect bad_state.is_err() == true
        _expect_compression_error(bad_state.unwrap_err(), "CorruptStream", "initial state")