#![allow(spipe_empty_examples)]
#![allow(spipe_boolean_wrapper_assertions)]
@allow(spipe_empty_examples)
@allow(spipe_boolean_wrapper_assertions)
use lib.versioned.{VersionedSnapshot, VersionedSnapshot__new, VersionedSnapshot__with_history, Snapshot, Snapshot__new}

fn main():
    # VersionedSnapshot -- MVCC Versioned Container Tests
    #
    # Tests for VersionedSnapshot and Snapshot classes from nogc_async_immut/versioned.
    # VersionedSnapshot maintains a bounded history of versioned values
    # for multi-version concurrency control style reads.


    describe "VersionedSnapshot":

        # ========================================================================
        # Creation
        # ========================================================================

        describe "creation":
            it "creates with initial value at version 0":
                val vs = VersionedSnapshot.new(100)
                expect vs.current() == 100
                expect vs.version() == 0

            it "creates with string initial value":
                val vs = VersionedSnapshot.new("hello")
                expect vs.current() == "hello"

            it "creates with nil initial value":
                val vs = VersionedSnapshot.new(nil)
                expect vs.current() == nil

            it "creates with custom max_history":
                val vs = VersionedSnapshot.with_history("start", 3)
                expect vs.current() == "start"
                expect vs.version() == 0

        # ========================================================================
        # Read operations
        # ========================================================================

        describe "current":
            it "returns initial value":
                val vs = VersionedSnapshot.new(42)
                expect vs.current() == 42

            it "returns latest value after updates":
                var vs = VersionedSnapshot.new(1)
                vs.update(2)
                vs.update(3)
                expect vs.current() == 3

        describe "version":
            it "starts at 0":
                val vs = VersionedSnapshot.new(0)
                expect vs.version() == 0

            it "increments on each update":
                var vs = VersionedSnapshot.new(0)
                vs.update(10)
                expect vs.version() == 1
                vs.update(20)
                expect vs.version() == 2

        describe "at_version":
            it "returns value at version 0":
                val vs = VersionedSnapshot.new(100)
                expect vs.at_version(0) == 100

            it "returns value at specific version":
                var vs = VersionedSnapshot.new("a")
                vs.update("b")
                vs.update("c")
                expect vs.at_version(0) == "a"
                expect vs.at_version(1) == "b"
                expect vs.at_version(2) == "c"

            it "returns nil for missing version":
                val vs = VersionedSnapshot.new(10)
                expect vs.at_version(99) == nil

            it "returns nil for negative version":
                val vs = VersionedSnapshot.new(10)
                expect vs.at_version(-1) == nil

        describe "has_version":
            it "returns true for existing version":
                val vs = VersionedSnapshot.new(10)
                expect vs.has_version(0) == true

            it "returns false for missing version":
                val vs = VersionedSnapshot.new(10)
                expect vs.has_version(5) == false

            it "tracks updated versions":
                var vs = VersionedSnapshot.new(0)
                vs.update(1)
                expect vs.has_version(0) == true
                expect vs.has_version(1) == true
                expect vs.has_version(2) == false

        describe "version_count":
            it "starts at 1 with initial value":
                val vs = VersionedSnapshot.new(10)
                expect vs.version_count() == 1

            it "grows with updates":
                var vs = VersionedSnapshot.new(0)
                vs.update(1)
                vs.update(2)
                expect vs.version_count() == 3

        # ========================================================================
        # Snapshot
        # ========================================================================

        describe "snapshot":
            it "creates frozen snapshot of current state":
                val vs = VersionedSnapshot.new(42)
                val snap = vs.snapshot()
                expect snap.get() == 42
                expect snap.get_version() == 0

            it "snapshot reflects latest update":
                var vs = VersionedSnapshot.new(1)
                vs.update(2)
                vs.update(3)
                val snap = vs.snapshot()
                expect snap.get() == 3
                expect snap.get_version() == 2

            it "snapshot is immutable after creation":
                var vs = VersionedSnapshot.new(10)
                val snap = vs.snapshot()
                vs.update(20)
                vs.update(30)
                expect snap.get() == 10
                expect snap.get_version() == 0
                expect vs.current() == 30

        describe "Snapshot__new":
            it "creates snapshot directly":
                val snap = Snapshot.new(5, "data")
                expect snap.get() == "data"
                expect snap.get_version() == 5

            it "creates snapshot with nil value":
                val snap = Snapshot.new(0, nil)
                expect snap.get() == nil
                expect snap.get_version() == 0

        # ========================================================================
        # History
        # ========================================================================

        describe "history":
            it "returns all version entries":
                var vs = VersionedSnapshot.new("a")
                vs.update("b")
                vs.update("c")
                val h = vs.history()
                expect h.len() == 3

            it "entries contain version and value":
                var vs = VersionedSnapshot.new(10)
                vs.update(20)
                val h = vs.history()
                expect h[0][0] == 0
                expect h[0][1] == 10
                expect h[1][0] == 1
                expect h[1][1] == 20

            it "initial state has one entry":
                val vs = VersionedSnapshot.new(42)
                val h = vs.history()
                expect h.len() == 1
                expect h[0][0] == 0
                expect h[0][1] == 42

        describe "history_since":
            it "returns entries from given version onwards":
                var vs = VersionedSnapshot.new("a")
                vs.update("b")
                vs.update("c")
                val h = vs.history_since(1)
                expect h.len() == 2
                expect h[0][1] == "b"
                expect h[1][1] == "c"

            it "returns all entries when version is 0":
                var vs = VersionedSnapshot.new(10)
                vs.update(20)
                val h = vs.history_since(0)
                expect h.len() == 2

            it "returns empty when version is beyond current":
                var vs = VersionedSnapshot.new(10)
                vs.update(20)
                val h = vs.history_since(99)
                expect h.len() == 0

        # ========================================================================
        # Write operations
        # ========================================================================

        describe "update":
            it "adds new version":
                var vs = VersionedSnapshot.new(1)
                vs.update(2)
                expect vs.current() == 2
                expect vs.version() == 1

            it "multiple updates track all values":
                var vs = VersionedSnapshot.new(0)
                vs.update(10)
                vs.update(20)
                vs.update(30)
                expect vs.current() == 30
                expect vs.version() == 3
                expect vs.at_version(1) == 10
                expect vs.at_version(2) == 20

        describe "update_with":
            it "applies function to current value":
                var vs = VersionedSnapshot.new(10)
                vs.update_with(\x: x * 2)
                expect vs.current() == 20
                expect vs.version() == 1

            it "chains function applications":
                var vs = VersionedSnapshot.new(1)
                vs.update_with(\x: x + 1)
                vs.update_with(\x: x * 10)
                expect vs.current() == 20
                expect vs.at_version(1) == 2
                expect vs.at_version(2) == 20

        # ========================================================================
        # History trimming
        # ========================================================================

        describe "max_history trimming":
            it "trims oldest entries when exceeding max_history":
                var vs = VersionedSnapshot.with_history(0, 3)
                vs.update(1)
                vs.update(2)
                vs.update(3)
                # 4 entries total, max is 3 -- version 0 should be trimmed
                expect vs.version_count() == 3
                expect vs.has_version(0) == false
                expect vs.has_version(1) == true

            it "retains latest entries":
                var vs = VersionedSnapshot.with_history(0, 2)
                vs.update(1)
                vs.update(2)
                vs.update(3)
                # max 2: should keep versions 2 and 3
                expect vs.current() == 3
                expect vs.version_count() == 2

            it "at_version returns nil for trimmed versions":
                var vs = VersionedSnapshot.with_history(0, 2)
                vs.update(10)
                vs.update(20)
                vs.update(30)
                expect vs.at_version(0) == nil
                expect vs.at_version(1) == nil
fn main():
    #![allow(spipe_empty_examples)]
    #![allow(spipe_boolean_wrapper_assertions)]
    @allow(spipe_empty_examples)
    @allow(spipe_boolean_wrapper_assertions)

fn main():
    #![allow(spipe_empty_examples)]
    #![allow(spipe_boolean_wrapper_assertions)]
    @allow(spipe_empty_examples)
    @allow(spipe_boolean_wrapper_assertions)
