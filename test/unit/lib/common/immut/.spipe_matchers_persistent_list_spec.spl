# PersistentList — Cons List Tests
#
# Tests for the PersistentList class from nogc_async_immut/persistent_list.
# Immutable singly-linked list with structural sharing.
# O(1) prepend, O(1) head/tail, O(n) indexed access.

use lib.persistent_list.{PersistentList, PersistentList__empty, PersistentList__of, PersistentList__from_array}

describe "PersistentList":

    describe "empty list":
        it "has zero length":
            val l = PersistentList.empty()
            expect l.len() == 0

        it "is empty":
            val l = PersistentList.empty()
            expect l.is_empty() == true

        it "head is nil":
            val l = PersistentList.empty()
            expect l.head() == nil

        it "tail is empty":
            val l = PersistentList.empty()
            val t = l.tail()
            expect t.len() == 0
            expect t.is_empty() == true

    describe "prepend":
        it "adds element to front":
            val l = PersistentList.empty().prepend(1)
            expect l.len() == 1
            expect l.head() == 1
            expect l.is_empty() == false

        it "preserves order":
            val l = PersistentList.empty().prepend(3).prepend(2).prepend(1)
            expect l.head() == 1
            expect l.get(1) == 2
            expect l.get(2) == 3
            expect l.len() == 3

        it "does not modify original":
            val l1 = PersistentList.empty().prepend(1)
            val l2 = l1.prepend(2)
            expect l1.len() == 1
            expect l1.head() == 1
            expect l2.len() == 2
            expect l2.head() == 2

        it "supports multiple branches from same base":
            val base = PersistentList.empty().prepend(1)
            val branch_a = base.prepend(10)
            val branch_b = base.prepend(20)
            expect base.len() == 1
            expect branch_a.len() == 2
            expect branch_b.len() == 2
            expect branch_a.head() == 10
            expect branch_b.head() == 20

    describe "PersistentList__of":
        it "builds list preserving order":
            val l = PersistentList.of([10, 20, 30])
            expect l.len() == 3
            expect l.head() == 10
            expect l.get(1) == 20
            expect l.get(2) == 30

        it "handles single element":
            val l = PersistentList.of([42])
            expect l.len() == 1
            expect l.head() == 42

    describe "from_array":
        it "builds list from array":
            val l = PersistentList.from_array([5, 10, 15])
            expect l.len() == 3
            expect l.head() == 5
            expect l.get(2) == 15

        it "empty array gives empty list":
            val l = PersistentList.from_array([])
            expect l.len() == 0
            expect l.is_empty() == true

    describe "get":
        it "returns element at index":
            val l = PersistentList.of([5, 10, 15])
            expect l.get(0) == 5
            expect l.get(1) == 10
            expect l.get(2) == 15

        it "returns nil for out of bounds":
            val l = PersistentList.of([1, 2])
            expect l.get(5) == nil

        it "returns nil for negative index":
            val l = PersistentList.of([1, 2])
            expect l.get(-1) == nil

    describe "contains":
        it "finds existing element":
            val l = PersistentList.of(["a", "b", "c"])
            expect l.contains("b") == true

        it "returns false for missing element":
            val l = PersistentList.of(["a", "b", "c"])
            expect l.contains("z") == false

        it "works with integers":
            val l = PersistentList.of([1, 2, 3, 4, 5])
            expect l.contains(3) == true
            expect l.contains(6) == false

        it "returns false for empty list":
            val l = PersistentList.empty()
            expect l.contains(1) == false

    describe "tail":
        it "returns rest of list":
            val l = PersistentList.of([1, 2, 3])
            val t = l.tail()
            expect t.len() == 2
            expect t.head() == 2

        it "tail of single element is empty":
            val l = PersistentList.of([42])
            val t = l.tail()
            expect t.len() == 0
            expect t.is_empty() == true

        it "chained tail calls":
            val l = PersistentList.of([1, 2, 3])
            val t = l.tail().tail()
            expect t.len() == 1
            expect t.head() == 3

    describe "head":
        it "returns first element":
            val l = PersistentList.of([99, 88, 77])
            expect l.head() == 99

        it "returns nil for empty":
            val l = PersistentList.empty()
            expect l.head() == nil

    describe "reverse":
        it "reverses the list":
            val l = PersistentList.of([1, 2, 3])
            val r = l.reverse()
            expect r.head() == 3
            expect r.get(1) == 2
            expect r.get(2) == 1

        it "preserves length":
            val l = PersistentList.of([1, 2, 3, 4])
            val r = l.reverse()
            expect r.len() == 4

        it "reverse of single element is same":
            val l = PersistentList.of([42])
            val r = l.reverse()
            expect r.head() == 42
            expect r.len() == 1

        it "reverse of empty is empty":
            val l = PersistentList.empty()
            val r = l.reverse()
            expect r.len() == 0

        it "does not modify original":
            val l = PersistentList.of([1, 2, 3])
            val r = l.reverse()
            expect l.head() == 1
            expect r.head() == 3

    describe "to_array":
        it "converts to array":
            val l = PersistentList.of([10, 20, 30])
            val arr = l.to_array()
            expect arr.len() == 3
            expect arr[0] == 10
            expect arr[1] == 20
            expect arr[2] == 30

        it "empty list gives empty array":
            val l = PersistentList.empty()
            val arr = l.to_array()
            expect arr.len() == 0

    describe "concat":
        it "joins two lists":
            val l1 = PersistentList.of([1, 2])
            val l2 = PersistentList.of([3, 4])
            val joined = l1.concat(l2)
            expect joined.len() == 4
            expect joined.head() == 1
            expect joined.get(1) == 2
            expect joined.get(2) == 3
            expect joined.get(3) == 4

        it "concat with empty list":
            val l1 = PersistentList.of([1, 2])
            val l2 = PersistentList.empty()
            val joined = l1.concat(l2)
            expect joined.len() == 2
            expect joined.head() == 1

        it "empty concat with list":
            val l1 = PersistentList.empty()
            val l2 = PersistentList.of([3, 4])
            val joined = l1.concat(l2)
            expect joined.len() == 2
            expect joined.head() == 3

        it "does not modify originals":
            val l1 = PersistentList.of([1, 2])
            val l2 = PersistentList.of([3, 4])
            val joined = l1.concat(l2)
            expect l1.len() == 2
            expect l2.len() == 2
            expect joined.len() == 4

    describe "map":
        it "applies function to each element":
            val l = PersistentList.of([1, 2, 3])
            val doubled = l.map(\x: x * 2)
            expect doubled.len() == 3
            expect doubled.get(0) == 2
            expect doubled.get(1) == 4
            expect doubled.get(2) == 6

        it "preserves length":
            val l = PersistentList.of([10, 20, 30])
            val result = l.map(\x: x + 1)
            expect result.len() == 3

        it "empty list map is empty":
            val l = PersistentList.empty()
            val result = l.map(\x: x * 2)
            expect result.len() == 0

    describe "filter":
        it "keeps matching elements":
            val l = PersistentList.of([1, 2, 3, 4, 5])
            val evens = l.filter(\x: x % 2 == 0)
            expect evens.len() == 2
            expect evens.get(0) == 2
            expect evens.get(1) == 4

        it "returns empty when nothing matches":
            val l = PersistentList.of([1, 3, 5])
            val evens = l.filter(\x: x % 2 == 0)
            expect evens.len() == 0

        it "returns all when everything matches":
            val l = PersistentList.of([2, 4, 6])
            val evens = l.filter(\x: x % 2 == 0)
            expect evens.len() == 3

    describe "fold":
        it "accumulates sum":
            val l = PersistentList.of([1, 2, 3, 4])
            val sum = l.fold(0, \acc, x: acc + x)
            expect sum == 10

        it "accumulates product":
            val l = PersistentList.of([1, 2, 3, 4])
            val product = l.fold(1, \acc, x: acc * x)
            expect product == 24

        it "returns init for empty list":
            val l = PersistentList.empty()
            val result = l.fold(42, \acc, x: acc + x)
            expect result == 42

        it "single element":
            val l = PersistentList.of([5])
            val result = l.fold(0, \acc, x: acc + x)
            expect result == 5