extern fn rt_file_read_text(path: text) -> text

fn source(path: text) -> text:
    rt_file_read_text(path) ?? ""

fn body_after_marker(source_text: text, marker: text) -> text:
    val start = source_text.find(marker)
    if start < 0:
        return ""
    source_text.slice(start, source_text.len())

fn assert_seed_status_surface(path: text):
    val text = source(path)
    val set_body = body_after_marker(text, "fn set_seed(seed: i64) -> text:")
    val manual_body = body_after_marker(text, "fn manual_seed(seed: i64) -> text:")

    expect(set_body).to_contain("fn set_seed(seed: i64) -> text:")
    expect(set_body).to_contain("\"unsupported\"")
    expect(set_body.contains("Currently a no-op")).to_equal(false)
    expect(set_body.contains("No-op until rt_torch_manual_seed")).to_equal(false)
    expect(manual_body).to_contain("fn manual_seed(seed: i64) -> text:")
    expect(manual_body).to_contain("set_seed(seed)")

describe "Torch training seed status":
    it "makes GC async seed helpers explicitly unsupported":
        assert_seed_status_surface("src/lib/gc_async_mut/torch/torch_training.spl")

    it "makes NoGC async seed helpers explicitly unsupported":
        assert_seed_status_surface("src/lib/nogc_async_mut/torch/torch_training.spl")

    it "makes NoGC sync seed helpers explicitly unsupported":
        assert_seed_status_surface("src/lib/nogc_sync_mut/torch/torch_training.spl")
