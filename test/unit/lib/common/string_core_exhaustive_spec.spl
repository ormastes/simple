# @covers src/lib/common/string_core.spl 80%
"""
# String Core Exhaustive Char Table Specification

**Feature IDs:** #LIB-STRING-CORE
**Category:** Stdlib
**Status:** Implemented

## Overview

Exhaustive per-character branch coverage for char_code_inline and
char_from_code_inline. Each digit, uppercase letter, and lowercase letter
is tested individually to cover every if-branch in the lookup tables.
"""

use common.string_core.{char_code_inline, char_from_code_inline}


# ============================================================================
# Test Group 13: Exhaustive char_code_inline branch coverage
# ============================================================================

describe "string_core - char_code_inline exhaustive digits":
    """
    ## char_code_inline - all digit branches

    Every digit 0-9 must be tested individually to cover each if-branch.
    """

    context "all digits":
        it "returns 49 for 1":
            expect(char_code_inline("1")).to_equal(49)

        it "returns 50 for 2":
            expect(char_code_inline("2")).to_equal(50)

        it "returns 51 for 3":
            expect(char_code_inline("3")).to_equal(51)

        it "returns 52 for 4":
            expect(char_code_inline("4")).to_equal(52)

        it "returns 54 for 6":
            expect(char_code_inline("6")).to_equal(54)

        it "returns 55 for 7":
            expect(char_code_inline("7")).to_equal(55)

        it "returns 56 for 8":
            expect(char_code_inline("8")).to_equal(56)

describe "string_core - char_code_inline exhaustive uppercase":
