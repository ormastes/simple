describe "string_core - char_from_code_inline exhaustive digits":
    """
    ## char_from_code_inline - all digit code branches

    Every digit code 48-57 must be tested individually.
    """

    context "all digit codes":
        it "returns 1 for 49":
            expect(char_from_code_inline(49)).to_equal("1")

        it "returns 2 for 50":
            expect(char_from_code_inline(50)).to_equal("2")

        it "returns 3 for 51":
