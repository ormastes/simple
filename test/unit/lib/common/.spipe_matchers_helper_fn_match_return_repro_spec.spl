# Regression: helper-fn return-from-match in spec it-block context.
#
# Q's note in `doc/08_tracking/bug/interpreter_match_ok_arm_text_type_lookup_2026-05-01.md`
# (Future work) hypothesised a separate "helper-fn return-from-match in spec it-block context
# returns wrong value" interpreter limitation, citing REQ-JWT-006 as the surface symptom.
#
# After the `text.from_char_code(n) -> n.chr()` fix in commit `4daecc081b`, REQ-JWT-006
# passes. Empirically the hypothesised limitation does not exist for any of the discriminator
# shapes below, including the one structurally identical to `_hs256_verify_ok`
# (helper returning bool from `match Ok(_)/Err(_)` over a Result<bool, text>).
#
# This spec captures discriminators D1, D2, D4, D6, D8, D9 from the diagnosis matrix
# in `doc/08_tracking/bug/interpreter_helper_fn_return_from_match_2026-05-01.md`
# so a future regression of this shape is caught immediately.
#
# Bug closed: see jwt_hs256_round_trip_failure_2026-05-01.md and
# interpreter_match_ok_arm_text_type_lookup_2026-05-01.md (Future-work item INVALID).

use std.spec.{describe, it, expect}
use std.common.jwt.sign.{jwt_sign_hs256, jwt_verify_hs256}

# D1: helper returns int from match arms.
fn _h_int(n: i64) -> i64:
    match n:
        0:
            return 100
        _:
            return 200

# D2: helper returns text from match arms.
fn _h_text(n: i64) -> text:
    match n:
        0:
            return "zero"
        _:
            return "nonzero"

# D4: helper returns bool from match arms (closest scalar shape to _hs256_verify_ok).
fn _h_bool(n: i64) -> bool:
    match n:
        0:
            return true
        _:
            return false

# D6: single-arm match returning bool unconditionally.
fn _h_bool_single(n: i64) -> bool:
    match n:
        _:
            return true

# D8: bool helper returning from match Ok(_)/Err(_) over a same-module Result<bool, text>.
# Structurally identical to _hs256_verify_ok except cross-module.
fn _produces_result(n: i64) -> Result<bool, text>:
    if n == 0:
        return Ok(true)
    return Err("bad")

fn _h_bool_via_result(n: i64) -> bool:
    val r = _produces_result(n)
    match r:
        Ok(_):
            return true
        Err(_):
            return false

# D9: bool helper returning from match Ok(_)/Err(_) over a cross-module Result<bool, text>.
# Mirrors _hs256_verify_ok exactly: pulls jwt_verify_hs256 from std.common.jwt.sign.
fn _h_bool_via_jwt(compact: text, key: [u8]) -> bool:
    val r = jwt_verify_hs256(compact, key)
    match r:
        Ok(_):
            return true
        Err(_):
            return false

describe "helper-fn match return regression":
    it "D1: int from match in helper called from it-block":
        expect _h_int(0) == 100
        expect _h_int(5) == 200

    it "D2: text from match in helper called from it-block":
        expect _h_text(0) == "zero"
        expect _h_text(5) == "nonzero"

    it "D4: bool from match in helper called from it-block":
        expect _h_bool(0) == true
        expect _h_bool(5) == false

    it "D6: single-arm match returning bool":
        expect _h_bool_single(0) == true
        expect _h_bool_single(99) == true

    it "D8: bool via same-module Result<bool, text> match (mirrors _hs256_verify_ok)":
        expect _h_bool_via_result(0) == true
        expect _h_bool_via_result(5) == false

    it "D9: bool via cross-module Result<bool, text> match (exact _hs256_verify_ok shape)":
        var key: [u8] = []
        var i = 0
        while i < 32:
            key.push(((i * 7 + 13) % 256).to_u8())
            i = i + 1
        var wrong_key: [u8] = []
        var j = 0
        while j < 32:
            wrong_key.push(((j * 3 + 99) % 256).to_u8())
            j = j + 1
        val payload = "{\"sub\":\"regress\"}"
        val compact = jwt_sign_hs256(payload, key)
        expect _h_bool_via_jwt(compact, key) == true
        expect _h_bool_via_jwt(compact, wrong_key) == false