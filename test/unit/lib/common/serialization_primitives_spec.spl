# Test Group 9: Binary List Serialization (serialize.spl)
# ============================================================================

describe "serialize_int_list_bytes":
    """
    ## Integer List Binary Serialization
    """

    it "starts with list type tag":
        val result = serialize_int_list_bytes([1, 2])
        expect(result[0]).to_equal(type_list())

    it "serializes empty int list":
        val result = serialize_int_list_bytes([])
        expect(result[0]).to_equal(type_list())

describe "serialize_text_list_bytes":
    """
    ## Text List Binary Serialization
    """

    it "starts with list type tag":
        val result = serialize_text_list_bytes(["hello"])
        expect(result[0]).to_equal(type_list())

    it "serializes empty text list":
        val result = serialize_text_list_bytes([])
        expect(result[0]).to_equal(type_list())

