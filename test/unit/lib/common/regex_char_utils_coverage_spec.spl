# Regex Engine - Character Utilities Coverage Specification
#
# Comprehensive branch coverage tests for src/lib/common/regex_engine/char_utils.spl
# Covers: char_code, string_from_code, is_digit_char, is_alpha_char, is_alnum_char,
# is_word_char, is_whitespace_char, is_hex_char, is_special_regex_char,
# escape_regex, unescape_regex, expand_escape, is_escape_char
#
# Imports actual functions from the source module so coverage instruments
# the real code paths in char_utils.spl.

use lib.common.regex_engine.{char_code, string_from_code, is_digit_char, is_alpha_char, is_alnum_char, is_word_char, is_whitespace_char, is_hex_char, is_special_regex_char, escape_regex, unescape_regex, expand_escape, is_escape_char}

"""
# Regex Character Utilities Coverage Specification

**Feature IDs:** #REGEX-CHAR-UTILS
**Category:** Testing / Coverage
**Status:** Implemented

## Overview

Tests all exported functions from `src/lib/common/regex_engine/char_utils.spl`
targeting 90%+ branch coverage. Each function is tested with inputs that exercise
both true and false branches, boundary values, and edge cases.
"""


# ============================================================================
# Test Group 1: char_code
# ============================================================================

describe "char_code":
    """
    ## char_code(ch: text) -> i64

    Converts a single character to its ASCII code value.
    Tests cover all character categories and the fallback branch.
    """

    context "digits":
        it "returns 48 for '0'":
            expect(char_code("0")).to_equal(48)

        it "returns 57 for '9'":
            expect(char_code("9")).to_equal(57)

        it "returns 53 for '5'":
            expect(char_code("5")).to_equal(53)

    context "uppercase letters":
        it "returns 65 for 'A'":
            expect(char_code("A")).to_equal(65)

        it "returns 90 for 'Z'":
            expect(char_code("Z")).to_equal(90)

        it "returns 77 for 'M'":
            expect(char_code("M")).to_equal(77)

    context "lowercase letters":
        it "returns 97 for 'a'":
            expect(char_code("a")).to_equal(97)

        it "returns 122 for 'z'":
            expect(char_code("z")).to_equal(122)

        it "returns 109 for 'm'":
            expect(char_code("m")).to_equal(109)

    context "special characters":
        it "returns 32 for space":
            expect(char_code(" ")).to_equal(32)

        it "returns 33 for '!'":
            expect(char_code("!")).to_equal(33)

        it "returns 46 for '.'":
            expect(char_code(".")).to_equal(46)

        it "returns 64 for '@'":
            expect(char_code("@")).to_equal(64)

        it "returns 95 for '_'":
            expect(char_code("_")).to_equal(95)

        it "returns 92 for backslash":
            expect(char_code("\\")).to_equal(92)

        it "returns 91 for '['":
            expect(char_code("[")).to_equal(91)

        it "returns 93 for ']'":
            expect(char_code("]")).to_equal(93)

        it "returns 123 for '{'":
            expect(char_code("{")).to_equal(123)

        it "returns 125 for '}'":
            expect(char_code("}")).to_equal(125)

        it "returns 124 for '|'":
            expect(char_code("|")).to_equal(124)

        it "returns 94 for '^'":
            expect(char_code("^")).to_equal(94)

        it "returns 36 for '$'":
            expect(char_code("$")).to_equal(36)

        it "returns 126 for '~'":
            expect(char_code("~")).to_equal(126)

        it "returns 34 for double quote":
            expect(char_code("\"")).to_equal(34)

        it "returns 39 for single quote":
            expect(char_code("'")).to_equal(39)

        it "returns 40 for '('":
            expect(char_code("(")).to_equal(40)

        it "returns 41 for ')'":
            expect(char_code(")")).to_equal(41)

        it "returns 42 for '*'":
            expect(char_code("*")).to_equal(42)

        it "returns 43 for '+'":
            expect(char_code("+")).to_equal(43)

        it "returns 44 for ','":
            expect(char_code(",")).to_equal(44)

        it "returns 45 for '-'":
            expect(char_code("-")).to_equal(45)

        it "returns 47 for '/'":
            expect(char_code("/")).to_equal(47)

        it "returns 58 for ':'":
            expect(char_code(":")).to_equal(58)

        it "returns 59 for ';'":
            expect(char_code(";")).to_equal(59)

        it "returns 60 for '<'":
            expect(char_code("<")).to_equal(60)

        it "returns 61 for '='":
            expect(char_code("=")).to_equal(61)

        it "returns 62 for '>'":
            expect(char_code(">")).to_equal(62)

        it "returns 63 for '?'":
            expect(char_code("?")).to_equal(63)

        it "returns 35 for '#'":
            expect(char_code("#")).to_equal(35)

        it "returns 37 for '%'":
            expect(char_code("%")).to_equal(37)

        it "returns 38 for '&'":
            expect(char_code("&")).to_equal(38)

        it "returns 96 for backtick":
            expect(char_code("`")).to_equal(96)

    context "whitespace characters":
        it "returns 10 for newline":
            expect(char_code("\n")).to_equal(10)

        it "returns 9 for tab":
            expect(char_code("\t")).to_equal(9)

        it "returns 13 for carriage return":
            expect(char_code("\r")).to_equal(13)

    context "edge cases":
        it "returns 0 for empty string":
            expect(char_code("")).to_equal(0)


# ============================================================================
# Test Group 2: string_from_code
# ============================================================================

describe "string_from_code":
    """
    ## string_from_code(code: i64) -> text

    Converts an ASCII code value to a single-character string.
    Tests cover representative codes and the fallback branch.
    """

    context "digits":
        it "returns '0' for 48":
            expect(string_from_code(48)).to_equal("0")

        it "returns '9' for 57":
            expect(string_from_code(57)).to_equal("9")

        it "returns '5' for 53":
            expect(string_from_code(53)).to_equal("5")

    context "uppercase letters":
        it "returns 'A' for 65":
            expect(string_from_code(65)).to_equal("A")

        it "returns 'Z' for 90":
            expect(string_from_code(90)).to_equal("Z")

        it "returns 'M' for 77":
            expect(string_from_code(77)).to_equal("M")

    context "lowercase letters":
        it "returns 'a' for 97":
            expect(string_from_code(97)).to_equal("a")

        it "returns 'z' for 122":
            expect(string_from_code(122)).to_equal("z")

        it "returns 'm' for 109":
            expect(string_from_code(109)).to_equal("m")

    context "special characters":
        it "returns space for 32":
            expect(string_from_code(32)).to_equal(" ")

        it "returns '_' for 95":
            expect(string_from_code(95)).to_equal("_")

        it "returns backslash for 92":
            expect(string_from_code(92)).to_equal("\\")

        it "returns '.' for 46":
            expect(string_from_code(46)).to_equal(".")

        it "returns '|' for 124":
            expect(string_from_code(124)).to_equal("|")

        it "returns '~' for 126":
            expect(string_from_code(126)).to_equal("~")

        it "returns '!' for 33":
            expect(string_from_code(33)).to_equal("!")

    context "whitespace":
        it "returns newline for 10":
            expect(string_from_code(10)).to_equal("\n")

        it "returns tab for 9":
            expect(string_from_code(9)).to_equal("\t")

        it "returns carriage return for 13":
            expect(string_from_code(13)).to_equal("\r")

    context "edge cases - fallback":
        it "returns empty string for 0":
            expect(string_from_code(0)).to_equal("")

        it "returns empty string for 255":
            expect(string_from_code(255)).to_equal("")

        it "returns empty string for negative code":
            expect(string_from_code(-1)).to_equal("")


# ============================================================================
# Test Group 3: char_code and string_from_code roundtrip
# ============================================================================

describe "char_code and string_from_code roundtrip":
    """
    ## Roundtrip verification

    Verifies that char_code and string_from_code are inverse operations
    for printable ASCII characters.
    """

    it "roundtrips digits":
        expect(string_from_code(char_code("0"))).to_equal("0")
        expect(string_from_code(char_code("9"))).to_equal("9")

    it "roundtrips uppercase":
        expect(string_from_code(char_code("A"))).to_equal("A")
        expect(string_from_code(char_code("Z"))).to_equal("Z")

    it "roundtrips lowercase":
        expect(string_from_code(char_code("a"))).to_equal("a")
        expect(string_from_code(char_code("z"))).to_equal("z")

    it "roundtrips special chars":
        expect(string_from_code(char_code("."))).to_equal(".")
        expect(string_from_code(char_code("_"))).to_equal("_")
        expect(string_from_code(char_code("@"))).to_equal("@")

    it "roundtrips whitespace":
        expect(string_from_code(char_code("\n"))).to_equal("\n")
        expect(string_from_code(char_code("\t"))).to_equal("\t")


# ============================================================================
# Test Group 4: is_digit_char
# ============================================================================

describe "is_digit_char":
    """
    ## is_digit_char(ch: text) -> bool

    Returns true for digits 0-9, false for everything else.
    Branch coverage: code >= 48 (true/false), code <= 57 (true/false).
    """

    context "true branch - digit characters":
        it "returns true for '0'":
            expect(is_digit_char("0")).to_equal(true)

        it "returns true for '9'":
            expect(is_digit_char("9")).to_equal(true)

        it "returns true for '5'":
            expect(is_digit_char("5")).to_equal(true)

        it "returns true for '1'":
            expect(is_digit_char("1")).to_equal(true)

    context "false branch - non-digit characters":
        it "returns false for 'a'":
            expect(is_digit_char("a")).to_equal(false)

        it "returns false for 'Z'":
            expect(is_digit_char("Z")).to_equal(false)

        it "returns false for space":
            expect(is_digit_char(" ")).to_equal(false)

        it "returns false for '.'":
            expect(is_digit_char(".")).to_equal(false)

        it "returns false for '_'":
            expect(is_digit_char("_")).to_equal(false)

        it "returns false for empty string":
            expect(is_digit_char("")).to_equal(false)

    context "boundary values":
        it "returns false for '/' (code 47, just below 0)":
            expect(is_digit_char("/")).to_equal(false)

        it "returns false for ':' (code 58, just above 9)":
            expect(is_digit_char(":")).to_equal(false)


# ============================================================================
# Test Group 5: is_alpha_char
# ============================================================================

describe "is_alpha_char":
    """
    ## is_alpha_char(ch: text) -> bool

    Returns true for a-z and A-Z, false otherwise.
    Branch coverage: is_upper (true/false), is_lower (true/false).
    """

    context "true branch - uppercase letters":
        it "returns true for 'A'":
            expect(is_alpha_char("A")).to_equal(true)

        it "returns true for 'Z'":
            expect(is_alpha_char("Z")).to_equal(true)

        it "returns true for 'M'":
            expect(is_alpha_char("M")).to_equal(true)

    context "true branch - lowercase letters":
        it "returns true for 'a'":
            expect(is_alpha_char("a")).to_equal(true)

        it "returns true for 'z'":
            expect(is_alpha_char("z")).to_equal(true)

        it "returns true for 'm'":
            expect(is_alpha_char("m")).to_equal(true)

    context "false branch - non-alphabetic characters":
        it "returns false for '0'":
            expect(is_alpha_char("0")).to_equal(false)

        it "returns false for '9'":
            expect(is_alpha_char("9")).to_equal(false)

        it "returns false for space":
            expect(is_alpha_char(" ")).to_equal(false)

        it "returns false for '_'":
            expect(is_alpha_char("_")).to_equal(false)

        it "returns false for '.'":
            expect(is_alpha_char(".")).to_equal(false)

        it "returns false for empty string":
            expect(is_alpha_char("")).to_equal(false)

    context "boundary values":
        it "returns false for '@' (code 64, just below A)":
            expect(is_alpha_char("@")).to_equal(false)

        it "returns false for '[' (code 91, just above Z)":
            expect(is_alpha_char("[")).to_equal(false)

        it "returns false for '`' (code 96, just below a)":
            expect(is_alpha_char("`")).to_equal(false)

        it "returns false for '{' (code 123, just above z)":
            expect(is_alpha_char("{")).to_equal(false)


