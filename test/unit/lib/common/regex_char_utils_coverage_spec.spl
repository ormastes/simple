describe "is_special_regex_char":
    """
    ## is_special_regex_char(ch: text) -> bool

    Returns true for regex metacharacters: . * + ? | ( ) [ ] { } ^ $ \\
    Branch coverage: each metachar true, non-metachar false.
    """

    context "true branch - all regex metacharacters":
        it "returns true for '.'":
            expect(is_special_regex_char(".")).to_equal(true)

        it "returns true for '*'":
            expect(is_special_regex_char("*")).to_equal(true)

        it "returns true for '+'":
            expect(is_special_regex_char("+")).to_equal(true)

        it "returns true for '?'":
            expect(is_special_regex_char("?")).to_equal(true)

        it "returns true for '|'":
            expect(is_special_regex_char("|")).to_equal(true)

        it "returns true for '('":
            expect(is_special_regex_char("(")).to_equal(true)

        it "returns true for ')'":
            expect(is_special_regex_char(")")).to_equal(true)

        it "returns true for '['":
            expect(is_special_regex_char("[")).to_equal(true)

        it "returns true for ']'":
            expect(is_special_regex_char("]")).to_equal(true)

        it "returns true for '{'":
            expect(is_special_regex_char("{")).to_equal(true)

        it "returns true for '}'":
            expect(is_special_regex_char("}")).to_equal(true)

        it "returns true for '^'":
            expect(is_special_regex_char("^")).to_equal(true)

        it "returns true for '$'":
            expect(is_special_regex_char("$")).to_equal(true)

        it "returns true for backslash":
            expect(is_special_regex_char("\\")).to_equal(true)

    context "false branch - non-metacharacters":
        it "returns false for 'a'":
            expect(is_special_regex_char("a")).to_equal(false)

        it "returns false for '0'":
            expect(is_special_regex_char("0")).to_equal(false)

        it "returns false for space":
            expect(is_special_regex_char(" ")).to_equal(false)

        it "returns false for '_'":
            expect(is_special_regex_char("_")).to_equal(false)

        it "returns false for '-'":
            expect(is_special_regex_char("-")).to_equal(false)

        it "returns false for '@'":
            expect(is_special_regex_char("@")).to_equal(false)

        it "returns false for empty string":
            expect(is_special_regex_char("")).to_equal(false)


# ============================================================================
# Test Group 11: escape_regex
# ============================================================================

describe "escape_regex":
    """
    ## escape_regex(text_str: text) -> text

    Escapes all special regex characters with a preceding backslash.
    Branch coverage: string with special chars, string without, empty string,
    mixed content.
    """

    context "strings with special characters":
        it "escapes a dot":
            expect(escape_regex(".")).to_equal("\\.")

        it "escapes a star":
            expect(escape_regex("*")).to_equal("\\*")

        it "escapes parentheses":
            expect(escape_regex("()")).to_equal("\\(\\)")

        it "escapes brackets":
            expect(escape_regex("[]")).to_equal("\\[\\]")

        it "escapes braces":
            expect(escape_regex("{}")).to_equal("\\{\\}")

        it "escapes caret and dollar":
            expect(escape_regex("^$")).to_equal("\\^\\$")

        it "escapes pipe":
            expect(escape_regex("|")).to_equal("\\|")

        it "escapes plus and question mark":
            expect(escape_regex("+?")).to_equal("\\+\\?")

        it "escapes backslash":
            expect(escape_regex("\\")).to_equal("\\\\")

    context "strings without special characters":
        it "returns plain text unchanged":
            expect(escape_regex("hello")).to_equal("hello")

        it "returns digits unchanged":
            expect(escape_regex("12345")).to_equal("12345")

    context "mixed content":
        it "escapes only special chars in mixed string":
            expect(escape_regex("a.b")).to_equal("a\\.b")

        it "escapes multiple special chars among normal text":
            expect(escape_regex("a+b*c")).to_equal("a\\+b\\*c")

    context "edge cases":
        it "returns empty string for empty input":
            expect(escape_regex("")).to_equal("")

        it "handles single normal character":
            expect(escape_regex("x")).to_equal("x")


# ============================================================================
# Test Group 12: unescape_regex
# ============================================================================

describe "unescape_regex":
    """
    ## unescape_regex(text_str: text) -> text

    Removes escape backslashes from regex string. Handles: normal chars,
    escaped chars, trailing backslash.
    Branch coverage: ch == backslash (true/false), i+1 < len (true/false).
    """

    context "escaped special characters":
        it "unescapes a dot":
            expect(unescape_regex("\\.")).to_equal(".")

        it "unescapes a star":
            expect(unescape_regex("\\*")).to_equal("*")

        it "unescapes parentheses":
            expect(unescape_regex("\\(\\)")).to_equal("()")

        it "unescapes brackets":
            expect(unescape_regex("\\[\\]")).to_equal("[]")

    context "normal characters pass through":
        it "returns plain text unchanged":
            expect(unescape_regex("hello")).to_equal("hello")

        it "returns digits unchanged":
            expect(unescape_regex("12345")).to_equal("12345")

    context "mixed content":
        it "unescapes only escaped chars in mixed string":
            expect(unescape_regex("a\\.b")).to_equal("a.b")

        it "handles multiple escaped chars":
            expect(unescape_regex("a\\+b\\*c")).to_equal("a+b*c")

    context "trailing backslash":
        it "preserves trailing backslash when no char follows":
            expect(unescape_regex("abc\\")).to_equal("abc\\")

        it "handles lone backslash":
            expect(unescape_regex("\\")).to_equal("\\")

    context "edge cases":
        it "returns empty string for empty input":
            expect(unescape_regex("")).to_equal("")

        it "unescapes escaped backslash":
            expect(unescape_regex("\\\\")).to_equal("\\")


# ============================================================================
# Test Group 13: expand_escape
# ============================================================================

describe "expand_escape":
    """
    ## expand_escape(esc: text) -> text

    Expands known escape sequence characters to their actual values.
    Branch coverage: each recognized escape, plus fallback for unknown.
    """

    context "literal escapes":
        it "expands 'n' to newline":
            expect(expand_escape("n")).to_equal("\n")

        it "expands 't' to tab":
            expect(expand_escape("t")).to_equal("\t")

        it "expands 'r' to carriage return":
            expect(expand_escape("r")).to_equal("\r")

    context "character class escapes":
        it "expands 'd' to digit class":
            expect(expand_escape("d")).to_equal("[0-9]")

        it "expands 'D' to non-digit class":
            expect(expand_escape("D")).to_equal("[^0-9]")

        it "expands 'w' to word class":
            expect(expand_escape("w")).to_equal("[a-zA-Z0-9_]")

        it "expands 'W' to non-word class":
            expect(expand_escape("W")).to_equal("[^a-zA-Z0-9_]")

        it "expands 's' to whitespace class":
            expect(expand_escape("s")).to_equal("[ \t\n\r]")

        it "expands 'S' to non-whitespace class":
            expect(expand_escape("S")).to_equal("[^ \t\n\r]")

    context "boundary escapes":
        it "expands 'b' to word boundary":
            expect(expand_escape("b")).to_equal("\\b")

        it "expands 'B' to non-word boundary":
            expect(expand_escape("B")).to_equal("\\B")

    context "fallback - unrecognized escapes":
        it "returns 'x' unchanged":
            expect(expand_escape("x")).to_equal("x")

        it "returns 'a' unchanged":
            expect(expand_escape("a")).to_equal("a")

        it "returns '.' unchanged":
            expect(expand_escape(".")).to_equal(".")

        it "returns empty string unchanged":
            expect(expand_escape("")).to_equal("")

        it "returns '1' unchanged":
            expect(expand_escape("1")).to_equal("1")


# ============================================================================
# Test Group 14: is_escape_char
# ============================================================================

describe "is_escape_char":
    """
    ## is_escape_char(ch: text) -> bool

    Returns true for characters that are recognized escape sequences.
    Branch coverage: each recognized char true, non-recognized false.
    """

    context "true branch - all recognized escape characters":
        it "returns true for 'n'":
            expect(is_escape_char("n")).to_equal(true)

        it "returns true for 't'":
            expect(is_escape_char("t")).to_equal(true)

        it "returns true for 'r'":
            expect(is_escape_char("r")).to_equal(true)

        it "returns true for 'd'":
            expect(is_escape_char("d")).to_equal(true)

        it "returns true for 'D'":
            expect(is_escape_char("D")).to_equal(true)

        it "returns true for 'w'":
            expect(is_escape_char("w")).to_equal(true)

        it "returns true for 'W'":
            expect(is_escape_char("W")).to_equal(true)

        it "returns true for 's'":
            expect(is_escape_char("s")).to_equal(true)

        it "returns true for 'S'":
            expect(is_escape_char("S")).to_equal(true)

        it "returns true for 'b'":
            expect(is_escape_char("b")).to_equal(true)

        it "returns true for 'B'":
            expect(is_escape_char("B")).to_equal(true)

    context "false branch - non-escape characters":
        it "returns false for 'a'":
            expect(is_escape_char("a")).to_equal(false)

        it "returns false for 'x'":
            expect(is_escape_char("x")).to_equal(false)

        it "returns false for '0'":
            expect(is_escape_char("0")).to_equal(false)

        it "returns false for '.'":
            expect(is_escape_char(".")).to_equal(false)

        it "returns false for empty string":
            expect(is_escape_char("")).to_equal(false)

        it "returns false for space":
            expect(is_escape_char(" ")).to_equal(false)


# ============================================================================
# Test Group 15: escape_regex and unescape_regex roundtrip
# ============================================================================

describe "escape and unescape roundtrip":
    """
    ## Roundtrip verification

    Verifies that escaping and then unescaping produces the original string.
    """

    it "roundtrips plain text":
        val original = "hello world"
        expect(unescape_regex(escape_regex(original))).to_equal(original)

    it "roundtrips string with dots":
        val original = "a.b.c"
        expect(unescape_regex(escape_regex(original))).to_equal(original)

    it "roundtrips string with all metacharacters":
        val original = ".*+?|()[]{}^$"
        expect(unescape_regex(escape_regex(original))).to_equal(original)

    it "roundtrips empty string":
        expect(unescape_regex(escape_regex(""))).to_equal("")

    it "roundtrips mixed content":
        val original = "foo(bar)+baz*"
        expect(unescape_regex(escape_regex(original))).to_equal(original)
