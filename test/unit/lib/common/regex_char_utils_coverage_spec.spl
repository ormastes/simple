        it "returns true for '9'":
            expect(is_hex_char("9")).to_equal(true)

        it "returns true for '5'":
            expect(is_hex_char("5")).to_equal(true)

    context "true via uppercase branch (A-F)":
        it "returns true for 'A'":
            expect(is_hex_char("A")).to_equal(true)

        it "returns true for 'F'":
            expect(is_hex_char("F")).to_equal(true)

        it "returns true for 'C'":
            expect(is_hex_char("C")).to_equal(true)

    context "true via lowercase branch (a-f)":
        it "returns true for 'a'":
            expect(is_hex_char("a")).to_equal(true)

        it "returns true for 'f'":
            expect(is_hex_char("f")).to_equal(true)

        it "returns true for 'c'":
            expect(is_hex_char("c")).to_equal(true)

    context "false branch - non-hex characters":
        it "returns false for 'g'":
            expect(is_hex_char("g")).to_equal(false)

        it "returns false for 'G'":
            expect(is_hex_char("G")).to_equal(false)

        it "returns false for 'z'":
            expect(is_hex_char("z")).to_equal(false)

        it "returns false for space":
            expect(is_hex_char(" ")).to_equal(false)

        it "returns false for '_'":
            expect(is_hex_char("_")).to_equal(false)

        it "returns false for empty string":
            expect(is_hex_char("")).to_equal(false)

    context "boundary values":
        it "returns false for '/' (code 47, just below 0)":
            expect(is_hex_char("/")).to_equal(false)

        it "returns false for ':' (code 58, just above 9)":
            expect(is_hex_char(":")).to_equal(false)

        it "returns false for '@' (code 64, just below A)":
            expect(is_hex_char("@")).to_equal(false)

        it "returns false for 'G' (code 71, just above F)":
            expect(is_hex_char("G")).to_equal(false)

        it "returns false for '`' (code 96, just below a)":
            expect(is_hex_char("`")).to_equal(false)

        it "returns false for 'g' (code 103, just above f)":
            expect(is_hex_char("g")).to_equal(false)


