# @covers src/lib/common/math_repr.spl 85%
"""
# Math Repr Coverage Specification

**Feature IDs:** #LIB-MATH-COV
**Category:** Stdlib
**Difficulty:** 2/5
**Status:** Implemented
**Requirements:** N/A
**Plan:** N/A
**Design:** N/A
**Research:** N/A

## Overview

Branch coverage tests for `std.math_repr` parser and renderers.
Split from math_coverage_spec.spl for memory. Tests to_text, to_debug,
to_pretty, to_md, render_latex_raw, and tokenizer/parser edge cases.

## Key Concepts

| Concept | Description |
|---------|-------------|
| math_repr | Parser + renderer: to_text, to_debug, to_pretty, to_md, render_latex_raw |
"""

use std.math_repr.{to_text, to_debug, to_pretty, to_md, render_latex_raw}

# ============================================================================
# 1. math_repr — to_text (Normalized plain text renderer)
# ============================================================================

describe "math_repr chained operations":
    """
    ## Chained Operations

    Exercises loop continuation in _parse_add and _parse_mul by using
    chained operators that force multiple iterations.
    """

    context "chained additions":
        it "triple addition exercises loop continuation":
            val result = to_text("a + b + c + d")
            expect result == "a + b + c + d"

        it "triple addition via debug":
            val result = to_debug("a + b + c + d")
            expect (result).contains("Add")

        it "addition then subtraction chain":
            val result = to_text("a + b - c + d")
            expect (result).contains("+")
            expect (result).contains("-")

        it "many additions via pretty":
            val result = to_pretty("a + b + c + d + e")
            expect (result).contains("+")

        it "many additions via latex":
            val result = render_latex_raw("a + b + c + d + e")
            expect (result).contains("+")

    context "chained multiplications":
        it "triple explicit mul":
            val result = to_text("a * b * c * d")
            expect (result).contains("*")

        it "triple division":
            val result = to_text("a / b / c")
            expect (result).contains("/")

        it "mixed mul and div":
            val result = to_text("a * b / c * d")
            expect (result).contains("*")
            expect (result).contains("/")

        it "chained implicit mul":
            val result = to_text("2x(y)")
            expect (result).contains("2")

    context "chained postfix operations":
        it "multiple subscripts":
            val result = to_text("a[i][j][k]")
            expect (result).contains("[")

        it "subscript then transpose then subscript":
            val result = to_text("A[i]'")
            expect (result).contains("A")


# ============================================================================
# 17. Tokenizer paths - ensure every operator char goes through tokenizer
# ============================================================================


describe "math_repr tokenizer operator paths":
    """
    ## Tokenizer Operator Paths

    Each operator character must be tokenized. This exercises the specific
    elif branches in _tokenize for each character type.
    """

    context "each operator individually":
        it "tokenizes plus only":
            val result = to_debug("1 + 2")
            expect result == "Add(Num(1), Num(2))"

        it "tokenizes minus only":
            val result = to_debug("1 - 2")
            expect result == "Sub(Num(1), Num(2))"

        it "tokenizes star only":
            val result = to_debug("1 * 2")
            expect result == "Mul(Num(1), Num(2))"

        it "tokenizes slash only":
            val result = to_debug("1 / 2")
            expect result == "Div(Num(1), Num(2))"

        it "tokenizes caret only":
            val result = to_debug("1^2")
            expect result == "Pow(Num(1), Num(2))"

        it "tokenizes apostrophe only":
            val result = to_debug("x'")
            expect (result).contains("Transpose")

        it "tokenizes open paren only":
            val result = to_debug("(x)")
            expect (result).contains("Group")

        it "tokenizes close paren":
            val result = to_debug("(1)")
            expect (result).contains("Group")

        it "tokenizes open bracket":
            val result = to_debug("x[1]")
            expect (result).contains("Sub")

        it "tokenizes close bracket":
            val result = to_debug("a[0]")
            expect (result).contains("Sub")

        it "tokenizes comma in args":
            val result = to_debug("f(1, 2)")
            expect (result).contains("Call")

    context "expressions with only division":
        it "division-only expression":
            val result = to_text("10 / 5")
            expect result == "10 / 5"

        it "division via pretty":
            val result = to_pretty("10 / 5")
            expect (result).contains("/")

        it "division via latex":
            val result = render_latex_raw("10 / 5")
            expect (result).contains("/")

    context "expressions with only parens and brackets":
        it "paren-only expression via text":
            val result = to_text("(1)")
            expect result == "(1)"

        it "bracket-only expression via text":
            val result = to_text("x[0]")
            expect result == "x[0]"


# ============================================================================
# 18. _parse_sum_call without comma and without range
# ============================================================================


describe "math_repr sum_call edge cases":
    """
    ## Sum Call Edge Cases

    Exercises edge cases in _parse_sum_call: missing comma,
    missing range operator, missing close paren.
    """

    context "sum without comma separator":
        it "sum without comma":
            val result = to_text("sum(i 1..n) i")
            expect (result).contains("i")

    context "sum without range dots":
        it "sum without range operator":
            val result = to_text("sum(i, 1 n) i")
            expect (result).contains("i")

    context "sum without closing paren":
        it "sum missing rparen":
            val result = to_text("sum(i, 1..n i")
            expect (result).contains("i")

    context "frac without comma":
        it "frac missing comma":
            val result = to_text("frac(a b)")
            expect (result).contains("a")

    context "frac without closing paren":
        it "frac missing rparen":
            val result = to_text("frac(a, b x")
            expect (result).contains("a")


# ============================================================================
# 19. _can_start_expr and _can_implicit_mul num path
# ============================================================================


describe "math_repr can_start_expr num path":
    """
    ## _can_start_expr Num Path

    The num branch in _can_start_expr returns true but is never the trigger
    for implicit multiplication (since _can_implicit_mul requires id or lparen).
    This exercises the num path specifically.
    """

    context "expression starting with number":
        it "number after operator uses can_start_expr num":
            val result = to_debug("x + 3")
            expect result == "Add(Id(x), Num(3))"

        it "number in complex expression":
            val result = to_debug("3 + 4 + 5")
            expect (result).contains("Add")

    context "can_implicit_mul false because num not id or lparen":
        it "number after number is not implicit mul":
            # "3 4" - the 4 can start expr (num) but implicit mul only for id/lparen
            # So "3" is parsed, "4" starts new expr context
            val result = to_text("3 + 4")
            expect result == "3 + 4"


# ============================================================================
# 20. _parse_primary fallback path
# ============================================================================


describe "math_repr parse_primary fallback":
    """
    ## Parse Primary Fallback

    When _parse_primary encounters an unexpected token (not num, id, lparen),
    it advances past it and returns an error node "?".
    """

    context "unexpected token triggers fallback":
        it "unexpected token at start":
            val result = to_text("]")
            expect (result).contains("?")

        it "unexpected rparen at start":
            val result = to_debug(")")
            expect (result).contains("Id(?)")

    context "identifier-like tokens with mixed chars":
        it "identifier with digits":
            val result = to_text("var123")
            expect result == "var123"


# ============================================================================
# 21. Malformed input for parser FALSE paths
# ============================================================================


describe "math_repr malformed input":
    """
    ## Malformed Input

    Tests missing brackets, parens, and operators to exercise the FALSE
    branches of parser guard checks (_peek_kind == "rbracket" etc).
    """

    context "missing close bracket in subscript":
        it "subscript without rbracket via text":
            val result = to_text("x[i")
            expect (result).contains("x")

        it "subscript without rbracket via debug":
            val result = to_debug("x[i")
            expect (result).contains("Sub")

        it "subscript without rbracket via pretty":
            val result = to_pretty("x[i")
            expect (result).contains("x")

        it "subscript without rbracket via latex":
            val result = render_latex_raw("x[i")
            expect (result).contains("x")

    context "missing close paren in function call":
        it "function call without rparen via text":
            val result = to_text("f(x")
            expect (result).contains("f")

        it "function call without rparen via debug":
            val result = to_debug("f(x")
            expect (result).contains("Call")

        it "function call without rparen via pretty":
            val result = to_pretty("f(x")
            expect (result).contains("f")

        it "function call without rparen via latex":
            val result = render_latex_raw("f(x")
            expect (result).contains("f")

    context "missing close paren in group":
        it "group without rparen via text":
            val result = to_text("(a + b")
            expect (result).contains("a")

        it "group without rparen via debug":
            val result = to_debug("(a + b")
            expect (result).contains("Group")

        it "group without rparen via pretty":
            val result = to_pretty("(a + b")
            expect (result).contains("a")

        it "group without rparen via latex":
            val result = render_latex_raw("(a + b")
            expect (result).contains("a")

    context "missing close paren in frac":
        it "frac without rparen":
            val result = to_text("frac(a, b")
            expect (result).contains("a")

    context "missing comma in sum":
        it "sum missing comma":
            val result = to_text("sum(i 1..10) i")
            expect (result).contains("i")

    context "missing range in sum":
        it "sum missing dotdot":
            val result = to_text("sum(i, 1 10) i")
            expect (result).contains("i")

    context "missing rparen in sum":
        it "sum missing rparen":
            val result = to_text("sum(i, 1..10 i")
            expect (result).contains("i")


# ============================================================================
# 22. Number tokenization edge cases for decimal/range boundary
# ============================================================================


describe "math_repr number tokenization edges":
    """
    ## Number Tokenization Edges

    Exercises the decimal dot and range boundary in number tokenization.
    Specifically: decimal number followed by ".." range should not consume
    the dots as decimal.
    """

    context "number-dot-dot boundary":
        it "integer before range is not decimal":
            val result = to_debug("sum(i, 5..10) i")
            expect (result).contains("Num(5)")
            expect (result).contains("Num(10)")

        it "decimal number in simple expression":
            val result = to_debug("3.14")
            expect result == "Num(3.14)"

        it "decimal followed by operator":
            val result = to_debug("3.14 + 1")
            expect (result).contains("Num(3.14)")

    context "single dot tokenization":
        it "dot between identifiers":
            val result = to_text("a.b")
            expect (result).contains("a")

        it "dot at end of input":
            val result = to_text("x.")
            expect (result).contains("x")

        it "standalone dot":
            val result = to_text(".")
            expect (result).contains("?")


# ============================================================================
# 23. _is_alpha underscore coverage
# ============================================================================


describe "math_repr underscore alpha coverage":
    """
    ## Underscore Alpha Coverage

    The underscore check in _is_alpha must evaluate to TRUE.
    """

    context "underscore as first alpha character":
        it "underscore-only identifier":
            # Underscore is alpha in _is_alpha; tokenized as identifier
            # But the output might strip leading underscore
            val result = to_text("_")
            expect (result).contains("?")

        it "underscore with trailing letters":
            # a_b is one identifier token since _ is alnum
            val result = to_text("a_b")
            expect (result).contains("a")

        it "underscore in middle of identifier":
            val result = to_text("x_y")
            expect (result).contains("x")


# ============================================================================
# 24. Intensive loop coverage for parse_add and tokenizer inner loops
# ============================================================================


describe "math_repr intensive loop coverage":
    """
    ## Intensive Loop Coverage

    Exercises inner loops many times to ensure loop continuation decisions
    are covered in both true and false directions.
    """

    context "long chained addition to exercise _parse_add loop":
        it "six-way addition":
            val result = to_text("a + b + c + d + e + f")
            expect (result).contains("a")
            expect (result).contains("f")

        it "addition and subtraction interleaved":
            val result = to_text("a + b - c + d - e + f")
            expect (result).contains("a")

        it "six-way via debug":
            val result = to_debug("a + b + c + d + e + f")
            expect (result).contains("Add")

    context "long chained mul to exercise _parse_mul loop":
        it "six-way multiplication":
            val result = to_text("a * b * c * d * e * f")
            expect (result).contains("*")

        it "six-way division":
            val result = to_text("a / b / c / d / e / f")
            expect (result).contains("/")

    context "large number for digit loop":
        it "ten-digit number exercises inner digit loop":
            val result = to_text("1234567890")
            expect result == "1234567890"

        it "number with many decimal places":
            val result = to_text("3.14159265")
            expect result == "3.14159265"

    context "long identifier for alnum loop":
        it "long identifier exercises inner alnum loop":
            val result = to_text("abcdefghijklmnop")
            expect result == "abcdefghijklmnop"

    context "many subscripts for postfix loop":
        it "four chained subscripts":
            val result = to_text("a[i][j][k][l]")
            expect (result).contains("[")

    context "many function args for comma loop":
        it "five-arg function":
            val result = to_text("f(a, b, c, d, e)")
            expect (result).contains("f")
            expect (result).contains("e")

    context "deeply nested parens":
        it "triple nested parens":
            val result = to_text("(((x)))")
            expect (result).contains("x")

    context "expression with many different token types":
        it "all token types in one expression":
            val result = to_text("f(a + b * c / d, e^2, g[i])")
            expect (result).contains("f")
            expect (result).contains("g")

    context "number then range dots in sum context":
        it "two-digit number before range":
            val result = to_debug("sum(i, 10..20) i")
            expect (result).contains("Num(10)")
            expect (result).contains("Num(20)")

        it "single digit before range":
            val result = to_debug("sum(i, 1..9) i")
            expect (result).contains("Num(1)")
            expect (result).contains("Num(9)")

    context "number followed by number for can_start_expr num path":
        it "two numbers separated by space":
            # "3 4" - first parsed as Num(3), then _parse_mul checks for implicit mul
            # _can_implicit_mul calls _can_start_expr which hits pk=="num" TRUE
            # then _can_implicit_mul checks pk=="id" (false), pk=="lparen" (false)
            # so implicit mul doesn't happen, "4" is left unconsumed
            val result = to_debug("3 4")
            expect (result).contains("Num(3)")

        it "number then number then id":
            val result = to_debug("3 4 x")
            expect (result).contains("Num(3)")

        it "number after paren group forces can_start_expr":
            val result = to_debug("(a) 5")
            expect (result).contains("Group")

    context "single-char inputs for tokenizer path isolation":
        it "only lparen":
            val result = to_text("(")
            expect (result).contains("?")

        it "only rparen":
            val result = to_text(")")
            expect (result).contains("?")

        it "only lbracket":
            val result = to_text("[")
            expect (result).contains("?")

        it "only rbracket":
            val result = to_text("]")
            expect (result).contains("?")

        it "only comma":
            val result = to_text(",")
            expect (result).contains("?")

        it "only slash":
            val result = to_text("/")
            expect (result).contains("?")

        it "only star":
            val result = to_text("*")
            expect (result).contains("?")

        it "only caret":
            val result = to_text("^")
            expect (result).contains("?")

        it "only apostrophe":
            val result = to_text("'")
            expect (result).contains("?")

    context "two-char inputs: operator then identifier":
        it "lparen then x":
            val result = to_text("(x")
            expect (result).contains("x")

        it "slash then x":
            val result = to_text("/x")
            expect (result).contains("x")

        it "comma then x":
            val result = to_text(",x")
            expect (result).contains("x")