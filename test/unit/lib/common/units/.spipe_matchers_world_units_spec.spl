use std.common.units.model.world_units.{catalog_has_required_world_units, exact_ratio, exact_ratio_div, exact_ratio_mul, exact_ratio_normalize, is_prefix_blocked, kilometre_per_hour_expression, kilometre_per_hour_factor_to_metre_per_second, mole_per_litre_expression, unit_expression_div, unit_expression_factor_count, unit_expression_factor_exponent, unit_expression_from_base, unit_expression_mul}

describe "World unit model":
    it "keeps km/h conversion exact":
        val factor = kilometre_per_hour_factor_to_metre_per_second()
        expect factor.numerator == 5
        expect factor.denominator == 18

    it "blocks prefixes for accepted non-SI time and calendar units":
        expect is_prefix_blocked("h") == true
        expect is_prefix_blocked("d") == true
        expect is_prefix_blocked("a_g") == true
        expect is_prefix_blocked("m") == false

    it "constructs exact ratios":
        val ratio = exact_ratio(1024, 1)
        expect ratio.numerator == 1024
        expect ratio.denominator == 1

    it "normalizes exact ratios":
        val ratio = exact_ratio_normalize(exact_ratio(10, -20))
        expect ratio.numerator == -1
        expect ratio.denominator == 2

    it "multiplies and divides exact ratios":
        val multiplied = exact_ratio_mul(exact_ratio(2, 3), exact_ratio(9, 4))
        val divided = exact_ratio_div(exact_ratio(5, 18), exact_ratio(10, 3))
        expect multiplied.numerator == 3
        expect multiplied.denominator == 2
        expect divided.numerator == 1
        expect divided.denominator == 12

    it "normalizes derived unit expressions exactly":
        val expression = kilometre_per_hour_expression()
        expect expression.scale.numerator == 5
        expect expression.scale.denominator == 18
        expect unit_expression_factor_exponent(expression, "metre") == 1
        expect unit_expression_factor_exponent(expression, "second") == -1

    it "cancels matching unit factors":
        val expression = unit_expression_div(
            unit_expression_mul(unit_expression_from_base("metre"), unit_expression_from_base("second")),
            unit_expression_from_base("metre")
        )
        expect unit_expression_factor_count(expression) == 1
        expect unit_expression_factor_exponent(expression, "second") == 1
        expect unit_expression_factor_exponent(expression, "metre") == 0

    it "represents amount concentration through litre composition":
        val expression = mole_per_litre_expression()
        expect expression.scale.numerator == 1000
        expect expression.scale.denominator == 1
        expect unit_expression_factor_exponent(expression, "mole") == 1
        expect unit_expression_factor_exponent(expression, "metre") == -3

    it "pins required catalog identities":
        val catalog = file_read("src/lib/common/units/catalog/world_units_v1.sdn")
        expect catalog_has_required_world_units(catalog) == true