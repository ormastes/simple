use std.common.units.engine.unit_expr.{format_unit_expression, parse_unit_expression}
use std.common.units.model.world_units.{unit_expression_factor_exponent}

describe "World unit expression engine":
    it "parses km per hour exactly":
        val parsed = parse_unit_expression("km/h")
        expect parsed.ok == true
        expect parsed.expression.scale.numerator == 5
        expect parsed.expression.scale.denominator == 18
        expect unit_expression_factor_exponent(parsed.expression, "metre") == 1
        expect unit_expression_factor_exponent(parsed.expression, "second") == -1

    it "accepts canonical aliases without changing canonical formatting":
        val parsed = parse_unit_expression("kmph")
        expect parsed.ok == true
        expect format_unit_expression(parsed.expression) == "km/h"

    it "parses chemistry concentration aliases":
        val parsed = parse_unit_expression("M")
        expect parsed.ok == true
        expect parsed.expression.scale.numerator == 1000
        expect unit_expression_factor_exponent(parsed.expression, "mole") == 1
        expect unit_expression_factor_exponent(parsed.expression, "metre") == -3
        expect format_unit_expression(parsed.expression) == "mol/L"

    it "reports unsupported expressions":
        val parsed = parse_unit_expression("USD/h")
        expect parsed.ok == false
        expect (parsed.error).contains("unknown unit expression")