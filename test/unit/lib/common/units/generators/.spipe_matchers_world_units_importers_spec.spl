use std.common.units.generators.world_units_importers.{import_all_world_unit_seed_rows, imported_rows_have_unique_ids, imported_rows_to_sdn}

describe "World unit importers":
    it "imports required standard-backed seed rows":
        val rows = import_all_world_unit_seed_rows()
        val sdn = imported_rows_to_sdn(rows)
        expect rows.len() == 10
        expect imported_rows_have_unique_ids(rows) == true
        expect (sdn).contains("source: \"UCUM\"")
        expect (sdn).contains("source: \"ISO 4217/SIX\"")
        expect (sdn).contains("source: \"UNECE Rec 20\"")
        expect (sdn).contains("source: \"IUPAC Gold Book\"")
        expect (sdn).contains("source: \"IEC 80000-13\"")
        expect (sdn).contains("symbol: \"KiB\"")
        expect (sdn).contains("code: \"DZN\"")
        expect (sdn).contains("code: \"840\"")