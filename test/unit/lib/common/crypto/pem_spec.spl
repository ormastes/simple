# @cover src/lib/common/crypto/pem.spl 80%
"""
# PEM Parser Specification

**Feature IDs:** N/A
**Category:** Stdlib
**Difficulty:** 2/5
**Status:** Implemented
**Requirements:** N/A
**Plan:** N/A
**Design:** N/A
**Research:** N/A

## Overview

Validates the PEM parser module that parses PEM-encoded certificates and
private keys into DER bytes. Tests cover single blocks, certificate chains,
private key extraction, is_pem detection, and error/edge cases.

NOTE: interpreter-mode runner verifies file loading and spec structure only.
Field-value assertions fire under compiled/native mode
(see .claude/memory/feedback_compile_mode_false_greens.md).
"""

use std.spipe.*
use std.crypto.pem.{parse_pem, parse_pem_certs, parse_pem_key, is_pem, PemBlock}

# ============================================================================
# Module-level helpers — avoid it-block var-mutation footgun
# (see .claude/memory/feedback_it_block_var_mutation.md)
# ============================================================================

fn _single_cert_pem() -> text:
    "-----BEGIN CERTIFICATE-----\nMIIBYTCCAQagAwIBAgIBATAKBggqhkjOPQQDAgAPMQ0wCwYDVQQDDAR0ZXN0MB4X\nDTI2MDUwMjIyNTEzOVoXDTM2MDQyOTIyNTEzOVowDzENMAsGA1UEAwwEdGVzdDBZ\nMBMGByqGSM49AgEGCCqGSM49AwEHA0IABLFkg2iiHTxYnlFgbYUcZl9lMhAKgyZR\nAW3Li0yBgKo8/sdu5nXwZCifgcdrBs6LrSQ9ig3/rEJKC/LgszqjUzBRMB0GA1Ud\nDgQWBBQyEGTCGAtnHQd23mYjiSDYV0166jAfBgNVHSMEGDAWgBQyEGTCGAtnHQd2\n3mYjiSDYV0166jAPBgNVHRMBAf8EBTADAQHAMAoGCCqGSM49BAMDADFGMBEGDQIJBQ\nHANSCKUbFqHb8BLt2OsmzqF+1KoFPUFJXGgY9Ah0gIhAJBW5SluKy4r3ldbhb0sOd\nKAgr+A/8ewumr1foX/ta8w\n-----END CERTIFICATE-----\n"

fn _chain_pem() -> text:
    "-----BEGIN CERTIFICATE-----\nMIIBYTCCAQag\n-----END CERTIFICATE-----\n-----BEGIN CERTIFICATE-----\nMIIDXTCCAkWg\n-----END CERTIFICATE-----\n"

fn _key_pem() -> text:
    "-----BEGIN PRIVATE KEY-----\nMIGHAgEAMBMGByqGSM49AgEGCCqGSM49AwEH\n-----END PRIVATE KEY-----\n"

fn _rsa_key_pem() -> text:
    "-----BEGIN RSA PRIVATE KEY-----\nMIIEpAIBAAKCAQEA0Z3VS5JJcds3xfn/ygWe\n-----END RSA PRIVATE KEY-----\n"

fn _ec_key_pem() -> text:
    "-----BEGIN EC PRIVATE KEY-----\nMHQCAQEEIBkg4LVWM9nuwNSk3yByxZpYRTBn\n-----END EC PRIVATE KEY-----\n"

fn _mixed_pem() -> text:
    "-----BEGIN CERTIFICATE-----\nMIIBYTCCAQag\n-----END CERTIFICATE-----\n-----BEGIN PRIVATE KEY-----\nMIGHAgEAMBMG\n-----END PRIVATE KEY-----\n-----BEGIN CERTIFICATE-----\nMIIDXTCCAkWg\n-----END CERTIFICATE-----\n"

fn _parse_single_cert() -> [PemBlock]:
    parse_pem(_single_cert_pem())

fn _parse_chain() -> [PemBlock]:
    parse_pem(_chain_pem())

fn _parse_mixed() -> [PemBlock]:
    parse_pem(_mixed_pem())

# ============================================================================
# Single certificate parsing
# ============================================================================

describe "parse_pem — single certificate block":

    it "returns exactly one block for a single certificate PEM":
        val blocks = _parse_single_cert()
        expect(blocks.len()).to_equal(1)

    it "sets label to CERTIFICATE":
        val blocks = _parse_single_cert()
        expect(blocks[0].label).to_equal("CERTIFICATE")

    it "produces non-empty DER bytes":
        val blocks = _parse_single_cert()
        expect(blocks[0].der_bytes.len()).to_be_greater_than(0)

    it "DER bytes start with SEQUENCE tag 0x30":
        val blocks = _parse_single_cert()
        expect(blocks[0].der_bytes[0u64].to_i64()).to_equal(48)

# ============================================================================
# Certificate chain parsing
# ============================================================================

describe "parse_pem — certificate chain":

    it "returns two blocks for a two-cert chain":
        val blocks = _parse_chain()
        expect(blocks.len()).to_equal(2)

    it "both blocks have label CERTIFICATE":
        val blocks = _parse_chain()
        expect(blocks[0].label).to_equal("CERTIFICATE")
        expect(blocks[1].label).to_equal("CERTIFICATE")

    it "both blocks have non-empty DER bytes":
        val blocks = _parse_chain()
        expect(blocks[0].der_bytes.len()).to_be_greater_than(0)
        expect(blocks[1].der_bytes.len()).to_be_greater_than(0)

# ============================================================================
# Private key parsing
# ============================================================================

describe "parse_pem_key — private key extraction":

    it "finds PRIVATE KEY block":
        val key = parse_pem_key(_key_pem())
        expect(key.label).to_equal("PRIVATE KEY")

    it "finds RSA PRIVATE KEY block":
        val key = parse_pem_key(_rsa_key_pem())
        expect(key.label).to_equal("RSA PRIVATE KEY")

    it "finds EC PRIVATE KEY block":
        val key = parse_pem_key(_ec_key_pem())
        expect(key.label).to_equal("EC PRIVATE KEY")

    it "key DER bytes are non-empty":
        val key = parse_pem_key(_key_pem())
        expect(key.der_bytes.len()).to_be_greater_than(0)

    it "returns empty label when no key found":
        val key = parse_pem_key(_single_cert_pem())
        expect(key.label).to_equal("")

# ============================================================================
# parse_pem_certs — certificate-only filter
# ============================================================================

describe "parse_pem_certs — filter certificates from mixed PEM":

    it "returns only certificate blocks from mixed PEM":
        val certs = parse_pem_certs(_mixed_pem())
        expect(certs.len()).to_equal(2)

    it "all returned blocks have label CERTIFICATE":
        val certs = parse_pem_certs(_mixed_pem())
        expect(certs[0].label).to_equal("CERTIFICATE")
        expect(certs[1].label).to_equal("CERTIFICATE")

# ============================================================================
# Mixed PEM parsing
# ============================================================================

describe "parse_pem — mixed blocks":

    it "returns three blocks for cert+key+cert PEM":
        val blocks = _parse_mixed()
        expect(blocks.len()).to_equal(3)

    it "first block is CERTIFICATE":
        val blocks = _parse_mixed()
        expect(blocks[0].label).to_equal("CERTIFICATE")

    it "second block is PRIVATE KEY":
        val blocks = _parse_mixed()
        expect(blocks[1].label).to_equal("PRIVATE KEY")

    it "third block is CERTIFICATE":
        val blocks = _parse_mixed()
        expect(blocks[2].label).to_equal("CERTIFICATE")

# ============================================================================
# is_pem detection
# ============================================================================

describe "is_pem — PEM format detection":

    it "returns true for valid PEM text":
        expect(is_pem(_single_cert_pem())).to_equal(true)

    it "returns true for key PEM text":
        expect(is_pem(_key_pem())).to_equal(true)

    it "returns false for plain text":
        expect(is_pem("not pem data")).to_equal(false)

    it "returns false for empty string":
        expect(is_pem("")).to_equal(false)

    it "returns false for partial marker":
        expect(is_pem("-----BEGIN")).to_equal(false)

# ============================================================================
# Edge cases and error handling
# ============================================================================

describe "parse_pem — edge cases":

    it "returns empty list for empty string":
        val blocks = parse_pem("")
        expect(blocks.len()).to_equal(0)

    it "returns empty list for non-PEM text":
        val blocks = parse_pem("just some random text without markers")
        expect(blocks.len()).to_equal(0)

    it "returns empty list for incomplete BEGIN marker":
        val blocks = parse_pem("-----BEGIN CERTIFICATE-----\ndata without end")
        expect(blocks.len()).to_equal(0)

    it "handles PEM with extra whitespace in body":
        val pem = "-----BEGIN TEST-----\n  SGVsbG8=  \n-----END TEST-----\n"
        val blocks = parse_pem(pem)
        expect(blocks.len()).to_equal(1)
        expect(blocks[0].label).to_equal("TEST")

    it "handles PEM with no newlines in body":
        val pem = "-----BEGIN TEST-----SGVsbG8=-----END TEST-----"
        val blocks = parse_pem(pem)
        expect(blocks.len()).to_equal(1)
        expect(blocks[0].label).to_equal("TEST")
