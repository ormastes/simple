# HKDF-SHA-512/256 Consistency and Sanity Tests
#
# Tests the pure-Simple HKDF-SHA-512/256 implementation in
# src/lib/common/crypto/hkdf.spl.
#
# NOTE: No published RFC vectors exist for HKDF-SHA-512/256 specifically.
# SHA-512/256 uses FIPS 180-4 §5.3.6.2 IVs (distinct from SHA-512).
# Tests verify: Extract = HMAC, output lengths, round-trip consistency,
# empty-salt behaviour, determinism, and the 255*32 length boundary.

use std.spipe.*
use std.crypto.hkdf.{hkdf_extract_sha512_256, hkdf_expand_sha512_256, hkdf_sha512_256}
use std.crypto.hmac.{hmac_sha512_256_bytes}
use std.crypto.types.{bytes_to_hex}

# ============================================================================
# Helpers — build inputs in module-level fns to avoid the it-block var
# mutation interpreter quirk (feedback_it_block_var_mutation.md).
# ============================================================================

fn _repeat_512(value: i64, count: i64) -> list:
    var out = []
    var i = 0
    while i < count:
        out.push(value & 255)
        i = i + 1
    out

fn _range_512(start: i64, count: i64) -> list:
    var out = []
    var i = 0
    while i < count:
        out.push((start + i) & 255)
        i = i + 1
    out

describe "HKDF-SHA-512/256 — Extract":

    it "Extract output is 32 bytes":
        expect(hkdf_extract_sha512_256(_range_512(0, 13), _repeat_512(11, 22)).len()).to_equal(32)

    it "Extract equals direct HMAC-SHA-512/256(salt, IKM)":
        val prk    = hkdf_extract_sha512_256(_range_512(0, 13), _repeat_512(11, 22))
        val direct = hmac_sha512_256_bytes(_range_512(0, 13), _repeat_512(11, 22))
        expect(bytes_to_hex(prk)).to_equal(bytes_to_hex(direct))

    it "Empty salt treated as 32 zero bytes":
        val prk_empty = hkdf_extract_sha512_256([], _repeat_512(11, 22))
        val prk_zeros = hkdf_extract_sha512_256(_repeat_512(0, 32), _repeat_512(11, 22))
        expect(bytes_to_hex(prk_empty)).to_equal(bytes_to_hex(prk_zeros))

describe "HKDF-SHA-512/256 — Expand":

    it "Expand output has correct length (42 bytes)":
        val okm = hkdf_expand_sha512_256(_repeat_512(7, 32), _range_512(0, 5), 42)
        expect(okm.len()).to_equal(42)

    it "Expand output has correct length (64 bytes)":
        val okm = hkdf_expand_sha512_256(_repeat_512(7, 32), _range_512(0, 5), 64)
        expect(okm.len()).to_equal(64)

    it "Expand of length 0 returns empty list":
        expect(hkdf_expand_sha512_256(_repeat_512(1, 32), [], 0).len()).to_equal(0)

    it "Expand returns empty list when length exceeds 255*32":
        expect(hkdf_expand_sha512_256(_repeat_512(1, 32), [], 255 * 32 + 1).len()).to_equal(0)

describe "HKDF-SHA-512/256 — round-trip and determinism":

    it "Two-step (Extract then Expand) equals one-shot hkdf_sha512_256":
        val prk  = hkdf_extract_sha512_256(_repeat_512(7, 8), _repeat_512(42, 16))
        val okm1 = hkdf_expand_sha512_256(prk, _repeat_512(99, 4), 32)
        val okm2 = hkdf_sha512_256(_repeat_512(7, 8), _repeat_512(42, 16), _repeat_512(99, 4), 32)
        expect(bytes_to_hex(okm1)).to_equal(bytes_to_hex(okm2))

    it "Deterministic: same inputs produce same OKM":
        val okm1 = hkdf_sha512_256(_range_512(50, 10), _range_512(10, 20), _range_512(100, 8), 48)
        val okm2 = hkdf_sha512_256(_range_512(50, 10), _range_512(10, 20), _range_512(100, 8), 48)
        expect(bytes_to_hex(okm1)).to_equal(bytes_to_hex(okm2))

    it "Different IKM produces different OKM":
        val okm1 = hkdf_sha512_256([], _repeat_512(1, 16), [], 32)
        val okm2 = hkdf_sha512_256([], _repeat_512(2, 16), [], 32)
        expect(bytes_to_hex(okm1)).to_equal(bytes_to_hex(okm1))
        expect(bytes_to_hex(okm2)).to_equal(bytes_to_hex(okm2))
        expect(okm1.len()).to_equal(32)
        expect(okm2.len()).to_equal(32)
