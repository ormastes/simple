# HKDF-SHA-1 Reference Vectors (RFC 5869 §A.4-§A.7)
#
# Tests the pure-Simple HKDF-SHA-1 implementation in
# src/lib/common/crypto/hkdf.spl against RFC 5869 Appendix A.4 - A.7.
#
# RFC 5869 specifies four HKDF-SHA-1 test cases:
#   A.4 — basic, salt+info+L=42                       (PRK=9b6c..., OKM=085a...)
#   A.5 — long IKM/salt/info, L=82                    (PRK=8ada..., OKM=0bd7...)
#   A.6 — empty salt and info, L=42                   (PRK=da8c..., OKM=0ac1...)
#   A.7 — explicit 20-byte zero salt, empty info, L=42 (PRK=2adc..., OKM=2c91...)
#
# These complete the SHA family alongside hkdf_sha256/384/512 (already in tree).
#
# WARNING: SHA-1 is cryptographically broken for collision resistance.
# HKDF-SHA-1 retains PRF strength under current best public attacks but
# should be used only for legacy interop (TLS 1.2 PRF, RFC 6070 PBKDF2,
# legacy IKEv2 PRF profiles).

use std.spipe.*
use std.crypto.hkdf.{hkdf_extract_sha1, hkdf_expand_sha1, hkdf_sha1}
use std.crypto.types.{bytes_to_hex}

# ============================================================================
# Helpers — input builders in module-level fns to avoid the it-block var
# mutation interpreter quirk (feedback_it_block_var_mutation.md).
# ============================================================================

# Bytes 0x00..0x4f (80 bytes) — RFC 5869 §A.5 IKM
fn _a5_ikm() -> list:
    var out = []
    var i = 0
    while i < 80:
        out.push(i)
        i = i + 1
    out

# Bytes 0x60..0xaf (80 bytes) — RFC 5869 §A.5 salt
fn _a5_salt() -> list:
    var out = []
    var i = 0x60
    while i <= 0xaf:
        out.push(i)
        i = i + 1
    out

# Bytes 0xb0..0xff (80 bytes) — RFC 5869 §A.5 info
fn _a5_info() -> list:
    var out = []
    var i = 0xb0
    while i <= 0xff:
        out.push(i)
        i = i + 1
    out

# 22 copies of 0x0b — RFC 5869 §A.4 / §A.6 IKM
fn _ikm_22_0b() -> list:
    var out = []
    var i = 0
    while i < 22:
        out.push(0x0b)
        i = i + 1
    out

# 22 copies of 0x0c — RFC 5869 §A.7 IKM
fn _ikm_22_0c() -> list:
    var out = []
    var i = 0
    while i < 22:
        out.push(0x0c)
        i = i + 1
    out

# 20-byte zero salt — RFC 5869 §A.7
fn _zeros_20() -> list:
    var out = []
    var i = 0
    while i < 20:
        out.push(0)
        i = i + 1
    out

# ============================================================================
# RFC 5869 §A.4 — basic case
# ============================================================================

describe "HKDF-SHA-1 — RFC 5869 §A.4 (basic)":

    val _ikm = _ikm_22_0b()
    # NOTE: bare lists are at module-level only; build inputs in helpers above.

    it "Extract PRK = 9b6c18c432a7bf8f0e71c8eb88f4b30baa2ba243":
        # salt = 0x000102030405060708090a0b0c (13 bytes)
        # ikm  = 22 * 0x0b
        val salt = [0x00, 0x01, 0x02, 0x03, 0x04, 0x05, 0x06, 0x07, 0x08, 0x09, 0x0a, 0x0b, 0x0c]
        expect(bytes_to_hex(hkdf_extract_sha1(salt, _ikm_22_0b()))).to_equal(
            "9b6c18c432a7bf8f0e71c8eb88f4b30baa2ba243"
        )

    it "Expand OKM(L=42) = 085a01ea1b10f36933068b56efa5ad81a4f14b822f5b091568a9cdd4f155fda2c22e422478d305f3f896":
        # info = 0xf0f1f2f3f4f5f6f7f8f9 (10 bytes), L = 42
        val salt = [0x00, 0x01, 0x02, 0x03, 0x04, 0x05, 0x06, 0x07, 0x08, 0x09, 0x0a, 0x0b, 0x0c]
        val info = [0xf0, 0xf1, 0xf2, 0xf3, 0xf4, 0xf5, 0xf6, 0xf7, 0xf8, 0xf9]
        expect(bytes_to_hex(hkdf_sha1(salt, _ikm_22_0b(), info, 42))).to_equal(
            "085a01ea1b10f36933068b56efa5ad81a4f14b822f5b091568a9cdd4f155fda2c22e422478d305f3f896"
        )

# ============================================================================
# RFC 5869 §A.5 — long IKM/salt/info, L=82
# ============================================================================

describe "HKDF-SHA-1 — RFC 5869 §A.5 (long inputs)":

    it "Extract PRK = 8adae09a2a307059478d309b26c4115a224cfaf6":
        expect(bytes_to_hex(hkdf_extract_sha1(_a5_salt(), _a5_ikm()))).to_equal(
            "8adae09a2a307059478d309b26c4115a224cfaf6"
        )

    it "Expand OKM(L=82) matches RFC 5869 §A.5":
        expect(bytes_to_hex(hkdf_sha1(_a5_salt(), _a5_ikm(), _a5_info(), 82))).to_equal(
            "0bd770a74d1160f7c9f12cd5912a06ebff6adcae899d92191fe4305673ba2ffe8fa3f1a4e5ad79f3f334b3b202b2173c486ea37ce3d397ed034c7f9dfeb15c5e927336d0441f4c4300e2cff0d0900b52d3b4"
        )

# ============================================================================
# RFC 5869 §A.6 — empty salt and info
# ============================================================================

describe "HKDF-SHA-1 — RFC 5869 §A.6 (empty salt and info)":

    it "Extract PRK with empty salt = da8c8a73c7fa77288ec6f5e7c297786aa0d32d01":
        # Empty salt -> HashLen (20) zero bytes per RFC 5869 §2.2
        expect(bytes_to_hex(hkdf_extract_sha1([], _ikm_22_0b()))).to_equal(
            "da8c8a73c7fa77288ec6f5e7c297786aa0d32d01"
        )

    it "Expand OKM(L=42) = 0ac1af7002b3d761d1e55298da9d0506b9ae52057220a306e07b6b87e8df21d0ea00033de03984d34918":
        expect(bytes_to_hex(hkdf_sha1([], _ikm_22_0b(), [], 42))).to_equal(
            "0ac1af7002b3d761d1e55298da9d0506b9ae52057220a306e07b6b87e8df21d0ea00033de03984d34918"
        )

# ============================================================================
# RFC 5869 §A.7 — explicit 20-byte zero salt, empty info
# ============================================================================

describe "HKDF-SHA-1 — RFC 5869 §A.7 (explicit zero salt)":

    it "Extract PRK = 2adccada18779e7c2077ad2eb19d3f3e731385dd":
        expect(bytes_to_hex(hkdf_extract_sha1(_zeros_20(), _ikm_22_0c()))).to_equal(
            "2adccada18779e7c2077ad2eb19d3f3e731385dd"
        )

    it "Expand OKM(L=42) = 2c91117204d745f3500d636a62f64f0ab3bae548aa53d423b0d1f27ebba6f5e5673a081d70cce7acfc48":
        expect(bytes_to_hex(hkdf_sha1(_zeros_20(), _ikm_22_0c(), [], 42))).to_equal(
            "2c91117204d745f3500d636a62f64f0ab3bae548aa53d423b0d1f27ebba6f5e5673a081d70cce7acfc48"
        )

# ============================================================================
# Round-trip and boundaries
# ============================================================================

describe "HKDF-SHA-1 round-trip and boundaries":

    it "Two-step (Extract then Expand) equals combined hkdf_sha1":
        val salt = [0x00, 0x01, 0x02, 0x03, 0x04, 0x05, 0x06, 0x07, 0x08, 0x09, 0x0a, 0x0b, 0x0c]
        val info = [0xf0, 0xf1, 0xf2, 0xf3, 0xf4, 0xf5, 0xf6, 0xf7, 0xf8, 0xf9]
        val prk = hkdf_extract_sha1(salt, _ikm_22_0b())
        val two_step = hkdf_expand_sha1(prk, info, 42)
        val combined = hkdf_sha1(salt, _ikm_22_0b(), info, 42)
        expect(bytes_to_hex(two_step)).to_equal(bytes_to_hex(combined))

    it "Extract PRK is exactly 20 bytes (SHA-1 HashLen)":
        expect(hkdf_extract_sha1([], _ikm_22_0b()).len()).to_equal(20)

    it "L=0 returns empty list":
        val salt = [0x00, 0x01, 0x02, 0x03, 0x04, 0x05, 0x06, 0x07, 0x08, 0x09, 0x0a, 0x0b, 0x0c]
        val info = [0xf0, 0xf1, 0xf2, 0xf3, 0xf4, 0xf5, 0xf6, 0xf7, 0xf8, 0xf9]
        expect(hkdf_sha1(salt, _ikm_22_0b(), info, 0).len()).to_equal(0)

    it "L=1 returns exactly 1 byte":
        val salt = [0x00, 0x01, 0x02, 0x03, 0x04, 0x05, 0x06, 0x07, 0x08, 0x09, 0x0a, 0x0b, 0x0c]
        val info = [0xf0, 0xf1, 0xf2, 0xf3, 0xf4, 0xf5, 0xf6, 0xf7, 0xf8, 0xf9]
        expect(hkdf_sha1(salt, _ikm_22_0b(), info, 1).len()).to_equal(1)

    it "L exceeding 255*20 (5100) returns empty list":
        val salt = [0x00, 0x01, 0x02, 0x03, 0x04, 0x05, 0x06, 0x07, 0x08, 0x09, 0x0a, 0x0b, 0x0c]
        val info = [0xf0, 0xf1, 0xf2, 0xf3, 0xf4, 0xf5, 0xf6, 0xf7, 0xf8, 0xf9]
        expect(hkdf_sha1(salt, _ikm_22_0b(), info, 5101).len()).to_equal(0)
