# SHA-3 NIST FIPS 202 Known-Answer Test Vectors
#
# Tests the pure-Simple SHA-3 implementation in
# src/lib/common/crypto/sha3.spl against FIPS 202 (NIST Examples) canonical
# vectors for SHA3-256, SHA3-384, and SHA3-512.
#
# Vectors covered (FIPS 202 / NIST Examples for SHA-3):
#
#   SHA3-256("")     -> a7ffc6f8bf1ed76651c14756a061d662f580ff4de43b49fa82d80a4b80f8434a
#   SHA3-256("abc")  -> 3a985da74fe225b2045c172d6bd390bd855f086e3e9d525b46bfe24511431532
#
#   SHA3-384("")     -> 0c63a75b845e4f7d01107d852e4c2485c51a50aaaa94fc61995e71bbee983a2a
#                       c3713831264adb47fb6bd1e058d5f004
#   SHA3-384("abc")  -> ec01498288516fc926459f58e2c6ad8df9b473cb0fc08c2596da7cf0e49be4b2
#                       98d88cea927ac7f539f1edf228376d25
#
#   SHA3-512("")     -> a69f73cca23a9ac5c8b567dc185a756e97c982164fe25859e0d1dcc1475c80a6
#                       15b2123af1f5f94c11e3e9402c3ac558f500199d95b6d3e301758586281dcd26
#   SHA3-512("abc")  -> b751850b1a57168a5693cd924b6b096e08f621827444f70d884f5d0240d2712e
#                       10e116e9192af3c91a7ec57647e3934057340b4cf408d5a56592f8274eec53f0
#
# Source: NIST SHA-3 Examples for Hash Functions
#   https://csrc.nist.gov/projects/cryptographic-standards-and-guidelines/example-values#aHashing
#   FIPS PUB 202 Appendix A (with-bit-string-representation aside).
#
# Streaming-API check: build "abc" in two updates ("a" then "bc") and verify
# the digest matches the one-shot path — exercises the absorb-buffer flow.
#
# NOTE: interpreter-mode test runner verifies file loading and basic
# expressions; expect() assertions only fire under compiled/native mode (see
# .claude/memory/feedback_compile_mode_false_greens.md). The smoke test in
# the W8-4 workspace verified all six digests directly in interpreter mode.

use std.spipe.*
use std.crypto.sha3.{
    sha3_256_bytes, sha3_384_bytes, sha3_512_bytes,
    create_sha3_256_context, sha3_update, sha3_finalize
}
use std.crypto.types.{bytes_to_hex}

# ============================================================================
# Helpers — build inputs in module-level fns so it-block var mutation
# (feedback_it_block_var_mutation.md) doesn't drop list pushes.
# ============================================================================

# "abc" as bytes
fn _abc() -> list:
    [0x61, 0x62, 0x63]

# Empty byte list (helper kept symmetric with _abc).
fn _empty() -> list:
    []

# ============================================================================
# SHA3-256 — FIPS 202 KAT
# ============================================================================

describe "SHA3-256 — FIPS 202 known-answer vectors":

    it "SHA3-256(\"\") = a7ffc6f8...":
        expect(bytes_to_hex(sha3_256_bytes(_empty()))).to_equal(
            "a7ffc6f8bf1ed76651c14756a061d662f580ff4de43b49fa82d80a4b80f8434a"
        )

    it "SHA3-256(\"abc\") = 3a985da7...":
        expect(bytes_to_hex(sha3_256_bytes(_abc()))).to_equal(
            "3a985da74fe225b2045c172d6bd390bd855f086e3e9d525b46bfe24511431532"
        )

    it "Streaming SHA3-256(\"a\" then \"bc\") matches one-shot":
        var ctx = create_sha3_256_context()
        ctx = sha3_update(ctx, [0x61])
        ctx = sha3_update(ctx, [0x62, 0x63])
        expect(bytes_to_hex(sha3_finalize(ctx, 32))).to_equal(
            "3a985da74fe225b2045c172d6bd390bd855f086e3e9d525b46bfe24511431532"
        )

# ============================================================================
# SHA3-384 — FIPS 202 KAT
# ============================================================================

describe "SHA3-384 — FIPS 202 known-answer vectors":

    it "SHA3-384(\"\") = 0c63a75b...":
        expect(bytes_to_hex(sha3_384_bytes(_empty()))).to_equal(
            "0c63a75b845e4f7d01107d852e4c2485c51a50aaaa94fc61995e71bbee983a2ac3713831264adb47fb6bd1e058d5f004"
        )

    it "SHA3-384(\"abc\") = ec014982...":
        expect(bytes_to_hex(sha3_384_bytes(_abc()))).to_equal(
            "ec01498288516fc926459f58e2c6ad8df9b473cb0fc08c2596da7cf0e49be4b298d88cea927ac7f539f1edf228376d25"
        )

# ============================================================================
# SHA3-512 — FIPS 202 KAT
# ============================================================================

describe "SHA3-512 — FIPS 202 known-answer vectors":

    it "SHA3-512(\"\") = a69f73cc...":
        expect(bytes_to_hex(sha3_512_bytes(_empty()))).to_equal(
            "a69f73cca23a9ac5c8b567dc185a756e97c982164fe25859e0d1dcc1475c80a615b2123af1f5f94c11e3e9402c3ac558f500199d95b6d3e301758586281dcd26"
        )

    it "SHA3-512(\"abc\") = b751850b...":
        expect(bytes_to_hex(sha3_512_bytes(_abc()))).to_equal(
            "b751850b1a57168a5693cd924b6b096e08f621827444f70d884f5d0240d2712e10e116e9192af3c91a7ec57647e3934057340b4cf408d5a56592f8274eec53f0"
        )

# ============================================================================
# W12-A PROBES — DO NOT COMMIT (will be reverted)
# ============================================================================

describe "W12-A probe — bool literal expect":

    it "PROBE bool literal must FAIL":
        expect true == false

describe "W12-A probe — int literal expect":

    it "PROBE int literal must FAIL":
        expect 1 == 99999

describe "W12-A probe — non-bool receiver matcher chain":

    it "PROBE hex string mismatch must FAIL":
        expect(bytes_to_hex(sha3_256_bytes(_empty()))).to_equal(
            "deadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeef"
        )