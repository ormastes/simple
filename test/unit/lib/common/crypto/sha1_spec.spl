# SHA-1 Reference Vectors
#
# Tests the pure-Simple SHA-1 implementation in
# src/lib/common/crypto/sha1.spl against FIPS 180-4 §B.1 and RFC 3174 §7.3
# canonical vectors.
#
# Vectors (FIPS 180-4 §B.1):
#   "abc"                 -> a9993e364706816aba3e25717850c26c9cd0d89d
#   "" (empty)            -> da39a3ee5e6b4b0d3255bfef95601890afd80709
#   "abcdbcdecdefdefg..." -> 84983e441c3bd26ebaae4aa1f95129e5e54670f1
#                            (the 56-byte two-block vector)
#
# AC-4 also calls for the 1-million-byte "a" vector
#   (34aa973cd4c4daa4f61eeb2bdbad27316534016f).
# That vector requires compiled-mode SHA-1: in interpreter mode the list-push
# message-build dominates and 100K 'a' already exceeds 5 minutes. Tracking:
# doc/08_tracking/feature_request/sha1_pbkdf2_perf_2026-05-01.md.
# The two attested 56-byte two-block vector + a 1000-byte vector exercise the
# multi-block code path adequately.
#
# WARNING: SHA-1 is cryptographically broken. These vectors validate
# implementation correctness for legacy interop only.

use std.spipe.*
use std.crypto.sha1.{sha1, sha1_hex, sha1_bytes, create_sha1_context, sha1_init, sha1_update, sha1_finalize, sha1_final}
use std.crypto.types.{bytes_to_hex}

# ============================================================================
# Helpers — build inputs in module-level fns so it-block var mutation
# (feedback_it_block_var_mutation.md) doesn't drop list pushes.
# ============================================================================

# Build n copies of byte b
fn _bytes_repeat(b: i64, n: i64) -> list:
    var out = []
    var i = 0
    while i < n:
        out.push(b)
        i = i + 1
    out

# FIPS 180-4 §B.1 two-block vector:
# "abcdbcdecdefdefgefghfghighijhijkijkljklmklmnlmnomnopnopq"
# Built byte-by-byte from the ASCII pattern.
fn _abcd_pattern_56() -> list:
    [
        0x61, 0x62, 0x63, 0x64, 0x62, 0x63, 0x64, 0x65,
        0x63, 0x64, 0x65, 0x66, 0x64, 0x65, 0x66, 0x67,
        0x65, 0x66, 0x67, 0x68, 0x66, 0x67, 0x68, 0x69,
        0x67, 0x68, 0x69, 0x6a, 0x68, 0x69, 0x6a, 0x6b,
        0x69, 0x6a, 0x6b, 0x6c, 0x6a, 0x6b, 0x6c, 0x6d,
        0x6b, 0x6c, 0x6d, 0x6e, 0x6c, 0x6d, 0x6e, 0x6f,
        0x6d, 0x6e, 0x6f, 0x70, 0x6e, 0x6f, 0x70, 0x71
    ]

# ============================================================================
# FIPS 180-4 §B.1 / RFC 3174 §7.3 — canonical vectors
# ============================================================================

describe "SHA-1 — FIPS 180-4 §B.1 canonical vectors":

    it "empty string":
        expect(sha1_hex("")).to_equal("da39a3ee5e6b4b0d3255bfef95601890afd80709")

    it "'abc' (single-block)":
        expect(sha1_hex("abc")).to_equal("a9993e364706816aba3e25717850c26c9cd0d89d")

    it "56-byte ABCD pattern (two-block, FIPS 180-4 §B.1)":
        # "abcdbcdecdefdefgefghfghighijhijkijkljklmklmnlmnomnopnopq"
        # -> 84983e441c3bd26ebaae4aa1f95129e5e54670f1
        expect(bytes_to_hex(sha1_bytes(_abcd_pattern_56()))).to_equal(
            "84983e441c3bd26ebaae4aa1f95129e5e54670f1"
        )

    it "1000 'a' bytes (multi-block stress, attested via Python hashlib)":
        # hashlib.sha1(b'a'*1000).hexdigest() = 291e9a6c66994949b57ba5e650361e98fc36b1ba
        expect(bytes_to_hex(sha1_bytes(_bytes_repeat(0x61, 1000)))).to_equal(
            "291e9a6c66994949b57ba5e650361e98fc36b1ba"
        )

# ============================================================================
# bytes_to_hex output and digest length sanity
# ============================================================================

describe "SHA-1 — output shape":

    it "digest is exactly 20 bytes":
        expect(sha1_bytes([]).len()).to_equal(20)

    it "digest is exactly 20 bytes for non-empty input":
        expect(sha1_bytes([0x61, 0x62, 0x63]).len()).to_equal(20)

    it "hex form is exactly 40 lowercase chars":
        expect(sha1_hex("abc").len()).to_equal(40)

# ============================================================================
# Streaming API parity — sha1_init / sha1_update / sha1_final
# ============================================================================

describe "SHA-1 streaming API parity":

    it "init+update+final equals one-shot for 'abc'":
        var ctx = sha1_init()
        ctx = sha1_update(ctx, [0x61, 0x62, 0x63])
        expect(bytes_to_hex(sha1_final(ctx))).to_equal(
            "a9993e364706816aba3e25717850c26c9cd0d89d"
        )

    it "create_sha1_context+update+finalize equals one-shot for ABCD pattern":
        var ctx = create_sha1_context()
        ctx = sha1_update(ctx, _abcd_pattern_56())
        expect(bytes_to_hex(sha1_finalize(ctx))).to_equal(
            "84983e441c3bd26ebaae4aa1f95129e5e54670f1"
        )

    it "two-chunk update equals one-shot (split 'abc' = 'a' || 'bc')":
        var ctx = sha1_init()
        ctx = sha1_update(ctx, [0x61])
        ctx = sha1_update(ctx, [0x62, 0x63])
        expect(bytes_to_hex(sha1_finalize(ctx))).to_equal(
            "a9993e364706816aba3e25717850c26c9cd0d89d"
        )
