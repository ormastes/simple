# @covers src/lib/common/cbor/types.spl 80%
# duplicate-typed-args suppression was removed from this coverage spec
# primitive-api suppression was removed from this coverage spec
# CBOR Types Coverage Test
# Branch coverage for types.spl: byte array helpers + text/byte conversion
#
# **Feature IDs:** #CBOR-COVERAGE
# **Category:** Testing
# **Status:** Implemented

use std.common.cbor.major_types.*
use std.common.cbor.types.*
use std.common.cbor.encode.*
use std.common.cbor.decode.*

# ============================================================================
# Helper functions
# ============================================================================

fn check(condition: bool):
    expect condition == true

fn empty_i64_list() -> [i64]:
    var r = [0]
    r = []
    r

# ============================================================================
# Test Group 1: types.spl - Byte Array Helpers
# ============================================================================

describe "CBOR Types - byte_at":
    context "when index is valid":
        it "returns the byte at the given index":
            val bytes = [10, 20, 30]
            expect byte_at(bytes, 0) == 10
            expect byte_at(bytes, 1) == 20
            expect byte_at(bytes, 2) == 30

    context "when index is negative":
        it "returns 0":
            val bytes = [10, 20, 30]
            expect byte_at(bytes, -1) == 0
            expect byte_at(bytes, -100) == 0

    context "when index is out of bounds":
        it "returns 0":
            val bytes = [10, 20, 30]
            expect byte_at(bytes, 3) == 0
            expect byte_at(bytes, 100) == 0

    context "when array is empty":
        it "returns 0 for any index":
            val bts = empty_i64_list()
            expect byte_at(bts, 0) == 0

describe "CBOR Types - bytes_append":
    context "when appending to array":
        it "returns array with new byte at end":
            val bytes = [1, 2]
            val result = bytes_append(bytes, 3)
            expect result.len() == 3
            expect result[2] == 3

    context "when appending to empty array":
        it "returns single-element array":
            val bts = empty_i64_list()
            val result = bytes_append(bts, 42)
            expect result.len() == 1
            expect result[0] == 42

describe "CBOR Types - bytes_concat":
    context "when both arrays have elements":
        it "concatenates them":
            val a = [1, 2]
            val b = [3, 4]
            val result = bytes_concat(a, b)
            expect result.len() == 4
            expect result[0] == 1
            expect result[3] == 4

    context "when first array is empty":
        it "returns copy of second array":
            val empty = empty_i64_list()
            val non_empty = [5, 6]
            val result = bytes_concat(empty, non_empty)
            expect result.len() == 2
            expect result[0] == 5

    context "when second array is empty":
        it "returns copy of first array":
            val non_empty = [7, 8]
            val empty = empty_i64_list()
            val result = bytes_concat(non_empty, empty)
            expect result.len() == 2
            expect result[1] == 8

describe "CBOR Types - bytes_slice":
    context "when slice is within bounds":
        it "extracts the correct slice":
            val bytes = [10, 20, 30, 40, 50]
            val result = bytes_slice(bytes, 1, 3)
            expect result.len() == 3
            expect result[0] == 20
            expect result[1] == 30
            expect result[2] == 40

    context "when slice extends past end":
        it "returns only available bytes":
            val bytes = [10, 20, 30]
            val result = bytes_slice(bytes, 2, 5)
            # Only index 2 is valid, rest are beyond end
            expect result.len() == 1
            expect result[0] == 30

    context "when start is at end":
        it "returns empty for zero-length":
            val bytes = [10, 20]
            val result = bytes_slice(bytes, 0, 0)
            expect result.len() == 0

# ============================================================================
# Test Group 2: types.spl - Initial Byte Encoding/Decoding
# ============================================================================

describe "CBOR Types - make_initial_byte":
    context "when encoding major type 0 with value 0":
        it "returns 0x00":
            expect make_initial_byte(0, 0) == 0

    context "when encoding major type 0 with value 23":
        it "returns 23":
            expect make_initial_byte(0, 23) == 23

    context "when encoding major type 1 with value 0":
        it "returns 32":
            # major_type 1 * 32 + 0 = 32
            expect make_initial_byte(1, 0) == 32

    context "when encoding major type 7 with value 31":
        it "returns 0xFF (255)":
            # major_type 7 * 32 + 31 = 224 + 31 = 255
            expect make_initial_byte(7, 31) == 255

    context "when encoding all major types":
        it "correctly shifts major type bits":
            expect make_initial_byte(0, 0) == 0
            expect make_initial_byte(1, 0) == 32
            expect make_initial_byte(2, 0) == 64
            expect make_initial_byte(3, 0) == 96
            expect make_initial_byte(4, 0) == 128
            expect make_initial_byte(5, 0) == 160
            expect make_initial_byte(6, 0) == 192
            expect make_initial_byte(7, 0) == 224

describe "CBOR Types - get_major_type":
    context "when byte represents each major type":
        it "extracts the correct major type":
            expect get_major_type(0) == 0
            expect get_major_type(32) == 1
            expect get_major_type(64) == 2
            expect get_major_type(96) == 3
            expect get_major_type(128) == 4
            expect get_major_type(160) == 5
            expect get_major_type(192) == 6
            expect get_major_type(224) == 7

    context "when additional info is non-zero":
        it "still extracts correct major type":
            # 0x58 = 88 = major 2 (byte string) + addl 24 (uint8)
            expect get_major_type(88) == 2

describe "CBOR Types - get_additional_info":
    context "when extracting additional info":
        it "returns the low 5 bits":
            expect get_additional_info(0) == 0
            expect get_additional_info(23) == 23
            expect get_additional_info(24) == 24
            expect get_additional_info(31) == 31

    context "when major type is non-zero":
        it "still extracts correct additional info":
            # 0x38 = 56 = major 1 (neg int) + addl 24 (uint8)
            expect get_additional_info(56) == 24

# ============================================================================
# Test Group 3: types.spl - Text/Byte Conversion
# ============================================================================

describe "CBOR Types - text_to_bytes":
    context "when converting ASCII text":
        # NOTE: text_to_bytes only reliably handles single-char input due to
        # a known runtime limitation with substring() inside while loops.
        it "returns correct byte values for lowercase":
            val result_a = text_to_bytes("a")
            expect result_a.len() == 1
            expect result_a[0] == 97
            val result_b = text_to_bytes("b")
            expect result_b[0] == 98
            val result_c = text_to_bytes("c")
            expect result_c[0] == 99

        it "returns correct byte values for uppercase":
            val result_a = text_to_bytes("A")
            expect result_a.len() == 1
            expect result_a[0] == 65
            val result_b = text_to_bytes("B")
            expect result_b[0] == 66
            val result_c = text_to_bytes("C")
            expect result_c[0] == 67

        it "returns correct byte values for digits":
            val result_0 = text_to_bytes("0")
            expect result_0.len() == 1
            expect result_0[0] == 48
            val result_1 = text_to_bytes("1")
            expect result_1[0] == 49
            val result_2 = text_to_bytes("2")
            expect result_2[0] == 50

        it "returns correct value for space":
            val result = text_to_bytes(" ")
            expect result[0] == 32

        it "handles special characters":
            val result_bang = text_to_bytes("!")
            expect result_bang[0] == 33
            val result_at = text_to_bytes("@")
            expect result_at[0] == 64
            val result_hash = text_to_bytes("#")
            expect result_hash[0] == 35

    context "when converting empty text":
        it "returns empty array":
            val result = text_to_bytes("")
            expect result.len() == 0

    context "when converting punctuation":
        it "handles braces and brackets":
            val result_open = text_to_bytes("{")
            expect result_open[0] == 123
            val result_close = text_to_bytes("}")
            expect result_close[0] == 125

        it "handles tilde and backtick":
            val result_tilde = text_to_bytes("~")
            expect result_tilde[0] == 126
            val result_backtick = text_to_bytes("`")
            expect result_backtick[0] == 96

describe "CBOR Types - bytes_to_text":
    context "when converting byte values to text":
        it "returns correct ASCII text for lowercase":
            val bytes = [104, 105]  # h, i
            val result = bytes_to_text(bytes)
            expect result == "hi"

        it "returns correct ASCII text for uppercase":
            val bytes = [72, 73]  # H, I
            val result = bytes_to_text(bytes)
            expect result == "HI"

        it "returns correct text for digits":
            val bytes = [48, 49, 50]  # 0, 1, 2
            val result = bytes_to_text(bytes)
            expect result == "012"

    context "when converting empty byte array":
        it "returns empty text":
            val empty = empty_i64_list()
            val result = bytes_to_text(empty)
            expect result == ""

    context "when roundtripping":
        it "text_to_bytes then bytes_to_text returns original":
            # Single-char roundtrip (multi-char limited by runtime substring bug)
            val original = "H"
            val bts = text_to_bytes(original)
            val roundtrip = bytes_to_text(bts)
            expect roundtrip == original

# ============================================================================
# Test Group 23: types.spl - text_to_bytes more character coverage
# ============================================================================

describe "CBOR Types - text_to_bytes extended chars":
    context "when converting additional lowercase letters":
        it "handles d through h":
            expect text_to_bytes("d")[0] == 100
            expect text_to_bytes("e")[0] == 101
            expect text_to_bytes("f")[0] == 102
            expect text_to_bytes("g")[0] == 103
            expect text_to_bytes("h")[0] == 104

        it "handles i through m":
            expect text_to_bytes("i")[0] == 105
            expect text_to_bytes("j")[0] == 106
            expect text_to_bytes("k")[0] == 107
            expect text_to_bytes("l")[0] == 108
            expect text_to_bytes("m")[0] == 109

        it "handles n through r":
            expect text_to_bytes("n")[0] == 110
            expect text_to_bytes("o")[0] == 111
            expect text_to_bytes("p")[0] == 112
            expect text_to_bytes("q")[0] == 113
            expect text_to_bytes("r")[0] == 114

        it "handles s through w":
            expect text_to_bytes("s")[0] == 115
            expect text_to_bytes("t")[0] == 116
            expect text_to_bytes("u")[0] == 117
            expect text_to_bytes("v")[0] == 118
            expect text_to_bytes("w")[0] == 119

        it "handles x through z":
            expect text_to_bytes("x")[0] == 120
            expect text_to_bytes("y")[0] == 121
            expect text_to_bytes("z")[0] == 122

    context "when converting additional uppercase letters":
        it "handles D through H":
            expect text_to_bytes("D")[0] == 68
            expect text_to_bytes("E")[0] == 69
            expect text_to_bytes("F")[0] == 70
            expect text_to_bytes("G")[0] == 71
            expect text_to_bytes("H")[0] == 72

        it "handles I through M":
            expect text_to_bytes("I")[0] == 73
            expect text_to_bytes("J")[0] == 74
            expect text_to_bytes("K")[0] == 75
            expect text_to_bytes("L")[0] == 76
            expect text_to_bytes("M")[0] == 77

        it "handles N through R":
            expect text_to_bytes("N")[0] == 78
            expect text_to_bytes("O")[0] == 79
            expect text_to_bytes("P")[0] == 80
            expect text_to_bytes("Q")[0] == 81
            expect text_to_bytes("R")[0] == 82

        it "handles S through W":
            expect text_to_bytes("S")[0] == 83
            expect text_to_bytes("T")[0] == 84
            expect text_to_bytes("U")[0] == 85
            expect text_to_bytes("V")[0] == 86
            expect text_to_bytes("W")[0] == 87

        it "handles X through Z":
            expect text_to_bytes("X")[0] == 88
            expect text_to_bytes("Y")[0] == 89
            expect text_to_bytes("Z")[0] == 90

    context "when converting digits":
        it "handles 3 through 9":
            expect text_to_bytes("3")[0] == 51
            expect text_to_bytes("4")[0] == 52
            expect text_to_bytes("5")[0] == 53
            expect text_to_bytes("6")[0] == 54
            expect text_to_bytes("7")[0] == 55
            expect text_to_bytes("8")[0] == 56
            expect text_to_bytes("9")[0] == 57

    context "when converting special characters":
        it "handles quote and dollar and percent":
            expect text_to_bytes("\"")[0] == 34
            expect text_to_bytes("$")[0] == 36
            expect text_to_bytes("%")[0] == 37

        it "handles ampersand and apostrophe":
            expect text_to_bytes("&")[0] == 38
            expect text_to_bytes("'")[0] == 39

        it "handles parentheses and asterisk":
            expect(text_to_bytes("(")[0]).to_equal(40)
            expect(text_to_bytes(")")[0]).to_equal(41)
            expect text_to_bytes("*")[0] == 42

        it "handles plus comma minus period":
            expect text_to_bytes("+")[0] == 43
            expect text_to_bytes(",")[0] == 44
            expect text_to_bytes("-")[0] == 45
            expect text_to_bytes(".")[0] == 46

        it "handles slash colon semicolon":
            expect text_to_bytes("/")[0] == 47
            expect text_to_bytes(":")[0] == 58
            expect text_to_bytes(";")[0] == 59

        it "handles angle brackets equals question":
            expect text_to_bytes("<")[0] == 60
            expect text_to_bytes("=")[0] == 61
            expect text_to_bytes(">")[0] == 62
            expect text_to_bytes("?")[0] == 63

        it "handles brackets backslash caret underscore":
            expect text_to_bytes("[")[0] == 91
            expect text_to_bytes("\\")[0] == 92
            expect text_to_bytes("]")[0] == 93
            expect text_to_bytes("^")[0] == 94
            expect text_to_bytes("_")[0] == 95

        it "handles pipe":
            expect text_to_bytes("|")[0] == 124

