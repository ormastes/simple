            expect bytes_to_text([79]) == "O"
            expect bytes_to_text([80]) == "P"
            expect bytes_to_text([81]) == "Q"
            expect bytes_to_text([82]) == "R"

        it "handles S through W":
            expect bytes_to_text([83]) == "S"
            expect bytes_to_text([84]) == "T"
            expect bytes_to_text([85]) == "U"
            expect bytes_to_text([86]) == "V"
            expect bytes_to_text([87]) == "W"

        it "handles X through Z":
            expect bytes_to_text([88]) == "X"
            expect bytes_to_text([89]) == "Y"
            expect bytes_to_text([90]) == "Z"

    context "when converting digit byte values":
        it "handles 3 through 9":
            expect bytes_to_text([51]) == "3"
