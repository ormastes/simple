# Test Group 24: types.spl - bytes_to_text more character coverage
# ============================================================================

describe "CBOR Types - bytes_to_text extended chars":
    context "when converting additional lowercase byte values":
        it "handles d through h":
            expect bytes_to_text([100]) == "d"
            expect bytes_to_text([101]) == "e"
            expect bytes_to_text([102]) == "f"
            expect bytes_to_text([103]) == "g"
            expect bytes_to_text([104]) == "h"

        it "handles i through m":
            expect bytes_to_text([105]) == "i"
            expect bytes_to_text([106]) == "j"
            expect bytes_to_text([107]) == "k"
            expect bytes_to_text([108]) == "l"
            expect bytes_to_text([109]) == "m"

        it "handles n through r":
            expect bytes_to_text([110]) == "n"
            expect bytes_to_text([111]) == "o"
            expect bytes_to_text([112]) == "p"
            expect bytes_to_text([113]) == "q"
            expect bytes_to_text([114]) == "r"

        it "handles s through w":
            expect bytes_to_text([115]) == "s"
            expect bytes_to_text([116]) == "t"
            expect bytes_to_text([117]) == "u"
            expect bytes_to_text([118]) == "v"
            expect bytes_to_text([119]) == "w"

        it "handles x through z":
            expect bytes_to_text([120]) == "x"
            expect bytes_to_text([121]) == "y"
            expect bytes_to_text([122]) == "z"

    context "when converting additional uppercase byte values":
