    context "when converting special character byte values":
        it "handles quote dollar percent":
            expect bytes_to_text([34]) == "\""
            expect bytes_to_text([36]) == "$"
            expect bytes_to_text([37]) == "%"

        it "handles ampersand apostrophe":
            expect bytes_to_text([38]) == "&"
