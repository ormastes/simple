"""
# Unicode Math & Math Repr Coverage Specification

**Feature IDs:** #LIB-MATH-COV
**Category:** Stdlib
**Difficulty:** 2/5
**Status:** Implemented
**Requirements:** N/A
**Plan:** N/A
**Design:** N/A
**Research:** N/A

## Overview

Comprehensive branch coverage tests for `std.unicode_math` and `std.math_repr`.
Targets 90%+ branch coverage by exercising every lookup function (hit + miss),
string conversion functions, tokenizer paths, parser grammar rules, and all
four renderers (text, debug, pretty, LaTeX/markdown).

## Key Concepts

| Concept | Description |
|---------|-------------|
| unicode_math | Lookup tables: greek, superscript, subscript, math_sym, math_op, brackets |
| math_repr | Parser + renderer: to_text, to_debug, to_pretty, to_md, render_latex_raw |
"""

use std.unicode_math.{greek, greek_upper, superscript_char, subscript_char}
use std.unicode_math.{superscript, subscript, math_sym, math_op, hline}
use std.unicode_math.{bracket_left_top, bracket_left_mid, bracket_left_bot}
use std.unicode_math.{bracket_right_top, bracket_right_mid, bracket_right_bot}
use std.unicode_math.{paren_left_top, paren_left_mid, paren_left_bot}
use std.unicode_math.{paren_right_top, paren_right_mid, paren_right_bot}
use std.unicode_math.{brace_left_top, brace_left_mid, brace_left_bot}
use std.unicode_math.{brace_right_top, brace_right_mid, brace_right_bot}
use std.unicode_math.{brace_ext}
use std.math_repr.{to_text, to_debug, to_pretty, to_md, render_latex_raw}

# ============================================================================
# 1. unicode_math — Greek Letters
# ============================================================================

describe "unicode_math greek":
    """
    ## Greek Letter Lookup

    Tests lowercase and uppercase Greek letter conversion.
    Each branch returns a specific Unicode character; the fallback returns name unchanged.
    """

    context "lowercase greek letters":
        it "converts alpha":
            expect(greek("alpha")).to_equal("\u03B1")

        it "converts beta":
            expect(greek("beta")).to_equal("\u03B2")

        it "converts gamma":
            expect(greek("gamma")).to_equal("\u03B3")

        it "converts delta":
            expect(greek("delta")).to_equal("\u03B4")

        it "converts epsilon":
            expect(greek("epsilon")).to_equal("\u03B5")

        it "converts zeta":
            expect(greek("zeta")).to_equal("\u03B6")

        it "converts eta":
            expect(greek("eta")).to_equal("\u03B7")

        it "converts theta":
            expect(greek("theta")).to_equal("\u03B8")

        it "converts iota":
            expect(greek("iota")).to_equal("\u03B9")

        it "converts kappa":
            expect(greek("kappa")).to_equal("\u03BA")

        it "converts lambda":
            expect(greek("lambda")).to_equal("\u03BB")

        it "converts mu":
            expect(greek("mu")).to_equal("\u03BC")

        it "converts nu":
            expect(greek("nu")).to_equal("\u03BD")

        it "converts xi":
            expect(greek("xi")).to_equal("\u03BE")

        it "converts omicron":
            expect(greek("omicron")).to_equal("\u03BF")

        it "converts pi":
            expect(greek("pi")).to_equal("\u03C0")

        it "converts rho":
            expect(greek("rho")).to_equal("\u03C1")

        it "converts sigma":
            expect(greek("sigma")).to_equal("\u03C3")

        it "converts tau":
            expect(greek("tau")).to_equal("\u03C4")

        it "converts upsilon":
            expect(greek("upsilon")).to_equal("\u03C5")

        it "converts phi":
            expect(greek("phi")).to_equal("\u03C6")

        it "converts chi":
            expect(greek("chi")).to_equal("\u03C7")

        it "converts psi":
            expect(greek("psi")).to_equal("\u03C8")

        it "converts omega":
            expect(greek("omega")).to_equal("\u03C9")

    context "variant greek forms":
        it "converts varepsilon":
            expect(greek("varepsilon")).to_equal("\u03F5")

        it "converts vartheta":
            expect(greek("vartheta")).to_equal("\u03D1")

        it "converts varphi":
            expect(greek("varphi")).to_equal("\u03D5")

        it "converts varrho":
            expect(greek("varrho")).to_equal("\u03F1")

        it "converts varpi":
            expect(greek("varpi")).to_equal("\u03D6")

        it "converts varkappa":
            expect(greek("varkappa")).to_equal("\u03F0")

        it "converts partial":
            expect(greek("partial")).to_equal("\u2202")

        it "converts nabla":
            expect(greek("nabla")).to_equal("\u2207")

    context "fallback for unknown names":
        it "returns name unchanged for unknown greek":
            expect(greek("notgreek")).to_equal("notgreek")

        it "returns empty string unchanged":
            expect(greek("")).to_equal("")

    context "uppercase greek letters":
        it "converts Gamma":
            expect(greek_upper("Gamma")).to_equal("\u0393")

        it "converts Delta":
            expect(greek_upper("Delta")).to_equal("\u0394")

        it "converts Theta":
            expect(greek_upper("Theta")).to_equal("\u0398")

        it "converts Lambda":
            expect(greek_upper("Lambda")).to_equal("\u039B")

        it "converts Xi":
            expect(greek_upper("Xi")).to_equal("\u039E")

        it "converts Pi":
            expect(greek_upper("Pi")).to_equal("\u03A0")

        it "converts Sigma":
            expect(greek_upper("Sigma")).to_equal("\u03A3")

        it "converts Upsilon":
            expect(greek_upper("Upsilon")).to_equal("\u03A5")

        it "converts Phi":
            expect(greek_upper("Phi")).to_equal("\u03A6")

        it "converts Psi":
            expect(greek_upper("Psi")).to_equal("\u03A8")

        it "converts Omega":
            expect(greek_upper("Omega")).to_equal("\u03A9")

        it "returns unknown uppercase unchanged":
            expect(greek_upper("NotUpper")).to_equal("NotUpper")


# ============================================================================
# 2. unicode_math — Superscript
# ============================================================================

describe "unicode_math superscript":
    """
    ## Superscript Conversion

    Tests single-character and multi-character superscript conversion.
    Covers digits 0-9, operators, letters, and the fallback branch.
    """

    context "superscript_char digits":
        it "converts 0":
            expect(superscript_char("0")).to_equal("\u2070")

        it "converts 1":
            expect(superscript_char("1")).to_equal("\u00B9")

        it "converts 2":
            expect(superscript_char("2")).to_equal("\u00B2")

        it "converts 3":
            expect(superscript_char("3")).to_equal("\u00B3")

        it "converts 4":
            expect(superscript_char("4")).to_equal("\u2074")

        it "converts 5":
            expect(superscript_char("5")).to_equal("\u2075")

        it "converts 6":
            expect(superscript_char("6")).to_equal("\u2076")

        it "converts 7":
            expect(superscript_char("7")).to_equal("\u2077")

        it "converts 8":
            expect(superscript_char("8")).to_equal("\u2078")

        it "converts 9":
            expect(superscript_char("9")).to_equal("\u2079")

    context "superscript_char operators and letters":
        it "converts plus":
            expect(superscript_char("+")).to_equal("\u207A")

        it "converts minus":
            expect(superscript_char("-")).to_equal("\u207B")

        it "converts equals":
            expect(superscript_char("=")).to_equal("\u207C")

        it "converts left paren":
            expect(superscript_char("(")).to_equal("\u207D")

        it "converts right paren":
            expect(superscript_char(")")).to_equal("\u207E")

        it "converts n":
            expect(superscript_char("n")).to_equal("\u207F")

        it "converts i":
            expect(superscript_char("i")).to_equal("\u2071")

        it "converts x":
            expect(superscript_char("x")).to_equal("\u02E3")

    context "superscript_char fallback":
        it "returns unknown char unchanged":
            expect(superscript_char("z")).to_equal("z")

        it "returns q unchanged":
            expect(superscript_char("q")).to_equal("q")

    context "superscript multi-char string":
        it "converts digit string 23":
            val result = superscript("23")
            expect(result).to_contain("\u00B2")
            expect(result).to_contain("\u00B3")

        it "converts mixed n+1":
            val result = superscript("n+1")
            expect(result).to_contain("\u207F")
            expect(result).to_contain("\u207A")
            expect(result).to_contain("\u00B9")

        it "handles empty string":
            expect(superscript("")).to_equal("")


