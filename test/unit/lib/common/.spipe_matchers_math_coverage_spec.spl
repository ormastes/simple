# @covers src/lib/common/unicode_math.spl 80%
"""
# Unicode Math Greek/Superscript/Subscript Coverage Specification

**Feature IDs:** #LIB-MATH-COV
**Category:** Stdlib
**Difficulty:** 2/5
**Status:** Implemented
**Requirements:** N/A
**Plan:** N/A
**Design:** N/A
**Research:** N/A

## Overview

Branch coverage tests for `std.unicode_math` greek, superscript, and subscript
lookup functions. Split from the original monolithic spec for memory safety.
See also: math_symbols_coverage_spec.spl and math_repr_coverage_spec.spl.

## Key Concepts

| Concept | Description |
|---------|-------------|
| unicode_math | Lookup tables: greek, superscript, subscript |
"""

use std.unicode_math.{greek, greek_upper, superscript_char, subscript_char}
use std.unicode_math.{superscript, subscript}

# ============================================================================
# 1. unicode_math — Greek Letters
# ============================================================================

describe "unicode_math greek":
    """
    ## Greek Letter Lookup

    Tests lowercase and uppercase Greek letter conversion.
    Each branch returns a specific Unicode character; the fallback returns name unchanged.
    """

    context "lowercase greek letters":
        it "converts alpha":
            expect greek("alpha") == "\u03B1"

        it "converts beta":
            expect greek("beta") == "\u03B2"

        it "converts gamma":
            expect greek("gamma") == "\u03B3"

        it "converts delta":
            expect greek("delta") == "\u03B4"

        it "converts epsilon":
            expect greek("epsilon") == "\u03B5"

        it "converts zeta":
            expect greek("zeta") == "\u03B6"

        it "converts eta":
            expect greek("eta") == "\u03B7"

        it "converts theta":
            expect greek("theta") == "\u03B8"

        it "converts iota":
            expect greek("iota") == "\u03B9"

        it "converts kappa":
            expect greek("kappa") == "\u03BA"

        it "converts lambda":
            expect greek("lambda") == "\u03BB"

        it "converts mu":
            expect greek("mu") == "\u03BC"

        it "converts nu":
            expect greek("nu") == "\u03BD"

        it "converts xi":
            expect greek("xi") == "\u03BE"

        it "converts omicron":
            expect greek("omicron") == "\u03BF"

        it "converts pi":
            expect greek("pi") == "\u03C0"

        it "converts rho":
            expect greek("rho") == "\u03C1"

        it "converts sigma":
            expect greek("sigma") == "\u03C3"

        it "converts tau":
            expect greek("tau") == "\u03C4"

        it "converts upsilon":
            expect greek("upsilon") == "\u03C5"

        it "converts phi":
            expect greek("phi") == "\u03C6"

        it "converts chi":
            expect greek("chi") == "\u03C7"

        it "converts psi":
            expect greek("psi") == "\u03C8"

        it "converts omega":
            expect greek("omega") == "\u03C9"

    context "variant greek forms":
        it "converts varepsilon":
            expect greek("varepsilon") == "\u03F5"

        it "converts vartheta":
            expect greek("vartheta") == "\u03D1"

        it "converts varphi":
            expect greek("varphi") == "\u03D5"

        it "converts varrho":
            expect greek("varrho") == "\u03F1"

        it "converts varpi":
            expect greek("varpi") == "\u03D6"

        it "converts varkappa":
            expect greek("varkappa") == "\u03F0"

        it "converts partial":
            expect greek("partial") == "\u2202"

        it "converts nabla":
            expect greek("nabla") == "\u2207"

    context "fallback for unknown names":
        it "returns name unchanged for unknown greek":
            expect greek("notgreek") == "notgreek"

        it "returns empty string unchanged":
            expect greek("") == ""

    context "uppercase greek letters":
        it "converts Gamma":
            expect greek_upper("Gamma") == "\u0393"

        it "converts Delta":
            expect greek_upper("Delta") == "\u0394"

        it "converts Theta":
            expect greek_upper("Theta") == "\u0398"

        it "converts Lambda":
            expect greek_upper("Lambda") == "\u039B"

        it "converts Xi":
            expect greek_upper("Xi") == "\u039E"

        it "converts Pi":
            expect greek_upper("Pi") == "\u03A0"

        it "converts Sigma":
            expect greek_upper("Sigma") == "\u03A3"

        it "converts Upsilon":
            expect greek_upper("Upsilon") == "\u03A5"

        it "converts Phi":
            expect greek_upper("Phi") == "\u03A6"

        it "converts Psi":
            expect greek_upper("Psi") == "\u03A8"

        it "converts Omega":
            expect greek_upper("Omega") == "\u03A9"

        it "returns unknown uppercase unchanged":
            expect greek_upper("NotUpper") == "NotUpper"


# ============================================================================
# 2. unicode_math — Superscript
# ============================================================================

describe "unicode_math superscript":
    """
    ## Superscript Conversion

    Tests single-character and multi-character superscript conversion.
    Covers digits 0-9, operators, letters, and the fallback branch.
    """

    context "superscript_char digits":
        it "converts 0":
            expect superscript_char("0") == "\u2070"

        it "converts 1":
            expect superscript_char("1") == "\u00B9"

        it "converts 2":
            expect superscript_char("2") == "\u00B2"

        it "converts 3":
            expect superscript_char("3") == "\u00B3"

        it "converts 4":
            expect superscript_char("4") == "\u2074"

        it "converts 5":
            expect superscript_char("5") == "\u2075"

        it "converts 6":
            expect superscript_char("6") == "\u2076"

        it "converts 7":
            expect superscript_char("7") == "\u2077"

        it "converts 8":
            expect superscript_char("8") == "\u2078"

        it "converts 9":
            expect superscript_char("9") == "\u2079"

    context "superscript_char operators and letters":
        it "converts plus":
            expect superscript_char("+") == "\u207A"

        it "converts minus":
            expect superscript_char("-") == "\u207B"

        it "converts equals":
            expect superscript_char("=") == "\u207C"

        it "converts left paren":
            expect(superscript_char("(")).to_equal("\u207D")

        it "converts right paren":
            expect(superscript_char(")")).to_equal("\u207E")

        it "converts n":
            expect superscript_char("n") == "\u207F"

        it "converts i":
            expect superscript_char("i") == "\u2071"

        it "converts x":
            expect superscript_char("x") == "\u02E3"

    context "superscript_char fallback":
        it "returns unknown char unchanged":
            expect superscript_char("z") == "z"

        it "returns q unchanged":
            expect superscript_char("q") == "q"

    context "superscript multi-char string":
        it "converts digit string 23":
            val result = superscript("23")
            expect (result).contains("\u00B2")
            expect (result).contains("\u00B3")

        it "converts mixed n+1":
            val result = superscript("n+1")
            expect (result).contains("\u207F")
            expect (result).contains("\u207A")
            expect (result).contains("\u00B9")

        it "handles empty string":
            expect superscript("") == ""


# ============================================================================
# 3. unicode_math — Subscript
# ============================================================================

describe "unicode_math subscript":
    """
    ## Subscript Conversion

    Tests single-character and multi-character subscript conversion.
    Covers digits, operators, letters, and fallback.
    """

    context "subscript_char digits":
        it "converts 0":
            expect subscript_char("0") == "\u2080"

        it "converts 1":
            expect subscript_char("1") == "\u2081"

        it "converts 2":
            expect subscript_char("2") == "\u2082"

        it "converts 3":
            expect subscript_char("3") == "\u2083"

        it "converts 4":
            expect subscript_char("4") == "\u2084"

        it "converts 5":
            expect subscript_char("5") == "\u2085"

        it "converts 6":
            expect subscript_char("6") == "\u2086"

        it "converts 7":
            expect subscript_char("7") == "\u2087"

        it "converts 8":
            expect subscript_char("8") == "\u2088"

        it "converts 9":
            expect subscript_char("9") == "\u2089"

    context "subscript_char operators":
        it "converts plus":
            expect subscript_char("+") == "\u208A"

        it "converts minus":
            expect subscript_char("-") == "\u208B"

        it "converts equals":
            expect subscript_char("=") == "\u208C"

        it "converts left paren":
            expect(subscript_char("(")).to_equal("\u208D")

        it "converts right paren":
            expect(subscript_char(")")).to_equal("\u208E")

    context "subscript_char letters":
        it "converts a":
            expect subscript_char("a") == "\u2090"

        it "converts e":
            expect subscript_char("e") == "\u2091"

        it "converts o":
            expect subscript_char("o") == "\u2092"

        it "converts x":
            expect subscript_char("x") == "\u2093"

        it "converts h":
            expect subscript_char("h") == "\u2095"

        it "converts k":
            expect subscript_char("k") == "\u2096"

        it "converts l":
            expect subscript_char("l") == "\u2097"

        it "converts m":
            expect subscript_char("m") == "\u2098"

        it "converts n":
            expect subscript_char("n") == "\u2099"

        it "converts p":
            expect subscript_char("p") == "\u209A"

        it "converts s":
            expect subscript_char("s") == "\u209B"

        it "converts t":
            expect subscript_char("t") == "\u209C"

        it "converts i":
            expect subscript_char("i") == "\u1D62"

        it "converts j":
            expect subscript_char("j") == "\u2C7C"

        it "converts r":
            expect subscript_char("r") == "\u1D63"

    context "subscript_char fallback":
        it "returns unknown char unchanged":
            expect subscript_char("z") == "z"

        it "returns Q unchanged":
            expect subscript_char("Q") == "Q"

    context "subscript multi-char string":
        it "converts digit string 12":
            val result = subscript("12")
            expect (result).contains("\u2081")
            expect (result).contains("\u2082")

        it "handles empty string":
            expect subscript("") == ""