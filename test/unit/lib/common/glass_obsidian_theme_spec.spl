# @cover src/lib/common/ui/glass_tokens.spl 80%
# @cover src/lib/common/ui/glass_numeric_tokens.spl 80%
# @cover src/lib/common/ui/glass_theme.spl 60%
"""
# Obsidian Dark Theme Specification

**Feature IDs:** #GUI-THEME-SHARING
**Category:** Stdlib
**Difficulty:** 2/5
**Status:** Draft
**Requirements:** N/A
**Plan:** N/A
**Design:** doc/05_design/stitch_design_system.md

## Overview

AC-6: Latest Stitch "Obsidian" dark theme applied to glass_tokens.spl and
glass_numeric_tokens.spl.

Verifies that:
- GlassColorTokens.obsidian_dark() exists and returns correct MD3 color values
- GlassDesignTokens.obsidian_dark() composes the right sub-token structs
- Numeric token constants match the Stitch MD3 spec
- MD3 surface container tier fields (6 tiers) are present
- glass_theme.spl recognizes "glass_obsidian_dark" as a valid glass theme
- glass_design_tokens() dispatches correctly for the obsidian theme

## Key Concepts

| Concept | Description |
|---------|-------------|
| GlassColorTokens | CSS-text token struct, extended with MD3 container tiers |
| Obsidian dark | Stitch MD3 theme: surface=#12121f, text=#E3E0F3, accent=#C6C6C8 |
| Surface container tiers | MD3 defines 5 container levels (lowest through highest) |
| on_surface_variant | MD3 secondary text color (#CCC4CE for Obsidian) |
"""

use std.sspec.*
use common.ui.glass.tokens.{GlassColorTokens, GlassDesignTokens}
use common.ui.glass.theme.{glass_design_tokens, is_glass_theme}
use common.ui.glass.numeric_tokens.{GLASS_OBSIDIAN_SURFACE, GLASS_OBSIDIAN_TEXT, GLASS_OBSIDIAN_ACCENT, GLASS_OBSIDIAN_CONTAINER_LOWEST, GLASS_OBSIDIAN_CONTAINER_LOW, GLASS_OBSIDIAN_CONTAINER, GLASS_OBSIDIAN_CONTAINER_HIGH, GLASS_OBSIDIAN_CONTAINER_HIGHEST, GLASS_OBSIDIAN_ERROR, GLASS_OBSIDIAN_RADIUS_MD}

# ============================================================================
# AC-6: GlassColorTokens.obsidian_dark() color values
# ============================================================================

describe "GlassColorTokens.obsidian_dark()":
    """
    ## Obsidian Dark Color Tokens

    All values come from the Stitch MD3 Obsidian spec:
    - Surface: #12121f (rgba with 72% alpha)
    - Text primary: #E3E0F3 (MD3 on_surface)
    - Accent: #C6C6C8 (MD3 primary)
    - Error: #FFB4AB (MD3 error)
    """

    it "has surface_primary matching Obsidian surface #12121f":
        val tokens = GlassColorTokens.obsidian_dark()
        expect(tokens.surface_primary).to_contain("18,18,31")

    it "has text_primary matching MD3 on_surface #E3E0F3":
        val tokens = GlassColorTokens.obsidian_dark()
        expect(tokens.text_primary).to_equal("#E3E0F3")

    it "has accent matching MD3 primary #C6C6C8":
        val tokens = GlassColorTokens.obsidian_dark()
        expect(tokens.accent).to_equal("#C6C6C8")

    it "has error matching MD3 error #FFB4AB":
        val tokens = GlassColorTokens.obsidian_dark()
        expect(tokens.error).to_equal("#FFB4AB")

    it "has text_secondary with reduced opacity":
        val tokens = GlassColorTokens.obsidian_dark()
        expect(tokens.text_secondary).to_contain("0.6")

# ============================================================================
# AC-6: MD3 Surface Container Tiers
# ============================================================================

describe "GlassColorTokens.obsidian_dark() MD3 surface containers":
    """
    ## MD3 Surface Container Tiers

    Obsidian defines 6 surface container levels:
    - surface_container_lowest: #0d0d1a
    - surface_container_low: #1a1a28
    - surface_container: #1e1e2c
    - surface_container_high: #292937
    - surface_container_highest: #343342
    - on_surface_variant: #ccc4ce
    """

    it "has surface_container_lowest":
        val tokens = GlassColorTokens.obsidian_dark()
        expect(tokens.surface_container_lowest).to_contain("13,13,26")

    it "has surface_container_low":
        val tokens = GlassColorTokens.obsidian_dark()
        expect(tokens.surface_container_low).to_contain("26,26,40")

    it "has surface_container":
        val tokens = GlassColorTokens.obsidian_dark()
        expect(tokens.surface_container).to_contain("30,30,44")

    it "has surface_container_high":
        val tokens = GlassColorTokens.obsidian_dark()
        expect(tokens.surface_container_high).to_contain("41,41,55")

    it "has surface_container_highest":
        val tokens = GlassColorTokens.obsidian_dark()
        expect(tokens.surface_container_highest).to_contain("52,51,66")

    it "has on_surface_variant":
        val tokens = GlassColorTokens.obsidian_dark()
        expect(tokens.on_surface_variant).to_contain("204,196,206")

# ============================================================================
# AC-6: Numeric token constants match Stitch MD3 spec
# ============================================================================

describe "Obsidian numeric token constants":
    """
    ## Numeric Hex Constants

    Verify the u64 hex values match the Stitch MD3 extraction.
    These are the single source of truth for both GlassConfig
    (compositor) and GlassColorTokens (widget lib CSS).
    """

    it "GLASS_OBSIDIAN_SURFACE equals 0x0012121F":
        expect(GLASS_OBSIDIAN_SURFACE).to_equal(0x0012121F)

    it "GLASS_OBSIDIAN_TEXT equals 0x00E3E0F3":
        expect(GLASS_OBSIDIAN_TEXT).to_equal(0x00E3E0F3)

    it "GLASS_OBSIDIAN_ACCENT equals 0x00C6C6C8":
        expect(GLASS_OBSIDIAN_ACCENT).to_equal(0x00C6C6C8)

    it "GLASS_OBSIDIAN_ERROR equals 0x00FFB4AB":
        expect(GLASS_OBSIDIAN_ERROR).to_equal(0x00FFB4AB)

    it "GLASS_OBSIDIAN_RADIUS_MD equals 8":
        expect(GLASS_OBSIDIAN_RADIUS_MD).to_equal(8)

    it "GLASS_OBSIDIAN_CONTAINER_LOWEST equals 0x000D0D1A":
        expect(GLASS_OBSIDIAN_CONTAINER_LOWEST).to_equal(0x000D0D1A)

    it "GLASS_OBSIDIAN_CONTAINER_LOW equals 0x001A1A28":
        expect(GLASS_OBSIDIAN_CONTAINER_LOW).to_equal(0x001A1A28)

    it "GLASS_OBSIDIAN_CONTAINER equals 0x001E1E2C":
        expect(GLASS_OBSIDIAN_CONTAINER).to_equal(0x001E1E2C)

    it "GLASS_OBSIDIAN_CONTAINER_HIGH equals 0x00292937":
        expect(GLASS_OBSIDIAN_CONTAINER_HIGH).to_equal(0x00292937)

    it "GLASS_OBSIDIAN_CONTAINER_HIGHEST equals 0x00343342":
        expect(GLASS_OBSIDIAN_CONTAINER_HIGHEST).to_equal(0x00343342)

# ============================================================================
# AC-6: GlassDesignTokens.obsidian_dark() composition
# ============================================================================

describe "GlassDesignTokens.obsidian_dark()":
    """
    ## Composite Token Verification

    GlassDesignTokens.obsidian_dark() composes GlassColorTokens.obsidian_dark()
    with shared blur, typography, radius, shadows, spacing, and animation tokens.
    """

    it "colors.text_primary matches Obsidian value":
        val tokens = GlassDesignTokens.obsidian_dark()
        expect(tokens.colors.text_primary).to_equal("#E3E0F3")

    it "colors.accent matches Obsidian value":
        val tokens = GlassDesignTokens.obsidian_dark()
        expect(tokens.colors.accent).to_equal("#C6C6C8")

    it "blur tokens are default":
        val tokens = GlassDesignTokens.obsidian_dark()
        expect(tokens.blur.surface_blur).to_equal(20)
        expect(tokens.blur.elevated_blur).to_equal(40)

# ============================================================================
# AC-6: glass_theme.spl recognizes Obsidian
# ============================================================================

describe "glass_theme Obsidian recognition":
    """
    ## Theme Dispatcher

    is_glass_theme() must recognize "glass_obsidian_dark".
    glass_design_tokens() must dispatch to the Obsidian factory.
    """

    it "is_glass_theme returns true for glass_obsidian_dark":
        expect(is_glass_theme("glass_obsidian_dark")).to_equal(true)

    it "is_glass_theme still recognizes glass_dark":
        expect(is_glass_theme("glass_dark")).to_equal(true)

    it "is_glass_theme still recognizes glass_light":
        expect(is_glass_theme("glass_light")).to_equal(true)

    it "is_glass_theme returns false for unknown theme":
        expect(is_glass_theme("unknown_theme")).to_equal(false)

    it "glass_design_tokens dispatches obsidian theme correctly":
        val tokens = glass_design_tokens("glass_obsidian_dark")
        expect(tokens.colors.text_primary).to_equal("#E3E0F3")

    it "glass_design_tokens still works for glass_dark":
        val tokens = glass_design_tokens("glass_dark")
        expect(tokens.colors.text_primary).to_equal("#F5F5F7")

# ============================================================================
# AC-6: Existing dark/light themes get MD3 container fields
# ============================================================================

describe "Existing themes with MD3 container fields":
    """
    ## Backward Compatibility

    The existing dark() and light() factories must also have the new
    surface_container_* and on_surface_variant fields filled in with
    their own appropriate values (not nil).
    """

    it "dark theme has surface_container_lowest":
        val tokens = GlassColorTokens.dark()
        expect(tokens.surface_container_lowest).to_contain("rgba")

    it "dark theme has on_surface_variant":
        val tokens = GlassColorTokens.dark()
        expect(tokens.on_surface_variant).to_contain("rgba")

    it "light theme has surface_container_lowest":
        val tokens = GlassColorTokens.light()
        expect(tokens.surface_container_lowest).to_contain("rgba")

    it "light theme has on_surface_variant":
        val tokens = GlassColorTokens.light()
        expect(tokens.on_surface_variant).to_contain("rgba")
