# Adler-32 & Fletcher-32 Checksum Specification
#
# Tests adler32() against RFC 1950 section 9 reference values,
# and fletcher32() against hand-computed 16-bit LE word checksums.
#
# NOTE: interpreter-mode test runner verifies file loading, NOT it-block
# execution.

use std.hash.adler32.{adler32, fletcher32}


# ============================================================================
# Helpers — convert ASCII string to byte array
# ============================================================================

fn _ascii_bytes(s: text) -> [u8]:
    var result: [u8] = []
    var i: i64 = 0
    while i < s.len():
        var ch: i64 = s[i].ord()
        result.push(ch)
        i = i + 1
    result


# ============================================================================
# Adler-32 — RFC 1950 section 9
# ============================================================================

describe "adler32 — RFC 1950":

    it "empty input returns 1":
        var data: [u8] = []
        expect adler32(data) == 1

    it "single byte 'a' (97) returns 0x00620062":
        # A = 1+97 = 98 = 0x62, B = 0+98 = 98 = 0x62
        # Result = (98 << 16) | 98 = 6422626
        var data: [u8] = _ascii_bytes("a")
        expect adler32(data) == 6422626

    it "'abc' returns 0x024D0127":
        # After 'a'(97): A=98, B=98
        # After 'b'(98): A=196, B=294
        # After 'c'(99): A=295, B=589
        # Result = (589 << 16) | 295 = 38600999
        var data: [u8] = _ascii_bytes("abc")
        expect adler32(data) == 38600999

    it "'Wikipedia' returns 0x11E60398":
        # Well-known reference vector
        # Result = (4582 << 16) | 920 = 300286872
        var data: [u8] = _ascii_bytes("Wikipedia")
        expect adler32(data) == 300286872

    it "all-zero bytes of length 4":
        # A = 1+0+0+0+0 = 1, B = 1+1+1+1 = 4
        # Result = (4 << 16) | 1 = 262145
        var data: [u8] = [0, 0, 0, 0]
        expect adler32(data) == 262145

    it "single byte 0xFF (255)":
        # A = 1+255 = 256, B = 0+256 = 256
        # Result = (256 << 16) | 256 = 16777472
        var data: [u8] = [255]
        expect adler32(data) == 16777472


# ============================================================================
# Fletcher-32 — 16-bit LE word checksum
# ============================================================================

describe "fletcher32 — 16-bit LE words":

    it "empty input returns 0":
        var data: [u8] = []
        expect fletcher32(data) == 0

    it "'abcd' (two 16-bit words) returns correct checksum":
        # word1 = 97|(98<<8) = 25185, word2 = 99|(100<<8) = 25699
        # sum1: 0 -> 25185 -> 50884
        # sum2: 0 -> 25185 -> (25185+50884)%65535 = 10534+2048... = 10536
        # Result = (10536 << 16) | 50884 = 690407108
        var data: [u8] = _ascii_bytes("abcd")
        expect fletcher32(data) == 690407108

    it "'abcde' (odd length, zero-padded) returns correct checksum":
        # word1 = 97|(98<<8)=25185, word2 = 99|(100<<8)=25699, word3 = 101|(0<<8)=101
        # sum1: 0 -> 25185 -> 50884 -> 50985
        # sum2: 0 -> 25185 -> 10536 -> 61521
        # Result = (61521 << 16) | 50985 = 4031760169
        var data: [u8] = _ascii_bytes("abcde")
        expect fletcher32(data) == 4031760169

    it "single byte pads with zero high byte":
        # word = 42|(0<<8) = 42
        # sum1 = 42, sum2 = 42
        # Result = (42 << 16) | 42 = 2752554
        var data: [u8] = [42]
        expect fletcher32(data) == 2752554

    it "two zero bytes returns 0":
        # word = 0|(0<<8) = 0
        # sum1 = 0, sum2 = 0
        # Result = 0
        var data: [u8] = [0, 0]
        expect fletcher32(data) == 0