# Base32 / Base32hex KAT — RFC 4648 §6, §7, §10
#
# Verifies the pure-Simple Base32 and Base32hex implementation in
# src/lib/common/base_encoding/base32.spl.
#
# All 7 RFC 4648 §10 test vectors for both alphabets are exercised:
#   Base32 standard  (alphabet A-Z 2-7, §6)
#   Base32hex        (alphabet 0-9 A-V, §7, preserves sort order)
#
# Encode-with-padding, encode-without-padding, and round-trip decode
# are all covered.
#
# NOTE: under interpreter-mode test runner, file-load is verified but it-
# block bodies don't execute the same way as compiled mode (see
# .claude/memory/feedback_compile_mode_false_greens.md).

use std.spipe.*
use std.common.base_encoding.base32.{
    base32_encode, base32_encode_no_pad,
    base32_encode_hex, base32_encode_hex_no_pad,
    base32_decode, base32_decode_hex
}
use std.common.base_encoding.utilities.{text_to_bytes, bytes_to_text}

# ============================================================================
# Helpers — module-level fns to avoid it-block var-mutation interpreter quirk
# (feedback_it_block_var_mutation.md).
# ============================================================================

fn _bytes_f() -> list:
    [0x66]

fn _bytes_fo() -> list:
    [0x66, 0x6f]

fn _bytes_foo() -> list:
    [0x66, 0x6f, 0x6f]

fn _bytes_foob() -> list:
    [0x66, 0x6f, 0x6f, 0x62]

fn _bytes_fooba() -> list:
    [0x66, 0x6f, 0x6f, 0x62, 0x61]

fn _bytes_foobar() -> list:
    [0x66, 0x6f, 0x6f, 0x62, 0x61, 0x72]

fn _empty() -> list:
    []

# ============================================================================
# RFC 4648 §10 — Base32 standard (alphabet A-Z2-7) encode with padding
# ============================================================================

describe "RFC 4648 §10 Base32 standard encode (padded)":

    it "empty input encodes to empty string":
        expect(base32_encode(_empty())).to_equal("")

    it "'f' encodes to 'MY======'":
        expect(base32_encode(_bytes_f())).to_equal("MY======")

    it "'fo' encodes to 'MZXQ===='":
        expect(base32_encode(_bytes_fo())).to_equal("MZXQ====")

    it "'foo' encodes to 'MZXW6==='":
        expect(base32_encode(_bytes_foo())).to_equal("MZXW6===")

    it "'foob' encodes to 'MZXW6YQ='":
        expect(base32_encode(_bytes_foob())).to_equal("MZXW6YQ=")

    it "'fooba' encodes to 'MZXW6YTB'":
        expect(base32_encode(_bytes_fooba())).to_equal("MZXW6YTB")

    it "'foobar' encodes to 'MZXW6YTBOI======'":
        expect(base32_encode(_bytes_foobar())).to_equal("MZXW6YTBOI======")

# ============================================================================
# RFC 4648 §10 — Base32 standard decode (padded and unpadded input accepted)
# ============================================================================

describe "RFC 4648 §10 Base32 standard decode":

    it "empty string decodes to empty bytes":
        expect(base32_decode("").len()).to_equal(0)

    it "'MY======' decodes to 'f'":
        expect(bytes_to_text(base32_decode("MY======"))).to_equal("f")

    it "'MZXQ====' decodes to 'fo'":
        expect(bytes_to_text(base32_decode("MZXQ===="))).to_equal("fo")

    it "'MZXW6===' decodes to 'foo'":
        expect(bytes_to_text(base32_decode("MZXW6==="))).to_equal("foo")

    it "'MZXW6YQ=' decodes to 'foob'":
        expect(bytes_to_text(base32_decode("MZXW6YQ="))).to_equal("foob")

    it "'MZXW6YTB' decodes to 'fooba'":
        expect(bytes_to_text(base32_decode("MZXW6YTB"))).to_equal("fooba")

    it "'MZXW6YTBOI======' decodes to 'foobar'":
        expect(bytes_to_text(base32_decode("MZXW6YTBOI======"))).to_equal("foobar")

# ============================================================================
# RFC 4648 §10 — Base32hex (alphabet 0-9A-V) encode with padding
# ============================================================================

describe "RFC 4648 §10 Base32hex encode (padded)":

    it "empty input encodes to empty string":
        expect(base32_encode_hex(_empty())).to_equal("")

    it "'f' encodes to 'CO======'":
        expect(base32_encode_hex(_bytes_f())).to_equal("CO======")

    it "'fo' encodes to 'CPNG===='":
        expect(base32_encode_hex(_bytes_fo())).to_equal("CPNG====")

    it "'foo' encodes to 'CPNMU==='":
        expect(base32_encode_hex(_bytes_foo())).to_equal("CPNMU===")

    it "'foob' encodes to 'CPNMUOG='":
        expect(base32_encode_hex(_bytes_foob())).to_equal("CPNMUOG=")

    it "'fooba' encodes to 'CPNMUOJ1'":
        expect(base32_encode_hex(_bytes_fooba())).to_equal("CPNMUOJ1")

    it "'foobar' encodes to 'CPNMUOJ1E8======'":
        expect(base32_encode_hex(_bytes_foobar())).to_equal("CPNMUOJ1E8======")

# ============================================================================
# RFC 4648 §10 — Base32hex decode
# ============================================================================

describe "RFC 4648 §10 Base32hex decode":

    it "empty string decodes to empty bytes":
        expect(base32_decode_hex("").len()).to_equal(0)

    it "'CO======' decodes to 'f'":
        expect(bytes_to_text(base32_decode_hex("CO======"))).to_equal("f")

    it "'CPNG====' decodes to 'fo'":
        expect(bytes_to_text(base32_decode_hex("CPNG===="))).to_equal("fo")

    it "'CPNMU===' decodes to 'foo'":
        expect(bytes_to_text(base32_decode_hex("CPNMU==="))).to_equal("foo")

    it "'CPNMUOG=' decodes to 'foob'":
        expect(bytes_to_text(base32_decode_hex("CPNMUOG="))).to_equal("foob")

    it "'CPNMUOJ1' decodes to 'fooba'":
        expect(bytes_to_text(base32_decode_hex("CPNMUOJ1"))).to_equal("fooba")

    it "'CPNMUOJ1E8======' decodes to 'foobar'":
        expect(bytes_to_text(base32_decode_hex("CPNMUOJ1E8======"))).to_equal("foobar")

# ============================================================================
# Round-trip: encode then decode returns original bytes (Base32 standard)
# ============================================================================

describe "Base32 standard round-trip":

    it "empty round-trips":
        val encoded = base32_encode(_empty())
        val decoded = base32_decode(encoded)
        expect(decoded.len()).to_equal(0)

    it "'f' round-trips":
        val encoded = base32_encode(_bytes_f())
        val decoded = base32_decode(encoded)
        expect(bytes_to_text(decoded)).to_equal("f")

    it "'foobar' round-trips":
        val encoded = base32_encode(_bytes_foobar())
        val decoded = base32_decode(encoded)
        expect(bytes_to_text(decoded)).to_equal("foobar")

# ============================================================================
# Round-trip: Base32hex
# ============================================================================

describe "Base32hex round-trip":

    it "empty round-trips":
        val encoded = base32_encode_hex(_empty())
        val decoded = base32_decode_hex(encoded)
        expect(decoded.len()).to_equal(0)

    it "'foobar' round-trips":
        val encoded = base32_encode_hex(_bytes_foobar())
        val decoded = base32_decode_hex(encoded)
        expect(bytes_to_text(decoded)).to_equal("foobar")

# ============================================================================
# No-padding variant encodes correctly (no trailing '=')
# ============================================================================

describe "Base32 no-padding encode":

    it "empty input encodes to empty string (no-pad)":
        expect(base32_encode_no_pad(_empty())).to_equal("")

    it "'f' no-pad encodes to 'MY'":
        expect(base32_encode_no_pad(_bytes_f())).to_equal("MY")

    it "'fooba' no-pad encodes to 'MZXW6YTB' (already full block)":
        expect(base32_encode_no_pad(_bytes_fooba())).to_equal("MZXW6YTB")

    it "'foobar' no-pad encodes to 'MZXW6YTBOI'":
        expect(base32_encode_no_pad(_bytes_foobar())).to_equal("MZXW6YTBOI")

describe "Base32hex no-padding encode":

    it "'f' no-pad encodes to 'CO'":
        expect(base32_encode_hex_no_pad(_bytes_f())).to_equal("CO")

    it "'foobar' no-pad encodes to 'CPNMUOJ1E8'":
        expect(base32_encode_hex_no_pad(_bytes_foobar())).to_equal("CPNMUOJ1E8")
