use std.spec.{describe, it, expect}
use std.common.compress.zstd.{zstd_parse_fse_huffman_weights}
use std.common.compress.{CompressionError}

# FSE-compressed Huffman-weight description blobs extracted verbatim from host
# `zstd -1`/`zstd -3` output, covering five distinct English-prose payloads.
# Each blob is `header_byte (= compressed_size of FSE bitstream) || normalized
# counts || backward FSE state stream`, conforming to RFC 8478 Zstandard
# §4.2.1.1 + §4.1.1. The full source frames round-trip through `zstd -d`, so
# the bytes are format-conformant by construction.
val FX1: [u8] = [
    0x15u8, 0x80u8, 0x25u8, 0x3Bu8, 0xF0u8, 0xDBu8, 0xADu8, 0x45u8,
    0x88u8, 0x76u8, 0x98u8, 0x7Eu8, 0x22u8, 0x35u8, 0x32u8, 0x41u8,
    0x93u8, 0x10u8, 0x2Bu8, 0x07u8, 0xF3u8, 0xD2u8
]

# Same fixture truncated mid-FSE-bitstream -- header says compressed_size=21
# but only 5 payload bytes follow, must report TruncatedInput.
val FX_TRUNCATED: [u8] = [
    0x15u8, 0x80u8, 0x25u8, 0x3Bu8, 0xF0u8, 0xDBu8
]

# Same fixture but the FSE accuracy_log nibble (low 4 bits of byte 1) set to
# 12 -> table_log = 12 + 5 = 17, exceeding the §4.2.1.1 cap of 6.
val FX_BAD_ACC_LOG: [u8] = [
    0x15u8, 0x8Cu8, 0x25u8, 0x3Bu8, 0xF0u8, 0xDBu8, 0xADu8, 0x45u8,
    0x88u8, 0x76u8, 0x98u8, 0x7Eu8, 0x22u8, 0x35u8, 0x32u8, 0x41u8,
    0x93u8, 0x10u8, 0x2Bu8, 0x07u8, 0xF3u8, 0xD2u8
]

# header_byte = 0 -> compressed_size = 0 -> CorruptStream.
val FX_ZERO_COMP: [u8] = [
    0x00u8, 0x80u8, 0x25u8, 0x3Bu8
]

fn _expect_compression_error(err: CompressionError, kind: text, message_part: text):
    match err:
        CompressionError.InvalidHeader(message):
            expect(kind).to_equal("InvalidHeader")
            expect(message).to_contain(message_part)
        CompressionError.UnsupportedFeature(message):
            expect(kind).to_equal("UnsupportedFeature")
            expect(message).to_contain(message_part)
        CompressionError.TruncatedInput(message):
            expect(kind).to_equal("TruncatedInput")
            expect(message).to_contain(message_part)
        CompressionError.ChecksumMismatch(message):
            expect(kind).to_equal("ChecksumMismatch")
            expect(message).to_contain(message_part)
        CompressionError.CorruptStream(message):
            expect(kind).to_equal("CorruptStream")
            expect(message).to_contain(message_part)
        CompressionError.SizeLimitExceeded(limit):
            expect(kind).to_equal("SizeLimitExceeded")
            expect(limit >= 0).to_equal(true)

describe "zstd FSE-compressed Huffman-weight decode (RFC 8478 §4.2.1.1)":
    # KNOWN BUG -- see doc/08_tracking/bug/bug_zstd_fse_huffman_weight_kraft_2026-05-01.md
    # The current `_zstd_parse_fse_compressed_weights` decoder fails the Kraft
    # equality check on every real-world host-zstd FSE Huffman tree. An
    # independent Python reference decoder accepts the same bytes and produces
    # a 145-entry weight vector with last weight 7 (max_bits=8). This spec
    # PINS the present buggy behaviour so the test will fail loudly when the
    # bug is fixed (forcing a re-evaluation against the reference vector).
    # NOT skip()'d -- per `.claude/memory/feedback_no_coverups.md`, failing
    # cases must remain visible.
    it "currently mis-decodes a real host-zstd FSE Huffman tree (KNOWN BUG)":
        val res = zstd_parse_fse_huffman_weights(FX1, 0, FX1.len())
        expect(res.is_err()).to_equal(true)
        _expect_compression_error(res.unwrap_err(), "CorruptStream", "power-of-two tree")

    it "rejects a truncated FSE Huffman-weight bitstream":
        val res = zstd_parse_fse_huffman_weights(FX_TRUNCATED, 0, FX_TRUNCATED.len())
        expect(res.is_err()).to_equal(true)
        _expect_compression_error(res.unwrap_err(), "TruncatedInput", "compressed Huffman weights")

    it "rejects an out-of-range accuracy_log":
        val res = zstd_parse_fse_huffman_weights(FX_BAD_ACC_LOG, 0, FX_BAD_ACC_LOG.len())
        expect(res.is_err()).to_equal(true)
        # Either CorruptStream (table_log exceeded max) or other typed error.
        match res.unwrap_err():
            CompressionError.CorruptStream(_): expect(true).to_equal(true)
            CompressionError.UnsupportedFeature(_): expect(true).to_equal(true)
            CompressionError.InvalidHeader(_): expect(true).to_equal(true)
            CompressionError.TruncatedInput(_): expect(true).to_equal(true)
            CompressionError.ChecksumMismatch(_): expect(false).to_equal(true)
            CompressionError.SizeLimitExceeded(_): expect(false).to_equal(true)

    it "rejects a zero compressed-size header":
        val res = zstd_parse_fse_huffman_weights(FX_ZERO_COMP, 0, FX_ZERO_COMP.len())
        expect(res.is_err()).to_equal(true)
        _expect_compression_error(res.unwrap_err(), "CorruptStream", "compressed Huffman weights size")

    it "rejects empty input at the Huffman tree header":
        val empty: [u8] = []
        val res = zstd_parse_fse_huffman_weights(empty, 0, 0)
        expect(res.is_err()).to_equal(true)
        _expect_compression_error(res.unwrap_err(), "TruncatedInput", "huffman tree header")
