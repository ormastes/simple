use std.spec.*
use std.gc_async_mut.web.browser_session.{BrowserSession, BrowserResponse}
use std.gc_async_mut.web.browser_session_loading.*
use std.gc_async_mut.web.browser_session_runtime.*
use std.gc_async_mut.file_system.file_ops.{file_write_text}
use std.js.types.js_types.{JsValue}

fn _display_js(v: JsValue) -> text:
    match v:
        JsValue.Undefined: "undefined"
        JsValue.Null: "null"
        JsValue.Boolean(b): if b: "true" else: "false"
        JsValue.Number(n):
            var s = "{n}"
            if s.ends_with(".0"):
                s = s.slice(0, s.len() - 2)
            s
        JsValue.String(s): s
        JsValue.Object(id): "[object Object]"
        JsValue.Array(id): "[object Array]"
        JsValue.Function(id): "[Function]"
        JsValue.Symbol(id): "Symbol()"

describe "BrowserSession fetch WASM promise chain":
    it "chains fetched arrayBuffer bytes into WebAssembly.instantiate":
        var session = BrowserSession.new()
        session.open_html(
            "https://example.com/webgpu-wasm.html",
            "<html><body><script>var out = ''; window.fetch('/mod.wasm');</script></body></html>"
        )

        match session.take_pending_request():
            Some(request):
                val _d0 = file_write_text("build/tmp_fetch_wasm_chain_debug.txt", "request=" + request.kind + ":" + request.url)
                expect(request.kind).to_equal("fetch")
                expect(request.url).to_equal("https://example.com/mod.wasm")
                val committed = session.commit_network_response(BrowserResponse.create(
                    request_id: request.id,
                    kind: "fetch",
                    url: request.url,
                    status: 200,
                    headers: "Content-Type: application/wasm\n",
                    body: "0061736d01000000",
                    error: ""
                ))
                match committed:
                    Ok(_):
                        match session.eval_script("out"):
                            Ok(value):
                                val _d1 = file_write_text("build/tmp_fetch_wasm_chain_debug.txt", "out=" + _display_js(value))
                                expect(_display_js(value)).to_equal("instantiated:8:object")
                            Err(err):
                                val _d2 = file_write_text("build/tmp_fetch_wasm_chain_debug.txt", "eval_err=" + err)
                                expect("unexpected js error: {err}").to_equal("")
                    Err(err):
                        val _d3 = file_write_text("build/tmp_fetch_wasm_chain_debug.txt", "commit_err=" + err)
                        expect("unexpected commit error: {err}").to_equal("")
            nil:
                val _d4 = file_write_text("build/tmp_fetch_wasm_chain_debug.txt", "missing")
                expect("missing fetch request").to_equal("")
