use std.spec.*
use std.common.web.browser_session.{BrowserSession, BrowserResponse}
use std.js.types.js_types.{JsValue}

fn _display_js(v: JsValue) -> text:
    match v:
        JsValue.Undefined: "undefined"
        JsValue.Null: "null"
        JsValue.Boolean(b): if b: "true" else: "false"
        JsValue.Number(n):
            var s = "{n}"
            if s.ends_with(".0"):
                s = s.slice(0, s.len() - 2)
            s
        JsValue.String(s): s
        JsValue.Object(id): "[object Object]"
        JsValue.Array(id): "[object Array]"
        JsValue.Function(id): "[Function]"
        JsValue.Symbol(id): "Symbol()"

describe "BrowserSession async fetch":

    it "adopts promises returned from then callbacks":
        var session = BrowserSession.new()
        session.open_html(
            "https://example.com/app",
            "<html><body><script>var out = 'start'; Promise.resolve('seed').then(function() { return Promise.resolve('inner'); }).then(function(v) { out = v; });</script></body></html>"
        )

        val result = session.eval_script("out")
        match result:
            Ok(value) =>
                expect _display_js(value) == "inner"
            Err(e) =>
                expect false == true

    it "adopts rejected promises returned from then callbacks":
        var session = BrowserSession.new()
        session.open_html(
            "https://example.com/app",
            "<html><body><script>var out = 'start'; Promise.resolve('seed').then(function() { return Promise.reject('boom'); }).catch(function(err) { out = err; });</script></body></html>"
        )

        val result = session.eval_script("out")
        match result:
            Ok(value) =>
                expect _display_js(value) == "boom"
            Err(e) =>
                expect false == true

    it "installs promise globals":
        var session = BrowserSession.new()
        session.open_html("https://example.com/app", "<html><body>Ready</body></html>")
        val result = session.eval_script("typeof Promise.resolve + ':' + typeof Promise.prototype.then")
        match result:
            Ok(value) =>
                expect _display_js(value) == "function:function"
            Err(e) =>
                expect false == true

    it "queues a pending fetch and settles it later":
        var session = BrowserSession.new()
        session.open_html(
            "https://example.com/app",
            "<html><body><script>var out = ''; window.fetch('/data.txt').then(function(r) { return r.text(); }).then(function(t) { out = t; document.body.textContent = t; });</script></body></html>"
        )

        match session.take_pending_request():
            Some(request) =>
                expect request.kind == "fetch"
                expect request.url == "https://example.com/data.txt"
                val commit_result = session.commit_network_response(BrowserResponse.create(
                    request_id: request.id,
                    kind: "fetch",
                    url: request.url,
                    status: 200,
                    headers: "Set-Cookie: token=abc; Path=/\n",
                    body: "alpha",
                    error: ""
                ))
                match commit_result:
                    Ok(_) =>
                        val out_result = session.eval_script("out + ':' + document.body.textContent + ':' + document.cookie")
                        match out_result:
                            Ok(value) =>
                                expect (_display_js(value)).contains("alpha:alpha")
                                expect (_display_js(value)).contains("token=abc")
                            Err(e) =>
                                expect false == true
                    Err(e) =>
                        expect false == true
            nil:
                expect false == true

    it "rejects promise callbacks on transport error":
        var session = BrowserSession.new()
        session.open_html(
            "https://example.com/app",
            "<html><body><script>var out = 'start'; window.fetch('/data.txt').catch(function(err) { out = err; });</script></body></html>"
        )

        match session.take_pending_request():
            Some(request) =>
                val commit_result = session.commit_network_response(BrowserResponse.create(
                    request_id: request.id,
                    kind: "fetch",
                    url: request.url,
                    status: 0,
                    headers: "",
                    body: "",
                    error: "network down"
                ))
                match commit_result:
                    Err(e) =>
                        expect e == "network down"
                        val result = session.eval_script("out")
                        match result:
                            Ok(value) =>
                                expect _display_js(value) == "network down"
                            Err(err) =>
                                expect false == true
                    Ok(_) =>
                        expect false == true
            nil:
                expect false == true

    it "resolves http error responses with ok false and readable metadata":
        var session = BrowserSession.new()
        session.open_html(
            "https://example.com/app",
            "<html><body><script>var meta = 'start'; window.fetch('/missing.txt').then(function(r) { meta = r.status + ':' + r.ok + ':' + r.headersText + ':' + r.text() + ':' + r.text(); document.body.textContent = meta; });</script></body></html>"
        )

        match session.take_pending_request():
            Some(request) =>
                val commit_result = session.commit_network_response(BrowserResponse.create(
                    request_id: request.id,
                    kind: "fetch",
                    url: request.url,
                    status: 404,
                    headers: "X-Test: missing\n",
                    body: "missing",
                    error: ""
                ))
                match commit_result:
                    Ok(_) =>
                        val result = session.eval_script("meta + ':' + document.body.textContent")
                        match result:
                            Ok(value) =>
                                expect _display_js(value) == "404:false:X-Test: missing\n:missing:missing:404:false:X-Test: missing\n:missing:missing"
                            Err(e) =>
                                expect false == true
                    Err(e) =>
                        expect false == true
            nil:
                expect false == true

    it "exposes response.statusText for resolved fetch responses":
        var session = BrowserSession.new()
        session.open_html(
            "https://example.com/app",
            "<html><body><script>var meta = 'start'; window.fetch('/missing.txt').then(function(r) { meta = r.status + ':' + r.statusText + ':' + r.ok; document.body.textContent = meta; });</script></body></html>"
        )

        match session.take_pending_request():
            Some(request) =>
                val commit_result = session.commit_network_response(BrowserResponse.create(
                    request_id: request.id,
                    kind: "fetch",
                    url: request.url,
                    status: 404,
                    headers: "",
                    body: "missing",
                    error: ""
                ))
                match commit_result:
                    Ok(_) =>
                        val result = session.eval_script("meta + ':' + document.body.textContent")
                        match result:
                            Ok(value) =>
                                expect _display_js(value) == "404:Not Found:false:404:Not Found:false"
                            Err(e) =>
                                expect false == true
                    Err(e) =>
                        expect false == true
            nil:
                expect false == true

    it "returns a promise from response.text and unwraps it through then chaining":
        var session = BrowserSession.new()
        session.open_html(
            "https://example.com/app",
            "<html><body><script>var meta = 'start'; window.fetch('/data.txt').then(function(r) { meta = typeof r.text().then; return r.text(); }).then(function(t) { document.body.textContent = meta + ':' + t; });</script></body></html>"
        )

        match session.take_pending_request():
            Some(request) =>
                val commit_result = session.commit_network_response(BrowserResponse.create(
                    request_id: request.id,
                    kind: "fetch",
                    url: request.url,
                    status: 200,
                    headers: "",
                    body: "alpha",
                    error: ""
                ))
                match commit_result:
                    Ok(_) =>
                        val result = session.eval_script("document.body.textContent")
                        match result:
                            Ok(value) =>
                                expect _display_js(value) == "function:alpha"
                            Err(e) =>
                                expect false == true
                    Err(e) =>
                        expect false == true
            nil:
                expect false == true

    it "marks response.bodyUsed after text consumption":
        var session = BrowserSession.new()
        session.open_html(
            "https://example.com/app",
            "<html><body><script>var meta = 'start'; window.fetch('/data.txt').then(function(r) { var before = r.bodyUsed; var text = r.text(); meta = before + ':' + r.bodyUsed + ':' + text; document.body.textContent = meta; });</script></body></html>"
        )

        match session.take_pending_request():
            Some(request) =>
                val commit_result = session.commit_network_response(BrowserResponse.create(
                    request_id: request.id,
                    kind: "fetch",
                    url: request.url,
                    status: 200,
                    headers: "",
                    body: "alpha",
                    error: ""
                ))
                match commit_result:
                    Ok(_) =>
                        val result = session.eval_script("meta + ':' + document.body.textContent")
                        match result:
                            Ok(value) =>
                                expect _display_js(value) == "false:true:alpha:false:true:alpha"
                            Err(e) =>
                                expect false == true
                    Err(e) =>
                        expect false == true
            nil:
                expect false == true

    it "returns a promise from response.json for simple JSON bodies":
        var session = BrowserSession.new()
        session.open_html(
            "https://example.com/app",
            "<html><body><script>var meta = 'start'; window.fetch('/data.json').then(function(r) { meta = typeof r.json; return r.json(); }).then(function(v) { document.body.textContent = meta + ':' + v; });</script></body></html>"
        )

        match session.take_pending_request():
            Some(request) =>
                val commit_result = session.commit_network_response(BrowserResponse.create(
                    request_id: request.id,
                    kind: "fetch",
                    url: request.url,
                    status: 200,
                    headers: "Content-Type: application/json\n",
                    body: "42",
                    error: ""
                ))
                match commit_result:
                    Ok(_) =>
                        val result = session.eval_script("document.body.textContent")
                        match result:
                            Ok(value) =>
                                expect _display_js(value) == "function:42"
                            Err(e) =>
                                expect false == true
                    Err(e) =>
                        expect false == true
            nil:
                expect false == true

    it "serializes plain object fetch headers into the pending request":
        var session = BrowserSession.new()
        session.open_html(
            "https://example.com/app",
            "<html><body><script>window.fetch('/data.txt', { method: 'POST', headers: { 'X-Test': '1', 'Accept': 'text/plain' }, body: 'alpha' });</script></body></html>"
        )

        match session.take_pending_request():
            Some(request) =>
                expect request.kind == "fetch"
                expect request.method == "POST"
                expect request.body == "alpha"
                expect (request.headers).contains("X-Test: 1")
                expect (request.headers).contains("Accept: text/plain")
            nil:
                expect false == true

    it "ignores caller cookie headers and keeps the session cookie on fetch requests":
        var session = BrowserSession.new()
        session.open_html(
            "https://example.com/app",
            "<html><body><script>document.cookie = 'sid=abc123; Path=/'; window.fetch('/data.txt', { headers: { 'Cookie': 'manual=1', 'X-Test': '1' } });</script></body></html>"
        )

        match session.take_pending_request():
            Some(request) =>
                expect request.kind == "fetch"
                expect (request.headers).contains("X-Test: 1")
                expect (request.headers).contains("Cookie: sid=abc123")
                expect request.headers.contains("manual=1") == false
                expect request.headers.split("\n").len() == 2
            nil:
                expect false == true

    it "uses cookies set by one fetch response on the next fetch from the same page":
        var session = BrowserSession.new()
        session.open_html(
            "https://example.com/app",
            "<html><body><script>var first = ''; var second = ''; window.fetch('/first.txt').then(function(r) { return r.text(); }).then(function(t) { first = document.cookie; return window.fetch('/second.txt'); }).then(function(r) { return r.text(); }).then(function(t) { second = document.cookie; document.body.textContent = first + ':' + second + ':' + t; });</script></body></html>"
        )

        match session.take_pending_request():
            Some(first_request) =>
                expect first_request.headers.contains("Cookie:") == false
                val first_result = session.commit_network_response(BrowserResponse.create(
                    request_id: first_request.id,
                    kind: "fetch",
                    url: first_request.url,
                    status: 200,
                    headers: "Set-Cookie: token=abc; Path=/\n",
                    body: "one",
                    error: ""
                ))
                match first_result:
                    Ok(_) =>
                        match session.take_pending_request():
                            Some(second_request) =>
                                expect (second_request.headers).contains("Cookie: token=abc")
                                val second_result = session.commit_network_response(BrowserResponse.create(
                                    request_id: second_request.id,
                                    kind: "fetch",
                                    url: second_request.url,
                                    status: 200,
                                    headers: "",
                                    body: "two",
                                    error: ""
                                ))
                                match second_result:
                                    Ok(_) =>
                                        val result = session.eval_script("document.body.textContent")
                                        match result:
                                            Ok(value) =>
                                                expect _display_js(value) == "token=abc:token=abc:two"
                                            Err(e) =>
                                                expect false == true
                                    Err(e) =>
                                        expect false == true
                            nil:
                                expect false == true
                    Err(e) =>
                        expect false == true
            nil:
                expect false == true

    it "applies Set-Cookie from fetch responses without exposing it in response headersText":
        var session = BrowserSession.new()
        session.open_html(
            "https://example.com/app",
            "<html><body><script>var meta = 'start'; window.fetch('/data.txt').then(function(r) { meta = r.headersText + ':' + document.cookie; document.body.textContent = meta; });</script></body></html>"
        )

        match session.take_pending_request():
            Some(request) =>
                val commit_result = session.commit_network_response(BrowserResponse.create(
                    request_id: request.id,
                    kind: "fetch",
                    url: request.url,
                    status: 200,
                    headers: "Set-Cookie: token=abc; Path=/\nX-Test: ok\n",
                    body: "alpha",
                    error: ""
                ))
                match commit_result:
                    Ok(_) =>
                        val result = session.eval_script("meta + ':' + document.body.textContent")
                        match result:
                            Ok(value) =>
                                expect _display_js(value) == "X-Test: ok\\n:token=abc:X-Test: ok\\n:token=abc"
                            Err(e) =>
                                expect false == true
                    Err(e) =>
                        expect false == true
            nil:
                expect false == true

    it "settles multiple fetches by request id even when responses arrive out of order":
        var session = BrowserSession.new()
        session.open_html(
            "https://example.com/app",
            "<html><body><script>var first = ''; var second = ''; window.fetch('/a.txt').then(function(r) { return r.text(); }).then(function(t) { first = t; }); window.fetch('/b.txt').then(function(r) { return r.text(); }).then(function(t) { second = t; document.body.textContent = first + ':' + second; });</script></body></html>"
        )

        var req_a = nil
        var req_b = nil
        match session.take_pending_request():
            Some(request) =>
                req_a = Some(request)
            nil =>
                expect false == true
                return
        match session.take_pending_request():
            Some(request) =>
                req_b = Some(request)
            nil =>
                expect false == true
                return

        match req_a:
            Some(first_request) =>
                match req_b:
                    Some(second_request) =>
                        expect first_request.url == "https://example.com/a.txt"
                        expect second_request.url == "https://example.com/b.txt"
                        val second_result = session.commit_network_response(BrowserResponse.create(
                            request_id: second_request.id,
                            kind: "fetch",
                            url: second_request.url,
                            status: 200,
                            headers: "",
                            body: "B",
                            error: ""
                        ))
                        match second_result:
                            Ok(_) =>
                                val mid = session.eval_script("first + ':' + second + ':' + document.body.textContent")
                                match mid:
                                    Ok(value) =>
                                        expect _display_js(value) == ":B::B"
                                    Err(e) =>
                                        expect false == true
                            Err(e) =>
                                expect false == true
                        val first_result = session.commit_network_response(BrowserResponse.create(
                            request_id: first_request.id,
                            kind: "fetch",
                            url: first_request.url,
                            status: 200,
                            headers: "",
                            body: "A",
                            error: ""
                        ))
                        match first_result:
                            Ok(_) =>
                                val final = session.eval_script("first + ':' + second")
                                match final:
                                    Ok(value) =>
                                        expect _display_js(value) == "A:B"
                                    Err(e) =>
                                        expect false == true
                            Err(e) =>
                                expect false == true
                    nil =>
                        expect false == true
            nil =>
                expect false == true

    it "preserves fulfilled values through finally chains":
        var session = BrowserSession.new()
        session.open_html(
            "https://example.com/app",
            "<html><body><script>var out = 'start'; window.fetch('/data.txt').then(function(r) { return r.text(); }).finally(function() { document.body.textContent = 'cleanup'; return 'ignored'; }).then(function(t) { out = t + ':' + document.body.textContent; });</script></body></html>"
        )

        match session.take_pending_request():
            Some(request) =>
                val commit_result = session.commit_network_response(BrowserResponse.create(
                    request_id: request.id,
                    kind: "fetch",
                    url: request.url,
                    status: 200,
                    headers: "",
                    body: "alpha",
                    error: ""
                ))
                match commit_result:
                    Ok(_) =>
                        val result = session.eval_script("out")
                        match result:
                            Ok(value) =>
                                expect _display_js(value) == "alpha:cleanup"
                            Err(e) =>
                                expect false == true
                    Err(e) =>
                        expect false == true
            nil:
                expect false == true

    it "preserves rejected values through finally chains":
        var session = BrowserSession.new()
        session.open_html(
            "https://example.com/app",
            "<html><body><script>var out = 'start'; window.fetch('/data.txt').finally(function() { document.body.textContent = 'cleanup'; return 'ignored'; }).catch(function(err) { out = err + ':' + document.body.textContent; });</script></body></html>"
        )

        match session.take_pending_request():
            Some(request) =>
                val commit_result = session.commit_network_response(BrowserResponse.create(
                    request_id: request.id,
                    kind: "fetch",
                    url: request.url,
                    status: 0,
                    headers: "",
                    body: "",
                    error: "network down"
                ))
                match commit_result:
                    Err(e) =>
                        expect e == "network down"
                        val result = session.eval_script("out")
                        match result:
                            Ok(value) =>
                                expect _display_js(value) == "network down:cleanup"
                            Err(err) =>
                                expect false == true
                    Ok(_) =>
                        expect false == true
            nil:
                expect false == true