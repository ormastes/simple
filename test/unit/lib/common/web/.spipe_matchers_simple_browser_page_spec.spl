use std.spec.*

use std.common.web.simple_browser_page.{SimpleBrowserPageState, SimpleBrowserTarget,
    simple_browser_render_remote_page, simple_browser_hit_target,
    simple_browser_set_field_value, simple_browser_submit_get_url,
    simple_browser_submit_request}

fn _find_target(page: SimpleBrowserPageState, kind: text) -> SimpleBrowserTarget?:
    var idx = 0
    while idx < page.targets.len():
        if page.targets[idx].kind == kind:
            return Some(page.targets[idx])
        idx = idx + 1
    nil

describe "Simple browser page adapter":

    it "collects anchor and form targets from rendered html":
        val html = "<html><body><a href='/next'>Next</a><form action='/search' method='get'><input name='q' value='hello'><button>Go</button></form></body></html>"
        val page = simple_browser_render_remote_page("https://example.com/start", html, 320, 240)

        val anchor_target = _find_target(page, "anchor")
        match anchor_target:
            Some(target) =>
                expect target.action == "https://example.com/next"
                expect target.width > 0
            nil =>
                expect false == true

        val field_target = _find_target(page, "field")
        match field_target:
            Some(target) =>
                expect target.field_key.len() > 0
            nil =>
                expect false == true

        val submit_target = _find_target(page, "submit")
        match submit_target:
            Some(target) =>
                expect target.form_key.len() > 0
                expect target.action == "https://example.com/search"
            nil =>
                expect false == true

    it "preserves field edits and builds GET submission urls":
        val html = "<html><body><form action='/search' method='get'><input name='q' value='hello'><button>Go</button></form></body></html>"
        val page = simple_browser_render_remote_page("https://example.com/start", html, 320, 240)

        val field_target = _find_target(page, "field")
        val submit_target = _find_target(page, "submit")
        match field_target:
            Some(field_hit) =>
                match submit_target:
                    Some(submit_hit) =>
                        val edited = simple_browser_set_field_value(page, field_hit.field_key, "cats and dogs")
                        val next_url = simple_browser_submit_get_url(edited, submit_hit.form_key, submit_hit.action)
                        expect next_url == "https://example.com/search?q=cats+and+dogs"
                    nil =>
                        expect false == true
            nil =>
                expect false == true

    it "builds POST submission requests for post forms":
        val html = "<html><body><form action='/submit' method='post'><input name='q' value='hello'><button>Save</button></form></body></html>"
        val page = simple_browser_render_remote_page("https://example.com/start", html, 320, 240)

        val field_target = _find_target(page, "field")
        val submit_target = _find_target(page, "submit")
        match field_target:
            Some(field_hit) =>
                match submit_target:
                    Some(submit_hit) =>
                        val edited = simple_browser_set_field_value(page, field_hit.field_key, "cats and dogs")
                        val request = simple_browser_submit_request(edited, submit_hit.form_key, submit_hit.action, submit_hit.method)
                        expect request.method == "POST"
                        expect request.url == "https://example.com/submit"
                        expect request.body == "q=cats+and+dogs"
                        expect request.content_type == "application/x-www-form-urlencoded"
                    nil =>
                        expect false == true
            nil =>
                expect false == true

    it "hit tests the rendered target rectangles":
        val html = "<html><body><a href='/go'>Go</a></body></html>"
        val page = simple_browser_render_remote_page("https://example.com/base", html, 320, 240)
        val anchor_target = _find_target(page, "anchor")
        match anchor_target:
            Some(target) =>
                val hit = simple_browser_hit_target(page, target.x + 1, target.y + 1)
                match hit:
                    Some(resolved) =>
                        expect resolved.kind == "anchor"
                        expect resolved.action == "https://example.com/go"
                    nil =>
                        expect false == true
            nil =>
                expect false == true