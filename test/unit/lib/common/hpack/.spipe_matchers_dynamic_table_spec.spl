# Specification for src/lib/common/hpack/dynamic_table.spl
#
# Verifies the RFC 7541 §2.3.2 / §4 dynamic table behaviour:
#   - empty table, single insert, multi-insert ordering
#   - eviction when size cap exceeded
#   - single-entry-larger-than-max empties table without inserting
#   - resize-down evicts, resize-up preserves entries
#   - dynamic_table_find: full match, name-only match, no match
#   - eviction order is from the oldest end

use std.spipe.*
use std.common.hpack.dynamic_table.{
    DynamicEntry,
    DynamicTable,
    dynamic_table_new,
    dynamic_table_insert,
    dynamic_table_lookup,
    dynamic_table_find,
    dynamic_table_resize,
}

# ---------------------------------------------------------------------------
# Module-scope helpers — build test fixtures outside it blocks to avoid
# interpreter-mode mutation-persistence footgun.
# ---------------------------------------------------------------------------

fn _make_empty() -> DynamicTable:
    dynamic_table_new(4096)

fn _make_single() -> DynamicTable:
    dynamic_table_insert(dynamic_table_new(4096), "content-type", "text/plain")

# Insert two entries: "content-type: text/plain" then "accept: */*".
# After two inserts, newest (accept) is at index 1, oldest (content-type) at index 2.
fn _make_two() -> DynamicTable:
    val t0 = dynamic_table_new(4096)
    val t1 = dynamic_table_insert(t0, "content-type", "text/plain")
    dynamic_table_insert(t1, "accept", "*/*")

# Small-cap table that fits exactly one small entry.
# "a: b" = 1 + 1 + 32 = 34 bytes.  cap = 68 fits two, but we'll insert three
# to force eviction of the oldest.
fn _make_eviction_scenario() -> DynamicTable:
    # cap = 68 bytes — fits exactly two "a: b"-sized entries (34 each)
    val t0 = dynamic_table_new(68)
    val t1 = dynamic_table_insert(t0, "a", "1")   # size 34
    val t2 = dynamic_table_insert(t1, "b", "2")   # size 34, total 68
    # insert third entry: evicts oldest ("a","1") to make room
    dynamic_table_insert(t2, "c", "3")

# Table where a single entry is larger than max_size.
fn _make_oversized_insert() -> DynamicTable:
    # max_size = 10, entry "name: value" = 4+5+32 = 41 > 10
    val t0 = dynamic_table_new(10)
    dynamic_table_insert(t0, "name", "value")

# Table used for resize-down test: two entries, then resize below one entry.
fn _make_before_resize_down() -> DynamicTable:
    val t0 = dynamic_table_new(200)
    val t1 = dynamic_table_insert(t0, "x", "1")  # 1+1+32 = 34
    dynamic_table_insert(t1, "y", "2")            # 34 each, total 68

fn _make_after_resize_down() -> DynamicTable:
    dynamic_table_resize(_make_before_resize_down(), 34)

fn _make_after_resize_up() -> DynamicTable:
    dynamic_table_resize(_make_two(), 8192)

# Table with two entries having the same name but different values, plus one
# with a matching name+value, for dynamic_table_find tests.
fn _make_find_table() -> DynamicTable:
    # Insert oldest first so newest ends at index 1.
    val t0 = dynamic_table_new(4096)
    val t1 = dynamic_table_insert(t0, "cache-control", "no-store")
    val t2 = dynamic_table_insert(t1, "cache-control", "no-cache")
    dynamic_table_insert(t2, "content-type", "application/json")

# ---------------------------------------------------------------------------
# Specs
# ---------------------------------------------------------------------------

describe "DynamicTable — empty table":

    it "lookup on empty table returns nil for index 1":
        val t = _make_empty()
        expect dynamic_table_lookup(t, 1).? == false

    it "lookup on empty table returns nil for index 0":
        val t = _make_empty()
        expect dynamic_table_lookup(t, 0).? == false

    it "lookup on empty table returns nil for negative index":
        val t = _make_empty()
        expect dynamic_table_lookup(t, -1).? == false

    it "empty table has current_size 0":
        val t = _make_empty()
        expect t.current_size == 0

    it "empty table has correct max_size":
        val t = _make_empty()
        expect t.max_size == 4096

describe "DynamicTable — single insert":

    it "lookup at relative index 1 returns the entry":
        val t = _make_single()
        val e = dynamic_table_lookup(t, 1) ?? DynamicEntry(name: "", value: "")
        expect e.name == "content-type"
        expect e.value == "text/plain"

    it "lookup at relative index 2 returns nil after single insert":
        val t = _make_single()
        expect dynamic_table_lookup(t, 2).? == false

    it "current_size equals name_len + value_len + 32":
        val t = _make_single()
        # "content-type".len() = 12, "text/plain".len() = 10, +32 = 54
        expect t.current_size == 54

    it "entries length is 1 after single insert":
        val t = _make_single()
        expect t.entries.len() == 1

describe "DynamicTable — multi-insert ordering":

    it "most recent entry is at relative index 1":
        val t = _make_two()
        val e = dynamic_table_lookup(t, 1) ?? DynamicEntry(name: "", value: "")
        expect e.name == "accept"
        expect e.value == "*/*"

    it "oldest entry is at the highest relative index":
        val t = _make_two()
        val e = dynamic_table_lookup(t, 2) ?? DynamicEntry(name: "", value: "")
        expect e.name == "content-type"
        expect e.value == "text/plain"

    it "entries length is 2 after two inserts":
        val t = _make_two()
        expect t.entries.len() == 2

    it "current_size is sum of both entry sizes":
        val t = _make_two()
        # "content-type"(12) + "text/plain"(10) + 32 = 54
        # "accept"(6) + "*/*"(3) + 32 = 41
        # total = 95
        expect t.current_size == 95

describe "DynamicTable — eviction when size cap exceeded":

    it "evicts oldest entry when inserting third entry into cap=68 table":
        val t = _make_eviction_scenario()
        # ("a","1") was evicted; newest is ("c","3"), then ("b","2")
        expect t.entries.len() == 2

    it "newest entry after eviction is at index 1":
        val t = _make_eviction_scenario()
        val e = dynamic_table_lookup(t, 1) ?? DynamicEntry(name: "", value: "")
        expect e.name == "c"
        expect e.value == "3"

    it "second entry after eviction is the middle insert":
        val t = _make_eviction_scenario()
        val e = dynamic_table_lookup(t, 2) ?? DynamicEntry(name: "", value: "")
        expect e.name == "b"
        expect e.value == "2"

    it "evicted entry is not accessible":
        val t = _make_eviction_scenario()
        expect dynamic_table_lookup(t, 3).? == false

    it "current_size after eviction fits within max_size":
        val t = _make_eviction_scenario()
        expect t.current_size < 69

describe "DynamicTable — single entry larger than max_size":

    it "table is empty after oversized insert":
        val t = _make_oversized_insert()
        expect t.entries.len() == 0

    it "current_size is 0 after oversized insert":
        val t = _make_oversized_insert()
        expect t.current_size == 0

    it "oversized entry is not present in the table":
        val t = _make_oversized_insert()
        expect dynamic_table_lookup(t, 1).? == false

    it "max_size is unchanged after oversized insert":
        val t = _make_oversized_insert()
        expect t.max_size == 10

describe "DynamicTable — resize":

    it "resize down evicts oldest entries to fit":
        val t = _make_after_resize_down()
        # original had ("y","2") at idx 1, ("x","1") at idx 2; resize to 34
        # keeps only one entry (the newest)
        expect t.entries.len() == 1

    it "resize down keeps newest entry":
        val t = _make_after_resize_down()
        val e = dynamic_table_lookup(t, 1) ?? DynamicEntry(name: "", value: "")
        expect e.name == "y"
        expect e.value == "2"

    it "resize up does not change number of entries":
        val before = _make_two()
        val after = _make_after_resize_up()
        expect after.entries.len() == before.entries.len()

    it "resize up raises max_size":
        val t = _make_after_resize_up()
        expect t.max_size == 8192

    it "resize up preserves entry at index 1":
        val t = _make_after_resize_up()
        val e = dynamic_table_lookup(t, 1) ?? DynamicEntry(name: "", value: "")
        expect e.name == "accept"

    it "resize down sets correct new max_size":
        val t = _make_after_resize_down()
        expect t.max_size == 34

describe "DynamicTable — dynamic_table_find":

    it "returns full match for existing (name, value)":
        val t = _make_find_table()
        # content-type: application/json is newest (index 1)
        val r = dynamic_table_find(t, "content-type", "application/json")
        expect r.0 == 1
        expect r.1 == true

    it "returns name-only match when value differs":
        # cache-control appears twice; no entry has value "max-age=3600"
        val t = _make_find_table()
        val r = dynamic_table_find(t, "cache-control", "max-age=3600")
        expect r.0 > 0
        expect r.1 == false

    it "returns (-1, false) for unknown name":
        val t = _make_find_table()
        val r = dynamic_table_find(t, "x-custom", "anything")
        expect r.0 == -1
        expect r.1 == false

    it "find on empty table returns (-1, false)":
        val t = _make_empty()
        val r = dynamic_table_find(t, "content-type", "text/html")
        expect r.0 == -1
        expect r.1 == false

    it "returns the newest matching index for name-only match":
        # cache-control appears at indices 2 (no-cache, newer) and 3 (no-store, oldest)
        val t = _make_find_table()
        val r = dynamic_table_find(t, "cache-control", "max-age=0")
        # newest cache-control is at index 2 (content-type is 1, cache-control no-cache is 2)
        expect r.0 == 2
        expect r.1 == false

describe "DynamicTable — eviction order is from oldest end":

    it "three inserts into tight cap evict in FIFO (oldest-first) order":
        # cap = 34 fits exactly one entry (size 34 each)
        val t0 = dynamic_table_new(34)
        val t1 = dynamic_table_insert(t0, "a", "1")
        val t2 = dynamic_table_insert(t1, "b", "2")
        val t3 = dynamic_table_insert(t2, "c", "3")
        # After each insert only one entry fits; newest survives
        val e1 = dynamic_table_lookup(t1, 1) ?? DynamicEntry(name: "", value: "")
        val e2 = dynamic_table_lookup(t2, 1) ?? DynamicEntry(name: "", value: "")
        val e3 = dynamic_table_lookup(t3, 1) ?? DynamicEntry(name: "", value: "")
        expect e1.name == "a"
        expect e2.name == "b"
        expect e3.name == "c"

    it "after each eviction the table has at most one entry":
        val t0 = dynamic_table_new(34)
        val t1 = dynamic_table_insert(t0, "a", "1")
        val t2 = dynamic_table_insert(t1, "b", "2")
        val t3 = dynamic_table_insert(t2, "c", "3")
        expect t1.entries.len() == 1
        expect t2.entries.len() == 1
        expect t3.entries.len() == 1