@allow(spipe_empty_examples)
@allow(spipe_boolean_wrapper_assertions)
use std.sdn.value.{SdnValue, Span}


fn main():

    describe "minimal":
        it "int works":
            val v = SdnValue.int(42)
            expect v.is_int() == true