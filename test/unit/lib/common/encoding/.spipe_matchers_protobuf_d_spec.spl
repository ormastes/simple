# Protobuf wire-format encoder/decoder spec
#
# @covers src/lib/common/encoding/protobuf.spl
#
# NOTE: All payload-building is done in module-level helper functions to avoid
# the it-block var-mutation footgun
# (see .claude/memory/feedback_it_block_var_mutation.md).

use std.common.encoding.protobuf.{pb_encode_varint, pb_decode_varint, pb_encode_zigzag, pb_decode_zigzag, pb_encode_tag, pb_encode_field_varint, pb_encode_field_bytes, pb_encode_field_string, pb_encode_fixed32, pb_encode_fixed64, pb_decode_field}

    it "round-trips -1":
        expect pb_decode_zigzag(pb_encode_zigzag(-1)) == -1

    it "round-trips 1":
        expect pb_decode_zigzag(pb_encode_zigzag(1)) == 1

    it "round-trips large negative":
        expect pb_decode_zigzag(pb_encode_zigzag(-100000)) == -100000

# ============================================================================
# Tag encoding specs
# ============================================================================

describe "pb_encode_tag":
    it "encodes field 1, wire_type 0 (varint) as single byte 0x08":
        val enc = _tag_field1_varint()
        expect enc.len() == 1
        expect enc[0].to_i64() == 0x08

    it "encodes field 2, wire_type 2 (length-delimited) as single byte 0x12":
        val enc = _tag_field2_len()
        expect enc.len() == 1
        expect enc[0].to_i64() == 0x12

# ============================================================================
# Fixed32 / Fixed64 specs
# ============================================================================

describe "pb_encode_fixed32":
    it "encodes 300 as 4 little-endian bytes":
        val enc = _fixed32_300()
        expect enc.len() == 4
        expect enc[0].to_i64() == 44
        expect enc[1].to_i64() == 1)    # (300>>8
        expect enc[2].to_i64() == 0
        expect enc[3].to_i64() == 0

describe "pb_encode_fixed64":
    it "encodes 1000000000000 as 8 little-endian bytes":
        val enc = _fixed64_as_field()
        # Just verify the tag+value field is 9 bytes (1 tag byte + 8 data bytes)
        expect enc.len() == 9

# ============================================================================
# Full message round-trip spec
# ============================================================================

describe "protobuf message round-trip":
    context "field1 = varint 150":
        it "decodes field_num = 1":
            val r = pb_decode_field(_roundtrip_message(), 0)
            expect r[0] == 1

        it "decodes wire_type = 0 (varint)":
            expect _roundtrip_field1_wire_type() == 0

        it "decodes value = 150":
            expect _roundtrip_field1_value() == 150

    context "field2 = string testing":
        it "decodes field_num = 2":
            expect _roundtrip_field2_field_num() == 2

        it "decodes wire_type = 2 (length-delimited)":
            expect _roundtrip_field2_wire_type() == 2

        it "decodes 7 bytes for 'testing'":
            expect _roundtrip_field2_bytes_len() == 7

        it "first decoded byte = ord('t') = 116":
            expect _roundtrip_field2_first_byte() == 116

# ============================================================================
# Fixed field decode round-trip
# ============================================================================

describe "pb_decode_field fixed32":
    it "decodes field_num = 3":
        val r = pb_decode_field(_fixed32_300_as_field(), 0)
        expect r[0] == 3

    it "decodes wire_type = 5":
        val r = pb_decode_field(_fixed32_300_as_field(), 0)
        expect r[1] == 5

    it "decodes value = 300":
        val r = pb_decode_field(_fixed32_300_as_field(), 0)
        expect r[2] == 300

    it "advances pos by 5 (1 tag + 4 data)":
        val r = pb_decode_field(_fixed32_300_as_field(), 0)
        expect r[3] == 5

describe "pb_decode_field fixed64":
    it "decodes field_num = 4":
        val r = pb_decode_field(_fixed64_as_field(), 0)
        expect r[0] == 4

    it "decodes wire_type = 1":
        val r = pb_decode_field(_fixed64_as_field(), 0)
        expect r[1] == 1

    it "decodes value = 1000000000000":
        val r = pb_decode_field(_fixed64_as_field(), 0)
        expect r[2] == 1000000000000

    it "advances pos by 9 (1 tag + 8 data)":
        val r = pb_decode_field(_fixed64_as_field(), 0)
        expect r[3] == 9