describe "CBOR — cbor_encode_negint":

    it "-1 encodes as [0x20]":
        expect _negint_minus1_ok() == true

    it "-24 encodes as [0x37]":
        expect _negint_minus24_ok() == true

    it "-25 encodes as [0x38, 0x18]":
        expect _negint_minus25_ok() == true

    it "-100 encodes as [0x38, 0x63]":
        expect _negint_minus100_ok() == true

# ============================================================================
# Spec — unified cbor_decode
# ============================================================================

describe "CBOR — unified cbor_decode":

    it "decodes unsigned integer":
        expect _decode_uint_ok() == true

    it "decodes negative integer":
        expect _decode_negint_ok() == true

    it "decodes text string":
        expect _decode_text_ok() == true

    it "decodes byte string":
        expect _decode_bytes_ok() == true

    it "decodes bool true":
        expect _decode_bool_true_ok() == true

    it "decodes bool false":
        expect _decode_bool_false_ok() == true

    it "decodes null":
        expect _decode_null_ok() == true

    it "decodes undefined":
        expect _decode_undefined_ok() == true

    it "decodes array [1, 2, 3]":
        expect _decode_array_ok() == true

    it "decodes map {1: 2}":
        expect _decode_map_ok() == true

    it "decodes tagged value":
        expect _decode_tag_ok() == true

    it "decodes nested array [[1], [2, 3]]":
        expect _decode_nested_array_ok() == true