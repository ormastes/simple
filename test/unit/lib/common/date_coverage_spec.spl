describe "Locale Dates - Relative Time":
    context "English locale":
        it "formats seconds ago":
            var locale = ("en", "US", "", "")
            expect(relative_time_seconds(-30, locale)).to_equal("a few seconds ago")

        it "formats seconds in future":
            var locale = ("en", "US", "", "")
            expect(relative_time_seconds(30, locale)).to_equal("in a few seconds")

        it "formats minutes ago":
            var locale = ("en", "US", "", "")
            expect(relative_time_seconds(-300, locale)).to_equal("5 minutes ago")

        it "formats minutes in future":
            var locale = ("en", "US", "", "")
            expect(relative_time_seconds(300, locale)).to_equal("in 5 minutes")

        it "formats hours ago":
            var locale = ("en", "US", "", "")
            expect(relative_time_seconds(-7200, locale)).to_equal("2 hours ago")

        it "formats hours in future":
            var locale = ("en", "US", "", "")
            expect(relative_time_seconds(7200, locale)).to_equal("in 2 hours")

        it "formats days ago":
            var locale = ("en", "US", "", "")
            expect(relative_time_seconds(-172800, locale)).to_equal("2 days ago")

        it "formats days in future":
            var locale = ("en", "US", "", "")
            expect(relative_time_seconds(172800, locale)).to_equal("in 2 days")

    context "French locale":
        it "formats seconds ago in French":
            var locale = ("fr", "FR", "", "")
            expect(relative_time_seconds(-30, locale)).to_equal("il y a quelques secondes")

        it "formats seconds in future in French":
            var locale = ("fr", "FR", "", "")
            expect(relative_time_seconds(30, locale)).to_equal("dans quelques secondes")

        it "formats minutes ago in French":
            var locale = ("fr", "FR", "", "")
            expect(relative_time_seconds(-300, locale)).to_equal("il y a 5 minutes")

        it "formats minutes in future in French":
            var locale = ("fr", "FR", "", "")
            expect(relative_time_seconds(300, locale)).to_equal("dans 5 minutes")

        it "formats hours ago in French":
            var locale = ("fr", "FR", "", "")
            expect(relative_time_seconds(-7200, locale)).to_equal("il y a 2 heures")

        it "formats hours in future in French":
            var locale = ("fr", "FR", "", "")
            expect(relative_time_seconds(7200, locale)).to_equal("dans 2 heures")

        it "formats days ago in French":
            var locale = ("fr", "FR", "", "")
            expect(relative_time_seconds(-172800, locale)).to_equal("il y a 2 jours")

        it "formats days in future in French":
            var locale = ("fr", "FR", "", "")
            expect(relative_time_seconds(172800, locale)).to_equal("dans 2 jours")

    context "Spanish locale":
        it "formats seconds ago in Spanish":
            var locale = ("es", "ES", "", "")
            expect(relative_time_seconds(-30, locale)).to_equal("hace unos segundos")

        it "formats seconds in future in Spanish":
            var locale = ("es", "ES", "", "")
            expect(relative_time_seconds(30, locale)).to_equal("en unos segundos")

        it "formats minutes ago in Spanish":
            var locale = ("es", "ES", "", "")
            expect(relative_time_seconds(-300, locale)).to_equal("hace 5 minutos")

        it "formats minutes in future in Spanish":
            var locale = ("es", "ES", "", "")
            expect(relative_time_seconds(300, locale)).to_equal("en 5 minutos")

        it "formats hours ago in Spanish":
            var locale = ("es", "ES", "", "")
            var result = relative_time_seconds(-7200, locale)
            expect(result).to_equal("hace 2 horas")

        it "formats hours in future in Spanish":
            var locale = ("es", "ES", "", "")
            var result = relative_time_seconds(7200, locale)
            expect(result).to_equal("en 2 horas")

        it "formats days ago in Spanish":
            var locale = ("es", "ES", "", "")
            var result = relative_time_seconds(-172800, locale)
            expect(result).to_contain("hace 2")

        it "formats days in future in Spanish":
            var locale = ("es", "ES", "", "")
            var result = relative_time_seconds(172800, locale)
            expect(result).to_contain("en 2")

    context "time_ago and time_until wrappers":
        it "time_ago delegates to relative_time_seconds":
            var locale = ("en", "US", "", "")
            expect(time_ago(-3600, locale)).to_equal("1 hours ago")

        it "time_until delegates to relative_time_seconds":
            var locale = ("en", "US", "", "")
            expect(time_until(3600, locale)).to_equal("in 1 hours")

# ============================================================================
# Test Group 25: Edge Cases and Boundary Conditions
# ============================================================================

describe "Edge Cases - Leap Year Boundaries":
    it "Feb 28 is valid on non-leap year":
        expect(is_valid_date(2025, 2, 28)).to_equal(true)

    it "Feb 29 is invalid on non-leap year":
        expect(is_valid_date(2025, 2, 29)).to_equal(false)

    it "Feb 29 is valid on leap year":
        expect(is_valid_date(2024, 2, 29)).to_equal(true)

    it "Feb 29 is valid on year 2000 (div by 400)":
        expect(is_valid_date(2000, 2, 29)).to_equal(true)

    it "Feb 29 is invalid on year 1900 (div by 100 not 400)":
        expect(is_valid_date(1900, 2, 29)).to_equal(false)

describe "Edge Cases - Day of Year Boundaries":
    it "Dec 31 non-leap returns 365":
        expect(day_of_year((2025, 12, 31))).to_equal(365)

    it "Dec 31 leap returns 366":
        expect(day_of_year((2024, 12, 31))).to_equal(366)

    it "Mar 1 non-leap returns 60":
        expect(day_of_year((2025, 3, 1))).to_equal(60)

    it "Mar 1 leap returns 61":
        expect(day_of_year((2024, 3, 1))).to_equal(61)

describe "Edge Cases - Month Arithmetic Overflow":
    it "adding 12 months equals next year":
        var result = add_months((2025, 6, 15), 12)
        expect(result[0]).to_equal(2026)
        expect(result[1]).to_equal(6)

    it "adding 24 months equals two years later":
        var result = add_months((2025, 6, 15), 24)
        expect(result[0]).to_equal(2027)
        expect(result[1]).to_equal(6)

    it "subtracting 12 months equals previous year":
        var result = add_months((2025, 6, 15), -12)
        expect(result[0]).to_equal(2024)
        expect(result[1]).to_equal(6)

describe "Edge Cases - Constants Verification":
    it "MONDAY equals 1":
        expect(MONDAY).to_equal(1)

    it "SUNDAY equals 7":
        expect(SUNDAY).to_equal(7)

    it "THURSDAY equals 4":
        expect(THURSDAY).to_equal(4)

    it "JANUARY equals 1":
        expect(JANUARY).to_equal(1)

    it "DECEMBER equals 12":
        expect(DECEMBER).to_equal(12)

    it "FEBRUARY equals 2":
        expect(FEBRUARY).to_equal(2)
