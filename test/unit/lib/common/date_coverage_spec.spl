# ============================================================================
# Test Group 22: locale/dates.spl - format_date
# ============================================================================

describe "Locale Dates - format_date":
    it "formats yyyy-MM-dd pattern":
        var locale = ("en", "US", "", "")
        var result = format_date(2026, 2, 11, "yyyy-MM-dd", locale)
        expect(result).to_equal("2026-02-11")

    it "pads month with leading zero":
        var locale = ("en", "US", "", "")
        var result = format_date(2026, 2, 11, "yyyy-MM-dd", locale)
        expect(result).to_contain("-02-")

    it "does not pad month 10":
        var locale = ("en", "US", "", "")
        var result = format_date(2026, 10, 5, "yyyy-MM-dd", locale)
        expect(result).to_contain("-10-")

    it "pads day with leading zero":
        var locale = ("en", "US", "", "")
        var result = format_date(2026, 2, 5, "yyyy-MM-dd", locale)
        expect(result).to_end_with("-05")

    it "does not pad day 15":
        var locale = ("en", "US", "", "")
        var result = format_date(2026, 2, 15, "yyyy-MM-dd", locale)
        expect(result).to_end_with("-15")

    it "formats with full month name pattern":
        var locale = ("en", "US", "", "")
        var result = format_date(2026, 2, 11, "MMMM dd, yyyy", locale)
        expect(result).to_contain("February")

    it "formats with short month name pattern":
        var locale = ("en", "US", "", "")
        var result = format_date(2026, 2, 11, "MMM dd, yyyy", locale)
        expect(result).to_contain("Feb")

    it "formats with French locale full month":
        var locale = ("fr", "FR", "", "")
        var result = format_date(2026, 2, 11, "MMMM dd, yyyy", locale)
        expect(result).to_contain("vri")

# ============================================================================
# Test Group 23: locale/dates.spl - format_time
# ============================================================================

describe "Locale Dates - format_time":
    it "formats HH:mm:ss pattern":
        var locale = ("en", "US", "", "")
        var result = format_time(14, 30, 0, "HH:mm:ss", locale)
        expect(result).to_equal("14:30:00")

    it "pads hour with leading zero":
        var locale = ("en", "US", "", "")
        var result = format_time(9, 30, 0, "HH:mm:ss", locale)
        expect(result).to_start_with("09")

    it "does not pad hour 14":
        var locale = ("en", "US", "", "")
        var result = format_time(14, 30, 0, "HH:mm:ss", locale)
        expect(result).to_start_with("14")

    it "formats 12-hour with PM":
        var locale = ("en", "US", "", "")
        var result = format_time(14, 30, 0, "hh:mm a", locale)
        expect(result).to_contain("PM")

    it "formats 12-hour with AM":
        var locale = ("en", "US", "", "")
        var result = format_time(9, 30, 0, "hh:mm a", locale)
        expect(result).to_contain("AM")

    it "converts hour 0 to 12 in 12-hour format":
        var locale = ("en", "US", "", "")
        var result = format_time(0, 0, 0, "hh:mm a", locale)
        expect(result).to_start_with("12")
        expect(result).to_contain("AM")

    it "converts hour 12 to 12 in 12-hour format":
        var locale = ("en", "US", "", "")
        var result = format_time(12, 0, 0, "hh:mm a", locale)
        expect(result).to_start_with("12")
        expect(result).to_contain("PM")

    it "pads 12-hour when less than 10":
        var locale = ("en", "US", "", "")
        var result = format_time(1, 0, 0, "hh:mm a", locale)
        expect(result).to_start_with("01")

    it "does not pad 12-hour when 10 or more":
        var locale = ("en", "US", "", "")
        var result = format_time(22, 0, 0, "hh:mm a", locale)
        expect(result).to_start_with("10")

    it "pads minute with leading zero":
        var locale = ("en", "US", "", "")
        var result = format_time(14, 5, 0, "HH:mm:ss", locale)
        expect(result).to_contain(":05:")

    it "does not pad minute 30":
        var locale = ("en", "US", "", "")
        var result = format_time(14, 30, 0, "HH:mm:ss", locale)
        expect(result).to_contain(":30:")

    it "pads second with leading zero":
        var locale = ("en", "US", "", "")
        var result = format_time(14, 30, 5, "HH:mm:ss", locale)
        expect(result).to_end_with(":05")

    it "does not pad second 45":
        var locale = ("en", "US", "", "")
        var result = format_time(14, 30, 45, "HH:mm:ss", locale)
        expect(result).to_end_with(":45")

