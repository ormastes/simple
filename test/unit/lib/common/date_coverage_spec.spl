# Test Group 1: date/types.spl - Constants and Day/Month Names
# ============================================================================

describe "Date Types - Day Names":
    it "returns Monday for day 1":
        expect(day_name(1)).to_equal("Monday")

    it "returns Tuesday for day 2":
        expect(day_name(2)).to_equal("Tuesday")

    it "returns Wednesday for day 3":
        expect(day_name(3)).to_equal("Wednesday")

    it "returns Thursday for day 4":
        expect(day_name(4)).to_equal("Thursday")

    it "returns Friday for day 5":
        expect(day_name(5)).to_equal("Friday")

    it "returns Saturday for day 6":
        expect(day_name(6)).to_equal("Saturday")

    it "returns Sunday for day 7":
        expect(day_name(7)).to_equal("Sunday")

    it "returns Invalid for day 0":
        expect(day_name(0)).to_equal("Invalid")

    it "returns Invalid for day 8":
        expect(day_name(8)).to_equal("Invalid")

