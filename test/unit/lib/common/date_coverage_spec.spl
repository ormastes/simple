# Test Group 9: date/types.spl - Weekend/Weekday/Quarter
# ============================================================================

describe "Date Types - Weekend and Weekday":
    it "identifies Saturday as weekend":
        # 2025-01-04 is Saturday
        expect(is_weekend((2025, 1, 4))).to_equal(true)

    it "identifies Sunday as weekend":
        # 2025-01-05 is Sunday
        expect(is_weekend((2025, 1, 5))).to_equal(true)

    it "identifies Monday as not weekend":
        # 2025-01-06 is Monday
        expect(is_weekend((2025, 1, 6))).to_equal(false)

    it "identifies Friday as not weekend":
        # 2025-01-03 is Friday
        expect(is_weekend((2025, 1, 3))).to_equal(false)

    it "identifies Monday as weekday":
        expect(is_weekday((2025, 1, 6))).to_equal(true)

    it "identifies Saturday as not weekday":
        expect(is_weekday((2025, 1, 4))).to_equal(false)

describe "Date Types - Quarter":
    it "returns Q1 for January":
        expect(quarter((2025, 1, 15))).to_equal(1)

    it "returns Q1 for March":
        expect(quarter((2025, 3, 31))).to_equal(1)

    it "returns Q2 for April":
        expect(quarter((2025, 4, 1))).to_equal(2)

    it "returns Q2 for June":
        expect(quarter((2025, 6, 30))).to_equal(2)

    it "returns Q3 for July":
        expect(quarter((2025, 7, 1))).to_equal(3)

    it "returns Q3 for September":
        expect(quarter((2025, 9, 30))).to_equal(3)

    it "returns Q4 for October":
        expect(quarter((2025, 10, 1))).to_equal(4)

    it "returns Q4 for December":
        expect(quarter((2025, 12, 31))).to_equal(4)

# ============================================================================
# Test Group 10: date/format.spl - Date Formatting
# ============================================================================

describe "Date Format - to_string":
    it "formats a date with padding":
        expect(date_to_string((2025, 1, 5))).to_equal("2025-01-05")

    it "formats a date without padding needed":
        expect(date_to_string((2025, 12, 25))).to_equal("2025-12-25")

    it "formats month 10 without padding":
        expect(date_to_string((2025, 10, 15))).to_equal("2025-10-15")

    it "formats day 10 without padding":
        expect(date_to_string((2025, 3, 10))).to_equal("2025-03-10")

describe "Date Format - to_iso8601":
    it "delegates to to_string":
        expect(date_to_string((2025, 6, 15))).to_equal("2025-06-15")

describe "Date Format - to_readable":
    it "formats as full month name day year":
        expect(to_readable((2025, 1, 15))).to_equal("January 15, 2025")

    it "formats December date":
        expect(to_readable((2025, 12, 25))).to_equal("December 25, 2025")

describe "Date Format - to_short":
    it "formats with abbreviated month":
        expect(to_short((2025, 1, 15))).to_equal("Jan 15, 2025")

    it "formats December with abbreviated month":
        expect(to_short((2025, 12, 25))).to_equal("Dec 25, 2025")

describe "Date Format - text_from_i64 helper":
    it "converts zero":
        expect(text_from_i64(0)).to_equal("0")

    it "converts positive number":
        expect(text_from_i64(42)).to_equal("42")

    it "converts negative number":
        expect(text_from_i64(-7)).to_equal("-7")

    it "converts single digit":
        expect(text_from_i64(5)).to_equal("5")

    it "converts large number":
        expect(text_from_i64(2025)).to_equal("2025")

# ============================================================================
# Test Group 11: date/calculate.spl - Date Arithmetic
# ============================================================================

describe "Date Calculate - to_days":
    it "converts epoch to day 1":
        expect(to_days((1, 1, 1))).to_equal(1)

    it "converts Jan 31 year 1 to day 31":
        expect(to_days((1, 1, 31))).to_equal(31)

    it "converts Feb 1 year 1 to day 32":
        expect(to_days((1, 2, 1))).to_equal(32)

    it "handles year crossing":
        # Year 1 has 365 days, so Jan 1 year 2 = day 366
        expect(to_days((2, 1, 1))).to_equal(366)

    it "handles leap year in calculation":
        # Year 4 is leap: days = 365*3 + 366 + 1 = 1462
        expect(to_days((5, 1, 1))).to_equal(1462)

describe "Date Calculate - add_days":
    it "adds days to a date":
        var result = add_days((2025, 1, 1), 10)
        expect(result[0]).to_equal(2025)
        expect(result[1]).to_equal(1)
        expect(result[2]).to_equal(11)

    it "adds days crossing month boundary":
        var result = add_days((2025, 1, 30), 5)
        expect(result[0]).to_equal(2025)
        expect(result[1]).to_equal(2)
        expect(result[2]).to_equal(4)

    it "returns nil when result is before epoch":
        var result = add_days((1, 1, 1), -5)
        expect(result).to_equal(nil)

describe "Date Calculate - subtract_days":
    it "subtracts days from a date":
        var result = subtract_days((2025, 1, 15), 5)
        expect(result[0]).to_equal(2025)
        expect(result[1]).to_equal(1)
        expect(result[2]).to_equal(10)

describe "Date Calculate - difference_in_days":
    it "returns positive for later date first":
        var diff = difference_in_days((2025, 1, 15), (2025, 1, 10))
        expect(diff).to_equal(5)

    it "returns negative for earlier date first":
        var diff = difference_in_days((2025, 1, 10), (2025, 1, 15))
        expect(diff).to_equal(-5)

    it "returns zero for same date":
        var diff = difference_in_days((2025, 1, 15), (2025, 1, 15))
        expect(diff).to_equal(0)

describe "Date Calculate - add_months":
    it "adds months within same year":
        var result = add_months((2025, 1, 15), 3)
        expect(result[0]).to_equal(2025)
        expect(result[1]).to_equal(4)
        expect(result[2]).to_equal(15)

    it "adds months crossing year boundary":
        var result = add_months((2025, 11, 15), 3)
        expect(result[0]).to_equal(2026)
        expect(result[1]).to_equal(2)
        expect(result[2]).to_equal(15)

    it "clamps day when new month has fewer days":
        # Jan 31 + 1 month -> Feb 28 (2025 non-leap)
        var result = add_months((2025, 1, 31), 1)
        expect(result[0]).to_equal(2025)
        expect(result[1]).to_equal(2)
        expect(result[2]).to_equal(28)

    it "handles negative months":
        var result = add_months((2025, 3, 15), -2)
        expect(result[0]).to_equal(2025)
        expect(result[1]).to_equal(1)
        expect(result[2]).to_equal(15)

    it "handles negative months crossing year boundary":
        var result = add_months((2025, 2, 15), -3)
        expect(result[0]).to_equal(2024)
        expect(result[1]).to_equal(11)
        expect(result[2]).to_equal(15)

describe "Date Calculate - subtract_months":
    it "subtracts months":
        var result = subtract_months((2025, 6, 15), 3)
        expect(result[0]).to_equal(2025)
        expect(result[1]).to_equal(3)
        expect(result[2]).to_equal(15)

describe "Date Calculate - add_years":
    it "adds years to a normal date":
        var result = add_years((2025, 6, 15), 2)
        expect(result[0]).to_equal(2027)
        expect(result[1]).to_equal(6)
        expect(result[2]).to_equal(15)

    it "handles Feb 29 landing on non-leap year":
        # 2024 is leap, 2025 is not
        var result = add_years((2024, 2, 29), 1)
        expect(result[0]).to_equal(2025)
        expect(result[1]).to_equal(2)
        expect(result[2]).to_equal(28)

    it "handles Feb 29 landing on leap year":
        # 2024 is leap, 2028 is also leap
        var result = add_years((2024, 2, 29), 4)
        expect(result[0]).to_equal(2028)
        expect(result[1]).to_equal(2)
        expect(result[2]).to_equal(29)

    it "does not adjust non-Feb dates":
        var result = add_years((2024, 3, 15), 1)
        expect(result[0]).to_equal(2025)
        expect(result[1]).to_equal(3)
        expect(result[2]).to_equal(15)

    it "does not adjust Feb 28":
        var result = add_years((2024, 2, 28), 1)
        expect(result[0]).to_equal(2025)
        expect(result[1]).to_equal(2)
        expect(result[2]).to_equal(28)

describe "Date Calculate - subtract_years":
    it "subtracts years":
        var result = subtract_years((2025, 6, 15), 5)
        expect(result[0]).to_equal(2020)

# ============================================================================
# Test Group 12: date/calculate.spl - Date Comparison
# ============================================================================

describe "Date Calculate - Comparison":
    context "equal":
        it "returns true for same dates":
            expect(equal((2025, 1, 15), (2025, 1, 15))).to_equal(true)

        it "returns false for different years":
            expect(equal((2025, 1, 15), (2024, 1, 15))).to_equal(false)

        it "returns false for different months":
            expect(equal((2025, 1, 15), (2025, 2, 15))).to_equal(false)

        it "returns false for different days":
            expect(equal((2025, 1, 15), (2025, 1, 16))).to_equal(false)

    context "before":
        it "returns true when date1 is earlier":
            expect(before((2025, 1, 1), (2025, 1, 2))).to_equal(true)

        it "returns false when date1 is later":
            expect(before((2025, 1, 2), (2025, 1, 1))).to_equal(false)

        it "returns false for same date":
            expect(before((2025, 1, 1), (2025, 1, 1))).to_equal(false)

    context "after":
        it "returns true when date1 is later":
            expect(after((2025, 1, 2), (2025, 1, 1))).to_equal(true)

        it "returns false when date1 is earlier":
            expect(after((2025, 1, 1), (2025, 1, 2))).to_equal(false)

        it "returns false for same date":
            expect(after((2025, 1, 1), (2025, 1, 1))).to_equal(false)

    context "compare":
        it "returns -1 for before":
            expect(compare((2025, 1, 1), (2025, 1, 2))).to_equal(-1)

        it "returns 1 for after":
            expect(compare((2025, 1, 2), (2025, 1, 1))).to_equal(1)

        it "returns 0 for equal":
            expect(compare((2025, 1, 1), (2025, 1, 1))).to_equal(0)

    context "before_or_equal":
        it "returns true for before":
            expect(before_or_equal((2025, 1, 1), (2025, 1, 2))).to_equal(true)

        it "returns true for equal":
            expect(before_or_equal((2025, 1, 1), (2025, 1, 1))).to_equal(true)

        it "returns false for after":
            expect(before_or_equal((2025, 1, 2), (2025, 1, 1))).to_equal(false)

    context "after_or_equal":
        it "returns true for after":
            expect(after_or_equal((2025, 1, 2), (2025, 1, 1))).to_equal(true)

        it "returns true for equal":
            expect(after_or_equal((2025, 1, 1), (2025, 1, 1))).to_equal(true)

        it "returns false for before":
            expect(after_or_equal((2025, 1, 1), (2025, 1, 2))).to_equal(false)

