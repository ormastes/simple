# # Date Module Coverage Test Suite
#
# **Feature IDs:** #DATE_COVERAGE
# **Category:** Testing
# **Status:** Implemented
#
# ## Overview
# Comprehensive branch coverage tests for:
# - src/lib/common/date/types.spl (constants, validation, properties)
# - src/lib/common/date/format.spl (date formatting)
# - src/lib/common/date/calculate.spl (arithmetic, comparison, calendar)
# - src/lib/common/locale/dates.spl (locale-aware formatting, relative time)

use lib.common.date.types.{day_name, month_name, month_abbrev, from_ymd, epoch, today_mock, from_days, is_leap_year, days_in_month, is_valid_date, day_of_week, day_of_year, week_of_year, is_weekend, is_weekday, quarter}
use lib.common.date.types.{MONDAY, TUESDAY, WEDNESDAY, THURSDAY, FRIDAY, SATURDAY, SUNDAY}
use lib.common.date.types.{JANUARY, FEBRUARY, MARCH, APRIL, MAY, JUNE, JULY, AUGUST, SEPTEMBER, OCTOBER, NOVEMBER, DECEMBER}
use lib.common.date.format.{to_string, to_iso8601, to_readable, to_short}
use lib.common.date.calculate.{to_days, add_days, subtract_days, difference_in_days, add_months, subtract_months, add_years, subtract_years}
use lib.common.date.calculate.{equal, before, after, compare, before_or_equal, after_or_equal}
use lib.common.date.calculate.{first_day_of_month, last_day_of_month, first_day_of_year, last_day_of_year, first_day_of_quarter, last_day_of_quarter}
use lib.common.date.calculate.{nth_day_of_month, last_day_of_week_in_month, next_day_of_week, prev_day_of_week}
use lib.common.date.calculate.{date_range, days_between, weekdays_between, weekends_between, count_day_of_week}
use lib.common.date.calculate.{easter_date, good_friday, ash_wednesday, pentecost, thanksgiving_us, labor_day_us, memorial_day_us}
use lib.common.date.calculate.{age_in_years, difference_in_months, difference_in_years}
use lib.common.locale.dates.{month_name_short, day_name_short, format_date, format_time, relative_time_seconds, time_ago, time_until}

fn check(condition: bool):
    expect(condition).to_equal(true)

