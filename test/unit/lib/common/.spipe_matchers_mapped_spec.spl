use std.spec
use lib.common.types.mapped.{
    partial, readonly_type, pick_type, omit_type,
    make_optional_field, make_required_field,
    mapped_result_get_type
}

describe "Mapped Types":
    it "exports and formats mapped-type helpers":
        expect partial("User") == "Partial<User>"
        expect readonly_type("Config") == "Readonly<Config>"
        expect pick_type("User", "name,age") == "Pick<User, name,age>"
        expect omit_type("User", "password") == "Omit<User, password>"

    it "exports field helper shorthands":
        expect make_optional_field("age") == "age?"
        expect make_required_field("email") == "email!"

    it "formats mapped result display names":
        expect mapped_result_get_type("User", "Partial") == "Partial<User>"