# Regression: cross-module Result<text,text> match Ok arm
#
# Original symptom (filed by Agent K, 2026-05-01):
#   "match Ok(_) arm on cross-module Result<text,text> raises 'variable text not found'"
#
# True root cause (diagnosed 2026-05-01): the Ok-arm-correlation was incidental.
# The trigger is the `text.from_char_code(n)` idiom inside transitively-called
# library functions (jwt/encode.spl, cert/pem.spl, http/utilities.spl). That
# idiom parses as `MethodCall { receiver: Identifier("text"), method: "from_char_code" }`
# and the interpreter's method-call dispatch has no static-method handler for
# primitive type names — `evaluate_method_call_with_self_update` calls
# `evaluate_expr(receiver)` which fails with "variable `text` not found".
#
# Fix: rewrote the four call sites to use the supported `n.chr()` idiom.
#
# This spec exercises the JWT base64url_decode path that was the original blocker.

use std.spec.{describe, it, expect}
use std.common.jwt.encode.{base64url_decode, base64url_encode}

describe "cross-module text.from_char_code regression":
    it "REQ-INTERP-CMR-001: base64url_decode round-trip across module boundary":
        # base64url_decode internally used the broken `text.from_char_code(n)` idiom.
        # Encode "hello" then decode; the decode path crashed pre-fix with
        # `variable 'text' not found`.
        val original = "hello"
        val encoded = base64url_encode(original)
        val decoded = base64url_decode(encoded)
        expect decoded == original

    it "REQ-INTERP-CMR-002: base64url_decode on JWT-style input":
        # "aGVsbG8" is base64url for "hello" (no padding).
        val s = base64url_decode("aGVsbG8")
        expect s == "hello"