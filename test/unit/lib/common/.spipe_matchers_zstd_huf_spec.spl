use std.spec.{describe, it, expect}
use std.common.compress.zstd_huf.{
    ZstdHufCanonicalEntry,
    zstd_huf_encode_literals,
    zstd_huf_complete_weights,
    zstd_huf_weights_to_symbols,
    zstd_huf_build_canonical_entries,
    zstd_huf_reverse_bits,
    zstd_huf_expand_decode_table
}
use std.common.compress.{CompressionError}

fn _expect_compression_error(err: CompressionError, kind: text, message_part: text):
    match err:
        CompressionError.InvalidHeader(message):
            expect kind == "InvalidHeader"
            expect (message).contains(message_part)
        CompressionError.UnsupportedFeature(message):
            expect kind == "UnsupportedFeature"
            expect (message).contains(message_part)
        CompressionError.TruncatedInput(message):
            expect kind == "TruncatedInput"
            expect (message).contains(message_part)
        CompressionError.ChecksumMismatch(message):
            expect kind == "ChecksumMismatch"
            expect (message).contains(message_part)
        CompressionError.CorruptStream(message):
            expect kind == "CorruptStream"
            expect (message).contains(message_part)
        CompressionError.SizeLimitExceeded(limit):
            expect kind == "SizeLimitExceeded"
            expect limit >= 0 == true

fn _expect_entry(entry: ZstdHufCanonicalEntry, symbol: i64, weight: i64, bits: i64, code: u32):
    expect entry.symbol == symbol
    expect entry.weight == weight
    expect entry.bits == bits
    expect entry.code == code

describe "zstd huffman helpers":
    it "completes weights and assigns canonical codes using zstd ordering":
        val complete_res = zstd_huf_complete_weights([4, 3, 2, 0, 1])
        expect complete_res.is_err() == false
        val weights = complete_res.unwrap()
        expect weights.len() == 6
        expect weights[5] == 1

        val symbols_res = zstd_huf_weights_to_symbols(weights)
        expect symbols_res.is_err() == false
        val symbols = symbols_res.unwrap()
        expect symbols[0].bits == 1
        expect symbols[1].bits == 2
        expect symbols[2].bits == 3
        expect symbols[3].bits == 0
        expect symbols[4].bits == 4
        expect symbols[5].bits == 4

        val entries_res = zstd_huf_build_canonical_entries(weights)
        expect entries_res.is_err() == false
        val entries = entries_res.unwrap()
        expect entries.len() == 5
        _expect_entry(entries[0], 4, 1, 4, 0u32)
        _expect_entry(entries[1], 5, 1, 4, 1u32)
        _expect_entry(entries[2], 2, 2, 3, 1u32)
        _expect_entry(entries[3], 1, 3, 2, 1u32)
        _expect_entry(entries[4], 0, 4, 1, 1u32)

    it "expands an lsb-indexed decode table for the backward bit reader":
        val entries = [
            ZstdHufCanonicalEntry(symbol: 4, weight: 1, bits: 4, code: 0u32),
            ZstdHufCanonicalEntry(symbol: 5, weight: 1, bits: 4, code: 1u32),
            ZstdHufCanonicalEntry(symbol: 2, weight: 2, bits: 3, code: 1u32),
            ZstdHufCanonicalEntry(symbol: 1, weight: 3, bits: 2, code: 1u32),
            ZstdHufCanonicalEntry(symbol: 0, weight: 4, bits: 1, code: 1u32)
        ]
        expect zstd_huf_reverse_bits(1u32, 3) == 4u32
        val table_res = zstd_huf_expand_decode_table(entries, 4)
        expect table_res.is_err() == false
        val table = table_res.unwrap()
        expect table.len() == 16
        expect table[0].symbol == 4
        expect table[0].bits == 4
        expect table[8].symbol == 5
        expect table[8].bits == 4
        expect table[4].symbol == 2
        expect table[12].symbol == 2
        expect table[2].symbol == 1
        expect table[6].symbol == 1
        expect table[10].symbol == 1
        expect table[14].symbol == 1
        expect table[1].symbol == 0
        expect table[15].symbol == 0

    it "rejects oversubscribed and incomplete weight sets":
        val over = zstd_huf_weights_to_symbols([2, 2, 2, 2, 2])
        expect over.is_err() == true
        _expect_compression_error(over.unwrap_err(), "CorruptStream", "oversubscribed")

        val under = zstd_huf_weights_to_symbols([2, 1])
        expect under.is_err() == true
        _expect_compression_error(under.unwrap_err(), "CorruptStream", "incomplete")

    it "encodes a two-symbol alphabet with a one-bit tree":
        val literals: [u8] = [0x41u8, 0x42u8, 0x41u8, 0x42u8, 0x41u8, 0x41u8]
        val encoded_res = zstd_huf_encode_literals(literals)
        expect encoded_res.is_err() == false
        val (_bitstream, weights) = encoded_res.unwrap()
        expect weights[0x41].to_i64() == 1
        expect weights[0x42].to_i64() == 1
        val entries_res = zstd_huf_build_canonical_entries(weights)
        expect entries_res.is_err() == false
        val entries = entries_res.unwrap()
        expect entries.len() == 2
        _expect_entry(entries[0], 65, 1, 1, 0u32)
        _expect_entry(entries[1], 66, 1, 1, 1u32)

    it "encodes a one-symbol literal stream via a bounded synthetic partner":
        val literals: [u8] = [
            0x5Au8, 0x5Au8, 0x5Au8, 0x5Au8,
            0x5Au8, 0x5Au8, 0x5Au8, 0x5Au8,
            0x5Au8, 0x5Au8, 0x5Au8, 0x5Au8
        ]
        val encoded_res = zstd_huf_encode_literals(literals)
        expect encoded_res.is_err() == false
        val (_bitstream, weights) = encoded_res.unwrap()
        expect weights[0x5A].to_i64() == 1
        expect weights[0].to_i64() == 1
        val entries_res = zstd_huf_build_canonical_entries(weights)
        expect entries_res.is_err() == false
        val entries = entries_res.unwrap()
        expect entries.len() == 2
        _expect_entry(entries[0], 0, 1, 1, 0u32)
        _expect_entry(entries[1], 90, 1, 1, 1u32)