# Test Group 34: age_in_years edge cases (no extra date arithmetic)
# ============================================================================


describe "Calculate - age_in_years edge cases":
    it "same month day after birthday":
        var age = age_in_years((1990, 6, 15), (2025, 6, 16))
        expect age == 35

    it "birthday month later in year":
        var age = age_in_years((1990, 12, 25), (2025, 3, 15))
        expect age == 34


describe "Calculate - difference_in_months edge cases":
    it "day1 greater than or equal to day2":
        var months = difference_in_months((2025, 6, 20), (2025, 1, 15))
        expect months == 5

    it "negative month difference":
        var months = difference_in_months((2025, 1, 15), (2025, 6, 15))
        expect months == -5

# ============================================================================
# Test Group 35: add_months overflow edge cases
# ============================================================================


describe "Add Months - More overflow cases":
    it "adds months where total_months exactly 12":
        var result = add_months((2025, 10, 15), 2)
        expect result[0] == 2025
        expect result[1] == 12

    it "subtracts months where total is 0":
        var result = add_months((2025, 3, 15), -3)
        expect result[0] == 2024
        expect result[1] == 12