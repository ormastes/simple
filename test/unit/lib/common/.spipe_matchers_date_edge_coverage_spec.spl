# Test Group 29: Locale format_time additional edge cases
# ============================================================================


describe "Locale Format Time - Additional branches":
    it "formats hour 0 (midnight) 24-hour":
        var locale = ("en", "US", "", "")
        var result = locale_format_time(0, 0, 0, "HH:mm:ss", locale)
        expect result == "00:00:00"

    it "formats 12-hour for hour 13 (PM)":
        var locale = ("en", "US", "", "")
        var result = locale_format_time(13, 0, 0, "hh:mm a", locale)
        expect (result).starts_with("01")
        expect (result).contains("PM")

