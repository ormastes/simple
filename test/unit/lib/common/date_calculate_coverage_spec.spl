describe "Locale Dates - Month Name":
    context "English locale":
        it "returns January for month 1":
            var locale = ("en", "US", "", "")
            expect(locale_month_name(1, locale)).to_equal("January")

        it "returns December for month 12":
            var locale = ("en", "US", "", "")
            expect(locale_month_name(12, locale)).to_equal("December")

        it "returns empty for invalid month":
            var locale = ("en", "US", "", "")
            expect(locale_month_name(0, locale)).to_equal("")

    context "French locale":
        it "returns janvier for month 1":
            var locale = ("fr", "FR", "", "")
            expect(locale_month_name(1, locale)).to_equal("janvier")

        it "returns décembre for month 12":
            var locale = ("fr", "FR", "", "")
            expect(locale_month_name(12, locale)).to_equal("décembre")

        it "returns empty for invalid month":
            var locale = ("fr", "FR", "", "")
            expect(locale_month_name(0, locale)).to_equal("")

    context "Spanish locale":
        it "returns enero for month 1":
            var locale = ("es", "ES", "", "")
            expect(locale_month_name(1, locale)).to_equal("enero")

        it "returns diciembre for month 12":
            var locale = ("es", "ES", "", "")
            expect(locale_month_name(12, locale)).to_equal("diciembre")

        it "returns empty for invalid month":
            var locale = ("es", "ES", "", "")
            expect(locale_month_name(0, locale)).to_equal("")

    context "German locale":
        it "returns Januar for month 1":
            var locale = ("de", "DE", "", "")
            expect(locale_month_name(1, locale)).to_equal("Januar")

        it "returns Dezember for month 12":
            var locale = ("de", "DE", "", "")
            expect(locale_month_name(12, locale)).to_equal("Dezember")

        it "returns empty for invalid month":
            var locale = ("de", "DE", "", "")
            expect(locale_month_name(0, locale)).to_equal("")

