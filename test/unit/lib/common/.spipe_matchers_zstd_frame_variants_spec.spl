use std.spec.{describe, it, expect}
use std.common.compress.{CompressionCodec, CompressionError, decompress_bytes}

val ZSTD_MAGIC_BYTES: [u8] = [0x28u8, 0xB5u8, 0x2Fu8, 0xFDu8]
val ZSTD_XXH64_PRIME1: u64 = 0x9E3779B185EBCA87u64
val ZSTD_XXH64_PRIME2: u64 = 0xC2B2AE3D27D4EB4Fu64
val ZSTD_XXH64_PRIME3: u64 = 0x165667B19E3779F9u64
val ZSTD_XXH64_PRIME4: u64 = 0x85EBCA77C2B2AE63u64
val ZSTD_XXH64_PRIME5: u64 = 0x27D4EB2F165667C5u64

fn _expect_error_contains(result: Result<[u8], CompressionError>, kind: text, part: text):
    match result:
        Ok(_): expect(false).to_equal(true)
        Err(err):
            match err:
                CompressionError.InvalidHeader(message):
                    expect kind == "InvalidHeader"
                    expect (message).contains(part)
                CompressionError.UnsupportedFeature(message):
                    expect kind == "UnsupportedFeature"
                    expect (message).contains(part)
                CompressionError.TruncatedInput(message):
                    expect kind == "TruncatedInput"
                    expect (message).contains(part)
                CompressionError.ChecksumMismatch(message):
                    expect kind == "ChecksumMismatch"
                    expect (message).contains(part)
                CompressionError.CorruptStream(message):
                    expect kind == "CorruptStream"
                    expect (message).contains(part)
                CompressionError.SizeLimitExceeded(_):
                    expect kind == "SizeLimitExceeded"

fn _write_u32_le(value: u32) -> [u8]:
    [
        (value & 0xFFu32).to_u8(),
        ((value >> 8u32) & 0xFFu32).to_u8(),
        ((value >> 16u32) & 0xFFu32).to_u8(),
        ((value >> 24u32) & 0xFFu32).to_u8()
    ]

fn _write_u64_le(value: u64) -> [u8]:
    [
        (value & 0xFFu64).to_u8(),
        ((value >> 8u64) & 0xFFu64).to_u8(),
        ((value >> 16u64) & 0xFFu64).to_u8(),
        ((value >> 24u64) & 0xFFu64).to_u8(),
        ((value >> 32u64) & 0xFFu64).to_u8(),
        ((value >> 40u64) & 0xFFu64).to_u8(),
        ((value >> 48u64) & 0xFFu64).to_u8(),
        ((value >> 56u64) & 0xFFu64).to_u8()
    ]

fn _zstd_xxh64_rotl(value: u64, amount: u64) -> u64:
    (value << amount) | (value >> (64u64 - amount))

fn _zstd_xxh64_round(acc: u64, input: u64) -> u64:
    val mixed = acc + input * ZSTD_XXH64_PRIME2
    _zstd_xxh64_rotl(mixed, 31u64) * ZSTD_XXH64_PRIME1

fn _zstd_xxh64_merge_round(acc: u64, value: u64) -> u64:
    (acc ^ _zstd_xxh64_round(0u64, value)) * ZSTD_XXH64_PRIME1 + ZSTD_XXH64_PRIME4

fn _zstd_xxh64_avalanche(value: u64) -> u64:
    var acc = value
    acc = acc ^ (acc >> 33u64)
    acc = acc * ZSTD_XXH64_PRIME2
    acc = acc ^ (acc >> 29u64)
    acc = acc * ZSTD_XXH64_PRIME3
    acc ^ (acc >> 32u64)

fn _read_u64_lane(data: [u8], pos: i64) -> u64:
    data[pos].to_u64() |
        (data[pos + 1].to_u64() << 8u64) |
        (data[pos + 2].to_u64() << 16u64) |
        (data[pos + 3].to_u64() << 24u64) |
        (data[pos + 4].to_u64() << 32u64) |
        (data[pos + 5].to_u64() << 40u64) |
        (data[pos + 6].to_u64() << 48u64) |
        (data[pos + 7].to_u64() << 56u64)

fn _xxh64_bytes(data: [u8]) -> u64:
    var idx = 0
    var hash: u64 = 0u64
    if data.len() >= 32:
        var v1 = ZSTD_XXH64_PRIME1 + ZSTD_XXH64_PRIME2
        var v2 = ZSTD_XXH64_PRIME2
        var v3: u64 = 0u64
        var v4 = 0u64 - ZSTD_XXH64_PRIME1
        while idx + 32 <= data.len():
            v1 = _zstd_xxh64_round(v1, _read_u64_lane(data, idx))
            v2 = _zstd_xxh64_round(v2, _read_u64_lane(data, idx + 8))
            v3 = _zstd_xxh64_round(v3, _read_u64_lane(data, idx + 16))
            v4 = _zstd_xxh64_round(v4, _read_u64_lane(data, idx + 24))
            idx = idx + 32
        hash = _zstd_xxh64_rotl(v1, 1u64) +
            _zstd_xxh64_rotl(v2, 7u64) +
            _zstd_xxh64_rotl(v3, 12u64) +
            _zstd_xxh64_rotl(v4, 18u64)
        hash = _zstd_xxh64_merge_round(hash, v1)
        hash = _zstd_xxh64_merge_round(hash, v2)
        hash = _zstd_xxh64_merge_round(hash, v3)
        hash = _zstd_xxh64_merge_round(hash, v4)
    else:
        hash = ZSTD_XXH64_PRIME5
    hash = hash + data.len().to_u64()
    while idx + 8 <= data.len():
        val lane = _read_u64_lane(data, idx)
        hash = hash ^ _zstd_xxh64_round(0u64, lane)
        hash = _zstd_xxh64_rotl(hash, 27u64) * ZSTD_XXH64_PRIME1 + ZSTD_XXH64_PRIME4
        idx = idx + 8
    if idx + 4 <= data.len():
        val lane = data[idx].to_u64() |
            (data[idx + 1].to_u64() << 8u64) |
            (data[idx + 2].to_u64() << 16u64) |
            (data[idx + 3].to_u64() << 24u64)
        hash = _zstd_xxh64_rotl(hash ^ (lane * ZSTD_XXH64_PRIME1), 23u64) * ZSTD_XXH64_PRIME2 + ZSTD_XXH64_PRIME3
        idx = idx + 4
    while idx < data.len():
        hash = _zstd_xxh64_rotl(hash ^ (data[idx].to_u64() * ZSTD_XXH64_PRIME5), 11u64) * ZSTD_XXH64_PRIME1
        idx = idx + 1
    _zstd_xxh64_avalanche(hash)

fn _raw_block(payload: [u8], last: bool) -> [u8]:
    val last_bit = if last: 1 else: 0
    val header = ((payload.len() << 3) | last_bit).to_u32()
    [
        (header & 0xFFu32).to_u8(),
        ((header >> 8u32) & 0xFFu32).to_u8(),
        ((header >> 16u32) & 0xFFu32).to_u8()
    ] + payload

fn _frame(descriptor: u8, header_tail: [u8], payload: [u8], checksum: bool) -> [u8]:
    var frame = ZSTD_MAGIC_BYTES + [descriptor] + header_tail + _raw_block(payload, true)
    if checksum:
        val low32 = (_xxh64_bytes(payload) & 0xFFFFFFFFu64).to_u32()
        frame = frame + _write_u32_le(low32)
    frame

describe "zstd frame header variants":
    it "decodes single-segment frames with 1-byte content size":
        val payload = [0x61u8, 0x62u8, 0x63u8]
        val frame = _frame(0x20u8, [payload.len().to_u8()], payload, false)
        val decoded = decompress_bytes(frame, Some(CompressionCodec.zstd))
        expect decoded.is_err() == false
        expect decoded.unwrap() == payload

    it "decodes single-segment frames with 2-byte content size":
        var payload: [u8] = []
        var i = 0
        while i < 260:
            payload.push((0x70 + (i % 7)).to_u8())
            i = i + 1
        val encoded_size = (payload.len() - 256).to_u16()
        val frame = _frame(
            0x60u8,
            [(encoded_size & 0xFFu16).to_u8(), ((encoded_size >> 8) & 0xFFu16).to_u8()],
            payload,
            false
        )
        val decoded = decompress_bytes(frame, Some(CompressionCodec.zstd))
        expect decoded.is_err() == false
        expect decoded.unwrap() == payload

    it "decodes single-segment frames with 8-byte content size":
        val payload = [0x21u8, 0x22u8, 0x23u8, 0x24u8, 0x25u8]
        val frame = _frame(0xE0u8, _write_u64_le(payload.len().to_u64()), payload, false)
        val decoded = decompress_bytes(frame, Some(CompressionCodec.zstd))
        expect decoded.is_err() == false
        expect decoded.unwrap() == payload

    it "decodes non-single-segment frames with a window descriptor":
        val payload = [0x41u8, 0x42u8, 0x43u8, 0x44u8]
        val frame = _frame(0x00u8, [0x00u8], payload, false)
        val decoded = decompress_bytes(frame, Some(CompressionCodec.zstd))
        expect decoded.is_err() == false
        expect decoded.unwrap() == payload

    it "verifies frame-level content checksums":
        val payload = [0x31u8, 0x32u8, 0x33u8, 0x34u8]
        val frame = _frame(0x24u8, [payload.len().to_u8()], payload, true)
        val decoded = decompress_bytes(frame, Some(CompressionCodec.zstd))
        expect decoded.is_err() == false
        expect decoded.unwrap() == payload

    it "rejects dictionary-backed frames explicitly":
        val payload = [0x51u8, 0x52u8]
        val frame = _frame(0x21u8, [0x09u8, payload.len().to_u8()], payload, false)
        _expect_error_contains(decompress_bytes(frame, Some(CompressionCodec.zstd)), "UnsupportedFeature", "dictionary")

    it "decodes concatenated frames in one buffer":
        val left = _frame(0x20u8, [2u8], [0x61u8, 0x62u8], false)
        val right = _frame(0x20u8, [3u8], [0x63u8, 0x64u8, 0x65u8], false)
        val decoded = decompress_bytes(left + right, Some(CompressionCodec.zstd))
        expect decoded.is_err() == false
        expect decoded.unwrap() == [0x61u8, 0x62u8, 0x63u8, 0x64u8, 0x65u8]

    it "fails closed on a corrupt content checksum":
        val payload = [0x90u8, 0x91u8, 0x92u8]
        var frame = _frame(0x24u8, [payload.len().to_u8()], payload, true)
        frame[frame.len() - 1] = frame[frame.len() - 1] ^ 0x01u8
        _expect_error_contains(decompress_bytes(frame, Some(CompressionCodec.zstd)), "ChecksumMismatch", "checksum")