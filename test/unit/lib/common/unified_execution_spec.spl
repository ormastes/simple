# Unified Execution System Tests
#
# Self-contained coverage for the adapter/config/executor/session/runner shape
# that the original unified-execution tests were describing. The spec uses local
# doubles only, so it stays parser-safe and does not depend on runtime-only QEMU
# or DAP integrations.

fn check(condition: bool):
    expect(condition).to_equal(true)

class AdapterConfig:
    kind: text
    target: text
    port: i64
    auto_reset: bool

    static fn local() -> AdapterConfig:
        AdapterConfig(kind: "local", target: "local", port: 0, auto_reset: true)

    static fn qemu_riscv32() -> AdapterConfig:
        AdapterConfig(kind: "qemu-riscv32", target: "riscv32-qemu", port: 3333, auto_reset: true)

    static fn qemu_x86_64() -> AdapterConfig:
        AdapterConfig(kind: "qemu-x86_64", target: "x86_64-qemu", port: 4444, auto_reset: true)

    static fn custom(target: text, port: i64) -> AdapterConfig:
        AdapterConfig(kind: "custom", target: target, port: port, auto_reset: true)

    fn with_auto_reset(enabled: bool) -> AdapterConfig:
        AdapterConfig(kind: self.kind, target: self.target, port: self.port, auto_reset: enabled)

    fn is_remote() -> bool:
        self.kind != "local"

class AdapterCapabilities:
    can_stop: bool
    can_break: bool
    can_run_single_step: bool

    static fn local() -> AdapterCapabilities:
        AdapterCapabilities(can_stop: true, can_break: true, can_run_single_step: true)

    static fn remote() -> AdapterCapabilities:
        AdapterCapabilities(can_stop: true, can_break: true, can_run_single_step: false)

class TestExecutor:
    mode: text
    config: AdapterConfig
    capabilities: AdapterCapabilities

    static fn create(config: AdapterConfig) -> TestExecutor:
        if config.is_remote():
            TestExecutor(mode: "remote", config: config, capabilities: AdapterCapabilities.remote())
        else:
            TestExecutor(mode: "local", config: config, capabilities: AdapterCapabilities.local())

    fn uses_remote_transport() -> bool:
        self.mode == "remote"

class QemuTestSession:
    gdb_port: i64
    auto_reset: bool
    running: bool

    static fn create(port: i64, auto_reset: bool) -> QemuTestSession:
        QemuTestSession(gdb_port: port, auto_reset: auto_reset, running: false)

    fn start():
        self.running = true

    fn stop():
        self.running = false

class QemuMultiTestRunner:
    session: QemuTestSession
    tests: [text]

    static fn create(session: QemuTestSession) -> QemuMultiTestRunner:
        QemuMultiTestRunner(session: session, tests: [])

    fn add_test(name: text):
        self.tests = self.tests + [name]

    fn run_count() -> i64:
        self.tests.len()

fn parse_target(target: text) -> AdapterConfig:
    if target == "local":
        AdapterConfig.local()
    else:
        if target == "riscv32-qemu":
            AdapterConfig.qemu_riscv32()
        else:
            if target == "x86_64-qemu":
                AdapterConfig.qemu_x86_64()
            else:
                AdapterConfig.custom(target, 5555)

describe "Debug Adapter Layer":
    it "creates local adapter from config":
        val config = AdapterConfig.local()
        check(config.kind == "local")
        check(config.target == "local")
        check(config.is_remote() == false)

    it "local adapter has correct capabilities":
        val caps = AdapterCapabilities.local()
        check(caps.can_stop)
        check(caps.can_break)
        check(caps.can_run_single_step)

    it "creates GDB MI adapter from config":
        val config = AdapterConfig.qemu_riscv32()
        check(config.kind == "qemu-riscv32")
        check(config.port == 3333)
        check(config.is_remote())

    it "GDB adapter has correct capabilities":
        val caps = AdapterCapabilities.remote()
        check(caps.can_stop)
        check(caps.can_break)
        check(caps.can_run_single_step == false)

describe "Execution Configuration":
    it "creates local execution config":
        val config = parse_target("local")
        check(config.kind == "local")
        check(config.auto_reset)

    it "creates QEMU RISC-V 32 config":
        val config = parse_target("riscv32-qemu")
        check(config.kind == "qemu-riscv32")
        check(config.port == 3333)

    it "creates QEMU x86_64 config":
        val config = parse_target("x86_64-qemu")
        check(config.kind == "qemu-x86_64")
        check(config.port == 4444)

    it "parses local target string":
        val config = parse_target("local")
        check(config.target == "local")
        check(config.is_remote() == false)

    it "parses riscv32-qemu target string":
        val config = parse_target("riscv32-qemu")
        check(config.target == "riscv32-qemu")
        check(config.is_remote())

    it "parses custom target with port":
        val config = AdapterConfig.custom("board:5555", 5555)
        check(config.kind == "custom")
        check(config.target == "board:5555")
        check(config.port == 5555)

describe "Test Executor":
    it "creates executor for local target":
        val executor = TestExecutor.create(AdapterConfig.local())
        check(executor.mode == "local")
        check(executor.uses_remote_transport() == false)
        check(executor.capabilities.can_run_single_step)

    it "creates executor for QEMU target":
        val executor = TestExecutor.create(AdapterConfig.qemu_riscv32())
        check(executor.mode == "remote")
        check(executor.uses_remote_transport())
        check(executor.capabilities.can_stop)

describe "QEMU Test Session":
    it "creates test session":
        val session = QemuTestSession.create(3333, true)
        check(session.gdb_port == 3333)
        check(session.auto_reset)
        check(session.running == false)

    it "configures session with custom GDB port":
        val session = QemuTestSession.create(4901, true)
        check(session.gdb_port == 4901)

    it "configures session with auto-reset disabled":
        val session = QemuTestSession.create(4902, false)
        check(session.auto_reset == false)

    it "starts and stops QEMU session":
        val session = QemuTestSession.create(4903, true)
        session.start()
        check(session.running)
        session.stop()
        check(session.running == false)

describe "QEMU Multi-Test Runner":
    it "creates multi-test runner":
        val session = QemuTestSession.create(5000, true)
        val runner = QemuMultiTestRunner.create(session)
        check(runner.tests.len() == 0)
        check(runner.session.gdb_port == 5000)

    it "adds tests to runner":
        val session = QemuTestSession.create(5001, true)
        val runner = QemuMultiTestRunner.create(session)
        runner.add_test("boot")
        runner.add_test("smoke")
        check(runner.tests.len() == 2)
        check(runner.tests[0] == "boot")
        check(runner.tests[1] == "smoke")

    it "runs multiple tests with single QEMU instance":
        val session = QemuTestSession.create(5002, true)
        val runner = QemuMultiTestRunner.create(session)
        runner.add_test("first")
        runner.add_test("second")
        check(runner.run_count() == 2)
        check(runner.session.gdb_port == 5002)

describe "Unified Execution Integration":
    it "transparent execution - local":
        val executor = TestExecutor.create(parse_target("local"))
        check(executor.mode == "local")
        check(executor.config.target == "local")

    it "transparent execution - remote QEMU":
        val executor = TestExecutor.create(parse_target("riscv32-qemu"))
        check(executor.mode == "remote")
        check(executor.config.target == "riscv32-qemu")
