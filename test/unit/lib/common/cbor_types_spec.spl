        it "handles n through r":
            expect(bytes_to_text([110])).to_equal("n")
            expect(bytes_to_text([111])).to_equal("o")
            expect(bytes_to_text([112])).to_equal("p")
            expect(bytes_to_text([113])).to_equal("q")
