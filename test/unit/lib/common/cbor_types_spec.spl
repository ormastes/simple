            expect(bytes_to_text([79])).to_equal("O")
            expect(bytes_to_text([80])).to_equal("P")
            expect(bytes_to_text([81])).to_equal("Q")
            expect(bytes_to_text([82])).to_equal("R")

        it "handles S through W":
