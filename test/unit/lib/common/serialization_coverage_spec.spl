    it "serializes zero":
        expect(serialize_int(0)).to_equal("0")

    it "serializes negative integer":
        expect(serialize_int(-7)).to_equal("-7")

describe "serialize_bool":
    """
    ## Boolean Text Serialization

    Both true and false branches.
    """

    it "serializes true":
        expect(serialize_bool(true)).to_equal("true")

    it "serializes false":
        expect(serialize_bool(false)).to_equal("false")

describe "serialize_nil":
    """
    ## Nil Text Serialization
    """

    it "returns nil string":
        expect(serialize_nil()).to_equal("nil")

describe "serialize_text":
    """
    ## Text Serialization
    """

    it "quotes and escapes text":
        val result = serialize_text("hello")
