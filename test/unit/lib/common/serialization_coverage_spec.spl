    it "escapes special characters in text":
        val result = serialize_text("a\nb")
        expect(result).to_contain("\\n")

# ============================================================================
# Test Group 7: Text Serialization - Collections (serialize.spl)
# ============================================================================

describe "serialize_list":
    """
    ## List Text Serialization

    Tests empty list (branch: len==0) and non-empty list with separator logic.
    """

    it "serializes empty list":
        val result = serialize_list([])
        expect(result).to_equal("[]")

    it "serializes single-item list":
        val result = serialize_list(["42"])
        expect(result).to_equal("[42]")

    it "serializes multi-item list with commas":
        val result = serialize_list(["1", "2", "3"])
        expect(result).to_equal("[1, 2, 3]")

describe "serialize_tuple_text":
    """
    ## Tuple Text Serialization

    Tests empty tuple and non-empty tuple.
    """

    it "serializes empty tuple":
        val result = serialize_tuple_text([])
        expect(result).to_equal("()")

    it "serializes single-value tuple":
        val result = serialize_tuple_text(["42"])
        expect(result).to_equal("(42)")

    it "serializes multi-value tuple with commas":
        val result = serialize_tuple_text(["1", "2", "3"])
        expect(result).to_equal("(1, 2, 3)")

describe "serialize_dict":
    """
    ## Dict Text Serialization

    Tests empty dict and non-empty dict.
    """

    it "serializes empty dict":
        val result = serialize_dict([])
        expect(result).to_equal("{}")

    it "serializes single entry":
        val result = serialize_dict([("key", "val")])
        expect(result).to_equal("{key: val}")

    it "serializes multiple entries with commas":
        val result = serialize_dict([("a", "1"), ("b", "2")])
        expect(result).to_equal("{a: 1, b: 2}")

