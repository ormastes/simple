        expect(result).to_equal("@MyType{data}")

describe "get_type_tag":
    """
    ## Type Tag Extraction

    Tests valid tagged, too short, missing @, no brace, and nil return.
    """

    it "extracts tag from tagged string":
        val result = get_type_tag("@MyType{data}")
        expect(result).to_equal("MyType")

    it "returns nil for short string":
        val result = get_type_tag("ab")
        expect(result).to_be_nil()

    it "returns nil when not starting with @":
        val result = get_type_tag("NoAt{data}")
        expect(result).to_be_nil()

    it "returns nil when no opening brace":
        val result = get_type_tag("@NobraceHere")
        expect(result).to_be_nil()

describe "strip_type_tag":
    """
