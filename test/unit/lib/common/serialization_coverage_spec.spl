# Test Group 16: Deep Cloning (utilities.spl)
# ============================================================================

describe "Deep Cloning":
    """
    ## Deep Clone Functions
    """

    it "clones integer":
        expect(deep_clone_int(42)).to_equal(42)

    it "clones boolean true":
        expect(deep_clone_bool(true)).to_equal(true)

    it "clones boolean false":
        expect(deep_clone_bool(false)).to_equal(false)

    it "clones text":
        expect(deep_clone_text("hello")).to_equal("hello")

    it "clones int list":
        val original = [1, 2, 3]
        val cloned = deep_clone_list_int(original)
        expect(deep_equal_list_int(original, cloned)).to_equal(true)

    it "clones text list":
        val original = ["a", "b"]
        val cloned = deep_clone_list_text(original)
        expect(deep_equal_list_text(original, cloned)).to_equal(true)

    it "clones empty int list":
        val cloned = deep_clone_list_int([])
        expect(cloned.len()).to_equal(0)

    it "clones empty text list":
        val cloned = deep_clone_list_text([])
        expect(cloned.len()).to_equal(0)

describe "Shallow Cloning":
    """
    ## Shallow Clone Functions (delegate to deep clone)
    """

    it "shallow clones int list":
        val original = [10, 20]
        val cloned = shallow_clone_list_int(original)
        expect(deep_equal_list_int(original, cloned)).to_equal(true)

    it "shallow clones text list":
        val original = ["x", "y"]
        val cloned = shallow_clone_list_text(original)
        expect(deep_equal_list_text(original, cloned)).to_equal(true)

# ============================================================================
# Test Group 17: Deep Equality (utilities.spl)
# ============================================================================

describe "Deep Equality":
    """
    ## Deep Equality Comparisons

    Tests equal and unequal cases for each type, plus length mismatch branch.
    """

    it "compares equal integers":
        expect(deep_equal_int(5, 5)).to_equal(true)

    it "compares unequal integers":
        expect(deep_equal_int(5, 6)).to_equal(false)

    it "compares equal booleans":
        expect(deep_equal_bool(true, true)).to_equal(true)

    it "compares unequal booleans":
        expect(deep_equal_bool(true, false)).to_equal(false)

    it "compares equal text":
        expect(deep_equal_text("abc", "abc")).to_equal(true)

    it "compares unequal text":
        expect(deep_equal_text("abc", "xyz")).to_equal(false)

    it "compares equal int lists":
        expect(deep_equal_list_int([1, 2], [1, 2])).to_equal(true)

    it "compares unequal int lists by element":
        expect(deep_equal_list_int([1, 2], [1, 3])).to_equal(false)

    it "compares int lists of different lengths":
        expect(deep_equal_list_int([1], [1, 2])).to_equal(false)

    it "compares empty int lists":
        expect(deep_equal_list_int([], [])).to_equal(true)

    it "compares equal text lists":
        expect(deep_equal_list_text(["a", "b"], ["a", "b"])).to_equal(true)

    it "compares unequal text lists by element":
        expect(deep_equal_list_text(["a"], ["b"])).to_equal(false)

    it "compares text lists of different lengths":
        expect(deep_equal_list_text(["a"], ["a", "b"])).to_equal(false)

    it "compares empty text lists":
        expect(deep_equal_list_text([], [])).to_equal(true)

# ============================================================================
# Test Group 18: Structural Hashing (utilities.spl)
# ============================================================================

describe "Structural Hashing":
    """
    ## Hash Functions

    Tests determinism, different inputs produce different hashes, and combine_hashes.
    """

    it "hashes integer deterministically":
        val h1 = structural_hash_int(42)
        val h2 = structural_hash_int(42)
        expect(h1).to_equal(h2)

    it "hashes different integers differently":
        val h1 = structural_hash_int(1)
        val h2 = structural_hash_int(2)
        expect(h1 == h2).to_equal(false)

    it "hashes true and false differently":
        val h_true = structural_hash_bool(true)
        val h_false = structural_hash_bool(false)
        expect(h_true == h_false).to_equal(false)

    it "hashes bool true to 1":
        expect(structural_hash_bool(true)).to_equal(1)

    it "hashes bool false to 0":
        expect(structural_hash_bool(false)).to_equal(0)

    it "hashes text deterministically":
        val h1 = structural_hash_text("hello")
        val h2 = structural_hash_text("hello")
        expect(h1).to_equal(h2)

    it "hashes different text differently":
        val h1 = structural_hash_text("hello")
        val h2 = structural_hash_text("world")
        expect(h1 == h2).to_equal(false)

    it "hashes empty text":
        val h = structural_hash_text("")
        expect(h).to_equal(2166136261)

    it "hashes int list deterministically":
        val h1 = structural_hash_list_int([1, 2, 3])
        val h2 = structural_hash_list_int([1, 2, 3])
        expect(h1).to_equal(h2)

    it "hashes text list deterministically":
        val h1 = structural_hash_list_text(["a", "b"])
        val h2 = structural_hash_list_text(["a", "b"])
        expect(h1).to_equal(h2)

    it "combines hashes":
        val combined = combine_hashes(100, 200)
        expect(combined).to_equal(100 * 31 + 200)

