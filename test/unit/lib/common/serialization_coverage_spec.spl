    Tests tagged input, untagged input, and edge cases.
    """

    it "strips tag and returns inner content":
        val result = strip_type_tag("@MyType{data}")
        expect(result).to_equal("data")

    it "returns original when no tag present":
        val result = strip_type_tag("notatag")
        expect(result).to_equal("notatag")

    it "returns original for short input":
