# @cover src/lib/common/encoding/utf8.spl
# @cover src/lib/common/aes/cipher.spl

use std.spec.*
use std.common.encoding.utf8.{text_codepoint_len, utf8_count_codepoints}
use std.common.aes.cipher.{aes_decrypt_block, aes_encrypt_block, aes_decrypt_block_with_expanded, aes_encrypt_block_with_expanded}
use std.common.aes.key_expansion.expand_key
use std.common.aes.utilities.{bytes_to_hex, hex_to_bytes}

describe "SIMD dispatch facades":
    describe "utf8 counting facade":
        it "preserves mixed-width UTF-8 counting through the public entrypoints":
            val bytes = [0x41, 0xE2, 0x82, 0xAC, 0xF0, 0x9F, 0x98, 0x80]
            expect utf8_count_codepoints(bytes) == 3
            expect text_codepoint_len("A€😀") == 3

    describe "aes block facade":
        it "preserves the AES-128 encrypt/decrypt known answer through the public API":
            val key = hex_to_bytes("000102030405060708090a0b0c0d0e0f")
            val plaintext = hex_to_bytes("00112233445566778899aabbccddeeff")
            val ciphertext = aes_encrypt_block(plaintext, key)
            expect bytes_to_hex(ciphertext) == "69c4e0d86a7b0430d8cdb78070b4c55a"
            expect aes_decrypt_block(ciphertext, key) == plaintext

        it "keeps the expanded-key block helpers wired through the same facade":
            val key = hex_to_bytes("000102030405060708090a0b0c0d0e0f")
            val plaintext = hex_to_bytes("00112233445566778899aabbccddeeff")
            val expanded = expand_key(key, 16)
            val ciphertext = aes_encrypt_block_with_expanded(plaintext, expanded, 10)
            expect bytes_to_hex(ciphertext) == "69c4e0d86a7b0430d8cdb78070b4c55a"
            expect aes_decrypt_block_with_expanded(ciphertext, expanded, 10) == plaintext