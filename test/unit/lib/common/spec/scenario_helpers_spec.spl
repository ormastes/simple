use std.spec.{describe, it, expect}
use std.common.spec.scenario_helpers.{
    ScenarioStepResult,
    check_text_contains,
    check_status_code,
    check_file_exists,
    check_json_field,
    capture_text,
    capture_log,
    step_result,
    step_result_summary
}
use std.common.spec.scenario_evidence.{
    ScenarioCaptureKind
}

describe "scenario checker helpers":
    it "checks text containment returns true when substring present":
        expect(check_text_contains("hello world", "world")).to_be_true()

    it "checks text containment returns false when substring absent":
        expect(check_text_contains("hello world", "mars")).to_be_false()

    it "checks status code equality when codes match":
        expect(check_status_code(200, 200)).to_be_true()

    it "checks status code inequality when codes differ":
        expect(check_status_code(404, 200)).to_be_false()

    it "checks json field present in json text":
        val json = "{\"name\": \"test\", \"value\": 42}"
        expect(check_json_field(json, "name")).to_be_true()

    it "checks json field absent in json text":
        val json = "{\"name\": \"test\"}"
        expect(check_json_field(json, "missing")).to_be_false()

    it "checks file exists for a known path":
        # /dev/null exists on all unix systems
        expect(check_file_exists("/dev/null")).to_be_true()

    it "checks file does not exist for bogus path":
        expect(check_file_exists("/tmp/nonexistent_scenario_helper_test_file_xyz")).to_be_false()

describe "scenario capture helpers":
    it "captures text evidence with correct kind and body":
        val artifact = capture_text("Response body", "ok: logged in")
        expect(artifact.kind).to_equal(ScenarioCaptureKind.text)
        expect(artifact.title).to_equal("Response body")
        expect(artifact.body).to_equal("ok: logged in")
        expect(artifact.mime).to_equal("text/plain")

    it "captures log evidence joining lines":
        val lines = ["line 1", "line 2", "line 3"]
        val artifact = capture_log("Server log", lines)
        expect(artifact.kind).to_equal(ScenarioCaptureKind.log)
        expect(artifact.title).to_equal("Server log")
        expect(artifact.body).to_contain("line 1")
        expect(artifact.body).to_contain("line 2")
        expect(artifact.body).to_contain("line 3")

    it "captures log evidence with empty list":
        val lines: [text] = []
        val artifact = capture_log("Empty log", lines)
        expect(artifact.body).to_equal("")

describe "scenario step result":
    it "creates a passing step result":
        val sr = step_result("Login succeeds", true)
        expect(sr.description).to_equal("Login succeeds")
        expect(sr.passed).to_be_true()

    it "creates a failing step result":
        val sr = step_result("Token valid", false)
        expect(sr.passed).to_be_false()

    it "renders passing step result summary":
        val sr = step_result("API returns 200", true)
        expect(step_result_summary(sr)).to_equal("API returns 200 (passed)")

    it "renders failing step result summary":
        val sr = step_result("File exists", false)
        expect(step_result_summary(sr)).to_equal("File exists (failed)")
