# @covers src/lib/common/math_repr.spl 85%
"""
# Math Repr Coverage Specification

**Feature IDs:** #LIB-MATH-COV
**Category:** Stdlib
**Difficulty:** 2/5
**Status:** Implemented
**Requirements:** N/A
**Plan:** N/A
**Design:** N/A
**Research:** N/A

## Overview

Branch coverage tests for `std.math_repr` parser and renderers.
Split from math_coverage_spec.spl for memory. Tests to_text, to_debug,
to_pretty, to_md, render_latex_raw, and tokenizer/parser edge cases.

## Key Concepts

| Concept | Description |
|---------|-------------|
| math_repr | Parser + renderer: to_text, to_debug, to_pretty, to_md, render_latex_raw |
"""

use std.math_repr.{to_text, to_debug, to_pretty, to_md, render_latex_raw}

# ============================================================================
# 1. math_repr — to_text (Normalized plain text renderer)
# ============================================================================

describe "math_repr to_text":
    """
    ## Plain Text Rendering

    Tests the text renderer across all AST node types.
    """

    context "number literals":
        it "renders integer":
            expect(to_text("42")).to_equal("42")

        it "renders decimal":
            expect(to_text("3.14")).to_equal("3.14")

    context "identifiers":
        it "renders plain identifier":
            expect(to_text("x")).to_equal("x")

        it "renders multi-char identifier":
            expect(to_text("foo")).to_equal("foo")

    context "addition and subtraction":
        it "renders addition":
            expect(to_text("x + 1")).to_equal("x + 1")

        it "renders subtraction":
            expect(to_text("x - 1")).to_equal("x - 1")

        it "renders chained addition":
            expect(to_text("a + b + c")).to_equal("a + b + c")

    context "multiplication and division":
        it "renders explicit multiplication":
            expect(to_text("x * y")).to_equal("x * y")

        it "renders division":
            expect(to_text("x / y")).to_equal("x / y")

        it "renders implicit multiplication":
            expect(to_text("2x")).to_equal("2x")

    context "power":
        it "renders power expression":
            expect(to_text("x^2")).to_equal("x^2")

        it "renders nested power":
            expect(to_text("x^y")).to_equal("x^y")

    context "negation":
        it "renders negation":
            expect(to_text("-x")).to_equal("-x")

        it "renders negation of number":
            expect(to_text("-3")).to_equal("-3")

    context "grouping":
        it "renders parenthesized expression":
            expect(to_text("(x + 1)")).to_equal("(x + 1)")

    context "subscript":
        it "renders subscript notation":
            expect(to_text("x[i]")).to_equal("x[i]")

    context "transpose":
        it "renders transpose":
            expect(to_text("A'")).to_equal("A'")

    context "function calls":
        it "renders single arg function":
            expect(to_text("sin(x)")).to_equal("sin(x)")

        it "renders multi arg function":
            expect(to_text("max(a, b)")).to_equal("max(a, b)")

    context "frac expression":
        it "renders fraction as division":
            expect(to_text("frac(a, b)")).to_equal("a / b")

    context "sum expression":
        it "renders sum notation":
            expect(to_text("sum(i, 1..n) i")).to_equal("sum(i, 1..n) i")

    context "int expression":
        it "renders integral notation":
            expect(to_text("int(x, 0..1) x")).to_equal("int(x, 0..1) x")

    context "complex expressions":
        it "renders compound expression":
            expect(to_text("x^2 + 2*x + 1")).to_equal("x^2 + 2 * x + 1")


# ============================================================================
# 2. math_repr — to_debug (AST structure renderer)
# ============================================================================

describe "math_repr to_debug":
    """
    ## Debug AST Rendering

    Tests the debug renderer for each node type producing AST notation.
    """

    context "leaf nodes":
        it "renders number node":
            expect(to_debug("42")).to_equal("Num(42)")

        it "renders identifier node":
            expect(to_debug("x")).to_equal("Id(x)")

    context "binary operations":
        it "renders Add node":
            expect(to_debug("a + b")).to_equal("Add(Id(a), Id(b))")

        it "renders Sub node":
            expect(to_debug("a - b")).to_equal("Sub(Id(a), Id(b))")

        it "renders Mul node":
            expect(to_debug("a * b")).to_equal("Mul(Id(a), Id(b))")

        it "renders Div node":
            expect(to_debug("a / b")).to_equal("Div(Id(a), Id(b))")

        it "renders Pow node":
            expect(to_debug("a^b")).to_equal("Pow(Id(a), Id(b))")

    context "unary operations":
        it "renders Neg node":
            expect(to_debug("-x")).to_equal("Neg(Id(x))")

    context "grouping":
        it "renders Group node":
            expect(to_debug("(x)")).to_equal("Group(Id(x))")

    context "subscript and transpose":
        it "renders subscript as Sub":
            expect(to_debug("x[i]")).to_equal("Sub(Id(x), Id(i))")

        it "renders Transpose node":
            expect(to_debug("A'")).to_equal("Transpose(Id(A))")

    context "function calls":
        it "renders Call node":
            expect(to_debug("f(x)")).to_equal("Call(f, Id(x))")

        it "renders Call with multiple args":
            expect(to_debug("f(x, y)")).to_equal("Call(f, Id(x), Id(y))")

    context "frac expression":
        it "renders Frac node":
            expect(to_debug("frac(a, b)")).to_equal("Frac(Id(a), Id(b))")

    context "sum and integral expressions":
        it "renders Sum node":
            expect(to_debug("sum(i, 1..n) i")).to_equal("Sum(i, Num(1), Id(n), Id(i))")

        it "renders Int node":
            expect(to_debug("int(x, 0..1) x")).to_equal("Int(x, Num(0), Num(1), Id(x))")

    context "implicit multiplication":
        it "renders implicit mul as Mul":
            expect(to_debug("2x")).to_equal("Mul(Num(2), Id(x))")


# ============================================================================
# 3. math_repr — to_pretty (Unicode renderer)
# ============================================================================

describe "math_repr to_pretty":
    """
    ## Unicode Pretty Rendering

    Tests the pretty renderer which uses Greek letters and Unicode superscripts.
    """

    context "number literals":
        it "renders number unchanged":
            expect(to_pretty("42")).to_equal("42")

    context "identifiers with greek resolution":
        it "renders plain identifier":
            expect(to_pretty("x")).to_equal("x")

        it "resolves lowercase greek":
            val result = to_pretty("alpha")
            expect(result).to_equal("\u03B1")

        it "resolves uppercase greek":
            val result = to_pretty("Gamma")
            expect(result).to_equal("\u0393")

        it "leaves non-greek identifier unchanged":
            expect(to_pretty("foo")).to_equal("foo")

    context "arithmetic operations":
        it "renders addition":
            expect(to_pretty("a + b")).to_contain("+")

        it "renders subtraction":
            expect(to_pretty("a - b")).to_contain("-")

        it "renders explicit multiplication":
            expect(to_pretty("a * b")).to_contain("*")

        it "renders implicit multiplication without operator":
            val result = to_pretty("2x")
            expect(result).to_contain("2")
            expect(result).to_contain("x")

        it "renders division":
            expect(to_pretty("a / b")).to_contain("/")

    context "power rendering":
        it "renders power with pretty_power":
            val result = to_pretty("x^2")
            expect(result).to_contain("x")

    context "negation":
        it "renders negation with minus":
            expect(to_pretty("-x")).to_start_with("-")

    context "grouping":
        it "renders parentheses":
            val result = to_pretty("(x + 1)")
            expect(result).to_start_with("(")
            expect(result).to_end_with(")")

    context "subscript rendering":
        it "renders subscript with pretty_sub":
            val result = to_pretty("x[i]")
            expect(result).to_contain("x")

    context "transpose rendering":
        it "renders transpose with T suffix":
            val result = to_pretty("A'")
            expect(result).to_contain("A")
            expect(result).to_contain("T")

    context "function calls":
        it "renders sqrt with pretty_sqrt":
            val result = to_pretty("sqrt(x)")
            expect(result).to_contain("x")

        it "renders non-sqrt function normally":
            val result = to_pretty("sin(x)")
            expect(result).to_contain("sin")
            expect(result).to_contain("x")

    context "frac rendering":
        it "renders fraction with pretty_fraction":
            val result = to_pretty("frac(a, b)")
            expect(result).to_contain("a")
            expect(result).to_contain("b")

    context "sum and integral rendering":
        it "renders sum expression":
            val result = to_pretty("sum(i, 1..n) i")
            expect(result).to_contain("i")

        it "renders integral expression":
            val result = to_pretty("int(x, 0..1) x")
            expect(result).to_contain("x")


# ============================================================================
# 4. math_repr — to_md and render_latex_raw (LaTeX / Markdown renderer)
# ============================================================================

describe "math_repr to_md":
    """
    ## Markdown LaTeX Rendering

    Tests the markdown renderer which wraps LaTeX in dollar signs.
    """

    context "markdown wrapping and identifiers":
        it "wraps output in dollar signs":
            val result = to_md("x")
            expect(result).to_start_with("$")
            expect(result).to_end_with("$")

        it "renders number and plain identifier":
            expect(to_md("42")).to_equal("$42$")
            expect(to_md("x")).to_equal("$x$")

        it "renders greek and uppercase greek":
            expect(to_md("alpha")).to_contain("\\alpha")
            expect(to_md("Gamma")).to_contain("\\Gamma")

    context "binary operations and unary":
        it "renders add, sub, mul, div":
            expect(to_md("a + b")).to_contain("+")
            expect(to_md("a - b")).to_contain("-")
            expect(to_md("a * b")).to_contain("\\cdot")
            expect(to_md("a / b")).to_contain("/")

        it "renders implicit mul, power, negation":
            expect(to_md("2x")).to_contain("x")
            expect(to_md("x^2")).to_contain("x")
            expect(to_md("-x")).to_contain("-")

    context "grouping, subscript, transpose":
        it "renders grouped expression":
            expect(to_md("(a + b)")).to_contain("(")

        it "renders subscript and transpose":
            expect(to_md("x[i]")).to_contain("x")
            expect(to_md("A'")).to_contain('^{T}')

    context "function calls":
        it "renders unknown function with operatorname":
            expect(to_md("foo(x)")).to_contain('\operatorname{foo}')

        it "renders sqrt, known, and multi-arg functions":
            expect(to_md("sqrt(x)")).to_contain("x")
            expect(to_md("sin(x)")).to_contain("\\sin")
            expect(to_md("max(a, b)")).to_contain("\\max")

    context "frac, sum, integral rendering":
        it "renders frac with latex_fraction":
            expect(to_md("frac(a, b)")).to_contain("a")

        it "renders sum and integral":
            expect(to_md("sum(i, 1..n) i")).to_contain("i")
            expect(to_md("int(x, 0..1) x")).to_contain("x")


describe "math_repr render_latex_raw":
    """
    ## Raw LaTeX Rendering

    Tests render_latex_raw which returns LaTeX without dollar sign wrapping.
    """

    context "raw latex output":
        it "does not wrap in dollar signs":
            val result = render_latex_raw("x")
            expect(result).to_equal("x")

        it "renders expression without wrapping":
            val result = render_latex_raw("x + 1")
            expect(result).to_contain("+")


# ============================================================================
# 5. math_repr — Tokenizer edge cases
# ============================================================================

describe "math_repr tokenizer edges":
    """
    ## Tokenizer Edge Cases

    Exercises less common tokenizer branches: dots, brackets, commas,
    whitespace handling, and unknown characters.
    """

    context "whitespace handling":
        it "handles extra spaces":
            expect(to_text("x  +  y")).to_equal("x + y")

        it "handles tabs":
            expect(to_text("x\t+\ty")).to_equal("x + y")

    context "dot and range tokens":
        it "handles dot-dot range in sum":
            val result = to_text("sum(i, 1..10) i")
            expect(result).to_contain("..")

    context "bracket tokens":
        it "handles square brackets for subscript":
            expect(to_text("a[0]")).to_equal("a[0]")

    context "comma tokens":
        it "handles commas in function args":
            expect(to_text("f(a, b, c)")).to_equal("f(a, b, c)")

    context "unknown characters":
        it "skips unknown characters gracefully":
            val result = to_text("x + y")
            expect(result).to_contain("x")
            expect(result).to_contain("y")

    context "empty input":
        it "handles empty string with fallback":
            # Empty input produces eof token; parser fallback returns "?" node
            val result = to_text("")
            expect(result).to_equal("?")


# ============================================================================
# 6. math_repr — Parser edge cases
# ============================================================================

describe "math_repr parser edges":
    """
    ## Parser Edge Cases

    Exercises parser branches for complex nesting, operator precedence,
    and special form parsing.
    """

    context "operator precedence":
        it "mul binds tighter than add":
            expect(to_debug("a + b * c")).to_equal("Add(Id(a), Mul(Id(b), Id(c)))")

        it "power binds tighter than mul":
            expect(to_debug("a * b^c")).to_equal("Mul(Id(a), Pow(Id(b), Id(c)))")

        it "negation applies to power":
            expect(to_debug("-x^2")).to_equal("Neg(Pow(Id(x), Num(2)))")

    context "implicit multiplication":
        it "number followed by identifier":
            expect(to_debug("3x")).to_equal("Mul(Num(3), Id(x))")

        it "number followed by paren group":
            expect(to_debug("2(x)")).to_equal("Mul(Num(2), Group(Id(x)))")

        it "identifier followed by paren starts function call":
            expect(to_debug("f(x)")).to_equal("Call(f, Id(x))")

    context "nested grouping":
        it "handles nested parentheses":
            expect(to_debug("((x))")).to_equal("Group(Group(Id(x)))")

    context "chained postfix":
        it "handles subscript then transpose":
            val result = to_debug("A[i]'")
            expect(result).to_contain("Transpose")
            expect(result).to_contain("Sub")

    context "known function detection for latex":
        it "recognizes sin as known":
            val result = render_latex_raw("sin(x)")
            expect(result).to_contain("\\sin")

        it "recognizes cos as known":
            val result = render_latex_raw("cos(x)")
            expect(result).to_contain("\\cos")

        it "recognizes tan as known":
            val result = render_latex_raw("tan(x)")
            expect(result).to_contain("\\tan")

        it "recognizes log as known":
            val result = render_latex_raw("log(x)")
            expect(result).to_contain("\\log")

        it "recognizes ln as known":
            val result = render_latex_raw("ln(x)")
            expect(result).to_contain("\\ln")

        it "recognizes exp as known":
            val result = render_latex_raw("exp(x)")
            expect(result).to_contain("\\exp")

        it "recognizes min as known":
            val result = render_latex_raw("min(a, b)")
            expect(result).to_contain("\\min")

        it "recognizes lim as known":
            val result = render_latex_raw("lim(x)")
            expect(result).to_contain("\\lim")

        it "recognizes tanh as known":
            val result = render_latex_raw("tanh(x)")
            expect(result).to_contain("\\tanh")

        it "recognizes sinh as known":
            val result = render_latex_raw("sinh(x)")
            expect(result).to_contain("\\sinh")

        it "recognizes cosh as known":
            val result = render_latex_raw("cosh(x)")
            expect(result).to_contain("\\cosh")

        it "treats unknown function as operatorname":
            val result = render_latex_raw("foo(x)")
            expect(result).to_contain('\operatorname{foo}')

    context "zero-arg function call":
        it "renders function with no args":
            expect(to_text("f()")).to_equal("f()")

    context "single dot token":
        it "handles single dot at end of input":
            val result = to_text("x.")
            expect(result).to_contain("x")

    context "character coverage for _is_digit":
        it "exercises all digit branches 0-9":
            # Number containing all 10 digits covers every _is_digit branch
            val result = to_text("1234567890")
            expect(result).to_equal("1234567890")

        it "exercises decimal number with dot":
            val result = to_text("3.14159")
            expect(result).to_equal("3.14159")

    context "character coverage for _is_alpha":
        it "exercises lowercase a-m in identifiers":
            val r1 = to_text("abcdefg")
            expect(r1).to_equal("abcdefg")
            val r2 = to_text("hijklm")
            expect(r2).to_equal("hijklm")

        it "exercises lowercase n-z in identifiers":
            val r1 = to_text("nopqr")
            expect(r1).to_equal("nopqr")
            val r2 = to_text("stuvwxyz")
            expect(r2).to_equal("stuvwxyz")

        it "exercises uppercase A-M in identifiers":
            val r1 = to_text("ABCDEFG")
            expect(r1).to_equal("ABCDEFG")
            val r2 = to_text("HIJKLM")
            expect(r2).to_equal("HIJKLM")

        it "exercises uppercase N-Z in identifiers":
            val r1 = to_text("NOPQR")
            expect(r1).to_equal("NOPQR")
            val r2 = to_text("STUVWXYZ")
            expect(r2).to_equal("STUVWXYZ")

        it "exercises underscore in identifier":
            # Underscore is alpha in math tokenizer; tokenizes as single ident
            val result = to_text("a_b")
            expect(result).to_contain("a")

    context "_can_start_expr and _can_implicit_mul edge cases":
        it "no implicit mul after operator":
            # After +, next token is num - not implicit mul context
            val result = to_debug("a + 2")
            expect(result).to_equal("Add(Id(a), Num(2))")

        it "implicit mul with num before lparen":
            val result = to_debug("3(a + b)")
            expect(result).to_contain("Mul")
            expect(result).to_contain("Group")

    context "tokenizer number-dot boundary":
        it "handles number followed by dot-dot range":
            # In sum(i, 1..10), the 1 must not consume ".." as decimal
            val result = to_debug("sum(i, 1..10) i")
            expect(result).to_contain("Sum")
            expect(result).to_contain("Num(1)")
            expect(result).to_contain("Num(10)")

    context "greek letter resolution through pretty renderer":
        # Each call exercises a different branch in greek() via _resolve_greek
        it "resolves beta through pretty":
            expect(to_pretty("beta")).to_contain("\u03B2")

        it "resolves gamma delta epsilon through pretty":
            expect(to_pretty("gamma")).to_contain("\u03B3")
            expect(to_pretty("delta")).to_contain("\u03B4")
            expect(to_pretty("epsilon")).to_contain("\u03B5")

        it "resolves zeta eta theta through pretty":
            expect(to_pretty("zeta")).to_contain("\u03B6")
            expect(to_pretty("eta")).to_contain("\u03B7")
            expect(to_pretty("theta")).to_contain("\u03B8")

        it "resolves iota kappa lambda through pretty":
            expect(to_pretty("iota")).to_contain("\u03B9")
            expect(to_pretty("kappa")).to_contain("\u03BA")
            expect(to_pretty("lambda")).to_contain("\u03BB")

        it "resolves mu nu xi through pretty":
            expect(to_pretty("mu")).to_contain("\u03BC")
            expect(to_pretty("nu")).to_contain("\u03BD")
            expect(to_pretty("xi")).to_contain("\u03BE")

        it "resolves omicron pi rho through pretty":
            expect(to_pretty("omicron")).to_contain("\u03BF")
            expect(to_pretty("pi")).to_contain("\u03C0")
            expect(to_pretty("rho")).to_contain("\u03C1")

        it "resolves sigma tau upsilon through pretty":
            expect(to_pretty("sigma")).to_contain("\u03C3")
            expect(to_pretty("tau")).to_contain("\u03C4")
            expect(to_pretty("upsilon")).to_contain("\u03C5")

        it "resolves phi chi psi omega through pretty":
            expect(to_pretty("phi")).to_contain("\u03C6")
            expect(to_pretty("chi")).to_contain("\u03C7")
            expect(to_pretty("psi")).to_contain("\u03C8")
            expect(to_pretty("omega")).to_contain("\u03C9")

        it "resolves variant forms through pretty":
            expect(to_pretty("varepsilon")).to_contain("\u03F5")
            expect(to_pretty("vartheta")).to_contain("\u03D1")
            expect(to_pretty("varphi")).to_contain("\u03D5")
            expect(to_pretty("varrho")).to_contain("\u03F1")

        it "resolves more variants and specials through pretty":
            expect(to_pretty("varpi")).to_contain("\u03D6")
            expect(to_pretty("varkappa")).to_contain("\u03F0")
            expect(to_pretty("partial")).to_contain("\u2202")
            expect(to_pretty("nabla")).to_contain("\u2207")

    context "uppercase greek through pretty renderer":
        it "resolves Delta Theta Lambda Xi through pretty":
            expect(to_pretty("Delta")).to_contain("\u0394")
            expect(to_pretty("Theta")).to_contain("\u0398")
            expect(to_pretty("Lambda")).to_contain("\u039B")
            expect(to_pretty("Xi")).to_contain("\u039E")

        it "resolves Pi Sigma Upsilon through pretty":
            expect(to_pretty("Pi")).to_contain("\u03A0")
            expect(to_pretty("Sigma")).to_contain("\u03A3")
            expect(to_pretty("Upsilon")).to_contain("\u03A5")

        it "resolves Phi Psi Omega through pretty":
            expect(to_pretty("Phi")).to_contain("\u03A6")
            expect(to_pretty("Psi")).to_contain("\u03A8")
            expect(to_pretty("Omega")).to_contain("\u03A9")

    context "greek through latex renderer":
        it "renders greek letters as latex commands":
            expect(render_latex_raw("alpha")).to_contain("\\alpha")
            expect(render_latex_raw("beta")).to_contain("\\beta")
            expect(render_latex_raw("gamma")).to_contain("\\gamma")

        it "renders uppercase greek as latex commands":
            expect(render_latex_raw("Gamma")).to_contain("\\Gamma")
            expect(render_latex_raw("Delta")).to_contain("\\Delta")
            expect(render_latex_raw("Omega")).to_contain("\\Omega")

    context "superscript char coverage through pretty power":
        # to_pretty("x^N") calls pretty_power which calls superscript on N
        # Each digit exercises a different superscript_char branch
        it "exercises superscript digits 0-4 via power":
            val r0 = to_pretty("x^0")
            expect(r0).to_contain("x")
            val r1 = to_pretty("x^1")
            expect(r1).to_contain("x")
            val r3 = to_pretty("x^3")
            expect(r3).to_contain("x")
            val r4 = to_pretty("x^4")
            expect(r4).to_contain("x")

        it "exercises superscript digits 5-9 via power":
            val r5 = to_pretty("x^5")
            expect(r5).to_contain("x")
            val r6 = to_pretty("x^6")
            expect(r6).to_contain("x")
            val r7 = to_pretty("x^7")
            expect(r7).to_contain("x")
            val r8 = to_pretty("x^8")
            expect(r8).to_contain("x")
            val r9 = to_pretty("x^9")
            expect(r9).to_contain("x")

        it "exercises superscript letters n i x via power":
            val rn = to_pretty("x^n")
            expect(rn).to_contain("x")
            val ri = to_pretty("x^i")
            expect(ri).to_contain("x")

    context "subscript char coverage through pretty subscript":
        # to_pretty("x[N]") calls pretty_sub which calls subscript_char on N
        it "exercises subscript digits 0-4":
            val r0 = to_pretty("x[0]")
            expect(r0).to_contain("x")
            val r1 = to_pretty("x[1]")
            expect(r1).to_contain("x")
            val r2 = to_pretty("x[2]")
            expect(r2).to_contain("x")
            val r3 = to_pretty("x[3]")
            expect(r3).to_contain("x")
            val r4 = to_pretty("x[4]")
            expect(r4).to_contain("x")

        it "exercises subscript digits 5-9":
            val r5 = to_pretty("x[5]")
            expect(r5).to_contain("x")
            val r6 = to_pretty("x[6]")
            expect(r6).to_contain("x")
            val r7 = to_pretty("x[7]")
            expect(r7).to_contain("x")
            val r8 = to_pretty("x[8]")
            expect(r8).to_contain("x")
            val r9 = to_pretty("x[9]")
            expect(r9).to_contain("x")

        it "exercises subscript letters a e o x":
            val ra = to_pretty("x[a]")
            expect(ra).to_contain("x")
            val re = to_pretty("x[e]")
            expect(re).to_contain("x")
            val ro = to_pretty("x[o]")
            expect(ro).to_contain("x")

        it "exercises subscript letters h k l m n p s t":
            val rh = to_pretty("x[h]")
            expect(rh).to_contain("x")
            val rk = to_pretty("x[k]")
            expect(rk).to_contain("x")
            val rl = to_pretty("x[l]")
            expect(rl).to_contain("x")
            val rm2 = to_pretty("x[m]")
            expect(rm2).to_contain("x")
            val rn = to_pretty("x[n]")
            expect(rn).to_contain("x")
            val rp = to_pretty("x[p]")
            expect(rp).to_contain("x")
            val rs = to_pretty("x[s]")
            expect(rs).to_contain("x")
            val rt = to_pretty("x[t]")
            expect(rt).to_contain("x")

        it "exercises subscript letters i j r":
            val ri = to_pretty("x[j]")
            expect(ri).to_contain("x")
            val rr = to_pretty("x[r]")
            expect(rr).to_contain("x")


# ============================================================================
# 7. Empty input fallback paths for all public API functions
# ============================================================================

describe "math_repr empty input fallbacks":
    """
    ## Empty Input Coverage

    Each public API function has an early return when tags.len() == 0.
    We need to hit the empty-input path for to_debug, to_pretty, to_md,
    and render_latex_raw (to_text already tested above).
    """

    context "empty string fallback for each API function":
        it "to_debug handles empty string":
            val result = to_debug("")
            expect(result).to_contain("?")

        it "to_pretty handles empty string":
            val result = to_pretty("")
            expect(result).to_contain("?")

        it "to_md handles empty string":
            val result = to_md("")
            expect(result).to_start_with("$")

        it "render_latex_raw handles empty string":
            val result = render_latex_raw("")
            expect(result).to_contain("?")


# ============================================================================
# 8. int_expr through all four renderers
# ============================================================================

describe "math_repr int_expr all renderers":
    """
    ## Integral Expression Coverage

    Exercises the int_expr branch in each renderer: text, debug, pretty, latex.
    """

    context "integral through text renderer":
        it "renders integral via to_text":
            val result = to_text("int(t, 0..1) t")
            expect(result).to_contain("int")
            expect(result).to_contain("t")

    context "integral through debug renderer":
        it "renders integral via to_debug":
            val result = to_debug("int(t, 0..1) t")
            expect(result).to_contain("Int")

    context "integral through pretty renderer":
        it "renders integral via to_pretty":
            val result = to_pretty("int(t, 0..1) t")
            expect(result).to_contain("t")

    context "integral through latex renderer":
        it "renders integral via render_latex_raw":
            val result = render_latex_raw("int(t, 0..1) t")
            expect(result).to_contain("\\int")

    context "integral through markdown renderer":
        it "renders integral via to_md":
            val result = to_md("int(t, 0..1) t")
            expect(result).to_start_with("$")
            expect(result).to_contain("t")


# ============================================================================
# 9. Negative idx paths and renderer edge cases
# ============================================================================

describe "math_repr renderer edge cases":
    """
    ## Renderer Edge Cases

    Tests for negative index paths (idx < 0) which occur when
    nodes have -1 for left/right children (e.g. leaf nodes).
    Also exercises tag fallthrough paths.
    """

    context "negative idx through render paths":
        it "neg of number exercises right=-1 path in text":
            # Neg node has right=-1, when rendering text it calls _render_text(left) only
            val result = to_text("-42")
            expect(result).to_equal("-42")

        it "neg of expr exercises render in debug":
            val result = to_debug("-42")
            expect(result).to_equal("Neg(Num(42))")

        it "neg exercises render in pretty":
            val result = to_pretty("-42")
            expect(result).to_equal("-42")

        it "neg exercises render in latex":
            val result = render_latex_raw("-42")
            expect(result).to_equal("-42")

    context "transpose exercises right=-1 in all renderers":
        it "transpose in text":
            val result = to_text("x'")
            expect(result).to_equal("x'")

        it "transpose in debug":
            val result = to_debug("x'")
            expect(result).to_contain("Transpose")

        it "transpose in pretty":
            val result = to_pretty("x'")
            expect(result).to_contain("T")

        it "transpose in latex":
            val result = render_latex_raw("A'")
            expect(result).to_contain("T")


# ============================================================================
# 10. Superscript and subscript operator characters
# ============================================================================

describe "math_repr superscript operator chars":
    """
    ## Superscript Operator Characters

    Exercises superscript_char branches for +, -, =, (, ) which are hit
    when pretty_power processes multi-character exponents containing operators.
    """

    context "superscript plus minus equals parens":
        it "exercises superscript + via power":
            val result = to_pretty("x^(n+1)")
            expect(result).to_contain("x")

        it "exercises superscript - via power":
            val result = to_pretty("x^(n-1)")
            expect(result).to_contain("x")

        it "exercises superscript = via power":
            # Use grouped exponent with equals-like expression
            val result = to_pretty("x^(a=b)")
            expect(result).to_contain("x")

    context "subscript plus minus":
        it "exercises subscript + via subscript":
            val result = to_pretty("x[i+1]")
            expect(result).to_contain("x")

        it "exercises subscript - via subscript":
            val result = to_pretty("x[i-1]")
            expect(result).to_contain("x")


# ============================================================================
# 11. Tokenizer branch coverage gaps
# ============================================================================

describe "math_repr tokenizer branch gaps":
    """
    ## Tokenizer Branch Coverage

    Exercises tokenizer branches that were missed: standalone dot followed
    by non-dot char, decimal number before range operator, and specific
    operator paths.
    """

    context "dot followed by non-dot character":
        it "handles dot followed by identifier":
            val result = to_text("x.y")
            expect(result).to_contain("x")

    context "decimal number before range":
        it "handles number with decimal part":
            val result = to_text("3.14")
            expect(result).to_equal("3.14")

    context "division operator tokenization":
        it "tokenizes division in complex expression":
            val result = to_text("a / b + c")
            expect(result).to_contain("/")

        it "tokenizes multiple divisions":
            val result = to_text("a / b / c")
            expect(result).to_contain("/")

    context "parentheses tokenization":
        it "tokenizes nested parens":
            val result = to_text("((a + b))")
            expect(result).to_contain("(")
            expect(result).to_contain(")")

    context "bracket tokenization standalone":
        it "tokenizes brackets in subscript":
            val result = to_text("a[b]")
            expect(result).to_contain("[")
            expect(result).to_contain("]")

    context "comma tokenization":
        it "tokenizes commas in multi-arg function":
            val result = to_text("f(a, b, c)")
            expect(result).to_contain(",")

    context "unknown character skipping":
        it "skips at sign":
            val result = to_text("a @ b")
            expect(result).to_contain("a")

        it "skips hash character":
            val result = to_text("a # b")
            expect(result).to_contain("a")

    context "underscore in identifiers":
        it "tokenizes identifier starting with underscore":
            val result = to_text("_x")
            expect(result).to_contain("x")

        it "tokenizes identifier with embedded underscore":
            val result = to_text("a_b")
            expect(result).to_contain("a")

    context "is_alnum exercising is_digit false then is_alpha":
        it "exercises alnum branch for letter after number in ident":
            val result = to_text("x1y")
            expect(result).to_contain("x1y")


# ============================================================================
# 12. Parser edge cases for deeper coverage
# ============================================================================

describe "math_repr parser edge cases deeper":
    """
    ## Parser Edge Cases - Deeper

    Exercises additional parser branches for frac, sum with edge cases,
    implicit mul distinctions, and can_start_expr false paths.
    """

    context "frac without comma":
        it "handles frac with space separation":
            val result = to_text("frac(a b)")
            expect(result).to_contain("a")

    context "sum without range":
        it "handles sum expression completely":
            val result = to_debug("sum(k, 1..n) k^2")
            expect(result).to_contain("Sum")
            expect(result).to_contain("Pow")

    context "can_start_expr false for non-expression tokens":
        it "handles expression ending at eof":
            val result = to_debug("x +")
            expect(result).to_contain("Id(x)")

    context "implicit mul variations":
        it "identifier followed by paren group":
            val result = to_debug("a(b + c)")
            expect(result).to_contain("Call")

        it "paren group followed by identifier":
            val result = to_debug("(a)b")
            expect(result).to_contain("Mul")
            expect(result).to_contain("Group")

    context "multi-arg function calls through all renderers":
        it "renders multi-arg call through pretty":
            val result = to_pretty("f(a, b, c)")
            expect(result).to_contain("f")
            expect(result).to_contain("a")

        it "renders multi-arg call through latex":
            val result = render_latex_raw("f(a, b, c)")
            expect(result).to_contain("f")

    context "sqrt through latex":
        it "renders sqrt in latex":
            val result = render_latex_raw("sqrt(x)")
            expect(result).to_contain("\\sqrt")

    context "frac through all renderers":
        it "frac through debug":
            val result = to_debug("frac(x, y)")
            expect(result).to_contain("Frac")

        it "frac through pretty":
            val result = to_pretty("frac(x, y)")
            expect(result).to_contain("x")
            expect(result).to_contain("y")

        it "frac through latex":
            val result = render_latex_raw("frac(x, y)")
            expect(result).to_contain("\\frac")

    context "subscript through all renderers":
        it "subscript through text":
            val result = to_text("a[0]")
            expect(result).to_equal("a[0]")

        it "subscript through debug":
            val result = to_debug("a[0]")
            expect(result).to_contain("Sub")

        it "subscript through latex":
            val result = render_latex_raw("a[0]")
            expect(result).to_contain("_")

    context "group through all renderers":
        it "group through debug":
            val result = to_debug("(a)")
            expect(result).to_contain("Group")

        it "group through pretty":
            val result = to_pretty("(a)")
            expect(result).to_start_with("(")
            expect(result).to_end_with(")")

        it "group through latex":
            val result = render_latex_raw("(a)")
            expect(result).to_start_with("(")

    context "division through all renderers":
        it "div through pretty":
            val result = to_pretty("a / b")
            expect(result).to_contain("/")

        it "div through latex":
            val result = render_latex_raw("a / b")
            expect(result).to_contain("/")

    context "explicit mul through latex":
        it "explicit mul renders cdot in latex":
            val result = render_latex_raw("a * b")
            expect(result).to_contain("\\cdot")

    context "implicit mul through latex":
        it "implicit mul renders space in latex":
            val result = render_latex_raw("2x")
            expect(result).to_contain("2")
            expect(result).to_contain("x")


# ============================================================================
# 13. All node types through all renderers for full branch coverage
# ============================================================================

describe "math_repr full renderer node coverage":
    """
    ## Full Renderer Node Coverage

    Each renderer (text, debug, pretty, latex) has if/elif chains for every
    node type. We must hit every node type through every renderer.
    """

    context "add through all renderers":
        it "add via pretty":
            val result = to_pretty("a + b")
            expect(result).to_equal("a + b")

        it "add via latex":
            val result = render_latex_raw("a + b")
            expect(result).to_equal("a + b")

    context "sub through all renderers":
        it "sub via text":
            val result = to_text("a - b")
            expect(result).to_equal("a - b")

        it "sub via debug":
            val result = to_debug("a - b")
            expect(result).to_equal("Sub(Id(a), Id(b))")

        it "sub via pretty":
            val result = to_pretty("a - b")
            expect(result).to_equal("a - b")

        it "sub via latex":
            val result = render_latex_raw("a - b")
            expect(result).to_equal("a - b")

    context "mul explicit through all renderers":
        it "mul via text":
            val result = to_text("a * b")
            expect(result).to_equal("a * b")

        it "mul via debug":
            val result = to_debug("a * b")
            expect(result).to_equal("Mul(Id(a), Id(b))")

        it "mul via pretty":
            val result = to_pretty("a * b")
            expect(result).to_contain("*")

    context "mul implicit through all renderers":
        it "implicit mul via text":
            val result = to_text("2x")
            expect(result).to_equal("2x")

        it "implicit mul via pretty":
            val result = to_pretty("2x")
            expect(result).to_contain("2")

        it "implicit mul via latex":
            val result = render_latex_raw("2x")
            expect(result).to_contain("x")

    context "div through all renderers":
        it "div via text":
            val result = to_text("a / b")
            expect(result).to_equal("a / b")

        it "div via debug":
            val result = to_debug("a / b")
            expect(result).to_equal("Div(Id(a), Id(b))")

    context "pow through all renderers":
        it "pow via text":
            val result = to_text("a^b")
            expect(result).to_equal("a^b")

        it "pow via debug":
            val result = to_debug("a^b")
            expect(result).to_equal("Pow(Id(a), Id(b))")

        it "pow via pretty":
            val result = to_pretty("a^b")
            expect(result).to_contain("a")

        it "pow via latex":
            val result = render_latex_raw("a^b")
            expect(result).to_contain("a")

    context "neg through all renderers":
        it "neg via text":
            val result = to_text("-a")
            expect(result).to_equal("-a")

        it "neg via debug":
            val result = to_debug("-a")
            expect(result).to_equal("Neg(Id(a))")

        it "neg via pretty":
            val result = to_pretty("-a")
            expect(result).to_equal("-a")

        it "neg via latex":
            val result = render_latex_raw("-a")
            expect(result).to_equal("-a")

    context "frac through all renderers":
        it "frac via text":
            val result = to_text("frac(a, b)")
            expect(result).to_equal("a / b")

        it "frac via debug":
            val result = to_debug("frac(a, b)")
            expect(result).to_equal("Frac(Id(a), Id(b))")

    context "group through all renderers":
        it "group via text":
            val result = to_text("(a)")
            expect(result).to_equal("(a)")

        it "group via latex":
            val result = render_latex_raw("(a)")
            expect(result).to_contain("(")

    context "subscript through all renderers":
        it "subscript via text":
            val result = to_text("a[i]")
            expect(result).to_equal("a[i]")

        it "subscript via pretty":
            val result = to_pretty("a[i]")
            expect(result).to_contain("a")

        it "subscript via latex":
            val result = render_latex_raw("a[i]")
            expect(result).to_contain("a")

    context "transpose through all renderers":
        it "transpose via text":
            val result = to_text("A'")
            expect(result).to_equal("A'")

        it "transpose via debug":
            val result = to_debug("A'")
            expect(result).to_contain("Transpose")

    context "call through all renderers":
        it "call via text":
            val result = to_text("f(x)")
            expect(result).to_equal("f(x)")

        it "call via pretty":
            val result = to_pretty("f(x)")
            expect(result).to_contain("f")

        it "call via latex known fn":
            val result = render_latex_raw("sin(x)")
            expect(result).to_contain("\\sin")

        it "call via latex unknown fn":
            val result = render_latex_raw("foo(x)")
            expect(result).to_contain("foo")

    context "sum_expr through all renderers":
        it "sum via text":
            val result = to_text("sum(i, 1..n) i")
            expect(result).to_contain("sum")

        it "sum via debug":
            val result = to_debug("sum(i, 1..n) i")
            expect(result).to_contain("Sum")

        it "sum via pretty":
            val result = to_pretty("sum(i, 1..n) i")
            expect(result).to_contain("i")

        it "sum via latex":
            val result = render_latex_raw("sum(i, 1..n) i")
            expect(result).to_contain("\\sum")

        it "sum via md":
            val result = to_md("sum(i, 1..n) i")
            expect(result).to_start_with("$")

    context "int_expr through all renderers":
        it "int via text":
            val result = to_text("int(x, 0..1) x")
            expect(result).to_contain("int")

        it "int via debug":
            val result = to_debug("int(x, 0..1) x")
            expect(result).to_contain("Int")

        it "int via pretty":
            val result = to_pretty("int(x, 0..1) x")
            expect(result).to_contain("x")

        it "int via latex":
            val result = render_latex_raw("int(x, 0..1) x")
            expect(result).to_contain("x")

    context "sqrt call special case":
        it "sqrt via pretty":
            val result = to_pretty("sqrt(x)")
            expect(result).to_contain("x")

        it "sqrt via latex":
            val result = render_latex_raw("sqrt(x)")
            expect(result).to_contain("\\sqrt")

        it "sqrt via text":
            val result = to_text("sqrt(x)")
            expect(result).to_contain("sqrt")

        it "sqrt via debug":
            val result = to_debug("sqrt(x)")
            expect(result).to_contain("Call")


