use std.spec.*

use std.common.render_scene.scene.{scene_fill_rect, scene_text, scene_clip_push, scene_clip_pop, render_scene}
use std.common.render_scene.scene_to_canvas2d_json.{render_scene_to_canvas2d_ops, render_scene_to_canvas2d_ops_with_offset}

describe "render_scene_to_canvas2d_ops":

    it "serializes basic scene commands for the hosted canvas shell":
        val scene = render_scene(
            [
                scene_fill_rect(4, 6, 20, 12, 0xFFFF0000),
                scene_text(10, 24, "Hello", 0xFF112233, 14),
                scene_clip_push(0, 0, 40, 30),
                scene_clip_pop()
            ],
            80,
            60
        )

        val json = render_scene_to_canvas2d_ops(scene)
        expect (json).contains("\"op\":\"fillRect\"")
        expect (json).contains("\"text\":\"Hello\"")
        expect (json).contains("\"op\":\"pushClip\"")
        expect (json).contains("\"op\":\"popClip\"")

    it "applies offsets when translating scene output":
        val scene = render_scene([scene_fill_rect(2, 3, 8, 9, 0xFF00FF00)], 32, 24)
        val json = render_scene_to_canvas2d_ops_with_offset(scene, 10, 20)

        expect (json).contains("\"x\":12")
        expect (json).contains("\"y\":23")