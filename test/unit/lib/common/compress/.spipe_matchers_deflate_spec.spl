use std.spec.{describe, it, expect}
use std.common.compress.deflate.{deflate_compress, deflate_decompress}

fn _make_hello_bytes() -> [u8]:
    # "Hello" = [72, 101, 108, 108, 111]
    var data: [u8] = []
    var b0: u8 = 72u8
    var b1: u8 = 101u8
    var b2: u8 = 108u8
    var b3: u8 = 108u8
    var b4: u8 = 111u8
    data.push(b0)
    data.push(b1)
    data.push(b2)
    data.push(b3)
    data.push(b4)
    data

fn _make_hello_world_bytes() -> [u8]:
    # "Hello, World!"
    val text_bytes = [72, 101, 108, 108, 111, 44, 32, 87, 111, 114, 108, 100, 33]
    var data: [u8] = []
    var i = 0
    while i < text_bytes.len():
        var b: u8 = text_bytes[i].to_u8()
        data.push(b)
        i = i + 1
    data

fn _make_repeated_pattern(count: i64) -> [u8]:
    # "ABCDEFGH" repeated to fill `count` bytes
    val pattern = [65, 66, 67, 68, 69, 70, 71, 72]
    var data: [u8] = []
    var i = 0
    while i < count:
        var b: u8 = pattern[i % pattern.len()].to_u8()
        data.push(b)
        i = i + 1
    data

fn _make_known_deflate_hello() -> [u8]:
    # Raw DEFLATE fixed Huffman for "Hello" — produced by Python zlib level=1
    # f3 48 cd c9 c9 07 00 (BFINAL=1)
    var data: [u8] = []
    var b0: u8 = 0xF3u8
    var b1: u8 = 0x48u8
    var b2: u8 = 0xCDu8
    var b3: u8 = 0xC9u8
    var b4: u8 = 0xC9u8
    var b5: u8 = 0x07u8
    var b6: u8 = 0x00u8
    data.push(b0)
    data.push(b1)
    data.push(b2)
    data.push(b3)
    data.push(b4)
    data.push(b5)
    data.push(b6)
    data

describe "DEFLATE RFC 1951 encoder/decoder":
    it "decompresses known fixed-Huffman stream for Hello":
        val compressed = _make_known_deflate_hello()
        val decompressed = deflate_decompress(compressed)
        val expected = _make_hello_bytes()
        expect decompressed.len() == 5
        expect decompressed == expected

    it "round-trips empty input":
        var empty: [u8] = []
        val compressed = deflate_compress(empty)
        val decompressed = deflate_decompress(compressed)
        expect decompressed.len() == 0
        expect decompressed == empty

    it "round-trips Hello World":
        val input = _make_hello_world_bytes()
        val compressed = deflate_compress(input)
        val decompressed = deflate_decompress(compressed)
        expect decompressed.len() == input.len()
        expect decompressed == input

    it "round-trips 1000 bytes of repeated pattern":
        val input = _make_repeated_pattern(1000)
        val compressed = deflate_compress(input)
        # Repeated data should compress significantly
        expect compressed.len() < input.len() == true
        val decompressed = deflate_decompress(compressed)
        expect decompressed.len() == input.len()
        expect decompressed == input

    it "compressed output is smaller than input for repetitive data":
        val input = _make_repeated_pattern(1000)
        val compressed = deflate_compress(input)
        expect compressed.len() < 100 == true