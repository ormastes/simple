# ============================================================================
# Test Group 31: Locale relative time - German locale (fast - no date arithmetic)
# ============================================================================


describe "Locale Relative Time - German locale":
    it "formats seconds ago in German":
        var locale = ("de", "DE", "", "")
        var result = locale_relative_time_seconds(-30, locale)
        expect(result).to_equal("a few seconds ago")

    it "formats seconds in future in German":
        var locale = ("de", "DE", "", "")
        var result = locale_relative_time_seconds(30, locale)
        expect(result).to_equal("in a few seconds")

    it "formats minutes ago in German":
        var locale = ("de", "DE", "", "")
        var result = locale_relative_time_seconds(-300, locale)
        expect(result).to_equal("5 minutes ago")

    it "formats minutes in future in German":
        var locale = ("de", "DE", "", "")
        var result = locale_relative_time_seconds(300, locale)
        expect(result).to_equal("in 5 minutes")

    it "formats hours ago in German":
        var locale = ("de", "DE", "", "")
        var result = locale_relative_time_seconds(-7200, locale)
        expect(result).to_equal("2 hours ago")

    it "formats hours in future in German":
        var locale = ("de", "DE", "", "")
        var result = locale_relative_time_seconds(7200, locale)
        expect(result).to_equal("in 2 hours")

    it "formats days ago in German":
        var locale = ("de", "DE", "", "")
        var result = locale_relative_time_seconds(-172800, locale)
        expect(result).to_equal("2 days ago")

    it "formats days in future in German":
        var locale = ("de", "DE", "", "")
        var result = locale_relative_time_seconds(172800, locale)
        expect(result).to_equal("in 2 days")

# ============================================================================
# Test Group 32: Relative time boundary seconds
# ============================================================================


describe "Locale Relative Time - Boundary":
    it "zero seconds":
        var locale = ("en", "US", "", "")
        var result = locale_relative_time_seconds(0, locale)
        expect(result).to_equal("a few seconds ago")

    it "exactly 60 seconds":
        var locale = ("en", "US", "", "")
        expect(locale_relative_time_seconds(-60, locale)).to_equal("1 minutes ago")

    it "exactly 3600 seconds":
        var locale = ("en", "US", "", "")
        expect(locale_relative_time_seconds(-3600, locale)).to_equal("1 hours ago")

    it "exactly 86400 seconds":
        var locale = ("en", "US", "", "")
        expect(locale_relative_time_seconds(-86400, locale)).to_equal("1 days ago")

