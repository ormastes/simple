use std.spec.{describe, it, expect}
use std.common.compress.{CompressionError}
use std.common.compress.lzma2.{lzma2_decompress_xz}

fn _payload(size: i64) -> [u8]:
    var out: [u8] = []
    var i = 0
    while i < size:
        out.push((((i * 17) + (i / 13) + 23) % 251).to_u8())
        i = i + 1
    out

describe "lzma2 random 256":
    it "decodes 256B random-ish payload via host xz":
        val encoded: [u8] = [
            0xfdu8, 0x37u8, 0x7au8, 0x58u8, 0x5au8, 0x00u8, 0x00u8, 0x01u8,
            0x69u8, 0x22u8, 0xdeu8, 0x36u8, 0x02u8, 0x00u8, 0x21u8, 0x01u8,
            0x16u8, 0x00u8, 0x00u8, 0x00u8, 0x74u8, 0x2fu8, 0xe5u8, 0xa3u8,
            0xe0u8, 0x00u8, 0xffu8, 0x00u8, 0xc2u8, 0x5du8, 0x00u8, 0x0bu8,
            0x8au8, 0xd8u8, 0xe8u8, 0x08u8, 0x80u8, 0x2cu8, 0x15u8, 0xccu8,
            0xa2u8, 0x96u8, 0xabu8, 0x0bu8, 0x0bu8, 0x6cu8, 0x0eu8, 0xc7u8,
            0x2fu8, 0x4au8, 0xc7u8, 0x8eu8, 0xf5u8, 0xf1u8, 0x68u8, 0x37u8,
            0xc5u8, 0xd9u8, 0x0au8, 0x8du8, 0x8fu8, 0x78u8, 0x93u8, 0x3bu8,
            0x90u8, 0x92u8, 0xf9u8, 0x69u8, 0x92u8, 0x13u8, 0x70u8, 0x8au8,
            0x7fu8, 0x15u8, 0x50u8, 0x3du8, 0x93u8, 0xe6u8, 0x67u8, 0xa4u8,
            0x82u8, 0x96u8, 0xedu8, 0x43u8, 0x79u8, 0x74u8, 0x05u8, 0xf5u8,
            0x26u8, 0x5cu8, 0xd9u8, 0xa3u8, 0xabu8, 0x63u8, 0x47u8, 0x2fu8,
            0xa0u8, 0x4au8, 0xeeu8, 0xf3u8, 0xf0u8, 0x42u8, 0x07u8, 0xe3u8,
            0xa4u8, 0x32u8, 0xd7u8, 0x41u8, 0x48u8, 0xffu8, 0x56u8, 0x22u8,
            0x2eu8, 0x89u8, 0x55u8, 0xc9u8, 0xa4u8, 0xdbu8, 0xedu8, 0x38u8,
            0x6cu8, 0xa4u8, 0x4cu8, 0x04u8, 0x89u8, 0xf5u8, 0x2fu8, 0xe5u8,
            0x59u8, 0x86u8, 0xddu8, 0x3fu8, 0x8cu8, 0xc0u8, 0xcau8, 0x25u8,
            0xd9u8, 0x01u8, 0x29u8, 0x85u8, 0x66u8, 0xefu8, 0xe9u8, 0xe6u8,
            0xa3u8, 0x4eu8, 0xcdu8, 0x96u8, 0xdbu8, 0x5bu8, 0x1eu8, 0xd3u8,
            0xd6u8, 0xd1u8, 0x59u8, 0xfcu8, 0xb7u8, 0xfdu8, 0xa9u8, 0x80u8,
            0xccu8, 0xfeu8, 0x87u8, 0xa5u8, 0x20u8, 0x85u8, 0xabu8, 0xf8u8,
            0x42u8, 0x4au8, 0x7cu8, 0x56u8, 0x2cu8, 0x70u8, 0x46u8, 0xbcu8,
            0xdau8, 0x10u8, 0xe3u8, 0xc6u8, 0xe3u8, 0x1bu8, 0x6cu8, 0x6fu8,
            0x2au8, 0x5eu8, 0x12u8, 0xf3u8, 0x46u8, 0x66u8, 0x57u8, 0xa1u8,
            0x0fu8, 0xfeu8, 0x4fu8, 0x76u8, 0xe7u8, 0x34u8, 0x35u8, 0x66u8,
            0x21u8, 0xa8u8, 0x94u8, 0x0bu8, 0xc6u8, 0xedu8, 0x36u8, 0xedu8,
            0xc5u8, 0x89u8, 0x02u8, 0x64u8, 0x75u8, 0xc4u8, 0xfcu8, 0xe2u8,
            0xfcu8, 0xf5u8, 0x78u8, 0x7cu8, 0x1cu8, 0x17u8, 0x5cu8, 0x6bu8,
            0x00u8, 0x00u8, 0x00u8, 0x00u8, 0xfcu8, 0x73u8, 0xf2u8, 0xbbu8,
            0x00u8, 0x01u8, 0xdau8, 0x01u8, 0x80u8, 0x02u8, 0x00u8, 0x00u8,
            0x71u8, 0xa0u8, 0x4du8, 0xa3u8, 0x3eu8, 0x30u8, 0x0du8, 0x8bu8,
            0x02u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x01u8, 0x59u8, 0x5au8
        ]
        val decoded = lzma2_decompress_xz(encoded)
        if decoded.is_err():
            match decoded.unwrap_err():
                CompressionError.CorruptStream(m): print("CorruptStream: " + m)
                CompressionError.UnsupportedFeature(m): print("Unsup: " + m)
                CompressionError.TruncatedInput(m): print("Trunc: " + m)
                CompressionError.ChecksumMismatch(m): print("CRC: " + m)
                CompressionError.InvalidHeader(m): print("Inv: " + m)
                CompressionError.SizeLimitExceeded(l): print("Size")
        expect decoded.is_err() == false
        val out = decoded.unwrap()
        print("got len=" + out.len().to_text())
        val want = _payload(256)
        var i = 0
        while i < 32 and i < out.len():
            print("i=" + i.to_text() + " got=" + out[i].to_text() + " want=" + want[i].to_text())
            i = i + 1
        expect out == want