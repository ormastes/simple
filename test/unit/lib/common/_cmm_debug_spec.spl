fn lex_cmm_line(line: text, line_num: i64) -> [text]:
    val trimmed = line.trim()
    if trimmed.len() == 0:
        return []
    if trimmed.starts_with(";") or trimmed.starts_with("//"):
        return ["t1"]
    if trimmed.starts_with("\""):
        return ["t1"]
    var count = 1
    var i = 0
    var in_string = false
    while i < trimmed.len():
        val ch = trimmed[i]
        if ch == "\"":
            in_string = not in_string
        elif not in_string:
            if ch == " " or ch == "\t":
                count = count + 1
                while i + 1 < trimmed.len() and trimmed[i + 1] == " ":
                    i = i + 1
            elif ch == "=" and i > 0 and trimmed[i - 1] != "!" and trimmed[i - 1] != "<" and trimmed[i - 1] != ">" and trimmed[i - 1] != "=":
                count = count + 1
        i = i + 1
    if trimmed.contains("--") and not trimmed.starts_with("--"):
        count = count + 1
    var result: [text] = []
    var j = 0
    while j < count:
        result = result.push("t")
        j = j + 1
    result

describe "CMM stub debug":
    it "test full line 1":
        val tokens = lex_cmm_line("  SYStem.CPU 78K0R", 1)
        print "tokens: {tokens}"
        print "len: {tokens.len()}"
        expect(tokens.len()).to_be_greater_than(1)
    
    it "test tab line":
        val tokens = lex_cmm_line("\tStep", 1)
        print "tokens: {tokens}"
        print "len: {tokens.len()}"
        expect(tokens.len()).to_equal(1)
