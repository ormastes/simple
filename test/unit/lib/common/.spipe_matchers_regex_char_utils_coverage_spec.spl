describe "is_escape_char":
    """
    ## is_escape_char(ch: text) -> bool

    Returns true for characters that are recognized escape sequences.
    Branch coverage: each recognized char true, non-recognized false.
    """

    context "true branch - all recognized escape characters":
        it "returns true for 'n'":
            expect is_escape_char("n") == true

        it "returns true for 't'":
            expect is_escape_char("t") == true

        it "returns true for 'r'":
            expect is_escape_char("r") == true

        it "returns true for 'd'":
            expect is_escape_char("d") == true

        it "returns true for 'D'":
            expect is_escape_char("D") == true

        it "returns true for 'w'":
            expect is_escape_char("w") == true

        it "returns true for 'W'":
            expect is_escape_char("W") == true

        it "returns true for 's'":
            expect is_escape_char("s") == true

        it "returns true for 'S'":
            expect is_escape_char("S") == true

        it "returns true for 'b'":
            expect is_escape_char("b") == true

        it "returns true for 'B'":
            expect is_escape_char("B") == true

    context "false branch - non-escape characters":
        it "returns false for 'a'":
            expect is_escape_char("a") == false

        it "returns false for 'x'":
            expect is_escape_char("x") == false

        it "returns false for '0'":
            expect is_escape_char("0") == false

        it "returns false for '.'":
            expect is_escape_char(".") == false

        it "returns false for empty string":
            expect is_escape_char("") == false

        it "returns false for space":
            expect is_escape_char(" ") == false


# ============================================================================
# Test Group 15: escape_regex and unescape_regex roundtrip
# ============================================================================

describe "escape and unescape roundtrip":
    """
    ## Roundtrip verification

    Verifies that escaping and then unescaping produces the original string.
    """

    it "roundtrips plain text":
        val original = "hello world"
        expect unescape_regex(escape_regex(original)) == original

    it "roundtrips string with dots":
        val original = "a.b.c"
        expect unescape_regex(escape_regex(original)) == original

    it "roundtrips string with all metacharacters":
        val original = ".*+?|()[]{}^$"
        expect unescape_regex(escape_regex(original)) == original

    it "roundtrips empty string":
        expect unescape_regex(escape_regex("")) == ""

    it "roundtrips mixed content":
        val original = "foo(bar)+baz*"
        expect unescape_regex(escape_regex(original)) == original


