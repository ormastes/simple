# ============================================================================
# Test Group 11: escape_regex
# ============================================================================

describe "escape_regex":
    """
    ## escape_regex(text_str: text) -> text

    Escapes all special regex characters with a preceding backslash.
    Branch coverage: string with special chars, string without, empty string,
    mixed content.
    """

    context "strings with special characters":
        it "escapes a dot":
            expect escape_regex(".") == "\\."

        it "escapes a star":
            expect escape_regex("*") == "\\*"

        it "escapes parentheses":
            expect escape_regex("()") == "\\(\\)"

        it "escapes brackets":
            expect escape_regex("[]") == "\\[\\]"

        it "escapes braces":
            expect escape_regex("{}") == "\\{\\}"

        it "escapes caret and dollar":
            expect escape_regex("^$") == "\\^\\$"

        it "escapes pipe":
            expect escape_regex("|") == "\\|"

        it "escapes plus and question mark":
            expect escape_regex("+?") == "\\+\\?"

        it "escapes backslash":
            expect escape_regex("\\") == "\\\\"

    context "strings without special characters":
        it "returns plain text unchanged":
            expect escape_regex("hello") == "hello"

        it "returns digits unchanged":
            expect escape_regex("12345") == "12345"

    context "mixed content":
        it "escapes only special chars in mixed string":
            expect escape_regex("a.b") == "a\\.b"

        it "escapes multiple special chars among normal text":
            expect escape_regex("a+b*c") == "a\\+b\\*c"

    context "edge cases":
        it "returns empty string for empty input":
            expect escape_regex("") == ""

        it "handles single normal character":
            expect escape_regex("x") == "x"


# ============================================================================
# Test Group 12: unescape_regex
# ============================================================================

describe "unescape_regex":
    """
    ## unescape_regex(text_str: text) -> text

    Removes escape backslashes from regex string. Handles: normal chars,
    escaped chars, trailing backslash.
    Branch coverage: ch == backslash (true/false), i+1 < len (true/false).
    """

    context "escaped special characters":
        it "unescapes a dot":
            expect unescape_regex("\\.") == "."

        it "unescapes a star":
            expect unescape_regex("\\*") == "*"

        it "unescapes parentheses":
            expect unescape_regex("\\(\\)") == "()"

        it "unescapes brackets":
            expect unescape_regex("\\[\\]") == "[]"

    context "normal characters pass through":
        it "returns plain text unchanged":
            expect unescape_regex("hello") == "hello"

        it "returns digits unchanged":
            expect unescape_regex("12345") == "12345"

    context "mixed content":
        it "unescapes only escaped chars in mixed string":
            expect unescape_regex("a\\.b") == "a.b"

        it "handles multiple escaped chars":
            expect unescape_regex("a\\+b\\*c") == "a+b*c"

    context "trailing backslash":
        it "preserves trailing backslash when no char follows":
            expect unescape_regex("abc\\") == "abc\\"

        it "handles lone backslash":
            expect unescape_regex("\\") == "\\"

    context "edge cases":
        it "returns empty string for empty input":
            expect unescape_regex("") == ""

        it "unescapes escaped backslash":
            expect unescape_regex("\\\\") == "\\"


# ============================================================================
# Test Group 13: expand_escape
# ============================================================================

describe "expand_escape":
    """
    ## expand_escape(esc: text) -> text

    Expands known escape sequence characters to their actual values.
    Branch coverage: each recognized escape, plus fallback for unknown.
    """

    context "literal escapes":
        it "expands 'n' to newline":
            expect expand_escape("n") == "\n"

        it "expands 't' to tab":
            expect expand_escape("t") == "\t"

        it "expands 'r' to carriage return":
            expect expand_escape("r") == "\r"

    context "character class escapes":
        it "expands 'd' to digit class":
            expect expand_escape("d") == "[0-9]"

        it "expands 'D' to non-digit class":
            expect expand_escape("D") == "[^0-9]"

        it "expands 'w' to word class":
            expect expand_escape("w") == "[a-zA-Z0-9_]"

        it "expands 'W' to non-word class":
            expect expand_escape("W") == "[^a-zA-Z0-9_]"

        it "expands 's' to whitespace class":
            expect expand_escape("s") == "[ \t\n\r]"

        it "expands 'S' to non-whitespace class":
            expect expand_escape("S") == "[^ \t\n\r]"

    context "boundary escapes":
        it "expands 'b' to word boundary":
            expect expand_escape("b") == "\\b"

        it "expands 'B' to non-word boundary":
            expect expand_escape("B") == "\\B"

    context "fallback - unrecognized escapes":
        it "returns 'x' unchanged":
            expect expand_escape("x") == "x"

        it "returns 'a' unchanged":
            expect expand_escape("a") == "a"

        it "returns '.' unchanged":
            expect expand_escape(".") == "."

        it "returns empty string unchanged":
            expect expand_escape("") == ""

        it "returns '1' unchanged":
            expect expand_escape("1") == "1"


