# @cover src/lib/common/parser/parser.spl 80%
# @cover src/lib/common/parser/ast.spl 80%
"""
# Export Star Specification

**Feature IDs:** #TODO-26
**Category:** Language
**Difficulty:** 2/5
**Status:** Implemented

## Overview

Tests that `export *` is parsed into `Stmt.ExportUseStmt("", ImportTarget.Glob)`,
and that `export foo, bar` still produces `Stmt.Export(["foo","bar"])`.
"""

use std.spipe.*
use std.parser.ast (Stmt, ImportTarget)
use std.parser.parser (parse_stmt)


# ============================================================================
# Export Star Parsing
# ============================================================================

describe "export * parsing":
    it "parses export star into ExportUseStmt with Glob target":
        val result = parse_stmt("export *")
        match result:
            case Ok(stmt):
                match stmt:
                    case Stmt.ExportUseStmt(path, target):
                        expect path == ""
                        match target:
                            case ImportTarget.Glob:
                                expect true == true
                            case _:
                                expect false == true
                    case _:
                        expect false == true
            case Err(e):
                expect false == true

    it "parses export name list into Stmt.Export":
        val result = parse_stmt("export foo, bar")
        match result:
            case Ok(stmt):
                match stmt:
                    case Stmt.Export(names):
                        expect names.len() == 2
                        expect names[0] == "foo"
                        expect names[1] == "bar"
                    case _:
                        expect false == true
            case Err(e):
                expect false == true

    it "parses export single name into Stmt.Export":
        val result = parse_stmt("export baz")
        match result:
            case Ok(stmt):
                match stmt:
                    case Stmt.Export(names):
                        expect names.len() == 1
                        expect names[0] == "baz"
                    case _:
                        expect false == true
            case Err(e):
                expect false == true