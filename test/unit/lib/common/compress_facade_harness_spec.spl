use std.spec.{describe, it, expect}
use std.common.compress.{
    CompressionCodec,
    CompressionError,
    CompressionOptions,
    default_compression_options,
    compress_bytes,
    decompress_bytes
}
use std.common.compress.lz4.{lz4_compress_frame_for_tier, lz4_decompress_frame_for_tier}
use std.common.compress.zstd.{zstd_compress_frame_for_tier, zstd_decompress_frame_for_tier}
use std.common.compress.lzma2.{lzma2_compress_xz_for_tier, lzma2_decompress_xz_for_tier}
use std.common.compress.utilities.{CompressionSimdTier}

fn _expect_error_kind(result: Result<[u8], CompressionError>, expected: text):
    match result:
        Ok(_): expect(false).to_equal(true)
        Err(err):
            match err:
                CompressionError.InvalidHeader(_): expect(expected).to_equal("InvalidHeader")
                CompressionError.UnsupportedFeature(_): expect(expected).to_equal("UnsupportedFeature")
                CompressionError.TruncatedInput(_): expect(expected).to_equal("TruncatedInput")
                CompressionError.ChecksumMismatch(_): expect(expected).to_equal("ChecksumMismatch")
                CompressionError.CorruptStream(_): expect(expected).to_equal("CorruptStream")
                CompressionError.SizeLimitExceeded(_): expect(expected).to_equal("SizeLimitExceeded")

fn _fixture_empty() -> [u8]:
    []

fn _fixture_short() -> [u8]:
    [0x41u8]

fn _fixture_mixed() -> [u8]:
    "literal-run-mixed-literal-run".bytes()

fn _fixture_repetitive(count: i64) -> [u8]:
    val seed = "abcabcabcXYZXYZ".bytes()
    var out: [u8] = []
    var i = 0
    while i < count:
        out.push(seed[i % seed.len()])
        i = i + 1
    out

fn _fixture_incompressible(count: i64) -> [u8]:
    var out: [u8] = []
    var i = 0
    while i < count:
        out.push((((i * 73) + (i / 11) + 19) % 251).to_u8())
        i = i + 1
    out

fn _fixture_overlap_heavy(count: i64) -> [u8]:
    var out: [u8] = []
    var i = 0
    while i < count:
        if (i % 19) < 12:
            out.push(0x41u8 + (i % 4).to_u8())
        else:
            out.push(0x30u8 + (i % 10).to_u8())
        i = i + 1
    out

fn _assert_auto_round_trip(codec: CompressionCodec, payload: [u8]):
    val options = default_compression_options(codec)
    val encoded = compress_bytes(payload, options)
    val decoded = decompress_bytes(encoded, nil)
    expect(decoded.is_err()).to_equal(false)
    expect(decoded.unwrap()).to_equal(payload)

fn _assert_lz4_block_round_trip(payload: [u8]):
    val base = default_compression_options(CompressionCodec.lz4)
    val options = CompressionOptions(
        codec: base.codec,
        level: base.level,
        checksum: false,
        block_mode: "block",
        dictionary_bytes: base.dictionary_bytes,
        dictionary_id: base.dictionary_id,
        content_size: nil
    )
    val encoded = compress_bytes(payload, options)
    _expect_error_kind(decompress_bytes(encoded, nil), "InvalidHeader")
    val decoded = decompress_bytes(encoded, Some(CompressionCodec.lz4))
    expect(decoded.is_err()).to_equal(false)
    expect(decoded.unwrap()).to_equal(payload)

fn _assert_forced_tier_parity(codec: CompressionCodec, payload: [u8]):
    val options = default_compression_options(codec)
    val facade = compress_bytes(payload, options)
    if codec == CompressionCodec.lz4:
        val scalar = lz4_compress_frame_for_tier(payload, options, CompressionSimdTier.scalar)
        val avx2 = lz4_compress_frame_for_tier(payload, options, CompressionSimdTier.avx2)
        val neon = lz4_compress_frame_for_tier(payload, options, CompressionSimdTier.neon)
        expect(facade).to_equal(scalar)
        expect(avx2).to_equal(scalar)
        expect(neon).to_equal(scalar)
        expect(lz4_decompress_frame_for_tier(facade, CompressionSimdTier.scalar).unwrap()).to_equal(payload)
        expect(lz4_decompress_frame_for_tier(facade, CompressionSimdTier.avx2).unwrap()).to_equal(payload)
        expect(lz4_decompress_frame_for_tier(facade, CompressionSimdTier.neon).unwrap()).to_equal(payload)
    elif codec == CompressionCodec.zstd:
        val scalar = zstd_compress_frame_for_tier(payload, options, CompressionSimdTier.scalar)
        val avx2 = zstd_compress_frame_for_tier(payload, options, CompressionSimdTier.avx2)
        val neon = zstd_compress_frame_for_tier(payload, options, CompressionSimdTier.neon)
        expect(facade).to_equal(scalar)
        expect(avx2).to_equal(scalar)
        expect(neon).to_equal(scalar)
        expect(zstd_decompress_frame_for_tier(facade, CompressionSimdTier.scalar).unwrap()).to_equal(payload)
        expect(zstd_decompress_frame_for_tier(facade, CompressionSimdTier.avx2).unwrap()).to_equal(payload)
        expect(zstd_decompress_frame_for_tier(facade, CompressionSimdTier.neon).unwrap()).to_equal(payload)
    else:
        val scalar = lzma2_compress_xz_for_tier(payload, options, CompressionSimdTier.scalar)
        val avx2 = lzma2_compress_xz_for_tier(payload, options, CompressionSimdTier.avx2)
        val neon = lzma2_compress_xz_for_tier(payload, options, CompressionSimdTier.neon)
        expect(facade).to_equal(scalar)
        expect(avx2).to_equal(scalar)
        expect(neon).to_equal(scalar)
        expect(lzma2_decompress_xz_for_tier(facade, CompressionSimdTier.scalar).unwrap()).to_equal(payload)
        expect(lzma2_decompress_xz_for_tier(facade, CompressionSimdTier.avx2).unwrap()).to_equal(payload)
        expect(lzma2_decompress_xz_for_tier(facade, CompressionSimdTier.neon).unwrap()).to_equal(payload)

describe "common compression facade harness":
    it "round-trips deterministic framed fixtures across every public codec":
        val payloads = [
            _fixture_empty(),
            _fixture_short(),
            _fixture_mixed(),
            _fixture_repetitive(256),
            _fixture_incompressible(1024),
            _fixture_overlap_heavy(4096)
        ]
        for payload in payloads:
            _assert_auto_round_trip(CompressionCodec.lz4, payload)
            _assert_auto_round_trip(CompressionCodec.zstd, payload)
            _assert_auto_round_trip(CompressionCodec.lzma2, payload)

    it "requires an explicit lz4 block hint for deterministic raw-block fixtures":
        _assert_lz4_block_round_trip(_fixture_short())
        _assert_lz4_block_round_trip(_fixture_repetitive(128))
        _assert_lz4_block_round_trip(_fixture_overlap_heavy(2048))

    it "keeps the public facade byte-identical with forced scalar avx2 and neon tiers":
        val payload = _fixture_overlap_heavy(8192) + _fixture_incompressible(1024)
        _assert_forced_tier_parity(CompressionCodec.lz4, payload)
        _assert_forced_tier_parity(CompressionCodec.zstd, payload)
        _assert_forced_tier_parity(CompressionCodec.lzma2, payload)

    it "returns typed invalid-header and truncation failures through the public facade":
        val payload = _fixture_repetitive(512)

        val lz4 = compress_bytes(payload, default_compression_options(CompressionCodec.lz4))
        val zstd = compress_bytes(payload, default_compression_options(CompressionCodec.zstd))
        val xz = compress_bytes(payload, default_compression_options(CompressionCodec.lzma2))

        var bad_lz4 = lz4
        bad_lz4[0] = bad_lz4[0] ^ 0x01u8
        _expect_error_kind(decompress_bytes(bad_lz4, nil), "InvalidHeader")

        var bad_zstd = zstd
        bad_zstd[0] = bad_zstd[0] ^ 0x01u8
        _expect_error_kind(decompress_bytes(bad_zstd, nil), "InvalidHeader")

        var bad_xz = xz
        bad_xz[0] = bad_xz[0] ^ 0x01u8
        _expect_error_kind(decompress_bytes(bad_xz, nil), "InvalidHeader")

        _expect_error_kind(decompress_bytes(lz4.slice(0, lz4.len() - 1), nil), "TruncatedInput")
        _expect_error_kind(decompress_bytes(zstd.slice(0, zstd.len() - 1), nil), "TruncatedInput")
        _expect_error_kind(decompress_bytes(xz.slice(0, xz.len() - 1), nil), "TruncatedInput")
