    ## Extended Compression Marker Coverage
    """

    it "marks and detects long content":
        val marked = mark_compressed("a long piece of content here")
        expect is_compressed(marked) == true

    it "returns false for encrypted marker":
        val encrypted = mark_encrypted("secret")
        expect is_compressed(encrypted) == false

describe "Encryption Markers extended":
    """
    ## Extended Encryption Marker Coverage
    """

    it "marks and detects long content":
        val marked = mark_encrypted("a long piece of content here")
        expect is_encrypted(marked) == true

    it "returns false for compressed marker":
        val compressed = mark_compressed("stuff")
        expect is_encrypted(compressed) == false