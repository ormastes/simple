        expect is_valid_sdn("42") == true

    it "returns true for quoted text":
        expect is_valid_sdn("\"hello\"") == true

    it "returns false for single char":
        expect is_valid_sdn("x") == false

describe "get_type_tag extended":
    """
    ## Extended Type Tag Extraction

    Exercise the while loop scanning with various tag lengths.
    """

    it "extracts single char tag":
        val result = get_type_tag("@X\{v\}")
        expect result == "X"

    it "extracts long tag name":
        val result = get_type_tag("@VeryLongTypeName\{v\}")
        expect result == "VeryLongTypeName"

    it "returns nil for at-sign only":
        val result = get_type_tag("@ab")
        expect result == nil

describe "strip_type_tag extended":
    """
    ## Extended Type Tag Stripping
    """

    it "strips single char tag":
        val result = strip_type_tag("@X\{hello\}")
        expect result == "hello"

    it "strips tag with empty content":
        val result = strip_type_tag("@T\{\}")
        expect result == ""

describe "get_version extended":
    """
    ## Extended Version Extraction Coverage
    """

    it "extracts single digit version":
        val versioned = add_version("x", 1)
        val result = get_version(versioned)
        expect result == 1

    it "extracts multi-digit version":
        val versioned = add_version("x", 99)
        val result = get_version(versioned)
        expect result == 99

describe "strip_version extended":
    """
    ## Extended Version Stripping Coverage
    """

    it "strips version with complex data":
        val versioned = add_version("[1, 2, 3]", 10)
        val result = strip_version(versioned)
        expect result == "[1, 2, 3]"

    it "strips version with text data":
        val versioned = add_version("\"hello\"", 2)
        val result = strip_version(versioned)
        expect result == "\"hello\""

