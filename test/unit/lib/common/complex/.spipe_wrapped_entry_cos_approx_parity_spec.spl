#![allow(spipe_empty_examples)]
#![allow(spipe_boolean_wrapper_assertions)]
@allow(spipe_empty_examples)
@allow(spipe_boolean_wrapper_assertions)
use std.common.complex.utilities.{cos_approx, sin_approx, cosh_approx, sinh_approx}

val PI = 3.141592653589793

fn main():
    # Cosine Approximation Parity Specification
    #
    # Verifies that the canonical cos_approx (and sibling trig/exp helpers) in
    # utilities.spl is reachable from the sibling files (trigonometric, types,
    # exponential, arithmetic) via cross-module `use` imports — replacing the
    # 18 stub fns that previously returned constants.


    describe "cos_approx canonical impl":
        # Pre-refactor: every stub returned 1.0; only utilities had the Taylor
        # series. After refactor, sibling files import the real impl via `use`.
        context "Taylor-series correctness":
            it "cos(0) = 1.0":
                val r = cos_approx(0.0)
                expect r == 1.0

            it "cos(PI) is approximately -1.0":
                val r = cos_approx(PI)
                val diff = r - (0.0 - 1.0)
                val abs_diff = if diff < 0.0: 0.0 - diff else: diff
                expect abs_diff < 0.000001

            it "cos(PI/2) is approximately 0.0":
                val r = cos_approx(PI / 2.0)
                val abs_r = if r < 0.0: 0.0 - r else: r
                expect abs_r < 0.000001

    describe "sin_approx canonical impl":
        context "Taylor-series correctness":
            it "sin(0) = 0.0":
                val r = sin_approx(0.0)
                expect r == 0.0

            it "sin(PI/2) is approximately 1.0":
                val r = sin_approx(PI / 2.0)
                val diff = r - 1.0
                val abs_diff = if diff < 0.0: 0.0 - diff else: diff
                expect abs_diff < 0.000001

    describe "Identity sin^2 + cos^2 = 1 (former-stub call sites are now real)":
        # If the sibling files still had the constant stubs, the cos and sin
        # results would not satisfy the Pythagorean identity. This is the
        # strongest check that the use-import refactor is wired correctly.
        context "Pythagorean identity":
            it "holds at PI/4":
                val s = sin_approx(PI / 4.0)
                val c = cos_approx(PI / 4.0)
                val sum = s * s + c * c
                val abs_diff = if sum > 1.0: sum - 1.0 else: 1.0 - sum
                expect abs_diff < 0.000001

            it "holds at PI/3":
                val s = sin_approx(PI / 3.0)
                val c = cos_approx(PI / 3.0)
                val sum = s * s + c * c
                val abs_diff = if sum > 1.0: sum - 1.0 else: 1.0 - sum
                expect abs_diff < 0.000001