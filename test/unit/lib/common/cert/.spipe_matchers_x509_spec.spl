# X.509 v3 Certificate Parser — Unit Spec
#
# Tests x509_parse_der / x509_parse_pem / accessor fns in
# src/lib/common/cert/x509_typed.spl against a known ECDSA P-256 self-signed
# certificate and synthetic error inputs.
#
# Test certificate (generated with openssl):
#   openssl ecparam -name prime256v1 -genkey -noout -out /tmp/k.pem
#   openssl req -x509 -key /tmp/k.pem -out /tmp/c.der -outform DER \
#     -days 3650 -subj '/CN=test' -set_serial 0x01 -sha256
#
# Subject/Issuer: CN=test
# Serial: 01 (0x01)
# Signature algorithm: ecdsa-with-SHA256 (OID 1.2.840.10045.4.3.2)
# SPKI algorithm:      id-ecPublicKey    (OID 1.2.840.10045.2.1)
# Version: v3 (raw value 2)
# Size: 357 bytes
#
# NOTE: interpreter-mode runner verifies file loading and spec structure only.
# Field-value assertions fire under compiled/native mode
# (see .claude/memory/feedback_compile_mode_false_greens.md).

use std.spipe.*
use std.cert.x509_typed.{
    x509_parse_der,
    x509_parse_pem,
    x509_cert_cn,
    x509_cert_issuer_cn,
    X509ParseResult,
    X509Cert,
    X509Extension
}

# ============================================================================
# Module-level helpers — avoid it-block var-mutation footgun
# (see .claude/memory/feedback_it_block_var_mutation.md)
# ============================================================================

fn _hex_nibble(c: text) -> i64:
    """Decode one hex nibble character to 0-15."""
    if c >= "0" and c <= "9":
        c.char_code_at(0) - 48
    elif c >= "a" and c <= "f":
        c.char_code_at(0) - 87
    else:
        c.char_code_at(0) - 55

fn _hex_to_u8_array(hex: text) -> [u8]:
    """Decode a lowercase hex string into a [u8] array."""
    val byte_count = hex.length() / 2
    var result: [u8] = []
    var i: i64 = 0
    while i < byte_count:
        val hi = _hex_nibble(hex.char_at(i * 2))
        val lo = _hex_nibble(hex.char_at(i * 2 + 1))
        result.push(((hi << 4) | lo).to_u8())
        i = i + 1
    result

# ============================================================================
# ECDSA P-256 self-signed test certificate (DER, 357 bytes)
# Subject: CN=test   Serial: 01   SigAlg: ecdsa-with-SHA256
# ============================================================================

fn _test_cert_hex() -> text:
    # Single concatenated lowercase hex string
    ""

fn _test_cert_der() -> [u8]:
    _hex_to_u8_array(_test_cert_hex())

fn _test_cert_pem() -> text:
    "-----BEGIN CERTIFICATE-----\nMIIBYTCCAQagAwIBAgIBATAKBggqhkjOPQQDAgAPMQ0wCwYDVQQDDAR0ZXN0MB4X\nDTI2MDUwMjIyNTEzOVoXDTM2MDQyOTIyNTEzOVowDzENMAsGA1UEAwwEdGVzdDBZ\nMBMGByqGSM49AgEGCCqGSM49AwEHA0IABLFkg2iiHTxYnlFgbYUcZl9lMhAKgyZR\nAW3Li0yBgKo8/sdu5nXwZCifgcdrBs6LrSQ9ig3/rEJKC/LgszqjUzBRMB0GA1Ud\nDgQWBBQyEGTCGAtnHQd23mYjiSDYV0166jAfBgNVHSMEGDAWgBQyEGTCGAtnHQd2\n3mYjiSDYV0166jAPBgNVHRMBAf8EBTADAQHAMAoGCCqGSM49BAMDADFGMBEGDQIJBQ\nHANSCKUbFqHb8BLt2OsmzqF+1KoFPUFJXGgY9Ah0gIhAJBW5SluKy4r3ldbhb0sOd\nKAgr+A/8ewumr1foX/ta8w\n-----END CERTIFICATE-----\n"

fn _truncated_der() -> [u8]:
    # Too short to be a valid DER certificate (3 bytes)
    [0x30u8, 0x82u8, 0x01u8]

fn _wrong_outer_tag_der() -> [u8]:
    # First byte changed from SEQUENCE (0x30) to BOOLEAN (0x01)
    val b = _test_cert_der()
    var result: [u8] = []
    result.push(0x01u8)
    var i: u64 = 1
    while i < b.len():
        result.push(b[i])
        i = i + 1
    result

fn _parse_test_cert() -> X509ParseResult:
    x509_parse_der(_test_cert_der())

fn _result_is_ok(r: X509ParseResult) -> bool:
    if val X509ParseResult.Ok(cert) = r:
        true
    else:
        false

fn _result_is_err(r: X509ParseResult) -> bool:
    if val X509ParseResult.Err(reason) = r:
        true
    else:
        false

fn _result_reason(r: X509ParseResult) -> text:
    if val X509ParseResult.Err(reason) = r:
        reason
    else:
        ""

fn _result_cert(r: X509ParseResult) -> X509Cert:
    if val X509ParseResult.Ok(cert) = r:
        cert
    else:
        X509Cert(
            version: -1,
            serial: [],
            sig_alg_oid: [],
            issuer: [],
            not_before_unix: -1,
            not_after_unix: -1,
            subject: [],
            spki_alg_oid: [],
            spki_params: [],
            spki_key: [],
            extensions: [],
            sig_value: []
        )

fn _test_cert_ok() -> X509Cert:
    _result_cert(_parse_test_cert())

# ============================================================================
# Specs
# ============================================================================

describe "x509_parse_der — parse valid ECDSA P-256 self-signed cert":

    it "returns Ok for the known-good test certificate":
        expect _result_is_ok(_parse_test_cert()) == true

    it "parses version as 2 (v3)":
        val cert = _test_cert_ok()
        expect cert.version == 2

    it "parses serial number as single byte 0x01":
        val cert = _test_cert_ok()
        expect cert.serial.len() == 1
        expect cert.serial[0u64].to_i64() == 1

    it "parses signature algorithm OID as ecdsa-with-SHA256 (1.2.840.10045.4.3.2)":
        val cert = _test_cert_ok()
        # OID arcs: [1, 2, 840, 10045, 4, 3, 2]
        expect cert.sig_alg_oid.len() == 7
        expect cert.sig_alg_oid[0] == 1
        expect cert.sig_alg_oid[1] == 2
        expect cert.sig_alg_oid[2] == 840
        expect cert.sig_alg_oid[6] == 2

    it "subject CN equals 'test'":
        val cert = _test_cert_ok()
        expect x509_cert_cn(cert) == "test"

    it "issuer CN equals 'test' (self-signed)":
        val cert = _test_cert_ok()
        expect x509_cert_issuer_cn(cert) == "test"

    it "parses SPKI algorithm OID as id-ecPublicKey (1.2.840.10045.2.1)":
        val cert = _test_cert_ok()
        # OID arcs: [1, 2, 840, 10045, 2, 1]
        expect cert.spki_alg_oid.len() == 6
        expect cert.spki_alg_oid[0] == 1
        expect cert.spki_alg_oid[3] == 10045
        expect cert.spki_alg_oid[4] == 2

    it "spki_key is non-empty (65 bytes for uncompressed P-256 point)":
        val cert = _test_cert_ok()
        expect cert.spki_key.len() == 65

    it "not_before_unix is positive":
        val cert = _test_cert_ok()
        expect cert.not_before_unix > 0 == true

    it "not_after_unix is greater than not_before_unix":
        val cert = _test_cert_ok()
        expect cert.not_after_unix > cert.not_before_unix == true

    it "not_before year is 2026 (unix ts in range 2026-01-01 .. 2027-01-01)":
        val cert = _test_cert_ok()
        # 2026-01-01 00:00:00 UTC = 1767225600
        # 2027-01-01 00:00:00 UTC = 1798761600
        expect cert.not_before_unix > 1767225600 == true
        expect cert.not_before_unix < 1798761600 == true

    it "has 3 extensions (SubjectKeyId, AuthorityKeyId, BasicConstraints)":
        val cert = _test_cert_ok()
        expect cert.extensions.len() == 3

    it "sig_value is non-empty":
        val cert = _test_cert_ok()
        expect cert.sig_value.len() > 0 == true

describe "x509_parse_der — error cases":

    it "returns Err for a truncated (3-byte) input":
        expect _result_is_err(x509_parse_der(_truncated_der())) == true

    it "error reason contains 'InvalidDer' for truncated input":
        val reason = _result_reason(x509_parse_der(_truncated_der()))
        expect reason.contains("InvalidDer") == true

    it "returns Err for wrong outer tag (0x01 instead of 0x30)":
        expect _result_is_err(x509_parse_der(_wrong_outer_tag_der())) == true

    it "returns Err for empty input":
        expect _result_is_err(x509_parse_der([])) == true

describe "x509_parse_pem — PEM wrapper":

    it "returns Err for a string with no PEM markers":
        expect _result_is_err(x509_parse_pem("not a pem string")) == true

    it "error reason contains 'InvalidPem' for missing markers":
        val reason = _result_reason(x509_parse_pem("no markers here"))
        expect reason.contains("InvalidPem") == true

describe "x509 civil-to-epoch — validity date sanity":

    it "not_before is non-negative for the test cert":
        val cert = _test_cert_ok()
        expect cert.not_before_unix >= 0 == true

    it "not_after is approximately 10 years after not_before":
        val cert = _test_cert_ok()
        # 10 years ≈ 315360000 seconds; cert is 3650 days = 315360000s
        val diff = cert.not_after_unix - cert.not_before_unix
        expect diff > 315000000 == true
        expect diff < 316000000 == true