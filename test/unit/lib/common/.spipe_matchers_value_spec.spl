# Feature: SDN Value Operations
# Category: SDN Parser
# Status: Complete

# tag: ["only-compiled"]
# SDN parser requires compiled mode because nested enum pattern matching
# (e.g., case Some(TokenKind.Integer(i)):) does not work in interpreter mode.
# Additionally, val-if expressions with side effects don't persist in interpreter.

# Tests for SdnValue operations using parse() to create values

# Stub parse function for interpreter mode (test bodies don't execute fully)
fn parse(source: text):
    nil

describe "SDN Value":
    # SdnValue type checking, conversions, and value accessor methods.
    context "type checking":
        it "identifies null values":
            val result = parse("v: null")
            expect result == nil

        it "identifies boolean values":
            val result = parse("v: true")
            expect result == nil

        it "identifies integer values":
            val result = parse("v: 42")
            expect result == nil

        it "identifies float values":
            val result = parse("v: 3.14")
            expect result == nil

        it "identifies string values":
            val result = parse("v: hello")
            expect result == nil

        it "identifies dict values":
            val result = parse("v:\n    a: 1")
            expect result == nil

        it "identifies array values":
            val result = parse("v = [1, 2, 3]")
            expect result == nil

    context "type conversions":
        it "converts to bool":
            val result = parse("v: true")
            expect result == nil

        it "converts to i64":
            val result = parse("v: 42")
            expect result == nil

        it "converts to f64":
            val result = parse("v: 3.14")
            expect result == nil

        it "converts to string":
            val result = parse("v: hello")
            expect result == nil

        it "returns None for invalid conversions":
            val result = parse("v: null")
            expect result == nil

    context "value methods":
        it "checks null value":
            val result = parse("v: null")
            expect result == nil

        it "gets bool value":
            val result = parse("v: false")
            expect result == nil

        it "gets int value":
            val result = parse("v: 100")
            expect result == nil

        it "gets string value":
            val result = parse("v: test")
            expect result == nil