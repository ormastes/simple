# @cover src/lib/common/ui/glass_css.spl 80%
# @cover src/lib/common/ui/glass_tokens.spl 40%
"""
# Glass CSS Output Specification

**Feature IDs:** #GUI-THEME-SHARING
**Category:** Stdlib
**Difficulty:** 2/5
**Status:** Draft
**Requirements:** N/A
**Plan:** N/A
**Design:** doc/05_design/stitch_design_system.md

## Overview

AC-2: Theme system supports HTML+CSS output (Electron-like) from glass
design tokens.

Verifies that:
- glass_tokens_to_css() emits all existing custom properties
- glass_tokens_to_css() emits new MD3 surface container custom properties
- glass_tokens_to_css() emits --glass-on-surface-variant
- generate_glass_css() produces a complete CSS string with :root block
- generate_glass_css() returns empty string for unknown themes
- Component CSS classes are present (widget-panel, glass-window, etc.)

## Key Concepts

| Concept | Description |
|---------|-------------|
| glass_tokens_to_css | Emits CSS custom properties from GlassDesignTokens |
| generate_glass_css | Full CSS entry point: :root vars + component styles |
| MD3 containers | --glass-surface-container-lowest through --glass-surface-container-highest |
"""

use std.spipe.*
use common.ui.glass.tokens.{GlassDesignTokens}
use common.ui.glass_css.{glass_tokens_to_css, generate_glass_css}

# ============================================================================
# AC-2: Existing CSS custom properties still emitted
# ============================================================================

describe "glass_tokens_to_css existing properties":
    """
    ## Existing CSS Custom Properties

    Backward compatibility: all previously emitted custom properties
    must still appear in the output.
    """

    it "emits --glass-surface-primary":
        val tokens = GlassDesignTokens.dark()
        val css = glass_tokens_to_css(tokens)
        expect (css).contains("--glass-surface-primary:")

    it "emits --glass-text-primary":
        val tokens = GlassDesignTokens.dark()
        val css = glass_tokens_to_css(tokens)
        expect (css).contains("--glass-text-primary:")

    it "emits --glass-accent":
        val tokens = GlassDesignTokens.dark()
        val css = glass_tokens_to_css(tokens)
        expect (css).contains("--glass-accent:")

    it "emits --glass-error":
        val tokens = GlassDesignTokens.dark()
        val css = glass_tokens_to_css(tokens)
        expect (css).contains("--glass-error:")

    it "emits --glass-blur-surface":
        val tokens = GlassDesignTokens.dark()
        val css = glass_tokens_to_css(tokens)
        expect (css).contains("--glass-blur-surface:")

    it "emits --glass-radius-md":
        val tokens = GlassDesignTokens.dark()
        val css = glass_tokens_to_css(tokens)
        expect (css).contains("--glass-radius-md:")

    it "emits --glass-shadow-md":
        val tokens = GlassDesignTokens.dark()
        val css = glass_tokens_to_css(tokens)
        expect (css).contains("--glass-shadow-md:")

    it "emits --glass-spacing-md":
        val tokens = GlassDesignTokens.dark()
        val css = glass_tokens_to_css(tokens)
        expect (css).contains("--glass-spacing-md:")

    it "emits --glass-duration-fast":
        val tokens = GlassDesignTokens.dark()
        val css = glass_tokens_to_css(tokens)
        expect (css).contains("--glass-duration-fast:")

# ============================================================================
# AC-2: New MD3 surface container CSS custom properties
# ============================================================================

describe "glass_tokens_to_css MD3 container properties":
    """
    ## MD3 Surface Container CSS Variables

    After the change, glass_tokens_to_css must emit 5 new MD3 surface
    container custom properties and the on_surface_variant property.
    """

    it "emits --glass-surface-container-lowest":
        val tokens = GlassDesignTokens.dark()
        val css = glass_tokens_to_css(tokens)
        expect (css).contains("--glass-surface-container-lowest:")

    it "emits --glass-surface-container-low":
        val tokens = GlassDesignTokens.dark()
        val css = glass_tokens_to_css(tokens)
        expect (css).contains("--glass-surface-container-low:")

    it "emits --glass-surface-container:":
        val tokens = GlassDesignTokens.dark()
        val css = glass_tokens_to_css(tokens)
        expect (css).contains("--glass-surface-container:")

    it "emits --glass-surface-container-high":
        val tokens = GlassDesignTokens.dark()
        val css = glass_tokens_to_css(tokens)
        expect (css).contains("--glass-surface-container-high:")

    it "emits --glass-surface-container-highest":
        val tokens = GlassDesignTokens.dark()
        val css = glass_tokens_to_css(tokens)
        expect (css).contains("--glass-surface-container-highest:")

    it "emits --glass-on-surface-variant":
        val tokens = GlassDesignTokens.dark()
        val css = glass_tokens_to_css(tokens)
        expect (css).contains("--glass-on-surface-variant:")

# ============================================================================
# AC-2: Obsidian theme CSS output contains correct values
# ============================================================================

describe "glass_tokens_to_css Obsidian theme values":
    """
    ## Obsidian CSS Values

    When given Obsidian design tokens, the CSS output must contain
    the correct Obsidian-specific color values.
    """

    it "contains Obsidian text color #E3E0F3":
        val tokens = GlassDesignTokens.obsidian_dark()
        val css = glass_tokens_to_css(tokens)
        expect (css).contains("#E3E0F3")

    it "contains Obsidian accent color #C6C6C8":
        val tokens = GlassDesignTokens.obsidian_dark()
        val css = glass_tokens_to_css(tokens)
        expect (css).contains("#C6C6C8")

    it "contains Obsidian surface rgba with 18,18,31":
        val tokens = GlassDesignTokens.obsidian_dark()
        val css = glass_tokens_to_css(tokens)
        expect (css).contains("18,18,31")

# ============================================================================
# AC-2: generate_glass_css full output
# ============================================================================

describe "generate_glass_css full output":
    """
    ## Full CSS Generation

    generate_glass_css(theme_name) combines :root vars + component styles.
    """

    it "wraps tokens in :root block for glass_dark":
        val css = generate_glass_css("glass_dark")
        expect (css).contains(":root")

    it "includes component CSS for glass_dark":
        val css = generate_glass_css("glass_dark")
        expect (css).contains(".widget-panel")

    it "includes glass-window CSS":
        val css = generate_glass_css("glass_dark")
        expect (css).contains(".glass-window")

    it "includes glass-dock CSS":
        val css = generate_glass_css("glass_dark")
        expect (css).contains(".glass-dock")

    it "includes glass-titlebar CSS":
        val css = generate_glass_css("glass_dark")
        expect (css).contains(".glass-titlebar")

    it "includes glass-systembar CSS":
        val css = generate_glass_css("glass_dark")
        expect (css).contains(".glass-systembar")

    it "returns empty for unknown theme":
        val css = generate_glass_css("nonexistent_theme")
        expect css == ""

    it "produces non-empty output for glass_light":
        val css = generate_glass_css("glass_light")
        expect (css).contains(":root")

    it "produces non-empty output for glass_obsidian_dark":
        val css = generate_glass_css("glass_obsidian_dark")
        expect (css).contains(":root")

    it "obsidian CSS contains MD3 container variables":
        val css = generate_glass_css("glass_obsidian_dark")
        expect (css).contains("--glass-surface-container-lowest")

    it "obsidian CSS contains backdrop-filter":
        val css = generate_glass_css("glass_obsidian_dark")
        expect (css).contains("backdrop-filter")