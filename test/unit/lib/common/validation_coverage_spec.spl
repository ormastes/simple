# @covers src/lib/common/validation.spl 80%
# @covers src/lib/common/result_helpers.spl 80%
#![allow(unnamed_duplicate_typed_args)]
"""
# Validation & Result Helpers Coverage Specification

**Feature IDs:** #LIB-VALIDATION-COV
**Category:** Stdlib
**Difficulty:** 2/5
**Status:** Implemented
**Requirements:** N/A
**Plan:** N/A
**Design:** N/A
**Research:** N/A

## Overview

Comprehensive branch-coverage tests for `src/lib/common/validation.spl` and
`src/lib/common/result_helpers.spl`. Every exported function is exercised on
both its true and false (or Ok/Err) branches, targeting 90%+ condition coverage.

## Key Concepts

| Concept | Description |
|---------|-------------|
| Branch coverage | Each boolean branch taken at least once |
| Result pattern | Ok = [value, nil], Err = [nil, error] |

## Related Specifications

- [Result Spec](result_spec.spl) - Existing result tests
- [Option Spec](option_spec.spl) - Existing option tests
"""

use std.common.validation.{
    is_valid_identifier, is_numeric, is_alphanumeric, is_hex_string,
    is_email_like, is_positive_i64, is_positive_f64,
    is_non_negative_i64, is_non_negative_f64,
    is_positive, is_negative, is_non_negative, is_zero,
    clamp, clamp_i64, clamp_f64,
    validate_length, validate_min_length, validate_max_length,
    validate_array_length, is_empty_array, is_non_empty_array,
    is_empty, is_not_empty,
    is_in_range, is_outside_range, is_divisible, is_multiple_of,
    contains_only_letters, contains_only_digits, contains_whitespace,
    starts_with_letter,
    is_valid_version, is_valid_path_component,
    require, require_all
}

# Result tests use built-in Result<T, E> enum (Ok/Err constructors and methods)


# ============================================================================
# Test Group 1: String Pattern Validation
# ============================================================================

describe "validation - is_valid_identifier":
    context "when valid":
        it "accepts lowercase letter start":
            expect(is_valid_identifier("abc")).to_equal(true)

        it "accepts underscore start":
            expect(is_valid_identifier("_foo")).to_equal(true)

        it "accepts uppercase start":
            expect(is_valid_identifier("Abc")).to_equal(true)

        it "accepts letters digits underscores":
            expect(is_valid_identifier("my_var2")).to_equal(true)

        it "accepts single letter":
            expect(is_valid_identifier("x")).to_equal(true)

    context "when invalid":
        it "rejects empty string":
            expect(is_valid_identifier("")).to_equal(false)

        it "rejects digit start":
            expect(is_valid_identifier("1abc")).to_equal(false)

        it "rejects hyphen in body":
            expect(is_valid_identifier("a-b")).to_equal(false)

        it "rejects space in body":
            expect(is_valid_identifier("a b")).to_equal(false)

        it "rejects special char start":
            expect(is_valid_identifier("@foo")).to_equal(false)


describe "validation - is_numeric":
    context "when valid":
        it "accepts all digits":
            expect(is_numeric("12345")).to_equal(true)

        it "accepts single digit":
            expect(is_numeric("0")).to_equal(true)

    context "when invalid":
        it "rejects empty string":
            expect(is_numeric("")).to_equal(false)

        it "rejects letters":
            expect(is_numeric("12a3")).to_equal(false)

        it "rejects special chars":
            expect(is_numeric("12.3")).to_equal(false)


describe "validation - is_alphanumeric":
    context "when valid":
        it "accepts letters and digits":
            expect(is_alphanumeric("abc123")).to_equal(true)

        it "accepts only letters":
            expect(is_alphanumeric("abc")).to_equal(true)

        it "accepts only digits":
            expect(is_alphanumeric("123")).to_equal(true)

    context "when invalid":
        it "rejects empty string":
            expect(is_alphanumeric("")).to_equal(false)

        it "rejects underscores":
            expect(is_alphanumeric("abc_123")).to_equal(false)

        it "rejects spaces":
            expect(is_alphanumeric("abc 123")).to_equal(false)


describe "validation - is_hex_string":
    context "when valid":
        it "accepts lowercase hex":
            expect(is_hex_string("0123456789abcdef")).to_equal(true)

        it "accepts uppercase hex":
            expect(is_hex_string("ABCDEF")).to_equal(true)

        it "accepts mixed case hex":
            expect(is_hex_string("aF09")).to_equal(true)

    context "when invalid":
        it "rejects empty string":
            expect(is_hex_string("")).to_equal(false)

        it "rejects non-hex letter":
            expect(is_hex_string("0g1")).to_equal(false)

        it "rejects spaces":
            expect(is_hex_string("ab cd")).to_equal(false)


describe "validation - is_email_like":
    context "when valid":
        it "accepts basic email":
            expect(is_email_like("user@example.com")).to_equal(true)

        it "accepts email with dot after at":
            expect(is_email_like("a@b.c")).to_equal(true)

    context "when invalid":
        it "rejects too short":
            expect(is_email_like("ab")).to_equal(false)

        it "rejects no at sign":
            expect(is_email_like("userexample.com")).to_equal(false)

        it "rejects at at start":
            expect(is_email_like("@example.com")).to_equal(false)

        it "rejects at at end":
            expect(is_email_like("user@")).to_equal(false)

        it "rejects multiple at signs":
            expect(is_email_like("user@@example.com")).to_equal(false)

        it "rejects no dot after at":
            expect(is_email_like("user@examplecom")).to_equal(false)

        it "rejects dot at very end only":
            expect(is_email_like("user@example.")).to_equal(false)


# ============================================================================
# Test Group 2: Numeric Validation
# ============================================================================

describe "validation - is_positive_i64":
    it "returns true for positive":
        expect(is_positive_i64(5)).to_equal(true)

    it "returns false for zero":
        expect(is_positive_i64(0)).to_equal(false)

    it "returns false for negative":
        expect(is_positive_i64(-3)).to_equal(false)


describe "validation - is_positive_f64":
    it "returns true for positive float":
        expect(is_positive_f64(0.5)).to_equal(true)

    it "returns false for zero float":
        expect(is_positive_f64(0.0)).to_equal(false)

    it "returns false for negative float":
        expect(is_positive_f64(-1.5)).to_equal(false)


describe "validation - is_non_negative_i64":
    it "returns true for positive":
        expect(is_non_negative_i64(1)).to_equal(true)

    it "returns true for zero":
        expect(is_non_negative_i64(0)).to_equal(true)

    it "returns false for negative":
        expect(is_non_negative_i64(-1)).to_equal(false)


describe "validation - is_non_negative_f64":
    it "returns true for positive float":
        expect(is_non_negative_f64(0.1)).to_equal(true)

    it "returns true for zero float":
        expect(is_non_negative_f64(0.0)).to_equal(true)

    it "returns false for negative float":
        expect(is_non_negative_f64(-0.1)).to_equal(false)


describe "validation - is_positive alias":
    it "returns true for positive":
        expect(is_positive(10)).to_equal(true)

    it "returns false for zero":
        expect(is_positive(0)).to_equal(false)

    it "returns false for negative":
        expect(is_positive(-10)).to_equal(false)


describe "validation - is_negative":
    it "returns true for negative":
        expect(is_negative(-5)).to_equal(true)

    it "returns false for zero":
        expect(is_negative(0)).to_equal(false)

    it "returns false for positive":
        expect(is_negative(5)).to_equal(false)


describe "validation - is_non_negative alias":
    it "returns true for zero":
        expect(is_non_negative(0)).to_equal(true)

    it "returns true for positive":
        expect(is_non_negative(5)).to_equal(true)

    it "returns false for negative":
        expect(is_non_negative(-5)).to_equal(false)


describe "validation - is_zero":
    it "returns true for zero":
        expect(is_zero(0)).to_equal(true)

    it "returns false for positive":
        expect(is_zero(5)).to_equal(false)

    it "returns false for negative":
        expect(is_zero(-5)).to_equal(false)


describe "validation - clamp_i64":
    it "returns value when in range":
        expect(clamp_i64(5, 0, 10)).to_equal(5)

    it "clamps to min when below":
        expect(clamp_i64(-5, 0, 10)).to_equal(0)

    it "clamps to max when above":
        expect(clamp_i64(15, 0, 10)).to_equal(10)

    it "returns min when equal to min":
        expect(clamp_i64(0, 0, 10)).to_equal(0)

    it "returns max when equal to max":
        expect(clamp_i64(10, 0, 10)).to_equal(10)


describe "validation - clamp alias":
    it "delegates to clamp_i64":
        expect(clamp(5, 0, 10)).to_equal(5)

    it "clamps below min":
        expect(clamp(-1, 0, 10)).to_equal(0)

    it "clamps above max":
        expect(clamp(20, 0, 10)).to_equal(10)


describe "validation - clamp_f64":
    it "returns value when in range":
        expect(clamp_f64(5.0, 0.0, 10.0)).to_equal(5.0)

    it "clamps to min when below":
        expect(clamp_f64(-1.0, 0.0, 10.0)).to_equal(0.0)

    it "clamps to max when above":
        expect(clamp_f64(15.0, 0.0, 10.0)).to_equal(10.0)


# ============================================================================
# Test Group 3: Length Validation
# ============================================================================

describe "validation - validate_length":
    it "returns true when length in range":
        expect(validate_length("hello", 1, 10)).to_equal(true)

    it "returns true at exact min":
        expect(validate_length("hi", 2, 10)).to_equal(true)

    it "returns true at exact max":
        expect(validate_length("hi", 1, 2)).to_equal(true)

    it "returns false when too short":
        expect(validate_length("", 1, 10)).to_equal(false)

    it "returns false when too long":
        expect(validate_length("hello world", 1, 5)).to_equal(false)


describe "validation - validate_min_length":
    it "returns true when meets min":
        expect(validate_min_length("hello", 3)).to_equal(true)

    it "returns true at exact min":
        expect(validate_min_length("hi", 2)).to_equal(true)

    it "returns false when too short":
        expect(validate_min_length("a", 5)).to_equal(false)


describe "validation - validate_max_length":
    it "returns true when within max":
        expect(validate_max_length("hi", 5)).to_equal(true)

    it "returns true at exact max":
        expect(validate_max_length("hello", 5)).to_equal(true)

    it "returns false when too long":
        expect(validate_max_length("hello world", 5)).to_equal(false)


# ============================================================================
# Test Group 4: Collection Validation
# ============================================================================

describe "validation - validate_array_length":
    it "returns true when in range":
        expect(validate_array_length([1, 2, 3], 1, 5)).to_equal(true)

    it "returns false when too short":
        expect(validate_array_length([], 1, 5)).to_equal(false)

    it "returns false when too long":
        expect(validate_array_length([1, 2, 3, 4, 5, 6], 1, 5)).to_equal(false)


describe "validation - is_empty_array":
    it "returns true for empty array":
        expect(is_empty_array([])).to_equal(true)

    it "returns false for non-empty array":
        expect(is_empty_array([1])).to_equal(false)


describe "validation - is_non_empty_array":
    it "returns true for non-empty array":
        expect(is_non_empty_array([1, 2])).to_equal(true)

    it "returns false for empty array":
        expect(is_non_empty_array([])).to_equal(false)


describe "validation - is_empty":
    it "returns true for empty string":
        expect(is_empty("")).to_equal(true)

    it "returns false for non-empty string":
        expect(is_empty("hello")).to_equal(false)


describe "validation - is_not_empty":
    it "returns true for non-empty string":
        expect(is_not_empty("hello")).to_equal(true)

    it "returns false for empty string":
        expect(is_not_empty("")).to_equal(false)


describe "validation - is_in_range":
    it "returns true when in range":
        expect(is_in_range(5, 0, 10)).to_equal(true)

    it "returns true at min boundary":
        expect(is_in_range(0, 0, 10)).to_equal(true)

    it "returns true at max boundary":
        expect(is_in_range(10, 0, 10)).to_equal(true)

    it "returns false below range":
        expect(is_in_range(-1, 0, 10)).to_equal(false)

    it "returns false above range":
        expect(is_in_range(11, 0, 10)).to_equal(false)


describe "validation - is_outside_range":
    it "returns true below range":
        expect(is_outside_range(-1, 0, 10)).to_equal(true)

    it "returns true above range":
        expect(is_outside_range(11, 0, 10)).to_equal(true)

    it "returns false when in range":
        expect(is_outside_range(5, 0, 10)).to_equal(false)

    it "returns false at min boundary":
        expect(is_outside_range(0, 0, 10)).to_equal(false)


describe "validation - is_divisible":
    it "returns true when evenly divisible":
        expect(is_divisible(10, 2)).to_equal(true)

    it "returns false when not divisible":
        expect(is_divisible(10, 3)).to_equal(false)

    it "returns false when divisor is zero":
        expect(is_divisible(10, 0)).to_equal(false)

    it "returns true for zero dividend":
        expect(is_divisible(0, 5)).to_equal(true)


describe "validation - is_multiple_of":
    it "returns true for multiple":
        expect(is_multiple_of(15, 3)).to_equal(true)

    it "returns false for non-multiple":
        expect(is_multiple_of(15, 4)).to_equal(false)

    it "returns false for zero factor":
        expect(is_multiple_of(15, 0)).to_equal(false)


# ============================================================================
# Test Group 5: String Content Validation
# ============================================================================

describe "validation - contains_only_letters":
    it "returns true for all letters":
        expect(contains_only_letters("abcXYZ")).to_equal(true)

    it "returns false for empty string":
        expect(contains_only_letters("")).to_equal(false)

    it "returns false when has digits":
        expect(contains_only_letters("abc123")).to_equal(false)

    it "returns false when has underscore":
        expect(contains_only_letters("abc_def")).to_equal(false)


describe "validation - contains_only_digits":
    it "returns true for all digits":
        expect(contains_only_digits("12345")).to_equal(true)

    it "returns false for empty":
        expect(contains_only_digits("")).to_equal(false)

    it "returns false when has letters":
        expect(contains_only_digits("12a")).to_equal(false)


describe "validation - contains_whitespace":
    it "returns true for space":
        expect(contains_whitespace("hello world")).to_equal(true)

    it "returns true for tab":
        expect(contains_whitespace("hello\tworld")).to_equal(true)

    it "returns false for no whitespace":
        expect(contains_whitespace("helloworld")).to_equal(false)

    it "returns false for empty string":
        expect(contains_whitespace("")).to_equal(false)


describe "validation - starts_with_letter":
    it "returns true for lowercase start":
        expect(starts_with_letter("abc")).to_equal(true)

    it "returns true for uppercase start":
        expect(starts_with_letter("Abc")).to_equal(true)

    it "returns false for digit start":
        expect(starts_with_letter("1abc")).to_equal(false)

    it "returns false for empty string":
        expect(starts_with_letter("")).to_equal(false)

    it "returns false for underscore start":
        expect(starts_with_letter("_abc")).to_equal(false)


# ============================================================================
# Test Group 6: Format Validation
# ============================================================================

describe "validation - is_valid_version":
    it "returns true for semver":
        expect(is_valid_version("1.2.3")).to_equal(true)

    it "returns true for two-part version":
        expect(is_valid_version("1.0")).to_equal(true)

    it "returns false for empty":
        expect(is_valid_version("")).to_equal(false)

    it "returns false for no dot":
        expect(is_valid_version("123")).to_equal(false)

    it "returns false for only dots":
        expect(is_valid_version("...")).to_equal(false)

    it "returns false for letters":
        expect(is_valid_version("1.2.a")).to_equal(false)


describe "validation - is_valid_path_component":
    it "returns true for valid name":
        expect(is_valid_path_component("myfile")).to_equal(true)

    it "returns false for empty":
        expect(is_valid_path_component("")).to_equal(false)

    it "returns false for dot start":
        expect(is_valid_path_component(".hidden")).to_equal(false)

    it "returns false for forward slash":
        expect(is_valid_path_component("path/to")).to_equal(false)

    it "returns false for backslash":
        expect(is_valid_path_component("path\\to")).to_equal(false)


# ============================================================================
# Test Group 7: Validation Result Helpers
# ============================================================================

describe "validation - require":
    it "returns nil when condition is true":
        val result = require(true, "error msg")
        expect(result == nil).to_equal(true)

    it "returns Some message when condition is false":
        val result = require(false, "must be valid")
        expect(result.unwrap()).to_equal("must be valid")


describe "validation - require_all":
    it "returns empty array when all conditions pass":
        val errors = require_all([(true, "err1"), (true, "err2")])
        expect(errors.len()).to_equal(0)

    it "collects messages for failed conditions":
        val errors = require_all([(false, "err1"), (true, "ok"), (false, "err3")])
        expect(errors.len()).to_equal(2)
        expect(errors[0]).to_equal("err1")
        expect(errors[1]).to_equal("err3")

    it "returns all messages when all fail":
        val errors = require_all([(false, "a"), (false, "b")])
        expect(errors.len()).to_equal(2)


# ============================================================================
# Test Group 8: Result Enum - Creation and Checks
# ============================================================================

describe "Result enum - Ok and Err":
    it "Ok creates result with value":
        val r = Ok(42)
        expect(r.is_ok()).to_equal(true)
        expect(r.unwrap()).to_equal(42)

    it "Err creates result with error":
        val r = Err("bad")
        expect(r.is_err()).to_equal(true)
        expect(r.unwrap_err()).to_equal("bad")


describe "Result enum - is_ok":
    it "returns true for Ok":
        expect(Ok(42).is_ok()).to_equal(true)

    it "returns false for Err":
        expect(Err("e").is_ok()).to_equal(false)


describe "Result enum - is_err":
    it "returns true for Err":
        expect(Err("e").is_err()).to_equal(true)

    it "returns false for Ok":
        expect(Ok(42).is_err()).to_equal(false)


# ============================================================================
# Test Group 9: Result Enum - Unwrap
# ============================================================================

describe "Result enum - unwrap_or":
    it "returns Ok value when Ok":
        expect(Ok(42).unwrap_or(0)).to_equal(42)

    it "returns default when Err":
        expect(Err("e").unwrap_or(0)).to_equal(0)


describe "Result enum - unwrap":
    it "returns Ok value":
        expect(Ok(42).unwrap()).to_equal(42)


describe "Result enum - unwrap_err":
    it "returns Err value":
        expect(Err("bad").unwrap_err()).to_equal("bad")


describe "Result enum - unwrap_or_else":
    it "returns Ok value when Ok":
        expect(Ok(42).unwrap_or_else(\e: 0)).to_equal(42)

    it "calls function when Err":
        expect(Err("e").unwrap_or_else(\e: 99)).to_equal(99)


# ============================================================================
# Test Group 10: Result Enum - Map
# ============================================================================

describe "Result enum - map":
    it "maps Ok value":
        val r = Ok(5).map(\x: x * 2)
        expect(r.is_ok()).to_equal(true)
        expect(r.unwrap()).to_equal(10)

    it "passes through Err":
        val r = Err("e").map(\x: x * 2)
        expect(r.is_err()).to_equal(true)
        expect(r.unwrap_err()).to_equal("e")


describe "Result enum - map_err":
    it "maps Err value":
        val r = Err("io").map_err(\e: "Error: " + e)
        expect(r.is_err()).to_equal(true)
        expect(r.unwrap_err()).to_equal("Error: io")

    it "passes through Ok":
        val r = Ok(5).map_err(\e: "Error: " + e)
        expect(r.is_ok()).to_equal(true)
        expect(r.unwrap()).to_equal(5)


# ============================================================================
# Test Group 11: Result Enum - FlatMap and Chaining
# ============================================================================

describe "Result enum - map then flatten":
    it "flat maps Ok value via map+flatten":
        val mapped = Ok(5).map(\x: Ok(x * 2))
        val r = mapped.flatten()
        expect(r.unwrap()).to_equal(10)

    it "flat maps Ok to Err via map+flatten":
        val mapped = Ok(5).map(\x: Err("bad"))
        val r = mapped.flatten()
        expect(r.is_err()).to_equal(true)

    it "passes through Err with map":
        val r = Err("e").map(\x: Ok(x * 2))
        expect(r.is_err()).to_equal(true)


describe "Result enum - or":
    it "returns first when first is Ok":
        val r = Ok(5).or(Ok(10))
        expect(r.unwrap()).to_equal(5)

    it "returns second when first is Err":
        val r = Err("e").or(Ok(10))
        expect(r.unwrap()).to_equal(10)

    it "returns second Err when both Err":
        val r = Err("e1").or(Err("e2"))
        expect(r.unwrap_err()).to_equal("e2")


describe "Result enum - or_else":
    it "returns Ok when Ok":
        val r = Ok(5).or_else(\e: Ok(0))
        expect(r.unwrap()).to_equal(5)

    it "calls function when Err":
        val r = Err("e").or_else(\e: Ok(99))
        expect(r.unwrap()).to_equal(99)


# ============================================================================
# Test Group 12: Result Enum - Flatten and Transpose
# ============================================================================

describe "Result enum - flatten":
    it "flattens Ok(Ok(v)) to Ok(v)":
        val r = Ok(Ok(5)).flatten()
        expect(r.unwrap()).to_equal(5)

    it "flattens Ok(Err(e)) to Err(e)":
        val r = Ok(Err("e")).flatten()
        expect(r.is_err()).to_equal(true)

    it "passes through outer Err":
        val r = Err("outer").flatten()
        expect(r.is_err()).to_equal(true)


describe "Result enum - unwrap_or with Err":
    it "returns default for Err via unwrap_or":
        val r = Err("e")
        expect(r.unwrap_or(99)).to_equal(99)

    it "returns value for Ok via unwrap_or":
        val r = Ok(5)
        expect(r.unwrap_or(99)).to_equal(5)


# ============================================================================
# Test Group 13: Result Enum - Extract Ok/Err as Option
# ============================================================================

describe "Result enum - ok":
    it "returns Some(value) for Ok":
        val opt = Ok(42).ok()
        expect(opt.unwrap()).to_equal(42)

    it "returns None for Err":
        val opt = Err("e").ok()
        expect(opt.?).to_equal(false)


describe "Result enum - err":
    it "returns Some(error) for Err":
        val opt = Err("bad").err()
        expect(opt.unwrap()).to_equal("bad")

    it "returns None for Ok":
        val opt = Ok(42).err()
        expect(opt.?).to_equal(false)


# ============================================================================
# Test Group 14: Result Enum - Expect and Contains
# ============================================================================

describe "Result enum - expect":
    it "returns Ok value with expect":
        expect(Ok(42).expect("should be ok")).to_equal(42)


describe "Result enum - expect_err":
    it "returns Err value with expect_err":
        expect(Err("bad").expect_err("should be err")).to_equal("bad")


describe "Result enum - map_err chaining":
    it "maps error and checks original Ok preserved":
        val r = Ok(10).map_err(\e: "wrapped: " + e)
        expect(r.is_ok()).to_equal(true)
        expect(r.unwrap()).to_equal(10)

    it "maps error message on Err":
        val r = Err("timeout").map_err(\e: "wrapped: " + e)
        expect(r.is_err()).to_equal(true)
        expect(r.unwrap_err()).to_equal("wrapped: timeout")


# ============================================================================
# Test Group 15: Result Enum - or and or_else additional
# ============================================================================

describe "Result enum - or_else chaining":
    it "returns recovery value on Err":
        val r = Err("first").or_else(\e: Err("fallback"))
        expect(r.is_err()).to_equal(true)
        expect(r.unwrap_err()).to_equal("fallback")

    it "ignores or_else on Ok":
        val r = Ok(42).or_else(\e: Ok(0))
        expect(r.unwrap()).to_equal(42)


# ============================================================================
# Test Group 16: Result Enum - flatten additional
# ============================================================================

describe "Result enum - flatten nested":
    it "flattens nested Ok":
        val r = Ok(Ok(100)).flatten()
        expect(r.unwrap()).to_equal(100)

    it "flattens nested Err inside Ok":
        val r = Ok(Err("inner")).flatten()
        expect(r.is_err()).to_equal(true)
        expect(r.unwrap_err()).to_equal("inner")
