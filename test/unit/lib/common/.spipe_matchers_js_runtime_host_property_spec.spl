use std.spec.*
use std.js.engine.runtime.{JsRuntime}
use std.js.engine.js_error.{Logger, LogLevel}
use std.js.types.js_types.{JsValue}

describe "JS runtime host property object store invariants":

    it "keeps host-property arrays aligned for object store readers":
        val runtime = JsRuntime.new(Logger.new("js-runtime-host-prop-test", LogLevel.Error))
        val parent_id = runtime.create_host_object()
        val child_id = runtime.create_host_object()

        runtime.set_host_property(parent_id, "label", JsValue.String(v: "ok"))
        runtime.set_host_property(parent_id, "child", JsValue.Object(id: child_id))

        val store = runtime.interpreter.object_store
        expect store.prop_obj_ids.len() == store.prop_keys.len()
        expect store.prop_obj_ids.len() == store.prop_values.len()
        expect store.prop_obj_ids.len() == store.prop_ref_tags.len()
        expect store.prop_obj_ids.len() == store.prop_ref_ids.len()
        expect store.prop_obj_ids.len() == store.prop_enumerables.len()
        expect store.prop_obj_ids.len() == store.prop_configurables.len()

        match store.get_property(parent_id, "label"):
            JsValue.String(v):
                expect v == "ok"
            _:
                expect false == true

        match store.get_property(parent_id, "child"):
            JsValue.Object(id):
                expect id == child_id
            _:
                expect false == true

        val snapshot = store.get_object(parent_id)
        expect snapshot.properties.len() == 2