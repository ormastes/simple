# Regression coverage for the GC async immutable compatibility family.

use std.gc_async_immut.{Atom, VersionedSnapshot, pmap, nogc_async_immut_version}

describe "gc_async_immut facade resolution":
    it "resolves persistent helpers through the no-GC async immutable backing family":
        expect(pmap([1, 2, 3], fn(x): x + 1)).to_equal([2, 3, 4])
        expect(nogc_async_immut_version()).to_equal("0.1.0")

    it "preserves root coordination type behavior through the GC facade":
        var atom = Atom.new(5)
        atom.reset(8)
        expect(atom.deref()).to_equal(8)

        var snapshot = VersionedSnapshot.new("old")
        snapshot.update("new")
        expect(snapshot.current()).to_equal("new")
