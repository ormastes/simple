use std.spec.*

use hardware.riscv_common.pkg.riscv_generated_core_pkg.{RiscvProofLane, GeneratedCoreShellContract}

describe "RISC-V generated core proof lanes":
    it "labels external reference lanes explicitly":
        expect RiscvProofLane.ReferenceExternalRv32Linux.to_text() == "reference_external_rv32_linux"
        expect RiscvProofLane.ReferenceExternalRv64Linux.to_text() == "reference_external_rv64_linux"
        expect RiscvProofLane.ReferenceExternalRv32Linux.is_external_reference() == true
        expect RiscvProofLane.ReferenceExternalRv64Linux.requires_linux_boot() == true

    it "labels generated proof lanes separately from external Linux references":
        expect RiscvProofLane.GeneratedRv32Baremetal.to_text() == "generated_rv32_baremetal"
        expect RiscvProofLane.GeneratedRv64Linux.to_text() == "generated_rv64_linux"
        expect RiscvProofLane.GeneratedRv32Baremetal.requires_linux_boot() == false
        expect RiscvProofLane.GeneratedRv64Linux.is_external_reference() == false

describe "RISC-V generated core shell contracts":
    it "keeps RV32 semihost and mailbox at the shell seam":
        val shell = GeneratedCoreShellContract.rv32_baremetal()
        expect shell.xlen_bits == 32
        expect shell.proof_lane == RiscvProofLane.GeneratedRv32Baremetal
        expect shell.semihost_shell_service == true
        expect shell.mailbox_shell_service == true
        expect shell.shell_services_summary() == "semihost+mailbox"
        expect (shell.acceptance_markers()).contains("mailbox-sentinel")
        expect (shell.debug_outputs).contains("semihost_trigger")

    it "keeps RV64 on the Linux fw_jump/OpenSBI proof path":
        val shell = GeneratedCoreShellContract.rv64_linux()
        expect shell.xlen_bits == 64
        expect shell.proof_lane == RiscvProofLane.GeneratedRv64Linux
        expect shell.boot.opensbi_fw_jump == true
        expect shell.boot.hartid_register == "a0"
        expect shell.boot.dtb_register == "a1"
        expect (shell.acceptance_markers()).contains("Linux version")
        expect (shell.interrupt_inputs).contains("supervisor_external")