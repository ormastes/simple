import std.spec

use hardware.riscv_common.pkg.riscv_linux_pkg.{RiscvTargetAbi, RiscvLinuxProfile, RiscvPlatformProfile, Rv32LinuxBootArtifacts, Rv64LinuxBootArtifacts}

describe "RISC-V Linux shared profiles":
    it "defines RV64 QEMU virt as LP64D Sv39 with OpenSBI handoff":
        val linux = RiscvLinuxProfile.rv64_qemu_virt_linux()
        val platform = RiscvPlatformProfile.qemu_virt_rv64()
        expect linux.abi == RiscvTargetAbi.LP64D
        expect linux.mmu_mode.to_text() == "sv39"
        expect linux.opensbi_required == true
        expect platform.name == "qemu_virt_rv64"
        expect platform.hartid_register == "a0"
        expect platform.dtb_register == "a1"
        expect (platform.required_soc_blocks()).contains("opensbi-handoff")

    it "defines RV32 QEMU virt as ILP32D Sv32 with OpenSBI handoff":
        val linux = RiscvLinuxProfile.rv32_qemu_virt_linux()
        val platform = RiscvPlatformProfile.qemu_virt_rv32()
        expect linux.abi == RiscvTargetAbi.ILP32D
        expect linux.mmu_mode.to_text() == "sv32"
        expect linux.opensbi_required == true
        expect platform.linux.abi == RiscvTargetAbi.ILP32D
        expect platform.name == "qemu_virt_rv32"
        expect (platform.required_soc_blocks()).contains("rv32gc-core")

describe "RV64 Linux boot artifacts":
    it "rejects missing dtb and firmware for RV64 Linux":
        val artifacts = Rv64LinuxBootArtifacts.empty()
        val errors = artifacts.validate_for(RiscvLinuxProfile.rv64_qemu_virt_linux())
        expect (errors).contains("kernel_image is required")
        expect (errors).contains("initrd_rootfs is required")
        expect (errors).contains("dtb is required")
        expect (errors).contains("OpenSBI or U-Boot firmware is required")

describe "RV32 Linux boot artifacts":
    it "rejects missing dtb and firmware for RV32 Linux":
        val artifacts = Rv32LinuxBootArtifacts.empty()
        val errors = artifacts.validate_for(RiscvLinuxProfile.rv32_qemu_virt_linux())
        expect (errors).contains("kernel_image is required")
        expect (errors).contains("initrd_rootfs is required")
        expect (errors).contains("dtb is required")
        expect (errors).contains("OpenSBI or U-Boot firmware is required")