use std.spec.*

extern fn rt_file_read_text(path: text) -> text

fn read_text(path: text) -> text:
    rt_file_read_text(path)

describe "MLK-S02-100T assumption validation campaign":
    it "locks the launch plan to the assumption-only MLK lane":
        val script = read_text("scripts/mlk_s02_100t_assumption_validation.shs")
        expect (script).contains("scripts/mlk_s02_100t_generated_linux.shs")
        expect (script).contains("mlk_s02_100t_assumed_unverified.xdc")
        expect (script).contains("--allow-assumed-board-top")
        expect (script).contains("--allow-unsafe-assumed-bitstream")
        expect (script).contains("ARCH_MODE=\"both\"")
        expect (script).contains("rv32 rv64")

    it "records the staged matrix and assumption ledger for each arch":
        val script = read_text("scripts/mlk_s02_100t_assumption_validation.shs")
        expect (script).contains("generated Linux behavioral gate")
        expect (script).contains("assumption-only synth")
        expect (script).contains("assumption-only place/route")
        expect (script).contains("assumption-only bitstream")
        expect (script).contains("hardware programming")
        expect (script).contains("UART observation")
        expect (script).contains("Linux launch attempt")
        expect (script).contains("Assumption Ledger")
        expect (script).contains("confirmed by toolchain only")
        expect (script).contains("confirmed by programming only")
        expect (script).contains("confirmed by UART/LED hardware behavior")
        expect (script).contains("still unknown")

    it "keeps linux launch gated behind staged artifacts and a boot delivery command":
        val script = read_text("scripts/mlk_s02_100t_assumption_validation.shs")
        expect (script).contains("boot delivery command not configured")
        expect (script).contains("linux_stage_ready()")
        expect (script).contains("staged_boot_artifact_path")
        expect (script).contains("--prepare-only --skip-ghdl")
        expect (script).contains("--skip-ghdl --skip-synth --skip-program")
        expect (script).contains("assumption-only wrapper ties memory off and drives uart_tx idle-high; Linux boot proof is blocked")
        expect (script).contains("if [ \"$linux_status\" = \"pass\" ]; then")

    it "documents the assumption validation runner in the assumed profile guide":
        val guide = read_text("doc/07_guide/hardware/mlk_s02_100t_assumed_profile.md")
        expect (guide).contains("scripts/mlk_s02_100t_assumption_validation.shs")
        expect (guide).contains("build/fpga/mlk_s02_100t/assumption_validation/")
        expect (guide).contains("confirmed by UART/LED hardware behavior")