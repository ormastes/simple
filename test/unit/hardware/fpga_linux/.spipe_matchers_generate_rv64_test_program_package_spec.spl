use std.spec.*
use app.io.mod.{file_read}

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

fn shell(command: text) -> i64:
    val (stdout, stderr, code) = rt_process_run("/bin/sh", ["-c", command])
    if code != 0:
        print stdout
        print stderr
    code

describe "generate_rv64_test_program_package":
    it "emits 64-bit preload rows and keeps byte-array metadata coherent":
        val root = "/tmp/generate_rv64_test_program_package_spec"
        val fw_bin = "{root}/fw.bin"
        val fw_hex = "{root}/fw.hex"
        val payload_bin = "{root}/payload.bin"
        val payload_hex = "{root}/payload.hex"
        val pkg = "{root}/test_program.vhd"

        expect shell("rm -rf '" + root + "' && mkdir -p '" + root + "'") == 0

        expect shell("printf '\\001\\002\\003\\004\\005\\006\\007\\010\\011' > '" + fw_bin + "'") == 0
        expect shell("printf '\\252\\273\\314\\335' > '" + payload_bin + "'") == 0

        expect shell("bin/simple run src/hardware/fpga_linux/generate_rv64_test_program_package.spl -- '" + fw_bin + "' '" + fw_hex + "' '" + payload_bin + "' '" + payload_hex + "' '" + pkg + "'") == 0

        expect file_read(fw_hex) == "0807060504030201\n0000000000000009\n"
        expect file_read(payload_hex) == "00000000DDCCBBAA\n"

        val pkg_text = file_read(pkg)
        expect (pkg_text).contains("constant HEX_WORD_BYTES : integer := 8;")
        expect (pkg_text).contains("constant FW_SIZE_BYTES : integer := 9;")
        expect (pkg_text).contains("constant FW_HEX_PATH : string := \"" + fw_hex + "\";")
        expect (pkg_text).contains("constant PAYLOAD_SIZE_BYTES : integer := 4;")
        expect (pkg_text).contains("constant PAYLOAD_HEX_PATH : string := \"" + payload_hex + "\";")
        expect (pkg_text).contains("constant FW_BYTES : byte_array_t(0 to 8) := (")
        expect (pkg_text).contains("        x\"01\",")
        expect (pkg_text).contains("        x\"09\"\n    );")
        expect (pkg_text).contains("constant PAYLOAD_BYTES : byte_array_t(0 to 3) := (")
        expect (pkg_text).contains("        x\"AA\",")
        expect (pkg_text).contains("        x\"DD\"\n    );")