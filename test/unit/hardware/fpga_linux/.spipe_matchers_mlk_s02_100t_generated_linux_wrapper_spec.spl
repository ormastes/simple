use std.spec.*

extern fn rt_file_read_text(path: text) -> text

fn read_text(path: text) -> text:
    rt_file_read_text(path)

describe "MLK-S02-100T generated Linux wrapper scripts":
    it "publishes the board wrapper and boot verifier script names":
        val wrapper = read_text("scripts/mlk_s02_100t_generated_linux.shs")
        expect (wrapper).contains("scripts/mlk_s02_100t_generated_linux_boot.shs")
        expect (wrapper).contains("scripts/vivado_mlk_s02_100t_generated_linux.tcl")
        expect (wrapper).contains("scripts/rtl_riscv32_linux_generated.shs")
        expect (wrapper).contains("scripts/rtl_riscv64_linux_generated.shs")

    it "maps each arch to the expected MLK product id and generated bundle flow":
        val wrapper = read_text("scripts/mlk_s02_100t_generated_linux.shs")
        expect (wrapper).contains("echo \"mlk_s02_100t_$1_linux\"")
        expect (wrapper).contains("--board=mlk_s02_100t")
        expect (wrapper).contains("src/hardware/fpga_linux/generate_riscv_fpga_bundle.spl")
        expect (wrapper).contains("ARCH_MODE=\"both\"")
        expect (wrapper).contains("rv32 rv64")
        expect (wrapper).contains("BOOT_STAGE_ROOT")
        expect (wrapper).contains("stage_boot_artifacts \"$arch\"")

    it "hands synthesis to the MLK Vivado TCL with board-specific arguments":
        val wrapper = read_text("scripts/mlk_s02_100t_generated_linux.shs")
        val vivado_tcl = read_text("scripts/vivado_mlk_s02_100t_generated_linux.tcl")
        expect (wrapper).contains("vivado -mode batch")
        expect (wrapper).contains("assert_ready_xdc \"$xdc_path\"")
        expect (wrapper).contains("FAIL: XDC is still a placeholder scaffold")
        expect (wrapper).contains("Provide a verified vendor/user constraint file via --vendor-xdc or MLK_VENDOR_XDC before synth.")
        expect (wrapper).contains("-source \"$REPO_ROOT/scripts/vivado_mlk_s02_100t_generated_linux.tcl\"")
        expect (wrapper).contains("-tclargs \"$product_id\" \"$arch\" \"$BUNDLE_ROOT\" \"$product_dir\" \"$xdc_path\"")
        expect (wrapper).contains("assert_staged_boot_artifacts \"$arch\"")
        expect (wrapper).contains("boot delivery command not configured; pass --boot-delivery-cmd or set MLK_BOOT_DELIVERY_CMD")
        expect (vivado_tcl).contains("create_project -force $product_id $project_dir -part xc7a100t-2ffg484i")
        expect (vivado_tcl).contains("set rtl_dir [file join $bundle_root \"rv32\" \"rtl\"]")
        expect (vivado_tcl).contains("set rtl_dir [file join $bundle_root \"rv64\" \"rtl\"]")

    it "uses the UART verification helper with deterministic Linux boot markers":
        val wrapper = read_text("scripts/mlk_s02_100t_generated_linux.shs")
        val boot = read_text("scripts/mlk_s02_100t_generated_linux_boot.shs")
        expect (wrapper).contains("sh \"$REPO_ROOT/scripts/mlk_s02_100t_generated_linux_boot.shs\"")
        expect (wrapper).contains("BOOT_PRODUCTS_MANIFEST=\"$(boot_products_manifest_path)\"")
        expect (wrapper).contains("--product-id=\"$product_id\"")
        expect (wrapper).contains("--boot-products-manifest=\"$BOOT_PRODUCTS_MANIFEST\"")
        expect (wrapper).contains("\"--boot-loader-cmd=$BOOT_DELIVERY_CMD\"")
        expect (boot).contains("markers_from_manifest()")
        expect (boot).contains("expected_markers = \"")
        expect (boot).contains("missing UART markers; pass --markers or both --boot-products-manifest and --product-id")
        expect (boot).contains("FAIL: UART markers missing")
        expect (boot).contains("PASS: UART markers found for $COLD_BOOTS cold boot(s)")