use std.spec.*

extern fn rt_file_read_text(path: text) -> text

fn read_text(path: text) -> text:
    rt_file_read_text(path)

describe "generated RV64 RTL Linux smoke script":
    it "selects a runnable Simple compiler instead of trusting executable bits alone":
        val script = read_text("scripts/rtl_riscv64_linux_generated.shs")
        expect(script).to_contain("can_run_simple_bin()")
        expect(script).to_contain("timeout 5 \"$candidate\" --help >/dev/null 2>&1")
        expect(script).to_contain("SIMPLE_BIN=\"$(pick_simple_bin)\" || {")
        expect(script).to_contain("FAIL: no runnable Simple compiler found; set SIMPLE_BINARY to a working host runtime")

    it "still prefers SIMPLE_BINARY before falling back to repo launchers":
        val script = read_text("scripts/rtl_riscv64_linux_generated.shs")
        expect(script).to_contain("SIMPLE_BINARY")
        expect(script).to_contain("\"$REPO_ROOT/src/compiler_rust/target/bootstrap/simple\"")
        expect(script).to_contain("\"$REPO_ROOT/src/compiler_rust/target/release/simple\"")
        expect(script).to_contain("\"$REPO_ROOT/bin/simple\"")

    it "builds the payload with the selected launcher":
        val script = read_text("scripts/rtl_riscv64_linux_generated.shs")
        expect(script).to_contain("\"$SIMPLE_BIN\" native-build")
