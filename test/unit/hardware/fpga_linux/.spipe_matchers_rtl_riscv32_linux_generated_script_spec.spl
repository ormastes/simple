use std.spec.*

extern fn rt_file_read_text(path: text) -> text

fn read_text(path: text) -> text:
    rt_file_read_text(path)

describe "generated RV32 RTL Linux smoke script":
    it "probes LLVM native-build capability instead of trusting help output alone":
        val script = read_text("scripts/rtl_riscv32_linux_generated.shs")
        expect (script).contains("can_run_simple_bin()")
        expect (script).contains("build_simple_candidate_list()")
        expect (script).contains("if \"$candidate\" native-build")
        expect (script).contains("--backend llvm")
        expect (script).contains("missing llvm feature (log:")

    it "tries bootstrap and packaged release candidates before the generic wrapper":
        val script = read_text("scripts/rtl_riscv32_linux_generated.shs")
        expect (script).contains("\"$REPO_ROOT/bin/release/x86_64-unknown-linux-gnu/simple\"")
        expect (script).contains("\"$REPO_ROOT/build/bootstrap/full/x86_64-unknown-linux-gnu/simple\"")
        expect (script).contains("\"$REPO_ROOT/build/bootstrap/stage3/x86_64-unknown-linux-gnu/simple\"")
        expect (script).contains("\"$REPO_ROOT/src/compiler_rust/target/release-opt/simple\"")
        expect (script).contains("\"$REPO_ROOT/bin/simple\"")

    it "reports a precise prerequisite after exhausting LLVM candidates":
        val script = read_text("scripts/rtl_riscv32_linux_generated.shs")
        expect (script).contains("FAIL: unable to build $LANE_ID payload with an LLVM-capable Simple compiler")
        expect (script).contains("tried candidates:")
        expect (script).contains("cargo build --features llvm -p simple-driver")