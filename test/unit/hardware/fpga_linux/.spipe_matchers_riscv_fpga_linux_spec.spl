        expect (rv64_core).contains("-- source-map: RiscvExecuteDatapathEncoding.opcode => imem_rdata(6 downto 0)")
        expect (rv64_core).contains("-- source-map: RiscvExecuteDatapathEncoding.funct3 => imem_rdata(14 downto 12)")
        expect (rv64_core).contains("-- source-map: RiscvExecuteDatapathEncoding.bit30 => imem_rdata(30 downto 30)")
        expect (rv64_core).contains("-- source-map: RiscvBranchDatapathEncoding.opcode => imem_rdata(6 downto 0)")
        expect (rv64_core).contains("-- source-map: RiscvBranchDatapathEncoding.funct3 => imem_rdata(14 downto 12)")
        expect (rv64_core).contains("-- source-map: RiscvControlFlowDatapathEncoding.opcode => imem_rdata(6 downto 0)")
        expect (rv64_core).contains("-- source-map: RiscvMemoryAccessControlEncoding.funct3 => imem_rdata(14 downto 12)")
        expect (rv64_core).contains("-- source-map: RiscvDispatchClassEncoding.opcode => imem_rdata(6 downto 0)")
        expect (rv64_core).contains("-- source-map: RiscvTrapHaltControlEncoding.opcode => imem_rdata(6 downto 0)")
        expect (rv64_core).contains("variable decode_execute_datapath_bits : std_logic_vector(31 downto 0);")
        expect (rv64_core).contains("variable decode_branch_datapath_bits : std_logic_vector(31 downto 0);")
        expect (rv64_core).contains("variable decode_control_flow_datapath_bits : std_logic_vector(31 downto 0);")
        expect (rv64_core).contains("variable decode_dispatch_class_bits : std_logic_vector(31 downto 0);")
