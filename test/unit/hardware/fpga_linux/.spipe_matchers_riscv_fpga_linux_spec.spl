"""
# RISC-V FPGA Linux Preparation Tests

Truthfulness and orchestration tests for the shared RV32/RV64 Linux pipeline.
"""

use std.spec.*

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_file_read_text(path: text) -> text

use hardware.fpga_linux.riscv_fpga_linux.{RiscvReadinessStatus, XilinxBoardProfile, LinuxArtifactSet, RiscvFpgaLane, create_default_riscv_fpga_linux_manifest, generate_default_riscv_fpga_rtl_bundle, read_generated_riscv_fpga_rtl_file}
use hardware.riscv_common.pkg.riscv_generated_core_pkg.RiscvProofLane

fn shell(command: text) -> i64:
    val (_stdout, _stderr, code) = rt_process_run("/bin/sh", ["-c", command])
    code

describe "RISC-V FPGA Linux board profile":
    it "allows the generic Xilinx profile for prepare-only generation":
        val profile = XilinxBoardProfile.generic()
        expect profile.name == "xilinx_generic"
        expect profile.is_generic() == true
        expect profile.validate_for_prepare().len() == 0

    it "blocks hardware boot until the exact part and memory are known":
        val profile = XilinxBoardProfile.generic()
        val errors = profile.validate_for_hardware_boot()
        expect (errors).contains("xilinx part must be selected before hardware boot")
        expect (errors).contains("memory_size_bytes must be set before hardware boot")

describe "RISC-V FPGA Linux lanes":
    it "defines RV64 as a repo-native QEMU virt Linux contract lane":
        val lane = RiscvFpgaLane.rv64_default()
        expect lane.xlen.to_text() == "rv64"
        expect lane.readiness_status() == RiscvReadinessStatus.Contract
        expect lane.proof_lane() == RiscvProofLane.GeneratedRv64Linux
        expect lane.xlen.linux_policy() == "repo-native-rv64-linux"
        expect lane.platform_profile.name == "qemu_virt_rv64"
        expect lane.linux_profile.abi.to_text() == "lp64d"
        expect lane.linux_profile.mmu_mode.to_text() == "sv39"
        expect (lane.required_soc_blocks()).contains("opensbi-handoff")
        expect (lane.required_soc_blocks()).contains("generated-core-shell")
        expect (lane.proof_acceptance_markers()).contains("OpenSBI")
        expect (lane.expected_boot_markers()).contains("Linux version")
        expect (lane.expected_boot_markers()).contains("init started")
        expect lane.proof_lane_summary() == "generated_rv64_linux shell=none"
        expect lane.hardware_source_contract_errors().len() == 0

    it "defines RV32 as a repo-native generated-core baremetal proof lane":
        val lane = RiscvFpgaLane.rv32_default()
        expect lane.xlen.to_text() == "rv32"
        expect lane.readiness_status() == RiscvReadinessStatus.Contract
        expect lane.proof_lane() == RiscvProofLane.GeneratedRv32Baremetal
        expect lane.xlen.linux_policy() == "repo-native-rv32-baremetal"
        expect lane.linux_profile.abi.to_text() == "ilp32d"
        expect lane.platform_profile.name == "qemu_virt_rv32"
        expect lane.linux_profile.mmu_mode.to_text() == "sv32"
        expect (lane.required_soc_blocks()).contains("semihost-shell-service")
        expect (lane.required_soc_blocks()).contains("mailbox-shell-service")
        expect (lane.proof_acceptance_markers()).contains("mailbox-sentinel")

    it "requires validation plus boot artifacts before Linux boot claims":
        val lane = RiscvFpgaLane.rv32_default()
        val errors = lane.validate_for_linux_boot()
        expect (errors).contains("rv32 readiness must be qemu-boot-validated, rtl-linux-validated, or fpga-validated before claiming Linux boot")
        expect (errors).contains("kernel_image is required")
        expect (errors).contains("initrd_rootfs is required")
        expect (errors).contains("dtb is required")
        expect (errors).contains("OpenSBI or U-Boot firmware is required")
        expect (errors).contains("rv32 toolchain prefix must be configured")

    it "does not accept configured RV64 artifacts before readiness advances beyond contract":
        val lane = RiscvFpgaLane(
            xlen: RiscvFpgaLane.rv64_default().xlen,
            top_module: "simple_rv64gc_core",
            rtl_dir: "build/fpga/rv64/rtl",
            rtl_sim_backend: "ghdl-vhdl-2008",
            bootrom_path: "build/fpga/rv64/bootrom.bin",
            readiness: RiscvReadinessStatus.Contract,
            linux_profile: RiscvFpgaLane.rv64_default().linux_profile,
            platform_profile: RiscvFpgaLane.rv64_default().platform_profile,
            scope_note: "repo-native RV64GC Linux contract lane",
            linux: LinuxArtifactSet(
                kernel_image: "linux/arch/riscv/boot/Image",
                rootfs_image: "rootfs/rv64.cpio",
                opensbi_image: "opensbi/build/platform/generic/firmware/fw_payload.bin",
                uboot_image: "",
                dtb_path: "build/fpga/rv64/simple.dtb",
                toolchain_prefix: "riscv64-linux-gnu-"
            )
        )
        expect (lane.validate_for_linux_boot()).contains("rv64 readiness must be qemu-boot-validated, rtl-linux-validated, or fpga-validated before claiming Linux boot")

describe "RISC-V FPGA Linux manifest":
    it "defaults to dual repo-native RV32/RV64 lanes":
        val manifest = create_default_riscv_fpga_linux_manifest()
        expect manifest.board.name == "xilinx_generic"
        expect manifest.lanes.len() == 2
        expect manifest.validate_for_prepare().len() == 0
        expect (manifest.readiness_summary()).contains("rv32:contract:qemu_virt_rv32:simple_rv32gc_core:generated_rv32_baremetal")
        expect (manifest.readiness_summary()).contains("rv64:contract:qemu_virt_rv64:simple_rv64gc_core:generated_rv64_linux")

    it "emits generated RV64 Linux lane metadata in the manifest":
        val manifest = create_default_riscv_fpga_linux_manifest()
        val text = manifest.rtl_manifest_text("/tmp/rv64_linux_manifest")
        expect (text).contains("proof_lane = \"generated_rv64_linux\"")
        expect (text).contains("shell_contract = \"generated_rv64_linux shell=none\"")
        expect (text).contains("firmware_mode = \"fw_jump\"")
        expect (text).contains("authoritative_rtl_root = \"/tmp/rv64_linux_manifest/rv32/rtl\"")
        expect (text).contains("support_package_file = \"/tmp/rv64_linux_manifest/rv32/rtl/rv32i_pkg.vhd\"")
        expect (text).contains("wrapper_file = \"/tmp/rv64_linux_manifest/rv32/rtl/rv32i_generated_wrapper.vhd\"")
        expect (text).contains("runner_testbench = \"/tmp/rv64_linux_manifest/rv32/rtl/tb_mailbox.vhd\"")
        expect (text).contains("runner_testbench = \"/tmp/rv64_linux_manifest/rv64/rtl/tb_generated_rv64_boot_banner.vhd\"")
        expect text.contains("examples/09_embedded/fpga_riscv/rtl") == false

    it "generates a deterministic Vivado TCL plan from both lanes":
        val manifest = create_default_riscv_fpga_linux_manifest()
        val tcl = manifest.vivado_tcl_plan()
        expect (tcl).contains("create_project simple_riscv_fpga")
        expect (tcl).contains("-part BOARD_PART_TBD")
        expect (tcl).contains("add_files constraints/xilinx_generic.xdc")
        expect (tcl).contains("add_files build/fpga/rv32/rtl")
        expect (tcl).contains("add_files build/fpga/rv64/rtl")
        expect (tcl).contains("set_property top simple_rv64gc_core")

describe "RISC-V FPGA Linux RTL generation":
    it "emits dual-architecture bundles by default":
        expect shell("rm -rf '/tmp/simple_rv64_fpga_rtl_spec'") == 0
        val result = generate_default_riscv_fpga_rtl_bundle("/tmp/simple_rv64_fpga_rtl_spec")
        expect result.is_ok() == true
        val bundle = result.unwrap()

        val rv32_source = read_generated_riscv_fpga_rtl_file("/tmp/simple_rv64_fpga_rtl_spec/rv32/rtl/simple_rv32gc_core.spl")
        val rv32_support_pkg = read_generated_riscv_fpga_rtl_file("/tmp/simple_rv64_fpga_rtl_spec/rv32/rtl/rv32i_pkg.vhd")
        val rv32_wrapper = read_generated_riscv_fpga_rtl_file("/tmp/simple_rv64_fpga_rtl_spec/rv32/rtl/rv32i_generated_wrapper.vhd")
        val rv32_smoke_tb = read_generated_riscv_fpga_rtl_file("/tmp/simple_rv64_fpga_rtl_spec/rv32/rtl/tb_generated_rv32_smoke.vhd")
        val rv32_strobe_tb = read_generated_riscv_fpga_rtl_file("/tmp/simple_rv64_fpga_rtl_spec/rv32/rtl/tb_generated_rv32_strobe.vhd")
        val rv32_semihost_tb = read_generated_riscv_fpga_rtl_file("/tmp/simple_rv64_fpga_rtl_spec/rv32/rtl/tb_semi_run.vhd")
        val rv32_mailbox_tb = read_generated_riscv_fpga_rtl_file("/tmp/simple_rv64_fpga_rtl_spec/rv32/rtl/tb_mailbox.vhd")
        val rv64_source = read_generated_riscv_fpga_rtl_file("/tmp/simple_rv64_fpga_rtl_spec/rv64/rtl/simple_rv64gc_core.spl")
        val rv64_pkg = read_generated_riscv_fpga_rtl_file("/tmp/simple_rv64_fpga_rtl_spec/rv64/rtl/simple_rv64gc_core_pkg.vhd")
        val rv64_core = read_generated_riscv_fpga_rtl_file("/tmp/simple_rv64_fpga_rtl_spec/rv64/rtl/simple_rv64gc_core.vhd")
        val rv64_smoke_tb = read_generated_riscv_fpga_rtl_file("/tmp/simple_rv64_fpga_rtl_spec/rv64/rtl/tb_generated_rv64_smoke.vhd")
        val rv64_irq_tb = read_generated_riscv_fpga_rtl_file("/tmp/simple_rv64_fpga_rtl_spec/rv64/rtl/tb_generated_rv64_irq.vhd")
        val rv64_linux_handoff_tb = read_generated_riscv_fpga_rtl_file("/tmp/simple_rv64_fpga_rtl_spec/rv64/rtl/tb_generated_rv64_linux_handoff.vhd")
        val rv64_boot_banner_tb = read_generated_riscv_fpga_rtl_file("/tmp/simple_rv64_fpga_rtl_spec/rv64/rtl/tb_generated_rv64_boot_banner.vhd")
        val rv64_fw_jump_tb = read_generated_riscv_fpga_rtl_file("/tmp/simple_rv64_fpga_rtl_spec/rv64/rtl/tb_generated_rv64_fw_jump.vhd")
        val rv64_real_dtb_tb = read_generated_riscv_fpga_rtl_file("/tmp/simple_rv64_fpga_rtl_spec/rv64/rtl/tb_generated_rv64_boot_info_real_dtb.vhd")
        val rv64_sv39_tb = read_generated_riscv_fpga_rtl_file("/tmp/simple_rv64_fpga_rtl_spec/rv64/rtl/tb_generated_rv64_sv39.vhd")
        val rv64_sv39_fault_tb = read_generated_riscv_fpga_rtl_file("/tmp/simple_rv64_fpga_rtl_spec/rv64/rtl/tb_generated_rv64_sv39_fault.vhd")
        val rv64_tb = read_generated_riscv_fpga_rtl_file("/tmp/simple_rv64_fpga_rtl_spec/rv64/rtl/tb_generated_rv64_boot_info_dtb.vhd")
        val manifest_text = read_generated_riscv_fpga_rtl_file("/tmp/simple_rv64_fpga_rtl_spec/riscv_fpga_rtl_manifest.sdn")

        expect rv32_source != "" == true
        expect rv32_support_pkg != "" == true
        expect rv32_wrapper != "" == true
        expect rv32_smoke_tb != "" == true
        expect rv32_strobe_tb != "" == true
        expect rv32_semihost_tb != "" == true
        expect rv32_mailbox_tb != "" == true
        expect rv64_source != "" == true
        expect rv64_pkg != "" == true
        expect rv64_core != "" == true
        expect rv64_smoke_tb != "" == true
        expect rv64_irq_tb != "" == true
        expect rv64_linux_handoff_tb != "" == true
        expect rv64_boot_banner_tb != "" == true
        expect rv64_fw_jump_tb != "" == true
        expect rv64_real_dtb_tb != "" == true
        expect rv64_sv39_tb != "" == true
        expect rv64_sv39_fault_tb != "" == true
        expect rv64_tb != "" == true
        expect manifest_text != "" == true
        expect (bundle.generated_files).contains("/tmp/simple_rv64_fpga_rtl_spec/rv32/rtl/rv32i_pkg.vhd")
        expect (bundle.generated_files).contains("/tmp/simple_rv64_fpga_rtl_spec/rv32/rtl/rv32i_generated_wrapper.vhd")
        expect (bundle.generated_files).contains("/tmp/simple_rv64_fpga_rtl_spec/rv32/rtl/tb_generated_rv32_smoke.vhd")
        expect (bundle.generated_files).contains("/tmp/simple_rv64_fpga_rtl_spec/rv32/rtl/tb_generated_rv32_strobe.vhd")
        expect (bundle.generated_files).contains("/tmp/simple_rv64_fpga_rtl_spec/rv32/rtl/tb_semi_run.vhd")
        expect (bundle.generated_files).contains("/tmp/simple_rv64_fpga_rtl_spec/rv32/rtl/tb_mailbox.vhd")
        expect (bundle.generated_files).contains("/tmp/simple_rv64_fpga_rtl_spec/rv64/rtl/tb_generated_rv64_smoke.vhd")
        expect (bundle.generated_files).contains("/tmp/simple_rv64_fpga_rtl_spec/rv64/rtl/tb_generated_rv64_irq.vhd")
        expect (bundle.generated_files).contains("/tmp/simple_rv64_fpga_rtl_spec/rv64/rtl/tb_generated_rv64_linux_handoff.vhd")
        expect (bundle.generated_files).contains("/tmp/simple_rv64_fpga_rtl_spec/rv64/rtl/tb_generated_rv64_boot_banner.vhd")
        expect (bundle.generated_files).contains("/tmp/simple_rv64_fpga_rtl_spec/rv64/rtl/tb_generated_rv64_fw_jump.vhd")
        expect (bundle.generated_files).contains("/tmp/simple_rv64_fpga_rtl_spec/rv64/rtl/tb_generated_rv64_boot_info_real_dtb.vhd")
        expect (bundle.generated_files).contains("/tmp/simple_rv64_fpga_rtl_spec/rv64/rtl/tb_generated_rv64_sv39.vhd")
        expect (bundle.generated_files).contains("/tmp/simple_rv64_fpga_rtl_spec/rv64/rtl/tb_generated_rv64_sv39_fault.vhd")
        expect (bundle.generated_files).contains("/tmp/simple_rv64_fpga_rtl_spec/rv64/rtl/tb_generated_rv64_boot_info_dtb.vhd")
        expect (rv32_source).contains("bitfield Rv32Instruction(u32):")
        expect (rv32_source).contains("platform: qemu_virt_rv32")
        expect (rv32_source).contains("proof_lane: generated_rv32_baremetal")
        expect (rv32_source).contains("scope: repo-native RV32GC generated-core baremetal lane")
        expect (rv32_support_pkg).contains("package rv32i_pkg is")
        expect (rv32_wrapper).contains("entity rv32i_core is")
        expect (rv32_wrapper).contains("entity work.simple_rv32gc_core")
        expect (rv32_semihost_tb).contains("entity tb_semi_run is")
        expect (rv32_mailbox_tb).contains("entity tb_mailbox is")
        expect (rv64_source).contains("bitfield Rv64Instruction(u32):")
        expect (rv64_source).contains("platform: qemu_virt_rv64")
        expect (rv64_source).contains("proof_lane: generated_rv64_linux")
        expect (rv64_source).contains("scope: repo-native RV64GC generated-core Linux lane")
        expect (rv64_source).contains("fn simple_rv64gc_core_decode_writeback")
        expect (rv64_source).contains("fn simple_rv64gc_core_decode_i_immediate")
        expect (rv64_source).contains("fn simple_rv64gc_core_decode_upper_immediate")
        expect (rv64_source).contains("fn simple_rv64gc_core_decode_execute_control")
        expect (rv64_source).contains("fn simple_rv64gc_core_decode_execute_datapath")
        expect (rv64_source).contains("fn simple_rv64gc_core_decode_branch_datapath")
        expect (rv64_source).contains("fn simple_rv64gc_core_decode_control_flow_datapath")
        expect (rv64_source).contains("fn simple_rv64gc_core_decode_memory_access_control")
        expect (rv64_source).contains("fn simple_rv64gc_core_decode_dispatch_class")
        expect (rv64_source).contains("fn simple_rv64gc_core_decode_trap_halt_control")
        expect (rv64_source).contains("bitfield RiscvDispatchClass(u32):")
        expect (rv64_source).contains("bitfield RiscvTrapHaltControl(u32):")
        expect (rv64_source).contains("control.continue_exec = 1 as u32")
        expect (rv64_source).contains("if addr_i(0) = '1' then")
        expect (rv64_source).contains("if addr_i(1 downto 0) /= \"00\" then")
        expect (rv64_source).contains("if addr_i(2 downto 0) /= \"000\" then")
        expect (rv64_source).contains("bitfield RiscvExecuteDatapath(u32):")
        expect (rv64_source).contains("bitfield RiscvExecuteDatapathEncoding(u32):")
