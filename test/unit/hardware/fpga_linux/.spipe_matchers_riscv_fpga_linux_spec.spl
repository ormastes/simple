"""
# RISC-V FPGA Linux Preparation Tests

Truthfulness and orchestration tests for the shared RV32/RV64 Linux pipeline.
"""

use std.spec.*

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_file_read_text(path: text) -> text

use hardware.fpga_linux.riscv_fpga_linux.{RiscvReadinessStatus, XilinxBoardProfile, RiscvFpgaLane, create_default_riscv_fpga_linux_manifest, generate_default_riscv_fpga_rtl_bundle, read_generated_riscv_fpga_rtl_file}
use hardware.riscv_common.pkg.riscv_generated_core_pkg.RiscvProofLane

fn shell(command: text) -> i64:
    val (_stdout, _stderr, code) = rt_process_run("/bin/sh", ["-c", command])
    code

describe "RISC-V FPGA Linux board profile":
    it "keeps generic prepare validation separate from concrete hardware boot validation":
        val generic_profile = XilinxBoardProfile.generic()
        expect generic_profile.validate_for_prepare().len() == 0
        expect (generic_profile.validate_for_hardware_boot()).contains("xilinx part must be selected before hardware boot")

    it "publishes the MLK-S02-100T board facts used by the generated wrapper":
        val mlk = XilinxBoardProfile.from_id("mlk_s02_100t").ok().unwrap()
        expect mlk.part == "xc7a100t-2ffg484i"
        expect mlk.clock_hz == 25000000
        expect mlk.uart_baud == 115200
        expect mlk.programmer == "openFPGALoader"

describe "RISC-V FPGA Linux lanes":
    it "defines RV32 and RV64 as repo-native generated Linux lanes":
        val rv32 = RiscvFpgaLane.rv32_default()
        val rv64 = RiscvFpgaLane.rv64_default()
        expect rv32.readiness_status() == RiscvReadinessStatus.Contract
        expect rv32.proof_lane() == RiscvProofLane.GeneratedRv32Linux
        expect rv32.xlen.linux_policy() == "repo-native-rv32-linux"
        expect (rv32.required_soc_blocks()).contains("opensbi-handoff")
        expect (rv32.proof_acceptance_markers()).contains("OpenSBI")
        expect rv32.proof_lane_summary() == "generated_rv32_linux shell=none"
        expect rv64.proof_lane() == RiscvProofLane.GeneratedRv64Linux
        expect rv64.xlen.linux_policy() == "repo-native-rv64-linux"
        expect (rv64.proof_acceptance_markers()).contains("Linux version")

    it "keeps the default manifest dual-arch by construction":
        val manifest = create_default_riscv_fpga_linux_manifest()
        expect manifest.lanes.len() == 2
        expect (manifest.readiness_summary()).contains("rv32:contract:qemu_virt_rv32")
        expect (manifest.readiness_summary()).contains("rv64:contract:qemu_virt_rv64")

describe "RISC-V FPGA Linux manifest":
    it "emits authoritative RV32 and RV64 Linux metadata plus per-product boot outputs":
        val manifest = create_default_riscv_fpga_linux_manifest()
        val text = manifest.rtl_manifest_text("/tmp/rv_linux_manifest")
        val products = manifest.board_linux_boot_products_manifest_text("/tmp/rv_linux_manifest")
        expect (text).contains("proof_lane = \"generated_rv32_linux\"")
        expect (text).contains("proof_lane = \"generated_rv64_linux\"")
        expect (text).contains("debug_sidecar_file = \"/tmp/rv_linux_manifest/rv32/rtl/simple_rv32gc_core.debug.json\"")
        expect (text).contains("debug_sidecar_file = \"/tmp/rv_linux_manifest/rv64/rtl/simple_rv64gc_core.debug.json\"")
        expect (text).contains("runner_testbench = \"/tmp/rv_linux_manifest/rv32/rtl/tb_generated_rv32_linux_handoff.vhd\"")
        expect (text).contains("runner_testbench = \"/tmp/rv_linux_manifest/rv32/rtl/tb_generated_rv32_boot_info_real_dtb.vhd\"")
        expect (text).contains("runner_testbench = \"/tmp/rv_linux_manifest/rv64/rtl/tb_generated_rv64_boot_info_dtb.vhd\"")
        expect (text).contains("runner_testbench = \"/tmp/rv_linux_manifest/rv64/rtl/tb_generated_rv64_fw_jump.vhd\"")
        expect (text).contains("runner_testbench = \"/tmp/rv_linux_manifest/rv64/rtl/tb_generated_rv64_boot_info_real_dtb.vhd\"")
        expect (text).contains("runner_testbench = \"/tmp/rv_linux_manifest/rv64/rtl/tb_generated_rv64_sv39.vhd\"")
        expect (text).contains("runner_testbench = \"/tmp/rv_linux_manifest/rv64/rtl/tb_generated_rv64_sv39_fault.vhd\"")
        expect (text).contains("debug_output = \"semi_trigger\"")
        expect (text).contains("authoritative = \"true\"")
        expect (text).contains("authoritative_rtl_provenance = \"simple-compiler-generated\"")
        expect (text).contains("auxiliary_vhdl_provenance = \"emitted-text-vhdl\"")
        expect (text).contains("runner_testbench_provenance = \"emitted-text-vhdl\"")
        expect (text).contains("pure_simple_authoritative_rtl = \"true\"")
        expect (products).contains("product_id = \"xilinx_generic_rv32_linux\"")
        expect (products).contains("product_id = \"xilinx_generic_rv64_linux\"")
        expect (products).contains("boot_script = \"scripts/mlk_s02_100t_generated_linux_boot.shs\"")
        expect (products).contains("expected_markers = \"OpenSBI|Linux version|OF: fdt|Freeing unused kernel memory|init started\"")
        expect (products).contains("validation_kind = \"linux-uart-markers\"")
        expect (products).contains("authoritative_rtl_provenance = \"simple-compiler-generated\"")

describe "RISC-V FPGA Linux RTL generation":
    it "emits dual-architecture generated Linux bundles and the board boot products manifest":
        expect shell("rm -rf '/tmp/simple_rv_linux_fpga_rtl_spec'") == 0
        val result = generate_default_riscv_fpga_rtl_bundle("/tmp/simple_rv_linux_fpga_rtl_spec")
        expect result.is_ok() == true
        val bundle = result.unwrap()

        val rv32_source = read_generated_riscv_fpga_rtl_file("/tmp/simple_rv_linux_fpga_rtl_spec/rv32/rtl/simple_rv32gc_core.spl")
        val rv32_pkg = read_generated_riscv_fpga_rtl_file("/tmp/simple_rv_linux_fpga_rtl_spec/rv32/rtl/rv32i_pkg.vhd")
        val rv32_wrapper = read_generated_riscv_fpga_rtl_file("/tmp/simple_rv_linux_fpga_rtl_spec/rv32/rtl/rv32i_generated_wrapper.vhd")
        val rv32_sidecar = read_generated_riscv_fpga_rtl_file("/tmp/simple_rv_linux_fpga_rtl_spec/rv32/rtl/simple_rv32gc_core.debug.json")
        val rv32_handoff_tb = read_generated_riscv_fpga_rtl_file("/tmp/simple_rv_linux_fpga_rtl_spec/rv32/rtl/tb_generated_rv32_linux_handoff.vhd")
        val rv32_real_dtb_tb = read_generated_riscv_fpga_rtl_file("/tmp/simple_rv_linux_fpga_rtl_spec/rv32/rtl/tb_generated_rv32_boot_info_real_dtb.vhd")
        val rv32_mailbox_tb = read_generated_riscv_fpga_rtl_file("/tmp/simple_rv_linux_fpga_rtl_spec/rv32/rtl/tb_mailbox.vhd")
        val rv64_source = read_generated_riscv_fpga_rtl_file("/tmp/simple_rv_linux_fpga_rtl_spec/rv64/rtl/simple_rv64gc_core.spl")
        val rv64_pkg = read_generated_riscv_fpga_rtl_file("/tmp/simple_rv_linux_fpga_rtl_spec/rv64/rtl/simple_rv64gc_core_pkg.vhd")
        val rv64_core = read_generated_riscv_fpga_rtl_file("/tmp/simple_rv_linux_fpga_rtl_spec/rv64/rtl/simple_rv64gc_core.vhd")
        val rv64_sidecar = read_generated_riscv_fpga_rtl_file("/tmp/simple_rv_linux_fpga_rtl_spec/rv64/rtl/simple_rv64gc_core.debug.json")
        val products = read_generated_riscv_fpga_rtl_file(bundle.board_linux_boot_products_manifest_path)
        val readme = read_generated_riscv_fpga_rtl_file(bundle.bundle_readme_path)

        expect (rv32_source).contains("proof_lane: generated_rv32_linux")
        expect (rv32_source).contains("scope: repo-native RV32GC generated-core Linux lane")
        expect (rv32_pkg).contains("package rv32i_pkg is")
        expect (rv32_pkg).contains("constant OP_LUI    : std_logic_vector(6 downto 0) := \"0110111\";")
        expect (rv32_wrapper).contains("use work.simple_rv32gc_core_pkg.all;")
        expect (rv32_wrapper).contains("u_core : entity work.simple_rv32gc_core")
        expect (rv32_sidecar).contains("\"schemaVersion\": \"riscv_rtl_debuggability_lint/v1\"")
        expect (rv32_sidecar).contains("\"laneId\": \"rv32\"")
        expect (rv32_sidecar).contains("\"proofLane\": \"generated_rv32_linux\"")
        expect (rv32_sidecar).contains("\"generatedFrom\": \"simple_rv32gc_core.spl\"")
        expect (rv32_sidecar).contains("\"rtlDir\": \"/tmp/simple_rv_linux_fpga_rtl_spec/rv32/rtl\"")
        expect (rv32_sidecar).contains("\"shellSummary\": \"generated_rv32_linux shell=none\"")
        expect (rv32_sidecar).contains("\"readiness\": \"contract\"")
        expect (rv32_sidecar).contains("\"linuxBootValidated\": false")
        expect (rv32_sidecar).contains("\"platform\": \"qemu_virt_rv32\"")
        expect (rv32_sidecar).contains("\"linuxPolicy\": \"repo-native-rv32-linux\"")
        expect (rv32_sidecar).contains("\"authoritative\": true")
        expect (rv32_sidecar).contains("\"provenance\": {\"authoritativeRtl\": \"simple-compiler-generated\", \"auxiliaryVhdl\": \"emitted-text-vhdl\", \"runnerTestbenches\": \"emitted-text-vhdl\", \"pureSimpleAuthoritativeRtl\": true}")
        expect (rv32_sidecar).contains("\"abi\": \"ilp32d\"")
        expect (rv32_sidecar).contains("\"mmu\": \"sv32\"")
        expect (rv32_sidecar).contains("\"firmwareMode\": \"fw_jump\"")
        expect (rv32_sidecar).contains("\"acceptanceMarkers\": [\"OpenSBI\", \"Linux version\", \"OF: fdt\", \"Freeing unused kernel memory\", \"init started\"]")
        expect (rv32_sidecar).contains("\"reportMarkers\": [\"PASS_WORD:\", \"A0_LOW32:\", \"A1_LOW32:\", \"UART_BYTES_LOW32:\", \"DTB_PROBE_SEEN:\", \"FINAL_PC_HEX32:\", \"HALT_SEEN:\", \"TRAP_SEEN:\"]")
        expect (rv32_sidecar).contains("\"runnerSuccessMarkers\": {\"tb_generated_rv32_linux_handoff.vhd\":\"GENERATED_RV32_LINUX_HANDOFF: PASS\", \"tb_generated_rv32_boot_info_real_dtb.vhd\":\"GENERATED_RV32_BOOT_INFO_REAL_DTB: PASS\"}")
        expect (rv32_handoff_tb).contains("entity tb_generated_rv32_linux_handoff is")
        expect (rv32_handoff_tb).contains("use work.simple_rv32gc_core_pkg.all;")
        expect (rv32_handoff_tb).contains("u_cpu : entity work.simple_rv32gc_core")
        expect (rv32_handoff_tb).contains("constant BOOT_A1    : std_logic_vector(31 downto 0) := x\"88000000\";")
        expect (rv32_handoff_tb).contains("GENERATED_RV32_LINUX_HANDOFF: PASS")
        expect (rv32_real_dtb_tb).contains("entity tb_generated_rv32_boot_info_real_dtb is")
        expect (rv32_real_dtb_tb).contains("use work.simple_rv32gc_core_pkg.all;")
        expect (rv32_real_dtb_tb).contains("u_cpu : entity work.simple_rv32gc_core")
        expect (rv32_real_dtb_tb).contains("constant DTB_BASE_ADDR  : std_logic_vector(31 downto 0) := x\"88000000\";")
        expect (rv32_real_dtb_tb).contains("report \"DTB_PROBE_SEEN: 1\";")
        expect (rv32_real_dtb_tb).contains("GENERATED_RV32_BOOT_INFO_REAL_DTB: PASS")
        expect rv32_mailbox_tb == ""
        expect (rv64_source).contains("proof_lane: generated_rv64_linux")
        expect (rv64_pkg).contains("-- generated-from: simple_rv64gc_core.spl")
        expect (rv64_pkg).contains("-- proof-lane: generated_rv64_linux shell=none")
        expect (rv64_pkg).contains("-- readiness: contract linux-boot-validated=false")
        expect (rv64_pkg).contains("-- source-map: Rv64Instruction.opcode => imem_rdata(6 downto 0)")
        expect (rv64_core).contains("-- generated-from: simple_rv64gc_core.spl")
        expect (rv64_core).contains("-- proof-lane: generated_rv64_linux shell=none")
        expect (rv64_core).contains("-- readiness: contract linux-boot-validated=false")
        expect (rv64_core).contains("-- source-map: Rv64Instruction.opcode => imem_rdata(6 downto 0)")
        expect (rv64_sidecar).contains("\"schemaVersion\": \"riscv_rtl_debuggability_lint/v1\"")
        expect (rv64_sidecar).contains("\"laneId\": \"rv64\"")
        expect (rv64_sidecar).contains("\"generatedFrom\": \"simple_rv64gc_core.spl\"")
        expect (rv64_sidecar).contains("\"topModule\": \"simple_rv64gc_core\"")
        expect (rv64_sidecar).contains("\"readiness\": \"contract\"")
        expect (rv64_sidecar).contains("\"linuxBootValidated\": false")
        expect (rv64_sidecar).contains("\"platform\": \"qemu_virt_rv64\"")
        expect (rv64_sidecar).contains("\"scope\": \"repo-native RV64GC generated-core Linux lane\"")
        expect (rv64_sidecar).contains("\"linuxPolicy\": \"repo-native-rv64-linux\"")
        expect (rv64_sidecar).contains("\"authoritative\": true")
        expect (rv64_sidecar).contains("\"provenance\": {\"authoritativeRtl\": \"simple-compiler-generated\", \"auxiliaryVhdl\": \"emitted-text-vhdl\", \"runnerTestbenches\": \"emitted-text-vhdl\", \"pureSimpleAuthoritativeRtl\": true}")
        expect (rv64_sidecar).contains("\"abi\": \"lp64d\"")
        expect (rv64_sidecar).contains("\"mmu\": \"sv39\"")
        expect (rv64_sidecar).contains("\"firmwareMode\": \"fw_jump\"")
        expect (rv64_sidecar).contains("\"signal\":\"Rv64Instruction.opcode\",\"slice\":\"imem_rdata(6 downto 0)\"")
        expect (rv64_sidecar).contains("\"reportMarkers\": [\"PASS_WORD:\", \"A0_LOW32:\", \"A1_LOW32:\", \"UART_BYTES_LOW32:\", \"PC_LOW32:\", \"DTB_PROBE_SEEN:\", \"TRAP_EDGE_PC_HEX32\", \"HALT_EDGE_PC_HEX32\", \"HEARTBEAT_PC_HEX32\", \"PROGRESS_PC_HEX32\", \"CHECK_PRIV_MODE_OK:\", \"TRAP_CAUSE_WORD:\", \"TRAP_TVAL_WORD:\", \"CAUSE_WORD:\", \"TVAL_WORD:\"]")
        expect (rv64_sidecar).contains("\"runnerSuccessMarkers\": {\"tb_generated_rv64_linux_handoff.vhd\":\"GENERATED_RV64_LINUX_HANDOFF: PASS\", \"tb_generated_rv64_boot_banner.vhd\":\"GENERATED_RV64_BOOT_BANNER: PASS\", \"tb_generated_rv64_boot_info_dtb.vhd\":\"GENERATED_RV64_BOOT_INFO_DTB: PASS\", \"tb_generated_rv64_fw_jump.vhd\":\"GENERATED_RV64_FW_JUMP: PASS\", \"tb_generated_rv64_boot_info_real_dtb.vhd\":\"GENERATED_RV64_BOOT_INFO_REAL_DTB: PASS\", \"tb_generated_rv64_sv39.vhd\":\"GENERATED_RV64_SV39: PASS\", \"tb_generated_rv64_sv39_fault.vhd\":\"GENERATED_RV64_SV39_FAULT: PASS\"}")
        expect (rv64_sidecar).contains("\"runnerTestbenches\":")
        expect (rv64_sidecar).contains("\"path\":\"/tmp/simple_rv_linux_fpga_rtl_spec/rv64/rtl/tb_generated_rv64_boot_info_dtb.vhd\"")
        expect (rv64_sidecar).contains("\"passMarker\":\"GENERATED_RV64_BOOT_INFO_DTB: PASS\"")
        expect (rv64_sidecar).contains("\"passMarker\":\"GENERATED_RV64_FW_JUMP: PASS\"")
        expect (rv64_sidecar).contains("\"debugOutputs\": [\"semi_trigger\", \"semi_op\", \"semi_param\"")
        expect (rv64_sidecar).contains("\"shellServices\": {\"semihost\": false, \"mailbox\": false}")
        expect (products).contains("product_id = \"xilinx_generic_rv32_linux\"")
        expect (products).contains("product_id = \"xilinx_generic_rv64_linux\"")
        expect (bundle.generated_files).contains("/tmp/simple_rv_linux_fpga_rtl_spec/board_linux_boot_products.sdn")
        expect (readme).contains("per-arch boot products manifest: `board_linux_boot_products.sdn`")
        expect (readme).contains("Within each lane, `authoritative_rtl_root` is marked `simple-compiler-generated` and is the pure-Simple RTL contract.")
        expect (readme).contains("Generated-core runners must compile RTL only from the emitted bundle directories `rv32/rtl` and `rv64/rtl`.")

describe "Generated runner provenance":
    it "keeps the generated RV32 and RV64 Linux runners on emitted bundle roots only":
        val rv32_linux_handoff_runner = rt_file_read_text("src/lib/nogc_async_mut_noalloc/baremetal/ghdl_generated_rv32_linux_handoff_runner.shs")
        val rv32_boot_info_real_dtb_runner = rt_file_read_text("src/lib/nogc_async_mut_noalloc/baremetal/ghdl_generated_rv32_boot_info_real_dtb_runner.shs")
        val rv64_linux_handoff_runner = rt_file_read_text("src/lib/nogc_async_mut_noalloc/baremetal/ghdl_generated_rv64_linux_handoff_runner.shs")
        val rv32_uses_handwritten = rv32_linux_handoff_runner.contains("examples/09_embedded/fpga_riscv/rtl")
        val rv64_uses_handwritten = rv64_linux_handoff_runner.contains("examples/09_embedded/fpga_riscv/rtl")
        expect (rv32_linux_handoff_runner).contains("RTL_DIR=\"$GEN_DIR/rv32/rtl\"")
        expect (rv32_boot_info_real_dtb_runner).contains("RTL_DIR=\"$GEN_DIR/rv32/rtl\"")
        expect (rv64_linux_handoff_runner).contains("RTL_DIR=\"$GEN_DIR/rv64/rtl\"")
        expect rv32_uses_handwritten == false
        expect rv64_uses_handwritten == false