        expect (rv64_core).contains("dmem_wstrb_reg <= std_logic_vector(shift_left(to_unsigned(15, XLEN / 8), to_integer(unsigned(addr_i(2 downto 0)))));")
        expect (rv64_core).contains("dmem_wstrb_reg <= std_logic_vector(to_unsigned(15, XLEN / 8));")
        expect (rv64_core).contains("dmem_wstrb_reg <= (others => '1');")
        expect (rv64_core).contains("signal regs : reg_file_t := (2 => x\"0000000000000FFC\", 10 => x\"0000000000000000\", 11 => x\"0000000088000000\", others => (others => '0'));")
        expect (rv64_core).contains("regs <= (2 => x\"0000000000000FFC\", 10 => x\"0000000000000000\", 11 => x\"0000000088000000\", others => (others => '0'));")
        expect (rv64_core).contains("-- source-map: RiscvIImmediateEncoding.value => imem_rdata(31 downto 20)")
        expect (rv64_core).contains("-- source-map: RiscvUpperImmediateEncoding.high20 => imem_rdata(31 downto 12)")
        expect (rv64_core).contains("-- source-map: RiscvExecuteControlEncoding.funct3 => imem_rdata(14 downto 12)")
