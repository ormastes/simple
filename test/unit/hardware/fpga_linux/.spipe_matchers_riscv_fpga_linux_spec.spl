        expect (rv64_core).contains("case decode_dispatch_class is")
        expect (rv64_core).contains("if decode_next_pc_op = \"01\" and branch_taken then")
        val has_handwritten_funct3_case = rv64_core.contains("case decode_funct3 is")
        expect has_handwritten_funct3_case == false
        val has_handwritten_opcode_case = rv64_core.contains("case imem_rdata(6 downto 0) is")
        expect has_handwritten_opcode_case == false
        expect (rv64_tb).contains("entity tb_generated_rv64_boot_info_dtb is")
        expect (rv64_tb).contains("use work.simple_rv64i_core_pkg.all;")
        expect (rv64_tb).contains("constant DTB_SIZE_BYTES      : integer := 239;")
        expect (rv64_tb).contains("constant DTB_BYTES           : byte_array_t(0 to DTB_SIZE_BYTES - 1) := (")
        expect (rv64_tb).contains("function hex_to_word64(text_value : string) return std_logic_vector is")
        expect (rv64_tb).contains("procedure load_preload_file(")
        expect (rv64_tb).contains("report \"PRELOAD_\" & label_name & \"_DONE_WORDS: \"")
        expect (rv64_tb).contains("u_cpu : entity work.simple_rv64gc_core")
        expect (rv64_tb).contains("report \"GENERATED_RV64_BOOT_INFO_DTB: PASS\";")
        expect (rv64_tb).contains("dtb_probe_addr = BOOT_DTB_ADDR then")
        expect (rv64_fw_jump_tb).contains("entity tb_generated_rv64_fw_jump is")
        expect (rv64_fw_jump_tb).contains("use work.test_program.all;")
        expect (rv64_fw_jump_tb).contains("use work.simple_rv64i_core_pkg.all;")
        expect (rv64_fw_jump_tb).contains("u_cpu : entity work.simple_rv64gc_core")
        expect (rv64_fw_jump_tb).contains("report \"GENERATED_RV64_FW_JUMP: PASS\";")
        expect (rv64_real_dtb_tb).contains("entity tb_generated_rv64_boot_info_real_dtb is")
        expect (rv64_real_dtb_tb).contains("use work.test_program.all;")
        expect (rv64_real_dtb_tb).contains("use work.simple_rv64i_core_pkg.all;")
        expect (rv64_real_dtb_tb).contains("u_cpu : entity work.simple_rv64gc_core")
        expect (rv64_real_dtb_tb).contains("report \"GENERATED_RV64_BOOT_INFO_REAL_DTB: PASS\";")
        expect (rv64_sv39_tb).contains("entity tb_generated_rv64_sv39 is")
        expect (rv64_sv39_tb).contains("use work.test_program.all;")
        expect (rv64_sv39_tb).contains("use work.simple_rv64i_core_pkg.all;")
        expect (rv64_sv39_tb).contains("u_cpu : entity work.simple_rv64gc_core")
        expect (rv64_sv39_tb).contains("report \"GENERATED_RV64_SV39: PASS\";")
        expect (rv64_sv39_fault_tb).contains("entity tb_generated_rv64_sv39_fault is")
        expect (manifest_text).contains("authoritative_rtl_root = \"/tmp/simple_rv64_fpga_rtl_spec/rv32/rtl\"")
        expect (manifest_text).contains("authoritative_rtl_root = \"/tmp/simple_rv64_fpga_rtl_spec/rv64/rtl\"")
        expect manifest_text.contains("examples/09_embedded/fpga_riscv/rtl") == false
        expect (rv64_sv39_fault_tb).contains("use work.test_program.all;")
        expect (rv64_sv39_fault_tb).contains("use work.simple_rv64i_core_pkg.all;")
        expect (rv64_sv39_fault_tb).contains("u_cpu : entity work.simple_rv64gc_core")
        expect (rv64_sv39_fault_tb).contains("report \"GENERATED_RV64_SV39_FAULT: PASS\";")
        expect (manifest_text).contains("platform = \"qemu_virt_rv32\"")
        expect (manifest_text).contains("platform = \"qemu_virt_rv64\"")
        expect (manifest_text).contains("proof_lane = \"generated_rv32_baremetal\"")
        expect (manifest_text).contains("proof_lane = \"generated_rv64_linux\"")
        expect (manifest_text).contains("shell_contract = \"generated_rv32_baremetal shell=semihost+mailbox\"")
        expect (manifest_text).contains("abi = \"ilp32d\"")
        expect (manifest_text).contains("abi = \"lp64d\"")
        expect (manifest_text).contains("firmware_mode = \"supervisor\"")
        expect (manifest_text).contains("arch = \"rv32\"")
        expect (rv64_smoke_tb).contains("entity tb_generated_rv64_smoke is")
        expect (rv64_irq_tb).contains("entity tb_generated_rv64_irq is")
        expect (rv64_linux_handoff_tb).contains("entity tb_generated_rv64_linux_handoff is")
        expect (rv64_boot_banner_tb).contains("entity tb_generated_rv64_boot_banner is")

describe "Generated runner provenance":
    it "keeps generated runner families on emitted rtl roots only":
        val rv32_runner = rt_file_read_text("src/lib/nogc_async_mut_noalloc/baremetal/ghdl_generated_rv32_runner.shs")
        val rv32_semihost_runner = rt_file_read_text("src/lib/nogc_async_mut_noalloc/baremetal/ghdl_generated_rv32_semihost_runner.shs")
        val rv32_mailbox_runner = rt_file_read_text("src/lib/nogc_async_mut_noalloc/baremetal/ghdl_generated_rv32_mailbox_runner.shs")
        val rv32_strobe_runner = rt_file_read_text("src/lib/nogc_async_mut_noalloc/baremetal/ghdl_generated_rv32_strobe_runner.shs")
        val rv64_runner = rt_file_read_text("src/lib/nogc_async_mut_noalloc/baremetal/ghdl_generated_rv64_runner.shs")
        val rv64_irq_runner = rt_file_read_text("src/lib/nogc_async_mut_noalloc/baremetal/ghdl_generated_rv64_irq_runner.shs")
        val rv64_linux_handoff_runner = rt_file_read_text("src/lib/nogc_async_mut_noalloc/baremetal/ghdl_generated_rv64_linux_handoff_runner.shs")
        val rv64_boot_banner_runner = rt_file_read_text("src/lib/nogc_async_mut_noalloc/baremetal/ghdl_generated_rv64_boot_banner_runner.shs")

        expect (rv32_runner).contains("RTL_DIR=\"$GEN_DIR/rv32/rtl\"")
        expect (rv32_semihost_runner).contains("RTL_DIR=\"$GEN_DIR/rv32/rtl\"")
        expect (rv32_mailbox_runner).contains("RTL_DIR=\"$GEN_DIR/rv32/rtl\"")
        expect (rv32_strobe_runner).contains("RTL_DIR=\"$GEN_DIR/rv32/rtl\"")
        expect (rv64_runner).contains("RTL_DIR=\"$GEN_DIR/rv64/rtl\"")
        expect (rv64_irq_runner).contains("RTL_DIR=\"$GEN_DIR/rv64/rtl\"")
        expect (rv64_linux_handoff_runner).contains("RTL_DIR=\"$GEN_DIR/rv64/rtl\"")
        expect (rv64_boot_banner_runner).contains("RTL_DIR=\"$GEN_DIR/rv64/rtl\"")

        expect rv32_runner.contains("examples/09_embedded/fpga_riscv/rtl") == false
        expect rv32_semihost_runner.contains("examples/09_embedded/fpga_riscv/rtl") == false
        expect rv32_mailbox_runner.contains("examples/09_embedded/fpga_riscv/rtl") == false
        expect rv32_strobe_runner.contains("examples/09_embedded/fpga_riscv/rtl") == false
        expect rv64_runner.contains("examples/09_embedded/fpga_riscv/rtl") == false
        expect rv64_irq_runner.contains("examples/09_embedded/fpga_riscv/rtl") == false
        expect rv64_linux_handoff_runner.contains("examples/09_embedded/fpga_riscv/rtl") == false
        expect rv64_boot_banner_runner.contains("examples/09_embedded/fpga_riscv/rtl") == false