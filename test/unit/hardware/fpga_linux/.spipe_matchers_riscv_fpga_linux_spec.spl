        expect (rv64_core).contains("decode_dispatch_class := decode_dispatch_class_bits(3 downto 0);")
        expect (rv64_core).contains("decode_continue_exec := decode_trap_halt_control_bits(0);")
        expect (rv64_core).contains("decode_should_trap := decode_trap_halt_control_bits(1);")
        expect (rv64_core).contains("decode_should_halt := decode_trap_halt_control_bits(2);")
