        expect (rv64_source).contains("bitfield RiscvControlFlowDatapath(u32):")
        expect (rv64_source).contains("bitfield RiscvControlFlowDatapathEncoding(u32):")
        expect (rv64_pkg).contains("constant XLEN : natural := 64")
        expect (rv64_core).contains("-- proof-lane: generated_rv64_linux shell=none")
        expect (rv64_core).contains("-- readiness: contract linux-boot-validated=false")
        expect (rv64_core).contains("dmem_re       : out std_logic;")
        expect (rv64_core).contains("dmem_width    : out std_logic_vector(1 downto 0);")
        expect (rv64_core).contains("dmem_wstrb    : out std_logic_vector((XLEN / 8) - 1 downto 0);")
        expect (rv64_core).contains("dmem_re <= dmem_re_reg;")
        expect (rv64_core).contains("dmem_width <= dmem_width_reg;")
        expect (rv64_core).contains("dmem_wstrb <= dmem_wstrb_reg;")
        expect (rv64_core).contains("dmem_re_reg <= '1';")
        expect (rv64_core).contains("dmem_width_reg <= \"00\";")
        expect (rv64_core).contains("dmem_width_reg <= \"01\";")
        expect (rv64_core).contains("dmem_width_reg <= \"10\";")
        expect (rv64_core).contains("dmem_width_reg <= \"11\";")
        expect (rv64_core).contains("dmem_wstrb_reg <= (others => '0');")
        expect (rv64_core).contains("dmem_wdata_reg <= std_logic_vector(shift_left(unsigned(regs(rs2_i)), to_integer(unsigned(addr_i(2 downto 0))) * 8));")
        expect (rv64_core).contains("dmem_wstrb_reg <= std_logic_vector(shift_left(to_unsigned(1, XLEN / 8), to_integer(unsigned(addr_i(2 downto 0)))));")
        expect (rv64_core).contains("dmem_wstrb_reg <= std_logic_vector(shift_left(to_unsigned(3, XLEN / 8), to_integer(unsigned(addr_i(2 downto 0)))));")
