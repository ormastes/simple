"""
# RISC-V FPGA Linux Preparation Tests

Truthfulness and orchestration tests for the shared RV32/RV64 Linux pipeline.
"""

use std.spec.*

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_file_read_text(path: text) -> text

use hardware.fpga_linux.riscv_fpga_linux.{RiscvReadinessStatus, XilinxBoardProfile, RiscvFpgaLane, create_default_riscv_fpga_linux_manifest, create_default_riscv_fpga_linux_manifest_with_experimental_rv32_linux, generate_default_riscv_fpga_rtl_bundle, generate_default_riscv_fpga_rtl_bundle_with_experimental_rv32_linux, read_generated_riscv_fpga_rtl_file}
use hardware.riscv_common.pkg.riscv_generated_core_pkg.RiscvProofLane

fn shell(command: text) -> i64:
    val (_stdout, _stderr, code) = rt_process_run("/bin/sh", ["-c", command])
    code

describe "RISC-V FPGA Linux board profile":
    it "keeps generic prepare validation separate from concrete hardware boot validation":
        val generic_profile = XilinxBoardProfile.generic()
        expect(generic_profile.validate_for_prepare().len()).to_equal(0)
        expect(generic_profile.validate_for_hardware_boot()).to_contain("xilinx part must be selected before hardware boot")

    it "publishes the MLK-S02-100T board facts used by the generated wrapper":
        val mlk = XilinxBoardProfile.from_id("mlk_s02_100t").ok().unwrap()
        expect(mlk.part).to_equal("xc7a100t-2ffg484i")
        expect(mlk.clock_hz).to_equal(25000000)
        expect(mlk.uart_baud).to_equal(115200)
        expect(mlk.programmer).to_equal("openFPGALoader")

describe "RISC-V FPGA Linux lanes":
    it "defines RV32 and RV64 as repo-native generated Linux lanes":
        val rv32 = RiscvFpgaLane.rv32_default()
        val rv64 = RiscvFpgaLane.rv64_default()
        expect(rv32.readiness_status()).to_equal(RiscvReadinessStatus.Contract)
        expect(rv32.proof_lane()).to_equal(RiscvProofLane.GeneratedRv32Linux)
        expect(rv32.xlen.linux_policy()).to_equal("repo-native-rv32-linux")
        expect(rv32.required_soc_blocks()).to_contain("opensbi-handoff")
        expect(rv32.proof_acceptance_markers()).to_contain("OpenSBI")
        expect(rv32.proof_lane_summary()).to_equal("generated_rv32_linux shell=none")
        expect(rv64.proof_lane()).to_equal(RiscvProofLane.GeneratedRv64Linux)
        expect(rv64.xlen.linux_policy()).to_equal("repo-native-rv64-linux")
        expect(rv64.proof_acceptance_markers()).to_contain("Linux version")

    it "keeps the compatibility experimental manifest alias aligned with the default manifest":
        val manifest = create_default_riscv_fpga_linux_manifest()
        val compat_manifest = create_default_riscv_fpga_linux_manifest_with_experimental_rv32_linux()
        expect(manifest.lanes.len()).to_equal(2)
        expect(compat_manifest.lanes.len()).to_equal(2)
        expect(compat_manifest.readiness_summary()).to_equal(manifest.readiness_summary())

describe "RISC-V FPGA Linux manifest":
    it "emits authoritative RV32 and RV64 Linux metadata plus per-product boot outputs":
        val manifest = create_default_riscv_fpga_linux_manifest()
        val text = manifest.rtl_manifest_text("/tmp/rv_linux_manifest")
        val products = manifest.board_linux_boot_products_manifest_text("/tmp/rv_linux_manifest")
        expect(text).to_contain("proof_lane = \"generated_rv32_linux\"")
        expect(text).to_contain("proof_lane = \"generated_rv64_linux\"")
        expect(text).to_contain("debug_sidecar_file = \"/tmp/rv_linux_manifest/rv32/rtl/simple_rv32gc_core.debug.json\"")
        expect(text).to_contain("debug_sidecar_file = \"/tmp/rv_linux_manifest/rv64/rtl/simple_rv64gc_core.debug.json\"")
        expect(text).to_contain("runner_testbench = \"/tmp/rv_linux_manifest/rv32/rtl/tb_generated_rv32_linux_handoff.vhd\"")
        expect(text).to_contain("runner_testbench = \"/tmp/rv_linux_manifest/rv32/rtl/tb_generated_rv32_boot_info_real_dtb.vhd\"")
        expect(text).to_contain("runner_testbench = \"/tmp/rv_linux_manifest/rv64/rtl/tb_generated_rv64_boot_info_dtb.vhd\"")
        expect(text).to_contain("runner_testbench = \"/tmp/rv_linux_manifest/rv64/rtl/tb_generated_rv64_fw_jump.vhd\"")
        expect(text).to_contain("runner_testbench = \"/tmp/rv_linux_manifest/rv64/rtl/tb_generated_rv64_boot_info_real_dtb.vhd\"")
        expect(text).to_contain("runner_testbench = \"/tmp/rv_linux_manifest/rv64/rtl/tb_generated_rv64_sv39.vhd\"")
        expect(text).to_contain("runner_testbench = \"/tmp/rv_linux_manifest/rv64/rtl/tb_generated_rv64_sv39_fault.vhd\"")
        expect(text).to_contain("debug_output = \"semi_trigger\"")
        expect(text).to_contain("authoritative = \"true\"")
        expect(products).to_contain("product_id = \"xilinx_generic_rv32_linux\"")
        expect(products).to_contain("product_id = \"xilinx_generic_rv64_linux\"")
        expect(products).to_contain("boot_script = \"scripts/mlk_s02_100t_generated_linux_boot.shs\"")
        expect(products).to_contain("expected_markers = \"OpenSBI|Linux version|OF: fdt|Freeing unused kernel memory|init started\"")

describe "RISC-V FPGA Linux RTL generation":
    it "emits dual-architecture generated Linux bundles and the board boot products manifest":
        expect(shell("rm -rf '/tmp/simple_rv_linux_fpga_rtl_spec'")).to_equal(0)
        val result = generate_default_riscv_fpga_rtl_bundle("/tmp/simple_rv_linux_fpga_rtl_spec")
        expect(result.is_ok()).to_equal(true)
        val bundle = result.unwrap()

        val rv32_source = read_generated_riscv_fpga_rtl_file("/tmp/simple_rv_linux_fpga_rtl_spec/rv32/rtl/simple_rv32gc_core.spl")
        val rv32_sidecar = read_generated_riscv_fpga_rtl_file("/tmp/simple_rv_linux_fpga_rtl_spec/rv32/rtl/simple_rv32gc_core.debug.json")
        val rv32_handoff_tb = read_generated_riscv_fpga_rtl_file("/tmp/simple_rv_linux_fpga_rtl_spec/rv32/rtl/tb_generated_rv32_linux_handoff.vhd")
        val rv32_real_dtb_tb = read_generated_riscv_fpga_rtl_file("/tmp/simple_rv_linux_fpga_rtl_spec/rv32/rtl/tb_generated_rv32_boot_info_real_dtb.vhd")
        val rv32_mailbox_tb = read_generated_riscv_fpga_rtl_file("/tmp/simple_rv_linux_fpga_rtl_spec/rv32/rtl/tb_mailbox.vhd")
        val rv64_source = read_generated_riscv_fpga_rtl_file("/tmp/simple_rv_linux_fpga_rtl_spec/rv64/rtl/simple_rv64gc_core.spl")
        val rv64_pkg = read_generated_riscv_fpga_rtl_file("/tmp/simple_rv_linux_fpga_rtl_spec/rv64/rtl/simple_rv64gc_core_pkg.vhd")
        val rv64_core = read_generated_riscv_fpga_rtl_file("/tmp/simple_rv_linux_fpga_rtl_spec/rv64/rtl/simple_rv64gc_core.vhd")
        val rv64_sidecar = read_generated_riscv_fpga_rtl_file("/tmp/simple_rv_linux_fpga_rtl_spec/rv64/rtl/simple_rv64gc_core.debug.json")
        val products = read_generated_riscv_fpga_rtl_file(bundle.board_linux_boot_products_manifest_path)
        val readme = read_generated_riscv_fpga_rtl_file(bundle.bundle_readme_path)

        expect(rv32_source).to_contain("proof_lane: generated_rv32_linux")
        expect(rv32_source).to_contain("scope: repo-native RV32GC generated-core Linux lane")
        expect(rv32_sidecar).to_contain("\"schemaVersion\": \"riscv_rtl_debuggability_lint/v1\"")
        expect(rv32_sidecar).to_contain("\"proofLane\": \"generated_rv32_linux\"")
        expect(rv32_sidecar).to_contain("\"generatedFrom\": \"simple_rv32gc_core.spl\"")
        expect(rv32_sidecar).to_contain("\"rtlDir\": \"/tmp/simple_rv_linux_fpga_rtl_spec/rv32/rtl\"")
        expect(rv32_sidecar).to_contain("\"shellSummary\": \"generated_rv32_linux shell=none\"")
        expect(rv32_sidecar).to_contain("\"readiness\": \"contract\"")
        expect(rv32_sidecar).to_contain("\"linuxBootValidated\": false")
        expect(rv32_sidecar).to_contain("\"platform\": \"qemu_virt_rv32\"")
        expect(rv32_sidecar).to_contain("\"linuxPolicy\": \"repo-native-rv32-linux\"")
        expect(rv32_sidecar).to_contain("\"authoritative\": true")
        expect(rv32_sidecar).to_contain("\"abi\": \"ilp32d\"")
        expect(rv32_sidecar).to_contain("\"mmu\": \"sv32\"")
        expect(rv32_sidecar).to_contain("\"firmwareMode\": \"fw_jump\"")
        expect(rv32_sidecar).to_contain("\"acceptanceMarkers\": [\"OpenSBI\", \"Linux version\", \"OF: fdt\", \"Freeing unused kernel memory\", \"init started\"]")
        expect(rv32_sidecar).to_contain("\"reportMarkers\": [\"PASS_WORD:\", \"A0_LOW32:\", \"A1_LOW32:\", \"UART_BYTES_LOW32:\", \"DTB_PROBE_SEEN:\", \"FINAL_PC_HEX32:\", \"HALT_SEEN:\", \"TRAP_SEEN:\"]")
        expect(rv32_handoff_tb).to_contain("GENERATED_RV32_LINUX_HANDOFF: PASS")
        expect(rv32_real_dtb_tb).to_contain("GENERATED_RV32_BOOT_INFO_REAL_DTB: PASS")
        expect(rv32_mailbox_tb).to_equal("")
        expect(rv64_source).to_contain("proof_lane: generated_rv64_linux")
        expect(rv64_pkg).to_contain("-- generated-from: simple_rv64gc_core.spl")
        expect(rv64_pkg).to_contain("-- proof-lane: generated_rv64_linux shell=none")
        expect(rv64_pkg).to_contain("-- readiness: contract linux-boot-validated=false")
        expect(rv64_pkg).to_contain("-- source-map: Rv64Instruction.opcode => imem_rdata(6 downto 0)")
        expect(rv64_core).to_contain("-- generated-from: simple_rv64gc_core.spl")
        expect(rv64_core).to_contain("-- proof-lane: generated_rv64_linux shell=none")
        expect(rv64_core).to_contain("-- readiness: contract linux-boot-validated=false")
        expect(rv64_core).to_contain("-- source-map: Rv64Instruction.opcode => imem_rdata(6 downto 0)")
        expect(rv64_sidecar).to_contain("\"schemaVersion\": \"riscv_rtl_debuggability_lint/v1\"")
        expect(rv64_sidecar).to_contain("\"generatedFrom\": \"simple_rv64gc_core.spl\"")
        expect(rv64_sidecar).to_contain("\"topModule\": \"simple_rv64gc_core\"")
        expect(rv64_sidecar).to_contain("\"readiness\": \"contract\"")
        expect(rv64_sidecar).to_contain("\"linuxBootValidated\": false")
        expect(rv64_sidecar).to_contain("\"platform\": \"qemu_virt_rv64\"")
        expect(rv64_sidecar).to_contain("\"scope\": \"repo-native RV64GC generated-core Linux lane\"")
        expect(rv64_sidecar).to_contain("\"linuxPolicy\": \"repo-native-rv64-linux\"")
        expect(rv64_sidecar).to_contain("\"authoritative\": true")
        expect(rv64_sidecar).to_contain("\"abi\": \"lp64d\"")
        expect(rv64_sidecar).to_contain("\"mmu\": \"sv39\"")
        expect(rv64_sidecar).to_contain("\"firmwareMode\": \"fw_jump\"")
        expect(rv64_sidecar).to_contain("\"signal\":\"Rv64Instruction.opcode\",\"slice\":\"imem_rdata(6 downto 0)\"")
        expect(rv64_sidecar).to_contain("\"reportMarkers\": [\"PASS_WORD:\", \"A0_LOW32:\", \"A1_LOW32:\", \"UART_BYTES_LOW32:\", \"PC_LOW32:\", \"DTB_PROBE_SEEN:\", \"TRAP_EDGE_PC_HEX32\", \"HALT_EDGE_PC_HEX32\", \"HEARTBEAT_PC_HEX32\", \"PROGRESS_PC_HEX32\", \"CHECK_PRIV_MODE_OK:\", \"TRAP_CAUSE_WORD:\", \"TRAP_TVAL_WORD:\", \"CAUSE_WORD:\", \"TVAL_WORD:\"]")
        expect(rv64_sidecar).to_contain("\"runnerTestbenches\":")
        expect(rv64_sidecar).to_contain("\"path\":\"/tmp/simple_rv_linux_fpga_rtl_spec/rv64/rtl/tb_generated_rv64_boot_info_dtb.vhd\"")
        expect(rv64_sidecar).to_contain("\"passMarker\":\"GENERATED_RV64_BOOT_INFO_DTB: PASS\"")
        expect(rv64_sidecar).to_contain("\"passMarker\":\"GENERATED_RV64_FW_JUMP: PASS\"")
        expect(rv64_sidecar).to_contain("\"debugOutputs\": [\"semi_trigger\", \"semi_op\", \"semi_param\"")
        expect(rv64_sidecar).to_contain("\"shellServices\": {\"semihost\": false, \"mailbox\": false}")
        expect(products).to_contain("product_id = \"xilinx_generic_rv32_linux\"")
        expect(products).to_contain("product_id = \"xilinx_generic_rv64_linux\"")
        expect(bundle.generated_files).to_contain("/tmp/simple_rv_linux_fpga_rtl_spec/board_linux_boot_products.sdn")
        expect(readme).to_contain("per-arch boot products manifest: `board_linux_boot_products.sdn`")
        expect(readme).to_contain("Generated-core runners must compile RTL only from the emitted bundle directories `rv32/rtl` and `rv64/rtl`.")

    it "keeps the compatibility alias on the same RV32 bundle root":
        expect(shell("rm -rf '/tmp/simple_rv_linux_fpga_rtl_compat'")).to_equal(0)
        val result = generate_default_riscv_fpga_rtl_bundle_with_experimental_rv32_linux("/tmp/simple_rv_linux_fpga_rtl_compat")
        expect(result.is_ok()).to_equal(true)
        val manifest_text = read_generated_riscv_fpga_rtl_file("/tmp/simple_rv_linux_fpga_rtl_compat/riscv_fpga_rtl_manifest.sdn")
        val has_legacy_root = manifest_text.contains("rv32_linux/rtl")
        expect(manifest_text).to_contain("authoritative_rtl_root = \"/tmp/simple_rv_linux_fpga_rtl_compat/rv32/rtl\"")
        expect(has_legacy_root).to_equal(false)

describe "Generated runner provenance":
    it "keeps the generated RV32 and RV64 Linux runners on emitted bundle roots only":
        val rv32_linux_handoff_runner = rt_file_read_text("src/lib/nogc_async_mut_noalloc/baremetal/ghdl_generated_rv32_linux_handoff_runner.shs")
        val rv32_boot_info_real_dtb_runner = rt_file_read_text("src/lib/nogc_async_mut_noalloc/baremetal/ghdl_generated_rv32_boot_info_real_dtb_runner.shs")
        val rv64_linux_handoff_runner = rt_file_read_text("src/lib/nogc_async_mut_noalloc/baremetal/ghdl_generated_rv64_linux_handoff_runner.shs")
        val rv32_uses_handwritten = rv32_linux_handoff_runner.contains("examples/09_embedded/fpga_riscv/rtl")
        val rv64_uses_handwritten = rv64_linux_handoff_runner.contains("examples/09_embedded/fpga_riscv/rtl")
        expect(rv32_linux_handoff_runner).to_contain("RTL_DIR=\"$GEN_DIR/rv32/rtl\"")
        expect(rv32_boot_info_real_dtb_runner).to_contain("RTL_DIR=\"$GEN_DIR/rv32/rtl\"")
        expect(rv64_linux_handoff_runner).to_contain("RTL_DIR=\"$GEN_DIR/rv64/rtl\"")
        expect(rv32_uses_handwritten).to_equal(false)
        expect(rv64_uses_handwritten).to_equal(false)
