"""
# RISC-V FPGA Linux Preparation Tests

Pre-hardware tests for the Xilinx board-profiled RV32/RV64 Linux bring-up
contract.
"""

import std.spec

use hardware.fpga_linux.riscv_fpga_linux.{RiscvXlen, XilinxBoardProfile, LinuxArtifactSet, RiscvFpgaLane, FpgaPrepareManifest, create_default_riscv_fpga_linux_manifest, generate_default_riscv_fpga_rtl_bundle, read_generated_riscv_fpga_rtl_file}

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

describe "RISC-V FPGA Linux board profile":
    it "allows the generic Xilinx profile for prepare-only generation":
        val profile = XilinxBoardProfile.generic()
        expect(profile.name).to_equal("xilinx_generic")
        expect(profile.is_generic()).to_equal(true)
        expect(profile.validate_for_prepare().len()).to_equal(0)

    it "blocks hardware boot until the exact part and memory are known":
        val profile = XilinxBoardProfile.generic()
        val errors = profile.validate_for_hardware_boot()
        expect(errors.len()).to_equal(2)
        expect(errors).to_contain("xilinx part must be selected before hardware boot")
        expect(errors).to_contain("memory_size_bytes must be set before hardware boot")

    it "reports invalid profile fields before Vivado generation":
        val profile = XilinxBoardProfile(
            name: "",
            part: "xc7z020clg484-1",
            clock_hz: 0,
            reset_polarity: "floating",
            memory_kind: "sram",
            memory_base: 0x80000000,
            memory_size_bytes: 134217728,
            uart_baud: 0,
            constraints_path: "",
            programmer: "",
            vivado_mode: "gui"
        )
        val errors = profile.validate_for_prepare()
        expect(errors).to_contain("board name is required")
        expect(errors).to_contain("clock_hz must be positive")
        expect(errors).to_contain("reset_polarity must be active-low or active-high")
        expect(errors).to_contain("memory_kind must be ddr or bram")
        expect(errors).to_contain("uart_baud must be positive")
        expect(errors).to_contain("constraints_path is required")
        expect(errors).to_contain("programmer is required")
        expect(errors).to_contain("vivado_mode must be batch")

describe "RISC-V FPGA Linux lanes":
    it "defines RV64 as upstream Linux with Sv39 and OpenSBI handoff":
        val lane = RiscvFpgaLane.rv64_default()
        expect(lane.xlen.to_text()).to_equal("rv64")
        expect(lane.xlen.bits()).to_equal(64)
        expect(lane.xlen.linux_policy()).to_equal("upstream")
        expect(lane.xlen.mmu_mode()).to_equal("sv39")
        expect(lane.required_soc_blocks()).to_contain("sv39-mmu")
        expect(lane.required_soc_blocks()).to_contain("opensbi-handoff")
        expect(lane.expected_boot_markers()).to_contain("OpenSBI")

    it "defines RV32 as experimental Linux with Sv32":
        val lane = RiscvFpgaLane.rv32_default()
        expect(lane.xlen.to_text()).to_equal("rv32")
        expect(lane.xlen.bits()).to_equal(32)
        expect(lane.xlen.linux_policy()).to_equal("experimental")
        expect(lane.xlen.mmu_mode()).to_equal("sv32")
        expect(lane.required_soc_blocks()).to_contain("sv32-mmu")
        expect(lane.expected_boot_markers()).to_contain("rv32-linux-experimental")

    it "requires Linux artifacts before boot validation passes":
        val lane = RiscvFpgaLane.rv64_default()
        val errors = lane.validate_for_linux_boot()
        expect(errors).to_contain("rv64 linux kernel, rootfs, dtb, and toolchain must be configured")
        expect(errors).to_contain("rv64 linux requires OpenSBI or U-Boot firmware")

    it "accepts configured RV64 Linux artifacts":
        val lane = RiscvFpgaLane(
            xlen: RiscvXlen.Rv64,
            top_module: "simple_rv64_linux_soc",
            rtl_dir: "build/fpga/rv64/rtl",
            bootrom_path: "build/fpga/rv64/bootrom.bin",
            linux: LinuxArtifactSet(
                kernel_image: "linux/arch/riscv/boot/Image",
                rootfs_image: "rootfs/rv64.cpio",
                opensbi_image: "opensbi/build/platform/generic/firmware/fw_payload.bin",
                uboot_image: "",
                dtb_path: "build/fpga/rv64/simple.dtb",
                toolchain_prefix: "riscv64-linux-gnu-"
            )
        )
        expect(lane.validate_for_linux_boot().len()).to_equal(0)

describe "RISC-V FPGA Linux manifest":
    it "creates both RV32 and RV64 lanes for Xilinx prepare":
        val manifest = create_default_riscv_fpga_linux_manifest()
        expect(manifest.board.name).to_equal("xilinx_generic")
        expect(manifest.lanes.len()).to_equal(2)
        expect(manifest.validate_for_prepare().len()).to_equal(0)
        expect(manifest.readiness_summary()).to_contain("rv32:experimental:sv32")
        expect(manifest.readiness_summary()).to_contain("rv64:upstream:sv39")

    it "generates a deterministic Vivado TCL plan":
        val manifest = create_default_riscv_fpga_linux_manifest()
        val tcl = manifest.vivado_tcl_plan()
        expect(tcl).to_contain("create_project simple_riscv_fpga")
        expect(tcl).to_contain("-part BOARD_PART_TBD")
        expect(tcl).to_contain("set_property target_language VHDL")
        expect(tcl).to_contain("add_files constraints/xilinx_generic.xdc")
        expect(tcl).to_contain("add_files build/fpga/rv32/rtl")
        expect(tcl).to_contain("add_files build/fpga/rv64/rtl")
        expect(tcl).to_contain("set_property top simple_rv32_linux_soc")
        expect(tcl).to_contain("set_property top simple_rv64_linux_soc")

describe "RISC-V FPGA Linux RTL generation":
    it "emits RV32 and RV64 top-level VHDL bundles":
        val result = generate_default_riscv_fpga_rtl_bundle("/tmp/simple_riscv_fpga_rtl_spec")
        expect(result.is_ok()).to_equal(true)
        val bundle = result.ok().unwrap()
        expect(bundle.generated_files.len()).to_equal(5)

        val rv32_pkg = read_generated_riscv_fpga_rtl_file("/tmp/simple_riscv_fpga_rtl_spec/rv32/rtl/simple_rv32_linux_pkg.vhd")
        val rv32_soc = read_generated_riscv_fpga_rtl_file("/tmp/simple_riscv_fpga_rtl_spec/rv32/rtl/simple_rv32_linux_soc.vhd")
        val rv64_pkg = read_generated_riscv_fpga_rtl_file("/tmp/simple_riscv_fpga_rtl_spec/rv64/rtl/simple_rv64_linux_pkg.vhd")
        val rv64_soc = read_generated_riscv_fpga_rtl_file("/tmp/simple_riscv_fpga_rtl_spec/rv64/rtl/simple_rv64_linux_soc.vhd")
        val manifest_text = read_generated_riscv_fpga_rtl_file(bundle.manifest_path)

        expect(rv32_pkg).to_contain("constant XLEN : natural := 32")
        expect(rv32_pkg).to_contain("constant RESET_VECTOR : xword_t := x\"80000000\"")
        expect(rv32_soc).to_contain("entity simple_rv32_linux_soc is")
        expect(rv32_soc).to_contain("boot_pc_debug : out xword_t")
        expect(rv64_pkg).to_contain("constant XLEN : natural := 64")
        expect(rv64_pkg).to_contain("constant RESET_VECTOR : xword_t := x\"0000000080000000\"")
        expect(rv64_soc).to_contain("entity simple_rv64_linux_soc is")
        expect(rv64_soc).to_contain("pc_reg <= std_logic_vector(unsigned(pc_reg) + to_unsigned(BOOT_STRIDE, XLEN))")
        expect(manifest_text).to_contain("arch = \"rv32\"")
        expect(manifest_text).to_contain("arch = \"rv64\"")
        expect(manifest_text).to_contain("top = \"simple_rv64_linux_soc\"")

    slow_it "generated RV32 and RV64 VHDL analyze with GHDL when available":
        val probe = rt_process_run("which", ["ghdl"])
        if probe[2] != 0:
            return "skip: ghdl not available"
        val result = generate_default_riscv_fpga_rtl_bundle("/tmp/simple_riscv_fpga_rtl_ghdl_spec")
        expect(result.is_ok()).to_equal(true)
        val cmd = "rm -f work-obj08.cf && " +
            "ghdl -a --std=08 /tmp/simple_riscv_fpga_rtl_ghdl_spec/rv32/rtl/simple_rv32_linux_pkg.vhd /tmp/simple_riscv_fpga_rtl_ghdl_spec/rv32/rtl/simple_rv32_linux_soc.vhd && " +
            "ghdl -a --std=08 /tmp/simple_riscv_fpga_rtl_ghdl_spec/rv64/rtl/simple_rv64_linux_pkg.vhd /tmp/simple_riscv_fpga_rtl_ghdl_spec/rv64/rtl/simple_rv64_linux_soc.vhd"
        val analyzed = rt_process_run("/bin/sh", ["-c", cmd])
        expect(analyzed[2]).to_equal(0)
