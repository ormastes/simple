"""
# RISC-V FPGA Linux Preparation Tests

Truthfulness and orchestration tests for the shared RV32/RV64 Linux pipeline.
"""

use std.spec.*

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_file_read_text(path: text) -> text

use hardware.fpga_linux.riscv_fpga_linux.{RiscvReadinessStatus, XilinxBoardProfile, LinuxArtifactSet, RiscvFpgaLane, create_default_riscv_fpga_linux_manifest, create_default_riscv_fpga_linux_manifest_with_experimental_rv32_linux, generate_default_riscv_fpga_rtl_bundle, generate_default_riscv_fpga_rtl_bundle_with_experimental_rv32_linux, read_generated_riscv_fpga_rtl_file}
use hardware.riscv_common.pkg.riscv_generated_core_pkg.RiscvProofLane

fn shell(command: text) -> i64:
    val (_stdout, _stderr, code) = rt_process_run("/bin/sh", ["-c", command])
    code

describe "RISC-V FPGA Linux board profile":
    it "allows the generic Xilinx profile for prepare-only generation":
        val profile = XilinxBoardProfile.generic()
        expect(profile.name).to_equal("xilinx_generic")
        expect(profile.is_generic()).to_equal(true)
        expect(profile.validate_for_prepare().len()).to_equal(0)

    it "blocks hardware boot until the exact part and memory are known":
        val profile = XilinxBoardProfile.generic()
        val errors = profile.validate_for_hardware_boot()
        expect(errors).to_contain("xilinx part must be selected before hardware boot")
        expect(errors).to_contain("memory_size_bytes must be set before hardware boot")

describe "RISC-V FPGA Linux lanes":
    it "defines RV64 as a repo-native QEMU virt Linux contract lane":
        val lane = RiscvFpgaLane.rv64_default()
        expect(lane.xlen.to_text()).to_equal("rv64")
        expect(lane.readiness_status()).to_equal(RiscvReadinessStatus.Contract)
        expect(lane.proof_lane()).to_equal(RiscvProofLane.GeneratedRv64Linux)
        expect(lane.xlen.linux_policy()).to_equal("repo-native-rv64-linux")
        expect(lane.platform_profile.name).to_equal("qemu_virt_rv64")
        expect(lane.linux_profile.abi.to_text()).to_equal("lp64d")
        expect(lane.linux_profile.mmu_mode.to_text()).to_equal("sv39")
        expect(lane.required_soc_blocks()).to_contain("opensbi-handoff")
        expect(lane.required_soc_blocks()).to_contain("generated-core-shell")
        expect(lane.proof_acceptance_markers()).to_contain("OpenSBI")
        expect(lane.expected_boot_markers()).to_contain("Linux version")
        expect(lane.expected_boot_markers()).to_contain("init started")
        expect(lane.proof_lane_summary()).to_equal("generated_rv64_linux shell=none")
        expect(lane.hardware_source_contract_errors().len()).to_equal(0)

    it "defines RV32 as a repo-native generated-core baremetal proof lane":
        val lane = RiscvFpgaLane.rv32_default()
        expect(lane.xlen.to_text()).to_equal("rv32")
        expect(lane.readiness_status()).to_equal(RiscvReadinessStatus.Contract)
        expect(lane.proof_lane()).to_equal(RiscvProofLane.GeneratedRv32Baremetal)
        expect(lane.xlen.linux_policy()).to_equal("repo-native-rv32-baremetal")
        expect(lane.linux_profile.abi.to_text()).to_equal("ilp32d")
        expect(lane.platform_profile.name).to_equal("qemu_virt_rv32")
        expect(lane.linux_profile.mmu_mode.to_text()).to_equal("sv32")
        expect(lane.required_soc_blocks()).to_contain("semihost-shell-service")
        expect(lane.required_soc_blocks()).to_contain("mailbox-shell-service")
        expect(lane.proof_acceptance_markers()).to_contain("mailbox-sentinel")

    it "defines an explicit experimental RV32 Linux lane without changing the default proof lane":
        val lane = RiscvFpgaLane.rv32_linux_experimental()
        expect(lane.xlen.to_text()).to_equal("rv32")
        expect(lane.proof_lane()).to_equal(RiscvProofLane.GeneratedRv32Linux)
        expect(lane.bundle_root_name()).to_equal("rv32_linux")
        expect(lane.linux_policy()).to_equal("experimental-generated-rv32-linux")
        expect(lane.scope_note).to_contain("experimental")
        expect(lane.required_soc_blocks()).to_contain("opensbi-handoff")
        expect(lane.proof_acceptance_markers()).to_contain("Linux version")

    it "requires validation plus boot artifacts before Linux boot claims":
        val lane = RiscvFpgaLane.rv32_default()
        val errors = lane.validate_for_linux_boot()
        expect(errors).to_contain("rv32 readiness must be qemu-boot-validated, rtl-linux-validated, or fpga-validated before claiming Linux boot")
        expect(errors).to_contain("kernel_image is required")
        expect(errors).to_contain("initrd_rootfs is required")
        expect(errors).to_contain("dtb is required")
        expect(errors).to_contain("OpenSBI or U-Boot firmware is required")
        expect(errors).to_contain("rv32 toolchain prefix must be configured")

    it "does not accept configured RV64 artifacts before readiness advances beyond contract":
        val lane = RiscvFpgaLane(
            xlen: RiscvFpgaLane.rv64_default().xlen,
            top_module: "simple_rv64gc_core",
            rtl_dir: "build/fpga/rv64/rtl",
            rtl_sim_backend: "ghdl-vhdl-2008",
            bootrom_path: "build/fpga/rv64/bootrom.bin",
            readiness: RiscvReadinessStatus.Contract,
            linux_profile: RiscvFpgaLane.rv64_default().linux_profile,
            platform_profile: RiscvFpgaLane.rv64_default().platform_profile,
            scope_note: "repo-native RV64GC Linux contract lane",
            linux: LinuxArtifactSet(
                kernel_image: "linux/arch/riscv/boot/Image",
                rootfs_image: "rootfs/rv64.cpio",
                opensbi_image: "opensbi/build/platform/generic/firmware/fw_payload.bin",
                uboot_image: "",
                dtb_path: "build/fpga/rv64/simple.dtb",
                toolchain_prefix: "riscv64-linux-gnu-"
            )
        )
        expect(lane.validate_for_linux_boot()).to_contain("rv64 readiness must be qemu-boot-validated, rtl-linux-validated, or fpga-validated before claiming Linux boot")

describe "RISC-V FPGA Linux manifest":
    it "defaults to dual repo-native RV32/RV64 lanes":
        val manifest = create_default_riscv_fpga_linux_manifest()
        expect(manifest.board.name).to_equal("xilinx_generic")
        expect(manifest.lanes.len()).to_equal(2)
        expect(manifest.validate_for_prepare().len()).to_equal(0)
        expect(manifest.readiness_summary()).to_contain("rv32:contract:qemu_virt_rv32:simple_rv32gc_core:generated_rv32_baremetal")
        expect(manifest.readiness_summary()).to_contain("rv64:contract:qemu_virt_rv64:simple_rv64gc_core:generated_rv64_linux")

    it "adds an opt-in experimental RV32 Linux lane without changing the default manifest":
        val manifest = create_default_riscv_fpga_linux_manifest_with_experimental_rv32_linux()
        expect(manifest.lanes.len()).to_equal(3)
        expect(manifest.readiness_summary()).to_contain("rv32_linux_experimental:contract:qemu_virt_rv32:simple_rv32gc_core:generated_rv32_linux")
        val text = manifest.rtl_manifest_text("/tmp/rv32_linux_manifest")
        expect(text).to_contain("lane_id = \"rv32\"")
        expect(text).to_contain("lane_id = \"rv32_linux_experimental\"")
        expect(text).to_contain("bundle_dir = \"rv32_linux\"")
        expect(text).to_contain("proof_lane = \"generated_rv32_linux\"")
        expect(text).to_contain("linux_policy = \"experimental-generated-rv32-linux\"")
        expect(text).to_contain("authoritative = \"false\"")
        expect(text).to_contain("runner_testbench = \"/tmp/rv32_linux_manifest/rv32_linux/rtl/tb_generated_rv32_linux_handoff.vhd\"")
        expect(text).to_contain("runner_testbench = \"/tmp/rv32_linux_manifest/rv32_linux/rtl/tb_generated_rv32_boot_info_real_dtb.vhd\"")

    it "emits generated RV64 Linux lane metadata in the manifest":
        val manifest = create_default_riscv_fpga_linux_manifest()
        val text = manifest.rtl_manifest_text("/tmp/rv64_linux_manifest")
        expect(text).to_contain("proof_lane = \"generated_rv64_linux\"")
        expect(text).to_contain("shell_contract = \"generated_rv64_linux shell=none\"")
        expect(text).to_contain("firmware_mode = \"fw_jump\"")
        expect(text).to_contain("authoritative_rtl_root = \"/tmp/rv64_linux_manifest/rv32/rtl\"")
        expect(text).to_contain("support_package_file = \"/tmp/rv64_linux_manifest/rv32/rtl/rv32i_pkg.vhd\"")
        expect(text).to_contain("wrapper_file = \"/tmp/rv64_linux_manifest/rv32/rtl/rv32i_generated_wrapper.vhd\"")
        expect(text).to_contain("runner_testbench = \"/tmp/rv64_linux_manifest/rv32/rtl/tb_mailbox.vhd\"")
        expect(text).to_contain("runner_testbench = \"/tmp/rv64_linux_manifest/rv64/rtl/tb_generated_rv64_boot_banner.vhd\"")
        expect(text.contains("examples/09_embedded/fpga_riscv/rtl")).to_equal(false)

    it "generates a deterministic Vivado TCL plan from both lanes":
        val manifest = create_default_riscv_fpga_linux_manifest()
        val tcl = manifest.vivado_tcl_plan()
        expect(tcl).to_contain("create_project simple_riscv_fpga")
        expect(tcl).to_contain("-part BOARD_PART_TBD")
        expect(tcl).to_contain("add_files constraints/xilinx_generic.xdc")
        expect(tcl).to_contain("add_files build/fpga/rv32/rtl")
        expect(tcl).to_contain("add_files build/fpga/rv64/rtl")
        expect(tcl).to_contain("set_property top simple_rv64gc_core")

describe "RISC-V FPGA Linux RTL generation":
    it "emits dual-architecture bundles by default":
        expect(shell("rm -rf '/tmp/simple_rv64_fpga_rtl_spec'")).to_equal(0)
        val result = generate_default_riscv_fpga_rtl_bundle("/tmp/simple_rv64_fpga_rtl_spec")
        expect(result.is_ok()).to_equal(true)
        val bundle = result.unwrap()

        val rv32_source = read_generated_riscv_fpga_rtl_file("/tmp/simple_rv64_fpga_rtl_spec/rv32/rtl/simple_rv32gc_core.spl")
        val rv32_support_pkg = read_generated_riscv_fpga_rtl_file("/tmp/simple_rv64_fpga_rtl_spec/rv32/rtl/rv32i_pkg.vhd")
        val rv32_wrapper = read_generated_riscv_fpga_rtl_file("/tmp/simple_rv64_fpga_rtl_spec/rv32/rtl/rv32i_generated_wrapper.vhd")
        val rv32_smoke_tb = read_generated_riscv_fpga_rtl_file("/tmp/simple_rv64_fpga_rtl_spec/rv32/rtl/tb_generated_rv32_smoke.vhd")
        val rv32_strobe_tb = read_generated_riscv_fpga_rtl_file("/tmp/simple_rv64_fpga_rtl_spec/rv32/rtl/tb_generated_rv32_strobe.vhd")
        val rv32_semihost_tb = read_generated_riscv_fpga_rtl_file("/tmp/simple_rv64_fpga_rtl_spec/rv32/rtl/tb_semi_run.vhd")
        val rv32_mailbox_tb = read_generated_riscv_fpga_rtl_file("/tmp/simple_rv64_fpga_rtl_spec/rv32/rtl/tb_mailbox.vhd")
        val rv64_source = read_generated_riscv_fpga_rtl_file("/tmp/simple_rv64_fpga_rtl_spec/rv64/rtl/simple_rv64gc_core.spl")
        val rv64_pkg = read_generated_riscv_fpga_rtl_file("/tmp/simple_rv64_fpga_rtl_spec/rv64/rtl/simple_rv64gc_core_pkg.vhd")
        val rv64_core = read_generated_riscv_fpga_rtl_file("/tmp/simple_rv64_fpga_rtl_spec/rv64/rtl/simple_rv64gc_core.vhd")
        val rv64_smoke_tb = read_generated_riscv_fpga_rtl_file("/tmp/simple_rv64_fpga_rtl_spec/rv64/rtl/tb_generated_rv64_smoke.vhd")
        val rv64_irq_tb = read_generated_riscv_fpga_rtl_file("/tmp/simple_rv64_fpga_rtl_spec/rv64/rtl/tb_generated_rv64_irq.vhd")
        val rv64_linux_handoff_tb = read_generated_riscv_fpga_rtl_file("/tmp/simple_rv64_fpga_rtl_spec/rv64/rtl/tb_generated_rv64_linux_handoff.vhd")
        val rv64_boot_banner_tb = read_generated_riscv_fpga_rtl_file("/tmp/simple_rv64_fpga_rtl_spec/rv64/rtl/tb_generated_rv64_boot_banner.vhd")
        val rv64_fw_jump_tb = read_generated_riscv_fpga_rtl_file("/tmp/simple_rv64_fpga_rtl_spec/rv64/rtl/tb_generated_rv64_fw_jump.vhd")
        val rv64_real_dtb_tb = read_generated_riscv_fpga_rtl_file("/tmp/simple_rv64_fpga_rtl_spec/rv64/rtl/tb_generated_rv64_boot_info_real_dtb.vhd")
        val rv64_sv39_tb = read_generated_riscv_fpga_rtl_file("/tmp/simple_rv64_fpga_rtl_spec/rv64/rtl/tb_generated_rv64_sv39.vhd")
        val rv64_sv39_fault_tb = read_generated_riscv_fpga_rtl_file("/tmp/simple_rv64_fpga_rtl_spec/rv64/rtl/tb_generated_rv64_sv39_fault.vhd")
        val rv64_tb = read_generated_riscv_fpga_rtl_file("/tmp/simple_rv64_fpga_rtl_spec/rv64/rtl/tb_generated_rv64_boot_info_dtb.vhd")
        val manifest_text = read_generated_riscv_fpga_rtl_file("/tmp/simple_rv64_fpga_rtl_spec/riscv_fpga_rtl_manifest.sdn")

        expect(rv32_source != "").to_equal(true)
        expect(rv32_support_pkg != "").to_equal(true)
        expect(rv32_wrapper != "").to_equal(true)
        expect(rv32_smoke_tb != "").to_equal(true)
        expect(rv32_strobe_tb != "").to_equal(true)
        expect(rv32_semihost_tb != "").to_equal(true)
        expect(rv32_mailbox_tb != "").to_equal(true)
        expect(rv64_source != "").to_equal(true)
        expect(rv64_pkg != "").to_equal(true)
        expect(rv64_core != "").to_equal(true)
        expect(rv64_smoke_tb != "").to_equal(true)
        expect(rv64_irq_tb != "").to_equal(true)
        expect(rv64_linux_handoff_tb != "").to_equal(true)
        expect(rv64_boot_banner_tb != "").to_equal(true)
        expect(rv64_fw_jump_tb != "").to_equal(true)
        expect(rv64_real_dtb_tb != "").to_equal(true)
        expect(rv64_sv39_tb != "").to_equal(true)
        expect(rv64_sv39_fault_tb != "").to_equal(true)
        expect(rv64_tb != "").to_equal(true)
        expect(manifest_text != "").to_equal(true)
        expect(bundle.generated_files).to_contain("/tmp/simple_rv64_fpga_rtl_spec/rv32/rtl/rv32i_pkg.vhd")
        expect(bundle.generated_files).to_contain("/tmp/simple_rv64_fpga_rtl_spec/rv32/rtl/rv32i_generated_wrapper.vhd")
        expect(bundle.generated_files).to_contain("/tmp/simple_rv64_fpga_rtl_spec/rv32/rtl/tb_generated_rv32_smoke.vhd")
        expect(bundle.generated_files).to_contain("/tmp/simple_rv64_fpga_rtl_spec/rv32/rtl/tb_generated_rv32_strobe.vhd")
        expect(bundle.generated_files).to_contain("/tmp/simple_rv64_fpga_rtl_spec/rv32/rtl/tb_semi_run.vhd")
        expect(bundle.generated_files).to_contain("/tmp/simple_rv64_fpga_rtl_spec/rv32/rtl/tb_mailbox.vhd")
        expect(bundle.generated_files).to_contain("/tmp/simple_rv64_fpga_rtl_spec/rv64/rtl/tb_generated_rv64_smoke.vhd")
        expect(bundle.generated_files).to_contain("/tmp/simple_rv64_fpga_rtl_spec/rv64/rtl/tb_generated_rv64_irq.vhd")
        expect(bundle.generated_files).to_contain("/tmp/simple_rv64_fpga_rtl_spec/rv64/rtl/tb_generated_rv64_linux_handoff.vhd")
        expect(bundle.generated_files).to_contain("/tmp/simple_rv64_fpga_rtl_spec/rv64/rtl/tb_generated_rv64_boot_banner.vhd")
        expect(bundle.generated_files).to_contain("/tmp/simple_rv64_fpga_rtl_spec/rv64/rtl/tb_generated_rv64_fw_jump.vhd")
        expect(bundle.generated_files).to_contain("/tmp/simple_rv64_fpga_rtl_spec/rv64/rtl/tb_generated_rv64_boot_info_real_dtb.vhd")
        expect(bundle.generated_files).to_contain("/tmp/simple_rv64_fpga_rtl_spec/rv64/rtl/tb_generated_rv64_sv39.vhd")
        expect(bundle.generated_files).to_contain("/tmp/simple_rv64_fpga_rtl_spec/rv64/rtl/tb_generated_rv64_sv39_fault.vhd")
        expect(bundle.generated_files).to_contain("/tmp/simple_rv64_fpga_rtl_spec/rv64/rtl/tb_generated_rv64_boot_info_dtb.vhd")
        expect(rv32_source).to_contain("bitfield Rv32Instruction(u32):")
        expect(rv32_source).to_contain("platform: qemu_virt_rv32")
        expect(rv32_source).to_contain("proof_lane: generated_rv32_baremetal")
        expect(rv32_source).to_contain("scope: repo-native RV32GC generated-core baremetal lane")
        expect(rv32_support_pkg).to_contain("package rv32i_pkg is")
        expect(rv32_wrapper).to_contain("entity rv32i_core is")
        expect(rv32_wrapper).to_contain("entity work.simple_rv32gc_core")
        expect(rv32_semihost_tb).to_contain("entity tb_semi_run is")
        expect(rv32_mailbox_tb).to_contain("entity tb_mailbox is")
        expect(rv64_source).to_contain("bitfield Rv64Instruction(u32):")
        expect(rv64_source).to_contain("platform: qemu_virt_rv64")
        expect(rv64_source).to_contain("proof_lane: generated_rv64_linux")
        expect(rv64_source).to_contain("scope: repo-native RV64GC generated-core Linux lane")
        expect(rv64_source).to_contain("fn simple_rv64gc_core_decode_writeback")
        expect(rv64_source).to_contain("fn simple_rv64gc_core_decode_i_immediate")
        expect(rv64_source).to_contain("fn simple_rv64gc_core_decode_upper_immediate")
        expect(rv64_source).to_contain("fn simple_rv64gc_core_decode_execute_control")
        expect(rv64_source).to_contain("fn simple_rv64gc_core_decode_execute_datapath")
        expect(rv64_source).to_contain("fn simple_rv64gc_core_decode_branch_datapath")
        expect(rv64_source).to_contain("fn simple_rv64gc_core_decode_control_flow_datapath")
        expect(rv64_source).to_contain("fn simple_rv64gc_core_decode_memory_access_control")
        expect(rv64_source).to_contain("fn simple_rv64gc_core_decode_dispatch_class")
        expect(rv64_source).to_contain("fn simple_rv64gc_core_decode_trap_halt_control")
        expect(rv64_source).to_contain("bitfield RiscvDispatchClass(u32):")
        expect(rv64_source).to_contain("bitfield RiscvTrapHaltControl(u32):")
        expect(rv64_source).to_contain("control.continue_exec = 1 as u32")
        expect(rv64_source).to_contain("if addr_i(0) = '1' then")
        expect(rv64_source).to_contain("if addr_i(1 downto 0) /= \"00\" then")
        expect(rv64_source).to_contain("if addr_i(2 downto 0) /= \"000\" then")
        expect(rv64_source).to_contain("bitfield RiscvExecuteDatapath(u32):")
        expect(rv64_source).to_contain("bitfield RiscvExecuteDatapathEncoding(u32):")
        expect(rv64_source).to_contain("bitfield RiscvBranchDatapath(u32):")
        expect(rv64_source).to_contain("bitfield RiscvBranchDatapathEncoding(u32):")
        expect(rv64_source).to_contain("bitfield RiscvControlFlowDatapath(u32):")
        expect(rv64_source).to_contain("bitfield RiscvControlFlowDatapathEncoding(u32):")
        expect(rv64_pkg).to_contain("constant XLEN : natural := 64")
        expect(rv64_core).to_contain("-- proof-lane: generated_rv64_linux shell=none")
        expect(rv64_core).to_contain("-- readiness: contract linux-boot-validated=false")
        expect(rv64_core).to_contain("dmem_re       : out std_logic;")
        expect(rv64_core).to_contain("dmem_width    : out std_logic_vector(1 downto 0);")
        expect(rv64_core).to_contain("dmem_wstrb    : out std_logic_vector((XLEN / 8) - 1 downto 0);")
        expect(rv64_core).to_contain("dmem_re <= dmem_re_reg;")
        expect(rv64_core).to_contain("dmem_width <= dmem_width_reg;")
        expect(rv64_core).to_contain("dmem_wstrb <= dmem_wstrb_reg;")
        expect(rv64_core).to_contain("dmem_re_reg <= '1';")
        expect(rv64_core).to_contain("dmem_width_reg <= \"00\";")
        expect(rv64_core).to_contain("dmem_width_reg <= \"01\";")
        expect(rv64_core).to_contain("dmem_width_reg <= \"10\";")
        expect(rv64_core).to_contain("dmem_width_reg <= \"11\";")
        expect(rv64_core).to_contain("dmem_wstrb_reg <= (others => '0');")
        expect(rv64_core).to_contain("dmem_wdata_reg <= std_logic_vector(shift_left(unsigned(regs(rs2_i)), to_integer(unsigned(addr_i(2 downto 0))) * 8));")
        expect(rv64_core).to_contain("dmem_wstrb_reg <= std_logic_vector(shift_left(to_unsigned(1, XLEN / 8), to_integer(unsigned(addr_i(2 downto 0)))));")
        expect(rv64_core).to_contain("dmem_wstrb_reg <= std_logic_vector(shift_left(to_unsigned(3, XLEN / 8), to_integer(unsigned(addr_i(2 downto 0)))));")
        expect(rv64_core).to_contain("shift_right(unsigned(dmem_rdata), to_integer(unsigned(addr_i(2 downto 0))) * 8)")
        expect(rv64_core).to_contain("dmem_wstrb_reg <= std_logic_vector(shift_left(to_unsigned(15, XLEN / 8), to_integer(unsigned(addr_i(2 downto 0)))));")
        expect(rv64_core).to_contain("dmem_wstrb_reg <= std_logic_vector(to_unsigned(15, XLEN / 8));")
        expect(rv64_core).to_contain("dmem_wstrb_reg <= (others => '1');")
        expect(rv64_core).to_contain("signal regs : reg_file_t := (2 => x\"0000000000000FFC\", 10 => x\"0000000000000000\", 11 => x\"0000000088000000\", others => (others => '0'));")
        expect(rv64_core).to_contain("regs <= (2 => x\"0000000000000FFC\", 10 => x\"0000000000000000\", 11 => x\"0000000088000000\", others => (others => '0'));")
        expect(rv64_core).to_contain("-- source-map: RiscvIImmediateEncoding.value => imem_rdata(31 downto 20)")
        expect(rv64_core).to_contain("-- source-map: RiscvUpperImmediateEncoding.high20 => imem_rdata(31 downto 12)")
        expect(rv64_core).to_contain("-- source-map: RiscvExecuteControlEncoding.funct3 => imem_rdata(14 downto 12)")
        expect(rv64_core).to_contain("-- source-map: RiscvExecuteControlEncoding.bit30 => imem_rdata(30 downto 30)")
        expect(rv64_core).to_contain("-- source-map: RiscvExecuteDatapathEncoding.opcode => imem_rdata(6 downto 0)")
        expect(rv64_core).to_contain("-- source-map: RiscvExecuteDatapathEncoding.funct3 => imem_rdata(14 downto 12)")
        expect(rv64_core).to_contain("-- source-map: RiscvExecuteDatapathEncoding.bit30 => imem_rdata(30 downto 30)")
        expect(rv64_core).to_contain("-- source-map: RiscvBranchDatapathEncoding.opcode => imem_rdata(6 downto 0)")
        expect(rv64_core).to_contain("-- source-map: RiscvBranchDatapathEncoding.funct3 => imem_rdata(14 downto 12)")
        expect(rv64_core).to_contain("-- source-map: RiscvControlFlowDatapathEncoding.opcode => imem_rdata(6 downto 0)")
        expect(rv64_core).to_contain("-- source-map: RiscvMemoryAccessControlEncoding.funct3 => imem_rdata(14 downto 12)")
        expect(rv64_core).to_contain("-- source-map: RiscvDispatchClassEncoding.opcode => imem_rdata(6 downto 0)")
        expect(rv64_core).to_contain("-- source-map: RiscvTrapHaltControlEncoding.opcode => imem_rdata(6 downto 0)")
        expect(rv64_core).to_contain("variable decode_execute_datapath_bits : std_logic_vector(31 downto 0);")
        expect(rv64_core).to_contain("variable decode_branch_datapath_bits : std_logic_vector(31 downto 0);")
