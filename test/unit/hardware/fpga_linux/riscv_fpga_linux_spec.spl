"""
# RISC-V FPGA Linux Preparation Tests

Truthfulness and orchestration tests for the shared RV32/RV64 Linux pipeline.
"""

import std.spec

use hardware.fpga_linux.riscv_fpga_linux.{RiscvReadinessStatus, XilinxBoardProfile, LinuxArtifactSet, RiscvFpgaLane, create_default_riscv_fpga_linux_manifest, generate_default_riscv_fpga_rtl_bundle, read_generated_riscv_fpga_rtl_file}

describe "RISC-V FPGA Linux board profile":
    it "allows the generic Xilinx profile for prepare-only generation":
        val profile = XilinxBoardProfile.generic()
        expect(profile.name).to_equal("xilinx_generic")
        expect(profile.is_generic()).to_equal(true)
        expect(profile.validate_for_prepare().len()).to_equal(0)

    it "blocks hardware boot until the exact part and memory are known":
        val profile = XilinxBoardProfile.generic()
        val errors = profile.validate_for_hardware_boot()
        expect(errors).to_contain("xilinx part must be selected before hardware boot")
        expect(errors).to_contain("memory_size_bytes must be set before hardware boot")

describe "RISC-V FPGA Linux lanes":
    it "defines RV64 as a repo-native QEMU virt Linux contract lane":
        val lane = RiscvFpgaLane.rv64_default()
        expect(lane.xlen.to_text()).to_equal("rv64")
        expect(lane.readiness_status()).to_equal(RiscvReadinessStatus.Contract)
        expect(lane.xlen.linux_policy()).to_equal("repo-native-rv64-linux")
        expect(lane.platform_profile.name).to_equal("qemu_virt_rv64")
        expect(lane.linux_profile.abi.to_text()).to_equal("lp64d")
        expect(lane.linux_profile.mmu_mode.to_text()).to_equal("sv39")
        expect(lane.required_soc_blocks()).to_contain("opensbi-handoff")
        expect(lane.expected_boot_markers()).to_contain("OpenSBI")
        expect(lane.hardware_source_contract_errors().len()).to_equal(0)

    it "defines RV32 as a repo-native QEMU virt Linux contract lane":
        val lane = RiscvFpgaLane.rv32_default()
        expect(lane.xlen.to_text()).to_equal("rv32")
        expect(lane.readiness_status()).to_equal(RiscvReadinessStatus.Contract)
        expect(lane.xlen.linux_policy()).to_equal("repo-native-rv32-linux")
        expect(lane.linux_profile.abi.to_text()).to_equal("ilp32d")
        expect(lane.platform_profile.name).to_equal("qemu_virt_rv32")
        expect(lane.linux_profile.mmu_mode.to_text()).to_equal("sv32")
        expect(lane.expected_boot_markers()).to_contain("OpenSBI")

    it "requires validation plus boot artifacts before Linux boot claims":
        val lane = RiscvFpgaLane.rv32_default()
        val errors = lane.validate_for_linux_boot()
        expect(errors).to_contain("rv32 readiness must be qemu-boot-validated, rtl-linux-validated, or fpga-validated before claiming Linux boot")
        expect(errors).to_contain("kernel_image is required")
        expect(errors).to_contain("initrd_rootfs is required")
        expect(errors).to_contain("dtb is required")
        expect(errors).to_contain("OpenSBI or U-Boot firmware is required")
        expect(errors).to_contain("rv32 toolchain prefix must be configured")

    it "does not accept configured RV64 artifacts before readiness advances beyond contract":
        val lane = RiscvFpgaLane(
            xlen: RiscvFpgaLane.rv64_default().xlen,
            top_module: "simple_rv64gc_core",
            rtl_dir: "build/fpga/rv64/rtl",
            rtl_sim_backend: "ghdl-vhdl-2008",
            bootrom_path: "build/fpga/rv64/bootrom.bin",
            readiness: RiscvReadinessStatus.Contract,
            linux_profile: RiscvFpgaLane.rv64_default().linux_profile,
            platform_profile: RiscvFpgaLane.rv64_default().platform_profile,
            scope_note: "repo-native RV64GC Linux contract lane",
            linux: LinuxArtifactSet(
                kernel_image: "linux/arch/riscv/boot/Image",
                rootfs_image: "rootfs/rv64.cpio",
                opensbi_image: "opensbi/build/platform/generic/firmware/fw_payload.bin",
                uboot_image: "",
                dtb_path: "build/fpga/rv64/simple.dtb",
                toolchain_prefix: "riscv64-linux-gnu-"
            )
        )
        expect(lane.validate_for_linux_boot()).to_contain("rv64 readiness must be qemu-boot-validated, rtl-linux-validated, or fpga-validated before claiming Linux boot")

describe "RISC-V FPGA Linux manifest":
    it "defaults to dual repo-native RV32/RV64 lanes":
        val manifest = create_default_riscv_fpga_linux_manifest()
        expect(manifest.board.name).to_equal("xilinx_generic")
        expect(manifest.lanes.len()).to_equal(2)
        expect(manifest.validate_for_prepare().len()).to_equal(0)
        expect(manifest.readiness_summary()).to_contain("rv32:contract:qemu_virt_rv32:simple_rv32gc_core")
        expect(manifest.readiness_summary()).to_contain("rv64:contract:qemu_virt_rv64:simple_rv64gc_core")

    it "generates a deterministic Vivado TCL plan from both lanes":
        val manifest = create_default_riscv_fpga_linux_manifest()
        val tcl = manifest.vivado_tcl_plan()
        expect(tcl).to_contain("create_project simple_riscv_fpga")
        expect(tcl).to_contain("-part BOARD_PART_TBD")
        expect(tcl).to_contain("add_files constraints/xilinx_generic.xdc")
        expect(tcl).to_contain("add_files build/fpga/rv32/rtl")
        expect(tcl).to_contain("add_files build/fpga/rv64/rtl")
        expect(tcl).to_contain("set_property top simple_rv64gc_core")

describe "RISC-V FPGA Linux RTL generation":
    it "emits dual-architecture bundles by default":
        val result = generate_default_riscv_fpga_rtl_bundle("/tmp/simple_rv64_fpga_rtl_spec")
        expect(result.is_ok()).to_equal(true)
        val bundle = result.ok().unwrap()
        expect(bundle.generated_files.len()).to_equal(7)

        val rv32_source = read_generated_riscv_fpga_rtl_file("/tmp/simple_rv64_fpga_rtl_spec/rv32/rtl/simple_rv32gc_core.spl")
        val rv64_source = read_generated_riscv_fpga_rtl_file("/tmp/simple_rv64_fpga_rtl_spec/rv64/rtl/simple_rv64gc_core.spl")
        val rv64_pkg = read_generated_riscv_fpga_rtl_file("/tmp/simple_rv64_fpga_rtl_spec/rv64/rtl/simple_rv64gc_core_pkg.vhd")
        val rv64_core = read_generated_riscv_fpga_rtl_file("/tmp/simple_rv64_fpga_rtl_spec/rv64/rtl/simple_rv64gc_core.vhd")
        val manifest_text = read_generated_riscv_fpga_rtl_file(bundle.manifest_path)

        expect(rv32_source).to_contain("bitfield Rv32Instruction(u32):")
        expect(rv32_source).to_contain("platform: qemu_virt_rv32")
        expect(rv32_source).to_contain("scope: repo-native RV32GC Linux contract lane")
        expect(rv64_source).to_contain("bitfield Rv64Instruction(u32):")
        expect(rv64_source).to_contain("platform: qemu_virt_rv64")
        expect(rv64_source).to_contain("scope: repo-native RV64GC Linux contract lane")
        expect(rv64_source).to_contain("fn simple_rv64gc_core_decode_writeback")
        expect(rv64_source).to_contain("fn simple_rv64gc_core_decode_i_immediate")
        expect(rv64_source).to_contain("fn simple_rv64gc_core_decode_upper_immediate")
        expect(rv64_source).to_contain("fn simple_rv64gc_core_decode_execute_control")
        expect(rv64_source).to_contain("fn simple_rv64gc_core_decode_memory_access_control")
        expect(rv64_source).to_contain("if decode_memory_funct3 = \"001\" or decode_memory_funct3 = \"101\" then")
        expect(rv64_source).to_contain("if addr_i(1 downto 0) /= \"00\" then")
        expect(rv64_source).to_contain("if addr_i(2 downto 0) /= \"000\" then")
        expect(rv64_pkg).to_contain("constant XLEN : natural := 64")
        expect(rv64_core).to_contain("-- readiness: contract linux-boot-validated=false")
        expect(rv64_core).to_contain("-- source-map: RiscvIImmediateEncoding.value => imem_rdata(31 downto 20)")
        expect(rv64_core).to_contain("-- source-map: RiscvUpperImmediateEncoding.high20 => imem_rdata(31 downto 12)")
        expect(rv64_core).to_contain("-- source-map: RiscvExecuteControlEncoding.funct3 => imem_rdata(14 downto 12)")
        expect(rv64_core).to_contain("-- source-map: RiscvExecuteControlEncoding.bit30 => imem_rdata(30 downto 30)")
        expect(rv64_core).to_contain("-- source-map: RiscvMemoryAccessControlEncoding.funct3 => imem_rdata(14 downto 12)")
        expect(manifest_text).to_contain("platform = \"qemu_virt_rv32\"")
        expect(manifest_text).to_contain("platform = \"qemu_virt_rv64\"")
        expect(manifest_text).to_contain("abi = \"ilp32d\"")
        expect(manifest_text).to_contain("abi = \"lp64d\"")
        expect(manifest_text).to_contain("firmware_mode = \"supervisor\"")
        expect(manifest_text).to_contain("arch = \"rv32\"")
