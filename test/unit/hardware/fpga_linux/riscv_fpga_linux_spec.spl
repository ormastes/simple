describe "Generated runner provenance":
    it "keeps generated runner families on emitted rtl roots only":
        val rv32_runner = rt_file_read_text("src/lib/nogc_async_mut_noalloc/baremetal/ghdl_generated_rv32_runner.shs")
        val rv32_semihost_runner = rt_file_read_text("src/lib/nogc_async_mut_noalloc/baremetal/ghdl_generated_rv32_semihost_runner.shs")
        val rv32_mailbox_runner = rt_file_read_text("src/lib/nogc_async_mut_noalloc/baremetal/ghdl_generated_rv32_mailbox_runner.shs")
        val rv32_strobe_runner = rt_file_read_text("src/lib/nogc_async_mut_noalloc/baremetal/ghdl_generated_rv32_strobe_runner.shs")
        val rv32_linux_handoff_runner = rt_file_read_text("src/lib/nogc_async_mut_noalloc/baremetal/ghdl_generated_rv32_linux_handoff_runner.shs")
        val rv32_boot_info_real_dtb_runner = rt_file_read_text("src/lib/nogc_async_mut_noalloc/baremetal/ghdl_generated_rv32_boot_info_real_dtb_runner.shs")
        val rv64_runner = rt_file_read_text("src/lib/nogc_async_mut_noalloc/baremetal/ghdl_generated_rv64_runner.shs")
        val rv64_irq_runner = rt_file_read_text("src/lib/nogc_async_mut_noalloc/baremetal/ghdl_generated_rv64_irq_runner.shs")
        val rv64_linux_handoff_runner = rt_file_read_text("src/lib/nogc_async_mut_noalloc/baremetal/ghdl_generated_rv64_linux_handoff_runner.shs")
        val rv64_boot_banner_runner = rt_file_read_text("src/lib/nogc_async_mut_noalloc/baremetal/ghdl_generated_rv64_boot_banner_runner.shs")

        expect(rv32_runner).to_contain("RTL_DIR=\"$GEN_DIR/rv32/rtl\"")
        expect(rv32_semihost_runner).to_contain("RTL_DIR=\"$GEN_DIR/rv32/rtl\"")
        expect(rv32_mailbox_runner).to_contain("RTL_DIR=\"$GEN_DIR/rv32/rtl\"")
        expect(rv32_strobe_runner).to_contain("RTL_DIR=\"$GEN_DIR/rv32/rtl\"")
        expect(rv32_linux_handoff_runner).to_contain("RTL_DIR=\"$GEN_DIR/rv32_linux/rtl\"")
        expect(rv32_boot_info_real_dtb_runner).to_contain("RTL_DIR=\"$GEN_DIR/rv32_linux/rtl\"")
        expect(rv64_runner).to_contain("RTL_DIR=\"$GEN_DIR/rv64/rtl\"")
        expect(rv64_irq_runner).to_contain("RTL_DIR=\"$GEN_DIR/rv64/rtl\"")
        expect(rv64_linux_handoff_runner).to_contain("RTL_DIR=\"$GEN_DIR/rv64/rtl\"")
        expect(rv64_boot_banner_runner).to_contain("RTL_DIR=\"$GEN_DIR/rv64/rtl\"")

        expect(rv32_runner.contains("examples/09_embedded/fpga_riscv/rtl")).to_equal(false)
        expect(rv32_semihost_runner.contains("examples/09_embedded/fpga_riscv/rtl")).to_equal(false)
        expect(rv32_mailbox_runner.contains("examples/09_embedded/fpga_riscv/rtl")).to_equal(false)
        expect(rv32_strobe_runner.contains("examples/09_embedded/fpga_riscv/rtl")).to_equal(false)
        expect(rv32_linux_handoff_runner.contains("examples/09_embedded/fpga_riscv/rtl")).to_equal(false)
        expect(rv32_boot_info_real_dtb_runner.contains("examples/09_embedded/fpga_riscv/rtl")).to_equal(false)
        expect(rv64_runner.contains("examples/09_embedded/fpga_riscv/rtl")).to_equal(false)
        expect(rv64_irq_runner.contains("examples/09_embedded/fpga_riscv/rtl")).to_equal(false)
        expect(rv64_linux_handoff_runner.contains("examples/09_embedded/fpga_riscv/rtl")).to_equal(false)
        expect(rv64_boot_banner_runner.contains("examples/09_embedded/fpga_riscv/rtl")).to_equal(false)

describe "Experimental RV32 Linux bundle generation":
    it "emits the experimental lane in a separate runner-consumable rtl root":
        expect(shell("rm -rf '/tmp/simple_rv32_linux_fpga_rtl_spec'")).to_equal(0)
        val result = generate_default_riscv_fpga_rtl_bundle_with_experimental_rv32_linux("/tmp/simple_rv32_linux_fpga_rtl_spec")
        expect(result.is_ok()).to_equal(true)
        val bundle = result.unwrap()
        val manifest_text = read_generated_riscv_fpga_rtl_file(bundle.manifest_path)
        val rv32_linux_source = read_generated_riscv_fpga_rtl_file("/tmp/simple_rv32_linux_fpga_rtl_spec/rv32_linux/rtl/simple_rv32gc_core.spl")
        val rv32_linux_handoff_tb = read_generated_riscv_fpga_rtl_file("/tmp/simple_rv32_linux_fpga_rtl_spec/rv32_linux/rtl/tb_generated_rv32_linux_handoff.vhd")
        val rv32_linux_real_dtb_tb = read_generated_riscv_fpga_rtl_file("/tmp/simple_rv32_linux_fpga_rtl_spec/rv32_linux/rtl/tb_generated_rv32_boot_info_real_dtb.vhd")
        expect(rv32_linux_source).to_contain("proof_lane: generated_rv32_linux")
        expect(rv32_linux_source).to_contain("scope: experimental RV32GC generated-core Linux lane")
        expect(rv32_linux_handoff_tb).to_contain("entity tb_generated_rv32_linux_handoff is")
        expect(rv32_linux_handoff_tb).to_contain("report \"GENERATED_RV32_LINUX_HANDOFF: PASS\";")
        expect(rv32_linux_real_dtb_tb).to_contain("entity tb_generated_rv32_boot_info_real_dtb is")
        expect(rv32_linux_real_dtb_tb).to_contain("report \"GENERATED_RV32_BOOT_INFO_REAL_DTB: PASS\";")
        expect(manifest_text).to_contain("authoritative_rtl_root = \"/tmp/simple_rv32_linux_fpga_rtl_spec/rv32_linux/rtl\"")
        expect(manifest_text).to_contain("lane_id = \"rv32_linux_experimental\"")
        expect(manifest_text).to_contain("authoritative = \"false\"")
        expect(bundle.generated_files).to_contain("/tmp/simple_rv32_linux_fpga_rtl_spec/rv32_linux/rtl/tb_generated_rv32_linux_handoff.vhd")
        expect(bundle.generated_files).to_contain("/tmp/simple_rv32_linux_fpga_rtl_spec/rv32_linux/rtl/tb_generated_rv32_boot_info_real_dtb.vhd")
