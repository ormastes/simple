"""
# RV32 M Extension Unit Tests

**Feature IDs:** #RV32-MEXT-001
**Category:** Hardware
**Difficulty:** 2/5
**Status:** In Progress

## Overview

Unit tests for multiply and divide operations.
"""

import std.spec

use hardware.rv32imac.ext.rv32_muldiv.muldiv_execute
use hardware.rv32imac.pkg.rv32_types_pkg.*

describe "MUL Operations":
    """
    ## Multiply Lower 32 Bits
    """

    it "basic multiplication":
        expect(muldiv_execute(AluOp.Mul, 6, 7)).to_equal(42)

    it "multiply by zero":
        expect(muldiv_execute(AluOp.Mul, 12345, 0)).to_equal(0)

    it "multiply by one":
        expect(muldiv_execute(AluOp.Mul, 12345, 1)).to_equal(12345)

    it "overflow wraps to lower 32 bits":
        expect(muldiv_execute(AluOp.Mul, 0x10000, 0x10000)).to_equal(0)

describe "DIV Operations":
    """
    ## Signed Division
    """

    it "basic division":
        expect(muldiv_execute(AluOp.Div, 42, 6)).to_equal(7)

    it "truncates toward zero":
        expect(muldiv_execute(AluOp.Div, 7, 2)).to_equal(3)

    it "division by zero returns 0xFFFFFFFF":
        expect(muldiv_execute(AluOp.Div, 1, 0)).to_equal(0xFFFFFFFF)

    it "overflow case: INT_MIN / -1":
        expect(muldiv_execute(AluOp.Div, 0x80000000, 0xFFFFFFFF)).to_equal(0x80000000)

describe "DIVU Operations":
    """
    ## Unsigned Division
    """

    it "basic unsigned division":
        expect(muldiv_execute(AluOp.Divu, 100, 10)).to_equal(10)

    it "division by zero returns 0xFFFFFFFF":
        expect(muldiv_execute(AluOp.Divu, 1, 0)).to_equal(0xFFFFFFFF)

describe "REM Operations":
    """
    ## Remainder
    """

    it "basic remainder":
        expect(muldiv_execute(AluOp.Rem, 10, 3)).to_equal(1)

    it "remainder of exact division":
        expect(muldiv_execute(AluOp.Rem, 12, 4)).to_equal(0)

    it "remainder by zero returns dividend":
        expect(muldiv_execute(AluOp.Rem, 42, 0)).to_equal(42)

describe "REMU Operations":
    """
    ## Unsigned Remainder
    """

    it "basic unsigned remainder":
        expect(muldiv_execute(AluOp.Remu, 10, 3)).to_equal(1)

    it "remainder by zero returns dividend":
        expect(muldiv_execute(AluOp.Remu, 42, 0)).to_equal(42)
