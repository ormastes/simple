"""
# RV32 Pipeline Control Unit Tests

**Feature IDs:** #RV32-PIPELINE-001
**Category:** Hardware
**Difficulty:** 2/5
**Status:** In Progress

## Overview

Unit tests for pipeline hazard detection, forwarding, and control signals.
"""

import std.spec

use hardware.rv32imac.core.rv32_pipeline_ctrl.*
use hardware.rv32imac.pkg.rv32_types_pkg.*

describe "Load-Use Hazard Detection":
    """
    ## Load-Use Stall Detection
    """

    it "detects hazard on rs1":
        expect detect_load_use_hazard(5, 0, 5, MemOp.Load, true) == true

    it "detects hazard on rs2":
        expect detect_load_use_hazard(0, 5, 5, MemOp.Load, true) == true

    it "no hazard for non-load":
        expect detect_load_use_hazard(5, 0, 5, MemOp.Store, true) == false
        expect detect_load_use_hazard(5, 0, 5, MemOp.None, true) == false

    it "no hazard when EX invalid":
        expect detect_load_use_hazard(5, 0, 5, MemOp.Load, false) == false

    it "no hazard when rd is x0":
        expect detect_load_use_hazard(0, 3, 0, MemOp.Load, true) == false

    it "no hazard when no register match":
        expect detect_load_use_hazard(3, 4, 5, MemOp.Load, true) == false

describe "Data Forwarding":
    """
    ## Forwarding Source Resolution
    """

    it "forwards from EX stage when match":
        expect resolve_forward_rs1(5, 5, true, 0, false) == ForwardSrc.ExStage == true

    it "forwards from MEM stage when EX doesn't match":
        expect resolve_forward_rs1(5, 3, true, 5, true) == ForwardSrc.MemStage == true

    it "uses regfile when no match":
        expect resolve_forward_rs1(5, 3, true, 4, true) == ForwardSrc.RegFile == true

    it "x0 always from regfile":
        expect resolve_forward_rs1(0, 0, true, 0, true) == ForwardSrc.RegFile == true

    it "EX has priority over MEM":
        expect resolve_forward_rs1(5, 5, true, 5, true) == ForwardSrc.ExStage == true

describe "Pipeline Control Signals":
    """
    ## Stall/Flush Generation
    """

    it "normal operation - no stalls or flushes":
        val ctrl = compute_pipeline_control(false, false, false)
        expect ctrl.stall_if == false
        expect ctrl.stall_id == false
        expect ctrl.flush_if == false
        expect ctrl.flush_id == false
        expect ctrl.flush_ex == false

    it "load-use: stalls IF/ID, flushes EX":
        val ctrl = compute_pipeline_control(true, false, false)
        expect ctrl.stall_if == true
        expect ctrl.stall_id == true
        expect ctrl.flush_ex == true
        expect ctrl.flush_if == false

    it "branch taken: flushes IF/ID":
        val ctrl = compute_pipeline_control(false, true, false)
        expect ctrl.flush_if == true
        expect ctrl.flush_id == true
        expect ctrl.stall_if == false

    it "trap: flushes everything":
        val ctrl = compute_pipeline_control(false, false, true)
        expect ctrl.flush_if == true
        expect ctrl.flush_id == true
        expect ctrl.flush_ex == true

    it "branch overrides load-use stall":
        val ctrl = compute_pipeline_control(true, true, false)
        expect ctrl.flush_if == true
        expect ctrl.stall_if == false