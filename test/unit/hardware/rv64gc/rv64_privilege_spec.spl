"""
# RV64 Privilege Mode Unit Tests

**Feature IDs:** #RV64-PRIVILEGE-001
**Category:** Hardware
**Difficulty:** 3/5
**Status:** Draft

## Overview

Unit tests for M/S/U privilege mode transitions, trap delegation, CSR access control.
"""

# tag: only-compiled

import std.spec

# Privilege levels
val PRIV_U: i64 = 0
val PRIV_S: i64 = 1
val PRIV_M: i64 = 3

# mstatus fields
val MSTATUS_MIE: i64 = 0x8
val MSTATUS_MPIE: i64 = 0x80
val MSTATUS_MPP_SHIFT: i64 = 11
val MSTATUS_SPP: i64 = 0x100
val MSTATUS_SPIE: i64 = 0x20
val MSTATUS_SIE: i64 = 0x2
val MSTATUS_TW: i64 = 0x200000

class _PrivModel:
    mode: i64
    mstatus: i64
    medeleg: i64
    mideleg: i64
    mepc: i64
    sepc: i64

    me mret() -> i64:
        val mpp = (self.mstatus >> MSTATUS_MPP_SHIFT) and 0x3
        val mpie = (self.mstatus >> 7) and 1
        self.mode = mpp
        # Restore MIE from MPIE, set MPIE=1, MPP=U
        self.mstatus = (self.mstatus and 0xFFFFFFFFFFFFE777) or (mpie << 3) or (1 << 7)
        self.mepc

    me sret() -> i64:
        val spp = (self.mstatus >> 8) and 1
        val spie = (self.mstatus >> 5) and 1
        self.mode = spp
        # Restore SIE from SPIE, set SPIE=1, SPP=U
        self.mstatus = (self.mstatus and 0xFFFFFFFFFFFFFEDD) or (spie << 1) or (1 << 5)
        self.sepc

    fn should_delegate_exception(cause: i64) -> bool:
        (self.medeleg >> cause) and 1 == 1

    fn should_delegate_interrupt(cause: i64) -> bool:
        (self.mideleg >> cause) and 1 == 1

    fn can_access_csr(csr_addr: i64) -> bool:
        val required_priv = (csr_addr >> 8) and 0x3
        self.mode >= required_priv

fn _create_priv() -> _PrivModel:
    _PrivModel(mode: PRIV_M, mstatus: 0, medeleg: 0, mideleg: 0, mepc: 0, sepc: 0)

describe "M-to-S Transition via MRET":
    it "MRET with MPP=S transitions to S-mode":
        var p = _create_priv()
        p.mstatus = 1 << MSTATUS_MPP_SHIFT  # MPP=01 (S)
        p.mepc = 0x80002000
        val pc = p.mret()
        expect(p.mode).to_equal(PRIV_S)
        expect(pc).to_equal(0x80002000)

    it "MRET with MPP=U transitions to U-mode":
        var p = _create_priv()
        p.mstatus = 0  # MPP=00 (U)
        p.mepc = 0x10000
        val pc = p.mret()
        expect(p.mode).to_equal(PRIV_U)

describe "S-to-U Transition via SRET":
    it "SRET with SPP=0 transitions to U-mode":
        var p = _create_priv()
        p.mode = PRIV_S
        p.mstatus = 0  # SPP=0 (U)
        p.sepc = 0x10000
        val pc = p.sret()
        expect(p.mode).to_equal(PRIV_U)
        expect(pc).to_equal(0x10000)

    it "SRET with SPP=1 transitions to S-mode":
        var p = _create_priv()
        p.mode = PRIV_S
        p.mstatus = MSTATUS_SPP  # SPP=1 (S)
        p.sepc = 0x80003000
        val pc = p.sret()
        expect(p.mode).to_equal(PRIV_S)

describe "Trap Delegation":
    it "exception delegated when medeleg bit set":
        var p = _create_priv()
        p.medeleg = 1 << 8  # Delegate ecall-from-U
        expect(p.should_delegate_exception(8)).to_equal(true)

    it "exception not delegated when medeleg bit clear":
        var p = _create_priv()
        p.medeleg = 0
        expect(p.should_delegate_exception(8)).to_equal(false)

    it "interrupt delegated when mideleg bit set":
        var p = _create_priv()
        p.mideleg = 1 << 5  # Delegate S-mode timer
        expect(p.should_delegate_interrupt(5)).to_equal(true)

    it "interrupt not delegated when mideleg bit clear":
        var p = _create_priv()
        p.mideleg = 0
        expect(p.should_delegate_interrupt(5)).to_equal(false)

describe "CSR Access Per Mode":
    it "M-mode can access M-mode CSRs (0x3xx)":
        var p = _create_priv()
        p.mode = PRIV_M
        expect(p.can_access_csr(0x300)).to_equal(true)

    it "S-mode cannot access M-mode CSRs":
        var p = _create_priv()
        p.mode = PRIV_S
        expect(p.can_access_csr(0x300)).to_equal(false)

    it "S-mode can access S-mode CSRs (0x1xx)":
        var p = _create_priv()
        p.mode = PRIV_S
        expect(p.can_access_csr(0x100)).to_equal(true)

    it "U-mode cannot access S-mode CSRs":
        var p = _create_priv()
        p.mode = PRIV_U
        expect(p.can_access_csr(0x100)).to_equal(false)

    it "U-mode can access U-mode CSRs (0x0xx)":
        var p = _create_priv()
        p.mode = PRIV_U
        expect(p.can_access_csr(0x001)).to_equal(true)

    it "M-mode can access all privilege levels":
        var p = _create_priv()
        p.mode = PRIV_M
        expect(p.can_access_csr(0x001)).to_equal(true)
        expect(p.can_access_csr(0x100)).to_equal(true)
        expect(p.can_access_csr(0x300)).to_equal(true)

describe "MPP/SPP Field Encoding":
    it "MPP: 0=U, 1=S, 3=M":
        var p = _create_priv()
        # Set MPP=M (11)
        p.mstatus = 3 << MSTATUS_MPP_SHIFT
        p.mepc = 0x80000000
        val pc = p.mret()
        expect(p.mode).to_equal(PRIV_M)

    it "SPP: 0=U, 1=S":
        var p = _create_priv()
        p.mode = PRIV_S
        p.mstatus = MSTATUS_SPP
        p.sepc = 0x80001000
        val pc = p.sret()
        expect(p.mode).to_equal(PRIV_S)

describe "WFI in U-Mode":
    it "WFI raises exception when TW=1":
        var p = _create_priv()
        p.mode = PRIV_U
        p.mstatus = MSTATUS_TW
        val tw_set = (p.mstatus and MSTATUS_TW) != 0
        expect(tw_set and p.mode == PRIV_U).to_equal(true)
