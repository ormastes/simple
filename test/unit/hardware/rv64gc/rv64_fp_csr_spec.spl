"""
# RV64 FP CSR Unit Tests

**Feature IDs:** #RV64-FP-CSR-001
**Category:** Hardware
**Difficulty:** 2/5
**Status:** Draft

## Overview

Unit tests for floating-point CSRs: fcsr, fflags, frm.
"""

# tag: only-compiled

import std.spec

val FP_FLAG_NX: i64 = 0x01
val FP_FLAG_UF: i64 = 0x02
val FP_FLAG_OF: i64 = 0x04
val FP_FLAG_DZ: i64 = 0x08
val FP_FLAG_NV: i64 = 0x10

class _FpCsr:
    fcsr: i64

    fn fflags() -> i64: self.fcsr and 0x1F
    fn frm() -> i64: (self.fcsr >> 5) and 0x7
    me set_fflags(val_: i64): self.fcsr = (self.fcsr and 0xE0) or (val_ and 0x1F)
    me set_frm(val_: i64): self.fcsr = (self.fcsr and 0x1F) or ((val_ and 0x7) << 5)
    me accum_flags(flags: i64): self.fcsr = self.fcsr or (flags and 0x1F)
    me reset(): self.fcsr = 0

describe "FCSR Read/Write":
    it "fcsr initially zero":
        val csr = _FpCsr(fcsr: 0)
        expect(csr.fcsr).to_equal(0)

    it "write and read full fcsr":
        var csr = _FpCsr(fcsr: 0)
        csr.fcsr = 0xFF
        expect(csr.fcsr and 0xFF).to_equal(0xFF)

    it "fcsr only uses lower 8 bits (frm + fflags)":
        var csr = _FpCsr(fcsr: 0xFF)
        expect(csr.fflags()).to_equal(0x1F)
        expect(csr.frm()).to_equal(0x7)

describe "FFlags Individual Flags":
    it "NX (inexact) flag":
        var csr = _FpCsr(fcsr: 0)
        csr.accum_flags(FP_FLAG_NX)
        expect(csr.fflags() and FP_FLAG_NX).to_equal(FP_FLAG_NX)

    it "UF (underflow) flag":
        var csr = _FpCsr(fcsr: 0)
        csr.accum_flags(FP_FLAG_UF)
        expect(csr.fflags() and FP_FLAG_UF).to_equal(FP_FLAG_UF)

    it "OF (overflow) flag":
        var csr = _FpCsr(fcsr: 0)
        csr.accum_flags(FP_FLAG_OF)
        expect(csr.fflags() and FP_FLAG_OF).to_equal(FP_FLAG_OF)

    it "DZ (divide by zero) flag":
        var csr = _FpCsr(fcsr: 0)
        csr.accum_flags(FP_FLAG_DZ)
        expect(csr.fflags() and FP_FLAG_DZ).to_equal(FP_FLAG_DZ)

    it "NV (invalid operation) flag":
        var csr = _FpCsr(fcsr: 0)
        csr.accum_flags(FP_FLAG_NV)
        expect(csr.fflags() and FP_FLAG_NV).to_equal(FP_FLAG_NV)

describe "FRM Rounding Modes":
    it "RNE (round to nearest, ties to even) = 0":
        var csr = _FpCsr(fcsr: 0)
        csr.set_frm(0)
        expect(csr.frm()).to_equal(0)

    it "RTZ (round toward zero) = 1":
        var csr = _FpCsr(fcsr: 0)
        csr.set_frm(1)
        expect(csr.frm()).to_equal(1)

    it "RDN (round down) = 2":
        var csr = _FpCsr(fcsr: 0)
        csr.set_frm(2)
        expect(csr.frm()).to_equal(2)

    it "RUP (round up) = 3":
        var csr = _FpCsr(fcsr: 0)
        csr.set_frm(3)
        expect(csr.frm()).to_equal(3)

    it "RMM (round to nearest, ties to max magnitude) = 4":
        var csr = _FpCsr(fcsr: 0)
        csr.set_frm(4)
        expect(csr.frm()).to_equal(4)

describe "Exception Accumulation":
    it "flags OR together (accumulate)":
        var csr = _FpCsr(fcsr: 0)
        csr.accum_flags(FP_FLAG_NX)
        csr.accum_flags(FP_FLAG_OF)
        expect(csr.fflags()).to_equal(FP_FLAG_NX or FP_FLAG_OF)

    it "setting fflags preserves frm":
        var csr = _FpCsr(fcsr: 0)
        csr.set_frm(3)
        csr.set_fflags(0x1F)
        expect(csr.frm()).to_equal(3)
        expect(csr.fflags()).to_equal(0x1F)

    it "reset clears all":
        var csr = _FpCsr(fcsr: 0xFF)
        csr.reset()
        expect(csr.fcsr).to_equal(0)
