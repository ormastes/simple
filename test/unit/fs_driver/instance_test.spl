# @cover src/lib/nogc_sync_mut/fs_driver/instance.spl 80%
"""
# DriverInstance Unit Tests

**Feature IDs:** #FS-DRIVER-INSTANCE
**Category:** Infrastructure
**Difficulty:** 1/5
**Status:** In Progress
**Design:** doc/05_design/fs_driver_interface.md §3

## Overview

Tests for the DriverInstance enum:
  - RamFs variant construction using RamFsDriver.new()
  - driver_name() returns the expected string for each constructable variant
  - Match on DriverInstance is exhaustive (compiler-validated; tested by variant construction)

Note: Fat32, Nvfs, NvfsPosix variants require concrete device/arena wiring
that is out of scope for unit tests. Exhaustiveness is enforced by the compiler
on every match arm in this file.
"""

use std.spipe.*
use std.fs_driver.instance.{DriverInstance}
use std.fs_driver.ramfs.{RamFsDriver}


fn make_ramfs() -> DriverInstance:
    DriverInstance.RamFs(driver: RamFsDriver.new())


# ============================================================================
# DriverInstance.RamFs — construction + driver_name()
# ============================================================================

describe "DriverInstance — RamFs variant":
    """
    ## RamFs driver

    RamFsDriver is the only variant constructable without device/arena wiring.
    driver_name() must return "ramfs" for this variant.
    """

    it "RamFs variant can be constructed":
        val d = make_ramfs()
        match d:
            case RamFs(drv): expect(drv.name).to_equal("ramfs")
            case _:          expect(false).to_equal(true)

    it "driver_name() returns 'ramfs'":
        val d = make_ramfs()
        expect(d.driver_name()).to_equal("ramfs")

    it "RamFs name field is 'ramfs'":
        val d = make_ramfs()
        match d:
            case RamFs(drv): expect(drv.name).to_equal("ramfs")
            case _:          expect(false).to_equal(true)

    it "driver_name() is stable across two distinct RamFs instances":
        val d1 = make_ramfs()
        val d2 = make_ramfs()
        expect(d1.driver_name()).to_equal(d2.driver_name())


# ============================================================================
# DriverInstance exhaustiveness note
# ============================================================================

describe "DriverInstance — exhaustive match invariant":
    """
    ## Compiler-enforced exhaustiveness

    Adding a new variant to DriverInstance causes a compile error on every
    existing match in this file, enforcing that driver_name() stays current.
    This test confirms the match arms cover all variants present at this revision.
    """

    it "match on RamFs is non-empty and the arm is reachable":
        val d = make_ramfs()
        var reached = false
        match d:
            case RamFs(_):     reached = true
            case Fat32(_):     reached = true
            case Nvfs(_):      reached = true
            case NvfsPosix(_): reached = true
        expect(reached).to_equal(true)
