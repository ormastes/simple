# @cover src/lib/nogc_sync_mut/fs_driver/extension.spl 80%
"""
# FsDriver Extension Unit Tests

**Feature IDs:** #FS-DRIVER-EXT
**Category:** Infrastructure
**Difficulty:** 1/5
**Status:** In Progress
**Design:** doc/05_design/fs_driver_interface.md §4

## Overview

Tests for the Extension enum and its per-capability handle structs:
  - Each Extension variant can be constructed with its handle struct
  - The handle struct fields survive construction
  - Match on Extension is exhaustive (validated by compiler)
"""

use std.spipe.*
use std.fs_driver.extension.{
    Extension,
    SnapshotExt, DedupExt, ChecksumExt, SendRecvExt, ScrubExt,
    CompressExt, EncryptExt, QuotaExt, ReflinkExt, PosixCompatExt,
    DirectIoExt, DirectIoBuffer
}


# ============================================================================
# Extension variant construction — each variant holds its struct
# ============================================================================

describe "Extension — Snapshot variant":
    """
    ## Snapshot handle

    Extension.Snapshot wraps SnapshotExt with volume_name and snap_count.
    """

    it "Snapshot variant can be constructed":
        val ext = Extension.Snapshot(ext: SnapshotExt(volume_name: "vol0", snap_count: 3))
        match ext:
            case Snapshot(e): expect(e.snap_count).to_equal(3)
            case _:           expect(false).to_equal(true)

    it "Snapshot holds volume_name field":
        val ext = Extension.Snapshot(ext: SnapshotExt(volume_name: "myfs", snap_count: 0))
        match ext:
            case Snapshot(e): expect(e.volume_name).to_equal("myfs")
            case _:           expect(false).to_equal(true)


describe "Extension — Dedup variant":
    """
    ## Dedup handle

    Extension.Dedup wraps DedupExt with bytes_saved and scan_active.
    """

    it "Dedup variant can be constructed":
        val ext = Extension.Dedup(ext: DedupExt(bytes_saved: 1024, scan_active: false))
        match ext:
            case Dedup(e): expect(e.bytes_saved).to_equal(1024)
            case _:        expect(false).to_equal(true)

    it "Dedup scan_active field is preserved":
        val ext = Extension.Dedup(ext: DedupExt(bytes_saved: 0, scan_active: true))
        match ext:
            case Dedup(e): expect(e.scan_active).to_equal(true)
            case _:        expect(false).to_equal(true)


describe "Extension — Checksum variant":
    """
    ## Checksum handle

    Extension.Checksum wraps ChecksumExt with algo_tag and block_size.
    """

    it "Checksum variant stores algo_tag and block_size":
        val ext = Extension.Checksum(ext: ChecksumExt(algo_tag: 1, block_size: 4096))
        match ext:
            case Checksum(e):
                expect(e.algo_tag).to_equal(1)
                expect(e.block_size).to_equal(4096)
            case _: expect(false).to_equal(true)


describe "Extension — Compress variant":
    """
    ## Compress handle

    Extension.Compress wraps CompressExt.
    """

    it "Compress variant stores default_algo and enabled":
        val ext = Extension.Compress(ext: CompressExt(default_algo: 0, enabled: true))
        match ext:
            case Compress(e):
                expect(e.default_algo).to_equal(0)
                expect(e.enabled).to_equal(true)
            case _: expect(false).to_equal(true)


describe "Extension — Encrypt variant":
    """
    ## Encrypt handle

    Extension.Encrypt wraps EncryptExt with key_id and key_bits.
    """

    it "Encrypt variant stores key_id and key_bits":
        val ext = Extension.Encrypt(ext: EncryptExt(key_id: 7, key_bits: 256))
        match ext:
            case Encrypt(e):
                expect(e.key_id).to_equal(7)
                expect(e.key_bits).to_equal(256)
            case _: expect(false).to_equal(true)


describe "Extension — Reflink variant":
    """
    ## Reflink handle

    Extension.Reflink wraps ReflinkExt with shared_extents and cow_pending.
    """

    it "Reflink variant stores shared_extents":
        val ext = Extension.Reflink(ext: ReflinkExt(shared_extents: 5, cow_pending: false))
        match ext:
            case Reflink(e): expect(e.shared_extents).to_equal(5)
            case _:          expect(false).to_equal(true)


describe "Extension — PosixCompat variant":
    """
    ## PosixCompat handle

    Extension.PosixCompat wraps PosixCompatExt with flags and mode.
    """

    it "PosixCompat variant stores flags and mode":
        val ext = Extension.PosixCompat(ext: PosixCompatExt(flags: 0, mode: 420))
        match ext:
            case PosixCompat(e):
                expect(e.flags).to_equal(0)
                expect(e.mode).to_equal(420)
            case _: expect(false).to_equal(true)


describe "Extension — DirectIo variant":
    """
    ## Direct I/O handle

    Extension.DirectIo wraps DirectIoExt with explicit alignment and backend
    capability metadata. The default methods validate DMA descriptor alignment
    and fail closed with Unsupported unless a backend provides a real path.
    """

    it "DirectIo variant stores alignment metadata":
        val ext = Extension.DirectIo(ext: DirectIoExt(
            sector_alignment: 512,
            file_alignment: 512,
            max_io_bytes: 4096,
            backend_tag: "nvme",
            bounce_allowed: false))
        match ext:
            case DirectIo(e):
                expect(e.sector_alignment).to_equal(512)
                expect(e.backend_tag).to_equal("nvme")
                expect(e.bounce_allowed).to_equal(false)
            case _: expect(false).to_equal(true)

    it "DirectIo validates aligned caller-owned DMA buffers":
        val ext = DirectIoExt(
            sector_alignment: 512,
            file_alignment: 512,
            max_io_bytes: 4096,
            backend_tag: "virtio-blk",
            bounce_allowed: false)
        val buf = DirectIoBuffer(cpu_virt_addr: 0x1000, device_addr: 0x2000, byte_len: 1024, allocation_id: 5)
        val result = ext.validate_buffer(1024, buf)
        expect(result.is_ok()).to_equal(true)

    it "DirectIo rejects unaligned offsets instead of silently copying":
        val ext = DirectIoExt(
            sector_alignment: 512,
            file_alignment: 512,
            max_io_bytes: 4096,
            backend_tag: "virtio-blk",
            bounce_allowed: false)
        val buf = DirectIoBuffer(cpu_virt_addr: 0x1000, device_addr: 0x2000, byte_len: 1024, allocation_id: 5)
        val result = ext.validate_buffer(7, buf)
        expect(result.is_err()).to_equal(true)
