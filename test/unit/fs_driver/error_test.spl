# @cover src/lib/nogc_sync_mut/fs_driver/error.spl 80%
"""
# FsDriver Error Unit Tests

**Feature IDs:** #FS-DRIVER-ERR
**Category:** Infrastructure
**Difficulty:** 1/5
**Status:** In Progress
**Design:** doc/05_design/fs_driver_interface.md §7

## Overview

Tests for the FsError enum and errno_of() POSIX mapping:
  - Each simple variant can be constructed
  - Parameterised variants (Transient, IoError) hold their values
  - errno_of() returns the correct POSIX errno for each variant
"""

use std.sspec.*
use std.fs_driver.error.{
    FsError, errno_of,
    EINVAL, ENOSPC, EACCES, ENOENT, EEXIST, EBUSY, EINTR, EFBIG, EROFS,
    ENOTSUP, EIO, EAGAIN
}


# ============================================================================
# FsError variant construction
# ============================================================================

describe "FsError — variant construction":
    """
    ## Constructors

    Verifies that all FsError variants can be constructed and that
    parameterised variants hold their payload correctly.
    """

    it "Unsupported can be constructed":
        val e = FsError.Unsupported
        match e:
            case Unsupported: expect(true).to_equal(true)
            case _:           expect(false).to_equal(true)

    it "NoSpace can be constructed":
        val e = FsError.NoSpace
        match e:
            case NoSpace: expect(true).to_equal(true)
            case _:       expect(false).to_equal(true)

    it "Permission can be constructed":
        val e = FsError.Permission
        match e:
            case Permission: expect(true).to_equal(true)
            case _:          expect(false).to_equal(true)

    it "NotFound can be constructed":
        val e = FsError.NotFound
        match e:
            case NotFound: expect(true).to_equal(true)
            case _:        expect(false).to_equal(true)

    it "Transient holds its i32 code":
        val e = FsError.Transient(code: 42)
        match e:
            case Transient(code): expect(code).to_equal(42)
            case _:               expect(false).to_equal(true)

    it "IoError holds its u32 code":
        val e = FsError.IoError(code: 99)
        match e:
            case IoError(code): expect(code).to_equal(99)
            case _:             expect(false).to_equal(true)


# ============================================================================
# errno_of() POSIX mapping
# ============================================================================

describe "FsError — errno_of() mapping":
    """
    ## POSIX errno translation

    errno_of() must return the correct POSIX errno constant for each variant.
    Values match POSIX/Linux standard definitions.
    """

    it "Unsupported -> ENOTSUP (95)":
        expect(errno_of(FsError.Unsupported)).to_equal(ENOTSUP)

    it "NoSpace -> ENOSPC (28)":
        expect(errno_of(FsError.NoSpace)).to_equal(ENOSPC)

    it "Permission -> EACCES (13)":
        expect(errno_of(FsError.Permission)).to_equal(EACCES)

    it "NotFound -> ENOENT (2)":
        expect(errno_of(FsError.NotFound)).to_equal(ENOENT)

    it "AlreadyExists -> EEXIST (17)":
        expect(errno_of(FsError.AlreadyExists)).to_equal(EEXIST)

    it "Busy -> EBUSY (16)":
        expect(errno_of(FsError.Busy)).to_equal(EBUSY)

    it "Interrupted -> EINTR (4)":
        expect(errno_of(FsError.Interrupted)).to_equal(EINTR)

    it "TooLarge -> EFBIG (27)":
        expect(errno_of(FsError.TooLarge)).to_equal(EFBIG)

    it "ReadOnly -> EROFS (30)":
        expect(errno_of(FsError.ReadOnly)).to_equal(EROFS)

    it "InvalidArg -> EINVAL (22)":
        expect(errno_of(FsError.InvalidArg)).to_equal(EINVAL)

    it "Transient(_) -> EAGAIN (11)":
        expect(errno_of(FsError.Transient(code: 0))).to_equal(EAGAIN)

    it "IoError(_) -> EIO (5)":
        expect(errno_of(FsError.IoError(code: 0))).to_equal(EIO)

    it "Corrupt -> EIO (5)":
        expect(errno_of(FsError.Corrupt)).to_equal(EIO)
