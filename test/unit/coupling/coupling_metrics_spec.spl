# ============================================================================
# api_quality.spl — compute_overload_groups
# ============================================================================

describe "compute_overload_groups":
    it "counts groups with duplicate names":
        val result = compute_overload_groups(["foo", "bar", "foo", "baz", "bar"])
        expect(result).to_equal(2)

    it "returns 0 for all unique names":
        val result = compute_overload_groups(["a", "b", "c"])
