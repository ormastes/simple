# Coupling Analysis Unit Tests
#
# @parent test/system/coupling_analysis_spec.spl
# @req REQ-coupling-analysis
#
# Comprehensive unit tests for the coupling analysis modules:
# - metrics.spl: fan-in, fan-out, instability, cycles, inversions
# - layer_check.spl: layer number extraction, layer violations
# - lcom.spl: LCOM4 cohesion metric
# - api_quality.spl: PSS, EUR, entropy, API complexity
# - atss.spl: type set edit distance, deletion variants
# - dsm.spl: dependency structure matrix
# - relaxed_tokenizer.spl: token kind ordinal, relaxed token conversion

use std.spec.{describe, it, expect}
use compiler.common.dependency.graph.{ImportGraph, ImportEdge, ImportKind}
use compiler.tools.coupling.metrics.{
    compute_fan_in, compute_fan_out, compute_all_metrics,
    find_cycles, find_instability_inversions,
    CouplingMetrics, InstabilityInversion
}
use compiler.tools.coupling.layer_check.{
    extract_layer_number, find_layer_violations, is_digit,
    LayerViolation
}
use compiler.tools.coupling.lcom.{
    compute_lcom4, find_method_index, fields_share_access,
    sort_descending, MethodFieldAccess, LCOMResult
}
use compiler.tools.coupling.api_quality.{
    compute_pss, compute_eur, compute_entropy,
    compute_public_ratio, compute_avg_param_count,
    compute_max_param_count, compute_overload_groups,
    MethodUsage
}
use compiler.tools.coupling.atss.{
    type_set_edit_distance, generate_deletion_variants,
    compute_type_hash, TypeVector
}
use compiler.tools.coupling.dsm.{
    build_dsm, DSMMatrix
}
use compiler.tools.duplicate_check.tokenizer.{SimpleToken, SimpleTokenKind}
use compiler.tools.coupling.relaxed_tokenizer.{
    token_kind_ordinal, to_relaxed_tokens, RelaxedToken
}

# ============================================================================
# Helper Functions
# ============================================================================

fn make_graph(edges: Dict<text, [text]>) -> ImportGraph:
    ImportGraph(edges: edges, detailed_edges: [])

fn make_graph_with_edges(edges: Dict<text, [text]>, detailed: [ImportEdge]) -> ImportGraph:
    ImportGraph(edges: edges, detailed_edges: detailed)

fn make_edge(from: text, to: text) -> ImportEdge:
    ImportEdge(from: from, to: to, kind: ImportKind.UseImport)

fn make_method(name: text, fields: [text], calls: [text]) -> MethodFieldAccess:
    MethodFieldAccess(method_name: name, fields_accessed: fields, methods_called: calls)

fn make_usage(name: text, count: i64) -> MethodUsage:
    MethodUsage(method_name: name, external_call_count: count)

fn make_token(kind: SimpleTokenKind, line: i64, col: i64) -> SimpleToken:
    SimpleToken(kind: kind, value: "", line: line, column: col)

fn find_metric_by_name(metrics: [CouplingMetrics], name: text) -> CouplingMetrics:
    var i = 0
    while i < metrics.len():
        if metrics.get(i).module_name == name:
            return metrics.get(i)
        i = i + 1
    # Fallback — should not be reached in valid tests
    CouplingMetrics(module_name: "", cbo: 0, fan_in: 0, fan_out: 0, instability: 0.0, abstractness: 0.0, distance: 0.0)

# ============================================================================
# metrics.spl — compute_fan_out
# ============================================================================

describe "compute_fan_out":
    it "returns correct fan-out for a linear chain":
        var edges: Dict<text, [text]> = {}
        edges = edges.set("A", ["B"])
        edges = edges.set("B", ["C"])
        edges = edges.set("C", [])
        val graph = make_graph(edges)
        val result = compute_fan_out(graph)
        expect(result.get("A")).to_equal(1)
        expect(result.get("B")).to_equal(1)
        expect(result.get("C")).to_equal(0)

    it "returns correct fan-out for a module with multiple deps":
        var edges: Dict<text, [text]> = {}
        edges = edges.set("A", ["B", "C", "D"])
        edges = edges.set("B", [])
        edges = edges.set("C", [])
        edges = edges.set("D", [])
        val graph = make_graph(edges)
        val result = compute_fan_out(graph)
        expect(result.get("A")).to_equal(3)

    it "returns zero fan-out for isolated modules":
        var edges: Dict<text, [text]> = {}
        edges = edges.set("X", [])
        edges = edges.set("Y", [])
        val graph = make_graph(edges)
        val result = compute_fan_out(graph)
        expect(result.get("X")).to_equal(0)
        expect(result.get("Y")).to_equal(0)

    it "handles empty graph":
        var edges: Dict<text, [text]> = {}
        val graph = make_graph(edges)
        val result = compute_fan_out(graph)
        expect(result.keys().len()).to_equal(0)

# ============================================================================
# metrics.spl — compute_fan_in
# ============================================================================

describe "compute_fan_in":
    it "returns correct fan-in for a linear chain":
        var edges: Dict<text, [text]> = {}
        edges = edges.set("A", ["B"])
        edges = edges.set("B", ["C"])
        edges = edges.set("C", [])
        val graph = make_graph(edges)
        val result = compute_fan_in(graph)
        expect(result.get("A")).to_equal(0)
        expect(result.get("B")).to_equal(1)
        expect(result.get("C")).to_equal(1)

    it "counts multiple incomers correctly":
        var edges: Dict<text, [text]> = {}
        edges = edges.set("A", ["C"])
        edges = edges.set("B", ["C"])
        edges = edges.set("C", [])
        val graph = make_graph(edges)
        val result = compute_fan_in(graph)
        expect(result.get("C")).to_equal(2)
        expect(result.get("A")).to_equal(0)
        expect(result.get("B")).to_equal(0)

    it "handles empty graph":
        var edges: Dict<text, [text]> = {}
        val graph = make_graph(edges)
        val result = compute_fan_in(graph)
        expect(result.keys().len()).to_equal(0)

    it "handles single node with no edges":
        var edges: Dict<text, [text]> = {}
        edges = edges.set("Solo", [])
        val graph = make_graph(edges)
        val result = compute_fan_in(graph)
        expect(result.get("Solo")).to_equal(0)

# ============================================================================
# metrics.spl — compute_all_metrics
# ============================================================================

describe "compute_all_metrics":
    it "computes instability for a hub-and-spoke graph":
        var edges: Dict<text, [text]> = {}
        edges = edges.set("hub", ["a", "b", "c"])
        edges = edges.set("a", [])
        edges = edges.set("b", [])
        edges = edges.set("c", [])
        val graph = make_graph(edges)
        val metrics = compute_all_metrics(graph)
        val hub = find_metric_by_name(metrics, "hub")
        # hub: fan_out=3, fan_in=0, instability=3/(0+3)=1.0
        expect(hub.fan_out).to_equal(3)
        expect(hub.fan_in).to_equal(0)
        expect(hub.instability).to_equal(1.0)

    it "leaf modules have instability 0":
        var edges: Dict<text, [text]> = {}
        edges = edges.set("hub", ["leaf"])
        edges = edges.set("leaf", [])
        val graph = make_graph(edges)
        val metrics = compute_all_metrics(graph)
        val leaf = find_metric_by_name(metrics, "leaf")
        # leaf: fan_out=0, fan_in=1, instability=0/(1+0)=0.0
        expect(leaf.fan_out).to_equal(0)
        expect(leaf.instability).to_equal(0.0)

    it "isolated node has instability 0":
        var edges: Dict<text, [text]> = {}
        edges = edges.set("solo", [])
        val graph = make_graph(edges)
        val metrics = compute_all_metrics(graph)
        val solo = find_metric_by_name(metrics, "solo")
        expect(solo.instability).to_equal(0.0)
        expect(solo.distance).to_equal(1.0)

    it "cbo equals fan_out":
        var edges: Dict<text, [text]> = {}
        edges = edges.set("X", ["Y", "Z"])
        edges = edges.set("Y", [])
        edges = edges.set("Z", [])
        val graph = make_graph(edges)
        val metrics = compute_all_metrics(graph)
        val x = find_metric_by_name(metrics, "X")
        expect(x.cbo).to_equal(x.fan_out)

    it "distance from main sequence is computed correctly":
        # Module with instability=0.5, abstractness=0 -> distance = |0+0.5-1| = 0.5
        var edges: Dict<text, [text]> = {}
        edges = edges.set("M", ["N"])
        edges = edges.set("N", ["M"])
        val graph = make_graph(edges)
        val metrics = compute_all_metrics(graph)
        val m = find_metric_by_name(metrics, "M")
        # M: fan_out=1, fan_in=1, instability=0.5, abstractness=0 -> distance = |0+0.5-1| = 0.5
        expect(m.instability).to_equal(0.5)
        expect(m.distance).to_equal(0.5)

# ============================================================================
# metrics.spl — find_cycles
# ============================================================================

describe "find_cycles":
    it "detects a simple 2-node cycle":
        var edges: Dict<text, [text]> = {}
        edges = edges.set("A", ["B"])
        edges = edges.set("B", ["A"])
        val graph = make_graph(edges)
        val cycles = find_cycles(graph)
        expect(cycles.len()).to_equal(1)
        expect(cycles.get(0).len()).to_equal(2)

    it "detects a 3-node cycle":
        var edges: Dict<text, [text]> = {}
        edges = edges.set("A", ["B"])
        edges = edges.set("B", ["C"])
        edges = edges.set("C", ["A"])
        val graph = make_graph(edges)
        val cycles = find_cycles(graph)
        expect(cycles.len()).to_equal(1)
        expect(cycles.get(0).len()).to_equal(3)

    it "returns empty for an acyclic graph":
        var edges: Dict<text, [text]> = {}
        edges = edges.set("A", ["B"])
        edges = edges.set("B", ["C"])
        edges = edges.set("C", [])
        val graph = make_graph(edges)
        val cycles = find_cycles(graph)
        expect(cycles.len()).to_equal(0)

    it "returns empty for an empty graph":
        var edges: Dict<text, [text]> = {}
        val graph = make_graph(edges)
        val cycles = find_cycles(graph)
        expect(cycles.len()).to_equal(0)

    it "returns empty for a single node":
        var edges: Dict<text, [text]> = {}
        edges = edges.set("A", [])
        val graph = make_graph(edges)
        val cycles = find_cycles(graph)
        expect(cycles.len()).to_equal(0)

# ============================================================================
# metrics.spl — find_instability_inversions
# ============================================================================

describe "find_instability_inversions":
    it "detects inversion when stable depends on unstable":
        # A has fan_in=1, fan_out=1 => instability=0.5
        # B has fan_in=0, fan_out=1 => instability=1.0
        # A depends on B: A (stable=0.5) -> B (unstable=1.0) = inversion
        # But we also need B depending on something so B has fan_out
        var edges: Dict<text, [text]> = {}
        edges = edges.set("stable", ["unstable"])
        edges = edges.set("unstable", ["leaf1", "leaf2"])
        edges = edges.set("other", ["stable"])
        edges = edges.set("leaf1", [])
        edges = edges.set("leaf2", [])
        val graph = make_graph(edges)
        val metrics = compute_all_metrics(graph)
        val inversions = find_instability_inversions(metrics, graph)
        # stable (instab ~0.5) depends on unstable (instab=1.0) => inversion
        expect(inversions.len()).to_be_greater_than(0)

    it "returns empty when no inversions exist":
        # Linear: unstable -> stable -> leaf
        var edges: Dict<text, [text]> = {}
        edges = edges.set("A", ["B"])
        edges = edges.set("B", [])
        val graph = make_graph(edges)
        val metrics = compute_all_metrics(graph)
        val inversions = find_instability_inversions(metrics, graph)
        # A: instab=1.0 depends on B: instab=0.0 => no inversion (unstable depends on stable = OK)
        expect(inversions.len()).to_equal(0)

    it "returns empty for empty graph":
        var edges: Dict<text, [text]> = {}
        val graph = make_graph(edges)
        val metrics = compute_all_metrics(graph)
        val inversions = find_instability_inversions(metrics, graph)
        expect(inversions.len()).to_equal(0)

# ============================================================================
# layer_check.spl — extract_layer_number
# ============================================================================

describe "extract_layer_number":
    it "extracts layer from slash-separated path":
        val result = extract_layer_number("compiler/30.types/foo")
        expect(result).to_equal(30)

    it "extracts layer 00 from common":
        val result = extract_layer_number("compiler/00.common/bar")
        expect(result).to_equal(0)

    it "returns nil for non-layer path":
        val result = extract_layer_number("std/text/utils")
        expect(result).to_be_nil()

    it "extracts layer from dot-separated path":
        val result = extract_layer_number("compiler.70.backend.llvm")
        expect(result).to_equal(70)

    it "returns nil for single character segment":
        val result = extract_layer_number("a/b/c")
        expect(result).to_be_nil()

# ============================================================================
# layer_check.spl — is_digit
# ============================================================================

describe "is_digit":
    it "returns true for digit characters":
        expect(is_digit("0")).to_equal(true)
        expect(is_digit("5")).to_equal(true)
        expect(is_digit("9")).to_equal(true)

    it "returns false for non-digit characters":
        expect(is_digit("a")).to_equal(false)
        expect(is_digit("Z")).to_equal(false)
        expect(is_digit(" ")).to_equal(false)

# ============================================================================
# layer_check.spl — find_layer_violations
# ============================================================================

describe "find_layer_violations":
    it "detects violation when lower layer imports higher layer":
        var edges: Dict<text, [text]> = {}
        edges = edges.set("compiler/00.common/foo", ["compiler/30.types/bar"])
        edges = edges.set("compiler/30.types/bar", [])
        val graph = make_graph(edges)
        val violations = find_layer_violations(graph)
        expect(violations.len()).to_equal(1)
        expect(violations.get(0).from_layer).to_equal(0)
        expect(violations.get(0).to_layer).to_equal(30)

    it "allows higher layer importing lower layer":
        var edges: Dict<text, [text]> = {}
        edges = edges.set("compiler/30.types/bar", ["compiler/00.common/foo"])
        edges = edges.set("compiler/00.common/foo", [])
        val graph = make_graph(edges)
        val violations = find_layer_violations(graph)
        expect(violations.len()).to_equal(0)

    it "no violations for non-layer modules":
        var edges: Dict<text, [text]> = {}
        edges = edges.set("std/text/utils", ["std/math/ops"])
        edges = edges.set("std/math/ops", [])
        val graph = make_graph(edges)
        val violations = find_layer_violations(graph)
        expect(violations.len()).to_equal(0)

    it "returns empty for empty graph":
        var edges: Dict<text, [text]> = {}
        val graph = make_graph(edges)
        val violations = find_layer_violations(graph)
        expect(violations.len()).to_equal(0)

    it "uses detailed_edges when available":
        var edges: Dict<text, [text]> = {}
        val detailed = [
            make_edge("compiler/10.frontend/parser", "compiler/30.types/checker")
        ]
        val graph = make_graph_with_edges(edges, detailed)
        val violations = find_layer_violations(graph)
        expect(violations.len()).to_equal(1)
        expect(violations.get(0).from_layer).to_equal(10)
        expect(violations.get(0).to_layer).to_equal(30)

# ============================================================================
# lcom.spl — fields_share_access
# ============================================================================

describe "fields_share_access":
    it "returns true when lists share a field":
        val result = fields_share_access(["x", "y"], ["y", "z"])
        expect(result).to_equal(true)

    it "returns false when lists share no field":
        val result = fields_share_access(["x", "y"], ["z", "w"])
        expect(result).to_equal(false)

    it "returns false for empty lists":
        val result = fields_share_access([], [])
        expect(result).to_equal(false)

    it "returns false when one list is empty":
        val result = fields_share_access(["x"], [])
        expect(result).to_equal(false)

# ============================================================================
# lcom.spl — find_method_index
# ============================================================================

describe "find_method_index":
    it "finds existing method by name":
        val methods = [
            make_method("alpha", [], []),
            make_method("beta", [], []),
            make_method("gamma", [], [])
        ]
        expect(find_method_index(methods, "beta")).to_equal(1)

    it "returns -1 for missing method":
        val methods = [make_method("alpha", [], [])]
        expect(find_method_index(methods, "missing")).to_equal(-1)

    it "returns -1 for empty list":
        var methods: [MethodFieldAccess] = []
        expect(find_method_index(methods, "any")).to_equal(-1)

# ============================================================================
# lcom.spl — sort_descending
# ============================================================================

describe "sort_descending":
    it "sorts integers in descending order":
        val result = sort_descending([1, 3, 2, 5, 4])
        expect(result.get(0)).to_equal(5)
        expect(result.get(1)).to_equal(4)
        expect(result.get(2)).to_equal(3)

    it "handles single element":
        val result = sort_descending([42])
        expect(result.get(0)).to_equal(42)

    it "handles empty list":
        val result = sort_descending([])
        expect(result.len()).to_equal(0)

    it "handles already sorted input":
        val result = sort_descending([5, 4, 3, 2, 1])
        expect(result.get(0)).to_equal(5)
        expect(result.get(4)).to_equal(1)

# ============================================================================
# lcom.spl — compute_lcom4
# ============================================================================

describe "compute_lcom4":
    it "returns 0 for class with no methods":
        var methods: [MethodFieldAccess] = []
        val result = compute_lcom4("Empty", methods)
        expect(result.lcom4).to_equal(0)
        expect(result.method_count).to_equal(0)

    it "returns 1 for class with a single method":
        val methods = [make_method("do_thing", ["x"], [])]
        val result = compute_lcom4("Single", methods)
        expect(result.lcom4).to_equal(1)
        expect(result.method_count).to_equal(1)

    it "returns 1 for cohesive class (shared fields)":
        val methods = [
            make_method("get_x", ["x"], []),
            make_method("set_x", ["x"], []),
            make_method("compute", ["x", "y"], [])
        ]
        val result = compute_lcom4("Cohesive", methods)
        expect(result.lcom4).to_equal(1)
        expect(result.method_count).to_equal(3)

    it "returns 2 for non-cohesive class (disjoint methods)":
        val methods = [
            make_method("get_x", ["x"], []),
            make_method("get_y", ["y"], [])
        ]
        val result = compute_lcom4("Split", methods)
        expect(result.lcom4).to_equal(2)

    it "connects methods through method calls":
        val methods = [
            make_method("alpha", ["x"], []),
            make_method("beta", ["y"], ["alpha"])
        ]
        val result = compute_lcom4("Connected", methods)
        # alpha accesses x, beta accesses y but calls alpha => connected
        expect(result.lcom4).to_equal(1)

    it "counts fields correctly":
        val methods = [
            make_method("m1", ["a", "b"], []),
            make_method("m2", ["b", "c"], [])
        ]
        val result = compute_lcom4("FieldCount", methods)
        expect(result.field_count).to_equal(3)

    it "produces component_sizes that sum to method_count":
        val methods = [
            make_method("m1", ["a"], []),
            make_method("m2", ["a"], []),
            make_method("m3", ["b"], [])
        ]
        val result = compute_lcom4("Components", methods)
        expect(result.lcom4).to_equal(2)
        var total = 0
        var i = 0
        while i < result.component_sizes.len():
            total = total + result.component_sizes.get(i)
            i = i + 1
        expect(total).to_equal(3)

