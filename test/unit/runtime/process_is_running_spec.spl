# Regression test for rt_process_is_running with async-spawned children.
#
# Root cause (Round-13): rt_process_is_running used kill(pid,0) only.
# kill(pid,0) returns 0 for zombie processes (exited but not yet reaped),
# so a child that had exited was reported as still running.
# Fix: try waitpid(WNOHANG) first to correctly reap and detect exited children,
# then fall back to kill(pid,0)+errno for non-child processes.

use std.io.{file_read, process_run_timeout, process_spawn_async, process_is_running, process_wait, process_kill}

describe "rt_process_is_running with async-spawned children":
    it "reports async-spawned child as running while alive":
        # Spawn a child that sleeps for 5 seconds (long enough to check liveness)
        val pid = process_spawn_async("sleep", ["5"])
        expect(pid > 0).to_equal(true)

        # Child should be running immediately after spawn
        val running = process_is_running(pid)
        expect(running).to_equal(true)

        # Clean up: kill child and reap it
        process_wait(pid, 100)

    it "reports async-spawned child as not running after it exits":
        # Spawn a child that exits immediately
        val pid = process_spawn_async("true", [])
        expect(pid > 0).to_equal(true)

        # Wait for the child to finish
        val exit_code = process_wait(pid, 2000)
        expect(exit_code >= 0).to_equal(true)

        # After waitpid, process should not be running
        val running = process_is_running(pid)
        expect(running).to_equal(false)

    it "returns false for invalid pid zero":
        val running = process_is_running(0)
        expect(running).to_equal(false)

    it "returns false for negative pid":
        val running = process_is_running(-1)
        expect(running).to_equal(false)

    it "keeps invalid wait and kill pids behind facade guards":
        val src = file_read("src/lib/nogc_sync_mut/io/process_ops.spl")
        expect(src).to_contain("fn process_wait(pid: i64, timeout_ms: i64) -> i64:")
        expect(src).to_contain("if pid <= 0:")
        expect(src).to_contain("return -1")
        expect(src).to_contain("fn process_kill(pid: i64) -> bool:")
        expect(src).to_contain("if pid <= 1:")
        expect(src).to_contain("return false")

        val wait_code = process_wait(0, 1)
        expect(wait_code).to_equal(-1)
        expect(process_kill(0)).to_equal(false)

    it "times out without the external GNU timeout command":
        val src = file_read("src/lib/nogc_sync_mut/io/process_ops.spl")
        val c_runtime = file_read("src/runtime/platform/unix_common.h")
        val rust_runtime = file_read("src/compiler_rust/runtime/src/value/sffi/env_process.rs")
        expect(src.contains("rt_process_run(\"timeout\"")).to_equal(false)
        expect(src).to_contain("rt_process_spawn_async(\"/bin/sh\"")
        expect(src).to_contain("rt_process_wait(pid, effective_timeout)")
        expect(c_runtime).to_contain("if (kill((pid_t)pid, SIGKILL) != 0) return false")
        expect(c_runtime).to_contain("waitpid((pid_t)pid, &status, 0)")
        expect(c_runtime).to_contain("if (errno == ECHILD) break")
        expect(rust_runtime).to_contain("let reaped = child.wait().is_ok()")

        val (_stdout, stderr, exit_code) = process_run_timeout("sleep", ["2"], 50)
        expect(exit_code).to_equal(-1)
        expect(stderr).to_contain("[TIMEOUT:")
