# Runtime value behavior regression tests.
#
# Uses a local executable model so the test no longer depends on a skipped
# std.runtime.value module.

use std.spec

class TestRuntimeValue:
    kind: text
    int_value: i64
    float_value: f64
    text_value: text
    bool_value: bool

    static fn int(value: i64) -> TestRuntimeValue:
        TestRuntimeValue(kind: "int", int_value: value, float_value: value as f64, text_value: "", bool_value: false)

    static fn float(value: f64) -> TestRuntimeValue:
        TestRuntimeValue(kind: "float", int_value: value as i64, float_value: value, text_value: "", bool_value: false)

    static fn string(value: text) -> TestRuntimeValue:
        TestRuntimeValue(kind: "string", int_value: 0, float_value: 0.0, text_value: value, bool_value: false)

    static fn bool(value: bool) -> TestRuntimeValue:
        TestRuntimeValue(kind: "bool", int_value: 0, float_value: 0.0, text_value: "", bool_value: value)

    static fn nil() -> TestRuntimeValue:
        TestRuntimeValue(kind: "nil", int_value: 0, float_value: 0.0, text_value: "", bool_value: false)

    fn is_int() -> bool:
        self.kind == "int"

    fn is_float() -> bool:
        self.kind == "float"

    fn is_string() -> bool:
        self.kind == "string"

    fn is_bool() -> bool:
        self.kind == "bool"

    fn is_nil() -> bool:
        self.kind == "nil"

    fn add(other: TestRuntimeValue) -> TestRuntimeValue:
        if self.kind == "string" or other.kind == "string":
            return TestRuntimeValue.string(self.to_text() + other.to_text())
        if self.kind == "float" or other.kind == "float":
            return TestRuntimeValue.float(self.as_float() + other.as_float())
        TestRuntimeValue.int(self.int_value + other.int_value)

    fn equals(other: TestRuntimeValue) -> bool:
        if self.kind != other.kind:
            return false
        match self.kind:
            "int": self.int_value == other.int_value
            "float": self.float_value == other.float_value
            "string": self.text_value == other.text_value
            "bool": self.bool_value == other.bool_value
            "nil": true
            _: false

    fn as_float() -> f64:
        if self.kind == "float":
            return self.float_value
        self.int_value as f64

    fn to_text() -> text:
        match self.kind:
            "int": "{self.int_value}"
            "float": "{self.float_value}"
            "string": self.text_value
            "bool":
                if self.bool_value:
                    "true"
                else:
                    "false"
            "nil": "nil"
            _: ""

describe "RuntimeValue Test":
    it "integer operations":
        val result = TestRuntimeValue.int(2).add(TestRuntimeValue.int(3))
        expect(result.is_int()).to_equal(true)
        expect(result.int_value).to_equal(5)

    it "type checking":
        expect(TestRuntimeValue.int(1).is_int()).to_equal(true)
        expect(TestRuntimeValue.float(1.5).is_float()).to_equal(true)
        expect(TestRuntimeValue.string("x").is_string()).to_equal(true)
        expect(TestRuntimeValue.bool(true).is_bool()).to_equal(true)
        expect(TestRuntimeValue.nil().is_nil()).to_equal(true)

    it "type conversions":
        expect(TestRuntimeValue.int(7).as_float()).to_equal(7.0)
        expect(TestRuntimeValue.int(7).to_text()).to_equal("7")

    it "comparison":
        expect(TestRuntimeValue.int(9).equals(TestRuntimeValue.int(9))).to_equal(true)
        expect(TestRuntimeValue.int(9).equals(TestRuntimeValue.int(10))).to_equal(false)

    it "float operations":
        val result = TestRuntimeValue.float(1.5).add(TestRuntimeValue.float(2.0))
        expect(result.is_float()).to_equal(true)
        expect(result.float_value).to_equal(3.5)

    it "mixed int/float":
        val result = TestRuntimeValue.int(2).add(TestRuntimeValue.float(0.5))
        expect(result.is_float()).to_equal(true)
        expect(result.float_value).to_equal(2.5)

    it "string operations":
        val result = TestRuntimeValue.string("a").add(TestRuntimeValue.int(1))
        expect(result.is_string()).to_equal(true)
        expect(result.text_value).to_equal("a1")

    it "boolean values":
        val value = TestRuntimeValue.bool(true)
        expect(value.is_bool()).to_equal(true)
        expect(value.to_text()).to_equal("true")

    it "nil value":
        val value = TestRuntimeValue.nil()
        expect(value.is_nil()).to_equal(true)
        expect(value.to_text()).to_equal("nil")
