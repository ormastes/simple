# Progress Timing Test
#
# Local parser-safe coverage for the progress timing surface. The production
# progress APIs are not required for this spec to validate the intended shape.

fn check(condition: bool):
    expect(condition).to_equal(true)

class ProgressClock:
    elapsed: f64
    messages: [text]

    static fn create() -> ProgressClock:
        ProgressClock(elapsed: 0.0, messages: [])

    fn init_progress():
        self.elapsed = 0.0
        self.messages = []

    fn reset_progress():
        self.elapsed = 0.0
        self.messages = []

    fn progress(msg: text):
        self.messages = self.messages + [msg]
        self.elapsed = self.elapsed + 0.5

    fn progress_step(step: i64, total: i64, msg: text):
        self.progress("{step}/{total}: {msg}")

    fn get_elapsed_time() -> f64:
        self.elapsed

describe "Progress Timing":
    it "shows actual elapsed time using local progress helpers":
        val clock = ProgressClock.create()
        clock.init_progress()

        clock.progress("Starting test")

        var x = 0.0
        var i = 0
        while i < 10000:
            x = x + (i * 1.5) / (i + 1.0)
            i = i + 1

        clock.progress("After compute loop")
        clock.progress_step(1, 2, "First step done")
        clock.progress_step(2, 2, "Second step done")

        val elapsed = clock.get_elapsed_time()

        clock.reset_progress()

        check(elapsed > 0.0)
        check(clock.get_elapsed_time() == 0.0)
        check(clock.messages.len() == 0)
