# Dock, App Switcher, and Notification Center Unit Tests
#
# Tests for iOS-style system UI components.
# Defines types inline (interpreter mode does not resolve cross-file types).

# ============================================================================
# Inline Type Definitions (mirror source structs/classes)
# ============================================================================

struct DockItem:
    app_name: text
    icon_char: text
    is_pinned: bool
    is_running: bool
    window_id: i64

class Dock:
    items: [DockItem]
    visible: bool
    x: i64
    y: i64
    width: i64
    height: i64
    screen_width: i64
    screen_height: i64
    selected_index: i64
    auto_hide: bool
    hide_timer: i64

impl Dock:
    me add_pinned(app_name: text, icon_char: text):
        val item = DockItem(
            app_name: app_name, icon_char: icon_char,
            is_pinned: true, is_running: false, window_id: -1
        )
        self.items = self.items.push(item)

    me add_running(app_name: text, icon_char: text, window_id: i64):
        var idx: i64 = 0
        while idx < self.items.len():
            if self.items[idx].app_name == app_name:
                var item = self.items[idx]
                self.items[idx] = DockItem(
                    app_name: item.app_name, icon_char: item.icon_char,
                    is_pinned: item.is_pinned, is_running: true,
                    window_id: window_id
                )
                return
            idx = idx + 1
        val item = DockItem(
            app_name: app_name, icon_char: icon_char,
            is_pinned: false, is_running: true, window_id: window_id
        )
        self.items = self.items.push(item)

    me remove_running(window_id: i64):
        var new_items: [DockItem] = []
        var idx: i64 = 0
        while idx < self.items.len():
            val item = self.items[idx]
            if item.window_id == window_id:
                if item.is_pinned:
                    new_items = new_items.push(DockItem(
                        app_name: item.app_name, icon_char: item.icon_char,
                        is_pinned: true, is_running: false, window_id: -1
                    ))
            else:
                new_items = new_items.push(item)
            idx = idx + 1
        self.items = new_items

    me show():
        self.visible = true
        self.hide_timer = 300

    me hide():
        self.visible = false

    me toggle():
        if self.visible:
            self.visible = false
        else:
            self.visible = true
            self.hide_timer = 300

    me select_next():
        if self.items.len() == 0:
            return
        self.selected_index = (self.selected_index + 1) % self.items.len()

    me select_prev():
        if self.items.len() == 0:
            return
        self.selected_index = self.selected_index - 1
        if self.selected_index < 0:
            self.selected_index = self.items.len() - 1

    fn get_selected() -> DockItem?:
        if self.items.len() == 0:
            return nil
        if self.selected_index < 0 or self.selected_index >= self.items.len():
            return nil
        self.items[self.selected_index]

struct AppCard:
    window_id: i64
    title: text
    x: i64
    y: i64
    width: i64
    height: i64

class AppSwitcher:
    cards: [AppCard]
    visible: bool
    selected_index: i64
    screen_width: i64
    screen_height: i64

impl AppSwitcher:
    me show(window_ids: [i64], titles: [text]):
        var new_cards: [AppCard] = []
        var i: i64 = 0
        while i < window_ids.len():
            val title_str = if i < titles.len(): titles[i] else: "Window"
            new_cards = new_cards.push(AppCard(
                window_id: window_ids[i], title: title_str,
                x: 0, y: 0, width: 160, height: 120
            ))
            i = i + 1
        self.cards = new_cards
        self.selected_index = 0
        self.visible = true

    me hide():
        self.visible = false
        self.cards = []
        self.selected_index = 0

    me select_next():
        if self.cards.len() == 0:
            return
        self.selected_index = (self.selected_index + 1) % self.cards.len()

    me select_prev():
        if self.cards.len() == 0:
            return
        self.selected_index = self.selected_index - 1
        if self.selected_index < 0:
            self.selected_index = self.cards.len() - 1

    fn get_selected_window_id() -> i64:
        if self.cards.len() == 0:
            return -1
        if self.selected_index < 0 or self.selected_index >= self.cards.len():
            return -1
        self.cards[self.selected_index].window_id

    fn is_visible() -> bool:
        self.visible

    me close_selected() -> i64:
        if self.cards.len() == 0:
            return -1
        if self.selected_index < 0 or self.selected_index >= self.cards.len():
            return -1
        val closed_id = self.cards[self.selected_index].window_id
        var new_cards: [AppCard] = []
        var i: i64 = 0
        while i < self.cards.len():
            if i != self.selected_index:
                new_cards = new_cards.push(self.cards[i])
            i = i + 1
        self.cards = new_cards
        if self.cards.len() == 0:
            self.selected_index = 0
        elif self.selected_index >= self.cards.len():
            self.selected_index = self.cards.len() - 1
        closed_id

struct Notification:
    id: i64
    title: text
    body: text
    timestamp: i64
    read: bool
    app_name: text

class NotificationCenter:
    notifications: [Notification]
    visible: bool
    next_id: i64
    max_notifications: i64
    screen_width: i64

impl NotificationCenter:
    me push(title: text, body: text, app_name: text):
        val notif = Notification(
            id: self.next_id, title: title, body: body,
            timestamp: 0, read: false, app_name: app_name
        )
        self.next_id = self.next_id + 1
        var new_list: [Notification] = [notif]
        var i: i64 = 0
        while i < self.notifications.len():
            new_list = new_list.push(self.notifications[i])
            i = i + 1
        self.notifications = new_list

    me dismiss(notification_id: i64):
        var new_list: [Notification] = []
        var i: i64 = 0
        while i < self.notifications.len():
            if self.notifications[i].id != notification_id:
                new_list = new_list.push(self.notifications[i])
            i = i + 1
        self.notifications = new_list

    me clear_all():
        self.notifications = []

    me show():
        self.visible = true

    me hide():
        self.visible = false

    me toggle():
        if self.visible:
            self.visible = false
        else:
            self.visible = true

    fn unread_count() -> i64:
        var count: i64 = 0
        var i: i64 = 0
        while i < self.notifications.len():
            if not self.notifications[i].read:
                count = count + 1
            i = i + 1
        count

    fn is_visible() -> bool:
        self.visible

# ============================================================================
# Test Helpers
# ============================================================================

fn _make_test_dock() -> Dock:
    val items = [
        DockItem(app_name: "Terminal", icon_char: ">", is_pinned: true, is_running: false, window_id: -1),
        DockItem(app_name: "Editor", icon_char: "E", is_pinned: true, is_running: false, window_id: -1),
        DockItem(app_name: "Files", icon_char: "F", is_pinned: true, is_running: false, window_id: -1),
        DockItem(app_name: "Monitor", icon_char: "M", is_pinned: true, is_running: false, window_id: -1),
        DockItem(app_name: "Settings", icon_char: "S", is_pinned: true, is_running: false, window_id: -1)
    ]
    Dock(
        items: items, visible: true, x: 0, y: 0,
        width: 256, height: 64, screen_width: 1024,
        screen_height: 768, selected_index: 0,
        auto_hide: true, hide_timer: 300
    )

fn _make_test_switcher() -> AppSwitcher:
    AppSwitcher(
        cards: [], visible: false, selected_index: 0,
        screen_width: 1024, screen_height: 768
    )

fn _make_test_nc() -> NotificationCenter:
    NotificationCenter(
        notifications: [], visible: false, next_id: 1,
        max_notifications: 50, screen_width: 1024
    )

# ============================================================================
# Dock Creation
# ============================================================================

describe "Dock":
    it "creates with screen dimensions":
        val dock = _make_test_dock()
        expect(dock.screen_width).to_equal(1024)
        expect(dock.screen_height).to_equal(768)
        expect(dock.visible).to_equal(true)

    it "starts with selected_index at 0":
        val dock = _make_test_dock()
        expect(dock.selected_index).to_equal(0)

    it "has auto_hide enabled":
        val dock = _make_test_dock()
        expect(dock.auto_hide).to_equal(true)

    it "has 5 default items":
        val dock = _make_test_dock()
        expect(dock.items.len()).to_equal(5)

# ============================================================================
# Default Dock Items
# ============================================================================

describe "DockItem defaults":
    it "first item is Terminal":
        val dock = _make_test_dock()
        expect(dock.items[0].app_name).to_equal("Terminal")
        expect(dock.items[0].icon_char).to_equal(">")

    it "all items are pinned":
        val dock = _make_test_dock()
        expect(dock.items[0].is_pinned).to_equal(true)
        expect(dock.items[4].is_pinned).to_equal(true)

    it "no items are running":
        val dock = _make_test_dock()
        expect(dock.items[0].is_running).to_equal(false)
        expect(dock.items[0].window_id).to_equal(-1)

# ============================================================================
# Dock Item Management
# ============================================================================

describe "Dock add_pinned":
    it "adds a pinned item":
        var dock = _make_test_dock()
        val before = dock.items.len()
        dock.add_pinned("Browser", "B")
        expect(dock.items.len()).to_equal(before + 1)

    it "new pinned item is not running":
        var dock = _make_test_dock()
        dock.add_pinned("Browser", "B")
        val last = dock.items[dock.items.len() - 1]
        expect(last.is_pinned).to_equal(true)
        expect(last.is_running).to_equal(false)

describe "Dock add_running":
    it "marks existing pinned item as running":
        var dock = _make_test_dock()
        dock.add_running("Terminal", ">", 42)
        expect(dock.items[0].is_running).to_equal(true)
        expect(dock.items[0].window_id).to_equal(42)

    it "adds new unpinned running item":
        var dock = _make_test_dock()
        val before = dock.items.len()
        dock.add_running("Browser", "B", 99)
        expect(dock.items.len()).to_equal(before + 1)

describe "Dock remove_running":
    it "marks pinned item as not running":
        var dock = _make_test_dock()
        dock.add_running("Terminal", ">", 42)
        dock.remove_running(42)
        expect(dock.items[0].is_running).to_equal(false)
        expect(dock.items[0].window_id).to_equal(-1)

    it "removes unpinned running item entirely":
        var dock = _make_test_dock()
        val before = dock.items.len()
        dock.add_running("Browser", "B", 99)
        expect(dock.items.len()).to_equal(before + 1)
        dock.remove_running(99)
        expect(dock.items.len()).to_equal(before)

# ============================================================================
# Dock Selection
# ============================================================================

describe "Dock selection":
    it "select_next advances index":
        var dock = _make_test_dock()
        expect(dock.selected_index).to_equal(0)
        dock.select_next()
        expect(dock.selected_index).to_equal(1)

    it "select_next wraps around":
        var dock = _make_test_dock()
        var i: i64 = 0
        while i < dock.items.len():
            dock.select_next()
            i = i + 1
        expect(dock.selected_index).to_equal(0)

    it "select_prev wraps to end":
        var dock = _make_test_dock()
        dock.select_prev()
        expect(dock.selected_index).to_equal(dock.items.len() - 1)

    it "get_selected returns current item":
        var dock = _make_test_dock()
        val selected = dock.get_selected()
        expect(selected.unwrap().app_name).to_equal("Terminal")

# ============================================================================
# Dock Visibility
# ============================================================================

describe "Dock visibility":
    it "show makes visible":
        var dock = _make_test_dock()
        dock.hide()
        expect(dock.visible).to_equal(false)
        dock.show()
        expect(dock.visible).to_equal(true)

    it "hide makes invisible":
        var dock = _make_test_dock()
        dock.hide()
        expect(dock.visible).to_equal(false)

    it "toggle flips visibility":
        var dock = _make_test_dock()
        expect(dock.visible).to_equal(true)
        dock.toggle()
        expect(dock.visible).to_equal(false)
        dock.toggle()
        expect(dock.visible).to_equal(true)

# ============================================================================
# App Switcher
# ============================================================================

describe "AppSwitcher":
    it "creates hidden":
        val switcher = _make_test_switcher()
        expect(switcher.is_visible()).to_equal(false)

    it "show displays cards":
        var switcher = _make_test_switcher()
        switcher.show([1, 2, 3], ["A", "B", "C"])
        expect(switcher.is_visible()).to_equal(true)
        expect(switcher.cards.len()).to_equal(3)

    it "select_next advances":
        var switcher = _make_test_switcher()
        switcher.show([1, 2], ["A", "B"])
        expect(switcher.selected_index).to_equal(0)
        switcher.select_next()
        expect(switcher.selected_index).to_equal(1)

    it "get_selected_window_id returns correct id":
        var switcher = _make_test_switcher()
        switcher.show([10, 20, 30], ["A", "B", "C"])
        expect(switcher.get_selected_window_id()).to_equal(10)
        switcher.select_next()
        expect(switcher.get_selected_window_id()).to_equal(20)

    it "returns -1 when empty":
        val switcher = _make_test_switcher()
        expect(switcher.get_selected_window_id()).to_equal(-1)

    it "hide clears cards":
        var switcher = _make_test_switcher()
        switcher.show([1, 2], ["A", "B"])
        switcher.hide()
        expect(switcher.is_visible()).to_equal(false)
        expect(switcher.cards.len()).to_equal(0)

    it "close_selected removes card":
        var switcher = _make_test_switcher()
        switcher.show([10, 20, 30], ["A", "B", "C"])
        val closed = switcher.close_selected()
        expect(closed).to_equal(10)
        expect(switcher.cards.len()).to_equal(2)

# ============================================================================
# Notification Center
# ============================================================================

describe "NotificationCenter":
    it "creates empty and hidden":
        val nc = _make_test_nc()
        expect(nc.is_visible()).to_equal(false)
        expect(nc.notifications.len()).to_equal(0)
        expect(nc.unread_count()).to_equal(0)

    it "push adds notification":
        var nc = _make_test_nc()
        nc.push("Title1", "Body1", "Terminal")
        expect(nc.notifications.len()).to_equal(1)
        expect(nc.unread_count()).to_equal(1)

    it "push adds newest first":
        var nc = _make_test_nc()
        nc.push("First", "Body1", "App1")
        nc.push("Second", "Body2", "App2")
        expect(nc.notifications[0].title).to_equal("Second")
        expect(nc.notifications[1].title).to_equal("First")

    it "dismiss removes by id":
        var nc = _make_test_nc()
        nc.push("Title1", "Body1", "App1")
        nc.push("Title2", "Body2", "App2")
        val first_id = nc.notifications[1].id
        nc.dismiss(first_id)
        expect(nc.notifications.len()).to_equal(1)
        expect(nc.notifications[0].title).to_equal("Title2")

    it "clear_all removes everything":
        var nc = _make_test_nc()
        nc.push("A", "a", "App")
        nc.push("B", "b", "App")
        nc.push("C", "c", "App")
        expect(nc.notifications.len()).to_equal(3)
        nc.clear_all()
        expect(nc.notifications.len()).to_equal(0)
        expect(nc.unread_count()).to_equal(0)

    it "unread_count tracks unread":
        var nc = _make_test_nc()
        nc.push("A", "a", "App")
        nc.push("B", "b", "App")
        expect(nc.unread_count()).to_equal(2)

    it "toggle flips visibility":
        var nc = _make_test_nc()
        nc.toggle()
        expect(nc.is_visible()).to_equal(true)
        nc.toggle()
        expect(nc.is_visible()).to_equal(false)
