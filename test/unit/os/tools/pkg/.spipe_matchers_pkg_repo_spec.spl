use std.spipe.*
use os.tools.pkg.pkg_repository.{parse_http_url}

describe "parse_http_url":

    it "parses a basic URL with no port and no path":
        val result = parse_http_url("http://repo.example.com")
        expect result.0 == "repo.example.com"
        expect result.1 == 80
        expect result.2 == "/"

    it "parses a URL with explicit port and path":
        val result = parse_http_url("http://repo.example.com:8080/index.sdn")
        expect result.0 == "repo.example.com"
        expect result.1 == 8080
        expect result.2 == "/index.sdn"

    it "parses a URL with default port and sub-path":
        val result = parse_http_url("http://pkg.simpleos.org/v1/index.sdn")
        expect result.0 == "pkg.simpleos.org"
        expect result.1 == 80
        expect result.2 == "/v1/index.sdn"

    it "parses an https URL stripping scheme":
        val result = parse_http_url("https://secure.example.com:443/pkgs/index.sdn")
        expect result.0 == "secure.example.com"
        expect result.1 == 443
        expect result.2 == "/pkgs/index.sdn"

    it "defaults to port 443 for https URL without explicit port":
        val result = parse_http_url("https://secure.example.com/pkgs/index.sdn")
        expect result.0 == "secure.example.com"
        expect result.1 == 443
        expect result.2 == "/pkgs/index.sdn"