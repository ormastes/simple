# @cover src/os/tools/dev/lsusb_tool.spl 60%
"""
# lsusb PCI Class Filter Specification

**Feature IDs:** N/A
**Category:** Tooling
**Difficulty:** 1/5
**Status:** Implemented

## Overview

Verifies that `is_usb_controller` correctly identifies USB host controllers
by PCI class 0x0C and subclass 0x03, and rejects other class/subclass pairs.
"""

use std.sspec.*
use os.tools.dev.lsusb_tool.{is_usb_controller}

describe "is_usb_controller PCI class filter":

    it "accepts class 0x0C subclass 0x03 as a USB controller":
        val result = is_usb_controller(0x0C, 0x03)
        expect(result).to_equal(true)

    it "rejects class 0x01 (mass storage) as not USB":
        val result = is_usb_controller(0x01, 0x06)
        expect(result).to_equal(false)

    it "rejects class 0x0C with wrong subclass as not USB":
        val result = is_usb_controller(0x0C, 0x00)
        expect(result).to_equal(false)

    it "rejects class 0x02 (network) as not USB":
        val result = is_usb_controller(0x02, 0x00)
        expect(result).to_equal(false)

    it "rejects class 0x03 (display) as not USB":
        val result = is_usb_controller(0x03, 0x00)
        expect(result).to_equal(false)
