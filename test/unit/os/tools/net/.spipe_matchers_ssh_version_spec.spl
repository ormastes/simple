# @cover src/os/tools/net/ssh_tool.spl 30%
"""
# SSH Version String Specification

**Feature IDs:** #SSH1
**Category:** Infrastructure
**Difficulty:** 1/5
**Status:** Implemented

## Overview

Verifies that the SSH version string builder produces the correct
RFC 4253 identification string: "SSH-2.0-SimpleOS_1.0\\r\\n".
"""

use std.spipe.*
use os.apps.sshd.ssh_transport.{ssh_build_version_string}

describe "ssh_build_version_string":

    it "produces exactly 22 bytes":
        var buf: [u8] = ssh_build_version_string()
        expect buf.len() == 22

    it "starts with SSH-2.0-SimpleOS_1.0":
        var buf: [u8] = ssh_build_version_string()
        # S=0x53, S=0x53, H=0x48, -=0x2D
        expect buf[0] == 0x53
        expect buf[1] == 0x53
        expect buf[2] == 0x48
        expect buf[3] == 0x2D

    it "ends with CR LF":
        var buf: [u8] = ssh_build_version_string()
        expect buf[20] == 0x0D
        expect buf[21] == 0x0A

    it "contains version 2.0 marker bytes":
        var buf: [u8] = ssh_build_version_string()
        # '2'=0x32, '.'=0x2E, '0'=0x30
        expect buf[4] == 0x32
        expect buf[5] == 0x2E
        expect buf[6] == 0x30