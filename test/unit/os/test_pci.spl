fn check(n: text, v: bool):
    if v:
        print "OK: {n}"
    else:
        print "FAIL: {n}"
fn pci_bdf(bus: i64, dev: i64, f: i64) -> i64:
    (1 << 31) | (bus << 16) | (dev << 11) | (f << 8)
fn main():
    print "=== PCI ==="
    var a = pci_bdf(1, 2, 3) | (0x10 & 0xFC)
    check("enable", (a >> 31) == 1)
    check("bus=1", ((a >> 16) & 0xFF) == 1)
    check("dev=2", ((a >> 11) & 0x1F) == 2)
    check("fn=3", ((a >> 8) & 7) == 3)
    check("off", (a & 0xFC) == 0x10)
    print "=== DONE ==="
