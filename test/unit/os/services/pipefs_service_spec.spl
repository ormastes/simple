# @cover src/os/services/pipefs_service.spl 80%
"""
# PipefsService Specification (G7)

**Feature IDs:** #G7
**Category:** Infrastructure
**Difficulty:** 2/5
**Status:** Implemented

## Overview

Pipe filesystem capsule backed by ECS. Validates pipe creation,
buffer accounting (write and read notifications), close-side bitmask
semantics, and pipe count lifecycle.
"""

use std.spec
use os.services.pipefs_service.{PipefsService, PIPE_OPEN, PIPE_READER, PIPE_WRITER, PIPE_BOTH}

describe "PipefsService initial state":
    """
    ## Initial State

    A freshly constructed PipefsService must have zero pipes and
    the close-side constants at their specified values.
    """

    it "constructs with zero pipes":
        """Verify the pipe count starts at 0 on a fresh service."""
        val svc = PipefsService.new()
        expect(svc.pipe_count()).to_equal(0)

    it "PIPE_OPEN constant equals 0":
        """Neither-side-closed constant must be 0."""
        expect(PIPE_OPEN).to_equal(0)

    it "PIPE_READER constant equals 1":
        """Reader-closed constant must be 1."""
        expect(PIPE_READER).to_equal(1)

    it "PIPE_WRITER constant equals 2":
        """Writer-closed constant must be 2."""
        expect(PIPE_WRITER).to_equal(2)

    it "PIPE_BOTH constant equals 3":
        """Both-closed constant must be 3."""
        expect(PIPE_BOTH).to_equal(3)

describe "PipefsService pipe_create":
    """
    ## Pipe Creation

    Validates that pipe_create increments the count, returns a live
    entity, and that the new pipe has no closed ends.
    """

    it "create returns entity with positive id":
        """pipe_create must return an entity with id > 0."""
        var svc = PipefsService.new()
        val pipe = svc.pipe_create(10, 20, 4096)
        expect(pipe.id).to_be_greater_than(0)

    it "create increments pipe count":
        """After one pipe_create the count must be 1."""
        var svc = PipefsService.new()
        val _pipe = svc.pipe_create(10, 20, 4096)
        expect(svc.pipe_count()).to_equal(1)

    it "new pipe is not closed on reader side":
        """A freshly created pipe must not have PIPE_READER set."""
        var svc = PipefsService.new()
        val pipe = svc.pipe_create(10, 20, 4096)
        expect(svc.pipe_is_closed(pipe, PIPE_READER)).to_equal(false)

describe "PipefsService pipe_write_notify and pipe_read_notify":
    """
    ## Buffer Accounting

    Validates that write_notify accumulates bytes and read_notify
    decrements them, with clamping to 0.
    """

    it "write_notify returns new buffered count":
        """pipe_write_notify must return the total bytes after adding."""
        var svc = PipefsService.new()
        val pipe = svc.pipe_create(10, 20, 4096)
        val count = svc.pipe_write_notify(pipe, 512)
        expect(count).to_equal(512)

    it "write_notify accumulates across calls":
        """Two write_notify calls must sum the bytes."""
        var svc = PipefsService.new()
        val pipe = svc.pipe_create(10, 20, 4096)
        val _c1 = svc.pipe_write_notify(pipe, 200)
        val c2 = svc.pipe_write_notify(pipe, 100)
        expect(c2).to_equal(300)

    it "read_notify decrements buffered bytes":
        """After writing 512 and reading 200, 312 bytes must remain."""
        var svc = PipefsService.new()
        val pipe = svc.pipe_create(10, 20, 4096)
        val _w = svc.pipe_write_notify(pipe, 512)
        svc.pipe_read_notify(pipe, 200)
        val after = svc.pipe_write_notify(pipe, 0)
        expect(after).to_equal(312)

describe "PipefsService pipe_close and pipe_is_closed":
    """
    ## Close Semantics

    Validates bitmask OR accumulation, state-change detection, and
    full-both-sides closure.
    """

    it "close reader returns true (state changed)":
        """pipe_close on an open pipe must return true."""
        var svc = PipefsService.new()
        val pipe = svc.pipe_create(10, 20, 4096)
        val changed = svc.pipe_close(pipe, PIPE_READER)
        expect(changed).to_equal(true)

    it "pipe_is_closed reader after close":
        """After closing reader, pipe_is_closed(PIPE_READER) must be true."""
        var svc = PipefsService.new()
        val pipe = svc.pipe_create(10, 20, 4096)
        val _ok = svc.pipe_close(pipe, PIPE_READER)
        expect(svc.pipe_is_closed(pipe, PIPE_READER)).to_equal(true)

    it "close same side twice returns false (no new bits)":
        """A second close of the same side must return false (idempotent)."""
        var svc = PipefsService.new()
        val pipe = svc.pipe_create(10, 20, 4096)
        val _first = svc.pipe_close(pipe, PIPE_WRITER)
        val second = svc.pipe_close(pipe, PIPE_WRITER)
        expect(second).to_equal(false)

    it "close both sides sets PIPE_BOTH":
        """Closing reader then writer must make pipe_is_closed(PIPE_BOTH) true."""
        var svc = PipefsService.new()
        val pipe = svc.pipe_create(10, 20, 4096)
        val _r = svc.pipe_close(pipe, PIPE_READER)
        val _w = svc.pipe_close(pipe, PIPE_WRITER)
        expect(svc.pipe_is_closed(pipe, PIPE_BOTH)).to_equal(true)

    it "writer not closed when only reader closed":
        """After closing reader only, pipe_is_closed(PIPE_WRITER) must be false."""
        var svc = PipefsService.new()
        val pipe = svc.pipe_create(10, 20, 4096)
        val _ok = svc.pipe_close(pipe, PIPE_READER)
        expect(svc.pipe_is_closed(pipe, PIPE_WRITER)).to_equal(false)
