use std.spec
use os.services.launcher.launcher.{
    _seeded_app_name_for_path,
    _seeded_app_icon_for_path,
    _seeded_app_key_for_path
}

describe "Launcher seeded app metadata":
    it "resolves Simple tool aliases through one seeded metadata table":
        expect _seeded_app_name_for_path("/sys/apps/simple_browser") == "Simple Browser"
        expect _seeded_app_name_for_path("/sys/apps/sbrowser.smf") == "Simple Browser"
        expect _seeded_app_icon_for_path("/SYS/APPS/SBROWSMF.SMF") == "W"
        expect _seeded_app_key_for_path("/SYS/APPS/SBROWSMF.SMF") == 0x57

        expect _seeded_app_name_for_path("/sys/apps/simple_compiler.smf") == "Simple Compiler"
        expect _seeded_app_icon_for_path("/SYS/APPS/SCOMPSMF.SMF") == "C"
        expect _seeded_app_key_for_path("/SYS/APPS/SCOMPSMF.SMF") == 0x43

        expect _seeded_app_name_for_path("/sys/apps/simple_loader.smf") == "Simple Loader"
        expect _seeded_app_icon_for_path("/SYS/APPS/SLOADSMF.SMF") == "O"
        expect _seeded_app_key_for_path("/SYS/APPS/SLOADSMF.SMF") == 0x4F

    it "resolves toolchain app aliases through one seeded metadata table":
        expect _seeded_app_name_for_path("/sys/apps/llvm.smf") == "LLVM"
        expect _seeded_app_icon_for_path("/SYS/APPS/LLVMSMF.SMF") == "L"
        expect _seeded_app_key_for_path("/SYS/APPS/LLVMSMF.SMF") == 0x4C

        expect _seeded_app_name_for_path("/sys/apps/clang.smf") == "Clang"
        expect _seeded_app_icon_for_path("/SYS/APPS/CLANGSMF.SMF") == "K"
        expect _seeded_app_key_for_path("/SYS/APPS/CLANGSMF.SMF") == 0x47

        expect _seeded_app_name_for_path("/sys/apps/rust.smf") == "Rust"
        expect _seeded_app_icon_for_path("/SYS/APPS/RUSTSMF.SMF") == "R"
        expect _seeded_app_key_for_path("/SYS/APPS/RUSTSMF.SMF") == 0x52