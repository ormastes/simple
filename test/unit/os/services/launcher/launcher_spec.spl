"""
# Launcher Registry Specification

Tests the launcher app registry and process bookkeeping helpers.
The spec uses a seeded process record so it can validate state
transitions without relying on a real spawned binary in the unit runner.
"""

use std.spec
use os.services.launcher.launcher.{
    launcher_init, launcher_register, launcher_unregister,
    launcher_find_by_name, launcher_find_process_by_pid,
    launcher_get_app_count, launcher_get_running_app_count,
    launcher_get_app_name, launcher_get_app_path, launcher_get_app_identity,
    launcher_get_app_launch_state, launcher_get_app_window_count,
    launcher_get_app_exit_code, launcher_get_app_launch_count,
    launcher_get_app_last_pid, launcher_get_app_is_headless,
    launcher_is_running, launcher_get_pid,
    launcher_get_process_count, launcher_get_running_process_count,
    launcher_get_process_pid, launcher_get_process_app_index,
    launcher_get_process_name, launcher_get_process_path,
    launcher_get_process_app_id, launcher_get_process_app_id_for_pid,
    launcher_get_process_icon, launcher_get_process_state,
    launcher_get_process_exit_code, launcher_get_process_window_count,
    launcher_get_process_is_headless, launcher_get_process_launch_seq,
    launcher_get_last_launch_pid,
    launcher_process_is_process_backed,
    launcher_launch_path_with_args,
    launcher_record_process, launcher_note_window_opened,
    launcher_note_window_closed, launcher_mark_exited,
    launcher_mark_exited_with_code, launcher_terminate,
    launcher_note_task_probe, launcher_associated_app_for_path,
    launcher_resolve_command_path, launcher_command_resolution_candidates,
    MOD_META
}

describe "Launcher registry":
    it "seeds built-in apps with manifest-backed binary identities":
        launcher_init()
        expect(launcher_get_app_path(0)).to_equal("/sys/apps/hello_world.smf")
        expect(launcher_get_app_identity(0)).to_equal("/sys/apps/hello_world.smf")
        expect(launcher_get_app_path(1)).to_equal("/sys/apps/file_manager.smf")
        expect(launcher_get_app_path(2)).to_equal("/sys/apps/shell.smf")
        expect(launcher_get_app_path(3)).to_equal("/sys/apps/browser_demo.smf")

    it "registers apps with idle launch state":
        launcher_init()
        val registered = launcher_register("Demo App", "/apps/demo", "D", 0x44, MOD_META)
        expect(registered).to_equal(true)
        expect(launcher_get_app_count()).to_equal(6)
        expect(launcher_find_by_name("Demo App")).to_equal(5)
        expect(launcher_get_app_name(5)).to_equal("Demo App")
        expect(launcher_get_app_path(5)).to_equal("/apps/demo")
        expect(launcher_get_app_identity(5)).to_equal("/apps/demo")
        expect(launcher_get_app_launch_state(5)).to_equal("idle")
        expect(launcher_get_app_window_count(5)).to_equal(0)
        expect(launcher_get_app_exit_code(5)).to_equal(0)
        expect(launcher_get_app_launch_count(5)).to_equal(0)
        expect(launcher_get_app_last_pid(5)).to_equal(0)
        expect(launcher_get_app_is_headless(5)).to_equal(false)
        expect(launcher_get_running_app_count()).to_equal(0)
        expect(launcher_get_process_count()).to_equal(0)

    it "maps text and image files to the default opener app":
        launcher_init()
        expect(launcher_associated_app_for_path("/home/readme.txt")).to_equal("/sys/apps/editor")
        expect(launcher_associated_app_for_path("/home/notes.spl")).to_equal("/sys/apps/editor")
        expect(launcher_associated_app_for_path("/home/picture.png")).to_equal("/sys/apps/image_viewer")
        expect(launcher_associated_app_for_path("/home/archive.bin")).to_equal("")

    it "returns empty for an unknown command path":
        launcher_init()
        expect(launcher_resolve_command_path("definitely_missing_simpleos_command", "/", "")).to_equal("")

    it "prefers staged /sys/apps payloads before PATH lookups":
        val candidates = launcher_command_resolution_candidates("info", "/", "/bin:/usr/bin")
        expect(candidates[0]).to_equal("/sys/apps/info.smf")
        expect(candidates[1]).to_equal("/sys/apps/info")
        expect(candidates[2]).to_equal("/bin/info")
        expect(candidates[3]).to_equal("/usr/bin/info")

    it "normalizes migrated aliases before building sys-app candidates":
        val candidates = launcher_command_resolution_candidates("sbrowser", "/", "")
        expect(candidates[0]).to_equal("/sys/apps/simple_browser.smf")
        expect(candidates[1]).to_equal("/sys/apps/simple_browser")

        val compiler_candidates = launcher_command_resolution_candidates("scompiler.smf", "/", "")
        expect(compiler_candidates[0]).to_equal("/sys/apps/simple_compiler.smf")
        expect(compiler_candidates[1]).to_equal("/sys/apps/simple_compiler")

    it "keeps explicit paths ahead of catalog lookup":
        val candidates = launcher_command_resolution_candidates("./info", "/tmp/work", "/bin")
        expect(candidates.len()).to_equal(1)
        expect(candidates[0]).to_equal("/tmp/work/./info")

    it "canonicalizes seeded process rows to stable sys-app identity":
        launcher_init()
        val pid: u64 = 8022
        expect(launcher_record_process(pid, 5, "running", 0, 0, true)).to_equal(true)
        expect(launcher_get_process_path(0)).to_equal("/sys/apps/simple_browser.smf")
        expect(launcher_get_process_app_id(0)).to_equal("/sys/apps/simple_browser")
        expect(launcher_get_process_app_id_for_pid(pid)).to_equal("/sys/apps/simple_browser")

    it "tracks process snapshots and window counts":
        launcher_init()
        launcher_register("Demo App", "/apps/demo", "D", 0x44, MOD_META)
        val seeded = launcher_record_process(101, 5, "running", 0, 0, true)
        expect(seeded).to_equal(true)
        expect(launcher_get_running_app_count()).to_equal(1)
        expect(launcher_is_running(5)).to_equal(true)
        expect(launcher_get_pid(5)).to_equal(101)
        expect(launcher_get_app_launch_state(5)).to_equal("running")
        expect(launcher_get_app_window_count(5)).to_equal(0)
        expect(launcher_get_app_is_headless(5)).to_equal(true)
        expect(launcher_get_process_count()).to_equal(1)
        expect(launcher_get_running_process_count()).to_equal(1)
        expect(launcher_get_process_pid(0)).to_equal(101)
        expect(launcher_get_process_app_index(0)).to_equal(5)
        expect(launcher_get_process_name(0)).to_equal("Demo App")
        expect(launcher_get_process_path(0)).to_equal("/apps/demo")
        expect(launcher_get_process_app_id(0)).to_equal("/apps/demo")
        expect(launcher_get_process_app_id_for_pid(101)).to_equal("/apps/demo")
        expect(launcher_get_process_icon(0)).to_equal("D")
        expect(launcher_get_process_state(0)).to_equal("running")
        expect(launcher_get_process_exit_code(0)).to_equal(0)
        expect(launcher_get_process_window_count(0)).to_equal(0)
        expect(launcher_get_process_is_headless(0)).to_equal(true)
        expect(launcher_get_process_launch_seq(0)).to_equal(1)
        expect(launcher_process_is_process_backed(101)).to_equal(true)

        launcher_note_window_opened(101)
        expect(launcher_get_app_window_count(5)).to_equal(1)
        expect(launcher_get_app_is_headless(5)).to_equal(false)
        expect(launcher_get_process_window_count(0)).to_equal(1)
        expect(launcher_get_process_is_headless(0)).to_equal(false)

        launcher_note_window_closed(101)
        expect(launcher_get_app_window_count(5)).to_equal(0)
        expect(launcher_get_app_is_headless(5)).to_equal(true)
        expect(launcher_get_process_window_count(0)).to_equal(0)
        expect(launcher_get_process_is_headless(0)).to_equal(true)

    it "rejects synthetic and unknown pids as process-backed rows":
        launcher_init()
        launcher_register("Demo App", "/apps/demo", "D", 0x44, MOD_META)
        expect(launcher_process_is_process_backed(404)).to_equal(false)
        expect(launcher_record_process(0x40000010, -1, "running", 0, 0, true)).to_equal(true)
        expect(launcher_process_is_process_backed(0x40000010)).to_equal(false)

    it "clears stale last launch state on init":
        launcher_init()
        expect(launcher_record_process(101, 0, "running", 0, 0, true)).to_equal(true)
        launcher_init()
        expect(launcher_get_last_launch_pid()).to_equal(0)

    it "materializes seeded metadata before reporting spawn failure":
        launcher_init()
        launcher_unregister("Hello World")
        launcher_unregister("File Manager")
        launcher_unregister("Terminal")
        launcher_unregister("Browser Demo")
        launcher_unregister("Editor")
        expect(launcher_get_app_count()).to_equal(0)

        val pid = launcher_launch_path_with_args("/sys/apps/browser_demo.smf", [])
        expect(pid).to_be_less_than(0)
        expect(launcher_get_app_count()).to_equal(4)
        expect(launcher_get_app_name(3)).to_equal("Browser Demo")
        expect(launcher_get_app_path(3)).to_equal("/sys/apps/browser_demo.smf")
        expect(launcher_get_pid(3)).to_equal(0)
        expect(launcher_get_app_launch_state(3)).to_equal("failed")
        expect(launcher_get_app_window_count(3)).to_equal(0)
        expect(launcher_get_process_count()).to_equal(0)

    it "appends a new row when a kernel pid is reused after exit":
        launcher_init()
        launcher_register("Demo App", "/apps/demo", "D", 0x44, MOD_META)
        expect(launcher_record_process(505, 5, "running", 0, 0, true)).to_equal(true)
        launcher_mark_exited_with_code(505, 0)
        expect(launcher_record_process(505, 5, "running", 0, 0, true)).to_equal(true)
        expect(launcher_get_process_count()).to_equal(2)
        expect(launcher_get_process_state(0)).to_equal("exited")
        expect(launcher_get_process_state(1)).to_equal("running")
        expect(launcher_get_process_launch_seq(1)).to_equal(2)

    it "marks exits and preserves exit codes":
        launcher_init()
        launcher_register("Demo App", "/apps/demo", "D", 0x44, MOD_META)
        launcher_record_process(101, 5, "running", 0, 0, true)
        launcher_mark_exited(101)
        expect(launcher_get_pid(5)).to_equal(0)
        expect(launcher_get_app_launch_state(5)).to_equal("exited")
        expect(launcher_get_app_exit_code(5)).to_equal(-1)
        expect(launcher_get_running_app_count()).to_equal(0)
        expect(launcher_get_running_process_count()).to_equal(0)
        expect(launcher_get_process_state(0)).to_equal("exited")
        expect(launcher_get_process_exit_code(0)).to_equal(-1)
        expect(launcher_get_process_is_headless(0)).to_equal(true)

    it "stores explicit exit codes":
        launcher_init()
        launcher_register("Demo App", "/apps/demo", "D", 0x44, MOD_META)
        launcher_record_process(101, 5, "running", 0, 0, true)
        launcher_mark_exited_with_code(101, 7)
        expect(launcher_get_pid(5)).to_equal(0)
        expect(launcher_get_app_launch_state(5)).to_equal("crashed")
        expect(launcher_get_app_exit_code(5)).to_equal(7)
        expect(launcher_get_running_app_count()).to_equal(0)
        expect(launcher_get_running_process_count()).to_equal(0)
        expect(launcher_get_process_state(0)).to_equal("crashed")
        expect(launcher_get_process_exit_code(0)).to_equal(7)
        expect(launcher_get_process_is_headless(0)).to_equal(true)
        expect(launcher_get_process_window_count(0)).to_equal(0)

    it "keeps terminate flows separate from crash exits":
        launcher_init()
        launcher_register("Demo App", "/apps/demo", "D", 0x44, MOD_META)
        launcher_record_process(101, 5, "running", 0, 2, false)
        launcher_terminate(101)
        expect(launcher_get_process_state(0)).to_equal("terminating")
        expect(launcher_get_app_launch_state(5)).to_equal("terminating")
        launcher_mark_exited_with_code(101, 15)
        expect(launcher_get_pid(5)).to_equal(0)
        expect(launcher_get_app_launch_state(5)).to_equal("terminated")
        expect(launcher_get_app_exit_code(5)).to_equal(15)
        expect(launcher_get_app_window_count(5)).to_equal(0)
        expect(launcher_get_process_state(0)).to_equal("terminated")
        expect(launcher_get_process_exit_code(0)).to_equal(15)
        expect(launcher_get_process_window_count(0)).to_equal(0)
        expect(launcher_get_process_is_headless(0)).to_equal(true)

    it "fails terminate requests without mutating registry state":
        launcher_init()
        launcher_register("Demo App", "/apps/demo", "D", 0x44, MOD_META)
        launcher_record_process(101, 5, "running", 0, 0, true)
        val terminated = launcher_terminate(999999)
        expect(terminated).to_equal(false)
        expect(launcher_get_process_state(0)).to_equal("running")
        expect(launcher_get_app_launch_state(5)).to_equal("running")
        expect(launcher_get_running_process_count()).to_equal(1)

    it "compacts registry and keeps process app indices aligned":
        launcher_init()
        launcher_register("Demo A", "/apps/demo_a", "A", 0x41, MOD_META)
        launcher_register("Demo B", "/apps/demo_b", "B", 0x42, MOD_META)
        launcher_record_process(201, 5, "running", 0, 0, true)
        launcher_record_process(202, 6, "running", 0, 0, true)
        val removed = launcher_unregister("Demo A")
        expect(removed).to_equal(true)
        expect(launcher_find_by_name("Demo A")).to_equal(-1)
        expect(launcher_find_by_name("Demo B")).to_equal(5)
        expect(launcher_get_app_count()).to_equal(6)
        expect(launcher_get_app_name(5)).to_equal("Demo B")
        expect(launcher_get_process_count()).to_equal(2)
        expect(launcher_find_process_by_pid(202)).to_equal(1)
        expect(launcher_get_process_app_index(1)).to_equal(5)
        expect(launcher_get_process_name(1)).to_equal("Demo B")

describe "Launcher task reaper":
    it "leaves live probes untouched":
        launcher_init()
        launcher_register("Demo App", "/apps/demo", "D", 0x44, MOD_META)
        launcher_record_process(301, 5, "running", 0, 0, true)
        launcher_note_task_probe(301, true, 0)
        expect(launcher_get_process_state(0)).to_equal("running")
        expect(launcher_get_app_launch_state(5)).to_equal("running")
        expect(launcher_get_running_process_count()).to_equal(1)

    it "marks graceful exits as exited with the reported code":
        launcher_init()
        launcher_register("Demo App", "/apps/demo", "D", 0x44, MOD_META)
        launcher_record_process(302, 5, "running", 0, 1, false)
        launcher_note_task_probe(302, false, 0)
        expect(launcher_get_process_state(0)).to_equal("exited")
        expect(launcher_get_process_exit_code(0)).to_equal(0)
        expect(launcher_get_app_launch_state(5)).to_equal("exited")
        expect(launcher_get_app_exit_code(5)).to_equal(0)
        expect(launcher_get_app_window_count(5)).to_equal(0)
        expect(launcher_get_running_process_count()).to_equal(0)

    it "marks unexpected exits with nonzero code as crashed":
        launcher_init()
        launcher_register("Demo App", "/apps/demo", "D", 0x44, MOD_META)
        launcher_record_process(303, 5, "running", 0, 0, true)
        launcher_note_task_probe(303, false, 11)
        expect(launcher_get_process_state(0)).to_equal("crashed")
        expect(launcher_get_process_exit_code(0)).to_equal(11)
        expect(launcher_get_app_launch_state(5)).to_equal("crashed")
        expect(launcher_get_app_exit_code(5)).to_equal(11)
        expect(launcher_get_running_process_count()).to_equal(0)

    it "finalizes terminating processes as terminated":
        launcher_init()
        launcher_register("Demo App", "/apps/demo", "D", 0x44, MOD_META)
        launcher_record_process(304, 5, "running", 0, 0, true)
        launcher_terminate(304)
        expect(launcher_get_process_state(0)).to_equal("terminating")
        launcher_note_task_probe(304, false, 15)
        expect(launcher_get_process_state(0)).to_equal("terminated")
        expect(launcher_get_app_launch_state(5)).to_equal("terminated")
        expect(launcher_get_app_exit_code(5)).to_equal(15)
        expect(launcher_get_running_process_count()).to_equal(0)

    it "is idempotent across repeated probes for the same dead pid":
        launcher_init()
        launcher_register("Demo App", "/apps/demo", "D", 0x44, MOD_META)
        launcher_record_process(305, 5, "running", 0, 0, true)
        launcher_note_task_probe(305, false, 9)
        launcher_note_task_probe(305, false, 9)
        launcher_note_task_probe(305, false, 9)
        expect(launcher_get_process_state(0)).to_equal("crashed")
        expect(launcher_get_process_exit_code(0)).to_equal(9)
        expect(launcher_get_running_process_count()).to_equal(0)

    it "ignores probes for unknown pids":
        launcher_init()
        launcher_register("Demo App", "/apps/demo", "D", 0x44, MOD_META)
        launcher_record_process(306, 5, "running", 0, 0, true)
        launcher_note_task_probe(999999, false, 1)
        expect(launcher_get_process_state(0)).to_equal("running")
        expect(launcher_get_running_process_count()).to_equal(1)
