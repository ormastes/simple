# MCP Tool Registry Unit Tests
#
# Tests for register_os_tools: tool count, schema structure,
# uniqueness of tool names, and schema content validation.

# ============================================================================
# JSON Helpers
# ============================================================================

describe "Tool registry JSON helpers":
    it "_js wraps string in double quotes":
        val result = _js("hello")
        expect(result).to_equal("\"hello\"")

    it "_jp creates key-value pair":
        val result = _jp("name", "\"test\"")
        expect(result).to_equal("\"name\":\"test\"")

    it "_jo1 wraps single property in braces":
        val result = _jo1("\"a\":1")
        expect(result).to_equal("{\"a\":1}")

    it "_jo2 wraps two properties in braces":
        val result = _jo2("\"a\":1", "\"b\":2")
        expect(result).to_equal("{\"a\":1,\"b\":2}")

    it "_jo3 wraps three properties in braces":
        val result = _jo3("\"a\":1", "\"b\":2", "\"c\":3")
        expect(result).to_equal("{\"a\":1,\"b\":2,\"c\":3}")

    it "_jo4 wraps four properties in braces":
        val result = _jo4("\"a\":1", "\"b\":2", "\"c\":3", "\"d\":4")
        expect(result).to_equal("{\"a\":1,\"b\":2,\"c\":3,\"d\":4}")

# ============================================================================
# Tool Schema — File Tools
# ============================================================================

describe "Tool schemas — File tools":
    it "schema_file_read contains file_read name":
        val schema = schema_file_read()
        expect(schema).to_contain("file_read")

    it "schema_file_read contains path property":
        val schema = schema_file_read()
        expect(schema).to_contain("path")

    it "schema_file_read is read-only":
        val schema = schema_file_read()
        expect(schema).to_contain("readOnlyHint")

    it "schema_file_write contains file_write name":
        val schema = schema_file_write()
        expect(schema).to_contain("file_write")

    it "schema_file_write contains path and content":
        val schema = schema_file_write()
        expect(schema).to_contain("path")
        expect(schema).to_contain("content")

    it "schema_file_write is destructive":
        val schema = schema_file_write()
        expect(schema).to_contain("destructiveHint")

    it "schema_file_list contains file_list name":
        val schema = schema_file_list()
        expect(schema).to_contain("file_list")

    it "schema_file_search contains file_search name":
        val schema = schema_file_search()
        expect(schema).to_contain("file_search")

    it "schema_file_search contains pattern param":
        val schema = schema_file_search()
        expect(schema).to_contain("pattern")

