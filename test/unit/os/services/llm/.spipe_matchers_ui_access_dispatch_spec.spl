# UI access protocol MCP dispatch specification
#
# Verifies the dispatcher path for the canonical UI access tools.

use std.spec.{describe, it, expect}
use common.ui.builder.{column, text_widget, button, text_field, build_tree}
use common.ui.session.{UISession}
use common.ui.widget.{UIEvent}
use common.ui.access.{UiAccessNode, UiAccessSurface, UiAccessSnapshot, ui_access_canonical_id}
use common.ui.access_store.{UiAccessStore}
use os.services.vfs.vfs.{VfsManager}
use os.services.llm.cli_gui_bridge.{CliGuiBridge}
use os.services.llm.mcp_os_server.{OsMcpServer}
use app.io.mod.{file_exists, file_delete}

extern fn rt_env_set(key: text, value: text) -> bool

fn _session_with_popup() -> UISession:
    val root = column("root").child(
        text_widget("title", "Hello Access")
    ).child(
        text_field("name_input", "Ada", "Name")
    ).child(
        button("submit_btn", "Submit", "submit")
    )
    val tree = build_tree(root)
    var session = UISession.new(tree)
    val popup_tree = build_tree(
        column("popup_root").child(button("ok_btn", "OK", "ok"))
    )
    session.open_surface("popup", popup_tree)
    session.set_active_surface("popup")
    return session

fn _stored_surface(surface_id: text, title: text, active: bool, root_widget_id: text) -> UiAccessSurface:
    UiAccessSurface(
        surface_id: surface_id,
        title: title,
        active: active,
        window_id: "",
        app_id: "",
        root_canonical_id: ui_access_canonical_id(surface_id, root_widget_id),
    )

fn _stored_node(surface_id: text, widget_id: text, kind: text, text: text, child_ids: [text], action_names: [text]) -> UiAccessNode:
    UiAccessNode(
        canonical_id: ui_access_canonical_id(surface_id, widget_id),
        surface_id: surface_id,
        widget_id: widget_id,
        kind: kind,
        visible: true,
        focused: false,
        enabled: true,
        selected: false,
        text: text,
        props: [],
        child_ids: child_ids,
        action_names: action_names,
    )

fn _stored_snapshot() -> UiAccessSnapshot:
    UiAccessSnapshot(
        protocol_version: 1,
        mode: "NORMAL",
        active_surface: "popup",
        surfaces: [_stored_surface("popup", "Popup", true, "root_popup")],
        nodes: [
            _stored_node("popup", "root_popup", "root", "Popup", ["popup#stored_ok_btn"], []),
            _stored_node("popup", "stored_ok_btn", "button", "Stored OK", [], ["click"])
        ],
        recent_events: [],
    )

describe "ui_access_protocol MCP dispatch":
    it "routes snapshot and surface reads through the canonical dispatcher":
        val session = _session_with_popup()
        val bridge = CliGuiBridge.new(session)
        val server = OsMcpServer.new(VfsManager.new(), bridge)
        val snapshot = server.dispatch("ui_access_snapshot", "")
        expect (snapshot).contains("\"protocol_version\":1")
        expect (snapshot).contains("\"popup\"")
        val find = server.dispatch(
            "ui_access_find",
            "{\"surface_id\":\"popup\",\"kind\":\"button\",\"text\":\"OK\",\"focused_only\":\"false\"}"
        )
        expect (find).contains("popup#ok_btn")
        val surface = server.dispatch("ui_access_surface", "{\"surface_id\":\"popup\"}")
        expect (surface).contains("\"surface_id\":\"popup\"")
        expect (surface).contains("popup#ok_btn")

    it "binds window metadata through the shared session registry":
        val session = _session_with_popup()
        val bridge = CliGuiBridge.new(session)
        val server = OsMcpServer.new(VfsManager.new(), bridge)
        val created = server.dispatch(
            "window_create",
            "{\"title\":\"Inspector\",\"width\":\"640\",\"height\":\"480\"}"
        )
        expect (created).contains("ok: created window")
        val snapshot = server.dispatch("ui_access_snapshot", "")
        expect (snapshot).contains("\"window_id\":\"1\"")
        expect (snapshot).contains("\"surface_id\":\"window_1\"")

    it "dispatches canonical actions and rejects invalid targets":
        val session = _session_with_popup()
        val bridge = CliGuiBridge.new(session)
        val server = OsMcpServer.new(VfsManager.new(), bridge)
        val action = server.dispatch(
            "ui_access_act",
            "{\"surface_id\":\"popup\",\"canonical_id\":\"popup#ok_btn\",\"action\":\"click\"}"
        )
        expect (action).contains("ok: dispatched click_ok_btn")
        val alias = server.dispatch(
            "ui_access_act",
            "{\"surface_id\":\"main\",\"canonical_id\":\"main#submit_btn\",\"action\":\"submit\"}"
        )
        expect (alias).contains("ok: dispatched submit")
        expect bridge.session.active_surface() == "popup"
        val history = server.dispatch("ui_access_history", "{\"surface_id\":\"popup\",\"count\":\"5\"}")
        expect (history).contains("\"event_kind\":\"action\"")
        val missing_surface = server.dispatch(
            "ui_access_act",
            "{\"surface_id\":\"missing\",\"action\":\"click\"}"
        )
        expect (missing_surface).contains("error: surface missing not found")
        val missing_target = server.dispatch("ui_access_act", "{\"action\":\"click\"}")
        expect (missing_target).contains("error: missing surface_id")

    it "observes declarative state through snapshot, surface, node, and filtered reads":
        val session = _session_with_popup()
        val bridge = CliGuiBridge.new(session)
        val server = OsMcpServer.new(VfsManager.new(), bridge)
        val whole = server.dispatch("ui_access_observe", "{}")
        expect (whole).contains("\"protocol_version\":1")
        val surface = server.dispatch("ui_access_observe", "{\"surface_id\":\"popup\"}")
        expect (surface).contains("\"surface_id\":\"popup\"")
        val node = server.dispatch("ui_access_observe", "{\"canonical_id\":\"popup#ok_btn\"}")
        expect (node).contains("\"canonical_id\":\"popup#ok_btn\"")
        val filtered = server.dispatch(
            "ui_access_observe",
            "{\"surface_id\":\"popup\",\"kind\":\"button\",\"text\":\"OK\",\"focused_only\":\"false\"}"
        )
        expect (filtered).contains("popup#ok_btn")

    it "queries structured declarative results":
        val session = _session_with_popup()
        val bridge = CliGuiBridge.new(session)
        val server = OsMcpServer.new(VfsManager.new(), bridge)
        val query = server.dispatch(
            "ui_access_query",
            "{\"surface_id\":\"popup\",\"kind\":\"button\",\"text\":\"OK\",\"focused_only\":\"false\",\"limit\":\"1\"}"
        )
        expect (query).contains("\"match_count\":1")
        expect (query).contains("\"truncated\":false")
        expect (query).contains("\"surface_id\":\"popup\"")
        expect (query).contains("\"canonical_id\":\"popup#ok_btn\"")
        val missing = server.dispatch(
            "ui_access_query",
            "{\"canonical_id\":\"popup#missing\"}"
        )
        expect (missing).contains("error: canonical node popup#missing not found")

    it "ensures bounded declarative expectations over canonical queries":
        val session = _session_with_popup()
        val bridge = CliGuiBridge.new(session)
        val server = OsMcpServer.new(VfsManager.new(), bridge)
        val missing = server.dispatch(
            "ui_access_ensure",
            "{\"surface_id\":\"popup\",\"kind\":\"button\",\"text\":\"Missing\",\"expectation\":\"absent\"}"
        )
        expect (missing).contains("\"satisfied\":true")
        val focus = server.dispatch(
            "ui_access_state",
            "{\"canonical_id\":\"popup#ok_btn\",\"state_key\":\"focused\",\"state_value\":\"true\"}"
        )
        expect (focus).contains("ok: state focused=true -> focus_ok_btn")
        val ensured = server.dispatch(
            "ui_access_ensure",
            "{\"surface_id\":\"popup\",\"kind\":\"button\",\"focused_only\":\"true\",\"expectation\":\"match_count\",\"expected_value\":\"1\",\"limit\":\"1\"}"
        )
        expect (ensured).contains("\"satisfied\":true")
        expect (ensured).contains("\"match_count\":1")
        expect (ensured).contains("\"canonical_id\":\"popup#ok_btn\"")

    it "preserves focused semantics across state, observe, and query":
        val session = _session_with_popup()
        val bridge = CliGuiBridge.new(session)
        val server = OsMcpServer.new(VfsManager.new(), bridge)
        val empty = server.dispatch(
            "ui_access_query",
            "{\"surface_id\":\"popup\",\"kind\":\"button\",\"focused_only\":\"true\",\"limit\":\"1\"}"
        )
        expect (empty).contains("\"match_count\":0")
        val focus = server.dispatch(
            "ui_access_state",
            "{\"canonical_id\":\"popup#ok_btn\",\"state_key\":\"focused\",\"state_value\":\"true\"}"
        )
        expect (focus).contains("ok: state focused=true -> focus_ok_btn")
        val observed = server.dispatch(
            "ui_access_observe",
            "{\"canonical_id\":\"popup#ok_btn\"}"
        )
        expect (observed).contains("\"canonical_id\":\"popup#ok_btn\"")
        expect (observed).contains("\"focused\":true")
        val query = server.dispatch(
            "ui_access_query",
            "{\"surface_id\":\"popup\",\"kind\":\"button\",\"focused_only\":\"true\",\"limit\":\"1\"}"
        )
        expect (query).contains("\"match_count\":1")
        expect (query).contains("\"canonical_id\":\"popup#ok_btn\"")

    it "reads and sets declarative state through canonical targets":
        val session = _session_with_popup()
        val bridge = CliGuiBridge.new(session)
        val server = OsMcpServer.new(VfsManager.new(), bridge)
        val read = server.dispatch("ui_access_state", "{\"canonical_id\":\"popup#ok_btn\"}")
        expect (read).contains("\"canonical_id\":\"popup#ok_btn\"")
        val read_key = server.dispatch(
            "ui_access_state",
            "{\"canonical_id\":\"popup#ok_btn\",\"state_key\":\"focused\"}"
        )
        expect (read_key).contains("\"state_key\":\"focused\"")
        expect (read_key).contains("\"state_value\":\"false\"")
        val surface_read = server.dispatch(
            "ui_access_state",
            "{\"surface_id\":\"popup\",\"state_key\":\"active\"}"
        )
        expect (surface_read).contains("\"surface_id\":\"popup\"")
        expect (surface_read).contains("\"state_value\":\"true\"")
        val focus = server.dispatch(
            "ui_access_state",
            "{\"canonical_id\":\"popup#ok_btn\",\"state_key\":\"focused\",\"state_value\":\"true\"}"
        )
        expect (focus).contains("ok: state focused=true -> focus_ok_btn")
        val active = server.dispatch(
            "ui_access_state",
            "{\"surface_id\":\"main\",\"state_key\":\"active\",\"state_value\":\"true\"}"
        )
        expect (active).contains("ok: state active=true on main")
        expect bridge.session.active_surface() == "main"
        val invoke = server.dispatch(
            "ui_access_state",
            "{\"canonical_id\":\"main#submit_btn\",\"state_key\":\"invoke\",\"state_value\":\"true\"}"
        )
        expect (invoke).contains("ok: state invoke=true -> click_submit_btn")
        val selected_false = server.dispatch(
            "ui_access_state",
            "{\"canonical_id\":\"main#submit_btn\",\"state_key\":\"selected\",\"state_value\":\"false\"}"
        )
        expect (selected_false).contains("ok: state selected=false on main#submit_btn")

    it "reads and writes typed values for value-bearing canonical nodes":
        val session = _session_with_popup()
        val bridge = CliGuiBridge.new(session)
        val server = OsMcpServer.new(VfsManager.new(), bridge)
        val read = server.dispatch("ui_access_value", "{\"canonical_id\":\"main#name_input\"}")
        expect (read).contains("\"canonical_id\":\"main#name_input\"")
        expect (read).contains("\"value\":\"Ada\"")
        val write = server.dispatch(
            "ui_access_value",
            "{\"surface_id\":\"main\",\"canonical_id\":\"main#name_input\",\"value\":\"Grace\"}"
        )
        expect (write).contains("\"value\":\"Grace\"")
        val reread = server.dispatch("ui_access_value", "{\"canonical_id\":\"main#name_input\"}")
        expect (reread).contains("\"value\":\"Grace\"")
        val unsupported = server.dispatch("ui_access_value", "{\"canonical_id\":\"main#submit_btn\"}")
        expect (unsupported).contains("error: unsupported value target main#submit_btn")

    it "reads additive adapter snapshots and vision probes":
        val session = _session_with_popup()
        val bridge = CliGuiBridge.new(session)
        val server = OsMcpServer.new(VfsManager.new(), bridge)
        val adapter = server.dispatch("ui_access_adapter_snapshot", "{\"surface_id\":\"popup\"}")
        expect (adapter).contains("\"source_kind\":\"session\"")
        expect (adapter).contains("\"surface_id\":\"popup\"")
        expect (adapter).contains("\"issues\":[]")
        val probe = server.dispatch("ui_access_visual_probe", "{\"surface_id\":\"popup\"}")
        expect (probe).contains("\"active_surface\":\"popup\"")
        expect (probe).contains("\"captured\":false")
        expect (probe).contains("\"mark_id\":\"mark_1\"")

    it "rejects invalid declarative state transitions":
        val session = _session_with_popup()
        val bridge = CliGuiBridge.new(session)
        val server = OsMcpServer.new(VfsManager.new(), bridge)
        val unsupported = server.dispatch(
            "ui_access_state",
            "{\"canonical_id\":\"popup#ok_btn\",\"state_key\":\"focused\",\"state_value\":\"false\"}"
        )
        expect (unsupported).contains("error: unsupported state transition focused=false")
        val unsupported_key = server.dispatch(
            "ui_access_state",
            "{\"canonical_id\":\"popup#ok_btn\",\"state_key\":\"bogus\"}"
        )
        expect (unsupported_key).contains("error: unsupported state key bogus")
        val missing = server.dispatch("ui_access_state", "{\"state_key\":\"active\",\"state_value\":\"true\"}")
        expect (missing).contains("error: missing surface_id")

    it "reads persisted find and history results when a store is attached":
        var session = _session_with_popup()
        var store = UiAccessStore.memory()?
        session.attach_access_store(store)
        store.persist_snapshot(_stored_snapshot())?
        session.dispatch(UIEvent.Action(name: "submit"))
        session.access_events = []
        val bridge = CliGuiBridge.new(session)
        val server = OsMcpServer.new(VfsManager.new(), bridge)
        val find = server.dispatch(
            "ui_access_find",
            "{\"surface_id\":\"popup\",\"kind\":\"button\",\"text\":\"Stored\",\"focused_only\":\"false\"}"
        )
        expect (find).contains("popup#stored_ok_btn")
        val history = server.dispatch("ui_access_history", "{\"surface_id\":\"popup\",\"count\":\"5\"}")
        expect (history).contains("\"surface_id\":\"popup\"")
        expect (history).contains("\"event_kind\":\"action\"")

    it "auto-attaches a persisted store through CliGuiBridge.new when runtime path is configured":
        val db_path = "/tmp/ui_access_bridge_auto.sqlite"
        rt_env_set("SIMPLE_UI_ACCESS_DB_PATH", db_path)
        if file_exists(db_path):
            file_delete(db_path)
        var session = _session_with_popup()
        val bridge = CliGuiBridge.new(session)
        bridge.session.dispatch(UIEvent.Action(name: "submit"))
        bridge.session.access_events = []
        val server = OsMcpServer.new(VfsManager.new(), bridge)
        val history = server.dispatch("ui_access_history", "{\"surface_id\":\"popup\",\"count\":\"5\"}")
        expect (history).contains("\"surface_id\":\"popup\"")
        expect (history).contains("\"event_kind\":\"action\"")
        rt_env_set("SIMPLE_UI_ACCESS_DB_PATH", "")
        if file_exists(db_path):
            file_delete(db_path)