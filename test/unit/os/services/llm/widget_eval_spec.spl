    it "parses table widget":
        var eval = WidgetDslEvaluator.new()
        val result = eval.evaluate("table(headers: \"PID,Name\")")
        match result:
            Ok(session): expect(session).to_equal(session)
            Err(e): expect(e).to_equal("")
