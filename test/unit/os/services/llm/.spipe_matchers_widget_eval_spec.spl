    it "parses panel with title":
        var eval = WidgetDslEvaluator.new()
        val dsl = "panel(title: \"Dashboard\"):\n    text(\"content\")"
        val result = eval.evaluate(dsl)
        match result:
            Ok(session):
                expect session == session
            Err(e):
                expect e == ""

    it "parses button with label and action":
        var eval = WidgetDslEvaluator.new()
        val dsl = "button(\"OK\", action: \"submit\")"
        val result = eval.evaluate(dsl)
        match result:
            Ok(session):
                expect session == session
            Err(e):
                expect e == ""

# ============================================================================
# Error Handling
# ============================================================================

describe "Widget DSL — error handling":
    it "returns error for empty DSL input":
        var eval = WidgetDslEvaluator.new()
        val result = eval.evaluate("")
        match result:
            Ok(_):
                expect "should have errored" == ""
            Err(e):
                expect e == "Empty DSL input"

    it "returns error for whitespace-only input":
        var eval = WidgetDslEvaluator.new()
        val result = eval.evaluate("   \n   \n   ")
        match result:
            Ok(_):
                expect "should have errored" == ""
            Err(e):
                expect e == "Empty DSL input"

    it "returns error for comment-only input":
        var eval = WidgetDslEvaluator.new()
        val result = eval.evaluate("# just a comment")
        match result:
            Ok(_):
                expect "should have errored" == ""
            Err(e):
                expect e == "Empty DSL input"

    it "handles unknown widget type gracefully":
        var eval = WidgetDslEvaluator.new()
        val dsl = "foobar(\"test\")"
        val result = eval.evaluate(dsl)
        # Unknown types create a generic panel, so should succeed
        match result:
            Ok(session):
                expect session == session
            Err(e):
                expect e == ""

# ============================================================================
# Internal Parsing Functions
# ============================================================================

describe "Widget DSL — _parse_dsl_lines":
    it "parses single line":
        val lines = _parse_dsl_lines("text(\"Hello\")")
        expect lines.len() == 1
        expect lines[0].widget_type == "text"

    it "skips blank lines":
        val lines = _parse_dsl_lines("\n\ntext(\"Hello\")\n\n")
        expect lines.len() == 1

    it "skips comment lines":
        val lines = _parse_dsl_lines("# comment\ntext(\"Hello\")")
        expect lines.len() == 1
        expect lines[0].widget_type == "text"

    it "measures indentation correctly":
        val lines = _parse_dsl_lines("    text(\"indented\")")
        expect lines[0].indent == 4

    it "detects container lines ending with colon":
        val lines = _parse_dsl_lines("column:")
        expect lines[0].is_container == true

    it "detects leaf lines without colon":
        val lines = _parse_dsl_lines("text(\"leaf\")")
        expect lines[0].is_container == false

    it "parses multiple lines":
        val dsl = "column:\n    text(\"A\")\n    text(\"B\")"
        val lines = _parse_dsl_lines(dsl)
        expect lines.len() == 3
        expect lines[0].widget_type == "column"
        expect lines[1].widget_type == "text"
        expect lines[2].widget_type == "text"

describe "Widget DSL — argument parsing":
    it "_get_arg returns named arg by name":
        val args = [DslArg(name: "title", value: "Hello")]
        val result = _get_arg(args, "title", 0)
        expect result == "Hello"

    it "_get_arg returns positional arg by index":
        val args = [DslArg(name: "", value: "First")]
        val result = _get_arg(args, "unused", 0)
        expect result == "First"

    it "_get_arg returns empty for missing arg":
        val args: [DslArg] = []
        val result = _get_arg(args, "missing", 0)
        expect result == ""

    it "_get_named_arg returns named value":
        val args = [DslArg(name: "key", value: "value")]
        val result = _get_named_arg(args, "key")
        expect result == "value"

    it "_get_named_arg returns empty for missing name":
        val args = [DslArg(name: "other", value: "value")]
        val result = _get_named_arg(args, "missing")
        expect result == ""

    it "_strip_quotes removes double quotes":
        val result = _strip_quotes("\"hello\"")
        expect result == "hello"

    it "_strip_quotes removes single quotes":
        val result = _strip_quotes("'hello'")
        expect result == "hello"

    it "_strip_quotes leaves unquoted strings unchanged":
        val result = _strip_quotes("hello")
        expect result == "hello"

    it "_count_indent counts leading spaces":
        val result = _count_indent("    text")
        expect result == 4

    it "_count_indent returns 0 for no indent":
        val result = _count_indent("text")
        expect result == 0

    it "_count_indent returns 8 for double indent":
        val result = _count_indent("        text")
        expect result == 8

# ============================================================================
# Widget Types Coverage
# ============================================================================

describe "Widget DSL — all widget types":
    it "parses divider":
        var eval = WidgetDslEvaluator.new()
        val result = eval.evaluate("divider")
        match result:
            Ok(session): expect(session).to_equal(session)
            Err(e): expect(e).to_equal("")

    it "parses checkbox":
        var eval = WidgetDslEvaluator.new()
        val result = eval.evaluate("checkbox(\"Enable\")")
        match result:
            Ok(session): expect(session).to_equal(session)
            Err(e): expect(e).to_equal("")

    it "parses statusbar":
        var eval = WidgetDslEvaluator.new()
        val result = eval.evaluate("statusbar(\"Ready\")")
        match result:
            Ok(session): expect(session).to_equal(session)
            Err(e): expect(e).to_equal("")

    it "parses input":
        var eval = WidgetDslEvaluator.new()
        val result = eval.evaluate("input(\"Type here...\")")
        match result:
            Ok(session): expect(session).to_equal(session)
            Err(e): expect(e).to_equal("")

    it "parses heading":
        var eval = WidgetDslEvaluator.new()
        val result = eval.evaluate("heading(\"Title\")")
        match result:
            Ok(session): expect(session).to_equal(session)
            Err(e): expect(e).to_equal("")

    it "parses image with src and alt":
        var eval = WidgetDslEvaluator.new()
        val result = eval.evaluate("image(src: \"/icon.png\", alt: \"icon\")")
        match result:
            Ok(session): expect(session).to_equal(session)
            Err(e): expect(e).to_equal("")

    it "parses list widget":
        var eval = WidgetDslEvaluator.new()
        val result = eval.evaluate("list:\n    text(\"item1\")\n    text(\"item2\")")
        match result:
            Ok(session): expect(session).to_equal(session)
            Err(e): expect(e).to_equal("")

    it "parses table widget":
        var eval = WidgetDslEvaluator.new()
        val result = eval.evaluate("table(headers: \"PID,Name\")")
        match result:
            Ok(session): expect(session).to_equal(session)
            Err(e): expect(e).to_equal("")