# Widget DSL Evaluator Unit Tests
#
# Tests for WidgetDslEvaluator: DSL parsing, widget creation,
# argument handling, and error cases.

# ============================================================================
# DslArg Construction
# ============================================================================

describe "DslArg":
    it "constructs positional arg with empty name":
        val arg = DslArg(name: "", value: "Hello")
        expect arg.name == ""
        expect arg.value == "Hello"

    it "constructs named arg":
        val arg = DslArg(name: "title", value: "Dashboard")
        expect arg.name == "title"
        expect arg.value == "Dashboard"

# ============================================================================
# DslLine Construction
# ============================================================================

describe "DslLine":
    it "constructs container line":
        val line = DslLine(
            indent: 0,
            widget_type: "column",
            args: [],
            is_container: true
        )
        expect line.widget_type == "column"
        expect line.is_container == true

    it "constructs leaf line":
        val line = DslLine(
            indent: 4,
            widget_type: "text",
            args: [DslArg(name: "", value: "Hello")],
            is_container: false
        )
        expect line.widget_type == "text"
        expect line.is_container == false
        expect line.indent == 4

# ============================================================================
# WidgetDslEvaluator Construction
# ============================================================================

describe "WidgetDslEvaluator":
    it "starts with _id_counter at 0":
        val eval = WidgetDslEvaluator.new()
        expect eval._id_counter == 0

# ============================================================================
# Simple DSL Parsing — text widget
# ============================================================================

describe "Widget DSL — text widget":
    it "parses text(\"Hello\") to text widget":
        var eval = WidgetDslEvaluator.new()
        val dsl = "text(\"Hello\")"
        val result = eval.evaluate(dsl)
        # Should succeed
        match result:
            Ok(session):
                expect session == session
            Err(e):
                expect e == ""

    it "parses simple label":
        var eval = WidgetDslEvaluator.new()
        val dsl = "label(\"CPU:\")"
        val result = eval.evaluate(dsl)
        match result:
            Ok(session):
                expect session == session
            Err(e):
                expect e == ""

# ============================================================================
# Column Layout
# ============================================================================

describe "Widget DSL — column layout":
    it "parses column with text children":
        var eval = WidgetDslEvaluator.new()
        val dsl = "column:\n    text(\"A\")\n    text(\"B\")"
        val result = eval.evaluate(dsl)
        match result:
            Ok(session):
                expect session == session
            Err(e):
                expect e == ""

    it "parses nested column and row":
        var eval = WidgetDslEvaluator.new()
        val dsl = "column:\n    row:\n        text(\"Left\")\n        text(\"Right\")"
        val result = eval.evaluate(dsl)
        match result:
            Ok(session):
                expect session == session
            Err(e):
                expect e == ""

