# ============================================================================
# Schema Structural Validation
# ============================================================================

describe "Tool schema structure":
    it "all schemas produce valid JSON-like output (contain braces)":
        expect (schema_file_read()).starts_with("{")
        expect (schema_file_write()).starts_with("{")
        expect (schema_file_list()).starts_with("{")
        expect (schema_file_search()).starts_with("{")
        expect (schema_process_list()).starts_with("{")
        expect (schema_process_spawn()).starts_with("{")
        expect (schema_process_kill()).starts_with("{")

    it "all schemas end with closing brace":
        expect (schema_file_read()).ends_with("}")
        expect (schema_window_create()).ends_with("}")
        expect (schema_widget_set()).ends_with("}")
        expect (schema_ui_access_snapshot()).ends_with("}")
        expect (schema_screenshot()).ends_with("}")
        expect (schema_system_info()).ends_with("}")

    it "all schemas contain inputSchema":
        expect (schema_file_read()).contains("inputSchema")
        expect (schema_window_create()).contains("inputSchema")
        expect (schema_widget_set()).contains("inputSchema")
        expect (schema_ui_access_surface()).contains("inputSchema")
        expect (schema_system_exec()).contains("inputSchema")

    it "all schemas contain annotations":
        expect (schema_file_read()).contains("annotations")
        expect (schema_process_list()).contains("annotations")
        expect (schema_window_list()).contains("annotations")
        expect (schema_screenshot()).contains("annotations")

    it "all schemas contain description":
        expect (schema_file_read()).contains("description")
        expect (schema_process_spawn()).contains("description")
        expect (schema_window_close()).contains("description")
        expect (schema_system_exec()).contains("description")

# ============================================================================
# Tool Names Uniqueness
# ============================================================================

describe "Tool name uniqueness":
    it "file tools have distinct names":
        val r = schema_file_read()
        val w = schema_file_write()
        val l = schema_file_list()
        val s = schema_file_search()
        expect (r).contains("file_read")
        expect (w).contains("file_write")
        expect (l).contains("file_list")
        expect (s).contains("file_search")

    it "process tools have distinct names":
        val l = schema_process_list()
        val s = schema_process_spawn()
        val k = schema_process_kill()
        expect (l).contains("process_list")
        expect (s).contains("process_spawn")
        expect (k).contains("process_kill")

    it "window tools have distinct names":
        val c = schema_window_create()
        val cl = schema_window_close()
        val l = schema_window_list()
        val f = schema_window_focus()
        expect (c).contains("window_create")
        expect (cl).contains("window_close")
        expect (l).contains("window_list")
        expect (f).contains("window_focus")

    it "widget tools have distinct names":
        val s = schema_widget_set()
        val r = schema_widget_read()
        val a = schema_widget_action()
        expect (s).contains("widget_set")
        expect (r).contains("widget_read")
        expect (a).contains("widget_action")

    it "total tool count is 23":
        # file: read, write, list, search = 4
        # process: list, spawn, kill = 3
        # window: create, close, list, focus = 4
        # widget: set, read, action = 3
        # ui access: snapshot, surface, find, act, history = 5
        # screen: screenshot, screen_read_text = 2
        # system: system_info, system_exec = 2
        val total = 4 + 3 + 4 + 3 + 5 + 2 + 2
        expect total == 23