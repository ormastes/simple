describe "Tool schemas — Declarative UI access":
    it "schema_ui_access_observe contains selector fields and is read-only":
        val schema = schema_ui_access_observe()
        expect (schema).contains("ui_access_observe")
        expect (schema).contains("canonical_id")
        expect (schema).contains("focused_only")
        expect (schema).contains("readOnlyHint")

    it "schema_ui_access_state contains state fields and is non-idempotent":
        val schema = schema_ui_access_state()
        expect (schema).contains("ui_access_state")
        expect (schema).contains("state_key")
        expect (schema).contains("state_value")
        expect (schema).contains("destructiveHint")

    it "schema_ui_access_query contains structured selector fields and is read-only":
        val schema = schema_ui_access_query()
        expect (schema).contains("ui_access_query")
        expect (schema).contains("canonical_id")
        expect (schema).contains("focused_only")
        expect (schema).contains("limit")
        expect (schema).contains("readOnlyHint")

    it "schema_ui_access_ensure contains expectation fields and is read-only":
        val schema = schema_ui_access_ensure()
        expect (schema).contains("ui_access_ensure")
        expect (schema).contains("expectation")
        expect (schema).contains("expected_value")
        expect (schema).contains("timeout_ms")
        expect (schema).contains("poll_ms")
        expect (schema).contains("readOnlyHint")

    it "schema_ui_access_value contains canonical_id and value":
        val schema = schema_ui_access_value()
        expect (schema).contains("ui_access_value")
        expect (schema).contains("canonical_id")
        expect (schema).contains("value")

    it "schema_ui_access_adapter_snapshot contains surface selector and is read-only":
        val schema = schema_ui_access_adapter_snapshot()
        expect (schema).contains("ui_access_adapter_snapshot")
        expect (schema).contains("surface_id")
        expect (schema).contains("readOnlyHint")

    it "schema_ui_access_visual_probe contains surface selector and is read-only":
        val schema = schema_ui_access_visual_probe()
        expect (schema).contains("ui_access_visual_probe")
        expect (schema).contains("surface_id")
        expect (schema).contains("readOnlyHint")
