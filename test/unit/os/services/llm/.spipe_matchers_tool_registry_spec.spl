# Tool Schema — File Tools
# ============================================================================

describe "Tool schemas — File tools":
    it "schema_file_read contains file_read name":
        val schema = schema_file_read()
        expect (schema).contains("file_read")

    it "schema_file_read contains path property":
        val schema = schema_file_read()
        expect (schema).contains("path")

    it "schema_file_read is read-only":
        val schema = schema_file_read()
        expect (schema).contains("readOnlyHint")

    it "schema_file_write contains file_write name":
        val schema = schema_file_write()
        expect (schema).contains("file_write")

    it "schema_file_write contains path and content":
        val schema = schema_file_write()
        expect (schema).contains("path")
        expect (schema).contains("content")

    it "schema_file_write is destructive":
        val schema = schema_file_write()
        expect (schema).contains("destructiveHint")

    it "schema_file_list contains file_list name":
        val schema = schema_file_list()
        expect (schema).contains("file_list")

    it "schema_file_search contains file_search name":
        val schema = schema_file_search()
        expect (schema).contains("file_search")

    it "schema_file_search contains pattern param":
        val schema = schema_file_search()
        expect (schema).contains("pattern")

