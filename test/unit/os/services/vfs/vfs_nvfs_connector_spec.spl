"""VFS-to-NVFS connector coverage.

The NVFS POSIX shim already implements the generic FsDriver contract. This spec
proves SimpleOS service helpers can mount that driver and route normal VFS
read/write/size/existence operations through it.
"""

use std.spec
use os.services.vfs.vfs_init.{
    g_vfs_reset_mount_table_for_test,
    g_vfs_mount_nvfs_posix,
    g_vfs_write_file_text,
    g_vfs_read_file_text,
    g_vfs_read_file_bytes,
    g_vfs_file_size,
    g_vfs_file_exists
}

describe "VFS NVFS connector":
    """Covers the service-level connection from MountTable to NvfsPosixDriver."""

    it "mounts NVFS and round-trips file content through g_vfs helpers":
        g_vfs_reset_mount_table_for_test()
        expect(g_vfs_mount_nvfs_posix("/nvfs", "unit-nvfs", false)).to_equal(true)

        expect(g_vfs_write_file_text("/nvfs/hello.txt", "hello")).to_equal(true)
        expect(g_vfs_file_exists("/nvfs/hello.txt")).to_equal(true)
        expect(g_vfs_file_size("/nvfs/hello.txt")).to_equal(5)
        expect(g_vfs_read_file_text("/nvfs/hello.txt")).to_equal("hello")

        val bytes = g_vfs_read_file_bytes("/nvfs/hello.txt")
        expect(bytes.len()).to_equal(5)
        expect(bytes[0]).to_equal(0x68u8)

    it "replaces existing NVFS text instead of appending":
        g_vfs_reset_mount_table_for_test()
        expect(g_vfs_mount_nvfs_posix("/nvfs", "unit-nvfs-replace", false)).to_equal(true)

        expect(g_vfs_write_file_text("/nvfs/log.txt", "first")).to_equal(true)
        expect(g_vfs_write_file_text("/nvfs/log.txt", "second")).to_equal(true)

        expect(g_vfs_file_size("/nvfs/log.txt")).to_equal(6)
        expect(g_vfs_read_file_text("/nvfs/log.txt")).to_equal("second")
