"""VFS-to-NVFS connector coverage.

The NVFS POSIX shim already implements the generic FsDriver contract. This spec
proves SimpleOS service helpers can mount that driver and route normal VFS
read/write/size/existence operations through it.
"""

use std.spec
use os.services.vfs.nvfs_connector.{
    nvfs_vfs_connect,
    nvfs_vfs_write_text,
    nvfs_vfs_read_text,
    nvfs_vfs_read_bytes,
    nvfs_vfs_file_size,
    nvfs_vfs_file_exists
}

describe "VFS NVFS connector":
    """Covers the service-level connection from MountTable to NvfsPosixDriver."""

    it "mounts NVFS and round-trips file content through connector helpers":
        val conn = nvfs_vfs_connect("/nvfs", "unit-nvfs", false)

        expect(nvfs_vfs_write_text(conn, "/nvfs/hello.txt", "hello")).to_equal(true)
        expect(nvfs_vfs_file_exists(conn, "/nvfs/hello.txt")).to_equal(true)
        expect(nvfs_vfs_file_size(conn, "/nvfs/hello.txt")).to_equal(5)
        expect(nvfs_vfs_read_text(conn, "/nvfs/hello.txt")).to_equal("hello")

        val bytes = nvfs_vfs_read_bytes(conn, "/nvfs/hello.txt")
        expect(bytes.len()).to_equal(5)
        expect(bytes[0]).to_equal(0x68u8)

    it "replaces existing NVFS text instead of appending":
        val conn = nvfs_vfs_connect("/nvfs", "unit-nvfs-replace", false)

        expect(nvfs_vfs_write_text(conn, "/nvfs/log.txt", "first")).to_equal(true)
        expect(nvfs_vfs_write_text(conn, "/nvfs/log.txt", "second")).to_equal(true)

        expect(nvfs_vfs_file_size(conn, "/nvfs/log.txt")).to_equal(6)
        expect(nvfs_vfs_read_text(conn, "/nvfs/log.txt")).to_equal("second")
