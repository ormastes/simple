use std.spec.{describe, it, expect}
use std.fs_driver.mem_block_device.{MemBlockDevice}
use os.services.vfs.nvme_filesystem_mounts.{vfs_nvme_driver_instance_for_lease, vfs_nvme_driver_instance_for_lease_checked, vfs_nvme_filesystem_region_blocks}
use os.drivers.nvme.nvme_storage_model.{NvmeQueueRole, NvmeNamespaceMode, NvmeFilesystemConsumer, NvmeNamespaceIdentity, NvmeQueueAssignment, NvmeFilesystemLease, nvme_filesystem_lease}
use os.kernel.types.capability_types.{CAP_RIGHT_READ, CAP_RIGHT_WRITE, CAP_RIGHT_QUEUE_SUBMIT, SIMPLEOS_NVME_SYSTEM_QUEUE_ID, SIMPLEOS_NVME_FIRST_DATA_QUEUE_ID}

fn _mount_test_lease() -> NvmeFilesystemLease:
    val ns = NvmeNamespaceIdentity(
        controller_id: 0,
        nsid: 9,
        lba_size: 512,
        lba_count: 4096,
        eui64: 0,
        nguid_lo: 0,
        nguid_hi: 0,
        uuid_lo: 0,
        uuid_hi: 0
    )
    val queue = NvmeQueueAssignment(
        queue_id: SIMPLEOS_NVME_SYSTEM_QUEUE_ID,
        role: NvmeQueueRole.System,
        controller_id: 0,
        nsid: 9,
        owner_task: 0,
        max_depth: 128,
        rights: CAP_RIGHT_READ + CAP_RIGHT_WRITE + CAP_RIGHT_QUEUE_SUBMIT
    )
    nvme_filesystem_lease(ns, 128u64, 1024u64, NvmeNamespaceMode.System, queue, "simple-driver", "none", true, true)

fn _user_mount_test_lease(nsid: u32) -> NvmeFilesystemLease:
    val ns = NvmeNamespaceIdentity(
        controller_id: 0,
        nsid: nsid,
        lba_size: 512,
        lba_count: 4096,
        eui64: 0,
        nguid_lo: 0,
        nguid_hi: 0,
        uuid_lo: 0,
        uuid_hi: 0
    )
    val queue = NvmeQueueAssignment(
        queue_id: SIMPLEOS_NVME_FIRST_DATA_QUEUE_ID,
        role: NvmeQueueRole.Data,
        controller_id: 0,
        nsid: nsid,
        owner_task: 42,
        max_depth: 64,
        rights: CAP_RIGHT_READ + CAP_RIGHT_WRITE + CAP_RIGHT_QUEUE_SUBMIT
    )
    nvme_filesystem_lease(ns, 0u64, 1024u64, NvmeNamespaceMode.UserAssigned, queue, "simple-driver", "resource-grant-set:tok=300", true, true)

describe "NVMe filesystem mount factory":
    it "reports the lease region block count used by device-backed filesystems":
        val lease = _mount_test_lease()
        expect(vfs_nvme_filesystem_region_blocks(lease)).to_equal(1024i64)

    it "builds FAT32 from the shared lease-backed BlockDevice surface":
        val lease = _mount_test_lease()
        val fat = vfs_nvme_driver_instance_for_lease("fat32-root", MemBlockDevice.new(1024u64, 512u32), lease, NvmeFilesystemConsumer.Fat32)
        expect(fat.is_ok()).to_equal(true)
        val driver = fat.unwrap()
        expect(driver.driver_name()).to_equal("fat32-root")

    it "builds NVFS from the shared lease-backed BlockDevice surface":
        val lease = _mount_test_lease()
        val nvfs = vfs_nvme_driver_instance_for_lease("nvfs-root", MemBlockDevice.new(1024u64, 512u32), lease, NvmeFilesystemConsumer.Nvfs)
        expect(nvfs.is_ok()).to_equal(true)
        val driver = nvfs.unwrap()
        expect(driver.driver_name()).to_equal("nvfs-root")

    it "builds DBFS from the shared lease-backed BlockDevice surface":
        val lease = _mount_test_lease()
        val dbfs = vfs_nvme_driver_instance_for_lease("dbfs-root", MemBlockDevice.new(1024u64, 512u32), lease, NvmeFilesystemConsumer.Dbfs)
        expect(dbfs.is_ok()).to_equal(true)
        val driver = dbfs.unwrap()
        expect(driver.driver_name()).to_equal("DbFsDriver")

    it "rejects consumers when the lease is not filesystem-ready":
        val ns = NvmeNamespaceIdentity(
            controller_id: 0,
            nsid: 10,
            lba_size: 512,
            lba_count: 4096,
            eui64: 0,
            nguid_lo: 0,
            nguid_hi: 0,
            uuid_lo: 0,
            uuid_hi: 0
        )
        val queue = NvmeQueueAssignment(
            queue_id: SIMPLEOS_NVME_SYSTEM_QUEUE_ID,
            role: NvmeQueueRole.System,
            controller_id: 0,
            nsid: 10,
            owner_task: 0,
            max_depth: 128,
            rights: CAP_RIGHT_READ + CAP_RIGHT_WRITE + CAP_RIGHT_QUEUE_SUBMIT
        )
        val lease = nvme_filesystem_lease(ns, 0u64, 1024u64, NvmeNamespaceMode.System, queue, "simple-driver", "none", false, true)
        val result = vfs_nvme_driver_instance_for_lease("bad", MemBlockDevice.new(1024u64, 512u32), lease, NvmeFilesystemConsumer.Fat32)
        expect(result.is_err()).to_equal(true)
        expect(result.unwrap_err()).to_equal("nvme-fs-lease-missing-shared-block-interface")

    it "rejects checked mounts that would mix system and user ownership of one namespace":
        val system_lease = _mount_test_lease()
        val user_lease = _user_mount_test_lease(9u32)
        val result = vfs_nvme_driver_instance_for_lease_checked("user-fat", MemBlockDevice.new(1024u64, 512u32), user_lease, NvmeFilesystemConsumer.Fat32, [system_lease])
        expect(result.is_err()).to_equal(true)
        expect(result.unwrap_err()).to_equal("nvme-fs-namespace-mode-conflict:system:user-assigned")

    it "accepts checked mounts for different NVMe namespaces":
        val system_lease = _mount_test_lease()
        val user_lease = _user_mount_test_lease(11u32)
        val result = vfs_nvme_driver_instance_for_lease_checked("user-fat", MemBlockDevice.new(1024u64, 512u32), user_lease, NvmeFilesystemConsumer.Fat32, [system_lease])
        expect(result.is_ok()).to_equal(true)
