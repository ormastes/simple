use os.kernel.loader.x86_64_fs_exec_spawn.{x86_64_fs_exec_spawn, x86_64_fs_exec_handoff_blob_ready}

describe "x86_64 filesystem exec seeded app spawn":
    it "spawns known seeded disk apps without requiring VFS byte materialization":
        val hello_pid = x86_64_fs_exec_spawn("/sys/apps/hello_world.smf", [], [])
        val clang_pid = x86_64_fs_exec_spawn("/sys/apps/clang", ["/usr/share/simpleos/toolchain/clang/hello.c"], [])
        val rust_pid = x86_64_fs_exec_spawn("/sys/apps/rust", ["/usr/share/simpleos/toolchain/rust/Cargo.toml"], [])
        val simple_pid = x86_64_fs_exec_spawn("/sys/apps/simple.smf", ["--version"], [])

        expect(hello_pid > 0).to_equal(true)
        expect(clang_pid).to_equal(hello_pid + 1)
        expect(rust_pid).to_equal(clang_pid + 1)
        expect(simple_pid).to_equal(rust_pid + 1)

    it "keeps unknown executables on the generic VFS failure path":
        val pid = x86_64_fs_exec_spawn("/sys/apps/definitely_missing", [], [])

        expect(pid).to_equal(-2)

    it "requires a resident raw FAT buffer before ring3 handoff":
        expect(x86_64_fs_exec_handoff_blob_ready(4096, 0x1000.to_u64())).to_equal(true)
        expect(x86_64_fs_exec_handoff_blob_ready(4096, 0.to_u64())).to_equal(false)
        expect(x86_64_fs_exec_handoff_blob_ready(4, 0x1000.to_u64())).to_equal(false)
