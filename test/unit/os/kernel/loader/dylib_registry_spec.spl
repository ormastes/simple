use std.spec
use os.posix.errno.{EBADF, EINVAL, ENOENT, ENOEXEC}
use os.kernel.loader.dylib_registry.{
    dylib_registry_reset_for_test,
    dylib_registry_register,
    dylib_registry_open,
    dylib_registry_close,
    dylib_registry_symbol
}

fn push_u16_le(buf: [u8], value: i64) -> [u8]:
    buf.push((value & 0xFF).to_u8())
    buf.push(((value >> 8) & 0xFF).to_u8())
    buf

fn push_u32_le(buf: [u8], value: i64) -> [u8]:
    buf.push((value & 0xFF).to_u8())
    buf.push(((value >> 8) & 0xFF).to_u8())
    buf.push(((value >> 16) & 0xFF).to_u8())
    buf.push(((value >> 24) & 0xFF).to_u8())
    buf

fn push_u64_le(buf: [u8], value: i64) -> [u8]:
    var out = buf
    out = push_u32_le(out, value & 0xFFFFFFFF)
    out = push_u32_le(out, (value >> 32) & 0xFFFFFFFF)
    out

fn make_elf64_exec() -> [u8]:
    var bytes: [u8] = []
    bytes.push(0x7F.to_u8())
    bytes.push(0x45.to_u8())
    bytes.push(0x4C.to_u8())
    bytes.push(0x46.to_u8())
    bytes.push(2.to_u8())
    bytes.push(1.to_u8())
    bytes.push(1.to_u8())
    bytes.push(0.to_u8())
    bytes.push(0.to_u8())
    while bytes.len() < 16:
        bytes.push(0.to_u8())
    bytes = push_u16_le(bytes, 2)
    bytes = push_u16_le(bytes, 62)
    bytes = push_u32_le(bytes, 1)
    bytes = push_u64_le(bytes, 0x400000)
    bytes = push_u64_le(bytes, 64)
    bytes = push_u64_le(bytes, 0)
    bytes = push_u32_le(bytes, 0)
    bytes = push_u16_le(bytes, 64)
    bytes = push_u16_le(bytes, 56)
    bytes = push_u16_le(bytes, 1)
    bytes = push_u16_le(bytes, 0)
    bytes = push_u16_le(bytes, 0)
    bytes = push_u16_le(bytes, 0)
    bytes = push_u32_le(bytes, 1)
    bytes = push_u32_le(bytes, 5)
    bytes = push_u64_le(bytes, 0x1000)
    bytes = push_u64_le(bytes, 0x400000)
    bytes = push_u64_le(bytes, 0x400000)
    bytes = push_u64_le(bytes, 4)
    bytes = push_u64_le(bytes, 4)
    bytes = push_u64_le(bytes, 0x1000)
    while bytes.len() < 0x1000:
        bytes.push(0.to_u8())
    bytes.push(0xC3.to_u8())
    bytes.push(0x00.to_u8())
    bytes.push(0x00.to_u8())
    bytes.push(0x00.to_u8())
    bytes

fn make_smf_wrapped_elf64_exec() -> [u8]:
    var bytes = make_elf64_exec()
    val stub_size = bytes.len()
    bytes.push(83.to_u8())
    bytes.push(77.to_u8())
    bytes.push(70.to_u8())
    bytes.push(0.to_u8())
    var i = 4
    while i < 44:
        bytes.push(0.to_u8())
        i = i + 1
    bytes = push_u64_le(bytes, 0x400000)
    bytes = push_u32_le(bytes, stub_size)
    bytes = push_u32_le(bytes, stub_size)
    while bytes.len() < stub_size + 128:
        bytes.push(0.to_u8())
    bytes

fn _pad_to(buf: [u8], target: i64) -> [u8]:
    while buf.len() < target:
        buf.push(0.to_u8())
    buf

fn make_elf64_with_dynsym() -> [u8]:
    """Build minimal ELF64 with .dynsym containing symbol 'hello' at 0xBEEF."""
    var b: [u8] = []
    # ELF ident
    b.push(0x7F.to_u8())
    b.push(0x45.to_u8())
    b.push(0x4C.to_u8())
    b.push(0x46.to_u8())
    b.push(2.to_u8())
    b.push(1.to_u8())
    b.push(1.to_u8())
    b = _pad_to(b, 16)
    # e_type=ET_EXEC, e_machine=x86_64, e_version=1
    b = push_u16_le(b, 2)
    b = push_u16_le(b, 62)
    b = push_u32_le(b, 1)
    # e_entry=0x400000
    b = push_u64_le(b, 0x400000)
    # e_phoff=64
    b = push_u64_le(b, 64)
    # e_shoff=192
    b = push_u64_le(b, 192)
    # e_flags=0
    b = push_u32_le(b, 0)
    # e_ehsize=64
    b = push_u16_le(b, 64)
    # e_phentsize=56, e_phnum=1
    b = push_u16_le(b, 56)
    b = push_u16_le(b, 1)
    # e_shentsize=64, e_shnum=3, e_shstrndx=0
    b = push_u16_le(b, 64)
    b = push_u16_le(b, 3)
    b = push_u16_le(b, 0)
    # PT_LOAD program header at offset 64
    b = push_u32_le(b, 1)
    b = push_u32_le(b, 5)
    b = push_u64_le(b, 0)
    b = push_u64_le(b, 0x400000)
    b = push_u64_le(b, 0x400000)
    b = push_u64_le(b, 120)
    b = push_u64_le(b, 120)
    b = push_u64_le(b, 0x1000)
    # .strtab at 128: \0 h e l l o \0 = 7 bytes
    b = _pad_to(b, 128)
    b.push(0.to_u8())
    b.push(0x68.to_u8())
    b.push(0x65.to_u8())
    b.push(0x6C.to_u8())
    b.push(0x6C.to_u8())
    b.push(0x6F.to_u8())
    b.push(0.to_u8())
    # .dynsym at 144: null sym (24 bytes) + hello sym (24 bytes)
    b = _pad_to(b, 144)
    # null sym
    b = _pad_to(b, 168)
    # hello sym: st_name=1, st_info=0x12, st_other=0, st_shndx=1
    b = push_u32_le(b, 1)
    b.push(0x12.to_u8())
    b.push(0.to_u8())
    b = push_u16_le(b, 1)
    # st_value=0xBEEF, st_size=8
    b = push_u64_le(b, 0xBEEF)
    b = push_u64_le(b, 8)
    # Section headers at 192: null(64) + .dynsym(64) + .strtab(64)
    b = _pad_to(b, 192)
    # SHT_NULL
    b = _pad_to(b, 256)
    # .dynsym: sh_name=0, sh_type=11, sh_flags=0, sh_addr=0
    b = push_u32_le(b, 0)
    b = push_u32_le(b, 11)
    b = push_u64_le(b, 0)
    b = push_u64_le(b, 0)
    # sh_offset=144, sh_size=48
    b = push_u64_le(b, 144)
    b = push_u64_le(b, 48)
    # sh_link=2 (strtab), sh_info=0
    b = push_u32_le(b, 2)
    b = push_u32_le(b, 0)
    # sh_addralign=0, sh_entsize=24
    b = push_u64_le(b, 0)
    b = push_u64_le(b, 24)
    # .strtab: sh_name=0, sh_type=3, sh_flags=0, sh_addr=0
    b = push_u32_le(b, 0)
    b = push_u32_le(b, 3)
    b = push_u64_le(b, 0)
    b = push_u64_le(b, 0)
    # sh_offset=128, sh_size=7
    b = push_u64_le(b, 128)
    b = push_u64_le(b, 7)
    # sh_link=0, sh_info=0
    b = push_u32_le(b, 0)
    b = push_u32_le(b, 0)
    # sh_addralign=0, sh_entsize=0
    b = push_u64_le(b, 0)
    b = push_u64_le(b, 0)
    b

describe "dylib_registry":
    it "registers an ELF64 library and resolves entry symbols":
        dylib_registry_reset_for_test()
        val handle = dylib_registry_register("/lib/demo.so", make_elf64_exec())
        expect(handle).to_be_greater_than(0)
        expect(dylib_registry_symbol(handle, "_start")).to_equal(0x400000)
        expect(dylib_registry_symbol(handle, "main")).to_equal(0x400000)
        expect(dylib_registry_symbol(handle, "missing")).to_equal(0 - ENOENT as i64)

    it "registers an SMF wrapper that carries an ELF stub":
        dylib_registry_reset_for_test()
        val handle = dylib_registry_register("/lib/demo.smf", make_smf_wrapped_elf64_exec())
        expect(handle).to_be_greater_than(0)
        expect(dylib_registry_symbol(handle, "_start")).to_equal(0x400000)

    it "reuses the same handle for path-backed opens and closes by refcount":
        dylib_registry_reset_for_test()
        val handle = dylib_registry_register("/lib/demo.so", make_elf64_exec())
        val opened = dylib_registry_open("/lib/demo.so")
        expect(opened).to_equal(handle)

        expect(dylib_registry_close(handle)).to_equal(0)
        expect(dylib_registry_symbol(opened, "main")).to_equal(0x400000)

        expect(dylib_registry_close(opened)).to_equal(0)
        expect(dylib_registry_symbol(opened, "main")).to_equal(0 - EBADF as i64)

    it "rejects missing paths and invalid byte blobs":
        dylib_registry_reset_for_test()
        expect(dylib_registry_open("/lib/missing.so")).to_equal(0 - ENOENT as i64)
        expect(dylib_registry_register("", make_elf64_exec())).to_equal(0 - EINVAL as i64)

        var invalid: [u8] = []
        invalid.push(1.to_u8())
        invalid.push(2.to_u8())
        invalid.push(3.to_u8())
        expect(dylib_registry_register("/lib/bad.so", invalid)).to_equal(0 - ENOEXEC as i64)

        var invalid_smf: [u8] = [1.to_u8(), 2.to_u8(), 3.to_u8(), 4.to_u8()]
        invalid_smf.push(83.to_u8())
        invalid_smf.push(77.to_u8())
        invalid_smf.push(70.to_u8())
        invalid_smf.push(0.to_u8())
        var j = 4
        while j < 44:
            invalid_smf.push(0.to_u8())
            j = j + 1
        invalid_smf = push_u64_le(invalid_smf, 0x400000)
        invalid_smf = push_u32_le(invalid_smf, 4)
        invalid_smf = push_u32_le(invalid_smf, 4)
        while invalid_smf.len() < 132:
            invalid_smf.push(0.to_u8())
        expect(dylib_registry_register("/lib/bad.smf", invalid_smf)).to_equal(0 - ENOEXEC as i64)

    it "resolves arbitrary symbols via slow path":
        dylib_registry_reset_for_test()
        val handle = dylib_registry_register("/lib/dynsym.so", make_elf64_with_dynsym())
        expect(handle).to_be_greater_than(0)
        # Fast path
        expect(dylib_registry_symbol(handle, "_start")).to_equal(0x400000)
        # Slow path — symbol from .dynsym
        expect(dylib_registry_symbol(handle, "hello")).to_equal(0xBEEF)
        # Slow path — missing symbol
        expect(dylib_registry_symbol(handle, "missing")).to_equal(0 - ENOENT as i64)
