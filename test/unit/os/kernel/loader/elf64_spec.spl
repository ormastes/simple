"""
# ELF64 parser
**Feature IDs:** #WAVE2-G10
**Category:** Kernel loader

Verifies magic validation and header parsing of the minimal ELF64 loader.
"""
use std.spec.*
use os.kernel.loader.elf64.{elf64_parse_header, ELF64_MAGIC_0, ELF64_MAGIC_1, ELF64_MAGIC_2, ELF64_MAGIC_3, ELF64_EHDR_SIZE}

fn _truncated() -> [u8]:
    """Any buffer shorter than an ELF64 header."""
    var b: [u8] = []
    var i = 0
    while i < 16:
        b.push(0u8)
        i = i + 1
    b

fn _bad_magic() -> [u8]:
    """64 bytes that are not ELF (wrong magic)."""
    var b: [u8] = []
    var i = 0
    while i < (ELF64_EHDR_SIZE as i32):
        b.push(0x42u8)  # arbitrary non-ELF byte
        i = i + 1
    b

describe "elf64_parse_header":
    """Header validation corner cases."""

    it "rejects a truncated buffer":
        """Anything shorter than the full ELF64 header is not parseable."""
        val h = elf64_parse_header(_truncated())
        expect h.is_nil().to_equal(true)

    it "rejects a buffer with non-ELF magic":
        """Magic bytes must be 0x7F 'E' 'L' 'F'."""
        val h = elf64_parse_header(_bad_magic())
        expect h.is_nil().to_equal(true)

    it "exposes the ELF64 magic bytes as expected constants":
        """These constants are the canonical ELF magic sequence."""
        expect ELF64_MAGIC_0.to_equal(0x7Fu8)
        expect ELF64_MAGIC_1.to_equal(0x45u8)
        expect ELF64_MAGIC_2.to_equal(0x4Cu8)
        expect ELF64_MAGIC_3.to_equal(0x46u8)

    it "EHDR size is the canonical 64 bytes":
        """Misreading header size is a classic loader bug — pin it."""
        expect ELF64_EHDR_SIZE.to_equal(64)
