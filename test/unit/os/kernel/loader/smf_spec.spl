"""
# SMF parser
**Feature IDs:** #WAVE2-G10
**Category:** Kernel loader

Verifies magic check + header parse of the minimal SMF loader.
"""
use std.spec.*
use os.kernel.loader.smf.{smf_check_magic, smf_has_header, smf_header_offset, smf_parse_header, smf_extract_executable_stub, SMF64_MAGIC_0, SMF64_MAGIC_1, SMF64_MAGIC_2, SMF64_MAGIC_3, SMF_HEADER_TRAILER_SIZE}

fn _empty() -> [u8]:
    """Zero bytes — too short for any SMF."""
    var b: [u8] = []
    b

fn _good_magic() -> [u8]:
    """Minimum-length buffer starting with the SMF magic bytes."""
    var b: [u8] = []
    b.push(SMF64_MAGIC_0)
    b.push(SMF64_MAGIC_1)
    b.push(SMF64_MAGIC_2)
    b.push(SMF64_MAGIC_3)
    var i = 4
    while i < (SMF_HEADER_TRAILER_SIZE as i32):
        b.push(0u8)
        i = i + 1
    b

fn _trailer_magic() -> [u8]:
    """Full v1.1-style SMF bytes with payload before the header trailer."""
    var b: [u8] = [1u8, 2u8, 3u8, 4u8, 5u8]
    b.push(SMF64_MAGIC_0)
    b.push(SMF64_MAGIC_1)
    b.push(SMF64_MAGIC_2)
    b.push(SMF64_MAGIC_3)
    var i = 4
    while i < 44:
        b.push(0u8)
        i = i + 1
    b.push(52u8)  # entry_point low byte at header offset 44
    i = 45
    while i < 52:
        b.push(0u8)
        i = i + 1
    b.push(5u8)   # stub_size low byte
    b.push(0u8)
    b.push(0u8)
    b.push(0u8)
    b.push(5u8)   # smf_data_offset low byte
    b.push(0u8)
    b.push(0u8)
    b.push(0u8)
    while b.len() < 5 + (SMF_HEADER_TRAILER_SIZE as i32):
        b.push(0u8)
    b

fn _elf_stub_smf() -> [u8]:
    """SMF envelope whose executable stub starts with ELF magic."""
    var b: [u8] = [0x7Fu8, 0x45u8, 0x4Cu8, 0x46u8, 2u8, 1u8, 1u8, 0u8]
    val stub_len = b.len()
    b.push(SMF64_MAGIC_0)
    b.push(SMF64_MAGIC_1)
    b.push(SMF64_MAGIC_2)
    b.push(SMF64_MAGIC_3)
    var i = 4
    while i < 44:
        b.push(0u8)
        i = i + 1
    b.push(0u8)
    i = 45
    while i < 52:
        b.push(0u8)
        i = i + 1
    b.push(stub_len as u8)
    b.push(0u8)
    b.push(0u8)
    b.push(0u8)
    b.push(stub_len as u8)
    b.push(0u8)
    b.push(0u8)
    b.push(0u8)
    while b.len() < stub_len + (SMF_HEADER_TRAILER_SIZE as i32):
        b.push(0u8)
    b

describe "smf_check_magic":
    """Magic validation."""

    it "rejects an empty buffer":
        """Empty input cannot carry magic bytes."""
        expect smf_check_magic(_empty()).to_equal(false)

    it "accepts a buffer starting with the SMF magic bytes":
        """A conforming prefix is required for smf_load to proceed."""
        expect smf_check_magic(_good_magic()).to_equal(true)

    it "does not treat trailer-only SMF as offset-zero magic":
        """Offset-zero checks stay strict for legacy callers."""
        expect smf_check_magic(_trailer_magic()).to_equal(false)

describe "smf_has_header":
    """Header location detection."""

    it "accepts a v1.1 trailer header":
        """The kernel loader should sniff the same EOF-128 header as the compiler loader."""
        expect smf_has_header(_trailer_magic()).to_equal(true)
        expect smf_header_offset(_trailer_magic()).to_equal(5)

describe "smf_parse_header":
    """Header parsing either yields a descriptor or nil."""

    it "returns nil on an empty buffer":
        """Too-short input must be rejected without crashing."""
        val h = smf_parse_header(_empty())
        expect h.is_nil().to_equal(true)

    it "parses v1.1 trailer header fields":
        """Entry and stub metadata come from the trailer, not byte zero."""
        val h = smf_parse_header(_trailer_magic())
        expect h.is_nil().to_equal(false)
        val parsed = h.unwrap()
        expect parsed.header_offset.to_equal(5i64)
        expect parsed.entry_point.to_equal(52i64)
        expect parsed.stub_size.to_equal(5i64)
        expect parsed.smf_data_offset.to_equal(5i64)

    it "magic constants spell 'SMF\\0'":
        """Pin the magic-byte assignment so accidental refactors fail here."""
        expect SMF64_MAGIC_0.to_equal(83u8)
        expect SMF64_MAGIC_1.to_equal(77u8)
        expect SMF64_MAGIC_2.to_equal(70u8)
        expect SMF64_MAGIC_3.to_equal(0u8)

describe "smf_extract_executable_stub":
    """Executable-stub extraction for SMF-as-package loading."""

    it "extracts an ELF executable stub from a trailer SMF":
        val stub = smf_extract_executable_stub(_elf_stub_smf())
        expect stub.is_ok().to_equal(true)
        val bytes = stub.unwrap()
        expect bytes.len().to_equal(8)
        expect bytes[0].to_equal(0x7Fu8)
        expect bytes[1].to_equal(0x45u8)
        expect bytes[2].to_equal(0x4Cu8)
        expect bytes[3].to_equal(0x46u8)

    it "rejects SMF payloads that do not carry an ELF stub":
        val stub = smf_extract_executable_stub(_trailer_magic())
        expect stub.is_err().to_equal(true)
