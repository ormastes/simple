use std.spec
use os.kernel.loader.elf_loader.{load_riscv_executable, ElfClass}
use os.kernel.arch.arch_context.{Architecture}

fn push_u16_le(buf: [u8], value: i64) -> [u8]:
    buf.push((value & 0xFF).to_u8())
    buf.push(((value >> 8) & 0xFF).to_u8())
    buf

fn push_u32_le(buf: [u8], value: i64) -> [u8]:
    buf.push((value & 0xFF).to_u8())
    buf.push(((value >> 8) & 0xFF).to_u8())
    buf.push(((value >> 16) & 0xFF).to_u8())
    buf.push(((value >> 24) & 0xFF).to_u8())
    buf

fn push_u64_le(buf: [u8], value: i64) -> [u8]:
    var out = buf
    out = push_u32_le(out, value & 0xFFFFFFFF)
    out = push_u32_le(out, (value >> 32) & 0xFFFFFFFF)
    out

fn make_rv64_exec() -> [u8]:
    var bytes: [u8] = []
    bytes.push(0x7F.to_u8())
    bytes.push(0x45.to_u8())
    bytes.push(0x4C.to_u8())
    bytes.push(0x46.to_u8())
    bytes.push(2.to_u8())
    bytes.push(1.to_u8())
    bytes.push(1.to_u8())
    bytes.push(0.to_u8())
    bytes.push(0.to_u8())
    while bytes.len() < 16:
        bytes.push(0.to_u8())
    bytes = push_u16_le(bytes, 2)
    bytes = push_u16_le(bytes, 243)
    bytes = push_u32_le(bytes, 1)
    bytes = push_u64_le(bytes, 0x400000)
    bytes = push_u64_le(bytes, 64)
    bytes = push_u64_le(bytes, 0)
    bytes = push_u32_le(bytes, 0)
    bytes = push_u16_le(bytes, 64)
    bytes = push_u16_le(bytes, 56)
    bytes = push_u16_le(bytes, 1)
    bytes = push_u16_le(bytes, 0)
    bytes = push_u16_le(bytes, 0)
    bytes = push_u16_le(bytes, 0)
    bytes = push_u32_le(bytes, 1)
    bytes = push_u32_le(bytes, 5)
    bytes = push_u64_le(bytes, 0x1000)
    bytes = push_u64_le(bytes, 0x400000)
    bytes = push_u64_le(bytes, 0x400000)
    bytes = push_u64_le(bytes, 4)
    bytes = push_u64_le(bytes, 4)
    bytes = push_u64_le(bytes, 0x1000)
    while bytes.len() < 0x1000:
        bytes.push(0.to_u8())
    bytes.push(0x13.to_u8())
    bytes.push(0x00.to_u8())
    bytes.push(0x00.to_u8())
    bytes.push(0x00.to_u8())
    bytes

fn make_rv32_exec() -> [u8]:
    var bytes: [u8] = []
    bytes.push(0x7F.to_u8())
    bytes.push(0x45.to_u8())
    bytes.push(0x4C.to_u8())
    bytes.push(0x46.to_u8())
    bytes.push(1.to_u8())
    bytes.push(1.to_u8())
    bytes.push(1.to_u8())
    bytes.push(0.to_u8())
    bytes.push(0.to_u8())
    while bytes.len() < 16:
        bytes.push(0.to_u8())
    bytes = push_u16_le(bytes, 2)
    bytes = push_u16_le(bytes, 243)
    bytes = push_u32_le(bytes, 1)
    bytes = push_u32_le(bytes, 0x80000000)
    bytes = push_u32_le(bytes, 52)
    bytes = push_u32_le(bytes, 0)
    bytes = push_u32_le(bytes, 0)
    bytes = push_u16_le(bytes, 52)
    bytes = push_u16_le(bytes, 32)
    bytes = push_u16_le(bytes, 1)
    bytes = push_u16_le(bytes, 0)
    bytes = push_u16_le(bytes, 0)
    bytes = push_u16_le(bytes, 0)
    bytes = push_u32_le(bytes, 1)
    bytes = push_u32_le(bytes, 0x100)
    bytes = push_u32_le(bytes, 0x80000000)
    bytes = push_u32_le(bytes, 0x80000000)
    bytes = push_u32_le(bytes, 4)
    bytes = push_u32_le(bytes, 4)
    bytes = push_u32_le(bytes, 5)
    bytes = push_u32_le(bytes, 0x1000)
    while bytes.len() < 0x104:
        bytes.push(0.to_u8())
    bytes.push(0x13.to_u8())
    bytes.push(0x00.to_u8())
    bytes.push(0x00.to_u8())
    bytes.push(0x00.to_u8())
    bytes

describe "ELF loader":
    it "parses a minimal RV64 executable load plan":
        val image = load_riscv_executable(make_rv64_exec(), Architecture.Riscv64)
        expect(image.is_ok()).to_equal(true)
        val loaded = image.unwrap()
        expect(loaded.class_).to_equal(ElfClass.Elf64)
        expect(loaded.entry).to_equal(0x400000)
        expect(loaded.segments.len()).to_equal(1)
        expect(loaded.segments[0].file_offset).to_equal(0x1000)

    it "parses a minimal RV32 executable load plan":
        val image = load_riscv_executable(make_rv32_exec(), Architecture.Riscv32)
        expect(image.is_ok()).to_equal(true)
        val loaded = image.unwrap()
        expect(loaded.class_).to_equal(ElfClass.Elf32)
        expect(loaded.entry).to_equal(0x80000000)
        expect(loaded.segments.len()).to_equal(1)
        expect(loaded.segments[0].virt_addr).to_equal(0x80000000)

    it "rejects class mismatches":
        val image = load_riscv_executable(make_rv32_exec(), Architecture.Riscv64)
        expect(image.is_err()).to_equal(true)

    it "rejects images without PT_LOAD":
        var bytes = make_rv64_exec()
        bytes[64] = 0.to_u8()
        val image = load_riscv_executable(bytes, Architecture.Riscv64)
        expect(image.is_err()).to_equal(true)

    it "rejects segments with filesz larger than memsz":
        var bytes = make_rv64_exec()
        bytes[96] = 8.to_u8()
        bytes[104] = 4.to_u8()
        val image = load_riscv_executable(bytes, Architecture.Riscv64)
        expect(image.is_err()).to_equal(true)
