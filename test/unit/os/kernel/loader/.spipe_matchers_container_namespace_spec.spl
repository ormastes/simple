use os.kernel.loader.container_namespace.{
    simpleos_container_namespace_evidence,
    simpleos_container_namespace_gate,
    simpleos_container_rootfs_gate,
    simpleos_wine_container_contract
}

describe "SimpleOS container namespace contract":
    it "requires pid, filesystem, IPC, network, and capability evidence":
        val evidence = simpleos_container_namespace_evidence(42, "/containers/wine", true, true, true, false)
        expect (evidence).contains("pid")
        expect (evidence).contains("net")
        expect simpleos_container_namespace_gate(evidence) == "missing-capability"

    it "keeps app paths resolved under the container rootfs":
        expect simpleos_container_rootfs_gate("/containers/wine", "/sys/apps/wine_hello") == "ready"
        expect simpleos_container_rootfs_gate("/", "/sys/apps/wine_hello") == "invalid-rootfs"
        expect simpleos_container_rootfs_gate("/containers/wine", "/etc/passwd") == "invalid-app-path"

    it "builds desktop serial markers for a Wine app container":
        val contract = simpleos_wine_container_contract(42, "/containers/wine", "/sys/apps/wine_hello", "nvfs")
        expect contract.ok == true
        expect (contract.evidence).contains("capability")
        expect (contract.namespace_marker).contains("[desktop-e2e] container-namespace:ok")
        expect (contract.namespace_marker).contains("pid")
        expect (contract.rootfs_marker).contains("[desktop-e2e] container-rootfs:ok")
        expect (contract.rootfs_marker).contains("rootfs_backend=nvfs")

    it "does not produce ok markers for invalid rootfs contracts":
        val contract = simpleos_wine_container_contract(42, "/", "/sys/apps/wine_hello", "nvfs")
        expect contract.ok == false
        expect contract.error == "invalid-rootfs"
        expect contract.namespace_marker == ""
        expect contract.rootfs_marker == ""