use std.spec
use os.kernel.loader.executable_source.{
    resolve_executable_bytes,
    _set_synthetic_initramfs_for_test,
    _clear_synthetic_initramfs_for_test,
}
use os.kernel.loader.process_image.{build_user_process_image, X86_64_USER_STACK_TOP}
use os.kernel.arch.arch_context.{Architecture}

fn push_u16_le(buf: [u8], value: i64) -> [u8]:
    buf.push((value & 0xFF).to_u8())
    buf.push(((value >> 8) & 0xFF).to_u8())
    buf

fn push_u32_le(buf: [u8], value: i64) -> [u8]:
    buf.push((value & 0xFF).to_u8())
    buf.push(((value >> 8) & 0xFF).to_u8())
    buf.push(((value >> 16) & 0xFF).to_u8())
    buf.push(((value >> 24) & 0xFF).to_u8())
    buf

fn push_u64_le(buf: [u8], value: i64) -> [u8]:
    var out = buf
    out = push_u32_le(out, value & 0xFFFFFFFF)
    out = push_u32_le(out, (value >> 32) & 0xFFFFFFFF)
    out

fn make_x86_64_exec() -> [u8]:
    var bytes: [u8] = []
    bytes.push(0x7F.to_u8())
    bytes.push(0x45.to_u8())
    bytes.push(0x4C.to_u8())
    bytes.push(0x46.to_u8())
    bytes.push(2.to_u8())
    bytes.push(1.to_u8())
    bytes.push(1.to_u8())
    bytes.push(0.to_u8())
    bytes.push(0.to_u8())
    while bytes.len() < 16:
        bytes.push(0.to_u8())
    bytes = push_u16_le(bytes, 2)
    bytes = push_u16_le(bytes, 62)
    bytes = push_u32_le(bytes, 1)
    bytes = push_u64_le(bytes, 0x400000)
    bytes = push_u64_le(bytes, 64)
    bytes = push_u64_le(bytes, 0)
    bytes = push_u32_le(bytes, 0)
    bytes = push_u16_le(bytes, 64)
    bytes = push_u16_le(bytes, 56)
    bytes = push_u16_le(bytes, 1)
    bytes = push_u16_le(bytes, 0)
    bytes = push_u16_le(bytes, 0)
    bytes = push_u16_le(bytes, 0)
    bytes = push_u32_le(bytes, 1)
    bytes = push_u32_le(bytes, 5)
    bytes = push_u64_le(bytes, 0x1000)
    bytes = push_u64_le(bytes, 0x400000)
    bytes = push_u64_le(bytes, 0x400000)
    bytes = push_u64_le(bytes, 4)
    bytes = push_u64_le(bytes, 4)
    bytes = push_u64_le(bytes, 0x1000)
    while bytes.len() < 0x1000:
        bytes.push(0.to_u8())
    bytes.push(0xC3.to_u8())
    bytes

fn make_smf_wrapped_x86_64_exec() -> [u8]:
    var b = make_x86_64_exec()
    val stub_len = b.len()
    b.push(83u8)
    b.push(77u8)
    b.push(70u8)
    b.push(0u8)
    var i = 4
    while i < 44:
        b.push(0u8)
        i = i + 1
    b = push_u64_le(b, 0x400000)
    b = push_u32_le(b, stub_len)
    b = push_u32_le(b, stub_len)
    while b.len() < stub_len + 128:
        b.push(0u8)
    b

describe "process image builder":
    it "builds an rv64 user image from executable bytes":
        val bytes = resolve_executable_bytes("/sys/services/vfs", Architecture.Riscv64).unwrap()
        val image = build_user_process_image("/sys/services/vfs", bytes, Architecture.Riscv64)
        expect(image.is_ok()).to_equal(true)
        val built = image.unwrap()
        expect(built.entry).to_equal(0x400000)
        expect(built.argv[0]).to_equal("/sys/services/vfs")
        expect(built.segments.len()).to_equal(1)
        expect(built.segments[0].data.len()).to_equal(4)

    it "builds an rv32 user image from executable bytes":
        val bytes = resolve_executable_bytes("/sys/apps/desktop", Architecture.Riscv32).unwrap()
        val image = build_user_process_image("/sys/apps/desktop", bytes, Architecture.Riscv32)
        expect(image.is_ok()).to_equal(true)
        val built = image.unwrap()
        expect(built.entry).to_equal(0x80000000)
        expect(built.stack_top).to_equal(0x81000000)

    it "builds an x86_64 user image from executable bytes":
        _clear_synthetic_initramfs_for_test()
        _set_synthetic_initramfs_for_test("/usr/bin/x86_exec_probe", make_x86_64_exec())
        val bytes = resolve_executable_bytes("/usr/bin/x86_exec_probe", Architecture.X86_64).unwrap()
        val image = build_user_process_image("/usr/bin/x86_exec_probe", bytes, Architecture.X86_64)
        expect(image.is_ok()).to_equal(true)
        val built = image.unwrap()
        expect(built.entry).to_equal(0x400000)
        expect(built.stack_top).to_equal(X86_64_USER_STACK_TOP)
        _clear_synthetic_initramfs_for_test()

    it "builds an x86_64 user image from an SMF-wrapped executable stub":
        _clear_synthetic_initramfs_for_test()
        _set_synthetic_initramfs_for_test("/usr/bin/smf_x86_exec_probe", make_smf_wrapped_x86_64_exec())
        val bytes = resolve_executable_bytes("/usr/bin/smf_x86_exec_probe", Architecture.X86_64).unwrap()
        val image = build_user_process_image("/usr/bin/smf_x86_exec_probe", bytes, Architecture.X86_64)
        expect(image.is_ok()).to_equal(true)
        val built = image.unwrap()
        expect(built.entry).to_equal(0x400000)
        expect(built.stack_top).to_equal(X86_64_USER_STACK_TOP)
        expect(built.file_bytes[0]).to_equal(0x7Fu8)
        _clear_synthetic_initramfs_for_test()
