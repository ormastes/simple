use std.spec
use os.kernel.loader.executable_source.{resolve_executable_bytes}
use os.kernel.loader.process_image.{build_user_process_image, X86_64_USER_STACK_TOP}
use os.kernel.arch.arch_context.{Architecture}

describe "process image builder":
    it "builds an rv64 user image from executable bytes":
        val bytes = resolve_executable_bytes("/sys/services/vfs", Architecture.Riscv64).unwrap()
        val image = build_user_process_image("/sys/services/vfs", bytes, Architecture.Riscv64)
        expect(image.is_ok()).to_equal(true)
        val built = image.unwrap()
        expect(built.entry).to_equal(0x400000)
        expect(built.argv[0]).to_equal("/sys/services/vfs")
        expect(built.segments.len()).to_equal(1)
        expect(built.segments[0].data.len()).to_equal(4)

    it "builds an rv32 user image from executable bytes":
        val bytes = resolve_executable_bytes("/sys/apps/desktop", Architecture.Riscv32).unwrap()
        val image = build_user_process_image("/sys/apps/desktop", bytes, Architecture.Riscv32)
        expect(image.is_ok()).to_equal(true)
        val built = image.unwrap()
        expect(built.entry).to_equal(0x80000000)
        expect(built.stack_top).to_equal(0x81000000)

    it "builds an x86_64 user image from executable bytes":
        var bytes = resolve_executable_bytes("/sys/services/vfs", Architecture.Riscv64).unwrap()
        bytes[18] = 62.to_u8()
        bytes[19] = 0.to_u8()
        val image = build_user_process_image("/sys/services/vfs", bytes, Architecture.X86_64)
        expect(image.is_ok()).to_equal(true)
        val built = image.unwrap()
        expect(built.entry).to_equal(0x400000)
        expect(built.stack_top).to_equal(X86_64_USER_STACK_TOP)
