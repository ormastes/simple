use std.spec
use os.kernel.loader.process_image.{build_user_process_image}
use os.kernel.loader.process_image.{X86_64_USER_STACK_TOP, X86_32_USER_STACK_TOP}
use os.kernel.arch.arch_context.{Architecture}

fn push_u16_le(buf: [u8], value: i64) -> [u8]:
    buf.push((value & 0xFF).to_u8())
    buf.push(((value >> 8) & 0xFF).to_u8())
    buf

fn push_u32_le(buf: [u8], value: i64) -> [u8]:
    buf.push((value & 0xFF).to_u8())
    buf.push(((value >> 8) & 0xFF).to_u8())
    buf.push(((value >> 16) & 0xFF).to_u8())
    buf.push(((value >> 24) & 0xFF).to_u8())
    buf

fn push_u64_le(buf: [u8], value: i64) -> [u8]:
    var out = buf
    out = push_u32_le(out, value & 0xFFFFFFFF)
    out = push_u32_le(out, (value >> 32) & 0xFFFFFFFF)
    out

fn make_x86_64_exec() -> [u8]:
    var bytes: [u8] = []
    bytes.push(0x7F.to_u8())
    bytes.push(0x45.to_u8())
    bytes.push(0x4C.to_u8())
    bytes.push(0x46.to_u8())
    bytes.push(2.to_u8())
    bytes.push(1.to_u8())
    bytes.push(1.to_u8())
    bytes.push(0.to_u8())
    bytes.push(0.to_u8())
    while bytes.len() < 16:
        bytes.push(0.to_u8())
    bytes = push_u16_le(bytes, 2)
    bytes = push_u16_le(bytes, 62)
    bytes = push_u32_le(bytes, 1)
    bytes = push_u64_le(bytes, 0x400000)
    bytes = push_u64_le(bytes, 64)
    bytes = push_u64_le(bytes, 0)
    bytes = push_u32_le(bytes, 0)
    bytes = push_u16_le(bytes, 64)
    bytes = push_u16_le(bytes, 56)
    bytes = push_u16_le(bytes, 1)
    bytes = push_u16_le(bytes, 0)
    bytes = push_u16_le(bytes, 0)
    bytes = push_u16_le(bytes, 0)
    bytes = push_u32_le(bytes, 1)
    bytes = push_u32_le(bytes, 5)
    bytes = push_u64_le(bytes, 0x1000)
    bytes = push_u64_le(bytes, 0x400000)
    bytes = push_u64_le(bytes, 0x400000)
    bytes = push_u64_le(bytes, 4)
    bytes = push_u64_le(bytes, 4)
    bytes = push_u64_le(bytes, 0x1000)
    while bytes.len() < 0x1000:
        bytes.push(0.to_u8())
    bytes.push(0xC3.to_u8())
    bytes

fn make_multi_pt_load_x86_64_exec() -> [u8]:
    var bytes: [u8] = []
    bytes.push(0x7F.to_u8())
    bytes.push(0x45.to_u8())
    bytes.push(0x4C.to_u8())
    bytes.push(0x46.to_u8())
    bytes.push(2.to_u8())
    bytes.push(1.to_u8())
    bytes.push(1.to_u8())
    bytes.push(0.to_u8())
    bytes.push(0.to_u8())
    while bytes.len() < 16:
        bytes.push(0.to_u8())
    bytes = push_u16_le(bytes, 2)
    bytes = push_u16_le(bytes, 62)
    bytes = push_u32_le(bytes, 1)
    bytes = push_u64_le(bytes, 0x400000)
    bytes = push_u64_le(bytes, 64)
    bytes = push_u64_le(bytes, 0)
    bytes = push_u32_le(bytes, 0)
    bytes = push_u16_le(bytes, 64)
    bytes = push_u16_le(bytes, 56)
    bytes = push_u16_le(bytes, 2)
    bytes = push_u16_le(bytes, 0)
    bytes = push_u16_le(bytes, 0)
    bytes = push_u16_le(bytes, 0)

    # PT_LOAD #1: file-backed text segment.
    bytes = push_u32_le(bytes, 1)
    bytes = push_u32_le(bytes, 5)
    bytes = push_u64_le(bytes, 0x1000)
    bytes = push_u64_le(bytes, 0x400000)
    bytes = push_u64_le(bytes, 0x400000)
    bytes = push_u64_le(bytes, 4)
    bytes = push_u64_le(bytes, 4)
    bytes = push_u64_le(bytes, 0x1000)

    # PT_LOAD #2: BSS-only data segment.
    bytes = push_u32_le(bytes, 1)
    bytes = push_u32_le(bytes, 6)
    bytes = push_u64_le(bytes, 0x2000)
    bytes = push_u64_le(bytes, 0x401000)
    bytes = push_u64_le(bytes, 0x401000)
    bytes = push_u64_le(bytes, 0)
    bytes = push_u64_le(bytes, 0x1000)
    bytes = push_u64_le(bytes, 0x1000)

    while bytes.len() < 0x1000:
        bytes.push(0.to_u8())
    bytes.push(0xC3.to_u8())
    bytes.push(0x90.to_u8())
    bytes.push(0x90.to_u8())
    bytes.push(0x90.to_u8())
    while bytes.len() < 0x2000:
        bytes.push(0.to_u8())
    bytes

fn make_smf_wrapped_x86_64_exec() -> [u8]:
    var b = make_x86_64_exec()
    val stub_len = b.len()
    b.push(83.to_u8())
    b.push(77.to_u8())
    b.push(70.to_u8())
    b.push(0.to_u8())
    var i = 4
    while i < 44:
        b.push(0.to_u8())
        i = i + 1
    b = push_u64_le(b, 0x400000)
    b = push_u32_le(b, stub_len)
    b = push_u32_le(b, stub_len)
    while b.len() < stub_len + 128:
        b.push(0.to_u8())
    b

fn make_x86_32_exec() -> [u8]:
    var bytes: [u8] = []
    bytes.push(0x7F.to_u8())
    bytes.push(0x45.to_u8())
    bytes.push(0x4C.to_u8())
    bytes.push(0x46.to_u8())
    bytes.push(1.to_u8())
    bytes.push(1.to_u8())
    bytes.push(1.to_u8())
    bytes.push(0.to_u8())
    bytes.push(0.to_u8())
    while bytes.len() < 16:
        bytes.push(0.to_u8())
    bytes = push_u16_le(bytes, 2)
    bytes = push_u16_le(bytes, 3)
    bytes = push_u32_le(bytes, 1)
    bytes = push_u32_le(bytes, 0x8048000)
    bytes = push_u32_le(bytes, 52)
    bytes = push_u32_le(bytes, 0)
    bytes = push_u32_le(bytes, 0)
    bytes = push_u16_le(bytes, 52)
    bytes = push_u16_le(bytes, 32)
    bytes = push_u16_le(bytes, 1)
    bytes = push_u16_le(bytes, 0)
    bytes = push_u16_le(bytes, 0)
    bytes = push_u16_le(bytes, 0)
    bytes = push_u32_le(bytes, 1)
    bytes = push_u32_le(bytes, 0x100)
    bytes = push_u32_le(bytes, 0x8048000)
    bytes = push_u32_le(bytes, 0x8048000)
    bytes = push_u32_le(bytes, 4)
    bytes = push_u32_le(bytes, 4)
    bytes = push_u32_le(bytes, 5)
    bytes = push_u32_le(bytes, 0x1000)
    while bytes.len() < 0x100:
        bytes.push(0.to_u8())
    bytes.push(0xC3.to_u8())
    bytes.push(0x90.to_u8())
    bytes.push(0x90.to_u8())
    bytes.push(0x90.to_u8())
    bytes

describe "process image builder":
    it "builds an x86_64 user image from executable bytes":
        val bytes = make_x86_64_exec()
        val image = build_user_process_image("/usr/bin/x86_exec_probe", bytes, Architecture.X86_64)
        expect(image.is_ok()).to_equal(true)
        val built = image.unwrap()
        expect(built.entry).to_equal(0x400000)
        expect(built.stack_top).to_equal(X86_64_USER_STACK_TOP)
        expect(built.stack_size).to_equal(0x800000)
        expect(built.segment_count).to_equal(1)

    it "builds an x86_32 user image from executable bytes":
        val bytes = make_x86_32_exec()
        val image = build_user_process_image("/usr/bin/x86_32_exec_probe", bytes, Architecture.X86)
        expect(image.is_ok()).to_equal(true)
        val built = image.unwrap()
        expect(built.entry).to_equal(0x8048000)
        expect(built.stack_top).to_equal(X86_32_USER_STACK_TOP)
        expect(built.stack_size).to_equal(0x800000)
        expect(built.segment_count).to_equal(1)
        expect(built.segments[0].virt_addr).to_equal(0x8048000)

    it "builds an x86_64 user image from an SMF-wrapped executable stub":
        val bytes = make_smf_wrapped_x86_64_exec()
        val image = build_user_process_image("/usr/bin/smf_x86_exec_probe", bytes, Architecture.X86_64)
        expect(image.is_ok()).to_equal(true)
        val built = image.unwrap()
        expect(built.entry).to_equal(0x400000)
        expect(built.stack_top).to_equal(X86_64_USER_STACK_TOP)
        expect(built.stack_size).to_equal(0x800000)
        expect(built.segment_count).to_equal(1)
        expect(built.file_bytes[0]).to_equal(0x7F.to_u8())

    it "builds an x86_64 user image from multi-PT_LOAD app bytes and owns the copies":
        var bytes = make_multi_pt_load_x86_64_exec()
        val image = build_user_process_image("/sys/apps/browser_demo", bytes, Architecture.X86_64)
        expect(image.is_ok()).to_equal(true)
        val built = image.unwrap()

        expect(built.entry).to_equal(0x400000)
        expect(built.stack_top).to_equal(X86_64_USER_STACK_TOP)
        expect(built.stack_size).to_equal(0x800000)
        expect(built.segments.len()).to_equal(2)
        expect(built.segment_count).to_equal(2)
        expect(built.segments[0].data.len()).to_equal(4)
        expect(built.segments[0].data[0]).to_equal(0xC3.to_u8())
        expect(built.segments[1].file_size).to_equal(0)
        expect(built.segments[1].mem_size).to_equal(0x1000)
        expect(built.segments[1].data.len()).to_equal(0)
        expect(built.file_bytes[0]).to_equal(0x7F.to_u8())
        expect(built.file_bytes[0x1000]).to_equal(0xC3.to_u8())

        bytes[0] = 0x00.to_u8()
        bytes[0x1000] = 0x00.to_u8()

        expect(built.file_bytes[0]).to_equal(0x7F.to_u8())
        expect(built.segments[0].data[0]).to_equal(0xC3.to_u8())
