use std.spipe.*
use os.kernel.net.embedded_certs.{
    get_embedded_cert_der, get_embedded_key_der, has_embedded_certs
}
use os.kernel.net.tls_shim.{get_baremetal_tls_info}

describe "baremetal TLS material gate":

    it "does not advertise placeholder certificate material as available":
        expect(has_embedded_certs()).to_equal(false)

    it "returns empty certificate and key bytes until real DER material is embedded":
        expect(get_embedded_cert_der().len().to_u64()).to_equal(0u64)
        expect(get_embedded_key_der().len().to_u64()).to_equal(0u64)

    it "reports TLS info unavailable instead of exposing synthetic bytes":
        val info = get_baremetal_tls_info()
        expect(info.available).to_equal(false)
        expect(info.cert_der.len().to_u64()).to_equal(0u64)
        expect(info.key_der.len().to_u64()).to_equal(0u64)
