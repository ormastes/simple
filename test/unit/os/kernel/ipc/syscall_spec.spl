use std.spec
use os.kernel.ipc.syscall.{syscall_handler, syscall_dispatch, dispatch_spawn_binary_direct}
use os.kernel.types.syscall_types.{SyscallArgs, SyscallTrapDisposition}
use os.kernel.scheduler.scheduler.{Scheduler}
use os.kernel.ipc.ipc.{IpcManager}
use os.kernel.log.klog.{KernelLog}
use os.kernel.ipc.notification.{notification_create, notification_wait}
use os.kernel.ipc.notif_global.{g_notification_table}
use os.kernel.memory.pmm.{pmm_alloc_page_raw}
use os.kernel.memory.vmm.{vmm_map_page}
use os.kernel.types.task_types.{TaskId, TaskPriority, TaskState, BlockReason}
use os.kernel.types.memory_types.{PhysAddr, VirtAddr, VmFlags, VM_PRESENT, VM_WRITABLE, VM_USER, VM_NO_EXECUTE}
use os.kernel.types.capability_types.{CapabilitySet}
use os.kernel.loader.executable_source.{RV64_PROOF_BINARY_PATH, _set_synthetic_vfs_file_for_test, _clear_synthetic_vfs_for_test}
use os.kernel.loader.dylib_registry.{dylib_registry_reset_for_test}
use os.posix.fd_table.{fd_table_init, fd_activate_task, fd_set, fd_set_cloexec, fd_is_valid, fd_set_poll_notification, FD_TYPE_FILE, FD_TYPE_PIPE_READ, O_RDONLY, POLLIN}
use os.kernel.boot.mmio.{mmio_read8, mmio_read32, mmio_read64, mmio_write8, mmio_write16, mmio_write32, mmio_write64}

"""
Syscall dispatcher tests for process launch and scheduler control paths.
"""

"""
The scheduler-control cases verify reserved sys_schedule/sys_schedctl ABI
without requiring a full booted kernel.
"""
fn _map_user_pollfd_page(ptr: u64) -> bool:
    val phys = pmm_alloc_page_raw()
    if phys == 0:
        return false
    vmm_map_page(
        VirtAddr(addr: ptr),
        PhysAddr(addr: phys),
        VmFlags(bits: VM_PRESENT | VM_WRITABLE | VM_USER | VM_NO_EXECUTE)
    )

fn _write_pollfd(ptr: u64, index: u64, fd: i32, events: i16):
    val entry = ptr + index * 8
    mmio_write32(entry, fd as u32)
    mmio_write16(entry + 4, events as u16)
    mmio_write16(entry + 6, 0)

fn _write_user_cstr(ptr: u64, bytes: [u8]):
    var i: u64 = 0
    while i < bytes.len() as u64:
        mmio_write8(ptr + i, bytes[i])
        i = i + 1
    mmio_write8(ptr + i, 0)

fn _push_u16_le(buf: [u8], value: i64) -> [u8]:
    buf.push((value & 0xFF).to_u8())
    buf.push(((value >> 8) & 0xFF).to_u8())
    buf

fn _push_u32_le(buf: [u8], value: i64) -> [u8]:
    buf.push((value & 0xFF).to_u8())
    buf.push(((value >> 8) & 0xFF).to_u8())
    buf.push(((value >> 16) & 0xFF).to_u8())
    buf.push(((value >> 24) & 0xFF).to_u8())
    buf

fn _push_u64_le(buf: [u8], value: i64) -> [u8]:
    var out = buf
    out = _push_u32_le(out, value & 0xFFFFFFFF)
    out = _push_u32_le(out, (value >> 32) & 0xFFFFFFFF)
    out

fn _make_x86_64_exec() -> [u8]:
    var bytes: [u8] = []
    bytes.push(0x7F.to_u8())
    bytes.push(0x45.to_u8())
    bytes.push(0x4C.to_u8())
    bytes.push(0x46.to_u8())
    bytes.push(2.to_u8())
    bytes.push(1.to_u8())
    bytes.push(1.to_u8())
    bytes.push(0.to_u8())
    bytes.push(0.to_u8())
    while bytes.len() < 16:
        bytes.push(0.to_u8())
    bytes = _push_u16_le(bytes, 2)
    bytes = _push_u16_le(bytes, 62)
    bytes = _push_u32_le(bytes, 1)
    bytes = _push_u64_le(bytes, 0x400000)
    bytes = _push_u64_le(bytes, 64)
    bytes = _push_u64_le(bytes, 0)
    bytes = _push_u32_le(bytes, 0)
    bytes = _push_u16_le(bytes, 64)
    bytes = _push_u16_le(bytes, 56)
    bytes = _push_u16_le(bytes, 1)
    bytes = _push_u16_le(bytes, 0)
    bytes = _push_u16_le(bytes, 0)
    bytes = _push_u16_le(bytes, 0)
    bytes = _push_u32_le(bytes, 1)
    bytes = _push_u32_le(bytes, 5)
    bytes = _push_u64_le(bytes, 0x1000)
    bytes = _push_u64_le(bytes, 0x400000)
    bytes = _push_u64_le(bytes, 0x400000)
    bytes = _push_u64_le(bytes, 4)
    bytes = _push_u64_le(bytes, 4)
    bytes = _push_u64_le(bytes, 0x1000)
    while bytes.len() < 0x1000:
        bytes.push(0.to_u8())
    bytes.push(0xC3.to_u8())
    bytes

fn _make_exec_smf(stub: [u8]) -> [u8]:
    var bytes = stub
    var header: [u8] = []
    header.push(0x53.to_u8())
    header.push(0x4D.to_u8())
    header.push(0x46.to_u8())
    header.push(0x00.to_u8())
    while header.len() < 52:
        header.push(0.to_u8())
    header = _push_u32_le(header, stub.len())
    header = _push_u32_le(header, stub.len())
    while header.len() < 128:
        header.push(0.to_u8())
    for b in header:
        bytes.push(b)
    bytes

describe "syscall_handler":
    it "copies active task ids and task info for process diagnostics":
        var scheduler = Scheduler.new()
        val first = scheduler.create_task(0x1000, TaskPriority.High, CapabilitySet.full())
        val second = scheduler.create_task(0x2000, TaskPriority.Low, CapabilitySet.full())
        val pid_buf = 0x12000000u64
        val info_buf = 0x12000100u64
        val name_buf = 0x12000200u64
        expect(_map_user_pollfd_page(pid_buf)).to_equal(true)

        val list_result = syscall_handler(
            SyscallArgs(
                id: 5,
                arg0: pid_buf,
                arg1: 4,
                arg2: 0,
                arg3: 0,
                arg4: 0,
                arg5: 0
            ),
            scheduler,
            IpcManager.new(),
            KernelLog.new(16)
        )

        expect(list_result.value).to_equal(2)
        expect(mmio_read64(pid_buf)).to_equal(first.id)
        expect(mmio_read64(pid_buf + 8)).to_equal(second.id)

        val info_result = syscall_handler(
            SyscallArgs(
                id: 6,
                arg0: second.id,
                arg1: info_buf,
                arg2: name_buf,
                arg3: 64,
                arg4: 0,
                arg5: 0
            ),
            scheduler,
            IpcManager.new(),
            KernelLog.new(16)
        )

        expect(info_result.value).to_equal(0)
        expect(mmio_read64(info_buf)).to_equal(second.id)
        expect(mmio_read64(info_buf + 8)).to_equal(0)
        expect(mmio_read8(info_buf + 16)).to_equal(0u8)
        expect(mmio_read8(info_buf + 17)).to_equal(3u8)
        expect(mmio_read32(info_buf + 40)).to_equal(6u32)
        expect(mmio_read8(name_buf)).to_equal(116u8)
        expect(mmio_read8(name_buf + 5)).to_equal(50u8)

    it "launches built-in service binaries through spawn_binary":
        val path = "/sys/services/vfs"
        var scheduler = Scheduler.new()
        val result = syscall_handler(
            SyscallArgs(
                id: 13,
                arg0: &path as u64,
                arg1: path.len() as u64,
                arg2: 2,
                arg3: 0,
                arg4: 0,
                arg5: 0
            ),
            scheduler,
            IpcManager.new(),
            KernelLog.new(16)
        )
        expect(result.value).to_be_greater_than(0)
        val spawned = scheduler.get_task(TaskId(id: result.value as u64))
        val found = if spawned == nil: 0 else: 1
        expect(found).to_equal(1)
        if spawned != nil:
            val task = spawned
            expect(task.is_user).to_equal(true)

    it "sleep syscall blocks current task on a scheduler deadline":
        var scheduler = Scheduler.new()
        val task_id = scheduler.create_task(0x1000, TaskPriority.Normal, CapabilitySet.full())
        scheduler.schedule()

        val result = syscall_handler(
            SyscallArgs(
                id: 51,
                arg0: 15000000,
                arg1: 0,
                arg2: 0,
                arg3: 0,
                arg4: 0,
                arg5: 0
            ),
            scheduler,
            IpcManager.new(),
            KernelLog.new(16)
        )

        expect(result.value).to_equal(0)
        val tcb = scheduler.get_task(task_id)
        if tcb != nil:
            val task = tcb
            val blocked_until = match task.state:
                TaskState.Blocked(reason):
                    match reason:
                        BlockReason.Sleep(until_ns): until_ns
                        _: 0u64
                _: 0u64
            expect(blocked_until).to_equal(20000000u64)

    it "dispatch marks blocking sleep as BlockCurrent":
        var scheduler = Scheduler.new()
        scheduler.create_task(0x1000, TaskPriority.Normal, CapabilitySet.full())
        scheduler.schedule()

        val result = syscall_dispatch(
            SyscallArgs(
                id: 51,
                arg0: 15000000,
                arg1: 0,
                arg2: 0,
                arg3: 0,
                arg4: 0,
                arg5: 0
            ),
            scheduler,
            IpcManager.new(),
            KernelLog.new(16)
        )

        expect(result.result.value).to_equal(0)
        expect(result.disposition).to_equal(SyscallTrapDisposition.BlockCurrent)

    it "poll with no fds and finite timeout blocks on a scheduler deadline":
        var scheduler = Scheduler.new()
        val task_id = scheduler.create_task(0x1000, TaskPriority.Normal, CapabilitySet.full())
        scheduler.schedule()

        val result = syscall_handler(
            SyscallArgs(
                id: 68,
                arg0: 0,
                arg1: 0,
                arg2: 25,
                arg3: 0,
                arg4: 0,
                arg5: 0
            ),
            scheduler,
            IpcManager.new(),
            KernelLog.new(16)
        )

        expect(result.value).to_equal(0)
        val tcb = scheduler.get_task(task_id)
        if tcb != nil:
            val task = tcb
            val blocked_until = match task.state:
                TaskState.Blocked(reason):
                    match reason:
                        BlockReason.Sleep(until_ns): until_ns
                        _: 0u64
                _: 0u64
            expect(blocked_until).to_equal(30000000u64)

    it "dispatch marks blocking poll as BlockCurrent":
        var scheduler = Scheduler.new()
        scheduler.create_task(0x1000, TaskPriority.Normal, CapabilitySet.full())
        scheduler.schedule()

        val result = syscall_dispatch(
            SyscallArgs(
                id: 68,
                arg0: 0,
                arg1: 0,
                arg2: 25,
                arg3: 0,
                arg4: 0,
                arg5: 0
            ),
            scheduler,
            IpcManager.new(),
            KernelLog.new(16)
        )

        expect(result.result.value).to_equal(0)
        expect(result.disposition).to_equal(SyscallTrapDisposition.BlockCurrent)

    it "poll treats any negative timeout as an infinite wait":
        var scheduler = Scheduler.new()
        val task_id = scheduler.create_task(0x1000, TaskPriority.Normal, CapabilitySet.full())
        scheduler.schedule()

        val result = syscall_handler(
            SyscallArgs(
                id: 68,
                arg0: 0,
                arg1: 0,
                arg2: 0xFFFFFFFFFFFFFFFE,
                arg3: 0,
                arg4: 0,
                arg5: 0
            ),
            scheduler,
            IpcManager.new(),
            KernelLog.new(16)
        )

        expect(result.value).to_equal(0)
        val tcb = scheduler.get_task(task_id)
        if tcb != nil:
            val task = tcb
            val blocked_until = match task.state:
                TaskState.Blocked(reason):
                    match reason:
                        BlockReason.Sleep(until_ns): until_ns
                        _: 0u64
                _: 0u64
            expect(blocked_until).to_equal(0xFFFFFFFFFFFFFFFF)

    it "poll returns -EINVAL when more than four notification-backed fds are passed":
        fd_table_init()
        val pollfds_ptr = 0x10000000u64
        expect(_map_user_pollfd_page(pollfds_ptr)).to_equal(true)

        var i: u64 = 0
        while i < 5:
            val fd = (3 + i) as i32
            val notif = notification_create(g_notification_table)
            fd_set(fd, FD_TYPE_PIPE_READ, O_RDONLY, (10 + i) as u64)
            expect(fd_set_poll_notification(fd, POLLIN, notif)).to_equal(0)
            _write_pollfd(pollfds_ptr, i, fd, POLLIN)
            i = i + 1

        var scheduler = Scheduler.new()
        val task_id = scheduler.create_task(0x1000, TaskPriority.Normal, CapabilitySet.full())
        scheduler.schedule()

        val result = syscall_handler(
            SyscallArgs(
                id: 68,
                arg0: pollfds_ptr,
                arg1: 5,
                arg2: 25,
                arg3: 0,
                arg4: 0,
                arg5: 0
            ),
            scheduler,
            IpcManager.new(),
            KernelLog.new(16)
        )

        expect(result.value).to_equal(-22)
        val tcb = scheduler.get_task(task_id)
        if tcb != nil:
            val task = tcb
            val is_blocked = match task.state:
                TaskState.Blocked(reason): true
                _: false
            expect(is_blocked).to_equal(false)

    it "poll with a notification-backed fd and finite timeout blocks on a scheduler deadline":
        fd_table_init()
        val pollfds_ptr = 0x10000000u64
        expect(_map_user_pollfd_page(pollfds_ptr)).to_equal(true)

        val fd = 3
        val notif = notification_create(g_notification_table)
        fd_set(fd, FD_TYPE_PIPE_READ, O_RDONLY, 10u64)
        expect(fd_set_poll_notification(fd, POLLIN, notif)).to_equal(0)
        _write_pollfd(pollfds_ptr, 0, fd, POLLIN)

        var scheduler = Scheduler.new()
        val task_id = scheduler.create_task(0x1000, TaskPriority.Normal, CapabilitySet.full())
        scheduler.schedule()

        val result = syscall_handler(
            SyscallArgs(
                id: 68,
                arg0: pollfds_ptr,
                arg1: 1,
                arg2: 25,
                arg3: 0,
                arg4: 0,
                arg5: 0
            ),
            scheduler,
            IpcManager.new(),
            KernelLog.new(16)
        )

        expect(result.value).to_equal(0)
        val tcb = scheduler.get_task(task_id)
        if tcb != nil:
            val task = tcb
            val blocked_until = match task.state:
                TaskState.Blocked(reason):
                    match reason:
                        BlockReason.Sleep(until_ns): until_ns
                        _: 0u64
                _: 0u64
            expect(blocked_until).to_equal(30000000u64)

    it "notification signal syscall wakes every staged waiter":
        var scheduler = Scheduler.new()
        val first = scheduler.create_task(0x1000, TaskPriority.Normal, CapabilitySet.full())
        val second = scheduler.create_task(0x2000, TaskPriority.Normal, CapabilitySet.full())
        val notif = notification_create(g_notification_table)
        expect(notification_wait(g_notification_table, notif, first.id)).to_equal(0u64)
        expect(notification_wait(g_notification_table, notif, second.id)).to_equal(0u64)
        scheduler.block_task(first, BlockReason.Notification(id: notif))
        scheduler.block_task(second, BlockReason.Notification(id: notif))

        val result = syscall_handler(
            SyscallArgs(
                id: 25,
                arg0: notif,
                arg1: 1,
                arg2: 0,
                arg3: 0,
                arg4: 0,
                arg5: 0
            ),
            scheduler,
            IpcManager.new(),
            KernelLog.new(16)
        )

        expect(result.value).to_equal(0)
        val first_tcb = scheduler.get_task(first)
        val second_tcb = scheduler.get_task(second)
        if first_tcb != nil:
            val task = first_tcb
            val is_ready = match task.state:
                TaskState.Ready: true
                _: false
            expect(is_ready).to_equal(true)
        if second_tcb != nil:
            val task = second_tcb
            val is_ready = match task.state:
                TaskState.Ready: true
                _: false
            expect(is_ready).to_equal(true)

    it "launches the canonical rv64 proof binary path through spawn_binary":
        val path = RV64_PROOF_BINARY_PATH
        var scheduler = Scheduler.new()
        val result = syscall_handler(
            SyscallArgs(
                id: 13,
                arg0: &path as u64,
                arg1: path.len() as u64,
                arg2: 2,
                arg3: 0,
                arg4: 0,
                arg5: 0
            ),
            scheduler,
            IpcManager.new(),
            KernelLog.new(16)
        )
        expect(result.value).to_be_greater_than(0)
        val spawned = scheduler.get_task(TaskId(id: result.value as u64))
        val found = if spawned == nil: 0 else: 1
        expect(found).to_equal(1)

    it "rejects missing executable bytes without resident fallback":
        val path = "/sys/apps/hello_world"
        var scheduler = Scheduler.new()
        val result = syscall_handler(
            SyscallArgs(
                id: 13,
                arg0: &path as u64,
                arg1: path.len() as u64,
                arg2: 2,
                arg3: 0,
                arg4: 0,
                arg5: 0
            ),
            scheduler,
            IpcManager.new(),
            KernelLog.new(16)
        )
        expect(result.value).to_equal(-2)
        val spawned = scheduler.get_task(TaskId(id: 1))
        expect(spawned).to_be_nil()

    it "direct sentinel spawn creates process-backed user task for valid filesystem ELF":
        _clear_synthetic_vfs_for_test()
        _set_synthetic_vfs_file_for_test("/sys/apps/hello_world", _make_x86_64_exec())
        var scheduler = Scheduler.new()
        val pid = dispatch_spawn_binary_direct(3, 0, 2, scheduler, KernelLog.new(16))
        expect(pid).to_be_greater_than(0)
        expect(pid).not_to_equal(4103)
        val spawned = scheduler.get_task(TaskId(id: pid as u64))
        val found = if spawned == nil: 0 else: 1
        expect(found).to_equal(1)
        if spawned != nil:
            val task = spawned
            expect(task.is_user).to_equal(true)
            expect(task.entry_point).to_equal(0x400000)
        _clear_synthetic_vfs_for_test()

    it "direct SMF sentinel spawn creates process-backed user task without resident fallback":
        _clear_synthetic_vfs_for_test()
        _set_synthetic_vfs_file_for_test("/sys/apps/hello_world.smf", _make_exec_smf(_make_x86_64_exec()))
        var scheduler = Scheduler.new()
        val pid = dispatch_spawn_binary_direct(103, 0, 2, scheduler, KernelLog.new(16))
        expect(pid).to_be_greater_than(0)
        expect(pid).not_to_equal(4103)
        val spawned = scheduler.get_task(TaskId(id: pid as u64))
        val found = if spawned == nil: 0 else: 1
        expect(found).to_equal(1)
        if spawned != nil:
            val task = spawned
            expect(task.is_user).to_equal(true)
            expect(task.entry_point).to_equal(0x400000)
        _clear_synthetic_vfs_for_test()

    it "spawn_binary creates process-backed user task for executable SMF package":
        _clear_synthetic_vfs_for_test()
        val path = "/home/RUNME.SMF"
        _set_synthetic_vfs_file_for_test(path, _make_exec_smf(_make_x86_64_exec()))
        var scheduler = Scheduler.new()
        val result = syscall_handler(
            SyscallArgs(
                id: 13,
                arg0: &path as u64,
                arg1: path.len() as u64,
                arg2: 2,
                arg3: 0,
                arg4: 0,
                arg5: 0
            ),
            scheduler,
            IpcManager.new(),
            KernelLog.new(16)
        )
        expect(result.value).to_be_greater_than(0)
        val spawned = scheduler.get_task(TaskId(id: result.value as u64))
        val found = if spawned == nil: 0 else: 1
        expect(found).to_equal(1)
        if spawned != nil:
            val task = spawned
            expect(task.is_user).to_equal(true)
            expect(task.entry_point).to_equal(0x400000)
        _clear_synthetic_vfs_for_test()

    it "direct sentinel spawn rejects malformed filesystem bytes without resident fallback":
        _clear_synthetic_vfs_for_test()
        _set_synthetic_vfs_file_for_test("/sys/apps/hello_world", [0x7Fu8, 0x45u8, 0x4Cu8, 0x46u8])
        var scheduler = Scheduler.new()
        val pid = dispatch_spawn_binary_direct(3, 0, 2, scheduler, KernelLog.new(16))
        expect(pid).to_equal(-8)
        val spawned = scheduler.get_task(TaskId(id: 1))
        expect(spawned).to_be_nil()
        _clear_synthetic_vfs_for_test()

    it "rejects unknown spawn_binary paths":
        val path = "/sys/apps/does_not_exist"
        val result = syscall_handler(
            SyscallArgs(
                id: 13,
                arg0: &path as u64,
                arg1: path.len() as u64,
                arg2: 2,
                arg3: 0,
                arg4: 0,
                arg5: 0
            ),
            Scheduler.new(),
            IpcManager.new(),
            KernelLog.new(16)
        )
        expect(result.value).to_equal(-2)

    it "rejects empty spawn_binary requests":
        val result = syscall_handler(
            SyscallArgs(
                id: 13,
                arg0: 0,
                arg1: 0,
                arg2: 2,
                arg3: 0,
                arg4: 0,
                arg5: 0
            ),
            Scheduler.new(),
            IpcManager.new(),
            KernelLog.new(16)
        )
        expect(result.value).to_equal(-22)

    it "rejects oversized spawn_binary paths":
        val path = "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa"
        val result = syscall_handler(
            SyscallArgs(
                id: 13,
                arg0: &path as u64,
                arg1: path.len() as u64,
                arg2: 2,
                arg3: 0,
                arg4: 0,
                arg5: 0
            ),
            Scheduler.new(),
            IpcManager.new(),
            KernelLog.new(16)
        )
        expect(result.value).to_equal(-22)

    it "fork syscall clones the current scheduler task":
        var scheduler = Scheduler.new()
        val parent = scheduler.create_task(0x1000, TaskPriority.Normal, CapabilitySet.full())
        scheduler.schedule()
        val result = syscall_handler(
            SyscallArgs(
                id: 57,
                arg0: 0,
                arg1: 0,
                arg2: 0,
                arg3: 0,
                arg4: 0,
                arg5: 0
            ),
            scheduler,
            IpcManager.new(),
            KernelLog.new(16)
        )
        expect(result.value).to_be_greater_than(0)
        val child = scheduler.get_task(TaskId(id: result.value as u64))
        if child != nil:
            val task = child
            if task.parent != nil:
                val p = task.parent.unwrap()
                expect(p.id).to_equal(parent.id)

    it "wait syscall blocks current parent while child is live":
        var scheduler = Scheduler.new()
        val parent = scheduler.create_task(0x1000, TaskPriority.Normal, CapabilitySet.full())
        scheduler.schedule()
        val child = scheduler.clone_task(parent)
        val result = syscall_handler(
            SyscallArgs(
                id: 3,
                arg0: child.id,
                arg1: 0,
                arg2: 0,
                arg3: 0,
                arg4: 0,
                arg5: 0
            ),
            scheduler,
            IpcManager.new(),
            KernelLog.new(16)
        )
        expect(result.value).to_equal(0)
        val parent_tcb = scheduler.get_task(parent)
        if parent_tcb != nil:
            val task = parent_tcb
            val is_blocked = match task.state:
                TaskState.Blocked(reason): true
                _: false
            expect(is_blocked).to_equal(true)

    it "waitpid WNOHANG leaves live child and parent runnable":
        var scheduler = Scheduler.new()
        val parent = scheduler.create_task(0x1000, TaskPriority.Normal, CapabilitySet.full())
        scheduler.schedule()
        val child = scheduler.clone_task(parent)
        val result = syscall_handler(
            SyscallArgs(
                id: 61,
                arg0: child.id,
                arg1: 0,
                arg2: 1,
                arg3: 0,
                arg4: 0,
                arg5: 0
            ),
            scheduler,
            IpcManager.new(),
            KernelLog.new(16)
        )
        expect(result.value).to_equal(0)
        val parent_tcb = scheduler.get_task(parent)
        if parent_tcb != nil:
            val task = parent_tcb
            val is_blocked = match task.state:
                TaskState.Blocked(reason): true
                _: false
            expect(is_blocked).to_equal(false)
        expect(scheduler.get_task(child)).to_be_nil.to_equal(false)

    it "waitpid any child returns the reaped child pid":
        var scheduler = Scheduler.new()
        val parent = scheduler.create_task(0x1000, TaskPriority.Normal, CapabilitySet.full())
        scheduler.schedule()
        val child = scheduler.clone_task(parent)
        scheduler.schedule()
        scheduler.exit_task(9)

        val result = syscall_handler(
            SyscallArgs(
                id: 61,
                arg0: 0xFFFFFFFFFFFFFFFF,
                arg1: 0,
                arg2: 0,
                arg3: 0,
                arg4: 0,
                arg5: 0
            ),
            scheduler,
            IpcManager.new(),
            KernelLog.new(16)
        )

        expect(result.value).to_equal(child.id.to_i64())
        expect(scheduler.get_task(child)).to_be_nil

    it "waitpid writes encoded exit status before reaping child":
        var scheduler = Scheduler.new()
        val parent = scheduler.create_task(0x1000, TaskPriority.Normal, CapabilitySet.full())
        scheduler.schedule()
        val child = scheduler.clone_task(parent)
        scheduler.exit_task_by_id(child, 7)
        val status_ptr: u64 = 0x70000000
        expect(_map_user_pollfd_page(status_ptr)).to_equal(true)

        val result = syscall_handler(
            SyscallArgs(
                id: 61,
                arg0: child.id,
                arg1: status_ptr,
                arg2: 0,
                arg3: 0,
                arg4: 0,
                arg5: 0
            ),
            scheduler,
            IpcManager.new(),
            KernelLog.new(16)
        )

        expect(result.value).to_equal(child.id.to_i64())
        expect(mmio_read32(status_ptr)).to_equal(7u32 << 8)
        expect(scheduler.get_task(child)).to_be_nil

    it "waitpid rejects invalid status pointer without reaping zombie child":
        var scheduler = Scheduler.new()
        val parent = scheduler.create_task(0x1000, TaskPriority.Normal, CapabilitySet.full())
        scheduler.schedule()
        val child = scheduler.clone_task(parent)
        scheduler.exit_task_by_id(child, 5)

        val result = syscall_handler(
            SyscallArgs(
                id: 61,
                arg0: child.id,
                arg1: 1,
                arg2: 0,
                arg3: 0,
                arg4: 0,
                arg5: 0
            ),
            scheduler,
            IpcManager.new(),
            KernelLog.new(16)
        )

        expect(result.value).to_equal(-14)
        val child_tcb = scheduler.get_task(child)
        expect(child_tcb).to_be_nil.to_equal(false)
        if child_tcb != nil:
            val task = child_tcb
            val is_zombie = match task.state:
                TaskState.Zombie: true
                _: false
            expect(is_zombie).to_equal(true)

    it "waitpid syscall rejects missing children instead of returning ENOSYS":
        var scheduler = Scheduler.new()
        scheduler.create_task(0x1000, TaskPriority.Normal, CapabilitySet.full())
        scheduler.schedule()
        val result = syscall_handler(
            SyscallArgs(
                id: 61,
                arg0: 999,
                arg1: 0,
                arg2: 0,
                arg3: 0,
                arg4: 0,
                arg5: 0
            ),
            scheduler,
            IpcManager.new(),
            KernelLog.new(16)
        )
        expect(result.value).to_equal(-10)

    it "exec failure leaves current task image intact":
        var scheduler = Scheduler.new()
        val task = scheduler.create_task(0x1234, TaskPriority.Normal, CapabilitySet.full())
        scheduler.schedule()
        val path = "/does/not/exist"

        val result = syscall_handler(
            SyscallArgs(
                id: 59,
                arg0: &path as u64,
                arg1: path.len() as u64,
                arg2: 0,
                arg3: 0,
                arg4: 0,
                arg5: 0
            ),
            scheduler,
            IpcManager.new(),
            KernelLog.new(16)
        )

        expect(result.value).to_equal(-2)
        val tcb = scheduler.get_task(task)
        if tcb != nil:
            val current = tcb
            expect(current.is_user).to_equal(false)
            expect(current.entry_point).to_equal(0x1234)
            expect(current.address_space).to_equal(0)

    it "signal kill marks the target as a waitable zombie":
        var scheduler = Scheduler.new()
        val parent = scheduler.create_task(0x1000, TaskPriority.Normal, CapabilitySet.full())
        val child = scheduler.clone_task(parent)

        val kill_result = syscall_handler(
            SyscallArgs(
                id: 7,
                arg0: child.id,
                arg1: 1,
                arg2: 0,
                arg3: 0,
                arg4: 0,
                arg5: 0
            ),
            scheduler,
            IpcManager.new(),
            KernelLog.new(16)
        )
        expect(kill_result.value).to_equal(0)

        val status = scheduler.wait_for(parent, child)
        expect(status).to_equal(-9)
        expect(scheduler.get_task(child)).to_be_nil

    it "dynamic loading syscalls are wired instead of returning ENOSYS":
