                arg0: &path as u64,
                arg1: path.len() as u64,
                arg2: 0,
                arg3: 0,
                arg4: 0,
                arg5: 0
            ),
            scheduler,
            IpcManager.new(),
            KernelLog.new(16)
        )

        expect(result.value).to_equal(-2)
        expect(fd_is_valid(3)).to_equal(true)

