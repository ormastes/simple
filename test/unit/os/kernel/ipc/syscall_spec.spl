    it "requires RT bandwidth before schedctl RT activation":
        var scheduler = Scheduler.new()
        val task = scheduler.create_task(0x1000, TaskPriority.Normal, CapabilitySet.full())
        val rejected = syscall_handler(
            SyscallArgs(
                id: 107,
                arg0: 1,
                arg1: task.id,
                arg2: 2,
                arg3: 1024,
                arg4: 1000000,
                arg5: 0
            ),
            scheduler,
            IpcManager.new(),
            KernelLog.new(16)
        )
        expect(rejected.value).to_equal(-22)

        val budget = syscall_handler(
            SyscallArgs(
                id: 107,
                arg0: 5,
                arg1: task.id,
                arg2: 0,
                arg3: 10000000,
                arg4: 30000000,
                arg5: 0
            ),
            scheduler,
            IpcManager.new(),
            KernelLog.new(16)
        )
        expect(budget.value).to_equal(0)

        val accepted = syscall_handler(
            SyscallArgs(
                id: 107,
                arg0: 1,
                arg1: task.id,
                arg2: 2,
                arg3: 1024,
                arg4: 1000000,
                arg5: 0
            ),
            scheduler,
            IpcManager.new(),
            KernelLog.new(16)
        )
        expect(accepted.value).to_equal(0)

