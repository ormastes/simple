    describe "Normal":
        it "can be constructed":
            val prio = TaskPriority.Normal
            val is_normal = match prio:
                TaskPriority.Normal: true
                _: false
            expect is_normal == true

    describe "Low":
        it "can be constructed":
            val prio = TaskPriority.Low
            val is_low = match prio:
                TaskPriority.Low: true
                _: false
            expect is_low == true

    describe "Idle":
        it "can be constructed":
