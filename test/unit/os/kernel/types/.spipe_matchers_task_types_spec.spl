"""
# Task Types Specification

**Feature IDs:** #OS-002
**Category:** Runtime
**Difficulty:** 2/5
**Status:** Implemented
**Requirements:** N/A
**Plan:** N/A
**Design:** N/A
**Research:** N/A

## Overview

Tests for TaskId, TaskState, TaskPriority, TaskContext, and BlockReason
kernel types. Validates construction and field access for all task-related
structures used by the scheduler, IPC, and capability layers.
"""

use std.spec.{describe, it, expect}
use os.kernel.types.task_types.{TaskId, TaskState, TaskPriority, TaskContext, BlockReason, UserLoadSegment, UserProcessImage, user_process_image_segment_count}


# ============================================================================
# Test Group 1: TaskId
# ============================================================================

describe "TaskId":
    it "stores the task identifier":
        val id = TaskId(id: 1)
        expect id.id == 1

    it "supports zero id":
        val id = TaskId(id: 0)
        expect id.id == 0

    it "supports large id":
        val id = TaskId(id: 999999)
        expect id.id == 999999

    it "can compare two equal ids":
        val a = TaskId(id: 42)
        val b = TaskId(id: 42)
        expect a.id == b.id

    it "can distinguish different ids":
        val a = TaskId(id: 1)
        val b = TaskId(id: 2)
        val same = a.id == b.id
        expect same == false


# ============================================================================
# Test Group 2: TaskState
# ============================================================================

describe "TaskState":
    describe "Ready":
        it "can be constructed":
            val state = TaskState.Ready
            val is_ready = match state:
                TaskState.Ready: true
                _: false
            expect is_ready == true

    describe "Running":
        it "can be constructed":
            val state = TaskState.Running
            val is_running = match state:
                TaskState.Running: true
                _: false
            expect is_running == true

    describe "Blocked":
        it "can be constructed with IpcRecv reason":
            val reason = BlockReason.IpcRecv(port: 5)
            val state = TaskState.Blocked(reason: reason)
            val is_blocked = match state:
                TaskState.Blocked(reason): true
                _: false
            expect is_blocked == true

        it "can be constructed with Sleep reason":
            val reason = BlockReason.Sleep(until_ns: 1000000)
            val state = TaskState.Blocked(reason: reason)
            val is_blocked = match state:
                TaskState.Blocked(reason): true
                _: false
            expect is_blocked == true

    describe "Zombie":
        it "can be constructed":
            val state = TaskState.Zombie
            val is_zombie = match state:
                TaskState.Zombie: true
                _: false
            expect is_zombie == true


