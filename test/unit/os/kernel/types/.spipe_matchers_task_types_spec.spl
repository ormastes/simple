                _: false
            expect is_idle == true


# ============================================================================
# Test Group 4: BlockReason
# ============================================================================

describe "BlockReason":
    it "IpcRecv carries port number":
        val reason = BlockReason.IpcRecv(port: 42)
        val port_val = match reason:
            BlockReason.IpcRecv(port): port
            _: 0
        expect port_val == 42

    it "IpcSend carries port number":
        val reason = BlockReason.IpcSend(port: 7)
        val port_val = match reason:
            BlockReason.IpcSend(port): port
            _: 0
        expect port_val == 7

    it "Sleep carries timestamp":
        val reason = BlockReason.Sleep(until_ns: 5000000)
        val ts = match reason:
            BlockReason.Sleep(until_ns): until_ns
            _: 0
        expect ts == 5000000

    it "PageFault carries faulting address":
        val reason = BlockReason.PageFault(addr: 0xDEAD)
        val fault_addr = match reason:
            BlockReason.PageFault(addr): addr
            _: 0
        expect fault_addr == 0xDEAD

    it "Exit has no payload":
        val reason = BlockReason.Exit
        val is_exit = match reason:
            BlockReason.Exit: true
            _: false
        expect is_exit == true


# ============================================================================
# Test Group 5: TaskContext
# ============================================================================

describe "TaskContext":
    it "stores general-purpose registers":
        val ctx = TaskContext(
            rax: 1, rbx: 2, rcx: 3, rdx: 4,
            rsi: 5, rdi: 6, rbp: 7, rsp: 8,
            r8: 9, r9: 10, r10: 11, r11: 12,
            r12: 13, r13: 14, r14: 15, r15: 16,
            rip: 0x1000, rflags: 0x202,
            cs: 0x23, ss: 0x1B, fpu_state: 0
        )
        expect ctx.rax == 1
        expect ctx.rbx == 2
        expect ctx.rcx == 3
        expect ctx.rdx == 4
        expect ctx.rsi == 5
        expect ctx.rdi == 6

    it "stores stack and instruction pointers":
        val ctx = TaskContext(
            rax: 0, rbx: 0, rcx: 0, rdx: 0,
            rsi: 0, rdi: 0, rbp: 0xFFFF0000, rsp: 0xFFFF1000,
            r8: 0, r9: 0, r10: 0, r11: 0,
            r12: 0, r13: 0, r14: 0, r15: 0,
            rip: 0x401000, rflags: 0x202,
            cs: 0x23, ss: 0x1B, fpu_state: 0
        )
        expect ctx.rbp == 0xFFFF0000
        expect ctx.rsp == 0xFFFF1000
        expect ctx.rip == 0x401000

describe "UserProcessImage":
    it "stores executable path, entry, and stack":
        val image = UserProcessImage(
            binary_path: "/sys/services/vfs",
            entry: 0x400000,
            stack_top: 0x4000000000,
            stack_size: 65536,
            argv: ["/sys/services/vfs"],
            envp: [],
            segments: [],
            segment_count: 0,
            file_bytes: [0x13.to_u8(), 0, 0, 0],
            initial_sp: 0x3fffffff80,
            initial_stack_bytes: [0x01.to_u8(), 0x02, 0x03, 0x04]
        )
        expect image.binary_path == "/sys/services/vfs"
        expect image.entry == 0x400000
        expect image.stack_top == 0x4000000000
        expect user_process_image_segment_count(image) == 0
        expect image.initial_sp == 0x3fffffff80
        expect image.initial_stack_bytes.len() == 4

    it "stores loadable user segments":
        val seg = UserLoadSegment(
            virt_addr: 0x400000,
            mem_size: 4,
            file_size: 4,
            flags: 5,
            align: 0x1000,
            data: [0x13.to_u8(), 0, 0, 0]
        )
        expect seg.virt_addr == 0x400000
        expect seg.data.len() == 4

    it "stores segment selectors":
        val ctx = TaskContext(
            rax: 0, rbx: 0, rcx: 0, rdx: 0,
            rsi: 0, rdi: 0, rbp: 0, rsp: 0,
            r8: 0, r9: 0, r10: 0, r11: 0,
            r12: 0, r13: 0, r14: 0, r15: 0,
            rip: 0, rflags: 0x202,
            cs: 0x08, ss: 0x10, fpu_state: 0
        )
        expect ctx.cs == 0x08
        expect ctx.ss == 0x10

    it "stores rflags":
        val ctx = TaskContext(
            rax: 0, rbx: 0, rcx: 0, rdx: 0,
            rsi: 0, rdi: 0, rbp: 0, rsp: 0,
            r8: 0, r9: 0, r10: 0, r11: 0,
            r12: 0, r13: 0, r14: 0, r15: 0,
            rip: 0, rflags: 0x202,
            cs: 0, ss: 0, fpu_state: 0
        )
        expect ctx.rflags == 0x202

    it "stores extended registers r8-r15":
        val ctx = TaskContext(
            rax: 0, rbx: 0, rcx: 0, rdx: 0,
            rsi: 0, rdi: 0, rbp: 0, rsp: 0,
            r8: 100, r9: 200, r10: 300, r11: 400,
            r12: 500, r13: 600, r14: 700, r15: 800,
            rip: 0, rflags: 0,
            cs: 0, ss: 0, fpu_state: 0
        )
        expect ctx.r8 == 100
        expect ctx.r9 == 200
        expect ctx.r10 == 300
        expect ctx.r11 == 400
        expect ctx.r12 == 500
        expect ctx.r13 == 600
        expect ctx.r14 == 700
        expect ctx.r15 == 800

    it "stores fpu_state pointer":
        val ctx = TaskContext(
            rax: 0, rbx: 0, rcx: 0, rdx: 0,
            rsi: 0, rdi: 0, rbp: 0, rsp: 0,
            r8: 0, r9: 0, r10: 0, r11: 0,
            r12: 0, r13: 0, r14: 0, r15: 0,
            rip: 0, rflags: 0,
            cs: 0, ss: 0, fpu_state: 0xBEEF0000
        )
        expect ctx.fpu_state == 0xBEEF0000