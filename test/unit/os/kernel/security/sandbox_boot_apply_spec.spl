use std.spec.{describe, it, expect}
use os.kernel.security.sandbox_boot_apply.{
    ARM_MPU_CTRL,
    ARM_MPU_CTRL_ENABLE_PRIVDEF,
    ARM_MPU_RASR_XN,
    ARM_MPU_RBAR,
    ARM_MPU_RNR,
    arm_mpu_access_permission_bits,
    arm_mpu_mmio_write_plan_from_sandbox_lowering,
    arm_mpu_rasr_value,
    arm_mpu_region_size_encoding,
    embedded_sandbox_lowering_sdn_from_section,
    embedded_sandbox_section_bounds_valid,
    embedded_sandbox_section_text_valid,
    sandbox_boot_apply_arm_mpu_count
}

describe "sandbox boot apply metadata and ARM MPU planning":
    it "fails closed for missing embedded sandbox section bounds":
        expect(embedded_sandbox_section_bounds_valid(0, 4096)).to_equal(false)
        expect(embedded_sandbox_lowering_sdn_from_section(4096, 4096, "sandbox_lowering:")).to_equal("")

    it "accepts bounded generated sandbox lowering section text":
        val lowering = """
sandbox_lowering:
  pmp_region|2147483648|4096|rw|locked
"""
        expect(embedded_sandbox_section_text_valid(lowering)).to_equal(true)
        expect(embedded_sandbox_lowering_sdn_from_section(4096, 8192, lowering)).to_equal(lowering)

    it "maps lowered region size and permissions to ARM MPU RASR bits":
        expect(arm_mpu_region_size_encoding(4096)).to_equal(11)
        expect(arm_mpu_access_permission_bits("rw")).to_equal(3 << 24)
        expect((arm_mpu_rasr_value(4096, "rw") & ARM_MPU_RASR_XN) != 0).to_equal(true)
        expect((arm_mpu_rasr_value(4096, "rx") & ARM_MPU_RASR_XN) == 0).to_equal(true)

    it "builds concrete ARM MPU MMIO writes from sandbox lowering":
        val lowering = """
sandbox_lowering:
  pmp_region|2147483648|4096|rw|locked
"""
        val writes = arm_mpu_mmio_write_plan_from_sandbox_lowering(lowering)
        expect(writes.len()).to_equal(5)
        expect(writes[0].addr).to_equal(ARM_MPU_CTRL)
        expect(writes[0].value).to_equal(0)
        expect(writes[1].addr).to_equal(ARM_MPU_RNR)
        expect(writes[2].addr).to_equal(ARM_MPU_RBAR)
        expect(writes[4].value).to_equal(ARM_MPU_CTRL_ENABLE_PRIVDEF)
        expect(sandbox_boot_apply_arm_mpu_count(lowering)).to_equal(5)
