# @cover src/os/kernel/boot/riscv_noalloc_handoff.spl 0%
"""
# RiscvNoallocHandoff Memory Map Parameterization Specification

**Feature IDs:** opensource-riscv-rtl-simpleos
**Category:** Infrastructure
**Difficulty:** 2/5
**Status:** Draft
**Requirements:** REQ-6
**Artifacts:** N/A

## Overview

Verifies AC-6: riscv_noalloc_handoff accepts a RiscvBoardMemoryMap so the
boot chain works for both K26 (Kria) and DE10-Nano (LiteX) without
hard-coded addresses. Tests that the layout struct produced from each
memory map has correct fields.

Covers:
- AC-6 (Scheduler/handoff parameterization for real-hardware idle loop)
"""

use std.spipe.*
use os.kernel.arch.riscv64.platform.kria_memory_map.{
    KriaFpgaMemoryMap,
    kria_memory_map_new
}
use os.kernel.arch.riscv64.platform.litex_memory_map.{
    LitexFpgaMemoryMap,
    litex_memory_map_new
}
use os.kernel.boot.riscv_noalloc_handoff.{
    RiscvMemoryLayout,
    riscv_noalloc_layout_from_kria,
    riscv_noalloc_layout_from_litex
}


# ============================================================================
# Helpers
# ============================================================================

fn kria_layout() -> RiscvMemoryLayout:
    val m = kria_memory_map_new()
    return riscv_noalloc_layout_from_kria(m)

fn litex_layout() -> RiscvMemoryLayout:
    val m = litex_memory_map_new()
    return riscv_noalloc_layout_from_litex(m)


# ============================================================================
# AC-6: Kria memory layout
# ============================================================================

describe "RiscvNoallocHandoff Kria layout":
    it "AC-6: Kria layout uart_base matches KriaFpgaMemoryMap":
        val layout = kria_layout()
        expect(layout.uart_base).to_equal(268435456)

    it "AC-6: Kria layout ram_base is 0x80000000":
        val layout = kria_layout()
        expect(layout.ram_base).to_equal(2147483648)

    it "AC-6: Kria layout heap_start is within RAM":
        val layout = kria_layout()
        expect(layout.heap_start).to_be_greater_than(layout.ram_base)

    it "AC-6: Kria layout heap_size is 16MB":
        val layout = kria_layout()
        expect(layout.heap_size).to_equal(16777216)


# ============================================================================
# AC-6: LiteX memory layout
# ============================================================================

describe "RiscvNoallocHandoff LiteX layout":
    it "AC-6: LiteX layout uart_base is 0xf0001000":
        val layout = litex_layout()
        expect(layout.uart_base).to_equal(4026535936)

    it "AC-6: LiteX layout ram_base is 0x40000000":
        val layout = litex_layout()
        expect(layout.ram_base).to_equal(1073741824)

    it "AC-6: LiteX layout heap_start is within LiteX RAM":
        val layout = litex_layout()
        expect(layout.heap_start).to_be_greater_than(layout.ram_base)

    it "AC-6: LiteX and Kria uart_base differ":
        val kria = kria_layout()
        val litex = litex_layout()
        expect(kria.uart_base).to_equal(268435456)
        expect(litex.uart_base).to_equal(4026535936)
