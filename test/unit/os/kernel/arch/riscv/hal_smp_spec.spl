use std.spec

# SA-2 scope: HalSmp impl — cpu_count, cpu_start return paths via mock SBI;
#             ipi_send delivers to pending slot; ipi_broadcast targets all.
# AC-1: HalSmp trait methods for rv64/rv32
# AC-5: IPI delivery seen by recipient hart; hart-count from DTB
#
# NOTE (interpreter-mode discipline): Interpreter mode only verifies file loading.
# These it-blocks call functions that do not exist yet (TDD red).
# Phase 5 SA-1 adds test-only SBI shim; Phase 5 SA-2 adds HalSmp impl + dtb_scan.

# ---------------------------------------------------------------------------
# Synthetic FDT generator (local copy — avoids cross-spec import, per Phase 4 D3)
# ---------------------------------------------------------------------------

class HartDescSmp:
    id: u32
    status: text
    isa: text

fn make_fdt_with_cpus_smp(harts: [HartDescSmp]) -> [u8]:
    # Minimal sentinel FDT blob (Phase 5 SA-2 replaces with proper encoding).
    [0xD0u8, 0x0Du8, 0xFEu8, 0xEDu8]

# ---------------------------------------------------------------------------
# Mock SBI carrier for HalSmp tests (matches D2 mock design)
# ---------------------------------------------------------------------------

class SbiMockSmp:
    var probe_ext_results: [(u64, bool)]
    var ipi_calls: [(u64, u64)]
    var hart_start_calls: [(u64, u64, u64)]

fn make_sbi_mock_v3_smp() -> SbiMockSmp:
    SbiMockSmp(
        probe_ext_results: [(0x735049u64, true), (0x04u64, false)],
        ipi_calls: [],
        hart_start_calls: []
    )

fn make_sbi_mock_clint_smp() -> SbiMockSmp:
    SbiMockSmp(
        probe_ext_results: [(0x735049u64, false), (0x04u64, false)],
        ipi_calls: [],
        hart_start_calls: []
    )

# ---------------------------------------------------------------------------
# HalSmp module-level state (memoized at init time)
# ---------------------------------------------------------------------------

val MAX_HARTS: u32 = 8u32

class ApBootArgs:
    stack: u64
    arg: u64

var HAL_SMP_CPU_COUNT_STATE: u32 = 1u32
var HAL_SMP_PENDING_IPI: [u32] = [0u32, 0u32, 0u32, 0u32, 0u32, 0u32, 0u32, 0u32]
var HAL_SMP_BOOT_ARGS: [ApBootArgs] = [
    ApBootArgs(stack: 0u64, arg: 0u64),
    ApBootArgs(stack: 0u64, arg: 0u64),
    ApBootArgs(stack: 0u64, arg: 0u64),
    ApBootArgs(stack: 0u64, arg: 0u64),
    ApBootArgs(stack: 0u64, arg: 0u64),
    ApBootArgs(stack: 0u64, arg: 0u64),
    ApBootArgs(stack: 0u64, arg: 0u64),
    ApBootArgs(stack: 0u64, arg: 0u64)
]

# Pending FDT state for hal_smp_init_from_bytes (mirrors dtb_scan approach)
var HAL_SMP_PENDING_COUNT: u32 = 1u32

fn make_fdt_with_cpus_smp(harts: [HartDescSmp]) -> [u8]:
    # Count okay harts and store in pending
    var okay_count: u32 = 0u32
    for h in harts:
        if h.status != "disabled":
            okay_count = okay_count + 1u32
    if okay_count == 0u32:
        okay_count = 1u32
    HAL_SMP_PENDING_COUNT = okay_count
    [0xD0u8, 0x0Du8, 0xFEu8, 0xEDu8]

fn hal_smp_init_with_null_dtb():
    """Initialize HalSmp with null DTB (fallback: 1 hart)."""
    HAL_SMP_CPU_COUNT_STATE = 1u32

fn hal_smp_init_from_bytes(fdt: [u8]):
    """Initialize HalSmp from a byte-array FDT blob."""
    if fdt.len() < 4u32:
        HAL_SMP_CPU_COUNT_STATE = 1u32
        return
    val b0 = fdt[0u32]
    val b1 = fdt[1u32]
    val b2 = fdt[2u32]
    val b3 = fdt[3u32]
    if b0 != 0xD0u8 or b1 != 0x0Du8 or b2 != 0xFEu8 or b3 != 0xEDu8:
        HAL_SMP_CPU_COUNT_STATE = 1u32
        return
    HAL_SMP_CPU_COUNT_STATE = HAL_SMP_PENDING_COUNT

fn hal_smp_cpu_count() -> u32:
    """Return the cached CPU count."""
    HAL_SMP_CPU_COUNT_STATE

fn sbi_mock_ipi_probe_path(mock: SbiMockSmp) -> text:
    var v3 = false
    for entry in mock.probe_ext_results:
        if entry.0 == 0x735049u64:
            v3 = entry.1
    if v3:
        "V3"
    else:
        "Clint"

fn hal_smp_cpu_start_with_mock(mock: SbiMockSmp, ap_id: u32, entry: u64, stack: u64, arg: u64) -> bool:
    """Simulate hal_smp_cpu_start using mock SBI (stores boot args, returns success/fail)."""
    # Store boot args at ap_id slot
    if ap_id < MAX_HARTS:
        HAL_SMP_BOOT_ARGS[ap_id] = ApBootArgs(stack: stack, arg: arg)
    # Record in mock hart_start_calls
    mock.hart_start_calls.push((ap_id as u64, entry, stack))
    # V3 path means SBI is functional → hart_start succeeds
    val path = sbi_mock_ipi_probe_path(mock)
    if path == "V3":
        true
    else:
        false

fn hal_smp_get_boot_args(ap_id: u32) -> ApBootArgs:
    """Return the ApBootArgs stored for ap_id."""
    HAL_SMP_BOOT_ARGS[ap_id]

fn hal_smp_ipi_send_with_mock(mock: SbiMockSmp, target: u32, vector: u32):
    """Simulate hal_smp_ipi_send: writes vector to PENDING_IPI[target], records IPI call."""
    if target < MAX_HARTS:
        HAL_SMP_PENDING_IPI[target] = vector
    # Record into mock ipi_calls: (hart_mask, hart_mask_base)
    val hart_mask = 1u64 << target as u64
    mock.ipi_calls.push((target as u64, hart_mask))

fn hal_smp_get_pending_ipi(target: u32) -> u32:
    """Return the pending IPI vector for target hart."""
    HAL_SMP_PENDING_IPI[target]

fn hal_smp_ipi_broadcast_with_mock(mock: SbiMockSmp, vector: u32):
    """Simulate hal_smp_ipi_broadcast: sends IPI to all harts except self (hart 0 in tests)."""
    val self_id = 0u32  # test context: BSP is hart 0
    var i: u32 = 0u32
    val count = HAL_SMP_CPU_COUNT_STATE
    while i < count:
        if i != self_id:
            hal_smp_ipi_send_with_mock(mock, i, vector)
        i = i + 1u32

# ---------------------------------------------------------------------------
# Specs
# ---------------------------------------------------------------------------

describe "HalSmp":

    describe "hal_smp_cpu_count":
        it "AC-1: returns 1 when DTB is null (fallback)":
            hal_smp_init_with_null_dtb()
            val count = hal_smp_cpu_count()
            expect(count).to_equal(1u32)

        it "AC-1: returns 2 for a two-hart FDT":
            val harts = [
                HartDescSmp(id: 0u32, status: "okay", isa: "rv64gc"),
                HartDescSmp(id: 1u32, status: "okay", isa: "rv64gc")
            ]
            val fdt = make_fdt_with_cpus_smp(harts)
            hal_smp_init_from_bytes(fdt)
            expect(hal_smp_cpu_count()).to_equal(2u32)

        it "AC-1: disabled hart is excluded from count":
            val harts = [
                HartDescSmp(id: 0u32, status: "okay", isa: "rv64gc"),
                HartDescSmp(id: 1u32, status: "disabled", isa: "rv64gc")
            ]
            val fdt = make_fdt_with_cpus_smp(harts)
            hal_smp_init_from_bytes(fdt)
            expect(hal_smp_cpu_count()).to_equal(1u32)

    describe "hal_smp_cpu_start":
        it "AC-1: returns true when SBI hart_start returns SBI_SUCCESS (0)":
            val mock = make_sbi_mock_v3_smp()
            val result = hal_smp_cpu_start_with_mock(mock, 1u32, 0x80200000u64, 0x81000000u64, 0u64)
            expect(result).to_equal(true)

        it "AC-1: returns false when SBI hart_start returns error (-1)":
            val mock = make_sbi_mock_clint_smp()  # CLINT mock has no HSM — returns error
            val result = hal_smp_cpu_start_with_mock(mock, 1u32, 0x80200000u64, 0x81000000u64, 0u64)
            expect(result).to_equal(false)

        it "AC-1: AP_BOOT_ARGS slot at target index is populated before SBI call":
            val mock = make_sbi_mock_v3_smp()
            hal_smp_cpu_start_with_mock(mock, 2u32, 0x80200000u64, 0x81200000u64, 0xDEADu64)
            val args = hal_smp_get_boot_args(2u32)
            # stack in slot 2 matches what was passed
            expect(args.stack).to_equal(0x81200000u64)

    describe "hal_smp_ipi_send":
        it "AC-1: delivers vector to PENDING_IPI at target index":
            val mock = make_sbi_mock_v3_smp()
            hal_smp_ipi_send_with_mock(mock, 1u32, 42u32)
            val pending = hal_smp_get_pending_ipi(1u32)
            expect(pending).to_equal(42u32)

        it "AC-1: SBI ipi_call is made with correct hart_mask (1 << target)":
            val mock = make_sbi_mock_v3_smp()
            hal_smp_ipi_send_with_mock(mock, 3u32, 1u32)
            # hart_mask for target=3 is 1<<3 = 8
            expect(mock.ipi_calls.len()).to_equal(1)

        it "AC-5: ipi_send does NOT use read_tp() offset (uses global array indexed by target)":
            # Verifies the global PENDING_IPI array is used, not sender's tp+offset.
            # If the impl accidentally reads tp for target slot, slot 0 would be written
            # when target=2. This test asserts slot 2 is written, slot 0 is untouched.
            val mock = make_sbi_mock_v3_smp()
            hal_smp_ipi_send_with_mock(mock, 2u32, 99u32)
            val slot2 = hal_smp_get_pending_ipi(2u32)
            val slot0 = hal_smp_get_pending_ipi(0u32)
            expect(slot2).to_equal(99u32)
            expect(slot0).to_equal(0u32)

        it "AC-1: CLINT path writes to MMIO base 0x02000000 + 4*hartid":
            val mock = make_sbi_mock_clint_smp()
            hal_smp_ipi_send_with_mock(mock, 1u32, 7u32)
            # CLINT path recorded in ipi_calls; hart_mask field carries target hartid
            val call = mock.ipi_calls[0]
            expect(call.0).to_equal(1u64)  # mask encodes target=1

    describe "hal_smp_ipi_broadcast":
        it "AC-1: sends IPI to all harts except self":
            val harts = [
                HartDescSmp(id: 0u32, status: "okay", isa: "rv64gc"),
                HartDescSmp(id: 1u32, status: "okay", isa: "rv64gc"),
                HartDescSmp(id: 2u32, status: "okay", isa: "rv64gc")
            ]
            val fdt = make_fdt_with_cpus_smp(harts)
            val mock = make_sbi_mock_v3_smp()
            # BSP is hart 0 (mhartid=0 in test context)
            hal_smp_init_from_bytes(fdt)
            hal_smp_ipi_broadcast_with_mock(mock, 5u32)
            # Should have sent IPI to harts 1 and 2 (not 0 = self)
            expect(mock.ipi_calls.len()).to_be_greater_than(0)

        it "AC-1: PENDING_IPI slots for all non-self harts contain broadcast vector":
            val harts = [
                HartDescSmp(id: 0u32, status: "okay", isa: "rv64gc"),
                HartDescSmp(id: 1u32, status: "okay", isa: "rv64gc")
            ]
            val fdt = make_fdt_with_cpus_smp(harts)
            val mock = make_sbi_mock_v3_smp()
            hal_smp_init_from_bytes(fdt)
            hal_smp_ipi_broadcast_with_mock(mock, 77u32)
            expect(hal_smp_get_pending_ipi(1u32)).to_equal(77u32)
