"""x86_32 paging and timer HAL parity tests.

These tests cover hosted-safe HAL contracts without invoking privileged CR3,
page-table, or PIT port I/O operations.
"""

use std.spec
use os.kernel.arch.x86_32.mod.{create_x86_32_hal}
use os.kernel.arch_adapt.x86_32.mod.{create_x86_32_hal_adapter}
use os.kernel.arch_adapt.x86_32.timer.{timer_current_ticks, timer_elapsed_us, timer_frequency, timer_ticks_per_second}
use os.kernel.arch.x86_32.timer.{pit_tick_handler}

describe "x86_32 paging and timer HAL parity":
    """Verifies hosted-safe x86_32 HAL geometry and timer state contracts."""

    it "exposes x86_32 paging geometry through the aggregate HAL":
        val hal = create_x86_32_hal()

        expect(hal.paging.page_size()).to_equal(4096)
        expect(hal.paging.address_levels()).to_equal(2)

    it "exposes x86_32 paging geometry through the adapter aggregate":
        val adapter = create_x86_32_hal_adapter()

        expect(adapter.paging.page_size()).to_equal(4096)
        expect(adapter.paging.address_levels()).to_equal(2)

    it "exposes hosted-safe timer defaults through the aggregate HAL":
        val hal = create_x86_32_hal()

        expect(hal.timer.frequency()).to_equal(0)
        expect(hal.timer.ticks_per_second()).to_equal(0)
        expect(hal.timer.elapsed_us()).to_equal(0)

    it "routes timer tick state through HAL and adapter wrappers":
        val before = timer_current_ticks()
        pit_tick_handler()
        pit_tick_handler()

        val hal = create_x86_32_hal()
        expect(hal.timer.current_ticks()).to_equal(before + 2)
        expect(timer_current_ticks()).to_equal(before + 2)
        expect(timer_frequency()).to_equal(0)
        expect(timer_ticks_per_second()).to_equal(0)
        expect(timer_elapsed_us()).to_equal(0)
