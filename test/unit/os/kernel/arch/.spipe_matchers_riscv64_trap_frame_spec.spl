use std.spec
use os.kernel.arch.riscv64.trap_frame.{
    RV64_TRAP_FRAME_SLOT_BYTES,
    RV64_TRAP_FRAME_FIELD_COUNT,
    RV64_TRAP_FRAME_SIZE_BYTES,
    RV64_TRAP_RA_OFFSET,
    RV64_TRAP_SP_OFFSET,
    RV64_TRAP_A0_OFFSET,
    RV64_TRAP_A7_OFFSET,
    RV64_TRAP_SEPC_OFFSET,
    RV64_TRAP_SSTATUS_OFFSET,
    RV64_TRAP_SCAUSE_OFFSET,
    rv64_trap_frame_field_offsets
}

describe "rv64 trap frame layout":
    it "uses 8-byte slots for each saved field":
        expect RV64_TRAP_FRAME_SLOT_BYTES == 8

    it "reports the full saved frame size":
        expect RV64_TRAP_FRAME_FIELD_COUNT == 34
        expect RV64_TRAP_FRAME_SIZE_BYTES == 272

    it "keeps key register offsets stable":
        expect RV64_TRAP_RA_OFFSET == 0
        expect RV64_TRAP_SP_OFFSET == 8
        expect RV64_TRAP_A0_OFFSET == 72
        expect RV64_TRAP_A7_OFFSET == 128
        expect RV64_TRAP_SEPC_OFFSET == 248
        expect RV64_TRAP_SSTATUS_OFFSET == 256
        expect RV64_TRAP_SCAUSE_OFFSET == 264

    it "returns a monotonic ordered field list":
        val offsets = rv64_trap_frame_field_offsets()
        expect offsets.len() == 34

        var i = 1
        while i < offsets.len():
            expect offsets[i] == offsets[i - 1] + RV64_TRAP_FRAME_SLOT_BYTES
            i = i + 1