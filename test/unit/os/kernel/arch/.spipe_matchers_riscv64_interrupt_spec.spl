use std.spec
use os.kernel.arch.riscv64.interrupt.{Rv64Interrupt, rv64_install_trap_runtime, rv64_runtime_installed, rv64_read_trap_log, rv64_dispatch_installed_trap, rv64_dispatch_trap_frame_ptr}
use os.kernel.arch.riscv64.trap_runtime.{Rv64TrapRuntime}
use os.kernel.arch.riscv64.trap_model.{create_rv64_user_context, RV64_CAUSE_ECALL_FROM_U}
use os.kernel.scheduler.scheduler.{Scheduler}
use os.kernel.ipc.ipc.{IpcManager}
use os.kernel.log.klog.{KernelLog}

describe "rv64 interrupt runtime bridge":
    it "reports missing runtime until installed":
        expect rv64_runtime_installed() == false

    it "dispatches a user ecall through installed runtime objects":
        rv64_install_trap_runtime(Scheduler.new(), IpcManager.new(), KernelLog.new(16))
        expect rv64_runtime_installed() == true

        var ctx = create_rv64_user_context(0x400000, 0x410000, 0)
        ctx.a7 = 4      # GetPid
        ctx.scause = RV64_CAUSE_ECALL_FROM_U

        val result = rv64_dispatch_installed_trap(ctx)
        expect result.is_err() == false

        val updated = result.unwrap()
        expect updated.a0 == 0
        expect updated.sepc == 0x400004

    it "rejects unsupported supervisor ecalls":
        rv64_install_trap_runtime(Scheduler.new(), IpcManager.new(), KernelLog.new(16))

        var ctx = create_rv64_user_context(0x400000, 0x410000, 0)
        ctx.a7 = 4
        ctx.scause = 9

        val result = rv64_dispatch_installed_trap(ctx)
        expect result.is_err() == true
        expect (result.err().unwrap()).contains("unsupported RV64 supervisor ecall")

    it "allows the interrupt HAL to own runtime installation":
        Rv64Interrupt.install_runtime(Scheduler.new(), IpcManager.new(), KernelLog.new(8))
        expect Rv64Interrupt.runtime_installed() == true

    it "accepts a precomposed trap runtime bundle":
        val runtime = Rv64TrapRuntime.new(Scheduler.new(), IpcManager.new(), KernelLog.new(8))
        Rv64Interrupt.install_runtime_bundle(runtime)
        expect Rv64Interrupt.runtime_installed() == true

    it "accepts a bootstrap trap runtime install":
        Rv64Interrupt.install_bootstrap_runtime(8)
        expect Rv64Interrupt.runtime_installed() == true

    it "records trap failures in the installed kernel log":
        rv64_install_trap_runtime(Scheduler.new(), IpcManager.new(), KernelLog.new(8))

        var ctx = create_rv64_user_context(0x400000, 0x410000, 0)
        ctx.a7 = 4
        ctx.scause = 9

        val result = rv64_dispatch_installed_trap(ctx)
        expect result.is_err() == true

        val entries = rv64_read_trap_log(0, 0, 4)
        expect entries.len() > 0
        expect (entries[entries.len() - 1].message).contains("unsupported RV64 supervisor ecall")

    it "updates a trap frame in place through the pointer bridge":
        rv64_install_trap_runtime(Scheduler.new(), IpcManager.new(), KernelLog.new(8))

        var ctx = create_rv64_user_context(0x400000, 0x410000, 0)
        ctx.a7 = 4
        ctx.scause = RV64_CAUSE_ECALL_FROM_U

        val rc = rv64_dispatch_trap_frame_ptr(&ctx as u64)
        expect rc == 0
        expect ctx.a0 == 0
        expect ctx.sepc == 0x400004

    it "rejects a null trap frame pointer":
        rv64_install_trap_runtime(Scheduler.new(), IpcManager.new(), KernelLog.new(8))

        val rc = rv64_dispatch_trap_frame_ptr(0)
        expect rc == -1

        val entries = rv64_read_trap_log(0, 0, 4)
        expect entries.len() > 0
        expect (entries[entries.len() - 1].message).contains("trap frame pointer is null")