# @cover src/os/kernel/arch/riscv64/platform/board_memory_map.spl 0%
# @cover src/os/kernel/arch/riscv64/platform/kria_memory_map.spl 0%
# @cover src/os/kernel/arch/riscv64/platform/litex_memory_map.spl 0%
"""
# RiscvBoardMemoryMap Trait Specification

**Feature IDs:** opensource-riscv-rtl-simpleos
**Category:** Infrastructure
**Difficulty:** 2/5
**Status:** Draft
**Requirements:** REQ-5
**Artifacts:** N/A

## Overview

Verifies AC-5: RiscvBoardMemoryMap trait and its two concrete implementations
(KriaFpgaMemoryMap for K26, LitexFpgaMemoryMap for DE10-Nano) return correct
address constants. These constants gate the minimal-host boot chain.

Covers:
- AC-5 (SimpleOS boots with correct memory map: UART, RAM, heap, CLINT, PLIC)
"""

use std.spipe.*
use os.kernel.arch.riscv64.platform.kria_memory_map.{
    KriaFpgaMemoryMap,
    kria_memory_map_new
}
use os.kernel.arch.riscv64.platform.litex_memory_map.{
    LitexFpgaMemoryMap,
    litex_memory_map_new
}


# ============================================================================
# Helpers
# ============================================================================

fn kria_map() -> KriaFpgaMemoryMap:
    return kria_memory_map_new()

fn litex_map() -> LitexFpgaMemoryMap:
    return litex_memory_map_new()


# ============================================================================
# AC-5: KriaFpgaMemoryMap constants
# ============================================================================

describe "KriaFpgaMemoryMap":
    it "AC-5: uart_base returns 0x10000000":
        val m = kria_map()
        expect(m.uart_base()).to_equal(268435456)

    it "AC-5: ram_base returns 0x80000000":
        val m = kria_map()
        expect(m.ram_base()).to_equal(2147483648)

    it "AC-5: ram_size returns 128MB (134217728 bytes)":
        val m = kria_map()
        expect(m.ram_size()).to_equal(134217728)

    it "AC-5: clint_base returns 0x02000000":
        val m = kria_map()
        expect(m.clint_base()).to_equal(33554432)

    it "AC-5: plic_base returns 0x0c000000":
        val m = kria_map()
        expect(m.plic_base()).to_equal(201326592)

    it "AC-5: heap_start returns 0x87000000":
        val m = kria_map()
        expect(m.heap_start()).to_equal(2264924160)

    it "AC-5: heap_size is 16MB (16777216 bytes)":
        val m = kria_map()
        expect(m.heap_size()).to_equal(16777216)


# ============================================================================
# AC-5: LitexFpgaMemoryMap constants (DE10-Nano LiteX layout)
# ============================================================================

describe "LitexFpgaMemoryMap":
    it "AC-5: uart_base returns 0xf0001000":
        val m = litex_map()
        expect(m.uart_base()).to_equal(4026535936)

    it "AC-5: ram_base returns 0x40000000":
        val m = litex_map()
        expect(m.ram_base()).to_equal(1073741824)

    it "AC-5: ram_size returns 256MB (268435456 bytes)":
        val m = litex_map()
        expect(m.ram_size()).to_equal(268435456)

    it "AC-5: clint_base returns 0xf0010000":
        val m = litex_map()
        expect(m.clint_base()).to_equal(4026597376)

    it "AC-5: plic_base returns 0xf0c00000":
        val m = litex_map()
        expect(m.plic_base()).to_equal(4039114752)

    it "AC-5: heap_start returns 0x4f000000":
        val m = litex_map()
        expect(m.heap_start()).to_equal(1325400064)

    it "AC-5: LiteX and Kria uart_base are different":
        val kria = kria_map()
        val litex = litex_map()
        val kria_uart = kria.uart_base()
        val litex_uart = litex.uart_base()
        expect(kria_uart).to_equal(268435456)
        expect(litex_uart).to_equal(4026535936)
