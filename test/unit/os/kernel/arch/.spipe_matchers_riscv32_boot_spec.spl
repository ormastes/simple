use std.spec
use os.kernel.arch.riscv32.boot_info.{Rv32Boot}
use os.kernel.arch.arch_context.{Architecture}

describe "rv32 boot bootstrap trap runtime":
    it "records boot arguments":
        val boot = Rv32Boot(direct_boot: true)
        boot.save_boot_params(7, 0x88001000)
        expect boot.hart_id() == 7
        expect boot.dtb_addr() == 0x88001000

    it "keeps the fixed kernel load address":
        val boot = Rv32Boot(direct_boot: true)
        expect boot.kernel_load_addr() == 0x80000000

    it "builds an RV32 boot output with direct-boot defaults":
        val boot = Rv32Boot(direct_boot: true)
        boot.save_boot_params(0, 0)
        val boot_output = boot.build_boot_output()
        expect boot_output.arch == Architecture.Riscv32
        expect boot_output.serial_base == 0x10000000
        expect boot_output.kernel_phys_base.addr == 0x80000000
        expect boot_output.memory_map.len() == 2