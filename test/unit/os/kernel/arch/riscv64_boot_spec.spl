use std.spec
use os.kernel.arch.riscv64.boot.{Rv64Boot}
use os.kernel.arch.riscv64.interrupt.{Rv64Interrupt}

describe "rv64 boot bootstrap trap runtime":
    it "records boot arguments":
        Rv64Boot.save_boot_args(3, 0x88000000)
        expect(Rv64Boot.hart_id()).to_equal(3)
        expect(Rv64Boot.dtb_address()).to_equal(0x88000000)

    it "installs the bootstrap trap runtime during boot argument capture":
        Rv64Boot.save_boot_args(0, 0x87000000)
        expect(Rv64Interrupt.runtime_installed()).to_equal(true)

    it "keeps the fixed kernel load address":
        expect(Rv64Boot.kernel_load_address()).to_equal(0x80200000)
