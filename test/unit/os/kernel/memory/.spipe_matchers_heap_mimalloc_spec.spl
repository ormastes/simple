# @cover src/os/kernel/memory/heap.spl
#
# Focused contract tests for the SimpleOS kernel heap/mimalloc boundary.
# These tests avoid heap_init because it depends on platform paging/PMM externs;
# they lock the safe pre-init and query behavior that must remain true before
# architecture-specific boot code wires real pages.

use os.kernel.memory.heap.{
    heap_alloc,
    heap_free,
    heap_free_size,
    heap_total_allocated,
    heap_total_free,
    heap_alloc_count,
    heap_integrity_check,
}
use os.kernel.types.memory_types.{VirtAddr}

describe "SimpleOS mimalloc kernel heap boundary":
    it "starts with zero tracked allocation state":
        expect heap_total_allocated() == 0
        expect heap_total_free() == 0
        expect heap_alloc_count() == 0

    it "passes integrity check before boot heap initialization":
        expect heap_integrity_check() == true

    it "rejects zero-byte allocation":
        val ptr = heap_alloc(0)
        expect ptr.? == false

    it "returns nil before the mimalloc OS page provider has a bump region":
        val ptr = heap_alloc(64)
        expect ptr.? == false
        expect heap_alloc_count() == 0

    it "ignores null frees":
        heap_free(VirtAddr(addr: 0))
        expect heap_alloc_count() == 0
        expect heap_integrity_check() == true

    it "ignores null sized frees":
        heap_free_size(VirtAddr(addr: 0), 64)
        expect heap_alloc_count() == 0
        expect heap_integrity_check() == true