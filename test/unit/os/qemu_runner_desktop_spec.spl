        "SIMPLSTC\n" +
        "LLVMSMF\n" +
        "CLANGSMF\n" +
        "RUSTSMF\n" +
        "WINHLSMF\n" +
        "SimpleOS LLVM standalone app v1\n" +
        "clang version 20.0.0\n" +
        "SimpleOS Rust standalone app v1\n" +
        "mode=native-filesystem-app\n" +
