"""
# NVMe Storage Model Specification

**Feature IDs:** #OS-STORAGE-NVME-CAPS
**Category:** Runtime
**Difficulty:** 3/5
**Status:** Draft contract

BDD coverage for the multi-namespace NVMe queue policy constants and data-only
contracts used by capability-backed storage.
"""

use std.spec.{describe, it, expect}
use os.drivers.nvme.nvme_storage_model.{NvmeQueueRole, NvmeNamespaceMode, NvmeFilesystemConsumer, NvmeNamespaceIdentity, NvmePartitionIdentity, NvmeQueueAssignment, nvme_queue_role_for_id, nvme_queue_is_system_reserved, nvme_first_data_queue_id, nvme_transfer_evidence, nvme_transfer_readiness_reason, nvme_transfer_ready, nvme_filesystem_lease, nvme_filesystem_lease_reason, nvme_filesystem_lease_ready, nvme_filesystem_consumer_name, nvme_namespace_mode_name, nvme_filesystem_lease_sector_size, nvme_filesystem_lease_sector_count, nvme_filesystem_lease_absolute_lba}
use os.kernel.types.capability_types.{CAP_RIGHT_READ, CAP_RIGHT_WRITE, CAP_RIGHT_QUEUE_SUBMIT, SIMPLEOS_NVME_ADMIN_QUEUE_ID, SIMPLEOS_NVME_SYSTEM_QUEUE_ID, SIMPLEOS_NVME_FIRST_DATA_QUEUE_ID}

describe "NVMe storage model":
    describe "queue role policy":
        it "reserves queue 0 for admin commands":
            val role = nvme_queue_role_for_id(SIMPLEOS_NVME_ADMIN_QUEUE_ID)
            val is_admin = match role:
                NvmeQueueRole.Admin: true
                _: false
            expect(is_admin).to_equal(true)

        it "reserves queue 1 for system I/O":
            val role = nvme_queue_role_for_id(SIMPLEOS_NVME_SYSTEM_QUEUE_ID)
            val is_system = match role:
                NvmeQueueRole.System: true
                _: false
            expect(is_system).to_equal(true)

        it "uses queue 2 and above for data traffic":
            val role = nvme_queue_role_for_id(SIMPLEOS_NVME_FIRST_DATA_QUEUE_ID)
            val is_data = match role:
                NvmeQueueRole.Data: true
                _: false
            expect(is_data).to_equal(true)

        it "marks admin and system queues as reserved":
            expect(nvme_queue_is_system_reserved(SIMPLEOS_NVME_ADMIN_QUEUE_ID)).to_equal(true)
            expect(nvme_queue_is_system_reserved(SIMPLEOS_NVME_SYSTEM_QUEUE_ID)).to_equal(true)
            expect(nvme_queue_is_system_reserved(SIMPLEOS_NVME_FIRST_DATA_QUEUE_ID)).to_equal(false)

        it "publishes the first data queue id":
            expect(nvme_first_data_queue_id()).to_equal(2)

    describe "namespace and partition identities":
        it "stores namespace identity separately from partition identity":
            val ns = NvmeNamespaceIdentity(
                controller_id: 0,
                nsid: 2,
                lba_size: 4096,
                lba_count: 1024,
                eui64: 0,
                nguid_lo: 11,
                nguid_hi: 12,
                uuid_lo: 21,
                uuid_hi: 22
            )
            val part = NvmePartitionIdentity(
                controller_id: 0,
                nsid: 2,
                part_index: 1,
                base_lba: 128,
                lba_count: 256,
                type_guid_lo: 31,
                type_guid_hi: 32,
                unique_guid_lo: 41,
                unique_guid_hi: 42
            )
            expect(ns.nsid).to_equal(part.nsid)
            expect(part.base_lba).to_equal(128)

        it "stores queue assignment owner, depth, and rights":
            val assignment = NvmeQueueAssignment(
                queue_id: SIMPLEOS_NVME_FIRST_DATA_QUEUE_ID,
                role: NvmeQueueRole.Data,
                controller_id: 0,
                nsid: 1,
                owner_task: 99,
                max_depth: 64,
                rights: CAP_RIGHT_READ + CAP_RIGHT_WRITE + CAP_RIGHT_QUEUE_SUBMIT
            )
            expect(assignment.queue_id).to_equal(2)
            expect(assignment.owner_task).to_equal(99)

    describe "filesystem namespace leases":
        it "names all filesystem consumers and namespace modes":
            expect(nvme_filesystem_consumer_name(NvmeFilesystemConsumer.Fat32)).to_equal("fat32")
            expect(nvme_filesystem_consumer_name(NvmeFilesystemConsumer.Nvfs)).to_equal("nvfs")
            expect(nvme_filesystem_consumer_name(NvmeFilesystemConsumer.Dbfs)).to_equal("dbfs")
            expect(nvme_namespace_mode_name(NvmeNamespaceMode.System)).to_equal("system")
            expect(nvme_namespace_mode_name(NvmeNamespaceMode.UserAssigned)).to_equal("user-assigned")

        it "allows FAT32 NVFS and DBFS to share a system namespace lease through the system queue":
            val ns = NvmeNamespaceIdentity(
                controller_id: 0,
                nsid: 1,
                lba_size: 4096,
                lba_count: 4096,
                eui64: 0,
                nguid_lo: 0,
                nguid_hi: 0,
                uuid_lo: 0,
                uuid_hi: 0
            )
            val queue = NvmeQueueAssignment(
                queue_id: SIMPLEOS_NVME_SYSTEM_QUEUE_ID,
                role: NvmeQueueRole.System,
                controller_id: 0,
                nsid: 1,
                owner_task: 0,
                max_depth: 128,
                rights: CAP_RIGHT_READ + CAP_RIGHT_WRITE + CAP_RIGHT_QUEUE_SUBMIT
            )
            val lease = nvme_filesystem_lease(ns, 0u64, 2048u64, NvmeNamespaceMode.System, queue, "simple-driver", "none", true, true)
            expect(nvme_filesystem_lease_ready(lease, NvmeFilesystemConsumer.Fat32)).to_equal(true)
            expect(nvme_filesystem_lease_ready(lease, NvmeFilesystemConsumer.Nvfs)).to_equal(true)
            expect(nvme_filesystem_lease_ready(lease, NvmeFilesystemConsumer.Dbfs)).to_equal(true)

        it "requires user-assigned namespaces to use data queues and issued user-space grants":
            val ns = NvmeNamespaceIdentity(
                controller_id: 0,
                nsid: 2,
                lba_size: 4096,
                lba_count: 8192,
                eui64: 0,
                nguid_lo: 0,
                nguid_hi: 0,
                uuid_lo: 0,
                uuid_hi: 0
            )
            val system_queue = NvmeQueueAssignment(
                queue_id: SIMPLEOS_NVME_SYSTEM_QUEUE_ID,
                role: NvmeQueueRole.System,
                controller_id: 0,
                nsid: 2,
                owner_task: 42,
                max_depth: 64,
                rights: CAP_RIGHT_READ + CAP_RIGHT_WRITE + CAP_RIGHT_QUEUE_SUBMIT
            )
            val data_queue = NvmeQueueAssignment(
                queue_id: SIMPLEOS_NVME_FIRST_DATA_QUEUE_ID,
                role: NvmeQueueRole.Data,
                controller_id: 0,
                nsid: 2,
                owner_task: 42,
                max_depth: 64,
                rights: CAP_RIGHT_READ + CAP_RIGHT_WRITE + CAP_RIGHT_QUEUE_SUBMIT
            )
            val bad_queue = nvme_filesystem_lease(ns, 128u64, 1024u64, NvmeNamespaceMode.UserAssigned, system_queue, "simple-driver", "resource-grant-set:tok=99", true, true)
            val missing_token = nvme_filesystem_lease(ns, 128u64, 1024u64, NvmeNamespaceMode.UserAssigned, data_queue, "simple-driver", "resource-grant-set", true, true)
            val ready = nvme_filesystem_lease(ns, 128u64, 1024u64, NvmeNamespaceMode.UserAssigned, data_queue, "simple-driver", "resource-grant-set:tok=100", true, true)
            expect(nvme_filesystem_lease_reason(bad_queue, NvmeFilesystemConsumer.Nvfs)).to_equal("nvme-fs-user-namespace-not-data-queue")
            expect(nvme_filesystem_lease_reason(missing_token, NvmeFilesystemConsumer.Dbfs)).to_contain("missing-issued-device-grant-token")
            expect(nvme_filesystem_lease_ready(ready, NvmeFilesystemConsumer.Fat32)).to_equal(true)

        it "rejects filesystem leases that do not expose the shared block interface":
            val ns = NvmeNamespaceIdentity(
                controller_id: 0,
                nsid: 3,
                lba_size: 4096,
                lba_count: 4096,
                eui64: 0,
                nguid_lo: 0,
                nguid_hi: 0,
                uuid_lo: 0,
                uuid_hi: 0
            )
            val queue = NvmeQueueAssignment(
                queue_id: SIMPLEOS_NVME_SYSTEM_QUEUE_ID,
                role: NvmeQueueRole.System,
                controller_id: 0,
                nsid: 3,
                owner_task: 0,
                max_depth: 128,
                rights: CAP_RIGHT_READ + CAP_RIGHT_WRITE + CAP_RIGHT_QUEUE_SUBMIT
            )
            val lease = nvme_filesystem_lease(ns, 0u64, 512u64, NvmeNamespaceMode.System, queue, "simple-driver", "none", false, true)
            expect(nvme_filesystem_lease_reason(lease, NvmeFilesystemConsumer.Fat32)).to_equal("nvme-fs-lease-missing-shared-block-interface")

        it "translates filesystem-relative LBAs inside the namespace lease only":
            val ns = NvmeNamespaceIdentity(
                controller_id: 0,
                nsid: 4,
                lba_size: 4096,
                lba_count: 4096,
                eui64: 0,
                nguid_lo: 0,
                nguid_hi: 0,
                uuid_lo: 0,
                uuid_hi: 0
            )
            val queue = NvmeQueueAssignment(
                queue_id: SIMPLEOS_NVME_SYSTEM_QUEUE_ID,
                role: NvmeQueueRole.System,
                controller_id: 0,
                nsid: 4,
                owner_task: 0,
                max_depth: 128,
                rights: CAP_RIGHT_READ + CAP_RIGHT_WRITE + CAP_RIGHT_QUEUE_SUBMIT
            )
            val lease = nvme_filesystem_lease(ns, 128u64, 256u64, NvmeNamespaceMode.System, queue, "simple-driver", "none", true, true)
            expect(nvme_filesystem_lease_sector_size(lease)).to_equal(4096)
            expect(nvme_filesystem_lease_sector_count(lease)).to_equal(256u64)
            expect(nvme_filesystem_lease_absolute_lba(lease, 0u64).unwrap()).to_equal(128u64)
            expect(nvme_filesystem_lease_absolute_lba(lease, 255u64).unwrap()).to_equal(383u64)
            expect(nvme_filesystem_lease_absolute_lba(lease, 256u64).unwrap_err()).to_equal("nvme-fs-lease-lba-out-of-range")

    describe "pure Simple transfer evidence":
        it "rejects the C boot bridge as NVMe transfer completion":
            val bridge = nvme_transfer_evidence(
                "c-boot-bridge",
                true,
                true,
                true,
                true,
                true,
                true,
                true,
                true,
                true,
                "user-space-driver",
                "resource-grant-set:tok=31",
                "non-secure-resource-namespace",
                true,
                true
            )
            expect(nvme_transfer_ready(bridge)).to_equal(false)
            expect(nvme_transfer_readiness_reason(bridge)).to_equal("nvme-transfer-provider-not-simple:c-boot-bridge")

        it "requires queues doorbells completion and reversible sector I/O":
            val missing_completion = nvme_transfer_evidence(
                "simple-driver",
                true,
                true,
                true,
                true,
                false,
                true,
                true,
                true,
                true,
                "user-space-driver",
                "resource-grant-set:tok=32",
                "non-secure-resource-namespace",
                true,
                true
            )
            val missing_restore = nvme_transfer_evidence(
                "simple-driver",
                true,
                true,
                true,
                true,
                true,
                true,
                true,
                false,
                true,
                "user-space-driver",
                "resource-grant-set:tok=33",
                "non-secure-resource-namespace",
                true,
                true
            )
            val ready = nvme_transfer_evidence(
                "simple-driver",
                true,
                true,
                true,
                true,
                true,
                true,
                true,
                true,
                true,
                "user-space-driver",
                "resource-grant-set:tok=34",
                "non-secure-resource-namespace",
                true,
                true
            )

            expect(nvme_transfer_readiness_reason(missing_completion)).to_equal("missing-nvme-completion")
            expect(nvme_transfer_readiness_reason(missing_restore)).to_equal("missing-nvme-sector-restore")
            expect(nvme_transfer_ready(ready)).to_equal(true)

        it "requires issued grants non-secure namespace and common driver logic":
            val no_token = nvme_transfer_evidence(
                "simple-driver",
                true,
                true,
                true,
                true,
                true,
                true,
                true,
                true,
                true,
                "user-space-driver",
                "resource-grant-set",
                "non-secure-resource-namespace",
                true,
                true
            )
            val bad_namespace = nvme_transfer_evidence(
                "simple-driver",
                true,
                true,
                true,
                true,
                true,
                true,
                true,
                true,
                true,
                "user-space-driver",
                "resource-grant-set:tok=35",
                "secure-kernel-namespace",
                true,
                true
            )
            val missing_common = nvme_transfer_evidence(
                "simple-driver",
                true,
                true,
                true,
                true,
                true,
                true,
                true,
                true,
                true,
                "user-space-driver",
                "resource-grant-set:tok=36",
                "non-secure-resource-namespace",
                false,
                true
            )

            expect(nvme_transfer_readiness_reason(no_token)).to_contain("missing-issued-device-grant-token:resource-grant-set")
            expect(nvme_transfer_readiness_reason(bad_namespace)).to_contain("missing-non-secure-resource-namespace:secure-kernel-namespace")
            expect(nvme_transfer_readiness_reason(missing_common)).to_contain("missing-common-driver-logic")
