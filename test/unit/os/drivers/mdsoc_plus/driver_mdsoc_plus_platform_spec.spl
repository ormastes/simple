use std.spec.{describe, it, expect}

# --- GPU lane helpers (inlined) ---

fn gpu_lane_vendor_list() -> text:
    "nvidia-cuda,amd-rocm-radv,intel-anv-level-zero,qualcomm-arm-freedreno-turnip-panfrost,riscv"

fn gpu_lane_supports_vendor(vendor: text) -> bool:
    vendor == "nvidia-cuda" or
    vendor == "amd-rocm-radv" or
    vendor == "intel-anv-level-zero" or
    vendor == "qualcomm-arm-freedreno-turnip-panfrost" or
    vendor == "riscv"

fn gpu_lane_compute_allowed(vendor: text) -> bool:
    vendor == "nvidia-cuda" or vendor == "amd-rocm-radv" or vendor == "intel-anv-level-zero"

fn gpu_lane_software_vulkan_vendor(vendor: text) -> bool:
    vendor == "riscv"

fn gpu_lane_probe_label(vendor: text, runtime: bool, device: bool, queue: bool, memory: bool) -> text:
    if runtime and device and queue and memory:
        return "gpu-lane:ready:" + vendor
    if not runtime:
        return "gpu-lane:missing-runtime:" + vendor
    if not device:
        return "gpu-lane:missing-device:" + vendor
    if not queue:
        return "gpu-lane:missing-queue:" + vendor
    "gpu-lane:missing-memory:" + vendor

fn gpu_lane_framebuffer_compute_forbidden() -> bool:
    true

# --- Audio lane helpers (inlined) ---

fn audio_lane_controller() -> text:
    "intel-hda"

fn audio_lane_primary_codec() -> text:
    "realtek-hda"

fn audio_lane_secondary_codec() -> text:
    "cirrus-logic-hda"

fn audio_lane_codec_supported(codec: text) -> bool:
    codec == "realtek-hda" or codec == "cirrus-logic-hda"

fn audio_lane_probe_label(controller: bool, codec: bool, dma: bool, period: bool, mixer: text) -> text:
    if controller and codec and dma and period and mixer != "none":
        return "audio-lane:ready"
    if not controller:
        return "audio-lane:missing-controller"
    if not codec:
        return "audio-lane:missing-codec"
    if not dma:
        return "audio-lane:missing-dma"
    if not period:
        return "audio-lane:missing-period"
    "audio-lane:missing-mixer"

fn audio_lane_dma_without_period_invalid(dma: bool, period: bool) -> bool:
    dma and not period

# --- Input lane helpers (inlined) ---

fn input_lane_ps2_bus() -> text:
    "ps2"

fn input_lane_usb_hid_bus() -> text:
    "usb-hid"

fn input_lane_ps2_hotplug_supported() -> bool:
    false

fn input_lane_usb_hid_hotplug_supported() -> bool:
    true

fn input_lane_probe_label(bus: text, keyboard: bool, mouse: bool, events: bool) -> text:
    if keyboard and mouse and events:
        return "input-lane:ready:" + bus
    if not keyboard:
        return "input-lane:missing-keyboard:" + bus
    if not mouse:
        return "input-lane:missing-mouse:" + bus
    "input-lane:missing-events:" + bus

fn input_lane_usb_partial_without_hotplug(bus: text, hotplug: bool, hidraw: bool) -> bool:
    bus == "usb-hid" and (not hotplug or not hidraw)

# --- Exokernel lane helpers (inlined) ---

fn exokernel_lane_resources() -> text:
    "bar,irq,dma,iommu,broker"

fn exokernel_lane_raw_app_requires_iommu(raw_app: bool, iommu: bool) -> bool:
    raw_app and not iommu

fn exokernel_lane_probe_label(bar: bool, irq: bool, dma: bool, iommu: bool, broker: bool, raw_app: bool) -> text:
    if raw_app and not iommu:
        return "exokernel-lane:unsafe-raw-without-iommu"
    if not bar:
        return "exokernel-lane:missing-bar"
    if not irq:
        return "exokernel-lane:missing-irq"
    if not dma:
        return "exokernel-lane:missing-dma"
    if not iommu and not broker:
        return "exokernel-lane:missing-iommu-or-broker"
    "exokernel-lane:ready"

fn exokernel_lane_brokered_iommu_safe() -> bool:
    true

# --- Tests ---

describe "SimpleOS Driver MDSOC+ Platform":

    describe "GPU lane":
        it "vendor_list contains all five vendors":
            val lst = gpu_lane_vendor_list()
            expect(lst.contains("nvidia-cuda")).to_equal(true)
            expect(lst.contains("riscv")).to_equal(true)

        it "supports all five vendors":
            expect(gpu_lane_supports_vendor("nvidia-cuda")).to_equal(true)
            expect(gpu_lane_supports_vendor("amd-rocm-radv")).to_equal(true)
            expect(gpu_lane_supports_vendor("intel-anv-level-zero")).to_equal(true)
            expect(gpu_lane_supports_vendor("qualcomm-arm-freedreno-turnip-panfrost")).to_equal(true)
            expect(gpu_lane_supports_vendor("riscv")).to_equal(true)

        it "rejects unknown vendor":
            expect(gpu_lane_supports_vendor("unknown-gpu")).to_equal(false)

        it "compute allowed only for cuda amd intel":
            expect(gpu_lane_compute_allowed("nvidia-cuda")).to_equal(true)
            expect(gpu_lane_compute_allowed("amd-rocm-radv")).to_equal(true)
            expect(gpu_lane_compute_allowed("intel-anv-level-zero")).to_equal(true)
            expect(gpu_lane_compute_allowed("riscv")).to_equal(false)

        it "riscv is software vulkan vendor":
            expect(gpu_lane_software_vulkan_vendor("riscv")).to_equal(true)
            expect(gpu_lane_software_vulkan_vendor("nvidia-cuda")).to_equal(false)

        it "probe label ready when all caps present":
            val lbl = gpu_lane_probe_label("nvidia-cuda", true, true, true, true)
            expect(lbl).to_equal("gpu-lane:ready:nvidia-cuda")

        it "probe label missing-runtime when runtime false":
            val lbl = gpu_lane_probe_label("amd-rocm-radv", false, true, true, true)
            expect(lbl).to_equal("gpu-lane:missing-runtime:amd-rocm-radv")

        it "framebuffer compute is forbidden":
            expect(gpu_lane_framebuffer_compute_forbidden()).to_equal(true)

    describe "Audio lane":
        it "controller is intel-hda":
            expect(audio_lane_controller()).to_equal("intel-hda")

        it "primary codec is realtek-hda":
            expect(audio_lane_primary_codec()).to_equal("realtek-hda")

        it "secondary codec is cirrus-logic-hda":
            expect(audio_lane_secondary_codec()).to_equal("cirrus-logic-hda")

        it "codec_supported accepts realtek and cirrus":
            expect(audio_lane_codec_supported("realtek-hda")).to_equal(true)
            expect(audio_lane_codec_supported("cirrus-logic-hda")).to_equal(true)
            expect(audio_lane_codec_supported("other-codec")).to_equal(false)

        it "probe label ready when all present":
            val lbl = audio_lane_probe_label(true, true, true, true, "alsa")
            expect(lbl).to_equal("audio-lane:ready")

        it "probe label missing-controller when controller false":
            val lbl = audio_lane_probe_label(false, true, true, true, "alsa")
            expect(lbl).to_equal("audio-lane:missing-controller")

        it "dma without period is invalid":
            expect(audio_lane_dma_without_period_invalid(true, false)).to_equal(true)
            expect(audio_lane_dma_without_period_invalid(true, true)).to_equal(false)

    describe "Input lane":
        it "ps2 bus name correct":
            expect(input_lane_ps2_bus()).to_equal("ps2")

        it "usb hid bus name correct":
            expect(input_lane_usb_hid_bus()).to_equal("usb-hid")

        it "ps2 hotplug not supported usb hotplug supported":
            expect(input_lane_ps2_hotplug_supported()).to_equal(false)
            expect(input_lane_usb_hid_hotplug_supported()).to_equal(true)

        it "probe label ready for ps2 with all caps":
            val lbl = input_lane_probe_label("ps2", true, true, true)
            expect(lbl).to_equal("input-lane:ready:ps2")

        it "probe label missing-keyboard when keyboard false":
            val lbl = input_lane_probe_label("ps2", false, true, true)
            expect(lbl).to_equal("input-lane:missing-keyboard:ps2")

        it "usb partial without hotplug detected":
            expect(input_lane_usb_partial_without_hotplug("usb-hid", false, true)).to_equal(true)
            expect(input_lane_usb_partial_without_hotplug("usb-hid", true, true)).to_equal(false)

    describe "Exokernel lane":
        it "resource list contains bar irq dma":
            val res = exokernel_lane_resources()
            expect(res.contains("bar")).to_equal(true)
            expect(res.contains("irq")).to_equal(true)
            expect(res.contains("dma")).to_equal(true)

        it "raw app without iommu is unsafe":
            expect(exokernel_lane_raw_app_requires_iommu(true, false)).to_equal(true)
            expect(exokernel_lane_raw_app_requires_iommu(true, true)).to_equal(false)
            expect(exokernel_lane_raw_app_requires_iommu(false, false)).to_equal(false)

        it "probe label ready when all caps present":
            val lbl = exokernel_lane_probe_label(true, true, true, true, true, false)
            expect(lbl).to_equal("exokernel-lane:ready")

        it "probe label unsafe when raw without iommu":
            val lbl = exokernel_lane_probe_label(true, true, true, false, true, true)
            expect(lbl).to_equal("exokernel-lane:unsafe-raw-without-iommu")

        it "probe label missing-bar when bar false":
            val lbl = exokernel_lane_probe_label(false, true, true, true, true, false)
            expect(lbl).to_equal("exokernel-lane:missing-bar")

        it "brokered iommu is safe":
            expect(exokernel_lane_brokered_iommu_safe()).to_equal(true)
