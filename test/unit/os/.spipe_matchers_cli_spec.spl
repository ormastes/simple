use std.spec
use os.cli.{handle_os}
extern fn rt_env_get(key: text) -> text?
extern fn rt_env_set(key: text, value: text) -> bool

describe "SimpleOS CLI parser":
    it "rejects a trailing bare --log flag":
        expect handle_os(["build", "--log"]) == 1

    it "rejects an empty inline --log value":
        expect handle_os(["build", "--log="]) == 1

    it "rejects bare --log followed by another option":
        expect handle_os(["build", "--log", "--arch=x86_64"]) == 1

    it "rejects typoed --log-prefixed flags":
        expect handle_os(["build", "--logg", "off"]) == 1

    it "rejects a single invalid inline --log value":
        expect handle_os(["build", "--log=maybe"]) == 1

    it "rejects an invalid later --log value instead of keeping an earlier valid one":
        expect handle_os(["build", "--log=on", "--log", "maybe"]) == 1

    it "rejects a trailing bare --arch flag":
        expect handle_os(["build", "--arch"]) == 1

    it "rejects bare --arch followed by another option":
        expect handle_os(["build", "--arch", "--log=off"]) == 1

    it "rejects a trailing bare --target flag":
        expect handle_os(["build", "--target"]) == 1

    it "rejects bare --target followed by another option":
        expect handle_os(["build", "--target", "--log=off"]) == 1

    it "rejects a trailing bare --scenario flag":
        expect handle_os(["build", "--scenario"]) == 1

    it "rejects bare --scenario followed by another option":
        expect handle_os(["build", "--scenario", "--arch=x86_64"]) == 1

    it "rejects a trailing bare --board flag":
        expect handle_os(["test", "--board"]) == 1

    it "rejects bare --board followed by another option":
        expect handle_os(["test", "--board", "--arch=riscv64"]) == 1

    it "rejects unsupported board names":
        expect handle_os(["test", "--board=arm64"]) == 1

    it "restores SIMPLE_OS_LOG_MODE after a failed canonical build path":
        val prior = rt_env_get("SIMPLE_OS_LOG_MODE") ?? ""
        expect handle_os(["build", "--log=off", "--arch=bogus"]) == 1
        expect rt_env_get("SIMPLE_OS_LOG_MODE") ?? "" == prior
        expect rt_env_set("SIMPLE_OS_LOG_MODE", prior) == true