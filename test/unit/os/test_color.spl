fn check(n: text, v: bool):
    if v:
        print "OK: {n}"
    else:
        print "FAIL: {n}"
fn rgb(r: i64, g: i64, b: i64) -> i64:
    (0xFF000000) | ((r & 0xFF) << 16) | ((g & 0xFF) << 8) | (b & 0xFF)
fn main():
    print "=== Color ==="
    check("black", rgb(0, 0, 0) == 0xFF000000)
    check("white", rgb(255, 255, 255) == 0xFFFFFFFF)
    check("red R", ((rgb(255, 0, 0) >> 16) & 0xFF) == 255)
    check("red G", ((rgb(255, 0, 0) >> 8) & 0xFF) == 0)
    check("blue B", (rgb(0, 0, 255) & 0xFF) == 255)
    print "=== DONE ==="
