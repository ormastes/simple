fn check(n: text, v: bool):
    if v:
        print "OK: {n}"
    else:
        print "FAIL: {n}"

fn align_up(addr: i64, align: i64) -> i64:
    ((addr + align - 1) / align) * align

fn main():
    print "=== Heap ==="
    check("a16", align_up(1, 16) == 16)
    check("a16b", align_up(16, 16) == 16)
    check("a16c", align_up(17, 16) == 32)
    check("a4k", align_up(4097, 4096) == 8192)
    check("a0", align_up(0, 16) == 0)
    check("a8", align_up(100, 8) == 104)
    print "=== DONE ==="
