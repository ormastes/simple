use std.io_runtime

class DriverEntry:
    name: text
    present: bool
    status: text

    static fn create(n: text, p: bool, s: text) -> DriverEntry:
        DriverEntry(name: n, present: p, status: s)

class DriverMatrix:
    count: i32
    d0_name: text
    d0_present: bool
    d1_name: text
    d1_present: bool

    static fn create(c: i32, n0: text, p0: bool, n1: text, p1: bool) -> DriverMatrix:
        DriverMatrix(count: c, d0_name: n0, d0_present: p0, d1_name: n1, d1_present: p1)

class CapabilitySummary:
    platform: text
    storage: text
    display: text
    input: text
    network: text
    dma: text
    interrupt_mode: text

    static fn create(pl: text, st: text, di: text, inp: text, net: text, dm: text, im: text) -> CapabilitySummary:
        CapabilitySummary(platform: pl, storage: st, display: di, input: inp, network: net, dma: dm, interrupt_mode: im)

class PciResource:
    bar_addr: i32
    irq: i32
    has_dma: bool
    device_class: text

    static fn create(ba: i32, ir: i32, hd: bool, dc: text) -> PciResource:
        PciResource(bar_addr: ba, irq: ir, has_dma: hd, device_class: dc)

class StorageDmaResult:
    driver: text
    read_ok: bool
    write_ok: bool
    timeout: bool

    static fn create(dr: text, ro: bool, wo: bool, to: bool) -> StorageDmaResult:
        StorageDmaResult(driver: dr, read_ok: ro, write_ok: wo, timeout: to)

class DisplayReport:
    mode: text
    width: i32
    height: i32
    accelerated: bool

    static fn create(m: text, w: i32, h: i32, a: bool) -> DisplayReport:
        DisplayReport(mode: m, width: w, height: h, accelerated: a)

class InputDevice:
    kind: text
    accepted: bool
    blocking: bool

    static fn create(k: text, ac: bool, bl: bool) -> InputDevice:
        InputDevice(kind: k, accepted: ac, blocking: bl)

class VirtioNetInit:
    device_id: i32
    mac_addr: text
    queue_count: i32
    link_up: bool
    init_ok: bool

    static fn create(did: i32, mac: text, qc: i32, lu: bool, ok: bool) -> VirtioNetInit:
        VirtioNetInit(device_id: did, mac_addr: mac, queue_count: qc, link_up: lu, init_ok: ok)

class NetDriverCapability:
    has_checksum_offload: bool
    has_tso: bool
    has_multiqueue: bool
    tier: text

    static fn create(co: bool, ts: bool, mq: bool, ti: text) -> NetDriverCapability:
        NetDriverCapability(has_checksum_offload: co, has_tso: ts, has_multiqueue: mq, tier: ti)

class AcceptanceGate:
    driver_name: text
    claims_resident: bool
    actually_loaded: bool
    claims_dma: bool
    has_dma_desc: bool
    claims_accel: bool
    has_accel_proof: bool

    static fn create(dn: text, cr: bool, al: bool, cd: bool, hd: bool, ca: bool, ha: bool) -> AcceptanceGate:
        AcceptanceGate(driver_name: dn, claims_resident: cr, actually_loaded: al, claims_dma: cd, has_dma_desc: hd, claims_accel: ca, has_accel_proof: ha)

fn test_driver_present_passes():
    var e = DriverEntry.create("nvme", true, "ok")
    if e.present == true and e.status == "ok":
        print("PASS: test_driver_present_passes")
    else:
        print("FAIL: test_driver_present_passes")

fn test_driver_missing_fails():
    var e = DriverEntry.create("nvme", false, "missing")
    if e.present == false and e.status == "missing":
        print("PASS: test_driver_missing_fails")
    else:
        print("FAIL: test_driver_missing_fails")

fn test_matrix_all_present():
    var m = DriverMatrix.create(2, "nvme", true, "ahci", true)
    if m.count == 2 and m.d0_present == true and m.d1_present == true:
        print("PASS: test_matrix_all_present")
    else:
        print("FAIL: test_matrix_all_present")

fn test_polling_interrupt():
    var c = CapabilitySummary.create("uefi_acpi", "nvme", "vga", "ps2", "virtio", "enabled", "polling")
    var c2 = CapabilitySummary.create("uefi_acpi", "nvme", "vga", "ps2", "virtio", "enabled", "apic")
    if c.interrupt_mode == "polling" and c2.interrupt_mode == "apic":
        print("PASS: test_polling_interrupt")
    else:
        print("FAIL: test_polling_interrupt")

fn test_has_dma():
    var c = CapabilitySummary.create("uefi_acpi", "nvme", "vga", "ps2", "virtio", "enabled", "apic")
    if c.dma == "enabled":
        print("PASS: test_has_dma")
    else:
        print("FAIL: test_has_dma")

fn test_pci_owns_bar():
    var r = PciResource.create(4096, 10, true, "storage")
    if r.bar_addr > 0:
        print("PASS: test_pci_owns_bar")
    else:
        print("FAIL: test_pci_owns_bar")

fn test_pci_no_bar():
    var r = PciResource.create(0, 0, false, "unknown")
    if r.bar_addr == 0:
        print("PASS: test_pci_no_bar")
    else:
        print("FAIL: test_pci_no_bar")

fn test_pci_bind():
    var r = PciResource.create(8192, 11, true, "display")
    if r.has_dma == true and r.irq > 0:
        print("PASS: test_pci_bind")
    else:
        print("FAIL: test_pci_bind")

fn test_acpi_ok():
    var c = CapabilitySummary.create("uefi_acpi", "ahci", "framebuffer", "ps2", "e1000", "enabled", "apic")
    if c.platform == "uefi_acpi":
        print("PASS: test_acpi_ok")
    else:
        print("FAIL: test_acpi_ok")

fn test_discovery_complete():
    var c = CapabilitySummary.create("uefi_acpi", "nvme", "virtio_gpu", "ps2", "virtio_net", "enabled", "apic")
    var complete = (c.platform == "" == false) and (c.storage == "" == false) and (c.display == "" == false) and (c.input == "" == false) and (c.network == "" == false) and (c.dma == "" == false) and (c.interrupt_mode == "" == false)
    if complete == true:
        print("PASS: test_discovery_complete")
    else:
        print("FAIL: test_discovery_complete")

fn test_storage_success():
    var s = StorageDmaResult.create("nvme", true, true, false)
    if s.read_ok == true and s.write_ok == true and s.timeout == false:
        print("PASS: test_storage_success")
    else:
        print("FAIL: test_storage_success")

fn test_storage_timeout():
    var s = StorageDmaResult.create("ahci", false, false, true)
    if s.timeout == true:
        print("PASS: test_storage_timeout")
    else:
        print("FAIL: test_storage_timeout")

fn test_framebuffer_not_accel():
    var d = DisplayReport.create("framebuffer", 1024, 768, false)
    if d.mode == "framebuffer" and d.accelerated == false:
        print("PASS: test_framebuffer_not_accel")
    else:
        print("FAIL: test_framebuffer_not_accel")

fn test_vgpu_with_cmd_accel():
    var d = DisplayReport.create("virtio_gpu", 1920, 1080, true)
    if d.mode == "virtio_gpu" and d.accelerated == true:
        print("PASS: test_vgpu_with_cmd_accel")
    else:
        print("FAIL: test_vgpu_with_cmd_accel")

fn test_ps2_accepted():
    var inp = InputDevice.create("ps2_keyboard", true, false)
    if inp.kind == "ps2_keyboard" and inp.accepted == true:
        print("PASS: test_ps2_accepted")
    else:
        print("FAIL: test_ps2_accepted")

fn test_xhci_not_accepted():
    var inp = InputDevice.create("xhci", false, false)
    if inp.accepted == false:
        print("PASS: test_xhci_not_accepted")
    else:
        print("FAIL: test_xhci_not_accepted")

fn test_resident_fallback_fails():
    var g = AcceptanceGate.create("my_driver", true, false, false, false, false, false)
    if g.claims_resident == true and g.actually_loaded == false:
        print("PASS: test_resident_fallback_fails")
    else:
        print("FAIL: test_resident_fallback_fails")

fn test_no_false_claim():
    var g = AcceptanceGate.create("nvme_drv", true, true, true, true, true, true)
    var valid = g.claims_resident == g.actually_loaded and g.claims_dma == g.has_dma_desc and g.claims_accel == g.has_accel_proof
    if valid == true:
        print("PASS: test_no_false_claim")
    else:
        print("FAIL: test_no_false_claim")

fn test_matrix_missing_count():
    var m = DriverMatrix.create(2, "nvme", true, "ahci", false)
    if m.d1_present == false:
        print("PASS: test_matrix_missing_count")
    else:
        print("FAIL: test_matrix_missing_count")

fn test_matrix_incomplete():
    var m = DriverMatrix.create(2, "nvme", false, "ahci", true)
    if m.count == 2 and m.d0_present == false:
        print("PASS: test_matrix_incomplete")
    else:
        print("FAIL: test_matrix_incomplete")

fn main():
    test_driver_present_passes()
    test_driver_missing_fails()
    test_matrix_all_present()
    test_polling_interrupt()
    test_has_dma()
    test_pci_owns_bar()
    test_pci_no_bar()
    test_pci_bind()
    test_acpi_ok()
    test_discovery_complete()
    test_storage_success()
    test_storage_timeout()
    test_framebuffer_not_accel()
    test_vgpu_with_cmd_accel()
    test_ps2_accepted()
    test_xhci_not_accepted()
    test_resident_fallback_fails()
    test_no_false_claim()
    test_matrix_missing_count()
    test_matrix_incomplete()
    print("DONE")
