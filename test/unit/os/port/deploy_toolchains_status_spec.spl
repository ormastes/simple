use std.spec.{describe, it, expect}
use os.port.guest_toolchain_execution_gate.{
    guest_toolchain_execution_gate_detail,
    guest_toolchain_execution_gate_payload_detail,
    guest_toolchain_static_payload_detail,
}

fn _push_u16_le(buf: [u8], value: i64) -> [u8]:
    var out: [u8] = buf
    out.push((value & 0xFF).to_u8())
    out.push(((value >> 8) & 0xFF).to_u8())
    out

fn _push_u32_le(buf: [u8], value: i64) -> [u8]:
    var out: [u8] = buf
    out.push((value & 0xFF).to_u8())
    out.push(((value >> 8) & 0xFF).to_u8())
    out.push(((value >> 16) & 0xFF).to_u8())
    out.push(((value >> 24) & 0xFF).to_u8())
    out

fn _push_u64_le(buf: [u8], value: i64) -> [u8]:
    var out: [u8] = buf
    out = _push_u32_le(out, value & 0xFFFFFFFF)
    out = _push_u32_le(out, (value >> 32) & 0xFFFFFFFF)
    out

fn _elf64_x86_64_payload(include_interp: bool, machine: i64) -> [u8]:
    var bytes: [u8] = []
    bytes.push(0x7F.to_u8())
    bytes.push(0x45.to_u8())
    bytes.push(0x4C.to_u8())
    bytes.push(0x46.to_u8())
    bytes.push(2.to_u8())
    bytes.push(1.to_u8())
    bytes.push(1.to_u8())
    while bytes.len() < 16:
        bytes.push(0.to_u8())
    bytes = _push_u16_le(bytes, 2)
    bytes = _push_u16_le(bytes, machine)
    bytes = _push_u32_le(bytes, 1)
    bytes = _push_u64_le(bytes, 0x400000)
    bytes = _push_u64_le(bytes, 64)
    bytes = _push_u64_le(bytes, 0)
    bytes = _push_u32_le(bytes, 0)
    bytes = _push_u16_le(bytes, 64)
    bytes = _push_u16_le(bytes, 56)
    bytes = _push_u16_le(bytes, if include_interp: 2 else: 1)
    bytes = _push_u16_le(bytes, 0)
    bytes = _push_u16_le(bytes, 0)
    bytes = _push_u16_le(bytes, 0)
    if include_interp:
        bytes = _push_u32_le(bytes, 3)
        bytes = _push_u32_le(bytes, 4)
        bytes = _push_u64_le(bytes, 0x200)
        bytes = _push_u64_le(bytes, 0)
        bytes = _push_u64_le(bytes, 0)
        bytes = _push_u64_le(bytes, 16)
        bytes = _push_u64_le(bytes, 16)
        bytes = _push_u64_le(bytes, 1)
    bytes = _push_u32_le(bytes, 1)
    bytes = _push_u32_le(bytes, 5)
    bytes = _push_u64_le(bytes, 0x1000)
    bytes = _push_u64_le(bytes, 0x400000)
    bytes = _push_u64_le(bytes, 0x400000)
    bytes = _push_u64_le(bytes, 4)
    bytes = _push_u64_le(bytes, 4)
    bytes = _push_u64_le(bytes, 0x1000)
    bytes

describe "SimpleOS guest toolchain execution status gate":
    it "reports every missing prerequisite for real in-guest compiler execution":
        val detail = guest_toolchain_execution_gate_detail(false, false, false)
        expect(detail).to_contain("missing build/os/clang_static/bin/clang_static")
        expect(detail).to_contain("missing build/os/rust_static/bin/rustc_static")
        expect(detail).to_contain("build/os/.bake_include_toolchain not enabled")

    it "remains blocked until both compiler payloads and bake marker are ready":
        expect(guest_toolchain_execution_gate_detail(true, false, true)).to_contain("missing build/os/rust_static/bin/rustc_static")
        expect(guest_toolchain_execution_gate_detail(true, true, false)).to_contain("build/os/.bake_include_toolchain not enabled")
        expect(guest_toolchain_execution_gate_detail(true, true, true)).to_equal("READY")

    it "preserves invalid payload reasons in the aggregate gate":
        val detail = guest_toolchain_execution_gate_payload_detail(
            "not static ELF payload: PT_INTERP dynamic loader present in build/os/clang_static/bin/clang_static",
            "READY",
            true,
        )
        expect(detail).to_contain("PT_INTERP dynamic loader present")

    it "accepts a static ELF64 x86_64 payload":
        val detail = guest_toolchain_static_payload_detail("clang_static", _elf64_x86_64_payload(false, 62))
        expect(detail).to_equal("READY")

    it "rejects host-dynamic ELF payloads":
        val detail = guest_toolchain_static_payload_detail("clang_static", _elf64_x86_64_payload(true, 62))
        expect(detail).to_contain("PT_INTERP dynamic loader present")

    it "rejects non-x86_64 payloads":
        val detail = guest_toolchain_static_payload_detail("rustc_static", _elf64_x86_64_payload(false, 183))
        expect(detail).to_contain("e_machine=183")

    it "rejects placeholder payloads":
        var data: [u8] = []
        data.push(0x23.to_u8())
        data.push(0x21.to_u8())
        val detail = guest_toolchain_static_payload_detail("clang_static", data)
        expect(detail).to_contain("truncated header")
