use os.port.simpleos_multiplatform_build.{
    SimpleOsFirmwareContractKind,
    SimpleOsImageLayoutKind,
    SimpleOsLaneKind,
    SimpleOsNativeImplementationKind,
    SimpleOsStandaloneAsmPolicy,
    simpleos_platform_boot_asm_sources,
    simpleos_platform_boot_impl_kind,
    simpleos_platform_boot_c_sources,
    simpleos_platform_board_adapter_id,
    simpleos_platform_board_lane,
    simpleos_platform_c_flags,
    simpleos_platform_asm_flags,
    simpleos_platform_artifact_slug,
    simpleos_platform_default_entry,
    simpleos_platform_disk_image_output,
    simpleos_platform_float_abi,
    simpleos_platform_firmware_contract,
    simpleos_platform_grandfathered_native_sources,
    simpleos_platform_image_layout,
    simpleos_platform_isa,
    simpleos_platform_kernel_output,
    simpleos_platform_linker_script,
    simpleos_platform_native_target,
    simpleos_platform_qemu_acceptance_lane,
    simpleos_platform_qemu_acceptance_required_markers,
    simpleos_platform_qemu_lane,
    simpleos_platform_qemu_lanes,
    simpleos_platform_runtime_impl_kind,
    simpleos_platform_staged_toolchain_app_names,
    simpleos_platform_standalone_asm_policy,
    simpleos_platform_needs_soft_float_runtime,
    simpleos_platform_qemu_cpu,
    simpleos_platform_qemu_machine,
    simpleos_platform_qemu_system,
    simpleos_platform_target_by_name,
    simpleos_platform_target_names
}
use os.port.simpleos_native_build_config.{
    simpleos_boot_asm_sources,
    simpleos_boot_c_sources,
    simpleos_clang_target,
    simpleos_supported_targets,
    simpleos_target_arch,
    simpleos_target_artifact_slug,
    simpleos_target_boot_impl_kind,
    simpleos_target_disk_image_output,
    simpleos_target_float_abi,
    simpleos_target_grandfathered_native_sources,
    simpleos_target_kernel_output,
    simpleos_target_runtime_impl_kind,
    simpleos_target_standalone_asm_policy,
    simpleos_target_isa,
    simpleos_target_needs_soft_float_runtime
}
use os.kernel.arch.arch_context.{Architecture}

describe "SimpleOS multi-platform build catalog":
    it "exposes 32-bit x86 as a first-class supported target":
        val names = simpleos_platform_target_names()
        expect (names).contains("i686-simpleos")
        expect (simpleos_supported_targets()).contains("i686-simpleos")

    it "records unique QEMU artifact names for all first-class platforms":
        val names = simpleos_platform_target_names()
        expect names.len() == 6

        expect simpleos_platform_artifact_slug("x86_64") == "x86_64"
        expect simpleos_platform_disk_image_output("x86_64") == "build/os/fat32-x86_64.img"
        expect simpleos_platform_kernel_output("x86_64") == "build/os/simpleos_x86_64.elf"

        expect simpleos_platform_artifact_slug("x86_32") == "x86_32"
        expect simpleos_platform_disk_image_output("x86_32") == "build/os/fat32-x86_32.img"
        expect simpleos_platform_kernel_output("x86_32") == "build/os/simpleos_x86_32.elf"

        expect simpleos_platform_artifact_slug("arm64") == "arm64"
        expect simpleos_platform_disk_image_output("arm64") == "build/os/fat32-arm64.img"
        expect simpleos_platform_kernel_output("arm64") == "build/os/simpleos_aarch64.elf"

        expect simpleos_platform_artifact_slug("arm32") == "arm32"
        expect simpleos_platform_disk_image_output("arm32") == "build/os/fat32-arm32.img"
        expect simpleos_platform_kernel_output("arm32") == "build/os/simpleos_arm32.elf"

        expect simpleos_platform_artifact_slug("riscv64") == "riscv64"
        expect simpleos_platform_disk_image_output("riscv64") == "build/os/fat32-riscv64.img"
        expect simpleos_platform_kernel_output("riscv64") == "build/os/simpleos_riscv64.elf"

        expect simpleos_platform_artifact_slug("riscv32") == "riscv32"
        expect simpleos_platform_disk_image_output("riscv32") == "build/os/fat32-riscv32.img"
        expect simpleos_platform_kernel_output("riscv32") == "build/os/simpleos_riscv32.elf"

    it "exposes QEMU target metadata from the shared platform catalog":
        expect simpleos_platform_default_entry("x86_64") == "examples/simple_os/arch/x86_64/os_entry.spl"
        expect simpleos_platform_linker_script("x86_64") == "examples/simple_os/arch/x86_64/linker.ld"
        expect simpleos_platform_native_target("x86_64") == "x86_64-unknown-none"
        expect simpleos_platform_qemu_system("x86_64") == "qemu-system-x86_64"
        expect simpleos_platform_qemu_machine("x86_64") == "q35"
        expect simpleos_platform_qemu_cpu("x86_64") == "qemu64"

        expect simpleos_platform_default_entry("arm32") == "src/os/kernel/arch/arm32/boot.spl"
        expect simpleos_platform_qemu_system("arm32") == "qemu-system-arm"
        expect simpleos_platform_qemu_cpu("arm32") == "cortex-a15"

    it "resolves common x86_32 aliases to the i686 target":
        val target = simpleos_platform_target_by_name("x86_32")
        if val resolved = target:
            expect resolved.name == "i686-simpleos"
            expect resolved.arch == Architecture.X86
            expect resolved.bits == 32

        val i386 = simpleos_platform_target_by_name("i386")
        if val resolved_i386 = i386:
            expect resolved_i386.name == "i686-simpleos"

    it "uses freestanding i686 flags for 32-bit x86 C and assembly boot inputs":
        val c_flags = simpleos_platform_c_flags("i686-simpleos")
        expect (c_flags).contains("--target=i686-unknown-none-elf")
        expect (c_flags).contains("-m32")
        expect (c_flags).contains("-ffreestanding")
        expect (c_flags).contains("-DSIMPLEOS_ARCH_X86_32=1")

        val asm_flags = simpleos_platform_asm_flags("x86_32")
        expect (asm_flags).contains("--target=i686-unknown-none-elf")
        expect (asm_flags).contains("-m32")

    it "tracks x86_32 C and assembly boot support sources":
        val c_sources = simpleos_platform_boot_c_sources("x86_32")
        expect (c_sources).contains("examples/simple_os/arch/x86_32/boot/baremetal_stubs.c")

        val asm_sources = simpleos_platform_boot_asm_sources("x86_32")
        expect (asm_sources).contains("examples/simple_os/arch/x86_32/boot/crt0.s")

    it "records the grandfathered x86_64 native boot backlog separately from entry stubs":
        val backlog = simpleos_platform_grandfathered_native_sources("x86_64")
        expect (backlog).contains("examples/simple_os/arch/x86_64/boot/ap_trampoline.s")
        expect (backlog).contains("examples/simple_os/arch/x86_64/boot/syscall_entry.s")
        expect (backlog).contains("examples/simple_os/arch/x86_64/boot/auto_stubs.c")
        expect (backlog).contains("examples/simple_os/arch/x86_64/boot/rt_extras.c")

    it "tracks ARM C and assembly boot support sources":
        val arm64_c_sources = simpleos_platform_boot_c_sources("arm64")
        expect (arm64_c_sources).contains("examples/simple_os/arch/arm64/boot/baremetal_stubs.c")
        val arm64_asm_sources = simpleos_platform_boot_asm_sources("arm64")
        expect (arm64_asm_sources).contains("examples/simple_os/arch/arm64/boot/crt0.S")

        val arm32_c_sources = simpleos_platform_boot_c_sources("arm32")
        expect (arm32_c_sources).contains("examples/simple_os/arch/arm32/boot/baremetal_stubs.c")
        val arm32_asm_sources = simpleos_platform_boot_asm_sources("arm32")
        expect (arm32_asm_sources).contains("examples/simple_os/arch/arm32/boot/crt0.s")

    it "delegates native SimpleOS target helpers through the platform catalog":
        expect simpleos_target_arch("i686-simpleos") == "x86"
        expect simpleos_clang_target("i686-simpleos") == "i686-unknown-none-elf"
        expect (simpleos_boot_c_sources("i686-simpleos")).contains("examples/simple_os/arch/x86_32/boot/baremetal_stubs.c")
        expect (simpleos_boot_asm_sources("i686-simpleos")).contains("examples/simple_os/arch/x86_32/boot/crt0.s")
        expect simpleos_target_artifact_slug("i686-simpleos") == "x86_32"
        expect simpleos_target_kernel_output("i686-simpleos") == "build/os/simpleos_x86_32.elf"
        expect simpleos_target_disk_image_output("i686-simpleos") == "build/os/fat32-x86_32.img"

    it "records riscv32 as RV32IMAC ILP32 soft-float":
        val target = simpleos_platform_target_by_name("riscv32")
        if val resolved = target:
            expect resolved.name == "riscv32imac-simpleos"
            expect resolved.bits == 32
            expect resolved.isa == "rv32imac"
            expect resolved.abi == "ilp32"
            expect resolved.float_abi == "soft"

        val c_flags = simpleos_platform_c_flags("riscv32")
        expect (c_flags).contains("--target=riscv32-unknown-none-elf")
        expect (c_flags).contains("-march=rv32imac")
        expect (c_flags).contains("-mabi=ilp32")
        expect simpleos_platform_isa("riscv32") == "rv32imac"
        expect simpleos_platform_float_abi("riscv32") == "soft"
        expect simpleos_platform_needs_soft_float_runtime("riscv32") == true

    it "delegates riscv32 ABI helpers through native build config":
        expect simpleos_target_isa("riscv32imac-simpleos") == "rv32imac"
        expect simpleos_target_float_abi("riscv32imac-simpleos") == "soft"
        expect simpleos_target_needs_soft_float_runtime("riscv32imac-simpleos") == true

    it "keeps RISC-V SimpleOS boot support in Simple sources":
        expect simpleos_platform_boot_c_sources("riscv64").len() == 0
        expect simpleos_platform_boot_asm_sources("riscv64").len() == 0
        expect simpleos_boot_c_sources("riscv64gc-simpleos").len() == 0
        expect simpleos_boot_asm_sources("riscv64gc-simpleos").len() == 0

        expect simpleos_platform_boot_c_sources("riscv32").len() == 0
        expect simpleos_platform_boot_asm_sources("riscv32").len() == 0
        expect simpleos_boot_c_sources("riscv32imac-simpleos").len() == 0
        expect simpleos_boot_asm_sources("riscv32imac-simpleos").len() == 0

    it "records native-surface policy for primary reduction targets":
        expect simpleos_platform_boot_impl_kind("x86_64") == SimpleOsNativeImplementationKind.StandaloneAsm
        expect simpleos_platform_runtime_impl_kind("x86_64") == SimpleOsNativeImplementationKind.Simple
        expect simpleos_platform_standalone_asm_policy("x86_64") == SimpleOsStandaloneAsmPolicy.EntryStubsOnly

        expect simpleos_platform_boot_impl_kind("riscv64") == SimpleOsNativeImplementationKind.EmbeddedAsm
        expect simpleos_platform_runtime_impl_kind("riscv64") == SimpleOsNativeImplementationKind.Simple
        expect simpleos_platform_standalone_asm_policy("riscv64") == SimpleOsStandaloneAsmPolicy.EntryStubsOnly

        expect simpleos_platform_boot_impl_kind("riscv32") == SimpleOsNativeImplementationKind.EmbeddedAsm
        expect simpleos_platform_runtime_impl_kind("riscv32") == SimpleOsNativeImplementationKind.Simple
        expect simpleos_platform_standalone_asm_policy("riscv32") == SimpleOsStandaloneAsmPolicy.EntryStubsOnly

    it "delegates native-surface policy through native build config":
        expect simpleos_target_boot_impl_kind("x86_64-simpleos") == SimpleOsNativeImplementationKind.StandaloneAsm
        expect simpleos_target_runtime_impl_kind("x86_64-simpleos") == SimpleOsNativeImplementationKind.Simple
        expect simpleos_target_standalone_asm_policy("x86_64-simpleos") == SimpleOsStandaloneAsmPolicy.EntryStubsOnly
        expect (simpleos_target_grandfathered_native_sources("x86_64-simpleos")).contains("examples/simple_os/arch/x86_64/boot/ap_trampoline.s")

        expect simpleos_target_boot_impl_kind("riscv64gc-simpleos") == SimpleOsNativeImplementationKind.EmbeddedAsm
        expect simpleos_target_standalone_asm_policy("riscv64gc-simpleos") == SimpleOsStandaloneAsmPolicy.EntryStubsOnly

    it "records boot firmware, media layout, and staged toolchain contracts":
        expect simpleos_platform_firmware_contract("x86_64") == SimpleOsFirmwareContractKind.LimineBios
        expect simpleos_platform_image_layout("x86_64") == SimpleOsImageLayoutKind.Fat32Disk
        expect simpleos_platform_board_adapter_id("x86_64") == "x86_pc_bios_uefi"

        expect simpleos_platform_firmware_contract("arm64") == SimpleOsFirmwareContractKind.RawLoader
        expect simpleos_platform_image_layout("arm64") == SimpleOsImageLayoutKind.VirtioFat32
        expect simpleos_platform_board_adapter_id("arm64") == "arm64_u_boot_dtb_sbc"

        expect simpleos_platform_firmware_contract("riscv64") == SimpleOsFirmwareContractKind.OpenSbi
        expect simpleos_platform_image_layout("riscv64") == SimpleOsImageLayoutKind.HostedVirtioFat32
        expect simpleos_platform_board_adapter_id("riscv64") == "mlk_s02_100t"

        expect simpleos_platform_staged_toolchain_app_names("arm64") == ["simple_compiler", "simple_loader", "clang", "rust"]
        expect simpleos_platform_staged_toolchain_app_names("riscv64") == ["simple_compiler", "simple_loader", "llvm", "clang", "rust"]

    it "maps acceptance lanes from the catalog instead of separate target tables":
        val arm64_lane = simpleos_platform_qemu_acceptance_lane("arm64")
        expect arm64_lane.name == "arm64-virtio-fat32-smf"
        expect arm64_lane.lane_kind == SimpleOsLaneKind.FsExec
        expect arm64_lane.entry == "examples/simple_os/arch/arm64/fs_exec_entry.spl"
        expect arm64_lane.media_path_hint == "build/os/fat32-arm64.img"

        val rv64_lane = simpleos_platform_qemu_acceptance_lane("riscv64")
        expect rv64_lane.name == "riscv64-hosted"
        expect rv64_lane.lane_kind == SimpleOsLaneKind.HostedCompileSmoke
        expect rv64_lane.entry == "examples/simple_os/arch/riscv64/hosted_entry.spl"
        expect rv64_lane.media_path_hint == "build/os/fat32-riscv64.img"

        val arm_markers = simpleos_platform_qemu_acceptance_required_markers("arm64")
        expect (arm_markers).contains("[desktop-e2e] process-backed:ok app=simple_compiler pid=")
        expect (arm_markers).contains("[desktop-e2e] vfs-app-read:ok source=generic-vfs path=/sys/apps/rust bytes=")
        expect (arm_markers).contains("TEST PASSED")

        val rv64_markers = simpleos_platform_qemu_acceptance_required_markers("riscv64")
        expect (rv64_markers).contains("[desktop-e2e] native-toolchain-launch:ok app=llvm lane=riscv64-hosted mode=native-filesystem-app status=standalone-required tool=/sys/apps/llvm manifest=/SYS/LLVMMAN.TXT")
        expect (rv64_markers).contains("HOSTED_FS_TOOLCHAIN_READY arch=riscv64 apps=simple_compiler,simple_loader,llvm,clang,rust")

    it "looks up named QEMU lanes without duplicating the x86 smoke lane":
        val rv64_hosted = simpleos_platform_qemu_lane("riscv64", "riscv64-hosted")
        if val lane = rv64_hosted:
            expect lane.lane_kind == SimpleOsLaneKind.HostedCompileSmoke
            expect lane.output == "build/os/simpleos_riscv64_hosted.elf"
        else:
            fail("missing riscv64 hosted lane")

        val rv64_virtio = simpleos_platform_qemu_lane("riscv64", "riscv64-virtio-fat32-smf")
        if val lane = rv64_virtio:
            expect lane.lane_kind == SimpleOsLaneKind.FsExec
            expect lane.entry == "examples/simple_os/arch/riscv64/smoke_entry.spl"
            expect lane.timeout_ms == 60000
            expect lane.media_path_hint == "build/os/fat32-riscv64.img"
            expect lane.required_serial_markers.len() == 0
        else:
            fail("missing riscv64 virtio lane")

        val x64_lanes = simpleos_platform_qemu_lanes("x86_64")
        expect x64_lanes.len() == 1
        expect x64_lanes[0].name == "x86_64-smoke"

    it "captures representative board-ready lanes per ISA family":
        val x64_board = simpleos_platform_board_lane("x86_64")
        if val resolved_x64_board = x64_board:
            expect resolved_x64_board.lane_kind == SimpleOsLaneKind.BoardCompileSmoke
            expect resolved_x64_board.board_adapter_id == "x86_pc_bios_uefi"
            expect resolved_x64_board.media_path_hint == "build/os/fat32-x86_64.img"
        else:
            fail("missing x86_64 board lane")

        val arm64_board = simpleos_platform_board_lane("arm64")
        if val resolved_arm64_board = arm64_board:
            expect resolved_arm64_board.firmware_contract == SimpleOsFirmwareContractKind.UBootDtb
            expect resolved_arm64_board.board_adapter_id == "arm64_u_boot_dtb_sbc"
        else:
            fail("missing arm64 board lane")

        val rv64_board = simpleos_platform_board_lane("riscv64")
        if val resolved_rv64_board = rv64_board:
            expect resolved_rv64_board.board_adapter_id == "mlk_s02_100t"
            expect (resolved_rv64_board.media_path_hint).contains("generate_riscv_fpga_bundle.spl")
        else:
            fail("missing riscv64 board lane")

        expect simpleos_platform_board_lane("arm32") == nil

    it "tracks grandfathered non-hal native exceptions for riscv hosted leaves":
        val rv64_backlog = simpleos_platform_grandfathered_native_sources("riscv64")
        expect (rv64_backlog).contains("examples/simple_os/arch/riscv64/boot/baremetal_stubs.c")
        expect (rv64_backlog).contains("examples/simple_os/arch/riscv64/boot/ghdl_boot_info_runtime.c")

        val rv32_backlog = simpleos_platform_grandfathered_native_sources("riscv32")
        expect (rv32_backlog).contains("examples/simple_os/arch/riscv32/boot/baremetal_stubs.c")