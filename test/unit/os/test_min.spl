fn check(n: text, v: bool):
    if v:
        print "OK: {n}"
    else:
        print "FAIL: {n}"
fn pci_bdf(bus: i64, dev: i64, f: i64) -> i64:
    (1 << 31) | (bus << 16) | (dev << 11) | (f << 8)
fn main():
    print "=== PCI ==="
    check("enable", pci_bdf(1, 2, 3) > 0)
    check("enable2", (3 >> 1) == 1)
    print "=== DONE ==="
