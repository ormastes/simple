fn check(n: text, v: bool):
    if v:
        print "OK: {n}"
    else:
        print "FAIL: {n}"

fn set_bit(bmp: i64, bit: i64) -> i64:
    bmp | (1 << bit)

fn clr_bit(bmp: i64, bit: i64) -> i64:
    bmp & (0xFFFFFFFFFFFFFFFF - (1 << bit))

fn main():
    print "=== Bitmap ==="
    check("set0", set_bit(0, 0) == 1)
    check("set3", set_bit(0, 3) == 8)
    check("clr0", clr_bit(1, 0) == 0)
    check("clr3", clr_bit(0xFF, 3) == 0xF7)
    check("set_clr", clr_bit(set_bit(0, 5), 5) == 0)
    check("multi", set_bit(set_bit(0, 1), 3) == 10)
    print "=== DONE ==="
