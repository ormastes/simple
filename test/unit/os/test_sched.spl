fn check(n: text, v: bool):
    if v:
        print "OK: {n}"
    else:
        print "FAIL: {n}"

fn higher_pri(a: i64, b: i64) -> bool:
    a < b

fn next_tick(current: i64, total: i64) -> i64:
    (current + 1) - ((current + 1) / total) * total

fn main():
    print "=== Scheduler ==="
    check("hi_pri", higher_pri(0, 3))
    check("lo_pri", not higher_pri(3, 0))
    check("eq_pri", not higher_pri(2, 2))
    check("tick0", next_tick(0, 4) == 1)
    check("tick3", next_tick(3, 4) == 0)
    check("tick_mid", next_tick(2, 4) == 3)
    print "=== DONE ==="
