fn check(n: text, v: bool):
    if v:
        print "OK: {n}"
    else:
        print "FAIL: {n}"

fn shr(x: i64, n: i64) -> i64:
    x / (1 << n)

fn idt_lo(handler: i64) -> i64:
    handler & 0xFFFF

fn main():
    print "=== IDT ==="
    check("lo", idt_lo(0xDEADBEEF) == 0xBEEF)
    check("mid", (shr(0xDEADBEEF, 16) & 0xFFFF) == 0xDEAD)
    check("zero", idt_lo(0) == 0)
    check("max16", idt_lo(0xFFFF) == 0xFFFF)
    print "=== DONE ==="
