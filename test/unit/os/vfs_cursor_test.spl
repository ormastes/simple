# VFS select-file cursor tests — FR-SIMPLEOS-M5-001 (Option C)
#
# Tests the VfsCursor singleton helpers in vfs_init.spl:
#   g_vfs_select_file / g_vfs_get_selected_file / g_vfs_clear_selected_file
#
# These are pure unit tests of the cursor state; no mount table I/O is
# exercised (the underlying driver write path requires a real NVMe device).

use os.services.vfs.vfs_init.{
    g_vfs_select_file,
    g_vfs_get_selected_file,
    g_vfs_clear_selected_file,
}

feature "VfsCursor — select-file cursor semantics":

    it "starts empty before any selection":
        val name = g_vfs_get_selected_file()
        assert name == ""

    it "select_file sets the cursor":
        g_vfs_select_file("HELLO.TXT")
        val name = g_vfs_get_selected_file()
        assert name == "HELLO.TXT"

    it "select_file overwrites a previous selection":
        g_vfs_select_file("FIRST.TXT")
        g_vfs_select_file("SECOND.TXT")
        val name = g_vfs_get_selected_file()
        assert name == "SECOND.TXT"

    it "clear_selected_file resets cursor to empty":
        g_vfs_select_file("HELLO.TXT")
        g_vfs_clear_selected_file()
        val name = g_vfs_get_selected_file()
        assert name == ""

    it "select_file accepts absolute paths":
        g_vfs_select_file("/boot/CONFIG.TXT")
        val name = g_vfs_get_selected_file()
        assert name == "/boot/CONFIG.TXT"
        g_vfs_clear_selected_file()

    it "cursor is empty after clear even if set multiple times":
        g_vfs_select_file("A.TXT")
        g_vfs_select_file("B.TXT")
        g_vfs_clear_selected_file()
        val name = g_vfs_get_selected_file()
        assert name == ""
