use os.machine_profile.{get_arm_machine_profile, get_arm_machine_profiles, get_riscv_machine_profile, get_riscv_machine_profiles}
use os.kernel.arch.arch_context.{Architecture}

describe "Machine Profiles":
    it "exports the canonical simulator machine ids":
        val profiles = get_riscv_machine_profiles()
        expect profiles.len() == 2
        expect profiles[0].name == "simple-rv64"
        expect profiles[1].name == "simple-rv32"

    it "maps simple-rv64 to the RV64 Linux-capable profile":
        val profile = get_riscv_machine_profile("simple-rv64")
        val rv64 = profile.unwrap()
        expect rv64.name == "simple-rv64"
        expect rv64.arch == Architecture.Riscv64
        expect rv64.boot_protocol == "opensbi"
        expect rv64.target_triple == "riscv64-unknown-none"
        expect rv64.qemu_system == "qemu-system-riscv64"

    it "maps riscv32 alias to the canonical RV32 profile":
        val profile = get_riscv_machine_profile("riscv32")
        val rv32 = profile.unwrap()
        expect rv32.name == "simple-rv32"
        expect rv32.arch == Architecture.Riscv32
        expect rv32.target_triple == "riscv32-unknown-none"
        expect rv32.boot_protocol == "dtb"
        expect rv32.qemu_bios == "none"

    it "derives RISC-V profile QEMU fields from the platform catalog":
        val rv64 = get_riscv_machine_profile("riscv64").unwrap()
        expect rv64.entry == "src/os/kernel/arch/riscv64/boot.spl"
        expect rv64.linker_script == "src/os/kernel/arch/riscv64/linker.ld"
        expect rv64.output == "build/os/simpleos_riscv64.elf"
        expect rv64.qemu_machine == "virt"
        expect rv64.qemu_cpu == "rv64"

        val rv32 = get_riscv_machine_profile("simple-rv32").unwrap()
        expect rv32.entry == "src/os/kernel/arch/riscv32/boot.spl"
        expect rv32.output == "build/os/simpleos_riscv32.elf"
        expect rv32.qemu_cpu == "rv32"

    it "exports the canonical ARM machine ids":
        val profiles = get_arm_machine_profiles()
        expect profiles.len() == 2
        expect profiles[0].name == "simple-arm64"
        expect profiles[1].name == "simple-arm32"

    it "derives ARM profile QEMU fields from the platform catalog":
        val arm64 = get_arm_machine_profile("arm64").unwrap()
        expect arm64.arch == Architecture.Arm64
        expect arm64.entry == "src/os/kernel/arch/arm64/boot.spl"
        expect arm64.target_triple == "aarch64-unknown-none"
        expect arm64.qemu_system == "qemu-system-aarch64"
        expect arm64.qemu_cpu == "cortex-a72"
        expect arm64.boot_protocol == "raw-loader"

        val arm32 = get_arm_machine_profile("simple-arm32").unwrap()
        expect arm32.arch == Architecture.Arm32
        expect arm32.entry == "src/os/kernel/arch/arm32/boot.spl"
        expect arm32.target_triple == "armv7-unknown-none-eabihf"
        expect arm32.qemu_system == "qemu-system-arm"
        expect arm32.qemu_cpu == "cortex-a15"
        expect arm32.boot_protocol == "raw-loader"