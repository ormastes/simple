fn check(n: text, v: bool):
    if v:
        print "OK: {n}"
    else:
        print "FAIL: {n}"

fn is_esc(c: i64) -> bool:
    c == 27

fn is_csi(c: i64) -> bool:
    c == 91

fn is_final(c: i64) -> bool:
    c >= 64 and c <= 126

fn main():
    print "=== ANSI ==="
    check("esc", is_esc(27))
    check("not_esc", not is_esc(65))
    check("csi", is_csi(91))
    check("final_A", is_final(65))
    check("final_m", is_final(109))
    check("not_fin", not is_final(32))
    print "=== DONE ==="
