use std.io_runtime

class ProbeResult:
    vendor: text
    available: bool
    backend: text
    vram_mb: i64

    static fn unavailable(v: text) -> ProbeResult:
        ProbeResult(vendor: v, available: false, backend: "none", vram_mb: 0)

    static fn available(v: text, be: text, vram: i64) -> ProbeResult:
        ProbeResult(vendor: v, available: true, backend: be, vram_mb: vram)

    me summary() -> text:
        return self.vendor + ":" + self.available.to_text()

class RingBuf:
    capacity: i64
    write_pos: i64
    read_pos: i64

    static fn create(cap: i64) -> RingBuf:
        RingBuf(capacity: cap, write_pos: 0, read_pos: 0)

    me advance_write() -> i64:
        self.write_pos = (self.write_pos + 1) % self.capacity
        return self.write_pos

    me advance_read() -> i64:
        self.read_pos = (self.read_pos + 1) % self.capacity
        return self.read_pos

    me is_empty() -> bool:
        return self.write_pos == self.read_pos

class MixerState:
    volume: i64
    muted: bool

    static fn create(vol: i64) -> MixerState:
        MixerState(volume: vol, muted: false)

    me effective() -> i64:
        if self.muted:
            return 0
        return self.volume

class KeyEv:
    scan_code: i64
    pressed: bool
    modifiers: i64
    timestamp: i64

    static fn press(scan: i64, mods: i64, ts: i64) -> KeyEv:
        KeyEv(scan_code: scan, pressed: true, modifiers: mods, timestamp: ts)

    static fn release(scan: i64, mods: i64, ts: i64) -> KeyEv:
        KeyEv(scan_code: scan, pressed: false, modifiers: mods, timestamp: ts)

    me has_shift() -> bool:
        return (self.modifiers % 2) == 1

class BarGrant:
    bar_index: i64
    token: i64
    granted: bool

    static fn request(bar: i64) -> BarGrant:
        BarGrant(bar_index: bar, token: 0, granted: false)

    me grant(tok: i64) -> text:
        self.token = tok
        self.granted = true
        return ""

    me revoke() -> text:
        self.granted = false
        self.token = 0
        return ""

class LayerCheck:
    layer: text
    level: i64
    allowed_max: i64

    static fn kernel() -> LayerCheck:
        LayerCheck(layer: "kernel", level: 0, allowed_max: 0)

    static fn service() -> LayerCheck:
        LayerCheck(layer: "service", level: 1, allowed_max: 0)

    static fn driver() -> LayerCheck:
        LayerCheck(layer: "driver", level: 2, allowed_max: 1)

    static fn app() -> LayerCheck:
        LayerCheck(layer: "app", level: 3, allowed_max: 2)

    me can_import(from_level: i64) -> bool:
        return from_level <= self.allowed_max

class LaneGate:
    name: text
    has_contract: bool
    has_tests: bool
    has_docs: bool
    has_reviewer: bool
    blockers: i64

    static fn create(n: text) -> LaneGate:
        LaneGate(name: n, has_contract: false, has_tests: false, has_docs: false, has_reviewer: false, blockers: 0)

    me is_ready() -> bool:
        if self.has_contract == false:
            return false
        if self.has_tests == false:
            return false
        if self.has_docs == false:
            return false
        if self.has_reviewer == false:
            return false
        if self.blockers > 0:
            return false
        return true

fn test_gpu_probe_unavailable():
    val p = ProbeResult.unavailable("cuda")
    if p.available == false:
        if p.vendor == "cuda":
            print("PASS: test_gpu_probe_unavailable")
            return
    print("FAIL: test_gpu_probe_unavailable")

fn test_gpu_probe_available():
    val p = ProbeResult.available("amd", "vulkan", 8192)
    if p.available:
        if p.backend == "vulkan":
            if p.vram_mb == 8192:
                print("PASS: test_gpu_probe_available")
                return
    print("FAIL: test_gpu_probe_available")

fn test_gpu_best_selection():
    val cuda = ProbeResult.available("cuda", "cuda", 16384)
    val amd = ProbeResult.available("amd", "vulkan", 8192)
    var best = "none"
    if cuda.available:
        best = "cuda"
    elif amd.available:
        best = "amd"
    if best == "cuda":
        print("PASS: test_gpu_best_selection")
    else:
        print("FAIL: test_gpu_best_selection")

fn test_ring_buffer_advance():
    var rb = RingBuf.create(4)
    rb.advance_write()
    rb.advance_write()
    if rb.write_pos == 2:
        if rb.is_empty() == false:
            print("PASS: test_ring_buffer_advance")
            return
    print("FAIL: test_ring_buffer_advance")

fn test_ring_buffer_wrap():
    var rb = RingBuf.create(4)
    rb.advance_write()
    rb.advance_write()
    rb.advance_write()
    rb.advance_write()
    if rb.write_pos == 0:
        print("PASS: test_ring_buffer_wrap")
    else:
        print("FAIL: test_ring_buffer_wrap")

fn test_mixer_muted():
    var m = MixerState.create(75)
    m.muted = true
    if m.effective() == 0:
        print("PASS: test_mixer_muted")
    else:
        print("FAIL: test_mixer_muted")

fn test_mixer_unmuted():
    var m = MixerState.create(80)
    if m.effective() == 80:
        print("PASS: test_mixer_unmuted")
    else:
        print("FAIL: test_mixer_unmuted")

fn test_key_press():
    val ev = KeyEv.press(30, 1, 1000)
    if ev.pressed:
        if ev.has_shift():
            print("PASS: test_key_press")
            return
    print("FAIL: test_key_press")

fn test_key_release():
    val ev = KeyEv.release(30, 0, 2000)
    if ev.pressed == false:
        if ev.has_shift() == false:
            print("PASS: test_key_release")
            return
    print("FAIL: test_key_release")

fn test_bar_grant_lifecycle():
    var bg = BarGrant.request(2)
    if bg.granted == false:
        bg.grant(42)
        if bg.granted:
            if bg.token == 42:
                bg.revoke()
                if bg.granted == false:
                    print("PASS: test_bar_grant_lifecycle")
                    return
    print("FAIL: test_bar_grant_lifecycle")

fn test_iommu_domain_isolation():
    var bg1 = BarGrant.request(0)
    var bg2 = BarGrant.request(1)
    bg1.grant(100)
    bg2.grant(101)
    if bg1.token == 100:
        if bg2.token == 101:
            bg1.revoke()
            if bg1.granted == false:
                if bg2.granted:
                    print("PASS: test_iommu_domain_isolation")
                    return
    print("FAIL: test_iommu_domain_isolation")

fn test_layer_kernel_no_imports():
    val k = LayerCheck.kernel()
    if k.can_import(0):
        if k.can_import(1) == false:
            print("PASS: test_layer_kernel_no_imports")
            return
    print("FAIL: test_layer_kernel_no_imports")

fn test_layer_driver_imports():
    val d = LayerCheck.driver()
    if d.can_import(0):
        if d.can_import(1):
            if d.can_import(2) == false:
                print("PASS: test_layer_driver_imports")
                return
    print("FAIL: test_layer_driver_imports")

fn test_layer_app_imports():
    val a = LayerCheck.app()
    if a.can_import(0):
        if a.can_import(1):
            if a.can_import(2):
                if a.can_import(3) == false:
                    print("PASS: test_layer_app_imports")
                    return
    print("FAIL: test_layer_app_imports")

fn test_lane_gate_not_ready():
    var g = LaneGate.create("gpu")
    g.has_contract = true
    g.has_tests = true
    if g.is_ready() == false:
        print("PASS: test_lane_gate_not_ready")
    else:
        print("FAIL: test_lane_gate_not_ready")

fn test_lane_gate_ready():
    var g = LaneGate.create("audio")
    g.has_contract = true
    g.has_tests = true
    g.has_docs = true
    g.has_reviewer = true
    if g.is_ready():
        print("PASS: test_lane_gate_ready")
    else:
        print("FAIL: test_lane_gate_ready")

fn test_lane_gate_blocked():
    var g = LaneGate.create("input")
    g.has_contract = true
    g.has_tests = true
    g.has_docs = true
    g.has_reviewer = true
    g.blockers = 1
    if g.is_ready() == false:
        print("PASS: test_lane_gate_blocked")
    else:
        print("FAIL: test_lane_gate_blocked")

fn test_five_lane_readiness():
    var ready_count = 0
    var lane_a = LaneGate.create("gpu")
    lane_a.has_contract = true
    lane_a.has_tests = true
    lane_a.has_docs = true
    lane_a.has_reviewer = true
    if lane_a.is_ready():
        ready_count = ready_count + 1
    var lane_b = LaneGate.create("audio")
    lane_b.has_contract = true
    if lane_b.is_ready() == false:
        ready_count = ready_count + 0
    if ready_count == 1:
        print("PASS: test_five_lane_readiness")
    else:
        print("FAIL: test_five_lane_readiness")

fn main():
    test_gpu_probe_unavailable()
    test_gpu_probe_available()
    test_gpu_best_selection()
    test_ring_buffer_advance()
    test_ring_buffer_wrap()
    test_mixer_muted()
    test_mixer_unmuted()
    test_key_press()
    test_key_release()
    test_bar_grant_lifecycle()
    test_iommu_domain_isolation()
    test_layer_kernel_no_imports()
    test_layer_driver_imports()
    test_layer_app_imports()
    test_lane_gate_not_ready()
    test_lane_gate_ready()
    test_lane_gate_blocked()
    test_five_lane_readiness()
    print("DONE")
