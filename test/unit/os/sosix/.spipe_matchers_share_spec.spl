# @cover src/os/sosix/share.spl 80%
"""
# SOSIX Share Specification

SOSIX process sharing is immutable-data plus queue coordination.
"""

use std.spec
use os.posix.errno.{EAGAIN, EBADF, EINVAL}
use os.sosix.share.{
    SOSIX_NO_DATASET,
    SOSIX_POLL_READ,
    SOSIX_POLL_WRITE,
    SOSIX_POLL_HUP,
    SOSIX_QUEUE_CLOSE_SEND,
    sosix_share_init,
    sosix_dataset_create,
    sosix_dataset_write,
    sosix_dataset_seal,
    sosix_dataset_is_sealed,
    sosix_dataset_size,
    sosix_dataset_read_byte,
    sosix_dataset_close,
    sosix_dataset_handle_slot,
    sosix_dataset_handle_generation,
    sosix_queue_create,
    sosix_queue_send,
    sosix_queue_recv,
    sosix_queue_poll,
    sosix_queue_close,
    sosix_queue_handle_slot,
    sosix_queue_handle_generation
}

describe "SOSIX immutable datasets":
    it "allows writes before seal and reads after seal":
        sosix_share_init()
        val handle = sosix_dataset_create(4u64, 0)

        expect handle == 0
        expect sosix_dataset_write(handle as u64, 0u64, [1u8, 2u8, 3u8, 4u8]) == 4
        expect sosix_dataset_seal(handle as u64) == 0
        expect sosix_dataset_is_sealed(handle as u64) == true
        expect sosix_dataset_size(handle as u64) == 4u64
        expect sosix_dataset_handle_slot(handle as u64) == 0
        expect sosix_dataset_handle_generation(handle as u64) == 0
        expect sosix_dataset_read_byte(handle as u64, 2u64) == 3

    it "rejects writes after seal":
        sosix_share_init()
        val handle = sosix_dataset_create(2u64, 0)

        expect sosix_dataset_seal(handle as u64) == 0
        expect sosix_dataset_write(handle as u64, 0u64, [9u8]) == 0 - EINVAL as i64

    it "rejects invalid dataset reads":
        sosix_share_init()

        expect sosix_dataset_read_byte(99u64, 0u64) == 0 - EBADF as i64
        expect sosix_dataset_create(0u64, 0) == 0 - EINVAL as i64

describe "SOSIX process queues":
    it "sends and receives FIFO messages":
        sosix_share_init()
        val queue = sosix_queue_create(2u64, 8u64, 0)

        expect queue == 0
        expect sosix_queue_poll(queue as u64) & SOSIX_POLL_WRITE == SOSIX_POLL_WRITE
        expect sosix_queue_send(queue as u64, [10u8, 11u8], SOSIX_NO_DATASET) == 2
        expect sosix_queue_poll(queue as u64) & SOSIX_POLL_READ == SOSIX_POLL_READ

        val recv = sosix_queue_recv(queue as u64)
        expect recv.status == 2
        expect recv.len == 2u64
        expect recv.attached_dataset == SOSIX_NO_DATASET
        expect recv.data[0] == 10u8
        expect recv.data[1] == 11u8

    it "attaches sealed datasets to queue messages":
        sosix_share_init()
        val dataset = sosix_dataset_create(1u64, 0)
        val queue = sosix_queue_create(1u64, 4u64, 0)

        expect sosix_dataset_write(dataset as u64, 0u64, [55u8]) == 1
        expect sosix_dataset_seal(dataset as u64) == 0
        expect sosix_queue_send(queue as u64, [1u8], dataset as u64) == 1

        val recv = sosix_queue_recv(queue as u64)
        expect recv.status == 1
        expect recv.attached_dataset == dataset as u64
        expect sosix_dataset_read_byte(recv.attached_dataset, 0u64) == 55

    it "rejects unsealed dataset attachments":
        sosix_share_init()
        val dataset = sosix_dataset_create(1u64, 0)
        val queue = sosix_queue_create(1u64, 4u64, 0)

        expect sosix_queue_send(queue as u64, [1u8], dataset as u64) == 0 - EINVAL as i64

    it "reports full and empty queue readiness":
        sosix_share_init()
        val queue = sosix_queue_create(1u64, 4u64, 0)

        expect sosix_queue_recv(queue as u64).status == 0 - EAGAIN as i64
        expect sosix_queue_send(queue as u64, [1u8], SOSIX_NO_DATASET) == 1
        expect sosix_queue_send(queue as u64, [2u8], SOSIX_NO_DATASET) == 0 - EAGAIN as i64

    it "reports HUP after send-side close":
        sosix_share_init()
        val queue = sosix_queue_create(1u64, 4u64, 0)

        expect sosix_queue_close(queue as u64, SOSIX_QUEUE_CLOSE_SEND) == 0
        expect sosix_queue_poll(queue as u64) & SOSIX_POLL_HUP == SOSIX_POLL_HUP
        expect sosix_queue_recv(queue as u64).status == 0

    it "closes datasets and rejects later use":
        sosix_share_init()
        val dataset = sosix_dataset_create(1u64, 0)

        expect sosix_dataset_close(dataset as u64) == 0
        expect sosix_dataset_seal(dataset as u64) == 0 - EBADF as i64

        val second = sosix_dataset_create(1u64, 0)
        expect sosix_dataset_handle_slot(second as u64) == 0
        expect sosix_dataset_handle_generation(second as u64) == 1
        expect second == 65536
        expect sosix_dataset_read_byte(dataset as u64, 0u64) == 0 - EBADF as i64

    it "rejects stale queue handles after full close":
        sosix_share_init()
        val queue = sosix_queue_create(1u64, 4u64, 0)

        expect sosix_queue_handle_slot(queue as u64) == 0
        expect sosix_queue_handle_generation(queue as u64) == 0
        expect sosix_queue_close(queue as u64, 0) == 0
        expect sosix_queue_send(queue as u64, [1u8], SOSIX_NO_DATASET) == 0 - EBADF as i64

        val second = sosix_queue_create(1u64, 4u64, 0)
        expect sosix_queue_handle_slot(second as u64) == 0
        expect sosix_queue_handle_generation(second as u64) == 1
        expect second == 65536
        expect sosix_queue_recv(queue as u64).status == 0 - EBADF as i64