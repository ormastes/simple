# @cover src/os/sosix/io_state.spl 80%
"""
# SOSIX Async I/O Specification

SOSIX owns the async file I/O request pool and backend routing. POSIX keeps
compatibility wrappers over these APIs.
"""

use std.spec
use os.posix.errno.{EIO}
use os.posix.fd_table.{FD_TYPE_FILE, FD_TYPE_SERIAL, FD_TYPE_PIPE_READ, FD_TYPE_PIPE_WRITE, FD_TYPE_FREE}
use os.sosix.io_state.{
    SOSIX_IO_BACKEND_INVALID,
    SOSIX_IO_BACKEND_SERIAL,
    SOSIX_IO_BACKEND_VFS,
    SOSIX_MAX_ASYNC_REQUESTS,
    sosix_io_backend_for_fd_type,
    sosix_io_init,
    sosix_async_alloc_request,
    sosix_async_free_request,
    sosix_async_is_complete,
    sosix_async_get_result
}

describe "SOSIX async I/O backend ownership":
    it "owns serial descriptors":
        expect sosix_io_backend_for_fd_type(FD_TYPE_SERIAL) == SOSIX_IO_BACKEND_SERIAL

    it "owns VFS-backed file descriptors":
        expect sosix_io_backend_for_fd_type(FD_TYPE_FILE) == SOSIX_IO_BACKEND_VFS

    it "does not own pipe descriptors":
        expect sosix_io_backend_for_fd_type(FD_TYPE_PIPE_READ) == SOSIX_IO_BACKEND_INVALID
        expect sosix_io_backend_for_fd_type(FD_TYPE_PIPE_WRITE) == SOSIX_IO_BACKEND_INVALID

    it "rejects free descriptors":
        expect sosix_io_backend_for_fd_type(FD_TYPE_FREE) == SOSIX_IO_BACKEND_INVALID

describe "SOSIX async I/O request lifecycle":
    it "allocates pending requests and frees them for reuse":
        sosix_io_init()

        val req = sosix_async_alloc_request()
        expect req < SOSIX_MAX_ASYNC_REQUESTS
        expect sosix_async_is_complete(req) == false

        sosix_async_free_request(req)
        val reused = sosix_async_alloc_request()
        expect reused == req

    it "treats invalid request handles as completed EIO":
        expect sosix_async_is_complete(SOSIX_MAX_ASYNC_REQUESTS) == true
        expect sosix_async_get_result(SOSIX_MAX_ASYNC_REQUESTS) == 0 - EIO as i64