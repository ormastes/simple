fn check(n: text, v: bool):
    if v:
        print "OK: {n}"
    else:
        print "FAIL: {n}"

fn shr(x: i64, n: i64) -> i64:
    x / (1 << n)

fn gdt_lo(base: i64, limit: i64) -> i64:
    (limit & 0xFFFF) | ((base & 0xFFFF) << 16)

fn main():
    print "=== GDT ==="
    check("lim", (gdt_lo(0, 0xFFFF) & 0xFFFF) == 0xFFFF)
    check("base", shr(gdt_lo(0x1000, 0) & 0xFFFF0000, 16) == 0x1000)
    check("both", gdt_lo(0x1000, 0xFFFF) == 0x1000FFFF)
    check("zero", gdt_lo(0, 0) == 0)
    print "=== DONE ==="
