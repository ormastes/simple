use std.spipe.*
use os.crypto.ecdh_p256.{p256_keypair_pub, p256_ecdh_shared_x}

fn _trivial() -> [u8]:
    var s: [u8] = []
    s.push(0x01u8)
    s

fn _cs() -> [u8]:
    var s: [u8] = []
    s.push(0x31u8)
    s.push(0x32u8)
    s.push(0x33u8)
    s.push(0x34u8)
    s.push(0x35u8)
    s.push(0x36u8)
    s.push(0x37u8)
    s.push(0x38u8)
    s.push(0x39u8)
    s.push(0x3au8)
    s.push(0x3bu8)
    s.push(0x3cu8)
    s.push(0x3du8)
    s.push(0x3eu8)
    s.push(0x3fu8)
    s.push(0x40u8)
    s.push(0x41u8)
    s.push(0x42u8)
    s.push(0x43u8)
    s.push(0x44u8)
    s.push(0x45u8)
    s.push(0x46u8)
    s.push(0x47u8)
    s.push(0x48u8)
    s.push(0x49u8)
    s.push(0x4au8)
    s.push(0x4bu8)
    s.push(0x4cu8)
    s.push(0x4du8)
    s.push(0x4eu8)
    s.push(0x4fu8)
    s.push(0x50u8)
    s

describe "probe":
    it "smoke len inline":
        var s: [u8] = []
        var i: u64 = 0u64
        while i < 31u64:
            s.push(0x00u8)
            i = i + 1u64
        s.push(0x01u8)
        val out = p256_keypair_pub(s)
        expect out.len().to_u64() == 65u64

    it "smoke len fn-result-stored":
        val s: [u8] = _cs()
        val out = p256_keypair_pub(s)
        expect out.len().to_u64() == 65u64

    it "smoke len fn-direct":
        val out = p256_keypair_pub(_cs())
        expect out.len().to_u64() == 65u64

    it "trivial fn":
        val s: [u8] = _trivial()
        expect s.len().to_u64() == 1u64