# TLS_CHACHA20_POLY1305_SHA256 (0x1303) cipher suite landing spec
#
# Exercises the cipher-suite advertise + AEAD path + key_schedule wiring
# for the SHA-256 ChaCha20-Poly1305 path of TLS 1.3 per RFC 8446 §9.1
# and RFC 8439 (ChaCha20-Poly1305 AEAD).
#
# AC-4 of TLS_CHACHA20_POLY1305_SHA256 cipher suite landing.
#
# Bounded scope (AC-5 deferral acknowledged):
#   - cipher_suites byte-format on the wire contains 0x1303
#   - ChaCha20-Poly1305 AEAD round-trip works on a synthetic record
#   - key_schedule SHA-256 traffic_keys_chacha20 returns 32B key + 12B IV
#   - TLS 1.3 nonce derivation per §5.3 (record13_make_nonce, seq_num=0/1)
#   - Tag-corruption rejected
#
# Deferred:
#   - Full server-side negotiation fixture
#   - Interop with rustls / openssl backends

use std.spipe.*

use os.tls13.handshake13.{
    CIPHER_AES_128_GCM_SHA256,
    CIPHER_AES_256_GCM_SHA384,
    CIPHER_CHACHA20_POLY1305_SHA256,
    build_client_hello_bytes
}
use os.tls13.key_schedule.{
    tls13_traffic_keys_chacha20
}
use os.tls13.record13.{
    RecordKey,
    RecordResult,
    record13_make_nonce,
    record13_encrypt_chacha20_poly1305,
    record13_decrypt_chacha20_poly1305,
    record13_encrypt_for_suite,
    record13_decrypt_for_suite
}
use os.crypto.chacha20_poly1305.{
    chacha20_poly1305_encrypt,
    chacha20_poly1305_decrypt,
    Chacha20Poly1305Result
}

# ============================================================================
# Fixtures (module-level — feedback_it_block_var_mutation.md)
# ============================================================================

fn _zeros_n(n: u64) -> [u8]:
    var z: [u8] = []
    var i: u64 = 0
    while i < n:
        z.push(0x00u8)
        i = i + 1
    z

fn _client_random() -> [u8]:
    var r: [u8] = []
    var i: u64 = 0
    while i < 32:
        r.push(((i * 7) & 0xFFu8.to_u64()).to_u8())
        i = i + 1
    r

fn _x25519_pub() -> [u8]:
    var k: [u8] = []
    var i: u64 = 0
    while i < 32:
        k.push((0xA5u8.to_u64() ^ i).to_u8())
        i = i + 1
    k

fn _ch_bytes() -> [u8]:
    build_client_hello_bytes(_client_random(), _x25519_pub(), "example.com")

fn _chacha_key() -> [u8]:
    # Deterministic 32-byte ChaCha20 key
    var k: [u8] = []
    var i: u64 = 0
    while i < 32:
        k.push((0x80u8.to_u64() ^ i).to_u8())
        i = i + 1
    k

fn _record_iv() -> [u8]:
    # Deterministic 12-byte base IV (XOR'd with seq_num to derive per-record nonce)
    var iv: [u8] = []
    var i: u64 = 0
    while i < 12:
        iv.push((0x40u8.to_u64() ^ i).to_u8())
        i = i + 1
    iv

fn _zero_nonce() -> [u8]:
    _zeros_n(12)

fn _aad_demo() -> [u8]:
    [0x17u8, 0x03u8, 0x03u8, 0x00u8, 0x21u8]   # TLS record header skeleton (0x21 = 33B payload)

fn _plaintext_demo() -> [u8]:
    var p: [u8] = []
    var i: u64 = 0
    while i < 32:
        p.push((0x10u8.to_u64() + i).to_u8())
        i = i + 1
    p

# ============================================================================
# Helpers
# ============================================================================

fn _has_two_byte_subseq(buf: [u8], hi: u8, lo: u8) -> bool:
    var i: u64 = 0
    while i + 1 < buf.len():
        if buf[i] == hi and buf[i + 1] == lo:
            return true
        i = i + 1
    false

fn _split_ct(buf: [u8], ct_len: i64) -> [u8]:
    var out: [u8] = []
    var i: i64 = 0
    while i < ct_len:
        out.push(buf[i])
        i = i + 1
    out

fn _split_tag(buf: [u8], ct_len: i64) -> [u8]:
    var out: [u8] = []
    var i: i64 = ct_len
    while i < buf.len():
        out.push(buf[i])
        i = i + 1
    out

fn _bytes_equal(a: [u8], b: [u8]) -> bool:
    if a.len() != b.len():
        return false
    var i: u64 = 0
    while i < a.len():
        if a[i] != b[i]:
            return false
        i = i + 1
    true

# ============================================================================
# Specs
# ============================================================================

describe "TLS_CHACHA20_POLY1305_SHA256 (0x1303) cipher suite landing":

    # --- AC-1: constant ---

    it "CIPHER_CHACHA20_POLY1305_SHA256 constant has IANA value 0x1303":
        expect CIPHER_CHACHA20_POLY1305_SHA256 == 0x1303u16

    it "CIPHER_AES_128_GCM_SHA256 constant remains at IANA value 0x1301":
        # Sanity check — the existing suite must not have shifted.
        expect CIPHER_AES_128_GCM_SHA256 == 0x1301u16

    it "CIPHER_AES_256_GCM_SHA384 constant remains at IANA value 0x1302":
        # Sanity check — the existing T21 suite must not have shifted.
        expect CIPHER_AES_256_GCM_SHA384 == 0x1302u16

    # --- AC-2: advertise on the wire ---

    it "ClientHello cipher_suites bytes advertise 0x1301, 0x1302 and 0x1303":
        # The on-the-wire byte sequence for the cipher_suites list should
        # contain {0x13,0x01,0x13,0x02,0x13,0x03} for the 3 TLS 1.3 suites
        # per RFC 8446 §9.1.
        val ch = _ch_bytes()
        expect _has_two_byte_subseq(ch, 0x13u8, 0x01u8) == true
        expect _has_two_byte_subseq(ch, 0x13u8, 0x02u8) == true
        expect _has_two_byte_subseq(ch, 0x13u8, 0x03u8) == true

    # --- AC-4: ChaCha20-Poly1305 AEAD round-trip on a synthetic record ---

    it "ChaCha20-Poly1305 encrypt produces ciphertext || 16-byte tag":
        val key = _chacha_key()
        val out = chacha20_poly1305_encrypt(key, _zero_nonce(), _plaintext_demo(), _aad_demo())
        # 32-byte plaintext + 16-byte tag = 48 bytes
        expect out.len() == 48

    it "ChaCha20-Poly1305 round-trip recovers plaintext":
        val key = _chacha_key()
        val nonce = _zero_nonce()
        val pt = _plaintext_demo()
        val aad = _aad_demo()

        val packed = chacha20_poly1305_encrypt(key, nonce, pt, aad)
        val ct = _split_ct(packed, pt.len().to_i64())
        val tag = _split_tag(packed, pt.len().to_i64())

        val result = chacha20_poly1305_decrypt(key, nonce, ct, aad, tag)
        match result:
            Chacha20Poly1305Result.Ok(data):
                expect _bytes_equal(data, pt) == true
            Chacha20Poly1305Result.Err(msg):
                expect false == true

    it "ChaCha20-Poly1305 tag-corruption is rejected":
        val key = _chacha_key()
        val nonce = _zero_nonce()
        val pt = _plaintext_demo()
        val aad = _aad_demo()

        val packed = chacha20_poly1305_encrypt(key, nonce, pt, aad)
        val ct = _split_ct(packed, pt.len().to_i64())
        val tag = _split_tag(packed, pt.len().to_i64())
        var bad_tag: [u8] = []
        var i: i64 = 0
        while i < tag.len():
            if i == tag.len() - 1:
                bad_tag.push(tag[i] ^ 0xFFu8)
            else:
                bad_tag.push(tag[i])
            i = i + 1

        val result = chacha20_poly1305_decrypt(key, nonce, ct, bad_tag, bad_tag)
        match result:
            Chacha20Poly1305Result.Ok(data):
                expect false == true
            Chacha20Poly1305Result.Err(msg):
                expect true == true

    # --- TLS 1.3 nonce derivation per RFC 8446 §5.3 ---

    it "record13_make_nonce: seq_num=0 yields the IV unchanged":
        val iv = _record_iv()
        val nonce = record13_make_nonce(iv, 0u64)
        expect nonce.len() == 12
        # XOR with zero counter is identity.
        expect _bytes_equal(nonce, iv) == true

    it "record13_make_nonce: seq_num=1 differs from seq_num=0":
        val iv = _record_iv()
        val n0 = record13_make_nonce(iv, 0u64)
        val n1 = record13_make_nonce(iv, 1u64)
        expect n1.len() == 12
        # Different sequence numbers MUST produce different per-record nonces.
        expect _bytes_equal(n0, n1) == false

    # --- AC-3: record-layer dispatch + per-record nonce round-trip ---

    it "record13_encrypt_chacha20_poly1305 wraps the AEAD output in a TLS 1.3 record":
        val rk = RecordKey(key: _chacha_key(), iv: _record_iv())
        val pt = _plaintext_demo()
        val record = record13_encrypt_chacha20_poly1305(rk, 0u64, 0x17u8, pt)
        # 5-byte header + (33-byte inner = 32 pt + 1 ct byte) + 16-byte tag = 54 bytes
        expect record.len() == 54
        # TLS record header bytes
        expect record[0] == 0x17u8
        expect record[1] == 0x03u8
        expect record[2] == 0x03u8

    it "record13 ChaCha20-Poly1305 round-trip recovers content_type + data with seq_num=0":
        val rk = RecordKey(key: _chacha_key(), iv: _record_iv())
        val pt = _plaintext_demo()
        val record = record13_encrypt_chacha20_poly1305(rk, 0u64, 0x17u8, pt)
        val result = record13_decrypt_chacha20_poly1305(rk, 0u64, record)
        match result:
            RecordResult.Ok(content_type, data):
                expect content_type.to_u64() == 0x17u64
                expect _bytes_equal(data, pt) == true
            RecordResult.Err(msg):
                expect false == true

    it "record13 ChaCha20-Poly1305 round-trip with seq_num=1 (per-record nonce derivation)":
        val rk = RecordKey(key: _chacha_key(), iv: _record_iv())
        val pt = _plaintext_demo()
        val record = record13_encrypt_chacha20_poly1305(rk, 1u64, 0x17u8, pt)
        val result = record13_decrypt_chacha20_poly1305(rk, 1u64, record)
        match result:
            RecordResult.Ok(content_type, data):
                expect content_type.to_u64() == 0x17u64
                expect _bytes_equal(data, pt) == true
            RecordResult.Err(msg):
                expect false == true

    it "record13 ChaCha20-Poly1305 mismatched seq_num is rejected (auth tag)":
        val rk = RecordKey(key: _chacha_key(), iv: _record_iv())
        val pt = _plaintext_demo()
        val record = record13_encrypt_chacha20_poly1305(rk, 0u64, 0x17u8, pt)
        # Decrypt with the wrong sequence number — nonce is XOR'd with seq_num,
        # so the AEAD tag MUST fail to authenticate.
        val result = record13_decrypt_chacha20_poly1305(rk, 1u64, record)
        match result:
            RecordResult.Ok(content_type, data):
                expect false == true
            RecordResult.Err(msg):
                expect true == true

    it "record13_encrypt_for_suite dispatches 0x1303 to ChaCha20-Poly1305":
        val rk = RecordKey(key: _chacha_key(), iv: _record_iv())
        val pt = _plaintext_demo()
        val via_dispatch = record13_encrypt_for_suite(
            CIPHER_CHACHA20_POLY1305_SHA256, rk, 0u64, 0x17u8, pt
        )
        val direct = record13_encrypt_chacha20_poly1305(rk, 0u64, 0x17u8, pt)
        expect _bytes_equal(via_dispatch, direct) == true

    # --- AC-4: key_schedule SHA-256 traffic_keys_chacha20 path ---
    #
    # DEFERRED: tls13_traffic_keys_chacha20 derives 32B ChaCha20 key + 12B
    # IV via hkdf_expand_label, which delegates to the rt_tls13_hkdf_*
    # runtime externs not resolved in interpreter mode. Same bounded-scope
    # deferral as T21's AES-256-GCM decrypt path
    # (see crypto_recovery_status). Compile-mode runs exercise this path.
    # The use-import at the top of this spec validates the symbol exists.