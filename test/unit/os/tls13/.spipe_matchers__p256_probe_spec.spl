use std.spipe.*
use os.crypto.ecdh_p256.{p256_keypair_pub}

describe "probe":
    it "smoke":
        var s: [u8] = []
        var i: u64 = 0
        while i < 31:
            s.push(0x00u8)
            i = i + 1
        s.push(0x01u8)
        val out = p256_keypair_pub(s)
        expect out.len().to_u64() == 65u64