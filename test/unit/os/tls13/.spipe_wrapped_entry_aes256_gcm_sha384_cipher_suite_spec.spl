use std.spipe.*
use os.tls13.handshake13.{
use os.tls13.key_schedule.{
use os.crypto.aes256_gcm.{

fn _zeros_n(n: u64) -> [u8]:
    var z: [u8] = []
    var i: u64 = 0
    while i < n:
        z.push(0x00u8)
        i = i + 1
    z

fn _client_random() -> [u8]:
    # Deterministic 32-byte client random
    var r: [u8] = []
    var i: u64 = 0
    while i < 32:
        r.push(((i * 7) & 0xFFu8.to_u64()).to_u8())
        i = i + 1
    r

fn _x25519_pub() -> [u8]:
    var k: [u8] = []
    var i: u64 = 0
    while i < 32:
        k.push((0xA5u8.to_u64() ^ i).to_u8())
        i = i + 1
    k

fn _ch_bytes() -> [u8]:
    build_client_hello_bytes(_client_random(), _x25519_pub(), "example.com")

fn _dhe_shared() -> [u8]:
    var s: [u8] = []
    var i: u64 = 0
    while i < 32:
        s.push(0x42u8)
        i = i + 1
    s

fn _zero_nonce() -> [u8]:
    _zeros_n(12)

fn _aad_demo() -> [u8]:
    [0x17u8, 0x03u8, 0x03u8, 0x00u8, 0x10u8]   # TLS record header skeleton

fn _plaintext_demo() -> [u8]:
    var p: [u8] = []
    var i: u64 = 0
    while i < 32:
        p.push((0x10u8.to_u64() + i).to_u8())
        i = i + 1
    p

fn _has_two_byte_subseq(buf: [u8], hi: u8, lo: u8) -> bool:
    var i: u64 = 0
    while i + 1 < buf.len():
        if buf[i] == hi and buf[i + 1] == lo:
            return true
        i = i + 1
    false

fn _split_ct(buf: [u8], ct_len: i64) -> [u8]:
    var out: [u8] = []
    var i: i64 = 0
    while i < ct_len:
        out.push(buf[i])
        i = i + 1
    out

fn _split_tag(buf: [u8], ct_len: i64) -> [u8]:
    var out: [u8] = []
    var i: i64 = ct_len
    while i < buf.len():
        out.push(buf[i])
        i = i + 1
    out

fn main():
    # TLS_AES_256_GCM_SHA384 (0x1302) cipher suite landing spec
    #
    # Exercises the cipher-suite advertise + AEAD path + key_schedule wiring
    # for the SHA-384 path of TLS 1.3 per RFC 8446 §9.1.
    #
    # AC-8 of TLS_AES_256_GCM_SHA384 cipher suite landing.
    #
    # Bounded scope (AC-9 deferral acknowledged):
    #   - cipher_suites byte-format on the wire contains 0x1302
    #   - AES-256-GCM AEAD round-trip works on a synthetic Transcript
    #   - key_schedule SHA-384 path produces correct fixed-shape outputs
    #     (48-byte handshake_secret, 32-byte key, 12-byte IV)
    #
    # Deferred:
    #   - Full server-side negotiation fixture
    #   - Interop with rustls / openssl backends


        CIPHER_AES_128_GCM_SHA256,
        CIPHER_AES_256_GCM_SHA384,
        build_client_hello_bytes
    }
        tls13_early_secret_sha384,
        tls13_handshake_secret_sha384,
        tls13_traffic_keys_sha384,
        TrafficKeys
    }
        aes256_gcm_encrypt,
        aes256_gcm_decrypt,
        Aes256GcmResult
    }

    # ============================================================================
    # Fixtures (module-level — feedback_it_block_var_mutation.md)
    # ============================================================================

    # Synthetic 32-byte DHE shared secret for the SHA-384 key schedule
    # 12-byte all-zero nonce — TLS 1.3 nonce shape
    # ============================================================================
    # Helpers
    # ============================================================================

    # ============================================================================
    # Specs
    # ============================================================================

    describe "TLS_AES_256_GCM_SHA384 (0x1302) cipher suite landing":

        # --- AC-5: advertise on the wire ---

        it "CIPHER_AES_256_GCM_SHA384 constant has IANA value 0x1302":
            expect CIPHER_AES_256_GCM_SHA384 == 0x1302u16

        it "CIPHER_AES_128_GCM_SHA256 constant remains at IANA value 0x1301":
            # Sanity check — the existing suite must not have shifted.
            expect CIPHER_AES_128_GCM_SHA256 == 0x1301u16

        it "ClientHello cipher_suites bytes advertise 0x1301 then 0x1302":
            # The on-the-wire byte sequence for the cipher_suites list should
            # contain {0x13,0x01,0x13,0x02} consecutively for the 2 mandatory
            # TLS 1.3 suites per RFC 8446 §9.1.
            val ch = _ch_bytes()
            # 0x13 0x01 (TLS_AES_128_GCM_SHA256) appears
            expect _has_two_byte_subseq(ch, 0x13u8, 0x01u8) == true
            # 0x13 0x02 (TLS_AES_256_GCM_SHA384) appears
            expect _has_two_byte_subseq(ch, 0x13u8, 0x02u8) == true

        # --- AC-8: AEAD round-trip on a synthetic Transcript ---

        it "AES-256-GCM encrypt produces ciphertext || 16-byte tag":
            val key = _zeros_n(32)
            val out = aes256_gcm_encrypt(key, _zero_nonce(), _plaintext_demo(), _aad_demo())
            # 32-byte plaintext + 16-byte tag = 48 bytes
            expect out.len() == 48

        it "AES-256-GCM round-trip recovers plaintext for synthetic record":
            val key = _zeros_n(32)
            val nonce = _zero_nonce()
            val pt = _plaintext_demo()
            val aad = _aad_demo()

            val packed = aes256_gcm_encrypt(key, nonce, pt, aad)
            val ct = _split_ct(packed, pt.len().to_i64())
            val tag = _split_tag(packed, pt.len().to_i64())

            val result = aes256_gcm_decrypt(key, nonce, ct, aad, tag)
            match result:
                Aes256GcmResult.Ok(data):
                    expect data == pt
                Aes256GcmResult.Err(msg):
                    expect false == true

        it "AES-256-GCM tag-corruption is rejected":
            val key = _zeros_n(32)
            val nonce = _zero_nonce()
            val pt = _plaintext_demo()
            val aad = _aad_demo()

            val packed = aes256_gcm_encrypt(key, nonce, pt, aad)
            val ct = _split_ct(packed, pt.len().to_i64())
            val tag = _split_tag(packed, pt.len().to_i64())
            var bad_tag: [u8] = []
            var i: i64 = 0
            while i < tag.len():
                if i == tag.len() - 1:
                    bad_tag.push(tag[i] ^ 0xFFu8)
                else:
                    bad_tag.push(tag[i])
                i = i + 1

            val result = aes256_gcm_decrypt(key, nonce, ct, aad, bad_tag)
            match result:
                Aes256GcmResult.Ok(data):
                    expect false == true
                Aes256GcmResult.Err(msg):
                    expect true == true

        # --- AC-6: key_schedule SHA-384 path ---

        it "SHA-384 early_secret has 48-byte length":
            val es = tls13_early_secret_sha384()
            expect es.len() == 48

        it "SHA-384 handshake_secret has 48-byte length":
            val es = tls13_early_secret_sha384()
            val hs = tls13_handshake_secret_sha384(es, _dhe_shared())
            expect hs.len() == 48

        it "SHA-384 handshake_secret is deterministic for fixed inputs":
            val es = tls13_early_secret_sha384()
            val hs1 = tls13_handshake_secret_sha384(es, _dhe_shared())
            val hs2 = tls13_handshake_secret_sha384(es, _dhe_shared())
            expect hs1 == hs2

        it "SHA-384 traffic keys produce 32-byte AES-256 key + 12-byte IV":
            val traffic_secret = _zeros_n(48)
            val tk = tls13_traffic_keys_sha384(traffic_secret)
            expect tk.key.len() == 32
            expect tk.iv.len() == 12