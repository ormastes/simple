# KeyUpdate spec — RFC 8446 §4.6.3
#
# Exercises:
#   - parse_key_update: update_not_requested(0), update_requested(1),
#     invalid value, empty payload.
#   - emit_key_update: wire format (type=24, length=3 BE zeros+1, body byte).
#   - Round-trip: emit → strip header → parse.
#   - derive_next_traffic_secret: deterministic, SHA-256 path (hash_len=32)
#     produces 32 bytes, SHA-384 path (hash_len=48) produces 48 bytes,
#     and two calls from the same secret agree.

use std.spipe.*
use os.tls13.key_update.{
    KeyUpdateRequest,
    HS_KEY_UPDATE,
    parse_key_update,
    emit_key_update,
    derive_next_traffic_secret
}

# ============================================================================
# Module-level body-builder helpers
# (it-block var rebinds are not safe in interpreter mode — build payloads here)
# ============================================================================

fn _payload_not_requested() -> [u8]:
    [0x00u8]

fn _payload_requested() -> [u8]:
    [0x01u8]

fn _payload_invalid() -> [u8]:
    [0x02u8]

fn _payload_empty() -> [u8]:
    []

fn _strip_header(msg: [u8]) -> [u8]:
    # Strips the 4-byte handshake header; returns body bytes
    if msg.len() < 5:
        return []
    var body: [u8] = []
    var i: u64 = 4
    while i < msg.len():
        body.push(msg[i])
        i = i + 1
    body

fn _zeros_32() -> [u8]:
    var z: [u8] = []
    var i: u64 = 0
    while i < 32:
        z.push(0x00u8)
        i = i + 1
    z

fn _zeros_48() -> [u8]:
    var z: [u8] = []
    var i: u64 = 0
    while i < 48:
        z.push(0x00u8)
        i = i + 1
    z

fn _ones_32() -> [u8]:
    var z: [u8] = []
    var i: u64 = 0
    while i < 32:
        z.push(0x01u8)
        i = i + 1
    z

fn _is_all_zero(arr: [u8], n: u64) -> bool:
    # Returns true if every byte in arr[0..n) is 0x00, false if any differs.
    var i: u64 = 0
    while i < n:
        if arr[i] != 0x00u8:
            return false
        i = i + 1
    true

# ============================================================================
# AC-1: parse_key_update
# ============================================================================

describe "parse_key_update":

    it "returns UpdateNotRequested for byte value 0":
        val res = parse_key_update(_payload_not_requested())
        if val KeyUpdateRequest.UpdateNotRequested(unused) = res:
            expect true == true
        else:
            expect false == true

    it "returns UpdateRequested for byte value 1":
        val res = parse_key_update(_payload_requested())
        if val KeyUpdateRequest.UpdateRequested(unused) = res:
            expect true == true
        else:
            expect false == true

    it "returns Invalid for byte value 2":
        val res = parse_key_update(_payload_invalid())
        if val KeyUpdateRequest.Invalid(unused) = res:
            expect true == true
        else:
            expect false == true

    it "returns Invalid for empty payload":
        val res = parse_key_update(_payload_empty())
        if val KeyUpdateRequest.Invalid(unused) = res:
            expect true == true
        else:
            expect false == true

# ============================================================================
# AC-2: emit_key_update wire format
# ============================================================================

describe "emit_key_update wire format":

    it "emits exactly 5 bytes":
        val msg = emit_key_update(false)
        expect msg.len().to_u64() == 5u64

    it "first byte is HS_KEY_UPDATE (24 = 0x18)":
        val msg = emit_key_update(false)
        expect msg[0] == HS_KEY_UPDATE

    it "length field is 0x000001 (bytes 1-3)":
        val msg = emit_key_update(false)
        expect msg[1] == 0x00u8
        expect msg[2] == 0x00u8
        expect msg[3] == 0x01u8

    it "body byte is 0x00 for request_update=false":
        val msg = emit_key_update(false)
        expect msg[4] == 0x00u8

    it "body byte is 0x01 for request_update=true":
        val msg = emit_key_update(true)
        expect msg[4] == 0x01u8

# ============================================================================
# AC-3: round-trip emit -> parse
# ============================================================================

describe "KeyUpdate round-trip":

    it "emit(false) round-trips to UpdateNotRequested":
        val msg = emit_key_update(false)
        val body = _strip_header(msg)
        val res = parse_key_update(body)
        if val KeyUpdateRequest.UpdateNotRequested(unused) = res:
            expect true == true
        else:
            expect false == true

    it "emit(true) round-trips to UpdateRequested":
        val msg = emit_key_update(true)
        val body = _strip_header(msg)
        val res = parse_key_update(body)
        if val KeyUpdateRequest.UpdateRequested(unused) = res:
            expect true == true
        else:
            expect false == true

# ============================================================================
# AC-4: derive_next_traffic_secret
# ============================================================================

describe "derive_next_traffic_secret":

    it "SHA-256 path returns exactly 32 bytes":
        val secret = _zeros_32()
        val next = derive_next_traffic_secret(secret, 32)
        expect next.len().to_u64() == 32u64

    it "SHA-384 path returns exactly 48 bytes":
        val secret = _zeros_48()
        val next = derive_next_traffic_secret(secret, 48)
        expect next.len().to_u64() == 48u64

    it "SHA-256 path is deterministic (same input gives same output)":
        val secret = _zeros_32()
        val a = derive_next_traffic_secret(secret, 32)
        val b = derive_next_traffic_secret(secret, 32)
        expect a.len().to_u64() == b.len().to_u64()
        expect a[0] == b[0]
        expect a[31] == b[31]

    it "SHA-256 path output differs from all-zero input":
        val secret = _zeros_32()
        val next = derive_next_traffic_secret(secret, 32)
        # The HKDF output is a pseudo-random function; all-zeros input won't
        # produce all-zeros output for a well-formed label derivation.
        # We check that at least one byte differs (conservative correctness check).
        # Note: uses module-level helper to avoid interpreter var-mutation-in-loop bug.
        expect _is_all_zero(next, 32u64) == false

    it "SHA-256 path: different secrets produce different outputs":
        val s1 = _zeros_32()
        val s2 = _ones_32()
        val n1 = derive_next_traffic_secret(s1, 32)
        val n2 = derive_next_traffic_secret(s2, 32)
        # Check at least the first byte differs
        expect n1[0] == n2[0] == false