# P-256 ECDHE → handshake_secret round-trip spec
#
# Closes W5-A AC-7: P-256 ECDHE shared-secret derivation + key_schedule
# integration. This spec is the offline (no socket) round-trip check that
# the connect-flow path glues together correctly:
#
#   1. Client and server each generate a P-256 ephemeral keypair via
#      `p256_keypair_pub(scalar)` — returns 65-byte uncompressed SEC1
#      `04 || X || Y` per RFC 8446 §4.2.8.2 + RFC 8422 §5.4.
#   2. Client computes `p256_ecdh_shared_x(client_priv, server_pub)`;
#      server computes `p256_ecdh_shared_x(server_priv, client_pub)`.
#      Both MUST yield byte-identical 32-byte X-coordinates (the standard
#      DH symmetry property).
#   3. Both sides feed that shared X into
#      `tls13_compute_handshake_secrets(shared_x, transcript)` with the
#      SAME synthetic transcript bytes (modeling the post-HRR transcript
#      seed) and MUST derive byte-identical `handshake_secret`,
#      `client_hs_traffic`, and `server_hs_traffic` fields.
#   4. `tls13_traffic_keys` over each handshake-traffic secret yields a
#      16-byte AES-128 key and 12-byte IV (cipher 0x1301 path) and BOTH
#      sides agree on those derived bytes.
#
# DEFERRED (out of this spec's scope, see crypto_recovery_status.md Wave 6):
#   * Finished MAC verify (server + client).
#   * Application traffic secrets / app traffic keys.
#   * Constant-time hardening of P-256 scalar mult — see the parallel
#     landing in `src/os/crypto/ecdh_p256.spl` and the FR doc
#     `doc/08_tracking/feature_request/p256_scalar_mult_constant_time_2026-05-01.md`.
#
# Reference: RFC 8446 §7.1 (key schedule), §4.2.8.2 (ECDHE), §7.4.2
# (shared-secret X-coordinate); RFC 8422 §5.4; SEC2 v2.0 §2.4.2.

use std.spipe.*

use os.crypto.ecdh_p256.{p256_keypair_pub, p256_ecdh_shared_x}
use os.tls13.transcript.{Transcript, transcript_new, transcript_add}
use os.tls13.key_schedule.{
    Tls13Secrets, TrafficKeys,
    tls13_compute_handshake_secrets, tls13_traffic_keys
}

# ============================================================================
# Fixtures (module-level — feedback_it_block_var_mutation.md)
# ============================================================================

fn _client_scalar() -> [u8]:
    """32-byte big-endian scalar for the deterministic client ephemeral.

    Matches the bootstrap scalar used in `tls13.spl` HRR-after-CH2 today.
    """
    [
        0x31u8, 0x32u8, 0x33u8, 0x34u8, 0x35u8, 0x36u8, 0x37u8, 0x38u8,
        0x39u8, 0x3au8, 0x3bu8, 0x3cu8, 0x3du8, 0x3eu8, 0x3fu8, 0x40u8,
        0x41u8, 0x42u8, 0x43u8, 0x44u8, 0x45u8, 0x46u8, 0x47u8, 0x48u8,
        0x49u8, 0x4au8, 0x4bu8, 0x4cu8, 0x4du8, 0x4eu8, 0x4fu8, 0x50u8
    ]

fn _server_scalar() -> [u8]:
    """32-byte big-endian scalar for the deterministic server ephemeral.

    Distinct from the client scalar so the round-trip exercises the
    arbitrary-point scalar-mult path (not the base-point shortcut).
    """
    [
        0x91u8, 0x92u8, 0x93u8, 0x94u8, 0x95u8, 0x96u8, 0x97u8, 0x98u8,
        0x99u8, 0x9au8, 0x9bu8, 0x9cu8, 0x9du8, 0x9eu8, 0x9fu8, 0xa0u8,
        0xa1u8, 0xa2u8, 0xa3u8, 0xa4u8, 0xa5u8, 0xa6u8, 0xa7u8, 0xa8u8,
        0xa9u8, 0xaau8, 0xabu8, 0xacu8, 0xadu8, 0xaeu8, 0xafu8, 0xb0u8
    ]

fn _synthetic_transcript() -> Transcript:
    """A short fixed transcript seed standing in for the post-HRR replacement
    (synthetic message_hash || HRR-handshake-bytes || CH2 || SH2)."""
    var t = transcript_new()
    var seed: [u8] = []
    var i: u64 = 0
    while i < 64:
        seed.push((i.to_u8() ^ 0x5au8))
        i = i + 1
    t = transcript_add(t, seed)
    t

fn _bytes_equal(a: [u8], b: [u8]) -> bool:
    if a.len() != b.len():
        return false
    var i: u64 = 0
    while i < a.len().to_u64():
        if a[i] != b[i]:
            return false
        i = i + 1
    true

# ============================================================================
# AC-1: Pubkey shape — 65-byte uncompressed `04 || X || Y` per RFC 8422 §5.4
# ============================================================================

describe "P-256 ephemeral pubkeys are 65-byte uncompressed SEC1 points":

    it "client pub starts with 0x04 and is 65 bytes":
        val pub_c = p256_keypair_pub(_client_scalar())
        expect(pub_c.len().to_u64()).to_equal(65u64)
        expect(pub_c[0]).to_equal(0x04u8)

    it "server pub starts with 0x04 and is 65 bytes":
        val pub_s = p256_keypair_pub(_server_scalar())
        expect(pub_s.len().to_u64()).to_equal(65u64)
        expect(pub_s[0]).to_equal(0x04u8)

    it "client and server pubkeys differ (distinct ephemeral scalars)":
        val pub_c = p256_keypair_pub(_client_scalar())
        val pub_s = p256_keypair_pub(_server_scalar())
        expect(_bytes_equal(pub_c, pub_s)).to_equal(false)

# ============================================================================
# AC-2: ECDHE symmetry — client*server == server*client; 32-byte shared X
# ============================================================================

describe "P-256 ECDHE produces a symmetric 32-byte shared X":

    it "client_priv * server_pub yields 32 bytes":
        val pub_s = p256_keypair_pub(_server_scalar())
        val sh_c = p256_ecdh_shared_x(_client_scalar(), pub_s)
        expect(sh_c.len().to_u64()).to_equal(32u64)

    it "server_priv * client_pub yields 32 bytes":
        val pub_c = p256_keypair_pub(_client_scalar())
        val sh_s = p256_ecdh_shared_x(_server_scalar(), pub_c)
        expect(sh_s.len().to_u64()).to_equal(32u64)

    it "client and server agree byte-for-byte on shared X":
        val pub_c = p256_keypair_pub(_client_scalar())
        val pub_s = p256_keypair_pub(_server_scalar())
        val sh_c = p256_ecdh_shared_x(_client_scalar(), pub_s)
        val sh_s = p256_ecdh_shared_x(_server_scalar(), pub_c)
        expect(_bytes_equal(sh_c, sh_s)).to_equal(true)

    it "rejects malformed peer (key_len != 65)":
        val bad: [u8] = [0x04u8, 0x01u8, 0x02u8]
        val sh = p256_ecdh_shared_x(_client_scalar(), bad)
        expect(sh.len().to_u64()).to_equal(0u64)

    it "rejects peer without 0x04 uncompressed prefix":
        val pub_s = p256_keypair_pub(_server_scalar())
        var bad: [u8] = []
        bad.push(0x05u8)  # invalid prefix (not 0x04 uncompressed)
        var i: u64 = 1
        while i < 65:
            bad.push(pub_s[i])
            i = i + 1
        val sh = p256_ecdh_shared_x(_client_scalar(), bad)
        expect(sh.len().to_u64()).to_equal(0u64)

# ============================================================================
# AC-3: handshake_secret derivation (RFC 8446 §7.1, SHA-256 / cipher 0x1301)
# ============================================================================

describe "tls13_compute_handshake_secrets fed with P-256 shared X":

    it "yields a 32-byte handshake_secret on the client side":
        val pub_s = p256_keypair_pub(_server_scalar())
        val sh_c = p256_ecdh_shared_x(_client_scalar(), pub_s)
        val secrets = tls13_compute_handshake_secrets(sh_c, _synthetic_transcript())
        expect(secrets.handshake_secret.len().to_u64()).to_equal(32u64)

    it "yields 32-byte client_hs_traffic and server_hs_traffic":
        val pub_s = p256_keypair_pub(_server_scalar())
        val sh_c = p256_ecdh_shared_x(_client_scalar(), pub_s)
        val secrets = tls13_compute_handshake_secrets(sh_c, _synthetic_transcript())
        expect(secrets.client_hs_traffic.len().to_u64()).to_equal(32u64)
        expect(secrets.server_hs_traffic.len().to_u64()).to_equal(32u64)

    it "client and server derive byte-identical handshake_secret":
        val pub_c = p256_keypair_pub(_client_scalar())
        val pub_s = p256_keypair_pub(_server_scalar())
        val sh_c = p256_ecdh_shared_x(_client_scalar(), pub_s)
        val sh_s = p256_ecdh_shared_x(_server_scalar(), pub_c)
        val secrets_c = tls13_compute_handshake_secrets(sh_c, _synthetic_transcript())
        val secrets_s = tls13_compute_handshake_secrets(sh_s, _synthetic_transcript())
        expect(_bytes_equal(secrets_c.handshake_secret, secrets_s.handshake_secret)).to_equal(true)

    it "client and server derive byte-identical client_hs_traffic":
        val pub_c = p256_keypair_pub(_client_scalar())
        val pub_s = p256_keypair_pub(_server_scalar())
        val sh_c = p256_ecdh_shared_x(_client_scalar(), pub_s)
        val sh_s = p256_ecdh_shared_x(_server_scalar(), pub_c)
        val secrets_c = tls13_compute_handshake_secrets(sh_c, _synthetic_transcript())
        val secrets_s = tls13_compute_handshake_secrets(sh_s, _synthetic_transcript())
        expect(_bytes_equal(secrets_c.client_hs_traffic, secrets_s.client_hs_traffic)).to_equal(true)

    it "client and server derive byte-identical server_hs_traffic":
        val pub_c = p256_keypair_pub(_client_scalar())
        val pub_s = p256_keypair_pub(_server_scalar())
        val sh_c = p256_ecdh_shared_x(_client_scalar(), pub_s)
        val sh_s = p256_ecdh_shared_x(_server_scalar(), pub_c)
        val secrets_c = tls13_compute_handshake_secrets(sh_c, _synthetic_transcript())
        val secrets_s = tls13_compute_handshake_secrets(sh_s, _synthetic_transcript())
        expect(_bytes_equal(secrets_c.server_hs_traffic, secrets_s.server_hs_traffic)).to_equal(true)

# ============================================================================
# AC-4: traffic key + IV derivation (16B AES-128 key + 12B IV; cipher 0x1301)
# ============================================================================

describe "tls13_traffic_keys over P-256-derived handshake-traffic secrets":

    it "client AES-128 key is 16 bytes and IV is 12 bytes":
        val pub_s = p256_keypair_pub(_server_scalar())
        val sh_c = p256_ecdh_shared_x(_client_scalar(), pub_s)
        val secrets = tls13_compute_handshake_secrets(sh_c, _synthetic_transcript())
        val tk = tls13_traffic_keys(secrets.client_hs_traffic)
        expect(tk.key.len().to_u64()).to_equal(16u64)
        expect(tk.iv.len().to_u64()).to_equal(12u64)

    it "server AES-128 key is 16 bytes and IV is 12 bytes":
        val pub_s = p256_keypair_pub(_server_scalar())
        val sh_c = p256_ecdh_shared_x(_client_scalar(), pub_s)
        val secrets = tls13_compute_handshake_secrets(sh_c, _synthetic_transcript())
        val tk = tls13_traffic_keys(secrets.server_hs_traffic)
        expect(tk.key.len().to_u64()).to_equal(16u64)
        expect(tk.iv.len().to_u64()).to_equal(12u64)

    it "client and server agree on derived client-side AES key/IV":
        val pub_c = p256_keypair_pub(_client_scalar())
        val pub_s = p256_keypair_pub(_server_scalar())
        val sh_c = p256_ecdh_shared_x(_client_scalar(), pub_s)
        val sh_s = p256_ecdh_shared_x(_server_scalar(), pub_c)
        val secrets_c = tls13_compute_handshake_secrets(sh_c, _synthetic_transcript())
        val secrets_s = tls13_compute_handshake_secrets(sh_s, _synthetic_transcript())
        val tk_cc = tls13_traffic_keys(secrets_c.client_hs_traffic)
        val tk_sc = tls13_traffic_keys(secrets_s.client_hs_traffic)
        expect(_bytes_equal(tk_cc.key, tk_sc.key)).to_equal(true)
        expect(_bytes_equal(tk_cc.iv, tk_sc.iv)).to_equal(true)

    it "client and server agree on derived server-side AES key/IV":
        val pub_c = p256_keypair_pub(_client_scalar())
        val pub_s = p256_keypair_pub(_server_scalar())
        val sh_c = p256_ecdh_shared_x(_client_scalar(), pub_s)
        val sh_s = p256_ecdh_shared_x(_server_scalar(), pub_c)
        val secrets_c = tls13_compute_handshake_secrets(sh_c, _synthetic_transcript())
        val secrets_s = tls13_compute_handshake_secrets(sh_s, _synthetic_transcript())
        val tk_cs = tls13_traffic_keys(secrets_c.server_hs_traffic)
        val tk_ss = tls13_traffic_keys(secrets_s.server_hs_traffic)
        expect(_bytes_equal(tk_cs.key, tk_ss.key)).to_equal(true)
        expect(_bytes_equal(tk_cs.iv, tk_ss.iv)).to_equal(true)
