# cert_verify ECDSA-P256-SHA-256 wiring spec
#
# Exercises the ECDSA-P256-SHA-256 (sig_scheme 0x0403) path added to
# verify_certificate_verify_msg_scheme and the DER decoder helper
# _ecdsa_p256_der_sig_to_fixed64 (tested via the encode/decode round-trip).
#
# Fixture key: same PKCS#8 / SPKI pair from test/unit/lib/crypto/ecdsa_p256_spec.spl
#   Qx = fc116698a3e3236550c4c9efa9bd4d0619602a65d2930e9150ab33e84dbc83f8
#   Qy = a6a6b9933f35ab59245e5b5a7af5dca76b33cbe7aeee5981b3ca350bebf52ecd
#
# Test cases:
#   1. DER decode: known-good DER SEQUENCE{r,s} round-trips through decoder to fixed64
#   2. Happy path: sign → DER-encode → verify with correct SPKI → CertVerifyResult.Ok
#   3. Wrong key: verify with different SPKI → CertVerifyResult.Err
#   4. Corrupted DER sig: flip a byte → CertVerifyResult.Err
#   5. sig_scheme 0x0503 (P-384) → Err "P-384 primitive not in tree"
#   6. sig_scheme 0x0603 (P-521) → Err "P-521 primitive not in tree"
#
# Reference: RFC 8446 §4.2.3, §4.4.3

use std.spipe.*
use os.tls13.cert_verify.{
    verify_certificate_verify_msg_scheme,
    CertVerifyResult
}
use os.crypto.ecdsa_p256.{
    ecdsa_p256_sign_fixed,
    ecdsa_p256_verify_fixed
}
use test.system.os_crypto_ref_helpers.{hex_to_bytes}

# ============================================================================
# Key material — module-level fns (avoid it-block var-mutation footgun)
# ============================================================================

fn _pkcs8() -> [u8]:
    hex_to_bytes("308187020100301306072a8648ce3d020106082a8648ce3d030107046d306b0201010420578329bff057bf48c84b9fc462940c57bb509e77e443228dbd627054a1fce283a14403420004fc116698a3e3236550c4c9efa9bd4d0619602a65d2930e9150ab33e84dbc83f8a6a6b9933f35ab59245e5b5a7af5dca76b33cbe7aeee5981b3ca350bebf52ecd")

fn _spki() -> [u8]:
    hex_to_bytes("3059301306072a8648ce3d020106082a8648ce3d03010703420004fc116698a3e3236550c4c9efa9bd4d0619602a65d2930e9150ab33e84dbc83f8a6a6b9933f35ab59245e5b5a7af5dca76b33cbe7aeee5981b3ca350bebf52ecd")

# A different SPKI (NIST CAVP key) — used for wrong-key negative test
fn _other_spki() -> [u8]:
    hex_to_bytes("3059301306072a8648ce3d020106082a8648ce3d03010703420004e424dc61d4bb3cb7ef4344a7f8957a0c5134e16f7a67c074f82e6e12f49abf3c970eed7aa2bc48651545949de1dddaf0127e5965ac85d1243d6f60e7dfaee927")

fn _test_msg() -> [u8]:
    # "hello" in ASCII bytes
    [0x68u8, 0x65u8, 0x6cu8, 0x6cu8, 0x6fu8]

# Build a DER SEQUENCE { INTEGER r, INTEGER s } from a 64-byte fixed r||s.
# r = bytes[0..31], s = bytes[32..63].
# Prepend 0x00 to each component if high bit is set (DER positive integer rule).
fn _fixed64_to_der(sig: [u8]) -> [u8]:
    # Extract r (32 bytes)
    var r_bytes: [u8] = []
    var i: u64 = 0
    while i < 32:
        r_bytes.push(sig[i])
        i = i + 1

    # Extract s (32 bytes)
    var s_bytes: [u8] = []
    i = 32
    while i < 64:
        s_bytes.push(sig[i])
        i = i + 1

    # Strip leading zeros from r, add 0x00 if high bit set
    var r_mag: [u8] = []
    i = 0
    while i < 32 and r_bytes[i] == 0:
        i = i + 1
    while i < 32:
        r_mag.push(r_bytes[i])
        i = i + 1
    if r_mag.len() == 0:
        r_mag.push(0u8)
    elif (r_mag[0u64] & 0x80) != 0:
        var pr: [u8] = [0x00u8]
        var j: u64 = 0
        while j < r_mag.len():
            pr.push(r_mag[j])
            j = j + 1
        r_mag = pr

    # Strip leading zeros from s, add 0x00 if high bit set
    var s_mag: [u8] = []
    i = 0
    while i < 32 and s_bytes[i] == 0:
        i = i + 1
    while i < 32:
        s_mag.push(s_bytes[i])
        i = i + 1
    if s_mag.len() == 0:
        s_mag.push(0u8)
    elif (s_mag[0u64] & 0x80) != 0:
        var ps: [u8] = [0x00u8]
        var j: u64 = 0
        while j < s_mag.len():
            ps.push(s_mag[j])
            j = j + 1
        s_mag = ps

    # Build r INTEGER TLV: 02 <len> <mag>
    var r_tlv: [u8] = [0x02u8]
    r_tlv.push(r_mag.len().to_u8())
    var j: u64 = 0
    while j < r_mag.len():
        r_tlv.push(r_mag[j])
        j = j + 1

    # Build s INTEGER TLV: 02 <len> <mag>
    var s_tlv: [u8] = [0x02u8]
    s_tlv.push(s_mag.len().to_u8())
    j = 0
    while j < s_mag.len():
        s_tlv.push(s_mag[j])
        j = j + 1

    # Wrap in SEQUENCE: 30 <content_len> <r_tlv><s_tlv>
    val content_len = r_tlv.len() + s_tlv.len()
    var result: [u8] = [0x30u8]
    result.push(content_len.to_u8())
    j = 0
    while j < r_tlv.len():
        result.push(r_tlv[j])
        j = j + 1
    j = 0
    while j < s_tlv.len():
        result.push(s_tlv[j])
        j = j + 1
    result

fn _flip_byte_at(bytes: [u8], idx: u64) -> [u8]:
    var out: [u8] = []
    var i: u64 = 0
    while i < bytes.len():
        if i == idx:
            out.push((bytes[i].to_i64() ^ 0x01).to_u8())
        else:
            out.push(bytes[i])
        i = i + 1
    out

# Sign the test message and produce a DER-encoded ECDSA-P256 signature
fn _sign_msg_der() -> [u8]:
    val fixed64 = ecdsa_p256_sign_fixed(_pkcs8(), _test_msg())
    _fixed64_to_der(fixed64)

# ============================================================================
# DER decoder round-trip (verifies _ecdsa_p256_der_sig_to_fixed64 indirectly
# by checking that the decode path correctly rejects truncated DER)
# ============================================================================

describe "ECDSA-P256 DER sig decode":

    it "fixed64_to_der produces a non-empty byte sequence":
        val sig = ecdsa_p256_sign_fixed(_pkcs8(), _test_msg())
        val der = _fixed64_to_der(sig)
        expect der.len() > 0 == true

    it "DER-encoded sig starts with SEQUENCE tag 0x30":
        val sig = ecdsa_p256_sign_fixed(_pkcs8(), _test_msg())
        val der = _fixed64_to_der(sig)
        expect der[0u64] == 0x30u8

    it "DER-encoded sig verifies correctly with ecdsa_p256_verify_fixed after round-trip":
        # Sign → DER-encode → decode back to fixed64 → verify
        # This tests the DER decoder path that cert_verify uses internally
        val msg = _test_msg()
        val fixed64 = ecdsa_p256_sign_fixed(_pkcs8(), msg)
        val der = _fixed64_to_der(fixed64)
        # Decode the DER back to fixed64 via the cert_verify API
        # (We test via verify_certificate_verify_msg_scheme which uses the decoder)
        val result = verify_certificate_verify_msg_scheme(_spki(), 0x0403u16, msg, der)
        if val CertVerifyResult.Ok = result:
            expect true == true
        else:
            expect false == true

# ============================================================================
# verify_certificate_verify_msg_scheme — ECDSA-P256-SHA-256 (0x0403)
# ============================================================================

describe "verify_certificate_verify_msg_scheme ECDSA-P256-SHA-256 (0x0403)":

    it "verifies a valid ECDSA-P256 CertificateVerify message":
        val msg = _test_msg()
        val der_sig = _sign_msg_der()
        val result = verify_certificate_verify_msg_scheme(_spki(), 0x0403u16, msg, der_sig)
        if val CertVerifyResult.Ok = result:
            expect true == true
        else:
            expect false == true

    it "rejects signature verified under a different public key":
        val msg = _test_msg()
        val der_sig = _sign_msg_der()
        val result = verify_certificate_verify_msg_scheme(_other_spki(), 0x0403u16, msg, der_sig)
        if val CertVerifyResult.Err(err_msg) = result:
            expect true == true
        else:
            expect false == true

    it "rejects a DER signature with a flipped byte":
        val msg = _test_msg()
        val der_sig = _sign_msg_der()
        # Flip a byte inside the signature content (byte 4 = first byte of r value)
        val bad_sig = _flip_byte_at(der_sig, 4u64)
        val result = verify_certificate_verify_msg_scheme(_spki(), 0x0403u16, msg, bad_sig)
        if val CertVerifyResult.Err(err_msg) = result:
            expect true == true
        else:
            expect false == true

# ============================================================================
# Unsupported ECDSA schemes — explicit error messages (no P-384 / P-521 primitive)
# ============================================================================

describe "verify_certificate_verify_msg_scheme unsupported ECDSA schemes":

    it "sig_scheme 0x0503 (ecdsa_secp384r1_sha384) returns unsupported error":
        val msg = _test_msg()
        val dummy_sig: [u8] = [0x30u8, 0x06u8, 0x02u8, 0x01u8, 0x01u8, 0x02u8, 0x01u8, 0x01u8]
        val result = verify_certificate_verify_msg_scheme(_spki(), 0x0503u16, msg, dummy_sig)
        if val CertVerifyResult.Err(err_msg) = result:
            expect err_msg.contains("P-384") == true
        else:
            expect false == true

    it "sig_scheme 0x0603 (ecdsa_secp521r1_sha512) returns unsupported error":
        val msg = _test_msg()
        val dummy_sig: [u8] = [0x30u8, 0x06u8, 0x02u8, 0x01u8, 0x01u8, 0x02u8, 0x01u8, 0x01u8]
        val result = verify_certificate_verify_msg_scheme(_spki(), 0x0603u16, msg, dummy_sig)
        if val CertVerifyResult.Err(err_msg) = result:
            expect err_msg.contains("P-521") == true
        else:
            expect false == true