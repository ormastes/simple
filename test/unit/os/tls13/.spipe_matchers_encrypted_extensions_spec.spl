# EncryptedExtensions parsing spec — RFC 8446 §4.3.1
#
# Exercises parse_encrypted_extensions / EncryptedExtensions13 / EncryptedExtensionsResult
# added to handshake13.spl to replace the stub that ignored the body.
#
# Wire format (RFC 8446 §4.3.1):
#   struct { Extension extensions<0..2^16-1>; } EncryptedExtensions;
#   struct { ExtensionType type; opaque data<0..2^16-1>; } Extension;
#
# Cases:
#   1. Empty extensions list (outer length = 0) → Ok, no fields set.
#   2. server_name (0) with empty data → Ok, server_name_acknowledged=true.
#   3. ALPN (16) selecting "h2" → Ok, selected_alpn = "h2".
#   4. Duplicate extension_type → Err("illegal_parameter").
#   5. Unknown extension_type 0xFFFF → ignored, parse continues to ALPN.
#   6. Truncated outer length → Err("decode_error").
#   7. server_name with non-empty data → Err("illegal_parameter").
#   8. early_data (42) present → Err("unsupported_extension").
#   9. max_fragment_length echoed → Ok, mfl byte populated.
#  10. ALPN with two ProtocolNames → Err("illegal_parameter").

use std.spipe.*
use os.tls13.handshake13.{
    parse_encrypted_extensions,
    EncryptedExtensions13,
    EncryptedExtensionsResult
}

# ============================================================================
# EE body builders — module-level fns (it-block var rebinds aren't safe)
# ============================================================================

fn _ee_empty() -> [u8]:
    # outer extensions length = 0
    [0x00u8, 0x00u8]

fn _ext(ext_type_hi: u8, ext_type_lo: u8, data: [u8]) -> [u8]:
    # Build a single Extension: type(2) + length(2) + data
    val n = data.len()
    var out: [u8] = [ext_type_hi, ext_type_lo, ((n >> 8) & 0xFF).to_u8(), (n & 0xFF).to_u8()]
    var i: u64 = 0
    while i < n:
        out.push(data[i])
        i = i + 1
    out

fn _wrap_outer(exts: [u8]) -> [u8]:
    val n = exts.len()
    var out: [u8] = [((n >> 8) & 0xFF).to_u8(), (n & 0xFF).to_u8()]
    var i: u64 = 0
    while i < n:
        out.push(exts[i])
        i = i + 1
    out

fn _ee_server_name_ack() -> [u8]:
    # server_name extension with zero-length data
    _wrap_outer(_ext(0x00u8, 0x00u8, []))

fn _ee_server_name_nonempty() -> [u8]:
    # server_name with non-empty data — illegal in EE
    _wrap_outer(_ext(0x00u8, 0x00u8, [0x01u8, 0x02u8]))

fn _ee_alpn_h2() -> [u8]:
    # ALPN: list_len(2) + name_len(1) + "h2"
    val ext_data: [u8] = [0x00u8, 0x03u8, 0x02u8, 0x68u8, 0x32u8]
    _wrap_outer(_ext(0x00u8, 0x10u8, ext_data))

fn _ee_alpn_two_names() -> [u8]:
    # ALPN with two names "h2" and "h3" — illegal (server selects exactly one)
    val ext_data: [u8] = [0x00u8, 0x06u8, 0x02u8, 0x68u8, 0x32u8, 0x02u8, 0x68u8, 0x33u8]
    _wrap_outer(_ext(0x00u8, 0x10u8, ext_data))

fn _ee_dup_sni() -> [u8]:
    # Two server_name extensions back-to-back
    val a = _ext(0x00u8, 0x00u8, [])
    val b = _ext(0x00u8, 0x00u8, [])
    var combined: [u8] = []
    var i: u64 = 0
    while i < a.len():
        combined.push(a[i])
        i = i + 1
    var j: u64 = 0
    while j < b.len():
        combined.push(b[j])
        j = j + 1
    _wrap_outer(combined)

fn _ee_unknown_then_alpn() -> [u8]:
    # Unknown 0xFFFF (4 bytes data) followed by ALPN "h2"
    val unknown_ext = _ext(0xFFu8, 0xFFu8, [0xDEu8, 0xADu8, 0xBEu8, 0xEFu8])
    val alpn_data: [u8] = [0x00u8, 0x03u8, 0x02u8, 0x68u8, 0x32u8]
    val alpn_ext = _ext(0x00u8, 0x10u8, alpn_data)
    var combined: [u8] = []
    var i: u64 = 0
    while i < unknown_ext.len():
        combined.push(unknown_ext[i])
        i = i + 1
    var j: u64 = 0
    while j < alpn_ext.len():
        combined.push(alpn_ext[j])
        j = j + 1
    _wrap_outer(combined)

fn _ee_truncated_outer() -> [u8]:
    # outer length declares 4 bytes but body only has the 2-byte header
    [0x00u8, 0x04u8]

fn _ee_early_data() -> [u8]:
    # early_data (42 = 0x002A) with empty data → server accepts 0-RTT
    _wrap_outer(_ext(0x00u8, 0x2Au8, []))

fn _ee_mfl() -> [u8]:
    # max_fragment_length (1) with single-byte enum value 0x04 (2^12 = 4096)
    _wrap_outer(_ext(0x00u8, 0x01u8, [0x04u8]))

fn _ee_mfl_bad_len() -> [u8]:
    # max_fragment_length with 2 bytes (must be exactly 1)
    _wrap_outer(_ext(0x00u8, 0x01u8, [0x04u8, 0x04u8]))

# ============================================================================
# Happy paths
# ============================================================================

describe "parse_encrypted_extensions happy paths":

    it "accepts an empty extensions list":
        val res = parse_encrypted_extensions(_ee_empty())
        if val EncryptedExtensionsResult.Ok(value) = res:
            expect value.server_name_acknowledged == false
            expect value.selected_alpn == ""
            expect value.max_fragment_length == 0u8
        else:
            expect false == true

    it "records server_name acknowledgement":
        val res = parse_encrypted_extensions(_ee_server_name_ack())
        if val EncryptedExtensionsResult.Ok(value) = res:
            expect value.server_name_acknowledged == true
        else:
            expect false == true

    it "extracts the selected ALPN protocol":
        val res = parse_encrypted_extensions(_ee_alpn_h2())
        if val EncryptedExtensionsResult.Ok(value) = res:
            expect value.selected_alpn == "h2"
        else:
            expect false == true

    it "ignores unknown extension types and continues parsing":
        val res = parse_encrypted_extensions(_ee_unknown_then_alpn())
        if val EncryptedExtensionsResult.Ok(value) = res:
            expect value.selected_alpn == "h2"
        else:
            expect false == true

    it "echoes max_fragment_length byte":
        val res = parse_encrypted_extensions(_ee_mfl())
        if val EncryptedExtensionsResult.Ok(value) = res:
            expect value.max_fragment_length == 0x04u8
        else:
            expect false == true

# ============================================================================
# Rejection paths — RFC 8446 §4.2 / RFC 6066 / RFC 7301
# ============================================================================

describe "parse_encrypted_extensions rejections":

    it "rejects duplicate extension_type as illegal_parameter":
        val res = parse_encrypted_extensions(_ee_dup_sni())
        if val EncryptedExtensionsResult.Err(reason) = res:
            expect reason.contains("illegal_parameter") == true
        else:
            expect false == true

    it "rejects truncated body as decode_error":
        val res = parse_encrypted_extensions(_ee_truncated_outer())
        if val EncryptedExtensionsResult.Err(reason) = res:
            expect reason.contains("decode_error") == true
        else:
            expect false == true

    it "rejects non-empty server_name in EE":
        val res = parse_encrypted_extensions(_ee_server_name_nonempty())
        if val EncryptedExtensionsResult.Err(reason) = res:
            expect reason.contains("illegal_parameter") == true
        else:
            expect false == true

    it "rejects early_data extension (0-RTT not implemented)":
        val res = parse_encrypted_extensions(_ee_early_data())
        if val EncryptedExtensionsResult.Err(reason) = res:
            expect reason.contains("unsupported_extension") == true
        else:
            expect false == true

    it "rejects ALPN with multiple ProtocolNames":
        val res = parse_encrypted_extensions(_ee_alpn_two_names())
        if val EncryptedExtensionsResult.Err(reason) = res:
            expect reason.contains("illegal_parameter") == true
        else:
            expect false == true

    it "rejects malformed max_fragment_length":
        val res = parse_encrypted_extensions(_ee_mfl_bad_len())
        if val EncryptedExtensionsResult.Err(reason) = res:
            expect reason.contains("illegal_parameter") == true
        else:
            expect false == true