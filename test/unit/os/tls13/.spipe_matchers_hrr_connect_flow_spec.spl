# HRR connect-flow integration spec — RFC 8446 §4.1.4 + §4.4.1
#
# Drives `process_hrr_after_serverhello` end-to-end without a TCP socket:
#   - Server picks GROUP_X25519, but CH1 already advertised X25519 → §4.1.4
#     "no change to ClientHello" rejection.
#   - Server picks GROUP_SECP256R1, CH1 advertised both groups → still
#     rejected because CH1 also offered P-256 (live connect flow today).
#   - Server picks an unsupported group → illegal_parameter rejection.
#   - Server picks GROUP_SECP256R1, CH1 advertised X25519-only → CH2 built
#     with P-256 key_share + cookie echoed + transcript seed format
#     `synth(36) || HRR-handshake-bytes`.
#   - Two-HRR sequence (`seen_hrr=true`) → unexpected_message rejection.
#
# The pure helper lets us cover the connect-flow integration acceptance
# criteria (AC-1 through AC-5) while the actual `_io_send` / `_io_recv_record`
# wiring rides on top of it inside `tls13_connect_io_with_config`.

use std.spipe.*
use os.tls13.handshake13.{
    process_hrr_after_serverhello,
    HrrFlowResult,
    HrrFlowOk,
    HRR_MAGIC,
    HS_MESSAGE_HASH,
    EXT_KEY_SHARE,
    EXT_SUPPORTED_VERSIONS,
    GROUP_X25519,
    GROUP_SECP256R1,
}

# ============================================================================
# Fixtures — module-level fns (it-block var rebinds aren't safe per CLAUDE)
# ============================================================================

fn _hrr_random() -> [u8]:
    var out: [u8] = []
    var i: u64 = 0
    while i < 32:
        out.push(HRR_MAGIC[i])
        i = i + 1
    out

fn _u16be_bytes(v: u64) -> [u8]:
    [((v >> 8) & 0xFF).to_u8(), (v & 0xFF).to_u8()]

fn _ext_block(ext_type: u64, data: [u8]) -> [u8]:
    var out: [u8] = []
    val ty = _u16be_bytes(ext_type)
    val ln = _u16be_bytes(data.len().to_u64())
    var i: u64 = 0
    while i < ty.len():
        out.push(ty[i])
        i = i + 1
    var j: u64 = 0
    while j < ln.len():
        out.push(ln[j])
        j = j + 1
    var k: u64 = 0
    while k < data.len():
        out.push(data[k])
        k = k + 1
    out

fn _supported_versions_tls13() -> [u8]:
    _ext_block(0x002Bu64, [0x03u8, 0x04u8])

fn _key_share_group(group: u64) -> [u8]:
    _ext_block(EXT_KEY_SHARE.to_u64(), _u16be_bytes(group))

fn _cookie_ext(cookie: [u8]) -> [u8]:
    var inner: [u8] = []
    val ln = _u16be_bytes(cookie.len().to_u64())
    var i: u64 = 0
    while i < ln.len():
        inner.push(ln[i])
        i = i + 1
    var j: u64 = 0
    while j < cookie.len():
        inner.push(cookie[j])
        j = j + 1
    _ext_block(0x002Cu64, inner)

fn _concat(a: [u8], b: [u8]) -> [u8]:
    var out: [u8] = []
    var i: u64 = 0
    while i < a.len():
        out.push(a[i])
        i = i + 1
    var j: u64 = 0
    while j < b.len():
        out.push(b[j])
        j = j + 1
    out

fn _build_hrr_body(extensions: [u8]) -> [u8]:
    # legacy_version(2) + HRR_MAGIC(32) + session_id_len(1=0) +
    # cipher_suite(2=0x1301) + compression(1=0) + ext_len(2) + extensions
    var body: [u8] = []
    body.push(0x03u8)
    body.push(0x03u8)
    var i: u64 = 0
    while i < 32:
        body.push(HRR_MAGIC[i])
        i = i + 1
    body.push(0x00u8)             # session_id length
    body.push(0x13u8)             # cipher_suite high
    body.push(0x01u8)             # cipher_suite low (TLS_AES_128_GCM_SHA256)
    body.push(0x00u8)             # compression_method
    val el = _u16be_bytes(extensions.len().to_u64())
    body.push(el[0])
    body.push(el[1])
    var j: u64 = 0
    while j < extensions.len():
        body.push(extensions[j])
        j = j + 1
    body

fn _hs_wrap(body: [u8]) -> [u8]:
    # type(1=HS_SERVER_HELLO=2) + length(3) + body
    var out: [u8] = []
    out.push(0x02u8)              # HS_SERVER_HELLO
    val n = body.len().to_u64()
    out.push(((n >> 16) & 0xFF).to_u8())
    out.push(((n >> 8) & 0xFF).to_u8())
    out.push((n & 0xFF).to_u8())
    var i: u64 = 0
    while i < body.len():
        out.push(body[i])
        i = i + 1
    out

fn _hrr_p256_no_cookie_hs() -> [u8]:
    val exts = _concat(_supported_versions_tls13(), _key_share_group(GROUP_SECP256R1.to_u64()))
    val body = _build_hrr_body(exts)
    _hs_wrap(body)

fn _hrr_p256_no_cookie_body() -> [u8]:
    val exts = _concat(_supported_versions_tls13(), _key_share_group(GROUP_SECP256R1.to_u64()))
    _build_hrr_body(exts)

fn _hrr_p256_with_cookie_hs(cookie: [u8]) -> [u8]:
    val exts = _concat(_supported_versions_tls13(), _concat(_key_share_group(GROUP_SECP256R1.to_u64()), _cookie_ext(cookie)))
    val body = _build_hrr_body(exts)
    _hs_wrap(body)

fn _hrr_p256_with_cookie_body(cookie: [u8]) -> [u8]:
    val exts = _concat(_supported_versions_tls13(), _concat(_key_share_group(GROUP_SECP256R1.to_u64()), _cookie_ext(cookie)))
    _build_hrr_body(exts)

fn _hrr_x25519_no_cookie_hs() -> [u8]:
    val exts = _concat(_supported_versions_tls13(), _key_share_group(GROUP_X25519.to_u64()))
    val body = _build_hrr_body(exts)
    _hs_wrap(body)

fn _hrr_x25519_no_cookie_body() -> [u8]:
    val exts = _concat(_supported_versions_tls13(), _key_share_group(GROUP_X25519.to_u64()))
    _build_hrr_body(exts)

fn _hrr_unsupported_group_hs() -> [u8]:
    val exts = _concat(_supported_versions_tls13(), _key_share_group(0x0019u64))  # secp521r1 — not advertised
    val body = _build_hrr_body(exts)
    _hs_wrap(body)

fn _hrr_unsupported_group_body() -> [u8]:
    val exts = _concat(_supported_versions_tls13(), _key_share_group(0x0019u64))
    _build_hrr_body(exts)

fn _ch1_random() -> [u8]:
    var out: [u8] = []
    var i: u64 = 0
    while i < 32:
        out.push((0xA0u64 + i).to_u8())
        i = i + 1
    out

fn _ch1_hash_fixture() -> [u8]:
    # Deterministic 32-byte stand-in for SHA-256(CH1). The helper does not
    # re-hash; it just prepends the §4.4.1 4-byte handshake header.
    var out: [u8] = []
    var i: u64 = 0
    while i < 32:
        out.push((0x10u64 + i).to_u8())
        i = i + 1
    out

fn _fresh_x25519_pub() -> [u8]:
    var out: [u8] = []
    var i: u64 = 0
    while i < 32:
        out.push((0x40u64 + i).to_u8())
        i = i + 1
    out

fn _ch2_or_empty(r: HrrFlowResult) -> [u8]:
    if val HrrFlowResult.Ok(value) = r:
        value.client_hello2_bytes
    else:
        []

fn _contains_run(haystack: [u8], needle: [u8]) -> bool:
    if needle.len() == 0:
        return true
    if haystack.len() < needle.len():
        return false
    val limit = haystack.len() - needle.len() + 1u64
    var i: u64 = 0
    while i < limit:
        var k: u64 = 0
        var ok: bool = true
        while k < needle.len() and ok:
            if haystack[i + k] != needle[k]:
                ok = false
            k = k + 1
        if ok:
            return true
        i = i + 1
    false

fn _fresh_p256_pub() -> [u8]:
    # 65-byte uncompressed SEC1: 0x04 || X(32) || Y(32)
    var out: [u8] = []
    out.push(0x04u8)
    var i: u64 = 0
    while i < 64:
        out.push((0x80u64 + i).to_u8())
        i = i + 1
    out

# ============================================================================
# Specs
# ============================================================================

describe "process_hrr_after_serverhello AC-1 second-HRR rejection":

    it "rejects with unexpected_message when seen_hrr is already true":
        val hs = _hrr_p256_no_cookie_hs()
        val body = _hrr_p256_no_cookie_body()
        val r = process_hrr_after_serverhello(
            hs, body, _ch1_random(), _fresh_x25519_pub(), _ch1_hash_fixture(),
            _fresh_x25519_pub(), _fresh_p256_pub(), "example.com",
            true,   # seen_hrr — second HRR
            true,   # ch1_offered_x25519
            true,   # ch1_offered_p256
        )
        if val HrrFlowResult.Reject(reason) = r:
            expect reason.contains("unexpected_message") == true
            expect reason.contains("second HRR") == true
        else:
            expect "expected Reject(second HRR)" == "got Ok"

describe "process_hrr_after_serverhello AC-2 same-group rejection":

    it "rejects when HRR picks GROUP_X25519 and CH1 already offered X25519":
        val hs = _hrr_x25519_no_cookie_hs()
        val body = _hrr_x25519_no_cookie_body()
        val r = process_hrr_after_serverhello(
            hs, body, _ch1_random(), _fresh_x25519_pub(), _ch1_hash_fixture(),
            _fresh_x25519_pub(), _fresh_p256_pub(), "example.com",
            false,  # seen_hrr
            true,   # ch1_offered_x25519
            true,   # ch1_offered_p256
        )
        if val HrrFlowResult.Reject(reason) = r:
            expect reason.contains("illegal_parameter") == true
            expect reason.contains("X25519") == true
        else:
            expect "expected Reject(same-group X25519)" == "got Ok"

    it "rejects when HRR picks SECP256R1 and CH1 already offered SECP256R1":
        val hs = _hrr_p256_no_cookie_hs()
        val body = _hrr_p256_no_cookie_body()
        val r = process_hrr_after_serverhello(
            hs, body, _ch1_random(), _fresh_x25519_pub(), _ch1_hash_fixture(),
            _fresh_x25519_pub(), _fresh_p256_pub(), "example.com",
            false,
            true,   # ch1_offered_x25519
            true,   # ch1_offered_p256 — server has nothing to switch to
        )
        if val HrrFlowResult.Reject(reason) = r:
            expect reason.contains("illegal_parameter") == true
            expect reason.contains("secp256r1") == true
        else:
            expect "expected Reject(same-group secp256r1)" == "got Ok"

    it "rejects when HRR picks an unadvertised group":
        val hs = _hrr_unsupported_group_hs()
        val body = _hrr_unsupported_group_body()
        val r = process_hrr_after_serverhello(
            hs, body, _ch1_random(), _fresh_x25519_pub(), _ch1_hash_fixture(),
            _fresh_x25519_pub(), _fresh_p256_pub(), "example.com",
            false, true, true,
        )
        if val HrrFlowResult.Reject(reason) = r:
            expect reason.contains("illegal_parameter") == true
            expect reason.contains("not in client supported_groups") == true
        else:
            expect "expected Reject(unsupported group)" == "got Ok"

describe "process_hrr_after_serverhello AC-3 CH2 routing for SECP256R1":

    it "builds CH2 with P-256 key_share when CH1 only advertised X25519":
        val hs = _hrr_p256_no_cookie_hs()
        val body = _hrr_p256_no_cookie_body()
        val r = process_hrr_after_serverhello(
            hs, body, _ch1_random(), _fresh_x25519_pub(), _ch1_hash_fixture(),
            _fresh_x25519_pub(), _fresh_p256_pub(), "example.com",
            false,
            true,   # ch1_offered_x25519
            false,  # ch1_offered_p256 — server is allowed to pick secp256r1
        )
        if val HrrFlowResult.Ok(value) = r:
            expect value.selected_group == GROUP_SECP256R1
            # CH2 first byte is HS_CLIENT_HELLO (0x01)
            expect value.client_hello2_bytes[0] == 0x01u8
            # CH2 random echoes CH1
            var i: u64 = 0
            while i < 32:
                expect value.client_hello2_bytes[6 + i] == _ch1_random()[i]
                i = i + 1
        else:
            expect "expected Ok(P-256 CH2)" == "got Reject"

    it "preserves CH1 client_random verbatim in CH2 (RFC 8446 §4.1.2)":
        val hs = _hrr_p256_no_cookie_hs()
        val body = _hrr_p256_no_cookie_body()
        val r = process_hrr_after_serverhello(
            hs, body, _ch1_random(), _fresh_x25519_pub(), _ch1_hash_fixture(),
            _fresh_x25519_pub(), _fresh_p256_pub(), "example.com",
            false, true, false,
        )
        if val HrrFlowResult.Ok(value) = r:
            # CH2 layout: 0x01 + 3-byte len + 0x0303 + random[32] starting at offset 6
            var i: u64 = 0
            while i < 32:
                expect value.client_hello2_bytes[6 + i] == _ch1_random()[i]
                i = i + 1
        else:
            expect "expected Ok" == "got Reject"

    it "echoes a non-empty cookie verbatim as a contiguous run inside CH2":
        val cookie: [u8] = [0xCAu8, 0xFEu8, 0xBAu8, 0xBEu8, 0x01u8, 0x02u8]
        val hs = _hrr_p256_with_cookie_hs(cookie)
        val body = _hrr_p256_with_cookie_body(cookie)
        val r = process_hrr_after_serverhello(
            hs, body, _ch1_random(), _fresh_x25519_pub(), _ch1_hash_fixture(),
            _fresh_x25519_pub(), _fresh_p256_pub(), "example.com",
            false, true, false,
        )
        val ch2 = _ch2_or_empty(r)
        expect _contains_run(ch2, cookie) == true

describe "process_hrr_after_serverhello AC-4 transcript replacement (§4.4.1)":

    it "transcript_seed starts with synthetic message_hash 0xfe 0x00 0x00 0x20 || Hash(CH1)":
        val hs = _hrr_p256_no_cookie_hs()
        val body = _hrr_p256_no_cookie_body()
        val r = process_hrr_after_serverhello(
            hs, body, _ch1_random(), _fresh_x25519_pub(), _ch1_hash_fixture(),
            _fresh_x25519_pub(), _fresh_p256_pub(), "example.com",
            false, true, false,
        )
        if val HrrFlowResult.Ok(value) = r:
            val seed = value.transcript_seed
            expect seed[0] == HS_MESSAGE_HASH
            expect seed[1] == 0x00u8
            expect seed[2] == 0x00u8
            expect seed[3] == 0x20u8
            # Bytes 4..36 must equal CH1 hash.
            val ch1h = _ch1_hash_fixture()
            var i: u64 = 0
            while i < 32:
                expect seed[4 + i] == ch1h[i]
                i = i + 1
        else:
            expect "expected Ok" == "got Reject"

    it "transcript_seed appends HRR handshake bytes verbatim after synthetic prefix":
        val hs = _hrr_p256_no_cookie_hs()
        val body = _hrr_p256_no_cookie_body()
        val r = process_hrr_after_serverhello(
            hs, body, _ch1_random(), _fresh_x25519_pub(), _ch1_hash_fixture(),
            _fresh_x25519_pub(), _fresh_p256_pub(), "example.com",
            false, true, false,
        )
        if val HrrFlowResult.Ok(value) = r:
            val seed = value.transcript_seed
            # Prefix length = 4 (header) + 32 (hash) = 36
            expect seed.len() == (36u64 + hs.len().to_u64())
            var i: u64 = 0
            while i < hs.len():
                expect seed[36 + i] == hs[i]
                i = i + 1
        else:
            expect "expected Ok" == "got Reject"