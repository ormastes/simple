# P-256 ECDHE → handshake_secret round-trip spec
#
# Closes W5-A AC-7: P-256 ECDHE shared-secret derivation + key_schedule
# integration. This spec is the offline (no socket) round-trip check that
# the connect-flow path glues together correctly:
#
#   1. Client and server each generate a P-256 ephemeral keypair via
#      `p256_keypair_pub(scalar)` — returns 65-byte uncompressed SEC1
#      `04 || X || Y` per RFC 8446 §4.2.8.2 + RFC 8422 §5.4.
#   2. Client computes `p256_ecdh_shared_x(client_priv, server_pub)`;
#      server computes `p256_ecdh_shared_x(server_priv, client_pub)`.
#      Both MUST yield byte-identical 32-byte X-coordinates (the standard
#      DH symmetry property).
#   3. Both sides feed that shared X into
#      `tls13_compute_handshake_secrets(shared_x, transcript)` with the
#      SAME synthetic transcript bytes (modeling the post-HRR transcript
#      seed) and MUST derive byte-identical `handshake_secret`,
#      `client_hs_traffic`, and `server_hs_traffic` fields.
#   4. `tls13_traffic_keys` over each handshake-traffic secret yields a
#      16-byte AES-128 key and 12-byte IV (cipher 0x1301 path) and BOTH
#      sides agree on those derived bytes.
#
# DEFERRED (out of this spec's scope, see crypto_recovery_status.md Wave 6):
#   * Finished MAC verify (server + client).
#   * Application traffic secrets / app traffic keys.
#
# Inline-scalar pattern: scalars are built via `var ... push` inside each
# `it` block. Wrapping the same construction in a module-level
# `fn _scalar() -> [u8]` triggers a `semantic: cannot index array with type
# u64` compiler regression that affects every caller of `p256_keypair_pub`
# whose `[u8]` argument crosses a function-return boundary. The regression
# is NOT in this spec or in `ecdh_p256.spl`; it is a side-effect of the
# parallel `Value::UInt`-with-width-tag landing (see commits `2ec2342969`
# / `71e50b532c`). Recorded in
# `doc/08_tracking/bug/p256_keypair_pub_fn_arg_u64_index_regression_2026-05-01.md`.
# The inline form fully exercises the round-trip; no test coverage is
# weakened.
#
# Reference: RFC 8446 §7.1 (key schedule), §4.2.8.2 (ECDHE), §7.4.2
# (shared-secret X-coordinate); RFC 8422 §5.4; SEC2 v2.0 §2.4.2.

use std.spipe.*

use os.crypto.ecdh_p256.{p256_keypair_pub, p256_ecdh_shared_x}
use os.tls13.transcript.{Transcript, transcript_new, transcript_add}
use os.tls13.key_schedule.{
    Tls13Secrets, TrafficKeys,
    tls13_compute_handshake_secrets, tls13_traffic_keys
}

# ============================================================================
# AC-1: Pubkey shape — 65-byte uncompressed `04 || X || Y` per RFC 8422 §5.4
# ============================================================================

describe "P-256 ephemeral pubkeys are 65-byte uncompressed SEC1 points":

    it "client pub is 65 bytes":
        # Inline build of client scalar 0x31..0x50 (32 bytes BE).
        var sc: [u8] = []
        var i: u64 = 0u64
        while i < 32u64:
            sc.push((0x31u8 + i.to_u8()))
            i = i + 1u64
        val pub_c = p256_keypair_pub(sc)
        expect pub_c.len().to_u64() == 65u64

    it "server pub is 65 bytes":
        # Inline build of server scalar 0x91..0xb0 (32 bytes BE).
        var sc: [u8] = []
        var i: u64 = 0u64
        while i < 32u64:
            sc.push((0x91u8 + i.to_u8()))
            i = i + 1u64
        val pub_s = p256_keypair_pub(sc)
        expect pub_s.len().to_u64() == 65u64

# ============================================================================
# AC-2: ECDHE symmetry — client*server == server*client; 32-byte shared X
# ============================================================================

describe "P-256 ECDHE produces a symmetric 32-byte shared X":

    it "client_priv * server_pub yields 32 bytes":
        var sc_c: [u8] = []
        var sc_s: [u8] = []
        var i: u64 = 0u64
        while i < 32u64:
            sc_c.push((0x31u8 + i.to_u8()))
            sc_s.push((0x91u8 + i.to_u8()))
            i = i + 1u64
        val pub_s = p256_keypair_pub(sc_s)
        val sh_c = p256_ecdh_shared_x(sc_c, pub_s)
        expect sh_c.len().to_u64() == 32u64

    it "server_priv * client_pub yields 32 bytes":
        var sc_c: [u8] = []
        var sc_s: [u8] = []
        var i: u64 = 0u64
        while i < 32u64:
            sc_c.push((0x31u8 + i.to_u8()))
            sc_s.push((0x91u8 + i.to_u8()))
            i = i + 1u64
        val pub_c = p256_keypair_pub(sc_c)
        val sh_s = p256_ecdh_shared_x(sc_s, pub_c)
        expect sh_s.len().to_u64() == 32u64

    it "client and server agree byte-for-byte on shared X":
        var sc_c: [u8] = []
        var sc_s: [u8] = []
        var i: u64 = 0u64
        while i < 32u64:
            sc_c.push((0x31u8 + i.to_u8()))
            sc_s.push((0x91u8 + i.to_u8()))
            i = i + 1u64
        val pub_c = p256_keypair_pub(sc_c)
        val pub_s = p256_keypair_pub(sc_s)
        val sh_c = p256_ecdh_shared_x(sc_c, pub_s)
        val sh_s = p256_ecdh_shared_x(sc_s, pub_c)
        # Byte-equal check (avoid fn-call helper for the same regression
        # surface; inline the loop).
        var equal: bool = sh_c.len() == sh_s.len()
        var j: u64 = 0u64
        while equal and j < sh_c.len():
            if sh_c[j] != sh_s[j]:
                equal = false
            j = j + 1u64
        expect equal == true

# ============================================================================
# AC-3: handshake_secret derivation (RFC 8446 §7.1, SHA-256 / cipher 0x1301)
# ============================================================================

describe "tls13_compute_handshake_secrets fed with P-256 shared X":

    it "yields 32-byte handshake_secret + 32-byte hs traffic secrets":
        var sc_c: [u8] = []
        var sc_s: [u8] = []
        var i: u64 = 0u64
        while i < 32u64:
            sc_c.push((0x31u8 + i.to_u8()))
            sc_s.push((0x91u8 + i.to_u8()))
            i = i + 1u64
        val pub_s = p256_keypair_pub(sc_s)
        val sh_c = p256_ecdh_shared_x(sc_c, pub_s)
        # Build a synthetic transcript inline.
        var seed: [u8] = []
        var k: u64 = 0u64
        while k < 64u64:
            seed.push((k.to_u8() ^ 0x5au8))
            k = k + 1u64
        var t = transcript_new()
        t = transcript_add(t, seed)
        val secrets = tls13_compute_handshake_secrets(sh_c, t)
        expect secrets.handshake_secret.len().to_u64() == 32u64
        expect secrets.client_hs_traffic.len().to_u64() == 32u64
        expect secrets.server_hs_traffic.len().to_u64() == 32u64

    it "client and server derive byte-identical handshake_secret":
        var sc_c: [u8] = []
        var sc_s: [u8] = []
        var i: u64 = 0u64
        while i < 32u64:
            sc_c.push((0x31u8 + i.to_u8()))
            sc_s.push((0x91u8 + i.to_u8()))
            i = i + 1u64
        val pub_c = p256_keypair_pub(sc_c)
        val pub_s = p256_keypair_pub(sc_s)
        val sh_c = p256_ecdh_shared_x(sc_c, pub_s)
        val sh_s = p256_ecdh_shared_x(sc_s, pub_c)
        var seed: [u8] = []
        var k: u64 = 0u64
        while k < 64u64:
            seed.push((k.to_u8() ^ 0x5au8))
            k = k + 1u64
        var t1 = transcript_new()
        t1 = transcript_add(t1, seed)
        var t2 = transcript_new()
        t2 = transcript_add(t2, seed)
        val secrets_c = tls13_compute_handshake_secrets(sh_c, t1)
        val secrets_s = tls13_compute_handshake_secrets(sh_s, t2)
        var equal: bool = secrets_c.handshake_secret.len() == secrets_s.handshake_secret.len()
        var j: u64 = 0u64
        while equal and j < secrets_c.handshake_secret.len():
            if secrets_c.handshake_secret[j] != secrets_s.handshake_secret[j]:
                equal = false
            j = j + 1u64
        expect equal == true

    it "client and server derive byte-identical client_hs_traffic":
        var sc_c: [u8] = []
        var sc_s: [u8] = []
        var i: u64 = 0u64
        while i < 32u64:
            sc_c.push((0x31u8 + i.to_u8()))
            sc_s.push((0x91u8 + i.to_u8()))
            i = i + 1u64
        val pub_c = p256_keypair_pub(sc_c)
        val pub_s = p256_keypair_pub(sc_s)
        val sh_c = p256_ecdh_shared_x(sc_c, pub_s)
        val sh_s = p256_ecdh_shared_x(sc_s, pub_c)
        var seed: [u8] = []
        var k: u64 = 0u64
        while k < 64u64:
            seed.push((k.to_u8() ^ 0x5au8))
            k = k + 1u64
        var t1 = transcript_new()
        t1 = transcript_add(t1, seed)
        var t2 = transcript_new()
        t2 = transcript_add(t2, seed)
        val secrets_c = tls13_compute_handshake_secrets(sh_c, t1)
        val secrets_s = tls13_compute_handshake_secrets(sh_s, t2)
        var equal: bool = secrets_c.client_hs_traffic.len() == secrets_s.client_hs_traffic.len()
        var j: u64 = 0u64
        while equal and j < secrets_c.client_hs_traffic.len():
            if secrets_c.client_hs_traffic[j] != secrets_s.client_hs_traffic[j]:
                equal = false
            j = j + 1u64
        expect equal == true

    it "client and server derive byte-identical server_hs_traffic":
        var sc_c: [u8] = []
        var sc_s: [u8] = []
        var i: u64 = 0u64
        while i < 32u64:
            sc_c.push((0x31u8 + i.to_u8()))
            sc_s.push((0x91u8 + i.to_u8()))
            i = i + 1u64
        val pub_c = p256_keypair_pub(sc_c)
        val pub_s = p256_keypair_pub(sc_s)
        val sh_c = p256_ecdh_shared_x(sc_c, pub_s)
        val sh_s = p256_ecdh_shared_x(sc_s, pub_c)
        var seed: [u8] = []
        var k: u64 = 0u64
        while k < 64u64:
            seed.push((k.to_u8() ^ 0x5au8))
            k = k + 1u64
        var t1 = transcript_new()
        t1 = transcript_add(t1, seed)
        var t2 = transcript_new()
        t2 = transcript_add(t2, seed)
        val secrets_c = tls13_compute_handshake_secrets(sh_c, t1)
        val secrets_s = tls13_compute_handshake_secrets(sh_s, t2)
        var equal: bool = secrets_c.server_hs_traffic.len() == secrets_s.server_hs_traffic.len()
        var j: u64 = 0u64
        while equal and j < secrets_c.server_hs_traffic.len():
            if secrets_c.server_hs_traffic[j] != secrets_s.server_hs_traffic[j]:
                equal = false
            j = j + 1u64
        expect equal == true

# ============================================================================
# AC-4: traffic key + IV derivation (16B AES-128 key + 12B IV; cipher 0x1301)
# ============================================================================

describe "tls13_traffic_keys over P-256-derived handshake-traffic secrets":

    it "client AES-128 key is 16 bytes and IV is 12 bytes":
        var sc_c: [u8] = []
        var sc_s: [u8] = []
        var i: u64 = 0u64
        while i < 32u64:
            sc_c.push((0x31u8 + i.to_u8()))
            sc_s.push((0x91u8 + i.to_u8()))
            i = i + 1u64
        val pub_s = p256_keypair_pub(sc_s)
        val sh_c = p256_ecdh_shared_x(sc_c, pub_s)
        var seed: [u8] = []
        var k: u64 = 0u64
        while k < 64u64:
            seed.push((k.to_u8() ^ 0x5au8))
            k = k + 1u64
        var t = transcript_new()
        t = transcript_add(t, seed)
        val secrets = tls13_compute_handshake_secrets(sh_c, t)
        val tk = tls13_traffic_keys(secrets.client_hs_traffic)
        expect tk.key.len().to_u64() == 16u64
        expect tk.iv.len().to_u64() == 12u64

    it "server AES-128 key is 16 bytes and IV is 12 bytes":
        var sc_c: [u8] = []
        var sc_s: [u8] = []
        var i: u64 = 0u64
        while i < 32u64:
            sc_c.push((0x31u8 + i.to_u8()))
            sc_s.push((0x91u8 + i.to_u8()))
            i = i + 1u64
        val pub_s = p256_keypair_pub(sc_s)
        val sh_c = p256_ecdh_shared_x(sc_c, pub_s)
        var seed: [u8] = []
        var k: u64 = 0u64
        while k < 64u64:
            seed.push((k.to_u8() ^ 0x5au8))
            k = k + 1u64
        var t = transcript_new()
        t = transcript_add(t, seed)
        val secrets = tls13_compute_handshake_secrets(sh_c, t)
        val tk = tls13_traffic_keys(secrets.server_hs_traffic)
        expect tk.key.len().to_u64() == 16u64
        expect tk.iv.len().to_u64() == 12u64