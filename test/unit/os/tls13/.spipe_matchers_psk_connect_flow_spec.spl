# PSK + 0-RTT connect-flow byte-level spec — RFC 8446 §4.1.4 + §4.2.11 + §4.2.9
#
# Wave 13 closeout: byte-level coverage of the PSK splice path that
# tls13_connect_io_with_config invokes. W11-B already covers the primitives
# (encode_offered_psk_partial, tls13_compute_psk_binder, etc.); this spec
# locks down the connect-flow integration:
#
#   1. _splice_psk_extensions_into_ch produces wire bytes ending with
#      pre_shared_key extension (RFC 8446 §4.2.11 — MUST be last).
#   2. The bytes-before-binders length matches the documented offset
#      (binders_field_offset is the offset of the binders_len u16 field).
#   3. The partial-CH transcript hash STOPS at end of identities, NOT at
#      end of zeroed binders block (RFC 8446 §4.1.4 third paragraph).
#   4. Spliced binder bytes round-trip byte-exact what
#      tls13_compute_psk_binder produces — same input, same MAC, same wire.
#   5. psk_key_exchange_modes extension (type 0x002d) is present in the CH.
#   6. ServerHello with selected_identity=0 → swap to PSK-fed early_secret.
#   7. ServerHello without pre_shared_key → fall back to empty-PSK early_secret.

use std.spipe.*
use os.tls13.tls13.{
    Tls13ClientConfig, Tls13Io, PskCh,
    _splice_psk_extensions_into_ch, _splice_binder_bytes,
    _partial_ch_transcript_hash, _parse_sh_selected_identity,
    tls13_default_client_config,
}
use os.tls13.handshake13.{build_client_hello_bytes}
use os.tls13.key_schedule.{
    tls13_early_secret_from_psk, tls13_binder_key, tls13_compute_psk_binder,
}
use os.crypto.sha256.{sha256_hmac}
use os.tls13.hkdf.{hkdf_expand_label}

extern fn rt_bytes_u8_at(arr: [u8], idx: i64) -> i64
extern fn rt_tls13_sha256(data: [u8]) -> [u8]

# ============================================================================
# Module-level helpers — keep loop-mutated locals out of it-blocks
# ============================================================================

fn _u8_get(buf: [u8], i: u64) -> u8:
    rt_bytes_u8_at(buf, i.to_i64()).to_u8()

# Workaround for interpreter bug (push of u8 literal/var loses value):
# always route push through _pb(buf, n: i64) which casts via .to_u8() on
# arithmetic. See doc/08_tracking/bug/interpreter_array_push_u8_literal_lost_2026-05-02.md.
fn _pb(buf: [u8], n: i64) -> [u8]:
    var out = buf
    out.push((n & 0xFF).to_u8())
    out

fn _zeros(n: u64) -> [u8]:
    var out: [u8] = []
    var i: u64 = 0
    while i < n:
        out = _pb(out, 0)
        i = i + 1
    out

fn _seq_n(n: u64, byte_val: u8) -> [u8]:
    var out: [u8] = []
    var i: u64 = 0
    while i < n:
        out = _pb(out, byte_val.to_i64())
        i = i + 1
    out

fn _bytes_eq(a: [u8], b: [u8]) -> bool:
    if a.len() != b.len():
        return false
    var i: u64 = 0
    val n = a.len().to_u64()
    while i < n:
        if _u8_get(a, i) != _u8_get(b, i):
            return false
        i = i + 1
    true

fn _make_psk_config(psk_secret: [u8], identity: [u8]) -> Tls13ClientConfig:
    var c = tls13_default_client_config()
    Tls13ClientConfig(
        client_cert_chain: c.client_cert_chain,
        client_pkcs8: c.client_pkcs8,
        client_sig_scheme: c.client_sig_scheme,
        root_store: c.root_store,
        offered_psk_count: 1u32,
        offered_psk_identity: identity,
        offered_psk_secret: psk_secret,
        offered_psk_age_ms: 0u32,
        offered_psk_age_add: 0u32,
        offered_psk_hash_id: 1u8,
        offered_psk_is_resumption: true,
        offer_early_data: false,
        early_data_payload: [],
    )

fn _ch_random32() -> [u8]:
    _seq_n(32u64, 0xa5u8)

fn _x25519_pub32() -> [u8]:
    _seq_n(32u64, 0x42u8)

fn _check_ext_type_at(buf: [u8], off: u64, hi: u8, lo: u8) -> bool:
    if (off + 1u64) >= buf.len():
        return false
    _u8_get(buf, off) == hi and _u8_get(buf, off + 1u64) == lo

fn _scan_for_ext_type(wire: [u8], type_hi: i64, type_lo: i64) -> bool:
    """Module-level scan helper — keep loop state out of it-blocks."""
    var found = false
    var i: u64 = 0
    val n = wire.len().to_u64()
    while (i + 1u64) < n:
        val a = rt_bytes_u8_at(wire, i.to_i64())
        val b = rt_bytes_u8_at(wire, (i + 1u64).to_i64())
        if a == type_hi and b == type_lo:
            found = true
        i = i + 1
    found

fn _build_prefix_to(wire: [u8], end: u64) -> [u8]:
    """Module-level prefix-builder — keep loop state out of it-blocks."""
    var prefix: [u8] = []
    var i: u64 = 0
    while i < end:
        prefix = _pb(prefix, rt_bytes_u8_at(wire, i.to_i64()))
        i = i + 1
    prefix

fn _build_sh_body_with_psk(selected_identity: u16) -> [u8]:
    """Build a synthetic SH body with a pre_shared_key extension."""
    var body: [u8] = []
    body = _pb(body, 0x03)
    body = _pb(body, 0x03)                                # legacy_version
    var r: u64 = 0
    while r < 32u64:
        body = _pb(body, 0)
        r = r + 1
    body = _pb(body, 0)                                   # sid_len = 0
    body = _pb(body, 0x13)
    body = _pb(body, 0x01)                                # cipher_suite
    body = _pb(body, 0)                                   # comp = 0
    # extensions block: pre_shared_key(0x29) ext_data_len=2, value=selected_identity
    body = _pb(body, 0x00)
    body = _pb(body, 0x06)                                # ext_len = 6
    body = _pb(body, 0x00)
    body = _pb(body, 0x29)                                # ext type
    body = _pb(body, 0x00)
    body = _pb(body, 0x02)                                # ext data len = 2
    body = _pb(body, ((selected_identity.to_u32() >> 8) & 0xFF).to_i64())
    body = _pb(body, (selected_identity.to_u32() & 0xFF).to_i64())
    body

fn _build_sh_body_no_psk() -> [u8]:
    """Build a synthetic SH body without pre_shared_key (only supported_versions)."""
    var body: [u8] = []
    body = _pb(body, 0x03)
    body = _pb(body, 0x03)
    var r: u64 = 0
    while r < 32u64:
        body = _pb(body, 0)
        r = r + 1
    body = _pb(body, 0)
    body = _pb(body, 0x13)
    body = _pb(body, 0x01)
    body = _pb(body, 0)
    # extensions block: supported_versions only
    body = _pb(body, 0x00)
    body = _pb(body, 0x06)
    body = _pb(body, 0x00)
    body = _pb(body, 0x2b)
    body = _pb(body, 0x00)
    body = _pb(body, 0x02)
    body = _pb(body, 0x03)
    body = _pb(body, 0x04)
    body

# ============================================================================
# Specs
# ============================================================================

describe("PSK connect-flow splice — RFC 8446 §4.1.4 + §4.2.11 + §4.2.9"):

    it("partial-CH binders_field_offset places binders_len after identities"):
        # Build a CH with our PSK config and check that the offset matches
        # ext_data_len semantics: ext_data starts with u16 ids_len + ids,
        # followed by binders_len u16 at binders_field_offset.
        val cfg = _make_psk_config(_seq_n(32u64, 0x11u8), _seq_n(8u64, 0x77u8))
        val ch_base = build_client_hello_bytes(_ch_random32(), _x25519_pub32(), "example.com")
        val psk_ch = _splice_psk_extensions_into_ch(ch_base, cfg)
        val wire = psk_ch.bytes
        # binders_data_offset must equal binders_field_offset + 2
        expect psk_ch.binders_data_offset == psk_ch.binders_field_offset + 2u64
        # The bytes at binders_field_offset..binders_field_offset+2 are the
        # binders_len u16 = 1 (1-byte plen) + 32 (binder body) = 33.
        val bl_hi = _u8_get(wire, psk_ch.binders_field_offset).to_u32()
        val bl_lo = _u8_get(wire, psk_ch.binders_field_offset + 1u64).to_u32()
        val bl = ((bl_hi << 8) | bl_lo)
        expect bl == 33u32
        # The byte at binders_data_offset is the per-binder length prefix = 32.
        expect _u8_get(wire, psk_ch.binders_data_offset) == 32u8

    it("pre_shared_key extension is the LAST extension in CH (RFC 8446 §4.2.11)"):
        val cfg = _make_psk_config(_seq_n(32u64, 0x11u8), _seq_n(8u64, 0x77u8))
        val ch_base = build_client_hello_bytes(_ch_random32(), _x25519_pub32(), "example.com")
        val psk_ch = _splice_psk_extensions_into_ch(ch_base, cfg)
        # The last extension must start with type 0x00 0x29 (pre_shared_key).
        # Walk back from end: the binders block sits at the tail. The whole
        # pre_shared_key extension starts at psk_ch.binders_field_offset - 4 - ids_len_plus_2.
        # Simpler: the binders_data_offset + binder_len(33) should equal wire.len().
        val expected_end = psk_ch.binders_data_offset + 33u64
        expect expected_end == psk_ch.bytes.len().to_u64()

    it("psk_key_exchange_modes extension (type 0x002d) is present in CH"):
        val cfg = _make_psk_config(_seq_n(32u64, 0x11u8), _seq_n(8u64, 0x77u8))
        val ch_base = build_client_hello_bytes(_ch_random32(), _x25519_pub32(), "example.com")
        val psk_ch = _splice_psk_extensions_into_ch(ch_base, cfg)
        # Module-level helper to keep the scan loop out of the it-block
        # (interpreter doesn't persist var mutations across while iterations
        # inside it-blocks; see feedback_it_block_var_mutation.md).
        val found = _scan_for_ext_type(psk_ch.bytes, 0x00, 0x2d)
        expect found == true

    it("partial-CH transcript hash stops at end of identities (RFC 8446 §4.1.4)"):
        # The hash STOPS at binders_field_offset, NOT at end of zeroed binders.
        # _partial_ch_transcript_hash must equal SHA-256(wire[0..binders_field_offset]).
        val cfg = _make_psk_config(_seq_n(32u64, 0x11u8), _seq_n(8u64, 0x77u8))
        val ch_base = build_client_hello_bytes(_ch_random32(), _x25519_pub32(), "example.com")
        val psk_ch = _splice_psk_extensions_into_ch(ch_base, cfg)
        val got = _partial_ch_transcript_hash(psk_ch.bytes, psk_ch, 1u8)
        # Independent SHA-256 over the same prefix using a module-level helper
        # to keep the prefix-build loop out of the it-block.
        val prefix = _build_prefix_to(psk_ch.bytes, psk_ch.binders_field_offset)
        val expected = rt_tls13_sha256(prefix)
        expect got.len() == 32
        expect _bytes_eq(got, expected) == true

    it("partial-CH transcript hash is NOT the same as hashing including zero binders"):
        # Negative check: hashing [0..end_of_binders] would produce a DIFFERENT
        # digest than [0..binders_field_offset]. RFC 8446 §4.1.4 mandates the
        # latter; this guards against the silent wrong interpretation.
        val cfg = _make_psk_config(_seq_n(32u64, 0x11u8), _seq_n(8u64, 0x77u8))
        val ch_base = build_client_hello_bytes(_ch_random32(), _x25519_pub32(), "example.com")
        val psk_ch = _splice_psk_extensions_into_ch(ch_base, cfg)
        val got = _partial_ch_transcript_hash(psk_ch.bytes, psk_ch, 1u8)
        # Hash including the binders block (binders_len + zeroed binders).
        var full: [u8] = []
        var i: u64 = 0
        val end = psk_ch.bytes.len().to_u64()
        while i < end:
            full = _pb(full, rt_bytes_u8_at(psk_ch.bytes, i.to_i64()))
            i = i + 1
        val full_hash = rt_tls13_sha256(full)
        expect _bytes_eq(got, full_hash) == false

    it("spliced binder MAC matches tls13_compute_psk_binder byte-exact"):
        # Compute binder via the same path as tls13_connect_io_with_config and
        # verify the spliced wire bytes contain exactly that MAC.
        val psk_secret = _seq_n(32u64, 0x11u8)
        val cfg = _make_psk_config(psk_secret, _seq_n(8u64, 0x77u8))
        val ch_base = build_client_hello_bytes(_ch_random32(), _x25519_pub32(), "example.com")
        val psk_ch = _splice_psk_extensions_into_ch(ch_base, cfg)
        val partial_th = _partial_ch_transcript_hash(psk_ch.bytes, psk_ch, 1u8)
        val es = tls13_early_secret_from_psk(psk_secret, 1u8)
        val bk = tls13_binder_key(es, 1u8, true)
        val mac = tls13_compute_psk_binder(bk, partial_th, 1u8)
        var binders: [[u8]] = []
        binders.push(mac)
        val spliced = _splice_binder_bytes(psk_ch.bytes, psk_ch, binders)
        # Verify byte-exact: bytes[binders_data_offset+1 ..+33] == mac.
        var ok = true
        var i: u64 = 0
        while i < 32:
            val abs_off = psk_ch.binders_data_offset + 1u64 + i
            if _u8_get(spliced, abs_off) != _u8_get(mac, i):
                ok = false
            i = i + 1
        expect ok == true
        # Length unchanged after splice.
        expect spliced.len() == psk_ch.bytes.len()

    it("ServerHello with pre_shared_key selected_identity=0 returns 0"):
        val body = _build_sh_body_with_psk(0u16)
        val sel = _parse_sh_selected_identity(body)
        expect sel == 0

    it("ServerHello without pre_shared_key returns -1 (no PSK selected)"):
        val body = _build_sh_body_no_psk()
        val sel = _parse_sh_selected_identity(body)
        expect sel == -1