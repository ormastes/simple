# TLS 1.3 server-side wire-format invariants spec — RFC 8446
#
# Exercises the pure builders + selectors in src/os/tls13/server.spl.
# Bytes-only — no live socket, no syscalls. The full tls13_accept entry
# point currently returns Failed("not_implemented") and is not exercised
# end-to-end here; that lands with the server-side record I/O loop.
#
# Cases covered:
#   1. process_client_hello: parses random + cipher_suites + named_groups
#      + key_share groups + X25519 share + supported_versions=TLS1.3.
#   2. process_client_hello: rejects malformed CH (returns empty CH13).
#   3. select_cipher_suite: matches 0x1301 with deterministic preference.
#   4. select_cipher_suite: returns 0u16 if no overlap.
#   5. select_named_group: prefers X25519 over P-256 when both offered.
#   6. select_named_group: returns 0u16 if CH offered no acceptable group
#      (HRR-needed sentinel).
#   7. build_server_hello: legacy_version=0x0303, server_random copied,
#      legacy_session_id_len=0, cipher_suite present, compression=0x00,
#      extensions length-prefixed.
#   8. build_server_hello: handshake header type=2 + 3-byte length.
#   9. build_encrypted_extensions_server_side: empty extension list per
#      RFC 8446 §4.3.1 (length=0, no body).
#  10. build_certificate: handshake type=11 + non-zero length.
#  11. build_certificate_verify: round-trip — sign over signing input,
#      parse-back algorithm + signature length.
#  12. build_certificate_verify_signing_input: matches §4.4.3 prefix
#      (64×0x20 + "TLS 1.3, server CertificateVerify" + 0x00 + transcript).
#
# Reference: RFC 8446 §4.1.2, §4.1.3, §4.3.1, §4.4.2, §4.4.3.

use std.spipe.*
use os.tls13.server.{
    process_client_hello,
    select_cipher_suite, select_named_group,
    build_server_hello, build_encrypted_extensions_server_side,
    build_certificate, build_certificate_verify,
    build_certificate_verify_signing_input,
    ClientHello13, Tls13ServerConfig
}
use std.nogc_sync_mut.io.signature_ffi.{ed25519_sign, ed25519_verify}

# ============================================================================
# Test fixtures — deterministic CH bytes + key material
# ============================================================================

# Same Ed25519 PKCS#8 fixture used by test/system/os_rt_ed25519_sign_spec.spl.
# Pre-computed below as raw bytes so we don't pull in hex_to_bytes here.
# Hex source: 302e020100300506032b6570042204201f80192e224a71dddf8c082c7690db
#             9fdf583f3d4e02a19b77d0f8692f2ea40c
fn _ed25519_pkcs8() -> [u8]:
    var out: [u8] = []
    out.push(0x30u8)
    out.push(0x2eu8)
    out.push(0x02u8)
    out.push(0x01u8)
    out.push(0x00u8)
    out.push(0x30u8)
    out.push(0x05u8)
    out.push(0x06u8)
    out.push(0x03u8)
    out.push(0x2bu8)
    out.push(0x65u8)
    out.push(0x70u8)
    out.push(0x04u8)
    out.push(0x22u8)
    out.push(0x04u8)
    out.push(0x20u8)
    out.push(0x1fu8)
    out.push(0x80u8)
    out.push(0x19u8)
    out.push(0x2eu8)
    out.push(0x22u8)
    out.push(0x4au8)
    out.push(0x71u8)
    out.push(0xddu8)
    out.push(0xdfu8)
    out.push(0x8cu8)
    out.push(0x08u8)
    out.push(0x2cu8)
    out.push(0x76u8)
    out.push(0x90u8)
    out.push(0xdbu8)
    out.push(0x9fu8)
    out.push(0xdfu8)
    out.push(0x58u8)
    out.push(0x3fu8)
    out.push(0x3du8)
    out.push(0x4eu8)
    out.push(0x02u8)
    out.push(0xa1u8)
    out.push(0x9bu8)
    out.push(0x77u8)
    out.push(0xd0u8)
    out.push(0xf8u8)
    out.push(0x69u8)
    out.push(0x2fu8)
    out.push(0x2eu8)
    out.push(0xa4u8)
    out.push(0x0cu8)
    out

# 32-byte transcript hash (SHA-256-shaped) — content does not matter for
# byte-format invariants; only the length matters.
fn _transcript_hash_32() -> [u8]:
    var out: [u8] = []
    var i: u64 = 0
    while i < 32u64:
        out.push((0x10u8 + i.to_u8()).to_u8())
        i = i + 1u64
    out

fn _server_random_32() -> [u8]:
    var out: [u8] = []
    var i: u64 = 0
    while i < 32u64:
        out.push(0xA0u8 + i.to_u8())
        i = i + 1u64
    out

fn _x25519_pub_32() -> [u8]:
    var out: [u8] = []
    var i: u64 = 0
    while i < 32u64:
        out.push(0x50u8 + i.to_u8())
        i = i + 1u64
    out

# Build a valid minimal TLS 1.3 ClientHello body offering 0x1301 +
# 0x1303, supported_groups [X25519, P-256], supported_versions [TLS1.3],
# and a key_share for X25519 only.
fn _ch_body_x25519_only() -> [u8]:
    var b: [u8] = []
    # legacy_version
    b.push(0x03u8)
    b.push(0x03u8)
    # client_random — 32 bytes of pattern
    var i: u64 = 0
    while i < 32u64:
        b.push(0x00u8)
        i = i + 1u64
    # legacy_session_id_len = 0
    b.push(0x00u8)
    # cipher_suites: 4 bytes (2 suites): 0x1301 + 0x1303
    b.push(0x00u8)
    b.push(0x04u8)
    b.push(0x13u8)
    b.push(0x01u8)
    b.push(0x13u8)
    b.push(0x03u8)
    # legacy_compression_methods: 0x01 0x00
    b.push(0x01u8)
    b.push(0x00u8)

    # extensions
    var exts: [u8] = []

    # supported_versions (43): list_len=1+ list_data=2 bytes (TLS 1.3)
    exts.push(0x00u8)
    exts.push(0x2bu8)  # ext_type 43
    exts.push(0x00u8)
    exts.push(0x03u8)  # ext_len = 3
    exts.push(0x02u8)  # versions_len byte
    exts.push(0x03u8)
    exts.push(0x04u8)  # 0x0304

    # supported_groups (10): list_len=4 bytes, X25519+P-256
    exts.push(0x00u8)
    exts.push(0x0au8)
    exts.push(0x00u8)
    exts.push(0x06u8)  # ext_len = 6
    exts.push(0x00u8)
    exts.push(0x04u8)  # groups_list_len
    exts.push(0x00u8)
    exts.push(0x1du8)  # X25519
    exts.push(0x00u8)
    exts.push(0x17u8)  # secp256r1

    # key_share (51): one entry for X25519 (32-byte key)
    exts.push(0x00u8)
    exts.push(0x33u8)
    # ext_len = 2 (client_shares_len) + 4 (header) + 32 (key) = 38
    exts.push(0x00u8)
    exts.push(0x26u8)
    # client_shares_len = 36 (2 bytes header + 32 bytes key + 2-byte group)
    exts.push(0x00u8)
    exts.push(0x24u8)
    exts.push(0x00u8)
    exts.push(0x1du8)  # group X25519
    exts.push(0x00u8)
    exts.push(0x20u8)  # key_len = 32
    var k: u64 = 0
    while k < 32u64:
        exts.push(0x50u8 + k.to_u8())
        k = k + 1u64

    # Append extensions length-prefixed
    val n = exts.len()
    b.push(((n >> 8) & 0xFF).to_u8())
    b.push((n & 0xFF).to_u8())
    var j: u64 = 0
    while j < n:
        b.push(exts[j])
        j = j + 1u64
    b

# A degenerate CH body — too short to even contain legacy_version + random.
fn _ch_body_truncated() -> [u8]:
    var b: [u8] = []
    b.push(0x03u8)
    b.push(0x03u8)
    b

# ============================================================================
# process_client_hello
# ============================================================================

describe "process_client_hello":

    it "parses random, cipher_suites, key_share, supported_versions":
        val ch = process_client_hello(_ch_body_x25519_only())
        expect ch.random.len().to_u64() == 32u64
        expect ch.cipher_suites.len().to_u64() == 2u64
        expect ch.cipher_suites[0u64] == 0x1301u16
        expect ch.cipher_suites[1u64] == 0x1303u16
        expect ch.named_groups.len().to_u64() == 2u64
        expect ch.named_groups[0u64] == 0x001Du16
        expect ch.named_groups[1u64] == 0x0017u16
        expect ch.key_share_groups.len().to_u64() == 1u64
        expect ch.key_share_groups[0u64] == 0x001Du16
        expect ch.x25519_key_share.len().to_u64() == 32u64
        expect ch.p256_key_share.len().to_u64() == 0u64
        expect ch.has_supported_versions_tls13 == true

    it "returns empty CH on truncated body":
        val ch = process_client_hello(_ch_body_truncated())
        expect ch.random.len().to_u64() == 0u64
        expect ch.cipher_suites.len().to_u64() == 0u64
        expect ch.has_supported_versions_tls13 == false

# ============================================================================
# select_cipher_suite — RFC 8446 §4.1.1 server preference
# ============================================================================

describe "select_cipher_suite":

    it "picks the server's preferred suite that the client offered":
        var client: [u16] = []
        client.push(0x1301u16)
        client.push(0x1303u16)
        var server: [u16] = []
        server.push(0x1303u16)
        server.push(0x1301u16)
        # server prefers 0x1303; client offered it; expect 0x1303
        expect select_cipher_suite(client, server) == 0x1303u16

    it "returns 0u16 when no overlap":
        var client: [u16] = []
        client.push(0x9999u16)
        var server: [u16] = []
        server.push(0x1301u16)
        expect select_cipher_suite(client, server) == 0u16

    it "rejects non-mandatory suite codes even if both lists agree":
        # 0x9999 is not in the 0x1301/0x1302/0x1303 allowlist
        var client: [u16] = []
        client.push(0x9999u16)
        var server: [u16] = []
        server.push(0x9999u16)
        expect select_cipher_suite(client, server) == 0u16

# ============================================================================
# select_named_group — RFC 8446 §4.2.7 server preference
# ============================================================================

describe "select_named_group":

    it "prefers X25519 over P-256 when both offered":
        var ks: [u16] = []
        ks.push(0x001Du16)
        ks.push(0x0017u16)
        var server: [u16] = []
        server.push(0x001Du16)
        server.push(0x0017u16)
        expect select_named_group(ks, server) == 0x001Du16

    it "returns 0u16 when CH key_share has no acceptable group (HRR-needed)":
        var ks: [u16] = []
        ks.push(0x0018u16)  # secp384r1 — not in our supported list
        var server: [u16] = []
        server.push(0x001Du16)
        server.push(0x0017u16)
        expect select_named_group(ks, server) == 0u16

    it "falls back to P-256 when X25519 key_share absent":
        var ks: [u16] = []
        ks.push(0x0017u16)
        var server: [u16] = []
        server.push(0x001Du16)
        server.push(0x0017u16)
        expect select_named_group(ks, server) == 0x0017u16

# ============================================================================
# build_server_hello — RFC 8446 §4.1.3 wire format
# ============================================================================

describe "build_server_hello byte structure":

    it "emits handshake header type=2 + 3-byte length":
        val sh = build_server_hello(_server_random_32(), 0x1301u16, 0x001Du16, _x25519_pub_32())
        # type byte
        expect sh[0u64] == 0x02u8
        # length is 3 bytes; total bytes = 4 + length_value
        val len_val: u64 = (sh[1u64].to_u64() << 16) | (sh[2u64].to_u64() << 8) | sh[3u64].to_u64()
        expect (sh.len().to_u64() - 4u64) == len_val == true

    it "encodes legacy_version=0x0303 and copies server_random":
        val sh = build_server_hello(_server_random_32(), 0x1301u16, 0x001Du16, _x25519_pub_32())
        expect sh[4u64] == 0x03u8
        expect sh[5u64] == 0x03u8
        # server_random: bytes 6..38 must equal _server_random_32()
        var ok = true
        var i: u64 = 0
        val rnd = _server_random_32()
        while i < 32u64 and ok:
            if sh[6u64 + i] != rnd[i]:
                ok = false
            i = i + 1u64
        expect ok == true

    it "encodes legacy_session_id_len=0 + cipher_suite + compression=0x00":
        val sh = build_server_hello(_server_random_32(), 0x1303u16, 0x001Du16, _x25519_pub_32())
        # offset 4 + 2 + 32 = 38: legacy_session_id_len
        expect sh[38u64] == 0x00u8
        # offset 39..41: cipher_suite (2 bytes)
        expect sh[39u64] == 0x13u8
        expect sh[40u64] == 0x03u8
        # offset 41: compression_method
        expect sh[41u64] == 0x00u8

    it "encodes a non-zero extensions length":
        val sh = build_server_hello(_server_random_32(), 0x1301u16, 0x001Du16, _x25519_pub_32())
        # extensions_len at offset 42..44
        val ext_len: u64 = (sh[42u64].to_u64() << 8) | sh[43u64].to_u64()
        expect ext_len > 0u64 == true

    it "is deterministic — same inputs produce identical bytes":
        val a = build_server_hello(_server_random_32(), 0x1301u16, 0x001Du16, _x25519_pub_32())
        val b = build_server_hello(_server_random_32(), 0x1301u16, 0x001Du16, _x25519_pub_32())
        expect a.len() == b.len()
        var same = true
        var i: u64 = 0
        while i < a.len().to_u64() and same:
            if a[i] != b[i]:
                same = false
            i = i + 1u64
        expect same == true

# ============================================================================
# build_encrypted_extensions_server_side — RFC 8446 §4.3.1
# ============================================================================

describe "build_encrypted_extensions_server_side":

    it "emits handshake type=8 + length=2 + zero-length extensions list":
        val cfg = Tls13ServerConfig(
            cert_chain: [],
            server_pkcs8: _ed25519_pkcs8(),
            server_sig_scheme: 0x0807u16,
            alpn_protocols: []
        )
        val ee = build_encrypted_extensions_server_side(cfg)
        # type byte
        expect ee[0u64] == 0x08u8
        # body length = 2 (the empty extensions list_len)
        expect ee[1u64] == 0x00u8
        expect ee[2u64] == 0x00u8
        expect ee[3u64] == 0x02u8
        # list_len bytes
        expect ee[4u64] == 0x00u8
        expect ee[5u64] == 0x00u8
        expect ee.len().to_u64() == 6u64

# ============================================================================
# build_certificate — RFC 8446 §4.4.2
# ============================================================================

describe "build_certificate":

    it "emits handshake type=11 with non-zero body":
        var cert_chain: [[u8]] = []
        var leaf: [u8] = []
        leaf.push(0xCAu8)
        leaf.push(0xFEu8)
        leaf.push(0xBAu8)
        leaf.push(0xBEu8)
        cert_chain.push(leaf)
        val msg = build_certificate(cert_chain)
        expect msg[0u64] == 0x0Bu8
        # length must be > 0
        val body_len: u64 = (msg[1u64].to_u64() << 16) | (msg[2u64].to_u64() << 8) | msg[3u64].to_u64()
        expect body_len > 0u64 == true
        # request_context length byte at offset 4 = 0 for non-mTLS server
        expect msg[4u64] == 0x00u8

# ============================================================================
# build_certificate_verify — RFC 8446 §4.4.3
# ============================================================================

describe "build_certificate_verify_signing_input":

    it "starts with 64 bytes of 0x20":
        val sig_in = build_certificate_verify_signing_input(_transcript_hash_32())
        var ok = true
        var i: u64 = 0
        while i < 64u64 and ok:
            if sig_in[i] != 0x20u8:
                ok = false
            i = i + 1u64
        expect ok == true

    it "embeds 'TLS 1.3, server CertificateVerify' starting at offset 64":
        val sig_in = build_certificate_verify_signing_input(_transcript_hash_32())
        # First 4 bytes of context string: T L S space
        expect sig_in[64u64] == 0x54u8
        expect sig_in[65u64] == 0x4Cu8
        expect sig_in[66u64] == 0x53u8
        expect sig_in[67u64] == 0x20u8

    it "places 0x00 separator at offset 64+33 = 97":
        val sig_in = build_certificate_verify_signing_input(_transcript_hash_32())
        expect sig_in[97u64] == 0x00u8

    it "appends transcript hash after separator":
        val sig_in = build_certificate_verify_signing_input(_transcript_hash_32())
        # Total length = 64 + 33 + 1 + 32 = 130
        expect sig_in.len().to_u64() == 130u64
        # Last 32 bytes match _transcript_hash_32()
        val th = _transcript_hash_32()
        var ok = true
        var i: u64 = 0
        while i < 32u64 and ok:
            if sig_in[98u64 + i] != th[i]:
                ok = false
            i = i + 1u64
        expect ok == true

describe "build_certificate_verify byte structure":

    it "emits handshake type=15 + 2-byte algorithm + 2-byte sig_len + signature":
        val cv = build_certificate_verify(_transcript_hash_32(), _ed25519_pkcs8(), 0x0807u16)
        expect cv[0u64] == 0x0Fu8
        # Body length covers algorithm(2) + sig_len(2) + signature
        val body_len: u64 = (cv[1u64].to_u64() << 16) | (cv[2u64].to_u64() << 8) | cv[3u64].to_u64()
        # algorithm = 0x0807
        expect cv[4u64] == 0x08u8
        expect cv[5u64] == 0x07u8
        # signature_len at offset 6..8
        val sig_len: u64 = (cv[6u64].to_u64() << 8) | cv[7u64].to_u64()
        # Ed25519 signature is exactly 64 bytes (RFC 8032)
        expect sig_len == 64u64
        # body_len = 4 + sig_len
        expect body_len == 4u64 + sig_len

    it "round-trips: signature in CV verifies against the derived public key":
        # Sign + verify via the same Ed25519 pkcs8 fixture; we extract the
        # 32-byte raw public key from the pkcs8 fixture by deriving it
        # via ed25519_sign+ed25519_verify directly. This test is an
        # end-to-end byte-level check that build_certificate_verify
        # produces a real signature, not zeros.
        val cv = build_certificate_verify(_transcript_hash_32(), _ed25519_pkcs8(), 0x0807u16)
        # Extract signature bytes (64 bytes) from the CV.
        var sig: [u8] = []
        var i: u64 = 0
        while i < 64u64:
            sig.push(cv[8u64 + i])
            i = i + 1u64
        # The same signing input the builder used:
        val signing_input = build_certificate_verify_signing_input(_transcript_hash_32())
        # Independently sign with the same pkcs8 to get a reference signature.
        val ref_sig = ed25519_sign(_ed25519_pkcs8(), signing_input)
        # Ed25519 is deterministic — both signatures must be byte-identical.
        expect sig.len().to_u64() == ref_sig.len().to_u64()
        var same = true
        var j: u64 = 0
        while j < sig.len().to_u64() and same:
            if sig[j] != ref_sig[j]:
                same = false
            j = j + 1u64
        expect same == true