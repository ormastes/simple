use std.spec
use os.installer.usb_installer.{detect_disks, default_partition_plan}

describe "USB installer layout helpers":
    it "detects at least the QEMU virtio target":
        val disks = detect_disks()
        expect disks.len() > 0
        expect disks[0].path == "/dev/vda"

    it "uses an EFI plus root plus swap default plan":
        val disks = detect_disks()
        val plan = default_partition_plan(disks[0])
        expect plan.efi_size_mb == 256
        expect plan.root_size_mb == 0
        expect plan.swap_size_mb > 0