use std.spec
use os.installer.image_builder.{build_install_image, build_usb_installer_image}
use os.tools.pkg.pkg_format.{PkgArch}

extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_read_text(path: text) -> text
extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

fn _reset_dir(path: text):
    rt_process_run("/bin/sh", ["-c", "rm -rf '" + path + "' && mkdir -p '" + path + "'"])

describe "Image builder artifacts":
    it "writes a staged disk image tree and deploy manifest":
        val dir = "build/test-artifacts/image-builder"
        _reset_dir(dir)
        val output = "{dir}/simpleos-x86_64.img"
        val result = build_install_image(PkgArch.X86_64, "", "", output, 64)
        expect result.is_ok() == true
        expect rt_file_exists(output) == true
        expect rt_file_exists("{output}.manifest.sdn") == true
        expect rt_file_exists("{output}.contents/rootfs/etc/fstab") == true
        expect rt_file_exists("{output}.contents/rootfs/sbin/init") == true
        expect rt_file_exists("{output}.contents/rootfs/sys/apps/llvm") == true
        expect rt_file_exists("{output}.contents/rootfs/sys/apps/rust") == true
        expect rt_file_exists("{output}.contents/rootfs/SYS/LLVMMAN.TXT") == true
        expect rt_file_exists("{output}.contents/rootfs/SYS/RUSTMAN.TXT") == true
        expect rt_file_exists("{output}.contents/rootfs/usr/share/simpleos/toolchain/llvm/hello.ll") == true
        expect rt_file_exists("{output}.contents/rootfs/usr/share/simpleos/toolchain/rust/hello.rs") == true
        val llvm_manifest = rt_file_read_text("{output}.contents/rootfs/SYS/LLVMMAN.TXT")
        val rust_manifest = rt_file_read_text("{output}.contents/rootfs/SYS/RUSTMAN.TXT")
        expect (llvm_manifest).contains("mode=native-filesystem-app")
        expect (llvm_manifest).contains("status=standalone-required")
        expect (rust_manifest).contains("mode=native-filesystem-app")
        expect (rust_manifest).contains("status=standalone-required")

    it "writes installer-media staging for non-x86 architectures":
        val dir = "build/test-artifacts/image-builder-installer"
        _reset_dir(dir)
        val output = "{dir}/simpleos-arm64-installer.iso"
        val result = build_usb_installer_image(PkgArch.Arm64, "", "", output, 64)
        expect result.is_ok() == true
        expect rt_file_exists(output) == true
        expect rt_file_exists("{output}.manifest.sdn") == true
        expect rt_file_exists("{output}.contents/rootfs/usr/libexec/simpleos-installer/installer") == true