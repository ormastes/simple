fn check(n: text, v: bool):
    if v:
        print "OK: {n}"
    else:
        print "FAIL: {n}"
fn sc(code: i64) -> i64:
    if code == 0x1E: return 1
    if code == 0x39: return 2
    if code == 0x1C: return 3
    if code == 0x01: return 4
    if code == 0x0E: return 5
    0
fn main():
    print "=== Scancode ==="
    check("A", sc(0x1E) == 1)
    check("Space", sc(0x39) == 2)
    check("Enter", sc(0x1C) == 3)
    check("Esc", sc(0x01) == 4)
    check("BS", sc(0x0E) == 5)
    check("Unk", sc(0xFF) == 0)
    print "=== DONE ==="
