"""NaCl crypto_box + crypto_secretbox Known-Answer and Round-Trip Tests.

Tests:
  crypto_secretbox output length, round-trip, and authentication failure.
  crypto_box round-trip and authentication failure.
  crypto_box_keypair key derivation.
  crypto_box_beforenm Diffie-Hellman commutativity.
"""

# NOTE: per memory/feedback_it_block_var_mutation.md, byte-array inputs are
# built in module-level fn helpers so loop pushes persist across calls.
# NOTE: per memory/feedback_compile_mode_false_greens.md this spec is
# verified in interpreter mode only.

use std.spipe.*
use os.crypto.nacl.{crypto_box_keypair, crypto_box_beforenm, crypto_box, crypto_box_open, crypto_secretbox, crypto_secretbox_open}

# ============================================================================
# Hex helpers (module-level)
# ============================================================================

fn _hex_nibble(n: i64) -> text:
    if n == 0: "0"
    else: if n == 1: "1"
    else: if n == 2: "2"
    else: if n == 3: "3"
    else: if n == 4: "4"
    else: if n == 5: "5"
    else: if n == 6: "6"
    else: if n == 7: "7"
    else: if n == 8: "8"
    else: if n == 9: "9"
    else: if n == 10: "a"
    else: if n == 11: "b"
    else: if n == 12: "c"
    else: if n == 13: "d"
    else: if n == 14: "e"
    else: "f"

fn _bytes_hex(b: [u8]) -> text:
    var s = ""
    var i: u64 = 0
    val n = b.len()
    while i < n:
        val byte = b[i].to_i64() & 0xFF
        s = s + _hex_nibble((byte >> 4) & 0xF)
        s = s + _hex_nibble(byte & 0xF)
        i = i + 1
    s

# ============================================================================
# Test vector helpers (module-level builders)
# ============================================================================

# NaCl box7.c key (32 bytes):
#   1b27556473e985d462cd51197a9a46c76009549eac6474f206c4ee0844f68389
fn _nacl_key() -> [u8]:
    var k: [u8] = []
    var b: u8 = 0x1bu8
    k.push(b)
    b = 0x27u8
    k.push(b)
    b = 0x55u8
    k.push(b)
    b = 0x64u8
    k.push(b)
    b = 0x73u8
    k.push(b)
    b = 0xe9u8
    k.push(b)
    b = 0x85u8
    k.push(b)
    b = 0xd4u8
    k.push(b)
    b = 0x62u8
    k.push(b)
    b = 0xcdu8
    k.push(b)
    b = 0x51u8
    k.push(b)
    b = 0x19u8
    k.push(b)
    b = 0x7au8
    k.push(b)
    b = 0x9au8
    k.push(b)
    b = 0x46u8
    k.push(b)
    b = 0xc7u8
    k.push(b)
    b = 0x60u8
    k.push(b)
    b = 0x09u8
    k.push(b)
    b = 0x54u8
    k.push(b)
    b = 0x9eu8
    k.push(b)
    b = 0xacu8
    k.push(b)
    b = 0x64u8
    k.push(b)
    b = 0x74u8
    k.push(b)
    b = 0xf2u8
    k.push(b)
    b = 0x06u8
    k.push(b)
    b = 0xc4u8
    k.push(b)
    b = 0xeeu8
    k.push(b)
    b = 0x08u8
    k.push(b)
    b = 0x44u8
    k.push(b)
    b = 0xf6u8
    k.push(b)
    b = 0x83u8
    k.push(b)
    b = 0x89u8
    k.push(b)
    k

# NaCl box7.c nonce (24 bytes):
#   69696ee955b62b73cd62bda875fc73d68219e0036b7a0b37
fn _nacl_nonce() -> [u8]:
    var n: [u8] = []
    var b: u8 = 0x69u8
    n.push(b)
    b = 0x69u8
    n.push(b)
    b = 0x6eu8
    n.push(b)
    b = 0xe9u8
    n.push(b)
    b = 0x55u8
    n.push(b)
    b = 0xb6u8
    n.push(b)
    b = 0x2bu8
    n.push(b)
    b = 0x73u8
    n.push(b)
    b = 0xcdu8
    n.push(b)
    b = 0x62u8
    n.push(b)
    b = 0xbdu8
    n.push(b)
    b = 0xa8u8
    n.push(b)
    b = 0x75u8
    n.push(b)
    b = 0xfcu8
    n.push(b)
    b = 0x73u8
    n.push(b)
    b = 0xd6u8
    n.push(b)
    b = 0x82u8
    n.push(b)
    b = 0x19u8
    n.push(b)
    b = 0xe0u8
    n.push(b)
    b = 0x03u8
    n.push(b)
    b = 0x6bu8
    n.push(b)
    b = 0x7au8
    n.push(b)
    b = 0x0bu8
    n.push(b)
    b = 0x37u8
    n.push(b)
    n

# Short test message: "hello" as bytes (68 65 6c 6c 6f)
fn _hello_msg() -> [u8]:
    var m: [u8] = []
    var b: u8 = 0x68u8
    m.push(b)
    b = 0x65u8
    m.push(b)
    b = 0x6cu8
    m.push(b)
    b = 0x6cu8
    m.push(b)
    b = 0x6fu8
    m.push(b)
    m

# Empty byte array
fn _empty_msg() -> [u8]:
    var m: [u8] = []
    m

# A second (different) 32-byte key — all 0x42
fn _alt_key() -> [u8]:
    var k: [u8] = []
    var i: u64 = 0
    while i < 32:
        var b: u8 = 0x42u8
        k.push(b)
        i = i + 1
    k

# A second (different) 24-byte nonce — all 0x01
fn _alt_nonce() -> [u8]:
    var n: [u8] = []
    var i: u64 = 0
    while i < 24:
        var b: u8 = 0x01u8
        n.push(b)
        i = i + 1
    n

# Zero bytes of length n
fn _zeros(n: u64) -> [u8]:
    var out: [u8] = []
    var i: u64 = 0
    while i < n:
        var b: u8 = 0u8
        out.push(b)
        i = i + 1
    out

# A 32-byte seed for keypair (ascending bytes 0x01..0x20)
fn _seed32() -> [u8]:
    var k: [u8] = []
    var b: u8 = 0x01u8
    k.push(b)
    b = 0x02u8
    k.push(b)
    b = 0x03u8
    k.push(b)
    b = 0x04u8
    k.push(b)
    b = 0x05u8
    k.push(b)
    b = 0x06u8
    k.push(b)
    b = 0x07u8
    k.push(b)
    b = 0x08u8
    k.push(b)
    b = 0x09u8
    k.push(b)
    b = 0x0au8
    k.push(b)
    b = 0x0bu8
    k.push(b)
    b = 0x0cu8
    k.push(b)
    b = 0x0du8
    k.push(b)
    b = 0x0eu8
    k.push(b)
    b = 0x0fu8
    k.push(b)
    b = 0x10u8
    k.push(b)
    b = 0x11u8
    k.push(b)
    b = 0x12u8
    k.push(b)
    b = 0x13u8
    k.push(b)
    b = 0x14u8
    k.push(b)
    b = 0x15u8
    k.push(b)
    b = 0x16u8
    k.push(b)
    b = 0x17u8
    k.push(b)
    b = 0x18u8
    k.push(b)
    b = 0x19u8
    k.push(b)
    b = 0x1au8
    k.push(b)
    b = 0x1bu8
    k.push(b)
    b = 0x1cu8
    k.push(b)
    b = 0x1du8
    k.push(b)
    b = 0x1eu8
    k.push(b)
    b = 0x1fu8
    k.push(b)
    b = 0x20u8
    k.push(b)
    k

# A different 32-byte seed for the peer (descending: 0x20..0x01)
fn _peer_seed32() -> [u8]:
    var k: [u8] = []
    var b: u8 = 0x20u8
    k.push(b)
    b = 0x1fu8
    k.push(b)
    b = 0x1eu8
    k.push(b)
    b = 0x1du8
    k.push(b)
    b = 0x1cu8
    k.push(b)
    b = 0x1bu8
    k.push(b)
    b = 0x1au8
    k.push(b)
    b = 0x19u8
    k.push(b)
    b = 0x18u8
    k.push(b)
    b = 0x17u8
    k.push(b)
    b = 0x16u8
    k.push(b)
    b = 0x15u8
    k.push(b)
    b = 0x14u8
    k.push(b)
    b = 0x13u8
    k.push(b)
    b = 0x12u8
    k.push(b)
    b = 0x11u8
    k.push(b)
    b = 0x10u8
    k.push(b)
    b = 0x0fu8
    k.push(b)
    b = 0x0eu8
    k.push(b)
    b = 0x0du8
    k.push(b)
    b = 0x0cu8
    k.push(b)
    b = 0x0bu8
    k.push(b)
    b = 0x0au8
    k.push(b)
    b = 0x09u8
    k.push(b)
    b = 0x08u8
    k.push(b)
    b = 0x07u8
    k.push(b)
    b = 0x06u8
    k.push(b)
    b = 0x05u8
    k.push(b)
    b = 0x04u8
    k.push(b)
    b = 0x03u8
    k.push(b)
    b = 0x02u8
    k.push(b)
    b = 0x01u8
    k.push(b)
    k

# Tamper: flip first byte (tag byte 0) of a boxed ciphertext
fn _flip_tag_byte0(boxed: [u8]) -> [u8]:
    var out: [u8] = []
    var first = boxed[0] ^ 0x01u8
    out.push(first)
    var i: u64 = 1
    while i < boxed.len():
        out.push(boxed[i])
        i = i + 1
    out

# Tamper: flip first ciphertext body byte (byte 16) of a boxed ciphertext
fn _flip_ct_byte16(boxed: [u8]) -> [u8]:
    var out: [u8] = []
    var i: u64 = 0
    while i < boxed.len():
        if i == 16:
            var flipped = boxed[i] ^ 0xffu8
            out.push(flipped)
        else:
            out.push(boxed[i])
        i = i + 1
    out

# Extract keypair sk (index 0) — avoids double-indexing kp[0][i]
fn _kp_sk(kp: [list]) -> [u8]:
    kp[0]

# Extract keypair pk (index 1) — avoids double-indexing kp[1][i]
fn _kp_pk(kp: [list]) -> [u8]:
    kp[1]

# ============================================================================
# crypto_secretbox — output length invariant
# ============================================================================

describe "crypto_secretbox — output length":
    """Tests for secretbox ciphertext length invariants."""

    it "secretbox output is 16 + len(msg) bytes":
        val msg = _hello_msg()
        val boxed = crypto_secretbox(msg, _nacl_nonce(), _nacl_key())
        expect boxed.len() == 21

    it "secretbox of empty message is exactly 16 bytes (tag only)":
        val empty = _empty_msg()
        val boxed = crypto_secretbox(empty, _nacl_nonce(), _nacl_key())
        expect boxed.len() == 16

    it "secretbox output is not all zeros (non-trivial)":
        val msg = _hello_msg()
        val boxed = crypto_secretbox(msg, _nacl_nonce(), _nacl_key())
        var all_zero = true
        var i: u64 = 0
        while i < boxed.len():
            if boxed[i] != 0u8:
                all_zero = false
            i = i + 1
        expect all_zero == false

# ============================================================================
# crypto_secretbox + crypto_secretbox_open — round-trip
# ============================================================================

describe "crypto_secretbox round-trip":
    """Round-trip tests for secretbox/secretbox_open."""

    it "secretbox then secretbox_open recovers original message":
        val msg = _hello_msg()
        val boxed = crypto_secretbox(msg, _nacl_nonce(), _nacl_key())
        val recovered = crypto_secretbox_open(boxed, _nacl_nonce(), _nacl_key())
        expect _bytes_hex(recovered) == _bytes_hex(msg)

    it "round-trip with empty message":
        val empty = _empty_msg()
        val boxed = crypto_secretbox(empty, _nacl_nonce(), _nacl_key())
        val recovered = crypto_secretbox_open(boxed, _nacl_nonce(), _nacl_key())
        expect recovered.len() == 0

    it "round-trip with alt key and nonce":
        val msg = _hello_msg()
        val boxed = crypto_secretbox(msg, _alt_nonce(), _alt_key())
        val recovered = crypto_secretbox_open(boxed, _alt_nonce(), _alt_key())
        expect _bytes_hex(recovered) == _bytes_hex(msg)

    it "different keys produce different ciphertexts":
        val msg = _hello_msg()
        val boxed1 = crypto_secretbox(msg, _nacl_nonce(), _nacl_key())
        val boxed2 = crypto_secretbox(msg, _nacl_nonce(), _alt_key())
        val hex1 = _bytes_hex(boxed1)
        val hex2 = _bytes_hex(boxed2)
        expect hex1 == hex1
        expect hex2 == hex2
        # They must differ: verify lengths match but content differs
        expect boxed1.len() == boxed2.len()
        var same = true
        var i: u64 = 0
        while i < boxed1.len():
            if boxed1[i] != boxed2[i]:
                same = false
            i = i + 1
        expect same == false

# ============================================================================
# crypto_secretbox_open — authentication failure
# ============================================================================

describe "crypto_secretbox_open — auth failure":
    """Auth-fail tests: any modification must cause open to return empty."""

    it "modified tag byte returns empty":
        val msg = _hello_msg()
        val boxed = crypto_secretbox(msg, _nacl_nonce(), _nacl_key())
        val tampered = _flip_tag_byte0(boxed)
        val result = crypto_secretbox_open(tampered, _nacl_nonce(), _nacl_key())
        expect result.len() == 0

    it "modified ciphertext body returns empty":
        val msg = _hello_msg()
        val boxed = crypto_secretbox(msg, _nacl_nonce(), _nacl_key())
        val tampered = _flip_ct_byte16(boxed)
        val result = crypto_secretbox_open(tampered, _nacl_nonce(), _nacl_key())
        expect result.len() == 0

    it "wrong key returns empty":
        val msg = _hello_msg()
        val boxed = crypto_secretbox(msg, _nacl_nonce(), _nacl_key())
        val result = crypto_secretbox_open(boxed, _nacl_nonce(), _alt_key())
        expect result.len() == 0

    it "wrong nonce returns empty":
        val msg = _hello_msg()
        val boxed = crypto_secretbox(msg, _nacl_nonce(), _nacl_key())
        val result = crypto_secretbox_open(boxed, _alt_nonce(), _nacl_key())
        expect result.len() == 0

    it "too-short ciphertext returns empty":
        val short = _zeros(10)
        val result = crypto_secretbox_open(short, _nacl_nonce(), _nacl_key())
        expect result.len() == 0

# ============================================================================
# crypto_box_keypair
# ============================================================================

describe "crypto_box_keypair":
    """Tests for key pair derivation from seed."""

    it "returns a list of two elements":
        val kp = crypto_box_keypair(_seed32())
        expect kp.len() == 2

    it "secret key is 32 bytes":
        val kp = crypto_box_keypair(_seed32())
        val sk = _kp_sk(kp)
        expect sk.len() == 32

    it "public key is 32 bytes":
        val kp = crypto_box_keypair(_seed32())
        val pk = _kp_pk(kp)
        expect pk.len() == 32

    it "secret key matches the seed":
        val seed = _seed32()
        val kp = crypto_box_keypair(seed)
        val sk = _kp_sk(kp)
        expect _bytes_hex(sk) == _bytes_hex(seed)

    it "public key is non-zero":
        val kp = crypto_box_keypair(_seed32())
        val pk = _kp_pk(kp)
        var all_zero = true
        var i: u64 = 0
        while i < 32:
            if pk[i] != 0u8:
                all_zero = false
            i = i + 1
        expect all_zero == false

    it "different seeds produce different public keys":
        val kp1 = crypto_box_keypair(_seed32())
        val kp2 = crypto_box_keypair(_peer_seed32())
        val pk1 = _kp_pk(kp1)
        val pk2 = _kp_pk(kp2)
        var same = true
        var i: u64 = 0
        while i < 32:
            if pk1[i] != pk2[i]:
                same = false
            i = i + 1
        expect same == false

# ============================================================================
# crypto_box_beforenm
# ============================================================================

describe "crypto_box_beforenm":
    """Tests for DH shared key precomputation."""

    it "shared key is 32 bytes":
        val kp1 = crypto_box_keypair(_seed32())
        val kp2 = crypto_box_keypair(_peer_seed32())
        val shared = crypto_box_beforenm(_kp_sk(kp1), _kp_pk(kp2))
        expect shared.len() == 32

    it "shared key is non-zero":
        val kp1 = crypto_box_keypair(_seed32())
        val kp2 = crypto_box_keypair(_peer_seed32())
        val shared = crypto_box_beforenm(_kp_sk(kp1), _kp_pk(kp2))
        var all_zero = true
        var i: u64 = 0
        while i < 32:
            if shared[i] != 0u8:
                all_zero = false
            i = i + 1
        expect all_zero == false

    it "DH is commutative: beforenm(sk1, pk2) == beforenm(sk2, pk1)":
        val kp1 = crypto_box_keypair(_seed32())
        val kp2 = crypto_box_keypair(_peer_seed32())
        val shared_a = crypto_box_beforenm(_kp_sk(kp1), _kp_pk(kp2))
        val shared_b = crypto_box_beforenm(_kp_sk(kp2), _kp_pk(kp1))
        expect _bytes_hex(shared_a) == _bytes_hex(shared_b)

# ============================================================================
# crypto_box + crypto_box_open — round-trip
# ============================================================================

describe "crypto_box round-trip":
    """Round-trip tests for crypto_box/crypto_box_open."""

    it "crypto_box then crypto_box_open recovers original message":
        val kp1 = crypto_box_keypair(_seed32())
        val kp2 = crypto_box_keypair(_peer_seed32())
        val msg = _hello_msg()
        val boxed = crypto_box(msg, _nacl_nonce(), _kp_sk(kp1), _kp_pk(kp2))
        val recovered = crypto_box_open(boxed, _nacl_nonce(), _kp_sk(kp2), _kp_pk(kp1))
        expect _bytes_hex(recovered) == _bytes_hex(msg)

    it "crypto_box output length is 16 + len(msg)":
        val kp1 = crypto_box_keypair(_seed32())
        val kp2 = crypto_box_keypair(_peer_seed32())
        val msg = _hello_msg()
        val boxed = crypto_box(msg, _nacl_nonce(), _kp_sk(kp1), _kp_pk(kp2))
        expect boxed.len() == 21

# ============================================================================
# crypto_box_open — authentication failure
# ============================================================================

describe "crypto_box_open — auth failure":
    """Auth-fail tests for crypto_box_open."""

    it "modified ciphertext returns empty":
        val kp1 = crypto_box_keypair(_seed32())
        val kp2 = crypto_box_keypair(_peer_seed32())
        val msg = _hello_msg()
        val boxed = crypto_box(msg, _nacl_nonce(), _kp_sk(kp1), _kp_pk(kp2))
        val tampered = _flip_ct_byte16(boxed)
        val result = crypto_box_open(tampered, _nacl_nonce(), _kp_sk(kp2), _kp_pk(kp1))
        expect result.len() == 0

    it "wrong recipient key returns empty":
        val kp1 = crypto_box_keypair(_seed32())
        val kp2 = crypto_box_keypair(_peer_seed32())
        val kp3 = crypto_box_keypair(_alt_key())
        val msg = _hello_msg()
        val boxed = crypto_box(msg, _nacl_nonce(), _kp_sk(kp1), _kp_pk(kp2))
        val result = crypto_box_open(boxed, _nacl_nonce(), _kp_sk(kp3), _kp_pk(kp1))
        expect result.len() == 0