# ChaCha20 SIMD vs Scalar parity + RFC 8439 KAT spec
#
# Verifies that the SIMD vectorized path (chacha20_encrypt_simd, using the
# Phase 1 SIMD int intrinsics landed 2026-05-01) produces byte-identical
# output to the scalar reference (chacha20_encrypt) and matches the canonical
# RFC 8439 §2.4.2 test vector.
#
# Vectorization style: VERTICAL 4-block parallel.
#   - 16 Vec4i state words, lane k = block (counter+k).
#   - Bitwise/rotate via simd_xor/and/or/shl/shr_i32x4 (Phase 1 wired ops).
#   - Adds via direct field arithmetic (Phase 1 didn't wire rt_simd_add_i32x4).
#
# Reference: src/os/crypto/chacha20.spl (chacha20_block4_simd, chacha20_encrypt_simd)
# Feature:   doc/08_tracking/feature_request/simd_int_intrinsics_for_crypto_2026-05-01.md

use std.spipe.*
use os.crypto.chacha20.{chacha20_encrypt, chacha20_encrypt_simd}

# ============================================================================
# RFC 8439 §2.4.2 fixtures (mirrors test/system/os_crypto_ref_primitives_spec.spl)
# ============================================================================

fn _rfc7539_key() -> [u8]:
    [
        0x00u8,0x01u8,0x02u8,0x03u8,0x04u8,0x05u8,0x06u8,0x07u8,
        0x08u8,0x09u8,0x0au8,0x0bu8,0x0cu8,0x0du8,0x0eu8,0x0fu8,
        0x10u8,0x11u8,0x12u8,0x13u8,0x14u8,0x15u8,0x16u8,0x17u8,
        0x18u8,0x19u8,0x1au8,0x1bu8,0x1cu8,0x1du8,0x1eu8,0x1fu8
    ]

fn _rfc7539_nonce() -> [u8]:
    [0x00u8,0x00u8,0x00u8,0x00u8,0x00u8,0x00u8,0x00u8,0x4au8,0x00u8,0x00u8,0x00u8,0x00u8]

# RFC 8439 §2.4.2 plaintext (114 bytes):
# "Ladies and Gentlemen of the class of '99: If I could offer you only one tip
#  for the future, sunscreen would be it."
fn _sunscreen_pt() -> [u8]:
    [
        0x4cu8,0x61u8,0x64u8,0x69u8,0x65u8,0x73u8,0x20u8,0x61u8,0x6eu8,0x64u8,0x20u8,0x47u8,0x65u8,0x6eu8,0x74u8,0x6cu8,
        0x65u8,0x6du8,0x65u8,0x6eu8,0x20u8,0x6fu8,0x66u8,0x20u8,0x74u8,0x68u8,0x65u8,0x20u8,0x63u8,0x6cu8,0x61u8,0x73u8,
        0x73u8,0x20u8,0x6fu8,0x66u8,0x20u8,0x27u8,0x39u8,0x39u8,0x3au8,0x20u8,0x49u8,0x66u8,0x20u8,0x49u8,0x20u8,0x63u8,
        0x6fu8,0x75u8,0x6cu8,0x64u8,0x20u8,0x6fu8,0x66u8,0x66u8,0x65u8,0x72u8,0x20u8,0x79u8,0x6fu8,0x75u8,0x20u8,0x6fu8,
        0x6eu8,0x6cu8,0x79u8,0x20u8,0x6fu8,0x6eu8,0x65u8,0x20u8,0x74u8,0x69u8,0x70u8,0x20u8,0x66u8,0x6fu8,0x72u8,0x20u8,
        0x74u8,0x68u8,0x65u8,0x20u8,0x66u8,0x75u8,0x74u8,0x75u8,0x72u8,0x65u8,0x2cu8,0x20u8,0x73u8,0x75u8,0x6eu8,0x73u8,
        0x63u8,0x72u8,0x65u8,0x65u8,0x6eu8,0x20u8,0x77u8,0x6fu8,0x75u8,0x6cu8,0x64u8,0x20u8,0x62u8,0x65u8,0x20u8,0x69u8,
        0x74u8,0x2eu8
    ]

fn _bytes_eq(a: [u8], b: [u8]) -> bool:
    if a.len() != b.len():
        return false
    var i: u64 = 0
    while i < a.len():
        if a[i] != b[i]:
            return false
        i = i + 1
    true

# Build a deterministic "long" plaintext spanning multiple 256-byte SIMD chunks
# plus a non-aligned tail. Length = 600 bytes (2 full SIMD chunks of 256 + 88).
fn _long_pt() -> [u8]:
    var out: [u8] = []
    var i: u64 = 0
    while i < 600:
        out.push((i & 0xFF).to_u8())
        i = i + 1
    out

# Build a payload exactly 256 bytes (one SIMD bulk call, no tail).
fn _aligned256_pt() -> [u8]:
    var out: [u8] = []
    var i: u64 = 0
    while i < 256:
        out.push(((i * 31u64 + 7u64) & 0xFF).to_u8())
        i = i + 1
    out

# Build a 1024-byte payload (4 full SIMD chunks).
fn _kib_pt() -> [u8]:
    var out: [u8] = []
    var i: u64 = 0
    while i < 1024:
        out.push(((i * 17u64 + 3u64) & 0xFF).to_u8())
        i = i + 1
    out

describe "ChaCha20 SIMD vs scalar parity":

    it "RFC 8439 §2.4.2 SIMD path matches scalar on the 114-byte sunscreen vector":
        val key = _rfc7539_key()
        val nonce = _rfc7539_nonce()
        val pt = _sunscreen_pt()
        val ct_scalar = chacha20_encrypt(key, 1u32, nonce, pt)
        val ct_simd = chacha20_encrypt_simd(key, 1u32, nonce, pt)
        expect _bytes_eq(ct_scalar, ct_simd) == true

    it "RFC 8439 §2.4.2 SIMD ciphertext matches the published canonical bytes":
        # Spot-check the first 4 bytes of ciphertext as published in RFC 8439:
        # 0x6e, 0x2e, 0x35, 0x9a (matches the existing scalar KAT in
        # test/system/os_crypto_ref_primitives_spec.spl). The SIMD path is a
        # tail-only path here (114 < 256), so this verifies the scalar branch
        # used inside chacha20_encrypt_simd is byte-exact too.
        val key = _rfc7539_key()
        val nonce = _rfc7539_nonce()
        val pt = _sunscreen_pt()
        val ct = chacha20_encrypt_simd(key, 1u32, nonce, pt)
        expect ct.len() == 114u64
        expect ct[0] == 0x6eu8
        expect ct[1] == 0x2eu8
        expect ct[2] == 0x35u8
        expect ct[3] == 0x9au8

    it "256-byte aligned payload (one full SIMD chunk, no tail) matches scalar":
        val key = _rfc7539_key()
        val nonce = _rfc7539_nonce()
        val pt = _aligned256_pt()
        val ct_scalar = chacha20_encrypt(key, 1u32, nonce, pt)
        val ct_simd = chacha20_encrypt_simd(key, 1u32, nonce, pt)
        expect ct_simd.len() == 256u64
        expect _bytes_eq(ct_scalar, ct_simd) == true

    it "600-byte unaligned payload (2 SIMD chunks + 88-byte tail) matches scalar":
        val key = _rfc7539_key()
        val nonce = _rfc7539_nonce()
        val pt = _long_pt()
        val ct_scalar = chacha20_encrypt(key, 0u32, nonce, pt)
        val ct_simd = chacha20_encrypt_simd(key, 0u32, nonce, pt)
        expect ct_simd.len() == 600u64
        expect _bytes_eq(ct_scalar, ct_simd) == true

    it "1024-byte payload (4 SIMD chunks, no tail) matches scalar with non-zero counter":
        val key = _rfc7539_key()
        val nonce = _rfc7539_nonce()
        val pt = _kib_pt()
        val ct_scalar = chacha20_encrypt(key, 7u32, nonce, pt)
        val ct_simd = chacha20_encrypt_simd(key, 7u32, nonce, pt)
        expect ct_simd.len() == 1024u64
        expect _bytes_eq(ct_scalar, ct_simd) == true

    it "SIMD round-trip recovers original plaintext":
        val key = _rfc7539_key()
        val nonce = _rfc7539_nonce()
        val pt = _long_pt()
        val ct = chacha20_encrypt_simd(key, 1u32, nonce, pt)
        val recovered = chacha20_encrypt_simd(key, 1u32, nonce, ct)
        expect _bytes_eq(recovered, pt) == true