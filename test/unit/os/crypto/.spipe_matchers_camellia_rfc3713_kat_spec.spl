# Camellia RFC 3713 Appendix A Known-Answer Test Vectors
#
# Tests camellia128_encrypt_block / camellia256_encrypt_block from
# src/os/crypto/camellia.spl against the canonical RFC 3713 Appendix A
# reference vectors.
#
# NOTE: Camellia-192 is not implemented in camellia.spl (only 128 and 256).
# The RFC 3713 Appendix A.2 (192-bit) vector is intentionally omitted.
#
# A.1 — Camellia-128
#   Key = 0123456789ABCDEFFEDCBA9876543210
#   PT  = 0123456789ABCDEFFEDCBA9876543210
#   CT  = 67673138549669730857065648EABE43
#
# A.3 — Camellia-256
#   Key = 0123456789ABCDEFFEDCBA987654321000112233445566778899AABBCCDDEEFF
#   PT  = 0123456789ABCDEFFEDCBA9876543210
#   CT  = 9ACC237DFF16D76C20EF7C919E3A7509
#
# KNOWN LIMITATION (interpreter mode): camellia.spl's _st64() helper mutates
# the output buffer via a function-parameter push chain. In the Simple
# interpreter, array mutations via function-parameter references do not
# persist to the caller, so camellia128_encrypt_block and
# camellia256_encrypt_block return an empty buffer under interpreter mode.
# The KAT assertions below will FAIL under interpreter mode and PASS only
# under compiled/native mode (--mode=native or bin/simple build).
# This is a known interpreter limitation, not a spec or algorithm bug.
#
# Source: RFC 3713 §Appendix A
# https://datatracker.ietf.org/doc/html/rfc3713#appendix-A

use std.spec.*
use os.crypto.camellia.{camellia128_encrypt_block, camellia256_encrypt_block}

# ============================================================================
# Hex-dump helper (inline — no external dependency)
# ============================================================================

fn _hex_nibble(n: u8) -> text:
    if n == 0: "0"
    else if n == 1: "1"
    else if n == 2: "2"
    else if n == 3: "3"
    else if n == 4: "4"
    else if n == 5: "5"
    else if n == 6: "6"
    else if n == 7: "7"
    else if n == 8: "8"
    else if n == 9: "9"
    else if n == 10: "a"
    else if n == 11: "b"
    else if n == 12: "c"
    else if n == 13: "d"
    else if n == 14: "e"
    else: "f"

fn _bytes_hex(b: [u8]) -> text:
    var s: text = ""
    var i: i64 = 0
    while i < b.len():
        val byte = b[i]
        s = s + _hex_nibble((byte >> 4) & 0x0F)
        s = s + _hex_nibble(byte & 0x0F)
        i = i + 1
    s

# ============================================================================
# RFC 3713 Appendix A.1 — Camellia-128 test data
# ============================================================================

fn _a1_key() -> [u8]:
    var k: [u8] = []
    k.push(0x01)
    k.push(0x23)
    k.push(0x45)
    k.push(0x67)
    k.push(0x89)
    k.push(0xAB)
    k.push(0xCD)
    k.push(0xEF)
    k.push(0xFE)
    k.push(0xDC)
    k.push(0xBA)
    k.push(0x98)
    k.push(0x76)
    k.push(0x54)
    k.push(0x32)
    k.push(0x10)
    k

fn _a1_pt() -> [u8]:
    var p: [u8] = []
    p.push(0x01)
    p.push(0x23)
    p.push(0x45)
    p.push(0x67)
    p.push(0x89)
    p.push(0xAB)
    p.push(0xCD)
    p.push(0xEF)
    p.push(0xFE)
    p.push(0xDC)
    p.push(0xBA)
    p.push(0x98)
    p.push(0x76)
    p.push(0x54)
    p.push(0x32)
    p.push(0x10)
    p

# ============================================================================
# RFC 3713 Appendix A.3 — Camellia-256 test data
# ============================================================================

fn _a3_key() -> [u8]:
    var k: [u8] = []
    k.push(0x01)
    k.push(0x23)
    k.push(0x45)
    k.push(0x67)
    k.push(0x89)
    k.push(0xAB)
    k.push(0xCD)
    k.push(0xEF)
    k.push(0xFE)
    k.push(0xDC)
    k.push(0xBA)
    k.push(0x98)
    k.push(0x76)
    k.push(0x54)
    k.push(0x32)
    k.push(0x10)
    k.push(0x00)
    k.push(0x11)
    k.push(0x22)
    k.push(0x33)
    k.push(0x44)
    k.push(0x55)
    k.push(0x66)
    k.push(0x77)
    k.push(0x88)
    k.push(0x99)
    k.push(0xAA)
    k.push(0xBB)
    k.push(0xCC)
    k.push(0xDD)
    k.push(0xEE)
    k.push(0xFF)
    k

# PT is same as A.1
fn _a3_pt() -> [u8]:
    _a1_pt()

# ============================================================================
# RFC 3713 Appendix A — KAT specs
#
# These tests PASS under compiled/native mode.
# Under interpreter mode they will report failure due to the known
# array-mutation-via-function-parameter limitation in camellia.spl's _st64().
# ============================================================================

describe "Camellia RFC 3713 Appendix A — 128-bit":

    it "A.1 Camellia-128 encrypt → 67673138549669730857065648eabe43":
        val ct = camellia128_encrypt_block(_a1_key(), _a1_pt())
        expect _bytes_hex(ct) == "67673138549669730857065648eabe43"

    it "A.1 Camellia-128 output is 16 bytes":
        val ct = camellia128_encrypt_block(_a1_key(), _a1_pt())
        expect ct.len() == 16

describe "Camellia RFC 3713 Appendix A — 256-bit":

    it "A.3 Camellia-256 encrypt → 9acc237dff16d76c20ef7c919e3a7509":
        val ct = camellia256_encrypt_block(_a3_key(), _a3_pt())
        expect _bytes_hex(ct) == "9acc237dff16d76c20ef7c919e3a7509"

    it "A.3 Camellia-256 output is 16 bytes":
        val ct = camellia256_encrypt_block(_a3_key(), _a3_pt())
        expect ct.len() == 16