# Tiger/192 Known-Answer Test Vectors
#
# Tests the pure-Simple Tiger/192 implementation in src/os/crypto/tiger.spl
# against the reference vectors from Anderson+Biham 1996 tiger.c.
#
#   Tiger("")      = 3293ac630c13f0245f92bbb1766e16167a4e58492dde73f3
#   Tiger("a")     = 77befbef2e7ef8ab2ec8f93bf587a7fc613e247f5f247809
#   Tiger("abc")   = 2aab1484e8c158f2bfb8c5ff41b57a525129131c957b5f93
#   Tiger("Tiger") = dd00230799f5009fec6debc838bb6a27df2b9d6f110c7937
#
# Source: Ross Anderson and Eli Biham, "Tiger: A Fast New Hash Function",
#         Fast Software Encryption, 1996.
#
# NOTE: verified in interpreter mode per
#       .claude/memory/feedback_compile_mode_false_greens.md

use std.spipe.*
use os.crypto.tiger.{tiger192}

# ============================================================================
# Helpers -- build inputs in module-level fns so it-block var mutation
# (feedback_it_block_var_mutation.md) doesn't drop list pushes.
# ============================================================================

fn _empty_bytes() -> [u8]:
    var out: [u8] = []
    out

fn _a_bytes() -> [u8]:
    var out: [u8] = []
    out.push(0x61)
    out

fn _abc_bytes() -> [u8]:
    var out: [u8] = []
    out.push(0x61)
    out.push(0x62)
    out.push(0x63)
    out

fn _tiger_bytes() -> [u8]:
    var out: [u8] = []
    out.push(0x54)  # T
    out.push(0x69)  # i
    out.push(0x67)  # g
    out.push(0x65)  # e
    out.push(0x72)  # r
    out

fn _hex_nibble(n: u8) -> text:
    if n == 0: "0"
    else if n == 1: "1"
    else if n == 2: "2"
    else if n == 3: "3"
    else if n == 4: "4"
    else if n == 5: "5"
    else if n == 6: "6"
    else if n == 7: "7"
    else if n == 8: "8"
    else if n == 9: "9"
    else if n == 10: "a"
    else if n == 11: "b"
    else if n == 12: "c"
    else if n == 13: "d"
    else if n == 14: "e"
    else: "f"

fn _bytes_hex(b: [u8]) -> text:
    var s: text = ""
    var i: i64 = 0
    while i < b.len().to_i64():
        val byte = b[i]
        s = s + _hex_nibble((byte >> 4) & 0x0F)
        s = s + _hex_nibble(byte & 0x0F)
        i = i + 1
    s

# ============================================================================
# Tiger/192 -- Anderson+Biham 1996 reference KAT
# ============================================================================

describe "Tiger/192 -- Anderson+Biham 1996 known-answer vectors":

    it "Tiger(\"\") = 3293ac630c13f0245f92bbb1766e16167a4e58492dde73f3":
        expect(_bytes_hex(tiger192(_empty_bytes()))).to_equal(
            "3293ac630c13f0245f92bbb1766e16167a4e58492dde73f3"
        )

    it "Tiger(\"a\") = 77befbef2e7ef8ab2ec8f93bf587a7fc613e247f5f247809":
        expect(_bytes_hex(tiger192(_a_bytes()))).to_equal(
            "77befbef2e7ef8ab2ec8f93bf587a7fc613e247f5f247809"
        )

    it "Tiger(\"abc\") = 2aab1484e8c158f2bfb8c5ff41b57a525129131c957b5f93":
        expect(_bytes_hex(tiger192(_abc_bytes()))).to_equal(
            "2aab1484e8c158f2bfb8c5ff41b57a525129131c957b5f93"
        )

    it "Tiger(\"Tiger\") = dd00230799f5009fec6debc838bb6a27df2b9d6f110c7937":
        expect(_bytes_hex(tiger192(_tiger_bytes()))).to_equal(
            "dd00230799f5009fec6debc838bb6a27df2b9d6f110c7937"
        )

    it "Tiger/192 output length is 24 bytes":
        expect(tiger192(_abc_bytes()).len()).to_equal(24)
