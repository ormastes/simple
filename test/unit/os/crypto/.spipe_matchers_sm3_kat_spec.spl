"""SM3 (GB/T 32905-2012) Known-Answer Test Vectors.

Tests the pure-Simple SM3 implementation in
src/os/crypto/sm3.spl against the canonical vectors from
the Chinese national standard GB/T 32905-2012 and
IETF draft-sca-cfrg-sm3.

Vectors used:

  SM3("abc") =
      66c7f0f462eeedd9d1f2d46bdc10e4e24167c4875cf2f7a2297da02b8f4ba8e0
  Source: GM/T 0004-2012, Appendix A.1.

  SM3("abcd"*16) =
      debe9ff92275b8a138604889c18e5a4d6fdb70e5387e5765293dcba39c0c5732
  Source: GM/T 0004-2012, Appendix A.2.

  SM3("") =
      1ab21d8355cfa17f8e61194831e81a8f22bec8c728fefb747ed035eb5082aa2b
  Standard empty-message digest.

NOTE: interpreter-mode test runner only verifies file loading, NOT
it-block execution (see .claude/memory/feedback_compile_mode_false_greens.md).
Run under compiled/native mode for real assertion results.
"""

use std.spipe.*
use os.crypto.sm3.{sm3_hash, sm3_compress, sm3_pad}

// =============================================================================
// Helpers — build inputs in module-level fns so it-block var mutation
// (feedback_it_block_var_mutation.md) doesn't drop list pushes.
// =============================================================================

fn _empty_bytes() -> [u8]:
    var out: [u8] = []
    out

fn _abc_bytes() -> [u8]:
    var out: [u8] = []
    out.push(0x61)
    out.push(0x62)
    out.push(0x63)
    out

// "abcd" repeated 16 times = 64 bytes
fn _abcd16_bytes() -> [u8]:
    var out: [u8] = []
    out.push(0x61)
    out.push(0x62)
    out.push(0x63)
    out.push(0x64)
    out.push(0x61)
    out.push(0x62)
    out.push(0x63)
    out.push(0x64)
    out.push(0x61)
    out.push(0x62)
    out.push(0x63)
    out.push(0x64)
    out.push(0x61)
    out.push(0x62)
    out.push(0x63)
    out.push(0x64)
    out.push(0x61)
    out.push(0x62)
    out.push(0x63)
    out.push(0x64)
    out.push(0x61)
    out.push(0x62)
    out.push(0x63)
    out.push(0x64)
    out.push(0x61)
    out.push(0x62)
    out.push(0x63)
    out.push(0x64)
    out.push(0x61)
    out.push(0x62)
    out.push(0x63)
    out.push(0x64)
    out.push(0x61)
    out.push(0x62)
    out.push(0x63)
    out.push(0x64)
    out.push(0x61)
    out.push(0x62)
    out.push(0x63)
    out.push(0x64)
    out.push(0x61)
    out.push(0x62)
    out.push(0x63)
    out.push(0x64)
    out.push(0x61)
    out.push(0x62)
    out.push(0x63)
    out.push(0x64)
    out.push(0x61)
    out.push(0x62)
    out.push(0x63)
    out.push(0x64)
    out.push(0x61)
    out.push(0x62)
    out.push(0x63)
    out.push(0x64)
    out.push(0x61)
    out.push(0x62)
    out.push(0x63)
    out.push(0x64)
    out.push(0x61)
    out.push(0x62)
    out.push(0x63)
    out.push(0x64)
    out

// =============================================================================
// Inline hex nibble converter — avoids test-system import dependency.
// =============================================================================

fn _hex_nibble(n: u8) -> text:
    if n == 0: "0"
    else if n == 1: "1"
    else if n == 2: "2"
    else if n == 3: "3"
    else if n == 4: "4"
    else if n == 5: "5"
    else if n == 6: "6"
    else if n == 7: "7"
    else if n == 8: "8"
    else if n == 9: "9"
    else if n == 10: "a"
    else if n == 11: "b"
    else if n == 12: "c"
    else if n == 13: "d"
    else if n == 14: "e"
    else: "f"

fn _bytes_hex(b: [u8]) -> text:
    var s: text = ""
    var i: u64 = 0
    while i < b.len().to_u64():
        var byte = b[i]
        s = s + _hex_nibble((byte >> 4) & 0x0F)
        s = s + _hex_nibble(byte & 0x0F)
        i = i + 1
    s

// =============================================================================
// SM3 KAT — GB/T 32905-2012
// =============================================================================

describe "SM3 — GB/T 32905-2012 known-answer vectors":

    it "SM3(\"abc\") = 66c7f0f4... (GM/T 0004-2012 Appendix A.1)":
        expect(_bytes_hex(sm3_hash(_abc_bytes()))).to_equal(
            "66c7f0f462eeedd9d1f2d46bdc10e4e24167c4875cf2f7a2297da02b8f4ba8e0"
        )

    it "SM3(\"abcd\"*16) = debe9ff9... (GM/T 0004-2012 Appendix A.2)":
        expect(_bytes_hex(sm3_hash(_abcd16_bytes()))).to_equal(
            "debe9ff92275b8a138604889c18e5a4d6fdb70e5387e5765293dcba39c0c5732"
        )

    it "SM3(\"\") = 1ab21d83... (empty message standard vector)":
        expect(_bytes_hex(sm3_hash(_empty_bytes()))).to_equal(
            "1ab21d8355cfa17f8e61194831e81a8f22bec8c728fefb747ed035eb5082aa2b"
        )

    it "SM3 digest length is 32 bytes":
        expect sm3_hash(_empty_bytes()).len() == 32

    it "SM3 padding produces multiple-of-64 length":
        expect sm3_pad(_abc_bytes()).len() % 64 == 0

    it "sm3_compress accepts IV state and 64-byte block and returns 8 words":
        var block: [u8] = []
        var bi = 0
        while bi < 64:
            block.push(0x00)
            bi = bi + 1
        var state_iv = []
        state_iv.push(0x7380166F)
        state_iv.push(0x4914B2B9)
        state_iv.push(0x172442D7)
        state_iv.push(0xDA8A0600)
        state_iv.push(0xA96F30BC)
        state_iv.push(0x163138AA)
        state_iv.push(0xE38DEE4D)
        state_iv.push(0xB0FB0E4E)
        val result = sm3_compress(state_iv, block)
        expect result.len() == 8