# OCB3 (AES-128) — RFC 7253 Appendix A Known-Answer Tests
#
# Tests ocb3_encrypt against the canonical test vectors in RFC 7253 Appendix A.
# The vectors use:
#   K  = 000102030405060708090A0B0C0D0E0F  (16 bytes)
#   N  = BBAA99887766554433221100 .. etc    (12 bytes, varies per test)
#   TAGLEN = 128 bits (16-byte tag)
#
# Interpreter-mode note: bin/simple test verifies file loading only; it-block
# bodies are not executed. Byte-exact assertions fire in compiled/native mode.
#
# Source: RFC 7253 Appendix A — Sample Results
# https://www.rfc-editor.org/rfc/rfc7253#appendix-A
#
use std.spipe.*
use os.crypto.ocb3.{ocb3_encrypt, ocb3_decrypt, Ocb3Result}

extern fn rt_bytes_u8_at(arr: [u8], idx: i64) -> i64
extern fn rt_array_new_with_cap(cap: i64) -> [u8]

# ============================================================================
# Helpers — module-level to avoid it-block var-mutation interpreter quirk
# (per .claude/memory/feedback_it_block_var_mutation.md)
# ============================================================================

fn _u8_at(buf: [u8], idx: u64) -> u8:
    rt_bytes_u8_at(buf, idx.to_i64()).to_u8()

fn _bytes_to_hex(buf: [u8]) -> text:
    val hex_chars = "0123456789abcdef"
    var out = ""
    var i: u64 = 0
    while i < buf.len():
        val b = _u8_at(buf, i).to_u32()
        out = out + hex_chars.char_at(((b >> 4) & 0x0F).to_i64()) + hex_chars.char_at((b & 0x0F).to_i64())
        i = i + 1
    out

# RFC 7253 Appendix A shared key K = 000102030405060708090A0B0C0D0E0F
fn _rfc7253_key() -> [u8]:
    [0x00, 0x01, 0x02, 0x03, 0x04, 0x05, 0x06, 0x07,
     0x08, 0x09, 0x0A, 0x0B, 0x0C, 0x0D, 0x0E, 0x0F]

# ============================================================================
# Test #1: N=BBAA9988776655443322110 (nonce 0), empty AAD, empty PT
# RFC 7253 §A.1 (first entry):
#   N = BBAA99887766554433221100
#   A = (empty)
#   P = (empty)
#   C = 785407BFFFC8AD9EDCC5520AC9111EE6
# ============================================================================

fn _tc1_nonce() -> [u8]:
    [0xBB, 0xAA, 0x99, 0x88, 0x77, 0x66, 0x55, 0x44, 0x33, 0x22, 0x11, 0x00]

fn _tc1_expected_ct_tag() -> text:
    "785407bfffc8ad9edcc5520ac9111ee6"

# ============================================================================
# Test #2: N=BBAA99887766554433221101, A=0001020304050607, P=0001020304050607
# RFC 7253 §A.1 (entry index 1):
#   N = BBAA99887766554433221101
#   A = 0001020304050607
#   P = 0001020304050607
#   C = 6820B3657B6F615A5725BDA0D3B4EB3A257C9AF1F8F03009
# ============================================================================

fn _tc2_nonce() -> [u8]:
    [0xBB, 0xAA, 0x99, 0x88, 0x77, 0x66, 0x55, 0x44, 0x33, 0x22, 0x11, 0x01]

fn _tc2_aad() -> [u8]:
    [0x00, 0x01, 0x02, 0x03, 0x04, 0x05, 0x06, 0x07]

fn _tc2_pt() -> [u8]:
    [0x00, 0x01, 0x02, 0x03, 0x04, 0x05, 0x06, 0x07]

fn _tc2_expected_ct_tag() -> text:
    "6820b3657b6f615a5725bda0d3b4eb3a257c9af1f8f03009"

# ============================================================================
# Test #3: N=BBAA99887766554433221102, A=0001020304050607 (8 bytes), P=empty
# RFC 7253 §A.1:
#   N = BBAA99887766554433221102
#   A = 0001020304050607
#   P = (empty)
#   C = 81017F8203F081277152FADE694A0A00
# ============================================================================

fn _tc3_nonce() -> [u8]:
    [0xBB, 0xAA, 0x99, 0x88, 0x77, 0x66, 0x55, 0x44, 0x33, 0x22, 0x11, 0x02]

fn _tc3_aad() -> [u8]:
    [0x00, 0x01, 0x02, 0x03, 0x04, 0x05, 0x06, 0x07]

fn _tc3_expected_ct_tag() -> text:
    "81017f8203f081277152fade694a0a00"

# ============================================================================
# Test #4: N=BBAA99887766554433221103, A=empty, P=0001020304050607 (8 bytes)
# RFC 7253 §A.1:
#   N = BBAA99887766554433221103
#   A = (empty)
#   P = 0001020304050607
#   C = 45DD69F8F5AAE72414054CD1F35D82760B2CD00D2F99BFA9
# ============================================================================

fn _tc4_nonce() -> [u8]:
    [0xBB, 0xAA, 0x99, 0x88, 0x77, 0x66, 0x55, 0x44, 0x33, 0x22, 0x11, 0x03]

fn _tc4_pt() -> [u8]:
    [0x00, 0x01, 0x02, 0x03, 0x04, 0x05, 0x06, 0x07]

fn _tc4_expected_ct_tag() -> text:
    "45dd69f8f5aae72414054cd1f35d82760b2cd00d2f99bfa9"

# ============================================================================
# Enum helpers — module-level to avoid interpreter it-block limitations
# ============================================================================

fn _ocb3_is_err(r: Ocb3Result) -> bool:
    match r:
        Ocb3Result.Ok(_): false
        Ocb3Result.Err(_): true

fn _ocb3_unwrap_ok(r: Ocb3Result) -> [u8]:
    match r:
        Ocb3Result.Ok(data): data
        Ocb3Result.Err(_): []

fn _full_block_nonce() -> [u8]:
    [0xBB, 0xAA, 0x99, 0x88, 0x77, 0x66, 0x55, 0x44, 0x33, 0x22, 0x11, 0x04]

fn _full_block_pt() -> [u8]:
    [0x00, 0x01, 0x02, 0x03, 0x04, 0x05, 0x06, 0x07,
     0x08, 0x09, 0x0A, 0x0B, 0x0C, 0x0D, 0x0E, 0x0F]

fn _full_block_rt_ok() -> bool:
    val sealed = ocb3_encrypt(_rfc7253_key(), _full_block_nonce(), [], _full_block_pt())
    match ocb3_decrypt(_rfc7253_key(), _full_block_nonce(), [], sealed):
        Ocb3Result.Ok(data): data == _full_block_pt()
        Ocb3Result.Err(_): false

fn _partial_block_rt_ok() -> bool:
    val sealed = ocb3_encrypt(_rfc7253_key(), _tc4_nonce(), [], _tc4_pt())
    match ocb3_decrypt(_rfc7253_key(), _tc4_nonce(), [], sealed):
        Ocb3Result.Ok(data): data == _tc4_pt()
        Ocb3Result.Err(_): false

fn _tc1_decrypt_ok() -> bool:
    match ocb3_decrypt(_rfc7253_key(), _tc1_nonce(), [], ocb3_encrypt(_rfc7253_key(), _tc1_nonce(), [], [])):
        Ocb3Result.Ok(data): data == []
        Ocb3Result.Err(_): false

fn _tc2_decrypt_ok() -> bool:
    match ocb3_decrypt(_rfc7253_key(), _tc2_nonce(), _tc2_aad(), ocb3_encrypt(_rfc7253_key(), _tc2_nonce(), _tc2_aad(), _tc2_pt())):
        Ocb3Result.Ok(data): data == _tc2_pt()
        Ocb3Result.Err(_): false

fn _tc3_decrypt_ok() -> bool:
    match ocb3_decrypt(_rfc7253_key(), _tc3_nonce(), _tc3_aad(), ocb3_encrypt(_rfc7253_key(), _tc3_nonce(), _tc3_aad(), [])):
        Ocb3Result.Ok(data): data == []
        Ocb3Result.Err(_): false

fn _tc4_decrypt_ok() -> bool:
    match ocb3_decrypt(_rfc7253_key(), _tc4_nonce(), [], ocb3_encrypt(_rfc7253_key(), _tc4_nonce(), [], _tc4_pt())):
        Ocb3Result.Ok(data): data == _tc4_pt()
        Ocb3Result.Err(_): false

# Build a tampered copy of ct_tag (last byte flipped) at module level.
fn _tamper_last_byte(buf: [u8]) -> [u8]:
    var out: [u8] = rt_array_new_with_cap(buf.len().to_i64())
    var i: u64 = 0
    while i < buf.len() - 1:
        out.push(_u8_at(buf, i))
        i = i + 1
    out.push(_u8_at(buf, buf.len() - 1) ^ 0xFF)
    out

fn _tc4_ct_tag() -> [u8]:
    ocb3_encrypt(_rfc7253_key(), _tc4_nonce(), [], _tc4_pt())

fn _tc4_tampered() -> [u8]:
    _tamper_last_byte(_tc4_ct_tag())

fn _tc4_decrypt_tampered_is_err() -> bool:
    _ocb3_is_err(ocb3_decrypt(_rfc7253_key(), _tc4_nonce(), [], _tc4_tampered()))

fn _short_input_is_err() -> bool:
    _ocb3_is_err(ocb3_decrypt(_rfc7253_key(), _tc1_nonce(), [], [0x01, 0x02]))

# ============================================================================
# Specs
# ============================================================================

describe "OCB3 (AES-128) — RFC 7253 Appendix A test vectors":

    it "TC1: empty AAD, empty PT — tag only":
        val result = ocb3_encrypt(_rfc7253_key(), _tc1_nonce(), [], [])
        expect _bytes_to_hex(result) == _tc1_expected_ct_tag()

    it "TC2: 8-byte AAD, 8-byte PT — partial block":
        val result = ocb3_encrypt(_rfc7253_key(), _tc2_nonce(), _tc2_aad(), _tc2_pt())
        expect _bytes_to_hex(result) == _tc2_expected_ct_tag()

    it "TC3: 8-byte AAD, empty PT — AAD-only hash":
        val result = ocb3_encrypt(_rfc7253_key(), _tc3_nonce(), _tc3_aad(), [])
        expect _bytes_to_hex(result) == _tc3_expected_ct_tag()

    it "TC4: empty AAD, 8-byte PT — partial block":
        val result = ocb3_encrypt(_rfc7253_key(), _tc4_nonce(), [], _tc4_pt())
        expect _bytes_to_hex(result) == _tc4_expected_ct_tag()

describe "OCB3 — output length contract":

    it "encrypt empty input yields exactly 16-byte tag":
        val result = ocb3_encrypt(_rfc7253_key(), _tc1_nonce(), [], [])
        expect result.len() == 16

    it "encrypt 8-byte PT yields 8 + 16 = 24 bytes":
        val result = ocb3_encrypt(_rfc7253_key(), _tc2_nonce(), _tc2_aad(), _tc2_pt())
        expect result.len() == 24

    it "encrypt 8-byte PT (TC4) yields 8 + 16 = 24 bytes":
        val result = ocb3_encrypt(_rfc7253_key(), _tc4_nonce(), [], _tc4_pt())
        expect result.len() == 24

describe "OCB3 — decrypt error path":

    it "decrypt reproduces TC1 empty plaintext exactly":
        expect _tc1_decrypt_ok() == true

    it "decrypt reproduces TC2 plaintext exactly":
        expect _tc2_decrypt_ok() == true

    it "decrypt reproduces TC3 empty plaintext exactly":
        expect _tc3_decrypt_ok() == true

    it "decrypt reproduces TC4 plaintext exactly":
        expect _tc4_decrypt_ok() == true

    it "decrypt round-trips a full 16-byte block":
        expect _full_block_rt_ok() == true

    it "decrypt round-trips a partial block":
        expect _partial_block_rt_ok() == true

    it "decrypt with tampered tag returns Err":
        expect _tc4_decrypt_tampered_is_err() == true

    it "decrypt with too-short input returns Err":
        expect _short_input_is_err() == true