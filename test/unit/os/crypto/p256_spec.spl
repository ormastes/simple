use std.spipe.*
use os.crypto.p256.{
    p256_ecdsa_sign, p256_ecdsa_verify,
    p256_keygen, p256_ecdh,
    p256_point_on_curve, p256_add, p256_mul
}
use os.crypto.sha256.{sha256}

fn _hex_nibble(n: u8) -> text:
    if n == 0: "0"
    else if n == 1: "1"
    else if n == 2: "2"
    else if n == 3: "3"
    else if n == 4: "4"
    else if n == 5: "5"
    else if n == 6: "6"
    else if n == 7: "7"
    else if n == 8: "8"
    else if n == 9: "9"
    else if n == 10: "a"
    else if n == 11: "b"
    else if n == 12: "c"
    else if n == 13: "d"
    else if n == 14: "e"
    else: "f"

fn _bytes_hex(b: [u8]) -> text:
    var s: text = ""
    var i: u64 = 0
    var blen: u64 = b.len().to_u64()
    while i < blen:
        var byte: u8 = b[i]
        s = s + _hex_nibble((byte >> 4) & 0x0F)
        s = s + _hex_nibble(byte & 0x0F)
        i = i + 1
    s

fn _rfc6979_privkey() -> [u8]:
    var k: [u8] = []
    k.push(0xC9)
    k.push(0xAF)
    k.push(0xA9)
    k.push(0xD8)
    k.push(0x45)
    k.push(0xBA)
    k.push(0x75)
    k.push(0x16)
    k.push(0x6B)
    k.push(0x5C)
    k.push(0x21)
    k.push(0x57)
    k.push(0x67)
    k.push(0xB1)
    k.push(0xD6)
    k.push(0x93)
    k.push(0x4E)
    k.push(0x50)
    k.push(0xC3)
    k.push(0xDB)
    k.push(0x36)
    k.push(0xE8)
    k.push(0x9B)
    k.push(0x12)
    k.push(0x7B)
    k.push(0x8A)
    k.push(0x62)
    k.push(0x2B)
    k.push(0x12)
    k.push(0x0F)
    k.push(0x67)
    k.push(0x21)
    k

fn _sample_msg() -> [u8]:
    var m: [u8] = []
    m.push(0x73)
    m.push(0x61)
    m.push(0x6D)
    m.push(0x70)
    m.push(0x6C)
    m.push(0x65)
    m

describe "P-256 ECDSA/ECDH":

    it "keygen produces 65-byte uncompressed pubkey":
        val sk = _rfc6979_privkey()
        val pub_key = p256_keygen(sk)
        expect(pub_key.len()).to_equal(65)
        expect(pub_key[0u64]).to_equal(0x04u8)

    it "ECDSA sign produces 64-byte signature":
        val sk = _rfc6979_privkey()
        val msg = _sample_msg()
        val msg_hash = sha256(msg)
        val sig = p256_ecdsa_sign(sk, msg_hash)
        expect(sig.len()).to_equal(64)
