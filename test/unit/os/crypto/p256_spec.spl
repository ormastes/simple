describe "P-256 ECDSA/ECDH — RFC 6979 known-answer tests":

    it "keygen produces 65-byte uncompressed pubkey":
        val sk = _rfc6979_privkey()
        val pub_key = p256_keygen(sk)
        expect(pub_key.len()).to_equal(65)
        expect(pub_key[0u64]).to_equal(0x04u8)

    it "generated pubkey is on curve":
        val sk = _rfc6979_privkey()
        val pub_key = p256_keygen(sk)
        val px = _extract_pubkey_x(pub_key)
        val py = _extract_pubkey_y(pub_key)
        expect(p256_point_on_curve(px, py)).to_equal(true)

    it "ECDSA sign produces 64-byte signature":
        val sk = _rfc6979_privkey()
        val msg = _sample_msg()
        val msg_hash = sha256(msg)
        val sig = p256_ecdsa_sign(sk, msg_hash)
        expect(sig.len()).to_equal(64)

    it "ECDSA sign matches RFC 6979 A.2.5 r value":
        val sk = _rfc6979_privkey()
        val msg = _sample_msg()
        val msg_hash = sha256(msg)
        val sig = p256_ecdsa_sign(sk, msg_hash)
        val r_bytes = _extract_first_32(sig)
        expect(_bytes_hex(r_bytes)).to_equal(
            "efd48b2aacb6a8fd1140dd9cd45e81d69d2c877b56aaf991c34d0ea84eaf3716"
        )

    it "ECDSA sign matches RFC 6979 A.2.5 s value":
        val sk = _rfc6979_privkey()
        val msg = _sample_msg()
        val msg_hash = sha256(msg)
        val sig = p256_ecdsa_sign(sk, msg_hash)
        val s_bytes = _extract_last_32(sig)
        expect(_bytes_hex(s_bytes)).to_equal(
            "f7cb1c942d657c41d436c7a1b6e29f65f3e900dbb9aff4064dc4ab2f843acda8"
        )

    it "ECDSA verify accepts valid RFC 6979 signature":
        val sk = _rfc6979_privkey()
        val pub_key = p256_keygen(sk)
        val msg = _sample_msg()
        val msg_hash = sha256(msg)
        val sig = p256_ecdsa_sign(sk, msg_hash)
        expect(p256_ecdsa_verify(pub_key, msg_hash, sig)).to_equal(true)

    it "ECDSA verify rejects corrupted signature":
        val sk = _rfc6979_privkey()
        val pub_key = p256_keygen(sk)
        val msg = _sample_msg()
        val msg_hash = sha256(msg)
        val sig = p256_ecdsa_sign(sk, msg_hash)
        val bad_sig = _corrupt_sig(sig)
        expect(p256_ecdsa_verify(pub_key, msg_hash, bad_sig)).to_equal(false)

    it "ECDSA verify rejects wrong message":
        val sk = _rfc6979_privkey()
        val pub_key = p256_keygen(sk)
        val msg = _sample_msg()
        val msg_hash = sha256(msg)
        val sig = p256_ecdsa_sign(sk, msg_hash)
        val other = _test_msg()
        val wrong_hash = sha256(other)
        expect(p256_ecdsa_verify(pub_key, wrong_hash, sig)).to_equal(false)

    it "ECDH shared secret is 32 bytes":
        val sk = _rfc6979_privkey()
        val pub_key = p256_keygen(sk)
        val shared = p256_ecdh(sk, pub_key)
        expect(shared.len()).to_equal(32)

    it "ECDH is commutative (alice*Bob == bob*Alice)":
        val alice_sk = _rfc6979_privkey()
        val bob_sk = _bob_privkey()
        val alice_pub = p256_keygen(alice_sk)
        val bob_pub = p256_keygen(bob_sk)
        val shared_ab = p256_ecdh(alice_sk, bob_pub)
        val shared_ba = p256_ecdh(bob_sk, alice_pub)
        expect(_bytes_hex(shared_ab)).to_equal(_bytes_hex(shared_ba))

    it "p256_add(1, 1) mod p == 2":
        val one = _be32_one()
        val two_bytes = p256_add(one, one)
        val expected = _be32_two()
        expect(_bytes_hex(two_bytes)).to_equal(_bytes_hex(expected))

    it "p256_mul(2, 3) mod p == 6":
        val two = _be32_two()
        val three = _be32_three()
        val six_bytes = p256_mul(two, three)
        val expected = _be32_six()
        expect(_bytes_hex(six_bytes)).to_equal(_bytes_hex(expected))
