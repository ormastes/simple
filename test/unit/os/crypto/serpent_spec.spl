use std.spec.*
use os.crypto.serpent.{serpent_encrypt_block}

fn _hex_nibble(n: u8) -> text:
    if n == 0: "0"
    elif n == 1: "1"
    elif n == 2: "2"
    elif n == 3: "3"
    elif n == 4: "4"
    elif n == 5: "5"
    elif n == 6: "6"
    elif n == 7: "7"
    elif n == 8: "8"
    elif n == 9: "9"
    elif n == 10: "a"
    elif n == 11: "b"
    elif n == 12: "c"
    elif n == 13: "d"
    elif n == 14: "e"
    else: "f"

fn _bytes_hex(b: [u8]) -> text:
    var s: text = ""
    var i: i64 = 0
    while i < b.len():
        val byte = b[i]
        s = s + _hex_nibble((byte >> 4) & 0x0F)
        s = s + _hex_nibble(byte & 0x0F)
        i = i + 1
    s

fn _zero16() -> [u8]:
    var b: [u8] = []
    var i: i64 = 0
    while i < 16:
        b.push(0)
        i = i + 1
    b

describe "Serpent KAT":
    it "enc zero/zero":
        expect(_bytes_hex(serpent_encrypt_block(_zero16(), _zero16()))).to_equal("3620b17ae6a993d09618b8768266bae9")
