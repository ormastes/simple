# SM3 (GB/T 32905-2012) Known-Answer Test Vectors
#
# Tests the pure-Simple SM3 implementation in
#   src/os/crypto/sm3.spl
# against canonical vectors from the Chinese national standard
# GB/T 32905-2012 and GM/T 0004-2012 Appendix A.
#
# Vectors used:
#   SM3("abc") =
#       66c7f0f462eeedd9d1f2d46bdc10e4e24167c4875cf2f7a2297da02b8f4ba8e0
#   Source: GM/T 0004-2012, Appendix A.1
#
#   SM3("") =
#       1ab21d8355cfa17f8e61194831e81a8f22bec8c728fefb747ed035eb5082aa2b
#   Standard empty-message digest.
#
# NOTE: interpreter-mode test runner verifies file loading, NOT it-block
# execution. Digest assertions only fire under compiled/native mode
# (see feedback_compile_mode_false_greens.md).

use std.spipe.*
use os.crypto.sm3.{sm3_hash}

# ============================================================================
# Helpers
# ============================================================================

fn _bytes_to_hex(bs: [u8]) -> text:
    """Convert a byte slice to a lowercase hex string."""
    val hex_chars = "0123456789abcdef"
    var s: text = ""
    var i: u64 = 0
    while i < bs.len():
        val b = bs[i].to_u64()
        s = s + hex_chars.char_at((b >> 4).to_u64())
        s = s + hex_chars.char_at((b & 0xF).to_u64())
        i = i + 1
    s

fn _empty_bytes() -> [u8]:
    """Return an empty byte slice."""
    var b: [u8] = []
    b

fn _abc_bytes() -> [u8]:
    """Return bytes for the ASCII string 'abc'."""
    var b: [u8] = []
    b.push(0x61u8)
    b.push(0x62u8)
    b.push(0x63u8)
    b

# ============================================================================
# SM3 KAT — GB/T 32905-2012
# ============================================================================

describe "SM3 hash (GB/T 32905-2012)":

    it "SM3('abc') matches GM/T 0004-2012 Appendix A.1":
        val result = sm3_hash(_abc_bytes())
        val hex = _bytes_to_hex(result)
        expect(hex).to_equal("66c7f0f462eeedd9d1f2d46bdc10e4e24167c4875cf2f7a2297da02b8f4ba8e0")

    it "SM3('') matches empty-message standard vector":
        val result = sm3_hash(_empty_bytes())
        val hex = _bytes_to_hex(result)
        expect(hex).to_equal("1ab21d8355cfa17f8e61194831e81a8f22bec8c728fefb747ed035eb5082aa2b")

    it "SM3 digest length is 32 bytes":
        val result = sm3_hash(_abc_bytes())
        expect(result.len()).to_equal(32)
