# AES-OFB / AES-CFB NIST SP 800-38A Known-Answer Tests
#
# Tests aes128_ofb_encrypt, aes256_ofb_encrypt, aes128_cfb128_encrypt,
# aes128_cfb128_decrypt, aes128_cfb8_encrypt, aes128_cfb8_decrypt against
# NIST SP 800-38A Appendix F reference vectors.
#
# Coverage:
#   F.4.1 / F.4.2  OFB-AES-128 encrypt / decrypt (4 blocks = 8 tests)
#   F.4.5 / F.4.6  OFB-AES-256 encrypt / decrypt (4 blocks = 8 tests)
#   F.3.13/F.3.14  CFB128-AES-128 encrypt / decrypt (4 blocks)
#   F.3.7 / F.3.8  CFB8-AES-128 encrypt / decrypt (18-byte vector)
#
# NOTE: per memory/feedback_it_block_var_mutation.md, byte-array inputs are
# built in module-level fn helpers so loop pushes persist across calls.
# NOTE: per memory/feedback_compile_mode_false_greens.md this spec is
# verified in interpreter mode only.
# NOTE: rt_aes*_encrypt_block_pure requires Value::Int array elements.
# All helper fns use var/push with bare integer literals (no u8 suffix).
#
# Source: NIST SP 800-38A, Appendix F
# https://csrc.nist.gov/publications/detail/sp/800-38a/final

use std.spec.*
use os.crypto.aes_modes.{
    aes128_ofb_encrypt, aes128_ofb_decrypt,
    aes256_ofb_encrypt, aes256_ofb_decrypt,
    aes128_cfb128_encrypt, aes128_cfb128_decrypt,
    aes256_cfb128_encrypt, aes256_cfb128_decrypt,
    aes128_cfb8_encrypt, aes128_cfb8_decrypt
}

extern fn rt_bytes_u8_at(arr: [u8], idx: i64) -> i64
extern fn rt_array_new_with_cap(cap: i64) -> [u8]

fn _slice16(buf: [u8], block_idx: i64) -> [u8]:
    var s: [u8] = rt_array_new_with_cap(16)
    var i: i64 = 0
    val start: i64 = block_idx * 16
    while i < 16:
        s.push(rt_bytes_u8_at(buf, start + i))
        i = i + 1
    s

