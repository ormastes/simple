use std.sspec.*
use os.crypto.rsa.{RsaSignBackend, rsa_sha256_sign_with_backend, rsa_sha512_sign_with_backend, rsa_sha512_verify}
use os.apps.sshd.host_key_loader.{load_rsa_pkcs8_from_file}

extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_read_bytes(path: text) -> [u8]
extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_dir_create(path: text, recursive: bool) -> bool

val TEST_DIR = "/tmp/rsa_contract_parity_spec"
val RSA_PEM = TEST_DIR + "/rsa.pem"
val RSA_PK8 = TEST_DIR + "/rsa.pk8"
val RSA_SPKI = TEST_DIR + "/rsa.spki"
val EC_PEM = TEST_DIR + "/ec.pem"
val EC_PK8 = TEST_DIR + "/ec.pk8"

fn openssl_available() -> bool:
    val (_out, _err, code) = rt_process_run("which", ["openssl"])
    code == 0

fn _fixture_exists() -> bool:
    rt_file_exists(RSA_PK8) and rt_file_exists(RSA_SPKI) and rt_file_exists(EC_PK8)

fn _ensure_fixture_dir():
    rt_dir_create(TEST_DIR, true)

fn _run_or_print(cmd: text, args: [text]) -> bool:
    val (out, err, code) = rt_process_run(cmd, args)
    if code != 0:
        print("{cmd} stdout: {out}")
        print("{cmd} stderr: {err}")
    code == 0

fn _ensure_crypto_fixtures() -> bool:
    _ensure_fixture_dir()
    if _fixture_exists():
        return true
    if not openssl_available():
        return false

    if not _run_or_print("openssl", [
        "genpkey",
        "-algorithm", "RSA",
        "-pkeyopt", "rsa_keygen_bits:2048",
        "-out", RSA_PEM
    ]):
        return false
    if not _run_or_print("openssl", [
        "pkcs8",
        "-topk8",
        "-nocrypt",
        "-in", RSA_PEM,
        "-outform", "DER",
        "-out", RSA_PK8
    ]):
        return false
    if not _run_or_print("openssl", [
        "pkey",
        "-in", RSA_PEM,
        "-pubout",
        "-outform", "DER",
        "-out", RSA_SPKI
    ]):
        return false
    if not _run_or_print("openssl", [
        "genpkey",
        "-algorithm", "EC",
        "-pkeyopt", "ec_paramgen_curve:P-256",
        "-out", EC_PEM
    ]):
        return false
    _run_or_print("openssl", [
        "pkcs8",
        "-topk8",
        "-nocrypt",
        "-in", EC_PEM,
        "-outform", "DER",
        "-out", EC_PK8
    ])

fn _load_rsa_pkcs8() -> [u8]:
    match load_rsa_pkcs8_from_file(RSA_PK8):
        Ok(bytes):
            bytes
        Err(msg):
            print("load_rsa_pkcs8_from_file failed: {msg}")
            []

fn _load_bytes(path: text) -> [u8]:
    rt_file_read_bytes(path) ?? []

fn _test_message() -> [u8]:
    "rsa-contract-parity-message-2026-04-24".to_bytes()

fn _malformed_pkcs8() -> [u8]:
    [0x30, 0x03, 0x02, 0x01, 0x00]

describe "RSA signing contract backend selection":
    it "Auto matches HostedReference for a valid SHA-512 RSA fixture":
        if not _ensure_crypto_fixtures():
            return "skip: openssl fixture generation unavailable"
        val pkcs8 = _load_rsa_pkcs8()
        val msg = _test_message()
        val auto_sig = rsa_sha512_sign_with_backend(pkcs8, msg, RsaSignBackend.Auto)
        val hosted_sig = rsa_sha512_sign_with_backend(pkcs8, msg, RsaSignBackend.HostedReference)
        expect(auto_sig.len()).to_be_greater_than(0)
        expect(auto_sig).to_equal(hosted_sig)

    it "HostedReference SHA-512 signing is deterministic":
        if not _ensure_crypto_fixtures():
            return "skip: openssl fixture generation unavailable"
        val pkcs8 = _load_rsa_pkcs8()
        val msg = _test_message()
        val sig_a = rsa_sha512_sign_with_backend(pkcs8, msg, RsaSignBackend.HostedReference)
        val sig_b = rsa_sha512_sign_with_backend(pkcs8, msg, RsaSignBackend.HostedReference)
        expect(sig_a.len()).to_be_greater_than(0)
        expect(sig_a).to_equal(sig_b)

    it "PureSimple SHA-512 signing is deterministic":
        if not _ensure_crypto_fixtures():
            return "skip: openssl fixture generation unavailable"
        val pkcs8 = _load_rsa_pkcs8()
        val msg = _test_message()
        val sig_a = rsa_sha512_sign_with_backend(pkcs8, msg, RsaSignBackend.PureSimple)
        val sig_b = rsa_sha512_sign_with_backend(pkcs8, msg, RsaSignBackend.PureSimple)
        expect(sig_a.len()).to_be_greater_than(0)
        expect(sig_a).to_equal(sig_b)

    it "PureSimple SHA-512 matches HostedReference byte-for-byte and verifies":
        if not _ensure_crypto_fixtures():
            return "skip: openssl fixture generation unavailable"
        val pkcs8 = _load_rsa_pkcs8()
        val spki = _load_bytes(RSA_SPKI)
        val msg = _test_message()
        val hosted_sig = rsa_sha512_sign_with_backend(pkcs8, msg, RsaSignBackend.HostedReference)
        val pure_sig = rsa_sha512_sign_with_backend(pkcs8, msg, RsaSignBackend.PureSimple)
        expect(hosted_sig.len()).to_be_greater_than(0)
        expect(pure_sig).to_equal(hosted_sig)
        expect(rsa_sha512_verify(spki, msg, hosted_sig)).to_equal(true)
        expect(rsa_sha512_verify(spki, msg, pure_sig)).to_equal(true)

    it "malformed PKCS#8 returns empty signatures for SHA-256 and SHA-512 across backends":
        val malformed = _malformed_pkcs8()
        val msg = _test_message()
        expect(rsa_sha256_sign_with_backend(malformed, msg, RsaSignBackend.HostedReference)).to_equal([])
        expect(rsa_sha256_sign_with_backend(malformed, msg, RsaSignBackend.PureSimple)).to_equal([])
        expect(rsa_sha512_sign_with_backend(malformed, msg, RsaSignBackend.HostedReference)).to_equal([])
        expect(rsa_sha512_sign_with_backend(malformed, msg, RsaSignBackend.PureSimple)).to_equal([])

    it "wrong key type returns empty SHA-512 signatures across backends":
        if not _ensure_crypto_fixtures():
            return "skip: openssl fixture generation unavailable"
        val ec_pkcs8 = _load_bytes(EC_PK8)
        val msg = _test_message()
        expect(rsa_sha512_sign_with_backend(ec_pkcs8, msg, RsaSignBackend.HostedReference)).to_equal([])
        expect(rsa_sha512_sign_with_backend(ec_pkcs8, msg, RsaSignBackend.PureSimple)).to_equal([])
