use std.spec.*
use os.crypto.sm4.*

describe "SM4 probe3":
    it "cross-module param push [u8]":
        var b: [u8] = []
        var x: u8 = 0x01
        b.push(x)
        x = 0x23
        b.push(x)
        x = 0x45
        b.push(x)
        x = 0x67
        b.push(x)
        x = 0x89
        b.push(x)
        x = 0xAB
        b.push(x)
        x = 0xCD
        b.push(x)
        x = 0xEF
        b.push(x)
        x = 0xFE
        b.push(x)
        x = 0xDC
        b.push(x)
        x = 0xBA
        b.push(x)
        x = 0x98
        b.push(x)
        x = 0x76
        b.push(x)
        x = 0x54
        b.push(x)
        x = 0x32
        b.push(x)
        x = 0x10
        b.push(x)
        _sm4_fill_block_be(b, [])
        expect(1).to_equal(1)
    it "cross-module fill_block_be into local":
        var key: [u8] = [0x01u8, 0x23u8, 0x45u8, 0x67u8, 0x89u8, 0xABu8, 0xCDu8, 0xEFu8, 0xFEu8, 0xDCu8, 0xBAu8, 0x98u8, 0x76u8, 0x54u8, 0x32u8, 0x10u8]
        var mk: [u32] = []
        _sm4_fill_block_be(key, mk)
        expect(mk.len()).to_equal(4)
