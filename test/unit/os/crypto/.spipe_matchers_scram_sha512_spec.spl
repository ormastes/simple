# SCRAM-SHA-512 Known-Answer Tests — RFC 5802 (SHA-512 variant)
#
# Verifies the pure-Simple SCRAM-SHA-512 implementation in
# src/os/crypto/scram.spl against independently computed reference vectors.
#
# Test inputs reuse the RFC 7677 §3 example (same user/password/nonce/salt):
#   user          = "user"
#   password      = "pencil"
#   client-nonce  = "rOprNGfwEbeRWgbNEkqO"
#   server-nonce  = "rOprNGfwEbeRWgbNEkqO%hvYDpWUa2RaTCAfuxFIlj)hNlF$k0"
#   salt (b64)    = "W22ZaJ0SNY7soEsUEjb6gQ=="
#   salt (hex)    = 5b6d99689d12358eeca04b141236fa81
#   iterations    = 4096
#
# Expected values computed with Python 3 (python3 hashlib + hmac, 2026-05-03):
#   import hashlib, hmac, base64
#   salted = hashlib.pbkdf2_hmac('sha512', b'pencil',
#            base64.b64decode('W22ZaJ0SNY7soEsUEjb6gQ=='), 4096, 64)
#   ckey   = hmac.new(salted, b'Client Key', hashlib.sha512).digest()
#   skey   = hmac.new(salted, b'Server Key', hashlib.sha512).digest()
#   stored = hashlib.sha512(ckey).digest()
#   am     = b"n=user,...,c=biws,r=<combined_nonce>"   # see AuthMessage below
#   csig   = hmac.new(stored, am, hashlib.sha512).digest()
#   proof  = bytes(a^b for a,b in zip(ckey, csig))
#   ssig   = hmac.new(skey, am, hashlib.sha512).digest()
#
# Derived values:
#   SaltedPassword (hex) = f16efe1be67f1d09502ebd5ed9262fddffba5a377ab4f0b687e5ed5ba0f50686b8a4ae166476da8ab3b951d2fa9238b63998f45461bc33a464814949cec9631d
#   ClientKey (hex)      = f81d81a6c0467dbd957885e9f3a0387a99e989171077fc3b8d134b710907c424917b624f885a3667838762858a893a4fce39043aa57fa07388a5aaa6fdbac920
#   StoredKey (hex)      = e8002e6f7d3ae446119b216933644dc2a2be7869eb918b8459b5e7d7d2ec12606aceef106825cd735170a675fd3611f684affad1dce3f43a0ee43bd590e1dbbe
#   ClientProof (b64)    = gMGXRcevScNtxZ6/8lQYpGtnsNAc3mGcmNomv+xnoOMw+3R2xNJdMNnzMlTN8PPC6wdp6dybEmDYXYTxwnYPJQ==
#   ServerSig (hex)      = 6509d81205903059a6b0cf1a40c1749c30c2cbf0200b393093c0a631961c320d2f49594a0da9de90bb627c349e5464f8fb96715e726ad7df51546dab47b37b67
#   ServerSig (b64)      = ZQnYEgWQMFmmsM8aQMF0nDDCy/AgCzkwk8CmMZYcMg0vSVlKDanekLtifDSeVGT4+5ZxXnJq199RVG2rR7N7Zw==
#
# Tampered proof: ClientProof b64 with char[4] 'X'→'g' flipped (decodes to 64
# bytes, same length) so constant-time XOR-accumulate fires, not length check.
#
# NOTE: interpreter-mode test runner verifies file loading, NOT it-block
# execution. All MAC assertions require compiled/native mode
# (feedback_compile_mode_false_greens.md).
# All helper fns are module-level (feedback_it_block_var_mutation.md).

use string.{char_from_code}
use std.spipe.*
use os.crypto.scram.{
    scram_sha512_client_first,
    scram_sha512_client_final,
    scram_sha512_server_verify,
    scram_sha512_server_signature_check,
    scram_sha512_ct_eq,
    scram_sha512_decode_server_final
}

# ===========================================================================
# Data helpers — all module-level (no it-block var mutation)
# ===========================================================================

fn _str_to_u8_512(s: text) -> [u8]:
    var out: [u8] = []
    var i = 0
    while i < s.len():
        out.push(s.char_code_at(i).to_u8())
        i = i + 1
    out

fn _hex_pair_512(hi: i64, lo: i64) -> i64:
    val h = if hi >= 97: hi - 87 elif hi >= 65: hi - 55 else: hi - 48
    val l = if lo >= 97: lo - 87 elif lo >= 65: lo - 55 else: lo - 48
    (h << 4) | l

fn _hex_to_u8_512(hex: text) -> [u8]:
    var out: [u8] = []
    var i = 0
    while i + 1 < hex.len():
        val b = _hex_pair_512(hex.char_code_at(i), hex.char_code_at(i + 1))
        out.push(b.to_u8())
        i = i + 2
    out

fn _bytes_eq_512(a: [u8], b: [u8]) -> bool:
    if a.len() != b.len():
        return false
    var i: u64 = 0
    while i < a.len().to_u64():
        if a[i] != b[i]:
            return false
        i = i + 1
    true

fn _bytes_hex_512(buf: [u8]) -> text:
    var out: text = ""
    val hex_chars = "0123456789abcdef"
    var i: u64 = 0
    while i < buf.len().to_u64():
        val b = buf[i].to_i64()
        out = out + hex_chars.char_at((b >> 4) & 0xF)
        out = out + hex_chars.char_at(b & 0xF)
        i = i + 1
    out

fn _u8_to_text_512(buf: [u8]) -> text:
    var s: text = ""
    var i: u64 = 0
    while i < buf.len().to_u64():
        val code = buf[i].to_i64()
        if code >= 32 and code <= 126:
            s = s + char_from_code(code)
        i = i + 1
    s

fn _user_bytes_512() -> [u8]:
    _str_to_u8_512("user")

fn _client_nonce_bytes_512() -> [u8]:
    _str_to_u8_512("rOprNGfwEbeRWgbNEkqO")

fn _password_bytes_512() -> [u8]:
    _str_to_u8_512("pencil")

fn _gs2_header_bytes_512() -> [u8]:
    _str_to_u8_512("n,,")

fn _salt_bytes_512() -> [u8]:
    _hex_to_u8_512("5b6d99689d12358eeca04b141236fa81")

fn _client_first_expected_512() -> [u8]:
    _str_to_u8_512("n,,n=user,r=rOprNGfwEbeRWgbNEkqO")

fn _server_first_bytes_512() -> [u8]:
    _str_to_u8_512("r=rOprNGfwEbeRWgbNEkqO%hvYDpWUa2RaTCAfuxFIlj)hNlF$k0,s=W22ZaJ0SNY7soEsUEjb6gQ==,i=4096")

fn _auth_message_bytes_512() -> [u8]:
    _str_to_u8_512("n=user,r=rOprNGfwEbeRWgbNEkqO,r=rOprNGfwEbeRWgbNEkqO%hvYDpWUa2RaTCAfuxFIlj)hNlF$k0,s=W22ZaJ0SNY7soEsUEjb6gQ==,i=4096,c=biws,r=rOprNGfwEbeRWgbNEkqO%hvYDpWUa2RaTCAfuxFIlj)hNlF$k0")

fn _client_final_expected_512() -> [u8]:
    _str_to_u8_512("c=biws,r=rOprNGfwEbeRWgbNEkqO%hvYDpWUa2RaTCAfuxFIlj)hNlF$k0,p=gMGXRcevScNtxZ6/8lQYpGtnsNAc3mGcmNomv+xnoOMw+3R2xNJdMNnzMlTN8PPC6wdp6dybEmDYXYTxwnYPJQ==")

fn _tampered_final_bytes_512() -> [u8]:
    # ClientProof b64 with char[4] changed ('X'→'g') — 64-byte decode, content differs.
    _str_to_u8_512("c=biws,r=rOprNGfwEbeRWgbNEkqO%hvYDpWUa2RaTCAfuxFIlj)hNlF$k0,p=gMGgRcevScNtxZ6/8lQYpGtnsNAc3mGcmNomv+xnoOMw+3R2xNJdMNnzMlTN8PPC6wdp6dybEmDYXYTxwnYPJQ==")

# ===========================================================================
# Utility helpers
# ===========================================================================

fn _server_sig_hex_512() -> text:
    "6509d81205903059a6b0cf1a40c1749c30c2cbf0200b393093c0a631961c320d2f49594a0da9de90bb627c349e5464f8fb96715e726ad7df51546dab47b37b67"

fn _server_final_bytes_512() -> [u8]:
    _str_to_u8_512("v=ZQnYEgWQMFmmsM8aQMF0nDDCy/AgCzkwk8CmMZYcMg0vSVlKDanekLtifDSeVGT4+5ZxXnJq199RVG2rR7N7Zw==")

fn _salt_with_first_byte_flipped_512() -> [u8]:
    """Return a copy of _salt_bytes_512() with the first byte XOR'd with 1."""
    val a = _salt_bytes_512()
    var out: [u8] = []
    var i: u64 = 0
    while i < a.len().to_u64():
        if i == 0:
            out.push((a[i].to_i64() ^ 1).to_u8())
        else:
            out.push(a[i])
        i = i + 1
    out

# ===========================================================================
# Specs
# ===========================================================================

describe "SCRAM-SHA-512 — client-first":

    it "client-first format is n,,n=user,r=<nonce>":
        val cf = scram_sha512_client_first(_user_bytes_512(), _client_nonce_bytes_512())
        expect _bytes_eq_512(cf, _client_first_expected_512()) == true

    it "client-first length is 32 bytes":
        val cf = scram_sha512_client_first(_user_bytes_512(), _client_nonce_bytes_512())
        expect cf.len() == 32

describe "SCRAM-SHA-512 — client-final (full round-trip)":

    it "client-final is byte-exact with computed ClientProof":
        val (cf, _) = scram_sha512_client_final(
            _client_first_expected_512(),
            _server_first_bytes_512(),
            _password_bytes_512(),
            _gs2_header_bytes_512()
        )
        expect _bytes_eq_512(cf, _client_final_expected_512()) == true

    it "client-final text matches expected message with SHA-512 proof":
        val (cf, _) = scram_sha512_client_final(
            _client_first_expected_512(),
            _server_first_bytes_512(),
            _password_bytes_512(),
            _gs2_header_bytes_512()
        )
        val expected_text = "c=biws,r=rOprNGfwEbeRWgbNEkqO%hvYDpWUa2RaTCAfuxFIlj)hNlF$k0,p=gMGXRcevScNtxZ6/8lQYpGtnsNAc3mGcmNomv+xnoOMw+3R2xNJdMNnzMlTN8PPC6wdp6dybEmDYXYTxwnYPJQ=="
        expect _u8_to_text_512(cf) == expected_text

    it "ServerSignature hex matches Python-computed reference":
        val (_, server_sig) = scram_sha512_client_final(
            _client_first_expected_512(),
            _server_first_bytes_512(),
            _password_bytes_512(),
            _gs2_header_bytes_512()
        )
        expect _bytes_hex_512(server_sig) == _server_sig_hex_512()

    it "ServerSignature is 64 bytes":
        val (_, server_sig) = scram_sha512_client_final(
            _client_first_expected_512(),
            _server_first_bytes_512(),
            _password_bytes_512(),
            _gs2_header_bytes_512()
        )
        expect server_sig.len() == 64

describe "SCRAM-SHA-512 — server-side verify":

    it "server_verify accepts valid ClientProof":
        val ok = scram_sha512_server_verify(
            _client_final_expected_512(),
            _password_bytes_512(),
            _salt_bytes_512(),
            4096,
            _auth_message_bytes_512()
        )
        expect ok == true

    it "server_verify rejects tampered ClientProof (content differs, length=64)":
        val ok = scram_sha512_server_verify(
            _tampered_final_bytes_512(),
            _password_bytes_512(),
            _salt_bytes_512(),
            4096,
            _auth_message_bytes_512()
        )
        expect ok == false

    it "server_verify rejects wrong password":
        val ok = scram_sha512_server_verify(
            _client_final_expected_512(),
            _str_to_u8_512("wrongpassword"),
            _salt_bytes_512(),
            4096,
            _auth_message_bytes_512()
        )
        expect ok == false

describe "SCRAM-SHA-512 — constant-time equality":

    it "ct_eq returns true for identical 64-byte arrays":
        val a = _salt_bytes_512()
        val b = _salt_bytes_512()
        expect scram_sha512_ct_eq(a, b) == true

    it "ct_eq returns false for arrays differing in one byte":
        val a = _salt_bytes_512()
        val b = _salt_with_first_byte_flipped_512()
        expect scram_sha512_ct_eq(a, b) == false

    it "ct_eq returns false for different-length arrays":
        val a = _str_to_u8_512("abc")
        val b = _str_to_u8_512("abcd")
        expect scram_sha512_ct_eq(a, b) == false

describe "SCRAM-SHA-512 — server-final mutual auth":

    it "server_signature_check accepts valid server-final":
        val (_, server_sig) = scram_sha512_client_final(
            _client_first_expected_512(),
            _server_first_bytes_512(),
            _password_bytes_512(),
            _gs2_header_bytes_512()
        )
        val ok = scram_sha512_server_signature_check(_server_final_bytes_512(), server_sig)
        expect ok == true

    it "decode_server_final extracts 64-byte ServerSignature":
        val sig = scram_sha512_decode_server_final(_server_final_bytes_512())
        expect sig.len() == 64

    it "decoded ServerSignature hex matches Python-computed reference":
        val sig = scram_sha512_decode_server_final(_server_final_bytes_512())
        expect _bytes_hex_512(sig) == _server_sig_hex_512()