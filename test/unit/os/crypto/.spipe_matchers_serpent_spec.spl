use std.spec.*
use os.crypto.serpent.{serpent_encrypt_block, serpent_decrypt_block}

fn _hex_nibble(n: u8) -> text:
    if n == 0: "0"
    elif n == 1: "1"
    elif n == 2: "2"
    elif n == 3: "3"
    elif n == 4: "4"
    elif n == 5: "5"
    elif n == 6: "6"
    elif n == 7: "7"
    elif n == 8: "8"
    elif n == 9: "9"
    elif n == 10: "a"
    elif n == 11: "b"
    elif n == 12: "c"
    elif n == 13: "d"
    elif n == 14: "e"
    else: "f"

fn _bytes_hex(b: [u8]) -> text:
    var s: text = ""
    var i: i64 = 0
    while i < b.len():
        val byte = b[i]
        s = s + _hex_nibble((byte >> 4) & 0x0F)
        s = s + _hex_nibble(byte & 0x0F)
        i = i + 1
    s

fn _zero16() -> [u8]:
    var b: [u8] = []
    var i: i64 = 0
    while i < 16:
        b.push(0)
        i = i + 1
    b

fn _zero32() -> [u8]:
    var b: [u8] = []
    var i: i64 = 0
    while i < 32:
        b.push(0)
        i = i + 1
    b

fn _key_msb128() -> [u8]:
    var b: [u8] = []
    var v: u8 = 0x80
    b.push(v)
    v = 0
    var i: i64 = 0
    while i < 15:
        b.push(v)
        i = i + 1
    b

fn _pt_vec2() -> [u8]:
    var b: [u8] = []
    var v: u8 = 0xd2
    b.push(v)
    v = 0x9d
    b.push(v)
    v = 0x57
    b.push(v)
    v = 0x6f
    b.push(v)
    v = 0xce
    b.push(v)
    v = 0xa3
    b.push(v)
    v = 0xa3
    b.push(v)
    v = 0xa7
    b.push(v)
    v = 0xed
    b.push(v)
    v = 0x90
    b.push(v)
    v = 0x99
    b.push(v)
    v = 0xf2
    b.push(v)
    v = 0x92
    b.push(v)
    v = 0x73
    b.push(v)
    v = 0xd7
    b.push(v)
    v = 0x8e
    b.push(v)
    b

fn _ct_vec1() -> [u8]:
    var b: [u8] = []
    var v: u8 = 0x36
    b.push(v)
    v = 0x20
    b.push(v)
    v = 0xb1
    b.push(v)
    v = 0x7a
    b.push(v)
    v = 0xe6
    b.push(v)
    v = 0xa9
    b.push(v)
    v = 0x93
    b.push(v)
    v = 0xd0
    b.push(v)
    v = 0x96
    b.push(v)
    v = 0x18
    b.push(v)
    v = 0xb8
    b.push(v)
    v = 0x76
    b.push(v)
    v = 0x82
    b.push(v)
    v = 0x66
    b.push(v)
    v = 0xba
    b.push(v)
    v = 0xe9
    b.push(v)
    b

fn _ct_vec2() -> [u8]:
    var b: [u8] = []
    var v: u8 = 0xb2
    b.push(v)
    v = 0x28
    b.push(v)
    v = 0x8b
    b.push(v)
    v = 0x96
    b.push(v)
    v = 0x8a
    b.push(v)
    v = 0xe8
    b.push(v)
    v = 0xb0
    b.push(v)
    v = 0x86
    b.push(v)
    v = 0x48
    b.push(v)
    v = 0xd1
    b.push(v)
    v = 0xce
    b.push(v)
    v = 0x96
    b.push(v)
    v = 0x06
    b.push(v)
    v = 0xfd
    b.push(v)
    v = 0x99
    b.push(v)
    v = 0x2d
    b.push(v)
    b

fn _ct_vec3() -> [u8]:
    var b: [u8] = []
    var v: u8 = 0x26
    b.push(v)
    v = 0x4e
    b.push(v)
    v = 0x54
    b.push(v)
    v = 0x81
    b.push(v)
    v = 0xef
    b.push(v)
    v = 0xf4
    b.push(v)
    v = 0x2a
    b.push(v)
    v = 0x46
    b.push(v)
    v = 0x06
    b.push(v)
    v = 0xab
    b.push(v)
    v = 0xda
    b.push(v)
    v = 0x06
    b.push(v)
    v = 0xc0
    b.push(v)
    v = 0xbf
    b.push(v)
    v = 0xda
    b.push(v)
    v = 0x3d
    b.push(v)
    b

fn _t_enc_zero() -> text:
    _bytes_hex(serpent_encrypt_block(_zero16(), _zero16()))

fn _t_enc_zero_len() -> i64:
    serpent_encrypt_block(_zero16(), _zero16()).len()

fn _t_rt_zero() -> text:
    val ct = serpent_encrypt_block(_zero16(), _zero16())
    _bytes_hex(serpent_decrypt_block(_zero16(), ct))

fn _t_dec_vec1() -> text:
    _bytes_hex(serpent_decrypt_block(_zero16(), _ct_vec1()))

fn _t_enc_vec2() -> text:
    _bytes_hex(serpent_encrypt_block(_zero16(), _pt_vec2()))

fn _t_dec_vec2() -> text:
    _bytes_hex(serpent_decrypt_block(_zero16(), _ct_vec2()))

fn _t_enc_vec3() -> text:
    _bytes_hex(serpent_encrypt_block(_key_msb128(), _zero16()))

fn _t_dec_vec3() -> text:
    _bytes_hex(serpent_decrypt_block(_key_msb128(), _ct_vec3()))

fn _t_rt_256() -> text:
    val ct = serpent_encrypt_block(_zero32(), _zero16())
    _bytes_hex(serpent_decrypt_block(_zero32(), ct))

describe "Serpent KAT":
    it "enc zero/zero":
        expect _t_enc_zero() == "3620b17ae6a993d09618b8768266bae9"

    it "ct is 16 bytes":
        expect _t_enc_zero_len() == 16

    it "rt zero":
        expect _t_rt_zero() == "00000000000000000000000000000000"

    it "dec vec1":
        expect _t_dec_vec1() == "00000000000000000000000000000000"

    it "enc vec2":
        expect _t_enc_vec2() == "b2288b968ae8b08648d1ce9606fd992d"

    it "dec vec2":
        expect _t_dec_vec2() == "d29d576fcea3a3a7ed9099f29273d78e"

    it "enc vec3":
        expect _t_enc_vec3() == "264e5481eff42a4606abda06c0bfda3d"

    it "dec vec3":
        expect _t_dec_vec3() == "00000000000000000000000000000000"

    it "rt 256":
        expect _t_rt_256() == "00000000000000000000000000000000"