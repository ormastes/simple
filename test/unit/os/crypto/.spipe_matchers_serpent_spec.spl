# Serpent Block Cipher — Known-Answer Test Vectors
#
# Tests serpent_encrypt_block and serpent_decrypt_block against official
# NIST AES candidate submission vectors (Serpent-1 / AES submission byte order).
#
# Serpent-128 vectors (AES submission / serpent.org):
#   Key: 00000000000000000000000000000000, PT: 00000000000000000000000000000000
#   CT:  3620b17ae6a993d09618b8768266bae9
#
#   Key: 00000000000000000000000000000000, PT: d29d576fcea3a3a7ed9099f29273d78e
#   CT:  b2288b968ae8b08648d1ce9606fd992d
#
#   Key: 80000000000000000000000000000000, PT: 00000000000000000000000000000000
#   CT:  264e5481eff42a4606abda06c0bfda3d
#
# Source: NIST AES candidate evaluation package, Serpent submission.
# https://www.cl.cam.ac.uk/~rja14/serpent.html

use std.spec.*
use os.crypto.serpent.{serpent_encrypt_block, serpent_decrypt_block}

fn _hex_nibble(n: u8) -> text:
    if n == 0: "0"
    else if n == 1: "1"
    else if n == 2: "2"
    else if n == 3: "3"
    else if n == 4: "4"
    else if n == 5: "5"
    else if n == 6: "6"
    else if n == 7: "7"
    else if n == 8: "8"
    else if n == 9: "9"
    else if n == 10: "a"
    else if n == 11: "b"
    else if n == 12: "c"
    else if n == 13: "d"
    else if n == 14: "e"
    else: "f"

fn _bytes_to_hex(b: [u8]) -> text:
    var s: text = ""
    var i: u64 = 0
    while i < b.len().to_u64():
        val byte = b[i]
        s = s + _hex_nibble((byte >> 4) & 0x0F)
        s = s + _hex_nibble(byte & 0x0F)
        i = i + 1
    s

fn _zero16() -> [u8]:
    var b: [u8] = []
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b

fn _zero32() -> [u8]:
    var b: [u8] = []
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b

# Key: 80000000000000000000000000000000 (MSB set)
fn _key_msb128() -> [u8]:
    var b: [u8] = []
    b.push(0x80)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b

# PT: d29d576fcea3a3a7ed9099f29273d78e
fn _pt_vec2() -> [u8]:
    var b: [u8] = []
    b.push(0xd2)
    b.push(0x9d)
    b.push(0x57)
    b.push(0x6f)
    b.push(0xce)
    b.push(0xa3)
    b.push(0xa3)
    b.push(0xa7)
    b.push(0xed)
    b.push(0x90)
    b.push(0x99)
    b.push(0xf2)
    b.push(0x92)
    b.push(0x73)
    b.push(0xd7)
    b.push(0x8e)
    b

# CT: 3620b17ae6a993d09618b8768266bae9
fn _ct_128_vec1_expected() -> [u8]:
    var b: [u8] = []
    b.push(0x36)
    b.push(0x20)
    b.push(0xb1)
    b.push(0x7a)
    b.push(0xe6)
    b.push(0xa9)
    b.push(0x93)
    b.push(0xd0)
    b.push(0x96)
    b.push(0x18)
    b.push(0xb8)
    b.push(0x76)
    b.push(0x82)
    b.push(0x66)
    b.push(0xba)
    b.push(0xe9)
    b

# CT: b2288b968ae8b08648d1ce9606fd992d
fn _ct_128_vec2_expected() -> [u8]:
    var b: [u8] = []
    b.push(0xb2)
    b.push(0x28)
    b.push(0x8b)
    b.push(0x96)
    b.push(0x8a)
    b.push(0xe8)
    b.push(0xb0)
    b.push(0x86)
    b.push(0x48)
    b.push(0xd1)
    b.push(0xce)
    b.push(0x96)
    b.push(0x06)
    b.push(0xfd)
    b.push(0x99)
    b.push(0x2d)
    b

# CT: 264e5481eff42a4606abda06c0bfda3d
fn _ct_128_vec3_expected() -> [u8]:
    var b: [u8] = []
    b.push(0x26)
    b.push(0x4e)
    b.push(0x54)
    b.push(0x81)
    b.push(0xef)
    b.push(0xf4)
    b.push(0x2a)
    b.push(0x46)
    b.push(0x06)
    b.push(0xab)
    b.push(0xda)
    b.push(0x06)
    b.push(0xc0)
    b.push(0xbf)
    b.push(0xda)
    b.push(0x3d)
    b

describe "Serpent — known-answer vectors (NIST AES submission)":

    it "Serpent-128: encrypt zero/zero key+PT":
        val ct = serpent_encrypt_block(_zero16(), _zero16())
        expect _bytes_to_hex(ct) == "3620b17ae6a993d09618b8768266bae9"

    it "Serpent-128: ciphertext is 16 bytes":
        val ct = serpent_encrypt_block(_zero16(), _zero16())
        expect ct.len() == 16

    it "Serpent-128: decrypt round-trip recovers zero PT":
        val ct = serpent_encrypt_block(_zero16(), _zero16())
        val pt = serpent_decrypt_block(_zero16(), ct)
        expect _bytes_to_hex(pt) == "00000000000000000000000000000000"

    it "Serpent-128: decrypt known CT (vec1) recovers zero PT":
        val pt = serpent_decrypt_block(_zero16(), _ct_128_vec1_expected())
        expect _bytes_to_hex(pt) == "00000000000000000000000000000000"

    it "Serpent-128: encrypt zero-key + non-zero PT (vec2)":
        val ct = serpent_encrypt_block(_zero16(), _pt_vec2())
        expect _bytes_to_hex(ct) == "b2288b968ae8b08648d1ce9606fd992d"

    it "Serpent-128: decrypt vec2 CT recovers original PT":
        val pt = serpent_decrypt_block(_zero16(), _ct_128_vec2_expected())
        expect _bytes_to_hex(pt) == "d29d576fcea3a3a7ed9099f29273d78e"

    it "Serpent-128: encrypt MSB-set key + zero PT (vec3)":
        val ct = serpent_encrypt_block(_key_msb128(), _zero16())
        expect _bytes_to_hex(ct) == "264e5481eff42a4606abda06c0bfda3d"

    it "Serpent-128: decrypt vec3 CT recovers zero PT":
        val pt = serpent_decrypt_block(_key_msb128(), _ct_128_vec3_expected())
        expect _bytes_to_hex(pt) == "00000000000000000000000000000000"

    it "Serpent-256: round-trip with zero key + zero PT (no CT assertion)":
        val ct = serpent_encrypt_block(_zero32(), _zero16())
        val pt = serpent_decrypt_block(_zero32(), ct)
        expect _bytes_to_hex(pt) == "00000000000000000000000000000000"