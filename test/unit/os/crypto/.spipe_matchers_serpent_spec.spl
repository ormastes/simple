# Serpent Block Cipher — Known-Answer Test Vectors
#
# Tests serpent_encrypt_block and serpent_decrypt_block against official
# NIST AES candidate submission vectors (Serpent-1 / AES submission byte order).
#
# Serpent-128 vectors (AES submission / serpent.org):
#   Key: 00000000000000000000000000000000, PT: 00000000000000000000000000000000
#   CT:  3620b17ae6a993d09618b8768266bae9
#
#   Key: 00000000000000000000000000000000, PT: d29d576fcea3a3a7ed9099f29273d78e
#   CT:  b2288b968ae8b08648d1ce9606fd992d
#
#   Key: 80000000000000000000000000000000, PT: 00000000000000000000000000000000
#   CT:  264e5481eff42a4606abda06c0bfda3d
#
# Source: NIST AES candidate evaluation package, Serpent submission.
# https://www.cl.cam.ac.uk/~rja14/serpent.html

use std.spec.*
use os.crypto.serpent.{serpent_encrypt_block, serpent_decrypt_block}

fn _hex_nibble(n: u8) -> text:
    if n == 0: "0"
    elif n == 1: "1"
    elif n == 2: "2"
    elif n == 3: "3"
    elif n == 4: "4"
    elif n == 5: "5"
    elif n == 6: "6"
    elif n == 7: "7"
    elif n == 8: "8"
    elif n == 9: "9"
    elif n == 10: "a"
    elif n == 11: "b"
    elif n == 12: "c"
    elif n == 13: "d"
    elif n == 14: "e"
    else: "f"

fn _bytes_to_hex(b: [u8]) -> text:
    var s: text = ""
    var i: i64 = 0
    while i < b.len():
        val byte = b[i]
        s = s + _hex_nibble((byte >> 4) & 0x0F)
        s = s + _hex_nibble(byte & 0x0F)
        i = i + 1
    s

fn _push_byte(arr: [u8], byte_val: u8):
    arr.push(byte_val)

fn _zero16() -> [u8]:
    var b: [u8] = []
    var v: u8 = 0
    var i: i64 = 0
    while i < 16:
        _push_byte(b, v)
        i = i + 1
    b

fn _zero32() -> [u8]:
    var b: [u8] = []
    var v: u8 = 0
    var i: i64 = 0
    while i < 32:
        _push_byte(b, v)
        i = i + 1
    b

# Key: 80000000000000000000000000000000 (MSB set)
fn _key_msb128() -> [u8]:
    var b: [u8] = []
    var v: u8 = 0x80
    _push_byte(b, v)
    v = 0
    var i: i64 = 0
    while i < 15:
        _push_byte(b, v)
        i = i + 1
    b

# PT: d29d576fcea3a3a7ed9099f29273d78e
fn _pt_vec2() -> [u8]:
    var b: [u8] = []
    var v: u8 = 0xd2
    _push_byte(b, v)
    v = 0x9d
    _push_byte(b, v)
    v = 0x57
    _push_byte(b, v)
    v = 0x6f
    _push_byte(b, v)
    v = 0xce
    _push_byte(b, v)
    v = 0xa3
    _push_byte(b, v)
    v = 0xa3
    _push_byte(b, v)
    v = 0xa7
    _push_byte(b, v)
    v = 0xed
    _push_byte(b, v)
    v = 0x90
    _push_byte(b, v)
    v = 0x99
    _push_byte(b, v)
    v = 0xf2
    _push_byte(b, v)
    v = 0x92
    _push_byte(b, v)
    v = 0x73
    _push_byte(b, v)
    v = 0xd7
    _push_byte(b, v)
    v = 0x8e
    _push_byte(b, v)
    b

# CT: 3620b17ae6a993d09618b8768266bae9
fn _ct_128_vec1_expected() -> [u8]:
    var b: [u8] = []
    var v: u8 = 0x36
    _push_byte(b, v)
    v = 0x20
    _push_byte(b, v)
    v = 0xb1
    _push_byte(b, v)
    v = 0x7a
    _push_byte(b, v)
    v = 0xe6
    _push_byte(b, v)
    v = 0xa9
    _push_byte(b, v)
    v = 0x93
    _push_byte(b, v)
    v = 0xd0
    _push_byte(b, v)
    v = 0x96
    _push_byte(b, v)
    v = 0x18
    _push_byte(b, v)
    v = 0xb8
    _push_byte(b, v)
    v = 0x76
    _push_byte(b, v)
    v = 0x82
    _push_byte(b, v)
    v = 0x66
    _push_byte(b, v)
    v = 0xba
    _push_byte(b, v)
    v = 0xe9
    _push_byte(b, v)
    b

# CT: b2288b968ae8b08648d1ce9606fd992d
fn _ct_128_vec2_expected() -> [u8]:
    var b: [u8] = []
    var v: u8 = 0xb2
    _push_byte(b, v)
    v = 0x28
    _push_byte(b, v)
    v = 0x8b
    _push_byte(b, v)
    v = 0x96
    _push_byte(b, v)
    v = 0x8a
    _push_byte(b, v)
    v = 0xe8
    _push_byte(b, v)
    v = 0xb0
    _push_byte(b, v)
    v = 0x86
    _push_byte(b, v)
    v = 0x48
    _push_byte(b, v)
    v = 0xd1
    _push_byte(b, v)
    v = 0xce
    _push_byte(b, v)
    v = 0x96
    _push_byte(b, v)
    v = 0x06
    _push_byte(b, v)
    v = 0xfd
    _push_byte(b, v)
    v = 0x99
    _push_byte(b, v)
    v = 0x2d
    _push_byte(b, v)
    b

# CT: 264e5481eff42a4606abda06c0bfda3d
fn _ct_128_vec3_expected() -> [u8]:
    var b: [u8] = []
    var v: u8 = 0x26
    _push_byte(b, v)
    v = 0x4e
    _push_byte(b, v)
    v = 0x54
    _push_byte(b, v)
    v = 0x81
    _push_byte(b, v)
    v = 0xef
    _push_byte(b, v)
    v = 0xf4
    _push_byte(b, v)
    v = 0x2a
    _push_byte(b, v)
    v = 0x46
    _push_byte(b, v)
    v = 0x06
    _push_byte(b, v)
    v = 0xab
    _push_byte(b, v)
    v = 0xda
    _push_byte(b, v)
    v = 0x06
    _push_byte(b, v)
    v = 0xc0
    _push_byte(b, v)
    v = 0xbf
    _push_byte(b, v)
    v = 0xda
    _push_byte(b, v)
    v = 0x3d
    _push_byte(b, v)
    b

# Module-level helpers to avoid it-block var-mutation footgun
fn _t_enc_zero() -> text:
    _bytes_to_hex(serpent_encrypt_block(_zero16(), _zero16()))

fn _t_enc_zero_len() -> i64:
    serpent_encrypt_block(_zero16(), _zero16()).len()

fn _t_rt_zero() -> text:
    val ct = serpent_encrypt_block(_zero16(), _zero16())
    _bytes_to_hex(serpent_decrypt_block(_zero16(), ct))

fn _t_dec_vec1() -> text:
    _bytes_to_hex(serpent_decrypt_block(_zero16(), _ct_128_vec1_expected()))

fn _t_enc_vec2() -> text:
    _bytes_to_hex(serpent_encrypt_block(_zero16(), _pt_vec2()))

fn _t_dec_vec2() -> text:
    _bytes_to_hex(serpent_decrypt_block(_zero16(), _ct_128_vec2_expected()))

fn _t_enc_vec3() -> text:
    _bytes_to_hex(serpent_encrypt_block(_key_msb128(), _zero16()))

fn _t_dec_vec3() -> text:
    _bytes_to_hex(serpent_decrypt_block(_key_msb128(), _ct_128_vec3_expected()))

fn _t_rt_256() -> text:
    val ct = serpent_encrypt_block(_zero32(), _zero16())
    _bytes_to_hex(serpent_decrypt_block(_zero32(), ct))

describe "Serpent — known-answer vectors (NIST AES submission)":

    it "Serpent-128: encrypt zero/zero key+PT":
        expect _t_enc_zero() == "3620b17ae6a993d09618b8768266bae9"

    it "Serpent-128: ciphertext is 16 bytes":
        expect _t_enc_zero_len() == 16

    it "Serpent-128: decrypt round-trip recovers zero PT":
        expect _t_rt_zero() == "00000000000000000000000000000000"

    it "Serpent-128: decrypt known CT (vec1) recovers zero PT":
        expect _t_dec_vec1() == "00000000000000000000000000000000"

    it "Serpent-128: encrypt zero-key + non-zero PT (vec2)":
        expect _t_enc_vec2() == "b2288b968ae8b08648d1ce9606fd992d"

    it "Serpent-128: decrypt vec2 CT recovers original PT":
        expect _t_dec_vec2() == "d29d576fcea3a3a7ed9099f29273d78e"

    it "Serpent-128: encrypt MSB-set key + zero PT (vec3)":
        expect _t_enc_vec3() == "264e5481eff42a4606abda06c0bfda3d"

    it "Serpent-128: decrypt vec3 CT recovers zero PT":
        expect _t_dec_vec3() == "00000000000000000000000000000000"

    it "Serpent-256: round-trip with zero key + zero PT":
        expect _t_rt_256() == "00000000000000000000000000000000"