use std.spec.*
use os.crypto.camellia.{camellia128_encrypt_block}

fn _key() -> [u8]:
    var k: [u8] = []
    k.push(0x01)
    k.push(0x23)
    k.push(0x45)
    k.push(0x67)
    k.push(0x89)
    k.push(0xAB)
    k.push(0xCD)
    k.push(0xEF)
    k.push(0xFE)
    k.push(0xDC)
    k.push(0xBA)
    k.push(0x98)
    k.push(0x76)
    k.push(0x54)
    k.push(0x32)
    k.push(0x10)
    k

describe "camellia debug":
    it "encrypt returns 16 bytes":
        val ct = camellia128_encrypt_block(_key(), _key())
        expect ct.len() == 16