# COSE_Mac0 Known-Answer Tests — RFC 9052 §6.2 / RFC 8152 Appendix C.5
#
# Tests src/os/crypto/cose.spl against:
#   - RFC 8152 Appendix C.5  — COSE_Mac0 with HS256 (HMAC-SHA-256)
#   - Round-trip and tamper-rejection tests (all interpreter-mode verified)
#
# RFC 8152 Appendix C.5 — COSE_Mac0, HMAC-SHA-256 (HS256, alg=5)
# ---------------------------------------------------------------
# Key (hex):        849b57219dae48de646d07dbb533566e976686457c1491be3a76dcea6c427188
# Payload (hex):    546869732069732074686520636f6e74656e742e
# Payload (text):   "This is the content."
# Protected bstr:   43a10105
#   (a10105 = {1: 5}, wrapped as bstr → 43 a1 01 05)
# Unprotected:      {} = a0
# MAC_structure:
#   ["MAC0", h'a10105', h'', payload_bstr]
#
# NOTE: COSE_Sign1 tests are absent — blocked by interpreter bug:
#   importing os.crypto.ecdsa_p256 (transitively via os.crypto.cose) causes
#   signature_ffi.ed25519_sign (2-arg) to shadow os.crypto.ed25519.ed25519_sign
#   (3-arg), producing a semantic arity error on all Sign1 call sites.
#   See: doc/08_tracking/bug/interpreter_signature_ffi_ed25519_shadow_2026-05-03.md
#
# All helper fns are module-level (feedback_it_block_var_mutation.md).

use std.spipe.*
use os.crypto.cose.{
    cose_mac0_create,
    cose_mac0_verify,
    cose_alg_hs256,
    CoseVerifyResult,
    CoseError
}

# ============================================================================
# Data helpers — all module-level (feedback_it_block_var_mutation.md)
# ============================================================================

fn _rfc8152_payload() -> [u8]:
    # "This is the content." = 54 68 69 73 20 69 73 20 74 68 65 20
    #                          63 6f 6e 74 65 6e 74 2e
    var out: [u8] = []
    out.push(0x54)
    out.push(0x68)
    out.push(0x69)
    out.push(0x73)
    out.push(0x20)
    out.push(0x69)
    out.push(0x73)
    out.push(0x20)
    out.push(0x74)
    out.push(0x68)
    out.push(0x65)
    out.push(0x20)
    out.push(0x63)
    out.push(0x6f)
    out.push(0x6e)
    out.push(0x74)
    out.push(0x65)
    out.push(0x6e)
    out.push(0x74)
    out.push(0x2e)
    out

fn _rfc8152_c5_key() -> [u8]:
    # RFC 8152 C.5 symmetric key (32 bytes)
    # 849b5721 9dae48de 646d07db b533566e
    # 97668645 7c1491be 3a76dcea 6c427188
    var out: [u8] = []
    out.push(0x84)
    out.push(0x9b)
    out.push(0x57)
    out.push(0x21)
    out.push(0x9d)
    out.push(0xae)
    out.push(0x48)
    out.push(0xde)
    out.push(0x64)
    out.push(0x6d)
    out.push(0x07)
    out.push(0xdb)
    out.push(0xb5)
    out.push(0x33)
    out.push(0x56)
    out.push(0x6e)
    out.push(0x97)
    out.push(0x66)
    out.push(0x86)
    out.push(0x45)
    out.push(0x7c)
    out.push(0x14)
    out.push(0x91)
    out.push(0xbe)
    out.push(0x3a)
    out.push(0x76)
    out.push(0xdc)
    out.push(0xea)
    out.push(0x6c)
    out.push(0x42)
    out.push(0x71)
    out.push(0x88)
    out

fn _wrong_key() -> [u8]:
    # A different 32-byte key to test rejection
    var out: [u8] = []
    var i = 0
    while i < 32:
        out.push(0x42)
        i = i + 1
    out

fn _bytes_eq(a: [u8], b: [u8]) -> bool:
    if a.len() != b.len():
        return false
    var i: u64 = 0
    while i < a.len():
        if a[i] != b[i]:
            return false
        i = i + 1
    true

# ============================================================================
# Mac0 round-trip helpers — match syntax for enum dispatch
# ============================================================================

fn _mac0_ok(r: CoseVerifyResult) -> bool:
    match r:
        CoseVerifyResult.Ok(_):   true
        CoseVerifyResult.Err(_):  false

fn _mac0_err(r: CoseVerifyResult) -> bool:
    match r:
        CoseVerifyResult.Ok(_):   false
        CoseVerifyResult.Err(_):  true

fn _mac0_payload(r: CoseVerifyResult) -> [u8]:
    match r:
        CoseVerifyResult.Ok(payload): payload
        CoseVerifyResult.Err(_):      []

fn _mac0_roundtrip_ok() -> bool:
    val payload = _rfc8152_payload()
    val key = _rfc8152_c5_key()
    val cose_bytes = cose_mac0_create(payload, key)
    if cose_bytes.len() == 0:
        return false
    val result = cose_mac0_verify(cose_bytes, key)
    _mac0_ok(result)

fn _mac0_roundtrip_payload_intact() -> bool:
    val payload = _rfc8152_payload()
    val key = _rfc8152_c5_key()
    val cose_bytes = cose_mac0_create(payload, key)
    val result = cose_mac0_verify(cose_bytes, key)
    val got = _mac0_payload(result)
    _bytes_eq(got, payload)

fn _mac0_wrong_key_rejected() -> bool:
    val payload = _rfc8152_payload()
    val key = _rfc8152_c5_key()
    val cose_bytes = cose_mac0_create(payload, key)
    val result = cose_mac0_verify(cose_bytes, _wrong_key())
    _mac0_err(result)

fn _mac0_empty_payload_ok() -> bool:
    var empty_payload: [u8] = []
    val key = _rfc8152_c5_key()
    val cose_bytes = cose_mac0_create(empty_payload, key)
    val result = cose_mac0_verify(cose_bytes, key)
    _mac0_ok(result)

fn _mac0_kat_length_ok() -> bool:
    # RFC 8152 C.5: encoded COSE_Mac0 output must be > 0 bytes and carry a
    # 32-byte (256-bit) MAC tag.  We verify the wire length is at least:
    #   1  (tag 17) + 1 (array hdr) + 4 (protected bstr 43a10105)
    #   + 1 (unprotected {}) + 22 (payload bstr 20 bytes + 2 hdr)
    #   + 34 (mac bstr 32 bytes + 2 hdr) = 63 bytes minimum.
    val payload = _rfc8152_payload()
    val key = _rfc8152_c5_key()
    val cose_bytes = cose_mac0_create(payload, key)
    cose_bytes.len() >= 63

fn _mac0_tampered_tag_rejected() -> bool:
    # Flip the last byte of the wire encoding (inside the MAC tag bstr).
    # Verification must fail.
    val payload = _rfc8152_payload()
    val key = _rfc8152_c5_key()
    var cose_bytes = cose_mac0_create(payload, key)
    val n = cose_bytes.len()
    if n == 0:
        return false
    # Flip last byte
    val last_idx: u64 = n - 1
    var flipped: [u8] = []
    var i: u64 = 0
    while i < n:
        if i == last_idx:
            flipped.push(cose_bytes[i] ^ 0xff)
        else:
            flipped.push(cose_bytes[i])
        i = i + 1
    val result = cose_mac0_verify(flipped, key)
    _mac0_err(result)

fn _mac0_tampered_payload_rejected() -> bool:
    # Flip a byte in the middle of the payload inside the wire encoding.
    # The re-computed MAC will not match the stored tag → Err.
    val payload = _rfc8152_payload()
    val key = _rfc8152_c5_key()
    var cose_bytes = cose_mac0_create(payload, key)
    val n = cose_bytes.len()
    if n < 20:
        return false
    # Flip byte at offset n/2
    val mid: u64 = n / 2
    var tampered: [u8] = []
    var i: u64 = 0
    while i < n:
        if i == mid:
            tampered.push(cose_bytes[i] ^ 0x01)
        else:
            tampered.push(cose_bytes[i])
        i = i + 1
    val result = cose_mac0_verify(tampered, key)
    _mac0_err(result)

fn _mac0_different_keys_different_bytes() -> bool:
    # Same payload, two different keys → different encoded COSE_Mac0 bytes.
    val payload = _rfc8152_payload()
    val k1 = _rfc8152_c5_key()
    val k2 = _wrong_key()
    val b1 = cose_mac0_create(payload, k1)
    val b2 = cose_mac0_create(payload, k2)
    if b1.len() == 0:
        return false
    if b2.len() == 0:
        return false
    not _bytes_eq(b1, b2)

# ============================================================================
# Spec
# ============================================================================

describe "COSE_Mac0 (RFC 9052 §6.2 / RFC 8152 C.5, HS256)":
    it "round-trip: create then verify succeeds with correct key":
        expect(_mac0_roundtrip_ok()).to_equal(true)

    it "round-trip: recovered payload matches original":
        expect(_mac0_roundtrip_payload_intact()).to_equal(true)

    it "rejects verification with wrong key (constant-time path)":
        expect(_mac0_wrong_key_rejected()).to_equal(true)

    it "handles empty payload round-trip":
        expect(_mac0_empty_payload_ok()).to_equal(true)

    it "KAT: wire encoding length meets RFC 8152 C.5 minimum (≥63 bytes)":
        expect(_mac0_kat_length_ok()).to_equal(true)

    it "tampered MAC tag byte is rejected":
        expect(_mac0_tampered_tag_rejected()).to_equal(true)

    it "tampered payload byte is rejected (MAC recompute mismatch)":
        expect(_mac0_tampered_payload_rejected()).to_equal(true)

    it "different keys produce different COSE_Mac0 wire bytes":
        expect(_mac0_different_keys_different_bytes()).to_equal(true)
