fn _sample_msg() -> [u8]:
    """The message 'sample' as bytes."""
    var m: [u8] = []
    m.push(0x73)
    m.push(0x61)
    m.push(0x6D)
    m.push(0x70)
    m.push(0x6C)
    m.push(0x65)
    m

# ============================================================================
# Test Suite
# ============================================================================

describe "P-384 ECDSA/ECDH — known-answer tests":

    it "p384_add(1, 1) mod p == 2":
        var one: [u8] = []
        var i: u64 = 0
        while i < 47:
            one.push(0x00)
            i = i + 1
        one.push(0x01)
        val two_bytes = p384_add(one, one)
        var expected: [u8] = []
        i = 0
        while i < 47:
            expected.push(0x00)
            i = i + 1
        expected.push(0x02)
        expect(_bytes_hex(two_bytes)).to_equal(_bytes_hex(expected))

    it "p384_mul(2, 3) mod p == 6":
        var two: [u8] = []
        var i: u64 = 0
        while i < 47:
            two.push(0x00)
            i = i + 1
        two.push(0x02)
        var three: [u8] = []
        i = 0
        while i < 47:
            three.push(0x00)
            i = i + 1
        three.push(0x03)
        val six_bytes = p384_mul(two, three)
        var expected: [u8] = []
        i = 0
        while i < 47:
            expected.push(0x00)
            i = i + 1
        expected.push(0x06)
        expect(_bytes_hex(six_bytes)).to_equal(_bytes_hex(expected))

    it "Generator G is on the P-384 curve":
        expect(p384_point_on_curve(_gx_bytes(), _gy_bytes())).to_equal(true)

    it "keygen produces 97-byte uncompressed pubkey":
        val sk = _test_privkey_a()
        val pub_key = p384_keygen(sk)
        expect(pub_key.len()).to_equal(97)
        expect(pub_key[0u64]).to_equal(0x04u8)

    it "generated pubkey is on curve":
        val sk = _test_privkey_a()
        val pub_key = p384_keygen(sk)
        var px: [u8] = []
        var py: [u8] = []
        var i: u64 = 0
        while i < 48:
            px.push(pub_key[1 + i])
            i = i + 1
        i = 0
        while i < 48:
            py.push(pub_key[49 + i])
            i = i + 1
        expect(p384_point_on_curve(px, py)).to_equal(true)

    it "ECDSA sign produces 96-byte signature":
        val sk = _test_privkey_a()
        val msg = _sample_msg()
        val msg_hash = sha384(msg)
        val sig = p384_ecdsa_sign(sk, msg_hash)
        expect(sig.len()).to_equal(96)

    it "ECDSA verify accepts valid signature":
        val sk = _test_privkey_a()
        val pub_key = p384_keygen(sk)
        val msg = _sample_msg()
        val msg_hash = sha384(msg)
        val sig = p384_ecdsa_sign(sk, msg_hash)
        expect(p384_ecdsa_verify(pub_key, msg_hash, sig)).to_equal(true)

    it "ECDSA verify rejects corrupted signature":
        val sk = _test_privkey_a()
        val pub_key = p384_keygen(sk)
        val msg = _sample_msg()
        val msg_hash = sha384(msg)
        val sig = p384_ecdsa_sign(sk, msg_hash)
        sig[0u64] = (sig[0u64] ^ 0x01u8)
        expect(p384_ecdsa_verify(pub_key, msg_hash, sig)).to_equal(false)

    it "ECDH shared secret is 48 bytes":
        val sk = _test_privkey_a()
        val pub_key = p384_keygen(sk)
        val shared = p384_ecdh(sk, pub_key)
        expect(shared.len()).to_equal(48)

    it "ECDH is commutative (alice*Bob == bob*Alice)":
        val alice_priv = _test_privkey_a()
        val bob_priv = _test_privkey_b()
        val alice_pub = p384_keygen(alice_priv)
        val bob_pub = p384_keygen(bob_priv)
        val shared_ab = p384_ecdh(alice_priv, bob_pub)
        val shared_ba = p384_ecdh(bob_priv, alice_pub)
        expect(_bytes_hex(shared_ab)).to_equal(_bytes_hex(shared_ba))
