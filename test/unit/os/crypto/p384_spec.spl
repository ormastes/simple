# P-384 ECDSA/ECDH Known-Answer Test
#
# Verifies the pure-Simple P-384 implementation against standard test vectors.
#
# Tests:
#   1. Field arithmetic (add, mul)
#   2. Generator G is on the P-384 curve
#   3. Keygen produces valid 97-byte uncompressed pubkey
#   4. Generated pubkey is on curve
#   5. ECDSA sign/verify round-trip
#   6. ECDSA verify rejects corrupted signature
#   7. ECDH shared secret consistency (commutativity)
#
# References:
#   * FIPS 186-4 / SEC2 v2.0 §2.5.1 (P-384 parameters)
#   * RFC 6979 §A.2.6 (ECDSA with P-384 and SHA-384)

use std.spipe.*
use os.crypto.p384.{
    p384_ecdsa_sign, p384_ecdsa_verify,
    p384_keygen, p384_ecdh,
    p384_point_on_curve, p384_add, p384_mul
}
use os.crypto.sha384.{sha384}

# ============================================================================
# Helpers
# ============================================================================

fn _hex_nibble(n: u8) -> text:
    if n == 0: "0"
    elif n == 1: "1"
    elif n == 2: "2"
    elif n == 3: "3"
    elif n == 4: "4"
    elif n == 5: "5"
    elif n == 6: "6"
    elif n == 7: "7"
    elif n == 8: "8"
    elif n == 9: "9"
    elif n == 10: "a"
    elif n == 11: "b"
    elif n == 12: "c"
    elif n == 13: "d"
    elif n == 14: "e"
    else: "f"

fn _bytes_hex(b: [u8]) -> text:
    var s: text = ""
    var i: u64 = 0
    while i < b.len().to_u64():
        val byte = b[i]
        s = s + _hex_nibble((byte >> 4) & 0x0F)
        s = s + _hex_nibble(byte & 0x0F)
        i = i + 1
    s

