# Adler-32 and Fletcher-32 Known-Answer Test Vectors
#
# Tests adler32 / fletcher32 against standard reference values and the
# incremental (streaming) update APIs.
#
# Adler-32 (RFC 1950 §9):
#   ""          → 0x00000001   (initial state A=1, B=0)
#   "abc"       → 0x024D0127   (A=0x0127=295, B=0x024D=589)
#   "Wikipedia" → 0x11E60398   (RFC 1950 example)
#
# Fletcher-32:
#   ""          → 0x00000000   (initial sum1=0, sum2=0)
#   "abcd"      → 0x2926C6C4   (two LE u16 words: 0x6261, 0x6463)
#   "abc"       → 0xC52562C4   (odd length: padded to 0x6261, 0x0063)
#
# Reference: RFC 1950, Fletcher (1982)
# ============================================================================

use std.spipe.*
use os.crypto.adler32.{adler32, adler32_update, fletcher32, fletcher32_update}

# ============================================================================
# Test data helpers — module-level to avoid it-block var-mutation footgun
# (see .claude/memory/feedback_it_block_var_mutation.md)
# ============================================================================

fn _empty() -> [u8]:
    var out: [u8] = []
    out

fn _abc() -> [u8]:
    # ASCII "abc" = 0x61 0x62 0x63
    var out: [u8] = []
    out.push(0x61)
    out.push(0x62)
    out.push(0x63)
    out

fn _wikipedia() -> [u8]:
    # ASCII "Wikipedia" = 57 69 6b 69 70 65 64 69 61
    var out: [u8] = []
    out.push(0x57)
    out.push(0x69)
    out.push(0x6b)
    out.push(0x69)
    out.push(0x70)
    out.push(0x65)
    out.push(0x64)
    out.push(0x69)
    out.push(0x61)
    out

fn _abcd() -> [u8]:
    # ASCII "abcd" = 0x61 0x62 0x63 0x64
    var out: [u8] = []
    out.push(0x61)
    out.push(0x62)
    out.push(0x63)
    out.push(0x64)
    out

fn _abc_first() -> [u8]:
    # First byte of "abc" for streaming split: "a"
    var out: [u8] = []
    out.push(0x61)
    out

fn _abc_rest() -> [u8]:
    # Remaining bytes of "abc" for streaming split: "bc"
    var out: [u8] = []
    out.push(0x62)
    out.push(0x63)
    out

fn _abcd_first() -> [u8]:
    # First two bytes of "abcd" for even streaming split: "ab"
    var out: [u8] = []
    out.push(0x61)
    out.push(0x62)
    out

fn _abcd_rest() -> [u8]:
    # Remaining bytes of "abcd" for even streaming split: "cd"
    var out: [u8] = []
    out.push(0x63)
    out.push(0x64)
    out

# ============================================================================
# Adler-32 one-shot KATs
# ============================================================================

describe "Adler-32 one-shot KATs":

    it "empty input -> 0x00000001 (A=1, B=0)":
        expect(adler32(_empty())).to_equal(0x00000001)

    it "\"abc\" -> 0x024D0127":
        expect(adler32(_abc())).to_equal(0x024D0127)

    it "\"Wikipedia\" -> 0x11E60398 (RFC 1950 example)":
        expect(adler32(_wikipedia())).to_equal(0x11E60398)

# ============================================================================
# Adler-32 streaming (incremental update) API
# ============================================================================

describe "Adler-32 streaming API":

    it "update with empty data is identity":
        val s0 = 1
        val s1 = adler32_update(s0, _empty())
        expect(s1).to_equal(1)

    it "split \"abc\" gives same result as one-shot":
        val s0 = 1
        val s1 = adler32_update(s0, _abc_first())
        val s2 = adler32_update(s1, _abc_rest())
        expect(s2).to_equal(adler32(_abc()))

    it "full \"abc\" in one update matches one-shot":
        val s0 = 1
        val s1 = adler32_update(s0, _abc())
        expect(s1).to_equal(0x024D0127)

# ============================================================================
# Fletcher-32 one-shot KATs
# ============================================================================

describe "Fletcher-32 one-shot KATs":

    it "empty input -> 0":
        expect(fletcher32(_empty())).to_equal(0)

    it "\"abcd\" -> 0x2926C6C4":
        expect(fletcher32(_abcd())).to_equal(0x2926C6C4)

    it "\"abc\" (odd length, padded) -> 0xC52562C4":
        expect(fletcher32(_abc())).to_equal(0xC52562C4)

# ============================================================================
# Fletcher-32 streaming (incremental update) API
# ============================================================================

describe "Fletcher-32 streaming API":

    it "update with empty data is identity":
        val r = fletcher32_update(0, 0, _empty())
        expect(r[0]).to_equal(0)
        expect(r[1]).to_equal(0)

    it "split \"abcd\" on even boundary gives same result as one-shot":
        val r1 = fletcher32_update(0, 0, _abcd_first())
        val r2 = fletcher32_update(r1[0], r1[1], _abcd_rest())
        val expected = fletcher32(_abcd())
        expect((r2[1] << 16) | r2[0]).to_equal(expected)

    it "full \"abcd\" in one update matches one-shot":
        val r = fletcher32_update(0, 0, _abcd())
        expect((r[1] << 16) | r[0]).to_equal(0x2926C6C4)
