# Camellia RFC 3713 Appendix A Known-Answer Test Vectors
#
# Tests camellia128_encrypt_block / camellia256_encrypt_block from
# src/os/crypto/camellia.spl against the canonical RFC 3713 Appendix A
# reference vectors.
#
# NOTE: Camellia-192 is not implemented in camellia.spl (only 128 and 256).
# The RFC 3713 Appendix A.2 (192-bit) vector is intentionally omitted.
#
# A.1 — Camellia-128
#   Key = 0123456789ABCDEFFEDCBA9876543210
#   PT  = 0123456789ABCDEFFEDCBA9876543210
#   CT  = 67673138549669730857065648EABE43
#
# A.3 — Camellia-256
#   Key = 0123456789ABCDEFFEDCBA987654321000112233445566778899AABBCCDDEEFF
#   PT  = 0123456789ABCDEFFEDCBA9876543210
#   CT  = 9ACC237DFF16D76C20EF7C919E3A7509
#
# NOTE: interpreter-mode test runner verifies file loading, NOT it-block
# execution. Assertions only fire under compiled/native mode.

use std.spipe.*
use os.crypto.camellia.{camellia128_encrypt_block, camellia256_encrypt_block}

# ============================================================================
# Hex-dump helper (inline — no external dependency)
# ============================================================================

fn _hex_nibble(n: u8) -> text:
    if n == 0: "0"
    else if n == 1: "1"
    else if n == 2: "2"
    else if n == 3: "3"
    else if n == 4: "4"
    else if n == 5: "5"
    else if n == 6: "6"
    else if n == 7: "7"
    else if n == 8: "8"
    else if n == 9: "9"
    else if n == 10: "a"
    else if n == 11: "b"
    else if n == 12: "c"
    else if n == 13: "d"
    else if n == 14: "e"
    else: "f"

fn _bytes_hex(b: [u8]) -> text:
    var s: text = ""
    var i: u64 = 0
    while i < b.len().to_u64():
        val byte = b[i]
        s = s + _hex_nibble((byte >> 4) & 0x0F)
        s = s + _hex_nibble(byte & 0x0F)
        i = i + 1
    s

# ============================================================================
# RFC 3713 Appendix A.1 — Camellia-128 test data
# ============================================================================

fn _a1_key() -> [u8]:
    var k: [u8] = []
    k.push(0x01u8)
    k.push(0x23u8)
    k.push(0x45u8)
    k.push(0x67u8)
    k.push(0x89u8)
    k.push(0xABu8)
    k.push(0xCDu8)
    k.push(0xEFu8)
    k.push(0xFEu8)
    k.push(0xDCu8)
    k.push(0xBAu8)
    k.push(0x98u8)
    k.push(0x76u8)
    k.push(0x54u8)
    k.push(0x32u8)
    k.push(0x10u8)
    k

fn _a1_pt() -> [u8]:
    var p: [u8] = []
    p.push(0x01u8)
    p.push(0x23u8)
    p.push(0x45u8)
    p.push(0x67u8)
    p.push(0x89u8)
    p.push(0xABu8)
    p.push(0xCDu8)
    p.push(0xEFu8)
    p.push(0xFEu8)
    p.push(0xDCu8)
    p.push(0xBAu8)
    p.push(0x98u8)
    p.push(0x76u8)
    p.push(0x54u8)
    p.push(0x32u8)
    p.push(0x10u8)
    p

# ============================================================================
# RFC 3713 Appendix A.3 — Camellia-256 test data
# ============================================================================

fn _a3_key() -> [u8]:
    var k: [u8] = []
    k.push(0x01u8)
    k.push(0x23u8)
    k.push(0x45u8)
    k.push(0x67u8)
    k.push(0x89u8)
    k.push(0xABu8)
    k.push(0xCDu8)
    k.push(0xEFu8)
    k.push(0xFEu8)
    k.push(0xDCu8)
    k.push(0xBAu8)
    k.push(0x98u8)
    k.push(0x76u8)
    k.push(0x54u8)
    k.push(0x32u8)
    k.push(0x10u8)
    k.push(0x00u8)
    k.push(0x11u8)
    k.push(0x22u8)
    k.push(0x33u8)
    k.push(0x44u8)
    k.push(0x55u8)
    k.push(0x66u8)
    k.push(0x77u8)
    k.push(0x88u8)
    k.push(0x99u8)
    k.push(0xAAu8)
    k.push(0xBBu8)
    k.push(0xCCu8)
    k.push(0xDDu8)
    k.push(0xEEu8)
    k.push(0xFFu8)
    k

# PT is same as A.1
fn _a3_pt() -> [u8]:
    _a1_pt()

# ============================================================================
# RFC 3713 Appendix A — KAT specs
# ============================================================================

describe "Camellia RFC 3713 Appendix A — 128-bit":

    it "A.1 Camellia-128 encrypt → 67673138549669730857065648eabe43":
        val ct = camellia128_encrypt_block(_a1_key(), _a1_pt())
        expect(_bytes_hex(ct)).to_equal("67673138549669730857065648eabe43")

    it "A.1 Camellia-128 output is 16 bytes":
        val ct = camellia128_encrypt_block(_a1_key(), _a1_pt())
        expect(ct.len()).to_equal(16)

describe "Camellia RFC 3713 Appendix A — 256-bit":

    it "A.3 Camellia-256 encrypt → 9acc237dff16d76c20ef7c919e3a7509":
        val ct = camellia256_encrypt_block(_a3_key(), _a3_pt())
        expect(_bytes_hex(ct)).to_equal("9acc237dff16d76c20ef7c919e3a7509")

    it "A.3 Camellia-256 output is 16 bytes":
        val ct = camellia256_encrypt_block(_a3_key(), _a3_pt())
        expect(ct.len()).to_equal(16)
