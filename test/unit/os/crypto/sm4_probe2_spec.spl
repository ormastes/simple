use std.spec.*
use os.crypto.sm4.*

describe "SM4 probe2 cross-module":
    it "cross-module param push [u32]":
        var fk: [u32] = []
        _sm4_fill_fk(fk)
        expect(fk.len()).to_equal(4)
    it "cross-module return sbox [u8]":
        val s = _sm4_sbox()
        expect(s.len()).to_equal(256)
    it "cross-module local push then return":
        val rk = sm4_key_expand([0x01u8, 0x23u8, 0x45u8, 0x67u8, 0x89u8, 0xABu8, 0xCDu8, 0xEFu8, 0xFEu8, 0xDCu8, 0xBAu8, 0x98u8, 0x76u8, 0x54u8, 0x32u8, 0x10u8])
        expect(rk.len()).to_equal(32)
