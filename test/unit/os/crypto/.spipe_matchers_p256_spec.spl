use std.spipe.*
use os.crypto.p256.{
    p256_ecdsa_sign, p256_ecdsa_verify,
    p256_keygen, p256_ecdh,
    p256_point_on_curve, p256_add, p256_mul
}
use os.crypto.sha256.{sha256}

fn _rfc6979_privkey() -> [u8]:
    var k: [u8] = []
    k.push(0xC9)
    k.push(0xAF)
    k.push(0xA9)
    k.push(0xD8)
    k.push(0x45)
    k.push(0xBA)
    k.push(0x75)
    k.push(0x16)
    k.push(0x6B)
    k.push(0x5C)
    k.push(0x21)
    k.push(0x57)
    k.push(0x67)
    k.push(0xB1)
    k.push(0xD6)
    k.push(0x93)
    k.push(0x4E)
    k.push(0x50)
    k.push(0xC3)
    k.push(0xDB)
    k.push(0x36)
    k.push(0xE8)
    k.push(0x9B)
    k.push(0x12)
    k.push(0x7B)
    k.push(0x8A)
    k.push(0x62)
    k.push(0x2B)
    k.push(0x12)
    k.push(0x0F)
    k.push(0x67)
    k.push(0x21)
    k

fn _sample_msg() -> [u8]:
    var m: [u8] = []
    m.push(0x73)
    m.push(0x61)
    m.push(0x6D)
    m.push(0x70)
    m.push(0x6C)
    m.push(0x65)
    m

describe "P-256 ECDSA/ECDH":

    it "keygen produces 65-byte uncompressed pubkey":
        val sk = _rfc6979_privkey()
        val pub_key = p256_keygen(sk)
        expect pub_key.len() == 65
        expect pub_key[0u64] == 0x04u8

    it "ECDSA sign produces 64-byte signature":
        val sk = _rfc6979_privkey()
        val msg = _sample_msg()
        val msg_hash = sha256(msg)
        val sig = p256_ecdsa_sign(sk, msg_hash)
        expect sig.len() == 64