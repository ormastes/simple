    k.push(0x0B)
    k.push(0x0C)
    k.push(0x0D)
    k.push(0x0E)
    k.push(0x0F)
    k.push(0x10)
    k.push(0x11)
    k.push(0x12)
    k.push(0x13)
    k.push(0x14)
    k.push(0x15)
    k.push(0x16)
    k.push(0x17)
    k.push(0x18)
    k.push(0x19)
    k.push(0x1A)
    k.push(0x1B)
    k.push(0x1C)
    k.push(0x1D)
    k.push(0x1E)
    k.push(0x1F)
    k.push(0x20)
    k

fn _be32_val(last_byte: u8) -> [u8]:
    var b: [u8] = []
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(last_byte)
    b

describe "P-256 ECDSA/ECDH — RFC 6979 known-answer tests":

    it "keygen produces 65-byte uncompressed pubkey":
        val sk = _rfc6979_privkey()
        val pk = p256_keygen(sk)
        expect pk.len() == 65
        expect pk[0u64] == 0x04u8

    it "generated pubkey is on curve":
        val sk = _rfc6979_privkey()
        val pk = p256_keygen(sk)
        val px = _get_pubkey_x(pk)
        val py = _get_pubkey_y(pk)
        expect p256_point_on_curve(px, py) == true

    it "ECDSA sign produces 64-byte signature":
        val sk = _rfc6979_privkey()
        val msg = _sample_msg()
        val msg_hash = sha256(msg)
        val sig = p256_ecdsa_sign(sk, msg_hash)
        expect sig.len() == 64

    it "ECDSA sign matches RFC 6979 A.2.5 r value":
        val sk = _rfc6979_privkey()
        val msg = _sample_msg()
        val msg_hash = sha256(msg)
        val sig = p256_ecdsa_sign(sk, msg_hash)
        val r_bytes = _extract_first_32(sig)
        expect(_bytes_hex(r_bytes)).to_equal(
            "efd48b2aacb6a8fd1140dd9cd45e81d69d2c877b56aaf991c34d0ea84eaf3716"
        )

    it "ECDSA sign matches RFC 6979 A.2.5 s value":
        val sk = _rfc6979_privkey()
        val msg = _sample_msg()
        val msg_hash = sha256(msg)
        val sig = p256_ecdsa_sign(sk, msg_hash)
        val s_bytes = _extract_last_32(sig)
        expect(_bytes_hex(s_bytes)).to_equal(
            "f7cb1c942d657c41d436c7a1b6e29f65f3e900dbb9aff4064dc4ab2f843acda8"
        )

    it "ECDSA verify accepts valid RFC 6979 signature":
        val sk = _rfc6979_privkey()
        val pk = p256_keygen(sk)
        val msg = _sample_msg()
        val msg_hash = sha256(msg)
        val sig = p256_ecdsa_sign(sk, msg_hash)
        expect p256_ecdsa_verify(pk, msg_hash, sig) == true

    it "ECDSA verify rejects corrupted signature":
        val sk = _rfc6979_privkey()
        val pk = p256_keygen(sk)
        val msg = _sample_msg()
        val msg_hash = sha256(msg)
        val sig = p256_ecdsa_sign(sk, msg_hash)
        val bad_sig = _flip_sig(sig)
        expect p256_ecdsa_verify(pk, msg_hash, bad_sig) == false

    it "ECDSA verify rejects wrong message":
        val sk = _rfc6979_privkey()
        val pk = p256_keygen(sk)
        val msg = _sample_msg()
        val msg_hash = sha256(msg)
        val sig = p256_ecdsa_sign(sk, msg_hash)
        val other = _msg_test()
        val wrong_hash = sha256(other)
        expect p256_ecdsa_verify(pk, wrong_hash, sig) == false

    it "ECDH shared secret is 32 bytes":
        val sk = _rfc6979_privkey()
        val pk = p256_keygen(sk)
        val shared = p256_ecdh(sk, pk)
        expect shared.len() == 32

    it "ECDH is commutative":
        val alice_sk = _rfc6979_privkey()
        val bob = _bob_sk()
        val alice_pub = p256_keygen(alice_sk)
        val bob_pub = p256_keygen(bob)
        val shared_ab = p256_ecdh(alice_sk, bob_pub)
        val shared_ba = p256_ecdh(bob, alice_pub)
        expect _bytes_hex(shared_ab) == _bytes_hex(shared_ba)

    it "p256_add(1, 1) mod p == 2":
        val one = _be32_val(0x01u8)
        val two_bytes = p256_add(one, one)
        val expected = _be32_val(0x02u8)
        expect _bytes_hex(two_bytes) == _bytes_hex(expected)

    it "p256_mul(2, 3) mod p == 6":
        val two = _be32_val(0x02u8)
        val three = _be32_val(0x03u8)
        val six_bytes = p256_mul(two, three)
        val expected = _be32_val(0x06u8)
        expect _bytes_hex(six_bytes) == _bytes_hex(expected)