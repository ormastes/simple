fn _flip_sig(sig_data: [u8]) -> [u8]:
    var r: [u8] = []
    var xored: u8 = sig_data[0u64] ^ 0x01u8
    r.push(xored)
    var i: u64 = 1
    while i < 64:
        r.push(sig_data[i])
        i = i + 1
    r

fn _msg_test() -> [u8]:
    var m: [u8] = []
    m.push(0x74)
    m.push(0x65)
    m.push(0x73)
    m.push(0x74)
    m

