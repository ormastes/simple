use std.spipe.*
use os.crypto.p256.{
    p256_ecdsa_sign, p256_ecdsa_verify,
    p256_keygen, p256_ecdh,
    p256_point_on_curve, p256_add, p256_mul
}
use os.crypto.sha256.{sha256}

fn _hex_nibble(n: u8) -> text:
    if n == 0: "0"
    else if n == 1: "1"
    else if n == 2: "2"
    else if n == 3: "3"
    else if n == 4: "4"
    else if n == 5: "5"
    else if n == 6: "6"
    else if n == 7: "7"
    else if n == 8: "8"
    else if n == 9: "9"
    else if n == 10: "a"
    else if n == 11: "b"
    else if n == 12: "c"
    else if n == 13: "d"
    else if n == 14: "e"
    else: "f"

fn _bytes_hex(b: [u8]) -> text:
    var s: text = ""
    var i: u64 = 0
    val blen = b.len().to_u64()
    while i < blen:
        val byte = b[i]
        s = s + _hex_nibble((byte >> 4) & 0x0F)
        s = s + _hex_nibble(byte & 0x0F)
        i = i + 1
    s

describe "P-256 minimal parse test":
    it "p256_add(1, 1) mod p == 2":
        var one: [u8] = []
        var i: u64 = 0
        while i < 31:
            one.push(0x00)
            i = i + 1
        one.push(0x01)
        val two_bytes = p256_add(one, one)
        var expected: [u8] = []
        i = 0
        while i < 31:
            expected.push(0x00)
            i = i + 1
        expected.push(0x02)
        expect _bytes_hex(two_bytes) == _bytes_hex(expected)