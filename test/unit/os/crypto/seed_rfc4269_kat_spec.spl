# SEED RFC 4269 Appendix B Known-Answer Test Vectors
#
# Tests seed_encrypt_block / seed_decrypt_block from src/os/crypto/seed.spl
# against the four canonical RFC 4269 Appendix B reference vectors.
#
# B.1: Key=0x00..00,          PT=0x000102..0F  → CT=5EBAC6E0054E166819AFF1CC6D346CDB
# B.2: Key=0x000102..0F,      PT=0x00..00      → CT=C11F22F20140505084483597E4370F43
# B.3: Key=0x47064808...,     PT=0x83A2F8A2... → CT=EE54D13EBCAE706D226BC3142CD40D4A
# B.4: Key=0x28DBC3BC...,     PT=0xB41E6BE2... → CT=9B9B7BFCD1813CB95D0B3618F40F5122
#
# Reference: RFC 4269 §Appendix B
# https://www.rfc-editor.org/rfc/rfc4269#appendix-B

use std.spec.*
use os.crypto.seed.{seed_encrypt_block, seed_decrypt_block}

# ============================================================================
# Hex-dump helper
# ============================================================================

fn _hex_nibble(n: u8) -> text:
    if n == 0: "0"
    else if n == 1: "1"
    else if n == 2: "2"
    else if n == 3: "3"
    else if n == 4: "4"
    else if n == 5: "5"
    else if n == 6: "6"
    else if n == 7: "7"
    else if n == 8: "8"
    else if n == 9: "9"
    else if n == 10: "a"
    else if n == 11: "b"
    else if n == 12: "c"
    else if n == 13: "d"
    else if n == 14: "e"
    else: "f"

fn _bytes_hex(b: [u8]) -> text:
    var s: text = ""
    var i: i64 = 0
    while i < b.len():
        val byte = b[i]
        s = s + _hex_nibble((byte >> 4) & 0x0F)
        s = s + _hex_nibble(byte & 0x0F)
        i = i + 1
    s

# ============================================================================
# B.1 test data — Key=zeros, PT=0x000102..0F
# ============================================================================

fn _b1_key() -> [u8]:
    var k: [u8] = []
    k.push(0x00u8)
    k.push(0x00u8)
    k.push(0x00u8)
    k.push(0x00u8)
    k.push(0x00u8)
    k.push(0x00u8)
    k.push(0x00u8)
    k.push(0x00u8)
    k.push(0x00u8)
    k.push(0x00u8)
    k.push(0x00u8)
    k.push(0x00u8)
    k.push(0x00u8)
    k.push(0x00u8)
    k.push(0x00u8)
    k.push(0x00u8)
    k

fn _b1_pt() -> [u8]:
    var p: [u8] = []
    p.push(0x00u8)
    p.push(0x01u8)
    p.push(0x02u8)
    p.push(0x03u8)
    p.push(0x04u8)
    p.push(0x05u8)
    p.push(0x06u8)
    p.push(0x07u8)
    p.push(0x08u8)
    p.push(0x09u8)
    p.push(0x0Au8)
    p.push(0x0Bu8)
    p.push(0x0Cu8)
    p.push(0x0Du8)
    p.push(0x0Eu8)
    p.push(0x0Fu8)
    p

# ============================================================================
# B.2 test data — Key=0x000102..0F, PT=zeros
