    k.push(0x08u8)
    k.push(0x09u8)
    k.push(0x0Au8)
    k.push(0x0Bu8)
    k.push(0x0Cu8)
    k.push(0x0Du8)
    k.push(0x0Eu8)
    k.push(0x0Fu8)
    k

fn _b2_pt() -> [u8]:
    var p: [u8] = []
    p.push(0x00u8)
    p.push(0x00u8)
    p.push(0x00u8)
    p.push(0x00u8)
    p.push(0x00u8)
    p.push(0x00u8)
    p.push(0x00u8)
    p.push(0x00u8)
    p.push(0x00u8)
    p.push(0x00u8)
    p.push(0x00u8)
    p.push(0x00u8)
    p.push(0x00u8)
    p.push(0x00u8)
    p.push(0x00u8)
    p.push(0x00u8)
    p

# ============================================================================
# B.3 test data — Key=47064808 51E61BE8 5D74BFB3 FD956185
#                  PT=83A2F8A2 88641FB9 A4E9A5CC 2F131C7D
# ============================================================================

fn _b3_key() -> [u8]:
    var k: [u8] = []
    k.push(0x47u8)
    k.push(0x06u8)
    k.push(0x48u8)
    k.push(0x08u8)
    k.push(0x51u8)
    k.push(0xE6u8)
    k.push(0x1Bu8)
    k.push(0xE8u8)
    k.push(0x5Du8)
    k.push(0x74u8)
    k.push(0xBFu8)
    k.push(0xB3u8)
    k.push(0xFDu8)
    k.push(0x95u8)
    k.push(0x61u8)
    k.push(0x85u8)
    k

fn _b3_pt() -> [u8]:
    var p: [u8] = []
    p.push(0x83u8)
    p.push(0xA2u8)
    p.push(0xF8u8)
    p.push(0xA2u8)
    p.push(0x88u8)
    p.push(0x64u8)
    p.push(0x1Fu8)
    p.push(0xB9u8)
    p.push(0xA4u8)
    p.push(0xE9u8)
    p.push(0xA5u8)
    p.push(0xCCu8)
    p.push(0x2Fu8)
    p.push(0x13u8)
    p.push(0x1Cu8)
    p.push(0x7Du8)
    p

# ============================================================================
# B.4 test data — Key=28DBC3BC 49FFD87D CFA509B1 1D422BE7
#                  PT=B41E6BE2 EBA84A14 8E2EED84 593C5EC7
# ============================================================================

fn _b4_key() -> [u8]:
    var k: [u8] = []
    k.push(0x28u8)
    k.push(0xDBu8)
    k.push(0xC3u8)
    k.push(0xBCu8)
    k.push(0x49u8)
    k.push(0xFFu8)
    k.push(0xD8u8)
    k.push(0x7Du8)
    k.push(0xCFu8)
    k.push(0xA5u8)
    k.push(0x09u8)
    k.push(0xB1u8)
    k.push(0x1Du8)
    k.push(0x42u8)
    k.push(0x2Bu8)
    k.push(0xE7u8)
    k

fn _b4_pt() -> [u8]:
    var p: [u8] = []
    p.push(0xB4u8)
    p.push(0x1Eu8)
    p.push(0x6Bu8)
    p.push(0xE2u8)
    p.push(0xEBu8)
    p.push(0xA8u8)
    p.push(0x4Au8)
    p.push(0x14u8)
    p.push(0x8Eu8)
    p.push(0x2Eu8)
    p.push(0xEDu8)
    p.push(0x84u8)
    p.push(0x59u8)
    p.push(0x3Cu8)
    p.push(0x5Eu8)
    p.push(0xC7u8)
    p

# ============================================================================
# RFC 4269 Appendix B — KAT specs
# ============================================================================

describe "SEED RFC 4269 §B.1 (key=zeros, pt=0..F)":

    it "encrypt → 5ebac6e0054e166819aff1cc6d346cdb":
        val ct = seed_encrypt_block(_b1_key(), _b1_pt())
        expect(_bytes_hex(ct)).to_equal("5ebac6e0054e166819aff1cc6d346cdb")

    it "output is 16 bytes":
        val ct = seed_encrypt_block(_b1_key(), _b1_pt())
        expect(ct.len()).to_equal(16)

    it "decrypt round-trip recovers plaintext":
        val ct = seed_encrypt_block(_b1_key(), _b1_pt())
        val pt2 = seed_decrypt_block(_b1_key(), ct)
        expect(_bytes_hex(pt2)).to_equal(_bytes_hex(_b1_pt()))

describe "SEED RFC 4269 §B.2 (key=0..F, pt=zeros)":

    it "encrypt → c11f22f20140505084483597e4370f43":
        val ct = seed_encrypt_block(_b2_key(), _b2_pt())
        expect(_bytes_hex(ct)).to_equal("c11f22f20140505084483597e4370f43")

    it "output is 16 bytes":
        val ct = seed_encrypt_block(_b2_key(), _b2_pt())
        expect(ct.len()).to_equal(16)

    it "decrypt round-trip recovers plaintext":
        val ct = seed_encrypt_block(_b2_key(), _b2_pt())
        val pt2 = seed_decrypt_block(_b2_key(), ct)
        expect(_bytes_hex(pt2)).to_equal(_bytes_hex(_b2_pt()))

describe "SEED RFC 4269 §B.3 (key=4706..85, pt=83A2..7D)":

    it "encrypt → ee54d13ebcae706d226bc3142cd40d4a":
        val ct = seed_encrypt_block(_b3_key(), _b3_pt())
        expect(_bytes_hex(ct)).to_equal("ee54d13ebcae706d226bc3142cd40d4a")

    it "output is 16 bytes":
        val ct = seed_encrypt_block(_b3_key(), _b3_pt())
        expect(ct.len()).to_equal(16)

    it "decrypt round-trip recovers plaintext":
        val ct = seed_encrypt_block(_b3_key(), _b3_pt())
        val pt2 = seed_decrypt_block(_b3_key(), ct)
        expect(_bytes_hex(pt2)).to_equal(_bytes_hex(_b3_pt()))

describe "SEED RFC 4269 §B.4 (key=28DB..E7, pt=B41E..C7)":

    it "encrypt → 9b9b7bfcd1813cb95d0b3618f40f5122":
        val ct = seed_encrypt_block(_b4_key(), _b4_pt())
        expect(_bytes_hex(ct)).to_equal("9b9b7bfcd1813cb95d0b3618f40f5122")

    it "output is 16 bytes":
        val ct = seed_encrypt_block(_b4_key(), _b4_pt())
        expect(ct.len()).to_equal(16)

    it "decrypt round-trip recovers plaintext":
        val ct = seed_encrypt_block(_b4_key(), _b4_pt())
        val pt2 = seed_decrypt_block(_b4_key(), ct)
        expect(_bytes_hex(pt2)).to_equal(_bytes_hex(_b4_pt()))
