# ARIA RFC 5794 §B Known-Answer Test Vectors
#
# Tests aria_encrypt_block / aria_decrypt_block from
# src/os/crypto/aria.spl against the canonical RFC 5794 Appendix B
# reference vectors.
#
# ARIA-128 (§B.1):
#   Key = 00112233445566778899aabbccddeeff
#   PT  = 11111111aaaaaaaa11111111bbbbbbbb
#   CT  = c6ecd08e22c30abdb215cf74e2075e6e
#
# ARIA-256 (§B.3):
#   Key = 00112233445566778899aabbccddeeff00112233445566778899aabbccddeeff
#   PT  = 11111111aaaaaaaa11111111bbbbbbbb
#   CT  = 58a875e6044ad7fffa4f58420f7f442d
#
# NOTE (interpreter mode): aria.spl builds output arrays via push() in helper
# functions that do NOT mutate caller-visible state under the Simple interpreter.
# The assertions below will FAIL under interpreter mode and PASS only under
# compiled/native mode (bin/simple build, --mode=native).
# This is a known interpreter limitation, not a spec or algorithm bug.
#
# Source: RFC 5794 — A Description of the ARIA Encryption Algorithm
#   https://datatracker.ietf.org/doc/html/rfc5794#appendix-B

use std.spec.*
use os.crypto.aria.{aria_encrypt_block, aria_decrypt_block}

# ============================================================================
# Hex-dump helper (inline — no external dependency)
# ============================================================================

fn _hex_nibble(n: u8) -> text:
    if n == 0: "0"
    else if n == 1: "1"
    else if n == 2: "2"
    else if n == 3: "3"
    else if n == 4: "4"
    else if n == 5: "5"
    else if n == 6: "6"
    else if n == 7: "7"
    else if n == 8: "8"
    else if n == 9: "9"
    else if n == 10: "a"
    else if n == 11: "b"
    else if n == 12: "c"
    else if n == 13: "d"
    else if n == 14: "e"
    else: "f"

fn _bytes_hex(b: [u8]) -> text:
    var s: text = ""
    var i: i64 = 0
    while i < b.len():
        val byte = b[i]
        s = s + _hex_nibble((byte >> 4) & 0x0F)
        s = s + _hex_nibble(byte & 0x0F)
        i = i + 1
    s

# ============================================================================
# ARIA-128 test data (RFC 5794 §B.1)
# ============================================================================

fn _b1_key() -> [u8]:
    var k: [u8] = []
    k.push(0x00)
    k.push(0x11)
    k.push(0x22)
    k.push(0x33)
    k.push(0x44)
    k.push(0x55)
    k.push(0x66)
    k.push(0x77)
    k.push(0x88)
    k.push(0x99)
    k.push(0xaa)
    k.push(0xbb)
    k.push(0xcc)
    k.push(0xdd)
    k.push(0xee)
    k.push(0xff)
    k

fn _b1_pt() -> [u8]:
    var p: [u8] = []
    p.push(0x11)
    p.push(0x11)
    p.push(0x11)
    p.push(0x11)
    p.push(0xaa)
    p.push(0xaa)
    p.push(0xaa)
    p.push(0xaa)
    p.push(0x11)
    p.push(0x11)
    p.push(0x11)
    p.push(0x11)
    p.push(0xbb)
    p.push(0xbb)
    p.push(0xbb)
    p.push(0xbb)
    p

fn _b1_ct() -> [u8]:
    var c: [u8] = []
    c.push(0xc6)
    c.push(0xec)
    c.push(0xd0)
    c.push(0x8e)
    c.push(0x22)
    c.push(0xc3)
    c.push(0x0a)
    c.push(0xbd)
    c.push(0xb2)
    c.push(0x15)
    c.push(0xcf)
    c.push(0x74)
    c.push(0xe2)
    c.push(0x07)
    c.push(0x5e)
    c.push(0x6e)
    c

# ============================================================================
# ARIA-256 test data (RFC 5794 §B.3)
# ============================================================================

fn _b3_key() -> [u8]:
    var k: [u8] = []
    k.push(0x00)
    k.push(0x11)
    k.push(0x22)
    k.push(0x33)
    k.push(0x44)
    k.push(0x55)
    k.push(0x66)
    k.push(0x77)
    k.push(0x88)
    k.push(0x99)
    k.push(0xaa)
    k.push(0xbb)
    k.push(0xcc)
    k.push(0xdd)
    k.push(0xee)
    k.push(0xff)
    k.push(0x00)
    k.push(0x11)
    k.push(0x22)
    k.push(0x33)
    k.push(0x44)
    k.push(0x55)
    k.push(0x66)
    k.push(0x77)
    k.push(0x88)
    k.push(0x99)
    k.push(0xaa)
    k.push(0xbb)
    k.push(0xcc)
    k.push(0xdd)
    k.push(0xee)
    k.push(0xff)
    k

fn _b3_ct() -> [u8]:
    var c: [u8] = []
    c.push(0x58)
    c.push(0xa8)
    c.push(0x75)
    c.push(0xe6)
    c.push(0x04)
    c.push(0x4a)
    c.push(0xd7)
    c.push(0xff)
    c.push(0xfa)
    c.push(0x4f)
    c.push(0x58)
    c.push(0x42)
    c.push(0x0f)
    c.push(0x7f)
    c.push(0x44)
    c.push(0x2d)
    c

# ============================================================================
# RFC 5794 §B — KAT specs
#
# These tests PASS under compiled/native mode.
# Under interpreter mode they will report failure due to the known
# array-mutation-via-function-parameter limitation.
# ============================================================================

describe "ARIA RFC 5794 §B.1 — ARIA-128":

    it "encrypt → c6ecd08e22c30abdb215cf74e2075e6e":
        val ct = aria_encrypt_block(_b1_key(), _b1_pt())
        expect(_bytes_hex(ct)).to_equal("c6ecd08e22c30abdb215cf74e2075e6e")

    it "output is 16 bytes":
        val ct = aria_encrypt_block(_b1_key(), _b1_pt())
        expect(ct.len()).to_equal(16)

    it "decrypt round-trips to plaintext":
        val ct = aria_encrypt_block(_b1_key(), _b1_pt())
        val pt = aria_decrypt_block(_b1_key(), ct)
        expect(_bytes_hex(pt)).to_equal(_bytes_hex(_b1_pt()))

    it "decrypt known ciphertext → 11111111aaaaaaaa11111111bbbbbbbb":
        val pt = aria_decrypt_block(_b1_key(), _b1_ct())
        expect(_bytes_hex(pt)).to_equal("11111111aaaaaaaa11111111bbbbbbbb")

describe "ARIA RFC 5794 §B.3 — ARIA-256":

    it "encrypt → 58a875e6044ad7fffa4f58420f7f442d":
        val ct = aria_encrypt_block(_b3_key(), _b1_pt())
        expect(_bytes_hex(ct)).to_equal("58a875e6044ad7fffa4f58420f7f442d")

    it "output is 16 bytes":
        val ct = aria_encrypt_block(_b3_key(), _b1_pt())
        expect(ct.len()).to_equal(16)

    it "decrypt round-trips to plaintext":
        val ct = aria_encrypt_block(_b3_key(), _b1_pt())
        val pt = aria_decrypt_block(_b3_key(), ct)
        expect(_bytes_hex(pt)).to_equal(_bytes_hex(_b1_pt()))

    it "decrypt known ciphertext → 11111111aaaaaaaa11111111bbbbbbbb":
        val pt = aria_decrypt_block(_b3_key(), _b3_ct())
        expect(_bytes_hex(pt)).to_equal("11111111aaaaaaaa11111111bbbbbbbb")
