use std.spec.*

fn ret_literal() -> [u32]:
    [1u32, 2u32, 3u32, 4u32]

fn ret_pushed() -> [u32]:
    var a: [u32] = []
    var v: u32 = 1
    a.push(v)
    v = 2
    a.push(v)
    a

fn fill_param(dest: [u32]):
    var v: u32 = 10
    dest.push(v)
    v = 20
    dest.push(v)

describe "SM4 probe":
    it "literal return":
        val a = ret_literal()
        expect(a.len()).to_equal(4)
    it "local push return":
        val a = ret_pushed()
        expect(a.len()).to_equal(2)
    it "param push same-file":
        var arr: [u32] = []
        fill_param(arr)
        expect(arr.len()).to_equal(2)
