# RC4 (ARC4/ARCFOUR) Stream Cipher — Known-Answer Test Vectors
#
# Tests the pure-Simple RC4 implementation in src/os/crypto/rc4.spl
# against well-known reference vectors.
#
# Vectors:
#   Key="Key"    (3B), pt="Plaintext"      -> BBF316E8D940AF0AD3
#   Key="Wiki"   (4B), pt="pedia"          -> 1021BF0420
#   Key="Secret" (6B), pt="Attack at dawn" -> 45A01F645FC35B383552544B9BF5
#   Key=0x0102030405 (5B), ks[0:16]        -> B2396305F03DC027CCC3524A0A1118A8
#     (RFC 6229 §2 offset-0 vector)
#
# NOTE: verified in interpreter mode per feedback_compile_mode_false_greens.md

use std.spipe.*
use os.crypto.rc4.{rc4_encrypt, rc4_decrypt, rc4_keystream, rc4_init}

# ============================================================================
# Helpers — module-level fns to avoid it-block var-mutation drop bug
# ============================================================================

fn _hex_nibble(n: u8) -> text:
    if n == 0: "0"
    elif n == 1: "1"
    elif n == 2: "2"
    elif n == 3: "3"
    elif n == 4: "4"
    elif n == 5: "5"
    elif n == 6: "6"
    elif n == 7: "7"
    elif n == 8: "8"
    elif n == 9: "9"
    elif n == 10: "A"
    elif n == 11: "B"
    elif n == 12: "C"
    elif n == 13: "D"
    elif n == 14: "E"
    else: "F"

fn _bytes_hex(b: [u8]) -> text:
    var s: text = ""
    var i: i64 = 0
    while i < b.len().to_i64():
        var byte: u8 = b[i.to_u64()]
        s = s + _hex_nibble((byte >> 4) & 0x0F)
        s = s + _hex_nibble(byte & 0x0F)
        i = i + 1
    s

fn _key_key() -> [u8]:
    var k: [u8] = []
    k.push(0x4B)  # K
    k.push(0x65)  # e
    k.push(0x79)  # y
    k

fn _pt_plaintext() -> [u8]:
    var p: [u8] = []
    p.push(0x50)  # P
    p.push(0x6C)  # l
    p.push(0x61)  # a
    p.push(0x69)  # i
    p.push(0x6E)  # n
    p.push(0x74)  # t
    p.push(0x65)  # e
    p.push(0x78)  # x
    p.push(0x74)  # t
    p

fn _key_wiki() -> [u8]:
    var k: [u8] = []
    k.push(0x57)  # W
    k.push(0x69)  # i
    k.push(0x6B)  # k
    k.push(0x69)  # i
    k

fn _pt_pedia() -> [u8]:
    var p: [u8] = []
    p.push(0x70)  # p
    p.push(0x65)  # e
    p.push(0x64)  # d
    p.push(0x69)  # i
    p.push(0x61)  # a
    p

fn _key_secret() -> [u8]:
    var k: [u8] = []
    k.push(0x53)  # S
    k.push(0x65)  # e
    k.push(0x63)  # c
    k.push(0x72)  # r
    k.push(0x65)  # e
    k.push(0x74)  # t
    k

fn _pt_attack_at_dawn() -> [u8]:
    var p: [u8] = []
    p.push(0x41)  # A
    p.push(0x74)  # t
    p.push(0x74)  # t
    p.push(0x61)  # a
    p.push(0x63)  # c
    p.push(0x6B)  # k
    p.push(0x20)  # (space)
    p.push(0x61)  # a
    p.push(0x74)  # t
    p.push(0x20)  # (space)
    p.push(0x64)  # d
    p.push(0x61)  # a
    p.push(0x77)  # w
    p.push(0x6E)  # n
    p

fn _key_rfc6229_5byte() -> [u8]:
    var k: [u8] = []
    k.push(0x01)
    k.push(0x02)
    k.push(0x03)
    k.push(0x04)
    k.push(0x05)
    k

# ============================================================================
# Tests
# ============================================================================

describe "RC4 — known-answer vectors":

    it "Key='Key', pt='Plaintext' -> BBF316E8D940AF0AD3":
        var ct = rc4_encrypt(_key_key(), _pt_plaintext())
        expect _bytes_hex(ct) == "BBF316E8D940AF0AD3"

    it "Key='Wiki', pt='pedia' -> 1021BF0420":
        var ct = rc4_encrypt(_key_wiki(), _pt_pedia())
        expect _bytes_hex(ct) == "1021BF0420"

    it "Key='Secret', pt='Attack at dawn' -> 45A01F645FC35B383552544B9BF5":
        var ct = rc4_encrypt(_key_secret(), _pt_attack_at_dawn())
        expect _bytes_hex(ct) == "45A01F645FC35B383552544B9BF5"

    it "rc4_decrypt is self-inverse of rc4_encrypt":
        var ct = rc4_encrypt(_key_secret(), _pt_attack_at_dawn())
        var pt = rc4_decrypt(_key_secret(), ct)
        expect _bytes_hex(pt) == _bytes_hex(_pt_attack_at_dawn())

    it "RFC 6229: Key=0x0102030405, keystream[0:16] -> B2396305F03DC027CCC3524A0A1118A8":
        var ks = rc4_keystream(_key_rfc6229_5byte(), 16)
        expect _bytes_hex(ks) == "B2396305F03DC027CCC3524A0A1118A8"

    it "rc4_encrypt output length equals input length":
        var ct = rc4_encrypt(_key_key(), _pt_plaintext())
        expect ct.len() == 9

    it "rc4_init returns 256-element S-box":
        var state = rc4_init(_key_key())
        expect state.len() == 256