# SHA-384 NIST FIPS 180-4 Known-Answer Test Vectors
#
# Tests the pure-Simple SHA-384 implementation in src/os/crypto/sha384.spl
# against FIPS 180-4 Appendix D canonical vectors.
#
#   SHA-384("")    -> 38b060a751ac96384cd9327eb1b1e36a21fdb71114be07434c0cc7bf
#                     63f6e1da274edebfe76f65fbd51ad2f14898b95b
#   SHA-384("abc") -> cb00753f45a35e8bb5a03d699ac65007272c32ab0eded1631a8b605a
#                     43ff5bed8086072ba1e7cc2358baeca134c825a7
#
# Source: NIST FIPS 180-4 Appendix D (also reproduced in NIST CSRC examples).
#
# NOTE: per .claude/memory/feedback_compile_mode_false_greens.md this spec is
# verified in interpreter mode. SHA-384 reuses os.crypto.sha512's pure-Simple
# block compression (sha512_process_block + the rt_sha512_K constant table —
# a constants lookup, not the rt_sha512_hash dispatch extern).

use std.spipe.*
use os.crypto.sha384.{sha384, _sha384_pad, _sha384_diag_w0, _sha384_diag_h0, _sha384_diag_rotr1, _sha384_diag_shl63, _sha384_diag_big_sigma0_h0}

# ============================================================================
# Helpers — build inputs in module-level fns so it-block var mutation
# (feedback_it_block_var_mutation.md) doesn't drop list pushes.
# ============================================================================

fn _empty_bytes() -> [u8]:
    var out: [u8] = []
    out

fn _abc_bytes() -> [u8]:
    var out: [u8] = []
    out.push(0x61)
    out.push(0x62)
    out.push(0x63)
    out

fn _hex_nibble(n: u8) -> text:
    if n == 0: "0"
    else if n == 1: "1"
    else if n == 2: "2"
    else if n == 3: "3"
    else if n == 4: "4"
    else if n == 5: "5"
    else if n == 6: "6"
    else if n == 7: "7"
    else if n == 8: "8"
    else if n == 9: "9"
    else if n == 10: "a"
    else if n == 11: "b"
    else if n == 12: "c"
    else if n == 13: "d"
    else if n == 14: "e"
    else: "f"

fn _bytes_hex(b: [u8]) -> text:
    var s: text = ""
    var i: u64 = 0
    while i < b.len().to_u64():
        val byte = b[i]
        s = s + _hex_nibble((byte >> 4) & 0x0F)
        s = s + _hex_nibble(byte & 0x0F)
        i = i + 1
    s

# ============================================================================
# SHA-384 — FIPS 180-4 Appendix D KAT
# ============================================================================

describe "SHA-384 — FIPS 180-4 known-answer vectors":

    it "padding empty: byte[0]=0x80, length=128":
        val padded = _sha384_pad(_empty_bytes())
        expect(padded.len()).to_equal(128)
        expect(padded[0]).to_equal(0x80)
        expect(padded[1]).to_equal(0x00)
        expect(padded[127]).to_equal(0x00)

    it "diag: w[0] for empty input = 0x8000000000000000":
        expect(_sha384_diag_w0(_empty_bytes())).to_equal(0x8000000000000000)

    it "diag: h[0] = 0xcbbb9d5dc1059ed8":
        expect(_sha384_diag_h0()).to_equal(0xCBBB9D5DC1059ED8)

    it "diag: big_sigma0(SHA-384 h[0]) == canonical 0xdb9a810738c045b1":
        # Regression guard for the u64-fn-param right-shift sign-extension bug
        # fixed via _logical_shr64 in sha384.spl. Before fix, this returned
        # 0xfffffffcb6c045b1 because (x >> 28/34/39) on a u64 fn param
        # arg with bit 63 set sign-extended into the high bits. See
        # doc/08_tracking/bug/u64_right_shift_fn_param_arithmetic_2026-05-02.md.
        expect(_sha384_diag_big_sigma0_h0()).to_equal(0xdb9a810738c045b1)

    it "SHA-384(\"\") = 38b060a7...":
        expect(_bytes_hex(sha384(_empty_bytes()))).to_equal(
            "38b060a751ac96384cd9327eb1b1e36a21fdb71114be07434c0cc7bf63f6e1da274edebfe76f65fbd51ad2f14898b95b"
        )

    it "SHA-384(\"abc\") = cb00753f...":
        expect(_bytes_hex(sha384(_abc_bytes()))).to_equal(
            "cb00753f45a35e8bb5a03d699ac65007272c32ab0eded1631a8b605a43ff5bed8086072ba1e7cc2358baeca134c825a7"
        )

    it "SHA-384 output length is 48 bytes":
        expect(sha384(_abc_bytes()).len()).to_equal(48)
