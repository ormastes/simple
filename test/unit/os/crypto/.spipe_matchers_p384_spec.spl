# P-384 ECDSA/ECDH Known-Answer Test

use std.spipe.*
use os.crypto.p384.{
    p384_ecdsa_sign, p384_ecdsa_verify,
    p384_keygen, p384_ecdh,
    p384_point_on_curve, p384_add, p384_mul
}
use os.crypto.sha384.{sha384}

fn _hex_nibble(n: u8) -> text:
    if n == 0: "0"
    elif n == 1: "1"
    elif n == 2: "2"
    elif n == 3: "3"
    elif n == 4: "4"
    elif n == 5: "5"
    elif n == 6: "6"
    elif n == 7: "7"
    elif n == 8: "8"
    elif n == 9: "9"
    elif n == 10: "a"
    elif n == 11: "b"
    elif n == 12: "c"
    elif n == 13: "d"
    elif n == 14: "e"
    else: "f"

fn _bytes_hex(b: [u8]) -> text:
    var s: text = ""
    var i: u64 = 0
    while i < b.len().to_u64():
        val bv = b[i]
        s = s + _hex_nibble((bv >> 4) & 0x0F)
        s = s + _hex_nibble(bv & 0x0F)
        i = i + 1
    s

fn _make_48_byte_key(seed: u8) -> [u8]:
    var k: [u8] = []
    var i: u64 = 0
    while i < 48:
        val v: u8 = ((seed.to_u64() + i * 7 + 3) & 0xFF).to_u8()
        k.push(v)
        i = i + 1
    k

fn _gx_bytes() -> [u8]:
    var b: [u8] = []
    b.push(0xAA)
    b.push(0x87)
    b.push(0xCA)
    b.push(0x22)
    b.push(0xBE)
    b.push(0x8B)
    b.push(0x05)
    b.push(0x37)
    b.push(0x8E)
    b.push(0xB1)
    b.push(0xC7)
    b.push(0x1E)
    b.push(0xF3)
    b.push(0x20)
    b.push(0xAD)
    b.push(0x74)
    b.push(0x6E)
    b.push(0x1D)
    b.push(0x3B)
    b.push(0x62)
    b.push(0x8B)
    b.push(0xA7)
    b.push(0x9B)
    b.push(0x98)
    b.push(0x59)
    b.push(0xF7)
    b.push(0x41)
    b.push(0xE0)
    b.push(0x82)
    b.push(0x54)
    b.push(0x2A)
    b.push(0x38)
    b.push(0x55)
    b.push(0x02)
    b.push(0xF2)
    b.push(0x5D)
    b.push(0xBF)
    b.push(0x55)
    b.push(0x29)
    b.push(0x6C)
    b.push(0x3A)
    b.push(0x54)
    b.push(0x5E)
    b.push(0x38)
    b.push(0x72)
    b.push(0x76)
    b.push(0x0A)
    b.push(0xB7)
    b

fn _gy_bytes() -> [u8]:
    var b: [u8] = []
    b.push(0x36)
    b.push(0x17)
    b.push(0xDE)
    b.push(0x4A)
    b.push(0x96)
    b.push(0x26)
    b.push(0x2C)
    b.push(0x6F)
    b.push(0x5D)
    b.push(0x9E)
    b.push(0x98)
    b.push(0xBF)
    b.push(0x92)
    b.push(0x92)
    b.push(0xDC)
    b.push(0x29)
    b.push(0xF8)
    b.push(0xF4)
    b.push(0x1D)
    b.push(0xBD)
    b.push(0x28)
    b.push(0x9A)
    b.push(0x14)
    b.push(0x7C)
    b.push(0xE9)
    b.push(0xDA)
    b.push(0x31)
    b.push(0x13)
    b.push(0xB5)
    b.push(0xF0)
    b.push(0xB8)
    b.push(0xC0)
    b.push(0x0A)
    b.push(0x60)
    b.push(0xB1)
    b.push(0xCE)
    b.push(0x1D)
    b.push(0x7E)
    b.push(0x81)
    b.push(0x9D)
    b.push(0x7A)
    b.push(0x43)
    b.push(0x1D)
    b.push(0x7C)
    b.push(0x90)
    b.push(0xEA)
    b.push(0x0E)
    b.push(0x5F)
    b

describe "P-384":

    it "p384_add 1 plus 1 mod p equals 2":
        var one: [u8] = []
        var i: u64 = 0
        while i < 47:
            one.push(0x00)
            i = i + 1
        one.push(0x01)
        val two_bytes = p384_add(one, one)
        var expected: [u8] = []
        i = 0
        while i < 47:
            expected.push(0x00)
            i = i + 1
        expected.push(0x02)
        expect _bytes_hex(two_bytes) == _bytes_hex(expected)

    it "p384_mul 2 times 3 mod p equals 6":
        var two: [u8] = []
        var i: u64 = 0
        while i < 47:
            two.push(0x00)
            i = i + 1
        two.push(0x02)
        var three: [u8] = []
        i = 0
        while i < 47:
            three.push(0x00)
            i = i + 1
        three.push(0x03)
        val six_bytes = p384_mul(two, three)
        var expected: [u8] = []
        i = 0
        while i < 47:
            expected.push(0x00)
            i = i + 1
        expected.push(0x06)
        expect _bytes_hex(six_bytes) == _bytes_hex(expected)

    it "Generator G is on the P-384 curve":
        expect p384_point_on_curve(_gx_bytes(), _gy_bytes()) == true

    it "keygen produces 97-byte uncompressed pubkey":
        val sk = _make_48_byte_key(0x6B)
        val pub_key = p384_keygen(sk)
        expect pub_key.len() == 97
        expect pub_key[0u64] == 0x04u8

    it "generated pubkey is on curve":
        val sk = _make_48_byte_key(0x6B)
        val pub_key = p384_keygen(sk)
        var px: [u8] = []
        var py: [u8] = []
        var i: u64 = 0
        while i < 48:
            px.push(pub_key[1 + i])
            i = i + 1
        i = 0
        while i < 48:
            py.push(pub_key[49 + i])
            i = i + 1
        expect p384_point_on_curve(px, py) == true

    it "ECDSA sign produces 96-byte signature":
        val sk = _make_48_byte_key(0x6B)
        val msg_hash = sha384(_make_48_byte_key(0x01))
        val sig = p384_ecdsa_sign(sk, msg_hash)
        expect sig.len() == 96

    it "ECDSA verify accepts valid signature":
        val sk = _make_48_byte_key(0x6B)
        val pub_key = p384_keygen(sk)
        val msg_hash = sha384(_make_48_byte_key(0x01))
        val sig = p384_ecdsa_sign(sk, msg_hash)
        expect p384_ecdsa_verify(pub_key, msg_hash, sig) == true

    it "ECDSA verify rejects corrupted signature":
        val sk = _make_48_byte_key(0x6B)
        val pub_key = p384_keygen(sk)
        val msg_hash = sha384(_make_48_byte_key(0x01))
        val sig = p384_ecdsa_sign(sk, msg_hash)
        sig[0u64] = (sig[0u64] ^ 0x01u8)
        expect p384_ecdsa_verify(pub_key, msg_hash, sig) == false

    it "ECDH shared secret is 48 bytes":
        val sk = _make_48_byte_key(0x6B)
        val pub_key = p384_keygen(sk)
        val shared = p384_ecdh(sk, pub_key)
        expect shared.len() == 48

    it "ECDH is commutative":
        val alice_priv = _make_48_byte_key(0x6B)
        val bob_priv = _make_48_byte_key(0x01)
        val alice_pub = p384_keygen(alice_priv)
        val bob_pub = p384_keygen(bob_priv)
        val shared_ab = p384_ecdh(alice_priv, bob_pub)
        val shared_ba = p384_ecdh(bob_priv, alice_pub)
        expect _bytes_hex(shared_ab) == _bytes_hex(shared_ba)