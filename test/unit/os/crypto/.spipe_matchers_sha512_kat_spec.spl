# SHA-512 NIST FIPS 180-4 Known-Answer Test Vectors
#
# Baselines whether the shared SHA-512-family compression chain in
# `src/os/crypto/sha384.spl` is broken at the compression layer or only at
# SHA-384's IV/truncation usage. Per `doc/08_tracking/bug/sha384_kat_failure_2026-05-02.md`
# step 1, this isolates the bug:
#   - if SHA-512 also fails: bug is in shared compression / sigma / K / pad / unpack chain
#   - if SHA-512 passes: bug is in SHA-384's IV use or 6-of-8 word truncation
#
# `src/os/crypto/sha384.spl` is self-contained (does NOT depend on
# `src/lib/common/crypto/sha512.spl`), so we exercise the same compression
# chain by exposing a `_sha384_sha512_emulate` entry that calls
# `_sha384_process_block` with the SHA-512 IV and emits all 8 of 8 words.
#
#   SHA-512("")    -> cf83e1357eefb8bdf1542850d66d8007d620e4050b5715dc83f4a921d36ce9ce
#                     47d0d13c5d85f2b0ff8318d2877eec2f63b931bd47417a81a538327af927da3e
#   SHA-512("abc") -> ddaf35a193617abacc417349ae20413112e6fa4e89a97ea20a9eeee64b55d39a
#                     2192992a274fc1a836ba3c23a3feebbd454d4423643ce80e2a9ac94fa54ca49f
#
# Source: NIST FIPS 180-4 Appendix D §D.1 / §D.2.

use std.spipe.*
use os.crypto.sha384.{_sha384_sha512_emulate}

fn _empty_bytes() -> [u8]:
    var out: [u8] = []
    out

fn _abc_bytes() -> [u8]:
    var out: [u8] = []
    out.push(0x61)
    out.push(0x62)
    out.push(0x63)
    out

fn _hex_nibble(n: u8) -> text:
    if n == 0: "0"
    else if n == 1: "1"
    else if n == 2: "2"
    else if n == 3: "3"
    else if n == 4: "4"
    else if n == 5: "5"
    else if n == 6: "6"
    else if n == 7: "7"
    else if n == 8: "8"
    else if n == 9: "9"
    else if n == 10: "a"
    else if n == 11: "b"
    else if n == 12: "c"
    else if n == 13: "d"
    else if n == 14: "e"
    else: "f"

fn _bytes_hex(b: [u8]) -> text:
    var s: text = ""
    var i: u64 = 0
    while i < b.len().to_u64():
        val byte = b[i]
        s = s + _hex_nibble((byte >> 4) & 0x0F)
        s = s + _hex_nibble(byte & 0x0F)
        i = i + 1
    s

describe "SHA-512 — FIPS 180-4 known-answer vectors (via sha384.spl compression chain)":

    it "SHA-512(\"\") = cf83e135...":
        expect(_bytes_hex(_sha384_sha512_emulate(_empty_bytes()))).to_equal(
            "cf83e1357eefb8bdf1542850d66d8007d620e4050b5715dc83f4a921d36ce9ce47d0d13c5d85f2b0ff8318d2877eec2f63b931bd47417a81a538327af927da3e"
        )

    it "SHA-512(\"abc\") = ddaf35a1...":
        expect(_bytes_hex(_sha384_sha512_emulate(_abc_bytes()))).to_equal(
            "ddaf35a193617abacc417349ae20413112e6fa4e89a97ea20a9eeee64b55d39a2192992a274fc1a836ba3c23a3feebbd454d4423643ce80e2a9ac94fa54ca49f"
        )

    it "SHA-512 output length is 64 bytes":
        expect _sha384_sha512_emulate(_abc_bytes()).len() == 64