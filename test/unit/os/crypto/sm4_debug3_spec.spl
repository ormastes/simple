use std.spec.*
use os.crypto.sm4.*

describe "SM4 debug3":
    it "sbox call":
        val sbox = _sm4_sbox()
        expect(sbox.len()).to_equal(256)
    it "fill_fk":
        var fk: [u32] = []
        _sm4_fill_fk(fk)
        expect(fk.len()).to_equal(4)
    it "fill_ck":
        var ck: [u32] = []
        _sm4_fill_ck(ck)
        expect(ck.len()).to_equal(32)
