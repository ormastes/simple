# Curve448/X448 — RFC 7748 §5.2 Known-Answer Test Vectors
#
# Tests the pure-Simple X448 implementation in src/os/crypto/curve448.spl
# against the canonical RFC 7748 §5.2 scalar-multiplication KAT vector.
#
# One X448 scalar mult ≈ 447 ladder steps × ~5 field muls × 256 limb ops.
# This is compute-heavy in interpreter mode; if the 60s watchdog triggers,
# file a native-helper feature request and defer per the scrypt-spec pattern.
#
# Reference: RFC 7748 §5.2 (Langley, Hamburg, Turner, January 2016).

use std.spipe.*
use os.crypto.curve448.{x448_scalar_mult, x448_clamp}

# ============================================================================
# Helpers — module-level fns to avoid it-block var mutation drop
# (per .claude/memory/feedback_it_block_var_mutation.md)
# ============================================================================

fn _hex_nibble(n: u8) -> text:
    if n == 0: "0"
    else if n == 1: "1"
    else if n == 2: "2"
    else if n == 3: "3"
    else if n == 4: "4"
    else if n == 5: "5"
    else if n == 6: "6"
    else if n == 7: "7"
    else if n == 8: "8"
    else if n == 9: "9"
    else if n == 10: "a"
    else if n == 11: "b"
    else if n == 12: "c"
    else if n == 13: "d"
    else if n == 14: "e"
    else: "f"

fn _bytes_hex(b: [u8]) -> text:
    var s: text = ""
    var i: u64 = 0
    while i < b.len().to_u64():
        val byte = b[i]
        s = s + _hex_nibble((byte >> 4) & 0x0Fu8)
        s = s + _hex_nibble(byte & 0x0Fu8)
        i = i + 1
    s

fn _first_n_hex(b: [u8], n: u64) -> text:
    var s: text = ""
    var i: u64 = 0
    while i < n:
        val byte = b[i]
        s = s + _hex_nibble((byte >> 4) & 0x0Fu8)
        s = s + _hex_nibble(byte & 0x0Fu8)
        i = i + 1
    s

# RFC 7748 §5.2 X448 KAT — Input scalar (56 bytes, little-endian)
# 203d494428b8399352665ddca42f9de8fef600908e0d461cb021f8c5
# 38345dd77c3e4806e25f46d3315c44e0a5b4371282dd2c8d5be3095f
fn _kat_scalar() -> [u8]:
    var k: [u8] = []
    k.push(0x20u8)
    k.push(0x3du8)
    k.push(0x49u8)
    k.push(0x44u8)
    k.push(0x28u8)
    k.push(0xb8u8)
    k.push(0x39u8)
    k.push(0x93u8)
    k.push(0x52u8)
    k.push(0x66u8)
    k.push(0x5du8)
    k.push(0xdcu8)
    k.push(0xa4u8)
    k.push(0x2fu8)
    k.push(0x9du8)
    k.push(0xe8u8)
    k.push(0xfeu8)
    k.push(0xf6u8)
    k.push(0x00u8)
    k.push(0x90u8)
    k.push(0x8eu8)
    k.push(0x0du8)
    k.push(0x46u8)
    k.push(0x1cu8)
    k.push(0xb0u8)
    k.push(0x21u8)
    k.push(0xf8u8)
    k.push(0xc5u8)
    k.push(0x38u8)
    k.push(0x34u8)
    k.push(0x5du8)
    k.push(0xd7u8)
    k.push(0x7cu8)
    k.push(0x3eu8)
    k.push(0x48u8)
    k.push(0x06u8)
    k.push(0xe2u8)
    k.push(0x5fu8)
    k.push(0x46u8)
    k.push(0xd3u8)
    k.push(0x31u8)
    k.push(0x5cu8)
    k.push(0x44u8)
    k.push(0xe0u8)
    k.push(0xa5u8)
    k.push(0xb4u8)
    k.push(0x37u8)
    k.push(0x12u8)
    k.push(0x82u8)
    k.push(0xddu8)
    k.push(0x2cu8)
    k.push(0x8du8)
    k.push(0x5bu8)
    k.push(0xe3u8)
    k.push(0x09u8)
    k.push(0x5fu8)
    k

# RFC 7748 §5.2 X448 KAT — Input u-coordinate (56 bytes, little-endian)
# 0fbcc2f993cd56d3305b0b7d9e55d4c1a8fb5dbb52f8e9a1e9b6201b
# 165d015894e56c4d3570bee52fe205e28a78b91cdfbde71ce8d157db
fn _kat_u() -> [u8]:
    var u: [u8] = []
    u.push(0x0fu8)
    u.push(0xbcu8)
    u.push(0xc2u8)
    u.push(0xf9u8)
    u.push(0x93u8)
    u.push(0xcdu8)
    u.push(0x56u8)
    u.push(0xd3u8)
    u.push(0x30u8)
    u.push(0x5bu8)
    u.push(0x0bu8)
    u.push(0x7du8)
    u.push(0x9eu8)
    u.push(0x55u8)
    u.push(0xd4u8)
    u.push(0xc1u8)
    u.push(0xa8u8)
    u.push(0xfbu8)
    u.push(0x5du8)
    u.push(0xbbu8)
    u.push(0x52u8)
    u.push(0xf8u8)
    u.push(0xe9u8)
    u.push(0xa1u8)
    u.push(0xe9u8)
    u.push(0xb6u8)
    u.push(0x20u8)
    u.push(0x1bu8)
    u.push(0x16u8)
    u.push(0x5du8)
    u.push(0x01u8)
    u.push(0x58u8)
    u.push(0x94u8)
    u.push(0xe5u8)
    u.push(0x6cu8)
    u.push(0x4du8)
    u.push(0x35u8)
    u.push(0x70u8)
    u.push(0xbeu8)
    u.push(0xe5u8)
    u.push(0x2fu8)
    u.push(0xe2u8)
    u.push(0x05u8)
    u.push(0xe2u8)
    u.push(0x8au8)
    u.push(0x78u8)
    u.push(0xb9u8)
    u.push(0x1cu8)
    u.push(0xdfu8)
    u.push(0xbdu8)
    u.push(0xe7u8)
    u.push(0x1cu8)
    u.push(0xe8u8)
    u.push(0xd1u8)
    u.push(0x57u8)
    u.push(0xdbu8)
    u

# ============================================================================
# RFC 7748 §5.2 — X448 KAT
# ============================================================================
#
# X448(k, u) where:
#   k = 203d4944...5be3095f  (56 bytes, pre-clamped domain input)
#   u = 0fbcc2f9...e8d157db  (56 bytes)
#   expected output = 884a0257...da7c179d

describe "curve448 — RFC 7748 §5.2 X448 KAT":

    it "V1: full output matches RFC 7748 §5.2 expected u-coordinate":
        val out = x448_scalar_mult(_kat_scalar(), _kat_u())
        expect out.len() == 56
        expect(_bytes_hex(out)).to_equal(
            "884a02576239ff7a2f2f63b2db6a9ff37047ac13568e1e30fe63c4a7ad1b3ee3a5700df34321d62077e63633c575c1c954514e99da7c179d"
        )

    it "V1 output length is 56 bytes":
        val out = x448_scalar_mult(_kat_scalar(), _kat_u())
        expect out.len() == 56

    it "V1 first 16 bytes = 884a02576239ff7a2f2f63b2db6a9ff3 (ladder discriminator)":
        # Independent prefix check: if Montgomery ladder or field arithmetic
        # has endianness/carry bugs this fails before the full-vector check,
        # giving an unambiguous diagnostic.
        val out = x448_scalar_mult(_kat_scalar(), _kat_u())
        expect(_first_n_hex(out, 16)).to_equal(
            "884a02576239ff7a2f2f63b2db6a9ff3"
        )

# ============================================================================
# x448_clamp — RFC 7748 §5 clamping invariants
# ============================================================================

describe "curve448 — x448_clamp RFC 7748 §5 invariants":

    it "clamp clears low 2 bits of byte[0]":
        val k = _kat_scalar()
        val c = x448_clamp(k)
        expect (c[0] & 0x03u8).to_i64() == 0

    it "clamp sets high bit of byte[55]":
        val k = _kat_scalar()
        val c = x448_clamp(k)
        expect (c[55] & 0x80u8).to_i64() == 128

    it "clamp output length is 56 bytes":
        val k = _kat_scalar()
        val c = x448_clamp(k)
        expect c.len() == 56