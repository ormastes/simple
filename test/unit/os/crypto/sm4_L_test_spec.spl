use std.spec.*
use os.crypto.sm4.{sm4_key_expand}

fn make_key() -> [u8]:
    var b: [u8] = []
    var x: u8 = 0x01
    b.push(x)
    x = 0x23
    b.push(x)
    x = 0x45
    b.push(x)
    x = 0x67
    b.push(x)
    x = 0x89
    b.push(x)
    x = 0xAB
    b.push(x)
    x = 0xCD
    b.push(x)
    x = 0xEF
    b.push(x)
    x = 0xFE
    b.push(x)
    x = 0xDC
    b.push(x)
    x = 0xBA
    b.push(x)
    x = 0x98
    b.push(x)
    x = 0x76
    b.push(x)
    x = 0x54
    b.push(x)
    x = 0x32
    b.push(x)
    x = 0x10
    b.push(x)
    b

describe "test":
    it "works":
        val rk = sm4_key_expand(make_key())
        expect(rk.len()).to_equal(32)
