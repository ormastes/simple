# SimpleOS Compiled Logic Test — all inline in main()

fn check(name: text, value: bool):
    if value:
        print "OK: {name}"
    else:
        print "FAIL: {name}"

fn pfn_to_phys(pfn: i64) -> i64: pfn * 4096
fn phys_to_pfn(addr: i64) -> i64: addr / 4096

fn scancode_to_key(code: i64) -> i64:
    if code == 0x1E: return 1
    if code == 0x39: return 2
    if code == 0x1C: return 3
    if code == 0x01: return 4
    if code == 0x0E: return 5
    0

fn pci_addr(bus: i64, dev: i64, func: i64, off: i64) -> i64:
    (1 << 31) | (bus << 16) | (dev << 11) | (func << 8) | (off & 0xFC)

fn cluster_sector(cluster: i64, start: i64, spc: i64) -> i64:
    start + (cluster - 2) * spc

fn is_eoc(e: i64) -> bool: e >= 0x0FFFFFF8

fn color_argb(r: i64, g: i64, b: i64, a: i64) -> i64:
    ((a & 0xFF) << 24) | ((r & 0xFF) << 16) | ((g & 0xFF) << 8) | (b & 0xFF)

fn main():
    print "=== SimpleOS Compiled Logic Test ==="

    # PageFrame
    check("pfn 42→172032", pfn_to_phys(42) == 172032)
    check("pfn 0→0", pfn_to_phys(0) == 0)
    check("pfn 1→4096", pfn_to_phys(1) == 4096)
    check("phys→pfn 42", phys_to_pfn(172032) == 42)
    check("round trip 100", phys_to_pfn(pfn_to_phys(100)) == 100)
    check("round trip 1M", phys_to_pfn(pfn_to_phys(1000000)) == 1000000)

    # VmFlags bitfield
    val VM_P: i64 = 1
    val VM_W: i64 = 2
    val VM_U: i64 = 4
    val VM_WT: i64 = 8
    val VM_CD: i64 = 16
    val VM_NX: i64 = 32

    val krw = VM_P | VM_W
    check("krw present", (krw & VM_P) != 0)
    check("krw writable", (krw & VM_W) != 0)
    check("krw not user", (krw & VM_U) == 0)

    val urw = VM_P | VM_W | VM_U | VM_NX
    check("urw W^X", (urw & VM_W) != 0 and (urw & VM_NX) != 0)

    val mmio = VM_P | VM_W | VM_WT | VM_CD | VM_NX
    check("mmio WT", (mmio & VM_WT) != 0)
    check("mmio CD", (mmio & VM_CD) != 0)
    check("mmio NX", (mmio & VM_NX) != 0)

    # Scancodes
    check("scan A", scancode_to_key(0x1E) == 1)
    check("scan Space", scancode_to_key(0x39) == 2)
    check("scan Enter", scancode_to_key(0x1C) == 3)
    check("scan Esc", scancode_to_key(0x01) == 4)
    check("scan Unknown", scancode_to_key(0xFF) == 0)

    # PCI config
    val a0 = pci_addr(0, 0, 0, 0)
    check("PCI enable", (a0 >> 31) == 1)
    val a1 = pci_addr(1, 2, 3, 0x10)
    check("PCI bus=1", ((a1 >> 16) & 0xFF) == 1)
    check("PCI dev=2", ((a1 >> 11) & 0x1F) == 2)
    check("PCI func=3", ((a1 >> 8) & 7) == 3)

    # FAT32 cluster
    check("cluster 2→100", cluster_sector(2, 100, 8) == 100)
    check("cluster 3→108", cluster_sector(3, 100, 8) == 108)
    check("EOC yes", is_eoc(0x0FFFFFF8))
    check("EOC no", not is_eoc(2))

    # Color ARGB
    val black = color_argb(0, 0, 0, 255)
    check("black", black == 0xFF000000)
    val white = color_argb(255, 255, 255, 255)
    check("white", white == 0xFFFFFFFF)
    val red = color_argb(255, 0, 0, 255)
    check("red R", ((red >> 16) & 0xFF) == 255)

    # Bitwise
    check("shift", (1 << 31) != 0)
    check("AND", (0xFF & 0x0F) == 0x0F)
    check("OR", (0x55 | 0xAA) == 0xFF)

    print "=== DONE ==="
