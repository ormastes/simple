extern fn rt_dir_create_all(path: text) -> bool
extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_delete(path: text) -> bool
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_read_text(path: text) -> text
extern fn rt_env_get(key: text) -> text?
extern fn rt_env_set(key: text, value: text) -> bool
extern fn rt_process_run_timeout(cmd: text, args: [text], timeout_ms: i64) -> (text, text, i32)
extern fn rt_exit(code: i32) -> void

fn scenario_name_or_missing(name: text) -> text:
    val scenario = get_scenario(name)
    if val resolved = scenario:
        return resolved.name
    "missing"

fn command_contains_label(cmd: [text], needle: text) -> text:
    if cmd.contains(needle):
        return "present"
    "absent"

fn shell_exit_code(cmd: text) -> i32:
    val (_stdout, _stderr, exit_code) = rt_process_run_timeout("/bin/sh", ["-c", cmd], 5000)
    exit_code

fn shell_status_output(cmd: text) -> text:
    val wrapped = cmd + "\ncode=$?\nprintf '\\n__exit=%s\\n' \"$code\"\nexit 0"
    val (stdout, _stderr, _exit_code) = rt_process_run_timeout("/bin/sh", ["-c", wrapped], 5000)
    stdout

fn shell_ok(cmd: text) -> bool:
    shell_exit_code(cmd) == 0

fn write_shell_shim(path: text, content: text) -> bool:
    if not rt_file_write_text(path, content):
        return false
    shell_ok("/bin/chmod +x \"" + path + "\"")

fn install_failing_simple_shim(root: text, exit_code: i32) -> text:
    val path = root + "/simple-fails.sh"
    val _ = rt_dir_create_all(root)
    val _ok = write_shell_shim(path, "#!/bin/sh\nexit " + exit_code.to_text() + "\n")
    path

fn restore_board_bundle_tooling(root: text) -> bool:
    val script_backup = root + "/backup/scripts/make_os_disk.shs"
    val runner_backup = root + "/backup/scripts/mlk_s02_100t_generated_linux.shs"
    val simple_backup = root + "/backup/bin/simple"
    var ok = true
    val _ = shell_exit_code("rm -f \"scripts/make_os_disk.shs\"")
    val _ = shell_exit_code("rm -f \"scripts/mlk_s02_100t_generated_linux.shs\"")
    val _ = shell_exit_code("rm -f \"bin/simple\"")
    if rt_file_exists(script_backup):
        if not shell_ok("mv \"" + script_backup + "\" \"scripts/make_os_disk.shs\""):
            ok = false
    if rt_file_exists(runner_backup):
        if not shell_ok("mv \"" + runner_backup + "\" \"scripts/mlk_s02_100t_generated_linux.shs\""):
            ok = false
    if rt_file_exists(simple_backup):
        if not shell_ok("mv \"" + simple_backup + "\" \"bin/simple\""):
            ok = false
    ok

fn install_board_bundle_tooling_shims(root: text) -> bool:
    val _ = shell_exit_code("rm -rf \"" + root + "\"")
    if not rt_dir_create_all(root + "/backup/scripts"):
        return false
    if not rt_dir_create_all(root + "/backup/bin"):
        return false
    if rt_file_exists("scripts/make_os_disk.shs"):
        if not shell_ok("mv \"scripts/make_os_disk.shs\" \"" + root + "/backup/scripts/make_os_disk.shs\""):
            return false
    if rt_file_exists("scripts/mlk_s02_100t_generated_linux.shs"):
        if not shell_ok("mv \"scripts/mlk_s02_100t_generated_linux.shs\" \"" + root + "/backup/scripts/mlk_s02_100t_generated_linux.shs\""):
            val _ = shell_exit_code("mv \"" + root + "/backup/scripts/make_os_disk.shs\" \"scripts/make_os_disk.shs\"")
            return false
    if rt_file_exists("bin/simple"):
        if not shell_ok("mv \"bin/simple\" \"" + root + "/backup/bin/simple\""):
            val _ = shell_exit_code("mv \"" + root + "/backup/scripts/make_os_disk.shs\" \"scripts/make_os_disk.shs\"")
            val _ = shell_exit_code("mv \"" + root + "/backup/scripts/mlk_s02_100t_generated_linux.shs\" \"scripts/mlk_s02_100t_generated_linux.shs\"")
            return false
    val disk_shim = "#!/bin/sh\n" +
        "mkdir -p \"$(dirname \"$2\")\"\n" +
        "printf 'fake-board-bundle:%s\\n' \"$4\" > \"$2\"\n"
    if not write_shell_shim("scripts/make_os_disk.shs", disk_shim):
        return false
    val simple_shim = "#!/bin/sh\n" +
        "out=\"\"\n" +
        "for arg in \"$@\"; do out=\"$arg\"; done\n" +
        "mkdir -p \"$out\"\n" +
        "printf 'fake-board-bundle:riscv64\\n' > \"$out/board_linux_boot_products.sdn\"\n"
    if not write_shell_shim("bin/simple", simple_shim):
        return false
    val runner_shim = "#!/bin/sh\n" +
        "bundle_root=\"\"\n" +
        "product_root=\"\"\n" +
        "for arg in \"$@\"; do\n" +
        "  case \"$arg\" in\n" +
        "    --bundle-root=*) bundle_root=\"$(printf '%s\\n' \"$arg\" | cut -d= -f2-)\" ;;\n" +
        "    --product-root=*) product_root=\"$(printf '%s\\n' \"$arg\" | cut -d= -f2-)\" ;;\n" +
        "  esac\n" +
        "done\n" +
        "[ -n \"$bundle_root\" ] || exit 2\n" +
        "[ -n \"$product_root\" ] || exit 2\n" +
        "mkdir -p \"$bundle_root\" \"$product_root\"\n" +
        "printf 'fake-board-run:riscv64\\n' > \"$product_root/run.log\"\n" +
        "[ -f \"$bundle_root/board_linux_boot_products.sdn\" ] || exit 3\n"
    if not write_shell_shim("scripts/mlk_s02_100t_generated_linux.shs", runner_shim):
        return false
    true

