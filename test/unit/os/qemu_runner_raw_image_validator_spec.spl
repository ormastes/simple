fn expect_tool_app_validation_reference(cmd: text, app_name: text, marker: text, app_path: text):
    val img_path = "build/os/fat32-x86_64.img"
    expect(cmd).to_contain("::/SYS/APPS/{app_name}")
    expect(cmd).to_contain("::/SYS/APPS/{app_name}.smf")
    expect(cmd).to_contain("grep -a -q '{marker}'")
    expect(cmd).to_contain("grep -a -q '{app_path}'")
    expect(cmd).to_contain("mtype -i \"{img_path}\" ::/SYS/APPS/{app_name} 2>/dev/null | strings | grep -q '{app_path}'")
    expect(cmd).to_contain("mtype -i \"{img_path}\" ::/SYS/APPS/{app_name}.smf 2>/dev/null | strings | grep -q '{app_path}'")
    expect(cmd).to_contain("mtype -i \"{img_path}\" ::/SYS/APPS/{app_name}.smf 2>/dev/null | grep -a -q 'SMF'")

    it "rejects raw-image validation when mdir and mtype are unavailable even when catalog markers are present":
        val root = "build/test-qemu-tool-app-validator"
        val bin_dir = root + "/bin"
        val img_path = root + "/desktop-uefi-tools.raw"
        expect(rt_dir_create_all(bin_dir)).to_equal(true)
        expect(shell_exit_code("ln -sf /usr/bin/grep \"" + bin_dir + "/grep\"")).to_equal(0)
        expect(shell_exit_code("ln -sf /usr/bin/strings \"" + bin_dir + "/strings\"")).to_equal(0)
        expect(rt_file_write_text(img_path, desktop_tool_app_fallback_fixture())).to_equal(true)

        val cmd = "PATH=\"" + bin_dir + "\"; export PATH; " + desktop_uefi_disk_image_tool_app_validation_command(img_path)
        expect(shell_status_output(cmd)).to_contain("__exit=1")

rt_exit(0)
