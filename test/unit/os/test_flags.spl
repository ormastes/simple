fn check(n: text, v: bool):
    if v:
        print "OK: {n}"
    else:
        print "FAIL: {n}"

fn vmflags(p: i64, w: i64, u: i64, nx: i64) -> i64:
    p | (w << 1) | (u << 2) | (nx << 5)

fn has_flag(flags: i64, bit: i64) -> bool:
    (flags & (1 << bit)) != 0

fn main():
    print "=== VmFlags ==="
    check("present", has_flag(vmflags(1, 0, 0, 0), 0))
    check("write", has_flag(vmflags(1, 1, 0, 0), 1))
    check("user", has_flag(vmflags(1, 0, 1, 0), 2))
    check("nx", has_flag(vmflags(1, 0, 0, 1), 5))
    check("no_write", not has_flag(vmflags(1, 0, 0, 0), 1))
    check("rw_user", vmflags(1, 1, 1, 0) == 7)
    print "=== DONE ==="
