"""
# coreutils/mem argument parsing
**Feature IDs:** #WAVE5-G9
**Category:** Userland coreutils
"""
use std.spec.*
use os.apps.coreutils.mem.{main_mem}

describe "mem argument parsing":
    """Argument handling paths."""

    it "--help returns 0":
        """Help is a no-op that exits successfully."""
        val rc = main_mem(["--help"])
        expect rc.to_equal(0i32)

    it "empty args returns an i32":
        """Memory reporting should still compile and return a status."""
        val rc = main_mem([])
        val is_int: bool = rc == 0i32 or rc != 0i32
        expect is_int.to_equal(true)

