use std.spec
use os.apps.smux.api.{
    smux_reset_for_test,
    smux_list_sessions,
    smux_list_windows,
    smux_list_panes
}
use os.apps.smux.smux_app.{
    smux_help_text,
    smux_run_cmd
}
use os.apps.smux.smux_remote.{
    SMUX_APP_ID,
    smux_ready_marker,
    smux_remote_launch_once
}

describe "smux app":
    it "creates a session from the cli entry":
        smux_reset_for_test()
        expect smux_run_cmd(["new", "dev"]) == 0
        val sessions = smux_list_sessions()
        expect sessions.len() == 1
        expect sessions[0].name == "dev"

    it "sends and captures through the active pane commands":
        smux_reset_for_test()
        expect smux_run_cmd(["new", "io"]) == 0
        expect smux_run_cmd(["send", "io", "echo", "hi"]) == 0
        expect smux_run_cmd(["capture", "io"]) == 0
        val session = smux_list_sessions()[0]
        val window = smux_list_windows(session.id)[0]
        val pane = smux_list_panes(session.id, window.id)[0]
        expect pane.id != "" == true

    it "reports deferred features and exposes a filesystem app identity":
        smux_reset_for_test()
        expect smux_run_cmd(["deferred", "copy-mode"]) == 0
        expect (smux_help_text()).contains("smux deferred <feature>")
        expect (smux_ready_marker(42)).contains(SMUX_APP_ID)
        expect smux_remote_launch_once(42) == true