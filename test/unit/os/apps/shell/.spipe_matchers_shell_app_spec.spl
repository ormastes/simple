# Shell Application Unit Tests
#
# Tests for ShellApp: construction, command parsing, environment variables,
# history tracking, and built-in commands.

use os.tools.tool_registry.{ToolRegistry, ToolEntry}

fn _fake_registry_tool(args: [text]) -> i32:
    41

# ============================================================================
# ShellApp Construction
# ============================================================================

describe "ShellApp":
    context "when newly created":
        it "starts with cwd at root":
            val shell = ShellApp.new()
            expect shell.cwd == "/"

        it "starts with empty history":
            val shell = ShellApp.new()
            expect shell.history.len() == 0

        it "starts with history_pos at -1":
            val shell = ShellApp.new()
            expect shell.history_pos == -1

        it "starts in running state":
            val shell = ShellApp.new()
            expect shell.running == true

        it "starts with exit code 0":
            val shell = ShellApp.new()
            expect shell.last_exit_code == 0

        it "has a default prompt":
            val shell = ShellApp.new()
            expect shell.prompt == "$ "

        it "has empty output_lines":
            val shell = ShellApp.new()
            expect shell.output_lines.len() == 0

        it "has nil vfs by default":
            val shell = ShellApp.new()
            expect(shell.vfs).to_be_nil

    context "environment variables":
        it "has HOME set to /":
            val shell = ShellApp.new()
            val env = shell.env
            # env is a list of (text, text) tuples
            expect env.len() > 0

        it "has at least 3 default environment variables":
            val shell = ShellApp.new()
            # HOME, PATH, SHELL
            expect shell.env.len() == 3

    context "terminal":
        it "has a terminal attached":
            val shell = ShellApp.new()
            expect shell.terminal.cols == 80
            expect shell.terminal.rows == 24

# ============================================================================
# Command Parsing — _tokenize
# ============================================================================

describe "ShellApp command parsing":
    context "simple commands":
        it "splits simple command into tokens":
            var shell = ShellApp.new()
            val tokens = shell._tokenize("ls -la /home")
            expect tokens.len() == 3
            expect tokens[0] == "ls"
            expect tokens[1] == "-la"
            expect tokens[2] == "/home"

        it "handles single word command":
            var shell = ShellApp.new()
            val tokens = shell._tokenize("pwd")
            expect tokens.len() == 1
            expect tokens[0] == "pwd"

        it "handles empty input":
            var shell = ShellApp.new()
            val tokens = shell._tokenize("")
            expect tokens.len() == 0

        it "handles extra whitespace":
            var shell = ShellApp.new()
            val tokens = shell._tokenize("  ls   -la   ")
            expect tokens.len() == 2
            expect tokens[0] == "ls"
            expect tokens[1] == "-la"

    context "quoted arguments":
        it "handles double-quoted string":
            var shell = ShellApp.new()
            val tokens = shell._tokenize("echo \"hello world\"")
            expect tokens.len() == 2
            expect tokens[0] == "echo"
            expect tokens[1] == "hello world"

        it "handles single-quoted string":
            var shell = ShellApp.new()
            val tokens = shell._tokenize("echo 'hello world'")
            expect tokens.len() == 2
            expect tokens[0] == "echo"
            expect tokens[1] == "hello world"

        it "handles escaped characters":
            var shell = ShellApp.new()
            val tokens = shell._tokenize("echo hello\\ world")
            expect tokens.len() == 2
            expect tokens[0] == "echo"
            expect tokens[1] == "hello world"

    context "multiple arguments":
        it "parses command with flag and path":
            var shell = ShellApp.new()
            val tokens = shell._tokenize("cat -n /etc/passwd")
            expect tokens.len() == 3
            expect tokens[0] == "cat"
            expect tokens[1] == "-n"
            expect tokens[2] == "/etc/passwd"

        it "parses command with many args":
            var shell = ShellApp.new()
            val tokens = shell._tokenize("cp -r src/ dst/")
            expect tokens.len() == 3

# ============================================================================
# History Tracking
# ============================================================================

describe "ShellApp history":
    it "starts empty":
        val shell = ShellApp.new()
        expect shell.history.len() == 0

    it "records executed command":
        var shell = ShellApp.new()
        shell._execute_line("help")
        expect shell.history.len() == 1
        expect shell.history[0] == "help"

    it "records multiple commands":
        var shell = ShellApp.new()
        shell._execute_line("help")
        shell._execute_line("pwd")
        expect shell.history.len() == 2

    it "does not record empty input":
        var shell = ShellApp.new()
        shell._execute_line("")
        expect shell.history.len() == 0

# ============================================================================
# Built-in Commands
# ============================================================================

describe "ShellApp built-in commands":
    context "help command":
        it "executes without error":
            var shell = ShellApp.new()
            shell._execute_line("help")
            expect shell.last_exit_code == 0

        it "lists kernel MVP commands":
            var shell = ShellApp.new()
            shell._execute_line("help")
            var seen_run = false
            var seen_mem = false
            var seen_reboot = false
            for line in shell.output_lines:
                if line.contains("run CMD"):
                    seen_run = true
                if line.contains("mem"):
                    seen_mem = true
                if line.contains("reboot"):
                    seen_reboot = true
            expect seen_run == true
            expect seen_mem == true
            expect seen_reboot == true

    context "pwd command":
        it "shows current directory":
            var shell = ShellApp.new()
            shell._execute_line("pwd")
            expect shell.last_exit_code == 0

    context "exit command":
        it "sets running to false":
            var shell = ShellApp.new()
            shell._execute_line("exit")
            expect shell.running == false

    context "cd command":
        it "changes cwd":
            var shell = ShellApp.new()
            shell._execute_line("cd /home")
            expect shell.cwd == "/home"

        it "cd / goes to root":
            var shell = ShellApp.new()
            shell._execute_line("cd /home")
            shell._execute_line("cd /")
            expect shell.cwd == "/"

    context "echo command":
        it "produces output":
            var shell = ShellApp.new()
            shell._execute_line("echo hello")
            expect shell.last_exit_code == 0

    context "env command":
        it "lists environment variables":
            var shell = ShellApp.new()
            shell._execute_line("env")
            expect shell.last_exit_code == 0

    context "export command":
        it "sets environment variable":
            var shell = ShellApp.new()
            shell._execute_line("export FOO=bar")
            # Verify env grew
            expect shell.env.len() > 3

    context "run command":
        it "is treated as a built-in":
            var shell = ShellApp.new()
            expect shell._is_builtin_command("run") == true

        it "prints usage for --help":
            var shell = ShellApp.new()
            shell._execute_line("run --help")
            expect shell.last_exit_code == 0

    context "mem command":
        it "is treated as a built-in":
            var shell = ShellApp.new()
            expect shell._is_builtin_command("mem") == true

        it "prints usage for --help":
            var shell = ShellApp.new()
            shell._execute_line("mem --help")
            expect shell.last_exit_code == 0

    context "reboot command":
        it "is treated as a built-in":
            var shell = ShellApp.new()
            expect shell._is_builtin_command("reboot") == true

        it "prints a validation error when invoked":
            var shell = ShellApp.new()
            shell._execute_line("reboot")
            expect shell.last_exit_code == 1

    context "bootstrap tool commands":
        it "treats uname as a built-in":
            var shell = ShellApp.new()
            expect shell._is_builtin_command("uname") == true

        it "treats cmake as a built-in":
            var shell = ShellApp.new()
            expect shell._is_builtin_command("cmake") == true

        it "treats ninja as a built-in":
            var shell = ShellApp.new()
            expect shell._is_builtin_command("ninja") == true

describe "ShellApp external command routing":
    it "does not execute registry callbacks for non-builtins":
        var shell = ShellApp.new()
        var registry = ToolRegistry.new()
        registry.register(ToolEntry(
            name: "fake_external",
            description: "test-only external command",
            category: "test",
            run_fn: _fake_registry_tool,
            capabilities: []
        ))
        shell.tool_registry = registry

        shell._execute_line("fake_external")

        expect shell.last_exit_code == 127

    it "still rejects backgrounded built-ins":
        var shell = ShellApp.new()

        shell._execute_line("pwd &")

        expect shell.last_exit_code == 1