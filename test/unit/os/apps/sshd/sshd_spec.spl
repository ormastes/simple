use os.apps.sshd.sshd.{SshDaemon, sshd_decode_net_runtime_i32_for_test}
use os.apps.sshd.ssh_kex.{host_key_set_advertised_algorithms}

describe "sshd direct runtime integer decoding":
    it "untags positive file descriptors returned by the baremetal net runtime":
        expect(sshd_decode_net_runtime_i32_for_test(8)).to_equal(1)
        expect(sshd_decode_net_runtime_i32_for_test(16)).to_equal(2)

    it "preserves zero and negative status codes":
        expect(sshd_decode_net_runtime_i32_for_test(0)).to_equal(0)
        expect(sshd_decode_net_runtime_i32_for_test(-72)).to_equal(-72)

describe "sshd host key selection":
    it "keeps Ed25519 advertised when an RSA host key is configured":
        var daemon = SshDaemon.new(22)
        daemon.host_private_key = [1, 2, 3, 4]
        daemon.host_public_key = [5, 6, 7, 8]
        daemon.set_host_rsa_key([9, 10, 11, 12])
        daemon.set_host_rsa_public_blob([13, 14, 15, 16])
        val host_keys = daemon.build_host_keys_for_session()
        expect(host_keys.ed25519_seed != nil).to_equal(true)
        expect(host_keys.rsa_pkcs8 != nil).to_equal(true)
        expect(host_key_set_advertised_algorithms(host_keys)).to_equal("ssh-ed25519,rsa-sha2-256,rsa-sha2-512")
