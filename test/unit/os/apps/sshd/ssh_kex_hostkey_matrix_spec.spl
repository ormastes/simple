describe "rsa-sha2-512 host key signing":
    """
    ## rsa-sha2-512 Signature Blob

    Validates dispatch structure for rsa-sha2-512 (SHA-512 digest).
    Same RSA key as rsa-sha2-256, different hash algorithm.
    """

    it "returns Err when RSA key is absent":
        val host_keys = HostKeySet(
            ed25519_seed: nil,
            rsa_pkcs8: nil,
            rsa_public_blob: nil,
            ecdsa_p256_pkcs8: nil
        )
        val result = ssh_sign_exchange_hash("rsa-sha2-512", host_keys, _test_exchange_hash())
        expect(result.is_err()).to_equal(true)

    it "blob algo field is rsa-sha2-512 when signing succeeds":
        val pkcs8 = _rsa_2048_pkcs8_der()
        val host_keys = HostKeySet(
            ed25519_seed: nil,
            rsa_pkcs8: pkcs8,
            ecdsa_p256_pkcs8: nil
        )
        val result = ssh_sign_exchange_hash("rsa-sha2-512", host_keys, _test_exchange_hash())
        if result.is_ok():
            val parts = _decode_sig_blob(result.unwrap())
            expect(parts.0).to_equal("rsa-sha2-512")
        else:
            expect(result.is_err()).to_equal(true)

    it "raw RSA-512 signature is non-empty when signing succeeds":
        val pkcs8 = _rsa_2048_pkcs8_der()
        val host_keys = HostKeySet(
            ed25519_seed: nil,
            rsa_pkcs8: pkcs8,
            ecdsa_p256_pkcs8: nil
        )
        val result = ssh_sign_exchange_hash("rsa-sha2-512", host_keys, _test_exchange_hash())
        if result.is_ok():
            val raw_sig = _decode_sig_blob(result.unwrap()).1
            expect(raw_sig.len()).to_be_greater_than(0)
        else:
            expect(result.is_err()).to_equal(true)

# ============================================================================
# ecdsa-sha2-nistp256 Tests
# ============================================================================

describe "ecdsa-sha2-nistp256 host key signing":
    """
    ## ecdsa-sha2-nistp256 Signature Blob

    Validates that the inner signature is SSH mpint pair (mpint r + mpint s)
    that round-trips through ssh_mpint_pair_to_fixed64 to 64 bytes.
    """

    it "returns Err when ECDSA key is absent":
        val host_keys = HostKeySet(
            ed25519_seed: nil,
            rsa_pkcs8: nil,
            rsa_public_blob: nil,
            ecdsa_p256_pkcs8: nil
        )
        val result = ssh_sign_exchange_hash("ecdsa-sha2-nistp256", host_keys, _test_exchange_hash())
        expect(result.is_err()).to_equal(true)

    it "blob algo field is ecdsa-sha2-nistp256 when signing succeeds":
        val pkcs8 = _ecdsa_p256_pkcs8_der()
        val host_keys = HostKeySet(
            ed25519_seed: nil,
            rsa_pkcs8: nil,
            rsa_public_blob: nil,
            ecdsa_p256_pkcs8: pkcs8
        )
        val result = ssh_sign_exchange_hash("ecdsa-sha2-nistp256", host_keys, _test_exchange_hash())
        if result.is_ok():
            val parts = _decode_sig_blob(result.unwrap())
            expect(parts.0).to_equal("ecdsa-sha2-nistp256")
        else:
            expect(result.is_err()).to_equal(true)

    it "ECDSA inner blob decodes to 64-byte fixed r||s":
        val pkcs8 = _ecdsa_p256_pkcs8_der()
        val host_keys = HostKeySet(
            ed25519_seed: nil,
            rsa_pkcs8: nil,
            rsa_public_blob: nil,
            ecdsa_p256_pkcs8: pkcs8
        )
        val result = ssh_sign_exchange_hash("ecdsa-sha2-nistp256", host_keys, _test_exchange_hash())
        if result.is_ok():
            val inner = _decode_sig_blob(result.unwrap()).1
            val fixed64 = ssh_mpint_pair_to_fixed64(inner)
            expect(fixed64.len()).to_equal(64)
        else:
            expect(result.is_err()).to_equal(true)

    it "ECDSA fixed64 signature is non-zero":
        val pkcs8 = _ecdsa_p256_pkcs8_der()
        val host_keys = HostKeySet(
            ed25519_seed: nil,
            rsa_pkcs8: nil,
            rsa_public_blob: nil,
            ecdsa_p256_pkcs8: pkcs8
        )
        val result = ssh_sign_exchange_hash("ecdsa-sha2-nistp256", host_keys, _test_exchange_hash())
        if result.is_ok():
            val inner = _decode_sig_blob(result.unwrap()).1
            val fixed64 = ssh_mpint_pair_to_fixed64(inner)
            if fixed64.len() == 64:
                expect(_bytes_all_zero(fixed64)).to_equal(false)
        else:
            expect(result.is_err()).to_equal(true)

