use os.apps.sshd.ssh_session.{ssh_validate_kex_payload_for_test}

describe "SSH session pre-NEWKEYS validation":
    it "accepts the expected packet type":
        val result = ssh_validate_kex_payload_for_test(21, [21u8], true)
        expect(result.is_ok()).to_equal(true)

    it "rejects IGNORE during strict-kex":
        val result = ssh_validate_kex_payload_for_test(21, [2u8], true)
        expect(result.is_err()).to_equal(true)
        expect(result.unwrap_err()).to_equal("strict-kex unexpected pre-newkeys message")

    it "rejects the wrong packet type":
        val result = ssh_validate_kex_payload_for_test(21, [30u8], false)
        expect(result.is_err()).to_equal(true)
        expect(result.unwrap_err()).to_equal("unexpected kex packet type")
