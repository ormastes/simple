use std.spec
use os.packages.os_packages.{list_all_packages}
use os.tools.pkg.pkg_format.{PkgArch}

fn _find_tools_files() -> [text]:
    for pkg in list_all_packages(PkgArch.X86_64):
        if pkg.base.name == "simpleos-tools":
            return pkg.base.files
    []

describe "simpleos-tools toolchain paths":
    it "ships stable native command paths and manifests for the guest toolchain surface":
        val files = _find_tools_files()
        expect(files).to_contain("/usr/bin/cmake")
        expect(files).to_contain("/usr/bin/ninja")
        expect(files).to_contain("/usr/bin/clang")
        expect(files).to_contain("/usr/bin/rustc")
        expect(files).to_contain("/usr/bin/cargo")
        expect(files).to_contain("/usr/bin/cargo-simpleos")
        expect(files).to_contain("/SYS/CMAKEVER.TXT")
        expect(files).to_contain("/SYS/CMAKEMAN.TXT")
        expect(files).to_contain("/SYS/NINJAVER.TXT")
        expect(files).to_contain("/SYS/NINJAMAN.TXT")
        expect(files).to_contain("/SYS/LLVMMAN.TXT")
        expect(files).to_contain("/SYS/RUSTMAN.TXT")
