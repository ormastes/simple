# @cover src/os/posix/fd_table.spl 80%
"""
# POSIX fd table specification

The fd table maps descriptors to open file descriptions. Duplicated
descriptors share status flags and file offsets, while FD_CLOEXEC remains
per descriptor.
"""

use std.spec
use os.posix.errno.{EBADF, EMFILE}
use os.posix.fd_table.{fd_table_init, fd_activate_task, fd_current_task, fd_alloc, fd_set, fd_close, fd_is_valid, fd_dup, fd_dup2, fd_get_cloexec, fd_set_cloexec, fd_close_on_exec, fd_exec_cleanup, fd_prepare_fork, fd_prepare_fork_to_task, fd_release_on_process_exit, fd_release_task, fd_get_status_flags, fd_set_status_flags, fd_get_offset, fd_set_offset, fd_get_type, fd_get_backend_handle, fd_get_object_id, fd_get_refcount, fd_poll_ready, fd_set_poll_notification, fd_poll_notification, fd_update_ready, fd_get_ready_generation, fd_types, fd_ports, fd_refcounts, FD_TYPE_FREE, FD_TYPE_FILE, FD_TYPE_PIPE_READ, FD_TYPE_SERIAL, O_RDONLY, O_WRONLY, O_RDWR, O_NONBLOCK, O_CLOEXEC, POLLIN, POLLOUT, POLLHUP, POLLNVAL, MAX_FDS}

describe "POSIX fd table":
    it "initializes stdio descriptors and allocates the lowest free descriptor":
        fd_table_init()

        expect fd_is_valid(0) == true
        expect fd_is_valid(1) == true
        expect fd_is_valid(2) == true
        expect fd_types[0] == FD_TYPE_SERIAL
        expect fd_alloc() == 3

        expect fd_close(0) == 0
        expect fd_alloc() == 0

    it "keeps O_CLOEXEC as a per-descriptor flag":
        fd_table_init()
        expect fd_set(3, FD_TYPE_FILE, O_RDWR | O_NONBLOCK | O_CLOEXEC, 99u64) == 0

        expect fd_get_cloexec(3) == true
        expect fd_get_status_flags(3) & O_CLOEXEC == 0u32
        expect fd_get_status_flags(3) & O_NONBLOCK == O_NONBLOCK

    it "reports open-file-description exhaustion through fd_set":
        fd_table_init()
        var fd: i32 = 3
        while (fd as u64) < MAX_FDS - 1:
            expect fd_set(fd, FD_TYPE_FILE, O_RDONLY, fd as u64) == 0
            fd = fd + 1

        expect fd_set(255, FD_TYPE_FILE, O_RDONLY, 255u64) == 0 - EMFILE
        expect fd_is_valid(255) == false

    it "duplicates descriptors onto a shared open file description":
        fd_table_init()
        fd_set(3, FD_TYPE_FILE, O_RDWR | O_CLOEXEC, 99u64)
        expect fd_set_offset(3, 44u64) == 0
        expect fd_set_status_flags(3, O_RDWR | O_NONBLOCK) == 0

        val dup_fd = fd_dup(3)

        expect dup_fd == 4
        expect fd_get_cloexec(dup_fd) == false
        expect fd_refcounts[3] == 2u32
        expect fd_refcounts[4] == 2u32
        expect fd_get_offset(dup_fd) == 44u64
        expect fd_get_status_flags(dup_fd) & O_NONBLOCK == O_NONBLOCK

        expect fd_set_offset(dup_fd, 88u64) == 0
        expect fd_get_offset(3) == 88u64

        expect fd_set_status_flags(dup_fd, O_RDWR) == 0
        expect fd_get_status_flags(3) & O_NONBLOCK == 0u32

    it "exposes a stable token for duplicated open file descriptions":
        fd_table_init()
        fd_set(3, FD_TYPE_FILE, O_RDONLY, 10u64)
        val original_token = fd_get_object_id(3)

        val dup_fd = fd_dup(3)
        expect dup_fd == 4
        expect fd_get_object_id(dup_fd) == original_token

        fd_set(5, FD_TYPE_FILE, O_RDONLY, 20u64)
        expect fd_get_object_id(5) == 20u64
        expect fd_dup2(3, 5) == 5
        expect fd_get_object_id(5) == original_token

    it "implements dup2 replacement semantics":
        fd_table_init()
        fd_set(3, FD_TYPE_FILE, O_RDONLY, 10u64)
        fd_set(4, FD_TYPE_FILE, O_WRONLY | O_CLOEXEC, 20u64)
        expect fd_set_offset(3, 7u64) == 0
        expect fd_set_offset(4, 99u64) == 0

        expect fd_dup2(3, 4) == 4

        expect fd_ports[4] == 10u64
        expect fd_get_cloexec(4) == false
        expect fd_refcounts[3] == 2u32
        expect fd_refcounts[4] == 2u32
        expect fd_get_offset(4) == 7u64

        expect fd_set_offset(4, 12u64) == 0
        expect fd_get_offset(3) == 12u64

    it "preserves descriptor flags when dup2 targets the same descriptor":
        fd_table_init()
        fd_set(3, FD_TYPE_FILE, O_RDONLY | O_CLOEXEC, 10u64)

        expect fd_dup2(3, 3) == 3
        expect fd_get_cloexec(3) == true
        expect fd_refcounts[3] == 1u32

    it "rejects invalid dup descriptors with EBADF":
        fd_table_init()
        fd_set(3, FD_TYPE_FILE, O_RDONLY, 10u64)

        expect fd_dup(-1) == 0 - EBADF
        expect fd_dup2(99, 4) == 0 - EBADF
        expect fd_dup2(3, -1) == 0 - EBADF
        expect fd_dup2(3, 256) == 0 - EBADF

    it "closes only descriptors marked close-on-exec":
        fd_table_init()
        fd_set(3, FD_TYPE_FILE, O_RDONLY, 10u64)
        fd_set(4, FD_TYPE_FILE, O_RDONLY, 20u64)
        expect fd_set_cloexec(3, true) == 0
        expect fd_set_cloexec(4, false) == 0

        expect fd_close_on_exec() == 1u32
        expect fd_is_valid(3) == false
        expect fd_is_valid(4) == true
        expect fd_types[3] == FD_TYPE_FREE

    it "applies exec cleanup through the exec lifecycle alias":
        fd_table_init()
        fd_set(3, FD_TYPE_FILE, O_RDONLY | O_CLOEXEC, 10u64)
        fd_set(4, FD_TYPE_FILE, O_RDONLY, 20u64)

        expect fd_exec_cleanup() == 1u32
        expect fd_is_valid(3) == false
        expect fd_is_valid(4) == true

    it "inherits live descriptors across fork without changing cloexec flags":
        fd_table_init()
        fd_set(3, FD_TYPE_FILE, O_RDONLY | O_CLOEXEC, 10u64)
        fd_set(4, FD_TYPE_FILE, O_WRONLY, 20u64)

        expect fd_get_refcount(3) == 1u32
        expect fd_prepare_fork() == 5u32

        expect fd_get_refcount(3) == 2u32
        expect fd_get_refcount(4) == 2u32
        expect fd_get_cloexec(3) == true
        expect fd_get_cloexec(4) == false

    it "releases every live descriptor on process exit":
        fd_table_init()
        fd_set(3, FD_TYPE_FILE, O_RDONLY, 10u64)
        fd_set(4, FD_TYPE_FILE, O_WRONLY, 20u64)

        expect fd_release_on_process_exit() == 5u32
        expect fd_is_valid(0) == false
        expect fd_is_valid(3) == false
        expect fd_is_valid(4) == false

    it "keeps descriptor tables isolated between active tasks":
        fd_table_init()
        fd_activate_task(10u64)
        fd_set(3, FD_TYPE_FILE, O_RDONLY, 10u64)
        expect fd_current_task() == 10u64
        expect fd_is_valid(3) == true

        fd_activate_task(11u64)
        expect fd_current_task() == 11u64
        expect fd_is_valid(3) == false
        expect fd_is_valid(0) == true

        fd_activate_task(10u64)
        expect fd_is_valid(3) == true
        expect fd_get_backend_handle(3) == 10u64

    it "does not alias descriptor contexts with modulo-colliding task ids":
        fd_table_init()
        fd_activate_task(10u64)
        fd_set(3, FD_TYPE_FILE, O_RDONLY, 10u64)

        fd_activate_task(266u64)
        expect fd_current_task() == 266u64
        expect fd_is_valid(3) == false
        fd_set(3, FD_TYPE_FILE, O_RDONLY, 266u64)

        fd_activate_task(10u64)
        expect fd_is_valid(3) == true
        expect fd_get_backend_handle(3) == 10u64

        fd_activate_task(266u64)
        expect fd_is_valid(3) == true
        expect fd_get_backend_handle(3) == 266u64

    it "clones active descriptor table into fork child context":
        fd_table_init()
        fd_activate_task(20u64)
        fd_set(3, FD_TYPE_FILE, O_RDONLY | O_CLOEXEC, 30u64)
        expect fd_set_offset(3, 44u64) == 0

        expect fd_prepare_fork_to_task(21u64) == 4u32
        expect fd_get_refcount(3) == 2u32

        fd_activate_task(21u64)
        expect fd_is_valid(3) == true
        expect fd_get_cloexec(3) == true
        expect fd_get_offset(3) == 44u64
        expect fd_set_offset(3, 88u64) == 0

        fd_activate_task(20u64)
        expect fd_get_offset(3) == 88u64

    it "releases inactive task descriptor contexts":
        fd_table_init()
        fd_activate_task(30u64)
        fd_set(3, FD_TYPE_FILE, O_RDONLY, 40u64)
        expect fd_prepare_fork_to_task(31u64) == 4u32
        expect fd_get_refcount(3) == 2u32

        expect fd_release_task(31u64) == 4u32
        expect fd_get_refcount(3) == 1u32
        fd_activate_task(31u64)
        expect fd_is_valid(3) == false

    it "keeps duplicated open descriptions alive until the last close":
        fd_table_init()
        fd_set(3, FD_TYPE_FILE, O_RDONLY, 10u64)
        expect fd_set_offset(3, 55u64) == 0

        val dup_fd = fd_dup(3)
        expect dup_fd == 4
        expect fd_close(3) == 0

        expect fd_is_valid(3) == false
        expect fd_is_valid(4) == true
        expect fd_get_offset(4) == 55u64
        expect fd_refcounts[4] == 1u32

        expect fd_close(4) == 0
        expect fd_is_valid(4) == false

    it "exposes fd backend metadata without direct table access":
        fd_table_init()
        fd_set(3, FD_TYPE_FILE, O_RDONLY, 77u64)

        expect fd_get_type(3) == FD_TYPE_FILE
        expect fd_get_backend_handle(3) == 77u64
        expect fd_get_type(99) == FD_TYPE_FREE

    it "tracks readiness and notifications on the shared open description":
        fd_table_init()
        fd_set(3, FD_TYPE_PIPE_READ, O_RDONLY, 11u64)
        expect fd_set_poll_notification(3, POLLIN, 500u64) == 0

        val dup_fd = fd_dup(3)
        expect dup_fd == 4
        expect fd_poll_notification(dup_fd, POLLIN) == 500u64
        expect fd_poll_ready(dup_fd, POLLIN) == 0 as i16
        expect fd_get_ready_generation(3) == 0u64

        expect fd_update_ready(3, POLLIN, 0 as i16) == 0
        expect fd_poll_ready(dup_fd, POLLIN) == POLLIN
        expect fd_get_ready_generation(dup_fd) == 1u64

        expect fd_update_ready(dup_fd, POLLHUP, POLLIN) == 0
        expect fd_poll_ready(3, POLLIN) == POLLHUP
        expect fd_get_ready_generation(3) == 2u64

    it "reports invalid descriptors through poll readiness":
        fd_table_init()

        expect fd_poll_ready(99, POLLIN | POLLOUT) == POLLNVAL