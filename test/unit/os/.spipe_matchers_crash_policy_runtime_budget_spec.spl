use std.spipe.*
use os.crash_policy.{
    _half_available_threads, AppWorkloadProfile, default_runtime_budget,
    is_heavy_workload_profile
}

describe "Crash policy runtime budgets":
    it "uses half the available threads with a floor of one":
        expect _half_available_threads(1) == 1
        expect _half_available_threads(2) == 1
        expect _half_available_threads(7) == 3
        expect _half_available_threads(8) == 4

    it "caps dashboard session memory at 8 GiB":
        val budget = default_runtime_budget(AppWorkloadProfile.DashboardSession)
        expect budget.memory_limit_mb == 8192
        expect budget.max_fds == 256
        expect budget.max_procs == 32
        expect budget.quarantine_millis == 900000

    it "marks compiler profile as heavy":
        expect is_heavy_workload_profile(AppWorkloadProfile.CompilerHeavy) == true
        expect is_heavy_workload_profile(AppWorkloadProfile.DashboardSession) == false

    it "keeps baremetal single threaded with no host limits":
        val budget = default_runtime_budget(AppWorkloadProfile.BaremetalDomain)
        expect budget.max_threads == 1
        expect budget.memory_limit_mb == 0
        expect budget.wall_timeout_ms == 0