use os.qemu_runner.{
    build_qemu_command, build_qemu_command_with_options,
    get_all_targets, get_gui_target, get_target,
    get_scenario, scenario_arm64_virtio_fat32_smf, scenario_arm32_virtio_fat32_smf,
    scenario_riscv64_virtio_fat32_smf, scenario_riscv32_virtio_fat32_smf,
    scenario_x64_desktop_uefi, scenario_x64_wm_simple_web_check,
    scenario_x64_net_user, scenario_x64_ssh,
    build_scenario_command, scenario_test_timeout_ms, arm_fs_exec_disk_image_path,
    riscv_fs_exec_disk_image_path, scenario_target, get_wm_simple_web_check_target,
    get_ssh_live_target, get_ssh_x25519_probe_target,
    default_os_build_backend_for_target,
    desktop_disk_image_candidates, desktop_disk_image_path_in, desktop_disk_make_script_args,
    desktop_installer_iso_candidates, desktop_release_disk_image_path_in,
    desktop_release_installer_iso_path, native_build_prerequisite_hint, ovmf_code_path,
    os_native_build_args, os_native_build_sources, os_native_build_env_prefix,
    desktop_uefi_disk_image_tool_app_validation_command, build_os_with_backend,
    OsTarget,
    qemu_run_options_debug_gui
}
use os.kernel.arch.arch_context.{Architecture}
extern fn rt_dir_create_all(path: text) -> bool
extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_delete(path: text) -> bool
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_env_set(key: text, value: text) -> bool
extern fn rt_process_run_timeout(cmd: text, args: [text], timeout_ms: i64) -> (text, text, i32)

fn scenario_name_or_missing(name: text) -> text:
    val scenario = get_scenario(name)
    if val resolved = scenario:
        return resolved.name
    "missing"

fn command_contains_label(cmd: [text], needle: text) -> text:
    if cmd.contains(needle):
        return "present"
    "absent"

fn shell_exit_code(cmd: text) -> i32:
    val (_stdout, _stderr, exit_code) = rt_process_run_timeout("/bin/sh", ["-c", cmd], 5000)
    exit_code

fn desktop_tool_app_fallback_fixture() -> text:
    "SBROWSMF\n" +
        "info|src/app/info/main.spl|smoke|staged\n" +
        "SCOMPSMF\n" +
        "SINTSMF\n" +
        "SLOADSMF\n" +
        "LLVMSMF\n" +
        "RUSTSMF\n" +
        "SimpleOS LLVM standalone app v1\n" +
        "SimpleOS Rust standalone app v1\n" +
        "mode=native-filesystem-app\n" +
        "status=standalone-required\n" +
        "SIMPLECLI.CAT\n" +
        "/sys/apps/simple_browser\n" +
        "/sys/apps/simple_compiler\n" +
        "/sys/apps/simple_interpreter\n" +
        "/sys/apps/simple_loader\n" +
        "/sys/apps/llvm\n" +
        "/sys/apps/rust\n" +
        "/usr/share/simpleos/toolchain/llvm/hello.ll\n" +
        "/usr/share/simpleos/toolchain/rust/hello.rs\n" +
        "SMF\n"

fn expect_tool_app_validation_reference(cmd: text, app_name: text, marker: text, app_path: text):
    val img_path = "build/os/fat32-x86_64.img"
    expect (cmd).contains("::/SYS/APPS/{app_name}")
    expect (cmd).contains("::/SYS/APPS/{app_name}.smf")
    expect (cmd).contains("grep -a -q '{marker}'")
    expect (cmd).contains("grep -a -q '{app_path}'")
    expect (cmd).contains("mtype -i \"{img_path}\" ::/SYS/APPS/{app_name} 2>/dev/null | strings | grep -q '{app_path}'")
    expect (cmd).contains("mtype -i \"{img_path}\" ::/SYS/APPS/{app_name}.smf 2>/dev/null | strings | grep -q '{app_path}'")
    expect (cmd).contains("mtype -i \"{img_path}\" ::/SYS/APPS/{app_name}.smf 2>/dev/null | grep -a -q 'SMF'")

describe "Qemu runner serial routing":
    it "enumerates 32-bit x86 as a first-class target":
        var found_x86_32 = false
        for target in get_all_targets():
            if target.arch == Architecture.X86:
                found_x86_32 = true
                expect target.target_triple == "i686-unknown-none"
                expect target.qemu_system == "qemu-system-i386"
        expect found_x86_32 == true

    it "builds normal targets from the shared platform catalog":
        val x86_64 = get_target(Architecture.X86_64)
        expect x86_64.entry == "examples/simple_os/arch/x86_64/os_entry.spl"
        expect x86_64.linker_script == "examples/simple_os/arch/x86_64/linker.ld"
        expect x86_64.target_triple == "x86_64-unknown-none"
        expect x86_64.qemu_system == "qemu-system-x86_64"

        val arm32 = get_target(Architecture.Arm32)
        expect arm32.entry == "src/os/kernel/arch/arm32/boot.spl"
        expect arm32.target_triple == "armv7-unknown-none-eabihf"
        expect arm32.qemu_system == "qemu-system-arm"

    it "defines ARM VirtIO FAT32 SMF execution scenarios":
        val arm64 = scenario_arm64_virtio_fat32_smf()
        expect arm64.name == "arm64-virtio-fat32-smf"
        expect arm64.arch == Architecture.Arm64
        expect (arm64.qemu_extra).contains("virtio-blk-device,drive=armdisk")
        expect (arm64.qemu_extra).contains("file=build/os/fat32-arm64.img,if=none,id=armdisk,format=raw")
        expect (arm64.qemu_extra).contains("-semihosting-config")
        expect scenario_test_timeout_ms(arm64) == 60000

        val arm32 = scenario_arm32_virtio_fat32_smf()
        expect arm32.name == "arm32-virtio-fat32-smf"
        expect arm32.arch == Architecture.Arm32
        expect (arm32.qemu_extra).contains("virtio-blk-device,drive=armdisk")
        expect (arm32.qemu_extra).contains("file=build/os/fat32-arm32.img,if=none,id=armdisk,format=raw")
        expect (arm32.qemu_extra).contains("-semihosting-config")

    it "builds QEMU commands with ARM loader and VirtIO block disks":
        val arm64 = scenario_arm64_virtio_fat32_smf()
        val cmd = build_scenario_command(arm64, "build/os/simpleos_arm64_fs_exec.bin")
        expect cmd[0] == "qemu-system-aarch64"
        expect (cmd).contains("loader,file=build/os/simpleos_arm64_fs_exec.bin,addr=0x40200000,force-raw=on")
        expect (cmd).contains("loader,addr=0x40200000,cpu-num=0")
        expect cmd.contains("-kernel") == false
        expect (cmd).contains("virtio-blk-device,drive=armdisk")

        val target = scenario_target(arm64)
        expect target.entry == "examples/simple_os/arch/arm64/fs_exec_entry.spl"
        expect target.linker_script == "examples/simple_os/arch/arm64/fs_exec_linker.ld"

    it "looks up ARM SMF scenarios by name":
        expect scenario_name_or_missing("arm64-virtio-fat32-smf") == "arm64-virtio-fat32-smf"
        expect scenario_name_or_missing("arm32-virtio-fat32-smf") == "arm32-virtio-fat32-smf"
        expect arm_fs_exec_disk_image_path(Architecture.Arm64) == "build/os/fat32-arm64.img"
        expect arm_fs_exec_disk_image_path(Architecture.Arm32) == "build/os/fat32-arm32.img"

    it "defines RISC-V VirtIO FAT32 SMF execution scenarios":
        val rv64 = scenario_riscv64_virtio_fat32_smf()
        expect rv64.name == "riscv64-virtio-fat32-smf"
        expect rv64.arch == Architecture.Riscv64
        expect (rv64.qemu_extra).contains("virtio-blk-device,drive=rvdisk")
        expect (rv64.qemu_extra).contains("file=build/os/fat32-riscv64.img,if=none,id=rvdisk,format=raw")
        expect scenario_test_timeout_ms(rv64) == 60000

        val rv32 = scenario_riscv32_virtio_fat32_smf()
        expect rv32.name == "riscv32-virtio-fat32-smf"
        expect rv32.arch == Architecture.Riscv32
        expect (rv32.qemu_extra).contains("virtio-blk-device,drive=rvdisk")
        expect (rv32.qemu_extra).contains("file=build/os/fat32-riscv32.img,if=none,id=rvdisk,format=raw")
        expect scenario_test_timeout_ms(rv32) == 60000

    it "builds QEMU commands with RISC-V kernels and VirtIO block disks":
        val rv64 = scenario_riscv64_virtio_fat32_smf()
        val cmd64 = build_scenario_command(rv64, "build/os/simpleos_riscv64_smf_fs.elf")
        expect cmd64[0] == "qemu-system-riscv64"
        expect (cmd64).contains("-kernel")
        expect (cmd64).contains("build/os/simpleos_riscv64_smf_fs.elf")
        expect (cmd64).contains("virtio-blk-device,drive=rvdisk")
        val target64 = scenario_target(rv64)
        expect target64.entry == "examples/simple_os/arch/riscv64/smoke_entry.spl"

        val rv32 = scenario_riscv32_virtio_fat32_smf()
        val cmd32 = build_scenario_command(rv32, "build/os/simpleos_riscv32_smf_fs.elf")
        expect cmd32[0] == "qemu-system-riscv32"
        expect (cmd32).contains("-kernel")
        expect (cmd32).contains("build/os/simpleos_riscv32_smf_fs.elf")
        expect (cmd32).contains("virtio-blk-device,drive=rvdisk")
        val target32 = scenario_target(rv32)
        expect target32.entry == "examples/simple_os/arch/riscv32/smoke_entry.spl"

    it "scopes RISC-V SMF native builds to arch-local sources":
        val rv64_target = scenario_target(scenario_riscv64_virtio_fat32_smf())
        val rv64_args = os_native_build_args(rv64_target, "llvm")
        expect (rv64_args).contains("examples/simple_os/arch/riscv64")
        expect rv64_args.contains("src") == false

        val rv32_target = scenario_target(scenario_riscv32_virtio_fat32_smf())
        val rv32_args = os_native_build_args(rv32_target, "llvm")
        expect (rv32_args).contains("examples/simple_os/arch/riscv32")
        expect rv32_args.contains("src") == false

    it "looks up RISC-V SMF scenarios by name":
        expect scenario_name_or_missing("riscv64-virtio-fat32-smf") == "riscv64-virtio-fat32-smf"
        expect scenario_name_or_missing("riscv32-virtio-fat32-smf") == "riscv32-virtio-fat32-smf"
        expect riscv_fs_exec_disk_image_path(Architecture.Riscv64) == "build/os/fat32-riscv64.img"
        expect riscv_fs_exec_disk_image_path(Architecture.Riscv32) == "build/os/fat32-riscv32.img"

    it "uses per-platform x86_64 FAT32 media for filesystem scenarios":
        val scenario = get_scenario("x64-nvme-fat32")
        expect scenario_name_or_missing("x64-nvme-fat32") == "x64-nvme-fat32"
        if val resolved = scenario:
            val cmd = build_scenario_command(resolved, "build/os/simpleos_fs_test_32.elf")
            expect (cmd).contains("file=build/os/fat32-x86_64.img,if=none,id=nvm,format=raw")

    it "keeps x64 desktop smoke diskless and leaves storage to the disk lane":
        val smoke = get_scenario("x64-desktop-test")
        expect scenario_name_or_missing("x64-desktop-test") == "x64-desktop-test"
        if val resolved_smoke = smoke:
            val smoke_cmd = build_scenario_command(resolved_smoke, "build/os/simpleos_desktop_e2e_32.elf")
            expect command_contains_label(smoke_cmd, "drive=nvm") == "absent"
            expect command_contains_label(smoke_cmd, "-vga") == "present"

        val disk = get_scenario("x64-desktop-disk")
        expect scenario_name_or_missing("x64-desktop-disk") == "x64-desktop-disk"
        if val resolved_disk = disk:
            val disk_cmd = build_scenario_command(resolved_disk, "build/os/simpleos_desktop_e2e_32.elf")
            expect (disk_cmd).contains("drive=nvm")
            expect (disk_cmd).contains("file=build/os/fat32-x86_64.img,if=none,id=nvm,format=raw")

    it "defines a UEFI-native x64 desktop disk boot scenario":
        expect rt_env_set("SIMPLEOS_OVMF_CODE", "build/test-ovmf/OVMF_CODE.fd") == true
        expect ovmf_code_path() == "build/test-ovmf/OVMF_CODE.fd"
        val scenario = scenario_x64_desktop_uefi()
        expect scenario.name == "x64-desktop-uefi"
        expect scenario.arch == Architecture.X86_64
        expect scenario_test_timeout_ms(scenario) == 180000

        val resolved = get_scenario("x64-desktop-uefi")
        if val s = resolved:
            val cmd = build_scenario_command(s, "build/os/simpleos_desktop_e2e_32.elf")
            expect cmd[0] == "qemu-system-x86_64"
            expect cmd.contains("-kernel") == false
            expect (cmd).contains("if=pflash,format=raw,readonly=on,file=build/test-ovmf/OVMF_CODE.fd")
            expect (cmd).contains("file=build/os/fat32-x86_64.img,if=none,id=uefidisk,format=raw")
            expect (cmd).contains("nvme,serial=uefi-desktop,drive=uefidisk")
        else:
            expect "missing" == "x64-desktop-uefi"

    it "builds a desktop UEFI validator command with mdir and raw-image fallbacks for migrated tool apps":
        val cmd = desktop_uefi_disk_image_tool_app_validation_command("build/os/fat32-x86_64.img")
        expect (cmd).contains("command -v mdir")
        expect (cmd).contains("::/SYS/APPS/simple_browser")
        expect (cmd).contains("::/SYS/APPS/simple_browser.smf")
        expect (cmd).contains("::/SYS/APPS/simple_compiler")
        expect (cmd).contains("::/SYS/APPS/simple_compiler.smf")
        expect (cmd).contains("::/SYS/APPS/simple_interpreter")
        expect (cmd).contains("::/SYS/APPS/simple_interpreter.smf")
        expect (cmd).contains("::/SYS/APPS/simple_loader")
        expect (cmd).contains("::/SYS/APPS/simple_loader.smf")
        expect (cmd).contains("::/SYS/APPS/llvm")
        expect (cmd).contains("::/SYS/APPS/llvm.smf")
        expect (cmd).contains("::/SYS/APPS/rust")
        expect (cmd).contains("::/SYS/APPS/rust.smf")
        expect (cmd).contains("::/SYS/LLVMVER.TXT")
        expect (cmd).contains("::/SYS/RUSTVER.TXT")
        expect (cmd).contains("grep -a -q 'SBROWSMF'")
        expect (cmd).contains("grep -a -q 'SCOMPSMF'")
        expect (cmd).contains("grep -a -q 'SINTSMF'")
        expect (cmd).contains("grep -a -q 'SLOADSMF'")
        expect (cmd).contains("grep -a -q 'LLVMSMF'")
        expect (cmd).contains("grep -a -q 'RUSTSMF'")
        expect (cmd).contains("command -v mtype")
        expect (cmd).contains("/sys/apps/simple_browser")
        expect (cmd).contains("/sys/apps/simple_compiler")
        expect (cmd).contains("/sys/apps/simple_interpreter")
        expect (cmd).contains("/sys/apps/simple_loader")
        expect (cmd).contains("/sys/apps/llvm")
        expect (cmd).contains("/sys/apps/rust")
        expect (cmd).contains("grep -q '^SimpleOS LLVM standalone app v1'")
        expect (cmd).contains("grep -q '^SimpleOS Rust standalone app v1'")
        expect (cmd).contains("grep -q 'mode=native-filesystem-app'")
        expect (cmd).contains("grep -q 'status=standalone-required'")
        expect (cmd).contains("/usr/share/simpleos/toolchain/llvm/hello.ll")
        expect (cmd).contains("/usr/share/simpleos/toolchain/rust/hello.rs")

    it "defines a BGA WM Simple Web Engine2D scenario":
        val scenario = scenario_x64_wm_simple_web_check()
        expect scenario.name == "x64-wm-simple-web-check"
        expect scenario.arch == Architecture.X86_64
        expect scenario.memory == "2G"
        expect (scenario.qemu_extra).contains("-vga")
        expect (scenario.qemu_extra).contains("std")
        expect scenario.qemu_extra.contains("virtio-gpu,disable-modern=on,disable-legacy=off") == false
        expect scenario_test_timeout_ms(scenario) == 120000

        expect scenario_name_or_missing("x64-wm-simple-web-check") == "x64-wm-simple-web-check"
        val target = scenario_target(scenario)
        expect target.entry == "examples/simple_os/arch/x86_64/gui_entry_engine2d.spl"
        expect target.output == "build/os/simpleos_wm_simple_web_check_32.elf"
        expect target.qemu_memory == "2G"

        val direct_target = get_wm_simple_web_check_target()
        expect direct_target.entry == target.entry

        val cmd = build_scenario_command(scenario, target.output)
        expect cmd[0] == "qemu-system-x86_64"
        expect (cmd).contains("-kernel")
        expect (cmd).contains("build/os/simpleos_wm_simple_web_check_32.elf")
        expect (cmd).contains("-vga")
        expect (cmd).contains("std")
        expect cmd.contains("virtio-gpu,disable-modern=on,disable-legacy=off") == false

    it "keeps headless targets on stdio and disables the display":
        val target = get_target(Architecture.X86_64)
        val cmd = build_qemu_command(target)
        expect (cmd).contains("-no-user-config")
        expect (cmd).contains("-monitor")
        expect (cmd).contains("none")
        expect (cmd).contains("-net")
        expect (cmd).contains("-serial")
        expect (cmd).contains("stdio")
        expect (cmd).contains("-display")
        expect (cmd).contains("none")

    it "hardens x86_64 scenario launches without disabling explicit network scenarios":
        val desktop = get_scenario("x64-desktop-test")
        if val resolved_desktop = desktop:
            val desktop_cmd = build_scenario_command(resolved_desktop, "build/os/simpleos_desktop_e2e_32.elf")
            expect (desktop_cmd).contains("-no-user-config")
            expect (desktop_cmd).contains("-monitor")
            expect (desktop_cmd).contains("-net")
            expect (desktop_cmd).contains("none")
        else:
            expect "missing" == "x64-desktop-test"

        val net_user = scenario_x64_net_user()
        val net_cmd = build_scenario_command(net_user, "build/os/simpleos_x86_64.elf")
        expect (net_cmd).contains("-no-user-config")
        expect (net_cmd).contains("-monitor")
        expect (net_cmd).contains("-netdev")
        expect net_cmd.contains("-net") == false

        val ssh = scenario_x64_ssh()
        expect scenario_name_or_missing("x64-ssh") == "x64-ssh"
        val ssh_cmd = build_scenario_command(ssh, "build/os/simpleos_x86_64.elf")
        expect (ssh_cmd).contains("user,id=n0,hostfwd=tcp::2222-:22")
        expect ssh_cmd.contains("-net") == false
        expect scenario_test_timeout_ms(ssh) == 120000
        val ssh_target = scenario_target(ssh)
        expect ssh_target.entry == get_ssh_live_target().entry
        expect ssh_target.output == "build/os/simpleos_ssh_live_32.elf"

        val ssh_probe_target = get_ssh_x25519_probe_target()
        expect ssh_probe_target.entry == "examples/simple_os/arch/x86_64/ssh_x25519_probe_entry.spl"
        expect ssh_probe_target.output == "build/os/simpleos_ssh_x25519_probe_32.elf"

    it "keeps gui targets quiet by default":
        val target = get_gui_target()
        val cmd = build_qemu_command(target)
        expect (cmd).contains("-no-user-config")
        expect (cmd).contains("-monitor")
        expect (cmd).contains("-net")
        expect (cmd).contains("-serial")
        expect (cmd).contains("none")
        expect cmd.contains("stdio") == false
        expect cmd.contains("-display") == false

    it "enables gui serial output only in the explicit debug lane":
        val target = get_gui_target()
        val cmd = build_qemu_command_with_options(target, qemu_run_options_debug_gui())
        expect (cmd).contains("-serial")
        expect (cmd).contains("stdio")
        expect cmd.contains("none") == false
        expect cmd.contains("-display") == false

describe "Qemu runner native-build prerequisites":
    it "passes entry closure for the x86_64 OS entry build":
        val target = OsTarget(
            arch: Architecture.X86_64,
            entry: "examples/simple_os/arch/x86_64/os_entry.spl",
            linker_script: "examples/simple_os/arch/x86_64/linker.ld",
            target_triple: "x86_64-unknown-none",
            output: "build/os/simpleos_x86_64.elf",
            qemu_system: "qemu-system-x86_64",
            qemu_machine: "q35",
            qemu_cpu: "qemu64",
            qemu_memory: "128M",
            qemu_bios: "",
            qemu_extra: [],
            gui_mode: false
        )
        val args = os_native_build_args(target, "llvm")
        expect (args).contains("--entry-closure")
        expect (args).contains("--entry")
        expect (args).contains("examples/simple_os/arch/x86_64/os_entry.spl")
        expect args.contains("examples/simple_os/arch/x86_64/wm_entry.spl") == false

    it "defaults RISC-V OS targets to LLVM native-build backend":
        expect default_os_build_backend_for_target(get_target(Architecture.Riscv32)) == "llvm"
        expect default_os_build_backend_for_target(get_target(Architecture.Riscv64)) == "llvm"
        expect default_os_build_backend_for_target(get_target(Architecture.Arm64)) == "llvm"
        expect default_os_build_backend_for_target(get_target(Architecture.Arm32)) == "llvm"

    it "explains when the selected compiler lacks the LLVM backend":
        val stderr = "LLVM backend requested but 'llvm' feature not enabled"
        val hint = native_build_prerequisite_hint("llvm", stderr)
        expect (hint).contains("Rust `llvm` feature")
        expect (hint).contains("LLVM 18")

    it "explains when cranelift cannot initialize a freestanding target":
        val stderr = "Compilation error: Support for this target has not been implemented yet"
        val hint = native_build_prerequisite_hint("cranelift", stderr)
        expect (hint).contains("Cranelift cannot build this freestanding target")
        expect (hint).contains("LLVM-enabled")

    it "adds the generated SSH live marker source to the live build source set":
        val sources = os_native_build_sources(get_ssh_live_target())
        expect (sources).contains("src/os")
        expect (sources).contains("src/lib")
        expect (sources).contains("examples/simple_os")
        expect (sources).contains("build/os/generated")

    it "uses the baremetal bootstrap env for the SSH live target":
        val env_prefix = os_native_build_env_prefix(get_ssh_live_target(), "")
        expect (env_prefix).contains("SIMPLE_BOOTSTRAP=1")
        expect (env_prefix).contains("SIMPLE_LIB=\"$(pwd)/src\"")

    it "uses the baremetal bootstrap env for the SSH X25519 probe target":
        val env_prefix = os_native_build_env_prefix(get_ssh_x25519_probe_target(), "")
        expect (env_prefix).contains("SIMPLE_BOOTSTRAP=1")
        expect (env_prefix).contains("SIMPLE_LIB=\"$(pwd)/src\"")

    it "does not reuse a stale SSH live artifact after a failed build":
        val target = get_ssh_live_target()
        expect rt_dir_create_all("build/os") == true
        expect rt_file_write_text(target.output, "stale-kernel") == true
        expect rt_file_exists(target.output) == true
        expect rt_env_set("SIMPLE_BINARY", "/definitely-missing/simple") == true

        val built = build_os_with_backend(target, "cranelift")

        expect built == false
        expect rt_file_exists(target.output) == false
        expect rt_env_set("SIMPLE_BINARY", "bin/simple") == true

describe "Qemu runner release artifacts":
    it "prefers release disk images before platform and legacy build fixtures":
        val candidates = desktop_disk_image_candidates()
        expect (candidates[0]).starts_with("release/")
        expect candidates[1] == "build/os/fat32-x86_64.img"
        expect candidates[2] == "build/os/fat32.img"

    it "materializes the desktop disk lane at the platform image path":
        val args = desktop_disk_make_script_args("build/os/fat32-x86_64.img")
        expect args[0] == "scripts/make_os_disk.shs"
        expect args[1] == "64"
        expect args[2] == "build/os/fat32-x86_64.img"

    it "resolves the release disk path when the release artifact exists":
        val release_root = "build/test-qemu-release-artifacts"
        val release_path = desktop_release_disk_image_path_in(release_root)
        rt_dir_create_all("{release_root}/x86_64/images")
        expect rt_file_write_text(release_path, "disk-image") == true
        expect desktop_disk_image_path_in(release_root) == release_path

    it "exposes the future installer ISO path hook":
        val iso_path = desktop_release_installer_iso_path()
        expect (iso_path).ends_with(".iso")
        val candidates = desktop_installer_iso_candidates()
        expect candidates[0] == iso_path

describe "Qemu runner desktop UEFI tool app validator":
    it "builds raw-image fallback checks for the migrated tool apps and CLI catalog":
        val cmd = desktop_uefi_disk_image_tool_app_validation_command("build/os/fat32-x86_64.img")
        expect (cmd).contains("if command -v mdir >/dev/null 2>&1; then")
        expect (cmd).contains("if command -v mtype >/dev/null 2>&1; then")
        expect (cmd).contains("::/SYS/APPS/info")
        expect (cmd).contains("::/SYS/APPS/info.smf")
        expect (cmd).contains("::/SYS/APPS/SIMPLECLI.CAT")
        expect (cmd).contains("grep -q '^info|src/app/info/main.spl|smoke|staged$'")
        expect_tool_app_validation_reference(cmd, "simple_browser", "SBROWSMF", "/sys/apps/simple_browser")
        expect_tool_app_validation_reference(cmd, "simple_compiler", "SCOMPSMF", "/sys/apps/simple_compiler")
        expect_tool_app_validation_reference(cmd, "simple_interpreter", "SINTSMF", "/sys/apps/simple_interpreter")
        expect_tool_app_validation_reference(cmd, "simple_loader", "SLOADSMF", "/sys/apps/simple_loader")
        expect_tool_app_validation_reference(cmd, "llvm", "LLVMSMF", "/sys/apps/llvm")
        expect_tool_app_validation_reference(cmd, "rust", "RUSTSMF", "/sys/apps/rust")
        expect (cmd).contains("::/SYS/LLVMMAN.TXT")
        expect (cmd).contains("::/SYS/RUSTMAN.TXT")
        expect (cmd).contains("grep -q 'mode=native-filesystem-app'")
        expect (cmd).contains("grep -q 'lane=x86_64-uefi-hardware'")
        expect (cmd).contains("grep -q 'status=standalone-required'")
        expect (cmd).contains("/usr/share/simpleos/toolchain/llvm/pipeline.step")
        expect (cmd).contains("/usr/share/simpleos/toolchain/rust/pipeline.step")
        expect (cmd).contains("grep -a -q 'SMF'")

    it "accepts the raw-image fallback when mdir and mtype are unavailable but the CLI catalog marker is present":
        val root = "build/test-qemu-tool-app-validator"
        val bin_dir = root + "/bin"
        val img_path = root + "/desktop-uefi-tools.raw"
        expect rt_dir_create_all(bin_dir) == true
        expect shell_exit_code("ln -sf /usr/bin/grep \"" + bin_dir + "/grep\"") == 0
        expect shell_exit_code("ln -sf /usr/bin/strings \"" + bin_dir + "/strings\"") == 0
        expect rt_file_write_text(img_path, desktop_tool_app_fallback_fixture()) == true

        val cmd = "PATH=\"" + bin_dir + "\" " + desktop_uefi_disk_image_tool_app_validation_command(img_path)
        expect shell_exit_code(cmd) == 0

    it "rejects the raw-image fallback when the CLI catalog marker is missing":
        val root = "build/test-qemu-tool-app-validator-missing"
        val bin_dir = root + "/bin"
        val img_path = root + "/desktop-uefi-tools.raw"
        expect rt_dir_create_all(bin_dir) == true
        expect shell_exit_code("ln -sf /usr/bin/grep \"" + bin_dir + "/grep\"") == 0
        expect shell_exit_code("ln -sf /usr/bin/strings \"" + bin_dir + "/strings\"") == 0
        expect rt_file_write_text(img_path, desktop_tool_app_fallback_fixture().replace("info|src/app/info/main.spl|smoke|staged\n", "")) == true

        val cmd = "PATH=\"" + bin_dir + "\" " + desktop_uefi_disk_image_tool_app_validation_command(img_path)
        expect shell_exit_code(cmd) == 1