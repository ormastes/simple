# SimpleOS Smoke Test — Verify actual logic executes
#
# This file tests core OS logic by running it and printing results.
# If you see "ALL SMOKE TESTS PASSED" at the end, the logic works.

use os.kernel.types.memory_types.{PhysAddr, VirtAddr, PageFrame, VmFlags}
use os.kernel.types.task_types.{TaskId, TaskState, TaskPriority, BlockReason}
use os.kernel.types.capability_types.{CapabilityToken, CapabilityKind, CapabilitySet}
use os.kernel.types.fs_types.{FsNode, FsNodeKind, DirEntry}
use os.drivers.input.ps2_keyboard.{scancode_to_key, Key}
use os.drivers.framebuffer.fb_driver.{Color}
use os.drivers.pci.pci.{pci_config_addr, PciDevice, PciBus}
use os.services.init.init_service.{InitService, ServiceDef, RestartPolicy, default_services}

var pass_count: i32 = 0
var fail_count: i32 = 0

fn assert_eq(name: text, actual: i64, expected: i64):
    if actual == expected:
        pass_count = pass_count + 1
    else:
        print "FAIL: {name} — expected {expected}, got {actual}"
        fail_count = fail_count + 1

fn assert_true(name: text, value: bool):
    if value:
        pass_count = pass_count + 1
    else:
        print "FAIL: {name} — expected true, got false"
        fail_count = fail_count + 1

fn assert_false(name: text, value: bool):
    if not value:
        pass_count = pass_count + 1
    else:
        print "FAIL: {name} — expected false, got true"
        fail_count = fail_count + 1

fn assert_text_eq(name: text, actual: text, expected: text):
    if actual == expected:
        pass_count = pass_count + 1
    else:
        print "FAIL: {name} — expected '{expected}', got '{actual}'"
        fail_count = fail_count + 1

# ============================================================================
# Test 1: PageFrame arithmetic
# ============================================================================
print "--- PageFrame arithmetic ---"
val frame = PageFrame(pfn: 42)
assert_eq("pfn 42 → phys addr", frame.to_phys_addr().addr.to_i64(), (42 * 4096).to_i64())

val frame2 = PageFrame.from_phys_addr(PhysAddr(addr: 172032))
assert_eq("phys 172032 → pfn", frame2.pfn.to_i64(), 42)

val frame3 = PageFrame(pfn: 0)
assert_eq("pfn 0 → phys 0", frame3.to_phys_addr().addr.to_i64(), 0)

# ============================================================================
# Test 2: VmFlags constructors
# ============================================================================
print "--- VmFlags constructors ---"
val rw = VmFlags.kernel_rw()
assert_true("kernel_rw present", rw.present)
assert_true("kernel_rw writable", rw.writable)
assert_false("kernel_rw not user", rw.user)

val rx = VmFlags.user_rx()
assert_true("user_rx present", rx.present)
assert_false("user_rx not writable", rx.writable)
assert_true("user_rx user", rx.user)
assert_false("user_rx no NX", rx.no_execute)

val mmio = VmFlags.mmio()
assert_true("mmio write_through", mmio.write_through)
assert_true("mmio cache_disable", mmio.cache_disable)
assert_true("mmio no_execute", mmio.no_execute)

# ============================================================================
# Test 3: CapabilitySet pledge
# ============================================================================
print "--- CapabilitySet pledge ---"
var caps = CapabilitySet.full()
assert_false("not pledged initially", caps.is_pledged)

val token1 = CapabilityToken(kind: CapabilityKind.FileRead(path_prefix: "/"), generation: 1, owner: 0)
val token2 = CapabilityToken(kind: CapabilityKind.NetConnect(port: 443), generation: 1, owner: 0)
caps.caps.push(token1)
caps.caps.push(token2)
assert_eq("has 2 caps", caps.caps.len().to_i64(), 2)

caps.pledge([CapabilityKind.FileRead(path_prefix: "/")])
assert_true("pledged after pledge()", caps.is_pledged)
# After pledge, only FileRead should remain
assert_eq("pledge filtered to 1", caps.caps.len().to_i64(), 1)

# ============================================================================
# Test 4: PS/2 scancode mapping
# ============================================================================
print "--- PS/2 scancode mapping ---"
val key_a = scancode_to_key(0x1E)
assert_true("0x1E → Key.A", key_a == Key.A)

val key_space = scancode_to_key(0x39)
assert_true("0x39 → Key.Space", key_space == Key.Space)

val key_enter = scancode_to_key(0x1C)
assert_true("0x1C → Key.Enter", key_enter == Key.Enter)

val key_unk = scancode_to_key(0xFF)
assert_true("0xFF → Key.Unknown", key_unk == Key.Unknown)

# ============================================================================
# Test 5: Color ARGB packing
# ============================================================================
print "--- Color ARGB packing ---"
val black = Color.black()
assert_eq("black r", black.r.to_i64(), 0)
assert_eq("black g", black.g.to_i64(), 0)
assert_eq("black b", black.b.to_i64(), 0)

val white = Color.white()
assert_eq("white r", white.r.to_i64(), 255)

val red = Color.rgb(255, 0, 0)
assert_eq("red.to_u32 high byte", (red.to_u32() >> 16 & 0xFF).to_i64(), 255)
assert_eq("red.to_u32 green", (red.to_u32() >> 8 & 0xFF).to_i64(), 0)

# ============================================================================
# Test 6: PCI config address
# ============================================================================
print "--- PCI config address ---"
val addr = pci_config_addr(0, 0, 0, 0)
assert_true("enable bit set", (addr >> 31) == 1)

val addr2 = pci_config_addr(1, 2, 3, 0x10)
assert_eq("bus=1", ((addr2 >> 16) & 0xFF).to_i64(), 1)
assert_eq("dev=2", ((addr2 >> 11) & 0x1F).to_i64(), 2)
assert_eq("func=3", ((addr2 >> 8) & 0x07).to_i64(), 3)

# ============================================================================
# Test 7: PciDevice predicates
# ============================================================================
print "--- PciDevice predicates ---"
val dev = PciDevice(bus: 0, device: 1, function: 0, vendor_id: 0x1AF4, device_id: 0x1001,
    class_code: 0x01, subclass: 0x00, prog_if: 0x00, header_type: 0x00,
    bar0: 0, bar1: 0, irq_line: 10)
assert_true("valid device", dev.is_valid())
assert_true("is virtio", dev.is_virtio())
assert_false("not bridge", dev.is_bridge())

val invalid = PciDevice(bus: 0, device: 0, function: 0, vendor_id: 0xFFFF, device_id: 0,
    class_code: 0, subclass: 0, prog_if: 0, header_type: 0, bar0: 0, bar1: 0, irq_line: 0)
assert_false("invalid device", invalid.is_valid())

# ============================================================================
# Test 8: Init service dependency sort
# ============================================================================
print "--- Init service dependency sort ---"
var init = InitService.new()
val svcs = default_services()
for svc in svcs:
    init.register(svc)
val order = init.resolve_start_order()
assert_true("order has entries", order.len() > 0)
# VFS and net have no deps, should come before compositor
# Check that compositor comes after vfs
var vfs_idx: i32 = -1
var comp_idx: i32 = -1
var i = 0
while i < order.len():
    if order[i] == "vfs":
        vfs_idx = i
    if order[i] == "compositor":
        comp_idx = i
    i = i + 1
assert_true("vfs before compositor", vfs_idx < comp_idx)

# ============================================================================
# Results
# ============================================================================
print ""
print "=== SMOKE TEST RESULTS ==="
print "Passed: {pass_count}"
print "Failed: {fail_count}"
if fail_count == 0:
    print "ALL SMOKE TESTS PASSED"
else:
    print "SOME TESTS FAILED"
