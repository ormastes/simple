use std.spec.{describe, it, expect}
use os.toolchain_vfs_probe_contract.{
    toolchain_vfs_probe_required_marker_fragments,
    toolchain_vfs_probe_serial_accepts_completion
}

fn toolchain_vfs_probe_complete_serial() -> text:
    toolchain_vfs_probe_required_marker_fragments().join("\n")

fn toolchain_vfs_probe_without_prepared_task_marker() -> text:
    toolchain_vfs_probe_complete_serial()
        .replace("[fs-exec] spawn:prepared path=/sys/apps/clang pid=1 entry=", "")

describe "toolchain VFS probe completion contract":
    it "accepts serial output with prepared scheduler task markers":
        expect(toolchain_vfs_probe_serial_accepts_completion(toolchain_vfs_probe_complete_serial())).to_equal(true)

    it "rejects serial output that lacks prepared scheduler task evidence":
        expect(toolchain_vfs_probe_serial_accepts_completion(toolchain_vfs_probe_without_prepared_task_marker())).to_equal(false)
