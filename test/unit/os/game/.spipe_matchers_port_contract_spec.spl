use std.spec
use os.game.common.port_contract.{
    game_port_core_capabilities,
    game_port_manifest,
    game_port_marker,
    game_port_probe,
    game_port_profile
}

describe "MDSOC game port contract":
    it "defines the common rebuild profile outside Steam implementation":
        val profile = game_port_profile(2048, "SimpleOS Steam 2048 Smoke", "2048", "https://github.com/gabrielecirulli/2048", "MIT", "/sys/apps/steam_2048")
        expect profile.profile_version == "steamos-rebuild-v1"
        expect profile.rebuild_target == "simpleos-native"
        expect profile.graphics_api == "sdl2_subset"
        expect profile.steam_facade_abi == "simple-steam-sffi-v1"

    it "probes required rebuild capabilities":
        val profile = game_port_profile(2048, "SimpleOS Steam 2048 Smoke", "2048", "https://github.com/gabrielecirulli/2048", "MIT", "/sys/apps/steam_2048")
        val readiness = game_port_probe(profile, game_port_core_capabilities())
        expect readiness.ready == true
        expect readiness.matched_count == readiness.required_count

    it "fails closed when the rebuild toolchain contract is missing":
        val profile = game_port_profile(2048, "SimpleOS Steam 2048 Smoke", "2048", "https://github.com/gabrielecirulli/2048", "MIT", "/sys/apps/steam_2048")
        val readiness = game_port_probe(profile, ["simpleos_smf_packaging"])
        expect readiness.ready == false
        expect (readiness.blocker).contains("simple_native_rebuild")

    it "emits a package manifest and guest marker":
        val profile = game_port_profile(2048, "SimpleOS Steam 2048 Smoke", "2048", "https://github.com/gabrielecirulli/2048", "MIT", "/sys/apps/steam_2048")
        val readiness = game_port_probe(profile, game_port_core_capabilities())
        val manifest = game_port_manifest(profile)
        val marker = game_port_marker(profile, readiness)
        expect (manifest).contains("port_profile=steamos-rebuild-v1")
        expect (manifest).contains("upstream=https://github.com/gabrielecirulli/2048")
        expect (manifest).contains("steam_facade=simple-steam-sffi-v1")
        expect (marker).contains("[game-port]")
        expect (marker).contains("ready=true")