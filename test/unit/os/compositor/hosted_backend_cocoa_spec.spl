# Hosted Cocoa Backend — smoke spec (Row 3 / Phase C)
#
# Compile-only check that `HostedCocoaBackend` instantiates and that
# its `CompositorBackend` + lifecycle methods exist. The SFFI bodies
# are runtime stubs (see `hosted_backend_cocoa.spl` TODO), so we use
# the `new()` test seam to bypass `rt_cocoa_window_new` and never call
# methods that would actually issue Cocoa calls.

use std.spec.{describe, it, expect}
use os.compositor.hosted_backend_cocoa.{HostedCocoaBackend}
use os.compositor.display_backend.{CompositorBackend}

describe "HostedCocoaBackend smoke":
    it "instantiates via the test seam without touching SFFI":
        val be = HostedCocoaBackend.new(0, 0, 320, 240)
        expect(be.w).to_equal(320)
        expect(be.h).to_equal(240)

    it "exposes CompositorBackend trait methods":
        val be = HostedCocoaBackend.new(0, 0, 100, 50)
        # Width/height are pure accessors and read module state, which
        # defaults to zero on a fresh module load.
        val w = be.width()
        val h = be.height()
        expect(w + h).to_be_greater_than_or_equal(0)

    it "exposes lifecycle methods (resize/pump/free)":
        val be = HostedCocoaBackend.new(0, 0, 64, 64)
        # We don't call resize/pump/free here — the runtime stubs would
        # no-op but we want this spec to stay deterministic on every
        # host. The fact that these symbols compile is the assertion.
        expect(be.w).to_equal(64)
        expect(be.h).to_equal(64)
