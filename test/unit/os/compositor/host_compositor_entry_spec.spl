# @cover src/os/compositor/host_compositor_entry.spl 80%
"""
# Host Compositor Entry Spec

**Feature IDs:** N/A
**Category:** Infrastructure
**Difficulty:** 2/5
**Status:** Implemented

## Overview

Unit tests for `host_compositor_entry.spl` — the unified WM startup path
that lets host-side apps (Electron, Browser, Cocoa, Win32) share the same
Compositor + WmService code as SimpleOS.
"""

use std.sspec.*
use os.compositor.host_compositor_entry.{HostBackendKind, HostWmConfig, HostWmHandle, init_host_wm}
use common.window_protocol.geometry.{Size}

# ============================================================================
# HostWmConfig construction
# ============================================================================

describe "HostWmConfig":

    it "constructs with Browser backend":
        val cfg = HostWmConfig(
            backend: HostBackendKind.Browser,
            initial_size: Size.wh(800, 600),
            title: "test-window"
        )
        expect(cfg.title).to_equal("test-window")

    it "constructs with Electron backend":
        val cfg = HostWmConfig(
            backend: HostBackendKind.Electron,
            initial_size: Size.wh(1280, 800),
            title: "electron-test"
        )
        expect(cfg.title).to_equal("electron-test")

# ============================================================================
# init_host_wm — Browser backend (no native FFI needed)
# ============================================================================

describe "init_host_wm Browser":

    it "returns a non-nil HostWmHandle for Browser backend":
        val cfg = HostWmConfig(
            backend: HostBackendKind.Browser,
            initial_size: Size.wh(320, 240),
            title: "browser-wm"
        )
        val result = init_host_wm(cfg)
        expect(result == nil).to_equal(false)

    it "handle.compositor is non-nil for Browser backend":
        val cfg = HostWmConfig(
            backend: HostBackendKind.Browser,
            initial_size: Size.wh(320, 240),
            title: "browser-wm-2"
        )
        val result = init_host_wm(cfg)
        if val h = result:
            expect(true).to_equal(true)
        else:
            expect(false).to_equal(true)

    it "handle.wm is initialized (running=false before init()) for Browser backend":
        val cfg = HostWmConfig(
            backend: HostBackendKind.Browser,
            initial_size: Size.wh(320, 240),
            title: "browser-wm-3"
        )
        val result = init_host_wm(cfg)
        if val h = result:
            expect(h.wm.running).to_equal(false)
        else:
            expect(false).to_equal(true)

# ============================================================================
# init_host_wm — WebCanvas backend (same BrowserCompositorBackend)
# ============================================================================

describe "init_host_wm WebCanvas":

    it "returns a non-nil HostWmHandle for WebCanvas backend":
        val cfg = HostWmConfig(
            backend: HostBackendKind.WebCanvas,
            initial_size: Size.wh(640, 480),
            title: "webcanvas-wm"
        )
        val result = init_host_wm(cfg)
        expect(result == nil).to_equal(false)

# ============================================================================
# init_host_wm — Tui backend (stub, should return nil)
# ============================================================================

describe "init_host_wm Tui stub":

    it "returns nil for Tui backend (not yet implemented)":
        val cfg = HostWmConfig(
            backend: HostBackendKind.Tui,
            initial_size: Size.wh(80, 24),
            title: "tui-wm"
        )
        val result = init_host_wm(cfg)
        expect(result == nil).to_equal(true)
