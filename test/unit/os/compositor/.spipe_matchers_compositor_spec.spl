# Compositor Unit Tests
#
# Tests for WindowSurface, Compositor: construction, create_window,
# destroy_window, focus_window, and Z-order management.

use std.spec
use os.compositor.compositor.{Compositor, WindowSurface}
use os.compositor.cursor.{CursorState}
use os.drivers.framebuffer.fb_driver.{Color}

# ============================================================================
# WindowSurface Construction
# ============================================================================

describe "WindowSurface":
    it "constructs with all fields":
        val surface = WindowSurface(
            id: 1,
            title: "Test Window",
            x: 100,
            y: 50,
            width: 640,
            height: 480,
            visible: true,
            session: nil,
            dirty: false,
            owner_port: 0,
            process_id: 0,
            app_id: ""
        )
        expect surface.id == 1
        expect surface.title == "Test Window"
        expect surface.x == 100
        expect surface.y == 50
        expect surface.width == 640
        expect surface.height == 480
        expect surface.visible == true
        expect surface.dirty == false

    it "has correct title":
        val surface = WindowSurface(
            id: 42,
            title: "My App",
            x: 0, y: 0,
            width: 800, height: 600,
            visible: true, session: nil, dirty: true,
            owner_port: 0,
            process_id: 0,
            app_id: ""
        )
        expect surface.title == "My App"

    it "supports dirty flag":
        val surface = WindowSurface(
            id: 1,
            title: "Dirty",
            x: 0, y: 0,
            width: 100, height: 100,
            visible: true, session: nil, dirty: true,
            owner_port: 0,
            process_id: 0,
            app_id: ""
        )
        expect surface.dirty == true

# ============================================================================
# Compositor Construction
# ============================================================================

describe "Compositor":
    context "when newly created":
        it "starts with empty surfaces":
            val comp = _make_test_compositor()
            expect comp.surfaces.len() == 0

        it "starts with focused_idx at -1":
            val comp = _make_test_compositor()
            expect comp.focused_idx == -1

        it "starts with next_id at 1":
            val comp = _make_test_compositor()
            expect comp.next_id == 1

        it "starts not running":
            val comp = _make_test_compositor()
            expect comp.running == false

# ============================================================================
# Window Creation
# ============================================================================

describe "Compositor create_window":
    it "returns window ID":
        var comp = _make_test_compositor()
        val id = comp.create_window("Test", 0, 0, 640, 480)
        expect id == 1

    it "adds surface to list":
        var comp = _make_test_compositor()
        val id = comp.create_window("Test", 0, 0, 640, 480)
        expect comp.surfaces.len() == 1

    it "increments next_id":
        var comp = _make_test_compositor()
        val id1 = comp.create_window("Win1", 0, 0, 640, 480)
        val id2 = comp.create_window("Win2", 100, 100, 640, 480)
        expect id1 == 1
        expect id2 == 2

    it "creates multiple windows":
        var comp = _make_test_compositor()
        val _ = comp.create_window("A", 0, 0, 640, 480)
        val _ = comp.create_window("B", 100, 0, 640, 480)
        val _ = comp.create_window("C", 200, 0, 640, 480)
        expect comp.surfaces.len() == 3

    it "sets correct title on created surface":
        var comp = _make_test_compositor()
        val id = comp.create_window("My Window", 10, 20, 800, 600)
        expect comp.surfaces[0].title == "My Window"

    it "sets correct position on created surface":
        var comp = _make_test_compositor()
        val id = comp.create_window("Pos", 50, 75, 400, 300)
        expect comp.surfaces[0].x == 50
        expect comp.surfaces[0].y == 75

    it "sets correct size on created surface":
        var comp = _make_test_compositor()
        val id = comp.create_window("Size", 0, 0, 1024, 768)
        expect comp.surfaces[0].width == 1024
        expect comp.surfaces[0].height == 768

    it "creates visible window":
        var comp = _make_test_compositor()
        val id = comp.create_window("Visible", 0, 0, 640, 480)
        expect comp.surfaces[0].visible == true

    it "focuses newly created window":
        var comp = _make_test_compositor()
        val id = comp.create_window("Focus", 0, 0, 640, 480)
        expect comp.focused_idx > -1

# ============================================================================
# Window Identity Metadata
# ============================================================================

describe "Compositor identity metadata":
    it "preserves process and app identity across window updates":
        var comp = _make_test_compositor()
        val id = comp.create_window("Identity", 0, 0, 640, 480)
        comp.set_window_identity(id, 99, "app.identity")
        comp.move_window(id, 20, 30)
        expect comp.window_process_id(id) == 99
        expect comp.window_app_id(id) == "app.identity"
        expect comp.window_count_for_process(99) == 1
        expect comp.windows_for_process(99).len() == 1

# ============================================================================
# Window Destruction
# ============================================================================

describe "Compositor destroy_window":
    it "removes window by ID":
        var comp = _make_test_compositor()
        val id = comp.create_window("ToRemove", 0, 0, 640, 480)
        comp.destroy_window(id)
        expect comp.surfaces.len() == 0

    it "does not remove other windows":
        var comp = _make_test_compositor()
        val id1 = comp.create_window("Keep", 0, 0, 640, 480)
        val id2 = comp.create_window("Remove", 100, 0, 640, 480)
        comp.destroy_window(id2)
        expect comp.surfaces.len() == 1
        expect comp.surfaces[0].title == "Keep"

    it "handles destroying from list of three":
        var comp = _make_test_compositor()
        val id1 = comp.create_window("A", 0, 0, 640, 480)
        val id2 = comp.create_window("B", 100, 0, 640, 480)
        val id3 = comp.create_window("C", 200, 0, 640, 480)
        comp.destroy_window(id2)
        expect comp.surfaces.len() == 2

# ============================================================================
# Window Focus
# ============================================================================

describe "Compositor focus_window":
    it "updates focused_idx":
        var comp = _make_test_compositor()
        val id1 = comp.create_window("A", 0, 0, 640, 480)
        val id2 = comp.create_window("B", 100, 0, 640, 480)
        comp.focus_window(id1)
        # The focused window should be moved to front (last position in Z-order)
        val last_idx = comp.surfaces.len() - 1
        expect comp.surfaces[last_idx].id == id1

    it "brings focused window to front of Z-order":
        var comp = _make_test_compositor()
        val id1 = comp.create_window("Back", 0, 0, 640, 480)
        val id2 = comp.create_window("Front", 100, 0, 640, 480)
        # id2 is currently front; focus id1 should bring it to front
        comp.focus_window(id1)
        val last = comp.surfaces[comp.surfaces.len() - 1]
        expect last.id == id1

    it "updates focused_idx to correct position":
        var comp = _make_test_compositor()
        val id1 = comp.create_window("A", 0, 0, 640, 480)
        val id2 = comp.create_window("B", 100, 0, 640, 480)
        comp.focus_window(id1)
        expect comp.focused_idx > -1
        expect comp.focused_idx < comp.surfaces.len()

# ============================================================================
# Z-Order Management
# ============================================================================

describe "Compositor Z-order":
    it "new windows are added at end (front)":
        var comp = _make_test_compositor()
        val id1 = comp.create_window("Back", 0, 0, 640, 480)
        val id2 = comp.create_window("Front", 100, 0, 640, 480)
        val last = comp.surfaces[comp.surfaces.len() - 1]
        expect last.id == id2

    it "first window is at index 0 (backmost)":
        var comp = _make_test_compositor()
        val id1 = comp.create_window("First", 0, 0, 640, 480)
        val id2 = comp.create_window("Second", 100, 0, 640, 480)
        expect comp.surfaces[0].id == id1

    it "surfaces list length matches window count":
        var comp = _make_test_compositor()
        expect comp.surfaces.len() == 0
        val _ = comp.create_window("A", 0, 0, 640, 480)
        expect comp.surfaces.len() == 1
        val _ = comp.create_window("B", 100, 0, 640, 480)
        expect comp.surfaces.len() == 2

# ============================================================================
# Cycle Focus
# ============================================================================

describe "Compositor cycle_focus":
    it "does nothing with single window":
        var comp = _make_test_compositor()
        val _ = comp.create_window("Only", 0, 0, 640, 480)
        val before = comp.focused_idx
        comp.cycle_focus()
        # Should still be focused on the only window
        expect comp.surfaces.len() == 1

    it "does nothing with no windows":
        var comp = _make_test_compositor()
        comp.cycle_focus()
        expect comp.focused_idx == -1

# ============================================================================
# Helpers
# ============================================================================

fn _make_test_compositor() -> Compositor:
    """Create a minimal Compositor for testing.

    Uses stubbed framebuffer, keyboard, and mouse since we only test
    window management logic, not rendering or input hardware.
    """
    val cursor = CursorState(
        x: 512,
        y: 384,
        visible: true,
        hotspot_x: 1,
        hotspot_y: 1
    )
    return Compositor(
        surfaces: [],
        focused_idx: -1,
        fb: nil,
        keyboard: nil,
        mouse: nil,
        cursor: cursor,
        desktop_bg: Color.rgb(0, 48, 96),
        next_id: 1,
        screen_width: 1024,
        screen_height: 768,
        running: false,
        dragging: false,
        drag_window_id: 0,
        drag_offset_x: 0,
        drag_offset_y: 0
    )