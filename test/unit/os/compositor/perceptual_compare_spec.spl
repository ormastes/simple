# @cover src/os/compositor/perceptual_compare.spl 90%
# @tag: rendering, pixel, perceptual, yiq
#
# Perceptual Compare Specification
#
# Verifies YIQ color-space perceptual distance computation,
# anti-aliasing pixel detection, and full perceptual comparison
# pipeline (Kotsarenko & Ramos 2010 / Vyshniauskas 2009).

use std.spec.{describe, context, it, expect}
use os.compositor.perceptual_compare.{
    yiq_distance, is_antialiased, compare_perceptual, PerceptualResult}

# ============================================================================
# Constants
# ============================================================================

# ARGB pixel values (alpha=0xFF in high byte)
val BLACK: u32   = 0xFF000000
val WHITE: u32   = 0xFFFFFFFF
val RED: u32     = 0xFFFF0000
val GREEN: u32   = 0xFF00FF00
val BLUE: u32    = 0xFF0000FF
val GRAY_128: u32 = 0xFF808080
val GRAY_64: u32  = 0xFF404040
val GRAY_192: u32 = 0xFFC0C0C0

val W: i32 = 4
val H: i32 = 4

# ============================================================================
# Test Group 1: YIQ Distance (AC-4)
# ============================================================================

describe "PerceptualCompare — yiq_distance":

    context "identical pixels":

        it "AC-4: returns zero distance for identical black pixels":
            val dist = yiq_distance(BLACK, BLACK)
            expect(dist).to_equal(0.0)

        it "AC-4: returns zero distance for identical white pixels":
            val dist = yiq_distance(WHITE, WHITE)
            expect(dist).to_equal(0.0)

        it "AC-4: returns zero distance for identical color pixels":
            val dist = yiq_distance(RED, RED)
            expect(dist).to_equal(0.0)

    context "maximally different pixels":

        it "AC-4: returns large distance for black vs white":
            val dist = yiq_distance(BLACK, WHITE)
            expect(dist).to_be_greater_than(0.5)

    context "perceptually similar pixels":

        it "AC-4: returns small distance for nearby grays":
            val dist = yiq_distance(GRAY_128, GRAY_192)
            expect(dist).to_be_less_than(0.5)

    context "color channel differences":

        it "AC-4: red vs green has nonzero distance":
            val dist = yiq_distance(RED, GREEN)
            expect(dist).to_be_greater_than(0.0)

        it "AC-4: red vs blue has nonzero distance":
            val dist = yiq_distance(RED, BLUE)
            expect(dist).to_be_greater_than(0.0)

# ============================================================================
# Test Group 2: Anti-Aliasing Detection (AC-4)
# ============================================================================

describe "PerceptualCompare — is_antialiased":

    context "uniform region":

        it "AC-4: pixel in uniform solid block is not antialiased":
            # 4x4 all-black image
            val pixels = [BLACK, BLACK, BLACK, BLACK,
                          BLACK, BLACK, BLACK, BLACK,
                          BLACK, BLACK, BLACK, BLACK,
                          BLACK, BLACK, BLACK, BLACK]
            val result = is_antialiased(pixels, 1, 1, W, H)
            expect(result).to_equal(false)

    context "sharp edge":

        it "AC-4: pixel at a hard black/white boundary is not antialiased":
            # Left half black, right half white — hard edge at column 2
            val pixels = [BLACK, BLACK, WHITE, WHITE,
                          BLACK, BLACK, WHITE, WHITE,
                          BLACK, BLACK, WHITE, WHITE,
                          BLACK, BLACK, WHITE, WHITE]
            val result = is_antialiased(pixels, 1, 1, W, H)
            expect(result).to_equal(false)

    context "anti-aliased edge":

        it "AC-4: pixel with intermediate gray neighbors along edge is detected as AA":
            # Row pattern: BLACK, GRAY, WHITE — gray is AA between black and white
            val pixels = [BLACK, BLACK,    WHITE,    WHITE,
                          BLACK, GRAY_64,  GRAY_192, WHITE,
                          BLACK, GRAY_128, GRAY_192, WHITE,
                          BLACK, BLACK,    WHITE,    WHITE]
            val result = is_antialiased(pixels, 1, 1, W, H)
            expect(result).to_equal(true)

    context "corner pixels":

        it "AC-4: corner pixel (0,0) does not crash":
            val pixels = [WHITE, BLACK, BLACK, BLACK,
                          BLACK, BLACK, BLACK, BLACK,
                          BLACK, BLACK, BLACK, BLACK,
                          BLACK, BLACK, BLACK, BLACK]
            val result = is_antialiased(pixels, 0, 0, W, H)
            # Corner with fewer neighbors — should not crash
            expect(result).to_equal(false)

# ============================================================================
# Test Group 3: Full Perceptual Comparison (AC-4)
# ============================================================================

describe "PerceptualCompare — compare_perceptual":

    context "identical buffers":

        it "AC-4: identical buffers yield 100% match and zero mismatches":
            val a = [BLACK, BLACK, BLACK, BLACK,
                     BLACK, BLACK, BLACK, BLACK,
                     BLACK, BLACK, BLACK, BLACK,
                     BLACK, BLACK, BLACK, BLACK]
            val b = [BLACK, BLACK, BLACK, BLACK,
                     BLACK, BLACK, BLACK, BLACK,
                     BLACK, BLACK, BLACK, BLACK,
                     BLACK, BLACK, BLACK, BLACK]
            val result = compare_perceptual(a, b, W, H, 0.1, true)
            expect(result.mismatched_pixels).to_equal(0)
            expect(result.total_pixels).to_equal(16)
            expect(result.match_percentage).to_equal(10000)

    context "completely different buffers":

        it "AC-4: all-black vs all-white yields zero or near-zero match":
            val a = [BLACK, BLACK, BLACK, BLACK,
                     BLACK, BLACK, BLACK, BLACK,
                     BLACK, BLACK, BLACK, BLACK,
                     BLACK, BLACK, BLACK, BLACK]
            val b = [WHITE, WHITE, WHITE, WHITE,
                     WHITE, WHITE, WHITE, WHITE,
                     WHITE, WHITE, WHITE, WHITE,
                     WHITE, WHITE, WHITE, WHITE]
            val result = compare_perceptual(a, b, W, H, 0.1, true)
            expect(result.mismatched_pixels).to_equal(16)
            expect(result.match_percentage).to_equal(0)

    context "threshold sensitivity":

        it "AC-4: high threshold makes near-similar pixels match":
            val a = [GRAY_128, GRAY_128, GRAY_128, GRAY_128,
                     GRAY_128, GRAY_128, GRAY_128, GRAY_128,
                     GRAY_128, GRAY_128, GRAY_128, GRAY_128,
                     GRAY_128, GRAY_128, GRAY_128, GRAY_128]
            val b = [GRAY_192, GRAY_192, GRAY_192, GRAY_192,
                     GRAY_192, GRAY_192, GRAY_192, GRAY_192,
                     GRAY_192, GRAY_192, GRAY_192, GRAY_192,
                     GRAY_192, GRAY_192, GRAY_192, GRAY_192]
            # Very high threshold — should match despite difference
            val result = compare_perceptual(a, b, W, H, 1.0, true)
            expect(result.mismatched_pixels).to_equal(0)

        it "AC-4: zero threshold makes any difference a mismatch":
            val a = [GRAY_128, GRAY_128, GRAY_128, GRAY_128,
                     GRAY_128, GRAY_128, GRAY_128, GRAY_128,
                     GRAY_128, GRAY_128, GRAY_128, GRAY_128,
                     GRAY_128, GRAY_128, GRAY_128, GRAY_128]
            val b = [GRAY_192, GRAY_192, GRAY_192, GRAY_192,
                     GRAY_192, GRAY_192, GRAY_192, GRAY_192,
                     GRAY_192, GRAY_192, GRAY_192, GRAY_192,
                     GRAY_192, GRAY_192, GRAY_192, GRAY_192]
            val result = compare_perceptual(a, b, W, H, 0.0, true)
            expect(result.mismatched_pixels).to_be_greater_than(0)

    context "AA exclusion":

        it "AC-4: include_aa=false excludes AA pixels from mismatch count":
            # Craft image with an AA edge
            val a = [BLACK, BLACK,    WHITE,    WHITE,
                     BLACK, GRAY_64,  GRAY_192, WHITE,
                     BLACK, GRAY_128, GRAY_192, WHITE,
                     BLACK, BLACK,    WHITE,    WHITE]
            val b = [BLACK, BLACK,    WHITE,    WHITE,
                     BLACK, GRAY_128, GRAY_128, WHITE,
                     BLACK, GRAY_192, GRAY_128, WHITE,
                     BLACK, BLACK,    WHITE,    WHITE]
            val with_aa = compare_perceptual(a, b, W, H, 0.1, true)
            val without_aa = compare_perceptual(a, b, W, H, 0.1, false)
            # Excluding AA should report fewer mismatches (or equal)
            val fewer_or_equal = without_aa.mismatched_pixels <= with_aa.mismatched_pixels
            expect(fewer_or_equal).to_equal(true)

        it "AC-4: aa_pixels count is reported in result":
            val a = [BLACK, GRAY_128, WHITE, WHITE,
                     BLACK, GRAY_128, WHITE, WHITE,
                     BLACK, GRAY_128, WHITE, WHITE,
                     BLACK, GRAY_128, WHITE, WHITE]
            val b = [BLACK, GRAY_64,  WHITE, WHITE,
                     BLACK, GRAY_64,  WHITE, WHITE,
                     BLACK, GRAY_64,  WHITE, WHITE,
                     BLACK, GRAY_64,  WHITE, WHITE]
            val result = compare_perceptual(a, b, W, H, 0.1, false)
            # aa_pixels should be non-negative
            val non_neg = result.aa_pixels >= 0
            expect(non_neg).to_equal(true)
