# @cover src/os/compositor/qemu_capture.spl 80%
# @tag: rendering, qemu, capture
#
# QEMU Capture Specification
#
# Verifies QEMU screenshot capture: in-process via BrowserCompositorBackend
# and external via QMP screendump. Both paths return ARGB [u32] CaptureResult.

use std.spec.{describe, context, it, expect}
use os.compositor.qemu_capture.{
    capture_qemu_inprocess, capture_qemu_vm}
use os.compositor.electron_capture.{CaptureResult}
use os.compositor.wm_scene.{standard_wm_scene}

# ============================================================================
# Constants
# ============================================================================

val W: i32 = 800
val H: i32 = 600

# ============================================================================
# Test Group 1: In-Process Capture (AC-3)
# ============================================================================

describe "QemuCapture — capture_qemu_inprocess":

    context "basic capture":

        it "AC-3: in-process capture returns CaptureResult with shared compositor backend name":
            val scene = standard_wm_scene(W, H)
            val result = capture_qemu_inprocess(scene)
            expect(result.backend_name).to_equal("browser_compositor")

        it "AC-3: in-process capture returns correct dimensions":
            val scene = standard_wm_scene(W, H)
            val result = capture_qemu_inprocess(scene)
            expect(result.width).to_equal(W)
            expect(result.height).to_equal(H)

        it "AC-3: in-process capture returns non-empty pixel buffer":
            val scene = standard_wm_scene(W, H)
            val result = capture_qemu_inprocess(scene)
            expect(result.pixels.len()).to_be_greater_than(0)

        it "AC-3: in-process capture pixel buffer has correct size":
            val scene = standard_wm_scene(W, H)
            val result = capture_qemu_inprocess(scene)
            val expected_len = W * H
            expect(result.pixels.len().to_i32()).to_equal(expected_len)

        it "AC-3: in-process capture reports success":
            val scene = standard_wm_scene(W, H)
            val result = capture_qemu_inprocess(scene)
            expect(result.success).to_equal(true)

# ============================================================================
# Test Group 2: VM Capture via QMP (AC-3)
# ============================================================================

describe "QemuCapture — capture_qemu_vm":

    context "QMP screendump capture":

        it "AC-3: VM capture with invalid socket returns error":
            val result = capture_qemu_vm("/nonexistent/qmp.sock", "/tmp/test_screendump.png")
            expect(result.success).to_equal(false)

        it "AC-3: VM capture with invalid socket has error message":
            val result = capture_qemu_vm("/nonexistent/qmp.sock", "/tmp/test_screendump.png")
            val has_error = result.error.len() > 0
            expect(has_error).to_equal(true)

        it "AC-3: VM capture result has backend_name 'qemu_vm'":
            val result = capture_qemu_vm("/nonexistent/qmp.sock", "/tmp/test_screendump.png")
            expect(result.backend_name).to_equal("qemu_vm")

# ============================================================================
# Test Group 3: Capture Result Uniformity (AC-3)
# ============================================================================

describe "QemuCapture — result uniformity":

    context "both paths return same CaptureResult type":

        it "AC-3: in-process and VM results both have width, height, pixels fields":
            val scene = standard_wm_scene(W, H)
            val inprocess = capture_qemu_inprocess(scene)
            val vm = capture_qemu_vm("/nonexistent/qmp.sock", "/tmp/test.png")
            # Both should have the same structural fields
            val both_have_width = inprocess.width > 0 or vm.width >= 0
            expect(both_have_width).to_equal(true)
