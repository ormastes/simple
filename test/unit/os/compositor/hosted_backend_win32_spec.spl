# Hosted Win32 Backend — compile-only trait coverage spec (Row 3 / Phase C)
#
# Smoke + trait method presence checks for `HostedWin32Backend`.
# The Win32 backend uses typed geometry wrappers (Rect, Point, Argb32,
# Alpha, BlurRadius) from `std.common.window_protocol.geometry`.
# All method calls that would reach SFFI are guarded by `if false: ...`
# so the runtime stubs are never invoked.

use std.spec.{describe, it, expect}
use os.compositor.hosted_backend_win32.{HostedWin32Backend}
use os.compositor.display_backend.{CompositorBackend, CompositorGlassCapable}
use std.common.window_protocol.geometry.{Px, Point, Rect, Argb32, Alpha, BlurRadius}

describe "HostedWin32Backend smoke":
    """Compile-only checks that HostedWin32Backend implements CompositorBackend
    and CompositorGlassCapable with the geometry wrapper types. All SFFI-reaching
    calls are guarded by if false."""

    it "instantiates via the test seam without touching SFFI":
        """Verify new() constructs a backend with the given w/h fields set."""
        val be = HostedWin32Backend.new(0, 0, 320, 240)
        expect(be.w).to_equal(320)
        expect(be.h).to_equal(240)

    it "exposes CompositorBackend trait methods":
        val be = HostedWin32Backend.new(0, 0, 100, 50)
        val w = be.width()
        val h = be.height()
        expect(true).to_be_true()

    it "exposes lifecycle methods (resize/pump/free)":
        val be = HostedWin32Backend.new(0, 0, 64, 64)
        # Symbols compiling is the assertion — we don't invoke the
        # SFFI stubs to keep the spec host-agnostic.
        expect(be.w).to_equal(64)
        expect(be.h).to_equal(64)

    it "CompositorBackend drawing methods exist (compile-only)":
        val be = HostedWin32Backend.new(0, 0, 128, 128)
        if false:
            val white = Argb32(value: 0xFFFFFFFF)
            val black = Argb32(value: 0xFF000000)
            val r = Rect.xywh(0, 0, 64, 64)
            val p = Point.xy(0, 0)
            be.clear(black)
            be.fill_rect(r, white)
            be.draw_text(p, "x", white, black)
            val ch: u8 = 65
            be.draw_char_8x16(p, ch, white, black)
            be.put_pixel(p, white)
            be.present()
            be.present_rect(r)
        expect(true).to_be_true()

    it "as_glass_capable returns non-none (compile-only)":
        val be = HostedWin32Backend.new(0, 0, 128, 128)
        if false:
            val gc = be.as_glass_capable()
        expect(true).to_be_true()

    it "CompositorGlassCapable methods exist (compile-only)":
        val be = HostedWin32Backend.new(0, 0, 128, 128)
        if false:
            val r = Rect.xywh(0, 0, 64, 64)
            val p = Point.xy(4, 4)
            val color = Argb32(value: 0x80FFFFFF)
            val alpha = Alpha(value: 128)
            val radius = BlurRadius(value: 4)
            be.blend_rect(r, color, alpha)
            be.blur_region(r, radius)
            be.gradient_v(r, Argb32(value: 0xFF000000), Argb32(value: 0xFFFFFFFF))
            val _px = be.read_pixel(p)
        expect(true).to_be_true()

    it "lifecycle resize and pump methods exist (compile-only)":
        val be = HostedWin32Backend.new(0, 0, 64, 64)
        if false:
            val _ok = be.resize(128, 128)
            val _ev = be.pump()
            be.free()
        expect(true).to_be_true()
