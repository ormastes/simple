#![allow(unnamed_duplicate_typed_args)]
# @tag: compositor, gpu, virtio_gpu, glass
# @cover src/os/compositor/display_backend.spl 40%
#
# D2 Phase 2 Gpu — GpuCompositorBackend native CompositorGlassCapable.
#
# VirtIO-GPU is an MMIO-backed driver: any actual pixel op derefs
# `fb_virt`, which is only safe inside a baremetal QEMU image. This spec
# is therefore COMPILE-ONLY — it proves the `CompositorGlassCapable` impl
# is wired through `glass_dispatch.cap_*` for the Gpu backend without
# touching the DMA buffer at runtime. The glass ops are guarded by a
# never-taken `if false:` branch so the type-checker still walks every
# call site exactly as it would for a real invocation.
#
# End-to-end behavioural coverage lives under
# `examples/simple_os/arch/*/gpu_render_test_entry.spl` (integration,
# runs against real QEMU virtio-GPU).

use std.spec.{describe, context, it, expect}
use os.drivers.virtio.virtio_gpu.{VirtioGpuDriver}
use os.compositor.display_backend.{GpuCompositorBackend, CompositorGlassCapable}
use os.compositor.glass_dispatch.{cap_blend_rect, cap_blur_region, cap_gradient_v, cap_read_pixel}

# ============================================================================
# Helpers
# ============================================================================

fn _make_backend() -> GpuCompositorBackend:
    """Build a zero-initialised GpuCompositorBackend.

    The underlying VirtioGpuDriver is NOT initialised against real
    hardware — calling any pixel op on the returned backend would MMIO
    into `fb_virt = 0` and crash. Every call site below MUST be guarded
    by a never-taken branch.
    """
    val gpu = VirtioGpuDriver.new()
    GpuCompositorBackend.new(gpu)

# ============================================================================
# Tests
# ============================================================================

describe "GpuCompositorBackend CompositorGlassCapable (D2 Phase 2 Gpu)":
    """VirtIO-GPU path glass dispatch — native, no rt_gui_*."""

    context "as_glass_capable":
        """Backend opts back in to the glass subtrait in Phase 2 Gpu."""

        it "opts in (returns non-nil, unlike Phase 1)":
            """Phase 1 returned nil; Phase 2 Gpu must return self."""
            val backend = _make_backend()
            val cap = backend.as_glass_capable()
            expect(cap != nil).to_be_true()

    context "cap_blend_rect dispatch":
        """Compile-only: proves the generic cap_blend_rect accepts the
        Gpu backend as a CompositorBackend and routes through its native
        CompositorGlassCapable impl."""

        it "type-checks against the Gpu backend":
            val backend = _make_backend()
            if false:
                cap_blend_rect(backend, 0, 0, 4, 4, 0xFF7F7F7Fu32, 128u8)
            expect(true).to_be_true()

    context "cap_blur_region dispatch":

        it "type-checks against the Gpu backend":
            val backend = _make_backend()
            if false:
                cap_blur_region(backend, 0, 0, 4, 4, 2u32)
            expect(true).to_be_true()

    context "cap_gradient_v dispatch":

        it "type-checks against the Gpu backend":
            val backend = _make_backend()
            if false:
                cap_gradient_v(backend, 0, 0, 4, 4, 0xFF000000u32, 0xFFFFFFFFu32)
            expect(true).to_be_true()

    context "cap_read_pixel dispatch":

        it "type-checks against the Gpu backend":
            val backend = _make_backend()
            if false:
                val _px = cap_read_pixel(backend, 0, 0)
            expect(true).to_be_true()
