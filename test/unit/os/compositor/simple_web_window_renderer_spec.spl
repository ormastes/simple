use std.spec.*
use os.compositor.browser_compositor_backend.{BrowserCompositorBackend}
use os.compositor.simple_web_window_renderer.{render_simple_web_app_content, simple_web_app_html}

fn _count_changed(pixels: [u32], bg: u32) -> i32:
    var count: i32 = 0
    var idx: i32 = 0
    while idx < pixels.len():
        if pixels[idx] != bg:
            count = count + 1
        idx = idx + 1
    count

describe "Simple Web compositor adapter":

    it "provides app HTML for the SimpleOS browser window":
        val html = simple_web_app_html("Browser", "")
        expect(html.contains("about:network")).to_equal(true)
        expect(html.contains("Simple Web")).to_equal(true)

    it "blits Simple Web rendered pixels into a compositor backend":
        var backend = BrowserCompositorBackend.with_color(96, 64, 0xFF000000)
        render_simple_web_app_content(backend, "Browser", 8, 6, 64, 40, "")
        val pixels = backend.get_pixel_buffer()

        expect(pixels.len()).to_equal(96 * 64)
        expect(_count_changed(pixels, 0xFF000000)).to_be_greater_than(0)
        expect(pixels[0]).to_equal(0xFF000000)
