"""
# JS Values Specification

**Category:** Stdlib
**Difficulty:** 1/5
**Status:** Draft

## Overview

Tests for JsVal, JsObj, JsHeap, and type coercion helpers in
`src/lib/gc_async_mut/gpu/browser_engine/js/values.spl`.

## Key Behaviors

- JsVal enum covers Undefined, Null, Bool, Num, Str, Obj, Func
- JsObj supports get/set/delete property operations
- JsHeap allocates objects and functions with auto-incrementing IDs
- Type coercion: js_to_bool, js_to_number, js_to_string, js_typeof
- Strict equality: js_strict_equal
"""

use std.spec.*
use std.gc_async_mut.gpu.browser_engine.js.values.{
    JsVal, JsObj, JsProp, JsFunc, JsHeap,
    js_to_bool, js_to_number, js_to_string, js_typeof, js_strict_equal
}

# ===========================================================================
# Helper functions
# ===========================================================================

fn _make_heap() -> JsHeap:
    return JsHeap.new()

fn _to_bool_result(v: JsVal) -> bool:
    return js_to_bool(v)

fn _to_string_result(v: JsVal) -> text:
    return js_to_string(v)

fn _typeof_result(v: JsVal) -> text:
    return js_typeof(v)

fn _strict_eq_result(a: JsVal, b: JsVal) -> bool:
    return js_strict_equal(a, b)

fn _obj_get_prop(key: text) -> JsVal:
    var obj = JsObj.create(1)
    obj.set_prop("name", JsVal.Str("test"))
    obj.set_prop("count", JsVal.Num(42.0))
    return obj.get_prop(key)

fn _obj_has_prop_check(key: text) -> bool:
    var obj = JsObj.create(1)
    obj.set_prop("x", JsVal.Num(1.0))
    return obj.has_prop(key)

fn _obj_delete_prop_check() -> bool:
    var obj = JsObj.create(1)
    obj.set_prop("a", JsVal.Num(1.0))
    obj.set_prop("b", JsVal.Num(2.0))
    obj.delete_prop("a")
    return obj.has_prop("a")

fn _heap_alloc_object_id() -> i64:
    var heap = JsHeap.new()
    return heap.alloc_object()

fn _heap_alloc_two_objects() -> i64:
    var heap = JsHeap.new()
    heap.alloc_object()
    return heap.alloc_object()

fn _heap_set_get_prop() -> text:
    var heap = JsHeap.new()
    val id = heap.alloc_object()
    heap.set_object_prop(id, "hello", JsVal.Str("world"))
    val v = heap.get_object_prop(id, "hello")
    return js_to_string(v)

# ===========================================================================
# Specs
# ===========================================================================

describe "JsVal type coercion":
    describe "js_to_bool":
        it "Undefined is falsy":
            val result = _to_bool_result(JsVal.Undefined)
            expect(result).to_equal(false)

        it "Null is falsy":
            val result = _to_bool_result(JsVal.Null)
            expect(result).to_equal(false)

        it "Bool true is truthy":
            val result = _to_bool_result(JsVal.Bool(true))
            expect(result).to_equal(true)

        it "Bool false is falsy":
            val result = _to_bool_result(JsVal.Bool(false))
            expect(result).to_equal(false)

        it "Num 0.0 is falsy":
            val result = _to_bool_result(JsVal.Num(0.0))
            expect(result).to_equal(false)

        it "Num 1.0 is truthy":
            val result = _to_bool_result(JsVal.Num(1.0))
            expect(result).to_equal(true)

        it "empty string is falsy":
            val result = _to_bool_result(JsVal.Str(""))
            expect(result).to_equal(false)

        it "non-empty string is truthy":
            val result = _to_bool_result(JsVal.Str("hello"))
            expect(result).to_equal(true)

    describe "js_to_string":
        it "Undefined becomes 'undefined'":
            val result = _to_string_result(JsVal.Undefined)
            expect(result).to_equal("undefined")

        it "Null becomes 'null'":
            val result = _to_string_result(JsVal.Null)
            expect(result).to_equal("null")

        it "Bool true becomes 'true'":
            val result = _to_string_result(JsVal.Bool(true))
            expect(result).to_equal("true")

        it "Bool false becomes 'false'":
            val result = _to_string_result(JsVal.Bool(false))
            expect(result).to_equal("false")

    describe "js_typeof":
        it "Undefined is 'undefined'":
            val result = _typeof_result(JsVal.Undefined)
            expect(result).to_equal("undefined")

        it "Null is 'object'":
            val result = _typeof_result(JsVal.Null)
            expect(result).to_equal("object")

        it "Bool is 'boolean'":
            val result = _typeof_result(JsVal.Bool(true))
            expect(result).to_equal("boolean")

        it "Num is 'number'":
            val result = _typeof_result(JsVal.Num(42.0))
            expect(result).to_equal("number")

        it "Str is 'string'":
            val result = _typeof_result(JsVal.Str("hi"))
            expect(result).to_equal("string")

        it "Func is 'function'":
            val result = _typeof_result(JsVal.Func(1))
            expect(result).to_equal("function")

    describe "js_strict_equal":
        it "Undefined equals Undefined":
            val result = _strict_eq_result(JsVal.Undefined, JsVal.Undefined)
            expect(result).to_equal(true)

        it "Null equals Null":
            val result = _strict_eq_result(JsVal.Null, JsVal.Null)
            expect(result).to_equal(true)

        it "Undefined does not equal Null":
            val result = _strict_eq_result(JsVal.Undefined, JsVal.Null)
            expect(result).to_equal(false)

        it "same numbers are equal":
            val result = _strict_eq_result(JsVal.Num(5.0), JsVal.Num(5.0))
            expect(result).to_equal(true)

        it "different numbers are not equal":
            val result = _strict_eq_result(JsVal.Num(5.0), JsVal.Num(6.0))
            expect(result).to_equal(false)

        it "same strings are equal":
            val result = _strict_eq_result(JsVal.Str("abc"), JsVal.Str("abc"))
            expect(result).to_equal(true)

describe "JsObj":
    describe "property access":
        it "get_prop returns set value":
            val v = _obj_get_prop("name")
            expect(js_to_string(v)).to_equal("test")

        it "get_prop returns Undefined for missing key":
            val v = _obj_get_prop("missing")
            expect(js_typeof(v)).to_equal("undefined")

        it "has_prop returns true for existing key":
            val result = _obj_has_prop_check("x")
            expect(result).to_equal(true)

        it "has_prop returns false for missing key":
            val result = _obj_has_prop_check("y")
            expect(result).to_equal(false)

        it "delete_prop removes the key":
            val result = _obj_delete_prop_check()
            expect(result).to_equal(false)

describe "JsHeap":
    describe "allocation":
        it "first alloc returns id 1":
            val id = _heap_alloc_object_id()
            expect(id).to_equal(1)

        it "second alloc returns id 2":
            val id = _heap_alloc_two_objects()
            expect(id).to_equal(2)

        it "set and get object prop works":
            val result = _heap_set_get_prop()
            expect(result).to_equal("world")
