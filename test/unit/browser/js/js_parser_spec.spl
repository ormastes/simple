"""
# JS Parser Specification

**Category:** Stdlib
**Difficulty:** 2/5
**Status:** Draft

## Overview

Tests for JsParse recursive-descent parser in
`src/lib/gc_async_mut/gpu/browser_engine/js/parser.spl`.

## Key Behaviors

- Parses expressions: literals, binary ops, unary ops, calls, member access
- Parses statements: var decl, if/else, while, for, return, function decl
- Produces JsProgram with correct statement count
"""

use std.spec.*
use std.gc_async_mut.gpu.browser_engine.js.parser.{js_parse}
use std.gc_async_mut.gpu.browser_engine.js.ast.{JsExpr, JsStmt, JsProgram}

# ===========================================================================
# Helper functions
# ===========================================================================

fn _parse_stmt_count(source: text) -> i32:
    val program = js_parse(source)
    return program.body.len()

fn _parse_first_stmt(source: text) -> JsStmt:
    val program = js_parse(source)
    return program.body[0]

fn _is_var_decl(source: text) -> bool:
    val stmt = _parse_first_stmt(source)
    match stmt:
        JsStmt.VarDecl(_, _, _) => return true
        _ => return false

fn _is_func_decl(source: text) -> bool:
    val stmt = _parse_first_stmt(source)
    match stmt:
        JsStmt.FuncDecl(_, _, _) => return true
        _ => return false

fn _is_if_stmt(source: text) -> bool:
    val stmt = _parse_first_stmt(source)
    match stmt:
        JsStmt.IfStmt(_, _, _) => return true
        _ => return false

fn _is_while_stmt(source: text) -> bool:
    val stmt = _parse_first_stmt(source)
    match stmt:
        JsStmt.WhileStmt(_, _) => return true
        _ => return false

fn _is_for_stmt(source: text) -> bool:
    val stmt = _parse_first_stmt(source)
    match stmt:
        JsStmt.ForStmt(_, _, _, _) => return true
        _ => return false

fn _is_return_stmt(source: text) -> bool:
    val stmt = _parse_first_stmt(source)
    match stmt:
        JsStmt.ReturnStmt(_) => return true
        _ => return false

fn _is_expr_stmt(source: text) -> bool:
    val stmt = _parse_first_stmt(source)
    match stmt:
        JsStmt.ExprStmt(_) => return true
        _ => return false

fn _is_break_stmt(source: text) -> bool:
    val stmt = _parse_first_stmt(source)
    match stmt:
        JsStmt.BreakStmt => return true
        _ => return false

fn _is_try_stmt(source: text) -> bool:
    val stmt = _parse_first_stmt(source)
    match stmt:
        JsStmt.TryCatch(_, _, _, _) => return true
        _ => return false

# ===========================================================================
# Specs
# ===========================================================================

describe "JsParse":
    describe "empty program":
        it "empty string has 0 statements":
            val count = _parse_stmt_count("")
            expect(count).to_equal(0)

    describe "variable declarations":
        it "var x = 5 is VarDecl":
            val result = _is_var_decl("var x = 5;")
            expect(result).to_equal(true)

        it "let y = 10 is VarDecl":
            val result = _is_var_decl("let y = 10;")
            expect(result).to_equal(true)

        it "const z = 20 is VarDecl":
            val result = _is_var_decl("const z = 20;")
            expect(result).to_equal(true)

    describe "function declarations":
        it "function foo() {} is FuncDecl":
            val result = _is_func_decl("function foo() {}")
            expect(result).to_equal(true)

        it "function with params is FuncDecl":
            val result = _is_func_decl("function add(a, b) { return a + b; }")
            expect(result).to_equal(true)

    describe "control flow":
        it "if statement is IfStmt":
            val result = _is_if_stmt("if (x > 0) { y = 1; }")
            expect(result).to_equal(true)

        it "while statement is WhileStmt":
            val result = _is_while_stmt("while (i < 10) { i++; }")
            expect(result).to_equal(true)

        it "for statement is ForStmt":
            val result = _is_for_stmt("for (var i = 0; i < 10; i++) {}")
            expect(result).to_equal(true)

        it "return is ReturnStmt":
            val result = _is_return_stmt("return 42;")
            expect(result).to_equal(true)

        it "break is BreakStmt":
            val result = _is_break_stmt("break;")
            expect(result).to_equal(true)

    describe "expression statements":
        it "assignment is ExprStmt":
            val result = _is_expr_stmt("x = 5;")
            expect(result).to_equal(true)

        it "function call is ExprStmt":
            val result = _is_expr_stmt("foo();")
            expect(result).to_equal(true)

    describe "try/catch":
        it "try/catch is TryCatch":
            val result = _is_try_stmt("try { x = 1; } catch (e) { y = 2; }")
            expect(result).to_equal(true)

    describe "multiple statements":
        it "two var decls give 2 statements":
            val count = _parse_stmt_count("var x = 1; var y = 2;")
            expect(count).to_equal(2)

        it "function + call give 2 statements":
            val count = _parse_stmt_count("function foo() {} foo();")
            expect(count).to_equal(2)
