"""
# JS Lexer Specification

**Category:** Stdlib
**Difficulty:** 1/5
**Status:** Draft

## Overview

Tests for JsLex tokenizer in
`src/lib/gc_async_mut/gpu/browser_engine/js/lexer.spl`.

## Key Behaviors

- Tokenizes numbers, strings, identifiers, keywords, operators, punctuation
- Skips whitespace and comments
- Produces EOF at end of input
"""

use std.spec.*
use std.gc_async_mut.gpu.browser_engine.js.lexer.{JsLex, JsTok, JsTokKind, js_tokenize}

# ===========================================================================
# Helper functions
# ===========================================================================

fn _tokenize(source: text) -> [JsTok]:
    return js_tokenize(source)

fn _first_kind(source: text) -> JsTokKind:
    val tokens = js_tokenize(source)
    return tokens[0].kind

fn _first_value(source: text) -> text:
    val tokens = js_tokenize(source)
    return tokens[0].value

fn _token_count(source: text) -> i32:
    val tokens = js_tokenize(source)
    return tokens.len()

# ===========================================================================
# Specs
# ===========================================================================

describe "JsLex":
    describe "empty input":
        it "produces single EOF token":
            val count = _token_count("")
            expect(count).to_equal(1)

    describe "number literals":
        it "tokenizes integer":
            val v = _first_value("42")
            expect(v).to_equal("42")

        it "tokenizes float":
            val v = _first_value("3.14")
            expect(v).to_equal("3.14")

        it "kind is Number":
            val k = _first_kind("42")
            expect(k).to_equal(JsTokKind.Number)

    describe "string literals":
        it "tokenizes double-quoted string":
            val v = _first_value("\"hello\"")
            expect(v).to_equal("hello")

        it "tokenizes single-quoted string":
            val v = _first_value("'world'")
            expect(v).to_equal("world")

        it "kind is String":
            val k = _first_kind("\"test\"")
            expect(k).to_equal(JsTokKind.String)

    describe "identifiers":
        it "tokenizes simple identifier":
            val v = _first_value("myVar")
            expect(v).to_equal("myVar")

        it "kind is Ident":
            val k = _first_kind("myVar")
            expect(k).to_equal(JsTokKind.Ident)

        it "tokenizes identifier starting with underscore":
            val v = _first_value("_private")
            expect(v).to_equal("_private")

        it "tokenizes identifier starting with dollar":
            val v = _first_value("$elem")
            expect(v).to_equal("$elem")

    describe "keywords":
        it "var is Keyword":
            val k = _first_kind("var")
            expect(k).to_equal(JsTokKind.Keyword)

        it "function is Keyword":
            val k = _first_kind("function")
            expect(k).to_equal(JsTokKind.Keyword)

        it "if is Keyword":
            val k = _first_kind("if")
            expect(k).to_equal(JsTokKind.Keyword)

        it "return is Keyword":
            val k = _first_kind("return")
            expect(k).to_equal(JsTokKind.Keyword)

    describe "boolean and null":
        it "true is Boolean":
            val k = _first_kind("true")
            expect(k).to_equal(JsTokKind.Boolean)

        it "false value is 'false'":
            val v = _first_value("false")
            expect(v).to_equal("false")

        it "null is Null":
            val k = _first_kind("null")
            expect(k).to_equal(JsTokKind.Null)

    describe "operators":
        it "=== is EqEqEq":
            val k = _first_kind("===")
            expect(k).to_equal(JsTokKind.EqEqEq)

        it "!== is NotEqEq":
            val k = _first_kind("!==")
            expect(k).to_equal(JsTokKind.NotEqEq)

        it "== is EqEq":
            val k = _first_kind("==")
            expect(k).to_equal(JsTokKind.EqEq)

        it "&& is And":
            val k = _first_kind("&&")
            expect(k).to_equal(JsTokKind.And)

        it "|| is Or":
            val k = _first_kind("||")
            expect(k).to_equal(JsTokKind.Or)

        it "<= is LtEq":
            val k = _first_kind("<=")
            expect(k).to_equal(JsTokKind.LtEq)

        it "++ is PlusPlus":
            val k = _first_kind("++")
            expect(k).to_equal(JsTokKind.PlusPlus)

    describe "punctuation":
        it "( is LParen":
            val k = _first_kind("(")
            expect(k).to_equal(JsTokKind.LParen)

        it "{ is LBrace":
            val k = _first_kind("{")
            expect(k).to_equal(JsTokKind.LBrace)

        it "; is Semi":
            val k = _first_kind(";")
            expect(k).to_equal(JsTokKind.Semi)

    describe "multi-token input":
        it "var x = 5 produces 5 tokens (plus EOF)":
            val count = _token_count("var x = 5;")
            expect(count).to_equal(6)

    describe "comments":
        it "single-line comment is skipped":
            val count = _token_count("// comment\n42")
            expect(count).to_equal(2)

        it "multi-line comment is skipped":
            val count = _token_count("/* comment */42")
            expect(count).to_equal(2)
