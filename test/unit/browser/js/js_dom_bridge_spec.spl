"""
# JS DOM Bridge Specification

**Category:** Stdlib
**Difficulty:** 1/5
**Status:** Draft

## Overview

Tests for JsDomBridge in
`src/lib/gc_async_mut/gpu/browser_engine/js/dom_bridge.spl`.

## Key Behaviors

- JsDomBridge wraps a BeDomNode tree
- find_by_id delegates to be_dom_find_by_id
- query_selector delegates to be_dom_query_selector
- Event listener registration and lookup
- Dirty flag tracks DOM mutations
"""

use std.spec.*
use std.gc_async_mut.gpu.browser_engine.js.dom_bridge.{JsDomBridge, JsDomListener}
use std.gc_async_mut.gpu.browser_engine.dom.{BeDomNode, be_dom_find_by_id}

# ===========================================================================
# Helper functions
# ===========================================================================

fn _make_simple_dom() -> BeDomNode:
    var root = BeDomNode.element("div")
    root.id = "root"
    var child1 = BeDomNode.element("p")
    child1.id = "para1"
    var child2 = BeDomNode.element("button")
    child2.id = "btn1"
    root.children = [child1, child2]
    return root

fn _make_bridge() -> JsDomBridge:
    val dom = _make_simple_dom()
    return JsDomBridge.new(dom)

fn _bridge_find_id(id: text) -> bool:
    var bridge = _make_bridge()
    val found = bridge.find_by_id(id)
    return found != nil

fn _bridge_query_tag(tag: text) -> bool:
    var bridge = _make_bridge()
    val found = bridge.query_selector(tag)
    return found != nil

fn _bridge_dirty_after_set_text() -> bool:
    var bridge = _make_bridge()
    bridge.set_text_content("para1", "hello")
    return bridge.dirty()

fn _bridge_dirty_initial() -> bool:
    var bridge = _make_bridge()
    return bridge.dirty()

fn _bridge_clear_dirty() -> bool:
    var bridge = _make_bridge()
    bridge.set_text_content("para1", "hello")
    bridge.clear_dirty()
    return bridge.dirty()

fn _bridge_listener_count() -> i32:
    var bridge = _make_bridge()
    bridge.add_event_listener("btn1", "click", 100)
    bridge.add_event_listener("btn1", "mouseover", 101)
    return bridge.listener_count()

fn _bridge_get_listeners() -> i32:
    var bridge = _make_bridge()
    bridge.add_event_listener("btn1", "click", 100)
    bridge.add_event_listener("btn1", "click", 101)
    bridge.add_event_listener("btn1", "mouseover", 102)
    val listeners = bridge.get_listeners("btn1", "click")
    return listeners.len()

fn _bridge_remove_listener() -> i32:
    var bridge = _make_bridge()
    bridge.add_event_listener("btn1", "click", 100)
    bridge.add_event_listener("btn1", "click", 101)
    bridge.remove_event_listener("btn1", "click", 100)
    return bridge.listener_count()

# ===========================================================================
# Specs
# ===========================================================================

describe "JsDomBridge":
    describe "find_by_id":
        it "finds existing element by id":
            val result = _bridge_find_id("para1")
            expect(result).to_equal(true)

        it "finds button by id":
            val result = _bridge_find_id("btn1")
            expect(result).to_equal(true)

        it "returns nil for missing id":
            val result = _bridge_find_id("nonexistent")
            expect(result).to_equal(false)

    describe "query_selector":
        it "finds element by tag name":
            val result = _bridge_query_tag("button")
            expect(result).to_equal(true)

        it "finds root by tag name":
            val result = _bridge_query_tag("div")
            expect(result).to_equal(true)

        it "returns nil for missing tag":
            val result = _bridge_query_tag("table")
            expect(result).to_equal(false)

    describe "dirty flag":
        it "starts clean":
            val result = _bridge_dirty_initial()
            expect(result).to_equal(false)

        it "dirty after set_text_content":
            val result = _bridge_dirty_after_set_text()
            expect(result).to_equal(true)

        it "clear_dirty resets flag":
            val result = _bridge_clear_dirty()
            expect(result).to_equal(false)

    describe "event listeners":
        it "listener_count after two adds":
            val result = _bridge_listener_count()
            expect(result).to_equal(2)

        it "get_listeners filters by event type":
            val result = _bridge_get_listeners()
            expect(result).to_equal(2)

        it "remove_listener decrements count":
            val result = _bridge_remove_listener()
            expect(result).to_equal(1)
