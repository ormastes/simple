    it "converts WebGL buffer attribute and draw calls":
        val result = js_transpile("const vao = gl.createVertexArray();\ngl.bindVertexArray(vao);\nconst ok = gl.isVertexArray(vao);\nconst buffer = gl.createBuffer();\ngl.bindBuffer(gl.ARRAY_BUFFER, buffer);\ngl.bufferData(gl.ARRAY_BUFFER, 48, gl.STATIC_DRAW);\nconst size = gl.getBufferParameter(gl.ARRAY_BUFFER, gl.BUFFER_SIZE);\ngl.enableVertexAttribArray(0);\ngl.vertexAttribPointer(0, 4, gl.FLOAT, false, 0, 0);\ngl.vertexAttribPointer(1, 4, gl.UNSIGNED_BYTE, true, 4, 0);\ngl.vertexAttribPointer(2, 2, gl.SHORT, false, 4, 2);\ngl.vertexAttribDivisor(1, 2);\ngl.vertexAttrib1f(0, 0.125);\ngl.vertexAttrib2f(0, 0.25, 0.5);\ngl.vertexAttrib3f(0, 0.25, 0.5, 0.75);\ngl.vertexAttrib4f(0, 0.25, 0.5, 0.75, 1.0);\ngl.vertexAttrib1fv(0, attrX);\ngl.vertexAttrib2fv(0, attrXY);\ngl.vertexAttrib3fv(0, attrXYZ);\ngl.vertexAttrib4fv(0, attrXYZW);\nconst current = gl.getVertexAttrib(0, gl.CURRENT_VERTEX_ATTRIB);\nconst enabled = gl.getVertexAttrib(0, gl.VERTEX_ATTRIB_ARRAY_ENABLED);\nconst divisor = gl.getVertexAttrib(1, gl.VERTEX_ATTRIB_ARRAY_DIVISOR);\nconst pointer = gl.getVertexAttribOffset(0, gl.VERTEX_ATTRIB_ARRAY_POINTER);\ngl.disableVertexAttribArray(0);\ngl.deleteVertexArray(vao);\ngl.drawArrays(gl.TRIANGLES, 0, 3);\ngl.drawArrays(gl.LINE_LOOP, 0, 3);\ngl.drawArrays(gl.LINE_STRIP, 0, 3);\ngl.drawArrays(gl.TRIANGLE_STRIP, 0, 3);\ngl.drawArraysInstanced(gl.TRIANGLES, 0, 3, 4);\ngl.drawElements(gl.LINES, 2, gl.UNSIGNED_SHORT, 0);\ngl.drawElements(gl.TRIANGLE_FAN, 2, gl.UNSIGNED_SHORT, 0);\ngl.drawElementsInstanced(gl.LINES, 2, gl.UNSIGNED_SHORT, 0, 5);")
        expect(result.contains("gl = canvas_webgl_create_vertex_array(gl)")).to_equal(true)
        expect(result.contains("val vao = canvas_webgl_last_vertex_array(gl)")).to_equal(true)
