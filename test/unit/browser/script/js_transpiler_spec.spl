    it "converts WebGL uniform reflection and setters":
        val result = js_transpile("const tint = gl.getUniformLocation(program, \"tint\");\nconst active = gl.getActiveUniform(program, 0);\nconst value = gl.getUniform(program, tint);\ngl.uniform1f(opacity, 0.5);\ngl.uniform2f(uvScale, 2.0, 4.0);\ngl.uniform3f(normalBias, 0.1, 0.2, 0.3);\ngl.uniform4f(tint, 0.1, 0.2, 0.3, 1.0);\ngl.uniform1fv(opacity, opacityArray);\ngl.uniform2fv(uvScale, uvArray);\ngl.uniform3fv(normalBias, normalArray);\ngl.uniform4fv(tint, tintArray);\ngl.uniform1i(diffuse, 2);\ngl.uniform2i(flags, 4, 5);\ngl.uniform3i(range, 6, 7, 8);\ngl.uniform4i(mask, 9, 10, 11, 12);\ngl.uniform1iv(layer, layerArray);\ngl.uniform2iv(flags, flagsArray);\ngl.uniform3iv(range, rangeArray);\ngl.uniform4iv(mask, maskArray);\nconst kind = gl.INT_VEC3;\nconst boolKind = gl.BOOL_VEC4;\nconst matKind = gl.FLOAT_MAT3;\ngl.uniformMatrix2fv(basis, false, basisMatrix);\ngl.uniformMatrix3fv(normalMatrix, false, normalMatrixData);\ngl.uniformMatrix4fv(model, false, matrix);")
