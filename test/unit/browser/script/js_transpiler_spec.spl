"""
# JS Transpiler Spec

Unit tests for the JS-to-Simple transpiler.
"""

use std.spec.{describe, it, expect}
use std.gc_async_mut.gpu.browser_engine.script.js_transpiler.{
    js_transpile, js_is_javascript, js_is_simple
}

# =========================================================================
# Script type detection
# =========================================================================

describe "JS Transpiler - Script Type Detection":
    it "empty type is JavaScript":
        expect(js_is_javascript("")).to_equal(true)

    it "text/javascript is JavaScript":
        expect(js_is_javascript("text/javascript")).to_equal(true)

    it "application/javascript is JavaScript":
        expect(js_is_javascript("application/javascript")).to_equal(true)

    it "module is JavaScript":
        expect(js_is_javascript("module")).to_equal(true)

    it "text/simple is not JavaScript":
        expect(js_is_javascript("text/simple")).to_equal(false)

    it "text/simple is Simple":
        expect(js_is_simple("text/simple")).to_equal(true)

    it "text/javascript is not Simple":
        expect(js_is_simple("text/javascript")).to_equal(false)

# =========================================================================
# Operator conversions
# =========================================================================

describe "JS Transpiler - Operators":
    it "converts === to ==":
        val result = js_transpile("x === y")
        expect(result.contains("==")).to_equal(true)
        expect(result.contains("===")).to_equal(false)

    it "converts !== to !=":
        val result = js_transpile("x !== y")
        expect(result.contains("!=")).to_equal(true)
        expect(result.contains("!==")).to_equal(false)

    it "preserves === inside strings":
        val result = js_transpile("var s = \"x === y\"")
        expect(result.contains("===")).to_equal(true)

# =========================================================================
# Declaration conversions
# =========================================================================

describe "JS Transpiler - Declarations":
    it "converts const to val":
        val result = js_transpile("const x = 5")
        expect(result.contains("val x = 5")).to_equal(true)

    it "converts let to var":
        val result = js_transpile("let x = 5")
        expect(result.contains("var x = 5")).to_equal(true)

    it "keeps var as var":
        val result = js_transpile("var x = 5")
        expect(result.contains("var x = 5")).to_equal(true)

# =========================================================================
# Keyword conversions
# =========================================================================

describe "JS Transpiler - Keywords":
    it "converts null to nil":
        val result = js_transpile("var x = null")
        expect(result.contains("nil")).to_equal(true)

    it "converts undefined to nil":
        val result = js_transpile("var x = undefined")
        expect(result.contains("nil")).to_equal(true)

    it "converts this to me":
        val result = js_transpile("this.name")
        expect(result.contains("me.name")).to_equal(true)

    it "removes new keyword":
        val result = js_transpile("var x = new Foo(1)")
        expect(result.contains("Foo(1)")).to_equal(true)
        expect(result.contains("new ")).to_equal(false)

# =========================================================================
# Comment conversions
# =========================================================================

describe "JS Transpiler - Comments":
    it "converts line comment":
        val result = js_transpile("// hello")
        expect(result.contains("# hello")).to_equal(true)
        expect(result.contains("//")).to_equal(false)

    it "removes block comments":
        val result = js_transpile("x /* comment */ + y")
        expect(result.contains("comment")).to_equal(false)
        expect(result.contains("x")).to_equal(true)

# =========================================================================
# Template literal conversions
# =========================================================================

describe "JS Transpiler - Template Literals":
    it "converts backtick to double quote":
        val input = "`hello`"
        val result = js_transpile(input)
        expect(result.contains("\"hello\"")).to_equal(true)

    it "converts template interpolation":
        val open = "{"
        val close = "}"
        val input = "`hi $" + open + "name" + close + "`"
        val result = js_transpile(input)
        expect(result.contains(open + "name" + close)).to_equal(true)

# =========================================================================
# DOM API conversions
# =========================================================================

describe "JS Transpiler - DOM API":
    it "converts document.querySelector":
        val result = js_transpile("document.querySelector(\".btn\")")
        expect(result.contains("document_query_selector(root, ")).to_equal(true)

    it "converts document.getElementById":
        val result = js_transpile("document.getElementById(\"main\")")
        expect(result.contains("document_get_element_by_id(root, ")).to_equal(true)

    it "converts document.createElement":
        val result = js_transpile("document.createElement(\"div\")")
        expect(result.contains("document_create_element(")).to_equal(true)

# =========================================================================
# WebGL API conversions
# =========================================================================

describe "JS Transpiler - WebGL API":
    it "converts canvas getContext webgl":
        val result = js_transpile("const gl = canvas.getContext(\"webgl\");")
        expect(result.contains("val gl = canvas_get_context_webgl(300, 150)")).to_equal(true)

    it "converts canvas getContext webgl2":
        val result = js_transpile("const gl = canvas.getContext(\"webgl2\");")
        expect(result.contains("val gl = canvas_get_context_webgl2(300, 150)")).to_equal(true)

    it "converts canvas getContext experimental webgl":
        val result = js_transpile("const gl = canvas.getContext(\"experimental-webgl\");")
        expect(result.contains("val gl = canvas_get_context_webgl(300, 150)")).to_equal(true)

    it "converts canvas getContext webgpu":
        val result = js_transpile("const gpu = canvas.getContext(\"webgpu\");")
        expect(result.contains("val gpu = canvas_get_context_webgpu(300, 150, true)")).to_equal(true)

    it "converts WebGPU command method names":
        val result = js_transpile("const encoder = gpu.createCommandEncoder(\"frame\");\nencoder.beginRenderPass();\nencoder.setPipeline(pipeline.id);\nencoder.draw(3, 1);\nencoder.drawIndirect(indirect.id, 0);\nencoder.drawIndexedIndirect(indirect.id, 16);\nencoder.endRenderPass();\nconst commands = encoder.finish(\"frame\");\ngpu.queueSubmit([commands]);")
        expect(result.contains("val encoder = gpu.create_command_encoder(\"frame\")")).to_equal(true)
        expect(result.contains("encoder.begin_render_pass()")).to_equal(true)
        expect(result.contains("encoder.set_pipeline(pipeline.id)")).to_equal(true)
        expect(result.contains("encoder.draw(3, 1)")).to_equal(true)
        expect(result.contains("encoder.draw_indirect(indirect.id, 0)")).to_equal(true)
        expect(result.contains("encoder.draw_indexed_indirect(indirect.id, 16)")).to_equal(true)
        expect(result.contains("encoder.end_render_pass()")).to_equal(true)
        expect(result.contains("gpu.queue_submit([commands])")).to_equal(true)

    it "converts WebGPU resource and queue write method names":
        val result = js_transpile("const buffer = gpu.createBuffer(\"upload\", 64, 8);\ngpu.queueWriteBuffer(buffer.id, 0, 32);")
        expect(result.contains("val buffer = gpu.create_buffer(\"upload\", 64, 8)")).to_equal(true)
        expect(result.contains("gpu.queue_write_buffer(buffer.id, 0, 32)")).to_equal(true)

    it "converts navigator.gpu metadata properties":
        val result = js_transpile("const secure = navigator.gpu.secureContext;\nconst format = navigator.gpu.preferredCanvasFormat;\nconst status = navigator.gpu.requestAdapterStatus;")
        expect(result.contains("val secure = navigator_gpu_secure_context(nav)")).to_equal(true)
        expect(result.contains("val format = navigator_gpu_preferred_canvas_format(nav)")).to_equal(true)
        expect(result.contains("val status = navigator_gpu_request_adapter_status(nav)")).to_equal(true)

    it "converts navigator.gpu requestAdapter and adapter requestDevice":
        val result = js_transpile("const adapter = navigator.gpu.requestAdapter();\nconst device = adapter.requestDevice();")
        expect(result.contains("val adapter = navigator_gpu_request_adapter(nav)")).to_equal(true)
        expect(result.contains("val device = adapter.request_device()")).to_equal(true)

    it "converts basic WebGL method calls":
        val result = js_transpile("gl.clearColor(1, 0, 0, 1);\ngl.clearDepth(1);\ngl.depthRange(0, 1);\ngl.clearStencil(7);\ngl.viewport(0, 0, 320, 240);\ngl.clear(gl.COLOR_BUFFER_BIT);\nconst depth = gl.getParameter(gl.DEPTH_CLEAR_VALUE);\nconst range = gl.getParameter(gl.DEPTH_RANGE);")
        expect(result.contains("gl = canvas_webgl_clear_color(gl, 1, 0, 0, 1)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_clear_depth(gl, 1)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_depth_range(gl, 0, 1)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_clear_stencil(gl, 7)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_viewport(gl, 0, 0, 320, 240)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_clear(gl, CANVAS_WEBGL_COLOR_BUFFER_BIT)")).to_equal(true)
        expect(result.contains("val depth = canvas_webgl_get_parameter(gl, CANVAS_WEBGL_DEPTH_CLEAR_VALUE)")).to_equal(true)
        expect(result.contains("val range = canvas_webgl_get_parameter(gl, CANVAS_WEBGL_DEPTH_RANGE)")).to_equal(true)

    it "converts assigned WebGL extension queries":
        val result = js_transpile("const ext = gl.getExtension(\"OES_texture_float\");\nconst supported = gl.getSupportedExtensions();\nconst lost = gl.isContextLost();\nconst width = gl.drawingBufferWidth;\nconst height = gl.drawingBufferHeight;")
        expect(result.contains("val ext = canvas_webgl_get_extension(gl, \"OES_texture_float\")")).to_equal(true)
        expect(result.contains("val supported = canvas_webgl_get_supported_extensions(gl)")).to_equal(true)
        expect(result.contains("val lost = canvas_webgl_is_context_lost(gl)")).to_equal(true)
        expect(result.contains("val width = canvas_webgl_drawing_buffer_width(gl)")).to_equal(true)
        expect(result.contains("val height = canvas_webgl_drawing_buffer_height(gl)")).to_equal(true)

    it "converts WebGL state query calls":
        val result = js_transpile("const attrs = gl.getContextAttributes();\nconst width = gl.getParameter(gl.LINE_WIDTH);\nconst offset = gl.getParameter(gl.POLYGON_OFFSET_FACTOR);\nconst coverage = gl.getParameter(gl.SAMPLE_COVERAGE_VALUE);\nconst blend = gl.getParameter(gl.BLEND_COLOR);\nconst dither = gl.isEnabled(gl.DITHER);")
        expect(result.contains("val attrs = canvas_webgl_get_context_attributes(gl)")).to_equal(true)
        expect(result.contains("val width = canvas_webgl_get_parameter(gl, CANVAS_WEBGL_LINE_WIDTH)")).to_equal(true)
        expect(result.contains("val offset = canvas_webgl_get_parameter(gl, CANVAS_WEBGL_POLYGON_OFFSET_FACTOR)")).to_equal(true)
        expect(result.contains("val coverage = canvas_webgl_get_parameter(gl, CANVAS_WEBGL_SAMPLE_COVERAGE_VALUE)")).to_equal(true)
        expect(result.contains("val blend = canvas_webgl_get_parameter(gl, CANVAS_WEBGL_BLEND_COLOR)")).to_equal(true)
        expect(result.contains("val dither = canvas_webgl_is_enabled(gl, CANVAS_WEBGL_DITHER)")).to_equal(true)

    it "converts WebGL depth stencil blend and mask state calls":
        val result = js_transpile("gl.scissor(4, 5, 64, 32);\ngl.depthFunc(gl.LEQUAL);\ngl.depthMask(false);\ngl.colorMask(true, false, true, false);\ngl.stencilFunc(gl.ALWAYS, 3, 255);\ngl.stencilOp(gl.KEEP, gl.REPLACE, gl.ZERO);\ngl.stencilMask(15);\ngl.stencilMaskSeparate(gl.BACK, 7);\ngl.blendFunc(gl.SRC_ALPHA, gl.ONE_MINUS_SRC_ALPHA);\ngl.blendFuncSeparate(gl.ONE, gl.ZERO, gl.SRC_ALPHA, gl.ONE_MINUS_SRC_ALPHA);\ngl.blendEquation(gl.FUNC_ADD);\ngl.blendEquationSeparate(gl.FUNC_ADD, gl.FUNC_SUBTRACT);\nconst box = gl.getParameter(gl.SCISSOR_BOX);\nconst depth = gl.getParameter(gl.DEPTH_FUNC);\nconst color = gl.getParameter(gl.COLOR_WRITEMASK);\nconst eq = gl.getParameter(gl.BLEND_EQUATION_ALPHA);")
        expect(result.contains("gl = canvas_webgl_scissor(gl, 4, 5, 64, 32)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_depth_func(gl, CANVAS_WEBGL_LEQUAL)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_depth_mask(gl, false)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_color_mask(gl, true, false, true, false)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_stencil_func(gl, CANVAS_WEBGL_ALWAYS, 3, 255)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_stencil_op(gl, CANVAS_WEBGL_KEEP, CANVAS_WEBGL_REPLACE, CANVAS_WEBGL_ZERO)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_stencil_mask(gl, 15)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_stencil_mask_separate(gl, CANVAS_WEBGL_BACK, 7)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_blend_func(gl, CANVAS_WEBGL_SRC_ALPHA, CANVAS_WEBGL_ONE_MINUS_SRC_ALPHA)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_blend_func_separate(gl, CANVAS_WEBGL_ONE, CANVAS_WEBGL_ZERO, CANVAS_WEBGL_SRC_ALPHA, CANVAS_WEBGL_ONE_MINUS_SRC_ALPHA)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_blend_equation(gl, CANVAS_WEBGL_FUNC_ADD)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_blend_equation_separate(gl, CANVAS_WEBGL_FUNC_ADD, CANVAS_WEBGL_FUNC_SUBTRACT)")).to_equal(true)
        expect(result.contains("val box = canvas_webgl_get_parameter(gl, CANVAS_WEBGL_SCISSOR_BOX)")).to_equal(true)
        expect(result.contains("val depth = canvas_webgl_get_parameter(gl, CANVAS_WEBGL_DEPTH_FUNC)")).to_equal(true)
        expect(result.contains("val color = canvas_webgl_get_parameter(gl, CANVAS_WEBGL_COLOR_WRITEMASK)")).to_equal(true)
        expect(result.contains("val eq = canvas_webgl_get_parameter(gl, CANVAS_WEBGL_BLEND_EQUATION_ALPHA)")).to_equal(true)

    it "converts WebGL identity and limit query constants":
        val result = js_transpile("const vendor = gl.getParameter(gl.VENDOR);\nconst version = gl.getParameter(gl.SHADING_LANGUAGE_VERSION);\nconst maxTexture = gl.getParameter(gl.MAX_TEXTURE_SIZE);\nconst dims = gl.getParameter(gl.MAX_VIEWPORT_DIMS);\nconst lineRange = gl.getParameter(gl.ALIASED_LINE_WIDTH_RANGE);\nconst formats = gl.getParameter(gl.COMPRESSED_TEXTURE_FORMATS);")
        expect(result.contains("val vendor = canvas_webgl_get_parameter(gl, CANVAS_WEBGL_VENDOR)")).to_equal(true)
        expect(result.contains("val version = canvas_webgl_get_parameter(gl, CANVAS_WEBGL_SHADING_LANGUAGE_VERSION)")).to_equal(true)
        expect(result.contains("val maxTexture = canvas_webgl_get_parameter(gl, CANVAS_WEBGL_MAX_TEXTURE_SIZE)")).to_equal(true)
        expect(result.contains("val dims = canvas_webgl_get_parameter(gl, CANVAS_WEBGL_MAX_VIEWPORT_DIMS)")).to_equal(true)
        expect(result.contains("val lineRange = canvas_webgl_get_parameter(gl, CANVAS_WEBGL_ALIASED_LINE_WIDTH_RANGE)")).to_equal(true)
        expect(result.contains("val formats = canvas_webgl_get_parameter(gl, CANVAS_WEBGL_COMPRESSED_TEXTURE_FORMATS)")).to_equal(true)

    it "converts WebGL state mutation calls":
        val result = js_transpile("gl.disable(gl.DITHER);\ngl.lineWidth(2);\ngl.frontFace(gl.CW);\ngl.polygonOffset(-1, 3);\ngl.sampleCoverage(0.5, true);\ngl.blendColor(0.1, 0.2, 0.3, 0.4);")
        expect(result.contains("gl = canvas_webgl_disable(gl, CANVAS_WEBGL_DITHER)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_line_width(gl, 2)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_front_face(gl, CANVAS_WEBGL_CW)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_polygon_offset(gl, -1, 3)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_sample_coverage(gl, 0.5, true)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_blend_color(gl, 0.1, 0.2, 0.3, 0.4)")).to_equal(true)

    it "converts WebGL readback and pixel-store calls":
        val result = js_transpile("gl.pixelStorei(gl.PACK_ALIGNMENT, 1);\ngl.pixelStorei(gl.UNPACK_ALIGNMENT, 8);\nconst pixels = gl.readPixels(0, 0, 1, 2, gl.RGB, gl.UNSIGNED_BYTE);\nconst error = gl.getError();")
        expect(result.contains("gl = canvas_webgl_pixel_store_i(gl, CANVAS_WEBGL_PACK_ALIGNMENT, 1)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_pixel_store_i(gl, CANVAS_WEBGL_UNPACK_ALIGNMENT, 8)")).to_equal(true)
        expect(result.contains("val pixels = canvas_webgl_read_pixels(gl, 0, 0, 1, 2, CANVAS_WEBGL_RGB, CANVAS_WEBGL_UNSIGNED_BYTE)")).to_equal(true)
        expect(result.contains("val error = canvas_webgl_get_error(gl)")).to_equal(true)

    it "converts WebGL framebuffer and renderbuffer calls":
        val result = js_transpile("const fb = gl.createFramebuffer();\ngl.bindFramebuffer(gl.FRAMEBUFFER, fb);\nconst rb = gl.createRenderbuffer();\ngl.bindRenderbuffer(gl.RENDERBUFFER, rb);\ngl.renderbufferStorage(gl.RENDERBUFFER, gl.RGBA4, 16, 16);\ngl.framebufferRenderbuffer(gl.FRAMEBUFFER, gl.COLOR_ATTACHMENT0, gl.RENDERBUFFER, rb);\nconst width = gl.getRenderbufferParameter(gl.RENDERBUFFER, gl.RENDERBUFFER_WIDTH);\nconst status = gl.checkFramebufferStatus(gl.FRAMEBUFFER);")
        expect(result.contains("gl = canvas_webgl_create_framebuffer(gl)")).to_equal(true)
        expect(result.contains("val fb = canvas_webgl_last_framebuffer(gl)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_bind_framebuffer(gl, CANVAS_WEBGL_FRAMEBUFFER, fb)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_create_renderbuffer(gl)")).to_equal(true)
        expect(result.contains("val rb = canvas_webgl_last_renderbuffer(gl)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_bind_renderbuffer(gl, CANVAS_WEBGL_RENDERBUFFER, rb)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_renderbuffer_storage(gl, CANVAS_WEBGL_RENDERBUFFER, CANVAS_WEBGL_RGBA4, 16, 16)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_framebuffer_renderbuffer(gl, CANVAS_WEBGL_FRAMEBUFFER, CANVAS_WEBGL_COLOR_ATTACHMENT0, CANVAS_WEBGL_RENDERBUFFER, rb)")).to_equal(true)
        expect(result.contains("val width = canvas_webgl_get_renderbuffer_parameter(gl, CANVAS_WEBGL_RENDERBUFFER, CANVAS_WEBGL_RENDERBUFFER_WIDTH)")).to_equal(true)
        expect(result.contains("val status = canvas_webgl_check_framebuffer_status(gl, CANVAS_WEBGL_FRAMEBUFFER)")).to_equal(true)

    it "converts WebGL framebuffer texture attachment queries":
        val result = js_transpile("gl.framebufferTexture2D(gl.FRAMEBUFFER, gl.COLOR_ATTACHMENT0, gl.TEXTURE_2D, tex, 0);\nconst kind = gl.getFramebufferAttachmentParameter(gl.FRAMEBUFFER, gl.COLOR_ATTACHMENT0, gl.FRAMEBUFFER_ATTACHMENT_OBJECT_TYPE);\nconst name = gl.getFramebufferAttachmentParameter(gl.FRAMEBUFFER, gl.COLOR_ATTACHMENT0, gl.FRAMEBUFFER_ATTACHMENT_OBJECT_NAME);")
        expect(result.contains("gl = canvas_webgl_framebuffer_texture_2d(gl, CANVAS_WEBGL_FRAMEBUFFER, CANVAS_WEBGL_COLOR_ATTACHMENT0, CANVAS_WEBGL_TEXTURE_2D, tex, 0)")).to_equal(true)
        expect(result.contains("val kind = canvas_webgl_get_framebuffer_attachment_parameter(gl, CANVAS_WEBGL_FRAMEBUFFER, CANVAS_WEBGL_COLOR_ATTACHMENT0, CANVAS_WEBGL_FRAMEBUFFER_ATTACHMENT_OBJECT_TYPE)")).to_equal(true)
        expect(result.contains("val name = canvas_webgl_get_framebuffer_attachment_parameter(gl, CANVAS_WEBGL_FRAMEBUFFER, CANVAS_WEBGL_COLOR_ATTACHMENT0, CANVAS_WEBGL_FRAMEBUFFER_ATTACHMENT_OBJECT_NAME)")).to_equal(true)

    it "converts WebGL resource probes and deletion":
        val result = js_transpile("const hasBuffer = gl.isBuffer(buffer);\ngl.deleteBuffer(buffer);\nconst hasTexture = gl.isTexture(tex);\ngl.deleteTexture(tex);\nconst hasFramebuffer = gl.isFramebuffer(fb);\ngl.deleteFramebuffer(fb);\nconst hasRenderbuffer = gl.isRenderbuffer(rb);\ngl.deleteRenderbuffer(rb);")
        expect(result.contains("val hasBuffer = canvas_webgl_is_buffer(gl, buffer)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_delete_buffer(gl, buffer)")).to_equal(true)
        expect(result.contains("val hasTexture = canvas_webgl_is_texture(gl, tex)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_delete_texture(gl, tex)")).to_equal(true)
        expect(result.contains("val hasFramebuffer = canvas_webgl_is_framebuffer(gl, fb)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_delete_framebuffer(gl, fb)")).to_equal(true)
        expect(result.contains("val hasRenderbuffer = canvas_webgl_is_renderbuffer(gl, rb)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_delete_renderbuffer(gl, rb)")).to_equal(true)

    it "converts WebGL shader and program setup calls":
        val result = js_transpile("const vs = gl.createShader(gl.VERTEX_SHADER);\ngl.shaderSource(vs, src);\ngl.compileShader(vs);\nconst shaderType = gl.getShaderParameter(vs, gl.SHADER_TYPE);\nconst shaderLog = gl.getShaderInfoLog(vs);\nconst precision = gl.getShaderPrecisionFormat(gl.FRAGMENT_SHADER, gl.HIGH_FLOAT);\nconst program = gl.createProgram();\ngl.attachShader(program, vs);\ngl.linkProgram(program);\ngl.validateProgram(program);\ngl.useProgram(program);\nconst linked = gl.getProgramParameter(program, gl.LINK_STATUS);\nconst deleted = gl.getProgramParameter(program, gl.DELETE_STATUS);\nconst attachedCount = gl.getProgramParameter(program, gl.ATTACHED_SHADERS);\nconst activeUniforms = gl.getProgramParameter(program, gl.ACTIVE_UNIFORMS);\nconst attrib = gl.getActiveAttrib(program, 0);\nconst programLog = gl.getProgramInfoLog(program);\nconst attached = gl.getAttachedShaders(program);\ngl.detachShader(program, vs);\ngl.deleteShader(vs);\ngl.deleteProgram(program);")
        expect(result.contains("gl = canvas_webgl_create_shader(gl, CANVAS_WEBGL_VERTEX_SHADER)")).to_equal(true)
        expect(result.contains("val vs = canvas_webgl_last_shader(gl)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_shader_source(gl, vs, src)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_compile_shader(gl, vs)")).to_equal(true)
        expect(result.contains("val shaderType = canvas_webgl_get_shader_parameter(gl, vs, CANVAS_WEBGL_SHADER_TYPE)")).to_equal(true)
        expect(result.contains("val shaderLog = canvas_webgl_get_shader_info_log(gl, vs)")).to_equal(true)
        expect(result.contains("val precision = canvas_webgl_get_shader_precision_format(gl, CANVAS_WEBGL_FRAGMENT_SHADER, CANVAS_WEBGL_HIGH_FLOAT)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_create_program(gl)")).to_equal(true)
        expect(result.contains("val program = canvas_webgl_last_program(gl)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_attach_shader(gl, program, vs)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_link_program(gl, program)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_validate_program(gl, program)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_use_program(gl, program)")).to_equal(true)
        expect(result.contains("val linked = canvas_webgl_get_program_parameter(gl, program, CANVAS_WEBGL_LINK_STATUS)")).to_equal(true)
        expect(result.contains("val deleted = canvas_webgl_get_program_parameter(gl, program, CANVAS_WEBGL_DELETE_STATUS)")).to_equal(true)
        expect(result.contains("val attachedCount = canvas_webgl_get_program_parameter(gl, program, CANVAS_WEBGL_ATTACHED_SHADERS)")).to_equal(true)
        expect(result.contains("val activeUniforms = canvas_webgl_get_program_parameter(gl, program, CANVAS_WEBGL_ACTIVE_UNIFORMS)")).to_equal(true)
        expect(result.contains("val attrib = canvas_webgl_get_active_attrib(gl, program, 0)")).to_equal(true)
        expect(result.contains("val programLog = canvas_webgl_get_program_info_log(gl, program)")).to_equal(true)
        expect(result.contains("val attached = canvas_webgl_get_attached_shaders(gl, program)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_detach_shader(gl, program, vs)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_delete_shader(gl, vs)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_delete_program(gl, program)")).to_equal(true)

    it "converts WebGL uniform reflection and setters":
        val result = js_transpile("const tint = gl.getUniformLocation(program, \"tint\");\nconst active = gl.getActiveUniform(program, 0);\ngl.uniform1f(opacity, 0.5);\ngl.uniform4f(tint, 0.1, 0.2, 0.3, 1.0);\ngl.uniform1i(diffuse, 2);\ngl.uniformMatrix4fv(model, false, matrix);")
        expect(result.contains("val tint = canvas_webgl_get_uniform_location(gl, program, \"tint\")")).to_equal(true)
        expect(result.contains("val active = canvas_webgl_get_active_uniform(gl, program, 0)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_uniform_1f(gl, opacity, 0.5)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_uniform_4f(gl, tint, 0.1, 0.2, 0.3, 1.0)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_uniform_1i(gl, diffuse, 2)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_uniform_matrix4fv(gl, model, false, matrix)")).to_equal(true)

    it "converts WebGL buffer attribute and draw calls":
        val result = js_transpile("const buffer = gl.createBuffer();\ngl.bindBuffer(gl.ARRAY_BUFFER, buffer);\ngl.bufferData(gl.ARRAY_BUFFER, 48, gl.STATIC_DRAW);\nconst size = gl.getBufferParameter(gl.ARRAY_BUFFER, gl.BUFFER_SIZE);\ngl.enableVertexAttribArray(0);\ngl.vertexAttribPointer(0, 4, gl.FLOAT, false, 0, 0);\nconst enabled = gl.getVertexAttrib(0, gl.VERTEX_ATTRIB_ARRAY_ENABLED);\nconst pointer = gl.getVertexAttribOffset(0, gl.VERTEX_ATTRIB_ARRAY_POINTER);\ngl.disableVertexAttribArray(0);\ngl.drawArrays(gl.TRIANGLES, 0, 3);\ngl.drawElements(gl.LINES, 2, gl.UNSIGNED_SHORT, 0);")
        expect(result.contains("gl = canvas_webgl_create_buffer(gl)")).to_equal(true)
        expect(result.contains("val buffer = canvas_webgl_last_buffer(gl)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_bind_buffer(gl, CANVAS_WEBGL_ARRAY_BUFFER, buffer)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_buffer_data_size(gl, CANVAS_WEBGL_ARRAY_BUFFER, 48, CANVAS_WEBGL_STATIC_DRAW)")).to_equal(true)
        expect(result.contains("val size = canvas_webgl_get_buffer_parameter(gl, CANVAS_WEBGL_ARRAY_BUFFER, CANVAS_WEBGL_BUFFER_SIZE)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_enable_vertex_attrib_array(gl, 0)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_vertex_attrib_pointer(gl, 0, 4, CANVAS_WEBGL_FLOAT, false, 0, 0)")).to_equal(true)
        expect(result.contains("val enabled = canvas_webgl_get_vertex_attrib(gl, 0, CANVAS_WEBGL_VERTEX_ATTRIB_ARRAY_ENABLED)")).to_equal(true)
        expect(result.contains("val pointer = canvas_webgl_get_vertex_attrib_offset(gl, 0, CANVAS_WEBGL_VERTEX_ATTRIB_ARRAY_POINTER)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_disable_vertex_attrib_array(gl, 0)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_draw_arrays(gl, CANVAS_WEBGL_TRIANGLES, 0, 3)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_draw_elements(gl, CANVAS_WEBGL_LINES, 2, CANVAS_WEBGL_UNSIGNED_SHORT, 0)")).to_equal(true)

    it "converts WebGL texture upload calls":
        val result = js_transpile("const tex = gl.createTexture();\ngl.bindTexture(gl.TEXTURE_2D, tex);\ngl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_MIN_FILTER, gl.LINEAR);\nconst wrap = gl.getTexParameter(gl.TEXTURE_2D, gl.TEXTURE_WRAP_S);\ngl.texImage2D(gl.TEXTURE_2D, 0, gl.RGBA, 1, 1, 0, gl.RGBA, gl.UNSIGNED_BYTE, pixels);\ngl.texSubImage2D(gl.TEXTURE_2D, 0, 0, 0, 1, 1, gl.RGBA, gl.UNSIGNED_BYTE, pixels);\ngl.generateMipmap(gl.TEXTURE_2D);")
        expect(result.contains("gl = canvas_webgl_create_texture(gl)")).to_equal(true)
        expect(result.contains("val tex = canvas_webgl_last_texture(gl)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_bind_texture(gl, CANVAS_WEBGL_TEXTURE_2D, tex)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_tex_parameter_i(gl, CANVAS_WEBGL_TEXTURE_2D, CANVAS_WEBGL_TEXTURE_MIN_FILTER, CANVAS_WEBGL_LINEAR)")).to_equal(true)
        expect(result.contains("val wrap = canvas_webgl_get_tex_parameter(gl, CANVAS_WEBGL_TEXTURE_2D, CANVAS_WEBGL_TEXTURE_WRAP_S)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_tex_image_2d(gl, CANVAS_WEBGL_TEXTURE_2D, 0, CANVAS_WEBGL_RGBA, 1, 1, 0, CANVAS_WEBGL_RGBA, CANVAS_WEBGL_UNSIGNED_BYTE, pixels)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_tex_sub_image_2d(gl, CANVAS_WEBGL_TEXTURE_2D, 0, 0, 0, 1, 1, CANVAS_WEBGL_RGBA, CANVAS_WEBGL_UNSIGNED_BYTE, pixels)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_generate_mipmap(gl, CANVAS_WEBGL_TEXTURE_2D)")).to_equal(true)

# =========================================================================
# Console API conversions
# =========================================================================

describe "JS Transpiler - Console API":
    it "converts console.log":
        val result = js_transpile("console.log(\"hi\")")
        expect(result.contains("buf = console_log(buf, ")).to_equal(true)

    it "converts console.error":
        val result = js_transpile("console.error(\"err\")")
        expect(result.contains("buf = console_error(buf, ")).to_equal(true)

# =========================================================================
# Timer conversions
# =========================================================================

describe "JS Transpiler - Timers":
    it "converts setTimeout":
        val result = js_transpile("setTimeout(cb, 100)")
        expect(result.contains("set_timeout(loop_ref, ")).to_equal(true)

    it "converts clearTimeout":
        val result = js_transpile("clearTimeout(tid)")
        expect(result.contains("clear_timeout(loop_ref, ")).to_equal(true)

# =========================================================================
# Worker conversions
# =========================================================================

describe "JS Transpiler - Workers":
    it "converts Worker construction":
        val result = js_transpile("const w = new Worker(\"worker.js\")")
        expect(result.contains("val w = worker_create(\"worker.js\")")).to_equal(true)

    it "converts worker postMessage":
        val result = js_transpile("w.postMessage(\"ready\")")
        expect(result.contains("worker_post_message(w, \"ready\")")).to_equal(true)

    it "converts worker terminate":
        val result = js_transpile("w.terminate()")
        expect(result.contains("worker_terminate(w)")).to_equal(true)

    it "converts WorkerGlobalScope self postMessage":
        val result = js_transpile("self.postMessage(\"ready\")")
        expect(result.contains("worker_global_post_message(scope, \"ready\")")).to_equal(true)

# =========================================================================
# Property assignment conversions
# =========================================================================

describe "JS Transpiler - Property Assignments":
    it "converts style assignment":
        val result = js_transpile("el.style.color = \"red\";")
        expect(result.contains("el = node_set_style_property(el")).to_equal(true)
        expect(result.contains("\"color\"")).to_equal(true)

    it "converts style getPropertyValue":
        val result = js_transpile("const value = el.style.getPropertyValue(\"display\");")
        expect(result.contains("val value = node_get_style_property(el, \"display\")")).to_equal(true)

    it "converts innerHTML assignment":
        val result = js_transpile("el.innerHTML = \"<b>hi</b>\";")
        expect(result.contains("el = node_set_inner_html(el")).to_equal(true)

    it "converts textContent assignment":
        val result = js_transpile("el.textContent = \"hello\";")
        expect(result.contains("el = node_set_text_content(el")).to_equal(true)

    it "converts classList.add":
        val result = js_transpile("el.classList.add(\"active\")")
        expect(result.contains("el = node_class_list_add(el")).to_equal(true)

    it "keeps classList.contains as an expression":
        val result = js_transpile("el.classList.contains(\"active\")")
        expect(result.contains("node_class_list_contains(el")).to_equal(true)

# =========================================================================
# Event listener conversion
# =========================================================================

describe "JS Transpiler - Event Listeners":
    it "converts addEventListener":
        val result = js_transpile("btn.addEventListener(\"click\", handler)")
        expect(result.contains("node_add_event_listener(btn")).to_equal(true)

# =========================================================================
# Control flow conversions
# =========================================================================

describe "JS Transpiler - Control Flow":
    it "converts for-of loop":
        val result = js_transpile("for (let x of arr) {}")
        expect(result.contains("for x in arr:")).to_equal(true)

    it "strips trailing semicolons":
        val result = js_transpile("var x = 5;")
        expect(result.contains("var x = 5")).to_equal(true)
        expect(result.ends_with(";")).to_equal(false)

    it "converts return with semicolon":
        val result = js_transpile("return 42;")
        expect(result.contains("return 42")).to_equal(true)
        expect(result.contains("return 42;")).to_equal(false)
