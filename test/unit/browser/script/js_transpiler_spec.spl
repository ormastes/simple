        expect(result.contains("val buffer = canvas_webgl_last_buffer(gl)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_bind_buffer(gl, CANVAS_WEBGL_ARRAY_BUFFER, buffer)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_buffer_data_size(gl, CANVAS_WEBGL_ARRAY_BUFFER, 48, CANVAS_WEBGL_STATIC_DRAW)")).to_equal(true)
        expect(result.contains("val size = canvas_webgl_get_buffer_parameter(gl, CANVAS_WEBGL_ARRAY_BUFFER, CANVAS_WEBGL_BUFFER_SIZE)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_enable_vertex_attrib_array(gl, 0)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_vertex_attrib_pointer(gl, 0, 4, CANVAS_WEBGL_FLOAT, false, 0, 0)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_vertex_attrib_pointer(gl, 1, 4, CANVAS_WEBGL_UNSIGNED_BYTE, true, 4, 0)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_vertex_attrib_pointer(gl, 2, 2, CANVAS_WEBGL_SHORT, false, 4, 2)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_vertex_attrib_divisor(gl, 1, 2)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_vertex_attrib_1f(gl, 0, 0.125)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_vertex_attrib_2f(gl, 0, 0.25, 0.5)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_vertex_attrib_3f(gl, 0, 0.25, 0.5, 0.75)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_vertex_attrib_4f(gl, 0, 0.25, 0.5, 0.75, 1.0)")).to_equal(true)
