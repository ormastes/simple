    it "converts WebGL shader and program setup calls":
        val result = js_transpile("const vs = gl.createShader(gl.VERTEX_SHADER);\ngl.shaderSource(vs, src);\ngl.compileShader(vs);\nconst shaderLive = gl.isShader(vs);\nconst shaderSource = gl.getShaderSource(vs);\nconst shaderType = gl.getShaderParameter(vs, gl.SHADER_TYPE);\nconst shaderLog = gl.getShaderInfoLog(vs);\nconst precision = gl.getShaderPrecisionFormat(gl.FRAGMENT_SHADER, gl.HIGH_FLOAT);\nconst program = gl.createProgram();\nconst programLive = gl.isProgram(program);\ngl.attachShader(program, vs);\ngl.linkProgram(program);\ngl.validateProgram(program);\ngl.useProgram(program);\nconst linked = gl.getProgramParameter(program, gl.LINK_STATUS);\nconst deleted = gl.getProgramParameter(program, gl.DELETE_STATUS);\nconst attachedCount = gl.getProgramParameter(program, gl.ATTACHED_SHADERS);\nconst activeUniforms = gl.getProgramParameter(program, gl.ACTIVE_UNIFORMS);\nconst attrib = gl.getActiveAttrib(program, 0);\nconst programLog = gl.getProgramInfoLog(program);\nconst attached = gl.getAttachedShaders(program);\ngl.detachShader(program, vs);\ngl.deleteShader(vs);\ngl.deleteProgram(program);")
        expect(result.contains("gl = canvas_webgl_create_shader(gl, CANVAS_WEBGL_VERTEX_SHADER)")).to_equal(true)
