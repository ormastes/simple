        expect(result.contains("gl = canvas_webgl_framebuffer_renderbuffer(gl, CANVAS_WEBGL_FRAMEBUFFER, CANVAS_WEBGL_COLOR_ATTACHMENT0, CANVAS_WEBGL_RENDERBUFFER, rb)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_draw_buffers(gl, [CANVAS_WEBGL_COLOR_ATTACHMENT0])")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_read_buffer(gl, CANVAS_WEBGL_COLOR_ATTACHMENT0)")).to_equal(true)
