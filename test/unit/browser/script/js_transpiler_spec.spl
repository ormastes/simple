        expect(result.contains("gl = canvas_webgl_draw_elements(gl, CANVAS_WEBGL_TRIANGLE_FAN, 2, CANVAS_WEBGL_UNSIGNED_SHORT, 0)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_draw_elements_instanced(gl, CANVAS_WEBGL_LINES, 2, CANVAS_WEBGL_UNSIGNED_SHORT, 0, 5)")).to_equal(true)

    it "converts WebGL texture upload calls":
        val result = js_transpile("const tex = gl.createTexture();\ngl.activeTexture(gl.TEXTURE0 + 1);\ngl.bindTexture(gl.TEXTURE_2D, tex);\ngl.bindTexture(gl.TEXTURE_CUBE_MAP, tex);\ngl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_MIN_FILTER, gl.LINEAR);\ngl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_MIN_FILTER, gl.LINEAR_MIPMAP_LINEAR);\ngl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_WRAP_T, gl.MIRRORED_REPEAT);\nconst active = gl.getParameter(gl.ACTIVE_TEXTURE);\nconst binding = gl.getParameter(gl.TEXTURE_BINDING_2D);\nconst cubeBinding = gl.getParameter(gl.TEXTURE_BINDING_CUBE_MAP);\nconst wrap = gl.getTexParameter(gl.TEXTURE_2D, gl.TEXTURE_WRAP_S);\ngl.texImage2D(gl.TEXTURE_2D, 0, gl.RGBA, 1, 1, 0, gl.RGBA, gl.UNSIGNED_BYTE, pixels);\ngl.texImage2D(gl.TEXTURE_CUBE_MAP_POSITIVE_X, 0, gl.RGBA, 1, 1, 0, gl.RGBA, gl.UNSIGNED_BYTE, pixels);\ngl.texImage2D(gl.TEXTURE_2D, 0, gl.RGB, 2, 1, 0, gl.RGB, gl.UNSIGNED_SHORT_5_6_5, packedRgb);\ngl.texImage2D(gl.TEXTURE_2D, 0, gl.RGBA, 2, 1, 0, gl.RGBA, gl.UNSIGNED_SHORT_4_4_4_4, packedRgba);\ngl.texSubImage2D(gl.TEXTURE_2D, 0, 0, 0, 1, 1, gl.RGBA, gl.UNSIGNED_BYTE, pixels);\ngl.compressedTexImage2D(gl.TEXTURE_2D, 0, gl.RGBA, 2, 2, 0, compressedPixels);\ngl.compressedTexSubImage2D(gl.TEXTURE_2D, 0, 0, 0, 1, 1, gl.RGBA, compressedPixels);\ngl.copyTexImage2D(gl.TEXTURE_2D, 0, gl.RGBA, 4, 5, 2, 2, 0);\ngl.copyTexSubImage2D(gl.TEXTURE_2D, 0, 1, 1, 8, 9, 1, 1);\ngl.generateMipmap(gl.TEXTURE_2D);")
        expect(result.contains("gl = canvas_webgl_create_texture(gl)")).to_equal(true)
        expect(result.contains("val tex = canvas_webgl_last_texture(gl)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_active_texture(gl, CANVAS_WEBGL_TEXTURE0 + 1)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_bind_texture(gl, CANVAS_WEBGL_TEXTURE_2D, tex)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_bind_texture(gl, CANVAS_WEBGL_TEXTURE_CUBE_MAP, tex)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_tex_parameter_i(gl, CANVAS_WEBGL_TEXTURE_2D, CANVAS_WEBGL_TEXTURE_MIN_FILTER, CANVAS_WEBGL_LINEAR)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_tex_parameter_i(gl, CANVAS_WEBGL_TEXTURE_2D, CANVAS_WEBGL_TEXTURE_MIN_FILTER, CANVAS_WEBGL_LINEAR_MIPMAP_LINEAR)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_tex_parameter_i(gl, CANVAS_WEBGL_TEXTURE_2D, CANVAS_WEBGL_TEXTURE_WRAP_T, CANVAS_WEBGL_MIRRORED_REPEAT)")).to_equal(true)
        expect(result.contains("val active = canvas_webgl_get_parameter(gl, CANVAS_WEBGL_ACTIVE_TEXTURE)")).to_equal(true)
        expect(result.contains("val binding = canvas_webgl_get_parameter(gl, CANVAS_WEBGL_TEXTURE_BINDING_2D)")).to_equal(true)
        expect(result.contains("val cubeBinding = canvas_webgl_get_parameter(gl, CANVAS_WEBGL_TEXTURE_BINDING_CUBE_MAP)")).to_equal(true)
        expect(result.contains("val wrap = canvas_webgl_get_tex_parameter(gl, CANVAS_WEBGL_TEXTURE_2D, CANVAS_WEBGL_TEXTURE_WRAP_S)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_tex_image_2d(gl, CANVAS_WEBGL_TEXTURE_2D, 0, CANVAS_WEBGL_RGBA, 1, 1, 0, CANVAS_WEBGL_RGBA, CANVAS_WEBGL_UNSIGNED_BYTE, pixels)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_tex_image_2d(gl, CANVAS_WEBGL_TEXTURE_CUBE_MAP_POSITIVE_X, 0, CANVAS_WEBGL_RGBA, 1, 1, 0, CANVAS_WEBGL_RGBA, CANVAS_WEBGL_UNSIGNED_BYTE, pixels)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_tex_image_2d(gl, CANVAS_WEBGL_TEXTURE_2D, 0, CANVAS_WEBGL_RGB, 2, 1, 0, CANVAS_WEBGL_RGB, CANVAS_WEBGL_UNSIGNED_SHORT_5_6_5, packedRgb)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_tex_image_2d(gl, CANVAS_WEBGL_TEXTURE_2D, 0, CANVAS_WEBGL_RGBA, 2, 1, 0, CANVAS_WEBGL_RGBA, CANVAS_WEBGL_UNSIGNED_SHORT_4_4_4_4, packedRgba)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_tex_sub_image_2d(gl, CANVAS_WEBGL_TEXTURE_2D, 0, 0, 0, 1, 1, CANVAS_WEBGL_RGBA, CANVAS_WEBGL_UNSIGNED_BYTE, pixels)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_compressed_tex_image_2d(gl, CANVAS_WEBGL_TEXTURE_2D, 0, CANVAS_WEBGL_RGBA, 2, 2, 0, compressedPixels)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_compressed_tex_sub_image_2d(gl, CANVAS_WEBGL_TEXTURE_2D, 0, 0, 0, 1, 1, CANVAS_WEBGL_RGBA, compressedPixels)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_copy_tex_image_2d(gl, CANVAS_WEBGL_TEXTURE_2D, 0, CANVAS_WEBGL_RGBA, 4, 5, 2, 2, 0)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_copy_tex_sub_image_2d(gl, CANVAS_WEBGL_TEXTURE_2D, 0, 1, 1, 8, 9, 1, 1)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_generate_mipmap(gl, CANVAS_WEBGL_TEXTURE_2D)")).to_equal(true)

    it "converts WebGL2 sampler object calls":
        val result = js_transpile("const sampler = gl.createSampler();\ngl.bindSampler(1, sampler);\ngl.samplerParameteri(sampler, gl.TEXTURE_MIN_FILTER, gl.LINEAR_MIPMAP_LINEAR);\nconst filter = gl.getSamplerParameter(sampler, gl.TEXTURE_MIN_FILTER);\nconst bound = gl.getParameter(gl.SAMPLER_BINDING);\nconst ok = gl.isSampler(sampler);\ngl.deleteSampler(sampler);")
        expect(result.contains("gl = canvas_webgl_create_sampler(gl)")).to_equal(true)
        expect(result.contains("val sampler = canvas_webgl_last_sampler(gl)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_bind_sampler(gl, 1, sampler)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_sampler_parameter_i(gl, sampler, CANVAS_WEBGL_TEXTURE_MIN_FILTER, CANVAS_WEBGL_LINEAR_MIPMAP_LINEAR)")).to_equal(true)
        expect(result.contains("val filter = canvas_webgl_get_sampler_parameter(gl, sampler, CANVAS_WEBGL_TEXTURE_MIN_FILTER)")).to_equal(true)
        expect(result.contains("val bound = canvas_webgl_get_parameter(gl, CANVAS_WEBGL_SAMPLER_BINDING)")).to_equal(true)
        expect(result.contains("val ok = canvas_webgl_is_sampler(gl, sampler)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_delete_sampler(gl, sampler)")).to_equal(true)

# =========================================================================
# Console API conversions
# =========================================================================

describe "JS Transpiler - Console API":
    it "converts console.log":
        val result = js_transpile("console.log(\"hi\")")
        expect(result.contains("buf = console_log(buf, ")).to_equal(true)

    it "converts console.error":
        val result = js_transpile("console.error(\"err\")")
        expect(result.contains("buf = console_error(buf, ")).to_equal(true)

# =========================================================================
# Timer conversions
# =========================================================================

describe "JS Transpiler - Timers":
    it "converts setTimeout":
        val result = js_transpile("setTimeout(cb, 100)")
        expect(result.contains("set_timeout(loop_ref, ")).to_equal(true)

    it "converts clearTimeout":
        val result = js_transpile("clearTimeout(tid)")
        expect(result.contains("clear_timeout(loop_ref, ")).to_equal(true)

# =========================================================================
# Worker conversions
# =========================================================================

describe "JS Transpiler - Workers":
    it "converts Worker construction":
        val result = js_transpile("const w = new Worker(\"worker.js\")")
        expect(result.contains("val w = worker_create(\"worker.js\")")).to_equal(true)

    it "converts worker postMessage":
        val result = js_transpile("w.postMessage(\"ready\")")
        expect(result.contains("worker_post_message(w, \"ready\")")).to_equal(true)

    it "converts worker terminate":
        val result = js_transpile("w.terminate()")
        expect(result.contains("worker_terminate(w)")).to_equal(true)

    it "converts WorkerGlobalScope self postMessage":
        val result = js_transpile("self.postMessage(\"ready\")")
        expect(result.contains("worker_global_post_message(scope, \"ready\")")).to_equal(true)

# =========================================================================
# Property assignment conversions
# =========================================================================

describe "JS Transpiler - Property Assignments":
    it "converts style assignment":
        val result = js_transpile("el.style.color = \"red\";")
        expect(result.contains("el = node_set_style_property(el")).to_equal(true)
        expect(result.contains("\"color\"")).to_equal(true)

    it "converts style getPropertyValue":
        val result = js_transpile("const value = el.style.getPropertyValue(\"display\");")
        expect(result.contains("val value = node_get_style_property(el, \"display\")")).to_equal(true)

    it "converts innerHTML assignment":
        val result = js_transpile("el.innerHTML = \"<b>hi</b>\";")
        expect(result.contains("el = node_set_inner_html(el")).to_equal(true)

    it "converts textContent assignment":
        val result = js_transpile("el.textContent = \"hello\";")
        expect(result.contains("el = node_set_text_content(el")).to_equal(true)

    it "converts classList.add":
        val result = js_transpile("el.classList.add(\"active\")")
        expect(result.contains("el = node_class_list_add(el")).to_equal(true)

    it "keeps classList.contains as an expression":
        val result = js_transpile("el.classList.contains(\"active\")")
        expect(result.contains("node_class_list_contains(el")).to_equal(true)

# =========================================================================
# Event listener conversion
# =========================================================================

describe "JS Transpiler - Event Listeners":
    it "converts addEventListener":
        val result = js_transpile("btn.addEventListener(\"click\", handler)")
        expect(result.contains("node_add_event_listener(btn")).to_equal(true)

# =========================================================================
# Control flow conversions
# =========================================================================

describe "JS Transpiler - Control Flow":
    it "converts for-of loop":
        val result = js_transpile("for (let x of arr) {}")
        expect(result.contains("for x in arr:")).to_equal(true)

    it "strips trailing semicolons":
        val result = js_transpile("var x = 5;")
        expect(result.contains("var x = 5")).to_equal(true)
        expect(result.ends_with(";")).to_equal(false)

    it "converts return with semicolon":
        val result = js_transpile("return 42;")
        expect(result.contains("return 42")).to_equal(true)
        expect(result.contains("return 42;")).to_equal(false)
