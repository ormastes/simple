        expect(result.contains("gl = canvas_webgl_uniform_2fv(gl, uvScale, uvArray)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_uniform_3fv(gl, normalBias, normalArray)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_uniform_4fv(gl, tint, tintArray)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_uniform_1i(gl, diffuse, 2)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_uniform_2i(gl, flags, 4, 5)")).to_equal(true)
