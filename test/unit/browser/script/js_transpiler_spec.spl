        expect(result.contains("gl = canvas_webgl_uniform_1iv(gl, layer, layerArray)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_uniform_2iv(gl, flags, flagsArray)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_uniform_3iv(gl, range, rangeArray)")).to_equal(true)
        expect(result.contains("gl = canvas_webgl_uniform_4iv(gl, mask, maskArray)")).to_equal(true)
        expect(result.contains("val kind = CANVAS_WEBGL_INT_VEC3")).to_equal(true)
        expect(result.contains("val boolKind = CANVAS_WEBGL_BOOL_VEC4")).to_equal(true)
        expect(result.contains("val matKind = CANVAS_WEBGL_FLOAT_MAT3")).to_equal(true)
