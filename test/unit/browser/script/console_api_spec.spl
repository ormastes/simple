"""
# Console API Spec

Unit tests for the Simple browser engine Console API.
"""

use std.spec.{describe, it, expect}
use std.gc_async_mut.gpu.browser_engine.script.console_buffer.{ConsoleBuffer}
use std.gc_async_mut.gpu.browser_engine.script.console_api.{
    console_log, console_warn, console_error,
    console_info, console_debug, console_clear,
    console_time, console_time_end
}

describe "Console API - Logging":
    it "logs a message":
        val buf = ConsoleBuffer.new()
        console_log(buf, "hello")
        val entries = buf.entries()
        expect(entries.len()).to_equal(1)

    it "log entry has correct level":
        val buf = ConsoleBuffer.new()
        console_log(buf, "test")
        val entries = buf.entries()
        expect(entries[0].level).to_equal("log")

    it "log entry has correct message":
        val buf = ConsoleBuffer.new()
        console_log(buf, "test msg")
        val entries = buf.entries()
        expect(entries[0].message).to_equal("test msg")

    it "warns a message":
        val buf = ConsoleBuffer.new()
        console_warn(buf, "warning")
        val entries = buf.entries()
        expect(entries[0].level).to_equal("warn")

    it "errors a message":
        val buf = ConsoleBuffer.new()
        console_error(buf, "err")
        val entries = buf.entries()
        expect(entries[0].level).to_equal("error")

    it "info message":
        val buf = ConsoleBuffer.new()
        console_info(buf, "info msg")
        val entries = buf.entries()
        expect(entries[0].level).to_equal("info")

    it "debug message":
        val buf = ConsoleBuffer.new()
        console_debug(buf, "dbg")
        val entries = buf.entries()
        expect(entries[0].level).to_equal("debug")

describe "Console API - Clear":
    it "clears all entries":
        val buf = ConsoleBuffer.new()
        console_log(buf, "a")
        console_log(buf, "b")
        console_clear(buf)
        val entries = buf.entries()
        expect(entries.len()).to_equal(0)

describe "Console API - Timers":
    it "starts a timer":
        val buf = ConsoleBuffer.new()
        console_time(buf, "op")
        # Timer started — no entry yet
        val entries = buf.entries()
        expect(entries.len()).to_equal(0)

    it "ends a timer and logs":
        val buf = ConsoleBuffer.new()
        console_time(buf, "op")
        console_time_end(buf, "op")
        val entries = buf.entries()
        expect(entries.len()).to_equal(1)

    it "warns on duplicate timer":
        val buf = ConsoleBuffer.new()
        console_time(buf, "op")
        console_time(buf, "op")
        val entries = buf.entries()
        expect(entries.len()).to_equal(1)

    it "warns on unknown timer end":
        val buf = ConsoleBuffer.new()
        console_time_end(buf, "unknown")
        val entries = buf.entries()
        expect(entries[0].level).to_equal("warn")
