"""
# Canvas API Spec

Unit tests for the Simple browser engine Canvas 2D API.
"""

use std.spec.{describe, it, expect}
use std.gc_async_mut.gpu.browser_engine.script.canvas_api.{
    CanvasContext2D, canvas_create,
    canvas_fill_rect, canvas_stroke_rect, canvas_clear_rect,
    canvas_fill_text, canvas_stroke_text,
    canvas_begin_path, canvas_move_to, canvas_line_to,
    canvas_arc, canvas_close_path, canvas_fill, canvas_stroke,
    canvas_set_fill_style, canvas_set_stroke_style, canvas_set_line_width,
    canvas_set_font, canvas_save, canvas_restore,
    canvas_translate, canvas_rotate, canvas_scale,
    canvas_measure_text, canvas_get_commands
}

describe "Canvas API - Context Creation":
    it "creates a context with correct dimensions":
        val ctx = canvas_create(800, 600)
        expect(ctx.width).to_equal(800)

    it "context has correct height":
        val ctx = canvas_create(800, 600)
        expect(ctx.height).to_equal(600)

    it "context starts with default fill color":
        val ctx = canvas_create(100, 100)
        expect(ctx.fill_color).to_equal("#000000")

describe "Canvas API - Shape Drawing":
    it "fillRect adds a command":
        val ctx = canvas_create(100, 100)
        canvas_fill_rect(ctx, 10.0, 20.0, 50.0, 30.0)
        val cmds = canvas_get_commands(ctx)
        expect(cmds.len()).to_equal(1)

    it "fillRect command contains coordinates":
        val ctx = canvas_create(100, 100)
        canvas_fill_rect(ctx, 10.0, 20.0, 50.0, 30.0)
        val cmds = canvas_get_commands(ctx)
        expect(cmds[0]).to_contain("fillRect")

    it "strokeRect adds a command":
        val ctx = canvas_create(100, 100)
        canvas_stroke_rect(ctx, 0.0, 0.0, 100.0, 100.0)
        val cmds = canvas_get_commands(ctx)
        expect(cmds[0]).to_contain("strokeRect")

    it "clearRect adds a command":
        val ctx = canvas_create(100, 100)
        canvas_clear_rect(ctx, 0.0, 0.0, 100.0, 100.0)
        val cmds = canvas_get_commands(ctx)
        expect(cmds[0]).to_contain("clearRect")

describe "Canvas API - Text Drawing":
    it "fillText adds a command":
        val ctx = canvas_create(100, 100)
        canvas_fill_text(ctx, "Hello", 10.0, 20.0)
        val cmds = canvas_get_commands(ctx)
        expect(cmds[0]).to_contain("fillText")

describe "Canvas API - Path Operations":
    it "path operations accumulate commands":
        val ctx = canvas_create(100, 100)
        canvas_begin_path(ctx)
        canvas_move_to(ctx, 0.0, 0.0)
        canvas_line_to(ctx, 100.0, 100.0)
        canvas_close_path(ctx)
        canvas_stroke(ctx)
        val cmds = canvas_get_commands(ctx)
        expect(cmds.len()).to_equal(5)

describe "Canvas API - Style":
    it "changes fill style":
        val ctx = canvas_create(100, 100)
        canvas_set_fill_style(ctx, "#ff0000")
        expect(ctx.fill_color).to_equal("#ff0000")

    it "changes stroke style":
        val ctx = canvas_create(100, 100)
        canvas_set_stroke_style(ctx, "#00ff00")
        expect(ctx.stroke_color).to_equal("#00ff00")

    it "changes line width":
        val ctx = canvas_create(100, 100)
        canvas_set_line_width(ctx, 3.0)
        expect(ctx.line_width).to_equal(3.0)

describe "Canvas API - State Save/Restore":
    it "save and restore preserves fill color":
        val ctx = canvas_create(100, 100)
        canvas_set_fill_style(ctx, "#ff0000")
        canvas_save(ctx)
        canvas_set_fill_style(ctx, "#0000ff")
        canvas_restore(ctx)
        expect(ctx.fill_color).to_equal("#ff0000")

describe "Canvas API - Transforms":
    it "translate adds a command":
        val ctx = canvas_create(100, 100)
        canvas_translate(ctx, 50.0, 50.0)
        val cmds = canvas_get_commands(ctx)
        expect(cmds[0]).to_contain("translate")

    it "rotate adds a command":
        val ctx = canvas_create(100, 100)
        canvas_rotate(ctx, 1.57)
        val cmds = canvas_get_commands(ctx)
        expect(cmds[0]).to_contain("rotate")

describe "Canvas API - Text Measurement":
    it "measures text width":
        val ctx = canvas_create(100, 100)
        val w = canvas_measure_text(ctx, "Hello")
        expect(w > 0.0).to_be_true()
