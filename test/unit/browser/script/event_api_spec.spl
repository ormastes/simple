"""
# Event API Spec

Unit tests for the Simple browser engine Event API.
"""

use std.spec.{describe, it, expect}
use std.gc_async_mut.gpu.browser_engine.dom.{BeDomNode, BeDomEvent}
use std.gc_async_mut.gpu.browser_engine.script.event_api.{
    node_add_event_listener, node_remove_event_listener,
    event_create, event_dispatch,
    event_prevent_default, event_stop_propagation
}

describe "Event API - Listener Registration":
    it "adds an event listener":
        val el = BeDomNode.element("button")
        node_add_event_listener(el, "click", "handle_click", false)
        expect(el.event_listener_types.len()).to_equal(1)

    it "removes an event listener":
        val el = BeDomNode.element("button")
        node_add_event_listener(el, "click", "handle_click", false)
        node_remove_event_listener(el, "click", "handle_click")
        expect(el.event_listener_types.len()).to_equal(0)

    it "adds capture phase listener":
        val el = BeDomNode.element("div")
        node_add_event_listener(el, "click", "cap_handler", true)
        expect(el.event_listener_capture[0]).to_be_true()

describe "Event API - Event Creation":
    it "creates an event with type":
        val ev = event_create("click", "btn1")
        expect(ev.event_type).to_equal("click")

    it "creates event with target id":
        val ev = event_create("click", "btn1")
        expect(ev.target_id).to_equal("btn1")

    it "created events bubble by default":
        val ev = event_create("keydown", "input1")
        expect(ev.bubbles).to_be_true()

describe "Event API - Event Control":
    it "prevents default action":
        val ev = event_create("submit", "form1")
        event_prevent_default(ev)
        expect(ev.default_prevented).to_be_true()

    it "stops propagation":
        val ev = event_create("click", "btn1")
        event_stop_propagation(ev)
        expect(ev.propagation_stopped).to_be_true()

describe "Event API - Dispatch":
    it "dispatches returns actions for registered listeners":
        val el = BeDomNode.element("button")
        node_add_event_listener(el, "click", "on_click", false)
        val ev = event_create("click", "btn")
        val actions = event_dispatch(el, ev)
        expect(actions.len()).to_equal(1)
