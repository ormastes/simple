"""
# text.slice() and text.substring() Specification

**Feature IDs:** #INTERP-SLICE-001
**Category:** Runtime
**Difficulty:** 2/5
**Status:** In Progress
**Requirements:** N/A
**Plan:** N/A
**Design:** N/A
**Research:** doc/bug/bug_report_text_slice_substring.md

## Overview

Verifies that text.slice(start, end) and text.substring(start, end)
return correct substrings. Previously:
- slice() was completely missing from the interpreter
- substring() crashed with "string index out of bounds"
- char_code_at and char_at also used broken substring internally

## Syntax

```simple
val s = "abcdefghijk"
s.slice(0, 5)       # "abcde"
s.substring(0, 5)   # "abcde"
s[2:5]              # "cde" (slice expression)
s.char_at(3)        # "d"
```

"""

use std.spec


# ============================================================================
# Test Group 1: text.slice() — Core Functionality
# ============================================================================

describe "text.slice() method":
    """
    ## Core Slicing

    slice(start, end) returns substring from index start (inclusive)
    to end (exclusive).
    """

    context "single character extraction":
        it "slices first character":
            val s = "abcdefghijk"
            expect(s.slice(0, 1)).to_equal("a")

        it "slices second character":
            val s = "abcdefghijk"
            expect(s.slice(1, 2)).to_equal("b")

        it "slices last character":
            val s = "abcdefghijk"
            expect(s.slice(10, 11)).to_equal("k")

        it "slices middle character":
            val s = "abcdefghijk"
            expect(s.slice(5, 6)).to_equal("f")

    context "multi-character ranges":
        it "slices first two characters":
            val s = "abcdefghijk"
            expect(s.slice(0, 2)).to_equal("ab")

        it "slices first three characters":
            val s = "abcdefghijk"
            expect(s.slice(0, 3)).to_equal("abc")

        it "slices first five characters":
            val s = "abcdefghijk"
            expect(s.slice(0, 5)).to_equal("abcde")

        it "slices from middle to middle":
            val s = "abcdefghijk"
            expect(s.slice(2, 5)).to_equal("cde")

        it "slices from offset 1":
            val s = "abcdefghijk"
            expect(s.slice(1, 5)).to_equal("bcde")

        it "slices tail portion":
            val s = "abcdefghijk"
            expect(s.slice(5, 11)).to_equal("fghijk")

        it "slices entire string":
            val s = "abcdefghijk"
            expect(s.slice(0, 11)).to_equal("abcdefghijk")

    context "boundary and edge cases":
        it "returns empty for equal start and end":
            val s = "abcdefghijk"
            expect(s.slice(3, 3)).to_equal("")

        it "returns empty for reversed range":
            val s = "abcdefghijk"
            expect(s.slice(5, 3)).to_equal("")

        it "clamps end beyond string length":
            val s = "abc"
            expect(s.slice(0, 100)).to_equal("abc")

        it "clamps negative start to 0":
            val s = "abc"
            expect(s.slice(-5, 2)).to_equal("ab")

        it "handles single-char string":
            val s = "x"
            expect(s.slice(0, 1)).to_equal("x")

        it "handles two-char string":
            val s = "ab"
            expect(s.slice(0, 1)).to_equal("a")
            expect(s.slice(1, 2)).to_equal("b")
            expect(s.slice(0, 2)).to_equal("ab")

    context "one-argument form":
        it "slices from start to end of string":
            val s = "abcdefghijk"
            expect(s.slice(0)).to_equal("abcdefghijk")

        it "slices tail from offset":
            val s = "abcdefghijk"
            expect(s.slice(5)).to_equal("fghijk")

    context "various string contents":
        it "slices string with spaces":
            val s = "hello world"
            expect(s.slice(0, 5)).to_equal("hello")
            expect(s.slice(6, 11)).to_equal("world")

        it "slices string with numbers":
            val s = "abc123def"
            expect(s.slice(3, 6)).to_equal("123")

        it "slices string with special characters":
            val s = "a-b_c.d"
            expect(s.slice(1, 4)).to_equal("-b_")

        it "slices path-like string":
            val s = "/home/user/file.txt"
            expect(s.slice(0, 5)).to_equal("/home")

        it "slices comma-separated values":
            val s = "one,two,three"
            expect(s.slice(0, 3)).to_equal("one")
            expect(s.slice(4, 7)).to_equal("two")
            expect(s.slice(8, 13)).to_equal("three")


# ============================================================================
# Test Group 2: text.substring() Method
# ============================================================================

describe "text.substring() method":
    """
    ## Substring Extraction

    substring(start, end) should behave identically to slice(start, end).
    """

    context "two-argument form":
        it "extracts from start":
            val s = "abcdefghijk"
            expect(s.substring(0, 5)).to_equal("abcde")

        it "extracts from middle":
            val s = "abcdefghijk"
            expect(s.substring(2, 5)).to_equal("cde")

        it "extracts single character":
            val s = "abcdefghijk"
            expect(s.substring(3, 4)).to_equal("d")

        it "extracts to end":
            val s = "abcdefghijk"
            expect(s.substring(5, 11)).to_equal("fghijk")

        it "extracts full string":
            val s = "abcdefghijk"
            expect(s.substring(0, 11)).to_equal("abcdefghijk")

    context "one-argument form":
        it "extracts from start to end of string":
            val s = "abcdefghijk"
            expect(s.substring(0)).to_equal("abcdefghijk")

        it "extracts tail":
            val s = "abcdefghijk"
            expect(s.substring(5)).to_equal("fghijk")

        it "extracts last character":
            val s = "abcdefghijk"
            expect(s.substring(10)).to_equal("k")

    context "boundary handling":
        it "clamps negative start to 0":
            val s = "abc"
            expect(s.substring(-1, 2)).to_equal("ab")

        it "clamps end beyond length":
            val s = "abc"
            expect(s.substring(0, 100)).to_equal("abc")

        it "returns empty for reversed range":
            val s = "abc"
            expect(s.substring(2, 1)).to_equal("")

        it "returns empty for start at length":
            val s = "abc"
            expect(s.substring(3, 3)).to_equal("")


# ============================================================================
# Test Group 3: Slice Expression s[start:end]
# ============================================================================

describe "text slice expression s[start:end]":
    """
    ## Bracket Slice Syntax

    s[start:end] is the slice expression form.
    """

    it "slices first five characters":
        val s = "abcdefghijk"
        expect(s[0:5]).to_equal("abcde")

    it "slices middle range":
        val s = "abcdefghijk"
        expect(s[2:5]).to_equal("cde")

    it "slices single character":
        val s = "abcdefghijk"
        expect(s[0:1]).to_equal("a")

    it "slices to end":
        val s = "abcdefghijk"
        expect(s[5:11]).to_equal("fghijk")

    it "slices full string":
        val s = "abcdefghijk"
        expect(s[0:11]).to_equal("abcdefghijk")

    it "returns empty for equal indices":
        val s = "abcdefghijk"
        expect(s[3:3]).to_equal("")


# ============================================================================
# Test Group 4: text.char_at() Method
# ============================================================================

describe "text.char_at() method":
    """
    ## Character Access as Text

    char_at(i) returns the character at index i as a text value.
    """

    it "returns first character":
        val s = "hello"
        expect(s.char_at(0)).to_equal("h")

    it "returns second character":
        val s = "hello"
        expect(s.char_at(1)).to_equal("e")

    it "returns middle character":
        val s = "hello"
        expect(s.char_at(2)).to_equal("l")

    it "returns last character":
        val s = "hello"
        expect(s.char_at(4)).to_equal("o")

    it "returns empty for out-of-bounds index":
        val s = "hello"
        expect(s.char_at(10)).to_equal("")

    it "returns empty for negative index":
        val s = "hello"
        expect(s.char_at(-1)).to_equal("")


# ============================================================================
# Test Group 5: text.char_code_at() Method
# ============================================================================

describe "text.char_code_at() method":
    """
    ## Character Code Access

    char_code_at(i) returns the Unicode code point of char at index i.
    """

    it "returns code for 'a'":
        val s = "abc"
        expect(s.char_code_at(0)).to_equal(97)

    it "returns code for 'b'":
        val s = "abc"
        expect(s.char_code_at(1)).to_equal(98)

    it "returns code for 'A'":
        val s = "ABC"
        expect(s.char_code_at(0)).to_equal(65)

    it "returns 0 for out-of-bounds":
        val s = "abc"
        expect(s.char_code_at(10)).to_equal(0)


# ============================================================================
# Test Group 6: text Indexing s[i]
# ============================================================================

describe "text indexing s[i]":
    """
    ## Single Character Indexing

    s[i] returns the character at position i.
    """

    it "gets first character":
        val s = "abc"
        val ch = s[0]
        expect(ch).to_equal("a")

    it "gets middle character":
        val s = "abc"
        val ch = s[1]
        expect(ch).to_equal("b")

    it "gets last character":
        val s = "abc"
        val ch = s[2]
        expect(ch).to_equal("c")

    it "gets space character":
        val s = "a b"
        val ch = s[1]
        expect(ch).to_equal(" ")


# ============================================================================
# Test Group 7: Regression — Other text Methods
# ============================================================================

describe "text methods regression":
    """
    ## Regression Tests

    Ensure existing text methods still work after slice/substring fixes.
    """

    it "len() still works":
        expect("hello".len()).to_equal(5)
        expect("".len()).to_equal(0)

    it "contains() still works":
        expect("hello".contains("ell")).to_equal(true)
        expect("hello".contains("xyz")).to_equal(false)

    it "starts_with() still works":
        expect("hello".starts_with("hel")).to_equal(true)
        expect("hello".starts_with("xyz")).to_equal(false)

    it "ends_with() still works":
        expect("hello".ends_with("llo")).to_equal(true)
        expect("hello".ends_with("xyz")).to_equal(false)

    it "trim() still works":
        expect("  hello  ".trim()).to_equal("hello")

    it "replace() still works":
        expect("hello".replace("l", "r")).to_equal("herro")

    it "split() still works":
        val parts = "a,b,c".split(",")
        expect(parts.len()).to_equal(3)

    it "index_of() still works":
        val idx = "hello".index_of("ll")
        expect(idx ?? -1).to_equal(2)

    it "to_upper() still works":
        expect("hello".to_upper()).to_equal("HELLO")

    it "to_lower() still works":
        expect("HELLO".to_lower()).to_equal("hello")

    it "to_string() still works":
        expect("hello".to_string()).to_equal("hello")
