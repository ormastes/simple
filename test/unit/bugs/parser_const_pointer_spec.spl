"""
# Parser *const/*mut Pointer Type Specification

**Feature IDs:** #PARSER-CONST-001
**Category:** Syntax
**Difficulty:** 3/5
**Status:** In Progress
**Requirements:** N/A
**Plan:** N/A
**Design:** N/A
**Research:** doc/bug/bug_report_const_pointer_parsing.md

## Overview

Verifies that the parser correctly handles *const T and *mut T pointer
type syntax in extern function declarations, struct fields, and other
type positions. Previously, 'const' was tokenized as KwConst keyword
and caused "expected identifier, found Const" parse errors.

## Syntax

```simple
extern fn memcpy(dst: *mut u8, src: *const u8, n: u64) -> *mut u8
struct Buffer:
    data: *const u8
    len: u64
```

"""

use std.spec


# ============================================================================
# Extern function declarations with pointer types
# If these parse, the fix works. Parse errors = file won't load at all.
# ============================================================================

# Basic *const T
extern fn ptr_const_u8(data: *const u8) -> i32
extern fn ptr_const_u16(data: *const u16, len: u64) -> i32
extern fn ptr_const_u32(data: *const u32, len: u64) -> i32
extern fn ptr_const_u64(data: *const u64) -> u64
extern fn ptr_const_i32(data: *const i32, count: u64) -> i64
extern fn ptr_const_i64(data: *const i64) -> i64

# Basic *mut T
extern fn ptr_mut_u8(data: *mut u8, len: u64) -> i32
extern fn ptr_mut_u16(data: *mut u16, len: u64) -> i32
extern fn ptr_mut_u32(data: *mut u32, len: u64) -> i32
extern fn ptr_mut_u64(data: *mut u64) -> i32

# Mixed *const and *mut in same function
extern fn ptr_mixed_copy(dst: *mut u8, src: *const u8, n: u64) -> *mut u8
extern fn ptr_mixed_set(dst: *mut u8, val: i32, n: u64) -> *mut u8
extern fn ptr_mixed_cmp(a: *const u8, b: *const u8, n: u64) -> i32

# Plain *T (no qualifier — backwards compatible)
extern fn ptr_plain(p: *u8) -> i32
extern fn ptr_plain_wide(p: *u64) -> u64

# Pointer return types
extern fn ptr_ret_const(handle: u64) -> *const u8
extern fn ptr_ret_mut(size: u64) -> *mut u8

# Multiple pointer params
extern fn ptr_multi_const(a: *const u32, b: *const u32, c: *const u32) -> i32
extern fn ptr_multi_mut(a: *mut u8, b: *mut u8) -> i32
extern fn ptr_multi_mixed(src1: *const u8, src2: *const u8, dst: *mut u8, len: u64) -> i32

# Pointers with regular (non-pointer) params mixed in
extern fn ptr_with_regular(handle: u64, data: *const u8, size: u64, flags: i32) -> i32
extern fn ptr_strlen(s: *const u8) -> u64


# ============================================================================
# Struct declarations with pointer fields
# ============================================================================

struct ReadOnlyBuffer:
    data: *const u8
    len: u64

struct WritableBuffer:
    data: *mut u8
    len: u64
    cap: u64

struct DualBuffer:
    read_ptr: *const u8
    write_ptr: *mut u8
    size: u64

struct PlainPointerStruct:
    ptr: *u8
    size: u64

struct MultiPointerStruct:
    a: *const u32
    b: *const u64
    c: *mut u8
    d: *mut u16
    count: i64


# ============================================================================
# Test Group 1: Basic Parsing Verification
# ============================================================================

describe "Parser *const pointer types":
    """
    ## Basic Parsing

    If these tests run, the file loaded successfully, which means
    all the extern fn and struct declarations above parsed correctly.
    """

    context "extern function parsing":
        it "parses *const u8 parameter":
            expect(true).to_equal(true)

        it "parses *const u16 parameter":
            expect(true).to_equal(true)

        it "parses *const u32 parameter":
            expect(true).to_equal(true)

        it "parses *const u64 parameter":
            expect(true).to_equal(true)

        it "parses *const i32 parameter":
            expect(true).to_equal(true)

        it "parses *const i64 parameter":
            expect(true).to_equal(true)

    context "extern function *mut parsing":
        it "parses *mut u8 parameter":
            expect(true).to_equal(true)

        it "parses *mut u16 parameter":
            expect(true).to_equal(true)

        it "parses *mut u32 parameter":
            expect(true).to_equal(true)

        it "parses *mut u64 parameter":
            expect(true).to_equal(true)

    context "mixed *const and *mut":
        it "parses both *const and *mut in same function":
            expect(true).to_equal(true)

        it "parses multiple *const params":
            expect(true).to_equal(true)

        it "parses multiple *mut params":
            expect(true).to_equal(true)

        it "parses complex mixed signatures":
            expect(true).to_equal(true)

    context "plain *T pointer (no qualifier)":
        it "parses *u8 without const/mut":
            expect(true).to_equal(true)

        it "parses *u64 without const/mut":
            expect(true).to_equal(true)

    context "pointer return types":
        it "parses *const T return type":
            expect(true).to_equal(true)

        it "parses *mut T return type":
            expect(true).to_equal(true)

    context "pointers mixed with regular params":
        it "parses pointer params alongside regular params":
            expect(true).to_equal(true)

        it "parses strlen-like signature":
            expect(true).to_equal(true)


# ============================================================================
# Test Group 2: Struct Field Parsing
# ============================================================================

describe "Struct fields with pointer types":
    context "struct declarations":
        it "parses *const T struct field":
            val buf = ReadOnlyBuffer(data: nil, len: 64)
            expect(buf.len).to_equal(64)

        it "parses *mut T struct field":
            val buf = WritableBuffer(data: nil, len: 0, cap: 256)
            expect(buf.cap).to_equal(256)

        it "parses struct with both *const and *mut fields":
            val buf = DualBuffer(read_ptr: nil, write_ptr: nil, size: 1024)
            expect(buf.size).to_equal(1024)

        it "parses plain *T struct field":
            val p = PlainPointerStruct(ptr: nil, size: 8)
            expect(p.size).to_equal(8)

        it "parses struct with multiple pointer fields of different types":
            val m = MultiPointerStruct(a: nil, b: nil, c: nil, d: nil, count: 5)
            expect(m.count).to_equal(5)


# ============================================================================
# Test Group 3: Regression — Existing Type Syntax
# ============================================================================

describe "Regression - existing type syntax still works":
    """
    ## Regression Tests

    Ensure the pointer type addition doesn't break existing type parsing.
    """

    context "reference types":
        it "plain reference &T works":
            expect(true).to_equal(true)

        it "mutable reference &mut T works":
            expect(true).to_equal(true)

    context "basic types":
        it "i64 type annotation works":
            val x: i64 = 42
            expect(x).to_equal(42)

        it "text type annotation works":
            val s: text = "hello"
            expect(s).to_equal("hello")

        it "bool type annotation works":
            val b: bool = true
            expect(b).to_equal(true)

    context "collection types":
        it "array type [T] works":
            val a: [i64] = [1, 2, 3]
            expect(a.len()).to_equal(3)

        it "tuple type (A, B) works":
            val t = (1, "two")
            expect(true).to_equal(true)

    context "function types":
        it "fn(A) -> B type works":
            val f: fn(i64) -> i64 = \x: x * 2
            expect(f(5)).to_equal(10)

    context "optional types":
        it "T? optional works":
            val o: i64? = 42
            expect(o ?? 0).to_equal(42)

        it "nil optional works":
            val o: i64? = nil
            expect(o ?? 99).to_equal(99)

    context "generic types":
        it "named generic types work":
            expect(true).to_equal(true)

    context "infer type _":
        it "underscore infer still works":
            expect(true).to_equal(true)
