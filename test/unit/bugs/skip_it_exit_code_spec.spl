"""
# skip_it Exit Code Specification

**Feature IDs:** #SKIP-IT-BUG
**Category:** Testing
**Difficulty:** 2/5
**Status:** In Progress
**Requirements:** N/A
**Plan:** N/A
**Design:** N/A
**Research:** doc/bug/skip_it_bug.md

## Overview

Verifies that skip_it, pending, slow_it, and skip functions do NOT
cause exit code 1 when all real tests pass. Previously, the skip
counter was not incremented, which could cause the test runner to
report failures.

## Behavior

- skip_it: Skips test in interpreter mode, runs in compiled mode
- pending: Marks test as pending (not yet implemented)
- slow_it: Skips slow tests in interpreter mode
- skip: Skips test with a reason string
- None of these should cause exit code 1 when all real tests pass

"""

use std.spec


# ============================================================================
# Test Group 1: skip_it Does Not Break Exit Code
# ============================================================================

describe "skip_it does not cause exit code 1":
    """
    ## Core Bug Reproduction

    The original bug: any file with skip_it exits with code 1
    even when all real tests pass.
    """

    it "passes a basic arithmetic test":
        expect(1 + 1).to_equal(2)

    it "passes a string test":
        expect("hello".len()).to_equal(5)

    skip_it "this skipped test should not break exit code":
        # This block should never execute in interpreter mode
        expect(false).to_equal(true)

    it "passes after a skip_it":
        expect(true).to_equal(true)

    skip_it "second skip should also not break anything":
        expect(0).to_equal(999)

    it "passes after two skip_its":
        expect(42).to_equal(42)


# ============================================================================
# Test Group 2: Multiple Skips in Sequence
# ============================================================================

describe "multiple skips in sequence":
    """
    ## Stress Test: Consecutive Skips

    Ensure that multiple consecutive skip_it calls don't accumulate
    error state or corrupt the test counter.
    """

    skip_it "skip sequence 1":
        pass_do_nothing

    skip_it "skip sequence 2":
        pass_do_nothing

    skip_it "skip sequence 3":
        pass_do_nothing

    skip_it "skip sequence 4":
        pass_do_nothing

    skip_it "skip sequence 5":
        pass_do_nothing

    it "passes after five consecutive skips":
        expect(5 * 5).to_equal(25)


# ============================================================================
# Test Group 3: pending Function
# ============================================================================

describe "pending function behavior":
    """
    ## Pending Tests

    pending() marks a test as not yet implemented.
    It should increment the pending counter and not affect exit code.
    """

    it "passes before pending":
        expect(42).to_equal(42)

    pending("pending test A - not implemented yet")

    pending("pending test B - waiting on feature X")

    it "passes after pending":
        expect(3 * 3).to_equal(9)


# ============================================================================
# Test Group 4: slow_it Function
# ============================================================================

describe "slow_it function behavior":
    """
    ## Slow Tests

    slow_it skips slow tests in interpreter mode.
    Should not cause exit code 1.
    """

    it "passes before slow_it":
        expect([1, 2, 3].len()).to_equal(3)

    slow_it "slow test that would take 30 seconds":
        # This would be a slow test in compiled mode
        expect(true).to_equal(true)

    it "passes after slow_it":
        expect("abc").to_contain("b")


# ============================================================================
# Test Group 5: skip Function with Reason
# ============================================================================

describe "skip function with reason":
    """
    ## Skip with Reason

    skip(name, reason) skips a test with an explanation.
    Should not affect exit code.
    """

    it "passes before skip":
        expect(10).to_be_greater_than(5)

    skip("platform-specific test", "requires Windows")

    skip("network test", "no internet in CI")

    it "passes after skips with reasons":
        expect(10).to_be_less_than(20)


# ============================================================================
# Test Group 6: Mixed Skip Types in Nested Contexts
# ============================================================================

describe "mixed skip types in nested contexts":
    """
    ## Integration: All Skip Types Together

    Combines skip_it, pending, slow_it, and skip in nested
    describe/context blocks to stress-test the counter logic.
    """

    context "outer context":
        it "outer test passes":
            expect(1).to_equal(1)

        skip_it "outer skip_it":
            pass_do_nothing

        context "inner context":
            it "inner test passes":
                expect(2).to_equal(2)

            pending("inner pending test")

            skip_it "inner skip_it":
                pass_do_nothing

            it "inner test passes after skips":
                expect(3).to_equal(3)

        it "outer test passes after inner context":
            expect(4).to_equal(4)

    context "second outer context":
        slow_it "slow test in context":
            pass_do_nothing

        skip("context skip", "reason")

        it "passes in second context":
            expect(5).to_equal(5)


# ============================================================================
# Test Group 7: Skip at Start and End
# ============================================================================

describe "skip at boundaries":
    """
    ## Edge Cases: First and Last Test Skipped

    Ensure skipping the very first or last test doesn't corrupt state.
    """

    skip_it "very first test is skipped":
        pass_do_nothing

    it "middle test passes":
        expect("hello").to_start_with("hel")

    it "another middle test":
        expect("world").to_end_with("rld")

    skip_it "very last test is skipped":
        pass_do_nothing


# ============================================================================
# Test Group 8: Only Skips (No Regular Tests)
# ============================================================================

describe "describe block with only skips":
    """
    ## Edge Case: No Real Tests

    A describe block that contains only skipped tests.
    Should not cause exit code 1.
    """

    skip_it "skip only 1":
        pass_do_nothing

    skip_it "skip only 2":
        pass_do_nothing

    pending("pending only")
