"""
# Dict Type Annotation on Empty Dict Specification

**Feature IDs:** #INTERP-DICT-001
**Category:** Runtime
**Difficulty:** 3/5
**Status:** In Progress
**Requirements:** N/A
**Plan:** N/A
**Design:** N/A
**Research:** doc/bug/bug_report_dict_type_annotation_interpreter.md

## Overview

Verifies Dict behavior. The known bug INTERP-DICT-001 is that empty
dict {} with type annotation is inferred as bool in interpreter mode.
Tests using Dict<K,V> type annotations are skip_it'd for interpreter.

## Workaround

Seed dicts with a dummy entry to force correct type inference.

"""

use std.spec


# ============================================================================
# Test Group 1: Non-Empty Dict (Control — Works in All Modes)
# ============================================================================

describe "Non-empty dict initialization":
    """
    ## Control Group

    Non-empty dict literals correctly infer types from their content.
    """

    it "creates dict from literal with string keys":
        var d = {"key": 42}
        expect(d["key"]).to_equal(42)

    it "creates dict with multiple entries":
        var d = {"a": 1, "b": 2, "c": 3}
        expect(d["a"]).to_equal(1)
        expect(d["b"]).to_equal(2)
        expect(d["c"]).to_equal(3)

    it "allows adding entries to non-empty dict":
        var d = {"init": 0}
        d["new_key"] = 99
        expect(d["new_key"]).to_equal(99)

    it "allows overwriting entries":
        var d = {"key": 1}
        d["key"] = 2
        expect(d["key"]).to_equal(2)

    it "supports text values":
        var d = {"name": "Alice"}
        expect(d["name"]).to_equal("Alice")

    it "supports bool values":
        var d = {"active": true}
        expect(d["active"]).to_equal(true)


# ============================================================================
# Test Group 2: Dict Workaround — Seed with Dummy Entry
# ============================================================================

describe "Dict workaround with seeded entry":
    """
    ## Workaround Verification

    Seeding with a dummy entry forces correct type inference.
    This works in both interpreter and compiled modes.
    """

    it "seeded text-to-int dict":
        var d = {"__init__": 0}
        d["real_key"] = 42
        expect(d["real_key"]).to_equal(42)

    it "seeded text-to-text dict":
        var d = {"__init__": ""}
        d["name"] = "Bob"
        expect(d["name"]).to_equal("Bob")

    it "seeded text-to-bool dict":
        var d = {"__init__": false}
        d["flag"] = true
        expect(d["flag"]).to_equal(true)

    it "seeded dict with many insertions":
        var d = {"__seed__": 0}
        d["alpha"] = 1
        d["beta"] = 2
        d["gamma"] = 3
        d["delta"] = 4
        d["epsilon"] = 5
        expect(d["alpha"]).to_equal(1)
        expect(d["epsilon"]).to_equal(5)

    it "seeded dict overwrite and read":
        var d = {"key": 100}
        expect(d["key"]).to_equal(100)
        d["key"] = 200
        expect(d["key"]).to_equal(200)
        d["key"] = 300
        expect(d["key"]).to_equal(300)


# ============================================================================
# Test Group 3: Dict Operations on Non-Empty Dicts
# ============================================================================

describe "Dict operations":
    """
    ## Dict Features

    Test dict operations that work with seeded (non-empty) dicts.
    """

    it "reads key that was just written":
        var d = {"x": 10}
        d["y"] = 20
        expect(d["x"]).to_equal(10)
        expect(d["y"]).to_equal(20)

    it "dict with numeric-like string keys":
        var d = {"1": 100}
        d["2"] = 200
        d["3"] = 300
        expect(d["1"]).to_equal(100)
        expect(d["2"]).to_equal(200)
        expect(d["3"]).to_equal(300)

    it "dict with long string keys":
        var d = {"short": 1}
        d["a_very_long_key_name_here"] = 42
        expect(d["a_very_long_key_name_here"]).to_equal(42)

    it "dict with empty string key":
        var d = {"": 0}
        d[""] = 99
        expect(d[""]).to_equal(99)

    it "dict with special char keys":
        var d = {"a-b": 1}
        d["c_d"] = 2
        d["e.f"] = 3
        expect(d["a-b"]).to_equal(1)
        expect(d["c_d"]).to_equal(2)
        expect(d["e.f"]).to_equal(3)


# ============================================================================
# Test Group 4: Dict with Text Values
# ============================================================================

describe "Dict with text values":
    it "stores and retrieves text values":
        var d = {"name": "Alice"}
        d["city"] = "NYC"
        d["role"] = "Dev"
        expect(d["name"]).to_equal("Alice")
        expect(d["city"]).to_equal("NYC")
        expect(d["role"]).to_equal("Dev")

    it "overwrites text values":
        var d = {"key": "old"}
        d["key"] = "new"
        expect(d["key"]).to_equal("new")

    it "stores empty string values":
        var d = {"key": "initial"}
        d["empty"] = ""
        expect(d["empty"]).to_equal("")


# ============================================================================
# Test Group 5: Empty Dict Bug Reproduction (skip_it — compiled-only)
# ============================================================================

describe "Empty dict type annotation bug reproduction":
    """
    ## Bug Reproduction (INTERP-DICT-001)

    These tests use Dict<K,V> type annotations on empty dicts.
    They are skip_it'd because:
    1. The interpreter parser may not support Dict<K,V> annotations
    2. Even if parsed, empty {} is inferred as bool (the actual bug)
    """

    skip_it "typed empty dict allows insertion (compiled-only)":
        # BUG: In interpreter mode, {} is inferred as bool
        # var d: Dict<text, i64> = {}
        # d["main"] = 42
        # expect(d["main"]).to_equal(42)
        expect(true).to_equal(true)

    skip_it "typed empty dict allows multiple insertions (compiled-only)":
        # BUG: In interpreter mode, this crashes with
        # "cannot index value of type bool"
        expect(true).to_equal(true)

    skip_it "typed empty dict len reports 0 (compiled-only)":
        # BUG: d.len() fails because d is bool, not Dict
        expect(true).to_equal(true)

    skip_it "shorthand typed empty dict (compiled-only)":
        # BUG: {text: i64} shorthand also fails
        expect(true).to_equal(true)


# ============================================================================
# Test Group 6: Regression — Array and Other Collections
# ============================================================================

describe "Regression - collections still work":
    """
    ## Regression Tests

    Ensure arrays and other collections aren't broken.
    """

    it "empty array with type annotation":
        var items: [i64] = []
        items.push(42)
        expect(items[0]).to_equal(42)

    it "empty text array with type annotation":
        var names: [text] = []
        names.push("hello")
        expect(names[0]).to_equal("hello")

    it "non-empty array works":
        val nums = [1, 2, 3, 4, 5]
        expect(nums.len()).to_equal(5)
        expect(nums[0]).to_equal(1)
        expect(nums[4]).to_equal(5)

    it "nested array works":
        val grid = [[1, 2], [3, 4]]
        expect(true).to_equal(true)

    it "array push and access":
        var arr: [text] = []
        arr.push("a")
        arr.push("b")
        arr.push("c")
        expect(arr.len()).to_equal(3)
        expect(arr[0]).to_equal("a")
        expect(arr[2]).to_equal("c")
