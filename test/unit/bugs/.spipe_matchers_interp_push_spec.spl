# Bug: Module-level .push() → "unsupported path call"
# Severity: P2
# Workaround: Use arr = arr + [item] for module-level arrays

fn _len(a): a.len()
fn _get(a, i): a[i]

# Module-level array - .push() fails here
var MODULE_ITEMS: [text] = []
var MODULE_COUNT = 0

# Workaround: concatenation instead of .push()
fn module_add_item(item: text):
    MODULE_ITEMS = MODULE_ITEMS + [item]
    MODULE_COUNT = MODULE_COUNT + 1

fn module_get_items() -> [text]:
    MODULE_ITEMS

# Wrap test logic in module-level functions to avoid closure capture limitation
fn _test_concat_workaround() -> Int:
    MODULE_ITEMS = []
    MODULE_COUNT = 0
    module_add_item("alpha")
    module_add_item("beta")
    module_add_item("gamma")
    MODULE_COUNT

fn _test_concat_items() -> [text]:
    MODULE_ITEMS = []
    MODULE_COUNT = 0
    module_add_item("alpha")
    module_add_item("beta")
    module_add_item("gamma")
    module_get_items()

fn _test_push_local() -> Int:
    var local_items: [text] = []
    local_items.push("one")
    local_items.push("two")
    local_items.len()

fn _test_push_local_first() -> text:
    var local_items: [text] = []
    local_items.push("one")
    local_items.push("two")
    local_items[0]

fn _test_preserve_items() -> text:
    MODULE_ITEMS = []
    MODULE_COUNT = 0
    module_add_item("first")
    module_add_item("second")
    val items = module_get_items()
    items[1]

describe "Module-level .push() bug":
    it "demonstrates workaround with concatenation":
        expect _test_concat_workaround() == 3
        val items = _test_concat_items()
        expect _len(items) == 3
        expect _get(items, 0) == "alpha"
        expect _get(items, 1) == "beta"
        expect _get(items, 2) == "gamma"

    it "push works inside local scope":
        expect _test_push_local() == 2
        expect _test_push_local_first() == "one"

    it "workaround preserves existing items":
        expect _test_preserve_items() == "second"