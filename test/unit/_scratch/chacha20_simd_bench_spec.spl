# Scratch bench: scalar vs SIMD ChaCha20 wall-clock at 1 KiB and 64 KiB.
# This is NOT a regression spec; recorded only for the commit message.
# Will be deleted before commit.

use std.spipe.*
use os.crypto.chacha20.{chacha20_encrypt, chacha20_encrypt_simd}

extern fn rt_time_now_unix_micros() -> i64

fn now_micros() -> i64:
    rt_time_now_unix_micros()

fn _key() -> [u8]:
    var k: [u8] = []
    var i: u64 = 0
    while i < 32:
        k.push((i & 0xFF).to_u8())
        i = i + 1
    k

fn _nonce() -> [u8]:
    [0u8,0u8,0u8,0u8,0u8,0u8,0u8,0x4au8,0u8,0u8,0u8,0u8]

fn _pt(n: u64) -> [u8]:
    var out: [u8] = []
    var i: u64 = 0
    while i < n:
        out.push(((i * 13u64 + 1u64) & 0xFF).to_u8())
        i = i + 1
    out

fn _bench_one(label: text, n: u64):
    val key = _key()
    val nonce = _nonce()
    val pt = _pt(n)

    val t0 = now_micros()
    val s = chacha20_encrypt(key, 1u32, nonce, pt)
    val t1 = now_micros()
    val v = chacha20_encrypt_simd(key, 1u32, nonce, pt)
    val t2 = now_micros()

    val scalar_us = t1 - t0
    val simd_us = t2 - t1
    print(label + " scalar=" + scalar_us.to_text() + "us simd=" + simd_us.to_text() + "us pt_len=" + pt.len().to_text() + " out_len_match=" + (s.len() == v.len()).to_text())

describe "ChaCha20 SIMD bench (informational)":
    it "1 KiB":
        _bench_one("1KiB", 1024u64)
        expect(true).to_equal(true)
    it "64 KiB":
        _bench_one("64KiB", 65536u64)
        expect(true).to_equal(true)
