use std.spipe.*
use std.simd.{Vec4i, simd_xor_i32x4, simd_shl_i32x4, simd_shr_i32x4, simd_or_i32x4}

describe "Vec4i construction":
    it "construct with u32-pattern constants via i32 cast":
        # 0x61707865 = 1634760805 as i32 (positive)
        # 0x3320646e = 857760878
        # 0x79622d32 = 2036477234
        # 0x6b206574 = 1797285228
        val v = Vec4i(x: 0x61707865, y: 0x3320646e, z: 0x79622d32, w: 0x6b206574)
        expect(v.x).to_equal(0x61707865)
        expect(v.w).to_equal(0x6b206574)
    it "rotate-left composition (rotl by 16) via shl|shr":
        val v = Vec4i(x: 0x12345678, y: 0x12345678, z: 0x12345678, w: 0x12345678)
        # rotl(x, 16) = (x << 16) | (x >> 16)  -- logical shr
        val l = simd_shl_i32x4(v, 16)
        val r = simd_shr_i32x4(v, 16)
        val rotated = simd_or_i32x4(l, r)
        # 0x12345678 rotl 16 = 0x56781234
        expect(rotated.x).to_equal(0x56781234)
    it "convert i32 lane to u32 via to_u32":
        # i32 0x80000000 = -2147483648 ; .to_u32() should yield 0x80000000 = 2147483648u32
        var v: i32 = -2147483648
        expect(v.to_u32()).to_equal(0x80000000u32)
