# VHDL Subprogram Emission Model Unit Tests
# Self-contained — all classes defined inline.
# 20 tests covering SubprogramKind, FunctionLower, ProcedureLower,
# SubprogramDecision, VhdlSanitizedName, CollisionCheck, StatefulCheck,
# CycleDetection, EmissionDiagnostic, SelectionCriteria.

class SubprogramKind:
    kind: text
    reason: text
    is_combinational: bool
    helper_name: text

    me is_function() -> bool:
        self.kind == "function"

    me is_procedure() -> bool:
        self.kind == "procedure"

    me is_entity() -> bool:
        self.kind == "entity"

    static fn function(name: text, r: text) -> SubprogramKind:
        SubprogramKind { kind: "function", reason: r, is_combinational: true, helper_name: name }

    static fn procedure(name: text, r: text) -> SubprogramKind:
        SubprogramKind { kind: "procedure", reason: r, is_combinational: false, helper_name: name }

    static fn entity(name: text, r: text) -> SubprogramKind:
        SubprogramKind { kind: "entity", reason: r, is_combinational: false, helper_name: name }

class FunctionLower:
    helper_name: text
    return_type: text
    param_count: int
    is_pure: bool
    vhdl_signature: text

    me is_single_return() -> bool:
        self.return_type != "" and self.return_type != "void"

    static fn create(name: text, ret: text, params: int, pure: bool) -> FunctionLower:
        FunctionLower { helper_name: name, return_type: ret, param_count: params, is_pure: pure, vhdl_signature: "" }

class ProcedureLower:
    helper_name: text
    out_count: int
    in_count: int
    total_params: int
    uses_record: bool

    me is_multi_output() -> bool:
        self.out_count > 1

    static fn create(name: text, ins: int, outs: int) -> ProcedureLower:
        ProcedureLower { helper_name: name, out_count: outs, in_count: ins, total_params: ins + outs, uses_record: false }

class SubprogramDecision:
    helper_ref: text
    chosen_kind: text
    reject_reason: text
    fallback_to_entity: bool

    me is_accepted() -> bool:
        self.reject_reason == ""

    me is_fallback() -> bool:
        self.fallback_to_entity

    static fn accept(ref: text, kind: text) -> SubprogramDecision:
        SubprogramDecision { helper_ref: ref, chosen_kind: kind, reject_reason: "", fallback_to_entity: false }

    static fn reject(ref: text, reason: text) -> SubprogramDecision:
        SubprogramDecision { helper_ref: ref, chosen_kind: "", reject_reason: reason, fallback_to_entity: true }

class VhdlSanitizedName:
    original_name: text
    sanitized_name: text
    was_modified: bool
    collision_index: int

    me needs_suffix() -> bool:
        self.collision_index > 0

    me final_name() -> text:
        if self.collision_index > 0:
            return self.sanitized_name + "_" + self.collision_index.to_text()
        self.sanitized_name

    static fn unchanged(name: text) -> VhdlSanitizedName:
        VhdlSanitizedName { original_name: name, sanitized_name: name, was_modified: false, collision_index: 0 }

    static fn sanitized(orig: text, safe: text) -> VhdlSanitizedName:
        VhdlSanitizedName { original_name: orig, sanitized_name: safe, was_modified: true, collision_index: 0 }

class CollisionCheck:
    name_a: text
    name_b: text
    is_collision: bool
    resolution: text

    me has_collision() -> bool:
        self.is_collision

    static fn no_collision(a: text, b: text) -> CollisionCheck:
        CollisionCheck { name_a: a, name_b: b, is_collision: false, resolution: "" }

    static fn collision(a: text, b: text, res: text) -> CollisionCheck:
        CollisionCheck { name_a: a, name_b: b, is_collision: true, resolution: res }

class StatefulCheck:
    helper_name: text
    has_state: bool
    state_kind: text
    diagnostic_msg: text

    me is_stateful() -> bool:
        self.has_state

    static fn pure(name: text) -> StatefulCheck:
        StatefulCheck { helper_name: name, has_state: false, state_kind: "", diagnostic_msg: "" }

    static fn stateful(name: text, kind: text, msg: text) -> StatefulCheck:
        StatefulCheck { helper_name: name, has_state: true, state_kind: kind, diagnostic_msg: msg }

class CycleDetection:
    caller: text
    callee: text
    is_cycle: bool
    cycle_depth: int

    me has_cycle() -> bool:
        self.is_cycle

    me is_self_recursive() -> bool:
        self.caller == self.callee

    static fn no_cycle(from: text, to: text) -> CycleDetection:
        CycleDetection { caller: from, callee: to, is_cycle: false, cycle_depth: 0 }

    static fn cycle(from: text, to: text, depth: int) -> CycleDetection:
        CycleDetection { caller: from, callee: to, is_cycle: true, cycle_depth: depth }

class EmissionDiagnostic:
    diagnostic_kind: text
    helper_name: text
    message: text
    severity: text

    me is_error() -> bool:
        self.severity == "error"

    me is_warning() -> bool:
        self.severity == "warning"

    static fn error(kind: text, name: text, msg: text) -> EmissionDiagnostic:
        EmissionDiagnostic { diagnostic_kind: kind, helper_name: name, message: msg, severity: "error" }

    static fn warning(kind: text, name: text, msg: text) -> EmissionDiagnostic:
        EmissionDiagnostic { diagnostic_kind: kind, helper_name: name, message: msg, severity: "warning" }

class SelectionCriteria:
    has_ports: bool
    has_state: bool
    has_process: bool
    return_count: int

    me needs_entity() -> bool:
        self.has_ports or self.has_state or self.has_process

    me can_be_function() -> bool:
        self.return_count == 1 and self.has_ports == false and self.has_state == false and self.has_process == false

    static fn pure_single() -> SelectionCriteria:
        SelectionCriteria { has_ports: false, has_state: false, has_process: false, return_count: 1 }

    static fn stateful() -> SelectionCriteria:
        SelectionCriteria { has_ports: false, has_state: true, has_process: false, return_count: 0 }

fn test_kind_function():
    val sk = SubprogramKind.function("add", "pure fn")
    if sk.kind == "function":
        print("PASS: test_kind_function")
    else:
        print("FAIL: test_kind_function")

fn test_kind_procedure():
    val sk = SubprogramKind.procedure("write_reg", "multi-output")
    if sk.kind == "procedure":
        print("PASS: test_kind_procedure")
    else:
        print("FAIL: test_kind_procedure")

fn test_kind_entity():
    val sk = SubprogramKind.entity("uart", "has ports")
    if sk.kind == "entity":
        print("PASS: test_kind_entity")
    else:
        print("FAIL: test_kind_entity")

fn test_func_lower():
    val fl = FunctionLower.create("add_fn", "i32", 2, true)
    if fl.return_type == "i32" and fl.param_count == 2:
        print("PASS: test_func_lower")
    else:
        print("FAIL: test_func_lower")

fn test_func_single_return():
    val fl = FunctionLower.create("clamp_fn", "f32", 3, true)
    if fl.is_single_return():
        print("PASS: test_func_single_return")
    else:
        print("FAIL: test_func_single_return")

fn test_proc_lower():
    val pl = ProcedureLower.create("divmod", 2, 2)
    if pl.in_count == 2 and pl.out_count == 2:
        print("PASS: test_proc_lower")
    else:
        print("FAIL: test_proc_lower")

fn test_proc_multi_output():
    val pl = ProcedureLower.create("rgb_split", 1, 3)
    if pl.is_multi_output():
        print("PASS: test_proc_multi_output")
    else:
        print("FAIL: test_proc_multi_output")

fn test_decision_accept():
    val sd = SubprogramDecision.accept("add_fn", "function")
    if sd.is_accepted():
        print("PASS: test_decision_accept")
    else:
        print("FAIL: test_decision_accept")

fn test_decision_reject():
    val sd = SubprogramDecision.reject("uart_fn", "has ports")
    if sd.fallback_to_entity:
        print("PASS: test_decision_reject")
    else:
        print("FAIL: test_decision_reject")

fn test_name_unchanged():
    val sn = VhdlSanitizedName.unchanged("add")
    if sn.was_modified == false:
        print("PASS: test_name_unchanged")
    else:
        print("FAIL: test_name_unchanged")

fn test_name_sanitized():
    val sn = VhdlSanitizedName.sanitized("my-fn", "my_fn")
    if sn.was_modified:
        print("PASS: test_name_sanitized")
    else:
        print("FAIL: test_name_sanitized")

fn test_name_collision_suffix():
    val sn = VhdlSanitizedName { original_name: "add", sanitized_name: "add", was_modified: false, collision_index: 1 }
    if sn.needs_suffix():
        print("PASS: test_name_collision_suffix")
    else:
        print("FAIL: test_name_collision_suffix")

fn test_collision_none():
    val cc = CollisionCheck.no_collision("add", "sub")
    if cc.is_collision == false:
        print("PASS: test_collision_none")
    else:
        print("FAIL: test_collision_none")

fn test_collision_found():
    val cc = CollisionCheck.collision("add", "add", "add_0")
    if cc.has_collision():
        print("PASS: test_collision_found")
    else:
        print("FAIL: test_collision_found")

fn test_stateful_pure():
    val sc = StatefulCheck.pure("logic_fn")
    if sc.has_state == false:
        print("PASS: test_stateful_pure")
    else:
        print("FAIL: test_stateful_pure")

fn test_stateful_signal():
    val sc = StatefulCheck.stateful("counter", "signal", "contains signal assignment")
    if sc.is_stateful():
        print("PASS: test_stateful_signal")
    else:
        print("FAIL: test_stateful_signal")

fn test_cycle_none():
    val cd = CycleDetection.no_cycle("a", "b")
    if cd.is_cycle == false:
        print("PASS: test_cycle_none")
    else:
        print("FAIL: test_cycle_none")

fn test_cycle_found():
    val cd = CycleDetection.cycle("a", "b", 2)
    if cd.has_cycle():
        print("PASS: test_cycle_found")
    else:
        print("FAIL: test_cycle_found")

fn test_self_recursive():
    val cd = CycleDetection.cycle("fib", "fib", 1)
    if cd.is_self_recursive():
        print("PASS: test_self_recursive")
    else:
        print("FAIL: test_self_recursive")

fn test_diag_error():
    val ed = EmissionDiagnostic.error("cycle", "fib", "self-recursive call")
    if ed.severity == "error":
        print("PASS: test_diag_error")
    else:
        print("FAIL: test_diag_error")

fn main():
    test_kind_function()
    test_kind_procedure()
    test_kind_entity()
    test_func_lower()
    test_func_single_return()
    test_proc_lower()
    test_proc_multi_output()
    test_decision_accept()
    test_decision_reject()
    test_name_unchanged()
    test_name_sanitized()
    test_name_collision_suffix()
    test_collision_none()
    test_collision_found()
    test_stateful_pure()
    test_stateful_signal()
    test_cycle_none()
    test_cycle_found()
    test_self_recursive()
    test_diag_error()
    print("DONE")
