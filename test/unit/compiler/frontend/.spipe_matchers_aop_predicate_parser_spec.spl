# @cover src/compiler/10.frontend/core/aop_predicate_parser.spl 80%
use std.spec
use compiler.frontend.core.aop_predicate_parser.{validate_predicate, validate_advice_form}

describe "AOP Predicate Parser":
    describe "validate_predicate":
        it "accepts wildcard predicate":
            expect validate_predicate("*") == ""

        it "accepts execution selector":
            expect validate_predicate("execution(* foo(..))") == ""

        it "accepts within selector":
            expect validate_predicate("within(services.*)") == ""

        it "accepts attr selector":
            expect validate_predicate("attr(logged)") == ""

        it "accepts AND operator":
            expect validate_predicate("execution(* foo(..)) & attr(logged)") == ""

        it "accepts OR operator":
            expect validate_predicate("execution(* a(..)) | execution(* b(..))") == ""

        it "accepts NOT operator":
            expect validate_predicate("!execution(* skip(..))") == ""

        it "accepts grouped expression":
            expect validate_predicate("(execution(*) | within(svc.*)) & attr(tx)") == ""

        it "rejects empty predicate":
            expect (validate_predicate("")).starts_with("E1501")

        it "rejects deferred selector get":
            expect (validate_predicate("get(field)")).starts_with("E1507")

        it "rejects deferred selector set":
            expect (validate_predicate("set(field)")).starts_with("E1507")

        it "rejects deferred selector init":
            expect (validate_predicate("init(Type)")).starts_with("E1507")

        it "rejects deferred selector effect":
            expect (validate_predicate("effect(io)")).starts_with("E1507")

        it "rejects unknown selector":
            expect (validate_predicate("foobar(x)")).starts_with("E1507")

        it "rejects unmatched parenthesis":
            expect(validate_predicate("execution(* foo(..")).to_start_with("E1501")

    describe "validate_advice_form":
        it "accepts before":
            expect validate_advice_form("before") == ""

        it "accepts after_success":
            expect validate_advice_form("after_success") == ""

        it "accepts after_error":
            expect validate_advice_form("after_error") == ""

        it "accepts around":
            expect validate_advice_form("around") == ""

        it "rejects invalid form":
            expect (validate_advice_form("invalid")).starts_with("E1503")