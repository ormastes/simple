use std.spec.{describe, it, expect}

@packed
struct PciStatus:
    vendor: u32:16
    command: u32:4

describe "@packed struct sugar":
    it "round-trips field read/write":
        var s: PciStatus = PciStatus(0)
        s.command = 5
        expect(s.command).to_equal(5)

    it "preserves adjacent fields on write":
        var s: PciStatus = PciStatus(0)
        s.vendor = 42
        s.command = 7
        expect(s.vendor).to_equal(42)
        expect(s.command).to_equal(7)
