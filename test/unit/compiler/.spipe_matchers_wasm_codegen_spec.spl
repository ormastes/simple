# WAT Codegen Specification
#
# Tests for the WAT-based WASM backend (Phase 2).
# Validates MIR to WAT translation, control flow structuring,
# memory layout, string table, and WASI import declarations.

use compiler.backend.wasm_backend.*
use compiler.backend.wasm_type_mapper.{WasmTypeMapper, WasmTypeMapper__create_wasm32}
use compiler.mir.mir_data.*

describe "WAT Codegen":

    context "WatBuilder basics":
        it "creates empty module":
            var builder = WatBuilder.create()
            builder.begin_module("test")
            builder.end_module()
            val wat = builder.build()
            expect (wat).contains("(module $test")
            expect (wat).contains(")")

        it "emits i32 const":
            var builder = WatBuilder.create()
            builder.emit_i32_const(42)
            val wat = builder.build()
            expect (wat).contains("i32.const 42")

        it "emits i64 const":
            var builder = WatBuilder.create()
            builder.emit_i64_const(100)
            val wat = builder.build()
            expect (wat).contains("i64.const 100")

        it "emits f64 const":
            var builder = WatBuilder.create()
            builder.emit_f64_const(3.14)
            val wat = builder.build()
            expect (wat).contains("f64.const")

        it "emits local get and set by name":
            var builder = WatBuilder.create()
            builder.emit_local_named_get("x")
            builder.emit_local_named_set("y")
            val wat = builder.build()
            expect (wat).contains("local.get $x")
            expect (wat).contains("local.set $y")

        it "emits call by name":
            var builder = WatBuilder.create()
            builder.emit_call_named("my_func")
            val wat = builder.build()
            expect (wat).contains("call $my_func")

    context "WatBuilder control flow":
        it "emits block and end":
            var builder = WatBuilder.create()
            builder.emit_block("exit")
            builder.emit_end()
            val wat = builder.build()
            expect (wat).contains("(block $exit")

        it "emits loop":
            var builder = WatBuilder.create()
            builder.emit_loop("loop_start")
            builder.emit_end()
            val wat = builder.build()
            expect (wat).contains("(loop $loop_start")

        it "emits branch instructions":
            var builder = WatBuilder.create()
            builder.emit_br("target")
            builder.emit_br_if("cond_target")
            val wat = builder.build()
            expect (wat).contains("br $target")
            expect (wat).contains("br_if $cond_target")

        it "emits return":
            var builder = WatBuilder.create()
            builder.emit_return()
            val wat = builder.build()
            expect (wat).contains("return")

        it "emits unreachable":
            var builder = WatBuilder.create()
            builder.emit_unreachable()
            val wat = builder.build()
            expect (wat).contains("unreachable")

    context "WatBuilder arithmetic":
        it "emits i64 arithmetic":
            var builder = WatBuilder.create()
            builder.emit_i64_add()
            builder.emit_i64_sub()
            builder.emit_i64_mul()
            builder.emit_i64_div_s()
            builder.emit_i64_rem_s()
            val wat = builder.build()
            expect (wat).contains("i64.add")
            expect (wat).contains("i64.sub")
            expect (wat).contains("i64.mul")
            expect (wat).contains("i64.div_s")
            expect (wat).contains("i64.rem_s")

        it "emits f64 arithmetic":
            var builder = WatBuilder.create()
            builder.emit_f64_add()
            builder.emit_f64_sub()
            builder.emit_f64_mul()
            builder.emit_f64_div()
            val wat = builder.build()
            expect (wat).contains("f64.add")
            expect (wat).contains("f64.sub")
            expect (wat).contains("f64.mul")
            expect (wat).contains("f64.div")

    context "WatBuilder comparison":
        it "emits i64 comparisons":
            var builder = WatBuilder.create()
            builder.emit_i64_eq()
            builder.emit_i64_ne()
            builder.emit_i64_lt_s()
            builder.emit_i64_ge_s()
            val wat = builder.build()
            expect (wat).contains("i64.eq")
            expect (wat).contains("i64.ne")
            expect (wat).contains("i64.lt_s")
            expect (wat).contains("i64.ge_s")

        it "emits f64 comparisons":
            var builder = WatBuilder.create()
            builder.emit_f64_eq()
            builder.emit_f64_lt()
            builder.emit_f64_gt()
            val wat = builder.build()
            expect (wat).contains("f64.eq")
            expect (wat).contains("f64.lt")
            expect (wat).contains("f64.gt")

    context "WatBuilder memory":
        it "emits i32 load and store":
            var builder = WatBuilder.create()
            builder.emit_i32_load(0, 4)
            builder.emit_i32_store(8, 4)
            val wat = builder.build()
            expect (wat).contains("i32.load offset=0 align=4")
            expect (wat).contains("i32.store offset=8 align=4")

        it "emits global get and set":
            var builder = WatBuilder.create()
            builder.emit_global_get("heap_ptr")
            builder.emit_global_set("heap_ptr")
            val wat = builder.build()
            expect (wat).contains("global.get $heap_ptr")
            expect (wat).contains("global.set $heap_ptr")

    context "WatBuilder logical":
        it "emits logical ops":
            var builder = WatBuilder.create()
            builder.emit_i32_and()
            builder.emit_i32_or()
            builder.emit_i32_xor()
            builder.emit_i32_eqz()
            val wat = builder.build()
            expect (wat).contains("i32.and")
            expect (wat).contains("i32.or")
            expect (wat).contains("i32.xor")
            expect (wat).contains("i32.eqz")

    context "WasmType":
        it "converts to text correctly":
            expect WasmType.I32.to_text() == "i32"
            expect WasmType.I64.to_text() == "i64"
            expect WasmType.F32.to_text() == "f32"
            expect WasmType.F64.to_text() == "f64"
            expect WasmType.FuncRef.to_text() == "funcref"
            expect WasmType.ExternRef.to_text() == "externref"

    context "WasmTarget":
        it "detects JS glue needs":
            expect WasmTarget.Browser.needs_js_glue() == true
            expect WasmTarget.Wasi.needs_js_glue() == false
            expect WasmTarget.Minimal.needs_js_glue() == false

        it "detects WASI import needs":
            expect WasmTarget.Wasi.needs_wasi_imports() == true
            expect WasmTarget.Browser.needs_wasi_imports() == false
            expect WasmTarget.Minimal.needs_wasi_imports() == false

    context "WasmTypeMapper":
        it "maps i64 to i64":
            val mapper = WasmTypeMapper__create_wasm32()
            val mir_type = MirType(kind: MirTypeKind.I64)
            expect mapper.map_type(mir_type) == "i64"

        it "maps f64 to f64":
            val mapper = WasmTypeMapper__create_wasm32()
            val mir_type = MirType(kind: MirTypeKind.F64)
            expect mapper.map_type(mir_type) == "f64"

        it "maps bool to i32":
            val mapper = WasmTypeMapper__create_wasm32()
            val mir_type = MirType(kind: MirTypeKind.Bool)
            expect mapper.map_type(mir_type) == "i32"

        it "maps i32 to i32":
            val mapper = WasmTypeMapper__create_wasm32()
            val mir_type = MirType(kind: MirTypeKind.I32)
            expect mapper.map_type(mir_type) == "i32"

        it "reports correct size for i64":
            val mapper = WasmTypeMapper__create_wasm32()
            val mir_type = MirType(kind: MirTypeKind.I64)
            expect mapper.size_of(mir_type) == 8

        it "reports correct size for i32":
            val mapper = WasmTypeMapper__create_wasm32()
            val mir_type = MirType(kind: MirTypeKind.I32)
            expect mapper.size_of(mir_type) == 4

        it "reports correct size for bool":
            val mapper = WasmTypeMapper__create_wasm32()
            val mir_type = MirType(kind: MirTypeKind.Bool)
            expect mapper.size_of(mir_type) == 1

        it "reports correct alignment for f64":
            val mapper = WasmTypeMapper__create_wasm32()
            val mir_type = MirType(kind: MirTypeKind.F64)
            expect mapper.align_of(mir_type) == 8

    context "JsGlueGenerator":
        it "generates JavaScript glue code":
            var glue = JsGlueGenerator.create()
            glue.add_binding(BrowserBinding.console_log())
            glue.add_export("main")
            val js = glue.generate()
            expect (js).contains("WebAssembly")
            expect (js).contains("memory")
            expect (js).contains("loadWasm")

    context "WasmBackend creation":
        it "creates browser backend":
            val backend = WasmBackend.create(WasmTarget.Browser)
            expect backend.target.to_text() == "browser"

        it "creates wasi backend":
            val backend = WasmBackend.create(WasmTarget.Wasi)
            expect backend.target.to_text() == "wasi"

        it "creates minimal backend":
            val backend = WasmBackend.create(WasmTarget.Minimal)
            expect backend.target.to_text() == "minimal"