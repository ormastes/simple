use std.spec
use compiler.tools.aop_proceed_minimal.{create_proceed_context_minimal}

describe "Aop Proceed":
    it "starts with zero proceed calls":
        val ctx = create_proceed_context_minimal("trace_around")
        expect ctx.was_called() == false
        expect ctx.call_count() == 0
        expect ctx.has_error == false

    it "records a single proceed call and verifies successfully":
        val ctx = create_proceed_context_minimal("trace_around")
        ctx.mark_proceed_called()
        expect ctx.was_called() == true
        expect ctx.call_count() == 1

        val result = ctx.verify()
        expect result.is_ok() == true

    it "fails verification when proceed is never called":
        val ctx = create_proceed_context_minimal("trace_around")
        val result = ctx.verify()

        expect result.is_err() == true
        expect(result.err.unwrap().format()).to_equal(
            "Around advice 'trace_around' must call proceed() exactly once (called 0 times)"
        )

    it "fails verification when proceed is called multiple times":
        val ctx = create_proceed_context_minimal("trace_around")
        ctx.mark_proceed_called()
        ctx.mark_proceed_called()
        ctx.mark_proceed_called()

        val result = ctx.verify()
        expect result.is_err() == true
        expect ctx.call_count() == 3
        expect(result.err.unwrap().format()).to_equal(
            "Around advice 'trace_around' must call proceed() exactly once (called 3 times)"
        )