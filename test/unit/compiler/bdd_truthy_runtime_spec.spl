# Regression spec: rt_bdd_expect_truthy_rv must accept bool/comparison
# results from native codegen — including raw 0/1 i64 from `==` ops and
# tagged RuntimeValue::TRUE / FALSE from literals.
#
# Surface bug: pre-fix, even bare `expect true` false-failed under
# `--mode=smf` with "Expected value to be truthy, got RuntimeValue::Heap(0x0)".
#
# Acceptance under `--mode=smf --force-rebuild`:
#   - "literal true is truthy" PASSES
#   - "comparison result is truthy" PASSES (raw-1 untagged path)
#   - "integer one is truthy" PASSES
#   - "integer zero deliberate-fail RED" FAILS (proves matcher is wired
#     up and not a no-op stub)

describe "rt_bdd_expect_truthy_rv accepts bool and comparison results":
    it "literal true is truthy":
        expect true

    it "comparison result is truthy":
        expect 1 == 1

    it "integer one is truthy":
        expect 1

    it "integer zero deliberate-fail RED":
        expect 0
