# R1 — repro for "class defined inside a function body".
#
# This is a `_test.spl` (NOT `_spec.spl`) so it bypasses
# `preprocess_sspec_for_smf` — the line-based wrapper that hoists nested
# class defs in spec files. The test runner runs the file as a script
# through the bootstrap binary, so the AST reaches HIR with a `class` node
# embedded in a function body. Before the R1 fix the compile-mode pipeline
# rejected this with `Undefined("undefined identifier: Point")` because the
# class was silently dropped during HIR lowering. After the fix the nested
# `class` is hoisted to module scope and the program runs to completion.
#
# Companion spec (BDD-DSL form): test/unit/compiler/r1_class_in_it_spec.spl

fn main():
    class Point:
        x: i32
        y: i32

    val p = Point(x: 7, y: 11)
    print "x="
    print p.x
    print "y="
    print p.y
