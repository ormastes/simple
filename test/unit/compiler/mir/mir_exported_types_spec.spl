"""
# MIR Exported Type Lowering Specification

**Feature IDs:** #SFFI-BIDIR #SFFI-MIR-TYPES
**Category:** Compiler / MIR
**Difficulty:** 3/5
**Status:** Implemented

## Overview

Verifies that HIR classes and structs are materialized into `MirModule.types`,
including export metadata, field offsets, and explicit bit-width metadata.
"""

use compiler.mir.mir_lowering.{MirLowering}
from hir_definitions import {HirClass, HirStruct, HirField, HirExpr, HirExprKind}
from hir_types import {HirModule, HirType, HirTypeKind, SymbolId, SymbolTable}
from lexer import {Span}
use compiler.types.type_layout.{LayoutAttr, LayoutKind}
use compiler.common.attributes.{ExportAttr}

fn empty_span() -> Span:
    Span(start: 0, end_pos: 0, line: 1, col: 1)

fn make_hir_type(kind: HirTypeKind) -> HirType:
    HirType(kind: kind, span: empty_span())

fn make_i32_type() -> HirType:
    make_hir_type(HirTypeKind.Int(32, true))

fn make_u8_type() -> HirType:
    make_hir_type(HirTypeKind.Int(8, false))

fn dummy_expr() -> HirExpr:
    HirExpr(
        kind: HirExprKind.UnitLit,
        has_type_: false,
        type_: make_hir_type(HirTypeKind.Unit),
        span: empty_span()
    )

fn make_field(name: text, type_: HirType) -> HirField:
    HirField(
        symbol: SymbolId(id: 0),
        name: name,
        type_: type_,
        has_default: false,
        default: dummy_expr(),
        is_public: true,
        is_volatile: false,
        has_bits_attr: false,
        bits_width: 0,
        has_fixed_address: false,
        fixed_address: 0,
        span: empty_span()
    )

fn make_bits_field(name: text, type_: HirType, bits_width: i64) -> HirField:
    val field = make_field(name, type_)
    field.has_bits_attr = true
    field.bits_width = bits_width
    field

fn make_exported_class() -> HirClass:
    HirClass(
        symbol: SymbolId(id: 10),
        name: "GpioRegister",
        type_params: [],
        fields: [
            make_bits_field("mode", make_u8_type(), 4),
            make_bits_field("output", make_u8_type(), 1),
            make_bits_field("input", make_u8_type(), 1),
            make_bits_field("speed", make_u8_type(), 2)
        ],
        methods: {},
        is_public: true,
        has_doc_comment: false,
        doc_comment: "",
        span: empty_span(),
        has_layout_attr: true,
        layout_attr: LayoutAttr(layout_kind: LayoutKind.C, is_packed: false),
        has_export_attr: true,
        export_attr: ExportAttr(is_export_c: true, export_name: ""),
        is_generic_template: false,
        has_specialization_of: false,
        specialization_of: "",
        type_bindings: {}
    )

fn make_plain_struct() -> HirStruct:
    HirStruct(
        symbol: SymbolId(id: 20),
        name: "Point",
        type_params: [],
        fields: [
            make_field("x", make_i32_type()),
            make_field("y", make_i32_type())
        ],
        is_public: true,
        has_doc_comment: false,
        doc_comment: "",
        span: empty_span(),
        has_layout_attr: true,
        layout_attr: LayoutAttr(layout_kind: LayoutKind.C, is_packed: false),
        is_generic_template: false,
        has_specialization_of: false,
        specialization_of: "",
        type_bindings: {}
    )

fn make_module() -> HirModule:
    var classes: Dict<SymbolId, HirClass> = {}
    val cls = make_exported_class()
    classes[cls.symbol] = cls

    var structs: Dict<SymbolId, HirStruct> = {}
    val struct_def = make_plain_struct()
    structs[struct_def.symbol] = struct_def

    HirModule(
        name: "test.mir",
        path: "test.mir.spl",
        imports: [],
        exports: [],
        symbols: SymbolTable.new(),
        functions: {},
        classes: classes,
        structs: structs,
        enums: {},
        bitfields: {},
        traits: {},
        impls: [],
        constants: {},
        static_asserts: [],
        aop_advices: [],
        di_bindings: [],
        arch_rules: [],
        mock_decls: []
    )

describe "MIR exported type lowering":
    it "materializes exported classes into MirModule.types with bit metadata":
        val hir_module = make_module()
        val lowering = MirLowering.new(hir_module.symbols)

        val mir_module = lowering.lower_module(hir_module)
        val type_def = mir_module.types[SymbolId(id: 10)]

        expect(type_def.is_export_c).to_equal(true)
        expect(type_def.name).to_equal("GpioRegister")

        match type_def.kind:
            case Struct(fields):
                expect(fields.len()).to_equal(4)
                expect(fields[0].name).to_equal("mode")
                expect(fields[0].has_bits_attr).to_equal(true)
                expect(fields[0].bits_width).to_equal(4)
                expect(fields[0].offset).to_equal(0)
                expect(fields[3].bits_width).to_equal(2)
                expect(fields[3].offset).to_equal(0)
            case _:
                expect(false).to_equal(true)

    it "materializes plain structs into MirModule.types with computed offsets":
        val hir_module = make_module()
        val lowering = MirLowering.new(hir_module.symbols)

        val mir_module = lowering.lower_module(hir_module)
        val type_def = mir_module.types[SymbolId(id: 20)]

        expect(type_def.is_export_c).to_equal(false)
        expect(type_def.name).to_equal("Point")

        match type_def.kind:
            case Struct(fields):
                expect(fields.len()).to_equal(2)
                expect(fields[0].offset).to_equal(0)
                expect(fields[1].offset).to_equal(4)
            case _:
                expect(false).to_equal(true)
