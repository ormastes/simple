use std.spec

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

fn run_standalone_driver(args_line: text) -> (text, text, i64):
    rt_process_run("/bin/sh", [
        "-c",
        "SIMPLE_FORCE_ARGS='" + args_line + "' bin/simple src/compiler/80.driver/main.spl"
    ])

describe "standalone driver opt-level parsing":
    it "rejects out-of-range legacy numeric opt levels":
        val result = run_standalone_driver("simple-compiler --opt-level=4 missing_input.spl")
        expect result.2 == 1
        expect (result.0).contains("Optimization level must be 0-3")

    it "rejects non-numeric legacy opt levels":
        val result = run_standalone_driver("simple-compiler --opt-level=basic missing_input.spl")
        expect result.2 == 1
        expect (result.0).contains("Invalid optimization level: basic")