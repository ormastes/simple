use std.spec.{describe, it, expect}
use compiler.semantics.lint.critical_file_guard.{
    CriticalFileEntry, load_critical_config,
    check_critical_file_deletion, check_critical_file_shrinkage
}

describe "Critical file guard lint":
    it "loads config from SDN file":
        val entries = load_critical_config("config/critical_files.sdn")
        expect(entries.len() > 0).to_equal(true)

    it "detects deleted critical file":
        var entries: [CriticalFileEntry] = []
        entries.push(CriticalFileEntry(path: "nonexistent_file_xyz.spl", min_lines: 10))
        val warnings = check_critical_file_deletion(entries)
        expect(warnings.len()).to_equal(1)
        expect(warnings[0].code).to_equal("CFG001")

    it "no warning for existing file":
        var entries: [CriticalFileEntry] = []
        entries.push(CriticalFileEntry(path: "config/critical_files.sdn", min_lines: 5))
        val warnings = check_critical_file_deletion(entries)
        expect(warnings.len()).to_equal(0)

    it "detects shrunk file below min_lines":
        var entries: [CriticalFileEntry] = []
        entries.push(CriticalFileEntry(path: "config/critical_files.sdn", min_lines: 9999))
        val warnings = check_critical_file_shrinkage(entries)
        expect(warnings.len()).to_equal(1)
        expect(warnings[0].code).to_equal("CFG002")

    it "no warning when file meets min_lines":
        var entries: [CriticalFileEntry] = []
        entries.push(CriticalFileEntry(path: "config/critical_files.sdn", min_lines: 5))
        val warnings = check_critical_file_shrinkage(entries)
        expect(warnings.len()).to_equal(0)
