use std.spec.{describe, it, expect}
use compiler.core.ast.{ast_reset, DECL_EXPORT, DECL_USE, decl_export_names, decl_use_import}
use compiler.semantics.lint.star_import.{check_star_export, check_star_export_file}

describe "Star export lint (W0407)":
    it "detects wildcard export":
        ast_reset()
        val idx = decl_export_names(["foo_module.*"], 0)
        val warnings = check_star_export([idx])
        expect(warnings.len()).to_equal(1)
        expect(warnings[0].code).to_equal("W0407")
        expect(warnings[0].module_path).to_equal("foo_module")

    it "does not warn on explicit named exports":
        ast_reset()
        val idx = decl_export_names(["MyClass", "my_function"], 0)
        val warnings = check_star_export([idx])
        expect(warnings.len()).to_equal(0)

    it "skips __init__.spl facade files":
        ast_reset()
        val idx = decl_export_names(["some_module.*"], 0)
        val warnings = check_star_export_file([idx], "src/lib/__init__.spl")
        expect(warnings.len()).to_equal(0)

    it "skips mod.spl facade files":
        ast_reset()
        val idx = decl_export_names(["some_module.*"], 0)
        val warnings = check_star_export_file([idx], "src/lib/mod.spl")
        expect(warnings.len()).to_equal(0)

    it "warns in regular files":
        ast_reset()
        val idx = decl_export_names(["utils.*"], 0)
        val warnings = check_star_export_file([idx], "src/app/main.spl")
        expect(warnings.len()).to_equal(1)

    it "facade exemption when all exports are wildcard":
        ast_reset()
        val idx1 = decl_export_names(["mod_a.*"], 0)
        val idx2 = decl_export_names(["mod_b.*"], 0)
        val warnings = check_star_export([idx1, idx2])
        expect(warnings.len()).to_equal(0)
