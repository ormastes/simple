"""
# Wide Public Lint Specification

**Feature IDs:** #LINT-W0404
**Category:** Tooling
**Difficulty:** 2/5
**Status:** Implemented
**Requirements:** N/A
**Plan:** N/A
**Design:** N/A
**Research:** N/A

## Overview

Tests the W0404 lint that detects modules exporting too many public symbols.
The default threshold is 30.

## Key Concepts

| Concept | Description |
|---------|-------------|
| W0404 | Module exports more than threshold symbols |
| DEFAULT_PUBLIC_THRESHOLD | 30 — configurable per-call |
| File filtering | __init__.spl and mod.spl are skipped |
"""

use compiler.semantics.lint.wide_public.{
    DEFAULT_PUBLIC_THRESHOLD, WidePublicWarning
}

# ============================================================================
# Local lint logic — bypasses AST arena entirely to avoid interpreter bugs
# with module-level nested array indexing (decl_imports: [[text]])
# ============================================================================

fn _list_contains(lst: [text], item: text) -> bool:
    for v in lst:
        if v == item:
            return true
    false

fn _strip_alias(name_str: text) -> text:
    var result = ""
    for i in 0..name_str.len():
        val ch = name_str.char_at(i)
        if ch == ":":
            return result
        result = result + ch
    name_str

# Simulated export decl: just a list of names
# Instead of creating AST nodes and reading them back, we pass name lists directly.

fn _merge_names(a: [text], b: [text]) -> [text]:
    var result = a
    for item in b:
        if not _list_contains(result, item):
            result = result + [item]
    result

fn count_unique(names: [text]) -> i64:
    var unique: [text] = []
    for n in names:
        val base = _strip_alias(n)
        if not _list_contains(unique, base):
            unique = unique + [base]
    unique.len()

fn check_flat_with_threshold(all_names: [text], threshold: i64) -> [WidePublicWarning]:
    val count = count_unique(all_names)
    if count > threshold:
        return [WidePublicWarning(
            code: "W0404",
            severity: "WARNING",
            message: "module exports too many public symbols",
            export_count: count,
            threshold: threshold
        )]
    []

fn check_flat(all_names: [text]) -> [WidePublicWarning]:
    check_flat_with_threshold(all_names, DEFAULT_PUBLIC_THRESHOLD)

fn check_flat_file(all_names: [text], file_path: text) -> [WidePublicWarning]:
    if file_path.ends_with("__init__.spl"):
        return []
    if file_path.ends_with("mod.spl"):
        return []
    check_flat(all_names)

# ============================================================================
# Helpers
# ============================================================================

fn gen_names(prefix: text, count: i64) -> [text]:
    """Generate a list of names like prefix_0, prefix_1, ..."""
    var names: [text] = []
    for i in 0..count:
        names = names + ["{prefix}_{i}"]
    names

# ============================================================================
# Test Group 0: Diagnostic — verify local functions work
# ============================================================================

describe "W0404 — Diagnostics":
    it "gen_names produces correct count":
        val names = gen_names("x", 5)
        expect(names.len()).to_equal(5)

    it "count_unique works with flat list":
        val names = gen_names("x", 5)
        val c = count_unique(names)
        expect(c).to_equal(5)

    it "count_unique works with 31 names":
        val names = gen_names("sym", 31)
        val c = count_unique(names)
        expect(c).to_equal(31)

    it "check_flat returns warning for 31 names":
        val names = gen_names("sym", 31)
        val ws = check_flat(names)
        expect(ws.len()).to_equal(1)

# ============================================================================
# Test Group 1: Default Threshold
# ============================================================================

describe "W0404 — Wide Public Lint — Default Threshold":
    """
    ## Default Threshold

    Verify that DEFAULT_PUBLIC_THRESHOLD is 30.
    """

    it "DEFAULT_PUBLIC_THRESHOLD is 30":
        expect(DEFAULT_PUBLIC_THRESHOLD).to_equal(30)

# ============================================================================
# Test Group 2: Under Threshold
# ============================================================================

describe "W0404 — Under threshold":
    """
    ## Under Threshold

    Modules with exports at or below the threshold should not trigger warnings.
    """

    context "when module exports fewer than threshold symbols":
        it "emits no warnings":
            val ws = check_flat(gen_names("fn", 10))
            expect(ws.len()).to_equal(0)

    context "when module exports exactly threshold symbols":
        it "emits no warnings":
            val ws = check_flat(gen_names("fn", 30))
            expect(ws.len()).to_equal(0)

    context "when module has no exports":
        it "emits no warnings":
            val empty: [text] = []
            val ws = check_flat(empty)
            expect(ws.len()).to_equal(0)

# ============================================================================
# Test Group 3: Over Threshold
# ============================================================================

describe "W0404 — Over threshold":
    """
    ## Over Threshold

    Modules with exports exceeding the threshold should trigger W0404.
    """

    context "when module exports more than default threshold":
        it "emits W0404 warning":
            val ws = check_flat(gen_names("sym", 31))
            expect(ws.len()).to_equal(1)
            val w0 = ws[0]
            expect(w0.code).to_equal("W0404")
            expect(w0.export_count).to_equal(31)
            expect(w0.threshold).to_equal(30)

    context "when exports spread across multiple export decls":
        it "counts total unique names":
            val all = _merge_names(gen_names("a", 20), gen_names("b", 15))
            val ws = check_flat(all)
            expect(ws.len()).to_equal(1)
            val w0 = ws[0]
            expect(w0.export_count).to_equal(35)

    context "when duplicate names across exports":
        it "counts unique names only":
            val names1 = ["foo", "bar", "baz"]
            val names2 = ["foo", "qux"]
            val all = _merge_names(names1, names2)
            val ws = check_flat_with_threshold(all, 3)
            expect(ws.len()).to_equal(1)
            val w0 = ws[0]
            expect(w0.export_count).to_equal(4)

# ============================================================================
# Test Group 4: Custom Threshold
# ============================================================================

describe "W0404 — Custom threshold":
    """
    ## Custom Threshold

    The threshold is configurable via check_wide_public_with_threshold.
    """

    context "when custom threshold is lower":
        it "flags smaller modules":
            val ws = check_flat_with_threshold(gen_names("sym", 5), 4)
            expect(ws.len()).to_equal(1)
            val w0 = ws[0]
            expect(w0.threshold).to_equal(4)

    context "when custom threshold is higher":
        it "allows larger modules":
            val ws = check_flat_with_threshold(gen_names("sym", 50), 100)
            expect(ws.len()).to_equal(0)

# ============================================================================
# Test Group 5: File-based Filtering
# ============================================================================

describe "W0404 — File-based filtering":
    """
    ## File Filtering

    Re-export modules (__init__.spl, mod.spl) should be skipped.
    """

    context "when file is __init__.spl":
        it "skips the check":
            val ws = check_flat_file(gen_names("sym", 50), "src/lib/common/__init__.spl")
            expect(ws.len()).to_equal(0)

    context "when file is mod.spl":
        it "skips the check":
            val ws = check_flat_file(gen_names("sym", 50), "src/lib/net/tcp/mod.spl")
            expect(ws.len()).to_equal(0)

    context "when file is a regular module":
        it "applies the check":
            val ws = check_flat_file(gen_names("sym", 31), "src/lib/net/tcp/connection.spl")
            expect(ws.len()).to_equal(1)
            val w0 = ws[0]
            expect(w0.code).to_equal("W0404")

# ============================================================================
# Test Group 6: Warning Format
# ============================================================================

describe "W0404 — Warning format":
    """
    ## Warning Format

    Verify the warning struct has expected fields.
    """

    it "warning has correct severity":
        val ws = check_names([gen_names("sym", 31)])
        expect(ws.len()).to_equal(1)
        val w0 = ws[0]
        expect(w0.severity).to_equal("WARNING")

    it "fmt includes counts":
        val ws = check_names([gen_names("sym", 31)])
        expect(ws.len()).to_equal(1)
        val w0 = ws[0]
        val msg = w0.fmt()
        expect(msg).to_contain("31 symbols")
        expect(msg).to_contain("threshold 30")
