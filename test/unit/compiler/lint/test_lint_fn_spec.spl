use compiler.core.ast.{ast_reset}
use compiler.core.ast_expr.{expr_int_lit}
use compiler.semantics.lint.stub_impl.{classify_trivial}

# Try to access the AST module indirectly through the lint module's imports
describe "test":
    """Focused smoke checks for classify_trivial imports."""

    it "classifies with negative index":
        """Negative expression ids are rejected as non-trivial."""
        val result = classify_trivial(-1)
        expect(result).to_equal("")
    
    it "classifies with 0 index":
        """A real integer literal expression is classified by value."""
        ast_reset()
        val expr = expr_int_lit(0, 0)
        val result = classify_trivial(expr)
        expect(result).to_equal("integer (0)")
