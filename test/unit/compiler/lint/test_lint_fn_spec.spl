use compiler.semantics.lint.stub_impl.{classify_trivial}

# Try to access the AST module indirectly through the lint module's imports
describe "test":
    it "classifies with negative index":
        val result = classify_trivial(-1)
        expect(result).to_equal("")
    
    it "classifies with 0 index":
        val result = classify_trivial(0)
        # 0 might work if there's something at index 0 in the global arrays
        print "result for 0: '{result}'"
        expect(true).to_equal(true)
