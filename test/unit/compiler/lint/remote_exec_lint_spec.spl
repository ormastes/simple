# Remote Exec Lint Specification
#
# Verifies that each RJIT lint check catches its target bug pattern and
# does not false-positive on clean code.

import std.spec


# ============================================================================
# Test Group 1: RJIT001 — Diff Markers
# ============================================================================

describe "RJIT001: Diff markers in source":
    """
    ## Diff Marker Detection

    Catches lines starting with '+' or '-' followed by 4+ spaces,
    which look like accidentally pasted diff hunks.
    """

    context "when source contains diff-like lines":
        """
        ### Scenario: Unmerged diff markers

        Lines starting with `+    ` or `-    ` at indent level
        should be flagged as RJIT001.
        """

        it "detects plus-marker diff hunk":
            val source = "fn main():\n+    val x = 1\n    val y = 2\n"
            val warnings = lint_diff_markers(source, "test.spl")
            expect(warnings.len()).to_be_greater_than(0)
            expect(warnings[0].code).to_equal("RJIT001")
            expect(warnings[0].line_num).to_equal(2)

        it "detects minus-marker diff hunk":
            val source = "fn main():\n-    val x = 1\n    val y = 2\n"
            val warnings = lint_diff_markers(source, "test.spl")
            expect(warnings.len()).to_be_greater_than(0)
            expect(warnings[0].code).to_equal("RJIT001")

    context "when source is clean":
        """
        ### Scenario: No false positives

        Comment lines, short lines, and normal code should not trigger.
        """

        it "ignores comment lines with dash":
            val source = "# - this is a comment\nfn main():\n    pass\n"
            val warnings = lint_diff_markers(source, "test.spl")
            expect(warnings.len()).to_equal(0)

        it "ignores normal indented code":
            val source = "fn main():\n    val x = 1\n    val y = 2\n"
            val warnings = lint_diff_markers(source, "test.spl")
            expect(warnings.len()).to_equal(0)

        it "ignores short plus/minus lines":
            val source = "+x\n-y\n"
            val warnings = lint_diff_markers(source, "test.spl")
            expect(warnings.len()).to_equal(0)

        it "ignores diff markers inside docstrings":
            val source = "fn main():\n    \"\"\"\n+    added line\n    \"\"\"\n    pass\n"
            val warnings = lint_diff_markers(source, "test.spl")
            expect(warnings.len()).to_equal(0)


# ============================================================================
# Test Group 2: RJIT002 — Leading Space Corruption
# ============================================================================

describe "RJIT002: Leading space corruption":
    """
    ## Leading Space Detection

    Catches files where the first non-empty, non-comment line starts
    with a space before a top-level keyword.
    """

    context "when file has leading-space corruption":
        """
        ### Scenario: Shifted file

        The entire file has an extra leading space, so 'fn main():'
        appears as ' fn main():' at the top level.
        """

        it "detects space before fn keyword":
            val source = " fn main():\n     val x = 1\n"
            val warnings = lint_leading_space_corruption(source, "test.spl")
            expect(warnings.len()).to_be_greater_than(0)
            expect(warnings[0].code).to_equal("RJIT002")

        it "detects space before class keyword":
            val source = " class Foo:\n     x: i64\n"
            val warnings = lint_leading_space_corruption(source, "test.spl")
            expect(warnings.len()).to_be_greater_than(0)
            expect(warnings[0].code).to_equal("RJIT002")

        it "detects space before use keyword":
            val source = " use std.io_runtime\n"
            val warnings = lint_leading_space_corruption(source, "test.spl")
            expect(warnings.len()).to_be_greater_than(0)

    context "when file is clean":
        """
        ### Scenario: Properly formatted file

        Files with correct indentation should not trigger.
        """

        it "accepts normal fn declaration":
            val source = "fn main():\n    val x = 1\n"
            val warnings = lint_leading_space_corruption(source, "test.spl")
            expect(warnings.len()).to_equal(0)

        it "accepts file starting with comment":
            val source = "# Header comment\nfn main():\n    pass\n"
            val warnings = lint_leading_space_corruption(source, "test.spl")
            expect(warnings.len()).to_equal(0)

        it "accepts file starting with blank lines":
            val source = "\n\nfn main():\n    pass\n"
            val warnings = lint_leading_space_corruption(source, "test.spl")
            expect(warnings.len()).to_equal(0)


# ============================================================================
# Test Group 3: RJIT004 — Wrong Shell Import
# ============================================================================

describe "RJIT004: Wrong shell import in library code":
    """
    ## Wrong Import Detection

    Catches `use app.io` in files under `src/lib/` which should use
    `use std.io_runtime` instead.
    """

    context "when lib code uses app.io":
        """
        ### Scenario: Forbidden import in library

        Library code importing `app.io` causes 120s+ timeout in tests.
        """

        it "detects use app.io in lib path":
            val source = "use app.io\n\nfn helper():\n    pass\n"
            val warnings = lint_wrong_shell_import(source, "src/lib/common/helpers.spl")
            expect(warnings.len()).to_be_greater_than(0)
            expect(warnings[0].code).to_equal("RJIT004")

        it "detects import app.io in lib path":
            val source = "import app.io\n\nfn helper():\n    pass\n"
            val warnings = lint_wrong_shell_import(source, "src/lib/common/helpers.spl")
            expect(warnings.len()).to_be_greater_than(0)

        it "detects use app.io.println in lib path":
            val source = "use app.io.println\n\nfn helper():\n    pass\n"
            val warnings = lint_wrong_shell_import(source, "src/lib/nogc_sync_mut/util.spl")
            expect(warnings.len()).to_be_greater_than(0)

    context "when import is valid":
        """
        ### Scenario: No false positives

        Non-lib paths and correct imports should not trigger.
        """

        it "ignores app.io in app code":
            val source = "use app.io\n\nfn main():\n    pass\n"
            val warnings = lint_wrong_shell_import(source, "src/app/cli/main.spl")
            expect(warnings.len()).to_equal(0)

        it "ignores std.io_runtime in lib code":
            val source = "use std.io_runtime\n\nfn helper():\n    pass\n"
            val warnings = lint_wrong_shell_import(source, "src/lib/common/helpers.spl")
            expect(warnings.len()).to_equal(0)

        it "ignores app.io in test code":
            val source = "use app.io\n\nfn test_helper():\n    pass\n"
            val warnings = lint_wrong_shell_import(source, "test/unit/some_spec.spl")
            expect(warnings.len()).to_equal(0)

        it "ignores comment containing app.io":
            val source = "# use app.io is deprecated\nuse std.io_runtime\n"
            val warnings = lint_wrong_shell_import(source, "src/lib/common/helpers.spl")
            expect(warnings.len()).to_equal(0)


# ============================================================================
# Test Group 4: RJIT005 — Zero-Capacity Memory Map
# ============================================================================

describe "RJIT005: Zero-capacity MemoryMap":
    """
    ## Zero-Capacity Detection

    Catches MemoryMap constructors where data_start == data_end
    or code_start == code_end, creating a zero-capacity region.
    """

    context "when MemoryMap has zero capacity":
        """
        ### Scenario: Identical start/end values

        Constructor with matching start and end values for data or code
        region should be flagged.
        """

        it "detects zero data capacity with same identifier":
            val source = "val mm = MemoryMap(data_start: base, data_end: base, code_start: 0, code_end: 4096)\n"
            val warnings = lint_zero_capacity_memory_map(source, "test.spl")
            expect(warnings.len()).to_be_greater_than(0)
            expect(warnings[0].code).to_equal("RJIT005")
            expect(warnings[0].message).to_contain("data")

        it "detects zero code capacity with same literal":
            val source = "val mm = MemoryMap(data_start: 0, data_end: 4096, code_start: 0, code_end: 0)\n"
            val warnings = lint_zero_capacity_memory_map(source, "test.spl")
            expect(warnings.len()).to_be_greater_than(0)
            expect(warnings[0].code).to_equal("RJIT005")
            expect(warnings[0].message).to_contain("code")

        it "detects both zero data and code capacity":
            val source = "val mm = MemoryMap(data_start: 0, data_end: 0, code_start: 0, code_end: 0)\n"
            val warnings = lint_zero_capacity_memory_map(source, "test.spl")
            expect(warnings.len()).to_equal(2)

    context "when MemoryMap is valid":
        """
        ### Scenario: Properly sized regions

        MemoryMap with different start and end values should not trigger.
        """

        it "accepts different data start and end":
            val source = "val mm = MemoryMap(data_start: 0, data_end: 4096, code_start: 4096, code_end: 8192)\n"
            val warnings = lint_zero_capacity_memory_map(source, "test.spl")
            expect(warnings.len()).to_equal(0)

        it "accepts multiline constructor with valid values":
            val source = "val mm = MemoryMap(\n    data_start: 0,\n    data_end: 4096,\n    code_start: 4096,\n    code_end: 8192\n)\n"
            val warnings = lint_zero_capacity_memory_map(source, "test.spl")
            expect(warnings.len()).to_equal(0)


# ============================================================================
# Test Group 5: Warning Formatting
# ============================================================================

describe "RemoteExecLintWarning formatting":
    """
    ## Warning Output Format

    The fmt() method should produce a readable diagnostic string.
    """

    it "produces formatted output":
        val w = RemoteExecLintWarning(
            code: "RJIT001",
            severity: "WARNING",
            message: "test message",
            hint: "test hint",
            line_num: 42,
            file_path: "foo.spl"
        )
        val output = w.fmt()
        expect(output).to_contain("RJIT001")
        expect(output).to_contain("WARNING")
        expect(output).to_contain("foo.spl")
        expect(output).to_contain("42")
