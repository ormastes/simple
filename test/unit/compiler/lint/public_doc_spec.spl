"""
# Public Documentation Lint Specification

**Feature IDs:** #PDOC-001 through #PDOC-005
**Category:** Tooling / Lint
**Status:** Implemented
**Requirements:** doc/requirement/doc_ref_lint.md
"""

use compiler.semantics.lint.public_doc.{check_public_doc, PublicDocWarning, pdoc_extract_refs, pdoc_index_of}

fn has_warning(warnings: [PublicDocWarning], code: text, fn_name: text) -> bool:
    for w in warnings:
        if w.code == code and w.fn_name == fn_name:
            return true
    false

fn count_by_code(warnings: [PublicDocWarning], code: text) -> i64:
    var n = 0
    for w in warnings:
        if w.code == code:
            n = n + 1
    n

# ============================================================================
# PDOC001: Missing sdoctest
# ============================================================================

describe "PDOC001":
    it "warns on fn without sdoctest":
        val source = "fn helper(x: i64) -> i64:\n    x + 1\n"
        val warnings = check_public_doc(source)
        expect(count_by_code(warnings, "PDOC001")).to_be_greater_than(0)

    it "no warning with sdoctest":
        val source = "\"\"\"\nsdoctest:\n    expect(1).to_equal(1)\n\"\"\"\nfn square(x: i64) -> i64:\n    x * x\n"
        val warnings = check_public_doc(source)
        expect(has_warning(warnings, "PDOC001", "square")).to_equal(false)

    it "no warning with @sdoctest delegation":
        val source = "\"\"\"\nsdoctest:\n    expect(foo(1)).to_equal(2)\n\"\"\"\nfn foo(x: i64) -> i64:\n    x * 2\n\n\"\"\"\n@sdoctest(foo)\n\"\"\"\nfn bar(x: i64) -> i64:\n    foo(x)\n"
        val warnings = check_public_doc(source)
        expect(has_warning(warnings, "PDOC001", "bar")).to_equal(false)

    it "skips extern fn":
        val source = "extern fn rt_read(path: text) -> text\n"
        val warnings = check_public_doc(source)
        expect(count_by_code(warnings, "PDOC001")).to_equal(0)

    it "skips _private":
        val source = "fn _helper(x: i64) -> i64:\n    x + 1\n"
        val warnings = check_public_doc(source)
        expect(count_by_code(warnings, "PDOC001")).to_equal(0)

    it "skips pass_todo":
        val source = "fn future_work(x: i64) -> i64:\n    pass_todo\n"
        val warnings = check_public_doc(source)
        expect(has_warning(warnings, "PDOC001", "future_work")).to_equal(false)

    it "warns on class":
        val source = "class Parser:\n    input: text\n"
        val warnings = check_public_doc(source)
        expect(warnings.len()).to_be_greater_than(0)
        expect(count_by_code(warnings, "PDOC001")).to_be_greater_than(0)

    it "handles empty source":
        val warnings = check_public_doc("")
        expect(warnings.len()).to_equal(0)

# ============================================================================
# PDOC002: Invalid reference target
# ============================================================================

describe "PDOC002":
    it "pdoc_index_of works":
        val pos = pdoc_index_of("hello world", "world")
        expect(pos).to_equal(6)

    it "pdoc_extract_refs works":
        val doc = "\n@see(helper)\n"
        val refs = pdoc_extract_refs(doc, "@see(")
        expect(refs.len()).to_equal(1)

    it "warns on @see to nonexistent":
        val source = "\"\"\"\n@see(nonexistent_fn)\n\"\"\"\nfn process(data: text) -> text:\n    data.trim()\n"
        val warnings = check_public_doc(source)
        expect(warnings.len()).to_be_greater_than(1)
        expect(count_by_code(warnings, "PDOC002")).to_be_greater_than(0)

    it "warns on @sdoctest to nonexistent":
        val source = "\"\"\"\n@sdoctest(ghost)\n\"\"\"\nfn process(data: text) -> text:\n    data.trim()\n"
        val warnings = check_public_doc(source)
        expect(has_warning(warnings, "PDOC002", "process")).to_equal(true)

    it "no warning when target exists":
        val source = "fn helper() -> i64:\n    42\n\n\"\"\"\n@see(helper)\nsdoctest:\n    expect(1).to_equal(1)\n\"\"\"\nfn main_fn() -> i64:\n    helper()\n"
        val warnings = check_public_doc(source)
        expect(has_warning(warnings, "PDOC002", "main_fn")).to_equal(false)

# ============================================================================
# PDOC003: Unused @see reference
# ============================================================================

describe "PDOC003":
    it "warns when @see target not used in body":
        val source = "class Lexer:\n    input: text\n\n\"\"\"\n@see(Lexer)\nsdoctest:\n    expect(1).to_equal(1)\n\"\"\"\nfn add(a: i64, b: i64) -> i64:\n    a + b\n"
        val warnings = check_public_doc(source)
        expect(has_warning(warnings, "PDOC003", "add")).to_equal(true)

    it "no warning when used in body":
        val source = "fn helper(x: i64) -> i64:\n    x + 1\n\n\"\"\"\n@see(helper)\nsdoctest:\n    expect(1).to_equal(1)\n\"\"\"\nfn main_fn(x: i64) -> i64:\n    helper(x)\n"
        val warnings = check_public_doc(source)
        expect(has_warning(warnings, "PDOC003", "main_fn")).to_equal(false)

# ============================================================================
# PDOC004: @sdoctest type mismatch
# ============================================================================

describe "PDOC004":
    it "warns fn referencing class":
        val source = "class Parser:\n    input: text\n\n\"\"\"\n@sdoctest(Parser)\n\"\"\"\nfn parse(input: text) -> text:\n    input\n"
        val warnings = check_public_doc(source)
        expect(has_warning(warnings, "PDOC004", "parse")).to_equal(true)

    it "no warning fn referencing fn":
        val source = "\"\"\"\nsdoctest:\n    expect(foo(1)).to_equal(2)\n\"\"\"\nfn foo(x: i64) -> i64:\n    x * 2\n\n\"\"\"\n@sdoctest(foo)\n\"\"\"\nfn bar(x: i64) -> i64:\n    foo(x)\n"
        val warnings = check_public_doc(source)
        expect(has_warning(warnings, "PDOC004", "bar")).to_equal(false)

# ============================================================================
# PDOC005: Chained delegation no sdoctest
# ============================================================================

describe "PDOC005":
    it "warns when target has no sdoctest":
        val source = "fn foo(x: i64) -> i64:\n    x + 1\n\n\"\"\"\n@sdoctest(foo)\n\"\"\"\nfn bar(x: i64) -> i64:\n    foo(x)\n"
        val warnings = check_public_doc(source)
        expect(has_warning(warnings, "PDOC005", "bar")).to_equal(true)

    it "no warning when target has sdoctest":
        val source = "\"\"\"\nsdoctest:\n    expect(foo(1)).to_equal(2)\n\"\"\"\nfn foo(x: i64) -> i64:\n    x * 2\n\n\"\"\"\n@sdoctest(foo)\n\"\"\"\nfn bar(x: i64) -> i64:\n    foo(x)\n"
        val warnings = check_public_doc(source)
        expect(has_warning(warnings, "PDOC005", "bar")).to_equal(false)

# ============================================================================
# Edge cases
# ============================================================================

describe "edge cases":
    it "struct and enum no PDOC001":
        val source = "struct Point:\n    x: i64\n\nenum Color:\n    Red\n"
        val warnings = check_public_doc(source)
        expect(count_by_code(warnings, "PDOC001")).to_equal(0)
