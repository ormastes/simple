# @cover src/compiler/35.semantics/gc_boundary_check.spl 80%
# @cover src/compiler/00.common/gc_config.spl 70%
#
# Tests for GC boundary enforcement — family prefix classification and
# cross-family import warning rules.
#
# No imports: all logic is replicated at module level so these tests run
# in interpreter mode without needing the full compiler pipeline.

# ============================================================================
# Replicated helpers (mirror gc_config.spl and gc_boundary_check.spl logic)
# ============================================================================

fn local_is_nogc_family(module_path: text) -> bool:
    var path = module_path
    if path.starts_with("std."):
        path = path[4:path.len()]
    elif path.starts_with("lib."):
        path = path[4:path.len()]
    path.starts_with("nogc_")

fn local_is_gc_family(module_path: text) -> bool:
    var path = module_path
    if path.starts_with("std."):
        path = path[4:path.len()]
    elif path.starts_with("lib."):
        path = path[4:path.len()]
    path.starts_with("gc_")

fn local_is_noalloc_family(module_path: text) -> bool:
    var path = module_path
    if path.starts_with("std."):
        path = path[4:path.len()]
    elif path.starts_with("lib."):
        path = path[4:path.len()]
    path.starts_with("nogc_async_mut_noalloc")

fn local_is_common_family(module_path: text) -> bool:
    var path = module_path
    if path.starts_with("std."):
        path = path[4:path.len()]
    elif path.starts_with("lib."):
        path = path[4:path.len()]
    path.starts_with("common")

struct LocalFamilyWarning:
    source_module: text
    imported_module: text
    message: text

fn local_check_gc_boundary_imports(source_module: text, imported_modules: [text]) -> [LocalFamilyWarning]:
    var warnings: [LocalFamilyWarning] = []
    val source_is_noalloc = local_is_noalloc_family(source_module)
    val source_is_nogc = local_is_nogc_family(source_module)
    val source_is_gc = local_is_gc_family(source_module)
    val source_is_common = local_is_common_family(source_module)

    for imported in imported_modules:
        val imported_is_gc = local_is_gc_family(imported)
        val imported_is_noalloc = local_is_noalloc_family(imported)
        val imported_is_allocating = local_is_nogc_family(imported) and not imported_is_noalloc or imported_is_gc

        if source_is_noalloc:
            if imported_is_gc:
                warnings.push(LocalFamilyWarning(
                    source_module: source_module,
                    imported_module: imported,
                    message: "no-alloc imports GC family"
                ))
            elif local_is_nogc_family(imported) and not imported_is_noalloc:
                warnings.push(LocalFamilyWarning(
                    source_module: source_module,
                    imported_module: imported,
                    message: "no-alloc imports allocating family"
                ))
        elif source_is_nogc:
            if imported_is_gc:
                warnings.push(LocalFamilyWarning(
                    source_module: source_module,
                    imported_module: imported,
                    message: "no-gc imports GC family"
                ))

    warnings

# ============================================================================
# Tests
# ============================================================================

describe "GC Boundary Enforcement":
    context "family prefix classification — is_nogc_family":
        it "classifies nogc_sync_mut as nogc":
            expect(local_is_nogc_family("nogc_sync_mut")).to_equal(true)

        it "classifies nogc_async_mut as nogc":
            expect(local_is_nogc_family("nogc_async_mut")).to_equal(true)

        it "classifies nogc_async_mut_noalloc as nogc":
            expect(local_is_nogc_family("nogc_async_mut_noalloc")).to_equal(true)

        it "classifies gc_async_mut as not nogc":
            expect(local_is_nogc_family("gc_async_mut")).to_equal(false)

        it "classifies common as not nogc":
            expect(local_is_nogc_family("common")).to_equal(false)

        it "strips std. prefix before classifying":
            expect(local_is_nogc_family("std.nogc_sync_mut.fs")).to_equal(true)

        it "strips lib. prefix before classifying":
            expect(local_is_nogc_family("lib.nogc_async_mut.thread")).to_equal(true)

    context "family prefix classification — is_gc_family":
        it "classifies gc_async_mut as gc":
            expect(local_is_gc_family("gc_async_mut")).to_equal(true)

        it "classifies nogc_sync_mut as not gc":
            expect(local_is_gc_family("nogc_sync_mut")).to_equal(false)

        it "classifies common as not gc":
            expect(local_is_gc_family("common")).to_equal(false)

        it "classifies empty string as not gc":
            expect(local_is_gc_family("")).to_equal(false)

    context "family prefix classification — is_noalloc_family":
        it "classifies nogc_async_mut_noalloc as noalloc":
            expect(local_is_noalloc_family("nogc_async_mut_noalloc")).to_equal(true)

        it "classifies nogc_sync_mut as not noalloc":
            expect(local_is_noalloc_family("nogc_sync_mut")).to_equal(false)

        it "classifies gc_async_mut as not noalloc":
            expect(local_is_noalloc_family("gc_async_mut")).to_equal(false)

        it "classifies common as not noalloc":
            expect(local_is_noalloc_family("common")).to_equal(false)

        it "strips std. prefix for noalloc check":
            expect(local_is_noalloc_family("std.nogc_async_mut_noalloc.exec")).to_equal(true)

    context "cross-family boundary rules — nogc importing gc":
        it "nogc_sync_mut importing gc_async_mut produces warning":
            val warnings = local_check_gc_boundary_imports(
                "nogc_sync_mut.fs",
                ["gc_async_mut.alloc"]
            )
            expect(warnings.len()).to_equal(1)

        it "nogc_async_mut importing gc_async_mut produces warning":
            val warnings = local_check_gc_boundary_imports(
                "nogc_async_mut.thread",
                ["gc_async_mut.runtime"]
            )
            expect(warnings.len()).to_equal(1)

        it "warning message identifies the cross-boundary nature":
            val warnings = local_check_gc_boundary_imports(
                "nogc_sync_mut.fs",
                ["gc_async_mut.alloc"]
            )
            expect(warnings[0].message).to_equal("no-gc imports GC family")

        it "nogc importing common produces no warning":
            val warnings = local_check_gc_boundary_imports(
                "nogc_sync_mut.fs",
                ["common.text"]
            )
            expect(warnings.len()).to_equal(0)

        it "gc importing nogc produces no warning":
            val warnings = local_check_gc_boundary_imports(
                "gc_async_mut.runtime",
                ["nogc_sync_mut.fs"]
            )
            expect(warnings.len()).to_equal(0)

        it "common importing gc produces no warning":
            val warnings = local_check_gc_boundary_imports(
                "common.text",
                ["gc_async_mut.alloc"]
            )
            expect(warnings.len()).to_equal(0)

        it "common importing nogc produces no warning":
            val warnings = local_check_gc_boundary_imports(
                "common.text",
                ["nogc_sync_mut.fs"]
            )
            expect(warnings.len()).to_equal(0)

    context "cross-family boundary rules — noalloc importing allocating":
        it "noalloc importing gc_async_mut produces warning":
            val warnings = local_check_gc_boundary_imports(
                "nogc_async_mut_noalloc.exec",
                ["gc_async_mut.alloc"]
            )
            expect(warnings.len()).to_equal(1)

        it "noalloc importing nogc_sync_mut produces warning":
            val warnings = local_check_gc_boundary_imports(
                "nogc_async_mut_noalloc.exec",
                ["nogc_sync_mut.fs"]
            )
            expect(warnings.len()).to_equal(1)

        it "noalloc importing noalloc produces no warning":
            val warnings = local_check_gc_boundary_imports(
                "nogc_async_mut_noalloc.exec",
                ["nogc_async_mut_noalloc.memory"]
            )
            expect(warnings.len()).to_equal(0)

        it "noalloc importing common produces no warning":
            val warnings = local_check_gc_boundary_imports(
                "nogc_async_mut_noalloc.exec",
                ["common.math"]
            )
            expect(warnings.len()).to_equal(0)

    context "multiple imports — warning count":
        it "two bad imports produce two warnings":
            val warnings = local_check_gc_boundary_imports(
                "nogc_sync_mut.mod",
                ["gc_async_mut.a", "gc_async_mut.b"]
            )
            expect(warnings.len()).to_equal(2)

        it "one bad one good produce one warning":
            val warnings = local_check_gc_boundary_imports(
                "nogc_sync_mut.mod",
                ["gc_async_mut.a", "common.text"]
            )
            expect(warnings.len()).to_equal(1)

        it "no imports produce no warnings":
            val empty: [text] = []
            val warnings = local_check_gc_boundary_imports("nogc_sync_mut.mod", empty)
            expect(warnings.len()).to_equal(0)
