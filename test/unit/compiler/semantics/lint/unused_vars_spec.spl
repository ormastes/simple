# Unused Variables Lint Specification
#
# Tests for UNUSED001-UNUSED003 detection of unused variables,
# parameters, and imports.

use compiler.core.ast.{ast_reset, module_get_decls}
use compiler.core.parser.{parse_module}
use compiler.semantics.lint.unused_vars.{check_unused_vars, UnusedVarWarning}

# ============================================================================
# Helpers
# ============================================================================

fn parse_and_check_unused(code: text) -> [UnusedVarWarning]:
    """Parse source and run unused vars lint."""
    ast_reset()
    parse_module(code, "<test>")
    val decls = module_get_decls()
    check_unused_vars(decls)

fn warnings_mention_name(warnings: [UnusedVarWarning], name: text) -> bool:
    """Check if any warning mentions a specific variable name in its message."""
    for w in warnings:
        if w.message.contains("'{name}'"):
            return true
    false

fn warnings_have_code(warnings: [UnusedVarWarning], code: text) -> bool:
    """Check if any warning has the given code."""
    for w in warnings:
        if w.code == code:
            return true
    false

# ============================================================================
# UNUSED001: Unused local variables
# ============================================================================

describe "Unused Variables Lint":
    context "used variables":
        it "does not flag variables that are used":
            val code = "fn compute() -> i64:\n    val x = 10\n    val y = 20\n    x + y\n"
            val warnings = parse_and_check_unused(code)
            val mentions_x = warnings_mention_name(warnings, "x")
            expect(mentions_x).to_equal(false)

        it "does not flag variables used in expressions":
            val code = "fn greet(name: text) -> text:\n    val greeting = \"Hello\"\n    \"{greeting}!\"\n"
            val warnings = parse_and_check_unused(code)
            val mentions_greeting = warnings_mention_name(warnings, "greeting")
            expect(mentions_greeting).to_equal(false)

    context "unused variables":
        it "flags unused val declarations":
            val code = "fn test():\n    val unused_val = 42\n    print \"done\"\n"
            val warnings = parse_and_check_unused(code)
            val mentions_unused = warnings_mention_name(warnings, "unused_val")
            expect(mentions_unused).to_equal(true)

        it "flags unused var declarations":
            val code = "fn test():\n    var unused_var = 0\n    print \"done\"\n"
            val warnings = parse_and_check_unused(code)
            val mentions_unused = warnings_mention_name(warnings, "unused_var")
            expect(mentions_unused).to_equal(true)

    context "underscore-prefixed variables":
        it "does not flag _prefixed variables":
            val code = "fn test():\n    val _ignored = 42\n    print \"done\"\n"
            val warnings = parse_and_check_unused(code)
            val mentions_ignored = warnings_mention_name(warnings, "_ignored")
            expect(mentions_ignored).to_equal(false)

        it "does not flag single underscore":
            val code = "fn test():\n    val _ = 42\n    print \"done\"\n"
            val warnings = parse_and_check_unused(code)
            val mentions_underscore = warnings_mention_name(warnings, "_")
            expect(mentions_underscore).to_equal(false)

# ============================================================================
# UNUSED003: Unused parameters
# ============================================================================

    context "unused parameters":
        it "does not flag _prefixed parameters":
            val code = "fn add(a: i64, b: i64, _c: i64) -> i64:\n    a + b\n"
            val warnings = parse_and_check_unused(code)
            val mentions_c = warnings_mention_name(warnings, "_c")
            expect(mentions_c).to_equal(false)

        it "does not flag used parameters":
            val code = "fn multiply(x: i64, y: i64) -> i64:\n    x * y\n"
            val warnings = parse_and_check_unused(code)
            val mentions_x = warnings_mention_name(warnings, "x")
            expect(mentions_x).to_equal(false)
