# Multiline Boolean Lint Specification
#
# Tests for BOOL001 detection of multiline boolean expressions without
# parentheses. Multiline `if` with trailing `and`/`or` should be wrapped
# in parentheses to avoid ambiguity.

use compiler.semantics.lint.multiline_bool.{check_multiline_bool, MultilineBoolWarning}

# ============================================================================
# Helpers
# ============================================================================

fn warnings_have_code(warnings: [MultilineBoolWarning], code: text) -> bool:
    """Check if any warning has the given code."""
    for w in warnings:
        if w.code == code:
            return true
    false

# ============================================================================
# BOOL001: Multiline boolean without parentheses
# ============================================================================

describe "Multiline Boolean Lint":
    context "multiline if with trailing boolean operator":
        it "flags multiline if with trailing and (BOOL001)":
            val code = "fn test(a: bool, b: bool):\n    if a and\n       b:\n        print \"both true\"\n"
            val warnings = check_multiline_bool(code)
            val has_bool001 = warnings_have_code(warnings, "BOOL001")
            expect(has_bool001).to_equal(true)

        it "flags multiline if with trailing or":
            val code = "fn test(x: bool, y: bool):\n    if x or\n       y:\n        print \"either true\"\n"
            val warnings = check_multiline_bool(code)
            val has_bool001 = warnings_have_code(warnings, "BOOL001")
            expect(has_bool001).to_equal(true)

    context "single-line boolean":
        it "does not flag single-line if with and":
            val code = "fn test(a: bool, b: bool):\n    if a and b:\n        print \"both true\"\n"
            val warnings = check_multiline_bool(code)
            val has_bool001 = warnings_have_code(warnings, "BOOL001")
            expect(has_bool001).to_equal(false)

        it "does not flag single-line if with or":
            val code = "fn test(x: bool, y: bool):\n    if x or y:\n        print \"either true\"\n"
            val warnings = check_multiline_bool(code)
            val has_bool001 = warnings_have_code(warnings, "BOOL001")
            expect(has_bool001).to_equal(false)

    context "parenthesized multiline boolean":
        it "does not flag parenthesized multiline boolean":
            val code = "fn test(a: bool, b: bool):\n    if (a and\n        b):\n        print \"both true\"\n"
            val warnings = check_multiline_bool(code)
            val has_bool001 = warnings_have_code(warnings, "BOOL001")
            expect(has_bool001).to_equal(false)

        it "does not flag parenthesized multiline or":
            val code = "fn test(x: bool, y: bool):\n    if (x or\n        y):\n        print \"either true\"\n"
            val warnings = check_multiline_bool(code)
            val has_bool001 = warnings_have_code(warnings, "BOOL001")
            expect(has_bool001).to_equal(false)
