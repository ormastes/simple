# Safety and Visibility Lint Specification
#
# Tests for visibility warnings (W0401) and safety checks (SAFE001).
# - W0401: Importing private symbols (prefixed with _) from another module
# - SAFE001: Using asm outside unsafe block
#
# These are text-based heuristic checks (no AST required).

# ============================================================================
# Inline text-based lint helpers (mirrors query_rich.spl private functions)
# ============================================================================

fn check_visibility_text(source: text) -> [text]:
    """Text-based heuristic for visibility checking.
    Returns list of diagnostic codes found."""
    var codes: [text] = []
    val lines = source.split("\n")
    var li = 0
    while li < lines.len():
        val line = lines[li]
        val trimmed = line.trim()
        if trimmed.starts_with("use ") and trimmed.contains(".{"):
            val brace_start = _find_char(trimmed, "{")
            val brace_end = _find_char(trimmed, "}")
            if brace_start >= 0 and brace_end > brace_start:
                val imports_str = trimmed.substring(brace_start + 1, brace_end)
                val imports = imports_str.split(",")
                for imp in imports:
                    val imp_name = imp.trim()
                    if (imp_name.starts_with("_") and not imp_name.starts_with("__") and
                        imp_name.len() > 1):
                        codes.push("W0401")
        li = li + 1
    codes

fn check_safety_text(source: text) -> [text]:
    """Text-based heuristic for safety checking.
    Returns list of diagnostic codes found."""
    var codes: [text] = []
    val lines = source.split("\n")
    var in_unsafe = false
    var unsafe_indent = -1
    var li = 0
    while li < lines.len():
        val line = lines[li]
        val trimmed = line.trim()
        val indent = _count_indent(line)
        if trimmed.starts_with("unsafe:") or trimmed.starts_with("unsafe {"):
            in_unsafe = true
            unsafe_indent = indent
        if in_unsafe and indent <= unsafe_indent and trimmed != "" and not trimmed.starts_with("unsafe"):
            in_unsafe = false
            unsafe_indent = -1
        if not in_unsafe and indent > 0:
            if trimmed.starts_with("asm ") or trimmed.starts_with("asm(") or trimmed == "asm":
                codes.push("SAFE001")
        li = li + 1
    codes

fn _find_char(text_val: text, ch: text) -> i64:
    """Find first occurrence of a character in text. Returns -1 if not found."""
    var i = 0
    while i < text_val.len():
        if text_val.substring(i, i + 1) == ch:
            return i
        i = i + 1
    -1

fn _count_indent(line: text) -> i64:
    """Count leading spaces in a line."""
    var count = 0
    for ch in line:
        if ch == " ":
            count = count + 1
        elif ch == "\t":
            count = count + 4
        else:
            break
    count

fn codes_contain(codes: [text], target: text) -> bool:
    """Check if codes list contains a target code."""
    for c in codes:
        if c == target:
            return true
    false

# ============================================================================
# W0401: Private symbol import
# ============================================================================

describe "Safety and Visibility Lint":
    context "private symbol imports":
        it "flags importing _private_fn from another module (W0401)":
            val code = "use std.nogc_sync_mut.fs.{_private_helper}\n\nfn test():\n    print \"test\"\n"
            val codes = check_visibility_text(code)
            val has_w0401 = codes_contain(codes, "W0401")
            expect(has_w0401).to_equal(true)

        it "flags importing _internal symbol":
            val code = "use std.common.text.{_internal_parse}\n\nfn test():\n    print \"test\"\n"
            val codes = check_visibility_text(code)
            val has_w0401 = codes_contain(codes, "W0401")
            expect(has_w0401).to_equal(true)

    context "public symbol imports":
        it "does not flag importing public symbols":
            val code = "use std.spec\n\nfn test():\n    print \"test\"\n"
            val codes = check_visibility_text(code)
            val has_w0401 = codes_contain(codes, "W0401")
            expect(has_w0401).to_equal(false)

    # ============================================================================
    # SAFE001: asm outside unsafe
    # ============================================================================

    context "asm outside unsafe":
        it "flags asm usage outside unsafe block (SAFE001)":
            val code = "fn test():\n    asm \"nop\"\n"
            val codes = check_safety_text(code)
            val has_safe001 = codes_contain(codes, "SAFE001")
            expect(has_safe001).to_equal(true)

        it "flags inline assembly without unsafe context":
            val code = "fn compute():\n    val result = asm \"mov eax, 42\"\n    print \"done\"\n"
            val codes = check_safety_text(code)
            val has_safe001 = codes_contain(codes, "SAFE001")
            expect(has_safe001).to_equal(true)
