# Match Exhaustiveness Lint Specification
#
# Tests for MEXH001-MEXH002 detection of non-exhaustive match expressions.

use compiler.core.ast.{ast_reset, module_get_decls}
use compiler.core.parser.{parse_module}
use compiler.semantics.lint.match_exhaustiveness.{check_match_exhaustiveness, MatchExhaustivenessWarning}

# ============================================================================
# Helpers
# ============================================================================

fn parse_and_check_match(code: text) -> [MatchExhaustivenessWarning]:
    """Parse source and run match exhaustiveness lint."""
    ast_reset()
    parse_module(code, "<test>")
    val decls = module_get_decls()
    check_match_exhaustiveness(decls)

fn warnings_have_match_warning(warnings: [MatchExhaustivenessWarning]) -> bool:
    """Check if any match exhaustiveness warning exists."""
    warnings.len() > 0

fn warnings_have_code(warnings: [MatchExhaustivenessWarning], code: text) -> bool:
    """Check if any warning has the given code."""
    for w in warnings:
        if w.code == code:
            return true
    false

# ============================================================================
# Match with all variants covered
# ============================================================================

describe "Match Exhaustiveness Lint":
    context "exhaustive matches":
        it "does not flag match with wildcard arm":
            val code = "fn classify(x: i64) -> text:\n    match x:\n        case 1: \"one\"\n        case 2: \"two\"\n        case _: \"other\"\n"
            val warnings = parse_and_check_match(code)
            val has_warning = warnings_have_match_warning(warnings)
            expect(has_warning).to_equal(false)

        it "does not flag match with default catch-all":
            val code = "fn test(x: i64) -> text:\n    match x:\n        case 0: \"zero\"\n        case _: \"nonzero\"\n"
            val warnings = parse_and_check_match(code)
            val has_warning = warnings_have_match_warning(warnings)
            expect(has_warning).to_equal(false)

    # ============================================================================
    # Non-exhaustive matches
    # ============================================================================

    context "non-exhaustive matches":
        it "flags match without wildcard or default case":
            val code = "fn test(x: i64) -> text:\n    match x:\n        case 1: \"one\"\n        case 2: \"two\"\n"
            val warnings = parse_and_check_match(code)
            val has_warning = warnings_have_match_warning(warnings)
            expect(has_warning).to_equal(true)

        it "flags match with only one case and no default":
            val code = "fn test(x: i64) -> text:\n    match x:\n        case 42: \"the answer\"\n"
            val warnings = parse_and_check_match(code)
            val has_warning = warnings_have_match_warning(warnings)
            expect(has_warning).to_equal(true)
