# R2 regression: `pending(name)` helper exists in interpreter mode.
#
# Background:
#   - `skip` is a Simple language KEYWORD (parsed as Node::Skip), so writing
#     `skip("reason")` in a spec body fails compiled-mode lowering with
#     "Unknown variable: skip" / SMF "Undefined symbol: skip".
#   - The interpreter has a BDD-call hook in
#     `src/compiler_rust/compiler/src/interpreter_call/bdd.rs:656`
#     that recognizes `pending` / `pending_it` and prints the test as
#     yellow "(skipped)" without running the body.
#   - Crypto-port specs that need a "TODO marker, do not execute" should
#     therefore use `pending("reason")` rather than `skip("reason")`.
#
# Compiled-mode caveat:
#   - In `--mode=smf` and `--mode=native`, NO `std.spec` library symbol is
#     currently linked into the test binary. Calling `pending(...)`,
#     `skip_it(...)`, `check(...)`, etc. fails at SMF link time with
#     "Undefined symbol: <name> (required by relocation N)". This is a broader
#     spec-runtime linkage bug — see
#     `doc/08_tracking/todo/compiler_bugs_for_crypto_2026-04-25.md` (R2
#     superseded entry). Until that lands, crypto specs that need pending
#     semantics MUST run in interpreter mode.
#
# This spec verifies the interpreter path still works (acceptance gate #2
# in the R2 ticket: "skip keyword usage and pending helper still work in
# interpreter mode").

use std.spec

describe "R2 pending helper":
    it "marks a TODO test as pending without running its body":
        # The interpreter BDD hook recognizes `pending` and prints
        # "○ <name> (skipped)" in yellow. The test does not fail.
        pending("reserved for future crypto KAT — see R2")

    it "regular tests next to pending tests still run":
        expect(2 + 2).to_equal(4)
