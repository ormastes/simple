# Baremetal Method Dispatch — Local-Annotation Receiver Type Spec
#
# Regression coverage for sys-gui-006 Blocker 2 (Round 16, 2026-04-14).
#
# Symptom: in the x86_64 SimpleOS desktop_e2e baremetal lane,
# `DesktopShell.init()` never executed its body. The serial markers
# `[shell] init: ...` and `[launcher] Initializing...` did not appear.
# Downstream `launcher_get_app_count()` returned 0 and the lane emitted
# `[desktop-e2e] launcher:fail registered=0`.
#
# Root cause:
#   In `src/compiler_rust/compiler/src/mir/lower/lowering_expr.rs`, MIR
#   lowering of `HirExprKind::MethodCall` qualifies the method name with
#   the receiver's class via `TypeRegistry::get_type_name(receiver.ty)`.
#   When type inference for `X.new()` falls through to `HirType::Any`
#   (cross-module constructor whose return type is unresolved), the
#   qualified name is dropped and codegen's "pick shortest candidate"
#   fallback silently dispatches `shell.init()` to another class's
#   `init()` symbol — `Ps2Keyboard.init()` (a static `fn`, no body
#   shared with the shell) on the desktop_e2e lane.
#
# Fix (Round 16):
#   Lowering now consults the type recorded in the corresponding
#   `MirFunction.locals[idx].ty` slot when the receiver is
#   `HirExprKind::Local(idx)` and `receiver.ty` is unnamed. That slot
#   is populated from the user's `var shell: DesktopShell = ...`
#   annotation by `stmt_lowering`, so the typed-receiver workaround at
#   `examples/simple_os/arch/x86_64/desktop_e2e_entry.spl:97` is now
#   actually honoured at the MIR boundary.
#
# This spec exercises the dispatch path in the hosted lane to lock in
# the new behaviour. Two distinct classes share an `init` method name;
# each receiver is bound through a `var x: T = T.new()` declaration so
# type inference may see `Any` on the right-hand side and the MirLocal
# fallback is the only thing that makes the call land on the right body.

use std.spec

class AmbigInitA:
    last: i64

    static fn new() -> AmbigInitA:
        AmbigInitA(last: 0)

    me init():
        self.last = 101

class AmbigInitB:
    tag: i64

    static fn new() -> AmbigInitB:
        AmbigInitB(tag: 0)

    me init():
        self.tag = 202

describe "baremetal method dispatch — local-annotation type qualifier":
    context "annotated `var x: T = T.new()` receivers":
        it "dispatches `a.init()` to AmbigInitA.init even when receiver.ty is unnamed":
            # Mirrors the desktop_e2e_entry.spl pattern that exposed the
            # bug. With the Round-16 fix, MIR lowering recovers the
            # `: AmbigInitA` annotation from the function's local table
            # so `a.init()` qualifies as `AmbigInitA.init` and never
            # dispatches to `AmbigInitB.init`.
            var a: AmbigInitA = AmbigInitA.new()
            a.init()
            expect(a.last).to_be(101)

        it "dispatches `b.init()` to AmbigInitB.init when both classes are in scope":
            var b: AmbigInitB = AmbigInitB.new()
            b.init()
            expect(b.tag).to_be(202)

        it "keeps each typed receiver's init body isolated":
            var a: AmbigInitA = AmbigInitA.new()
            var b: AmbigInitB = AmbigInitB.new()
            a.init()
            b.init()
            expect(a.last).to_be(101)
            expect(b.tag).to_be(202)
