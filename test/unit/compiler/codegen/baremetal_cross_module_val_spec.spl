# Cross-Module `val u32` Baremetal Codegen Regression Spec
#
# Regression coverage for the 2026-04-14 bug where module-level
# `val X: u32 = <literal>` constants imported from another module
# arrived corrupted at the use site in the x86_64 baremetal cranelift
# lane (Agent Z1 flagged in Round 8; Agent Beta diagnosed and fixed in
# Round 9).
#
# Symptom: `src/os/services/launcher/launcher.spl` declares
#
#     val MOD_META: u32 = 1
#     val MOD_CTRL: u32 = 2
#     val MOD_ALT:  u32 = 4
#     val MOD_SHIFT: u32 = 8
#
# and `examples/simple_os/arch/x86_64/desktop_e2e_entry.spl` does
#
#     use os.services.launcher.launcher.{MOD_META, KEY_B, launcher_shortcut_dispatch}
#     ...
#     launcher_shortcut_dispatch(KEY_B, MOD_META)
#
# At the call site the observed `mod` argument was `5940624`, not `1`.
# `KEY_B = 0x42 = 66` (from a LOCAL `val`) arrived correctly, so the
# bug was specific to cross-module-imported data constants.
#
# Root cause (Agent Beta):
#   src/compiler_rust/compiler/src/codegen/common_backend.rs had a
#   cross-module fast path in `declare_globals` that, for any global
#   name resolvable via use_map/import_map, unconditionally declared
#   the resolved symbol as a FUNCTION IMPORT (`Linkage::Import` on a
#   `declare_function`) and registered it in `func_ids` instead of
#   `global_ids`. The fast path was correct for function-as-value
#   references (e.g. `val f = some_other_module_fn`) but catastrophic
#   for data constants: the `MirInst::GlobalLoad` emitter in
#   `codegen/instr/mod.rs` found the name in `func_ids`, took the
#   "function reference used as a value" branch, and emitted
#   `func_addr` — returning the symbol's ADDRESS rather than loading
#   its VALUE. Hence `mod=<pointer>` instead of `mod=1`.
#
# Fix:
#   1. `pipeline/native_project/imports.rs` now builds a
#      `data_exports: HashSet<String>` containing the mangled names of
#      every `Node::Const`, `Node::Static`, and `Node::Let` (module-
#      level `val`/`var`) it sees during AST discovery.
#   2. `ModuleImports` threads this set through to `CodegenBackend`
#      via `set_data_exports`.
#   3. `declare_globals` consults `data_exports` before taking the
#      function-import fast path. When the resolved mangled name is a
#      known data export, the branch is skipped and the global falls
#      through to the data-import path
#      (`Linkage::Import` on `declare_data`), which causes
#      `GlobalLoad` to emit a proper `load` from the symbol's address.
#
# This spec is documentation-only at present (hosted unit tests cannot
# easily spawn a baremetal sub-compile). Contract post-conditions are
# validated out-of-band:
#   - `bin/simple test test/unit/os/services/launcher/launcher_spec.spl`
#     stays 14/14 (hosted regression).
#   - `bin/simple os test --scenario=x64-desktop-test` reaches
#     `[desktop-e2e] shortcut:ok key=meta+b app=browser_demo`.
#
# When the baremetal compile harness is unified with test/unit, this
# spec can be expanded to actually compile a 2-file module set
# (`val K: u32 = 12345` in file A, `use A.{K}` in file B, read K on
# baremetal) and assert `K == 12345` from the serial log.

val CROSS_MODULE_VAL_U32_MARKER: u32 = 12345
val CROSS_MODULE_VAL_U32_EXPECTED: u32 = 12345

describe "cross-module val u32 baremetal regression":
    context "same-module val u32 (sanity check)":
        it "same-module val u32 literal round-trips":
            # A same-module `val u32` is lowered to `ConstInt` and
            # emitted as `iconst` at the use site — this has ALWAYS
            # worked on hosted and baremetal. This test just pins the
            # behavior so a future refactor cannot silently break it.
            assert CROSS_MODULE_VAL_U32_MARKER == 12345
            assert CROSS_MODULE_VAL_U32_MARKER == CROSS_MODULE_VAL_U32_EXPECTED

    context "data_exports plumbing":
        it "data_exports is populated at import-map build time":
            # `pipeline/native_project/imports.rs::build_import_map`
            # inserts the mangled name of every `Node::Const`,
            # `Node::Static`, and `Node::Let` it encounters into
            # `ImportMapResult.data_exports`. This set is threaded
            # through `ModuleImports` to `CodegenBackend.data_exports`
            # via `set_data_exports`. This test is a reminder that
            # removing the plumbing re-introduces the bug — the cross-
            # module `GlobalLoad` for `val K: u32` would silently fall
            # back to the function-import fast path and return the
            # symbol's address instead of its value.
            assert true
