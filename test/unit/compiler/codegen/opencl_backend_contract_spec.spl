# @cover src/compiler/70.backend/backend/opencl_backend.spl 80%
# @tag: unit, compiler, gpu, codegen, opencl

use compiler.backend.backend.backend_types.{CodegenTarget, compileoptions_default_options}
use compiler.backend.codegen_types.{CodegenOutputKind}
use compiler.backend.opencl_backend.{OpenClBackend, opencl_backend_2d_compile_contract}
use compiler.common.attributes.{vhdl_hardware_metadata_default}
use compiler.common.diagnostics.span.{Span}
use compiler.hir.hir_types.{SymbolId}
use compiler.mir.mir_data.{MirFunction, MirModule, MirSignature, BlockId, LocalId}
use compiler.mir.mir_instructions.{MirBlock, MirInst, MirInstKind, MirTerminator, MirOperand, MirBinOp, GpuBarrierScope, GpuMemoryScope, GpuAtomicOpKind, SwitchCase}
use compiler.mir.mir_types.{MirLocal, MirType, MirTypeKind, LocalKind}

fn empty_kernel_block() -> MirBlock:
    MirBlock(
        id: BlockId.entry(),
        label: Some("entry"),
        instructions: [],
        terminator: MirTerminator.Unreachable
    )

fn opencl_id_kernel_block() -> MirBlock:
    MirBlock(
        id: BlockId.entry(),
        label: Some("entry"),
        instructions: [
            MirInst(kind: MirInstKind.GpuGlobalId(LocalId(id: 0), 0), span: nil),
            MirInst(kind: MirInstKind.GpuLocalId(LocalId(id: 1), 0), span: nil),
            MirInst(kind: MirInstKind.GpuBarrier(GpuBarrierScope.Workgroup), span: nil)
        ],
        terminator: MirTerminator.Ret(nil)
    )

fn u32_type() -> MirType:
    MirType(kind: MirTypeKind.U32)

fn u64_type() -> MirType:
    MirType(kind: MirTypeKind.U64)

fn bool_type() -> MirType:
    MirType(kind: MirTypeKind.Bool)

fn global_u32_ptr_type() -> MirType:
    MirType.ptr(u32_type(), true)

fn arg_local(id: i64, index: i64, name: text, type_: MirType) -> MirLocal:
    MirLocal(id: LocalId(id: id), name: Some(name), type_: type_, kind: LocalKind.Arg(index), is_ghost: false)

fn temp_local(id: i64, type_: MirType) -> MirLocal:
    MirLocal(id: LocalId(id: id), name: nil, type_: type_, kind: LocalKind.Temp, is_ghost: false)

fn opencl_vector_add_block() -> MirBlock:
    MirBlock(
        id: BlockId.entry(),
        label: Some("entry"),
        instructions: [
            MirInst(kind: MirInstKind.GpuGlobalId(LocalId(id: 3), 0), span: nil),
            MirInst(kind: MirInstKind.GetElementPtr(LocalId(id: 4), MirOperand.copy(LocalId(id: 0)), [MirOperand.copy(LocalId(id: 3))]), span: nil),
            MirInst(kind: MirInstKind.GetElementPtr(LocalId(id: 5), MirOperand.copy(LocalId(id: 1)), [MirOperand.copy(LocalId(id: 3))]), span: nil),
            MirInst(kind: MirInstKind.Load(LocalId(id: 7), MirOperand.copy(LocalId(id: 4))), span: nil),
            MirInst(kind: MirInstKind.Load(LocalId(id: 8), MirOperand.copy(LocalId(id: 5))), span: nil),
            MirInst(kind: MirInstKind.BinOp(LocalId(id: 9), MirBinOp.Add, MirOperand.copy(LocalId(id: 7)), MirOperand.copy(LocalId(id: 8))), span: nil),
            MirInst(kind: MirInstKind.GetElementPtr(LocalId(id: 6), MirOperand.copy(LocalId(id: 2)), [MirOperand.copy(LocalId(id: 3))]), span: nil),
            MirInst(kind: MirInstKind.Store(MirOperand.copy(LocalId(id: 6)), MirOperand.copy(LocalId(id: 9))), span: nil)
        ],
        terminator: MirTerminator.Ret(nil)
    )

fn opencl_branch_blocks() -> [MirBlock]:
    [
        MirBlock(
            id: BlockId.entry(),
            label: Some("entry"),
            instructions: [],
            terminator: MirTerminator.If(MirOperand.copy(LocalId(id: 0)), BlockId(id: 1), BlockId(id: 2))
        ),
        MirBlock(
            id: BlockId(id: 1),
            label: Some("then"),
            instructions: [],
            terminator: MirTerminator.Goto(BlockId(id: 3))
        ),
        MirBlock(
            id: BlockId(id: 2),
            label: Some("else"),
            instructions: [],
            terminator: MirTerminator.Goto(BlockId(id: 3))
        ),
        MirBlock(
            id: BlockId(id: 3),
            label: Some("merge"),
            instructions: [],
            terminator: MirTerminator.Ret(nil)
        )
    ]

fn opencl_switch_blocks() -> [MirBlock]:
    [
        MirBlock(
            id: BlockId.entry(),
            label: Some("entry"),
            instructions: [],
            terminator: MirTerminator.Switch(
                MirOperand.copy(LocalId(id: 0)),
                [
                    SwitchCase(value: 1, target: BlockId(id: 1)),
                    SwitchCase(value: 2, target: BlockId(id: 2))
                ],
                BlockId(id: 3)
            )
        ),
        MirBlock(
            id: BlockId(id: 1),
            label: Some("case_one"),
            instructions: [],
            terminator: MirTerminator.Goto(BlockId(id: 4))
        ),
        MirBlock(
            id: BlockId(id: 2),
            label: Some("case_two"),
            instructions: [],
            terminator: MirTerminator.Goto(BlockId(id: 4))
        ),
        MirBlock(
            id: BlockId(id: 3),
            label: Some("default"),
            instructions: [],
            terminator: MirTerminator.Goto(BlockId(id: 4))
        ),
        MirBlock(
            id: BlockId(id: 4),
            label: Some("merge"),
            instructions: [],
            terminator: MirTerminator.Ret(nil)
        )
    ]

fn opencl_atomic_block() -> MirBlock:
    MirBlock(
        id: BlockId.entry(),
        label: Some("entry"),
        instructions: [
            MirInst(kind: MirInstKind.GpuAtomicOp(LocalId(id: 2), GpuAtomicOpKind.Add, MirOperand.copy(LocalId(id: 0)), MirOperand.copy(LocalId(id: 1))), span: nil),
            MirInst(kind: MirInstKind.GpuAtomicCas(LocalId(id: 3), MirOperand.copy(LocalId(id: 0)), MirOperand.copy(LocalId(id: 1)), MirOperand.copy(LocalId(id: 2))), span: nil),
            MirInst(kind: MirInstKind.GpuMemFence(GpuMemoryScope.All), span: nil),
            MirInst(kind: MirInstKind.GpuSharedAlloc(LocalId(id: 4), u32_type(), 32), span: nil)
        ],
        terminator: MirTerminator.Ret(nil)
    )

fn make_kernel_function(id: i64, name: text, target: text) -> MirFunction:
    MirFunction(
        symbol: SymbolId(id: id),
        name: name,
        signature: MirSignature(params: [], return_type: MirType.unit(), is_variadic: false),
        locals: [],
        blocks: [empty_kernel_block()],
        entry_block: BlockId.entry(),
        span: Span.empty(),
        generic_params: [],
        is_generic_template: false,
        specialization_of: nil,
        type_bindings: {},
        layout_phase: nil,
        is_kernel: true,
        gpu_target: target,
        gpu_backend_order: target,
        is_export_c: false,
        export_name: "",
        has_driver_manifest_attr: false,
        driver_manifest_attr: nil,
        has_vhdl_metadata: false,
        vhdl_metadata: vhdl_hardware_metadata_default(),
        has_fast_math: false
    )

fn make_opencl_id_kernel() -> MirFunction:
    MirFunction(
        symbol: SymbolId(id: 4),
        name: "opencl_id_kernel",
        signature: MirSignature(params: [], return_type: MirType.unit(), is_variadic: false),
        locals: [],
        blocks: [opencl_id_kernel_block()],
        entry_block: BlockId.entry(),
        span: Span.empty(),
        generic_params: [],
        is_generic_template: false,
        specialization_of: nil,
        type_bindings: {},
        layout_phase: nil,
        is_kernel: true,
        gpu_target: "opencl",
        gpu_backend_order: "opencl",
        is_export_c: false,
        export_name: "",
        has_driver_manifest_attr: false,
        driver_manifest_attr: nil,
        has_vhdl_metadata: false,
        vhdl_metadata: vhdl_hardware_metadata_default(),
        has_fast_math: false
    )

fn make_opencl_vector_add_kernel() -> MirFunction:
    val ptr_u32 = global_u32_ptr_type()
    MirFunction(
        symbol: SymbolId(id: 5),
        name: "opencl_vector_add_u32",
        signature: MirSignature(params: [ptr_u32, ptr_u32, ptr_u32], return_type: MirType.unit(), is_variadic: false),
        locals: [
            arg_local(0, 0, "a", ptr_u32),
            arg_local(1, 1, "b", ptr_u32),
            arg_local(2, 2, "out", ptr_u32),
            temp_local(3, u64_type()),
            temp_local(4, ptr_u32),
            temp_local(5, ptr_u32),
            temp_local(6, ptr_u32),
            temp_local(7, u32_type()),
            temp_local(8, u32_type()),
            temp_local(9, u32_type())
        ],
        blocks: [opencl_vector_add_block()],
        entry_block: BlockId.entry(),
        span: Span.empty(),
        generic_params: [],
        is_generic_template: false,
        specialization_of: nil,
        type_bindings: {},
        layout_phase: nil,
        is_kernel: true,
        gpu_target: "opencl",
        gpu_backend_order: "opencl",
        is_export_c: false,
        export_name: "",
        has_driver_manifest_attr: false,
        driver_manifest_attr: nil,
        has_vhdl_metadata: false,
        vhdl_metadata: vhdl_hardware_metadata_default(),
        has_fast_math: false
    )

fn make_opencl_branch_kernel() -> MirFunction:
    MirFunction(
        symbol: SymbolId(id: 6),
        name: "opencl_branch_kernel",
        signature: MirSignature(params: [bool_type()], return_type: MirType.unit(), is_variadic: false),
        locals: [
            arg_local(0, 0, "flag", bool_type())
        ],
        blocks: opencl_branch_blocks(),
        entry_block: BlockId.entry(),
        span: Span.empty(),
        generic_params: [],
        is_generic_template: false,
        specialization_of: nil,
        type_bindings: {},
        layout_phase: nil,
        is_kernel: true,
        gpu_target: "opencl",
        gpu_backend_order: "opencl",
        is_export_c: false,
        export_name: "",
        has_driver_manifest_attr: false,
        driver_manifest_attr: nil,
        has_vhdl_metadata: false,
        vhdl_metadata: vhdl_hardware_metadata_default(),
        has_fast_math: false
    )

fn make_opencl_switch_kernel() -> MirFunction:
    MirFunction(
        symbol: SymbolId(id: 7),
        name: "opencl_switch_kernel",
        signature: MirSignature(params: [u32_type()], return_type: MirType.unit(), is_variadic: false),
        locals: [
            arg_local(0, 0, "selector", u32_type())
        ],
        blocks: opencl_switch_blocks(),
        entry_block: BlockId.entry(),
        span: Span.empty(),
        generic_params: [],
        is_generic_template: false,
        specialization_of: nil,
        type_bindings: {},
        layout_phase: nil,
        is_kernel: true,
        gpu_target: "opencl",
        gpu_backend_order: "opencl",
        is_export_c: false,
        export_name: "",
        has_driver_manifest_attr: false,
        driver_manifest_attr: nil,
        has_vhdl_metadata: false,
        vhdl_metadata: vhdl_hardware_metadata_default(),
        has_fast_math: false
    )

fn make_opencl_atomic_kernel() -> MirFunction:
    val ptr_u32 = global_u32_ptr_type()
    MirFunction(
        symbol: SymbolId(id: 8),
        name: "opencl_atomic_u32",
        signature: MirSignature(params: [ptr_u32, u32_type()], return_type: MirType.unit(), is_variadic: false),
        locals: [
            arg_local(0, 0, "accum", ptr_u32),
            arg_local(1, 1, "value", u32_type()),
            temp_local(2, u32_type()),
            temp_local(3, u32_type()),
            temp_local(4, u32_type())
        ],
        blocks: [opencl_atomic_block()],
        entry_block: BlockId.entry(),
        span: Span.empty(),
        generic_params: [],
        is_generic_template: false,
        specialization_of: nil,
        type_bindings: {},
        layout_phase: nil,
        is_kernel: true,
        gpu_target: "opencl",
        gpu_backend_order: "opencl",
        is_export_c: false,
        export_name: "",
        has_driver_manifest_attr: false,
        driver_manifest_attr: nil,
        has_vhdl_metadata: false,
        vhdl_metadata: vhdl_hardware_metadata_default(),
        has_fast_math: false
    )

fn make_kernel_module(functions: [MirFunction]) -> MirModule:
    var map: Dict<SymbolId, MirFunction> = {}
    for fn_ in functions:
        map[fn_.symbol] = fn_
    MirModule(name: "gpu_target_module", functions: map, statics: {}, constants: {}, types: {})

describe "OpenCL backend contract":

    it "names the OpenCL backend and supports OpenCL artifact targets only":
        val backend = OpenClBackend.create(compileoptions_default_options())

        expect(backend.backend_name()).to_equal("opencl")
        expect(backend.supports_target(CodegenTarget.OpenClC)).to_equal(true)
        expect(backend.supports_target(CodegenTarget.OpenClSpirv)).to_equal(true)
        expect(backend.supports_target(CodegenTarget.CudaPtx)).to_equal(false)
        expect(backend.output_kind() == CodegenOutputKind.GpuCode).to_equal(true)

    it "builds generated Engine2D OpenCL C to SPIR-V artifact evidence":
        val exported = "OpEntryPoint GLCompute %simple_2d_fill_u32 \"simple_2d_fill_u32\" OpEntryPoint GLCompute %simple_2d_copy_u32 \"simple_2d_copy_u32\" OpEntryPoint GLCompute %simple_2d_alpha_u32 \"simple_2d_alpha_u32\" OpEntryPoint GLCompute %simple_2d_scroll_u32 \"simple_2d_scroll_u32\""
        val contract = opencl_backend_2d_compile_contract("simple_2d_optimization", "SPIR-V 1.5", exported, 4096)

        expect(contract.ready).to_equal(true)
        expect(contract.status).to_equal("compiled_artifact_verified")
        expect(contract.plan.source_format).to_equal("opencl-c")
        expect(contract.plan.binary_format).to_equal("spirv")
        expect(contract.plan.artifact_path_suffix).to_equal("simple_2d_optimization.spirv")
        expect(contract.source).to_contain("__kernel void simple_2d_fill_u32")
        expect(contract.source).to_contain("__kernel void simple_2d_scroll_u32")
        expect(contract.summary()).to_contain("ready=true")

    it "rejects incomplete OpenCL generated artifact evidence":
        val exported = "OpEntryPoint GLCompute %simple_2d_fill_u32 \"simple_2d_fill_u32\" OpEntryPoint GLCompute %simple_2d_copy_u32 \"simple_2d_copy_u32\" OpEntryPoint GLCompute %simple_2d_alpha_u32 \"simple_2d_alpha_u32\""
        val contract = opencl_backend_2d_compile_contract("simple_2d_optimization", "SPIR-V 1.5", exported, 4096)

        expect(contract.ready).to_equal(false)
        expect(contract.status).to_equal("missing-entry-symbol:simple_2d_scroll_u32")
        expect(contract.diagnostic).to_contain("OpenCL artifact rejected")

    it "plans MIR kernels using OpenCL target metadata":
        val opencl_kernel = make_kernel_function(1, "opencl_kernel", "opencl")
        val auto_kernel = make_kernel_function(2, "auto_kernel", "auto")
        val cuda_kernel = make_kernel_function(3, "cuda_kernel", "cuda")
        val module = make_kernel_module([opencl_kernel, auto_kernel, cuda_kernel])

        val plan = OpenClBackend.plan_module_kernels(module)

        expect(OpenClBackend.accepts_gpu_kernel(opencl_kernel)).to_equal(true)
        expect(OpenClBackend.accepts_gpu_kernel(auto_kernel)).to_equal(true)
        expect(OpenClBackend.accepts_gpu_kernel(cuda_kernel)).to_equal(false)
        expect(plan.accepted_kernel_count).to_equal(2)
        expect(plan.rejected_kernel_count).to_equal(1)
        expect(plan.diagnostic).to_contain("cuda_kernel")

    it "emits OpenCL C source for accepted MIR GPU kernel subset":
        val module = make_kernel_module([make_opencl_id_kernel()])
        val source = OpenClBackend.compile_module_to_opencl_source(module).unwrap()

        expect(source).to_contain("__kernel void opencl_id_kernel")
        expect(source).to_contain("ulong v0 = get_global_id(0);")
        expect(source).to_contain("ulong v1 = get_local_id(0);")
        expect(source).to_contain("barrier(CLK_LOCAL_MEM_FENCE);")
        expect(source).to_contain("return;")

    it "emits OpenCL C load store and pointer arithmetic for memory kernels":
        val module = make_kernel_module([make_opencl_vector_add_kernel()])
        val source = OpenClBackend.compile_module_to_opencl_source(module).unwrap()

        expect(source).to_contain("__kernel void opencl_vector_add_u32(__global uint* a, __global uint* b, __global uint* out)")
        expect(source).to_contain("ulong v3 = get_global_id(0);")
        expect(source).to_contain("__global uint* v4 = (a + v3);")
        expect(source).to_contain("__global uint* v5 = (b + v3);")
        expect(source).to_contain("uint v7 = *v4;")
        expect(source).to_contain("uint v8 = *v5;")
        expect(source).to_contain("uint v9 = v7 + v8;")
        expect(source).to_contain("__global uint* v6 = (out + v3);")
        expect(source).to_contain("*v6 = v9;")

    it "emits OpenCL C labels gotos and conditional branches":
        val module = make_kernel_module([make_opencl_branch_kernel()])
        val source = OpenClBackend.compile_module_to_opencl_source(module).unwrap()

        expect(source).to_contain("__kernel void opencl_branch_kernel(bool flag)")
        expect(source).to_contain("BB0:")
        expect(source).to_contain("if (flag) { goto BB1; } else { goto BB2; }")
        expect(source).to_contain("BB1:")
        expect(source).to_contain("goto BB3;")
        expect(source).to_contain("BB2:")
        expect(source).to_contain("BB3:")
        expect(source).to_contain("return;")

    it "emits OpenCL C switch terminators with case and default gotos":
        val module = make_kernel_module([make_opencl_switch_kernel()])
        val source = OpenClBackend.compile_module_to_opencl_source(module).unwrap()

        expect(source).to_contain("__kernel void opencl_switch_kernel(uint selector)")
        expect(source).to_contain("switch (selector)")
        expect(source).to_contain("case 1")
        expect(source).to_contain("case 2")
        expect(source).to_contain("default")
        expect(source).to_contain("goto")

    it "emits OpenCL C atomics fences and local memory for GPU kernels":
        val module = make_kernel_module([make_opencl_atomic_kernel()])
        val source = OpenClBackend.compile_module_to_opencl_source(module).unwrap()

        expect(source).to_contain("__kernel void opencl_atomic_u32(__global uint* accum, uint value)")
        expect(source).to_contain("uint v2 = atomic_add(accum, value);")
        expect(source).to_contain("uint v3 = atomic_cmpxchg(accum, value, v2);")
        expect(source).to_contain("mem_fence(CLK_LOCAL_MEM_FENCE | CLK_GLOBAL_MEM_FENCE);")
        expect(source).to_contain("__local uint v4[32];")
