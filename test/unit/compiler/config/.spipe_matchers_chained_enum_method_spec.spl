"""
# Chained Enum Method Dispatch Regression Tests

**Category:** Runtime | Testing
**Bug ID:** INTERP-CHAIN-001
**Status:** Confirmed (runtime limitation)

## Overview

Tests for method calls on enum values. The chained `.unwrap().to_text()`
pattern fails in the compiled runtime because the method dispatcher loses
the concrete enum type after unwrap in a nested call context.

Workaround: use an intermediate variable to break the chain.

## Known Limitation

`TypeDefault.from_text("i32").unwrap().to_text()` — FAILS
`val td = TypeDefault.from_text("i32").unwrap(); td.to_text()` — WORKS
"""

use compiler.common.config.{TypeDefault, TypeInferenceConfig, CompilerProfile}


# ============================================================================
# Working patterns: intermediate variable after unwrap
# ============================================================================

describe "Enum Method After Unwrap (intermediate var)":
    context "TypeDefault from_text → unwrap → to_text":
        it "I32 via intermediate":
            val td = TypeDefault.from_text("i32").unwrap()
            expect td.to_text() == "i32"

        it "I64 via intermediate":
            val td = TypeDefault.from_text("i64").unwrap()
            expect td.to_text() == "i64"

        it "F32 via intermediate":
            val td = TypeDefault.from_text("f32").unwrap()
            expect td.to_text() == "f32"

        it "F64 via intermediate":
            val td = TypeDefault.from_text("f64").unwrap()
            expect td.to_text() == "f64"

        it "Bool via intermediate":
            val td = TypeDefault.from_text("bool").unwrap()
            expect td.to_text() == "bool"

        it "String via intermediate":
            val td = TypeDefault.from_text("text").unwrap()
            expect td.to_text() == "text"

        it "Void via intermediate":
            val td = TypeDefault.from_text("void").unwrap()
            expect td.to_text() == "void"

        it "Any via intermediate":
            val td = TypeDefault.from_text("any").unwrap()
            expect td.to_text() == "any"

        it "Nil via intermediate":
            val td = TypeDefault.from_text("nil").unwrap()
            expect td.to_text() == "nil"

        it "U8 via intermediate":
            val td = TypeDefault.from_text("u8").unwrap()
            expect td.to_text() == "u8"

        it "U16 via intermediate":
            val td = TypeDefault.from_text("u16").unwrap()
            expect td.to_text() == "u16"

        it "U32 via intermediate":
            val td = TypeDefault.from_text("u32").unwrap()
            expect td.to_text() == "u32"

        it "U64 via intermediate":
            val td = TypeDefault.from_text("u64").unwrap()
            expect td.to_text() == "u64"

        it "I8 via intermediate":
            val td = TypeDefault.from_text("i8").unwrap()
            expect td.to_text() == "i8"

        it "I16 via intermediate":
            val td = TypeDefault.from_text("i16").unwrap()
            expect td.to_text() == "i16"

    context "alias round-trips via intermediate":
        it "int alias":
            val td = TypeDefault.from_text("int").unwrap()
            expect td.to_text() == "i32"

        it "long alias":
            val td = TypeDefault.from_text("long").unwrap()
            expect td.to_text() == "i64"

        it "float alias":
            val td = TypeDefault.from_text("float").unwrap()
            expect td.to_text() == "f32"

        it "double alias":
            val td = TypeDefault.from_text("double").unwrap()
            expect td.to_text() == "f64"

        it "string alias":
            val td = TypeDefault.from_text("string").unwrap()
            expect td.to_text() == "text"

        it "byte alias":
            val td = TypeDefault.from_text("byte").unwrap()
            expect td.to_text() == "u8"

        it "dynamic alias":
            val td = TypeDefault.from_text("dynamic").unwrap()
            expect td.to_text() == "any"


# ============================================================================
# Direct enum method chaining (no unwrap — works)
# ============================================================================

describe "Direct Enum Method Chain (no unwrap)":
    context "CompilerProfile from_text().to_text()":
        it "Dev":
            expect CompilerProfile.from_text("dev").to_text() == "dev"

        it "Prod":
            expect CompilerProfile.from_text("prod").to_text() == "prod"

        it "Test":
            expect CompilerProfile.from_text("test").to_text() == "test"

        it "Sdn":
            expect CompilerProfile.from_text("sdn").to_text() == "sdn"

        it "aliases":
            expect CompilerProfile.from_text("production").to_text() == "prod"
            expect CompilerProfile.from_text("development").to_text() == "dev"
            expect CompilerProfile.from_text("testing").to_text() == "test"
            expect CompilerProfile.from_text("release").to_text() == "prod"
            expect CompilerProfile.from_text("data").to_text() == "sdn"

    context "enum method on struct field":
        it "TypeInferenceConfig field chain":
            val config = TypeInferenceConfig.default()
            expect config.empty_array_default.to_text() == "i32"
            expect config.empty_vector_default.to_text() == "f64"
            expect config.empty_dict_key_default.to_text() == "text"
            expect config.empty_dict_value_default.to_text() == "any"

        it "from_sdn result field chain":
            val config = TypeInferenceConfig.from_sdn("empty_array, i64").unwrap()
            expect config.empty_array_default.to_text() == "i64"


# ============================================================================
# Result.unwrap() with struct field access
# ============================================================================

describe "Result Unwrap + Struct Field":
    context "from_sdn result unwrap":
        it "unwrap Ok then access field method":
            val sdn = "empty_array, f32\nempty_vector, i64"
            val config = TypeInferenceConfig.from_sdn(sdn).unwrap()
            expect config.empty_array_default.to_text() == "f32"
            expect config.empty_vector_default.to_text() == "i64"

        it "unwrap Ok and check strict":
            val config = TypeInferenceConfig.from_sdn("strict, true").unwrap()
            expect config.strict_empty_collections == true