"""
# TypeInferenceConfig & TypeDefault Specification

**Category:** Infrastructure
**Status:** Implemented

## Overview

Tests for TypeDefault enum and TypeInferenceConfig struct — pure logic
type inference configuration that works in interpreter mode.
"""

use compiler.common.config.{TypeDefault, TypeInferenceConfig}


# ============================================================================
# TypeDefault Enum
# ============================================================================

describe "TypeDefault":
    context "to_text":
        it "converts Void":
            expect TypeDefault.Void.to_text() == "void"

        it "converts Bool":
            expect TypeDefault.Bool.to_text() == "bool"

        it "converts I8":
            expect TypeDefault.I8.to_text() == "i8"

        it "converts I16":
            expect TypeDefault.I16.to_text() == "i16"

        it "converts I32":
            expect TypeDefault.I32.to_text() == "i32"

        it "converts I64":
            expect TypeDefault.I64.to_text() == "i64"

        it "converts U8":
            expect TypeDefault.U8.to_text() == "u8"

        it "converts U16":
            expect TypeDefault.U16.to_text() == "u16"

        it "converts U32":
            expect TypeDefault.U32.to_text() == "u32"

        it "converts U64":
            expect TypeDefault.U64.to_text() == "u64"

        it "converts F32":
            expect TypeDefault.F32.to_text() == "f32"

        it "converts F64":
            expect TypeDefault.F64.to_text() == "f64"

        it "converts String":
            expect TypeDefault.String.to_text() == "text"

        it "converts Nil":
            expect TypeDefault.Nil.to_text() == "nil"

        it "converts Any":
            expect TypeDefault.Any.to_text() == "any"

    context "from_text":
        it "parses i32":
            val result = TypeDefault.from_text("i32")
            expect result.? == true
            val td = result.unwrap()
            expect td.to_text() == "i32"

        it "parses int alias to I32":
            val result = TypeDefault.from_text("int")
            expect result.? == true
            val td = result.unwrap()
            expect td.to_text() == "i32"

        it "parses i64":
            val result = TypeDefault.from_text("i64")
            expect result.? == true
            val td = result.unwrap()
            expect td.to_text() == "i64"

        it "parses long alias to I64":
            val result = TypeDefault.from_text("long")
            expect result.? == true
            val td = result.unwrap()
            expect td.to_text() == "i64"

        it "parses f32":
            val result = TypeDefault.from_text("f32")
            expect result.? == true
            val td = result.unwrap()
            expect td.to_text() == "f32"

        it "parses float alias to F32":
            val result = TypeDefault.from_text("float")
            expect result.? == true
            val td = result.unwrap()
            expect td.to_text() == "f32"

        it "parses f64":
            val result = TypeDefault.from_text("f64")
            expect result.? == true
            val td = result.unwrap()
            expect td.to_text() == "f64"

        it "parses double alias to F64":
            val result = TypeDefault.from_text("double")
            expect result.? == true
            val td = result.unwrap()
            expect td.to_text() == "f64"

        it "parses text":
            val result = TypeDefault.from_text("text")
            expect result.? == true
            val td = result.unwrap()
            expect td.to_text() == "text"

        it "parses string alias to String":
            val result = TypeDefault.from_text("string")
            expect result.? == true
            val td = result.unwrap()
            expect td.to_text() == "text"

        it "parses str alias to String":
            val result = TypeDefault.from_text("str")
            expect result.? == true
            val td = result.unwrap()
            expect td.to_text() == "text"

        it "parses bool":
            val result = TypeDefault.from_text("bool")
            expect result.? == true
            val td = result.unwrap()
            expect td.to_text() == "bool"

        it "parses void":
            val result = TypeDefault.from_text("void")
            expect result.? == true
            val td = result.unwrap()
            expect td.to_text() == "void"

        it "parses unit alias to Void":
            val result = TypeDefault.from_text("unit")
            expect result.? == true
            val td = result.unwrap()
            expect td.to_text() == "void"

        it "parses u8":
            val result = TypeDefault.from_text("u8")
            expect result.? == true
            val td = result.unwrap()
            expect td.to_text() == "u8"

        it "parses byte alias to U8":
            val result = TypeDefault.from_text("byte")
            expect result.? == true
            val td = result.unwrap()
            expect td.to_text() == "u8"

        it "parses any":
            val result = TypeDefault.from_text("any")
            expect result.? == true
            val td = result.unwrap()
            expect td.to_text() == "any"

        it "parses dynamic alias to Any":
            val result = TypeDefault.from_text("dynamic")
            expect result.? == true
            val td = result.unwrap()
            expect td.to_text() == "any"

        it "parses nil":
            val result = TypeDefault.from_text("nil")
            expect result.? == true
            val td = result.unwrap()
            expect td.to_text() == "nil"

        it "parses null alias to Nil":
            val result = TypeDefault.from_text("null")
            expect result.? == true
            val td = result.unwrap()
            expect td.to_text() == "nil"

        it "returns nil for invalid input":
            val result = TypeDefault.from_text("garbage")
            expect result.? == false

        it "returns nil for empty string":
            val result = TypeDefault.from_text("")
            expect result.? == false

    context "round-trip":
        it "I32 round-trips through text":
            val original = TypeDefault.I32
            val text_form = original.to_text()
            val restored = TypeDefault.from_text(text_form)
            expect restored.? == true
            val td = restored.unwrap()
            expect td.to_text() == "i32"

        it "F64 round-trips through text":
            val original = TypeDefault.F64
            val text_form = original.to_text()
            val restored = TypeDefault.from_text(text_form)
            expect restored.? == true
            val td = restored.unwrap()
            expect td.to_text() == "f64"

        it "Any round-trips through text":
            val original = TypeDefault.Any
            val text_form = original.to_text()
            val restored = TypeDefault.from_text(text_form)
            expect restored.? == true
            val td = restored.unwrap()
            expect td.to_text() == "any"


# ============================================================================
# TypeInferenceConfig
# ============================================================================

describe "TypeInferenceConfig":
    context "default":
        it "has I32 for empty array default":
            val config = TypeInferenceConfig.default()
            expect config.empty_array_default.to_text() == "i32"

        it "has F64 for empty vector default":
            val config = TypeInferenceConfig.default()
            expect config.empty_vector_default.to_text() == "f64"

        it "has String for empty dict key default":
            val config = TypeInferenceConfig.default()
            expect config.empty_dict_key_default.to_text() == "text"

        it "has Any for empty dict value default":
            val config = TypeInferenceConfig.default()
            expect config.empty_dict_value_default.to_text() == "any"

        it "is not strict by default":
            val config = TypeInferenceConfig.default()
            expect config.strict_empty_collections == false

    context "strict":
        it "creates strict config":
            val config = TypeInferenceConfig.strict()
            expect config.strict_empty_collections == true

        it "strict config has same type defaults as default":
            val config = TypeInferenceConfig.strict()
            expect config.empty_array_default.to_text() == "i32"
            expect config.empty_vector_default.to_text() == "f64"

    context "with_strict":
        it "creates non-strict when false":
            val config = TypeInferenceConfig.with_strict(false)
            expect config.strict_empty_collections == false

        it "creates strict when true":
            val config = TypeInferenceConfig.with_strict(true)
            expect config.strict_empty_collections == true

    context "from_sdn":
        it "parses empty array default":
            val sdn = "empty_array, i64"
            val result = TypeInferenceConfig.from_sdn(sdn)
            val config = result.unwrap()
            expect config.empty_array_default.to_text() == "i64"

        it "parses empty vector default":
            val sdn = "empty_vector, f32"
            val result = TypeInferenceConfig.from_sdn(sdn)
            val config = result.unwrap()
            expect config.empty_vector_default.to_text() == "f32"

        it "parses empty dict key default":
            val sdn = "empty_dict_key, i32"
            val result = TypeInferenceConfig.from_sdn(sdn)
            val config = result.unwrap()
            expect config.empty_dict_key_default.to_text() == "i32"

        it "parses empty dict value default":
            val sdn = "empty_dict_value, i64"
            val result = TypeInferenceConfig.from_sdn(sdn)
            val config = result.unwrap()
            expect config.empty_dict_value_default.to_text() == "i64"

        it "parses strict mode":
            val sdn = "strict, true"
            val result = TypeInferenceConfig.from_sdn(sdn)
            val config = result.unwrap()
            expect config.strict_empty_collections == true

        it "parses multiple fields":
            val sdn = "empty_array, i64\nempty_vector, f32\nstrict, true"
            val result = TypeInferenceConfig.from_sdn(sdn)
            val config = result.unwrap()
            expect config.empty_array_default.to_text() == "i64"
            expect config.empty_vector_default.to_text() == "f32"
            expect config.strict_empty_collections == true

        it "skips comments and empty lines":
            val sdn = "# comment\n\nempty_array, i64\n# another comment"
            val result = TypeInferenceConfig.from_sdn(sdn)
            val config = result.unwrap()
            expect config.empty_array_default.to_text() == "i64"

        it "skips header lines starting with pipe":
            val sdn = "| key | value |\nempty_array, i64"
            val result = TypeInferenceConfig.from_sdn(sdn)
            val config = result.unwrap()
            expect config.empty_array_default.to_text() == "i64"

        it "skips type_inference header line":
            val sdn = "type_inference\nempty_array, i64"
            val result = TypeInferenceConfig.from_sdn(sdn)
            val config = result.unwrap()
            expect config.empty_array_default.to_text() == "i64"

        it "ignores unknown keys":
            val sdn = "unknown_key, some_value\nempty_array, i64"
            val result = TypeInferenceConfig.from_sdn(sdn)
            val config = result.unwrap()
            expect config.empty_array_default.to_text() == "i64"

        it "keeps defaults for unparsed fields":
            val sdn = "empty_array, i64"
            val result = TypeInferenceConfig.from_sdn(sdn)
            val config = result.unwrap()
            # Only array was overridden; others keep defaults
            expect config.empty_vector_default.to_text() == "f64"
            expect config.empty_dict_key_default.to_text() == "text"

        it "accepts alternate key names":
            val sdn = "empty_array_default, i64\nempty_vector_default, f32"
            val result = TypeInferenceConfig.from_sdn(sdn)
            val config = result.unwrap()
            expect config.empty_array_default.to_text() == "i64"
            expect config.empty_vector_default.to_text() == "f32"

    context "merge":
        it "returns module config":
            val project = TypeInferenceConfig.default()
            var module = TypeInferenceConfig.with_strict(true)
            module.empty_array_default = TypeDefault.I64
            val merged = project.merge(module)
            expect merged.strict_empty_collections == true
            expect merged.empty_array_default.to_text() == "i64"

        it "module config fully overrides project config":
            var project = TypeInferenceConfig.default()
            project.empty_array_default = TypeDefault.F64
            val module = TypeInferenceConfig.default()
            val merged = project.merge(module)
            # Module default (I32) takes precedence over project (F64)
            expect merged.empty_array_default.to_text() == "i32"