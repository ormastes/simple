use std.spec.{describe, it, expect}

fn auth(user: text, password: text) -> text:
    return password

fn write_to(buffer: [u8], data: [u8]) -> [u8]:
    return data

describe "reserved keyword param rejection":
    it "non-reserved param names work fine":
        expect(auth("admin", "secret")).to_equal("secret")

    it "buffer param works":
        var d: [u8] = [0x01u8, 0x02u8]
        var result: [u8] = write_to([], d)
        expect(result.length()).to_equal(2)
