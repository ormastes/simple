# test/unit/compiler/backend/rvv_mask_emit_spec.spl
#
# Byte-equal golden tests for RVV v1.0 mask logic encoder.
# All goldens derived from RISC-V Vector Extension v1.0 spec.
#
# Encoding formula (funct3=OPMVV=2 for all ops):
#   word = (funct6 * 67108864) + (vm * 33554432) + (vs2 * 1048576)
#        + (vs1 * 32768) + (2 * 4096) + (vd * 128) + 87
#
# Mask-register logical ops (§11.15): vm=0, funct3=2
# VWXUNARY0 ops vcpop/vfirst (§11.16): vm=1, funct3=2, vs1 encodes sub-op
#
# Test registers: vd=1, vs2=2, vs1=3 (mask-mask); rd=1, vs2=2 (vcpop/vfirst).

use std.spec
use compiler.backend.backend.native.encode_rvv_mask.{
    emit_vmand_mm,
    emit_vmnand_mm,
    emit_vmand_not_mm,
    emit_vmor_mm,
    emit_vmnor_mm,
    emit_vmor_not_mm,
    emit_vmxor_mm,
    emit_vmxnor_mm,
    emit_vcpop_m,
    emit_vfirst_m
}

describe "encode_rvv_mask — vmand.mm (mask AND)":
    it "emit_vmand_mm vd=0 vs2=0 vs1=0 — zero-register canonical":
        # funct6=0x19,vm=0,vs2=0,vs1=0,funct3=2,vd=0 → word=0x64002057
        val got = emit_vmand_mm(0, 0, 0)
        expect(got.length) to_equal(4)
        expect(got[0]) to_equal(0x57)
        expect(got[1]) to_equal(0x20)
        expect(got[2]) to_equal(0x00)
        expect(got[3]) to_equal(0x64)

    it "emit_vmand_mm vd=1 vs2=2 vs1=3 — non-zero registers":
        # funct6=0x19,vm=0,vs2=2,vs1=3,funct3=2,vd=1 → word=0x6421A0D7
        val got = emit_vmand_mm(1, 2, 3)
        expect(got.length) to_equal(4)
        expect(got[0]) to_equal(0xD7)
        expect(got[1]) to_equal(0xA0)
        expect(got[2]) to_equal(0x21)
        expect(got[3]) to_equal(0x64)

