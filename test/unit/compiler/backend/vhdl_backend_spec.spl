    it "lowers middle-field hardware bitfield writes through MIR concat and slices":
        val src = """
bitfield Rv32Instruction(u32):
    opcode: 7
    rd: 5
    funct3: 3
    rs1: 5
    rs2: 5
    funct7: 7

@hardware
@clocked(clk, reset_n)
fn bitfield_write_rd(clk: bool, reset_n: bool, imem_rdata: u32, next_rd: u32) -> u32:
    var inst = Rv32Instruction.new(imem_rdata)
    inst.rd = next_rd
    inst
