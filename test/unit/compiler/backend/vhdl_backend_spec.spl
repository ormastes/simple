    it "lowers generated rv32 decode helpers through exact MIR slices, concat shapes, guards, and source maps":
        val src = RiscvFpgaLane.rv32_default().hardware_source_spl()
        val path = "testdata/simple_rv32i_core_generated_hw.spl"
        val log = make_logger()
        val module = parse_full_frontend(src, path, "simple_rv32i_core_generated_hw", log)
        var hir_lowering = HirLowering.with_filename(path)
        val hir_module = hir_lowering.lower_module(module)
        var mir_lowering = MirLowering.new(hir_module.symbols)
        val mir_module = mir_lowering.lower_module(hir_module)

        val mir_funcs = mir_module.functions.values()
        check(mir_funcs.len() >= 5)
        var saw_writeback_opcode_slice = false
        var saw_writeback_funct3_slice = false
        var saw_writeback_funct7_slice = false
        var saw_writeback_rs1_slice = false
        var saw_writeback_rs2_slice = false
        var saw_branch_opcode_slice = false
        var saw_branch_low_slice = false
        var saw_branch_high_slice = false
        var saw_branch_bit11_slice = false
        var saw_branch_bit12_slice = false
        var saw_store_opcode_slice = false
        var saw_store_low_slice = false
        var saw_store_high_slice = false
        var saw_iimm_opcode_slice = false
        var saw_iimm_value_slice = false
        var saw_upper_opcode_slice = false
        var saw_upper_high20_slice = false
        var saw_exec_opcode_slice = false
        var saw_exec_funct3_slice = false
        var saw_exec_shamt_low5_slice = false
        var saw_exec_shamt_bit5_slice = false
        var saw_exec_bit30_slice = false
        var saw_mem_access_opcode_slice = false
        var saw_mem_access_funct3_slice = false
        var saw_jump_opcode_slice = false
        var saw_jump_low10_slice = false
        var saw_jump_high8_slice = false
        var saw_jump_bit11_slice = false
        var saw_jump_bit20_slice = false
        var saw_writeback_rd_concat = false
        var saw_branch_concat = false
        var saw_store_concat = false
        var saw_iimm_concat = false
        var saw_upper_concat = false
        var saw_exec_concat = false
        var saw_mem_access_concat = false
        var saw_jump_concat = false
        var saw_helper_shift_mask_fallback = false
        for mir_fn in mir_funcs:
            if mir_fn.name == "simple_rv32i_core_decode_writeback":
                for block in mir_fn.blocks:
                    for inst in block.instructions:
                        match inst.kind:
                            case VhdlSlice(dest, signal, hi, lo):
                                if hi == 6 and lo == 0:
                                    saw_writeback_opcode_slice = true
                                if hi == 14 and lo == 12:
                                    saw_writeback_funct3_slice = true
                                if hi == 31 and lo == 25:
                                    saw_writeback_funct7_slice = true
                                if hi == 19 and lo == 15:
                                    saw_writeback_rs1_slice = true
                                if hi == 24 and lo == 20:
                                    saw_writeback_rs2_slice = true
                            case BinOp(dest, op, left, right):
                                if op == MirBinOp.BitAnd or op == MirBinOp.BitOr or op == MirBinOp.Shl or op == MirBinOp.Shr:
                                    saw_helper_shift_mask_fallback = true
                            case VhdlConcat(dest, parts):
                                if parts.len() == 3:
                                    saw_writeback_rd_concat = true
                            case _:
                                nil
            if mir_fn.name == "simple_rv32i_core_decode_branch_immediate":
                for block in mir_fn.blocks:
                    for inst in block.instructions:
                        match inst.kind:
                            case VhdlSlice(dest, signal, hi, lo):
                                if hi == 6 and lo == 0:
                                    saw_branch_opcode_slice = true
                                if hi == 11 and lo == 8:
                                    saw_branch_low_slice = true
                                if hi == 30 and lo == 25:
                                    saw_branch_high_slice = true
                                if hi == 7 and lo == 7:
                                    saw_branch_bit11_slice = true
                                if hi == 31 and lo == 31:
                                    saw_branch_bit12_slice = true
                            case BinOp(dest, op, left, right):
                                if op == MirBinOp.BitAnd or op == MirBinOp.BitOr or op == MirBinOp.Shl or op == MirBinOp.Shr:
                                    saw_helper_shift_mask_fallback = true
                            case VhdlConcat(dest, parts):
                                if parts.len() == 5:
                                    saw_branch_concat = true
                            case _:
                                nil
            if mir_fn.name == "simple_rv32i_core_decode_store_immediate":
                for block in mir_fn.blocks:
                    for inst in block.instructions:
                        match inst.kind:
                            case VhdlSlice(dest, signal, hi, lo):
                                if hi == 6 and lo == 0:
                                    saw_store_opcode_slice = true
                                if hi == 11 and lo == 7:
                                    saw_store_low_slice = true
                                if hi == 31 and lo == 25:
                                    saw_store_high_slice = true
                            case BinOp(dest, op, left, right):
                                if op == MirBinOp.BitAnd or op == MirBinOp.BitOr or op == MirBinOp.Shl or op == MirBinOp.Shr:
                                    saw_helper_shift_mask_fallback = true
                            case VhdlConcat(dest, parts):
                                if parts.len() == 3:
                                    saw_store_concat = true
                            case _:
                                nil
            if mir_fn.name == "simple_rv32i_core_decode_i_immediate":
                for block in mir_fn.blocks:
                    for inst in block.instructions:
                        match inst.kind:
                            case VhdlSlice(dest, signal, hi, lo):
                                if hi == 6 and lo == 0:
                                    saw_iimm_opcode_slice = true
                                if hi == 31 and lo == 20:
                                    saw_iimm_value_slice = true
                            case BinOp(dest, op, left, right):
                                if op == MirBinOp.BitAnd or op == MirBinOp.BitOr or op == MirBinOp.Shl or op == MirBinOp.Shr:
                                    saw_helper_shift_mask_fallback = true
                            case VhdlConcat(dest, parts):
                                if parts.len() == 2:
                                    saw_iimm_concat = true
                            case _:
                                nil
            if mir_fn.name == "simple_rv32i_core_decode_upper_immediate":
                for block in mir_fn.blocks:
                    for inst in block.instructions:
                        match inst.kind:
                            case VhdlSlice(dest, signal, hi, lo):
                                if hi == 6 and lo == 0:
                                    saw_upper_opcode_slice = true
                                if hi == 31 and lo == 12:
                                    saw_upper_high20_slice = true
                            case BinOp(dest, op, left, right):
                                if op == MirBinOp.BitAnd or op == MirBinOp.BitOr or op == MirBinOp.Shl or op == MirBinOp.Shr:
                                    saw_helper_shift_mask_fallback = true
                            case VhdlConcat(dest, parts):
                                if parts.len() == 2:
                                    saw_upper_concat = true
                            case _:
                                nil
            if mir_fn.name == "simple_rv32i_core_decode_execute_control":
                for block in mir_fn.blocks:
                    for inst in block.instructions:
                        match inst.kind:
                            case VhdlSlice(dest, signal, hi, lo):
                                if hi == 6 and lo == 0:
                                    saw_exec_opcode_slice = true
                                if hi == 14 and lo == 12:
                                    saw_exec_funct3_slice = true
                                if hi == 24 and lo == 20:
                                    saw_exec_shamt_low5_slice = true
                                if hi == 25 and lo == 25:
                                    saw_exec_shamt_bit5_slice = true
                                if hi == 30 and lo == 30:
                                    saw_exec_bit30_slice = true
                            case BinOp(dest, op, left, right):
                                if op == MirBinOp.BitAnd or op == MirBinOp.BitOr or op == MirBinOp.Shl or op == MirBinOp.Shr:
                                    saw_helper_shift_mask_fallback = true
                            case VhdlConcat(dest, parts):
                                if parts.len() == 4:
                                    saw_exec_concat = true
                            case _:
                                nil
            if mir_fn.name == "simple_rv32i_core_decode_memory_access_control":
                for block in mir_fn.blocks:
                    for inst in block.instructions:
                        match inst.kind:
                            case VhdlSlice(dest, signal, hi, lo):
                                if hi == 6 and lo == 0:
                                    saw_mem_access_opcode_slice = true
                                if hi == 14 and lo == 12:
                                    saw_mem_access_funct3_slice = true
                            case BinOp(dest, op, left, right):
                                if op == MirBinOp.BitAnd or op == MirBinOp.BitOr or op == MirBinOp.Shl or op == MirBinOp.Shr:
                                    saw_helper_shift_mask_fallback = true
                            case VhdlConcat(dest, parts):
                                if parts.len() == 2:
                                    saw_mem_access_concat = true
                            case _:
                                nil
            if mir_fn.name == "simple_rv32i_core_decode_jump_immediate":
                for block in mir_fn.blocks:
                    for inst in block.instructions:
                        match inst.kind:
                            case VhdlSlice(dest, signal, hi, lo):
                                if hi == 6 and lo == 0:
                                    saw_jump_opcode_slice = true
                                if hi == 30 and lo == 21:
                                    saw_jump_low10_slice = true
                                if hi == 19 and lo == 12:
                                    saw_jump_high8_slice = true
                                if hi == 20 and lo == 20:
                                    saw_jump_bit11_slice = true
                                if hi == 31 and lo == 31:
                                    saw_jump_bit20_slice = true
                            case BinOp(dest, op, left, right):
                                if op == MirBinOp.BitAnd or op == MirBinOp.BitOr or op == MirBinOp.Shl or op == MirBinOp.Shr:
                                    saw_helper_shift_mask_fallback = true
                            case VhdlConcat(dest, parts):
                                if parts.len() == 5:
                                    saw_jump_concat = true
                            case _:
                                nil
        check(saw_writeback_opcode_slice)
        check(saw_writeback_funct3_slice)
        check(saw_writeback_funct7_slice)
        check(saw_writeback_rs1_slice)
        check(saw_writeback_rs2_slice)
        check(saw_branch_opcode_slice)
        check(saw_branch_low_slice)
        check(saw_branch_high_slice)
        check(saw_branch_bit11_slice)
        check(saw_branch_bit12_slice)
        check(saw_store_opcode_slice)
        check(saw_store_low_slice)
        check(saw_store_high_slice)
        check(saw_iimm_opcode_slice)
        check(saw_iimm_value_slice)
        check(saw_upper_opcode_slice)
        check(saw_upper_high20_slice)
        check(saw_exec_opcode_slice)
        check(saw_exec_funct3_slice)
        check(saw_exec_shamt_low5_slice)
        check(saw_exec_shamt_bit5_slice)
        check(saw_exec_bit30_slice)
        check(saw_mem_access_opcode_slice)
        check(saw_mem_access_funct3_slice)
        check(saw_jump_opcode_slice)
        check(saw_jump_low10_slice)
        check(saw_jump_high8_slice)
        check(saw_jump_bit11_slice)
        check(saw_jump_bit20_slice)
        check(saw_writeback_rd_concat)
        check(saw_branch_concat)
        check(saw_store_concat)
        check(saw_iimm_concat)
        check(saw_upper_concat)
        check(saw_exec_concat)
        check(saw_mem_access_concat)
        check(saw_jump_concat)
        check(not saw_helper_shift_mask_fallback)

        val result = make_simple_backend().compile(mir_module)
        check(result.is_ok())
        val vhdl = result.unwrap().vhdl
        check(vhdl.contains("if unsigned(v_opcode) = to_unsigned(19, 32) then"))
        check(vhdl.contains("elsif unsigned(v_opcode) = to_unsigned(51, 32) and unsigned(v_funct3) = to_unsigned(0, 32) and unsigned(v_funct7) = to_unsigned(0, 32) then"))
        check(vhdl.contains("if unsigned(v_opcode) = to_unsigned(99, 32) then"))
        check(vhdl.contains("if unsigned(v_opcode) = to_unsigned(35, 32) then"))
        check(vhdl.contains("if unsigned(v_opcode) = to_unsigned(19, 32) or unsigned(v_opcode) = to_unsigned(3, 32) then"))
        check(vhdl.contains("if unsigned(v_opcode) = to_unsigned(55, 32) or unsigned(v_opcode) = to_unsigned(23, 32) then"))
        check(vhdl.contains("if unsigned(v_opcode) = to_unsigned(19, 32) or unsigned(v_opcode) = to_unsigned(51, 32) or unsigned(v_opcode) = to_unsigned(99, 32) then"))
        check(vhdl.contains("if unsigned(v_opcode) = to_unsigned(3, 32) or unsigned(v_opcode) = to_unsigned(35, 32) then"))
        check(vhdl.contains("if unsigned(v_opcode) = to_unsigned(111, 32) then"))
        check(vhdl.contains("imem_rdata(6 downto 0)"))
        check(vhdl.contains("imem_rdata(14 downto 12)"))
        check(vhdl.contains("imem_rdata(31 downto 25)"))
        check(vhdl.contains("imem_rdata(19 downto 15)"))
        check(vhdl.contains("imem_rdata(24 downto 20)"))
        check(vhdl.contains("imem_rdata(11 downto 8)"))
        check(vhdl.contains("imem_rdata(30 downto 25)"))
        check(vhdl.contains("imem_rdata(7 downto 7)"))
        check(vhdl.contains("imem_rdata(31 downto 31)"))
        check(vhdl.contains("imem_rdata(11 downto 7)"))
        check(vhdl.contains("imem_rdata(31 downto 20)"))
        check(vhdl.contains("imem_rdata(25 downto 25)"))
        check(vhdl.contains("imem_rdata(30 downto 30)"))
        check(vhdl.contains("imem_rdata(19 downto 12)"))
        check(vhdl.contains("imem_rdata(20 downto 20)"))
        check(vhdl.contains("imem_rdata(30 downto 21)"))
        check(vhdl.contains("imem_rdata(31 downto 12) & resize(unsigned(v_inst_rs1), 5) & imem_rdata(6 downto 0)"))
        check(vhdl.contains("imem_rdata(31 downto 12) & resize(unsigned(v_inst_rs2), 5) & imem_rdata(6 downto 0)"))
        check(vhdl.contains("to_unsigned(0, 20) & resize(unsigned(v_branch_inst_bit12), 1) & resize(unsigned(v_branch_inst_bit11), 1) & resize(unsigned(v_branch_inst_high), 6) & resize(unsigned(v_branch_inst_low), 4)"))
        check(vhdl.contains("to_unsigned(0, 20) & resize(unsigned(v_store_inst_high), 7) & resize(unsigned(v_store_inst_low), 5)"))
        check(vhdl.contains("to_unsigned(0, 20) & resize(unsigned(v_imm_inst_value), 12)"))
        check(vhdl.contains("resize(unsigned(v_upper_inst_high20), 20) & to_unsigned(0, 12)"))
        check(vhdl.contains("to_unsigned(0, 22) & resize(unsigned(v_control_inst_shamt_bit5), 1) & resize(unsigned(v_control_inst_bit30), 1) & resize(unsigned(v_control_inst_funct3), 3)"))
        check(vhdl.contains("to_unsigned(0, 29) & resize(unsigned(v_access_inst_funct3), 3)"))
        check(vhdl.contains("to_unsigned(0, 12) & resize(unsigned(v_jump_inst_bit20), 1) & resize(unsigned(v_jump_inst_high8), 8) & resize(unsigned(v_jump_inst_bit11), 1) & resize(unsigned(v_jump_inst_low10), 10)"))
        check(vhdl.contains("-- source-map: Rv32Instruction.funct3 => imem_rdata(14 downto 12)"))
        check(vhdl.contains("-- source-map: Rv32Instruction.funct7 => imem_rdata(31 downto 25)"))
        check(vhdl.contains("-- source-map: RiscvBranchEncoding.low => imem_rdata(11 downto 8)"))
        check(vhdl.contains("-- source-map: RiscvStoreEncoding.low => imem_rdata(11 downto 7)"))
        check(vhdl.contains("-- source-map: RiscvStoreEncoding.high => imem_rdata(31 downto 25)"))
        check(vhdl.contains("-- source-map: RiscvIImmediateEncoding.value => imem_rdata(31 downto 20)"))
        check(vhdl.contains("-- source-map: RiscvUpperImmediateEncoding.high20 => imem_rdata(31 downto 12)"))
        check(vhdl.contains("-- source-map: RiscvExecuteControlEncoding.funct3 => imem_rdata(14 downto 12)"))
        check(vhdl.contains("-- source-map: RiscvExecuteControlEncoding.shamt_low5 => imem_rdata(24 downto 20)"))
        check(vhdl.contains("-- source-map: RiscvExecuteControlEncoding.shamt_bit5 => imem_rdata(25 downto 25)"))
        check(vhdl.contains("-- source-map: RiscvExecuteControlEncoding.bit30 => imem_rdata(30 downto 30)"))
        check(vhdl.contains("-- source-map: RiscvMemoryAccessControlEncoding.funct3 => imem_rdata(14 downto 12)"))
        check(vhdl.contains("-- source-map: RiscvJumpEncoding.high8 => imem_rdata(19 downto 12)"))
        check(vhdl.contains("-- source-map: RiscvJumpEncoding.bit11 => imem_rdata(20 downto 20)"))
        check(vhdl.contains("-- source-map: RiscvJumpEncoding.low10 => imem_rdata(30 downto 21)"))
        check(vhdl.contains("-- source-map: RiscvJumpEncoding.bit20 => imem_rdata(31 downto 31)"))

    it "rejects non-positive fixed-width bit lanes before VHDL emission":
        val src_local = make_arg_local(1, 0, "bad", make_bits(0))
        val ret_local = make_return_local(2, make_bits(0))
        val block = MirBlock(
            id: BlockId(id: 0),
            label: Some("entry"),
            instructions: [],
            terminator: MirTerminator.Return(nil)
        )
        val func = MirFunction(
            symbol: SymbolId(id: 76),
            name: "bad_bits_width",
            signature: MirSignature(params: [make_bits(0)], return_type: make_bits(0), is_variadic: false),
            locals: [src_local, ret_local],
            blocks: [block],
            entry_block: BlockId.entry(),
            span: empty_span(),
            generic_params: [],
            is_generic_template: false,
            specialization_of: nil,
            type_bindings: {},
            layout_phase: nil,
            is_kernel: false,
            is_export_c: false,
            export_name: "",
            driver_manifest_attr: nil
        )
        val result = make_simple_backend().compile(single_block_module("bad_bits_width_mod", func))
        check(result.is_err())
        check(result.unwrap_err().message.contains("positive concrete width"))

    it "emits active-low async reset condition for reset_n process domains":
        val clk_local = make_arg_local(1, 0, "clk", make_bool())
        val reset_local = make_arg_local(2, 1, "reset_n", make_bool())
        val data_local = make_arg_local(3, 2, "data_in", make_i32())
        val ret_local = make_return_local(4, make_i32())
        val body_block = MirBlock(
            id: BlockId(id: 1),
            label: Some("proc_body"),
            instructions: [
                MirInst(
                    kind: MirInstKind.Copy(LocalId(id: 4), LocalId(id: 3)),
                    span: nil
                )
            ],
            terminator: MirTerminator.Return(nil)
        )
        val entry_block = MirBlock(
            id: BlockId(id: 0),
            label: Some("entry"),
            instructions: [
                MirInst(
                    kind: MirInstKind.VhdlProcess(
                        VhdlProcessKind.AsyncReset(VhdlClockDomain(name: "core", clock_signal: "clk", reset_signal: Some("reset_n"), reset_polarity: VhdlResetPolarity.ActiveLow, reset_synchrony: VhdlResetSynchrony.Async, edge: VhdlClockEdge.Rising)),
                        BlockId(id: 1)
                    ),
                    span: nil
                )
            ],
            terminator: MirTerminator.Return(nil)
        )
        val func = MirFunction(
            symbol: SymbolId(id: 31),
            name: "registered_low_reset",
            signature: MirSignature(params: [make_bool(), make_bool(), make_i32()], return_type: make_i32(), is_variadic: false),
            locals: [clk_local, reset_local, data_local, ret_local],
            blocks: [entry_block, body_block],
            entry_block: BlockId.entry(),
            span: empty_span(),
            generic_params: [],
            is_generic_template: false,
            specialization_of: nil,
            type_bindings: {},
            layout_phase: nil,
            is_kernel: false,
            is_export_c: false,
            export_name: "",
            driver_manifest_attr: nil
        )

        val backend = make_simple_backend()
        val result = backend.compile(single_block_module("async_low_mod", func))
        check(result.is_ok())
        val compiled = result.unwrap()

        check(compiled.vhdl.contains("process(clk, reset_n)"))
        check(compiled.vhdl.contains("if reset_n = '0' then"))
        check(compiled.vhdl.contains("if rising_edge(clk) then"))
        check(compiled.vhdl.contains("result_out <= data_in;"))

    it "emits active-high async reset condition for plain reset process domains":
        val clk_local = make_arg_local(1, 0, "clk", make_bool())
        val reset_local = make_arg_local(2, 1, "rst", make_bool())
