    it "emits clock-only process when clocked domain has no reset signal":
        val clk_local = make_arg_local(1, 0, "clk", make_bool())
        val data_local = make_arg_local(2, 1, "data_in", make_i32())
        val ret_local = make_return_local(3, make_i32())
        val body_block = MirBlock(
            id: BlockId(id: 1),
            label: Some("proc_body"),
            instructions: [
                MirInst(
                    kind: MirInstKind.Copy(LocalId(id: 3), LocalId(id: 2)),
                    span: nil
                )
            ],
            terminator: MirTerminator.Return(nil)
        )
        val entry_block = MirBlock(
            id: BlockId(id: 0),
            label: Some("entry"),
            instructions: [
                MirInst(
                    kind: MirInstKind.VhdlProcess(
                        VhdlProcessKind.Clocked(VhdlClockDomain(name: "core", clock_signal: "clk", reset_signal: nil, reset_polarity: VhdlResetPolarity.ActiveLow, reset_synchrony: VhdlResetSynchrony.None_, edge: VhdlClockEdge.Rising)),
                        BlockId(id: 1)
                    ),
                    span: nil
                )
            ],
            terminator: MirTerminator.Return(nil)
        )
        val func = MirFunction(
            symbol: SymbolId(id: 33),
            name: "registered_no_reset",
            signature: MirSignature(params: [make_bool(), make_i32()], return_type: make_i32(), is_variadic: false),
            locals: [clk_local, data_local, ret_local],
            blocks: [entry_block, body_block],
            entry_block: BlockId.entry(),
            span: empty_span(),
            generic_params: [],
            is_generic_template: false,
            specialization_of: nil,
            type_bindings: {},
            layout_phase: nil,
            is_kernel: false,
            is_export_c: false,
            export_name: "",
            driver_manifest_attr: nil
        )

        val backend = make_simple_backend()
        val result = backend.compile(single_block_module("clock_only_mod", func))
        check(result.is_ok())
        val compiled = result.unwrap()

        check(compiled.vhdl.contains("process(clk)"))
        check(compiled.vhdl.contains("if rising_edge(clk) then"))
        check(not compiled.vhdl.contains("async reset branch"))

    it "fails fast on unsupported MIR instructions":
        val alloc_result = compile_single_vhdl_instruction("bad_alloc", MirInstKind.Alloc(LocalId(id: 2), make_i32()))
        check(alloc_result.is_err())
        check(alloc_result.unwrap_err().message.contains("Alloc storage allocation"))

        val gep_result = compile_single_vhdl_instruction(
            "bad_gep",
            MirInstKind.GetElementPtr(
                LocalId(id: 2),
                MirOperand(kind: MirOperandKind.Copy(LocalId(id: 2))),
                [MirOperand(kind: MirOperandKind.Const(MirConstValue.Int(0), make_i32()))]
            )
        )
        check(gep_result.is_err())
        check(gep_result.unwrap_err().message.contains("GetElementPtr lowering"))

        val indirect_result = compile_single_vhdl_instruction(
            "bad_call_indirect",
            MirInstKind.CallIndirect(
                Some(LocalId(id: 2)),
                make_func_operand("dynamic_target"),
                [],
                MirSignature(params: [], return_type: make_i32(), is_variadic: false)
            )
        )
        check(indirect_result.is_err())
        check(indirect_result.unwrap_err().message.contains("CallIndirect lowering"))

        val checked_result = compile_single_vhdl_instruction(
            "bad_checked",
            MirInstKind.CheckedBinOp(
                LocalId(id: 2),
                MirBinOp.Add,
                MirOperand(kind: MirOperandKind.Copy(LocalId(id: 2))),
                MirOperand(kind: MirOperandKind.Const(MirConstValue.Int(1), make_i32()))
            )
        )
        check(checked_result.is_err())
        val checked_err = checked_result.unwrap_err()
        check(checked_err.message.contains("checked arithmetic MIR instruction"))
        check(checked_err.phase.contains("vhdl"))

    it "emits called pure combinational helpers as package functions":
        val helper_a = make_arg_local(1, 0, "a", make_i32())
        val helper_b = make_arg_local(2, 1, "b", make_i32())
        val helper_ret = make_return_local(3, make_i32())
        val helper_sum = make_temp_local(4, "sum-sig", make_i32())
        val helper_block = MirBlock(
            id: BlockId(id: 0),
            label: Some("entry"),
            instructions: [
                MirInst(kind: MirInstKind.BinOp(LocalId(id: 4), MirBinOp.Add, MirOperand(kind: MirOperandKind.Copy(LocalId(id: 1))), MirOperand(kind: MirOperandKind.Copy(LocalId(id: 2)))), span: nil),
                MirInst(kind: MirInstKind.Copy(LocalId(id: 3), LocalId(id: 4)), span: nil)
            ],
            terminator: MirTerminator.Return(nil)
        )
        val helper = MirFunction(
            symbol: SymbolId(id: 101),
            name: "mix-add",
            signature: MirSignature(params: [make_i32(), make_i32()], return_type: make_i32(), is_variadic: false),
            locals: [helper_a, helper_b, helper_ret, helper_sum],
            blocks: [helper_block],
            entry_block: BlockId.entry(),
            span: empty_span(),
            generic_params: [],
            is_generic_template: false,
            specialization_of: nil,
            type_bindings: {},
            layout_phase: nil,
            is_kernel: false,
            is_export_c: false,
            export_name: "",
            driver_manifest_attr: nil
        )
        val top_a = make_arg_local(11, 0, "left_in", make_i32())
        val top_b = make_arg_local(12, 1, "right_in", make_i32())
        val top_ret = make_return_local(13, make_i32())
        val top_tmp = make_temp_local(14, "call_result", make_i32())
        val top_block = MirBlock(
            id: BlockId(id: 0),
            label: Some("entry"),
            instructions: [
                MirInst(kind: MirInstKind.Call(Some(LocalId(id: 14)), make_func_operand("mix-add"), [MirOperand(kind: MirOperandKind.Copy(LocalId(id: 11))), MirOperand(kind: MirOperandKind.Copy(LocalId(id: 12)))]), span: nil),
                MirInst(kind: MirInstKind.Copy(LocalId(id: 13), LocalId(id: 14)), span: nil)
            ],
            terminator: MirTerminator.Return(nil)
        )
        val top = MirFunction(
            symbol: SymbolId(id: 102),
            name: "top_entity",
            signature: MirSignature(params: [make_i32(), make_i32()], return_type: make_i32(), is_variadic: false),
            locals: [top_a, top_b, top_ret, top_tmp],
            blocks: [top_block],
            entry_block: BlockId.entry(),
            span: empty_span(),
            generic_params: [],
            is_generic_template: false,
            specialization_of: nil,
            type_bindings: {},
            layout_phase: nil,
            is_kernel: false,
            is_export_c: false,
            export_name: "",
            driver_manifest_attr: nil,
            has_vhdl_metadata: true,
            vhdl_metadata: make_hardware_meta()
        )
        var functions: Dict<SymbolId, MirFunction> = {}
        functions[helper.symbol] = helper
        functions[top.symbol] = top
        val result = make_simple_backend().compile(MirModule(name: "helper_mod", functions: functions, statics: {}, constants: {}, types: {}))
        check(result.is_ok())
        val compiled = result.unwrap()
        check(compiled.package_vhdl.?)
        val pkg = compiled.package_vhdl.unwrap()
        check(pkg.contains("function mix_add(a : signed(31 downto 0); b : signed(31 downto 0)) return signed(31 downto 0);"))
        check(pkg.contains("package body helper_mod_pkg is"))
        check(pkg.contains("variable sum_sig : signed(31 downto 0);"))
        check(pkg.contains("sum_sig := a + b;"))
        check(pkg.contains("return return_value;"))
        check(compiled.vhdl.contains("use work.helper_mod_pkg.all;"))
        check(compiled.vhdl.contains("entity top_entity is"))
        check(not compiled.vhdl.contains("entity mix-add is"))
        check(compiled.vhdl.contains("call_result <= mix_add(left_in, right_in);"))

    it "rejects helper name collisions after sanitization":
        val a = make_adder_function()
        val b = MirFunction(..a, symbol: SymbolId(id: 111), name: "dup-helper")
        val c = MirFunction(..a, symbol: SymbolId(id: 112), name: "dup_helper")
        val top = MirFunction(..a, symbol: SymbolId(id: 113), name: "hardware_top", has_vhdl_metadata: true, vhdl_metadata: make_hardware_meta())
        var functions: Dict<SymbolId, MirFunction> = {}
        functions[b.symbol] = b
        functions[c.symbol] = c
        functions[top.symbol] = top
        val result = make_simple_backend().compile(MirModule(name: "helper_collision_mod", functions: functions, statics: {}, constants: {}, types: {}))
        check(result.is_err())
        check(result.unwrap_err().message.contains("Duplicate VHDL helper subprogram name after sanitization"))

    it "rejects unsupported helper memory behavior with a specific diagnostic":
        val bad_ret = make_return_local(1, make_i32())
        val bad_tmp = make_temp_local(2, "tmp", make_i32())
        val bad_block = MirBlock(
            id: BlockId(id: 0),
            label: Some("entry"),
            instructions: [MirInst(kind: MirInstKind.Alloc(LocalId(id: 2), make_i32()), span: nil)],
            terminator: MirTerminator.Return(nil)
        )
        val bad = MirFunction(
            symbol: SymbolId(id: 121),
            name: "bad_helper",
            signature: MirSignature(params: [], return_type: make_i32(), is_variadic: false),
            locals: [bad_ret, bad_tmp],
            blocks: [bad_block],
            entry_block: BlockId.entry(),
            span: empty_span(),
            generic_params: [],
            is_generic_template: false,
            specialization_of: nil,
            type_bindings: {},
            layout_phase: nil,
            is_kernel: false,
            is_export_c: false,
            export_name: "",
            driver_manifest_attr: nil
        )
        val top = MirFunction(..make_adder_function(), symbol: SymbolId(id: 122), name: "hardware_top", has_vhdl_metadata: true, vhdl_metadata: make_hardware_meta())
        var functions: Dict<SymbolId, MirFunction> = {}
        functions[bad.symbol] = bad
        functions[top.symbol] = top
        val result = make_simple_backend().compile(MirModule(name: "bad_helper_mod", functions: functions, statics: {}, constants: {}, types: {}))
        check(result.is_err())
        check(result.unwrap_err().message.contains("Unsupported VHDL helper subprogram memory behavior"))
