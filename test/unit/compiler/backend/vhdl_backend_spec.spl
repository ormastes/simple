    it "lowers hardware bitfield reads through MIR VhdlSlice into typed VHDL slices":
        val src = """
bitfield Rv32Instruction(u32):
    opcode: 7
    rd: 5
    funct3: 3
    rs1: 5
    rs2: 5
    funct7: 7

@hardware
@clocked(clk, reset_n)
fn bitfield_opcode(clk: bool, reset_n: bool, imem_rdata: u32) -> u32:
    val inst = Rv32Instruction.new(imem_rdata)
    inst.opcode as u32
"""
        val path = "testdata/bitfield_opcode_hw.spl"
        val log = make_logger()
        val module = parse_full_frontend(src, path, "bitfield_opcode_hw", log)
        var hir_lowering = HirLowering.with_filename(path)
        val hir_module = hir_lowering.lower_module(module)
        var mir_lowering = MirLowering.new(hir_module.symbols)
        val mir_module = mir_lowering.lower_module(hir_module)

        val mir_funcs = mir_module.functions.values()
        check(mir_funcs.len() > 0)
        val mir_fn = mir_funcs[0]
        var has_opcode_slice = false
        for block in mir_fn.blocks:
            for inst in block.instructions:
                match inst.kind:
                    case VhdlSlice(dest, signal, hi, lo):
                        if hi == 6 and lo == 0:
                            has_opcode_slice = true
                    case _:
                        nil
        check(has_opcode_slice)

        val result = make_simple_backend().compile(mir_module)
        check(result.is_ok())
        val vhdl = result.unwrap().vhdl
        check(vhdl.contains("imem_rdata : in unsigned(31 downto 0);"))
        check(vhdl.contains("imem_rdata(6 downto 0)"))
        check(vhdl.contains("resize(unsigned("))

    it "lowers low-edge hardware bitfield writes through MIR concat and slice":
        val src = """
bitfield Rv32Instruction(u32):
    opcode: 7
    rd: 5
    funct3: 3
    rs1: 5
    rs2: 5
    funct7: 7

@hardware
@clocked(clk, reset_n)
fn bitfield_write_opcode(clk: bool, reset_n: bool, imem_rdata: u32, next_opcode: u32) -> u32:
    var inst = Rv32Instruction.new(imem_rdata)
    inst.opcode = next_opcode
    inst
"""
        val path = "testdata/bitfield_write_opcode_hw.spl"
        val log = make_logger()
        val module = parse_full_frontend(src, path, "bitfield_write_opcode_hw", log)
        var hir_lowering = HirLowering.with_filename(path)
        val hir_module = hir_lowering.lower_module(module)
        var mir_lowering = MirLowering.new(hir_module.symbols)
        val mir_module = mir_lowering.lower_module(hir_module)

        val mir_funcs = mir_module.functions.values()
        check(mir_funcs.len() > 0)
        val mir_fn = mir_funcs[0]
        var has_preserved_high = false
        var has_concat = false
        var has_cast = false
        var concat_dest = -1
        var returns_concat = false
        for block in mir_fn.blocks:
            for inst in block.instructions:
                match inst.kind:
                    case VhdlSlice(dest, signal, hi, lo):
                        if hi == 31 and lo == 7:
                            has_preserved_high = true
                    case Cast(dest, operand, target):
                        if target == MirType.bits(7):
                            has_cast = true
                    case VhdlConcat(dest, parts):
                        has_concat = true
                        concat_dest = dest.id
                    case Copy(dest, src):
                        if concat_dest >= 0 and src.id == concat_dest:
                            returns_concat = true
                    case _:
                        nil
        check(has_preserved_high)
        check(has_cast)
        check(has_concat)
        check(returns_concat)

        val result = make_simple_backend().compile(mir_module)
        check(result.is_ok())
        val vhdl = result.unwrap().vhdl
        check(vhdl.contains("imem_rdata(31 downto 7) & resize(unsigned(next_opcode), 7)"))

