import std.spec

use compiler.backend.{CodegenTarget, riscv_linux_target_contract}
use compiler.backend.native.{RV64_WORD_SIZE}

describe "Isel Riscv64":
    it "uses the shared LP64D contract word size":
        val contract = riscv_linux_target_contract(CodegenTarget.Riscv64)
        expect RV64_WORD_SIZE == 8
        expect contract.pointer_bits == 64
        expect contract.stack_align_bytes == 16

    it "keeps RV64 Linux ABI metadata explicit":
        val contract = riscv_linux_target_contract(CodegenTarget.Riscv64)
        expect contract.abi.to_text() == "lp64d"
        expect contract.arg_register_count == 8