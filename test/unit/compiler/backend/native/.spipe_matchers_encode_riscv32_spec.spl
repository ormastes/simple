import std.spec

use compiler.backend.backend.backend_types.{CodegenTarget}
use compiler.backend.backend.riscv_target.{riscv_linux_target_contract}
use compiler.backend.native.encode_riscv32.{ELF32_EI_CLASS, ELF32_HEADER_SIZE}

describe "Encode Riscv32":
    it "retains ELF32 constants for the RV32 Linux lane":
        expect ELF32_EI_CLASS == 1
        expect ELF32_HEADER_SIZE == 52

    it "shares the Linux call relocation and ABI contract":
        val contract = riscv_linux_target_contract(CodegenTarget.Riscv32)
        expect contract.call_plt_reloc == 19
        expect contract.abi_text() == "ilp32d"
        expect contract.march == "rv32gc"