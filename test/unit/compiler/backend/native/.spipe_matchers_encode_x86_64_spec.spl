use std.spec.*

use compiler.backend.native.encode_x86_64.{new_encode_context, encode_inst}
use compiler.backend.native.mach_inst.{Operand, new_mach_inst, op_phys, X86_RAX, X86_OP_BSWAP}

fn encode_single_inst(inst_opcode: i64, operands: [Operand]) -> [i64]:
    val encoded = encode_inst(new_encode_context(), new_mach_inst(inst_opcode, operands))
    encoded.code

describe "Encode X86_64 scalar bitmanip":
    it "encodes bswap rax":
        expect encode_single_inst(X86_OP_BSWAP, [op_phys(X86_RAX)]) == [0x48, 0x0f, 0xc8]