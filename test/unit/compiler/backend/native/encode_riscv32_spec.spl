import std.spec

use compiler.backend.{CodegenTarget, riscv_linux_target_contract}
use compiler.backend.native.encode_riscv32.{RV32_R_RISCV_CALL_PLT, ELF32_EI_CLASS, ELF32_HEADER_SIZE}

describe "Encode Riscv32":
    it "retains ELF32 constants for the RV32 Linux lane":
        expect(ELF32_EI_CLASS).to_equal(1)
        expect(ELF32_HEADER_SIZE).to_equal(52)

    it "shares the Linux call relocation and ABI contract":
        val contract = riscv_linux_target_contract(CodegenTarget.Riscv32)
        expect(RV32_R_RISCV_CALL_PLT).to_equal(19)
        expect(contract.abi.to_text()).to_equal("ilp32d")
        expect(contract.march).to_equal("rv32gc")
