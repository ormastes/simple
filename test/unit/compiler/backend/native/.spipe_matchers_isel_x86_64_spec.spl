import std.spec

use compiler.mir.mir_data.*
use compiler.mir.intrinsics.{BIT_ROTATE_LEFT, BIT_ROTATE_RIGHT}
use compiler.backend.native.isel_x86_64.{isel_module}
use compiler.backend.native.mach_inst.{MachModule, MachBlock, X86_OP_MOV_REG_REG, X86_OP_MOV_REG_IMM, X86_OP_AND, X86_OP_OR, X86_OP_SHL, X86_OP_SHR}
use compiler.common.diagnostics.span.{Span}
use compiler.hir.hir_types.{SymbolId}

fn build_rotate_module(name: text, intrinsic_name: text) -> MirModule:
    val i64_type = MirType(kind: MirTypeKind.I64)
    val sig = MirSignature(params: [], return_type: i64_type, is_variadic: false)
    val locals = [
        MirLocal(id: LocalId(id: 0), name: Some("_return"), type_: i64_type, kind: LocalKind.Return),
        MirLocal(id: LocalId(id: 1), name: Some("value"), type_: i64_type, kind: LocalKind.Temp),
        MirLocal(id: LocalId(id: 2), name: Some("count"), type_: i64_type, kind: LocalKind.Temp),
        MirLocal(id: LocalId(id: 3), name: Some("result"), type_: i64_type, kind: LocalKind.Temp)
    ]
    val entry = MirBlock(
        id: BlockId.new(0),
        label: Some("entry"),
        instructions: [
            MirInst(kind: MirInstKind.Const(LocalId(id: 1), MirConstValue.Int(0x123456789ABCDEF), i64_type), span: nil),
            MirInst(kind: MirInstKind.Const(LocalId(id: 2), MirConstValue.Int(13), i64_type), span: nil),
            MirInst(
                kind: MirInstKind.Intrinsic(
                    Some(LocalId(id: 3)),
                    intrinsic_name,
                    [
                        MirOperand(kind: MirOperandKind.Copy(LocalId(id: 1))),
                        MirOperand(kind: MirOperandKind.Copy(LocalId(id: 2)))
                    ]
                ),
                span: nil
            )
        ],
        terminator: MirTerminator.Return(Some(MirOperand(kind: MirOperandKind.Copy(LocalId(id: 3)))))
    )
    val func = MirFunction(
        symbol: SymbolId.new(0),
        name: name,
        signature: sig,
        locals: locals,
        blocks: [entry],
        entry_block: BlockId.new(0),
        span: Span(start: 0, end: 0, line: 1, col: 1),
        generic_params: [],
        is_generic_template: false,
        specialization_of: nil,
        type_bindings: {}
    )
    var functions: Dict<SymbolId, MirFunction> = {}
    functions[SymbolId.new(0)] = func
    MirModule(name: name, functions: functions, statics: {}, constants: {}, types: {})

fn entry_block(module: MachModule) -> MachBlock:
    module.functions[0].blocks[1]

fn opcode_at(block: MachBlock, index: i64) -> i64:
    block.insts[index].opcode

describe "Isel X86_64 rotate intrinsic lowering":
    it "lowers bit_rotate_left into shift-or machine ops":
        val mach = isel_module(build_rotate_module("rol_test", BIT_ROTATE_LEFT))
        val block = entry_block(mach)

        expect block.insts.len() == 15
        expect opcode_at(block, 4) == X86_OP_MOV_REG_REG
        expect opcode_at(block, 5) == X86_OP_MOV_REG_REG
        expect opcode_at(block, 6) == X86_OP_MOV_REG_IMM
        expect opcode_at(block, 7) == X86_OP_AND
        expect opcode_at(block, 8) == X86_OP_MOV_REG_REG
        expect opcode_at(block, 9) == X86_OP_MOV_REG_REG
        expect opcode_at(block, 10) == X86_OP_SHL
        expect opcode_at(block, 11) == X86_OP_MOV_REG_IMM
        expect opcode_at(block, 12) == X86_OP_AND
        expect opcode_at(block, 13) == X86_OP_MOV_REG_REG
        expect opcode_at(block, 14) == X86_OP_SHR

    it "lowers bit_rotate_right into mirrored shift-or machine ops":
        val mach = isel_module(build_rotate_module("ror_test", BIT_ROTATE_RIGHT))
        val block = entry_block(mach)

        expect block.insts.len() == 15
        expect opcode_at(block, 10) == X86_OP_SHR
        expect opcode_at(block, 14) == X86_OP_SHL
        expect opcode_at(block, 15 - 1) == X86_OP_SHL
        expect block.insts[block.insts.len() - 1].opcode == X86_OP_SHL
        expect block.insts[block.insts.len() - 2].opcode == X86_OP_MOV_REG_REG
        expect block.insts[block.insts.len() - 3].opcode == X86_OP_AND
        expect block.insts[block.insts.len() - 4].opcode == X86_OP_MOV_REG_IMM
        expect block.insts[block.insts.len() - 5].opcode == X86_OP_SHR
        expect block.insts[block.insts.len() - 6].opcode == X86_OP_MOV_REG_REG
        expect block.insts[block.insts.len() - 7].opcode == X86_OP_MOV_REG_REG
        expect block.insts[block.insts.len() - 8].opcode == X86_OP_AND
        expect block.insts[block.insts.len() - 9].opcode == X86_OP_MOV_REG_IMM
        expect block.insts[block.insts.len() - 10].opcode == X86_OP_MOV_REG_REG
        expect block.insts[block.insts.len() - 11].opcode == X86_OP_MOV_REG_REG
        expect block.insts[block.insts.len() - 12].opcode == X86_OP_MOV_REG_REG
        expect block.insts[block.insts.len() - 13].opcode == X86_OP_MOV_REG_REG
        expect block.insts[block.insts.len() - 14].opcode == X86_OP_MOV_REG_REG
        expect block.insts[block.insts.len() - 15].opcode == X86_OP_MOV_REG_IMM
        expect block.insts[block.insts.len() - 16].opcode == X86_OP_MOV_REG_REG