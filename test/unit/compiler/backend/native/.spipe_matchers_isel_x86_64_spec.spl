use std.spec.*

use compiler.mir.mir_data.*
use compiler.mir.intrinsics.{BIT_BSWAP}
use compiler.backend.native.isel_x86_64.{isel_module}
use compiler.backend.native.mach_inst.{MachModule, MachBlock, X86_OP_MOV_REG_REG, X86_OP_MOV_REG_IMM, X86_OP_AND, X86_OP_OR, X86_OP_SUB, X86_OP_SHL, X86_OP_SHR, X86_OP_BSWAP}
use compiler.common.diagnostics.span.{Span}
use compiler.hir.hir_types.{SymbolId}

fn build_rotate_module(name: text, intrinsic_name: text) -> MirModule:
    val i64_type = MirType(kind: MirTypeKind.I64)
    val sig = MirSignature(params: [], return_type: i64_type, is_variadic: false)
    val locals = [
        MirLocal(id: LocalId(id: 0), name: Some("_return"), type_: i64_type, kind: LocalKind.Return),
        MirLocal(id: LocalId(id: 1), name: Some("value"), type_: i64_type, kind: LocalKind.Temp),
        MirLocal(id: LocalId(id: 2), name: Some("count"), type_: i64_type, kind: LocalKind.Temp),
        MirLocal(id: LocalId(id: 3), name: Some("result"), type_: i64_type, kind: LocalKind.Temp)
    ]
    val entry = MirBlock(
        id: BlockId.new(0),
        label: Some("entry"),
        instructions: [
            MirInst(kind: MirInstKind.Const(LocalId(id: 1), MirConstValue.Int(0x123456789ABCDEF), i64_type), span: nil),
            MirInst(kind: MirInstKind.Const(LocalId(id: 2), MirConstValue.Int(13), i64_type), span: nil),
            MirInst(
                kind: MirInstKind.Intrinsic(
                    Some(LocalId(id: 3)),
                    intrinsic_name,
                    [
                        MirOperand(kind: MirOperandKind.Copy(LocalId(id: 1))),
                        MirOperand(kind: MirOperandKind.Copy(LocalId(id: 2)))
                    ]
                ),
                span: nil
            )
        ],
        terminator: MirTerminator.Return(Some(MirOperand(kind: MirOperandKind.Copy(LocalId(id: 3)))))
    )
    val func = MirFunction(
        symbol: SymbolId.new(0),
        name: name,
        signature: sig,
        locals: locals,
        blocks: [entry],
        entry_block: BlockId.new(0),
        span: Span(start: 0, end: 0, line: 1, col: 1),
        generic_params: [],
        is_generic_template: false,
        specialization_of: nil,
        type_bindings: {}
    )
    var functions: Dict<SymbolId, MirFunction> = {}
    functions[SymbolId.new(0)] = func
    MirModule(name: name, functions: functions, statics: {}, constants: {}, types: {})

fn build_bswap_module(name: text) -> MirModule:
    val i64_type = MirType(kind: MirTypeKind.I64)
    val sig = MirSignature(params: [], return_type: i64_type, is_variadic: false)
    val locals = [
        MirLocal(id: LocalId(id: 0), name: Some("_return"), type_: i64_type, kind: LocalKind.Return),
        MirLocal(id: LocalId(id: 1), name: Some("value"), type_: i64_type, kind: LocalKind.Temp),
        MirLocal(id: LocalId(id: 2), name: Some("result"), type_: i64_type, kind: LocalKind.Temp)
    ]
    val entry = MirBlock(
        id: BlockId.new(0),
        label: Some("entry"),
        instructions: [
            MirInst(kind: MirInstKind.Const(LocalId(id: 1), MirConstValue.Int(0x123456789ABCDEF), i64_type), span: nil),
            MirInst(
                kind: MirInstKind.Intrinsic(
                    Some(LocalId(id: 2)),
                    BIT_BSWAP,
                    [MirOperand(kind: MirOperandKind.Copy(LocalId(id: 1)))]
                ),
                span: nil
            )
        ],
        terminator: MirTerminator.Return(Some(MirOperand(kind: MirOperandKind.Copy(LocalId(id: 2)))))
    )
    val func = MirFunction(
        symbol: SymbolId.new(0),
        name: name,
        signature: sig,
        locals: locals,
        blocks: [entry],
        entry_block: BlockId.new(0),
        span: Span(start: 0, end: 0, line: 1, col: 1),
        generic_params: [],
        is_generic_template: false,
        specialization_of: nil,
        type_bindings: {}
    )
    var functions: Dict<SymbolId, MirFunction> = {}
    functions[SymbolId.new(0)] = func
    MirModule(name: name, functions: functions, statics: {}, constants: {}, types: {})

fn entry_block(module: MachModule) -> MachBlock:
    module.functions[0].blocks[1]

fn opcode_at(block: MachBlock, index: i64) -> i64:
    block.insts[index].opcode

fn find_opcode(block: MachBlock, opcode: i64) -> i64:
    for i in 0..block.insts.len():
        if block.insts[i].opcode == opcode:
            return i
    -1

fn rotate_window(block: MachBlock) -> [i64]:
    [
        opcode_at(block, 4),
        opcode_at(block, 5),
        opcode_at(block, 6),
        opcode_at(block, 7),
        opcode_at(block, 8),
        opcode_at(block, 9),
        opcode_at(block, 10),
        opcode_at(block, 11),
        opcode_at(block, 12),
        opcode_at(block, 13),
        opcode_at(block, 14),
        opcode_at(block, 15),
        opcode_at(block, 16)
    ]

describe "Isel X86_64 rotate intrinsic lowering":
    it "lowers bit_rotate_left into shift-or machine ops":
        val mach = isel_module(build_rotate_module("rol_test", "bit_rotate_left"))
        val block = entry_block(mach)

        expect(rotate_window(block)).to_equal([
            X86_OP_MOV_REG_REG,
            X86_OP_MOV_REG_REG,
            X86_OP_MOV_REG_IMM,
            X86_OP_AND,
            X86_OP_MOV_REG_REG,
            X86_OP_MOV_REG_REG,
            X86_OP_SHL,
            X86_OP_MOV_REG_IMM,
            X86_OP_SUB,
            X86_OP_AND,
            X86_OP_MOV_REG_REG,
            X86_OP_SHR,
            X86_OP_OR
        ])

    it "lowers bit_rotate_right into mirrored shift-or machine ops":
        val mach = isel_module(build_rotate_module("ror_test", "bit_rotate_right"))
        val block = entry_block(mach)

        expect(rotate_window(block)).to_equal([
            X86_OP_MOV_REG_REG,
            X86_OP_MOV_REG_REG,
            X86_OP_MOV_REG_IMM,
            X86_OP_AND,
            X86_OP_MOV_REG_REG,
            X86_OP_MOV_REG_REG,
            X86_OP_SHR,
            X86_OP_MOV_REG_IMM,
            X86_OP_SUB,
            X86_OP_AND,
            X86_OP_MOV_REG_REG,
            X86_OP_SHL,
            X86_OP_OR
        ])

describe "Isel X86_64 bit_bswap intrinsic lowering":
    it "lowers bit_bswap into move plus bswap":
        val mach = isel_module(build_bswap_module("bswap_test"))
        val block = entry_block(mach)
        val bswap_idx = find_opcode(block, X86_OP_BSWAP)
        expect bswap_idx >= 0 == true
        expect opcode_at(block, bswap_idx - 1) == X86_OP_MOV_REG_REG