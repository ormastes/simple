import std.spec

use compiler.backend.backend.backend_types.{CodegenTarget}
use compiler.backend.backend.riscv_target.{riscv_linux_target_contract}

describe "Isel Riscv32":
    it "uses the shared ILP32D contract word size":
        val contract = riscv_linux_target_contract(CodegenTarget.Riscv32)
        expect contract.pointer_bits / 8 == 4
        expect contract.pointer_bits == 32
        expect contract.stack_align_bytes == 16

    it "keeps RV32 Linux ABI metadata explicit":
        val contract = riscv_linux_target_contract(CodegenTarget.Riscv32)
        expect contract.abi_text() == "ilp32d"
        expect contract.arg_register_count == 8