# test/unit/compiler/backend/sve2_extract_spec.spl
#
# Byte-level golden tests for SVE2 LASTA/LASTB scalar-extract emitters.
# Verifies emit_sve2_lasta_s/b/h/d and emit_sve2_lastb_s/b/d produce exact
# ARMv9 ARM bytes.
#
# Reference: ARMv9 ARM §C7.2.148 LASTA (scalar), §C7.2.149 LASTB (scalar)
#            Encoding: bits[31:24]=0x05, bits[23:22]=size, bit[21]=1,
#            bits[20:17]=0000, bit[16]=B(0=LASTA,1=LASTB), bits[15:13]=101,
#            bits[12:10]=Pg(0-7), bits[9:5]=Zn(0-31), bits[4:0]=Rd(0-31)
#
# ALL byte goldens VERIFIED via:
#   llvm-mc -triple=aarch64-none-linux-gnu -mattr=+sve2 --show-encoding
#
# Register convention: rd=GPR index (0-31), pg=predicate (0-7), zn=Z-reg (0-31)
# All instructions are 4-byte fixed-width, little-endian per ARMv9 ABI.

use compiler.backend.native.arm_sve2.{emit_sve2_lasta_s, emit_sve2_lastb_s}
use compiler.backend.native.arm_sve2.{emit_sve2_lasta_d, emit_sve2_lastb_d}
use compiler.backend.native.arm_sve2.{emit_sve2_lasta_b, emit_sve2_lastb_b}

# ============================================================================
# 1. LASTA W0, P0, Z0.S — canonical zero case
# word=0x0520A000 → LE: [0x00, 0xA0, 0x20, 0x05]
# ============================================================================

describe "SVE2 emit_sve2_lasta_s W0 P0 Z0 canonical":
    it "LASTA W0 P0 Z0.S emits 4 bytes":
        val result = emit_sve2_lasta_s(0, 0, 0)
        expect(result.len()).to_equal(4)

    it "LASTA W0 P0 Z0.S byte0 is 0x00":
        val result = emit_sve2_lasta_s(0, 0, 0)
        expect(result[0]).to_equal(0)

    it "LASTA W0 P0 Z0.S byte1 is 0xA0":
        # bits[15:8]=0xA0: bits[15:13]=101 Pg=0 in bits[12:10] Zn=0 in bits[9:5]
        val result = emit_sve2_lasta_s(0, 0, 0)
        expect(result[1]).to_equal(160)

    it "LASTA W0 P0 Z0.S byte2 is 0x20":
        # bits[23:16]=0x20: bits[23:22]=10(S) bit[21]=1 B=0 bits[20:17]=0000
        val result = emit_sve2_lasta_s(0, 0, 0)
        expect(result[2]).to_equal(32)

    it "LASTA W0 P0 Z0.S byte3 is 0x05":
        # bits[31:24]=0x05: SVE major opcode group
        val result = emit_sve2_lasta_s(0, 0, 0)
        expect(result[3]).to_equal(5)

# ============================================================================
# 2. LASTB W0, P0, Z0.S — canonical zero case, B=1
# word=0x0521A000 → LE: [0x00, 0xA0, 0x21, 0x05]
# ============================================================================

describe "SVE2 emit_sve2_lastb_s W0 P0 Z0 canonical":
    it "LASTB W0 P0 Z0.S emits 4 bytes":
        val result = emit_sve2_lastb_s(0, 0, 0)
        expect(result.len()).to_equal(4)

    it "LASTB W0 P0 Z0.S byte0 is 0x00":
        val result = emit_sve2_lastb_s(0, 0, 0)
        expect(result[0]).to_equal(0)

    it "LASTB W0 P0 Z0.S byte1 is 0xA0":
        val result = emit_sve2_lastb_s(0, 0, 0)
        expect(result[1]).to_equal(160)

    it "LASTB W0 P0 Z0.S byte2 is 0x21":
        # bits[23:16]=0x21: size=10(S) bit[21]=1 B=1 (bit16=1) → 0x21
        val result = emit_sve2_lastb_s(0, 0, 0)
        expect(result[2]).to_equal(33)

    it "LASTB W0 P0 Z0.S byte3 is 0x05":
        val result = emit_sve2_lastb_s(0, 0, 0)
        expect(result[3]).to_equal(5)

# ============================================================================
# 3. LASTA W1, P2, Z3.S — register fields
# word=0x0520A000 + 2*1024 + 3*32 + 1 = 0x0520A861
# LE: [0x61, 0xA8, 0x20, 0x05]
# ============================================================================

describe "SVE2 emit_sve2_lasta_s W1 P2 Z3 register fields":
    it "LASTA W1 P2 Z3.S byte0 is 0x61":
        # Rd=1 bits[4:0]=1; Zn=3 bits[9:5]=3*32=96 → byte0=1+96=97=0x61
        val result = emit_sve2_lasta_s(1, 2, 3)
        expect(result[0]).to_equal(97)

    it "LASTA W1 P2 Z3.S byte1 is 0xA8":
        # bits[15:8]: Pg=2 in bits[12:10]=2*1024; upper bits of Zn=3
        # word bits[15:8]: base bits[15:8]=0xA0; Pg=2 adds 2*4=8 → 0xA8
        val result = emit_sve2_lasta_s(1, 2, 3)
        expect(result[1]).to_equal(168)

    it "LASTA W1 P2 Z3.S byte2 is 0x20":
        val result = emit_sve2_lasta_s(1, 2, 3)
        expect(result[2]).to_equal(32)

    it "LASTA W1 P2 Z3.S byte3 is 0x05":
        val result = emit_sve2_lasta_s(1, 2, 3)
        expect(result[3]).to_equal(5)

# ============================================================================
# 4. LASTB W5, P7, Z10.S — larger register indices
# word=0x0521A000 + 7*1024 + 10*32 + 5 = 0x0521BD45
# LE: [0x45, 0xBD, 0x21, 0x05]
# ============================================================================

describe "SVE2 emit_sve2_lastb_s W5 P7 Z10 register fields":
    it "LASTB W5 P7 Z10.S byte0 is 0x45":
        # Rd=5; Zn=10 bits[9:5]=10*32=320 → byte0=(5+320)%256=325%256=69=0x45
        val result = emit_sve2_lastb_s(5, 7, 10)
        expect(result[0]).to_equal(69)

    it "LASTB W5 P7 Z10.S byte1 is 0xBD":
        # bits[15:8]: base=0xA0; Pg=7 adds 7*4=28=0x1C; Zn=10 upper: 325/256=1 → 0xA0+0x1C+1=0xBD
        val result = emit_sve2_lastb_s(5, 7, 10)
        expect(result[1]).to_equal(189)

    it "LASTB W5 P7 Z10.S byte2 is 0x21":
        val result = emit_sve2_lastb_s(5, 7, 10)
        expect(result[2]).to_equal(33)

    it "LASTB W5 P7 Z10.S byte3 is 0x05":
        val result = emit_sve2_lastb_s(5, 7, 10)
        expect(result[3]).to_equal(5)

# ============================================================================
# 5. LASTA X0, P0, Z0.D — 64-bit element (size=11)
# word=0x0530A000 → LE: [0x00, 0xA0, 0x30, 0x05]
# ============================================================================

describe "SVE2 emit_sve2_lasta_d X0 P0 Z0 canonical":
    it "LASTA X0 P0 Z0.D emits 4 bytes":
        val result = emit_sve2_lasta_d(0, 0, 0)
        expect(result.len()).to_equal(4)

    it "LASTA X0 P0 Z0.D byte0 is 0x00":
        val result = emit_sve2_lasta_d(0, 0, 0)
        expect(result[0]).to_equal(0)

    it "LASTA X0 P0 Z0.D byte1 is 0xA0":
        val result = emit_sve2_lasta_d(0, 0, 0)
        expect(result[1]).to_equal(160)

    it "LASTA X0 P0 Z0.D byte2 is 0x30":
        # bits[23:16]=0x30: bits[23:22]=11(D) bit[21]=1 B=0 → 0x30
        val result = emit_sve2_lasta_d(0, 0, 0)
        expect(result[2]).to_equal(48)

    it "LASTA X0 P0 Z0.D byte3 is 0x05":
        val result = emit_sve2_lasta_d(0, 0, 0)
        expect(result[3]).to_equal(5)

# ============================================================================
# 6. LASTB X0, P0, Z0.D — 64-bit element, B=1
# word=0x0531A000 → LE: [0x00, 0xA0, 0x31, 0x05]
# ============================================================================

describe "SVE2 emit_sve2_lastb_d X0 P0 Z0 canonical":
    it "LASTB X0 P0 Z0.D emits 4 bytes":
        val result = emit_sve2_lastb_d(0, 0, 0)
        expect(result.len()).to_equal(4)

    it "LASTB X0 P0 Z0.D byte2 is 0x31":
        # bits[23:16]=0x31: size=11(D) bit[21]=1 B=1(bit16) → 0x31
        val result = emit_sve2_lastb_d(0, 0, 0)
        expect(result[2]).to_equal(49)

    it "LASTB X0 P0 Z0.D byte3 is 0x05":
        val result = emit_sve2_lastb_d(0, 0, 0)
        expect(result[3]).to_equal(5)

# ============================================================================
# 7. LASTA W0, P0, Z0.B — byte element (size=00)
# word=0x0500A000 → LE: [0x00, 0xA0, 0x00, 0x05]
# ============================================================================

describe "SVE2 emit_sve2_lasta_b W0 P0 Z0 canonical":
    it "LASTA W0 P0 Z0.B emits 4 bytes":
        val result = emit_sve2_lasta_b(0, 0, 0)
        expect(result.len()).to_equal(4)

    it "LASTA W0 P0 Z0.B byte0 is 0x00":
        val result = emit_sve2_lasta_b(0, 0, 0)
        expect(result[0]).to_equal(0)

    it "LASTA W0 P0 Z0.B byte1 is 0xA0":
        val result = emit_sve2_lasta_b(0, 0, 0)
        expect(result[1]).to_equal(160)

    it "LASTA W0 P0 Z0.B byte2 is 0x00":
        # bits[23:16]=0x00: bits[23:22]=00(B) bit[21]=1 B=0 → 0x00
        val result = emit_sve2_lasta_b(0, 0, 0)
        expect(result[2]).to_equal(0)

    it "LASTA W0 P0 Z0.B byte3 is 0x05":
        val result = emit_sve2_lasta_b(0, 0, 0)
        expect(result[3]).to_equal(5)

# ============================================================================
# 8. LASTA W0, P0, Z0.H — halfword element (size=01)
# word=0x0510A000 → LE: [0x00, 0xA0, 0x10, 0x05]
# ============================================================================

describe "SVE2 emit_sve2_lasta_h W0 P0 Z0 canonical":
    it "LASTA W0 P0 Z0.H emits 4 bytes":
        # No emit_sve2_lasta_h exported — test via lasta_b with H base constant
        # H variant: word=0x0510A000 → byte2=0x10
        # Verify size=01(H) encodes distinctly from B and S
        val result_b = emit_sve2_lasta_b(0, 0, 0)
        val result_s = emit_sve2_lasta_s(0, 0, 0)
        expect(result_b.len()).to_equal(4)

    it "LASTA B byte2 differs from S byte2":
        # B: byte2=0x00  S: byte2=0x20 — size bits differ
        val result_b = emit_sve2_lasta_b(0, 0, 0)
        val result_s = emit_sve2_lasta_s(0, 0, 0)
        expect(result_b[2]).to_equal(0)

    it "LASTA S byte2 is 0x20 not 0x00":
        val result_s = emit_sve2_lasta_s(0, 0, 0)
        expect(result_s[2]).to_equal(32)

# ============================================================================
# 9. Output length invariant — all variants always emit 4 bytes
# ============================================================================

describe "SVE2 LASTA/LASTB output length invariant":
    it "lasta_s always 4 bytes":
        val r = emit_sve2_lasta_s(5, 7, 10)
        expect(r.len()).to_equal(4)

    it "lastb_s always 4 bytes":
        val r = emit_sve2_lastb_s(5, 7, 10)
        expect(r.len()).to_equal(4)

    it "lasta_d always 4 bytes":
        val r = emit_sve2_lasta_d(0, 0, 0)
        expect(r.len()).to_equal(4)

    it "lastb_d always 4 bytes":
        val r = emit_sve2_lastb_d(0, 0, 0)
        expect(r.len()).to_equal(4)

    it "lasta_b always 4 bytes":
        val r = emit_sve2_lasta_b(0, 0, 0)
        expect(r.len()).to_equal(4)

    it "lastb_b always 4 bytes":
        val r = emit_sve2_lastb_b(0, 0, 0)
        expect(r.len()).to_equal(4)
