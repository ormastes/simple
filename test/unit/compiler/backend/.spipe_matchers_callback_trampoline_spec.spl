"""
# Callback Trampoline Specification

**Feature IDs:** #SFFI-BIDIR #SFFI-CALLBACK #WS5
**Category:** Compiler / Backend / Callback Trampoline
**Difficulty:** 3/5
**Status:** Implemented

## Overview

Tests the callback trampoline generation module that converts C function
pointer types to Simple-callable patterns. Covers type classification,
naming, parsing, and C code emission.

v1 scope: stateless function pointers only (no closures with captures).
"""

use std.spec
use compiler.backend.callback_trampoline.*

# @cover src/compiler/70.backend/backend/callback_trampoline.spl 80%

describe "callback trampoline":
    describe "is_callback_type":
        it "accepts plain function pointer types":
            expect is_callback_type("Fn<(i64) -> i64>") == true

        it "accepts multi-param function pointers":
            expect is_callback_type("Fn<(i64, f64) -> bool>") == true

        it "accepts no-arg function pointers":
            expect is_callback_type("Fn<() -> void>") == true

        it "rejects closures with captures":
            expect is_callback_type("Fn<(i64) -> i64>[x, y]") == false

        it "rejects non-function types":
            expect is_callback_type("i64") == false
            expect is_callback_type("text") == false
            expect is_callback_type("List<i64>") == false

    describe "is_closure_with_captures":
        it "detects closures with capture lists":
            expect is_closure_with_captures("Fn<(i64) -> i64>[x, y]") == true

        it "rejects plain function pointers":
            expect is_closure_with_captures("Fn<(i64) -> i64>") == false

        it "rejects non-function types":
            expect is_closure_with_captures("i64") == false

    describe "callback_typedef_name":
        it "generates name for single-param callback":
            val name = callback_typedef_name(["i64"], "i64")
            expect name == "spl_callback_i64_to_i64"

        it "generates name for multi-param callback":
            val name = callback_typedef_name(["i64", "f64"], "bool")
            expect name == "spl_callback_i64_f64_to_bool"

        it "generates name for void-param callback":
            val name = callback_typedef_name([], "void")
            expect name == "spl_callback_void_to_void"

    describe "extract_callback_params":
        it "extracts single parameter":
            val params = extract_callback_params("Fn<(i64) -> i64>")
            expect params.len() == 1
            expect params[0] == "i64"

        it "extracts multiple parameters":
            val params = extract_callback_params("Fn<(i64, f64) -> bool>")
            expect params.len() == 2
            expect params[0] == "i64"
            expect params[1] == "f64"

        it "returns empty list for no-arg function":
            val params = extract_callback_params("Fn<() -> void>")
            expect params.len() == 0

    describe "extract_callback_return":
        it "extracts return type":
            val ret = extract_callback_return("Fn<(i64) -> bool>")
            expect ret == "bool"

        it "extracts void return":
            val ret = extract_callback_return("Fn<() -> void>")
            expect ret == "void"

        it "extracts i64 return":
            val ret = extract_callback_return("Fn<(i64, f64) -> i64>")
            expect ret == "i64"

    describe "emit_callback_typedef":
        it "generates correct C typedef for single-param callback":
            val cb = CallbackTypedef(
                name: "spl_callback_i64_to_i64",
                return_type: "int64_t",
                param_types: ["int64_t"]
            )
            val result = emit_callback_typedef(cb)
            expect result == "typedef int64_t (*spl_callback_i64_to_i64)(int64_t);"

        it "generates correct C typedef for multi-param callback":
            val cb = CallbackTypedef(
                name: "spl_callback_i64_f64_to_bool",
                return_type: "int64_t",
                param_types: ["int64_t", "double"]
            )
            val result = emit_callback_typedef(cb)
            expect result == "typedef int64_t (*spl_callback_i64_f64_to_bool)(int64_t, double);"

        it "generates void param list for no-arg callback":
            val cb = CallbackTypedef(
                name: "spl_callback_void_to_void",
                return_type: "void",
                param_types: []
            )
            val result = emit_callback_typedef(cb)
            expect result == "typedef void (*spl_callback_void_to_void)(void);"

    describe "emit_callback_trampoline":
        it "generates null-check and invocation":
            val cb = CallbackTypedef(
                name: "spl_callback_i64_to_i64",
                return_type: "int64_t",
                param_types: ["int64_t"]
            )
            val result = emit_callback_trampoline("_spl_trampoline_test", cb)
            expect (result).contains("if (!_cb)")
            expect (result).contains("return _cb(_a0)")

        it "generates void return for void callback":
            val cb = CallbackTypedef(
                name: "spl_callback_void_to_void",
                return_type: "void",
                param_types: []
            )
            val result = emit_callback_trampoline("_spl_trampoline_void", cb)
            expect (result).contains("if (!_cb)")
            expect (result).contains("_cb()")

    describe "build_callback_typedef":
        it "builds typedef from Fn type string":
            val cb = build_callback_typedef("Fn<(i64) -> i64>")
            expect (cb.name).contains("spl_callback")
            expect cb.return_type == "int64_t"
            expect cb.param_types.len() == 1
            expect cb.param_types[0] == "int64_t"

        it "builds typedef from multi-param Fn type":
            val cb = build_callback_typedef("Fn<(i64, f64) -> bool>")
            expect cb.return_type == "int64_t"
            expect cb.param_types.len() == 2
            expect cb.param_types[0] == "int64_t"
            expect cb.param_types[1] == "double"