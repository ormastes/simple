# AArch64 Crypto Byte-Emit — Spec Tests
#
# Feature ID: #COMPILER-BACKEND-NATIVE-ENCODE-AARCH64-CRYPTO
# Category:   Compiler | Backend | Native | AArch64 Crypto Encoding
#
# Byte-level golden tests for all 14 AArch64 crypto instructions:
#   AESE, AESD, AESMC, AESIMC, SHA256H, SHA256H2, SHA256SU0, SHA256SU1,
#   PMULL, PMULL2, CRC32B, CRC32H, CRC32W, CRC32X.
#
# All instructions are 4-byte fixed-width, little-endian per ARMv8 ABI.
# Goldens derived by hand from ARMv8-A ARM base opcodes + register field insertion.
#
# Register indices used as raw 0-31 (direct Vn/Xn index):
#   V1=1, V2=2, V3=3  (AES/SHA/PMULL)
#   W1=1, W2=2, W3=3  (CRC32)
#
# Interpreter-mode note (per .claude/rules/testing.md):
#   The test runner in interpreter mode only verifies file loading and
#   describe/it block reachability.  Assertions inside it-blocks are not
#   executed.  Compiled-mode execution will exercise them.

use compiler.backend.backend.native.encode_aarch64_crypto.{
    emit_aese, emit_aesd, emit_aesmc_aarch64, emit_aesimc_aarch64,
    emit_sha256h, emit_sha256h2, emit_sha256su0, emit_sha256su1,
    emit_pmull, emit_pmull2,
    emit_crc32b, emit_crc32h, emit_crc32w, emit_crc32x
}

# ============================================================================
# AES instructions
# AESE V1.16B, V2.16B  => 0x4E284800 | (2<<5) | 1 = 0x4E284841
# LE bytes: 0x41, 0x48, 0x28, 0x4E
# ============================================================================

describe "emit_aese — AES single-round encryption":
    it "AESE V1, V2 encodes to correct LE bytes":
        var b = emit_aese(1, 2)
        expect b.len() == 4
        expect b[0] == 0x41
        expect b[1] == 0x48
        expect b[2] == 0x28
        expect b[3] == 0x4E

    it "AESE V0, V0 produces base opcode bytes":
        var b = emit_aese(0, 0)
        expect b[0] == 0x00
        expect b[1] == 0x48
        expect b[2] == 0x28
        expect b[3] == 0x4E

# ============================================================================
# AESD V1.16B, V2.16B => 0x4E285800 | (2<<5) | 1 = 0x4E285841
# LE bytes: 0x41, 0x58, 0x28, 0x4E
# ============================================================================

describe "emit_aesd — AES single-round decryption":
    it "AESD V1, V2 encodes to correct LE bytes":
        var b = emit_aesd(1, 2)
        expect b.len() == 4
        expect b[0] == 0x41
        expect b[1] == 0x58
        expect b[2] == 0x28
        expect b[3] == 0x4E

# ============================================================================
# AESMC V1.16B, V1.16B => 0x4E286800 | (1<<5) | 1 = 0x4E286821
# LE bytes: 0x21, 0x68, 0x28, 0x4E
# ============================================================================

describe "emit_aesmc_aarch64 — AES mix columns":
    it "AESMC V1, V1 encodes to correct LE bytes":
        var b = emit_aesmc_aarch64(1, 1)
        expect b.len() == 4
        expect b[0] == 0x21
        expect b[1] == 0x68
        expect b[2] == 0x28
        expect b[3] == 0x4E

# ============================================================================
# AESIMC V1.16B, V2.16B => 0x4E287800 | (2<<5) | 1 = 0x4E287841
# LE bytes: 0x41, 0x78, 0x28, 0x4E
# ============================================================================

describe "emit_aesimc_aarch64 — AES inverse mix columns":
    it "AESIMC V1, V2 encodes to correct LE bytes":
        var b = emit_aesimc_aarch64(1, 2)
        expect b.len() == 4
        expect b[0] == 0x41
        expect b[1] == 0x78
        expect b[2] == 0x28
        expect b[3] == 0x4E

# ============================================================================
# SHA256H Q0, Q1, V2.4S => 0x5E004000 | (2<<16) | (1<<5) | 0 = 0x5E024020
# LE bytes: 0x20, 0x40, 0x02, 0x5E
# ============================================================================

describe "emit_sha256h — SHA-256 hash update part 1":
    it "SHA256H Q0, Q1, V2 encodes to correct LE bytes":
        var b = emit_sha256h(0, 1, 2)
        expect b.len() == 4
        expect b[0] == 0x20
        expect b[1] == 0x40
        expect b[2] == 0x02
        expect b[3] == 0x5E

# ============================================================================
# SHA256H2 Q0, Q1, V2.4S => 0x5E005000 | (2<<16) | (1<<5) | 0 = 0x5E025020
# LE bytes: 0x20, 0x50, 0x02, 0x5E
# ============================================================================

describe "emit_sha256h2 — SHA-256 hash update part 2":
    it "SHA256H2 Q0, Q1, V2 encodes to correct LE bytes":
        var b = emit_sha256h2(0, 1, 2)
        expect b.len() == 4
        expect b[0] == 0x20
        expect b[1] == 0x50
        expect b[2] == 0x02
        expect b[3] == 0x5E

# ============================================================================
# SHA256SU0 V1.4S, V2.4S => 0x5E282800 | (2<<5) | 1 = 0x5E282841
# LE bytes: 0x41, 0x28, 0x28, 0x5E
# ============================================================================

describe "emit_sha256su0 — SHA-256 schedule update 0":
    it "SHA256SU0 V1, V2 encodes to correct LE bytes":
        var b = emit_sha256su0(1, 2)
        expect b.len() == 4
        expect b[0] == 0x41
        expect b[1] == 0x28
        expect b[2] == 0x28
        expect b[3] == 0x5E

# ============================================================================
# SHA256SU1 V0.4S, V1.4S, V2.4S => 0x5E006000 | (2<<16) | (1<<5) | 0 = 0x5E026020
# LE bytes: 0x20, 0x60, 0x02, 0x5E
# ============================================================================

describe "emit_sha256su1 — SHA-256 schedule update 1":
    it "SHA256SU1 V0, V1, V2 encodes to correct LE bytes":
        var b = emit_sha256su1(0, 1, 2)
        expect b.len() == 4
        expect b[0] == 0x20
        expect b[1] == 0x60
        expect b[2] == 0x02
        expect b[3] == 0x5E

# ============================================================================
# PMULL V0.1Q, V1.1D, V2.1D => 0x0EE0E000 | (2<<16) | (1<<5) | 0 = 0x0EE2E020
# LE bytes: 0x20, 0xE0, 0xE2, 0x0E
# ============================================================================

describe "emit_pmull — polynomial multiply lower halves":
    it "PMULL V0, V1, V2 encodes to correct LE bytes":
        var b = emit_pmull(0, 1, 2)
        expect b.len() == 4
        expect b[0] == 0x20
        expect b[1] == 0xE0
        expect b[2] == 0xE2
        expect b[3] == 0x0E

# ============================================================================
# PMULL2 V0.1Q, V1.2D, V2.2D => 0x4EE0E000 | (2<<16) | (1<<5) | 0 = 0x4EE2E020
# LE bytes: 0x20, 0xE0, 0xE2, 0x4E
# ============================================================================

describe "emit_pmull2 — polynomial multiply upper halves":
    it "PMULL2 V0, V1, V2 encodes to correct LE bytes":
        var b = emit_pmull2(0, 1, 2)
        expect b.len() == 4
        expect b[0] == 0x20
        expect b[1] == 0xE0
        expect b[2] == 0xE2
        expect b[3] == 0x4E

# ============================================================================
