# LE bytes: 0x20, 0x48, 0xC2, 0x1A
# ============================================================================

describe "emit_crc32w — CRC32 word accumulate":
    it "CRC32W W0, W1, W2 encodes to correct LE bytes":
        var b = emit_crc32w(0, 1, 2)
        expect b.len() == 4
        expect b[0] == 0x20
        expect b[1] == 0x48
        expect b[2] == 0xC2
        expect b[3] == 0x1A

# ============================================================================
# CRC32X W0, W1, X2 => 0x9AC04C00 | (2<<16) | (1<<5) | 0 = 0x9AC24C20
# LE bytes: 0x20, 0x4C, 0xC2, 0x9A
# ============================================================================

describe "emit_crc32x — CRC32 doubleword accumulate":
    it "CRC32X W0, W1, X2 encodes to correct LE bytes":
        var b = emit_crc32x(0, 1, 2)
        expect b.len() == 4
        expect b[0] == 0x20
        expect b[1] == 0x4C
        expect b[2] == 0xC2
        expect b[3] == 0x9A