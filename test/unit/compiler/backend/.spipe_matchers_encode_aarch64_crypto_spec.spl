# LE bytes: 0x20, 0x40, 0xC2, 0x1A
# ============================================================================

describe "emit_crc32b — CRC32 byte accumulate":
    it "CRC32B W0, W1, W2 encodes to correct LE bytes":
        var b = emit_crc32b(0, 1, 2)
        expect b.len() == 4
        expect b[0] == 0x20
        expect b[1] == 0x40
        expect b[2] == 0xC2
        expect b[3] == 0x1A

# ============================================================================
# CRC32H W0, W1, W2 => 0x1AC04400 | (2<<16) | (1<<5) | 0 = 0x1AC24420
# LE bytes: 0x20, 0x44, 0xC2, 0x1A
# ============================================================================

describe "emit_crc32h — CRC32 halfword accumulate":
    it "CRC32H W0, W1, W2 encodes to correct LE bytes":
        var b = emit_crc32h(0, 1, 2)
        expect b.len() == 4
        expect b[0] == 0x20
        expect b[1] == 0x44
