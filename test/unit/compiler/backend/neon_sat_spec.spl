# test/unit/compiler/backend/neon_sat_spec.spl
#
# Feature ID: #COMPILER-BACKEND-NATIVE-NEON-SAT
# Category:   Compiler | Backend | Native | AArch64 SQADD/UQADD/SQSUB/UQSUB Encoding
#
# Byte-level golden tests for saturating add/sub emit variants:
#   SQADD Vd.4S, Vn.4S, Vm.4S  (Q=1, U=0, ARMv8 §C7.2.274)
#   UQADD Vd.4S, Vn.4S, Vm.4S  (Q=1, U=1, ARMv8 §C7.2.363)
#   SQSUB Vd.4S, Vn.4S, Vm.4S  (Q=1, U=0, ARMv8 §C7.2.277)
#   UQSUB Vd.4S, Vn.4S, Vm.4S  (Q=1, U=1, ARMv8 §C7.2.366)
#
# All instructions are 4-byte fixed-width, little-endian per ARMv8 ABI.
# Encoding: base + Rm*65536 + Rn*32 + Rd
#
# Interpreter-mode note (per .claude/rules/testing.md):
#   The test runner in interpreter mode only verifies file loading and
#   describe/it block reachability.  Assertions inside it-blocks are not
#   executed.  Compiled-mode execution will exercise them.

use compiler.backend.native.arm_neon.{emit_neon_sqadd_4s, emit_neon_uqadd_4s, emit_neon_sqsub_4s, emit_neon_uqsub_4s}

# ============================================================================
# SQADD V0.4S, V0.4S, V0.4S => base 0x4EA00C00
# LE bytes: 0x00, 0x0C, 0xA0, 0x4E
# ============================================================================

describe "emit_neon_sqadd_4s — signed saturating add 4 lanes":
    it "SQADD V0.4S, V0.4S, V0.4S encodes to base opcode bytes":
        var b = emit_neon_sqadd_4s(0, 0, 0)
        expect(b.len()).to_equal(4)
        expect(b[0]).to_equal(0x00)
        expect(b[1]).to_equal(0x0C)
        expect(b[2]).to_equal(0xA0)
        expect(b[3]).to_equal(0x4E)

    it "SQADD V1.4S, V2.4S, V3.4S encodes register fields correctly":
        # word = 0x4EA00C00 + 3*65536 + 2*32 + 1 = 0x4EA30C41
        # LE bytes: 0x41, 0x0C, 0xA3, 0x4E
        var b = emit_neon_sqadd_4s(1, 2, 3)
        expect(b.len()).to_equal(4)
        expect(b[0]).to_equal(0x41)
        expect(b[1]).to_equal(0x0C)
        expect(b[2]).to_equal(0xA3)
        expect(b[3]).to_equal(0x4E)

# ============================================================================
# UQADD V0.4S, V0.4S, V0.4S => base 0x6EA00C00
# LE bytes: 0x00, 0x0C, 0xA0, 0x6E
# ============================================================================

describe "emit_neon_uqadd_4s — unsigned saturating add 4 lanes":
    it "UQADD V0.4S, V0.4S, V0.4S encodes to base opcode bytes":
        var b = emit_neon_uqadd_4s(0, 0, 0)
        expect(b.len()).to_equal(4)
        expect(b[0]).to_equal(0x00)
        expect(b[1]).to_equal(0x0C)
        expect(b[2]).to_equal(0xA0)
        expect(b[3]).to_equal(0x6E)

    it "UQADD V5.4S, V6.4S, V7.4S encodes register fields correctly":
        # word = 0x6EA00C00 + 7*65536 + 6*32 + 5 = 0x6EA70CC5
        # LE bytes: 0xC5, 0x0C, 0xA7, 0x6E
        var b = emit_neon_uqadd_4s(5, 6, 7)
        expect(b.len()).to_equal(4)
        expect(b[0]).to_equal(0xC5)
        expect(b[1]).to_equal(0x0C)
        expect(b[2]).to_equal(0xA7)
        expect(b[3]).to_equal(0x6E)

# ============================================================================
# SQSUB V0.4S, V0.4S, V0.4S => base 0x4EA02C00
# LE bytes: 0x00, 0x2C, 0xA0, 0x4E
# ============================================================================

describe "emit_neon_sqsub_4s — signed saturating subtract 4 lanes":
    it "SQSUB V0.4S, V0.4S, V0.4S encodes to base opcode bytes":
        var b = emit_neon_sqsub_4s(0, 0, 0)
        expect(b.len()).to_equal(4)
        expect(b[0]).to_equal(0x00)
        expect(b[1]).to_equal(0x2C)
        expect(b[2]).to_equal(0xA0)
        expect(b[3]).to_equal(0x4E)

    it "SQSUB V1.4S, V2.4S, V3.4S encodes register fields correctly":
        # word = 0x4EA02C00 + 3*65536 + 2*32 + 1 = 0x4EA32C41
        # LE bytes: 0x41, 0x2C, 0xA3, 0x4E
        var b = emit_neon_sqsub_4s(1, 2, 3)
        expect(b.len()).to_equal(4)
        expect(b[0]).to_equal(0x41)
        expect(b[1]).to_equal(0x2C)
        expect(b[2]).to_equal(0xA3)
        expect(b[3]).to_equal(0x4E)

# ============================================================================
# UQSUB V0.4S, V0.4S, V0.4S => base 0x6EA02C00
# LE bytes: 0x00, 0x2C, 0xA0, 0x6E
# ============================================================================

describe "emit_neon_uqsub_4s — unsigned saturating subtract 4 lanes":
    it "UQSUB V0.4S, V0.4S, V0.4S encodes to base opcode bytes":
        var b = emit_neon_uqsub_4s(0, 0, 0)
        expect(b.len()).to_equal(4)
        expect(b[0]).to_equal(0x00)
        expect(b[1]).to_equal(0x2C)
        expect(b[2]).to_equal(0xA0)
        expect(b[3]).to_equal(0x6E)

    it "UQSUB V5.4S, V6.4S, V7.4S encodes register fields correctly":
        # word = 0x6EA02C00 + 7*65536 + 6*32 + 5 = 0x6EA72CC5
        # LE bytes: 0xC5, 0x2C, 0xA7, 0x6E
        var b = emit_neon_uqsub_4s(5, 6, 7)
        expect(b.len()).to_equal(4)
        expect(b[0]).to_equal(0xC5)
        expect(b[1]).to_equal(0x2C)
        expect(b[2]).to_equal(0xA7)
        expect(b[3]).to_equal(0x6E)

# ============================================================================
# Property: all variants always return exactly 4 bytes
# ============================================================================

describe "SQADD/UQADD/SQSUB/UQSUB emit output length":
    it "emit_neon_sqadd_4s always returns 4 bytes":
        var b = emit_neon_sqadd_4s(1, 2, 3)
        expect(b.len()).to_equal(4)

    it "emit_neon_uqsub_4s always returns 4 bytes":
        var b = emit_neon_uqsub_4s(5, 6, 7)
        expect(b.len()).to_equal(4)

# ============================================================================
# Property: signed vs unsigned differ only in byte[3] (U bit = bit29)
# ============================================================================

describe "signed vs unsigned byte[3] distinction":
    it "SQADD and UQADD with same registers match bytes 0-2 and differ at byte[3]":
        var s = emit_neon_sqadd_4s(1, 2, 3)
        var u = emit_neon_uqadd_4s(1, 2, 3)
        expect(s[0]).to_equal(u[0])
        expect(s[1]).to_equal(u[1])
        expect(s[2]).to_equal(u[2])
        # UQADD has U=1 (bit 29), which raises byte[3] by 0x20
        expect(u[3] - s[3]).to_equal(0x20)

    it "SQSUB and UQSUB with same registers match bytes 0-2 and differ at byte[3]":
        var s = emit_neon_sqsub_4s(1, 2, 3)
        var u = emit_neon_uqsub_4s(1, 2, 3)
        expect(s[0]).to_equal(u[0])
        expect(s[1]).to_equal(u[1])
        expect(s[2]).to_equal(u[2])
        # UQSUB has U=1 (bit 29), which raises byte[3] by 0x20
        expect(u[3] - s[3]).to_equal(0x20)
