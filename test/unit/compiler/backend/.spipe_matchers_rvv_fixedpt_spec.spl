# test/unit/compiler/backend/rvv_fixedpt_spec.spl
#
# RVV v1.0 fixed-point — byte-level emit golden tests
#
# Tests emit_vssrl_vv, emit_vssra_vv, emit_vnclipu_wv, emit_vnclip_wv,
# emit_vssrl_vx, emit_vssra_vx, emit_vsaddu_vv, emit_vsadd_vv from
# src/compiler/70.backend/backend/native/encode_rvv_fixedpt.spl
# against RVV v1.0 encoding formula (manual derivation; vd=1, vs2=2, vs1/rs1=3).
#
# Encoding formula: word = (funct6*67108864) + (vm*33554432) + (vs2*1048576)
#                        + (vs1*32768) + (funct3*4096) + (vd*128) + 87
# All instructions: vm=1 (unmasked), opcode=0x57=87.
use std.spec.*
use std.spipe.*
use compiler.backend.backend.native.encode_rvv_fixedpt.{emit_vssrl_vv, emit_vssra_vv, emit_vnclipu_wv, emit_vnclip_wv, emit_vssrl_vx, emit_vssra_vx, emit_vsaddu_vv, emit_vsadd_vv}

fn _list_hex(bytes: [i64]) -> text:
    val hex_chars = "0123456789abcdef"
    var s: text = ""
    var i: u64 = 0
    while i < bytes.len().to_u64():
        val b = bytes[i.to_i64()]
        s = s + hex_chars.char_at(((b / 16) % 16).to_u64())
        s = s + hex_chars.char_at((b % 16).to_u64())
        i = i + 1
    s

describe "RVV fixed-point vssrl.vv":

    it "emit_vssrl_vv(1,2,3) golden 0xAA2180D7":
        # funct6=0x2A, OPIVV funct3=0, vm=1: word=0xAA2180D7 LE d78021aa
        val bytes = emit_vssrl_vv(1, 2, 3)
        expect _list_hex(bytes) == "d78021aa"

    it "emit_vssrl_vv output length is 4 bytes":
        val bytes = emit_vssrl_vv(1, 2, 3)
        expect bytes.len() == 4

    it "emit_vssrl_vv opcode byte is 0xD7":
        val bytes = emit_vssrl_vv(1, 2, 3)
        expect bytes[0] == 215

describe "RVV fixed-point vssra.vv":

    it "emit_vssra_vv(1,2,3) golden 0xAE2180D7":
        # funct6=0x2B, OPIVV funct3=0, vm=1: word=0xAE2180D7 LE d78021ae
        val bytes = emit_vssra_vv(1, 2, 3)
        expect _list_hex(bytes) == "d78021ae"

    it "emit_vssra_vv output length is 4 bytes":
        val bytes = emit_vssra_vv(1, 2, 3)
        expect bytes.len() == 4

describe "RVV fixed-point vnclipu.wv":

    it "emit_vnclipu_wv(1,2,3) golden 0xBA2180D7":
        # funct6=0x2E, OPIVV funct3=0, vm=1: word=0xBA2180D7 LE d78021ba
        val bytes = emit_vnclipu_wv(1, 2, 3)
        expect _list_hex(bytes) == "d78021ba"

    it "emit_vnclipu_wv output length is 4 bytes":
        val bytes = emit_vnclipu_wv(1, 2, 3)
        expect bytes.len() == 4

describe "RVV fixed-point vnclip.wv":

    it "emit_vnclip_wv(1,2,3) golden 0xBE2180D7":
        # funct6=0x2F, OPIVV funct3=0, vm=1: word=0xBE2180D7 LE d78021be
        val bytes = emit_vnclip_wv(1, 2, 3)
        expect _list_hex(bytes) == "d78021be"

    it "emit_vnclip_wv output length is 4 bytes":
        val bytes = emit_vnclip_wv(1, 2, 3)
        expect bytes.len() == 4

describe "RVV fixed-point vssrl.vx":

    it "emit_vssrl_vx(1,2,3) golden 0xAA21C0D7":
        # funct6=0x2A, OPIVX funct3=4, vm=1: word=0xAA21C0D7 LE d7c021aa
        val bytes = emit_vssrl_vx(1, 2, 3)
        expect _list_hex(bytes) == "d7c021aa"

    it "emit_vssrl_vx output length is 4 bytes":
        val bytes = emit_vssrl_vx(1, 2, 3)
        expect bytes.len() == 4

    it "emit_vssrl_vx funct3 differs from emit_vssrl_vv (byte index 1)":
        val vv = emit_vssrl_vv(1, 2, 3)
        val vx = emit_vssrl_vx(1, 2, 3)
        expect vv[1] == vx[1] == false

describe "RVV fixed-point vssra.vx":

    it "emit_vssra_vx(1,2,3) golden 0xAE21C0D7":
        # funct6=0x2B, OPIVX funct3=4, vm=1: word=0xAE21C0D7 LE d7c021ae
        val bytes = emit_vssra_vx(1, 2, 3)
        expect _list_hex(bytes) == "d7c021ae"

    it "emit_vssra_vx output length is 4 bytes":
        val bytes = emit_vssra_vx(1, 2, 3)
        expect bytes.len() == 4

describe "RVV fixed-point vsaddu.vv":

    it "emit_vsaddu_vv(1,2,3) golden 0x822180D7":
        # funct6=0x20, OPIVV funct3=0, vm=1: word=0x822180D7 LE d7802182
        val bytes = emit_vsaddu_vv(1, 2, 3)
        expect _list_hex(bytes) == "d7802182"

    it "emit_vsaddu_vv output length is 4 bytes":
        val bytes = emit_vsaddu_vv(1, 2, 3)
        expect bytes.len() == 4

describe "RVV fixed-point vsadd.vv":

    it "emit_vsadd_vv(1,2,3) golden 0x862180D7":
        # funct6=0x21, OPIVV funct3=0, vm=1: word=0x862180D7 LE d7802186
        val bytes = emit_vsadd_vv(1, 2, 3)
        expect _list_hex(bytes) == "d7802186"

    it "emit_vsadd_vv output length is 4 bytes":
        val bytes = emit_vsadd_vv(1, 2, 3)
        expect bytes.len() == 4

    it "emit_vsadd_vv funct6 differs from emit_vsaddu_vv (byte index 3)":
        val u = emit_vsaddu_vv(1, 2, 3)
        val s = emit_vsadd_vv(1, 2, 3)
        expect u[3] == s[3] == false