use compiler.feature.codegen.backends.interpreter.backend.{create_interpreter_backend}

describe "Interpreter Backend":
    it "creates a backend port with stable metadata":
        val backend = create_interpreter_backend()

        expect(backend.name).to_equal("interpreter")
        expect(backend.target_triple_fn()).to_equal("interpreter-simple-runtime")
        expect(backend.supports_jit_fn()).to_equal(true)

    it "returns an independent backend port per factory call":
        val first = create_interpreter_backend()
        val second = create_interpreter_backend()

        expect(first.name).to_equal(second.name)
        expect(first.target_triple_fn()).to_equal(second.target_triple_fn())
        expect(first.supports_jit_fn()).to_equal(second.supports_jit_fn())

    it "provides a callable run function":
        val backend = create_interpreter_backend()

        expect(backend.run_fn).to_equal(backend.run_fn)

