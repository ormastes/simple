use compiler.backend.backend.runtime_compiler.{find_c_compiler, find_runtime_source_dir}
use app.io.mod.{cwd}

extern fn rt_env_get(key: text) -> text
extern fn rt_env_set(key: text, value: text)

fn with_env(key: text, value: text, block: fn()):
    val previous = rt_env_get(key) ?? ""
    rt_env_set(key, value)
    block()
    rt_env_set(key, previous)

describe "Runtime Compiler":
    it "honors SIMPLE_CC override":
        with_env("SIMPLE_CC", "/custom/toolchain/cc", fn():
            expect(find_c_compiler()).to_equal("/custom/toolchain/cc")
        )

    it "honors SIMPLE_PROJECT_ROOT override before cwd fallback":
        val project_root = cwd()
        with_env("SIMPLE_PROJECT_ROOT", project_root, fn():
            expect(find_runtime_source_dir()).to_equal("{project_root}/src/runtime")
        )

    it "finds runtime sources from cwd when no override is set":
        with_env("SIMPLE_PROJECT_ROOT", "", fn():
            expect(find_runtime_source_dir()).to_equal("src/runtime")
        )

