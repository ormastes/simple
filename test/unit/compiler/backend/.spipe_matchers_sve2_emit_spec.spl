# test/unit/compiler/backend/sve2_emit_spec.spl
#
# Byte-level golden tests for SVE2 emit bodies (N5 pilot).
# Verifies sve2_encode_add, emit_sve2_mul_s, emit_sve2_fadd_s/h/d,
# emit_sve2_fmla_s, emit_sve2_whilelo_s produce exact ARMv9 ARM bytes.
#
# Reference: doc/01_research/simd_isa_deep_2026-05-02.md §2 (SVE2 encoding)
#            doc/04_architecture/simd_backend_strict_emit_detail_part1.md §4
#            doc/04_architecture/simd_backend_strict_emit_detail_part2.md §8.3
#            ARMv9 ARM §C7.2 (individual instruction encoding pages)
#
# Register indices are raw: Z0=0..Z31=31, P0=0..P15=15, X0=0..X30=30.
# All instructions are 4-byte fixed-width, little-endian per ARMv9 ABI.
#
# ALL byte goldens VERIFIED via:
#   llvm-mc -triple=aarch64-none-linux-gnu -mattr=+sve2 --show-encoding
#   (run 2026-05-02)
#
# Destructive-form note: MUL and FADD predicated are architecturally destructive
# (ZDN appears as both dest and first source). Encoders accept a single zdn
# parameter — the asm form writes the register name twice but it's one field.

use compiler.backend.native.arm_sve2.{emit_sve2_add_s, emit_sve2_add_b, emit_sve2_add_h, emit_sve2_add_d}
use compiler.backend.native.arm_sve2.{emit_sve2_mul_s}
use compiler.backend.native.arm_sve2.{emit_sve2_fadd_s, emit_sve2_fadd_h, emit_sve2_fadd_d}
use compiler.backend.native.arm_sve2.{emit_sve2_fmla_s}
use compiler.backend.native.arm_sve2.{emit_sve2_whilelo_s}

# ============================================================================
# ADD Z0.S, Z0.S, Z0.S
# ADD ZD.S, ZN.S, ZM.S — unpredicated integer add, 32-bit elements
# Encoding: word 0x04A00000 → LE: 0x00 0x00 0xA0 0x04
# bits[31:24]=0x04 bits[23:22]=10(S) bit[21]=0 bits[20:16]=Zm=0
# bits[9:5]=Zn=0 bits[4:0]=Zd=0
# ARMv9 ARM §C7.2.2 ADD (vectors, unpredicated)
# ============================================================================

describe "SVE2 emit_sve2_add_s Z0.S golden":
    it "ADD Z0.S Z0.S Z0.S emits 4 bytes":
        val result = emit_sve2_add_s(0, 0, 0)
        expect result.len() == 4

    it "ADD Z0.S Z0.S Z0.S byte0 is 0x00":
        # bits[7:0]: Zd=0, Zn low bits=0
        val result = emit_sve2_add_s(0, 0, 0)
        expect result[0] == 0

    it "ADD Z0.S Z0.S Z0.S byte1 is 0x00":
        # bits[15:8]: sub-opcode zeros
        val result = emit_sve2_add_s(0, 0, 0)
        expect result[1] == 0

    it "ADD Z0.S Z0.S Z0.S byte2 is 0xA0":
        # bits[23:16]: 0xA0 = 10100000 → bits[23:22]=10(S) bit[21]=1 Zm=0
        val result = emit_sve2_add_s(0, 0, 0)
        expect result[2] == 160

    it "ADD Z0.S Z0.S Z0.S byte3 is 0x04":
        # bits[31:24]: SVE integer arithmetic group
        val result = emit_sve2_add_s(0, 0, 0)
        expect result[3] == 4

# ============================================================================
# ADD Z1.S, Z2.S, Z3.S — tests Zd/Zn/Zm register field placement
# Expected word: 0x04A30041 → LE: 0x41 0x00 0xA3 0x04
# Zd=1 → bits[4:0]=1  Zn=2 → bits[9:5]=2 → byte0=(1+(2*32))%256=0x41
# Zm=3 → bits[20:16]=3 → byte2=0xA0+3=0xA3
# ============================================================================

describe "SVE2 emit_sve2_add_s Z1 Z2 Z3 register fields":
    it "ADD Z1.S Z2.S Z3.S byte0 encodes Zd and Zn":
        # Zd=1 bits[4:0]=1; Zn=2 bits[9:5]=2 → byte0 = 1 + (2*32) = 0x41
        val result = emit_sve2_add_s(1, 2, 3)
        expect result[0] == 65

    it "ADD Z1.S Z2.S Z3.S byte1 is 0x00":
        val result = emit_sve2_add_s(1, 2, 3)
        expect result[1] == 0

    it "ADD Z1.S Z2.S Z3.S byte2 encodes Zm":
        # Zm=3 → bits[20:16]=3 → byte2 = 0xA0 + 3 = 0xA3
        val result = emit_sve2_add_s(1, 2, 3)
        expect result[2] == 163

    it "ADD Z1.S Z2.S Z3.S byte3 is 0x04":
        val result = emit_sve2_add_s(1, 2, 3)
        expect result[3] == 4

# ============================================================================
# ADD Z31.S, Z31.S, Z31.S — boundary test: all 5-bit fields = 31 (0b11111)
# Expected word: 0x04BF03FF → LE: 0xFF 0x03 0xBF 0x04
# Zd=31 bits[4:0]=11111; Zn=31 bits[9:5]=11111 → byte0=0xFF byte1=0x03
# Zm=31 bits[20:16]=11111 → byte2=0xA0+31=0xBF
# ============================================================================

describe "SVE2 emit_sve2_add_s Z31 boundary":
    it "ADD Z31.S Z31.S Z31.S byte0 is 0xFF":
        # Zd=31=0x1F; Zn=31 in bits[9:5]=31*32=992; byte0=(31+992)%256=1023%256=0xFF
        val result = emit_sve2_add_s(31, 31, 31)
        expect result[0] == 255

    it "ADD Z31.S Z31.S Z31.S byte1 is 0x03":
        # bits[15:8]: upper bits of Zn=31 overflow into byte1: 1023/256=3 remainder 255
        val result = emit_sve2_add_s(31, 31, 31)
        expect result[1] == 3

    it "ADD Z31.S Z31.S Z31.S byte2 is 0xBF":
        # Zm=31 → bits[20:16]=31 → byte2 = 0xA0 + 31 = 0xBF
        val result = emit_sve2_add_s(31, 31, 31)
        expect result[2] == 191

    it "ADD Z31.S Z31.S Z31.S byte3 is 0x04":
        val result = emit_sve2_add_s(31, 31, 31)
        expect result[3] == 4

# ============================================================================
# Lane-size variation: ADD Z0.B, ADD Z0.H, ADD Z0.D
# Tests that size bits change correctly between element width variants
# B: word 0x04200000 → [0x00, 0x00, 0x20, 0x04]  bits[22:21]=00
# H: word 0x04600000 → [0x00, 0x00, 0x60, 0x04]  bits[22:21]=01
# D: word 0x04E00000 → [0x00, 0x00, 0xE0, 0x04]  bits[22:21]=11
# ============================================================================

describe "SVE2 ADD lane-size variants":
    it "ADD Z0.B byte2 is 0x20":
        # bits[23:16]=0x20 → bits[23:22]=00(B) bit[21]=1
        val result = emit_sve2_add_b(0, 0, 0)
        expect result[2] == 32

    it "ADD Z0.H byte2 is 0x60":
        # bits[23:16]=0x60 → bits[23:22]=01(H) bit[21]=1
        val result = emit_sve2_add_h(0, 0, 0)
        expect result[2] == 96

    it "ADD Z0.D byte2 is 0xE0":
        # bits[23:16]=0xE0 → bits[23:22]=11(D) bit[21]=1
        val result = emit_sve2_add_d(0, 0, 0)
        expect result[2] == 224

    it "ADD Z0.B emits 4 bytes":
        val result = emit_sve2_add_b(0, 0, 0)
        expect result.len() == 4

    it "ADD Z0.H emits 4 bytes":
        val result = emit_sve2_add_h(0, 0, 0)
        expect result.len() == 4

    it "ADD Z0.D emits 4 bytes":
        val result = emit_sve2_add_d(0, 0, 0)
        expect result.len() == 4

# ============================================================================
# MUL Z0.S, P0/M, Z0.S, Z1.S — predicated integer multiply (destructive)
# Assembly: mul z0.s, p0/m, z0.s, z1.s  (Z0 is dest and first source)
# Expected word: 0x04900020 → LE: 0x20 0x00 0x90 0x04
# zdn=0 bits[4:0]=0; Zm=1 bits[9:5]=1 → byte0=(1*32)%256=0x20
# Pg=0 bits[19:16]=0; byte2=0x90 bits[23:16]=0x90
# ARMv9 ARM §C7.2.214 MUL (vectors, predicated)
# ============================================================================

describe "SVE2 emit_sve2_mul_s golden":
    it "MUL Z0.S P0/M Z0.S Z1.S emits 4 bytes":
        val result = emit_sve2_mul_s(0, 0, 1)
        expect result.len() == 4

    it "MUL Z0.S P0/M Z0.S Z1.S byte0 is 0x20":
        # Zm=1 in bits[9:5]=32; Zdn=0 bits[4:0]=0 → byte0=32=0x20
        val result = emit_sve2_mul_s(0, 0, 1)
        expect result[0] == 32

    it "MUL Z0.S P0/M Z0.S Z1.S byte1 is 0x00":
        val result = emit_sve2_mul_s(0, 0, 1)
        expect result[1] == 0

    it "MUL Z0.S P0/M Z0.S Z1.S byte2 is 0x90":
        # bits[23:16]=0x90 encodes predicated MUL S-element opcode with Pg=0
        val result = emit_sve2_mul_s(0, 0, 1)
        expect result[2] == 144

    it "MUL Z0.S P0/M Z0.S Z1.S byte3 is 0x04":
        val result = emit_sve2_mul_s(0, 0, 1)
        expect result[3] == 4

    it "MUL Z0.S P0/M Z0.S Z0.S byte0 is 0x00":
        # Zm=0, Zdn=0 → byte0=0
        val result = emit_sve2_mul_s(0, 0, 0)
        expect result[0] == 0

# ============================================================================
# FADD Z0.S, P0/M, Z0.S, Z1.S — predicated FP add (destructive)
# Assembly: fadd z0.s, p0/m, z0.s, z1.s
# Expected word: 0x65808020 → LE: 0x20 0x80 0x80 0x65
# zdn=0 bits[4:0]=0; Zm=1 bits[9:5]=32 → byte0=0x20
# Pg=0 bits[12:10]=0; bits[15:8]=0x80; byte2=0x80; byte3=0x65
# ARMv9 ARM §C7.2.57 FADD (vectors, predicated)
# ============================================================================

describe "SVE2 emit_sve2_fadd_s golden":
    it "FADD Z0.S P0/M Z0.S Z1.S emits 4 bytes":
        val result = emit_sve2_fadd_s(0, 0, 1)
        expect result.len() == 4

    it "FADD Z0.S P0/M Z0.S Z1.S byte0 is 0x20":
        # Zm=1 in bits[9:5]=32; zdn=0 → byte0=32=0x20
        val result = emit_sve2_fadd_s(0, 0, 1)
        expect result[0] == 32

    it "FADD Z0.S P0/M Z0.S Z1.S byte1 is 0x80":
        # bits[15:8]=0x80: merging-predication bit + Pg=0
        val result = emit_sve2_fadd_s(0, 0, 1)
        expect result[1] == 128

    it "FADD Z0.S P0/M Z0.S Z1.S byte2 is 0x80":
        # bits[23:16]=0x80: S-size encoding for FP predicated add
        val result = emit_sve2_fadd_s(0, 0, 1)
        expect result[2] == 128

    it "FADD Z0.S P0/M Z0.S Z1.S byte3 is 0x65":
        # bits[31:24]=0x65: SVE FP arithmetic group
        val result = emit_sve2_fadd_s(0, 0, 1)
        expect result[3] == 101

# ============================================================================
# FADD size variants: .H and .D
# H: [0x20, 0x80, 0x40, 0x65]  D: [0x20, 0x80, 0xC0, 0x65]
# ============================================================================

describe "SVE2 FADD size variants":
    it "FADD Z0.H P0/M Z0.H Z1.H byte2 is 0x40":
        # bits[23:22]=01(H) → byte2=0x40
        val result = emit_sve2_fadd_h(0, 0, 1)
        expect result[2] == 64

    it "FADD Z0.D P0/M Z0.D Z1.D byte2 is 0xC0":
        # bits[23:22]=11(D) → byte2=0xC0
        val result = emit_sve2_fadd_d(0, 0, 1)
        expect result[2] == 192

    it "FADD Z0.H emits byte3 0x65":
        val result = emit_sve2_fadd_h(0, 0, 1)
        expect result[3] == 101

    it "FADD Z0.D emits byte3 0x65":
        val result = emit_sve2_fadd_d(0, 0, 1)
        expect result[3] == 101

# ============================================================================
# FMLA Z0.S, P0/M, Z1.S, Z2.S — predicated FP fused multiply-add
# Assembly: fmla z0.s, p0/m, z1.s, z2.s
# Expected word: 0x65A20020 → LE: 0x20 0x00 0xA2 0x65
# Zda=0 bits[4:0]=0; Zn=1 bits[9:5]=32 → byte0=0x20
# Pg=0 bits[12:10]=0 → byte1=0x00
# Zm=2 bits[20:16]=2 → byte2=0xA0+2=0xA2; byte3=0x65
# ARMv9 ARM §C7.2.74 FMLA (vectors, predicated)
# ============================================================================

describe "SVE2 emit_sve2_fmla_s golden":
    it "FMLA Z0.S P0/M Z1.S Z2.S emits 4 bytes":
        val result = emit_sve2_fmla_s(0, 0, 1, 2)
        expect result.len() == 4

    it "FMLA Z0.S P0/M Z1.S Z2.S byte0 is 0x20":
        # Zda=0; Zn=1 bits[9:5]=32 → byte0=32=0x20
        val result = emit_sve2_fmla_s(0, 0, 1, 2)
        expect result[0] == 32

    it "FMLA Z0.S P0/M Z1.S Z2.S byte1 is 0x00":
        # Pg=0 in bits[12:10]; no overflow into byte1
        val result = emit_sve2_fmla_s(0, 0, 1, 2)
        expect result[1] == 0

    it "FMLA Z0.S P0/M Z1.S Z2.S byte2 is 0xA2":
        # bits[23:16]: FMLA S base=0xA0; Zm=2 in bits[20:16]=+2 → 0xA2
        val result = emit_sve2_fmla_s(0, 0, 1, 2)
        expect result[2] == 162

    it "FMLA Z0.S P0/M Z1.S Z2.S byte3 is 0x65":
        val result = emit_sve2_fmla_s(0, 0, 1, 2)
        expect result[3] == 101

    it "FMLA Z0.S P0/M Z0.S Z1.S byte0 is 0x00":
        # Zda=0, Zn=0 → byte0=0; Zm=1 → byte2=0xA1
        val result = emit_sve2_fmla_s(0, 0, 0, 1)
        expect result[0] == 0

    it "FMLA Z0.S P0/M Z0.S Z1.S byte2 is 0xA1":
        # Zm=1 bits[20:16]=1 → byte2=0xA0+1=0xA1
        val result = emit_sve2_fmla_s(0, 0, 0, 1)
        expect result[2] == 161

# ============================================================================
# WHILELO P0.S, X0, X1 — generate loop predicate for 32-bit elements
# Assembly: whilelo p0.s, x0, x1
# Expected word: 0x25A11C00 → LE: 0x00 0x1C 0xA1 0x25
# Pd=0 bits[3:0]=0; Xn=0 bits[9:5]=0 → byte0=0x00
# bits[15:8]=0x1C (opcode sub-bits); Xm=1 bits[20:16]=1 → byte2=0xA0+1=0xA1
# byte3=0x25 (SVE predicate-forming group)
# ARMv9 ARM §C7.2.376 WHILELO
# ============================================================================

describe "SVE2 emit_sve2_whilelo_s golden":
    it "WHILELO P0.S X0 X1 emits 4 bytes":
        val result = emit_sve2_whilelo_s(0, 0, 1)
        expect result.len() == 4

    it "WHILELO P0.S X0 X1 byte0 is 0x00":
        # Pd=0, Xn=0 → byte0=0
        val result = emit_sve2_whilelo_s(0, 0, 1)
        expect result[0] == 0

    it "WHILELO P0.S X0 X1 byte1 is 0x1C":
        # bits[15:8]=0x1C: opcode sub-field for WHILELO
        val result = emit_sve2_whilelo_s(0, 0, 1)
        expect result[1] == 28

    it "WHILELO P0.S X0 X1 byte2 is 0xA1":
        # Xm=1 in bits[20:16]=1; base bits[23:16]=0xA0 → byte2=0xA1
        val result = emit_sve2_whilelo_s(0, 0, 1)
        expect result[2] == 161

    it "WHILELO P0.S X0 X1 byte3 is 0x25":
        # SVE predicate-forming group opcode
        val result = emit_sve2_whilelo_s(0, 0, 1)
        expect result[3] == 37

    it "WHILELO P1.S X0 X1 byte0 is 0x01":
        # Pd=1 → bits[3:0]=1 → byte0=1
        val result = emit_sve2_whilelo_s(1, 0, 1)
        expect result[0] == 1

    it "WHILELO P0.S X0 X2 byte2 is 0xA2":
        # Xm=2 in bits[20:16]=2 → byte2=0xA0+2=0xA2
        val result = emit_sve2_whilelo_s(0, 0, 2)
        expect result[2] == 162