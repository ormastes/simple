# test/unit/compiler/backend/avx512_cmp_mask_spec.spl
#
# Byte-level golden tests for AVX-512 compare-to-mask emit bodies.
# Covers: VPCMPEQD, VPCMPEQQ (fixed-predicate), VPCMPD, VPCMPQ (imm8 predicate).
#
# All byte sequences verified against:
#   llvm-mc -triple=x86_64 -mattr=+avx512f --show-encoding
#   Intel SDM Vol 2C — VPCMPD, VPCMPQ, VPCMPEQD, VPCMPEQQ entries
#   Intel SDM Vol 2A §2.6.1 Table 2-36 (EVEX prefix layout)
#
# Register IDs (from x86_64_avx512.spl scaffold):
#   X86_ZMM0=48, X86_ZMM1=49
#   k_dst is raw 0-7 (k0=0, k1=1, etc.)
#
# Post-F4 corrected encoder (ERR-001a/b RESOLVED) — see simd_strict_emit_errata.md
#
# # C2 §1.1: Intel SDM Vol 2A §2.6.1 Table 2-36 (EVEX byte layout)
# # C2 §1.2: VPCMPD  EVEX.512.66.0F3A.W0 1F /r ib — Intel SDM Vol 2C
# # C2 §1.3: VPCMPQ  EVEX.512.66.0F3A.W1 1F /r ib — Intel SDM Vol 2C
# # C2 §1.4: VPCMPEQD EVEX.512.66.0F38.W0 76 /r   — Intel SDM Vol 2C
# # C2 §1.5: VPCMPEQQ EVEX.512.66.0F38.W1 29 /r   — Intel SDM Vol 2C

use compiler.backend.native.x86_64_avx512.{emit_avx512_vpcmpeqd, emit_avx512_vpcmpeqq, emit_avx512_vpcmpd, emit_avx512_vpcmpq}

# ============================================================================
# VPCMPEQD k0, zmm0, zmm1  (fixed-predicate EQ, 32-bit)
# EVEX.512.66.0F38.W0 76 /r
# k_dst=0 src1=zmm0(idx=0) src2=zmm1(idx=1) kmask=k0(unmasked) z=false
# Expected: 62 F2 7D 48 76 C1
# P0=0xF2: ~R=1 ~X=1 ~B=1 ~R'=1 0 mm[2:0]=010 (0F38 map) = 242
# P1=0x7D: W=0 ~vvvv=1111(src1=zmm0,idx=0) must-1 pp=01(0x66) = 125
# P2=0x48: z=0 L'=1 L=0 b=0 ~V'=1 aaa=000 = 72
# ModRM=0xC1: mod=11 reg=0(k0) rm=1(zmm1) = 193
# Intel SDM Vol 2C VPCMPEQD; Vol 2A §2.6.1 Table 2-36
# llvm-mc verified: vpcmpeqd k0, zmm0, zmm1 → 62 f2 7d 48 76 c1
# ============================================================================

describe "AVX-512 EVEX emit VPCMPEQD compare-to-mask golden":
    it "VPCMPEQD k0 zmm0 zmm1 emits 6 bytes":
        val result = emit_avx512_vpcmpeqd(0, 48, 49)
        expect(result.len()).to_equal(6)

    it "VPCMPEQD k0 zmm0 zmm1 escape byte is 0x62":
        val result = emit_avx512_vpcmpeqd(0, 48, 49)
        expect(result[0]).to_equal(98)

    it "VPCMPEQD k0 zmm0 zmm1 P0 is 0xF2":
        # P0: ~R=1 ~X=1 ~B=1 ~R'=1 0 mm[2:0]=010 (0F38 map) = 242
        val result = emit_avx512_vpcmpeqd(0, 48, 49)
        expect(result[1]).to_equal(242)

    it "VPCMPEQD k0 zmm0 zmm1 P1 is 0x7D":
        # P1: W=0 ~vvvv=1111(src1=zmm0,idx=0) must-1 pp=01(0x66) = 125
        val result = emit_avx512_vpcmpeqd(0, 48, 49)
        expect(result[2]).to_equal(125)

    it "VPCMPEQD k0 zmm0 zmm1 P2 is 0x48":
        # P2: z=0 L'=1 L=0 b=0 ~V'=1 aaa=000 = 72
        val result = emit_avx512_vpcmpeqd(0, 48, 49)
        expect(result[3]).to_equal(72)

    it "VPCMPEQD k0 zmm0 zmm1 opcode is 0x76":
        val result = emit_avx512_vpcmpeqd(0, 48, 49)
        expect(result[4]).to_equal(118)

    it "VPCMPEQD k0 zmm0 zmm1 ModRM is 0xC1":
        # ModRM: mod=11 reg=0(k0) rm=1(zmm1) = 192+0+1 = 193
        val result = emit_avx512_vpcmpeqd(0, 48, 49)
        expect(result[5]).to_equal(193)

# ============================================================================
# VPCMPEQQ k1, zmm0, zmm1  (fixed-predicate EQ, 64-bit)
# EVEX.512.66.0F38.W1 29 /r
# k_dst=1 src1=zmm0(idx=0) src2=zmm1(idx=1) kmask=k0(unmasked) z=false
# Expected: 62 F2 FD 48 29 C9
# P0=0xF2: ~R=1 ~X=1 ~B=1 ~R'=1 0 mm=010(0F38) = 242
# P1=0xFD: W=1 ~vvvv=1111 must-1 pp=01 = 253
# P2=0x48: z=0 L'=1 L=0 b=0 ~V'=1 aaa=000 = 72
# ModRM=0xC9: mod=11 reg=1(k1) rm=1(zmm1) = 192+8+1 = 201
# Intel SDM Vol 2C VPCMPEQQ; Vol 2A §2.6.1 Table 2-36
# llvm-mc verified: vpcmpeqq k1, zmm0, zmm1 → 62 f2 fd 48 29 c9
# ============================================================================

describe "AVX-512 EVEX emit VPCMPEQQ compare-to-mask golden":
    it "VPCMPEQQ k1 zmm0 zmm1 emits 6 bytes":
        val result = emit_avx512_vpcmpeqq(1, 48, 49)
        expect(result.len()).to_equal(6)

    it "VPCMPEQQ k1 zmm0 zmm1 escape byte is 0x62":
        val result = emit_avx512_vpcmpeqq(1, 48, 49)
        expect(result[0]).to_equal(98)

    it "VPCMPEQQ k1 zmm0 zmm1 P0 is 0xF2":
        # P0: ~R=1 ~X=1 ~B=1 ~R'=1 0 mm[2:0]=010 (0F38 map) = 242
        val result = emit_avx512_vpcmpeqq(1, 48, 49)
        expect(result[1]).to_equal(242)

    it "VPCMPEQQ k1 zmm0 zmm1 P1 is 0xFD":
        # P1: W=1 ~vvvv=1111 must-1 pp=01(0x66) = 253 (W=1 differentiates Q from D)
        val result = emit_avx512_vpcmpeqq(1, 48, 49)
        expect(result[2]).to_equal(253)

    it "VPCMPEQQ k1 zmm0 zmm1 P2 is 0x48":
        # P2: z=0 L'=1 L=0 b=0 ~V'=1 aaa=000 = 72
        val result = emit_avx512_vpcmpeqq(1, 48, 49)
        expect(result[3]).to_equal(72)

    it "VPCMPEQQ k1 zmm0 zmm1 opcode is 0x29":
        val result = emit_avx512_vpcmpeqq(1, 48, 49)
        expect(result[4]).to_equal(41)

    it "VPCMPEQQ k1 zmm0 zmm1 ModRM is 0xC9":
        # ModRM: mod=11 reg=1(k1) rm=1(zmm1) = 192+8+1 = 201
        val result = emit_avx512_vpcmpeqq(1, 48, 49)
        expect(result[5]).to_equal(201)

    it "VPCMPEQQ P1 byte differs from VPCMPEQD P1 by W-bit (0x7D vs 0xFD)":
        # W=0 → P1=0x7D=125 for D-form; W=1 → P1=0xFD=253 for Q-form
        val rd = emit_avx512_vpcmpeqd(0, 48, 49)
        val rq = emit_avx512_vpcmpeqq(1, 48, 49)
        expect(rd[2]).to_equal(125)
        expect(rq[2]).to_equal(253)

# ============================================================================
# VPCMPD k0, zmm0, zmm1, 0  (imm8 predicate EQ=0, 32-bit)
# EVEX.512.66.0F3A.W0 1F /r ib
# k_dst=0 src1=zmm0(idx=0) src2=zmm1(idx=1) imm8=0
# Expected: 62 F3 7D 48 1F C1 00
# P0=0xF3: ~R=1 ~X=1 ~B=1 ~R'=1 0 mm=011(0F3A) = 243
# P1=0x7D: W=0 ~vvvv=1111 must-1 pp=01 = 125
# P2=0x48: z=0 L'=1 L=0 b=0 ~V'=1 aaa=000 = 72
# ModRM=0xC1: mod=11 reg=0(k0) rm=1(zmm1) = 193
# imm8=0x00
# Intel SDM Vol 2C VPCMPD; Vol 2A §2.6.1 Table 2-36
# llvm-mc verified: vpcmpd k0, zmm0, zmm1, 0 → 62 f3 7d 48 1f c1 00
# ============================================================================

describe "AVX-512 EVEX emit VPCMPD imm8-predicate golden":
    it "VPCMPD k0 zmm0 zmm1 EQ=0 emits 7 bytes":
        val result = emit_avx512_vpcmpd(0, 48, 49, 0)
        expect(result.len()).to_equal(7)

    it "VPCMPD k0 zmm0 zmm1 EQ=0 escape byte is 0x62":
        val result = emit_avx512_vpcmpd(0, 48, 49, 0)
        expect(result[0]).to_equal(98)

    it "VPCMPD k0 zmm0 zmm1 EQ=0 P0 is 0xF3":
        # P0: ~R=1 ~X=1 ~B=1 ~R'=1 0 mm[2:0]=011 (0F3A map) = 243
        val result = emit_avx512_vpcmpd(0, 48, 49, 0)
        expect(result[1]).to_equal(243)

    it "VPCMPD k0 zmm0 zmm1 EQ=0 P1 is 0x7D":
        # P1: W=0 ~vvvv=1111 must-1 pp=01(0x66) = 125
        val result = emit_avx512_vpcmpd(0, 48, 49, 0)
        expect(result[2]).to_equal(125)

    it "VPCMPD k0 zmm0 zmm1 EQ=0 P2 is 0x48":
        # P2: z=0 L'=1 L=0 b=0 ~V'=1 aaa=000 = 72
        val result = emit_avx512_vpcmpd(0, 48, 49, 0)
        expect(result[3]).to_equal(72)

    it "VPCMPD k0 zmm0 zmm1 EQ=0 opcode is 0x1F":
        val result = emit_avx512_vpcmpd(0, 48, 49, 0)
        expect(result[4]).to_equal(31)

    it "VPCMPD k0 zmm0 zmm1 EQ=0 ModRM is 0xC1":
        # ModRM: mod=11 reg=0(k0) rm=1(zmm1) = 193
        val result = emit_avx512_vpcmpd(0, 48, 49, 0)
        expect(result[5]).to_equal(193)

    it "VPCMPD k0 zmm0 zmm1 EQ=0 imm8 is 0x00":
        val result = emit_avx512_vpcmpd(0, 48, 49, 0)
        expect(result[6]).to_equal(0)

    it "VPCMPD k0 zmm0 zmm1 LT=1 emits 7 bytes":
        val result = emit_avx512_vpcmpd(0, 48, 49, 1)
        expect(result.len()).to_equal(7)

    it "VPCMPD k0 zmm0 zmm1 LT=1 imm8 is 0x01":
        val result = emit_avx512_vpcmpd(0, 48, 49, 1)
        expect(result[6]).to_equal(1)

    it "VPCMPD LT differs from EQ only in imm8 byte":
        # All prefix bytes identical; only imm8 differs
        val req = emit_avx512_vpcmpd(0, 48, 49, 0)
        val rlt = emit_avx512_vpcmpd(0, 48, 49, 1)
        expect(req[0]).to_equal(rlt[0])
        expect(req[1]).to_equal(rlt[1])
        expect(req[2]).to_equal(rlt[2])
        expect(req[3]).to_equal(rlt[3])
        expect(req[4]).to_equal(rlt[4])
        expect(req[5]).to_equal(rlt[5])
        expect(req[6]).to_equal(0)
        expect(rlt[6]).to_equal(1)

# ============================================================================
# VPCMPQ k1, zmm0, zmm1, 0  (imm8 predicate EQ=0, 64-bit)
# EVEX.512.66.0F3A.W1 1F /r ib
# k_dst=1 src1=zmm0(idx=0) src2=zmm1(idx=1) imm8=0
# Expected: 62 F3 FD 48 1F C9 00
# P0=0xF3: mm=011(0F3A) = 243
# P1=0xFD: W=1 ~vvvv=1111 must-1 pp=01 = 253 (W=1 differentiates Q from D)
# P2=0x48: z=0 L'=1 L=0 b=0 ~V'=1 aaa=000 = 72
# ModRM=0xC9: mod=11 reg=1(k1) rm=1(zmm1) = 201
# imm8=0x00
# Intel SDM Vol 2C VPCMPQ; Vol 2A §2.6.1 Table 2-36
# llvm-mc verified: vpcmpq k1, zmm0, zmm1, 0 → 62 f3 fd 48 1f c9 00
# ============================================================================

describe "AVX-512 EVEX emit VPCMPQ imm8-predicate golden":
    it "VPCMPQ k1 zmm0 zmm1 EQ=0 emits 7 bytes":
        val result = emit_avx512_vpcmpq(1, 48, 49, 0)
        expect(result.len()).to_equal(7)

    it "VPCMPQ k1 zmm0 zmm1 EQ=0 P0 is 0xF3":
        # P0: ~R=1 ~X=1 ~B=1 ~R'=1 0 mm[2:0]=011 (0F3A map) = 243
        val result = emit_avx512_vpcmpq(1, 48, 49, 0)
        expect(result[1]).to_equal(243)

    it "VPCMPQ k1 zmm0 zmm1 EQ=0 P1 is 0xFD":
        # P1: W=1 ~vvvv=1111 must-1 pp=01(0x66) = 253
        val result = emit_avx512_vpcmpq(1, 48, 49, 0)
        expect(result[2]).to_equal(253)

    it "VPCMPQ k1 zmm0 zmm1 EQ=0 P2 is 0x48":
        val result = emit_avx512_vpcmpq(1, 48, 49, 0)
        expect(result[3]).to_equal(72)

    it "VPCMPQ k1 zmm0 zmm1 EQ=0 opcode is 0x1F":
        val result = emit_avx512_vpcmpq(1, 48, 49, 0)
        expect(result[4]).to_equal(31)

    it "VPCMPQ k1 zmm0 zmm1 EQ=0 ModRM is 0xC9":
        # ModRM: mod=11 reg=1(k1) rm=1(zmm1) = 201
        val result = emit_avx512_vpcmpq(1, 48, 49, 0)
        expect(result[5]).to_equal(201)

    it "VPCMPQ k1 zmm0 zmm1 EQ=0 imm8 is 0x00":
        val result = emit_avx512_vpcmpq(1, 48, 49, 0)
        expect(result[6]).to_equal(0)

    it "VPCMPQ P1 byte differs from VPCMPD P1 by W-bit (0x7D vs 0xFD)":
        # Same opcode 0x1F; W=0→P1=125 for D-form, W=1→P1=253 for Q-form
        val rd = emit_avx512_vpcmpd(0, 48, 49, 0)
        val rq = emit_avx512_vpcmpq(1, 48, 49, 0)
        expect(rd[2]).to_equal(125)
        expect(rq[2]).to_equal(253)
