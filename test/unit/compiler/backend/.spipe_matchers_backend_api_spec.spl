use compiler.backend.backend_types.{
    BackendKind,
    CodegenTarget,
    OptimizationLevel,
    compileoptions_default_options,
    compileoptions_debug_options,
    compileoptions_release_options,
    compileerror_target_unsupported
}

describe "Backend Api":
    it "creates default compile options with the expected baseline":
        val options = compileoptions_default_options()

        expect options.target == CodegenTarget.Host
        expect options.opt_level == OptimizationLevel.Speed
        expect options.debug_info == false
        expect options.emit_assembly == false
        expect options.emit_llvm_ir == false
        expect options.emit_mir == false
        expect options.verify_output == true

    it "creates debug and release compile options with distinct flags":
        val debug_options = compileoptions_debug_options()
        val release_options = compileoptions_release_options()

        expect debug_options.target == CodegenTarget.Host
        expect debug_options.opt_level == OptimizationLevel.Debug
        expect debug_options.debug_info == true
        expect debug_options.emit_mir == true

        expect release_options.target == CodegenTarget.Host
        expect release_options.opt_level == OptimizationLevel.Speed
        expect release_options.debug_info == false
        expect release_options.verify_output == true

    it "reports bitness and wasm helpers on codegen targets":
        expect CodegenTarget.X86_64.is_64bit() == true
        expect CodegenTarget.AArch64.is_64bit() == true
        expect CodegenTarget.X86.is_32bit() == true
        expect CodegenTarget.Arm.is_32bit() == true
        expect CodegenTarget.Wasm32.is_wasm() == true
        expect CodegenTarget.Wasm64.is_wasm() == true
        expect CodegenTarget.X86_64.is_wasm() == false

    it "formats unsupported target errors with the expected shape":
        val error = compileerror_target_unsupported(BackendKind.Cranelift, CodegenTarget.X86)

        expect (error.message).contains("Backend Cranelift does not support target X86")
        expect error.phase == "target selection"
        expect error.has_location == false
        expect error.location == nil