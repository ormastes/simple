# test/unit/compiler/backend/rvv_float_spec.spl
#
# Byte-equal golden tests for RVV v1.0 vector floating-point arithmetic encoder.
# All goldens derived from RISC-V Vector Extension v1.0 spec §13.2-13.6.
#
# Encoding formula:
#   word = (funct6 * 67108864) + (vm * 33554432) + (vs2 * 1048576)
#        + (vs1 * 32768) + (funct3 * 4096) + (vd * 128) + 87
#
# OPFVV (funct3=1): all 8 operations, vm=1 (unmasked).
#
# Test registers: vd=1, vs2=2, vs1=3 (where applicable), vm=1 (unmasked).
# Note: vfmadd/vfmsub API is (vd, vs1, vs2) — see function docs.

use std.spec
use compiler.backend.backend.native.encode_rvv_float.{
    emit_vfadd_vv,
    emit_vfsub_vv,
    emit_vfmul_vv,
    emit_vfdiv_vv,
    emit_vfmadd_vv,
    emit_vfmsub_vv,
    emit_vfmin_vv,
    emit_vfmax_vv
}

describe "encode_rvv_float — vfadd.vv (FP add, OPFVV funct3=1)":
    it "emit_vfadd_vv vd=0 vs2=0 vs1=0 — zero-register canonical":
        # funct6=0x00,vm=1,vs2=0,vs1=0,funct3=1,vd=0 → word=0x02001057
        val got = emit_vfadd_vv(0, 0, 0)
        expect(got.length) to_equal(4)
        expect(got[0]) to_equal(0x57)
        expect(got[1]) to_equal(0x10)
        expect(got[2]) to_equal(0x00)
        expect(got[3]) to_equal(0x02)

    it "emit_vfadd_vv vd=1 vs2=2 vs1=3 — non-zero registers":
        # funct6=0x00,vm=1,vs2=2,vs1=3,funct3=1,vd=1 → word=0x022190D7
        val got = emit_vfadd_vv(1, 2, 3)
        expect(got.length) to_equal(4)
        expect(got[0]) to_equal(0xD7)
        expect(got[1]) to_equal(0x90)
        expect(got[2]) to_equal(0x21)
        expect(got[3]) to_equal(0x02)

describe "encode_rvv_float — vfsub.vv (FP subtract, OPFVV funct3=1)":
    it "emit_vfsub_vv vd=0 vs2=0 vs1=0 — zero-register canonical":
        # funct6=0x02,vm=1,vs2=0,vs1=0,funct3=1,vd=0 → word=0x0A001057
        val got = emit_vfsub_vv(0, 0, 0)
        expect(got.length) to_equal(4)
        expect(got[0]) to_equal(0x57)
        expect(got[1]) to_equal(0x10)
        expect(got[2]) to_equal(0x00)
        expect(got[3]) to_equal(0x0A)

    it "emit_vfsub_vv vd=1 vs2=2 vs1=3 — non-zero registers":
        # funct6=0x02,vm=1,vs2=2,vs1=3,funct3=1,vd=1 → word=0x0A2190D7
        val got = emit_vfsub_vv(1, 2, 3)
        expect(got.length) to_equal(4)
        expect(got[0]) to_equal(0xD7)
        expect(got[1]) to_equal(0x90)
        expect(got[2]) to_equal(0x21)
        expect(got[3]) to_equal(0x0A)

