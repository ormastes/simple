    it "emit_vfmul_vv vd=1 vs2=2 vs1=3 — non-zero registers":
        # funct6=0x24,vm=1,vs2=2,vs1=3,funct3=1,vd=1 → word=0x922190D7
        val got = emit_vfmul_vv(1, 2, 3)
        expect(got.length) to_equal(4)
