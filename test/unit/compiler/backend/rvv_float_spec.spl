    it "emit_vfmul_vv vd=0 vs2=0 vs1=0 — zero-register canonical":
        # funct6=0x24,vm=1,vs2=0,vs1=0,funct3=1,vd=0 → word=0x92001057
        val got = emit_vfmul_vv(0, 0, 0)
