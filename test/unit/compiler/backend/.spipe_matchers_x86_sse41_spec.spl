# x86_64 SSE4.1 Encoder — Golden Byte Tests
#
# Feature ID: #COMPILER-BACKEND-ENCODE-X86-SSE41
# Category:   Compiler | Backend | x86_64 Byte Emitter
# Status:     Schema contract — byte golden tests for SSE4.1 blend/pack instructions
#
# ALL byte goldens verified against Intel SDM Vol 2 opcode tables.
#
# Interpreter-mode note (per .claude/rules/testing.md):
#   The test runner in interpreter mode only verifies file loading and
#   describe/it block reachability.  The assertions inside it-blocks are not
#   executed.  Compiled-mode execution will exercise them.

use compiler.backend.native.encode_x86_64_sse41.{
    emit_pblendw,
    emit_blendps,
    emit_blendpd,
    emit_dpps,
    emit_pblendvb,
    emit_packusdw,
    emit_pmovzxbd
}

# ============================================================================
# PBLENDW (66 0F 3A 0E /r ib)
# ============================================================================

describe "x86 SSE4.1 PBLENDW encoder — golden bytes":
    it "emit_pblendw(0, 1, 0xFF) → [0x66, 0x0F, 0x3A, 0x0E, 0xC1, 0xFF]":
        val bytes = emit_pblendw(0, 1, 0xFF)
        expect bytes.len() == 6
        expect bytes[0] == 0x66
        expect bytes[1] == 0x0F
        expect bytes[2] == 0x3A
        expect bytes[3] == 0x0E
        expect bytes[4] == 0xC1
        expect bytes[5] == 0xFF

    it "emit_pblendw(0, 0, 0x00) → [0x66, 0x0F, 0x3A, 0x0E, 0xC0, 0x00]":
        val bytes = emit_pblendw(0, 0, 0x00)
        expect bytes.len() == 6
        expect bytes[0] == 0x66
        expect bytes[1] == 0x0F
        expect bytes[2] == 0x3A
        expect bytes[3] == 0x0E
        expect bytes[4] == 0xC0
        expect bytes[5] == 0x00

    it "emit_pblendw(8, 9, 0x0A) → [0x66, 0x45, 0x0F, 0x3A, 0x0E, 0xC1, 0x0A] (REX.RB)":
        val bytes = emit_pblendw(8, 9, 0x0A)
        expect bytes.len() == 7
        expect bytes[0] == 0x66
        expect bytes[1] == 0x45
        expect bytes[2] == 0x0F
        expect bytes[3] == 0x3A
        expect bytes[4] == 0x0E
        expect bytes[5] == 0xC1
        expect bytes[6] == 0x0A

# ============================================================================
# BLENDPS (66 0F 3A 0C /r ib)
# ============================================================================

describe "x86 SSE4.1 BLENDPS encoder — golden bytes":
    it "emit_blendps(0, 1, 0x0F) → [0x66, 0x0F, 0x3A, 0x0C, 0xC1, 0x0F]":
        val bytes = emit_blendps(0, 1, 0x0F)
        expect bytes.len() == 6
        expect bytes[0] == 0x66
        expect bytes[1] == 0x0F
        expect bytes[2] == 0x3A
        expect bytes[3] == 0x0C
        expect bytes[4] == 0xC1
        expect bytes[5] == 0x0F

    it "emit_blendps(0, 0, 0x00) → [0x66, 0x0F, 0x3A, 0x0C, 0xC0, 0x00]":
        val bytes = emit_blendps(0, 0, 0x00)
        expect bytes.len() == 6
        expect bytes[0] == 0x66
        expect bytes[1] == 0x0F
        expect bytes[2] == 0x3A
        expect bytes[3] == 0x0C
        expect bytes[4] == 0xC0
        expect bytes[5] == 0x00

    it "emit_blendps(8, 0, 0x05) → [0x66, 0x44, 0x0F, 0x3A, 0x0C, 0xC0, 0x05] (REX.R only)":
        val bytes = emit_blendps(8, 0, 0x05)
        expect bytes.len() == 7
        expect bytes[0] == 0x66
        expect bytes[1] == 0x44
        expect bytes[2] == 0x0F
        expect bytes[3] == 0x3A
        expect bytes[4] == 0x0C
        expect bytes[5] == 0xC0
        expect bytes[6] == 0x05

# ============================================================================
# BLENDPD (66 0F 3A 0D /r ib)
# ============================================================================

describe "x86 SSE4.1 BLENDPD encoder — golden bytes":
    it "emit_blendpd(0, 1, 0x03) → [0x66, 0x0F, 0x3A, 0x0D, 0xC1, 0x03]":
        val bytes = emit_blendpd(0, 1, 0x03)
        expect bytes.len() == 6
        expect bytes[0] == 0x66
        expect bytes[1] == 0x0F
        expect bytes[2] == 0x3A
        expect bytes[3] == 0x0D
        expect bytes[4] == 0xC1
        expect bytes[5] == 0x03

    it "emit_blendpd(0, 0, 0x00) → [0x66, 0x0F, 0x3A, 0x0D, 0xC0, 0x00]":
        val bytes = emit_blendpd(0, 0, 0x00)
        expect bytes.len() == 6
        expect bytes[0] == 0x66
        expect bytes[1] == 0x0F
        expect bytes[2] == 0x3A
        expect bytes[3] == 0x0D
        expect bytes[4] == 0xC0
        expect bytes[5] == 0x00

    it "emit_blendpd(0, 8, 0x01) → [0x66, 0x41, 0x0F, 0x3A, 0x0D, 0xC0, 0x01] (REX.B only)":
        val bytes = emit_blendpd(0, 8, 0x01)
        expect bytes.len() == 7
        expect bytes[0] == 0x66
        expect bytes[1] == 0x41
        expect bytes[2] == 0x0F
        expect bytes[3] == 0x3A
        expect bytes[4] == 0x0D
        expect bytes[5] == 0xC0
        expect bytes[6] == 0x01

# ============================================================================
# PBLENDVB (66 0F 38 10 /r) — implicit XMM0 mask
# ============================================================================

describe "x86 SSE4.1 PBLENDVB encoder — golden bytes":
    it "emit_pblendvb(0, 1) → [0x66, 0x0F, 0x38, 0x10, 0xC1]":
        val bytes = emit_pblendvb(0, 1)
        expect bytes.len() == 5
        expect bytes[0] == 0x66
        expect bytes[1] == 0x0F
        expect bytes[2] == 0x38
        expect bytes[3] == 0x10
        expect bytes[4] == 0xC1

    it "emit_pblendvb(0, 0) → [0x66, 0x0F, 0x38, 0x10, 0xC0]":
        val bytes = emit_pblendvb(0, 0)
        expect bytes.len() == 5
        expect bytes[0] == 0x66
        expect bytes[1] == 0x0F
        expect bytes[2] == 0x38
        expect bytes[3] == 0x10
        expect bytes[4] == 0xC0

    it "emit_pblendvb(8, 0) → [0x66, 0x44, 0x0F, 0x38, 0x10, 0xC0] (REX.R)":
        val bytes = emit_pblendvb(8, 0)
        expect bytes.len() == 6
        expect bytes[0] == 0x66
        expect bytes[1] == 0x44
        expect bytes[2] == 0x0F
        expect bytes[3] == 0x38
        expect bytes[4] == 0x10
        expect bytes[5] == 0xC0

