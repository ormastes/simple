# AArch64 Cipher Intrinsic Lowering — Spec Tests
#
# Feature ID: #COMPILER-BACKEND-LOWERING-CIPHER-AARCH64
# Category:   Compiler | Backend | Cipher Lowering | AArch64
#
# Maps canonical MirInstKind.Intrinsic names (text) to AArch64 byte sequences
# via Aarch64Caps gating.  When the target lacks the cipher feature, the
# lowering returns LoweringResult(lowered=false, reason="no-cap") so the
# pattern engine can leave the original Call in place.
#
# Interpreter-mode note (per .claude/rules/testing.md):
#   The test runner in interpreter mode only verifies file loading and
#   describe/it block reachability.  Assertions inside it-blocks are not
#   executed.  Compiled-mode execution will exercise them.

use compiler.backend.lowering.intrinsic_lowering_x86.{LoweringResult}
use compiler.backend.lowering.intrinsic_lowering_aarch64.{
    intrinsic_to_target_idiom_aarch64, lower_cipher_intrinsic_aarch64
}
use compiler.backend.feature_caps.{Aarch64Caps, TargetIdiom}

# ============================================================================
# Helpers — capability fixtures
# ============================================================================

fn caps_full_crypto() -> Aarch64Caps:
    # has_aes=true, has_sha2=true, has_sha3=false, has_pmull=true,
    # has_crc32=true, has_neon=true, has_sve2=false, has_sha512=false
    Aarch64Caps(true, true, false, true, true, true, false, false)

fn caps_aes_only() -> Aarch64Caps:
    # AES + PMULL only (aarch64+crypto without CRC32)
    Aarch64Caps(true, false, false, true, false, true, false, false)

fn caps_bare() -> Aarch64Caps:
    # NEON only — no crypto extensions
    Aarch64Caps(false, false, false, false, false, true, false, false)

fn caps_sve2() -> Aarch64Caps:
    # NEON + SVE2 for bitreverse/matrix-capable paths
    Aarch64Caps(false, false, false, false, false, true, true, false)

# ============================================================================
# Name -> TargetIdiom mapping
# ============================================================================

describe "intrinsic_to_target_idiom_aarch64 — name mapping":
    it "crypto_aes_round maps to AesEnc idiom":
        var result = intrinsic_to_target_idiom_aarch64("crypto_aes_round")
        expect result.is_some() == true

    it "crypto_aes_round_last maps to AesEncLast idiom":
        var result = intrinsic_to_target_idiom_aarch64("crypto_aes_round_last")
        expect result.is_some() == true

    it "clmul_lo maps to ClmulLo idiom":
        var result = intrinsic_to_target_idiom_aarch64("clmul_lo")
        expect result.is_some() == true

    it "bit_popcount maps to Popcount idiom":
        var result = intrinsic_to_target_idiom_aarch64("bit_popcount")
        expect result.is_some() == true

    it "matrix_dot maps to MatrixDot idiom":
        var result = intrinsic_to_target_idiom_aarch64("matrix_dot")
        expect result.is_some() == true

    it "unknown name returns nil":
        var result = intrinsic_to_target_idiom_aarch64("not_a_real_intrinsic")
        expect result.is_some() == false

# ============================================================================
# AES family — full round emits 8 bytes (AESE + AESMC pair)
# ============================================================================

describe "lower_cipher_intrinsic_aarch64 — AES lowering with crypto caps":
    it "crypto_aes_round emits 8 bytes (AESE+AESMC pair)":
        var r = lower_cipher_intrinsic_aarch64("crypto_aes_round", [0, 1], caps_aes_only())
        expect r.lowered == true
        expect r.bytes.len() == 8

    it "crypto_aes_round_last emits 4 bytes (AESE only)":
        var r = lower_cipher_intrinsic_aarch64("crypto_aes_round_last", [0, 1], caps_aes_only())
        expect r.lowered == true
        expect r.bytes.len() == 4

    it "crypto_aes_inv_round emits 8 bytes (AESD+AESIMC pair)":
        var r = lower_cipher_intrinsic_aarch64("crypto_aes_inv_round", [0, 1], caps_aes_only())
        expect r.lowered == true
        expect r.bytes.len() == 8

    it "crypto_aes_inv_round_last emits 4 bytes (AESD only)":
        var r = lower_cipher_intrinsic_aarch64("crypto_aes_inv_round_last", [0, 1], caps_aes_only())
        expect r.lowered == true
        expect r.bytes.len() == 4

# ============================================================================
# Capability gating — bare caps refuses cipher idioms with reason="no-cap"
# ============================================================================

describe "lower_cipher_intrinsic_aarch64 — bare Aarch64Caps refuses cipher idioms":
    it "AES round on bare caps returns lowered=false, reason='no-cap'":
        var r = lower_cipher_intrinsic_aarch64("crypto_aes_round", [0, 1], caps_bare())
        expect r.lowered == false
        expect r.reason == "no-cap"

    it "SHA256 rnds2 on bare caps refuses":
        var r = lower_cipher_intrinsic_aarch64("crypto_sha256_rnds2", [0, 1, 2], caps_bare())
        expect r.lowered == false
        expect r.reason == "no-cap"

    it "CRC32_U8 on bare caps refuses":
        var r = lower_cipher_intrinsic_aarch64("crc32_u8", [0, 1, 2], caps_bare())
        expect r.lowered == false
        expect r.reason == "no-cap"

    it "CLMUL_LO on bare caps refuses":
        var r = lower_cipher_intrinsic_aarch64("clmul_lo", [0, 1, 2], caps_bare())
        expect r.lowered == false
        expect r.reason == "no-cap"

# ============================================================================
# Unknown intrinsic name -> reason="unknown"
# ============================================================================

describe "lower_cipher_intrinsic_aarch64 — unknown name handling":
    it "unrecognised intrinsic returns lowered=false, reason='unknown'":
        var r = lower_cipher_intrinsic_aarch64("not_a_real_intrinsic", [0, 1], caps_full_crypto())
        expect r.lowered == false
        expect r.reason == "unknown"

    it "empty name returns unknown":
        var r = lower_cipher_intrinsic_aarch64("", [], caps_full_crypto())
        expect r.lowered == false
        expect r.reason == "unknown"

# ============================================================================
# SHA-256 / CRC32 / PMULL on full crypto caps
# ============================================================================

describe "lower_cipher_intrinsic_aarch64 — SHA256 / CRC32 / CLMUL on full caps":
    it "crypto_sha256_rnds2 emits 8 bytes (SHA256H+SHA256H2) when has_sha2":
        var r = lower_cipher_intrinsic_aarch64("crypto_sha256_rnds2", [0, 1, 2], caps_full_crypto())
        expect r.lowered == true
        expect r.bytes.len() == 8

    it "crc32_u8 lowers when has_crc32":
        var r = lower_cipher_intrinsic_aarch64("crc32_u8", [0, 1, 2], caps_full_crypto())
        expect r.lowered == true
        expect r.bytes.len() == 4

    it "crc32_u32 lowers when has_crc32":
        var r = lower_cipher_intrinsic_aarch64("crc32_u32", [0, 1, 2], caps_full_crypto())
        expect r.lowered == true
        expect r.bytes.len() == 4

    it "crc32_u64 lowers when has_crc32":
        var r = lower_cipher_intrinsic_aarch64("crc32_u64", [0, 1, 2], caps_full_crypto())
        expect r.lowered == true
        expect r.bytes.len() == 4

    it "clmul_lo emits PMULL when has_pmull":
        var r = lower_cipher_intrinsic_aarch64("clmul_lo", [0, 1, 2], caps_full_crypto())
        expect r.lowered == true
        expect r.bytes.len() == 4

    it "clmul_hi emits PMULL2 when has_pmull":
        var r = lower_cipher_intrinsic_aarch64("clmul_hi", [0, 1, 2], caps_full_crypto())
        expect r.lowered == true
        expect r.bytes.len() == 4

# ============================================================================
# Bad arity -> reason="bad-arity"
# ============================================================================

describe "lower_cipher_intrinsic_aarch64 — arity checking":
    it "crypto_aes_round with 3 args returns bad-arity":
        var r = lower_cipher_intrinsic_aarch64("crypto_aes_round", [0, 1, 2], caps_aes_only())
        expect r.lowered == false
        expect r.reason == "bad-arity"

    it "clmul_lo with 2 args returns bad-arity":
        var r = lower_cipher_intrinsic_aarch64("clmul_lo", [0, 1], caps_aes_only())
        expect r.lowered == false
        expect r.reason == "bad-arity"

describe "lower_cipher_intrinsic_aarch64 — portable bit/matrix scaffolding":
    it "bit_bswap lowers on capable caps":
        var r = lower_cipher_intrinsic_aarch64("bit_bswap", [0, 1], caps_full_crypto())
        expect r.lowered == true
        expect r.bytes.len() == 4

    it "bit_clz lowers on capable caps":
        var r = lower_cipher_intrinsic_aarch64("bit_clz", [0, 1], caps_full_crypto())
        expect r.lowered == true
        expect r.bytes.len() == 4

    it "bit_ctz lowers on capable caps":
        var r = lower_cipher_intrinsic_aarch64("bit_ctz", [0, 1], caps_full_crypto())
        expect r.lowered == true
        expect r.bytes.len() == 8

    it "bit_bitreverse lowers on sve2-capable caps":
        var r = lower_cipher_intrinsic_aarch64("bit_bitreverse", [0, 1], caps_sve2())
        expect r.lowered == true
        expect r.bytes.len() == 4

    it "bit_popcount stays on the current non-direct path on capable caps":
        var r = lower_cipher_intrinsic_aarch64("bit_popcount", [0, 1], caps_full_crypto())
        expect r.lowered == false
        expect r.reason == "unknown"

    it "bit_clz with 1 arg returns bad-arity":
        var r = lower_cipher_intrinsic_aarch64("bit_clz", [0], caps_full_crypto())
        expect r.lowered == false
        expect r.reason == "bad-arity"

    it "bit_ctz with 1 arg returns bad-arity":
        var r = lower_cipher_intrinsic_aarch64("bit_ctz", [0], caps_full_crypto())
        expect r.lowered == false
        expect r.reason == "bad-arity"

    it "bit_bitreverse with 1 arg returns bad-arity":
        var r = lower_cipher_intrinsic_aarch64("bit_bitreverse", [0], caps_sve2())
        expect r.lowered == false
        expect r.reason == "bad-arity"

    it "matrix_dot is recognised and returns unimplemented on capable caps":
        var r = lower_cipher_intrinsic_aarch64("matrix_dot", [0, 1], caps_full_crypto())
        expect r.lowered == false
        expect r.reason == "unimplemented"