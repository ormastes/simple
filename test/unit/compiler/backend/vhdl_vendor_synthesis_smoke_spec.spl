# Optional VHDL vendor synthesis smoke coverage.
#
# This file lives outside test/system because the repository ignores any
# path component named "system". Keep opt-in skip behavior trackable here.

use std.spec

extern fn rt_env_get(key: text) -> text
extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_exists(path: text) -> bool
extern fn rt_dir_create(path: text, recursive: bool) -> bool

fn env_value(name: text) -> text:
    rt_env_get(name) ?? ""

fn vendor_smoke_enabled() -> bool:
    env_value("SIMPLE_VHDL_VENDOR_SMOKE") == "1"

fn selected_vendor() -> text:
    val requested_vendor = env_value("SIMPLE_VHDL_VENDOR")
    if requested_vendor != "":
        return requested_vendor
    "ghdl"

fn vendor_smoke_report_path(vendor: text) -> text:
    val override_path = env_value("SIMPLE_VHDL_VENDOR_REPORT_PATH")
    if override_path != "":
        return override_path
    "build/vhdl/vendor-smoke/" + vendor + "-report.sdn"

fn vendor_smoke_log_path(vendor: text) -> text:
    val override_path = env_value("SIMPLE_VHDL_VENDOR_LOG_PATH")
    if override_path != "":
        return override_path
    "build/vhdl/vendor-smoke/" + vendor + ".log"

fn vendor_smoke_vhdl_path(vendor: text) -> text:
    "build/vhdl/vendor-smoke/" + vendor + "-smoke.vhdl"

fn selected_vendor_tool(vendor: text) -> text:
    if vendor == "vivado":
        "vivado"
    elif vendor == "quartus":
        "quartus_sh"
    elif vendor == "yosys":
        "yosys"
    else:
        "ghdl"

fn tool_available(name: text) -> bool:
    val probe = "if command -v " + name + " >/dev/null 2>&1; then echo FOUND; else echo MISSING; fi"
    val (stdout, _stderr, _code) = rt_process_run("/bin/sh", ["-c", probe])
    stdout == "FOUND\n"

fn shell_write_text(path: text, content: text) -> bool:
    val (stdout, _stderr, _code) = rt_process_run("/bin/sh", ["-c", "if mkdir -p build/vhdl/vendor-smoke && printf '%s' \"$1\" > \"$2\"; then echo WROTE; else echo WRITE_FAILED; fi", "write_text", content, path])
    stdout == "WROTE\n"

fn shell_read_text(path: text) -> text:
    val (stdout, _stderr, _code) = rt_process_run("/bin/sh", ["-c", "cat \"$1\"", "read_text", path])
    stdout

fn shell_file_exists(path: text) -> bool:
    val (stdout, _stderr, _code) = rt_process_run("/bin/sh", ["-c", "if test -f \"$1\"; then echo EXISTS; else echo MISSING; fi", "exists", path])
    stdout == "EXISTS\n"

fn vendor_smoke_vhdl() -> text:
    """library ieee;
use ieee.std_logic_1164.all;

entity vendor_smoke_top is
    port (
        a : in std_logic;
        b : in std_logic;
        y : out std_logic
    );
end entity vendor_smoke_top;

architecture rtl of vendor_smoke_top is
begin
    y <= a and b;
end architecture rtl;
"""

fn vendor_smoke_command_line(vendor: text, tool: text, vhdl_path: text) -> text:
    if vendor == "vivado":
        tool + " -mode batch -nojournal -nolog -source " + vhdl_path + ".tcl"
    elif vendor == "quartus":
        tool + " --flow compile vendor_smoke_top"
    elif vendor == "yosys":
        tool + " -p read_vhdl " + vhdl_path + "; synth"
    else:
        tool + " --synth --std=08 " + vhdl_path + " -e vendor_smoke_top"

fn disabled_diagnostic(vendor: text, tool: text, report_path: text, log_path: text) -> text:
    "SKIP: status=disabled; SIMPLE_VHDL_VENDOR_SMOKE is not 1; vendor=" + vendor + "; tool=" + tool + "; report_path=" + report_path + "; log_path=" + log_path

fn missing_tool_diagnostic(vendor: text, tool: text, report_path: text, log_path: text) -> text:
    "SKIP: status=missing-tool; selected VHDL vendor tool is missing: " + tool + "; vendor=" + vendor + "; report_path=" + report_path + "; log_path=" + log_path

fn ready_diagnostic(vendor: text, tool: text, report_path: text, log_path: text) -> text:
    "READY: selected VHDL vendor tool is available: " + tool + "; vendor=" + vendor + "; report_path=" + report_path + "; log_path=" + log_path

fn write_vendor_sidecar(vendor: text, vhdl_path: text, report_path: text):
    if vendor == "vivado":
        val tcl_path = vhdl_path + ".tcl"
        val tcl = "read_vhdl " + vhdl_path + "\nsynth_design -top vendor_smoke_top\nreport_utilization -file " + report_path + "\nquit\n"
        expect(shell_write_text(tcl_path, tcl)).to_equal(true)

fn run_vendor_smoke(vendor: text, tool: text, vhdl_path: text, report_path: text, log_path: text, command_line: text) -> i64:
    rt_dir_create("build/vhdl/vendor-smoke", true)
    expect(shell_write_text(vhdl_path, vendor_smoke_vhdl())).to_equal(true)
    write_vendor_sidecar(vendor, vhdl_path, report_path)
    val (stdout, stderr, code) = if vendor == "vivado":
        rt_process_run(tool, ["-mode", "batch", "-nojournal", "-nolog", "-source", vhdl_path + ".tcl"])
    elif vendor == "quartus":
        rt_process_run(tool, ["--flow", "compile", "vendor_smoke_top"])
    elif vendor == "yosys":
        rt_process_run(tool, ["-p", "read_vhdl " + vhdl_path + "; synth"])
    else:
        rt_process_run(tool, ["--synth", "--std=08", vhdl_path, "-e", "vendor_smoke_top"])
    val log_text = "command: " + command_line + "\nexit_code: {code}\nstdout:\n" + stdout + "\nstderr:\n" + stderr
    val report_text = "status: executed\nvendor: " + vendor + "\ntool: " + tool + "\ncommand: " + command_line + "\nexit_code: {code}\nvhdl_path: " + vhdl_path + "\nlog_path: " + log_path + "\n"
    expect(shell_write_text(log_path, log_text)).to_equal(true)
    expect(shell_write_text(report_path, report_text)).to_equal(true)
    code

describe "VHDL vendor synthesis smoke":
    it "skips clearly when vendor smoke is disabled":
        val vendor = selected_vendor()
        val tool = selected_vendor_tool(vendor)
        val report_path = vendor_smoke_report_path(vendor)
        val log_path = vendor_smoke_log_path(vendor)
        if not vendor_smoke_enabled():
            val diagnostic = disabled_diagnostic(vendor, tool, report_path, log_path)
            print diagnostic
            expect(diagnostic).to_contain("SIMPLE_VHDL_VENDOR_SMOKE is not 1")
            expect(diagnostic).to_contain("status=disabled")
            expect(report_path).to_contain("build/vhdl/vendor-smoke/")
            expect(log_path).to_contain("build/vhdl/vendor-smoke/")
        else:
            expect(vendor_smoke_enabled()).to_equal(true)

    it "maps supported vendor names to executable tools":
        expect(selected_vendor_tool("vivado")).to_equal("vivado")
        expect(selected_vendor_tool("quartus")).to_equal("quartus_sh")
        expect(selected_vendor_tool("yosys")).to_equal("yosys")
        expect(selected_vendor_tool("")).to_equal("ghdl")
        expect(selected_vendor_tool("unknown")).to_equal("ghdl")

    it "reports deterministic vendor smoke output paths and command":
        val vendor = selected_vendor()
        val tool = selected_vendor_tool(vendor)
        val vhdl_path = vendor_smoke_vhdl_path(vendor)
        val report_path = vendor_smoke_report_path(vendor)
        val log_path = vendor_smoke_log_path(vendor)
        val command_line = vendor_smoke_command_line(vendor, tool, vhdl_path)
        val diagnostic = ready_diagnostic(vendor, tool, report_path, log_path)
        expect(report_path).to_contain("-report.sdn")
        expect(log_path).to_contain(".log")
        expect(diagnostic).to_contain("report_path=")
        expect(diagnostic).to_contain("log_path=")
        expect(command_line).to_contain(tool)
        expect(command_line).to_contain(vhdl_path)

    it "skips clearly when the selected vendor tool is missing":
        val vendor = selected_vendor()
        val tool = selected_vendor_tool(vendor)
        val report_path = vendor_smoke_report_path(vendor)
        val log_path = vendor_smoke_log_path(vendor)
        val available = tool_available(tool)
        if not vendor_smoke_enabled():
            val diagnostic = disabled_diagnostic(vendor, tool, report_path, log_path)
            print diagnostic
            expect(diagnostic).to_contain("status=disabled")
        elif available != true:
            val diagnostic = missing_tool_diagnostic(vendor, tool, report_path, log_path)
            print diagnostic
            expect(diagnostic).to_contain("status=missing-tool")
            expect(diagnostic).to_contain(tool)
        else:
            expect(available).to_equal(true)

    it "captures command report and log when vendor smoke is enabled":
        val vendor = selected_vendor()
        val tool = selected_vendor_tool(vendor)
        val vhdl_path = vendor_smoke_vhdl_path(vendor)
        val report_path = vendor_smoke_report_path(vendor)
        val log_path = vendor_smoke_log_path(vendor)
        val command_line = vendor_smoke_command_line(vendor, tool, vhdl_path)
        val available = tool_available(tool)
        if not vendor_smoke_enabled():
            val diagnostic = disabled_diagnostic(vendor, tool, report_path, log_path)
            print diagnostic
            expect(diagnostic).to_contain("status=disabled")
        elif available != true:
            val diagnostic = missing_tool_diagnostic(vendor, tool, report_path, log_path)
            print diagnostic
            expect(diagnostic).to_contain("status=missing-tool")
        else:
            val code = run_vendor_smoke(vendor, tool, vhdl_path, report_path, log_path, command_line)
            val diagnostic = "DONE: status=executed; vendor=" + vendor + "; tool=" + tool + "; exit_code={code}; report_path=" + report_path + "; log_path=" + log_path
            print diagnostic
            expect(code).to_equal(0)
            expect(shell_file_exists(report_path)).to_equal(true)
            expect(shell_file_exists(log_path)).to_equal(true)
            expect(shell_read_text(report_path)).to_contain("command: " + command_line)
            expect(shell_read_text(report_path)).to_contain("exit_code: 0")
            expect(shell_read_text(log_path)).to_contain("stdout:")
            expect(shell_read_text(log_path)).to_contain("stderr:")
