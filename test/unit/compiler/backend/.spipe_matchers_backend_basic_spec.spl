use compiler.backend.{MirTestBuilder, new_builder, simple_arithmetic, BackendTarget}

describe "Backend Basic":
    it "creates a builder with default metadata":
        val builder = new_builder("basic")

        expect builder.test_name == "basic"
        expect builder.instructions.len() == 0
        expect builder.next_vreg == 0

    it "tracks registers and preserves backend selection":
        val builder = new_builder("tracked")
        builder.add_const_int(0, 42)
        builder.add_const_int(3, 7)
        builder.add_add(4, 0, 3)
        builder.only_backend(BackendTarget.Interpreter)

        val test_case = builder.build()

        expect builder.next_vreg == 5
        expect test_case.name == "tracked"
        expect test_case.instructions.len() == 3
        expect test_case.expected_backends.len() == 1
        expect test_case.expected_backends[0] == BackendTarget.Interpreter

    it "builds the canned arithmetic helper":
        val test_case = simple_arithmetic()

        expect test_case.name == "simple_arithmetic"
        expect test_case.instructions.len() == 4
        expect test_case.expected_backends.len() == 3
        expect test_case.expected_backends[0] == BackendTarget.Cranelift