# Literal Converter Specification
#
# @req STUB-003
# @cover src/compiler/70.backend/backend/common/literal_converter.spl
#
# Verifies that LiteralConverter produces correct Value enum variants
# for array, tuple, and dict literals (previously returned empty stubs).

use std.test.*
use compiler.backend.backend_types.{Value}
use compiler.backend.backend.common.literal_converter.{LiteralConverter}

describe "LiteralConverter":

    context "array conversion (STUB-003 fix)":
        it "returns Value.Array with all elements":
            val elements = [Value.Int(1), Value.Int(2), Value.Int(3)]
            val result = LiteralConverter.convert_array(elements)
            match result:
                case Value.Array(elems):
                    expect elems.len() == 3
                case _:
                    expect "not Array" == "Array"

        it "handles empty array":
            val result = LiteralConverter.convert_array([])
            match result:
                case Value.Array(elems):
                    expect elems.len() == 0
                case _:
                    expect "not Array" == "Array"

    context "tuple conversion (STUB-003 fix)":
        it "returns Value.Tuple with all elements":
            val elements = [Value.String("a"), Value.Int(42)]
            val result = LiteralConverter.convert_tuple(elements)
            match result:
                case Value.Tuple(elems):
                    expect elems.len() == 2
                case _:
                    expect "not Tuple" == "Tuple"

    context "dict conversion (STUB-003 fix)":
        it "returns Value.Dict with string keys":
            val pairs = [(Value.String("x"), Value.Int(1)), (Value.String("y"), Value.Int(2))]
            val result = LiteralConverter.convert_dict(pairs)
            match result:
                case Value.Dict(entries):
                    expect entries.len() == 2
                case _:
                    expect "not Dict" == "Dict"

        it "handles empty dict":
            val result = LiteralConverter.convert_dict([])
            match result:
                case Value.Dict(entries):
                    expect entries.len() == 0
                case _:
                    expect "not Dict" == "Dict"