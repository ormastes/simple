# x86_64 Crypto Encoder — Golden Byte Tests
#
# Feature ID: #COMPILER-BACKEND-ENCODE-X86-CRYPTO
# Category:   Compiler | Backend | x86_64 Byte Emitter
# Status:     Schema contract — byte golden tests for AES-NI, SHA-NI, CRC32, PCLMULQDQ
#
# ALL byte goldens verified against Intel SDM Vol 2 opcode tables.
#
# Interpreter-mode note (per .claude/rules/testing.md):
#   The test runner in interpreter mode only verifies file loading and
#   describe/it block reachability.  The assertions inside it-blocks are not
#   executed.  Compiled-mode execution will exercise them.

use compiler.backend.native.encode_x86_64_crypto.{
    emit_aesenc,
    emit_aesenclast,
    emit_aesdec,
    emit_aesdeclast,
    emit_aesimc,
    emit_aeskeygenassist,
    emit_sha256rnds2,
    emit_sha256msg1,
    emit_sha256msg2,
    emit_crc32_r32_r8,
    emit_crc32_r32_r32,
    emit_crc32_r64_r64,
    emit_pclmulqdq
}

# ============================================================================
# AES-NI Instructions (66 0F 38 xx /r)
# ============================================================================

describe "x86 AES-NI encoder — golden bytes":
    it "emit_aesenc(0,0) → [0x66, 0x0F, 0x38, 0xDC, 0xC0]":
        val bytes = emit_aesenc(0, 0)
        expect bytes.len() == 5
        expect bytes[0] == 0x66
        expect bytes[1] == 0x0F
        expect bytes[2] == 0x38
        expect bytes[3] == 0xDC
        expect bytes[4] == 0xC0

    it "emit_aesenc(8,0) → [0x66, 0x44, 0x0F, 0x38, 0xDC, 0xC0] (REX.R for dst>=8)":
        val bytes = emit_aesenc(8, 0)
        expect bytes.len() == 6
        expect bytes[0] == 0x66
        expect bytes[1] == 0x44
        expect bytes[2] == 0x0F
        expect bytes[3] == 0x38
        expect bytes[4] == 0xDC
        expect bytes[5] == 0xC0

    it "emit_aesenclast(0,0) → [0x66, 0x0F, 0x38, 0xDD, 0xC0]":
        val bytes = emit_aesenclast(0, 0)
        expect bytes.len() == 5
        expect bytes[0] == 0x66
        expect bytes[1] == 0x0F
        expect bytes[2] == 0x38
        expect bytes[3] == 0xDD
        expect bytes[4] == 0xC0

    it "emit_aesdec(0,0) → [0x66, 0x0F, 0x38, 0xDE, 0xC0]":
        val bytes = emit_aesdec(0, 0)
        expect bytes.len() == 5
        expect bytes[0] == 0x66
        expect bytes[1] == 0x0F
        expect bytes[2] == 0x38
        expect bytes[3] == 0xDE
        expect bytes[4] == 0xC0

    it "emit_aesdeclast(0,0) → [0x66, 0x0F, 0x38, 0xDF, 0xC0]":
        val bytes = emit_aesdeclast(0, 0)
        expect bytes.len() == 5
        expect bytes[0] == 0x66
        expect bytes[1] == 0x0F
        expect bytes[2] == 0x38
        expect bytes[3] == 0xDF
        expect bytes[4] == 0xC0

    it "emit_aesimc(0,0) → [0x66, 0x0F, 0x38, 0xDB, 0xC0]":
        val bytes = emit_aesimc(0, 0)
        expect bytes.len() == 5
        expect bytes[0] == 0x66
        expect bytes[1] == 0x0F
        expect bytes[2] == 0x38
        expect bytes[3] == 0xDB
        expect bytes[4] == 0xC0

    it "emit_aeskeygenassist(0,0,0x10) → [0x66, 0x0F, 0x3A, 0xDF, 0xC0, 0x10]":
        val bytes = emit_aeskeygenassist(0, 0, 0x10)
        expect bytes.len() == 6
        expect bytes[0] == 0x66
        expect bytes[1] == 0x0F
        expect bytes[2] == 0x3A
        expect bytes[3] == 0xDF
        expect bytes[4] == 0xC0
        expect bytes[5] == 0x10

# ============================================================================
# SHA-NI Instructions (0F 38 xx /r)
# ============================================================================

describe "x86 SHA-NI encoder — golden bytes":
    it "emit_sha256rnds2(0,0) → [0x0F, 0x38, 0xCB, 0xC0]":
        val bytes = emit_sha256rnds2(0, 0)
        expect bytes.len() == 4
        expect bytes[0] == 0x0F
        expect bytes[1] == 0x38
        expect bytes[2] == 0xCB
        expect bytes[3] == 0xC0

    it "emit_sha256msg1(0,0) → [0x0F, 0x38, 0xCC, 0xC0]":
        val bytes = emit_sha256msg1(0, 0)
        expect bytes.len() == 4
        expect bytes[0] == 0x0F
        expect bytes[1] == 0x38
        expect bytes[2] == 0xCC
        expect bytes[3] == 0xC0

    it "emit_sha256msg2(0,0) → [0x0F, 0x38, 0xCD, 0xC0]":
        val bytes = emit_sha256msg2(0, 0)
        expect bytes.len() == 4
        expect bytes[0] == 0x0F
        expect bytes[1] == 0x38
        expect bytes[2] == 0xCD
        expect bytes[3] == 0xC0

# ============================================================================
# CRC32 Instructions (F2 0F 38 Fx /r)
# ============================================================================

describe "x86 CRC32 encoder — golden bytes":
    it "emit_crc32_r32_r32(0,0) → [0xF2, 0x0F, 0x38, 0xF1, 0xC0]":
        val bytes = emit_crc32_r32_r32(0, 0)
        expect bytes.len() == 5
        expect bytes[0] == 0xF2
        expect bytes[1] == 0x0F
        expect bytes[2] == 0x38
        expect bytes[3] == 0xF1
        expect bytes[4] == 0xC0

    it "emit_crc32_r64_r64(0,0) → [0xF2, 0x48, 0x0F, 0x38, 0xF1, 0xC0]":
        val bytes = emit_crc32_r64_r64(0, 0)
        expect bytes.len() == 6
        expect bytes[0] == 0xF2
        expect bytes[1] == 0x48
        expect bytes[2] == 0x0F
        expect bytes[3] == 0x38
        expect bytes[4] == 0xF1
        expect bytes[5] == 0xC0

# ============================================================================
# PCLMULQDQ (66 0F 3A 44 /r ib)
# ============================================================================

describe "x86 PCLMULQDQ encoder":
    it "emit_pclmulqdq(0,0,0x00) → [0x66, 0x0F, 0x3A, 0x44, 0xC0, 0x00]":
        val bytes = emit_pclmulqdq(0, 0, 0x00)
        expect bytes.len() == 6
        expect bytes[0] == 0x66
        expect bytes[1] == 0x0F
        expect bytes[2] == 0x3A
        expect bytes[3] == 0x44
        expect bytes[4] == 0xC0
        expect bytes[5] == 0x00

    it "emit_pclmulqdq(0,0,0x11) → [0x66, 0x0F, 0x3A, 0x44, 0xC0, 0x11]":
        val bytes = emit_pclmulqdq(0, 0, 0x11)
        expect bytes.len() == 6
        expect bytes[0] == 0x66
        expect bytes[1] == 0x0F
        expect bytes[2] == 0x3A
        expect bytes[3] == 0x44
        expect bytes[4] == 0xC0
        expect bytes[5] == 0x11