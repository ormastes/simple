use app.build.{scan_layout_annotations, get_layout_for_struct, layout_scanner_reset}
use std.unsafe.layout.{layout_info_has_repr, layout_info_field_is_volatile}

describe "Layout Scanner":
    it "captures repr annotations and struct entries":
        layout_scanner_reset()
        scan_layout_annotations(
            "# @repr(C, packed)\nstruct Dma:\n    ctrl: u32\n"
        )

        val info = get_layout_for_struct("Dma")

        expect info == nil == false
        expect layout_info_has_repr(info, "C") == true
        expect layout_info_has_repr(info, "packed") == true

    it "tracks volatile fields without leaking state":
        layout_scanner_reset()
        scan_layout_annotations(
            "struct Regs:\n    # @volatile\n    status: u32\n    addr: u64\n"
        )

        val info = get_layout_for_struct("Regs")

        expect info == nil == false
        expect layout_info_field_is_volatile(info, "status") == true
        expect layout_info_field_is_volatile(info, "addr") == false

    it "keeps multiple structs isolated and returns nil for missing entries":
        layout_scanner_reset()
        scan_layout_annotations(
            "struct A:\n    x: i64\n\n# @repr(C)\nstruct B:\n    y: u32\n"
        )

        val info_a = get_layout_for_struct("A")
        val info_b = get_layout_for_struct("B")
        val missing = get_layout_for_struct("Missing")

        expect info_a == nil == false
        expect info_b == nil == false
        expect layout_info_has_repr(info_a, "C") == false
        expect layout_info_has_repr(info_b, "C") == true
        expect missing == nil == true