use compiler.backend.{LlvmIRBuilder, LlvmTargetTriple}
use compiler.backend.backend_types.{CodegenTarget}

fn new_builder() -> LlvmIRBuilder:
    LlvmIRBuilder.create("demo.module", LlvmTargetTriple.from_target(CodegenTarget.X86_64))

describe "LLVM IR Builder":
    it "emits the module header from the selected target":
        val builder = new_builder()

        builder.emit_module_header()

        expect builder.instructions.len() == 4
        expect builder.instructions[0] == "; ModuleID = 'demo.module'"
        expect builder.instructions[1] == "source_filename = \"demo.module.spl\""
        expect (builder.instructions[2]).contains("target datalayout = \"")
        expect (builder.instructions[3]).contains("target triple = \"")

    it "creates fresh locals and wraps a function body":
        val builder = new_builder()
        val local0 = builder.fresh_local()
        val local1 = builder.fresh_local()

        expect local0 == "%0"
        expect local1 == "%1"

        builder.start_function("add_numbers", ["i64 %lhs", "i64 %rhs"], "i64")
        builder.emit_ret("i64", "%lhs")
        builder.end_function()

        expect builder.instructions[0] == "define i64 @add_numbers(i64 %lhs, i64 %rhs) nounwind {"
        expect builder.instructions[1] == "  ret i64 %lhs"
        expect builder.instructions[2] == "}"
        expect builder.instructions[3] == ""

    it "emits direct arithmetic, memory, and comparison instructions":
        val builder = new_builder()

        builder.emit_add("%2", "i64", "%0", "%1")
        builder.emit_load("%3", "i64", "%ptr")
        builder.emit_store("i64", "%3", "%ptr")
        builder.emit_icmp_eq("%4", "i64", "%3", "%2")

        expect builder.instructions[0] == "  %2 = add i64 %0, %1"
        expect builder.instructions[1] == "  %3 = load i64, ptr %ptr, align 8"
        expect builder.instructions[2] == "  store i64 %3, ptr %ptr, align 8"
        expect builder.instructions[3] == "  %4 = icmp eq i64 %3, %2"