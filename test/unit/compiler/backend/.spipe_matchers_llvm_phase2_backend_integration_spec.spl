use std.spec.{describe, it, expect}
use compiler.backend.backend.{escape_llvm_string, escaped_string_byte_len, ensure_float_literal}

describe "LLVM phase-2 backend integration scaffolding":
    it "exercises exported LLVM string helpers through the backend surface":
        val raw = "line1\n\t\"quoted\"\\tail"
        val escaped = escape_llvm_string(raw)

        expect escaped == "line1\\0A\\09\\22quoted\\22\\5Ctail"
        expect escaped_string_byte_len(raw) == raw.len()
        expect escaped.contains("\\0A") == true
        expect escaped.contains("\\22") == true
        expect escaped.contains("\\5C") == true

    it "keeps float literal normalization minimal for current LLVM IR emission":
        expect ensure_float_literal("3") == "3.0"
        expect ensure_float_literal("-7") == "-7.0"
        expect ensure_float_literal("3.25") == "3.25"
        expect ensure_float_literal("1e9") == "1e9"
        expect ensure_float_literal("nan") == "nan"