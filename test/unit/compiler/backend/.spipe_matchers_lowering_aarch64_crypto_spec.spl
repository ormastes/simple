"""AArch64 cipher intrinsic lowering — golden byte-level tests.

Tests lower_cipher_intrinsic_aarch64 end-to-end against known byte sequences.
Caps have all AArch64 crypto extensions enabled (has_aes, has_sha2, has_pmull,
has_crc32, has_neon).
Golden bytes are AArch64 instruction words stored little-endian (4 bytes each):
  AESE  Vd.16B,Vn.16B : 0x4E284800 | (Rn<<5) | Rd
  AESD  Vd.16B,Vn.16B : 0x4E285800 | (Rn<<5) | Rd
  AESMC Vd.16B,Vn.16B : 0x4E286800 | (Rn<<5) | Rd
  AESIMC Vd.16B,Vn.16B: 0x4E287800 | (Rn<<5) | Rd
  SHA256H  Qd,Qn,Vm.4S: 0x5E004000 | (Rm<<16) | (Rn<<5) | Rd
  SHA256H2 Qd,Qn,Vm.4S: 0x5E005000 | (Rm<<16) | (Rn<<5) | Rd
  CRC32B Wd,Wn,Wm     : 0x1AC04000 | (Rm<<16) | (Rn<<5) | Rd
  CRC32W Wd,Wn,Wm     : 0x1AC04800 | (Rm<<16) | (Rn<<5) | Rd
  CRC32X Wd,Wn,Xm     : 0x9AC04C00 | (Rm<<16) | (Rn<<5) | Rd
  PMULL  Vd.1Q,Vn.1D,Vm.1D: 0x0EE0E000 | (Rm<<16) | (Rn<<5) | Rd
  PMULL2 Vd.1Q,Vn.2D,Vm.2D: 0x4EE0E000 | (Rm<<16) | (Rn<<5) | Rd
All tests use rd=1, rn=2, rm=3 as representative registers.
"""

use std.spipe.*
use compiler.backend.lowering.intrinsic_lowering_aarch64.{lower_cipher_intrinsic_aarch64}
use compiler.backend.lowering.intrinsic_lowering_x86.{LoweringResult}
use compiler.backend.feature_caps.{Aarch64Caps}

fn _list_hex(bytes: [i64]) -> text:
    val hex_chars = "0123456789abcdef"
    var s: text = ""
    var i: u64 = 0
    while i < bytes.len().to_u64():
        val b = bytes[i.to_i64()]
        s = s + hex_chars.char_at(((b / 16) % 16).to_u64())
        s = s + hex_chars.char_at((b % 16).to_u64())
        i = i + 1
    s

# All AArch64 crypto extensions enabled
val TEST_AARCH64_CAPS = Aarch64Caps(
    has_aes: true,
    has_sha2: true,
    has_sha3: false,
    has_pmull: true,
    has_crc32: true,
    has_neon: true,
    has_sve2: false
)

describe "AArch64 cipher intrinsic lowering — AES encrypt rounds":

    it "AESE+AESMC V1,V2 (crypto_aes_round [1,2]) — full encrypt round (8 bytes)":
        val result = lower_cipher_intrinsic_aarch64("crypto_aes_round", [1, 2], TEST_AARCH64_CAPS)
        expect result.lowered == true
        expect result.reason == ""
        expect _list_hex(result.bytes) == "4148284e2168284e"

    it "crypto_aes_round output length is 8 bytes":
        val result = lower_cipher_intrinsic_aarch64("crypto_aes_round", [1, 2], TEST_AARCH64_CAPS)
        expect result.bytes.len() == 8

    it "AESE V1,V2 (crypto_aes_round_last [1,2]) — final encrypt round (4 bytes)":
        val result = lower_cipher_intrinsic_aarch64("crypto_aes_round_last", [1, 2], TEST_AARCH64_CAPS)
        expect result.lowered == true
        expect result.reason == ""
        expect _list_hex(result.bytes) == "4148284e"

    it "crypto_aes_round_last output length is 4 bytes":
        val result = lower_cipher_intrinsic_aarch64("crypto_aes_round_last", [1, 2], TEST_AARCH64_CAPS)
        expect result.bytes.len() == 4

describe "AArch64 cipher intrinsic lowering — AES decrypt rounds":

    it "AESD+AESIMC V1,V2 (crypto_aes_inv_round [1,2]) — full decrypt round (8 bytes)":
        val result = lower_cipher_intrinsic_aarch64("crypto_aes_inv_round", [1, 2], TEST_AARCH64_CAPS)
        expect result.lowered == true
        expect result.reason == ""
        expect _list_hex(result.bytes) == "4158284e2178284e"

    it "crypto_aes_inv_round output length is 8 bytes":
        val result = lower_cipher_intrinsic_aarch64("crypto_aes_inv_round", [1, 2], TEST_AARCH64_CAPS)
        expect result.bytes.len() == 8

    it "AESD V1,V2 (crypto_aes_inv_round_last [1,2]) — final decrypt round (4 bytes)":
        val result = lower_cipher_intrinsic_aarch64("crypto_aes_inv_round_last", [1, 2], TEST_AARCH64_CAPS)
        expect result.lowered == true
        expect result.reason == ""
        expect _list_hex(result.bytes) == "4158284e"

    it "crypto_aes_inv_round_last output length is 4 bytes":
        val result = lower_cipher_intrinsic_aarch64("crypto_aes_inv_round_last", [1, 2], TEST_AARCH64_CAPS)
        expect result.bytes.len() == 4

describe "AArch64 cipher intrinsic lowering — SHA-256":

    it "SHA256H+SHA256H2 Q1,Q2,V3 (crypto_sha256_rnds2 [1,2,3]) — sha2 rounds (8 bytes)":
        val result = lower_cipher_intrinsic_aarch64("crypto_sha256_rnds2", [1, 2, 3], TEST_AARCH64_CAPS)
        expect result.lowered == true
        expect result.reason == ""
        expect _list_hex(result.bytes) == "4140035e4150035e"

    it "crypto_sha256_rnds2 output length is 8 bytes":
        val result = lower_cipher_intrinsic_aarch64("crypto_sha256_rnds2", [1, 2, 3], TEST_AARCH64_CAPS)
        expect result.bytes.len() == 8

describe "AArch64 cipher intrinsic lowering — CRC32":

    it "CRC32B W1,W2,W3 (crc32_u8 [1,2,3]) — byte accumulate (4 bytes)":
        val result = lower_cipher_intrinsic_aarch64("crc32_u8", [1, 2, 3], TEST_AARCH64_CAPS)
        expect result.lowered == true
        expect result.reason == ""
        expect _list_hex(result.bytes) == "4140c31a"

    it "crc32_u8 output length is 4 bytes":
        val result = lower_cipher_intrinsic_aarch64("crc32_u8", [1, 2, 3], TEST_AARCH64_CAPS)
        expect result.bytes.len() == 4

    it "CRC32W W1,W2,W3 (crc32_u32 [1,2,3]) — word accumulate (4 bytes)":
        val result = lower_cipher_intrinsic_aarch64("crc32_u32", [1, 2, 3], TEST_AARCH64_CAPS)
        expect result.lowered == true
        expect result.reason == ""
        expect _list_hex(result.bytes) == "4148c31a"

    it "crc32_u32 output length is 4 bytes":
        val result = lower_cipher_intrinsic_aarch64("crc32_u32", [1, 2, 3], TEST_AARCH64_CAPS)
        expect result.bytes.len() == 4

    it "CRC32X W1,W2,X3 (crc32_u64 [1,2,3]) — doubleword accumulate (4 bytes)":
        val result = lower_cipher_intrinsic_aarch64("crc32_u64", [1, 2, 3], TEST_AARCH64_CAPS)
        expect result.lowered == true
        expect result.reason == ""
        expect _list_hex(result.bytes) == "414cc39a"

    it "crc32_u64 output length is 4 bytes":
        val result = lower_cipher_intrinsic_aarch64("crc32_u64", [1, 2, 3], TEST_AARCH64_CAPS)
        expect result.bytes.len() == 4

describe "AArch64 cipher intrinsic lowering — CLMUL (PMULL)":

    it "PMULL V1.1Q,V2.1D,V3.1D (clmul_lo [1,2,3]) — polynomial multiply low (4 bytes)":
        val result = lower_cipher_intrinsic_aarch64("clmul_lo", [1, 2, 3], TEST_AARCH64_CAPS)
        expect result.lowered == true
        expect result.reason == ""
        expect _list_hex(result.bytes) == "41e0e30e"

    it "clmul_lo output length is 4 bytes":
        val result = lower_cipher_intrinsic_aarch64("clmul_lo", [1, 2, 3], TEST_AARCH64_CAPS)
        expect result.bytes.len() == 4

    it "PMULL2 V1.1Q,V2.2D,V3.2D (clmul_hi [1,2,3]) — polynomial multiply high (4 bytes)":
        val result = lower_cipher_intrinsic_aarch64("clmul_hi", [1, 2, 3], TEST_AARCH64_CAPS)
        expect result.lowered == true
        expect result.reason == ""
        expect _list_hex(result.bytes) == "41e0e34e"

    it "clmul_hi output length is 4 bytes":
        val result = lower_cipher_intrinsic_aarch64("clmul_hi", [1, 2, 3], TEST_AARCH64_CAPS)
        expect result.bytes.len() == 4

describe "AArch64 cipher intrinsic lowering — failure cases":

    it "unknown intrinsic returns lowered=false, reason=unknown":
        val result = lower_cipher_intrinsic_aarch64("unknown_intrinsic", [0, 0], TEST_AARCH64_CAPS)
        expect result.lowered == false
        expect result.reason == "unknown"

    it "crypto_aes_round with 1 arg returns lowered=false, reason=bad-arity":
        val result = lower_cipher_intrinsic_aarch64("crypto_aes_round", [0], TEST_AARCH64_CAPS)
        expect result.lowered == false
        expect result.reason == "bad-arity"

    it "crypto_sha256_rnds2 with 2 args returns lowered=false, reason=bad-arity":
        val result = lower_cipher_intrinsic_aarch64("crypto_sha256_rnds2", [0, 0], TEST_AARCH64_CAPS)
        expect result.lowered == false
        expect result.reason == "bad-arity"

    it "crc32_u8 with 2 args returns lowered=false, reason=bad-arity":
        val result = lower_cipher_intrinsic_aarch64("crc32_u8", [0, 0], TEST_AARCH64_CAPS)
        expect result.lowered == false
        expect result.reason == "bad-arity"