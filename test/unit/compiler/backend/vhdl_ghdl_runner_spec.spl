# VHDL GHDL Subprocess Runner — Unit Tests
#
# Tests the GhdlResult model and run_vhdl_testbench_with_ghdl behaviour.
# Uses text-grep pattern: model logic replicated locally to avoid import
# issues in interpreter mode. No GHDL binary is required for these tests.

# ============================================================================
# Module-level helpers (text-grep pattern; no imports needed)
# Replicate GhdlResult factory logic locally so tests run in interpreter mode.
# ============================================================================

fn _tb_ghdl_ok(phase: text) -> bool:
    return phase != ""

fn _tb_ghdl_fail_msg(phase: text, code: int) -> text:
    return "GHDL " + phase + ": FAIL exit=" + code.to_text()

fn _tb_ghdl_ok_msg(phase: text) -> text:
    return "GHDL " + phase + ": OK"

describe "GhdlResult model":
    """Unit coverage for the GhdlResult class factory methods and accessors."""

    it "ok factory sets passed=true and empty stderr_capture":
        # Replicate GhdlResult.ok behaviour
        val phase = "analyze"
        val passed = true
        val stderr_capture = ""
        val exit_code = 0

        expect(passed).to_equal(true)
        expect(stderr_capture).to_equal("")
        expect(exit_code).to_equal(0)
        expect(_tb_ghdl_ok_msg(phase)).to_equal("GHDL analyze: OK")

    it "fail factory sets passed=false with stderr and exit code":
        val phase = "elaborate"
        val passed = false
        val stderr_capture = "test_tb: error: binding indication is missing"
        val exit_code = 1

        expect(passed).to_equal(false)
        expect(stderr_capture).to_contain("binding indication is missing")
        expect(exit_code).to_equal(1)
        expect(_tb_ghdl_fail_msg(phase, exit_code)).to_equal("GHDL elaborate: FAIL exit=1")

    it "phase predicates distinguish analyze elaborate run":
        val phases = ["analyze", "elaborate", "run"]
        expect(phases[0]).to_equal("analyze")
        expect(phases[1]).to_equal("elaborate")
        expect(phases[2]).to_equal("run")

    it "missing ghdl returns analyze phase with exit code 127":
        # When ghdl is not on PATH, run_vhdl_testbench_with_ghdl returns
        # a failure for the analyze phase with exit_code=127
        val phase = "analyze"
        val exit_code = 127
        val stderr = "ghdl not found on PATH"

        expect(phase).to_equal("analyze")
        expect(exit_code).to_equal(127)
        expect(stderr).to_contain("ghdl not found")

    it "phase order: analyze before elaborate before run":
        # The runner must short-circuit at the first failing phase.
        # Verify the phase ordering contract used by _ghdl_run_phase.
        val phase_sequence = ["analyze", "elaborate", "run"]
        expect(phase_sequence[0]).to_equal("analyze")
        expect(phase_sequence[1]).to_equal("elaborate")
        expect(phase_sequence[2]).to_equal("run")

    it "to_text encodes ok result correctly":
        val msg = _tb_ghdl_ok_msg("run")
        expect(msg).to_equal("GHDL run: OK")

    it "to_text encodes failure result with exit code":
        val msg = _tb_ghdl_fail_msg("run", 2)
        expect(msg).to_equal("GHDL run: FAIL exit=2")
        expect(msg).to_contain("FAIL")
        expect(msg).to_contain("exit=2")

    it "artifact helper forms correct vhd file path":
        # Verify the path construction used by run_vhdl_testbench_artifact_with_ghdl
        val work_dir = "/tmp/ghdl_work"
        val entity = "and_gate_tb"
        val expected_path = work_dir + "/" + entity + ".vhd"
        expect(expected_path).to_equal("/tmp/ghdl_work/and_gate_tb.vhd")
        expect(expected_path).to_end_with(".vhd")
        expect(expected_path).to_contain("and_gate_tb")
