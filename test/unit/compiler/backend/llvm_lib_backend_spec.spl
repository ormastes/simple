# LLVM Lib Backend Tests
#
# Tests for the LlvmLib backend (LLVM C API via DynLib).
# Interpreter cannot load std.ffi.llvm module — module-level var with DynLib?
# and Dict literal types cause "variable '_llvm_initialized' not found".
# These tests work in compiled mode only.

describe "LLVM Lib Backend":
    it "skipped":
        skip("interpreter cannot load std.ffi.llvm — module-level var DynLib?/Dict causes semantic error")

