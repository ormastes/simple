use compiler.backend.backend.exhaustiveness_validator.{
    ExhaustivenessValidator,
    CatchAllSeverity
}

fn validator() -> ExhaustivenessValidator:
    ExhaustivenessValidator.new()

describe "Exhaustiveness Validator":
    it "detects catch-all lines and ignores comment-only mentions":
        val subject = validator()

        expect subject.is_catch_all_line("_ => panic!(\"unsupported\")") == true
        expect subject.is_catch_all_line("    foo _ => bar") == true
        expect subject.is_catch_all_line("// _ => documented example") == false

    it "only treats explicit documentation as intentional":
        val subject = validator()

        expect subject.is_intentional_catch_all("// Intentional catch-all for type matching") == true
        expect subject.is_intentional_catch_all("// Type matching only for metadata") == true
        expect subject.is_intentional_catch_all("// Other instructions not yet implemented") == false

    it "keeps undispatched MirInst catch-alls as errors":
        val subject = validator()
        val context = "match inst {\n    MirInst::Foo => handle_foo(),\n    _ => todo!(\"later\")\n}"

        expect subject.determine_severity("backend.rs", context, false) == CatchAllSeverity.Error