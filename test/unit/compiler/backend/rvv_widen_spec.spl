# test/unit/compiler/backend/rvv_widen_spec.spl
#
# Byte-equal golden tests for RVV v1.0 widening/narrowing arithmetic encoder.
# All goldens derived from RISC-V Vector Extension v1.0 spec.
#
# Encoding formula:
#   word = (funct6 * 67108864) + (vm * 33554432) + (vs2 * 1048576)
#        + (vs1 * 32768) + (funct3 * 4096) + (vd * 128) + 87
#
# OPMVV (funct3=2): vwaddu, vwsubu, vwadd, vwsub, vwmul, vwmulu
# OPIVV (funct3=0): vnsrl, vnsra
#
# Test registers: vd=1, vs2=2, vs1=3 (where applicable), vm=1 (unmasked).

use std.spec
use compiler.backend.backend.native.encode_rvv_widen.{
    emit_vwaddu_vv,
    emit_vwsubu_vv,
    emit_vwadd_vv,
    emit_vwsub_vv,
    emit_vnsrl_wv,
    emit_vnsra_wv,
    emit_vwmul_vv,
    emit_vwmulu_vv
}

describe "encode_rvv_widen — vwaddu.vv (widening unsigned add)":
    it "emit_vwaddu_vv vd=0 vs2=0 vs1=0 — zero-register canonical":
        # funct6=0x30,vm=1,vs2=0,vs1=0,funct3=2,vd=0 → word=0xC2002057
        val got = emit_vwaddu_vv(0, 0, 0)
        expect(got.length) to_equal(4)
        expect(got[0]) to_equal(0x57)
        expect(got[1]) to_equal(0x20)
        expect(got[2]) to_equal(0x00)
        expect(got[3]) to_equal(0xC2)

    it "emit_vwaddu_vv vd=1 vs2=2 vs1=3 — non-zero registers":
        # funct6=0x30,vm=1,vs2=2,vs1=3,funct3=2,vd=1 → word=0xC221A0D7
        val got = emit_vwaddu_vv(1, 2, 3)
        expect(got.length) to_equal(4)
        expect(got[0]) to_equal(0xD7)
        expect(got[1]) to_equal(0xA0)
        expect(got[2]) to_equal(0x21)
        expect(got[3]) to_equal(0xC2)

