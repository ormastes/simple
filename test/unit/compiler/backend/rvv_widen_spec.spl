    it "emit_vwsubu_vv vd=1 vs2=2 vs1=3 — non-zero registers":
        # funct6=0x32,vm=1,vs2=2,vs1=3,funct3=2,vd=1 → word=0xCA21A0D7
        val got = emit_vwsubu_vv(1, 2, 3)
        expect(got.length) to_equal(4)
