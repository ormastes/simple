        # funct6=0x2D,vm=1,vs2=2,vs1=3,funct3=0,vd=1 → word=0xB62180D7
        # NOTE: byte[1]=0x80 (not 0xA0) because funct3=0 not 2
        val got = emit_vnsra_wv(1, 2, 3)
