"""
# VHDL Simulation Runner Unit Tests

**Feature IDs:** #VHDL-EMU-001
**Category:** Tooling
**Difficulty:** 2/5
**Status:** In Progress

## Overview

Unit tests for VhdlSimRunner orchestrator and configuration.
"""

import std.spec

use compiler.backend.vhdl.vhdl_simulator.{VhdlSimulator, VhdlSimConfig, VhdlSimulatorRunner}
use compiler.backend.vhdl.vhdl_sim_runner.{VhdlSimRunner, VhdlEmulationConfig, VhdlEmulationResult}
use compiler.backend.vhdl.vhdl_device_target.{VhdlDeviceTarget, VhdlDeviceFamily}

describe "VhdlSimRunner":
    """
    ## Orchestrator Tests

    Validates the end-to-end simulation runner configuration and error handling.
    """

    it "creates with default GHDL config":
        """
        **Given:** VhdlSimRunner.with_ghdl()
        **Then:** Runner is configured for GHDL simulation
        """
        val runner = VhdlSimRunner.with_ghdl()
        val check = runner.check_simulator()
        # Either OK or error with install instructions
        expect check.ok.? or check.err.? == true

    it "creates from VhdlEmulationConfig":
        """
        **Given:** Explicit VhdlEmulationConfig
        **Then:** Runner reflects all config settings
        """
        val config = VhdlEmulationConfig.ghdl_default()
        val runner = VhdlSimRunner.create(config)
        val check = runner.check_simulator()
        expect check.ok.? or check.err.? == true

    it "returns error for missing VHDL file":
        """
        **Given:** Path to non-existent file
        **When:** simulate_vhdl_file() called
        **Then:** Returns error with file path
        """
        val runner = VhdlSimRunner.with_ghdl()
        val result = runner.simulate_vhdl_file("/nonexistent/file.vhd", "test")
        expect result.success == false
        expect result.errors.len() > 0

describe "VhdlEmulationResult":
    """
    ## Result Type Tests
    """

    it "creates error result":
        """
        **Given:** Error message
        **Then:** success is false and errors list populated
        """
        val r = VhdlEmulationResult.error("test error")
        expect r.success == false
        expect r.errors.len() == 1
        expect r.errors[0] == "test error"