# RVV v1.0 Permutation/Slide — byte-level emit golden tests
#
# Tests vslideup/vslidedown/vslide1up/vslide1down/vrgather from
#   src/compiler/70.backend/backend/native/encode_rvv_permute.spl
# against RVV v1.0 §17 encoding.
#
# Golden bytes derived from instruction word formula and verified.

use std.spipe.*
use compiler.backend.native.encode_rvv_permute.{emit_rvv_vslideup_vx, emit_rvv_vslidedown_vx, emit_rvv_vslide1up_vx, emit_rvv_vslide1down_vx, emit_rvv_vrgather_vv, emit_rvv_vrgather_vx}

fn _list_hex(bytes: [i64]) -> text:
    val hex_chars = "0123456789abcdef"
    var s: text = ""
    var i: u64 = 0
    while i < bytes.len().to_u64():
        val b = bytes[i.to_i64()]
        s = s + hex_chars.char_at(((b / 16) % 16).to_u64())
        s = s + hex_chars.char_at((b % 16).to_u64())
        i = i + 1
    s

describe "RVV vslideup/vslidedown byte-level emit":

    it "vslideup.vx v0, v0, x0":
        expect _list_hex(emit_rvv_vslideup_vx(0, 0, 0)) == "5740003a"

    it "vslidedown.vx v0, v0, x0":
        expect _list_hex(emit_rvv_vslidedown_vx(0, 0, 0)) == "5740003e"

    it "vslide1up.vx v0, v0, x0":
        expect _list_hex(emit_rvv_vslide1up_vx(0, 0, 0)) == "5760003a"

    it "vslide1down.vx v0, v0, x0":
        expect _list_hex(emit_rvv_vslide1down_vx(0, 0, 0)) == "5760003e"

    it "vslideup.vx v1, v2, x3 (non-zero regs)":
        expect _list_hex(emit_rvv_vslideup_vx(1, 2, 3)) == "d7c0213a"

describe "RVV vrgather byte-level emit":

    it "vrgather.vv v0, v0, v0":
        expect _list_hex(emit_rvv_vrgather_vv(0, 0, 0)) == "57000032"

    it "vrgather.vx v0, v0, x0":
        expect _list_hex(emit_rvv_vrgather_vx(0, 0, 0)) == "57400032"

    it "vrgather.vv vs vrgather.vx differ in byte[1] (funct3)":
        val vv = emit_rvv_vrgather_vv(0, 0, 0)
        val vx = emit_rvv_vrgather_vx(0, 0, 0)
        expect vv[1] == vx[1] == false

describe "RVV permute output properties":

    it "all outputs are 4 bytes":
        expect emit_rvv_vslideup_vx(0, 0, 0).len() == 4
        expect emit_rvv_vrgather_vv(0, 0, 0).len() == 4

    it "slideup vs slidedown differ only in byte[3] high bits":
        val up = emit_rvv_vslideup_vx(0, 0, 0)
        val dn = emit_rvv_vslidedown_vx(0, 0, 0)
        expect up[0] == dn[0] == true
        expect up[3] == dn[3] == false