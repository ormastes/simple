# test/unit/compiler/backend/rvv_int_emit_spec.spl
#
# Byte-equal golden tests for RVV v1.0 integer arithmetic encoder.
# All goldens derived from RISC-V Vector Extension v1.0 spec.
#
# Encoding formula (funct3=OPIVV=0 for most, OPMVV=2 for vmul):
#   word = (funct6 * 67108864) + (vm * 33554432) + (vs2 * 1048576)
#        + (vs1 * 32768) + (funct3 * 4096) + (vd * 128) + 87
#
# All ops use vm=1 (unmasked).
# OPIVV ops (vadd/vsub/vand/vor/vxor/vsll/vsrl): funct3=0
# OPMVV ops (vmul): funct3=2
#
# Test registers used: (vd=0,vs2=0,vs1=0), (vd=1,vs2=2,vs1=3), (vd=4,vs2=5,vs1=6).

use std.spec
use compiler.backend.backend.native.encode_rvv_int.{
    emit_vadd_vv,
    emit_vsub_vv,
    emit_vand_vv,
    emit_vor_vv,
    emit_vxor_vv,
    emit_vsll_vv,
    emit_vsrl_vv,
    emit_vmul_vv
}

describe "encode_rvv_int — vadd.vv (vector add, §11.1)":
    it "emit_vadd_vv vd=0 vs2=0 vs1=0 — zero-register canonical":
        # funct6=0x00,vm=1,vs2=0,vs1=0,funct3=0,vd=0 → word=0x02000057
        val got = emit_vadd_vv(0, 0, 0)
        expect(got.length) to_equal(4)
        expect(got[0]) to_equal(0x57)
        expect(got[1]) to_equal(0x00)
        expect(got[2]) to_equal(0x00)
        expect(got[3]) to_equal(0x02)

    it "emit_vadd_vv vd=1 vs2=2 vs1=3 — non-zero registers":
        # funct6=0x00,vm=1,vs2=2,vs1=3,funct3=0,vd=1 → word=0x022180D7
        val got = emit_vadd_vv(1, 2, 3)
        expect(got.length) to_equal(4)
        expect(got[0]) to_equal(0xD7)
        expect(got[1]) to_equal(0x80)
        expect(got[2]) to_equal(0x21)
        expect(got[3]) to_equal(0x02)

describe "encode_rvv_int — vsub.vv (vector subtract, §11.1)":
    it "emit_vsub_vv vd=0 vs2=0 vs1=0 — zero-register canonical":
        # funct6=0x02,vm=1,vs2=0,vs1=0,funct3=0,vd=0 → word=0x0A000057
        val got = emit_vsub_vv(0, 0, 0)
        expect(got.length) to_equal(4)
        expect(got[0]) to_equal(0x57)
        expect(got[1]) to_equal(0x00)
        expect(got[2]) to_equal(0x00)
        expect(got[3]) to_equal(0x0A)

    it "emit_vsub_vv vd=1 vs2=2 vs1=3 — non-zero registers":
        # funct6=0x02,vm=1,vs2=2,vs1=3,funct3=0,vd=1 → word=0x0A2180D7
        val got = emit_vsub_vv(1, 2, 3)
        expect(got.length) to_equal(4)
        expect(got[0]) to_equal(0xD7)
        expect(got[1]) to_equal(0x80)
        expect(got[2]) to_equal(0x21)
        expect(got[3]) to_equal(0x0A)

