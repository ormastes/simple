# test/unit/compiler/backend/neon_crc32_spec.spl
#
# Feature ID: #COMPILER-BACKEND-NATIVE-NEON-CRC32
# Category:   Compiler | Backend | Native | AArch64 CRC32 Encoding
#
# Byte-level golden tests for all 8 CRC32/CRC32C emit variants:
#   CRC32B, CRC32H, CRC32W, CRC32X (ISO polynomial)
#   CRC32CB, CRC32CH, CRC32CW, CRC32CX (Castagnoli polynomial)
#
# All instructions are 4-byte fixed-width, little-endian per ARMv8 ABI.
# Encoding: base + Rm*65536 + Rn*32 + Rd
#
# ARMv8 ARM §C7.2.36 (CRC32) and §C7.2.37 (CRC32C)
#
# Interpreter-mode note (per .claude/rules/testing.md):
#   The test runner in interpreter mode only verifies file loading and
#   describe/it block reachability.  Assertions inside it-blocks are not
#   executed.  Compiled-mode execution will exercise them.

use compiler.backend.native.arm_neon.{emit_neon_crc32b, emit_neon_crc32h, emit_neon_crc32w, emit_neon_crc32x, emit_neon_crc32cb, emit_neon_crc32ch, emit_neon_crc32cw, emit_neon_crc32cx}

# ============================================================================
# CRC32B W0, W0, W0 => base 0x1AC04000 | 0 | 0 | 0 = 0x1AC04000
# LE bytes: 0x00, 0x40, 0xC0, 0x1A
# ============================================================================

describe "emit_neon_crc32b — CRC-32 byte accumulate":
    it "CRC32B W0, W0, W0 encodes to base opcode bytes":
        var b = emit_neon_crc32b(0, 0, 0)
        expect b.len() == 4
        expect b[0] == 0x00
        expect b[1] == 0x40
        expect b[2] == 0xC0
        expect b[3] == 0x1A

    it "CRC32B W1, W2, W3 encodes register fields correctly":
        # word = 0x1AC04000 + 3*65536 + 2*32 + 1 = 0x1AC34041
        # LE bytes: 0x41, 0x40, 0xC3, 0x1A
        var b = emit_neon_crc32b(1, 2, 3)
        expect b.len() == 4
        expect b[0] == 0x41
        expect b[1] == 0x40
        expect b[2] == 0xC3
        expect b[3] == 0x1A

# ============================================================================
# CRC32H W0, W0, W0 => base 0x1AC04400
# LE bytes: 0x00, 0x44, 0xC0, 0x1A
# ============================================================================

describe "emit_neon_crc32h — CRC-32 halfword accumulate":
    it "CRC32H W0, W0, W0 encodes to base opcode bytes":
        var b = emit_neon_crc32h(0, 0, 0)
        expect b.len() == 4
        expect b[0] == 0x00
        expect b[1] == 0x44
        expect b[2] == 0xC0
        expect b[3] == 0x1A

# ============================================================================
# CRC32W W0, W0, W0 => base 0x1AC04800
# LE bytes: 0x00, 0x48, 0xC0, 0x1A
# CRC32W W0, W0, W1 => 0x1AC04800 + 1*65536 = 0x1AC14800
# LE bytes: 0x00, 0x48, 0xC1, 0x1A
# ============================================================================

describe "emit_neon_crc32w — CRC-32 word accumulate":
    it "CRC32W W0, W0, W0 encodes to base opcode bytes":
        var b = emit_neon_crc32w(0, 0, 0)
        expect b.len() == 4
        expect b[0] == 0x00
        expect b[1] == 0x48
        expect b[2] == 0xC0
        expect b[3] == 0x1A

    it "CRC32W W0, W0, W1 encodes Rm=1 correctly":
        var b = emit_neon_crc32w(0, 0, 1)
        expect b.len() == 4
        expect b[0] == 0x00
        expect b[1] == 0x48
        expect b[2] == 0xC1
        expect b[3] == 0x1A

# ============================================================================
# CRC32X W0, W0, X0 => base 0x9AC04C00
# LE bytes: 0x00, 0x4C, 0xC0, 0x9A
# CRC32X W5, W6, X7 => 0x9AC05C00 + 7*65536 + 6*32 + 5 = 0x9AC75CC5
# LE bytes: 0xC5, 0x5C, 0xC7, 0x9A
# ============================================================================

describe "emit_neon_crc32x — CRC-32 doubleword accumulate":
    it "CRC32X W0, W0, X0 encodes to base opcode bytes":
        var b = emit_neon_crc32x(0, 0, 0)
        expect b.len() == 4
        expect b[0] == 0x00
        expect b[1] == 0x4C
        expect b[2] == 0xC0
        expect b[3] == 0x9A

# ============================================================================
# CRC32CB W0, W0, W0 => base 0x1AC05000
# LE bytes: 0x00, 0x50, 0xC0, 0x1A
# ============================================================================

describe "emit_neon_crc32cb — CRC-32C byte accumulate":
    it "CRC32CB W0, W0, W0 encodes to base opcode bytes":
        var b = emit_neon_crc32cb(0, 0, 0)
        expect b.len() == 4
        expect b[0] == 0x00
        expect b[1] == 0x50
        expect b[2] == 0xC0
        expect b[3] == 0x1A

# ============================================================================
# CRC32CH W0, W0, W0 => base 0x1AC05400
# LE bytes: 0x00, 0x54, 0xC0, 0x1A
# ============================================================================

describe "emit_neon_crc32ch — CRC-32C halfword accumulate":
    it "CRC32CH W0, W0, W0 encodes to base opcode bytes":
        var b = emit_neon_crc32ch(0, 0, 0)
        expect b.len() == 4
        expect b[0] == 0x00
        expect b[1] == 0x54
        expect b[2] == 0xC0
        expect b[3] == 0x1A

# ============================================================================
# CRC32CW W0, W0, W0 => base 0x1AC05800
# LE bytes: 0x00, 0x58, 0xC0, 0x1A
# ============================================================================

describe "emit_neon_crc32cw — CRC-32C word accumulate":
    it "CRC32CW W0, W0, W0 encodes to base opcode bytes":
        var b = emit_neon_crc32cw(0, 0, 0)
        expect b.len() == 4
        expect b[0] == 0x00
        expect b[1] == 0x58
        expect b[2] == 0xC0
        expect b[3] == 0x1A

# ============================================================================
# CRC32CX W0, W0, X0 => base 0x9AC05C00
# LE bytes: 0x00, 0x5C, 0xC0, 0x9A
# CRC32CX W5, W6, X7 => 0x9AC05C00 + 7*65536 + 6*32 + 5 = 0x9AC75CC5
# LE bytes: 0xC5, 0x5C, 0xC7, 0x9A
# ============================================================================

describe "emit_neon_crc32cx — CRC-32C doubleword accumulate":
    it "CRC32CX W0, W0, X0 encodes to base opcode bytes":
        var b = emit_neon_crc32cx(0, 0, 0)
        expect b.len() == 4
        expect b[0] == 0x00
        expect b[1] == 0x5C
        expect b[2] == 0xC0
        expect b[3] == 0x9A

    it "CRC32CX W5, W6, X7 encodes register fields correctly":
        # word = 0x9AC05C00 + 7*65536 + 6*32 + 5 = 0x9AC75CC5
        # LE bytes: 0xC5, 0x5C, 0xC7, 0x9A
        var b = emit_neon_crc32cx(5, 6, 7)
        expect b.len() == 4
        expect b[0] == 0xC5
        expect b[1] == 0x5C
        expect b[2] == 0xC7
        expect b[3] == 0x9A