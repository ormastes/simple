# test/unit/compiler/backend/avx512_reduction_emit_spec.spl
#
# Byte-level golden tests for AVX-512 reduction-style emit helpers (Wave O1).
# Covers: VBROADCASTSS (zmm←xmm), VSHUFF32X4, VPERMPS, VMAXPS, VMINPS.
# These are NOT k-register ops — they are broadcasts and horizontal reductions
# for Vec::reduce_sum / Vec::max_lane / Vec::min_lane lowering.
#
# All byte sequences verified against:
#   llvm-mc -triple=x86_64-linux-gnu -mattr=+avx512f,+avx512dq --show-encoding
#   Intel SDM Vol 2C — VBROADCASTSS, VSHUFF32X4, VPERMPS, VMAXPS, VMINPS entries
#   Intel SDM Vol 2A §2.6.1 Table 2-36 (EVEX prefix layout)
#
# Register IDs (from x86_64_avx512.spl scaffold):
#   X86_ZMM0=48, X86_ZMM1=49, X86_ZMM16=64, X86_ZMM31=79
#   XMM0 index = 0  (passed directly as raw XMM index, not ZMM ID)
#
# X-bit encoding note: for ZMM16-31 in the rm/src2 position, P0[6] (~X)
# encodes src2[4] per Intel SDM Vol 2A §2.6.1 — corrected in evex_encode_3op_zmm.
#
# Post-F4 corrected encoder (ERR-001a/b + X-bit RESOLVED) — see simd_strict_emit_errata.md

use compiler.backend.native.x86_64_avx512.{emit_avx512_vbroadcastss_zmm_from_xmm, emit_avx512_vshuff32x4_zmm, emit_avx512_vpermps_zmm, emit_avx512_vmaxps_zmm, emit_avx512_vminps_zmm}

# ============================================================================
# VBROADCASTSS zmm0, xmm0
# EVEX.512.66.0F38.W0 18 /r
# zdst=Z0(48) xsrc=X0(0)
# Expected: 62 F2 7D 48 18 C0
# Intel SDM Vol 2C VBROADCASTSS; CPUID: AVX-512F
# Bit decode: P0=0xF2(~R=1~X=1~B=1~R'=1 mm=010) P1=0x7D(W=0 ~vvvv=1111 pp=01)
#             P2=0x48(z=0 L'=1 L=0 b=0 ~V'=1 aaa=000) modrm=0xC0(mod=11 reg=0 rm=0)
# llvm-mc: vbroadcastss %xmm0, %zmm0 → 62 f2 7d 48 18 c0
# ============================================================================

describe "AVX-512 emit VBROADCASTSS zmm0 from xmm0 golden":
    it "VBROADCASTSS Z0 X0 emits 6 bytes":
        val result = emit_avx512_vbroadcastss_zmm_from_xmm(48, 0)
        expect(result.len()).to_equal(6)

    it "VBROADCASTSS Z0 X0 escape byte is 0x62":
        val result = emit_avx512_vbroadcastss_zmm_from_xmm(48, 0)
        expect(result[0]).to_equal(98)

    it "VBROADCASTSS Z0 X0 P0 is 0xF2":
        # P0: ~R=1 ~X=1 ~B=1 ~R'=1 0 mm=010(0F38) = 0xF2
        val result = emit_avx512_vbroadcastss_zmm_from_xmm(48, 0)
        expect(result[1]).to_equal(242)

    it "VBROADCASTSS Z0 X0 P1 is 0x7D":
        # P1: W=0 ~vvvv=1111(unused) must-1 pp=01(0x66) = 0x7D
        val result = emit_avx512_vbroadcastss_zmm_from_xmm(48, 0)
        expect(result[2]).to_equal(125)

    it "VBROADCASTSS Z0 X0 P2 is 0x48":
        # P2: z=0 L'=1 L=0 b=0 ~V'=1 aaa=000 = 0x48
        val result = emit_avx512_vbroadcastss_zmm_from_xmm(48, 0)
        expect(result[3]).to_equal(72)

    it "VBROADCASTSS Z0 X0 opcode is 0x18":
        val result = emit_avx512_vbroadcastss_zmm_from_xmm(48, 0)
        expect(result[4]).to_equal(24)

    it "VBROADCASTSS Z0 X0 ModRM is 0xC0":
        # ModRM: mod=11 reg=0(zmm0) rm=0(xmm0) = 0xC0
        val result = emit_avx512_vbroadcastss_zmm_from_xmm(48, 0)
        expect(result[5]).to_equal(192)

# ============================================================================
# VBROADCASTSS zmm31, xmm0 — tests dest=31 (R=1, R'=1 → ~R=0, ~R'=0 in P0)
# Expected: 62 62 7D 48 18 F8
# Bit decode: P0=0x62(~R=0 ~X=1 ~B=1 ~R'=0 mm=010) ModRM=0xF8(mod=11 reg=7 rm=0)
# llvm-mc: vbroadcastss %xmm0, %zmm31 → 62 62 7d 48 18 f8
# ============================================================================

describe "AVX-512 emit VBROADCASTSS zmm31 from xmm0 — dest=31 boundary":
    it "VBROADCASTSS Z31 X0 P0 is 0x62":
        # P0: ~R=0(dest[3]=1) ~X=1 ~B=1 ~R'=0(dest[4]=1) mm=010 = 0x62
        val result = emit_avx512_vbroadcastss_zmm_from_xmm(79, 0)
        expect(result[1]).to_equal(98)

    it "VBROADCASTSS Z31 X0 ModRM is 0xF8":
        # ModRM: mod=11 reg=7(zmm31%8) rm=0 = 0xF8
        val result = emit_avx512_vbroadcastss_zmm_from_xmm(79, 0)
        expect(result[5]).to_equal(248)

# ============================================================================
# VSHUFF32X4 zmm0, zmm0, zmm0, 0x4E — canonical 4-lane reverse-shuffle
# EVEX.512.66.0F3A.W0 23 /r ib  (7 bytes)
# imm8=0x4E=78: reverses upper/lower lane pairs — canonical horizontal-reduce step
# Expected: 62 F3 7D 48 23 C0 4E
# Intel SDM Vol 2C VSHUFF32X4; CPUID: AVX-512F
# llvm-mc: vshuff32x4 $78, %zmm0, %zmm0, %zmm0 → 62 f3 7d 48 23 c0 4e
# ============================================================================

describe "AVX-512 emit VSHUFF32X4 zmm0 zmm0 zmm0 0x4E golden":
    it "VSHUFF32X4 Z0 Z0 Z0 4E emits 7 bytes":
        val result = emit_avx512_vshuff32x4_zmm(48, 48, 48, 0x4E)
        expect(result.len()).to_equal(7)

    it "VSHUFF32X4 Z0 Z0 Z0 4E escape byte is 0x62":
        val result = emit_avx512_vshuff32x4_zmm(48, 48, 48, 0x4E)
        expect(result[0]).to_equal(98)

    it "VSHUFF32X4 Z0 Z0 Z0 4E P0 is 0xF3":
        # P0: ~R=1 ~X=1 ~B=1 ~R'=1 0 mm=011(0F3A) = 0xF3
        val result = emit_avx512_vshuff32x4_zmm(48, 48, 48, 0x4E)
        expect(result[1]).to_equal(243)

    it "VSHUFF32X4 Z0 Z0 Z0 4E P1 is 0x7D":
        # P1: W=0 ~vvvv=1111 must-1 pp=01(0x66) = 0x7D
        val result = emit_avx512_vshuff32x4_zmm(48, 48, 48, 0x4E)
        expect(result[2]).to_equal(125)

    it "VSHUFF32X4 Z0 Z0 Z0 4E P2 is 0x48":
        val result = emit_avx512_vshuff32x4_zmm(48, 48, 48, 0x4E)
        expect(result[3]).to_equal(72)

    it "VSHUFF32X4 Z0 Z0 Z0 4E opcode is 0x23":
        val result = emit_avx512_vshuff32x4_zmm(48, 48, 48, 0x4E)
        expect(result[4]).to_equal(35)

    it "VSHUFF32X4 Z0 Z0 Z0 4E ModRM is 0xC0":
        val result = emit_avx512_vshuff32x4_zmm(48, 48, 48, 0x4E)
        expect(result[5]).to_equal(192)

    it "VSHUFF32X4 Z0 Z0 Z0 4E imm8 is 0x4E":
        val result = emit_avx512_vshuff32x4_zmm(48, 48, 48, 0x4E)
        expect(result[6]).to_equal(78)

# ============================================================================
# VSHUFF32X4 zmm31, zmm0, zmm0, 0x4E — tests dest=31 bits in EVEX
# Expected: 62 63 7D 48 23 F8 4E
# P0=0x63: ~R=0 ~X=1 ~B=1 ~R'=0 mm=011
# llvm-mc: vshuff32x4 $78, %zmm0, %zmm0, %zmm31 → 62 63 7d 48 23 f8 4e
# ============================================================================

describe "AVX-512 emit VSHUFF32X4 zmm31 zmm0 zmm0 0x4E — dest=31 boundary":
    it "VSHUFF32X4 Z31 Z0 Z0 4E P0 is 0x63":
        # P0: ~R=0(dest[3]=1) ~X=1 ~B=1 ~R'=0(dest[4]=1) mm=011 = 0x63
        val result = emit_avx512_vshuff32x4_zmm(79, 48, 48, 0x4E)
        expect(result[1]).to_equal(99)

    it "VSHUFF32X4 Z31 Z0 Z0 4E ModRM is 0xF8":
        val result = emit_avx512_vshuff32x4_zmm(79, 48, 48, 0x4E)
        expect(result[5]).to_equal(248)

# ============================================================================
# VPERMPS zmm0, zmm1, zmm0 — variable-index permute (index=zmm1, src=zmm0)
# EVEX.512.66.0F38.W0 16 /r
# zdst=Z0(48) zindex=Z1(49) zsrc=Z0(48)
# Expected: 62 F2 75 48 16 C0
# Intel SDM Vol 2C VPERMPS; CPUID: AVX-512F (no BW/DQ needed)
# Bit decode: P1=0x75(~vvvv=1110=zmm1) ModRM=0xC0(reg=0 rm=0)
# llvm-mc: vpermps %zmm0, %zmm1, %zmm0 → 62 f2 75 48 16 c0
# ============================================================================

describe "AVX-512 emit VPERMPS zmm0 index=zmm1 src=zmm0 golden":
    it "VPERMPS Z0 Z1 Z0 emits 6 bytes":
        val result = emit_avx512_vpermps_zmm(48, 49, 48)
        expect(result.len()).to_equal(6)

    it "VPERMPS Z0 Z1 Z0 P0 is 0xF2":
        # P0: ~R=1 ~X=1 ~B=1 ~R'=1 mm=010(0F38) = 0xF2
        val result = emit_avx512_vpermps_zmm(48, 49, 48)
        expect(result[1]).to_equal(242)

    it "VPERMPS Z0 Z1 Z0 P1 is 0x75":
        # P1: W=0 ~vvvv=1110(zmm1 idx=1) must-1 pp=01(0x66) = 0x75
        val result = emit_avx512_vpermps_zmm(48, 49, 48)
        expect(result[2]).to_equal(117)

    it "VPERMPS Z0 Z1 Z0 opcode is 0x16":
        val result = emit_avx512_vpermps_zmm(48, 49, 48)
        expect(result[4]).to_equal(22)

    it "VPERMPS Z0 Z1 Z0 ModRM is 0xC0":
        val result = emit_avx512_vpermps_zmm(48, 49, 48)
        expect(result[5]).to_equal(192)

# ============================================================================
# VPERMPS zmm0, zmm0, zmm31 — tests src2=31 X-bit encoding in P0
# Expected: 62 92 7D 48 16 C7
# P0=0x92: ~R=1 ~X=0(src2[4]=1→X=1→~X=0) ~B=0(src2[3]=1) ~R'=1 mm=010
# ModRM=0xC7: mod=11 reg=0 rm=7(zmm31%8)
# llvm-mc: vpermps %zmm31, %zmm0, %zmm0 → 62 92 7d 48 16 c7
# ============================================================================

describe "AVX-512 emit VPERMPS src2=zmm31 — X-bit ZMM16-31 rm extension":
    it "VPERMPS Z0 Z0 Z31 P0 is 0x92":
        # P0: ~R=1 ~X=0(src2=31→X=1) ~B=0(src2[3]=1) ~R'=1 mm=010 = 0x92
        val result = emit_avx512_vpermps_zmm(48, 48, 79)
        expect(result[1]).to_equal(146)

    it "VPERMPS Z0 Z0 Z31 ModRM is 0xC7":
        # ModRM: mod=11 reg=0 rm=7(31%8) = 0xC7
        val result = emit_avx512_vpermps_zmm(48, 48, 79)
        expect(result[5]).to_equal(199)

# ============================================================================
# VMAXPS zmm0, zmm0, zmm0 — lane-wise max canonical
# EVEX.512.0F.W0 5F /r
# Expected: 62 F1 7C 48 5F C0
# Intel SDM Vol 2C VMAXPS; CPUID: AVX-512F
# llvm-mc: vmaxps %zmm0, %zmm0, %zmm0 → 62 f1 7c 48 5f c0
# ============================================================================

describe "AVX-512 emit VMAXPS zmm0 zmm0 zmm0 canonical golden":
    it "VMAXPS Z0 Z0 Z0 emits 6 bytes":
        val result = emit_avx512_vmaxps_zmm(48, 48, 48)
        expect(result.len()).to_equal(6)

    it "VMAXPS Z0 Z0 Z0 P0 is 0xF1":
        # P0: ~R=1 ~X=1 ~B=1 ~R'=1 mm=001(0F) = 0xF1
        val result = emit_avx512_vmaxps_zmm(48, 48, 48)
        expect(result[1]).to_equal(241)

    it "VMAXPS Z0 Z0 Z0 P1 is 0x7C":
        # P1: W=0 ~vvvv=1111 must-1 pp=00(none) = 0x7C
        val result = emit_avx512_vmaxps_zmm(48, 48, 48)
        expect(result[2]).to_equal(124)

    it "VMAXPS Z0 Z0 Z0 P2 is 0x48":
        val result = emit_avx512_vmaxps_zmm(48, 48, 48)
        expect(result[3]).to_equal(72)

    it "VMAXPS Z0 Z0 Z0 opcode is 0x5F":
        val result = emit_avx512_vmaxps_zmm(48, 48, 48)
        expect(result[4]).to_equal(95)

    it "VMAXPS Z0 Z0 Z0 ModRM is 0xC0":
        val result = emit_avx512_vmaxps_zmm(48, 48, 48)
        expect(result[5]).to_equal(192)

# ============================================================================
# VMAXPS zmm31, zmm0, zmm0 — tests Zd=31 bits in EVEX P0
# Expected: 62 61 7C 48 5F F8
# P0=0x61: ~R=0 ~X=1 ~B=1 ~R'=0 mm=001   ModRM=0xF8: mod=11 reg=7 rm=0
# llvm-mc: vmaxps %zmm0, %zmm0, %zmm31 → 62 61 7c 48 5f f8
# ============================================================================

describe "AVX-512 emit VMAXPS zmm31 dest — Zd=31 boundary":
    it "VMAXPS Z31 Z0 Z0 P0 is 0x61":
        # P0: ~R=0(dest[3]=1) ~X=1 ~B=1 ~R'=0(dest[4]=1) mm=001 = 0x61
        val result = emit_avx512_vmaxps_zmm(79, 48, 48)
        expect(result[1]).to_equal(97)

    it "VMAXPS Z31 Z0 Z0 ModRM is 0xF8":
        val result = emit_avx512_vmaxps_zmm(79, 48, 48)
        expect(result[5]).to_equal(248)

# ============================================================================
# VMAXPS zmm0, zmm0, zmm31 — tests src2=31 X-bit in P0
# Expected: 62 91 7C 48 5F C7
# P0=0x91: ~R=1 ~X=0(src2[4]=1) ~B=0(src2[3]=1) ~R'=1 mm=001 = 0x91
# ModRM=0xC7: mod=11 reg=0 rm=7
# llvm-mc: vmaxps %zmm31, %zmm0, %zmm0 → 62 91 7c 48 5f c7
# ============================================================================

describe "AVX-512 emit VMAXPS src2=zmm31 — Zn=31 X-bit boundary":
    it "VMAXPS Z0 Z0 Z31 P0 is 0x91":
        # P0: ~R=1 ~X=0(src2=31 X=1) ~B=0(src2[3]=1) ~R'=1 mm=001 = 0x91
        val result = emit_avx512_vmaxps_zmm(48, 48, 79)
        expect(result[1]).to_equal(145)

    it "VMAXPS Z0 Z0 Z31 ModRM is 0xC7":
        val result = emit_avx512_vmaxps_zmm(48, 48, 79)
        expect(result[5]).to_equal(199)

# ============================================================================
# VMINPS zmm0, zmm0, zmm0 — lane-wise min canonical
# EVEX.512.0F.W0 5D /r
# Expected: 62 F1 7C 48 5D C0
# Intel SDM Vol 2C VMINPS; CPUID: AVX-512F
# llvm-mc: vminps %zmm0, %zmm0, %zmm0 → 62 f1 7c 48 5d c0
# ============================================================================

describe "AVX-512 emit VMINPS zmm0 zmm0 zmm0 canonical golden":
    it "VMINPS Z0 Z0 Z0 emits 6 bytes":
        val result = emit_avx512_vminps_zmm(48, 48, 48)
        expect(result.len()).to_equal(6)

    it "VMINPS Z0 Z0 Z0 P0 is 0xF1":
        val result = emit_avx512_vminps_zmm(48, 48, 48)
        expect(result[1]).to_equal(241)

    it "VMINPS Z0 Z0 Z0 P1 is 0x7C":
        val result = emit_avx512_vminps_zmm(48, 48, 48)
        expect(result[2]).to_equal(124)

    it "VMINPS Z0 Z0 Z0 opcode is 0x5D":
        val result = emit_avx512_vminps_zmm(48, 48, 48)
        expect(result[4]).to_equal(93)

    it "VMINPS Z0 Z0 Z0 ModRM is 0xC0":
        val result = emit_avx512_vminps_zmm(48, 48, 48)
        expect(result[5]).to_equal(192)

# ============================================================================
# VMINPS zmm0, zmm31, zmm0 — tests Zn=31 (vvvv=31, V' extension in P2)
# Expected: 62 F1 04 40 5D C0
# P1=0x04: W=0 ~vvvv=0000(src1=31→vvvv_lo4=15→not_vvvv=0) must-1 pp=00 = 0x04
# P2=0x40: z=0 L'=1 L=0 b=0 ~V'=0(src1[4]=1→V'=1) aaa=000 = 0x40
# llvm-mc: vminps %zmm0, %zmm31, %zmm0 → 62 f1 04 40 5d c0
# ============================================================================

describe "AVX-512 emit VMINPS src1=zmm31 — Zn=31 V-prime boundary":
    it "VMINPS Z0 Z31 Z0 P1 is 0x04":
        # P1: W=0 ~vvvv=0000(src1=31→vvvv_lo4=15) must-1 pp=00 = 0x04
        val result = emit_avx512_vminps_zmm(48, 79, 48)
        expect(result[2]).to_equal(4)

    it "VMINPS Z0 Z31 Z0 P2 is 0x40":
        # P2: z=0 L'=1 L=0 b=0 ~V'=0(V'=1 for src1=31) aaa=000 = 0x40
        val result = emit_avx512_vminps_zmm(48, 79, 48)
        expect(result[3]).to_equal(64)

# ============================================================================
# VMAXPS zmm0, zmm16, zmm0 — tests src1=16 (V' bit: src1[4]=1 → ~V'=0 in P2)
# Expected: 62 F1 7C 40 5F C0
# P2=0x40: ~V'=0 (src1=16 → V'=1)
# llvm-mc: vmaxps %zmm0, %zmm16, %zmm0 → 62 f1 7c 40 5f c0
# ============================================================================

describe "AVX-512 emit VMAXPS src1=zmm16 — V-prime bit boundary":
    it "VMAXPS Z0 Z16 Z0 P2 is 0x40":
        # P2: z=0 L'=1 L=0 b=0 ~V'=0(src1=16 V'=1) aaa=000 = 0x40
        val result = emit_avx512_vmaxps_zmm(48, 64, 48)
        expect(result[3]).to_equal(64)

    it "VMAXPS Z0 Z16 Z0 P1 is 0x7C":
        # P1: ~vvvv=1111(src1=16→vvvv_lo4=0→not_vvvv=15) pp=00 = 0x7C
        val result = emit_avx512_vmaxps_zmm(48, 64, 48)
        expect(result[2]).to_equal(124)

# ============================================================================
# VMINPS zmm0, zmm0, zmm16 — tests src2=16 B-bit (but NOT X-bit since 16//16=1→X=1)
# Expected: 62 B1 7C 48 5D C0
# P0=0xB1: ~R=1 ~X=0(src2[4]=1) ~B=1(src2[3]=0 since 16//8=2%2=0) ~R'=1 mm=001
# Wait: 16//8=2 %2=0 → b_bit=0 → not_b=1; 16//16=1 %2=1 → x_bit=1 → not_x=0
# P0 = 1*128 + 0*64 + 1*32 + 1*16 + 0*4 + 0*2 + 1 = 128+32+16+1 = 177 = 0xB1
# llvm-mc: vminps %zmm16, %zmm0, %zmm0 → 62 b1 7c 48 5d c0
# ============================================================================

describe "AVX-512 emit VMINPS src2=zmm16 — X-bit without B-bit boundary":
    it "VMINPS Z0 Z0 Z16 P0 is 0xB1":
        # P0: ~R=1 ~X=0(src2[4]=1) ~B=1(src2[3]=0) ~R'=1 mm=001 = 0xB1 = 177
        val result = emit_avx512_vminps_zmm(48, 48, 64)
        expect(result[1]).to_equal(177)

    it "VMINPS Z0 Z0 Z16 opcode is 0x5D":
        val result = emit_avx512_vminps_zmm(48, 48, 64)
        expect(result[4]).to_equal(93)
