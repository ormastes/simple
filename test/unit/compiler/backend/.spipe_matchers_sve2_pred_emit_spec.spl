# SVE2 Predicate Emit Golden Byte Tests
#
# Verifies encode_aarch64_sve2_pred.spl emit functions produce correct
# 4-byte little-endian AArch64 instruction words.
#
# Reference: ARMv9-A ARM SVE supplement §C7.2

use std.spec.{describe, it, expect}
use compiler.backend.backend.native.encode_aarch64_sve2_pred.{
    emit_ptrue_s, emit_pfalse, emit_whilelt_s, emit_whilele_s,
    emit_and_pred, emit_orr_pred, emit_eor_pred, emit_not_pred,
    emit_brka, emit_pnext_s
}

describe "SVE2 predicate emit golden bytes":
    describe "PTRUE":
        it "ptrue_s pd=0":
            val b = emit_ptrue_s(0)
            expect b.length == 4
            expect b[0] == 0x00
            expect b[1] == 0xE0
            expect b[2] == 0x18
            expect b[3] == 0x25

        it "ptrue_s pd=3":
            val b = emit_ptrue_s(3)
            expect b[0] == 0x03
            expect b[1] == 0xE0
            expect b[2] == 0x18
            expect b[3] == 0x25

    describe "PFALSE":
        it "pfalse pd=0":
            val b = emit_pfalse(0)
            expect b[0] == 0x00
            expect b[1] == 0xE4
            expect b[2] == 0x18
            expect b[3] == 0x25

        it "pfalse pd=7":
            val b = emit_pfalse(7)
            expect b[0] == 0x07
            expect b[1] == 0xE4
            expect b[2] == 0x18
            expect b[3] == 0x25

    describe "WHILELT":
        it "whilelt_s pd=0 rn=0 rm=0":
            val b = emit_whilelt_s(0, 0, 0)
            expect b[0] == 0x00
            expect b[1] == 0x04
            expect b[2] == 0xA0
            expect b[3] == 0x25

        it "whilelt_s pd=1 rn=2 rm=3":
            val b = emit_whilelt_s(1, 2, 3)
            expect b[0] == 0x41
            expect b[1] == 0x04
            expect b[2] == 0xA3
            expect b[3] == 0x25

    describe "WHILELE":
        it "whilele_s pd=2 rn=5 rm=10":
            val b = emit_whilele_s(2, 5, 10)
            expect b[0] == 0xA2
            expect b[1] == 0x0C
            expect b[2] == 0xAA
            expect b[3] == 0x25

    describe "AND predicate":
        it "and_pred pd=0 pg=1 pn=2 pm=3":
            val b = emit_and_pred(0, 1, 2, 3)
            expect b[0] == 0x40
            expect b[1] == 0x44
            expect b[2] == 0x03
            expect b[3] == 0x25

        it "and_pred pd=5 pg=7 pn=3 pm=15":
            val b = emit_and_pred(5, 7, 3, 15)
            expect b[0] == 0x65
            expect b[1] == 0x5C
            expect b[2] == 0x0F
            expect b[3] == 0x25

    describe "ORR predicate":
        it "orr_pred pd=0 pg=0 pn=0 pm=0":
            val b = emit_orr_pred(0, 0, 0, 0)
            expect b[0] == 0x00
            expect b[1] == 0x40
            expect b[2] == 0x80
            expect b[3] == 0x25

        it "orr_pred pd=1 pg=2 pn=3 pm=4":
            val b = emit_orr_pred(1, 2, 3, 4)
            expect b[0] == 0x61
            expect b[1] == 0x48
            expect b[2] == 0x84
            expect b[3] == 0x25

    describe "EOR predicate":
        it "eor_pred pd=0 pg=1 pn=2 pm=3":
            val b = emit_eor_pred(0, 1, 2, 3)
            expect b[0] == 0x40
            expect b[1] == 0x46
            expect b[2] == 0x03
            expect b[3] == 0x25

    describe "NOT predicate":
        it "not_pred pd=0 pg=0 pn=0":
            val b = emit_not_pred(0, 0, 0)
            expect b[0] == 0x10
            expect b[1] == 0x42
            expect b[2] == 0x00
            expect b[3] == 0x25

        it "not_pred pd=1 pg=2 pn=3":
            val b = emit_not_pred(1, 2, 3)
            expect b[0] == 0x71
            expect b[1] == 0x4A
            expect b[2] == 0x00
            expect b[3] == 0x25

    describe "BRKA":
        it "brka pd=0 pg=1 pn=2":
            val b = emit_brka(0, 1, 2)
            expect b[0] == 0x40
            expect b[1] == 0x44
            expect b[2] == 0x10
            expect b[3] == 0x25

        it "brka pd=3 pg=7 pn=5":
            val b = emit_brka(3, 7, 5)
            expect b[0] == 0xA3
            expect b[1] == 0x5C
            expect b[2] == 0x10
            expect b[3] == 0x25

    describe "PNEXT":
        it "pnext_s pd=0 pg=1":
            val b = emit_pnext_s(0, 1)
            expect b[0] == 0x20
            expect b[1] == 0xC4
            expect b[2] == 0x19
            expect b[3] == 0x25

        it "pnext_s pd=5 pg=3":
            val b = emit_pnext_s(5, 3)
            expect b[0] == 0x65
            expect b[1] == 0xC4
            expect b[2] == 0x19
            expect b[3] == 0x25