# test/unit/compiler/backend/neon_cmp_emit_spec.spl
#
# Feature ID: #COMPILER-BACKEND-NATIVE-NEON-CMP
# Category:   Compiler | Backend | Native | AArch64 NEON Comparison/Select Encoding
#
# Byte-level golden tests for ARMv8-A NEON comparison and BSL emit functions:
#   CMEQ  Vd.4S, Vn.4S, Vm.4S  (ARMv8 ARM §C7.2.27)
#   CMGT  Vd.4S, Vn.4S, Vm.4S  (ARMv8 ARM §C7.2.33)
#   CMGE  Vd.4S, Vn.4S, Vm.4S  (ARMv8 ARM §C7.2.30)
#   CMHI  Vd.4S, Vn.4S, Vm.4S  (ARMv8 ARM §C7.2.36)
#   FCMEQ Vd.4S, Vn.4S, Vm.4S  (ARMv8 ARM §C7.2.79)
#   FCMGT Vd.4S, Vn.4S, Vm.4S  (ARMv8 ARM §C7.2.85)
#   FCMGE Vd.4S, Vn.4S, Vm.4S  (ARMv8 ARM §C7.2.82)
#   BSL   Vd.16B, Vn.16B, Vm.16B  (ARMv8 ARM §C7.2.22)
#
# All instructions are 4-byte fixed-width, little-endian per ARMv8 ABI.
# Encoding: base | (Rm << 16) | (Rn << 5) | Rd
#
# Interpreter-mode note (per .claude/rules/testing.md):
#   The test runner in interpreter mode only verifies file loading and
#   describe/it block reachability.  Assertions inside it-blocks are not
#   executed.  Compiled-mode execution will exercise them.

use compiler.backend.native.encode_aarch64_neon_cmp.{emit_cmeq_4s, emit_cmgt_4s, emit_cmge_4s, emit_cmhi_4s, emit_fcmeq_4s, emit_fcmgt_4s, emit_fcmge_4s, emit_bsl_16b}

# ============================================================================
# CMEQ V.4S — base 0x6EA08C00
# V0,V0,V0 => LE: 0x00, 0x8C, 0xA0, 0x6E
# ============================================================================

describe "emit_cmeq_4s — compare equal 4x32-bit lanes":
    it "CMEQ V0.4S, V0.4S, V0.4S encodes to base opcode bytes":
        var b = emit_cmeq_4s(0, 0, 0)
        expect b.len() == 4
        expect b[0] == 0x00
        expect b[1] == 0x8C
        expect b[2] == 0xA0
        expect b[3] == 0x6E

    it "CMEQ V1.4S, V2.4S, V3.4S encodes register fields correctly":
        # word = 0x6EA08C00 | (3 << 16) | (2 << 5) | 1
        #      = 0x6EA08C00 | 0x30000 | 0x40 | 1
        #      = 0x6EA38C41
        # LE: 0x41, 0x8C, 0xA3, 0x6E
        var b = emit_cmeq_4s(1, 2, 3)
        expect b.len() == 4
        expect b[0] == 0x41
        expect b[1] == 0x8C
        expect b[2] == 0xA3
        expect b[3] == 0x6E

    it "emit_cmeq_4s always returns 4 bytes":
        var b = emit_cmeq_4s(4, 5, 6)
        expect b.len() == 4

# ============================================================================
# CMGT V.4S — base 0x4EA03400
# V0,V0,V0 => LE: 0x00, 0x34, 0xA0, 0x4E
# ============================================================================

describe "emit_cmgt_4s — compare signed greater-than 4x32-bit lanes":
    it "CMGT V0.4S, V0.4S, V0.4S encodes to base opcode bytes":
        var b = emit_cmgt_4s(0, 0, 0)
        expect b.len() == 4
        expect b[0] == 0x00
        expect b[1] == 0x34
        expect b[2] == 0xA0
        expect b[3] == 0x4E

    it "CMGT V1.4S, V2.4S, V3.4S encodes register fields correctly":
        # word = 0x4EA03400 | (3 << 16) | (2 << 5) | 1
        #      = 0x4EA03400 | 0x30000 | 0x40 | 1
        #      = 0x4EA33441
        # LE: 0x41, 0x34, 0xA3, 0x4E
        var b = emit_cmgt_4s(1, 2, 3)
        expect b.len() == 4
        expect b[0] == 0x41
        expect b[1] == 0x34
        expect b[2] == 0xA3
        expect b[3] == 0x4E

    it "emit_cmgt_4s always returns 4 bytes":
        var b = emit_cmgt_4s(7, 8, 9)
        expect b.len() == 4

# ============================================================================
# CMGE V.4S — base 0x4EA03C00
# V0,V0,V0 => LE: 0x00, 0x3C, 0xA0, 0x4E
# ============================================================================

describe "emit_cmge_4s — compare signed greater-than-or-equal 4x32-bit lanes":
    it "CMGE V0.4S, V0.4S, V0.4S encodes to base opcode bytes":
        var b = emit_cmge_4s(0, 0, 0)
        expect b.len() == 4
        expect b[0] == 0x00
        expect b[1] == 0x3C
        expect b[2] == 0xA0
        expect b[3] == 0x4E

    it "CMGE V1.4S, V2.4S, V3.4S encodes register fields correctly":
        # word = 0x4EA03C00 | (3 << 16) | (2 << 5) | 1
        #      = 0x4EA03C00 | 0x30000 | 0x40 | 1
        #      = 0x4EA33C41
        # LE: 0x41, 0x3C, 0xA3, 0x4E
        var b = emit_cmge_4s(1, 2, 3)
        expect b.len() == 4
        expect b[0] == 0x41
        expect b[1] == 0x3C
        expect b[2] == 0xA3
        expect b[3] == 0x4E

    it "emit_cmge_4s always returns 4 bytes":
        var b = emit_cmge_4s(10, 11, 12)
        expect b.len() == 4

