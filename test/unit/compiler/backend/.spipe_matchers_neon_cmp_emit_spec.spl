# ============================================================================
# BSL V.16B — base 0x6E601C00
# V0,V0,V0 => LE: 0x00, 0x1C, 0x60, 0x6E
# ============================================================================

describe "emit_bsl_16b — bitwise select 128-bit":
    it "BSL V0.16B, V0.16B, V0.16B encodes to base opcode bytes":
        var b = emit_bsl_16b(0, 0, 0)
        expect b.len() == 4
        expect b[0] == 0x00
        expect b[1] == 0x1C
        expect b[2] == 0x60
        expect b[3] == 0x6E

    it "BSL V1.16B, V2.16B, V3.16B encodes register fields correctly":
        # word = 0x6E601C00 | (3 << 16) | (2 << 5) | 1
        #      = 0x6E601C00 | 0x30000 | 0x40 | 1
        #      = 0x6E631C41
        # LE: 0x41, 0x1C, 0x63, 0x6E
        var b = emit_bsl_16b(1, 2, 3)
        expect b.len() == 4
        expect b[0] == 0x41
        expect b[1] == 0x1C
        expect b[2] == 0x63
        expect b[3] == 0x6E

    it "emit_bsl_16b always returns 4 bytes":
        var b = emit_bsl_16b(25, 26, 27)
        expect b.len() == 4