# ============================================================================
# FCMEQ V.4S — base 0x4E20E400
# V0,V0,V0 => LE: 0x00, 0xE4, 0x20, 0x4E
# ============================================================================

describe "emit_fcmeq_4s — fp compare equal 4x32-bit lanes":
    it "FCMEQ V0.4S, V0.4S, V0.4S encodes to base opcode bytes":
        var b = emit_fcmeq_4s(0, 0, 0)
        expect b.len() == 4
        expect b[0] == 0x00
        expect b[1] == 0xE4
        expect b[2] == 0x20
        expect b[3] == 0x4E

    it "FCMEQ V1.4S, V2.4S, V3.4S encodes register fields correctly":
        # word = 0x4E20E400 | (3 << 16) | (2 << 5) | 1
        #      = 0x4E20E400 | 0x30000 | 0x40 | 1
        #      = 0x4E23E441
        # LE: 0x41, 0xE4, 0x23, 0x4E
        var b = emit_fcmeq_4s(1, 2, 3)
        expect b.len() == 4
        expect b[0] == 0x41
        expect b[1] == 0xE4
        expect b[2] == 0x23
        expect b[3] == 0x4E

    it "emit_fcmeq_4s always returns 4 bytes":
        var b = emit_fcmeq_4s(16, 17, 18)
        expect b.len() == 4

