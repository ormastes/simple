# test/unit/compiler/backend/neon_dot_spec.spl
#
# Feature ID: #COMPILER-BACKEND-NATIVE-NEON-DOT
# Category:   Compiler | Backend | Native | AArch64 SDOT/UDOT Encoding
#
# Byte-level golden tests for SDOT/UDOT int8 dot-product emit variants:
#   SDOT Vd.4S, Vn.16B, Vm.16B  (Q=1, U=0, ARMv8.2-DotProd)
#   UDOT Vd.4S, Vn.16B, Vm.16B  (Q=1, U=1, ARMv8.2-DotProd)
#   SDOT Vd.2S, Vn.8B,  Vm.8B   (Q=0, U=0)
#   UDOT Vd.2S, Vn.8B,  Vm.8B   (Q=0, U=1)
#
# All instructions are 4-byte fixed-width, little-endian per ARMv8 ABI.
# Encoding: base + Rm*65536 + Rn*32 + Rd
#
# ARMv8 ARM §C7.2.258 (SDOT) and §C7.2.363 (UDOT)
#
# Interpreter-mode note (per .claude/rules/testing.md):
#   The test runner in interpreter mode only verifies file loading and
#   describe/it block reachability.  Assertions inside it-blocks are not
#   executed.  Compiled-mode execution will exercise them.

use compiler.backend.native.arm_neon.{emit_neon_sdot_4s, emit_neon_udot_4s, emit_neon_sdot_2s, emit_neon_udot_2s}

# ============================================================================
# SDOT V0.4S, V0.16B, V0.16B => base 0x4E809400
# LE bytes: 0x00, 0x94, 0x80, 0x4E
# ============================================================================

describe "emit_neon_sdot_4s — signed int8 dot product 4 lanes":
    it "SDOT V0.4S, V0.16B, V0.16B encodes to base opcode bytes":
        var b = emit_neon_sdot_4s(0, 0, 0)
        expect(b.len()).to_equal(4)
        expect(b[0]).to_equal(0x00)
        expect(b[1]).to_equal(0x94)
        expect(b[2]).to_equal(0x80)
        expect(b[3]).to_equal(0x4E)

    it "SDOT V1.4S, V2.16B, V3.16B encodes register fields correctly":
        # word = 0x4E809400 + 3*65536 + 2*32 + 1 = 0x4E839441
        # LE bytes: 0x41, 0x94, 0x83, 0x4E
        var b = emit_neon_sdot_4s(1, 2, 3)
        expect(b.len()).to_equal(4)
        expect(b[0]).to_equal(0x41)
        expect(b[1]).to_equal(0x94)
        expect(b[2]).to_equal(0x83)
        expect(b[3]).to_equal(0x4E)

# ============================================================================
# UDOT V0.4S, V0.16B, V0.16B => base 0x6E809400
# LE bytes: 0x00, 0x94, 0x80, 0x6E
# ============================================================================

describe "emit_neon_udot_4s — unsigned int8 dot product 4 lanes":
    it "UDOT V0.4S, V0.16B, V0.16B encodes to base opcode bytes":
        var b = emit_neon_udot_4s(0, 0, 0)
        expect(b.len()).to_equal(4)
        expect(b[0]).to_equal(0x00)
        expect(b[1]).to_equal(0x94)
        expect(b[2]).to_equal(0x80)
        expect(b[3]).to_equal(0x6E)

    it "UDOT V5.4S, V6.16B, V7.16B encodes register fields correctly":
        # word = 0x6E809400 + 7*65536 + 6*32 + 5 = 0x6E8794C5
        # LE bytes: 0xC5, 0x94, 0x87, 0x6E
        var b = emit_neon_udot_4s(5, 6, 7)
        expect(b.len()).to_equal(4)
        expect(b[0]).to_equal(0xC5)
        expect(b[1]).to_equal(0x94)
        expect(b[2]).to_equal(0x87)
        expect(b[3]).to_equal(0x6E)

# ============================================================================
# SDOT V0.2S, V0.8B, V0.8B => base 0x0E809400
# LE bytes: 0x00, 0x94, 0x80, 0x0E
# ============================================================================

describe "emit_neon_sdot_2s — signed int8 dot product 2 lanes":
    it "SDOT V0.2S, V0.8B, V0.8B encodes to base opcode bytes":
        var b = emit_neon_sdot_2s(0, 0, 0)
        expect(b.len()).to_equal(4)
        expect(b[0]).to_equal(0x00)
        expect(b[1]).to_equal(0x94)
        expect(b[2]).to_equal(0x80)
        expect(b[3]).to_equal(0x0E)

# ============================================================================
# UDOT V0.2S, V0.8B, V0.8B => base 0x2E809400
# LE bytes: 0x00, 0x94, 0x80, 0x2E
# ============================================================================

describe "emit_neon_udot_2s — unsigned int8 dot product 2 lanes":
    it "UDOT V0.2S, V0.8B, V0.8B encodes to base opcode bytes":
        var b = emit_neon_udot_2s(0, 0, 0)
        expect(b.len()).to_equal(4)
        expect(b[0]).to_equal(0x00)
        expect(b[1]).to_equal(0x94)
        expect(b[2]).to_equal(0x80)
        expect(b[3]).to_equal(0x2E)

# ============================================================================
# Property: all variants always return exactly 4 bytes
# ============================================================================

describe "SDOT/UDOT emit output length":
    it "emit_neon_sdot_4s always returns 4 bytes":
        var b = emit_neon_sdot_4s(1, 2, 3)
        expect(b.len()).to_equal(4)

# ============================================================================
# Property: SDOT vs UDOT differ only in byte[3] (MSB in LE encoding)
# ============================================================================

describe "SDOT vs UDOT byte[3] distinction":
    it "SDOT and UDOT 4S with same registers match bytes 0-2 and differ at byte[3]":
        var s = emit_neon_sdot_4s(1, 2, 3)
        var u = emit_neon_udot_4s(1, 2, 3)
        expect(s[0]).to_equal(u[0])
        expect(s[1]).to_equal(u[1])
        expect(s[2]).to_equal(u[2])
        # UDOT has U=1 (bit 29), which raises byte[3] by 0x20
        expect(u[3] - s[3]).to_equal(0x20)
