use compiler.backend.{JitInterpreterConfig, JitMode}

describe "Interpreter Mode":
    it "creates the default hybrid JIT config":
        val config = JitInterpreterConfig.default()

        expect config.mode == JitMode.Auto
        expect config.backend == "auto"
        expect config.jit_threshold == 10
        expect config.verbose == false

    it "creates an always-interpret config":
        val config = JitInterpreterConfig.interpret_only()

        expect config.mode == JitMode.AlwaysInterpret
        expect config.backend == "auto"
        expect config.jit_threshold > 1000
        expect config.verbose == false

    it "creates an always-jit config":
        val config = JitInterpreterConfig.always_jit()

        expect config.mode == JitMode.AlwaysJit
        expect config.backend == "auto"
        expect config.jit_threshold == 0
        expect config.verbose == false

    it "creates a thresholded auto-jit config":
        val config = JitInterpreterConfig.auto_jit()

        expect config.mode == JitMode.Auto
        expect config.backend == "auto"
        expect config.jit_threshold == 1
        expect config.verbose == false