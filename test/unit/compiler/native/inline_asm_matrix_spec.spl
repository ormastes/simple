# Inline asm target/mode matrix.
#
# This spec is intentionally syntax-and-contract focused. Interpreter mode must
# parse and skip asm safely; loader/compiler modes must preserve raw instruction
# text for native linking/codegen. Hardware-effect execution belongs in QEMU or
# hardware-specific specs.

fn check(condition: bool):
    expect(condition).to_equal(true)

fn raw_asm_block(instruction: text) -> text:
    "asm { \"" + instruction + "\" }"

fn raw_volatile_asm_block(instruction: text) -> text:
    "asm volatile { \"" + instruction + "\" }"

fn mode_fixture(target: text, mode: text, instruction: text) -> text:
    """
    @platform("{target}")
    @test_mode("{mode}")
    fn inline_asm_smoke() -> i64:
        asm volatile {
            "{instruction}"
        }
        return 0
    """.replace("{target}", target).replace("{mode}", mode).replace("{instruction}", instruction)

fn assert_target_mode(target: text, mode: text, instruction: text):
    val code = mode_fixture(target, mode, instruction)
    check(code.contains("@platform(\"" + target + "\")"))
    check(code.contains("@test_mode(\"" + mode + "\")"))
    check(code.contains("asm volatile {"))
    check(code.contains(instruction))
    check(not code.contains("asm volatile("))

describe "Inline asm canonical block syntax":
    it "uses braced raw asm for non-volatile instructions":
        val code = raw_asm_block("nop")
        check(code == "asm { \"nop\" }")

    it "uses braced raw asm for volatile instructions":
        val code = raw_volatile_asm_block("wfi")
        check(code == "asm volatile { \"wfi\" }")

    it "keeps parenthesized syntax out of raw embedded asm fixtures":
        val code = mode_fixture("x86_64", "compiler", "nop")
        check(not code.contains("asm("))
        check(not code.contains("asm volatile("))

describe "Inline asm x86_32 matrix":
    it "covers x86_32 interpreter mode":
        assert_target_mode("x86_32", "interpreter", "nop")

    it "covers x86_32 loader mode":
        assert_target_mode("x86_32", "loader", "nop")

    it "covers x86_32 compiler mode":
        assert_target_mode("x86_32", "compiler", "nop")

describe "Inline asm x86_64 matrix":
    it "covers x86_64 interpreter mode":
        assert_target_mode("x86_64", "interpreter", "nop")

    it "covers x86_64 loader mode":
        assert_target_mode("x86_64", "loader", "nop")

    it "covers x86_64 compiler mode":
        assert_target_mode("x86_64", "compiler", "nop")

describe "Inline asm arm32 matrix":
    it "covers arm32 interpreter mode":
        assert_target_mode("arm32", "interpreter", "nop")

    it "covers arm32 loader mode":
        assert_target_mode("arm32", "loader", "nop")

    it "covers arm32 compiler mode":
        assert_target_mode("arm32", "compiler", "nop")

describe "Inline asm arm64 matrix":
    it "covers arm64 interpreter mode":
        assert_target_mode("arm64", "interpreter", "nop")

    it "covers arm64 loader mode":
        assert_target_mode("arm64", "loader", "nop")

    it "covers arm64 compiler mode":
        assert_target_mode("arm64", "compiler", "nop")

describe "Inline asm riscv32 matrix":
    it "covers riscv32 interpreter mode":
        assert_target_mode("riscv32", "interpreter", "nop")

    it "covers riscv32 loader mode":
        assert_target_mode("riscv32", "loader", "nop")

    it "covers riscv32 compiler mode":
        assert_target_mode("riscv32", "compiler", "nop")

describe "Inline asm riscv64 matrix":
    it "covers riscv64 interpreter mode":
        assert_target_mode("riscv64", "interpreter", "nop")

    it "covers riscv64 loader mode":
        assert_target_mode("riscv64", "loader", "nop")

    it "covers riscv64 compiler mode":
        assert_target_mode("riscv64", "compiler", "nop")

describe "Inline asm mode contracts":
    it "documents interpreter as parse-and-skip only":
        val code = mode_fixture("riscv64", "interpreter", "nop")
        check(code.contains("@test_mode(\"interpreter\")"))
        check(code.contains("nop"))

    it "documents loader as preservation and linking":
        val code = mode_fixture("arm64", "loader", "nop")
        check(code.contains("@test_mode(\"loader\")"))
        check(code.contains("asm volatile {"))

    it "documents compiler as raw instruction emission":
        val code = mode_fixture("x86_64", "compiler", "nop")
        check(code.contains("@test_mode(\"compiler\")"))
        check(code.contains("asm volatile {"))
