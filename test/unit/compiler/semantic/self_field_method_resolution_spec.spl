// @bug self-field-method-resolution
// Regression spec for: seed compiler self.field.method() resolution bug
// Phase-4 report STOP marker (2026-04-14)
//
// Expected: self.inner.foo() dispatches to Inner.foo(), returns 42
// Actual:   method call on field-access receiver either
//           (a) lowers receiver type to ANY → lookup_method_return_type fails silently, or
//           (b) MIR mangler resolves to the enclosing method name → infinite recursion
//
// DO NOT run until self_field_method_resume_2026-04-14.md fix is applied and
// src/compiler_rust/compiler/src/hir/lower/expr/calls.rs / access.rs are patched.

use std.testing

dataclass Inner:
  var value: i32

  fn foo() -> i32:
    return self.value

dataclass Outer:
  var inner: Inner

  fn trigger() -> i32:
    // This is the pattern that breaks: receiver is a FieldAccess node,
    // not a bare identifier. The seed compiler's lower_method_call sees
    // receiver_hir.ty == ANY (CannotInferFieldType fallback in access.rs:140)
    // and lookup_method_return_type returns ANY. MIR then misresolves the
    // mangled name to the enclosing function, causing infinite recursion.
    return self.inner.foo()

spec "self.field.method() resolution":
  it "dispatches through struct field to correct method":
    var inner_val: Inner = Inner(value: 42)
    var outer_val: Outer = Outer(inner: inner_val)
    var result: i32 = outer_val.trigger()
    assert result == 42

  it "two-level chained field method call":
    // Ensure x.a.b.method() also works (not just one hop)
    var inner_val: Inner = Inner(value: 7)
    var outer_val: Outer = Outer(inner: inner_val)
    // trigger() calls self.inner.foo() internally
    assert outer_val.trigger() == 7

  it "field method result used in arithmetic":
    var inner_val: Inner = Inner(value: 10)
    var outer_val: Outer = Outer(inner: inner_val)
    var doubled: i32 = outer_val.trigger() * 2
    assert doubled == 20
