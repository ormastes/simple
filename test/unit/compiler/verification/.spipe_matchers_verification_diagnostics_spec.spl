use verification.lean.verification_diagnostics as diag

describe "Verification Diagnostics":
    context "VerificationErrorCode":
        it "returns stable codes and help text":
            expect diag.VerificationErrorCode.AopNonGhostTargetsVerified.code() == "V-AOP-001"
            expect diag.VerificationErrorCode.MacroUndeclaredIntroduction.code() == "M-INTRO-001"
            expect diag.VerificationErrorCode.MissingTermination.code() == "V-TERM-001"
            expect (diag.VerificationErrorCode.UnsafeInVerified.message()).contains("unsafe")
            expect (diag.VerificationErrorCode.MissingTermination.help()).contains("decreases")
            expect (diag.VerificationErrorCode.FfiInVerified.help()).contains("@trusted")

    context "Span":
        it "creates spans":
            val span = diag.Span.new(10, 20, 5, 3)
            expect span.start == 10
            expect span.end == 20
            expect span.line == 5
            expect span.column == 3
            val empty = diag.Span.empty()
            expect empty.start == 0
            expect empty.end == 0

    context "VerificationDiagnostic":
        it "formats context and location":
            val span = diag.Span.new(0, 10, 1, 1)
            var d = diag.VerificationDiagnostic.new(
                diag.VerificationErrorCode.MissingTermination,
                span
            )
            d = d.with_item("factorial").with_file("math.spl").with_context("recursive function")
            val formatted = d.format()
            expect (formatted).contains("V-TERM-001")
            expect (formatted).contains("factorial")
            expect (formatted).contains("math.spl")
            expect (formatted).contains("recursive function")

    context "VerificationDiagnostics":
        it "collects and formats diagnostics":
            var collector = diag.VerificationDiagnostics.new()
            expect collector.is_empty() == true

            val span = diag.Span.new(0, 10, 1, 1)
            collector.push(diag.VerificationDiagnostic.new(diag.VerificationErrorCode.IoInVerified, span))
            collector.push(diag.VerificationDiagnostic.new(diag.VerificationErrorCode.FfiInVerified, span))

            expect collector.is_empty() == false
            expect collector.error_count() == 2
            expect collector.format_all().len() == 2

    context "Helper functions":
        it "builds common diagnostics":
            val span = diag.Span.new(0, 10, 1, 1)
            expect diag.missing_termination_error(span, "factorial").code.code() == "V-TERM-001"
            expect diag.io_in_verified_error(span, "read_file").code.code() == "V-EFFECT-001"
            expect diag.ffi_in_verified_error(span, "call_c_func").code.code() == "V-UNSAFE-003"
            expect diag.ghost_access_error(span, "counter").code.code() == "V-GHOST-001"