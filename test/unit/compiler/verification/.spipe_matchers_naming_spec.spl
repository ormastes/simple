use verification.lean.naming as naming

describe "Lean Naming Conventions":
    context "PascalCase":
        it "converts snake case":
            expect naming.to_pascal_case("ref_capability") == "RefCapability"

        it "handles empty input":
            expect naming.to_pascal_case("") == ""

    context "camelCase":
        it "converts snake case":
            expect naming.to_camel_case("get_value") == "getValue"

        it "lowercases the first character":
            expect naming.to_camel_case("UPPER") == "uPPER"

    context "reserved words":
        it "detects Lean keywords":
            expect naming.is_reserved("let") == true
            expect naming.is_reserved("forall") == true
            expect naming.is_reserved("myFunction") == false

        it "escapes reserved identifiers":
            expect naming.sanitize_lean_ident("def") == "«def»"
            expect naming.sanitize_lean_ident("myVar") == "myVar"

    context "Lean name helpers":
        it "converts type names":
            expect naming.to_lean_type_name("my_type") == "MyType"
            expect naming.to_lean_type_name("type") == "«Type»"

        it "converts function names":
            expect naming.to_lean_func_name("my_function") == "myFunction"
            expect naming.to_lean_func_name("let") == "«let»"

        it "converts namespaces and identifiers":
            expect naming.to_lean_namespace("std.collections") == "Std.Collections"
            expect naming.to_lean_ident("my-var") == "my_var"
            expect naming.to_lean_ident("123abc") == "_123abc"