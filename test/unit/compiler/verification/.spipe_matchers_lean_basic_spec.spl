use verification.lean.emitter as emitter
use verification.lean.naming as naming

describe "Lean Basic":
    context "LeanEmitter":
        it "emits indented lines":
            var emit = emitter.LeanEmitter.new()
            emit.emit_line("structure Foo where")
            emit.indent()
            emit.emit_line("x : Int")
            emit.emit_line("y : Bool")
            emit.dedent()

            val output = emit.finish()
            expect (output).contains("structure Foo where")
            expect (output).contains("  x : Int")
            expect (output).contains("  y : Bool")

        it "renders structure and theorem helpers":
            var emit = emitter.LeanEmitter.new()
            emit.emit_structure_data("Point", [("x", "Int"), ("y", "Int")], ["Repr"])
            emit.emit_theorem_data("point_eq", [("x", "Int")], "x = x", Some("rfl"), false)

            val output = emit.finish()
            expect (output).contains("structure Point where")
            expect (output).contains("deriving Repr")
            expect (output).contains("theorem point_eq")
            expect (output).contains("rfl")

    context "Naming conventions":
        it "translates module and identifier names":
            expect naming.to_pascal_case("my_type") == "MyType"
            expect naming.to_camel_case("get_value") == "getValue"
            expect naming.to_lean_namespace("std.collections") == "Std.Collections"
            expect naming.to_lean_ident("my var") == "my_var"

        it "detects and escapes reserved words":
            expect naming.is_reserved("let") == true
            expect naming.is_reserved("myVar") == false
            expect naming.sanitize_lean_ident("def") == "«def»"