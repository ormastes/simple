use verification.regenerate as regen
use verification.regenerate.async_compile as regen_async
use verification.regenerate.gc_manual_borrow as regen_gc
use verification.regenerate.memory_capabilities as regen_mem_cap

describe "Lean Regeneration":
    context "module generators":
        it "regenerates async compile output":
            val lean_code = regen_async.regenerate_async_compile()
            expect (lean_code).contains("inductive Effect")
            expect (lean_code).contains("theorem append_safe")
            expect (lean_code).contains("theorem wait_detected")
            expect lean_code.contains("sorry") == false

        it "regenerates GC borrow output":
            val lean_code = regen_gc.regenerate_gc_manual_borrow()
            expect (lean_code).contains("structure GcState")
            expect (lean_code).contains("theorem borrow_preserves")
            expect (lean_code).contains("theorem collect_preserves")
            expect lean_code.contains("sorry") == false

        it "regenerates memory capability output":
            val lean_code = regen_mem_cap.regenerate_memory_capabilities()
            expect (lean_code).contains("inductive RefCapability")
            expect (lean_code).contains("def canConvert")
            expect (lean_code).contains("theorem conversion_is_safe")

    context "regenerate_all":
        it "returns all expected file entries":
            val files = regen.regenerate_all()
            expect files.len() == 15
            expect files.has("src/verification/async_compile/src/AsyncCompile.lean") == true
            expect files.has("src/verification/gc_manual_borrow/src/GcManualBorrow.lean") == true

            if files.has("src/verification/async_compile/src/AsyncCompile.lean"):
                val async_file = files.get("src/verification/async_compile/src/AsyncCompile.lean")
                expect async_file.contains("theorem append_safe") == true
            else:
                expect false == true