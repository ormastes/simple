"""
# Newtype Auto-Derived Operators Specification

**Feature IDs:** #LANG-043
**Category:** Language
**Difficulty:** 2/5
**Status:** Implemented
**Requirements:** N/A
**Plan:** N/A
**Design:** N/A
**Research:** N/A

## Overview

Newtypes wrapping numeric primitives (i64, f64) auto-derive dunder methods
for arithmetic (`__add__`, `__sub__`, `__mul__`, `__div__`) and comparison
(`__eq__`, `__lt__`, `__gt__`) operators. This allows natural operator syntax
(`a + b`, `a < b`) on newtype instances without manual boilerplate.

## Syntax

```simple
newtype Width = i64
val a = Width(value: 3)
val b = Width(value: 4)
val c = a + b          # Width(value: 7)
val eq = a == b        # false
```

## Key Concepts

| Concept | Description |
|---------|-------------|
| newtype | A distinct type wrapping a single underlying value |
| auto-derive | Dunder methods generated automatically for numeric wrappers |
| type safety | Width + Width = Width; prevents mixing Width with Height |
"""

# ============================================================================
# i64 newtype operators
# ============================================================================

newtype Width = i64

describe "newtype i64 operators":
    """
    ## Arithmetic and Comparison on i64 Newtypes

    Verifies that `newtype Width = i64` auto-derives all expected
    arithmetic and comparison operators.
    """

    describe "arithmetic":
        it "supports addition":
            val a = Width(value: 3)
            val b = Width(value: 4)
            val c = a + b
            expect(c.value).to_equal(7)

        it "supports subtraction":
            val a = Width(value: 10)
            val b = Width(value: 3)
            val c = a - b
            expect(c.value).to_equal(7)

        it "supports multiplication":
            val a = Width(value: 3)
            val b = Width(value: 4)
            val c = a * b
            expect(c.value).to_equal(12)

        it "supports division":
            val a = Width(value: 12)
            val b = Width(value: 4)
            val c = a / b
            expect(c.value).to_equal(3)

    describe "comparison":
        it "supports equality when equal":
            val a = Width(value: 5)
            val b = Width(value: 5)
            expect(a == b).to_equal(true)

        it "supports equality when not equal":
            val a = Width(value: 5)
            val b = Width(value: 3)
            expect(a == b).to_equal(false)

        it "supports less than":
            val a = Width(value: 3)
            val b = Width(value: 5)
            expect(a < b).to_equal(true)

        it "supports less than when not less":
            val a = Width(value: 5)
            val b = Width(value: 3)
            expect(a < b).to_equal(false)

        it "supports greater than":
            val a = Width(value: 5)
            val b = Width(value: 3)
            expect(a > b).to_equal(true)

        it "supports greater than when not greater":
            val a = Width(value: 3)
            val b = Width(value: 5)
            expect(a > b).to_equal(false)

    describe "edge cases":
        it "handles zero values":
            val a = Width(value: 0)
            val b = Width(value: 0)
            val c = a + b
            expect(c.value).to_equal(0)
            expect(a == b).to_equal(true)

        it "handles negative values":
            val a = Width(value: -3)
            val b = Width(value: 2)
            val c = a + b
            expect(c.value).to_equal(-1)

        it "handles subtraction resulting in negative":
            val a = Width(value: 3)
            val b = Width(value: 10)
            val c = a - b
            expect(c.value).to_equal(-7)

# ============================================================================
# f64 newtype operators
# ============================================================================

newtype Temperature = f64

describe "newtype f64 operators":
    """
    ## Arithmetic and Comparison on f64 Newtypes

    Verifies that `newtype Temperature = f64` auto-derives the same
    operators, working correctly with floating-point values.
    """

    describe "arithmetic":
        it "supports addition":
            val a = Temperature(value: 1.5)
            val b = Temperature(value: 2.5)
            val c = a + b
            expect(c.value).to_equal(4.0)

        it "supports subtraction":
            val a = Temperature(value: 10.5)
            val b = Temperature(value: 3.5)
            val c = a - b
            expect(c.value).to_equal(7.0)

        it "supports multiplication":
            val a = Temperature(value: 2.5)
            val b = Temperature(value: 4.0)
            val c = a * b
            expect(c.value).to_equal(10.0)

        it "supports division":
            val a = Temperature(value: 9.0)
            val b = Temperature(value: 3.0)
            val c = a / b
            expect(c.value).to_equal(3.0)

    describe "comparison":
        it "supports equality":
            val a = Temperature(value: 36.6)
            val b = Temperature(value: 36.6)
            expect(a == b).to_equal(true)

        it "supports less than":
            val a = Temperature(value: 20.0)
            val b = Temperature(value: 30.0)
            expect(a < b).to_equal(true)

        it "supports greater than":
            val a = Temperature(value: 30.0)
            val b = Temperature(value: 20.0)
            expect(a > b).to_equal(true)

    describe "edge cases":
        it "handles zero values":
            val a = Temperature(value: 0.0)
            val b = Temperature(value: 0.0)
            val c = a + b
            expect(c.value).to_equal(0.0)

        it "handles negative values":
            val a = Temperature(value: -10.5)
            val b = Temperature(value: 5.5)
            val c = a + b
            expect(c.value).to_equal(-5.0)

# ============================================================================
# Type safety: distinct newtypes don't mix
# ============================================================================

newtype Height = i64

describe "newtype type safety":
    """
    ## Type Safety Between Distinct Newtypes

    Ensures that different newtypes wrapping the same underlying type
    remain distinct. Width and Height are both i64, but operations
    within each type produce the correct newtype.
    """

    it "Width operations produce Width":
        val a = Width(value: 3)
        val b = Width(value: 4)
        val c = a + b
        expect(c.value).to_equal(7)

    it "Height operations produce Height":
        val a = Height(value: 10)
        val b = Height(value: 5)
        val c = a + b
        expect(c.value).to_equal(15)
