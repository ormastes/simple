# R2-broader Phase 2 regression: `expect(...).to_*(...)` matcher folds in
# `rewrite_method_expect_line` (src/compiler_rust/driver/src/cli/test_runner/
# execution.rs) drop the unlinkable `Expectation` class and produce HIR-
# recognized infix forms.
#
# Run in compile mode:
#   bin/simple test --mode=smf --force-rebuild test/unit/compiler/r2_matchers_compile_spec.spl
#
# Coverage today (2026-04-26): only matchers whose folded primitive is fully
# wired through HIR + the BDD runtime (`rt_bdd_expect_eq_rv`) PASS in SMF
# mode. The remaining matchers fold correctly at the source level (see the
# wrapped `.sspec_wrapped_entry_*.spl`), but their primitive trips one of
# three pre-existing upstream bugs documented in
# ~/.claude/projects/-home-ormastes-dev-pub-simple/memory/
# feedback_compile_mode_false_greens.md (Phase 2 status update):
#   - `rt_bdd_expect_truthy_rv` on bool / comparison results false-fails
#   - `rt_bdd_expect_eq_rv` on string operands compares pointers, not values
#   - parser binds `expect (expr).method(...)` as `expect(expr)` then `.method`
#
# Once those land, extend this spec with the rest of the matcher table.

describe "R2 matcher folds (compile-mode regression)":
    it "to_equal folds to == (int operands)":
        expect(1 + 1).to_equal(2)

    it "to_be_nil folds to == nil":
        expect(nil).to_be_nil()
