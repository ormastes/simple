use std.spec.{describe, it, expect}
use app.io.mod.{dir_create_all, file_write}
use app.io.process_ops.{shell}
use compiler.backend.backend.backend_types.{CodegenTarget}
use compiler.backend.portable_numeric_capabilities.{portable_numeric_default_plan_for_target}
use compiler.backend.backend.llvm_target.{LlvmTargetConfig}
use compiler.backend.backend.riscv_target.{riscv_baremetal_target_contract_portable_numeric}

extern fn rt_getpid() -> i64

fn portable_numeric_fixture_root() -> text:
    "/tmp/portable_numeric_capabilities_spec_{rt_getpid()}"

fn portable_numeric_script_path(root: text) -> text:
    "{root}/portable_numeric_probe.spl"

fn portable_numeric_script() -> text:
    "use compiler.backend.target_presets.{preset_linux_x86_64, preset_riscv64_linux, preset_riscv32_baremetal}\n" +
    "use compiler.backend.portable_numeric_capabilities.{PortableNumericFeatureSelection, portable_numeric_default_plan, portable_numeric_lowering_plan}\n" +
    "fn main() -> i64:\n" +
    "    val x86_plan = portable_numeric_default_plan(preset_linux_x86_64())\n" +
    "    if not x86_plan.capabilities.has_scalar_fp or not x86_plan.capabilities.has_vector_simd:\n" +
    "        print \"x86 capability mismatch\"\n" +
    "        return 1\n" +
    "    if not x86_plan.capabilities.requires_runtime_simd_probe:\n" +
    "        print \"x86 runtime probe mismatch\"\n" +
    "        return 1\n" +
    "    if x86_plan.lowering_modules_csv() != \"scalar_fp,vector_simd,scalar_fallback,x86_avx\":\n" +
    "        print \"x86 modules mismatch\"\n" +
    "        return 1\n" +
    "    if x86_plan.diagnostics_csv() != \"x86_avx_requires_runtime_probe\":\n" +
    "        print \"x86 diagnostics mismatch\"\n" +
    "        return 1\n" +
    "    print \"x86-ok\"\n" +
    "    val rv64_plan = portable_numeric_default_plan(preset_riscv64_linux())\n" +
    "    if not rv64_plan.capabilities.has_scalar_fp or rv64_plan.capabilities.has_vector_simd:\n" +
    "        print \"rv64 capability mismatch\"\n" +
    "        return 1\n" +
    "    if not rv64_plan.capabilities.has_riscv_f or not rv64_plan.capabilities.has_riscv_d or rv64_plan.capabilities.has_riscv_v:\n" +
    "        print \"rv64 riscv extension mismatch\"\n" +
    "        return 1\n" +
    "    if rv64_plan.lowering_modules_csv() != \"scalar_fp,scalar_fallback,riscv_fd\":\n" +
    "        print \"rv64 modules mismatch\"\n" +
    "        return 1\n" +
    "    if rv64_plan.diagnostics_csv() != \"vector_simd_requested_but_target_lacks_vector_capability\":\n" +
    "        print \"rv64 diagnostics mismatch\"\n" +
    "        return 1\n" +
    "    print \"rv64-ok\"\n" +
    "    val rv64_scalar_only = portable_numeric_lowering_plan(preset_riscv64_linux(), PortableNumericFeatureSelection.scalar_only())\n" +
    "    if rv64_scalar_only.lowering_modules_csv() != \"scalar_fp,scalar_fallback,riscv_fd\":\n" +
    "        print \"rv64 scalar-only modules mismatch\"\n" +
    "        return 1\n" +
    "    if rv64_scalar_only.diagnostics_csv() != \"\":\n" +
    "        print \"rv64 scalar-only diagnostics mismatch\"\n" +
    "        return 1\n" +
    "    print \"rv64-scalar-only-ok\"\n" +
    "    val rv32_plan = portable_numeric_default_plan(preset_riscv32_baremetal())\n" +
    "    if rv32_plan.capabilities.has_scalar_fp or rv32_plan.capabilities.has_vector_simd:\n" +
    "        print \"rv32 capability mismatch\"\n" +
    "        return 1\n" +
    "    if rv32_plan.lowering_modules_csv() != \"scalar_fallback\":\n" +
    "        print \"rv32 modules mismatch\"\n" +
    "        return 1\n" +
    "    if rv32_plan.diagnostics_csv() != \"scalar_fp_requested_but_target_lacks_fp,vector_simd_requested_but_target_lacks_vector_capability\":\n" +
    "        print \"rv32 diagnostics mismatch\"\n" +
    "        return 1\n" +
    "    print \"rv32-ok\"\n" +
    "    0\n"

describe "Portable numeric capability registry":
    it "derives x86_64 and RISC-V lowering plans from target presets":
        val root = portable_numeric_fixture_root()
        val script_path = portable_numeric_script_path(root)
        val simple_bin = "/home/ormastes/dev/pub/simple/bin/simple"
        val simple_src = "/home/ormastes/dev/pub/simple/src"

        dir_create_all(root)
        expect(file_write(script_path, portable_numeric_script())).to_equal(true)

        val result = shell("cd {root} && SIMPLE_LIB={simple_src} {simple_bin} run {script_path}")
        expect(result.exit_code).to_equal(0)

        expect(result.stdout.contains("x86-ok")).to_equal(true)
        expect(result.stdout.contains("rv64-ok")).to_equal(true)
        expect(result.stdout.contains("rv64-scalar-only-ok")).to_equal(true)
        expect(result.stdout.contains("rv32-ok")).to_equal(true)

        shell("rm -rf {root}")

    it "maps backend codegen targets to portable numeric plans":
        val host_plan = portable_numeric_default_plan_for_target(CodegenTarget.Host)
        expect(host_plan.capabilities.has_scalar_fp).to_equal(true)
        expect(host_plan.capabilities.has_vector_simd).to_equal(true)
        expect(host_plan.lowering_modules_csv()).to_equal("scalar_fp,vector_simd,scalar_fallback,x86_avx")

        val rv32_plan = portable_numeric_default_plan_for_target(CodegenTarget.Riscv32)
        expect(rv32_plan.capabilities.has_scalar_fp).to_equal(false)
        expect(rv32_plan.capabilities.has_vector_simd).to_equal(false)
        expect(rv32_plan.lowering_modules_csv()).to_equal("scalar_fallback")

    it "builds a conservative llvm config for x86_64 portable numeric mode":
        val config = LlvmTargetConfig.for_target_portable_numeric(CodegenTarget.X86_64, nil)
        expect(config.cpu).to_equal("x86-64-v1")
        expect(config.supports_avx2()).to_equal(false)
        expect(config.to_feature_string()).to_equal("")

    it "builds an integer-only rv32 baremetal contract in portable numeric mode":
        val contract = riscv_baremetal_target_contract_portable_numeric(CodegenTarget.Riscv32)
        expect(contract.abi.to_text()).to_equal("ilp32")
        expect(contract.march).to_equal("rv32imac")
        expect(contract.features.contains("+f")).to_equal(false)
        expect(contract.features.contains("+d")).to_equal(false)

    # Phase 2 scenario #2: x86_64 generic preset — AVX flags NOT in LLVM features list
    # AC-1: requires_runtime_simd_probe is the live AVX gate; features list must be empty
    it "AC-1/P2-2: x86_64 generic preset keeps AVX flags out of LLVM features list":
        val config = LlvmTargetConfig.for_target_portable_numeric(CodegenTarget.X86_64, nil)
        expect(config.cpu).to_equal("x86-64-v1")
        expect(config.features.contains("+avx")).to_equal(false)
        expect(config.features.contains("+avx2")).to_equal(false)
        expect(config.to_feature_string()).to_equal("")

    # Phase 2 scenario #3: rv64_linux preset — +f and +d derive from registry, not hardcoded
    # AC-2: riscv_target.spl portable_numeric variant exposes +f/+d from preset, not constant
    it "AC-2/P2-3: rv64_linux portable plan has has_riscv_f and has_riscv_d from registry":
        val plan = portable_numeric_default_plan_for_target(CodegenTarget.Riscv64)
        expect(plan.capabilities.has_riscv_f).to_equal(true)
        expect(plan.capabilities.has_riscv_d).to_equal(true)
        expect(plan.capabilities.has_riscv_v).to_equal(false)

    # Phase 2 scenario #4: rv32_baremetal int-only preset — no +f/+d/+v
    # AC-2: integer-only preset must not expose FP or vector capabilities
    it "AC-2/P2-4: rv32_baremetal int-only preset has no FP or vector capability flags":
        val plan = portable_numeric_default_plan_for_target(CodegenTarget.Riscv32)
        expect(plan.capabilities.has_riscv_f).to_equal(false)
        expect(plan.capabilities.has_riscv_d).to_equal(false)
        expect(plan.capabilities.has_riscv_v).to_equal(false)
        expect(plan.capabilities.has_scalar_fp).to_equal(false)

    # GAP-1 scenario #7: generic x86_64 LLVM target — cpu=="x86-64-v1" and features has no +avx/+avx2
    # AC-4 negative: "generic-x86_64-claiming-AVX2" rejection
    it "AC-4/GAP-1: generic x86_64 LLVM target does not claim AVX or AVX2 features":
        val config = LlvmTargetConfig.for_target_portable_numeric(CodegenTarget.X86_64, nil)
        expect(config.cpu).to_equal("x86-64-v1")
        expect(config.features.contains("+avx")).to_equal(false)
        expect(config.features.contains("+avx2")).to_equal(false)

    # Zicbom cross-feature contract: Feature B reads these 4 fields; Feature A establishes false defaults
    # All existing presets must expose the 4 new bool fields with false defaults
    it "Feature-B-contract: Zicbom/Zicboz/Zicbop/cache-probe fields are false across all presets":
        val x86_plan = portable_numeric_default_plan_for_target(CodegenTarget.X86_64)
        expect(x86_plan.capabilities.has_riscv_zicbom).to_equal(false)
        expect(x86_plan.capabilities.has_riscv_zicboz).to_equal(false)
        expect(x86_plan.capabilities.has_riscv_zicbop).to_equal(false)
        expect(x86_plan.capabilities.requires_runtime_cache_probe).to_equal(false)

        val rv64_plan = portable_numeric_default_plan_for_target(CodegenTarget.Riscv64)
        expect(rv64_plan.capabilities.has_riscv_zicbom).to_equal(false)
        expect(rv64_plan.capabilities.has_riscv_zicboz).to_equal(false)
        expect(rv64_plan.capabilities.has_riscv_zicbop).to_equal(false)
        expect(rv64_plan.capabilities.requires_runtime_cache_probe).to_equal(false)

        val rv32_plan = portable_numeric_default_plan_for_target(CodegenTarget.Riscv32)
        expect(rv32_plan.capabilities.has_riscv_zicbom).to_equal(false)
        expect(rv32_plan.capabilities.has_riscv_zicboz).to_equal(false)
        expect(rv32_plan.capabilities.has_riscv_zicbop).to_equal(false)
        expect(rv32_plan.capabilities.requires_runtime_cache_probe).to_equal(false)
