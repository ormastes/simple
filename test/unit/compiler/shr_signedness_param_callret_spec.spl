# Right-shift signedness coverage for function-parameter and call-return paths.
#
# Complements `shr_signedness_test.spl` (which covers local variables).
# These tests exercise param-receive and call-return widening in both
# Cranelift (already correct) and LLVM (fixed in this change) backends.
#
# @tag: compiler,regression,shift,llvm,param,call-return

use std.spec.describe
use std.spec.it
use std.spec.expect

# ---------------------------------------------------------------------------
# Parameter path — value arrives via ABI, may need widening
# ---------------------------------------------------------------------------

fn shr_signed_param(x: i32) -> i32:
    return x >> 1

fn shr_unsigned_param(x: u32) -> u32:
    return x >> 1

# ---------------------------------------------------------------------------
# Call-return path — callee returns narrow type, caller shifts
# ---------------------------------------------------------------------------

fn get_neg_sixteen() -> i32:
    return -16

fn get_high_bit() -> u32:
    return 2147483648 as u32

# ---------------------------------------------------------------------------
# Specs
# ---------------------------------------------------------------------------

describe "right-shift signedness — param + call-return paths":
    it "signed param: shr_signed_param(-16) yields -8":
        val got: i32 = shr_signed_param(-16)
        expect(got).to_equal(-8)

    it "unsigned param: shr_unsigned_param(2147483648) yields 1073741824":
        val got: u32 = shr_unsigned_param(2147483648 as u32)
        val expected: u32 = 1073741824 as u32
        expect(got).to_equal(expected)

    it "signed call-return: get_neg_sixteen() >> 1 yields -8":
        val v: i32 = get_neg_sixteen()
        val got: i32 = v >> 1
        expect(got).to_equal(-8)

    it "unsigned call-return: get_high_bit() >> 1 yields 1073741824":
        val v: u32 = get_high_bit()
        val got: u32 = v >> 1
        val expected: u32 = 1073741824 as u32
        expect(got).to_equal(expected)
