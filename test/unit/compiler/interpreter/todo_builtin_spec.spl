"""
# Todo Builtin Interpreter Coverage
"""

use compiler.core.interpreter.{eval_builtin_call, val_get_kind, VAL_NIL}

describe "todo builtin interpreter behavior":
    it "evaluates todo as nil no-op":
        val result = eval_builtin_call("todo", [])
        expect(val_get_kind(result)).to_equal(VAL_NIL)
