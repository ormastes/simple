"""
# u64 Literal Precision Specification

**Feature IDs:** #INTERP-U64-LITERAL
**Category:** Interpreter
**Difficulty:** 2/5
**Status:** Regression

## Overview

Regression test for the high-bit `u64` literal bug tracked in
`doc/08_tracking/bug/parser_64bit_hex_literal_precision_loss_2026-05-03.md`.
The lexer already preserves the raw 64-bit pattern for explicit `u64`
literals, but the interpreter method dispatcher still routed `Value::UInt`
receivers through the signed integer method table. That made conversions like
`.to_text()` reinterpret values above `i64::MAX` as negative numbers.
"""

import std.spec

describe "u64 literal precision":
    it "renders high-bit u64 literals as unsigned text":
        expect (0x8000000000000000u64).to_text() == "9223372036854775808"
        expect (0xFFFFFFFFFFFFFFFFu64).to_text() == "18446744073709551615"
        expect (0xCAFEBABEDEADBEEFu64).to_text() == "14627333968688430831"

    it "keeps the original 64-bit hex text":
        expect (0x8000000000000000u64).to_hex() == "8000000000000000"
        expect (0xFFFFFFFFFFFFFFFFu64).to_hex() == "ffffffffffffffff"
        expect (0xCAFEBABEDEADBEEFu64).to_hex() == "cafebabedeadbeef"