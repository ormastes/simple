"""
# SmfSource Specification

**Feature IDs:** #SMF-009
**Category:** Infrastructure
**Difficulty:** 1/5
**Status:** In Progress
**Plan:** doc/03_plan/smf_load_enable_plan.md

## Overview

Tests for the SmfSource enum — unified abstraction for file-backed
and in-memory SMF modules.
"""

import std.spec

describe "SmfSource":
    it "creates file source and reports name":
        val src = SmfSource.FileSmf(path: "/cache/mod.smf")
        expect smf_source_get_name(src) == "/cache/mod.smf"

    it "creates memory source and reports name":
        val bytes: [u8] = [0, 1, 2, 3]
        val src = SmfSource.MemorySmf(bytes: bytes, logical_name: "std.text")
        expect smf_source_get_name(src) == "std.text"

    it "identifies file source correctly":
        val src = SmfSource.FileSmf(path: "/a.smf")
        expect smf_source_is_file(src) == true
        expect smf_source_is_memory(src) == false

    it "identifies memory source correctly":
        val bytes: [u8] = [0]
        val src = SmfSource.MemorySmf(bytes: bytes, logical_name: "m")
        expect smf_source_is_file(src) == false
        expect smf_source_is_memory(src) == true

    it "returns file path for file source":
        val src = SmfSource.FileSmf(path: "/cache/x.smf")
        expect smf_source_file_path(src) == "/cache/x.smf"

    it "returns empty path for memory source":
        val bytes: [u8] = [0]
        val src = SmfSource.MemorySmf(bytes: bytes, logical_name: "m")
        expect smf_source_file_path(src) == ""

    it "describes file source":
        val src = SmfSource.FileSmf(path: "/a.smf")
        expect (smf_source_describe(src)).starts_with("file:")

    it "describes memory source":
        val bytes: [u8] = [0]
        val src = SmfSource.MemorySmf(bytes: bytes, logical_name: "mod")
        expect (smf_source_describe(src)).starts_with("memory:")