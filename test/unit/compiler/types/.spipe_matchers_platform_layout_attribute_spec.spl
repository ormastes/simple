"""
# Platform Layout Attribute Specification

Tests the first @platform slice:
- typed platform predicate/variant data structures
- parsing of @platform attributes
- diagnostics helpers for duplicate, ambiguous, default, and missing-hint cases
"""

use std.spec

use compiler.common.attributes.{parse_platform_attrs}
use compiler.types.type_layout.{
    PlatformAbi, PlatformBit, PlatformDiagnosticLevel,
    platform_cpu_for_arch, platform_pointer_bit_for_arch,
    platform_predicate_matches_arch, platform_select_variant_for_arch
}
use compiler.frontend.parser_types.{Attribute, Expr, ExprKind}
use std.common.target.{TargetArch}
from lexer import {Span}

# ============================================================================
# Helpers
# ============================================================================

fn empty_span() -> Span:
    Span(start: 0, end_pos: 0, line: 1, col: 1)

fn make_ident_expr(name: text) -> Expr:
    Expr(kind: ExprKind.Ident(name), span: empty_span())

fn make_int_expr(value: i64) -> Expr:
    Expr(kind: ExprKind.IntLit(value), span: empty_span())

fn make_assign_expr(name: text, value: Expr) -> Expr:
    Expr(
        kind: ExprKind.Assign(make_ident_expr(name), nil, value),
        span: empty_span()
    )

fn make_platform_attr(args: [Expr]) -> Attribute:
    Attribute(
        name: "platform",
        args: args,
        span: empty_span()
    )

fn make_unrelated_attr() -> Attribute:
    Attribute(
        name: "repr",
        args: [make_ident_expr("C")],
        span: empty_span()
    )

fn contains_message(result, needle: text) -> bool:
    var i = 0
    while i < result.diagnostics.len():
        if result.diagnostics[i].message().contains(needle):
            return true
        i = i + 1
    false

# ============================================================================
# Tests
# ============================================================================

describe "Platform layout attributes":
    """
    Verifies typed parsing and validation diagnostics for platform-specific
    layout metadata used by ABI-sensitive declarations.
    """

    describe "parse_platform_attrs":
        it "returns an empty result when no platform attributes are present":
            val result = parse_platform_attrs([make_unrelated_attr()])
            expect result.variants.len() == 0
            expect result.diagnostics.len() == 0

        it "parses @platform and @platform(bit) into typed predicates":
            val result = parse_platform_attrs([
                make_platform_attr([]),
                make_platform_attr([make_ident_expr("bit")])
            ])

            expect result.variants.len() == 2
            expect result.variants[0].predicate.has_default == true
            expect result.variants[0].predicate.has_bit == false
            expect result.variants[1].predicate.has_default == false
            expect result.variants[1].predicate.has_bit == true
            expect result.variants[1].predicate.bit == PlatformBit.Pointer
            expect contains_message(result, "explicit bit, size, or align") == true

        it "normalizes cpu, os, abi, and bit values":
            val result = parse_platform_attrs([
                make_platform_attr([
                    make_assign_expr("cpu", make_ident_expr("x86_64")),
                    make_assign_expr("os", make_ident_expr("linux")),
                    make_assign_expr("abi", make_ident_expr("gnu")),
                    make_assign_expr("bit", make_int_expr(64))
                ])
            ])

            expect result.variants.len() == 1
            val variant = result.variants[0]
            expect variant.predicate.has_cpu == true
            expect variant.predicate.cpu == "x86_64"
            expect variant.predicate.has_os == true
            expect variant.predicate.os == "linux"
            expect variant.predicate.has_abi == true
            expect variant.predicate.abi == PlatformAbi.Gnu
            expect variant.predicate.has_bit == true
            expect variant.predicate.bit == PlatformBit.Bits64
            expect result.diagnostics.len() == 0

        it "rejects unknown keys and values":
            val result = parse_platform_attrs([
                make_platform_attr([
                    make_assign_expr("cpu", make_ident_expr("plan9")),
                    make_assign_expr("os", make_ident_expr("haiku")),
                    make_assign_expr("abi", make_ident_expr("weird")),
                    make_assign_expr("bit", make_int_expr(17)),
                    make_assign_expr("zip", make_int_expr(1))
                ])
            ])

            expect contains_message(result, "unknown @platform value 'plan9' for key 'cpu'") == true
            expect contains_message(result, "unknown @platform value 'haiku' for key 'os'") == true
            expect contains_message(result, "unknown @platform value 'weird' for key 'abi'") == true
            expect contains_message(result, "unknown @platform value '17' for key 'bit'") == true
            expect contains_message(result, "unknown @platform key 'zip'") == true

        it "flags duplicate default variants":
            val result = parse_platform_attrs([
                make_platform_attr([make_ident_expr("default")]),
                make_platform_attr([make_ident_expr("default")])
            ])

            expect contains_message(result, "duplicate @platform default fallback") == true

        it "flags duplicate exact predicates":
            val result = parse_platform_attrs([
                make_platform_attr([make_assign_expr("bit", make_int_expr(64))]),
                make_platform_attr([make_assign_expr("bit", make_int_expr(64))])
            ])

            expect contains_message(result, "duplicate @platform predicate") == true

        it "flags ambiguous predicates with different layout hints":
            val result = parse_platform_attrs([
                make_platform_attr([
                    make_assign_expr("cpu", make_ident_expr("x86_64")),
                    make_assign_expr("os", make_ident_expr("linux")),
                    make_assign_expr("abi", make_ident_expr("gnu")),
                    make_assign_expr("bit", make_int_expr(64))
                ]),
                make_platform_attr([
                    make_assign_expr("cpu", make_ident_expr("x86_64")),
                    make_assign_expr("os", make_ident_expr("linux")),
                    make_assign_expr("abi", make_ident_expr("gnu")),
                    make_assign_expr("bit", make_int_expr(64)),
                    make_assign_expr("size", make_int_expr(16))
                ])
            ])

            expect contains_message(result, "ambiguous @platform predicate") == true

        it "warns when no explicit size, align, or bit hint is provided":
            val result = parse_platform_attrs([
                make_platform_attr([make_ident_expr("default")])
            ])

            expect result.diagnostics.len() > 0
            expect result.diagnostics[0].level() == PlatformDiagnosticLevel.Warning
            expect(result.diagnostics[0].message()).to_equal(
                "@platform variant should spell out bit, size, or align explicitly"
            )

        it "maps target architectures to canonical platform cpu and pointer bits":
            expect platform_cpu_for_arch(TargetArch.X86_64) == "x86_64"
            expect platform_cpu_for_arch(TargetArch.X86) == "x86"
            expect platform_cpu_for_arch(TargetArch.Aarch64) == "aarch64"
            expect platform_cpu_for_arch(TargetArch.Arm) == "arm"
            expect platform_cpu_for_arch(TargetArch.Riscv64) == "riscv64"
            expect platform_cpu_for_arch(TargetArch.Riscv32) == "riscv32"
            expect platform_pointer_bit_for_arch(TargetArch.Riscv64) == PlatformBit.Bits64
            expect platform_pointer_bit_for_arch(TargetArch.Riscv32) == PlatformBit.Bits32

        it "matches platform predicates against target architecture and pointer width":
            val result = parse_platform_attrs([
                make_platform_attr([
                    make_assign_expr("cpu", make_ident_expr("riscv64")),
                    make_assign_expr("bit", make_int_expr(64))
                ]),
                make_platform_attr([
                    make_assign_expr("cpu", make_ident_expr("riscv32")),
                    make_assign_expr("bit", make_int_expr(32))
                ])
            ])

            expect platform_predicate_matches_arch(result.variants[0].predicate, TargetArch.Riscv64) == true
            expect platform_predicate_matches_arch(result.variants[0].predicate, TargetArch.Riscv32) == false
            expect platform_predicate_matches_arch(result.variants[1].predicate, TargetArch.Riscv32) == true

        it "selects the most specific matching variant before default fallback":
            val result = parse_platform_attrs([
                make_platform_attr([
                    make_ident_expr("default"),
                    make_assign_expr("bit", make_int_expr(64))
                ]),
                make_platform_attr([
                    make_assign_expr("bit", make_int_expr(32))
                ]),
                make_platform_attr([
                    make_assign_expr("cpu", make_ident_expr("riscv32")),
                    make_assign_expr("bit", make_int_expr(32)),
                    make_assign_expr("size", make_int_expr(4))
                ])
            ])

            val rv32 = platform_select_variant_for_arch(result.variants, TargetArch.Riscv32)
            val rv64 = platform_select_variant_for_arch(result.variants, TargetArch.Riscv64)

            expect rv32.? == true
            expect rv32.unwrap().predicate.has_cpu == true
            expect rv32.unwrap().predicate.cpu == "riscv32"
            expect rv64.? == true
            expect rv64.unwrap().predicate.has_default == true