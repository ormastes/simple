# Regression test: module-level typed var declarations resolve correctly
#
# Phase 0A fix: HIR module_pass.rs extract_pattern_type()
# Before fix: `var x: u64 = 42` resolved as TypeId::ANY → string concat
# After fix: resolves as u64 → native integer arithmetic
#
# @tag: compiler,regression,global

describe "Module-level typed variable declarations":
    it "var with u64 type annotation preserves integer semantics":
        var x: u64 = 100
        val result = x + 1
        expect(result).to_equal(101)

    it "val with u64 type preserves integer semantics":
        val y: u64 = 200
        val result = y + 50
        expect(result).to_equal(250)

    it "var with i64 type supports negative values":
        var z: i64 = -10
        val result = z + 20
        expect(result).to_equal(10)

    it "global var assignment and read round-trips":
        var addr: u64 = 0xFD000000
        val offset: u64 = 0x1000
        val computed = addr + offset
        expect(computed).to_equal(0xFD001000)
