# Builder Default Parser Tests
#
# @req STUB-001
# @cover src/compiler/15.blocks/blocks/builder.spl
#
# Verifies that BlockBuilder has a working default parser
# (previously was nil, causing nil function reference on build).

use std.test.*
use compiler.blocks.blocks.builder.{blockbuilder_new}
use compiler.blocks.blocks.value.{BlockValue}

describe "BlockBuilder Default Parser":
    context "builder created without explicit parser":
        it "has a non-nil default parser":
            val builder = blockbuilder_new("test_block")
            expect(builder._parser.?).to_equal(true)

        it "default parser is callable":
            val builder = blockbuilder_new("test_block")
            val parser = builder._parser
            expect(parser.?).to_equal(true)
