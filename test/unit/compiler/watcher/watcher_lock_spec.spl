# Watcher Lock Specification
#
# Tests singleton enforcement via lock file with PID.
# Uses module-level vars for mock state (avoids nested closure mutation).
#
# **Feature IDs:** #WATCH-011 to #WATCH-020
# **Category:** Infrastructure

# ============================================================================
# Module-level mock state
# ============================================================================

var mock_lock_pids: [i64] = []      # PIDs holding locks (parallel arrays)
var mock_lock_paths: [text] = []     # Lock paths (parallel arrays)
var mock_alive_pids: [i64] = []
var mock_my_pid: i64 = 1000

fn lock_reset():
    mock_lock_pids = []
    mock_lock_paths = []
    mock_alive_pids = [1000]
    mock_my_pid = 1000

fn lock_find(path: text) -> i64:
    # Returns index or -1
    var i = 0
    while i < mock_lock_paths.len():
        if mock_lock_paths[i] == path:
            return i
        i = i + 1
    -1

fn lock_get_pid(path: text) -> i64:
    val idx = lock_find(path)
    if idx >= 0:
        return mock_lock_pids[idx]
    -1

fn lock_set(path: text, pid: i64):
    val idx = lock_find(path)
    if idx >= 0:
        mock_lock_pids[idx] = pid
    else:
        mock_lock_paths = mock_lock_paths + [path]
        mock_lock_pids = mock_lock_pids + [pid]

fn lock_remove(path: text):
    val idx = lock_find(path)
    if idx >= 0:
        # Remove by rebuilding arrays without this index
        var new_pids: [i64] = []
        var new_paths: [text] = []
        var i = 0
        while i < mock_lock_paths.len():
            if i != idx:
                new_pids = new_pids + [mock_lock_pids[i]]
                new_paths = new_paths + [mock_lock_paths[i]]
            i = i + 1
        mock_lock_pids = new_pids
        mock_lock_paths = new_paths

fn pid_alive(pid: i64) -> bool:
    var i = 0
    while i < mock_alive_pids.len():
        if mock_alive_pids[i] == pid:
            return true
        i = i + 1
    false

fn try_acquire(path: text) -> i64:
    val existing_idx = lock_find(path)
    if existing_idx >= 0:
        val existing_pid = mock_lock_pids[existing_idx]
        if pid_alive(existing_pid):
            return -1
        lock_remove(path)

    lock_set(path, mock_my_pid)
    mock_my_pid

fn release_lock(pid: i64, path: text) -> bool:
    val existing_pid = lock_get_pid(path)
    if existing_pid < 0:
        return true
    if existing_pid != pid:
        return false
    lock_remove(path)
    true

fn is_running(path: text) -> bool:
    val pid = lock_get_pid(path)
    if pid < 0:
        return false
    pid_alive(pid)

# ============================================================================
# Tests
# ============================================================================

describe "WatcherLock":
    describe "acquisition":
        it "acquires lock when no existing lock":
            lock_reset()
            val pid = try_acquire(".build/watcher/watcher.lock")
            expect(pid).to_equal(1000)
            expect(is_running(".build/watcher/watcher.lock")).to_equal(true)

        it "fails when another watcher is running":
            lock_reset()
            val pid1 = try_acquire(".build/watcher/watcher.lock")
            val pid2 = try_acquire(".build/watcher/watcher.lock")
            expect(pid1).to_equal(1000)
            expect(pid2).to_equal(-1)

        it "acquires stale lock from dead process":
            lock_reset()
            lock_set(".build/watcher/watcher.lock", 9999)
            val pid = try_acquire(".build/watcher/watcher.lock")
            expect(pid).to_equal(1000)

    describe "release":
        it "releases owned lock":
            lock_reset()
            val pid = try_acquire(".build/watcher/watcher.lock")
            val released = release_lock(pid, ".build/watcher/watcher.lock")
            expect(released).to_equal(true)
            expect(is_running(".build/watcher/watcher.lock")).to_equal(false)

        it "refuses to release lock owned by another":
            lock_reset()
            lock_set(".build/watcher/watcher.lock", 2000)
            mock_alive_pids = mock_alive_pids + [2000]
            val released = release_lock(1000, ".build/watcher/watcher.lock")
            expect(released).to_equal(false)

        it "returns true for already-released lock":
            lock_reset()
            val released = release_lock(1000, ".build/watcher/watcher.lock")
            expect(released).to_equal(true)

    describe "status":
        it "reports not running when no lock":
            lock_reset()
            expect(is_running(".build/watcher/watcher.lock")).to_equal(false)

        it "reports running when lock held by alive process":
            lock_reset()
            try_acquire(".build/watcher/watcher.lock")
            expect(is_running(".build/watcher/watcher.lock")).to_equal(true)

        it "reports not running for dead process lock":
            lock_reset()
            lock_set(".build/watcher/watcher.lock", 9999)
            expect(is_running(".build/watcher/watcher.lock")).to_equal(false)

    describe "PID reading":
        it "reads PID from lock":
            lock_reset()
            try_acquire(".build/watcher/watcher.lock")
            val pid = lock_get_pid(".build/watcher/watcher.lock")
            expect(pid).to_equal(1000)

        it "returns -1 for missing lock":
            lock_reset()
            val pid = lock_get_pid(".build/watcher/watcher.lock")
            expect(pid).to_equal(-1)
