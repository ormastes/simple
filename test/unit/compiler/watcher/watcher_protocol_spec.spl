# Watcher Protocol Specification
#
# Tests file-based request/response protocol for watcher IPC.
#
# **Feature IDs:** #WATCH-021 to #WATCH-030
# **Category:** Infrastructure

# ============================================================================
# Module-level mock filesystem
# ============================================================================

var proto_files: [text] = []       # file paths
var proto_contents: [text] = []    # file contents (parallel)

fn proto_reset():
    proto_files = []
    proto_contents = []

fn proto_find(path: text) -> i64:
    var i = 0
    while i < proto_files.len():
        if proto_files[i] == path:
            return i
        i = i + 1
    -1

fn proto_write(path: text, content: text) -> bool:
    val idx = proto_find(path)
    if idx >= 0:
        proto_contents[idx] = content
    else:
        proto_files = proto_files + [path]
        proto_contents = proto_contents + [content]
    true

fn proto_read(path: text) -> text:
    val idx = proto_find(path)
    if idx >= 0:
        return proto_contents[idx]
    ""

fn proto_exists(path: text) -> bool:
    proto_find(path) >= 0

fn proto_delete(path: text) -> bool:
    val idx = proto_find(path)
    if idx < 0:
        return false
    var new_files: [text] = []
    var new_contents: [text] = []
    var i = 0
    while i < proto_files.len():
        if i != idx:
            new_files = new_files + [proto_files[i]]
            new_contents = new_contents + [proto_contents[i]]
        i = i + 1
    proto_files = new_files
    proto_contents = new_contents
    true

fn proto_list_req() -> [text]:
    var result: [text] = []
    var i = 0
    while i < proto_files.len():
        if proto_files[i].ends_with(".req"):
            result = result + [proto_files[i]]
        i = i + 1
    result

# ============================================================================
# Mock protocol functions
# ============================================================================

fn make_req_path(source_path: text, request_dir: text) -> text:
    # Avoid chained .replace() — use intermediate var
    var tmp = source_path.replace("/", "_")
    val base = tmp.replace(".spl", "")
    "{request_dir}/{base}.req"

fn mock_write_request(source_path: text, kind: text, request_dir: text) -> text:
    val req_path = make_req_path(source_path, request_dir)
    var content = "source_path={source_path}\n"
    content = content + "kind={kind}\n"
    content = content + "source_hash=0\n"
    content = content + "options_hash=0\n"
    content = content + "timestamp=1000\n"
    proto_write(req_path, content)
    req_path

fn extract_field(content: text, prefix: text) -> text:
    val lines = content.split("\n")
    var i = 0
    while i < lines.len():
        if lines[i].starts_with(prefix):
            return lines[i].substring(prefix.len())
        i = i + 1
    ""

fn mock_read_requests(request_dir: text) -> [(text, text)]:
    var results: [(text, text)] = []
    val files = proto_list_req()
    var i = 0
    while i < files.len():
        val path = files[i]
        val content = proto_read(path)
        val source_path = extract_field(content, "source_path=")
        val kind = extract_field(content, "kind=")
        results = results + [(source_path, kind)]
        i = i + 1
    results

# ============================================================================
# Tests
# ============================================================================

describe "WatcherProtocol":
    describe "write_request":
        it "creates request file in request directory":
            proto_reset()
            val path = mock_write_request("src/main.spl", "shb", ".build/watcher/requests")
            expect(path).to_end_with(".req")
            expect(proto_exists(path)).to_equal(true)

        it "serializes source_path and kind":
            proto_reset()
            val path = mock_write_request("src/lib/math.spl", "smf", ".build/watcher/requests")
            val content = proto_read(path)
            expect(content).to_contain("source_path=src/lib/math.spl")
            expect(content).to_contain("kind=smf")

    describe "read_requests":
        it "reads all request files":
            proto_reset()
            mock_write_request("src/a.spl", "shb", ".build/watcher/requests")
            mock_write_request("src/b.spl", "smf", ".build/watcher/requests")
            val requests = mock_read_requests(".build/watcher/requests")
            expect(requests.len()).to_equal(2)

        it "returns empty for no requests":
            proto_reset()
            val requests = mock_read_requests(".build/watcher/requests")
            expect(requests.len()).to_equal(0)

        it "parses source_path and kind correctly":
            proto_reset()
            mock_write_request("src/main.spl", "both", ".build/watcher/requests")
            val requests = mock_read_requests(".build/watcher/requests")
            expect(requests[0][0]).to_equal("src/main.spl")
            expect(requests[0][1]).to_equal("both")

    describe "request_path_for":
        it "generates deterministic path":
            val path1 = make_req_path("src/main.spl", ".build/watcher/requests")
            val path2 = make_req_path("src/main.spl", ".build/watcher/requests")
            expect(path1).to_equal(path2)

        it "generates different paths for different sources":
            val path1 = make_req_path("src/a.spl", ".build/watcher/requests")
            val path2 = make_req_path("src/b.spl", ".build/watcher/requests")
            expect(path1 != path2).to_equal(true)

    describe "cleanup":
        it "deletes processed request files":
            proto_reset()
            val path = mock_write_request("src/main.spl", "shb", ".build/watcher/requests")
            expect(proto_exists(path)).to_equal(true)
            proto_delete(path)
            expect(proto_exists(path)).to_equal(false)
