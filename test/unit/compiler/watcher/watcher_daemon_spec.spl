# Watcher Daemon Specification
#
# Tests the background watcher daemon's poll cycle and request processing.
# Uses module-level functions for all state mutations (closure limitation).
#
# **Feature IDs:** #WATCH-041 to #WATCH-050
# **Category:** Infrastructure

# ============================================================================
# Module-level daemon state
# ============================================================================

val D_IDLE: i64 = 0
val D_POLLING: i64 = 1
val D_PROCESSING: i64 = 2
val D_SHUTTING: i64 = 3

var d_running: bool = false
var d_status: i64 = 0
var d_cycle_count: i64 = 0
var d_files_processed: i64 = 0
var d_errors: i64 = 0
var d_shb_gen: [text] = []
var d_smf_gen: [text] = []

fn d_reset():
    d_running = false
    d_status = D_IDLE
    d_cycle_count = 0
    d_files_processed = 0
    d_errors = 0
    d_shb_gen = []
    d_smf_gen = []

fn d_start():
    d_running = true
    d_status = D_IDLE

fn d_shutdown():
    d_running = false
    d_status = D_SHUTTING

fn d_poll(changes: [text], req_sources: [text], req_kinds: [text]):
    if not d_running:
        return

    d_status = D_POLLING

    # Process file changes
    if changes.len() > 0:
        d_status = D_PROCESSING
        var i = 0
        while i < changes.len():
            d_shb_gen = d_shb_gen + [changes[i]]
            d_files_processed = d_files_processed + 1
            i = i + 1

    # Process requests
    var j = 0
    while j < req_sources.len():
        val source = req_sources[j]
        val kind = req_kinds[j]
        if kind == "shb":
            d_shb_gen = d_shb_gen + [source]
        else if kind == "smf":
            d_smf_gen = d_smf_gen + [source]
        d_files_processed = d_files_processed + 1
        j = j + 1

    d_cycle_count = d_cycle_count + 1
    d_status = D_IDLE

# Getter functions (direct module var reads from `it` closures return stale values)
fn d_get_running() -> bool:
    d_running

fn d_get_status() -> i64:
    d_status

fn d_get_cycle_count() -> i64:
    d_cycle_count

fn d_get_files_processed() -> i64:
    d_files_processed

fn d_get_shb_gen_len() -> i64:
    d_shb_gen.len()

fn d_get_smf_gen_len() -> i64:
    d_smf_gen.len()

# ============================================================================
# Tests
# ============================================================================

describe "WatcherDaemon":
    describe "lifecycle":
        it "starts in idle state":
            d_reset()
            d_start()
            expect(d_get_running()).to_equal(true)
            expect(d_get_status()).to_equal(D_IDLE)

        it "shuts down cleanly":
            d_reset()
            d_start()
            d_shutdown()
            expect(d_get_running()).to_equal(false)
            expect(d_get_status()).to_equal(D_SHUTTING)

    describe "poll cycle":
        it "processes file changes":
            d_reset()
            d_start()
            d_poll(["src/main.spl", "src/lib.spl"], [], [])
            expect(d_get_files_processed()).to_equal(2)
            expect(d_get_shb_gen_len()).to_equal(2)
            expect(d_get_cycle_count()).to_equal(1)

        it "processes requests":
            d_reset()
            d_start()
            d_poll([], ["src/main.spl", "src/lib.spl"], ["shb", "smf"])
            expect(d_get_files_processed()).to_equal(2)
            expect(d_get_shb_gen_len()).to_equal(1)
            expect(d_get_smf_gen_len()).to_equal(1)

        it "handles both changes and requests":
            d_reset()
            d_start()
            d_poll(["src/a.spl"], ["src/b.spl"], ["shb"])
            expect(d_get_files_processed()).to_equal(2)
            expect(d_get_shb_gen_len()).to_equal(2)

        it "does nothing when not running":
            d_reset()
            d_poll(["src/main.spl"], [], [])
            expect(d_get_files_processed()).to_equal(0)

    describe "state tracking":
        it "increments cycle count":
            d_reset()
            d_start()
            d_poll([], [], [])
            d_poll([], [], [])
            d_poll([], [], [])
            expect(d_get_cycle_count()).to_equal(3)

        it "accumulates files processed":
            d_reset()
            d_start()
            d_poll(["a.spl"], [], [])
            d_poll(["b.spl", "c.spl"], [], [])
            expect(d_get_files_processed()).to_equal(3)

        it "returns to idle after cycle":
            d_reset()
            d_start()
            d_poll(["a.spl"], [], [])
            expect(d_get_status()).to_equal(D_IDLE)
