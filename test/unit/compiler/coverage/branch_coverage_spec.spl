# # Comprehensive Branch Coverage Test Suite
#
# **Feature IDs:** #BRANCH-COVERAGE
# **Category:** Testing
# **Status:** Implemented
#
# ## Overview
#
# Exercises BOTH true AND false branches of every decision type by calling
# shared functions with different inputs. Same source line must evaluate
# to both true and false to count as "covered" (deterministic decision IDs).

# ============================================================================
# Shared decision functions — each called with both true/false inputs
# ============================================================================

fn branch_if_gt(x: i64, threshold: i64) -> text:
    if x > threshold:
        return "above"
    else:
        return "below"

fn branch_nested_if(x: i64) -> text:
    if x > 15:
        return "high"
    else:
        if x > 10:
            return "mid"
        else:
            if x > 5:
                return "low"
            else:
                return "tiny"

fn branch_if_no_else(flag: bool) -> text:
    var result = "default"
    if flag:
        result = "changed"
    result

fn branch_if_expr(flag: bool) -> text:
    val result = if flag: "yes" else: "no"
    result

fn branch_while_loop(n: i64) -> i64:
    var count = 0
    while count < n:
        count = count + 1
    count

fn branch_while_break(limit: i64) -> i64:
    var count = 0
    while count < 100:
        count = count + 1
        if count == limit:
            break
    count

fn branch_while_continue(n: i64) -> i64:
    var sum = 0
    var i = 0
    while i < n:
        i = i + 1
        if i % 2 == 0:
            continue
        sum = sum + i
    sum

fn branch_while_true_break(limit: i64) -> i64:
    var count = 0
    while true:
        count = count + 1
        if count >= limit:
            break
    count

fn branch_for_list(items: [i64]) -> i64:
    var sum = 0
    for x in items:
        sum = sum + x
    sum

fn branch_for_range(n: i64) -> i64:
    var count = 0
    for i in 0..n:
        count = count + 1
    count

fn branch_for_break(limit: i64) -> i64:
    var last = 0
    for i in 0..100:
        last = i
        if i == limit:
            break
    last

fn branch_for_continue(n: i64) -> i64:
    var sum = 0
    for i in 0..n:
        if i % 2 == 0:
            continue
        sum = sum + i
    sum

fn branch_match_int(x: i64) -> text:
    val result = match x:
        1: "one"
        2: "two"
        _: "other"
    result

fn branch_match_opt(opt) -> i64:
    val result = match opt:
        Some(v): v
        nil: -1
    result

fn branch_match_bool(b: bool) -> text:
    val result = match b:
        true: "yes"
        false: "no"
    result

fn branch_and(a: bool, b: bool) -> bool:
    a and b

fn branch_or(a: bool, b: bool) -> bool:
    a or b

fn branch_and_vars(a: i64, b: i64) -> bool:
    a > 3 and b > 7

fn branch_or_vars(a: i64, b: i64) -> bool:
    a > 3 or b > 7

fn branch_complex_and_or(a: bool, b: bool, c: bool) -> bool:
    (a and b) or c

fn branch_and_or_not(a: bool, b: bool) -> bool:
    not (a and b)

fn branch_or_not(a: bool, b: bool) -> bool:
    not (a or b)

fn branch_nested_if_bool(a: bool, b: bool, c: bool) -> text:
    var result = ""
    if (a and b) or c:
        result = "taken"
    else:
        result = "skipped"
    result

fn branch_option_check(opt) -> i64:
    var result = 0
    if opt.?:
        result = 1
    else:
        result = -1
    result

fn branch_coalesce(opt, default_val: i64) -> i64:
    opt ?? default_val

fn branch_cmp_eq(a: i64, b: i64) -> bool:
    a == b

fn branch_cmp_neq(a: i64, b: i64) -> bool:
    a != b

fn branch_cmp_lt(a: i64, b: i64) -> bool:
    a < b

fn branch_cmp_gt(a: i64, b: i64) -> bool:
    a > b

fn branch_cmp_lte(a: i64, b: i64) -> bool:
    a <= b

fn branch_cmp_gte(a: i64, b: i64) -> bool:
    a >= b

fn branch_early_return(n: i64) -> bool:
    if n > 0:
        return true
    return false

fn branch_loop_with_cond(n: i64) -> [i64]:
    var evens = 0
    var odds = 0
    for i in 0..n:
        if i % 2 == 0:
            evens = evens + 1
        else:
            odds = odds + 1
    [evens, odds]

fn branch_nested_break(outer: i64, inner_limit: i64) -> i64:
    var total = 0
    for i in 0..outer:
        for j in 0..10:
            if j >= inner_limit:
                break
            total = total + 1
    total

fn branch_while_match(n: i64) -> i64:
    var count = 0
    var sum = 0
    while count < n:
        val added = match count:
            0: 10
            1: 20
            2: 30
            _: 0
        sum = sum + added
        count = count + 1
    sum


# ============================================================================
# Tests — call each function with inputs for BOTH branches
# ============================================================================

describe "If/Else Decision Coverage":
    it "covers if-true and if-false via same function":
        expect(branch_if_gt(10, 5)).to_equal("above")
        expect(branch_if_gt(2, 5)).to_equal("below")

    it "covers nested if all paths":
        expect(branch_nested_if(20)).to_equal("high")
        expect(branch_nested_if(12)).to_equal("mid")
        expect(branch_nested_if(7)).to_equal("low")
        expect(branch_nested_if(2)).to_equal("tiny")

    it "covers if without else both ways":
        expect(branch_if_no_else(true)).to_equal("changed")
        expect(branch_if_no_else(false)).to_equal("default")

    it "covers if expression both ways":
        expect(branch_if_expr(true)).to_equal("yes")
        expect(branch_if_expr(false)).to_equal("no")


describe "While Loop Decision Coverage":
    it "covers while executed and zero iterations":
        expect(branch_while_loop(5)).to_equal(5)
        expect(branch_while_loop(0)).to_equal(0)

    it "covers while with break - hit and miss":
        expect(branch_while_break(3)).to_equal(3)
        expect(branch_while_break(200)).to_equal(100)

    it "covers while with continue":
        expect(branch_while_continue(10)).to_equal(25)
        expect(branch_while_continue(0)).to_equal(0)

    it "covers while true with break":
        expect(branch_while_true_break(3)).to_equal(3)
        expect(branch_while_true_break(1)).to_equal(1)


describe "For Loop Decision Coverage":
    it "covers for over non-empty and empty list":
        expect(branch_for_list([1, 2, 3])).to_equal(6)
        expect(branch_for_list([])).to_equal(0)

    it "covers for range non-empty and empty":
        expect(branch_for_range(5)).to_equal(5)
        expect(branch_for_range(0)).to_equal(0)

    it "covers for with break - hit and miss":
        expect(branch_for_break(4)).to_equal(4)
        expect(branch_for_break(200)).to_equal(99)

    it "covers for with continue":
        expect(branch_for_continue(10)).to_equal(25)
        expect(branch_for_continue(0)).to_equal(0)


describe "Match Decision Coverage":
    it "covers match all arms":
        expect(branch_match_int(1)).to_equal("one")
        expect(branch_match_int(2)).to_equal("two")
        expect(branch_match_int(99)).to_equal("other")

    it "covers match Some and nil":
        expect(branch_match_opt(Some(42))).to_equal(42)
        expect(branch_match_opt(nil)).to_equal(-1)

    it "covers match boolean both":
        expect(branch_match_bool(true)).to_equal("yes")
        expect(branch_match_bool(false)).to_equal("no")


describe "And/Or Short-Circuit Decision Coverage":
    it "covers and - all combos":
        expect(branch_and(true, true)).to_equal(true)
        expect(branch_and(true, false)).to_equal(false)
        expect(branch_and(false, true)).to_equal(false)
        expect(branch_and(false, false)).to_equal(false)

    it "covers or - all combos":
        expect(branch_or(true, true)).to_equal(true)
        expect(branch_or(true, false)).to_equal(true)
        expect(branch_or(false, true)).to_equal(true)
        expect(branch_or(false, false)).to_equal(false)

    it "covers and with variables":
        expect(branch_and_vars(5, 10)).to_equal(true)
        expect(branch_and_vars(1, 10)).to_equal(false)
        expect(branch_and_vars(5, 3)).to_equal(false)

    it "covers or with variables":
        expect(branch_or_vars(5, 3)).to_equal(true)
        expect(branch_or_vars(1, 10)).to_equal(true)
        expect(branch_or_vars(1, 3)).to_equal(false)


describe "Nested Boolean Decision Coverage":
    it "covers (a and b) or c all combos":
        expect(branch_complex_and_or(true, true, false)).to_equal(true)
        expect(branch_complex_and_or(false, true, false)).to_equal(false)
        expect(branch_complex_and_or(false, false, true)).to_equal(true)
        expect(branch_complex_and_or(false, false, false)).to_equal(false)

    it "covers not (a and b) both ways":
        expect(branch_and_or_not(true, true)).to_equal(false)
        expect(branch_and_or_not(true, false)).to_equal(true)

    it "covers not (a or b) both ways":
        expect(branch_or_not(false, false)).to_equal(true)
        expect(branch_or_not(false, true)).to_equal(false)

    it "covers nested if with complex boolean":
        expect(branch_nested_if_bool(true, true, false)).to_equal("taken")
        expect(branch_nested_if_bool(false, true, false)).to_equal("skipped")


describe "Option Decision Coverage":
    it "covers option existence both ways":
        expect(branch_option_check(Some(42))).to_equal(1)
        expect(branch_option_check(nil)).to_equal(-1)

    it "covers nil coalesce both ways":
        expect(branch_coalesce(Some(10), 0)).to_equal(10)
        expect(branch_coalesce(nil, 99)).to_equal(99)


describe "Comparison Decision Coverage":
    it "covers equals both ways":
        expect(branch_cmp_eq(5, 5)).to_equal(true)
        expect(branch_cmp_eq(5, 3)).to_equal(false)

    it "covers not-equals both ways":
        expect(branch_cmp_neq(5, 3)).to_equal(true)
        expect(branch_cmp_neq(5, 5)).to_equal(false)

    it "covers less-than both ways":
        expect(branch_cmp_lt(3, 5)).to_equal(true)
        expect(branch_cmp_lt(5, 3)).to_equal(false)

    it "covers greater-than both ways":
        expect(branch_cmp_gt(5, 3)).to_equal(true)
        expect(branch_cmp_gt(3, 5)).to_equal(false)

    it "covers less-equal both ways":
        expect(branch_cmp_lte(5, 5)).to_equal(true)
        expect(branch_cmp_lte(6, 5)).to_equal(false)

    it "covers greater-equal both ways":
        expect(branch_cmp_gte(5, 5)).to_equal(true)
        expect(branch_cmp_gte(4, 5)).to_equal(false)


describe "Mixed Control Flow Decision Coverage":
    it "covers early return both ways":
        expect(branch_early_return(5)).to_equal(true)
        expect(branch_early_return(-3)).to_equal(false)

    it "covers loop with if/else inside":
        val result = branch_loop_with_cond(10)
        expect(result[0]).to_equal(5)
        expect(result[1]).to_equal(5)

    it "covers nested loops with break":
        expect(branch_nested_break(3, 2)).to_equal(6)
        expect(branch_nested_break(3, 0)).to_equal(0)

    it "covers while with match inside":
        expect(branch_while_match(4)).to_equal(60)
        expect(branch_while_match(0)).to_equal(0)
