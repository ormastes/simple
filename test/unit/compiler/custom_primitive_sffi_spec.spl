use std.io_runtime

# ============================================================
# PrimInfo — metadata for a custom primitive type
# ============================================================

class PrimInfo:
    name: text
    underlying: text
    signedness: text
    bit_width: i32
    byte_size: i32
    is_transparent: bool

    static fn create(n: text, u: text) -> PrimInfo:
        var sign = "unsigned"
        if u == "i8" or u == "i16" or u == "i32" or u == "i64":
            sign = "signed"
        var bw: i32 = 32
        if u == "u8" or u == "i8":
            bw = 8
        if u == "u16" or u == "i16":
            bw = 16
        if u == "u32" or u == "i32":
            bw = 32
        if u == "u64" or u == "i64":
            bw = 64
        if u == "f32":
            bw = 32
        if u == "f64":
            bw = 64
        if u == "bool":
            bw = 8
            sign = "unsigned"
        var bs: i32 = bw / 8
        PrimInfo(
            name: n,
            underlying: u,
            signedness: sign,
            bit_width: bw,
            byte_size: bs,
            is_transparent: false
        )

    me is_custom() -> bool:
        true

    me abi_type() -> text:
        self.underlying

    me bit_capacity() -> i32:
        self.bit_width

    me is_integer() -> bool:
        if self.underlying == "bool":
            return false
        if self.underlying == "f32" or self.underlying == "f64":
            return false
        true

# ============================================================
# AbiMap — ABI type mappings
# ============================================================

class AbiMap:
    dummy: i32

    me map_c(underlying: text) -> text:
        if underlying == "u8":
            return "uint8_t"
        if underlying == "u16":
            return "uint16_t"
        if underlying == "u32":
            return "uint32_t"
        if underlying == "u64":
            return "uint64_t"
        if underlying == "i8":
            return "int8_t"
        if underlying == "i16":
            return "int16_t"
        if underlying == "i32":
            return "int32_t"
        if underlying == "i64":
            return "int64_t"
        if underlying == "f32":
            return "float"
        if underlying == "f64":
            return "double"
        if underlying == "bool":
            return "_Bool"
        "unknown"

    me map_rust(underlying: text) -> text:
        if underlying == "u8":
            return "u8"
        if underlying == "u16":
            return "u16"
        if underlying == "u32":
            return "u32"
        if underlying == "u64":
            return "u64"
        if underlying == "i8":
            return "i8"
        if underlying == "i16":
            return "i16"
        if underlying == "i32":
            return "i32"
        if underlying == "i64":
            return "i64"
        if underlying == "f32":
            return "f32"
        if underlying == "f64":
            return "f64"
        if underlying == "bool":
            return "bool"
        "unknown"

    me map_llvm(underlying: text) -> text:
        if underlying == "u8" or underlying == "i8":
            return "i8"
        if underlying == "u16" or underlying == "i16":
            return "i16"
        if underlying == "u32" or underlying == "i32":
            return "i32"
        if underlying == "u64" or underlying == "i64":
            return "i64"
        if underlying == "f32":
            return "float"
        if underlying == "f64":
            return "double"
        if underlying == "bool":
            return "i1"
        "unknown"

# ============================================================
# BitfieldCheck — bitfield backing/field type validation
# ============================================================

class BitfieldCheck:
    dummy: i32

    static fn check_backing(underlying: text) -> bool:
        if underlying == "u8":
            return true
        if underlying == "u16":
            return true
        if underlying == "u32":
            return true
        if underlying == "u64":
            return true
        if underlying == "i8":
            return true
        if underlying == "i16":
            return true
        if underlying == "i32":
            return true
        if underlying == "i64":
            return true
        false

    static fn check_field(underlying: text, bits: i32, max_bits: i32) -> bool:
        if bits > max_bits:
            return false
        if underlying == "f32" or underlying == "f64":
            return false
        if underlying == "bool":
            return bits == 1
        if underlying == "u8" or underlying == "i8":
            return bits <= 8
        if underlying == "u16" or underlying == "i16":
            return bits <= 16
        if underlying == "u32" or underlying == "i32":
            return bits <= 32
        if underlying == "u64" or underlying == "i64":
            return bits <= 64
        false

# ============================================================
# PrimClass — classification for migration analysis
# ============================================================

class PrimClass:
    classification: text

    me should_migrate() -> bool:
        self.classification == "convertible"

# ============================================================
# Metadata tests (1-4)
# ============================================================

fn test_u32_custom_primitive_metadata():
    val p = PrimInfo.create("MyU32", "u32")
    var ok = true
    if p.signedness != "unsigned":
        ok = false
    if p.bit_width != 32:
        ok = false
    if p.byte_size != 4:
        ok = false
    if ok:
        print("PASS: test_u32_custom_primitive_metadata")
    if ok == false:
        print("FAIL: test_u32_custom_primitive_metadata")

fn test_i64_custom_primitive_metadata():
    val p = PrimInfo.create("MyI64", "i64")
    var ok = true
    if p.signedness != "signed":
        ok = false
    if p.bit_width != 64:
        ok = false
    if ok:
        print("PASS: test_i64_custom_primitive_metadata")
    if ok == false:
        print("FAIL: test_i64_custom_primitive_metadata")

fn test_bool_custom_primitive():
    val p = PrimInfo.create("MyBool", "bool")
    var ok = true
    if p.bit_width != 8:
        ok = false
    if p.is_integer():
        ok = false
    if ok:
        print("PASS: test_bool_custom_primitive")
    if ok == false:
        print("FAIL: test_bool_custom_primitive")

fn test_is_always_custom_primitive():
    val p = PrimInfo.create("Anything", "u32")
    if p.is_custom():
        print("PASS: test_is_always_custom_primitive")
    if p.is_custom() == false:
        print("FAIL: test_is_always_custom_primitive")

# ============================================================
# ABI mapping tests (5-8)
# ============================================================

fn test_abi_type_returns_underlying():
    val p = PrimInfo.create("Wrap", "i32")
    if p.abi_type() == "i32":
        print("PASS: test_abi_type_returns_underlying")
    if p.abi_type() != "i32":
        print("FAIL: test_abi_type_returns_underlying")

fn test_c_mapping_u32():
    val m = AbiMap(dummy: 0)
    val c = m.map_c("u32")
    if c == "uint32_t":
        print("PASS: test_c_mapping_u32")
    if c != "uint32_t":
        print("FAIL: test_c_mapping_u32 - got " + c)

fn test_rust_mapping_i64():
    val m = AbiMap(dummy: 0)
    val r = m.map_rust("i64")
    if r == "i64":
        print("PASS: test_rust_mapping_i64")
    if r != "i64":
        print("FAIL: test_rust_mapping_i64 - got " + r)

fn test_llvm_mapping_f64():
    val m = AbiMap(dummy: 0)
    val l = m.map_llvm("f64")
    if l == "double":
        print("PASS: test_llvm_mapping_f64")
    if l != "double":
        print("FAIL: test_llvm_mapping_f64 - got " + l)

# ============================================================
# Bitfield backing tests (9-12)
# ============================================================

fn test_u32_valid_backing():
    if BitfieldCheck.check_backing("u32"):
        print("PASS: test_u32_valid_backing")
    if BitfieldCheck.check_backing("u32") == false:
        print("FAIL: test_u32_valid_backing")

fn test_u8_valid_backing():
    if BitfieldCheck.check_backing("u8"):
        print("PASS: test_u8_valid_backing")
    if BitfieldCheck.check_backing("u8") == false:
        print("FAIL: test_u8_valid_backing")

fn test_f32_invalid_backing():
    if BitfieldCheck.check_backing("f32") == false:
        print("PASS: test_f32_invalid_backing")
    if BitfieldCheck.check_backing("f32"):
        print("FAIL: test_f32_invalid_backing")

fn test_bool_invalid_backing():
    if BitfieldCheck.check_backing("bool") == false:
        print("PASS: test_bool_invalid_backing")
    if BitfieldCheck.check_backing("bool"):
        print("FAIL: test_bool_invalid_backing")

# ============================================================
# Bitfield field tests (13-16)
# ============================================================

fn test_integer_field_valid():
    if BitfieldCheck.check_field("u16", 4, 16):
        print("PASS: test_integer_field_valid")
    if BitfieldCheck.check_field("u16", 4, 16) == false:
        print("FAIL: test_integer_field_valid")

fn test_field_overflow_rejected():
    if BitfieldCheck.check_field("u8", 12, 8) == false:
        print("PASS: test_field_overflow_rejected")
    if BitfieldCheck.check_field("u8", 12, 8):
        print("FAIL: test_field_overflow_rejected")

fn test_float_field_rejected():
    if BitfieldCheck.check_field("f32", 8, 32) == false:
        print("PASS: test_float_field_rejected")
    if BitfieldCheck.check_field("f32", 8, 32):
        print("FAIL: test_float_field_rejected")

fn test_bool_field_1bit_valid():
    if BitfieldCheck.check_field("bool", 1, 32):
        print("PASS: test_bool_field_1bit_valid")
    if BitfieldCheck.check_field("bool", 1, 32) == false:
        print("FAIL: test_bool_field_1bit_valid")

# ============================================================
# Classification + domain tests (17-20)
# ============================================================

fn test_convertible_should_migrate():
    val c = PrimClass(classification: "convertible")
    if c.should_migrate():
        print("PASS: test_convertible_should_migrate")
    if c.should_migrate() == false:
        print("FAIL: test_convertible_should_migrate")

fn test_blocked_should_not_migrate():
    val c = PrimClass(classification: "blocked")
    if c.should_migrate() == false:
        print("PASS: test_blocked_should_not_migrate")
    if c.should_migrate():
        print("FAIL: test_blocked_should_not_migrate")

fn test_domain_file_handle():
    val p = PrimInfo.create("FileHandle", "u32")
    if p.underlying == "u32":
        print("PASS: test_domain_file_handle")
    if p.underlying != "u32":
        print("FAIL: test_domain_file_handle")

fn test_domain_irq_vector():
    val p = PrimInfo.create("IrqVector", "u16")
    if p.underlying == "u16":
        print("PASS: test_domain_irq_vector")
    if p.underlying != "u16":
        print("FAIL: test_domain_irq_vector")

# ============================================================
# Entry point
# ============================================================

fn main():
    test_u32_custom_primitive_metadata()
    test_i64_custom_primitive_metadata()
    test_bool_custom_primitive()
    test_is_always_custom_primitive()
    test_abi_type_returns_underlying()
    test_c_mapping_u32()
    test_rust_mapping_i64()
    test_llvm_mapping_f64()
    test_u32_valid_backing()
    test_u8_valid_backing()
    test_f32_invalid_backing()
    test_bool_invalid_backing()
    test_integer_field_valid()
    test_field_overflow_rejected()
    test_float_field_rejected()
    test_bool_field_1bit_valid()
    test_convertible_should_migrate()
    test_blocked_should_not_migrate()
    test_domain_file_handle()
    test_domain_irq_vector()
    print("DONE")
