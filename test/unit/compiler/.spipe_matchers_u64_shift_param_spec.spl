use std.spec.{describe, it, expect}

fn shr_u64(x: u64) -> u64:
    return x >> 1

fn shr_u64_by(x: u64, n: i64) -> u64:
    return x >> n

describe "u64 right shift via fn param":
    it "logical shift high-bit value":
        var result: u64 = shr_u64(0x8000000000000000u64)
        expect result == 0x4000000000000000u64

    it "logical shift all-ones":
        var result: u64 = shr_u64(0xFFFFFFFFFFFFFFFFu64)
        expect result == 0x7FFFFFFFFFFFFFFFu64

    it "logical shift SHA-384 initial hash value":
        var result: u64 = shr_u64_by(0xCBBB9D5DC1059ED8u64, 28)
        expect result == 0x0000000CBBB9D5DCu64

    it "no sign extension on high-bit u64 param":
        var x: u64 = 0x8000000000000000u64
        var result: u64 = shr_u64_by(x, 1)
        expect result == 0x4000000000000000u64