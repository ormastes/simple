"""
# Scalable Vector MIR Scaffolding Specification

**Feature IDs:** #PSFM-001
**Category:** Compiler Backend
**Difficulty:** 3/5
**Status:** Active
**Requirements:** doc/02_requirements/feature/simd_fixed_and_scalable_vectors.md
**Plan:** doc/03_plan/agent_tasks/simd_fixed_and_scalable_vectors.md
**Design:** doc/05_design/simd_fixed_and_scalable_vectors.md

## Overview

Tests that:
1. `ScalableVec(element, min_lanes)` is a valid `MirTypeKind` variant (Phase 2 scenario #1)
2. Native adapter guardrails report scalable-vector lowering status explicitly
   before RV64 ISel can panic.

Run in interpreter mode only (no --mode flag):
  bin/simple test --no-cache test/unit/compiler/scalable_vec_mir_scaffolding_spec.spl

Compile-mode regressions: file a separate FR; do not normalize (AC-6 policy).
"""

use std.spipe.*
use compiler.mir.mir_types.{MirType, MirTypeKind}
use compiler.mir.mir_data.{MirModule, MirFunction, MirSignature, MirLocal, LocalId, LocalKind, BlockId}
use compiler.common.diagnostics.span.{Span}
use compiler.common.attributes.{vhdl_hardware_metadata_default}
use compiler.hir.hir_types.{SymbolId}
use compiler.backend.backend.backend_types.{CodegenTarget, CompileOptions, OptimizationLevel}
use compiler.backend.backend.native_codegen_adapter.{NativeCodegenAdapter}


fn make_scalable_mir_module() -> MirModule:
    val scalable_ty = MirType.scalable_vec(MirType.i64(), 4)
    val func = MirFunction(
        symbol: SymbolId(id: 1),
        name: "simd_scalable_probe",
        signature: MirSignature(params: [], return_type: MirType.unit(), is_variadic: false),
        locals: [
            MirLocal(
                id: LocalId(id: 0),
                name: Some("sv"),
                type_: scalable_ty,
                kind: LocalKind.Var
            )
        ],
        blocks: [],
        entry_block: BlockId(id: 0),
        span: Span.empty(),
        generic_params: [],
        is_generic_template: false,
        specialization_of: nil,
        type_bindings: {},
        layout_phase: nil,
        is_kernel: false,
        is_export_c: false,
        export_name: "",
        driver_manifest_attr: nil,
        vhdl_metadata: vhdl_hardware_metadata_default(),
        has_fast_math: false
    )
    MirModule(
        name: "scalable_probe",
        functions: {SymbolId(id: 1): func},
        statics: {},
        constants: {},
        types: {}
    )


# ============================================================================
# Phase 2 Scenario #1 — riscv_v capability → ScalableVec MIR type instantiable
# AC-5: ScalableVec variant exists in MirTypeKind; lowering deferred (not crash)
# ============================================================================

describe "ScalableVec MIR type scaffolding":
    """
    ## AC-5 Scalable Vector MIR Type

    Confirms the explicit scalable MIR type remains available for semantic and
    backend planning work even though native scalable lowering is deferred.
    """

    context "MirTypeKind.ScalableVec variant":
        """
        ### Scenario: ScalableVec is a recognizable MirTypeKind

        The `MirTypeKind.ScalableVec(element: MirType, min_lanes: i64)` variant must exist
        and be constructible. Mirrors LLVM `<vscale x N x ty>` semantics.
        """

        it "AC-5/P2-1: ScalableVec MirType can be constructed and pattern-matched":
            val elem = MirType.i64()
            val sv = MirType(kind: MirTypeKind.ScalableVec(element: elem, min_lanes: 4))
            expect(sv.kind).to_equal(MirTypeKind.ScalableVec(element: elem, min_lanes: 4))


# ============================================================================
# Native adapter guardrails for scalable vectors
# ============================================================================

describe "NativeCodegenAdapter scalable diagnostics":
    """
    ## Explicit scalable-vector native status

    The adapter must expose a deterministic status query for scalable vectors.
    The current default RV64 target lacks scalable-vector capability, so it
    must not pretend the deferred RVV lowering path is selected.
    """

    it "reports lack-of-capability for default riscv64 target when MIR uses ScalableVec":
        val opts = CompileOptions(
            target: CodegenTarget.Riscv64,
            opt_level: OptimizationLevel.Speed,
            debug_info: false,
            emit_assembly: false,
            emit_llvm_ir: false,
            emit_mir: false,
            verify_output: true
        )
        val adapter = NativeCodegenAdapter(options: opts)
        val diagnostics = adapter.scalable_lowering_diagnostics(make_scalable_mir_module())
        expect(diagnostics.len()).to_equal(1)
        expect(diagnostics[0]).to_equal("scalable_vector_target_lacks_native_capability")

    it "reports no scalable diagnostic when MIR module does not use ScalableVec":
        val opts = CompileOptions(
            target: CodegenTarget.Riscv64,
            opt_level: OptimizationLevel.Speed,
            debug_info: false,
            emit_assembly: false,
            emit_llvm_ir: false,
            emit_mir: false,
            verify_output: true
        )
        val adapter = NativeCodegenAdapter(options: opts)
        val empty_module = MirModule(name: "empty", functions: {}, statics: {}, constants: {}, types: {})
        val diagnostics = adapter.scalable_lowering_diagnostics(empty_module)
        expect(diagnostics.len()).to_equal(0)
