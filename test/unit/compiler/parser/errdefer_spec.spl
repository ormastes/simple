describe "Errdefer":
    describe "parsing":
        it "parses errdefer statement":
            # errdefer is a keyword that parses like defer
            val code = "errdefer cleanup()"
            # If this file loads without error, the parser handles errdefer
            pass_do_nothing

    describe "interpreter semantics":
        it "errdefer does NOT run on success":
            # On success path, errdefer body must not execute
            var ran = false
            fn success_path():
                errdefer ran = true
                val x = 42
            success_path()
            expect(ran).to_equal(false)

        it "errdefer runs on error":
            # On error path, errdefer body must execute
            var ran = false
            fn error_path():
                errdefer ran = true
                val bad = 1 / 0  # triggers eval_had_error
            error_path()
            expect(ran).to_equal(true)

        it "defer always runs regardless of error":
            var ran = false
            fn success_with_defer():
                defer ran = true
                val x = 42
            success_with_defer()
            expect(ran).to_equal(true)

        it "multiple errdefers run in LIFO order on error":
            var order: [i64] = []
            fn multi_errdefer():
                errdefer order.push(1)
                errdefer order.push(2)
                errdefer order.push(3)
                val bad = 1 / 0
            multi_errdefer()
            expect(order).to_equal([3, 2, 1])
