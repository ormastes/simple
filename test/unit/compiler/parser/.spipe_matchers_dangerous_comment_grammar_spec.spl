"""
# Dangerous Comment Grammar Parser Coverage
"""

use compiler.core.parser.{parser_init, parser_warnings_get}
use compiler.core.parser_stmts.{parse_statement}
use compiler.core.ast.{expr_get_tag, expr_get_str, stmt_get_expr, EXPR_PASS_TODO}
use compiler.core.ast.{stmt_get_body, arm_get_pattern, arm_get_rationale}

describe "dangerous comment grammar parser":
    it "parses pass_todo with what-remains and hint strings":
        parser_init("pass_todo(\"implement retry backoff\", \"tracked by SIMPLE-123\")")
        val stmt = parse_statement()
        val expr = stmt_get_expr(stmt)
        expect expr_get_tag(expr) == EXPR_PASS_TODO
        expect (expr_get_str(expr)).contains("implement retry backoff")
        expect (expr_get_str(expr)).contains("tracked by SIMPLE-123")

    it "warns for bare pass_todo":
        parser_init("pass_todo")
        parse_statement()
        val warnings = parser_warnings_get()
        expect warnings.len() > 0
        expect (warnings[0]).contains("REQC001")

    it "parses todo as a pass_todo placeholder expression":
        parser_init("todo(\"implement retry backoff\", \"tracked by SIMPLE-123\")")
        val stmt = parse_statement()
        val expr = stmt_get_expr(stmt)
        expect expr_get_tag(expr) == EXPR_PASS_TODO
        expect (expr_get_str(expr)).contains("implement retry backoff")
        expect (expr_get_str(expr)).contains("tracked by SIMPLE-123")

    it "parses wildcard arm rationale metadata":
        parser_init("match value:\n    case _(\"all remaining values share fallback\"):\n        pass_do_nothing(\"fallback has no side effects\")\n")
        val stmt = parse_statement()
        val arms = stmt_get_body(stmt)
        expect arms.len() == 1
        expect expr_get_str(arm_get_pattern(arms[0])) == "_"
        expect (arm_get_rationale(arms[0])).contains("all remaining values")