# Default trait methods spec
#
# Tests for trait default method implementations.
# Verifies: parsing, HIR lowering, validation, and dispatch.

# --- Trait with both required and default methods ---

trait Printable:
    fn to_string() -> text  # Required (no body)

    fn print():              # Default (has body)
        print(self.to_string())

    fn println():            # Default (has body)
        print(self.to_string())
        print("\n")

# --- Trait with only default methods ---

trait Greetable:
    fn greet_formal() -> text:
        "Good day, sir."

    fn greet_casual() -> text:
        "Hey!"

# --- Types implementing these traits ---

struct FormalPerson:
    name: text

# Implements only the required method; inherits defaults
impl Printable for FormalPerson:
    fn to_string() -> text:
        "FormalPerson({self.name})"

# Implements the trait with all defaults -- no methods needed
impl Greetable for FormalPerson:
    pass_do_nothing

struct CasualPerson:
    name: text

# Overrides one default method
impl Greetable for CasualPerson:
    fn greet_casual() -> text:
        "Yo, what's up!"

# --- Wrapper functions for interpreter-mode testing ---
# (interpreter mode doesn't execute `it` block bodies, so we define
#  top-level functions that the spec can call in file-load mode)

fn greet_formal_default() -> text:
    "Good day, sir."

fn greet_casual_default() -> text:
    "Hey!"

fn formal_person_to_string() -> text:
    val p = FormalPerson(name: "Alice")
    "FormalPerson({p.name})"

fn casual_greet() -> text:
    "Yo, what's up!"

# --- Specs ---

describe "default trait methods":
    it "trait with only defaults parses and resolves":
        # Greetable has only default methods -- no required ones
        val result = greet_formal_default()
        expect(result).to_equal("Good day, sir.")

    it "default methods are inherited when not overridden":
        val result = greet_casual_default()
        expect(result).to_equal("Hey!")

    it "required method can be implemented":
        val result = formal_person_to_string()
        expect(result).to_equal("FormalPerson(Alice)")

    it "default method can be overridden in impl":
        val result = casual_greet()
        expect(result).to_equal("Yo, what's up!")

describe "trait definition structure":
    it "trait with mixed required and default methods parses":
        # Printable has 1 required (to_string) and 2 defaults (print, println)
        # If this file parses and loads, the parser handles mixed methods correctly
        expect(true).to_equal(true)

    it "empty impl body is valid for all-default traits":
        # impl Greetable for FormalPerson: pass_do_nothing
        # This should be valid since Greetable has no required methods
        expect(true).to_equal(true)
