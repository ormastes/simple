# const declaration spec
#
# Tests for `const` bindings (compile-time constants)

const MAX_SIZE = 100
const PI = 3.14159
const APP_NAME = "Simple"
const ENABLED = true
const ZERO = 0

describe "const declarations":
    it "const integer is accessible":
        expect MAX_SIZE == 100

    it "const float is accessible":
        expect PI > 3.0

    it "const text is accessible":
        expect APP_NAME == "Simple"

    it "const bool is accessible":
        expect ENABLED == true

    it "const used in expression":
        val double_max = MAX_SIZE * 2
        expect double_max == 200

    it "const zero works in arithmetic":
        val result = MAX_SIZE + ZERO
        expect result == 100

    it "const string concatenation":
        val greeting = "Hello, " + APP_NAME + "!"
        expect greeting == "Hello, Simple!"