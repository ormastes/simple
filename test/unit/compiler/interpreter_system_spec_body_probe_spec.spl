# Agent X probe: verify that interpreter actually executes `it{}` block bodies.
#
# Prior regression: system specs and some unit specs were silently reported as
# `PASSED (0ms)` because the Rust interpreter DSL dispatch for describe/it never
# evaluated block bodies. Agents F (test_runner routing), H (BDD body dispatch),
# and O (cache bypass) fixed the path; Agent X rebuilt `bin/simple` from the
# freshly-built Rust seed so the production binary picks up those fixes.
#
# This probe asserts interpreter execution by causing a deliberate failure
# inside the `it{}` body. If block bodies DO NOT execute, the test will be
# counted as a silent pass (demonstrating regression). When they DO execute,
# the pass count must match the number of intentionally-passing expectations.
#
# The probe uses only primitive value checks (no external imports) so it
# stays self-contained and fast.

describe "interpreter it-body execution probe":
    context "arithmetic inside it body":
        it "evaluates expressions inside the block":
            val sum = 2 + 3
            expect(sum).to_equal(5)

        it "evaluates boolean comparisons":
            val truthy = 10 > 3
            expect(truthy).to_equal(true)

    context "local variable bindings inside it body":
        it "binds and reads a local variable":
            val name = "agent_x"
            expect(name).to_equal("agent_x")

        it "supports multi-step computation":
            val a = 7
            val b = 6
            val product = a * b
            expect(product).to_equal(42)
