"""Library SMF format specification tests."""

use compiler.backend.linker.lib_smf.{ModuleIndexEntry, LibSmfHeader, fnv1a_hash}

describe "Lib Smf Format":
    it "creates and round-trips an index entry without an object file":
        val entry = ModuleIndexEntry.new("test/module", 128, 1024, 12345)
        expect entry.get_name() == "test/module"
        expect entry.has_object() == false
        expect entry.to_bytes().len() == 128

        val restored = ModuleIndexEntry.from_bytes(entry.to_bytes(), 0).unwrap()
        expect restored.get_name() == "test/module"
        expect restored.offset as i64 == 128
        expect restored.size as i64 == 1024

    it "creates and round-trips an index entry with an object file":
        val entry = ModuleIndexEntry.new_with_object("std/io/mod", 1000, 2000, 111111, 3000, 500, 222222)
        expect entry.has_object() == true

        val restored = ModuleIndexEntry.from_bytes(entry.to_bytes(), 0).unwrap()
        expect restored.get_name() == "std/io/mod"
        expect restored.obj_offset as i64 == 3000
        expect restored.obj_size as i64 == 500
        expect restored.obj_hash as i64 == 222222

    it "serializes and validates the library header":
        var header = LibSmfHeader.new_default()
        header.module_count = 42
        header.library_hash = 999999

        val bytes = header.to_bytes()
        expect bytes.len() == 128

        val restored = LibSmfHeader.from_bytes(bytes).unwrap()
        expect restored.is_valid() == true
        expect restored.module_count as i64 == 42
        expect restored.library_hash as i64 == 999999

    it "produces stable hashes":
        expect fnv1a_hash([1, 2, 3, 4, 5]) == fnv1a_hash([1, 2, 3, 4, 5])
        expect fnv1a_hash([1, 2, 3]) == fnv1a_hash([1, 2, 3])