"""Linker wrapper SMF specification tests."""

use compiler.backend.linker.linker_wrapper.{link_to_native, NativeLinkConfig}

describe "Linker Wrapper Smf":
    it "rejects mixed SMF and object inputs":
        val cfg = NativeLinkConfig.default()
        val result = link_to_native(["a.smf", "b.o"], "out.bin", cfg)
        expect(result.is_err()).to_equal(true)

    it "errors on empty input":
        val cfg = NativeLinkConfig.default()
        val result = link_to_native([], "out.bin", cfg)
        expect(result.is_err()).to_equal(true)
