"""Unit tests for native linker hardening helpers."""

use compiler.backend.linker.linker_wrapper.{
    unresolved_symbol_flags_for_unix_linker,
    unresolved_symbol_flags_for_cc
}
use testing.{describe, it, expect}

describe "Native linker hardening":
    it "adds unresolved-symbol flags for ELF direct linkers":
        expect(unresolved_symbol_flags_for_unix_linker("linux")).to_equal([
            "--allow-multiple-definition"
        ])
        expect(unresolved_symbol_flags_for_unix_linker("freebsd")).to_equal([
            "--allow-multiple-definition"
        ])

    it "skips unresolved-symbol flags on non-ELF direct linkers":
        expect(unresolved_symbol_flags_for_unix_linker("macos")).to_equal([])
        expect(unresolved_symbol_flags_for_unix_linker("darwin")).to_equal([])
        expect(unresolved_symbol_flags_for_unix_linker("windows")).to_equal([])

    it "adds unresolved-symbol flags for cc fallback on Linux and FreeBSD":
        expect(unresolved_symbol_flags_for_cc("Linux")).to_equal([
            "-Wl,--allow-multiple-definition"
        ])
        expect(unresolved_symbol_flags_for_cc("FreeBSD")).to_equal([
            "-Wl,--allow-multiple-definition"
        ])

    it "skips cc fallback unresolved-symbol flags on non-ELF hosts":
        expect(unresolved_symbol_flags_for_cc("Darwin")).to_equal([])
        expect(unresolved_symbol_flags_for_cc("macos")).to_equal([])
        expect(unresolved_symbol_flags_for_cc("Windows")).to_equal([])
