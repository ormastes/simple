"""Linker specification tests."""

use compiler.backend.linker.link.{LinkConfig, OutputFormat, Linker}
use compiler.backend.linker.obj_taker.{objtakerconfig_default}
use compiler.backend.linker.mold.{MoldConfig}
use compiler.loader.{ModuleLoaderConfig, ModuleLoader}

describe "Linker":
    it "uses expected default link configuration":
        val config = LinkConfig.default()
        expect config.output_format == OutputFormat.Smf
        expect config.output_path == "a.out"
        expect config.pie == true
        expect config.verbose == false
        expect config.allow_deferred == false

    it "creates native and smf configs":
        val native_cfg = LinkConfig.native("output.bin")
        val smf_cfg = LinkConfig.smf("output.smf")

        expect native_cfg.output_format == OutputFormat.Native
        expect native_cfg.output_path == "output.bin"
        expect smf_cfg.output_format == OutputFormat.Smf
        expect smf_cfg.output_path == "output.smf"

    it "initializes linker state and shared defaults":
        val linker = Linker.new(LinkConfig.default())
        val stats_cfg = objtakerconfig_default()

        expect linker.readers.len() == 0
        expect linker.symbols.len() == 0
        expect linker.errors.len() == 0
        expect linker.obj_taker.config.max_cache_size == stats_cfg.max_cache_size
        expect linker.config.output_format == OutputFormat.Smf

    it "keeps mold and module loader defaults aligned with the current pipeline":
        val mold_cfg = MoldConfig.default()
        val loader_cfg = ModuleLoaderConfig.default()
        val loader = ModuleLoader.with_defaults()

        expect mold_cfg.pie == true
        expect mold_cfg.verbose == false
        expect loader_cfg.enable_jit == true
        expect loader_cfg.enable_cache == true
        expect loader.stats().module_count == 0
        expect loader.stats().symbol_count == 0