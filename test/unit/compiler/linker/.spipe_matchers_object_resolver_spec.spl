"""Object file resolver specification tests."""

use compiler.backend.linker.object_resolver.{generate_object_candidates, default_object_search_paths}

describe "Object Resolver":
    it "generates the expected object file candidates":
        val candidates = generate_object_candidates("std/io/mod")
        expect candidates.contains("std/io/mod.o") == true
        expect candidates.contains("std_io_mod.o") == true
        expect candidates.contains("mod.o") == true
        expect candidates.contains("src/std/io/mod.o") == true

    it "handles single-component and deep module names":
        expect generate_object_candidates("math").len() > 0
        expect generate_object_candidates("a/b/c/d/e").len() > 3

    it "returns standard search paths":
        val paths = default_object_search_paths()
        expect paths.len() > 0
        expect paths.contains("build/obj") == true
        expect paths.contains(".") == true