"""Linker compilation context specification tests."""

use compiler.backend.linker.linker_context.*
use compiler.backend.compilation_context.*

describe "Linker Context":
    it "loads templates from the provided object map":
        var templates: Dict<text, GenericTemplate> = {}
        templates["Array"] = GenericTemplate(name: "Array", type_params: ["T"], ast_data: nil)

        val ctx = linkercompilationcontext_from_objects(templates, nil, nil)
        expect ctx.has_template("Array") == true
        expect ctx.has_template("Vec") == false

        val loaded = ctx.load_template("Array")
        expect loaded.is_ok() == true
        expect loaded.unwrap().name == "Array"

    it "reports linker-specific modes":
        val ctx = linkercompilationcontext_from_objects({}, nil, nil)
        expect ctx.contract_mode() == ContractMode.All
        expect ctx.coverage_enabled() == false
        expect ctx.instantiation_mode() == InstantiationMode.LinkTime
        expect ctx.recorded.len() == 0

    it "returns an error for missing templates":
        val ctx = linkercompilationcontext_from_objects({}, nil, nil)
        val result = ctx.load_template("Missing")
        expect result.is_err() == true
        expect (result.unwrap_err()).contains("Template not in objects")

    it "records instantiation metadata entries":
        var ctx = linkercompilationcontext_from_objects({}, nil, nil)
        ctx.record_instantiation(InstantiationEntry(
            id: 0,
            template_name: "Vec",
            type_args: "i64",
            mangled_name: "Vec$i64",
            from_file: "main.spl",
            from_loc: "1:1",
            to_obj: "main.smf",
            status: "completed"
        ))

        expect ctx.recorded.len() == 1
        expect ctx.recorded[0].mangled_name == "Vec$i64"