"""Library SMF integration specification tests."""

use compiler.backend.linker.lib_smf.{LibSmfHeader, ModuleIndexEntry, fnv1a_hash}
use compiler.backend.linker.lib_smf_reader.{LibSmfReader}
use compiler.backend.linker.lib_smf_writer.{LibSmfBuilder}
use compiler.backend.linker.smf_getter.{SmfGetter}

extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_delete(path: text) -> bool

fn delete_if_exists(path: text):
    if rt_file_exists(path):
        rt_file_delete(path)

describe "Lib Smf":
    it "round-trips header and index metadata":
        var header = LibSmfHeader.new_default()
        header.module_count = 3
        header.library_hash = 123456

        val header_bytes = header.to_bytes()
        val restored_header = LibSmfHeader.from_bytes(header_bytes).unwrap()
        expect restored_header.is_valid() == true
        expect restored_header.module_count as i64 == 3
        expect restored_header.library_hash as i64 == 123456

        val entry = ModuleIndexEntry.new_with_object("lib/core", 128, 64, 111, 192, 32, 222)
        val restored_entry = ModuleIndexEntry.from_bytes(entry.to_bytes(), 0).unwrap()
        expect restored_entry.get_name() == "lib/core"
        expect restored_entry.has_object() == true
        expect restored_entry.obj_offset as i64 == 192

    it "round-trips a library through writer and reader":
        val lib_path = "/tmp/unit_lib_smf_spec_roundtrip.lsm"
        delete_if_exists(lib_path)

        var builder = LibSmfBuilder.new()
        expect builder.add_module_data("math/add", [1, 2, 3, 4, 5]).is_ok() == true
        expect builder.add_module_data_with_object("math/mul", [6, 7, 8], [127, 69, 76, 70]).is_ok() == true
        expect builder.write(lib_path).is_ok() == true

        val reader = LibSmfReader.open(lib_path).unwrap()
        expect reader.module_count() == 2
        expect reader.get_module("math/add").unwrap() == [1, 2, 3, 4, 5]
        expect reader.get_object("math/mul").unwrap() == [127, 69, 76, 70]

        reader.close()
        delete_if_exists(lib_path)

    it "indexes library modules through smf getter":
        val lib_path = "/tmp/unit_lib_smf_spec_getter.lsm"
        delete_if_exists(lib_path)

        var builder = LibSmfBuilder.new()
        expect builder.add_module_data("pkg/foo", [9, 9, 1]).is_ok() == true
        expect builder.add_module_data_with_object("pkg/bar", [9, 9, 2], [127, 69, 76, 70, 0]).is_ok() == true
        expect builder.write(lib_path).is_ok() == true

        var getter = SmfGetter.new()
        expect getter.add_library(lib_path).is_ok() == true
        expect getter.has_module("pkg/foo") == true
        expect getter.has_module("pkg/bar") == true
        expect getter.get("pkg/foo").unwrap() == [9, 9, 1]
        expect getter.get_object("pkg/bar").unwrap() == [127, 69, 76, 70, 0]

        delete_if_exists(lib_path)

    it "produces deterministic hashes":
        expect fnv1a_hash([1, 2, 3]) == fnv1a_hash([1, 2, 3])
        expect fnv1a_hash([1, 2, 3]) == fnv1a_hash([1, 2, 3])