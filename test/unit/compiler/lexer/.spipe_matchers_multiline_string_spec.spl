# Multiline string spec
#
# Tests for triple-quote """ multiline string literals

describe "multiline strings":
    it "triple-quoted string is a string":
        val s = """hello world"""
        expect s == "hello world"

    it "triple-quoted string with embedded quotes":
        val s = """say "hello" to me"""
        expect s == "say \"hello\" to me"

    it "triple-quoted empty string":
        val s = """"""
        expect s == ""

    it "triple-quoted with single quotes inside":
        val s = """it's fine"""
        expect s == "it's fine"

    it "triple-quoted concatenation":
        val a = """hello """
        val b = """world"""
        val c = a + b
        expect c == "hello world"