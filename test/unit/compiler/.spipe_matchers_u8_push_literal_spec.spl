/// Verification spec: [u8].push(u8_literal) must preserve value
/// Bug: pushing a u8 literal directly writes 0 instead of the correct value.
/// Workaround: assign to var first. This spec verifies the fix.

use std.spec.*

describe "u8 push literal":
    it "preserves literal value pushed directly in it-block":
        var arr: [u8] = []
        arr.push(0x42u8)
        expect arr[0] == 0x42u8

    it "preserves hex literal via var workaround":
        var arr: [u8] = []
        var b: u8 = 0x42u8
        arr.push(b)
        expect arr[0] == 0x42u8

    it "preserves multiple direct literal pushes":
        var arr: [u8] = []
        arr.push(0x01u8)
        arr.push(0xFFu8)
        arr.push(0x7Fu8)
        expect arr[0] == 0x01u8
        expect arr[1] == 0xFFu8
        expect arr[2] == 0x7Fu8

    it "push decimal u8 literal":
        var arr: [u8] = []
        arr.push(65u8)
        expect arr[0] == 65u8

    it "indexing with int comparison":
        var arr: [u8] = []
        arr.push(0x42u8)
        val v = arr[0]
        expect v == 66