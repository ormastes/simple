use std.spec.{describe, it, expect}

fn top_bit() -> u64:
    return 0x8000000000000000u64

fn all_ones() -> u64:
    return 0xFFFFFFFFFFFFFFFFu64

fn cafe_babe() -> u64:
    return 0xCAFEBABEDEADBEEFu64

fn sha512_iv() -> u64:
    return 0x6a09e667f3bcc908u64

fn sha384_iv5() -> u64:
    return 0xdb0c2e0d64f98fa7u64

describe "u64 hex literal precision":
    it "preserves bit 63 (top bit only)":
        var v: u64 = top_bit()
        expect(v).to_equal(9223372036854775808u64)

    it "preserves all-ones (max u64)":
        var v: u64 = all_ones()
        expect(v).to_equal(18446744073709551615u64)

    it "preserves arbitrary 64-bit pattern":
        var v: u64 = cafe_babe()
        expect(v).to_equal(14627333968688430831u64)

    it "preserves SHA-512 IV constant":
        var v: u64 = sha512_iv()
        expect(v).to_equal(7640891576956012808u64)

    it "preserves SHA-384 IV5 constant (bit 63 set)":
        var v: u64 = sha384_iv5()
        expect(v).to_equal(15798461124467416487u64)
