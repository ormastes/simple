# Lazy Section Loading Specification
#
# Tests bitmap-tracked on-demand section loading for SHB files.
# Uses module-level vars to simulate mutable state (nested closure limitation).
#
# **Feature IDs:** #CACHE-031 to #CACHE-040
# **Category:** Infrastructure

# ============================================================================
# Section Flags
# ============================================================================

val FLAG_FUNCTIONS: i64 = 1
val FLAG_STRUCTS: i64 = 2
val FLAG_CLASSES: i64 = 4
val FLAG_TYPE_LAYOUTS: i64 = 8
val FLAG_ENUMS: i64 = 16
val FLAG_TRAITS: i64 = 32
val FLAG_REEXPORTS: i64 = 64
val FLAG_DEPENDENCIES: i64 = 128

# ============================================================================
# Module-level state (avoids nested closure mutation issue)
# ============================================================================

var lr_bitmap: i64 = 0
var lr_load_count: i64 = 0
var lr_functions: [text] = []
var lr_structs: [text] = []
var lr_classes: [text] = []

fn lr_reset():
    lr_bitmap = 0
    lr_load_count = 0
    lr_functions = []
    lr_structs = []
    lr_classes = []

fn lr_is_loaded(flag: i64) -> bool:
    (lr_bitmap & flag) != 0

fn lr_section_count() -> i64:
    var count: i64 = 0
    if (lr_bitmap & 1) != 0: count = count + 1
    if (lr_bitmap & 2) != 0: count = count + 1
    if (lr_bitmap & 4) != 0: count = count + 1
    if (lr_bitmap & 8) != 0: count = count + 1
    if (lr_bitmap & 16) != 0: count = count + 1
    if (lr_bitmap & 32) != 0: count = count + 1
    if (lr_bitmap & 64) != 0: count = count + 1
    if (lr_bitmap & 128) != 0: count = count + 1
    count

fn lr_ensure_functions() -> [text]:
    if not lr_is_loaded(FLAG_FUNCTIONS):
        lr_functions = ["fn_a", "fn_b", "fn_c"]
        lr_bitmap = lr_bitmap | FLAG_FUNCTIONS
        lr_load_count = lr_load_count + 1
    lr_functions

fn lr_ensure_structs() -> [text]:
    if not lr_is_loaded(FLAG_STRUCTS):
        lr_structs = ["Point", "Vec3"]
        lr_bitmap = lr_bitmap | FLAG_STRUCTS
        lr_load_count = lr_load_count + 1
    lr_structs

fn lr_ensure_classes() -> [text]:
    if not lr_is_loaded(FLAG_CLASSES):
        lr_classes = ["Widget"]
        lr_bitmap = lr_bitmap | FLAG_CLASSES
        lr_load_count = lr_load_count + 1
    lr_classes

# Getter functions (direct module var reads from `it` closures return stale values)
fn lr_get_load_count() -> i64:
    lr_load_count

fn lr_get_bitmap() -> i64:
    lr_bitmap

# ============================================================================
# Tests
# ============================================================================

describe "LazyShbReader":
    describe "bitmap tracking":
        it "starts with no sections loaded":
            lr_reset()
            expect(lr_section_count()).to_equal(0)
            expect(lr_is_loaded(FLAG_FUNCTIONS)).to_equal(false)
            expect(lr_is_loaded(FLAG_STRUCTS)).to_equal(false)

        it "marks section as loaded after first access":
            lr_reset()
            val fns = lr_ensure_functions()
            expect(lr_is_loaded(FLAG_FUNCTIONS)).to_equal(true)
            expect(lr_section_count()).to_equal(1)

        it "tracks multiple sections independently":
            lr_reset()
            lr_ensure_functions()
            lr_ensure_structs()
            expect(lr_section_count()).to_equal(2)
            expect(lr_is_loaded(FLAG_FUNCTIONS)).to_equal(true)
            expect(lr_is_loaded(FLAG_STRUCTS)).to_equal(true)
            expect(lr_is_loaded(FLAG_CLASSES)).to_equal(false)

    describe "caching behavior":
        it "loads section data only once":
            lr_reset()
            lr_ensure_functions()
            val count1 = lr_get_load_count()
            lr_ensure_functions()
            val count2 = lr_get_load_count()
            expect(count1).to_equal(1)
            expect(count2).to_equal(1)

        it "returns cached data on second access":
            lr_reset()
            val fns1 = lr_ensure_functions()
            val fns2 = lr_ensure_functions()
            expect(fns1.len()).to_equal(3)
            expect(fns2.len()).to_equal(3)

    describe "section data":
        it "returns function entries":
            lr_reset()
            val fns = lr_ensure_functions()
            expect(fns.len()).to_equal(3)
            expect(fns[0]).to_equal("fn_a")

        it "returns struct entries":
            lr_reset()
            val structs = lr_ensure_structs()
            expect(structs.len()).to_equal(2)
            expect(structs[0]).to_equal("Point")

        it "returns class entries":
            lr_reset()
            val classes = lr_ensure_classes()
            expect(classes.len()).to_equal(1)
            expect(classes[0]).to_equal("Widget")

    describe "optimization":
        it "type-check only loads functions and structs":
            lr_reset()
            lr_ensure_functions()
            lr_ensure_structs()
            expect(lr_is_loaded(FLAG_TYPE_LAYOUTS)).to_equal(false)
            expect(lr_is_loaded(FLAG_ENUMS)).to_equal(false)
            expect(lr_section_count()).to_equal(2)
