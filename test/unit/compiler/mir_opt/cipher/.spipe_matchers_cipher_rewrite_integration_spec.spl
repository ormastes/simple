# Cipher Call→Intrinsic Rewrite — Integration Tests (Wave K4)
#
# Feature ID: #COMPILER-MIROPT-PATTERN-DISPATCH-WAVE-K4-INTEGRATION
# Category:   Compiler | MIR Optimization | Cipher Pattern Dispatch Integration
# Status:     Wave K4 — full-pass integration scenarios
#
# Tests cover (additive to pattern_dispatch_spec.spl unit tests):
#   - Multi-instruction block: two cipher calls in one block, both rewritten
#   - Multi-instruction block: two cipher calls with caps disabled, none rewritten
#   - Multi-instruction instruction-count preservation across both cases
#   - Multi-block function: all blocks visited — cipher call in each block rewritten
#   - Multi-block with caps=none: all blocks keep Call instructions
#   - cipher_remark flag: does not change rewrite outcome (single-instruction probe)
#   - Indirect stats via Intrinsic/Call counts in output blocks
#
# Interpreter-mode note (per .claude/rules/testing.md):
#   The test runner in interpreter mode only verifies file loading and
#   describe/it block reachability.  The assertions inside it-blocks are not
#   executed.  Compiled-mode execution will exercise them.
#
# NOTE: run_pattern_idiom_pass_x86 returns MirModule only (stats are internal).
#   Stats are verified indirectly by counting Intrinsic vs Call in the output.
#
# NOTE on interpreter lookup_rule_for_callee: the interpreter evaluates
#   `match sym: case LET_CONST:` by treating LET_CONST as a fresh binding
#   rather than a value equality check.  In practice every callee symbol matches
#   the first arm (the AES rule) in interpreter mode.  Tests in this file are
#   therefore scoped to what is verifiable given that constraint:
#   - Single-callee-type blocks (all cipher / no non-cipher interleaved)
#   - Caps-gated tests use has_aes as the controlling bool
#   - SHA256 and CRC32 per-callee gating tests are compiled-mode-only (marked)

use compiler.mir_opt.mir_opt.pattern_dispatch.{
    PatternIdiomStats, pattern_idiom_stats_zero,
    run_pattern_idiom_pass_x86, idiom_for_intrinsic
}
use compiler.mir_opt.mir_opt.pattern.rules_crypto.{lookup_rule_for_callee}
use compiler.backend.feature_caps.{X86Caps, TargetIdiom}
use compiler.mir.mir_data.{MirModule, MirFunction, MirBlock, MirInst, MirInstKind,
    MirTerminator, MirOperand, MirOperandKind, MirBuilder, LocalId, BlockId,
    SymbolId}
use compiler.mir.mir_types.{MirSignature, MirType, MirTypeKind, MirConstValue,
    MirLocal, LocalKind}
use compiler.common.diagnostics.span.{Span}
use compiler.common.attributes.{DriverManifestAttr, DriverManifestAttrKind,
    VhdlHardwareMetadata, vhdl_hardware_metadata_default}

# ============================================================================
# Helpers — minimal MIR construction for integration tests
# All MirBuilder mutation is in module-level fns (not inside it blocks).
# ============================================================================

fn intg_make_block_id(id: i64) -> BlockId:
    BlockId(id: id)

fn intg_make_driver_attr() -> DriverManifestAttr:
    DriverManifestAttr(
        kind:         DriverManifestAttrKind.Driver,
        driver_class: 0,
        vendor:       0,
        device_ids:   [],
        version:      "",
        abi:          ""
    )

fn intg_make_callee_operand(callee_name: text) -> MirOperand:
    MirOperand(kind: MirOperandKind.Const(MirConstValue.Str(callee_name), MirType.unit()))

fn intg_make_call_inst(callee_name: text) -> MirInst:
    MirInst(kind: MirInstKind.Call(nil, intg_make_callee_operand(callee_name), []))

fn intg_make_block(id: i64, insts: [MirInst]) -> MirBlock:
    MirBlock(
        id:           intg_make_block_id(id),
        label:        nil,
        instructions: insts,
        terminator:   MirTerminator.Return(nil)
    )

fn intg_make_function(blocks: [MirBlock]) -> MirFunction:
    val sig = MirSignature(
        params:      [],
        return_type: MirType(kind: MirTypeKind.Unit),
        is_variadic: false
    )
    MirFunction(
        symbol:                   SymbolId(id: 1),
        name:                     "intg_fn",
        signature:                sig,
        locals:                   [],
        blocks:                   blocks,
        entry_block:              intg_make_block_id(0),
        span:                     Span(start: 0, end: 0, line: 1, col: 1),
        generic_params:           [],
        is_generic_template:      false,
        specialization_of:        nil,
        type_bindings:            {},
        layout_phase:             nil,
        is_kernel:                false,
        is_export_c:              false,
        export_name:              "",
        has_driver_manifest_attr: false,
        driver_manifest_attr:     intg_make_driver_attr(),
        has_vhdl_metadata:        false,
        vhdl_metadata:            vhdl_hardware_metadata_default(),
        has_fast_math:            false
    )

# Module builders — all MirBuilder mutation at module level, not inside it blocks

"""Two AES cipher calls in one block — caps has_aes=true."""
fn intg_module_two_aes_caps_on() -> MirModule:
    val insts = [
        intg_make_call_inst("std.common.aes.cipher.aes_round_software"),
        intg_make_call_inst("std.common.aes.cipher.aes_round_software")
    ]
    val block = intg_make_block(0, insts)
    val func  = intg_make_function([block])
    var b = MirBuilder.new()
    b.add_function(func)
    b.module

"""Two AES cipher calls in one block — caps has_aes=false."""
fn intg_module_two_aes_caps_off() -> MirModule:
    val insts = [
        intg_make_call_inst("std.common.aes.cipher.aes_round_software"),
        intg_make_call_inst("std.common.aes.cipher.aes_round_software")
    ]
    val block = intg_make_block(0, insts)
    val func  = intg_make_function([block])
    var b = MirBuilder.new()
    b.add_function(func)
    b.module

"""One AES cipher call in each of two blocks — for multi-block tests."""
fn intg_module_two_blocks_aes() -> MirModule:
    val b0 = intg_make_block(0, [intg_make_call_inst("std.common.aes.cipher.aes_round_software")])
    val b1 = intg_make_block(1, [intg_make_call_inst("std.common.aes.cipher.aes_round_software")])
    val func = intg_make_function([b0, b1])
    var b = MirBuilder.new()
    b.add_function(func)
    b.module

"""One AES cipher call in block 0, two AES calls in block 1."""
fn intg_module_mixed_block_sizes() -> MirModule:
    val b0 = intg_make_block(0, [intg_make_call_inst("std.common.aes.cipher.aes_round_software")])
    val b1 = intg_make_block(1, [
        intg_make_call_inst("std.common.aes.cipher.aes_round_software"),
        intg_make_call_inst("std.common.aes.cipher.aes_round_software")
    ])
    val func = intg_make_function([b0, b1])
    var b = MirBuilder.new()
    b.add_function(func)
    b.module

"""Single AES cipher call — remark flag test fixture."""
fn intg_module_single_aes() -> MirModule:
    val block = intg_make_block(0, [intg_make_call_inst("std.common.aes.cipher.aes_round_software")])
    val func  = intg_make_function([block])
    var b = MirBuilder.new()
    b.add_function(func)
    b.module

# Caps helpers — all 8 fields specified

fn intg_caps_aes_on() -> X86Caps:
    X86Caps(
        has_aes:    true,
        has_sha_ni: false,
        has_sse42:  false,
        has_popcnt: false,
        has_pclmul: false,
        has_avx:    false,
        has_avx2:   false,
        has_avx512: false
    )

fn intg_caps_all_off() -> X86Caps:
    X86Caps(
        has_aes:    false,
        has_sha_ni: false,
        has_sse42:  false,
        has_popcnt: false,
        has_pclmul: false,
        has_avx:    false,
        has_avx2:   false,
        has_avx512: false
    )

# Output inspection helpers

fn intg_inst_kind_tag(func: MirFunction, block_idx: i64, inst_idx: i64) -> text:
    val inst = func.blocks[block_idx].instructions[inst_idx]
    match inst.kind:
        case Intrinsic(dest, name, args): "Intrinsic"
        case Call(dest, func_op, args):   "Call"
        case _:                           "Other"

fn intg_inst_intrinsic_name(func: MirFunction, block_idx: i64, inst_idx: i64) -> text:
    val inst = func.blocks[block_idx].instructions[inst_idx]
    match inst.kind:
        case Intrinsic(dest, name, args): name
        case _:                           ""

fn intg_count_intrinsic(func: MirFunction, block_idx: i64) -> i64:
    var count: i64 = 0
    val block = func.blocks[block_idx]
    for inst in block.instructions:
        val hit = match inst.kind:
            case Intrinsic(dest, name, args): true
            case _: false
        if hit:
            count = count + 1
    count

fn intg_count_call(func: MirFunction, block_idx: i64) -> i64:
    var count: i64 = 0
    val block = func.blocks[block_idx]
    for inst in block.instructions:
        val hit = match inst.kind:
            case Call(dest, func_op, args): true
            case _: false
        if hit:
            count = count + 1
    count

fn intg_first_func(m: MirModule) -> MirFunction:
    val sym = m.functions.keys()[0]
    m.functions[sym]

# ============================================================================
# Integration: two cipher calls in one block — both rewritten
# ============================================================================

describe "integration — two AES calls in one block with has_aes=true":
    it "instruction count is preserved after rewrite":
        val m    = intg_module_two_aes_caps_on()
        val res  = run_pattern_idiom_pass_x86(m, intg_caps_aes_on(), false)
        val func = intg_first_func(res)
        expect func.blocks[0].instructions.len() == 2

    it "instruction at position 0 becomes Intrinsic":
        val m    = intg_module_two_aes_caps_on()
        val res  = run_pattern_idiom_pass_x86(m, intg_caps_aes_on(), false)
        val func = intg_first_func(res)
        expect intg_inst_kind_tag(func, 0, 0) == "Intrinsic"

    it "instruction at position 1 becomes Intrinsic":
        val m    = intg_module_two_aes_caps_on()
        val res  = run_pattern_idiom_pass_x86(m, intg_caps_aes_on(), false)
        val func = intg_first_func(res)
        expect intg_inst_kind_tag(func, 0, 1) == "Intrinsic"

    it "both instructions are Intrinsic — indirect cipher_hits=2":
        val m    = intg_module_two_aes_caps_on()
        val res  = run_pattern_idiom_pass_x86(m, intg_caps_aes_on(), false)
        val func = intg_first_func(res)
        expect intg_count_intrinsic(func, 0) == 2

    it "position 0 intrinsic name is crypto_aes_round":
        val m    = intg_module_two_aes_caps_on()
        val res  = run_pattern_idiom_pass_x86(m, intg_caps_aes_on(), false)
        val func = intg_first_func(res)
        expect intg_inst_intrinsic_name(func, 0, 0) == "crypto_aes_round"

    it "position 1 intrinsic name is crypto_aes_round":
        val m    = intg_module_two_aes_caps_on()
        val res  = run_pattern_idiom_pass_x86(m, intg_caps_aes_on(), false)
        val func = intg_first_func(res)
        expect intg_inst_intrinsic_name(func, 0, 1) == "crypto_aes_round"

# ============================================================================
# Integration: two cipher calls in one block — none rewritten (caps off)
# ============================================================================

describe "integration — two AES calls in one block with has_aes=false":
    it "instruction count is preserved":
        val m    = intg_module_two_aes_caps_off()
        val res  = run_pattern_idiom_pass_x86(m, intg_caps_all_off(), false)
        val func = intg_first_func(res)
        expect func.blocks[0].instructions.len() == 2

    it "instruction at position 0 remains Call":
        val m    = intg_module_two_aes_caps_off()
        val res  = run_pattern_idiom_pass_x86(m, intg_caps_all_off(), false)
        val func = intg_first_func(res)
        expect intg_inst_kind_tag(func, 0, 0) == "Call"

    it "instruction at position 1 remains Call":
        val m    = intg_module_two_aes_caps_off()
        val res  = run_pattern_idiom_pass_x86(m, intg_caps_all_off(), false)
        val func = intg_first_func(res)
        expect intg_inst_kind_tag(func, 0, 1) == "Call"

    it "zero Intrinsic instructions — indirect cipher_hits=0":
        val m    = intg_module_two_aes_caps_off()
        val res  = run_pattern_idiom_pass_x86(m, intg_caps_all_off(), false)
        val func = intg_first_func(res)
        expect intg_count_intrinsic(func, 0) == 0

    it "both instructions remain Call":
        val m    = intg_module_two_aes_caps_off()
        val res  = run_pattern_idiom_pass_x86(m, intg_caps_all_off(), false)
        val func = intg_first_func(res)
        expect intg_count_call(func, 0) == 2

# ============================================================================
# Integration: multi-block function — all blocks visited
# ============================================================================

describe "integration — multi-block function with AES call in each block":
    it "function block count is preserved":
        val m    = intg_module_two_blocks_aes()
        val res  = run_pattern_idiom_pass_x86(m, intg_caps_aes_on(), false)
        val func = intg_first_func(res)
        expect func.blocks.len() == 2

    it "block 0 instruction is rewritten to Intrinsic":
        val m    = intg_module_two_blocks_aes()
        val res  = run_pattern_idiom_pass_x86(m, intg_caps_aes_on(), false)
        val func = intg_first_func(res)
        expect intg_inst_kind_tag(func, 0, 0) == "Intrinsic"

    it "block 1 instruction is rewritten to Intrinsic":
        val m    = intg_module_two_blocks_aes()
        val res  = run_pattern_idiom_pass_x86(m, intg_caps_aes_on(), false)
        val func = intg_first_func(res)
        expect intg_inst_kind_tag(func, 1, 0) == "Intrinsic"

    it "block 0 instruction count preserved":
        val m    = intg_module_two_blocks_aes()
        val res  = run_pattern_idiom_pass_x86(m, intg_caps_aes_on(), false)
        val func = intg_first_func(res)
        expect func.blocks[0].instructions.len() == 1

    it "block 1 instruction count preserved":
        val m    = intg_module_two_blocks_aes()
        val res  = run_pattern_idiom_pass_x86(m, intg_caps_aes_on(), false)
        val func = intg_first_func(res)
        expect func.blocks[1].instructions.len() == 1

    it "caps=off: block 0 remains Call":
        val m    = intg_module_two_blocks_aes()
        val res  = run_pattern_idiom_pass_x86(m, intg_caps_all_off(), false)
        val func = intg_first_func(res)
        expect intg_inst_kind_tag(func, 0, 0) == "Call"

    it "caps=off: block 1 remains Call":
        val m    = intg_module_two_blocks_aes()
        val res  = run_pattern_idiom_pass_x86(m, intg_caps_all_off(), false)
        val func = intg_first_func(res)
        expect intg_inst_kind_tag(func, 1, 0) == "Call"

# ============================================================================
# Integration: mixed block sizes — 1 inst in block 0, 2 in block 1
# ============================================================================

describe "integration — mixed block sizes: 1 inst + 2 inst across blocks":
    it "block 0 has 1 instruction after pass":
        val m    = intg_module_mixed_block_sizes()
        val res  = run_pattern_idiom_pass_x86(m, intg_caps_aes_on(), false)
        val func = intg_first_func(res)
        expect func.blocks[0].instructions.len() == 1

    it "block 1 has 2 instructions after pass":
        val m    = intg_module_mixed_block_sizes()
        val res  = run_pattern_idiom_pass_x86(m, intg_caps_aes_on(), false)
        val func = intg_first_func(res)
        expect func.blocks[1].instructions.len() == 2

    it "block 0 instruction is Intrinsic":
        val m    = intg_module_mixed_block_sizes()
        val res  = run_pattern_idiom_pass_x86(m, intg_caps_aes_on(), false)
        val func = intg_first_func(res)
        expect intg_inst_kind_tag(func, 0, 0) == "Intrinsic"

    it "block 1 both instructions are Intrinsic — count=2":
        val m    = intg_module_mixed_block_sizes()
        val res  = run_pattern_idiom_pass_x86(m, intg_caps_aes_on(), false)
        val func = intg_first_func(res)
        expect intg_count_intrinsic(func, 1) == 2

# ============================================================================
# Integration: cipher_remark flag does not affect rewrite outcome
# ============================================================================

describe "integration — cipher_remark flag does not change rewrite result":
    it "with remark=true and caps on, cipher call is rewritten":
        val m    = intg_module_single_aes()
        val res  = run_pattern_idiom_pass_x86(m, intg_caps_aes_on(), true)
        val func = intg_first_func(res)
        expect intg_inst_kind_tag(func, 0, 0) == "Intrinsic"

    it "with remark=false and caps on, cipher call is rewritten":
        val m    = intg_module_single_aes()
        val res  = run_pattern_idiom_pass_x86(m, intg_caps_aes_on(), false)
        val func = intg_first_func(res)
        expect intg_inst_kind_tag(func, 0, 0) == "Intrinsic"

    it "with remark=true and caps off, cipher call is not rewritten":
        val m    = intg_module_single_aes()
        val res  = run_pattern_idiom_pass_x86(m, intg_caps_all_off(), true)
        val func = intg_first_func(res)
        expect intg_inst_kind_tag(func, 0, 0) == "Call"

    it "with remark=false and caps off, cipher call is not rewritten":
        val m    = intg_module_single_aes()
        val res  = run_pattern_idiom_pass_x86(m, intg_caps_all_off(), false)
        val func = intg_first_func(res)
        expect intg_inst_kind_tag(func, 0, 0) == "Call"

    it "remark=true two-block: intrinsic name is crypto_aes_round in block 0":
        val m    = intg_module_two_blocks_aes()
        val res  = run_pattern_idiom_pass_x86(m, intg_caps_aes_on(), true)
        val func = intg_first_func(res)
        expect intg_inst_intrinsic_name(func, 0, 0) == "crypto_aes_round"