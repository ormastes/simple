# Pattern-Idiom Pass Dispatch — Schema Tests
#
# Feature ID: #COMPILER-MIROPT-PATTERN-DISPATCH-WAVE-K3
# Category:   Compiler | MIR Optimization | Cipher Pattern Dispatch
# Status:     Wave K3 (visit-only) — no MIR rewrite yet
#
# These tests fix the public API of run_pattern_idiom_pass and
# pattern_idiom_stats_zero.  Wave K4 will add a recogniser/rewriter that
# replaces software cipher Calls with MirInstKind.Intrinsic.
#
# Interpreter-mode note (per .claude/rules/testing.md):
#   The test runner in interpreter mode only verifies file loading and
#   describe/it block reachability.  The assertions inside it-blocks are not
#   executed.  Compiled-mode execution will exercise them.

use compiler.mir_opt.mir_opt.pattern_dispatch.{
    PatternIdiomStats, pattern_idiom_stats_zero
}

# ============================================================================
# Schema: PatternIdiomStats and the zero builder
# ============================================================================

describe "PatternIdiomStats — zero builder":
    it "starts with zero visited functions":
        var s = pattern_idiom_stats_zero()
        expect s.visited_functions == 0

    it "starts with zero visited blocks":
        var s = pattern_idiom_stats_zero()
        expect s.visited_blocks == 0

    it "starts with zero visited calls":
        var s = pattern_idiom_stats_zero()
        expect s.visited_calls == 0

    it "starts with zero cipher hits":
        var s = pattern_idiom_stats_zero()
        expect s.cipher_hits == 0