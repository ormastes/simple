use std.spec
use compiler.mir.mir_instructions.{
    BlockId, MirBlock, MirInst, MirInstKind, MirBorrowKind,
    MirPlace, MirOperand, MirOperandKind, MirTerminator, MirBinOp
}
use compiler.mir.mir_types.{LocalId, MirConstValue, MirType}
use compiler.mir_opt.mir_opt.var_reassign_analysis.{
    analyze_var_reassign_blocks,
    var_reassign_analysis_to_jit_facts,
    ssa_var_transform_blocks
}
use compiler.interp.execution.tiered_jit.{
    FunctionProfile, JitTier, TieredJitConfig,
    jit_hotspot_plan_with_var_facts
}

fn local(id: i64) -> LocalId:
    LocalId(id: id)

fn int_operand(value: i64) -> MirOperand:
    MirOperand(kind: MirOperandKind.Const(MirConstValue.Int(value), MirType.i64()))

fn copy_operand(id: i64) -> MirOperand:
    MirOperand(kind: MirOperandKind.Copy(local(id)))

fn inst(kind: MirInstKind) -> MirInst:
    MirInst(kind: kind, span: nil)

fn one_block(instructions: [MirInst], terminator: MirTerminator) -> [MirBlock]:
    [
        MirBlock(
            id: BlockId.new(0),
            label: "entry",
            instructions: instructions,
            terminator: terminator
        )
    ]

fn hot_profile() -> FunctionProfile:
    FunctionProfile(
        name: "hot_var",
        call_count: 64,
        tier: JitTier.Interpreted,
        compile_time_ms: 0.0,
        source: "fn hot_var() -> i64: 1",
        typed_mir: true,
        safe_deopt: true,
        hotspot_specialized_source: "",
        hotspot_semantic_proof: false
    )

fn hotspot_config() -> TieredJitConfig:
    TieredJitConfig(tier1_threshold: 8, tier2_threshold: 128, debug_mode: false)

describe "var reassignment analysis":
    it "marks repeated local definitions as SSA-transformable when local and borrow-safe":
        val blocks = one_block(
            [
                inst(MirInstKind.Const(local(0), MirConstValue.Int(1), MirType.i64())),
                inst(MirInstKind.Const(local(0), MirConstValue.Int(2), MirType.i64()))
            ],
            MirTerminator.Return(Some(copy_operand(1)))
        )
        val analysis = analyze_var_reassign_blocks(blocks)
        expect(analysis.has_var_reassignment).to_equal(true)
        expect(analysis.reassignment_count).to_equal(1)
        expect(analysis.ssa_transform_safe).to_equal(true)
        expect(analysis.no_escape).to_equal(true)
        expect(analysis.borrow_reassign_safe).to_equal(true)

    it "rejects reassignment after an outstanding borrow of the same local":
        val blocks = one_block(
            [
                inst(MirInstKind.Const(local(0), MirConstValue.Int(1), MirType.i64())),
                inst(MirInstKind.Ref(local(2), MirBorrowKind.Shared, MirPlace.local_place(local(0)))),
                inst(MirInstKind.Const(local(0), MirConstValue.Int(2), MirType.i64()))
            ],
            MirTerminator.Return(Some(copy_operand(2)))
        )
        val analysis = analyze_var_reassign_blocks(blocks)
        expect(analysis.has_var_reassignment).to_equal(true)
        expect(analysis.ssa_transform_safe).to_equal(false)
        expect(analysis.borrow_reassign_safe).to_equal(false)
        expect(analysis.reason).to_equal("borrow.reassign_unsafe")

    it "rejects reassigned locals that escape through return":
        val blocks = one_block(
            [
                inst(MirInstKind.Const(local(0), MirConstValue.Int(1), MirType.i64())),
                inst(MirInstKind.Const(local(0), MirConstValue.Int(2), MirType.i64()))
            ],
            MirTerminator.Return(Some(copy_operand(0)))
        )
        val analysis = analyze_var_reassign_blocks(blocks)
        expect(analysis.has_var_reassignment).to_equal(true)
        expect(analysis.no_escape).to_equal(false)
        expect(analysis.ssa_transform_safe).to_equal(false)
        expect(analysis.reason).to_equal("escape.reassigned_storage")

    it "feeds analyzer output into JIT var hotspot planning":
        val blocks = one_block(
            [
                inst(MirInstKind.Const(local(0), MirConstValue.Int(1), MirType.i64())),
                inst(MirInstKind.Const(local(0), MirConstValue.Int(2), MirType.i64()))
            ],
            MirTerminator.Return(Some(copy_operand(1)))
        )
        val analysis = analyze_var_reassign_blocks(blocks)
        val facts = var_reassign_analysis_to_jit_facts(analysis)
        val plan = jit_hotspot_plan_with_var_facts(hot_profile(), hotspot_config(), true, true, facts)
        expect(plan.eligible).to_equal(true)
        expect(plan.facts.contains("ssa.var_transform")).to_equal(true)
        expect(plan.facts.contains("borrow.reassign_safe")).to_equal(true)

    it "rewrites straight-line reassignment into a fresh SSA local":
        val blocks = one_block(
            [
                inst(MirInstKind.Const(local(0), MirConstValue.Int(1), MirType.i64())),
                inst(MirInstKind.Const(local(0), MirConstValue.Int(2), MirType.i64())),
                inst(MirInstKind.BinOp(local(1), MirBinOp.Add, copy_operand(0), int_operand(1)))
            ],
            MirTerminator.Return(Some(copy_operand(1)))
        )
        val result = ssa_var_transform_blocks(blocks)
        expect(result.applied).to_equal(true)
        expect(result.renamed_count).to_equal(1)
        val rewritten = result.blocks[0].instructions
        match rewritten[1].kind:
            case Const(dest, _, _):
                expect(dest.id).to_equal(2)
            case _:
                expect(false).to_equal(true)
        match rewritten[2].kind:
            case BinOp(_, _, left, _):
                match left.kind:
                    case Copy(local_id):
                        expect(local_id.id).to_equal(2)
                    case _:
                        expect(false).to_equal(true)
            case _:
                expect(false).to_equal(true)

    it "reports unsupported CFG when no simple phi merge is recognized":
        val first = MirBlock(
            id: BlockId.new(0),
            label: "entry",
            instructions: [inst(MirInstKind.Const(local(0), MirConstValue.Int(1), MirType.i64()))],
            terminator: MirTerminator.Goto(BlockId.new(1))
        )
        val second = MirBlock(
            id: BlockId.new(1),
            label: "next",
            instructions: [inst(MirInstKind.Const(local(0), MirConstValue.Int(2), MirType.i64()))],
            terminator: MirTerminator.Return(Some(copy_operand(0)))
        )
        val result = ssa_var_transform_blocks([first, second])
        expect(result.applied).to_equal(false)
        expect(result.reason).to_equal("unsupported cfg")
        expect(result.phi_required_count).to_equal(0)

    it "reports phi-required locals for an if/else merge":
        val entry = MirBlock(
            id: BlockId.new(0),
            label: "entry",
            instructions: [],
            terminator: MirTerminator.If(copy_operand(9), BlockId.new(1), BlockId.new(2))
        )
        val then_block = MirBlock(
            id: BlockId.new(1),
            label: "then",
            instructions: [inst(MirInstKind.Const(local(0), MirConstValue.Int(1), MirType.i64()))],
            terminator: MirTerminator.Goto(BlockId.new(3))
        )
        val else_block = MirBlock(
            id: BlockId.new(2),
            label: "else",
            instructions: [inst(MirInstKind.Const(local(0), MirConstValue.Int(2), MirType.i64()))],
            terminator: MirTerminator.Goto(BlockId.new(3))
        )
        val join = MirBlock(
            id: BlockId.new(3),
            label: "join",
            instructions: [inst(MirInstKind.BinOp(local(1), MirBinOp.Add, copy_operand(0), int_operand(1)))],
            terminator: MirTerminator.Return(Some(copy_operand(1)))
        )
        val result = ssa_var_transform_blocks([entry, then_block, else_block, join])
        expect(result.applied).to_equal(false)
        expect(result.reason).to_equal("requires phi nodes")
        expect(result.phi_required_count).to_equal(1)
        expect(result.phi_required_locals[0]).to_equal(0)
