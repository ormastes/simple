# @cover src/compiler/60.mir_opt/mir_opt/copy_propagation.spl 80%
"""
# CopyPropagation Specification

**Feature IDs:** #web-server-optimizer-complete
**Category:** Compiler / MIR Optimization
**Difficulty:** 2/5
**Status:** Draft

## Overview

Validates the CopyPropagation pass which promotes copy-to-move when the
source register has no subsequent uses, and propagates through chains of
copies back to the original source.

## Behavior

- Source with no subsequent uses → copy promoted to move
- Source used after the copy → copy preserved
- Chain of copies resolved to original source
- Pass statistics count every promoted copy
"""

use std.spec


# ============================================================================
# Stub helpers
# ============================================================================

fn use_count_after(uses: List<i64>, copy_pos: i64) -> i64:
    # Count uses with position index greater than copy_pos.
    var count = 0
    var i = 0
    while i < uses.len():
        if uses[i] > copy_pos:
            count = count + 1
        i = i + 1
    count

fn can_promote_to_move(source_uses_after_copy: i64) -> bool:
    source_uses_after_copy == 0

fn resolve_copy_chain(chain: List<text>) -> text:
    # Returns the first element of the chain (the original source).
    if chain.len() == 0:
        "none"
    else:
        chain[0]

fn simulate_copy_promotion(copies: List<text>, moveable: List<bool>) -> i64:
    # Returns count of copies promoted to moves.
    var promoted = 0
    var i = 0
    while i < copies.len():
        if moveable[i]:
            promoted = promoted + 1
        i = i + 1
    promoted


# ============================================================================
# CopyPropagation tests
# ============================================================================

describe "CopyPropagation":

    describe "copy-to-move promotion":

        it "promotes copy to move when source has no subsequent uses":
            # %src is defined at pos 0, copied at pos 5, never used after pos 5.
            val src_uses = [0, 5]
            val copy_pos = 5
            val uses_after = use_count_after(src_uses, copy_pos)
            val should_promote = can_promote_to_move(uses_after)
            expect(should_promote).to_equal(true)

        it "preserves copy when source is used after copy":
            # %src is used at pos 7, copied at pos 5 — use comes after copy.
            val src_uses = [0, 5, 7]
            val copy_pos = 5
            val uses_after = use_count_after(src_uses, copy_pos)
            val should_promote = can_promote_to_move(uses_after)
            expect(should_promote).to_equal(false)

    describe "chain propagation":

        it "handles chain of copies — propagates through to original source":
            # %a → %b → %c → %d: original source is %a
            val chain = ["%a", "%b", "%c", "%d"]
            val original = resolve_copy_chain(chain)
            expect(original).to_equal("%a")

        it "returns sole element as source for length-1 chain":
            val chain = ["%x"]
            val original = resolve_copy_chain(chain)
            expect(original).to_equal("%x")

    describe "pass statistics":

        it "counts promoted copies in pass statistics":
            # 4 copies: first 3 promotable, last one is not.
            val copies = ["%a", "%b", "%c", "%d"]
            val moveable = [true, true, true, false]
            val promoted = simulate_copy_promotion(copies, moveable)
            expect(promoted).to_equal(3)
            expect(promoted).to_be_greater_than(0)

        it "reports zero promoted copies when none qualify":
            val copies = ["%x", "%y"]
            val moveable = [false, false]
            val promoted = simulate_copy_promotion(copies, moveable)
            expect(promoted).to_equal(0)
