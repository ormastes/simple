# ============================================================================
# N1 positive: end-to-end block structure for divisible trip count (0..16, VF=4)
#
# Verifies the three-block output of the rewrite by testing each codegen helper
# in isolation — same structural invariants without needing a full MirFunction.
# (MirFunction construction requires HirType/LayoutPhase; deferred to compiled mode.)
# ============================================================================

describe "AutoVectorize N1-rewrite — elementwise-add divisible trip count (0..16) via codegen":
    it "alignment-check block has If terminator (branches to vec_loop or peel)":
        val ctx = VectorizeContext(vector_width: 4, element_type: "i32", next_local: 1)
        val li  = LoopInfo(
            header_block:  make_block_id(1),
            body_blocks:   [],
            exit_block:    make_block_id(4),
            induction_var: make_local(4),
            start_value:   0,
            end_value:     16,
            step:          1
        )
        val align = create_alignment_check_block(ctx, li)
        val is_if = match align.terminator:
            case If(cond, then_, else_): true
            case _: false
        expect(is_if).to_equal(true)

    it "vec_loop block for i32x4 recipe has label vec_loop":
        val ctx = VectorizeContext(vector_width: 4, element_type: "i32", next_local: 1)
        val bb  = create_vector_loop_block(ctx, 1,
            [make_local(10), make_local(11)], make_local(12), "add_elementwise")
        expect(bb.label.?).to_equal(true)
        expect(bb.label.unwrap()).to_equal("vec_loop")

    it "vec_loop block for i32x4 has >= 4 SIMD instructions":
        val ctx = VectorizeContext(vector_width: 4, element_type: "i32", next_local: 1)
        val bb  = create_vector_loop_block(ctx, 1,
            [make_local(10), make_local(11)], make_local(12), "add_elementwise")
        # load_a + load_b + simd_add + simd_store + vi_inc = 5 instructions
        expect(bb.instructions.len() >= 4).to_equal(true)

    it "peel_loop block for trip_count=16 divisible trip has label peel_loop":
        val ctx = VectorizeContext(vector_width: 4, element_type: "i32", next_local: 1)
        val li  = LoopInfo(
            header_block:  make_block_id(1),
            body_blocks:   [],
            exit_block:    make_block_id(4),
            induction_var: make_local(4),
            start_value:   0,
            end_value:     16,
            step:          1
        )
        val peel = create_peeling_block(ctx, li)
        expect(peel.label.?).to_equal(true)
        expect(peel.label.unwrap()).to_equal("peel_loop")

# ============================================================================
# N1 positive: dynamic trip count (0..n, VF=4) → alignment_check is runtime
# ============================================================================

describe "AutoVectorize N1-rewrite — elementwise-add dynamic trip count (0..n) via codegen":
    it "alignment-check block for dynamic n (end_value=0 sentinel) still has If terminator":
        # When trip_count = -1 (unknown), rewriter uses end_value=0 as sentinel.
        # The alignment-check block still produces a runtime If terminator.
        val ctx = VectorizeContext(vector_width: 4, element_type: "i32", next_local: 1)
        val li  = LoopInfo(
            header_block:  make_block_id(1),
            body_blocks:   [],
            exit_block:    make_block_id(4),
            induction_var: make_local(4),
            start_value:   0,
            end_value:     0,
            step:          1
        )
        val align = create_alignment_check_block(ctx, li)
        val is_if = match align.terminator:
            case If(cond, then_, else_): true
            case _: false
        expect(is_if).to_equal(true)

    it "peel_loop block for dynamic n has Goto terminator (structural placeholder)":
        val ctx = VectorizeContext(vector_width: 4, element_type: "i32", next_local: 1)
        val li  = LoopInfo(
            header_block:  make_block_id(1),
            body_blocks:   [],
            exit_block:    make_block_id(4),
            induction_var: make_local(4),
            start_value:   0,
            end_value:     0,
            step:          1
        )
        val peel = create_peeling_block(ctx, li)
        val is_goto = match peel.terminator:
            case Goto(target): true
            case _: false
        expect(is_goto).to_equal(true)

# ============================================================================
# N1 negative: trip count < chunk_width → rewriter refuses
# ============================================================================

describe "AutoVectorize N1-rewrite — refuses trip count < chunk_width (0..3, VF=4)":
    it "trip-count=3 < VF=4 returns function unchanged (same block count)":
        val orig_block = make_elementwise_block_add()
        val func       = make_test_mir_function([orig_block], false)
        val recipe     = VectorRecipe(
            kind:          VectorRecipeKind.Elementwise,
            header_block:  make_block_id(1),
            induction_var: make_local(4),
            trip_count:    3,
            element_type:  "i32",
            vector_width:  4,
            op_name:       "add_elementwise",
            note:          "too short",
            input_bases:   [make_local(10), make_local(11)],
            output_base:   Some(make_local(12)),
            accumulator:   nil,
            chunk_width:   4,
            index_locals:  [make_local(4)],
            store_value:   nil
        )
        val result = rewrite_elementwise_add(recipe, func)
        expect(result.blocks.len()).to_equal(func.blocks.len())

# ============================================================================
# N1 negative: unsupported elementwise op → rewriter refuses
# ============================================================================

describe "AutoVectorize N1-rewrite — refuses unsupported elementwise div":
    it "div recipe is outside the phase-1 rewrite set":
        val orig_block = make_elementwise_block_mul()
        val func       = make_test_mir_function([orig_block], false)
        val recipe     = make_unsupported_div_recipe()
        val result     = rewrite_elementwise_add(recipe, func)
        expect(result.blocks.len()).to_equal(func.blocks.len())

describe "AutoVectorize N1-rewrite — elementwise mul is in the phase-1 rewrite set":
    it "mul recipe is accepted by the phase-1 rewrite gate":
        expect(supports_elementwise_rewrite("mul_elementwise")).to_equal(true)

# ============================================================================
# N1 positive: elementwise FP ops do not require fast-math
# ============================================================================

describe "AutoVectorize N1-rewrite — elementwise f32 add does not require fast_math":
    it "f32 elementwise-add remains in the supported rewrite set without fast_math":
        val recipe = make_elementwise_add_recipe_f32_no_fastmath()
        expect(supports_elementwise_rewrite(recipe.op_name)).to_equal(true)

# ============================================================================
# N1 codegen helper: create_vector_loop_block
# ============================================================================

describe "AutoVectorize N1-codegen — create_vector_loop_block":
    it "produces a block with label vec_loop":
        val ctx   = VectorizeContext(vector_width: 4, element_type: "i32", next_local: 100)
        val bb    = create_vector_loop_block(ctx, 100, [make_local(10), make_local(11)], make_local(12), "add_elementwise")
        expect(bb.label.?).to_equal(true)
        expect(bb.label.unwrap()).to_equal("vec_loop")

    it "vec_loop block contains >= 4 instructions (load_a, load_b, add, store)":
        val ctx   = VectorizeContext(vector_width: 4, element_type: "i32", next_local: 100)
        val bb    = create_vector_loop_block(ctx, 100, [make_local(10), make_local(11)], make_local(12), "xor_elementwise")
        expect(bb.instructions.len() >= 4).to_equal(true)
