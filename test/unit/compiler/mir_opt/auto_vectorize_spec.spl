# Auto-Vectorization Pass — Unit Tests (Wave K3)
#
# Feature ID: #COMPILER-MIROPT-AV-K3
# Category:   Compiler | MIR Optimization | Auto-Vectorization
# Status:     Skeleton — pattern matchers only; no MIR rewrite in this wave
#
# Test plan (from simd_auto_vectorize_design.md §9):
#   Positive cases (5): elementwise and reduction matchers return Some(recipe)
#                       for shapes drawn from J4 top-20 targets
#   Negative cases (5): matchers return nil for each §8 failure mode
#   No-op case  (1+):   run_auto_vectorize returns module byte-for-byte unchanged
#
# Interpreter-mode note (per .claude/rules/testing.md):
#   The test runner in interpreter mode only verifies file loading and describe/it
#   block reachability.  The assertions inside it-blocks are not executed.
#   All assertions use built-in matchers only: to_equal, to_be_nil, to_be.

use compiler.mir.mir_data.{MirModule, MirFunction, MirBlock, MirInst, MirInstKind,
    MirTerminator, MirOperand, MirOperandKind, MirBinOp, LocalId, BlockId,
    SymbolId}
use compiler.mir.mir_types.{MirSignature, MirType, MirTypeKind, MirLocal, LocalKind}
use compiler.common.diagnostics.span.{Span}
use compiler.common.attributes.{DriverManifestAttr, DriverManifestAttrKind,
    VhdlHardwareMetadata, vhdl_hardware_metadata_default}
use compiler.mir_opt.mir_opt.auto_vectorize.{
    VectorRecipeKind, VectorRecipe,
    mir_pattern_match_elementwise_loop,
    mir_pattern_match_reduction,
    mir_pattern_match_matrix_kernel,
    supports_elementwise_rewrite,
    run_auto_vectorize
}
use compiler.mir_opt.auto_vectorize_analysis.{LoopBounds, detect_bounds_from_block}
use compiler.mir_opt.mir_opt.auto_vectorize_codegen.{VectorizeContext, create_alignment_check_block, create_peeling_block, create_vector_loop_block}
use compiler.mir_opt.mir_opt.auto_vectorize.{rewrite_elementwise_add}
use compiler.mir_opt.auto_vectorize_types.{LoopInfo}

# ============================================================================
# Helpers — minimal MIR construction for tests
# ============================================================================

fn make_local(id: i64) -> LocalId:
    LocalId(id: id)

fn make_block_id(id: i64) -> BlockId:
    BlockId.new(id)

fn make_const_op(val_text: text) -> MirOperand:
    MirOperand(kind: MirOperandKind.Const("i64", val_text))

fn make_copy_op(local_id: i64) -> MirOperand:
    MirOperand(kind: MirOperandKind.Copy(make_local(local_id)))

fn make_load_inst(dest_id: i64, ptr_id: i64) -> MirInst:
    MirInst(kind: MirInstKind.Load(make_local(dest_id), make_copy_op(ptr_id)))

fn make_store_inst(ptr_id: i64, val_id: i64) -> MirInst:
    MirInst(kind: MirInstKind.Store(make_copy_op(ptr_id), make_copy_op(val_id)))

fn make_binop_inst(dest_id: i64, op: MirBinOp, left_id: i64, right_id: i64) -> MirInst:
    MirInst(kind: MirInstKind.BinOp(
        make_local(dest_id), op,
        make_copy_op(left_id), make_copy_op(right_id)
    ))

fn make_add_const_inst(dest_id: i64, src_id: i64) -> MirInst:
    # Represents  %dest = %src + 1  (induction variable increment)
    MirInst(kind: MirInstKind.BinOp(
        make_local(dest_id), MirBinOp.Add,
        make_copy_op(src_id), make_const_op("1")
    ))

fn make_call_inst(dest_id: i64) -> MirInst:
    MirInst(kind: MirInstKind.Call(
        Some(make_local(dest_id)),
        make_const_op("extern_fn"),
        []
    ))

fn make_jump_terminator() -> MirTerminator:
    MirTerminator.Goto(make_block_id(0))

# ============================================================================
# Fixture blocks
# ============================================================================

fn make_elementwise_block_add() -> MirBlock:
    """
    Simulates body of:  out[i] = a[i] + b[i]
    Instructions (in program order):
      %va  = Load(%pa)         # load a[i]
      %vb  = Load(%pb)         # load b[i]
      %vc  = Add(%va, %vb)     # data operation — NOT index inc (no Const operand)
      Store(%pout, %vc)        # store result
      %i1  = Add(%i, 1)        # index increment — Const operand
    """
    val insts = [
        make_load_inst(10, 1),                                       # %10 = Load(%1)
        make_load_inst(11, 2),                                       # %11 = Load(%2)
        make_binop_inst(12, MirBinOp.Add, 10, 11),                  # %12 = Add(%10,%11)
        make_store_inst(3, 12),                                      # Store(%3, %12)
        make_add_const_inst(5, 4)                                    # %5  = Add(%4, 1)
    ]
    MirBlock(id: make_block_id(1), label: nil, instructions: insts, terminator: make_jump_terminator())

fn make_elementwise_block_mul() -> MirBlock:
    """Simulates body of: out[i] = a[i] * b[i]"""
    val insts = [
        make_load_inst(10, 1),
        make_load_inst(11, 2),
        make_binop_inst(12, MirBinOp.Mul, 10, 11),
        make_store_inst(3, 12),
        make_add_const_inst(5, 4)
    ]
    MirBlock(id: make_block_id(2), label: nil, instructions: insts, terminator: make_jump_terminator())

fn make_elementwise_block_sub() -> MirBlock:
    """Simulates body of: out[i] = a[i] - b[i]"""
    val insts = [
        make_load_inst(10, 1),
        make_load_inst(11, 2),
        make_binop_inst(12, MirBinOp.Sub, 10, 11),
        make_store_inst(3, 12),
        make_add_const_inst(5, 4)
    ]
    MirBlock(id: make_block_id(3), label: nil, instructions: insts, terminator: make_jump_terminator())

fn make_saxpy_block() -> MirBlock:
    """
    Simulates body of: y[i] += alpha * x[i]  (saxpy — J4 T01)
    Two data BinOps: mul + add.  Both lack Const operands → both counted as data ops.
    This exceeds binop_count==1 threshold, so elementwise matcher should NOT match;
    however our conservative matcher counts any non-increment BinOp and returns Some
    when there are ≥1 data BinOps.  This is an intentional conservative positive.
    """
    val insts = [
        make_load_inst(10, 1),                                       # x[i]
        make_binop_inst(11, MirBinOp.Mul, 10, 20),                  # alpha * x[i]
        make_load_inst(12, 2),                                       # y[i]
        make_binop_inst(13, MirBinOp.Add, 12, 11),                  # y[i] + ...
        make_store_inst(3, 13),                                      # y[i] = ...
        make_add_const_inst(5, 4)
    ]
    MirBlock(id: make_block_id(4), label: nil, instructions: insts, terminator: make_jump_terminator())

fn make_reduction_sum_block() -> MirBlock:
    """
    Simulates body of: s = s + a[i]  (sum reduction — J4 T02)
    No store (accumulator is in a register), one Load, one Add (non-increment).
    """
    val insts = [
        make_load_inst(10, 1),                                       # a[i]
        make_binop_inst(11, MirBinOp.Add, 9, 10),                   # s = s + a[i]
        make_add_const_inst(5, 4)                                    # i = i + 1
    ]
    MirBlock(id: make_block_id(5), label: nil, instructions: insts, terminator: make_jump_terminator())

fn make_reduction_mul_block() -> MirBlock:
    """Simulates body of: p = p * a[i]  (product reduction)"""
    val insts = [
        make_load_inst(10, 1),
        make_binop_inst(11, MirBinOp.Mul, 9, 10),
        make_add_const_inst(5, 4)
    ]
    MirBlock(id: make_block_id(6), label: nil, instructions: insts, terminator: make_jump_terminator())

fn make_matrix_dot_block() -> MirBlock:
    """
    Simulates body of: acc = acc + a[i] * b[i]
    One mul, one add, one induction increment, no store.
    """
    val insts = [
        make_load_inst(10, 1),
        make_load_inst(11, 2),
        make_binop_inst(12, MirBinOp.Mul, 10, 11),
        make_binop_inst(13, MirBinOp.Add, 9, 12),
        make_add_const_inst(5, 4)
    ]
    MirBlock(id: make_block_id(7), label: nil, instructions: insts, terminator: make_jump_terminator())

fn make_block_with_call() -> MirBlock:
    """§8 failure: function call in body — must prevent vectorisation."""
    val insts = [
        make_load_inst(10, 1),
        make_call_inst(15),                                          # call — inhibits
        make_store_inst(3, 10),
        make_add_const_inst(5, 4)
    ]
    MirBlock(id: make_block_id(10), label: nil, instructions: insts, terminator: make_jump_terminator())

fn make_block_no_induction() -> MirBlock:
    """§8 failure: no induction variable (no Add-with-const found)."""
    val insts = [
        make_load_inst(10, 1),
        make_load_inst(11, 2),
        make_binop_inst(12, MirBinOp.Add, 10, 11)
        # no Store, no Add-const → no induction var AND no store
    ]
    MirBlock(id: make_block_id(11), label: nil, instructions: insts, terminator: make_jump_terminator())

fn make_block_no_loads() -> MirBlock:
    """§8 failure: no array loads (indirect load / pure scalar) → no elementwise match."""
    val insts = [
        make_binop_inst(12, MirBinOp.Add, 10, 11),
        make_store_inst(3, 12),
        make_add_const_inst(5, 4)
    ]
    MirBlock(id: make_block_id(12), label: nil, instructions: insts, terminator: make_jump_terminator())

fn make_reduction_with_store() -> MirBlock:
    """§8 failure for reduction: store present → not a pure reduction."""
    val insts = [
        make_load_inst(10, 1),
        make_binop_inst(11, MirBinOp.Add, 9, 10),
        make_store_inst(3, 11),                                      # inhibits reduction
        make_add_const_inst(5, 4)
    ]
    MirBlock(id: make_block_id(13), label: nil, instructions: insts, terminator: make_jump_terminator())

fn make_empty_module() -> MirModule:
    MirModule(
        name:      "test_module",
        functions: {},
        statics:   {},
        constants: {},
        types:     {}
    )

# ============================================================================
# Positive cases — elementwise matcher
# ============================================================================

describe "AutoVectorize elementwise pattern matcher — positive cases":
    it "recognises add elementwise loop (J4 T01-like saxpy)":
        val block = make_elementwise_block_add()
        val result = mir_pattern_match_elementwise_loop(block)
        expect(result.?).to_equal(true)

    it "recognises mul elementwise loop":
        val block = make_elementwise_block_mul()
        val result = mir_pattern_match_elementwise_loop(block)
        expect(result.?).to_equal(true)

    it "recognised sub elementwise loop":
        val block = make_elementwise_block_sub()
        val result = mir_pattern_match_elementwise_loop(block)
        expect(result.?).to_equal(true)

    it "recipe kind is Elementwise for add block":
        val block = make_elementwise_block_add()
        val result = mir_pattern_match_elementwise_loop(block)
        expect(result.?).to_equal(true)
        val recipe = result.unwrap()
        val is_elementwise = match recipe.kind:
            case Elementwise: true
            case _: false
        expect(is_elementwise).to_equal(true)

    it "recipe op_name contains add for add block":
        val block = make_elementwise_block_add()
        val result = mir_pattern_match_elementwise_loop(block)
        expect(result.?).to_equal(true)
        val recipe = result.unwrap()
        expect(recipe.op_name).to_contain("add")

# ============================================================================
# Positive cases — reduction matcher
# ============================================================================

describe "AutoVectorize reduction pattern matcher — positive cases":
    it "recognises sum reduction loop (J4 dot-product shape)":
        val block = make_reduction_sum_block()
        val result = mir_pattern_match_reduction(block, true)
        expect(result.?).to_equal(true)

    it "recognises product reduction loop":
        val block = make_reduction_mul_block()
        val result = mir_pattern_match_reduction(block, true)
        expect(result.?).to_equal(true)

    it "recipe kind is Reduction for sum block":
        val block = make_reduction_sum_block()
        val result = mir_pattern_match_reduction(block, true)
        expect(result.?).to_equal(true)
        val recipe = result.unwrap()
        val is_reduction = match recipe.kind:
            case Reduction: true
            case _: false
        expect(is_reduction).to_equal(true)

    it "recipe op_name contains add for sum block":
        val block = make_reduction_sum_block()
        val result = mir_pattern_match_reduction(block, true)
        expect(result.?).to_equal(true)
        val recipe = result.unwrap()
        expect(recipe.op_name).to_contain("add")

    it "recipe vector_width is positive for sum block":
        val block = make_reduction_sum_block()
        val result = mir_pattern_match_reduction(block, true)
        expect(result.?).to_equal(true)
        val recipe = result.unwrap()
        expect(recipe.vector_width > 0).to_equal(true)

describe "AutoVectorize matrix-kernel pattern matcher — positive cases":
    it "recognises a canonical dot-product inner loop with fast_math":
        val block = make_matrix_dot_block()
        val result = mir_pattern_match_matrix_kernel(block, true)
        expect(result.?).to_equal(true)

    it "matrix kernel recipe kind is MatrixKernel":
        val block = make_matrix_dot_block()
        val result = mir_pattern_match_matrix_kernel(block, true)
        expect(result.?).to_equal(true)
        val recipe = result.unwrap()
        val is_matrix = match recipe.kind:
            case MatrixKernel: true
            case _: false
        expect(is_matrix).to_equal(true)

# ============================================================================
# Negative cases — §8 failure modes
# ============================================================================

describe "AutoVectorize pattern matcher — §8 failure modes (must return nil)":
    it "function call in body inhibits elementwise match":
        # §8 failure: FFI/function call in loop body
        val block = make_block_with_call()
        val result = mir_pattern_match_elementwise_loop(block)
        expect(result.?).to_equal(false)

    it "function call in body inhibits reduction match":
        val block = make_block_with_call()
        val result = mir_pattern_match_reduction(block, true)
        expect(result.?).to_equal(false)

    it "no induction variable inhibits elementwise match":
        # §8 failure: loop structure not recognised (no counted induction)
        val block = make_block_no_induction()
        val result = mir_pattern_match_elementwise_loop(block)
        expect(result.?).to_equal(false)

    it "no array loads inhibits elementwise match":
        # §8 failure: indirect load / no contiguous stride-1 access
        val block = make_block_no_loads()
        val result = mir_pattern_match_elementwise_loop(block)
        expect(result.?).to_equal(false)

    it "store in loop body inhibits reduction match (not a pure accumulator)":
        # §8 failure: accumulator written to memory → not a register reduction
        val block = make_reduction_with_store()
        val result = mir_pattern_match_reduction(block, true)
        expect(result.?).to_equal(false)

# ============================================================================
# No-op / skeleton safety cases
# ============================================================================

describe "AutoVectorize run_auto_vectorize — skeleton no-op guarantee":
    it "returns module unchanged on empty module":
        val m = make_empty_module()
        val result = run_auto_vectorize(m)
        # Empty module: no functions, so no recipes found; module name is preserved
        expect(result.name).to_equal("test_module")

    it "module function count unchanged after pass":
        val m = make_empty_module()
        val before = m.functions.keys().len()
        val result = run_auto_vectorize(m)
        val after = result.functions.keys().len()
        expect(after).to_equal(before)

# ============================================================================
# W-recipe: VectorRecipe operand fields (L3 gap §1)
# ============================================================================

describe "AutoVectorize W-recipe — elementwise recipe fields":
    it "elementwise add recipe input_bases field exists (list, len >= 0)":
        val block = make_elementwise_block_add()
        val result = mir_pattern_match_elementwise_loop(block)
        expect(result.?).to_equal(true)
        val recipe = result.unwrap()
        val has_list = recipe.input_bases.len() >= 0
        expect(has_list).to_equal(true)

    it "elementwise recipe accumulator is nil":
        val block = make_elementwise_block_add()
        val result = mir_pattern_match_elementwise_loop(block)
        expect(result.?).to_equal(true)
        val recipe = result.unwrap()
        expect(recipe.accumulator.?).to_equal(false)

    it "elementwise recipe chunk_width matches vector_width":
        val block = make_elementwise_block_add()
        val result = mir_pattern_match_elementwise_loop(block)
        expect(result.?).to_equal(true)
        val recipe = result.unwrap()
        expect(recipe.chunk_width).to_equal(recipe.vector_width)

    it "elementwise recipe chunk_width is positive":
        val block = make_elementwise_block_add()
        val result = mir_pattern_match_elementwise_loop(block)
        expect(result.?).to_equal(true)
        val recipe = result.unwrap()
        expect(recipe.chunk_width > 0).to_equal(true)

    it "elementwise recipe index_locals tracks the induction variable":
        val block = make_elementwise_block_add()
        val result = mir_pattern_match_elementwise_loop(block)
        expect(result.?).to_equal(true)
        val recipe = result.unwrap()
        expect(recipe.index_locals.len()).to_equal(1)

describe "AutoVectorize W-recipe — reduction recipe fields":
    it "reduction sum recipe accumulator is Some":
        val block = make_reduction_sum_block()
        val result = mir_pattern_match_reduction(block, true)
        expect(result.?).to_equal(true)
        val recipe = result.unwrap()
        expect(recipe.accumulator.?).to_equal(true)

    it "reduction recipe output_base is nil":
        val block = make_reduction_sum_block()
        val result = mir_pattern_match_reduction(block, true)
        expect(result.?).to_equal(true)
        val recipe = result.unwrap()
        expect(recipe.output_base.?).to_equal(false)

    it "reduction recipe chunk_width is positive":
        val block = make_reduction_sum_block()
        val result = mir_pattern_match_reduction(block, true)
        expect(result.?).to_equal(true)
        val recipe = result.unwrap()
        expect(recipe.chunk_width > 0).to_equal(true)

    it "reduction recipe chunk_width matches vector_width":
        val block = make_reduction_sum_block()
        val result = mir_pattern_match_reduction(block, true)
        expect(result.?).to_equal(true)
        val recipe = result.unwrap()
        expect(recipe.chunk_width).to_equal(recipe.vector_width)

# ============================================================================
# W-scev: detect_bounds_from_block — LoopBounds extraction (L3 gap §2)
# ============================================================================

fn make_cmp_lt_inst(dest_id: i64, left_id: i64, right_id: i64) -> MirInst:
    MirInst(kind: MirInstKind.BinOp(
        make_local(dest_id), MirBinOp.Lt,
        make_copy_op(left_id), make_copy_op(right_id)
    ))

fn make_cmp_ne_inst(dest_id: i64, left_id: i64, right_id: i64) -> MirInst:
    MirInst(kind: MirInstKind.BinOp(
        make_local(dest_id), MirBinOp.Ne,
        make_copy_op(left_id), make_copy_op(right_id)
    ))

fn make_if_terminator(cond_id: i64, then_id: i64, else_id: i64) -> MirTerminator:
    MirTerminator.If(make_copy_op(cond_id), make_block_id(then_id), make_block_id(else_id))

fn make_bounds_block_for_n() -> MirBlock:
    """for i in 0..n  — %20 = %4 < %30, unit step %5 = %4 + 1"""
    val insts = [
        make_cmp_lt_inst(20, 4, 30),
        make_load_inst(10, 1),
        make_add_const_inst(5, 4)
    ]
    MirBlock(id: make_block_id(100), label: nil, instructions: insts,
        terminator: make_if_terminator(20, 100, 99))

fn make_bounds_block_for_arr_len() -> MirBlock:
    """for i in 0..arr.len — upper local = %31"""
    val insts = [
        make_cmp_lt_inst(20, 4, 31),
        make_load_inst(10, 1),
        make_add_const_inst(5, 4)
    ]
    MirBlock(id: make_block_id(101), label: nil, instructions: insts,
        terminator: make_if_terminator(20, 101, 99))

fn make_bounds_block_ne_cond() -> MirBlock:
    """while i != n  — Ne not Lt → nil"""
    val insts = [
        make_cmp_ne_inst(20, 4, 30),
        make_load_inst(10, 1),
        make_add_const_inst(5, 4)
    ]
    MirBlock(id: make_block_id(102), label: nil, instructions: insts,
        terminator: make_if_terminator(20, 102, 99))

fn make_bounds_block_no_increment() -> MirBlock:
    """Loop with no Add(induction, Const) increment → nil"""
    val insts = [
        make_cmp_lt_inst(20, 4, 30),
        make_load_inst(10, 1)
    ]
    MirBlock(id: make_block_id(103), label: nil, instructions: insts,
        terminator: make_if_terminator(20, 103, 99))

fn make_bounds_block_infinite() -> MirBlock:
    """Infinite loop — no BinOp(Lt) defining cond local %20 → nil"""
    val insts = [
        make_load_inst(10, 1),
        make_add_const_inst(5, 4)
    ]
    MirBlock(id: make_block_id(104), label: nil, instructions: insts,
        terminator: make_if_terminator(20, 104, 99))

describe "AutoVectorize W-scev — detect_bounds_from_block positive":
    it "for-i-in-0..n returns Some(LoopBounds)":
        val block = make_bounds_block_for_n()
        val result = detect_bounds_from_block(block, make_copy_op(20), make_block_id(99))
        expect(result.?).to_equal(true)

    it "for-i-in-0..n lower bound is 0":
        val result = detect_bounds_from_block(make_bounds_block_for_n(), make_copy_op(20), make_block_id(99))
        expect(result.?).to_equal(true)
        expect(result.unwrap().lower).to_equal(0)

    it "for-i-in-0..n step is 1":
        val result = detect_bounds_from_block(make_bounds_block_for_n(), make_copy_op(20), make_block_id(99))
        expect(result.?).to_equal(true)
        expect(result.unwrap().step).to_equal(1)

    it "for-i-in-0..n upper encodes local 30 as _l30":
        val result = detect_bounds_from_block(make_bounds_block_for_n(), make_copy_op(20), make_block_id(99))
        expect(result.?).to_equal(true)
        expect(result.unwrap().upper).to_equal("_l30")

    it "for-i-in-0..arr.len upper encodes local 31 as _l31":
        val result = detect_bounds_from_block(make_bounds_block_for_arr_len(), make_copy_op(20), make_block_id(99))
        expect(result.?).to_equal(true)
        expect(result.unwrap().upper).to_equal("_l31")

describe "AutoVectorize W-scev — detect_bounds_from_block negative":
    it "Ne condition (while i != n) returns nil":
        val result = detect_bounds_from_block(make_bounds_block_ne_cond(), make_copy_op(20), make_block_id(99))
        expect(result.?).to_equal(false)

    it "loop with no unit-step increment returns nil":
        val result = detect_bounds_from_block(make_bounds_block_no_increment(), make_copy_op(20), make_block_id(99))
        expect(result.?).to_equal(false)

    it "infinite loop (no cmp defining cond local) returns nil":
        val result = detect_bounds_from_block(make_bounds_block_infinite(), make_copy_op(20), make_block_id(99))
        expect(result.?).to_equal(false)

    it "Const cond operand (not a local) returns nil":
        val result = detect_bounds_from_block(make_bounds_block_for_n(), make_const_op("1"), make_block_id(99))
        expect(result.?).to_equal(false)

# ============================================================================
# W-fastmath: FP reduction gate (L3 gap §4)
# ============================================================================

describe "AutoVectorize W-fastmath — FP reduction gate":
    it "reduction matcher refuses f32 sum when has_fast_math=false":
        val block = make_reduction_sum_block()
        val result = mir_pattern_match_reduction(block, false)
        expect(result.?).to_equal(false)

    it "reduction matcher accepts f32 sum when has_fast_math=true":
        val block = make_reduction_sum_block()
        val result = mir_pattern_match_reduction(block, true)
        expect(result.?).to_equal(true)

    it "product reduction accepted with has_fast_math=true":
        val block = make_reduction_mul_block()
        val result = mir_pattern_match_reduction(block, true)
        expect(result.?).to_equal(true)

    it "product reduction refused with has_fast_math=false":
        val block = make_reduction_mul_block()
        val result = mir_pattern_match_reduction(block, false)
        expect(result.?).to_equal(false)

# ============================================================================
# W-cfg: alignment-check and peeling BBs (L3 gap §3)
# ============================================================================

fn make_test_loop_info() -> LoopInfo:
    LoopInfo(
        header_block:  make_block_id(0),
        body_blocks:   [make_block_id(1)],
        exit_block:    make_block_id(2),
        induction_var: make_local(4),
        start_value:   0,
        end_value:     100,
        step:          1
    )

fn make_test_vectorize_ctx() -> VectorizeContext:
    VectorizeContext(
        vector_width: 8,
        element_type: "f32",
        next_local:   200
    )

describe "AutoVectorize W-cfg — create_alignment_check_block":
    it "produces a block with label align_check":
        val li  = make_test_loop_info()
        val ctx = make_test_vectorize_ctx()
        val bb  = create_alignment_check_block(ctx, li)
        expect(bb.label.?).to_equal(true)
        expect(bb.label.unwrap()).to_equal("align_check")

    it "alignment-check terminator is If":
        val li  = make_test_loop_info()
        val ctx = make_test_vectorize_ctx()
        val bb  = create_alignment_check_block(ctx, li)
        val is_if = match bb.terminator:
            case If(cond, then_, else_): true
            case _: false
        expect(is_if).to_equal(true)

describe "AutoVectorize W-cfg — create_peeling_block":
    it "produces a block with label peel_loop":
        val li  = make_test_loop_info()
        val ctx = make_test_vectorize_ctx()
        val bb  = create_peeling_block(ctx, li)
        expect(bb.label.?).to_equal(true)
        expect(bb.label.unwrap()).to_equal("peel_loop")

# ============================================================================
# N1 Wave — rewrite_elementwise_add tests
# ============================================================================
#
# MirFunction construction helpers.
# In interpreter mode assertions are not executed; these tests verify that
# the rewriter API compiles and describe/it blocks are reachable.
# Structural invariants checked: block count changes, label presence, recipe
# refuse conditions.

fn make_driver_manifest_attr_default() -> DriverManifestAttr:
    DriverManifestAttr(
        kind:       DriverManifestAttrKind.Driver,
        driver_class: 0,
        vendor:     0,
        device_ids: [],
        version:    "",
        abi:        ""
    )

fn make_test_mir_function(blocks: [MirBlock], has_fast_math: bool) -> MirFunction:
    """Minimal MirFunction for rewriter tests."""
    val sig = MirSignature(
        params:       [],
        return_type:  MirType(kind: MirTypeKind.Unit),
        is_variadic:  false
    )
    MirFunction(
        symbol:                 SymbolId(id: 1),
        name:                   "test_fn",
        signature:              sig,
        locals:                 [],
        blocks:                 blocks,
        entry_block:            make_block_id(0),
        span:                   Span(start: 0, end: 0, line: 1, col: 1),
        generic_params:         [],
        is_generic_template:    false,
        specialization_of:      nil,
        type_bindings:          {},
        layout_phase:           nil,
        is_kernel:              false,
        is_export_c:            false,
        export_name:            "",
        has_driver_manifest_attr: false,
        driver_manifest_attr:   make_driver_manifest_attr_default(),
        has_vhdl_metadata:      false,
        vhdl_metadata:          vhdl_hardware_metadata_default(),
        has_fast_math:          has_fast_math
    )

fn make_elementwise_add_recipe_for_rewrite() -> VectorRecipe:
    """Recipe for: for i in 0..16: out[i] = a[i] + b[i]  (trip_count=16, chunk_width=4)"""
    VectorRecipe(
        kind:          VectorRecipeKind.Elementwise,
        header_block:  make_block_id(1),
        induction_var: make_local(4),
        trip_count:    16,
        element_type:  "i32",
        vector_width:  4,
        op_name:       "add_elementwise",
        note:          "test recipe",
        input_bases:   [make_local(10), make_local(11)],
        output_base:   Some(make_local(12)),
        accumulator:   nil,
        chunk_width:   4,
        index_locals:  [make_local(4)],
        store_value:   nil
    )

fn make_elementwise_add_recipe_dynamic_n() -> VectorRecipe:
    """Recipe for: for i in 0..n: out[i] = a[i] + b[i]  (trip_count=-1, dynamic)"""
    VectorRecipe(
        kind:          VectorRecipeKind.Elementwise,
        header_block:  make_block_id(1),
        induction_var: make_local(4),
        trip_count:    -1,
        element_type:  "i32",
        vector_width:  4,
        op_name:       "add_elementwise",
        note:          "test recipe dynamic",
        input_bases:   [make_local(10), make_local(11)],
        output_base:   Some(make_local(12)),
        accumulator:   nil,
        chunk_width:   4,
        index_locals:  [make_local(4)],
        store_value:   nil
    )

