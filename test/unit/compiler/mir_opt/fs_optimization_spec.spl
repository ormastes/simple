# Maps to: AC-4, AC-5
# Run: bin/simple test test/unit/compiler/mir_opt/fs_optimization_spec.spl
# @cover src/compiler/60.mir_opt/optimization_passes.spl 60%
# @cover src/compiler/60.mir_opt/optimizer_manifest.spl 40%
# @cover src/compiler/60.mir_opt/mir_opt/mod.spl 40%

"""
FS Optimization Pass Specification

Validates the 3 new MIR optimization passes for FS-aware transforms:
  - io_write_coalesce: merges adjacent writes
  - io_readahead_hoist: lifts reads before loops
  - io_batch_open_close: batches syscalls
  - PassScope.FsDriver recognized in manifest (D-5)
"""

use std.spipe.*
use std.compiler.mir_opt.optimization_passes.{optimize_write_coalesce, optimize_syscall_batch, optimize_read_ahead_hoist, OptimizationStats}
use std.compiler.mir_opt.{PassScope, PassKind}
use std.compiler.mir_opt.optimizer_manifest.{DynamicPassDescriptor, DynamicPassRegistry}
use std.compiler.mir_opt.{run_named_pass, run_pass_on_module, MirFunction, MirModule}

# ============================================================================
# Write Coalesce Pass (AC-4)
# ============================================================================

describe "MIR FS Passes — write coalesce":
    it "AC-4: run_named_pass accepts write_coalesce pass name":
        val stats = OptimizationStats.create()
        val func = MirFunction(name: "wc_fn", blocks: [], locals: [])
        val result = optimize_write_coalesce(func, stats)
        val n = result.name
        expect(n).to_equal("wc_fn")

    it "AC-4: write coalesce stat counter exists after pass":
        val stats = OptimizationStats.create()
        val func = MirFunction(name: "wc_fn2", blocks: [], locals: [])
        val result = optimize_write_coalesce(func, stats)
        val count = stats.write_coalesce_count
        expect(count).to_be_greater_than(-1)

# ============================================================================
# Syscall Batch Pass (AC-4)
# ============================================================================

describe "MIR FS Passes — syscall batch":
    it "AC-4: optimize_syscall_batch accepts MirFunction":
        val stats = OptimizationStats.create()
        val func = MirFunction(name: "sb_fn", blocks: [], locals: [])
        val result = optimize_syscall_batch(func, stats)
        val n = result.name
        expect(n).to_equal("sb_fn")

    it "AC-4: syscall batch stat counter exists after pass":
        val stats = OptimizationStats.create()
        val func = MirFunction(name: "sb_fn2", blocks: [], locals: [])
        val result = optimize_syscall_batch(func, stats)
        val count = stats.syscall_batch_count
        expect(count).to_be_greater_than(-1)

# ============================================================================
# Read-Ahead Hoist Pass (AC-4)
# ============================================================================

describe "MIR FS Passes — read-ahead hoist":
    it "AC-4: optimize_read_ahead_hoist accepts MirFunction":
        val stats = OptimizationStats.create()
        val func = MirFunction(name: "rah_fn", blocks: [], locals: [])
        val result = optimize_read_ahead_hoist(func, stats)
        val n = result.name
        expect(n).to_equal("rah_fn")

    it "AC-4: read-ahead hoist stat counter exists after pass":
        val stats = OptimizationStats.create()
        val func = MirFunction(name: "rah_fn2", blocks: [], locals: [])
        val result = optimize_read_ahead_hoist(func, stats)
        val count = stats.read_ahead_hoist_count
        expect(count).to_be_greater_than(-1)

# ============================================================================
# PassScope.FsDriver in Manifest (AC-5)
# ============================================================================

describe "Optimizer Manifest — PassScope.FsDriver":
    it "AC-5: PassScope.FsDriver variant exists":
        val scope = PassScope.FsDriver
        val is_fs = scope == PassScope.FsDriver
        expect(is_fs).to_equal(true)

    it "AC-5: DynamicPassRegistry accepts FsDriver-scoped pass":
        val registry = DynamicPassRegistry.new()
        val desc = DynamicPassDescriptor(name: "test_fs_pass", scope: PassScope.FsDriver, capability_requires: [])
        val r = registry.register(desc)
        val ok = r.is_ok()
        expect(ok).to_equal(true)

    it "AC-5: PassKind includes SyscallBatch variant":
        val pk = PassKind.SyscallBatch
        val is_batch = pk == PassKind.SyscallBatch
        expect(is_batch).to_equal(true)

    it "AC-5: PassKind includes WriteCoalesce variant":
        val pk = PassKind.WriteCoalesce
        val is_coalesce = pk == PassKind.WriteCoalesce
        expect(is_coalesce).to_equal(true)

    it "AC-5: PassKind includes ReadAheadHoist variant":
        val pk = PassKind.ReadAheadHoist
        val is_hoist = pk == PassKind.ReadAheadHoist
        expect(is_hoist).to_equal(true)
