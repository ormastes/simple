use compiler.mir_opt.mir_opt.mod.{
    mir_pass_descriptor_for_name,
    mir_pass_provider_name,
    mir_pass_uses_pipeline_provider
}
use compiler.mir_opt.pattern.rule_engine.{OptimizerRuleLookupKind}

describe "MIR optimization pass descriptors":
    it "keeps old aliases while exposing stable pass descriptors":
        val dce = mir_pass_descriptor_for_name("dce")
        expect(dce.?).to_equal(true)
        expect(dce.unwrap().stable_name).to_equal("dead_code_elimination")
        expect(mir_pass_provider_name("dce")).to_equal("simple.opt.mir.dead_code_elimination")
        expect(mir_pass_uses_pipeline_provider("dce")).to_equal(true)

    it "registers strength reduction through its Simple Optimization Plugin provider":
        val strength = mir_pass_descriptor_for_name("strength_reduction")
        expect(strength.?).to_equal(true)
        val provider = strength.unwrap().provider
        expect(provider.name).to_equal("simple.opt.math.strength_reduce")
        expect(provider.lookup_kind).to_equal(OptimizerRuleLookupKind.PipelinePass)

    it "maps legacy vectorization name to auto_vectorize":
        val vector = mir_pass_descriptor_for_name("vectorization")
        expect(vector.?).to_equal(true)
        expect(vector.unwrap().stable_name).to_equal("auto_vectorize")

    it "returns nil for unknown passes":
        expect(mir_pass_descriptor_for_name("missing_pass").?).to_equal(false)
