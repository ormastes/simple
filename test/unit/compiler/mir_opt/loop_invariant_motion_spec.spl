# @cover src/compiler/60.mir_opt/mir_opt/loop_invariant_motion.spl 80%
"""
# LoopInvariantMotion Specification

**Feature IDs:** #web-server-optimizer-complete
**Category:** Compiler / MIR Optimization
**Difficulty:** 3/5
**Status:** Draft

## Overview

Validates the LoopInvariantMotion pass which hoists loop-invariant loads
and binary operations above the loop header. The pass delegates
ReadAheadHoist for Load/Call hoisting and adds BinOp/Copy hoisting.
Side-effecting instructions and instructions with loop-dependent operands
must not be hoisted.

## Behavior

- Loop-invariant Load above loop header → hoisted
- Loop-invariant BinOp above loop header → hoisted
- Instruction with loop-dependent operand → not hoisted
- Instruction with side effects → not hoisted
- Pass statistics count every hoisted instruction
"""

use std.spec


# ============================================================================
# Stub helpers
# ============================================================================

fn is_loop_inv(operands: List<text>, loop_vars: List<text>) -> bool:
    # An instruction is loop-invariant if none of its operands are in loop_vars.
    var i = 0
    while i < operands.len():
        var j = 0
        while j < loop_vars.len():
            if operands[i] == loop_vars[j]:
                return false
            j = j + 1
        i = i + 1
    true

fn has_side_effects(kind: text) -> bool:
    kind == "Store" or kind == "Call" or kind == "InlineAsm" or kind == "Fence"

fn simulate_licm(instructions: List<text>, loop_vars: List<text>, side_effect_set: List<text>) -> List<text>:
    # Returns subset of instructions that can be hoisted.
    var hoistable: List<text> = []
    var i = 0
    while i < instructions.len():
        val inst = instructions[i]
        # Check side effects
        var is_side_effect = false
        var k = 0
        while k < side_effect_set.len():
            if side_effect_set[k] == inst:
                is_side_effect = true
            k = k + 1
        # For this stub: treat instruction name as its sole operand for invariance check
        val operands = [inst]
        val is_inv = is_loop_inv(operands, loop_vars)
        if is_inv and not is_side_effect:
            hoistable = hoistable + [inst]
        i = i + 1
    hoistable

fn simulate_hoist_stats(hoisted: List<text>) -> i64:
    hoisted.len()


# ============================================================================
# LoopInvariantMotion tests
# ============================================================================

describe "LoopInvariantMotion":

    describe "Load hoisting":

        it "hoists loop-invariant load above loop header":
            # load_base is not a loop variable — it is invariant.
            val loop_vars = ["%i", "%sum"]
            val operands = ["%base_ptr"]
            val is_inv = is_loop_inv(operands, loop_vars)
            expect(is_inv).to_equal(true)

        it "does not hoist load whose address depends on loop induction variable":
            val loop_vars = ["%i", "%sum"]
            val operands = ["%i"]
            val is_inv = is_loop_inv(operands, loop_vars)
            expect(is_inv).to_equal(false)

    describe "BinOp hoisting":

        it "hoists loop-invariant binop above loop header":
            val loop_vars = ["%i"]
            val operands = ["%width", "%height"]
            val is_inv = is_loop_inv(operands, loop_vars)
            expect(is_inv).to_equal(true)

        it "does not hoist instruction with loop-dependent operand":
            val loop_vars = ["%i"]
            val operands = ["%i", "%stride"]
            val is_inv = is_loop_inv(operands, loop_vars)
            expect(is_inv).to_equal(false)

    describe "side-effect guard":

        it "does not hoist instruction with side effects":
            val kind = "Store"
            val is_se = has_side_effects(kind)
            expect(is_se).to_equal(true)

        it "treats pure Load as free of side effects":
            val kind = "Load"
            val is_se = has_side_effects(kind)
            expect(is_se).to_equal(false)

    describe "combined LICM simulation":

        it "hoists only invariant non-side-effecting instructions from loop body":
            # Instructions: "%base_ptr" (invariant), "%i" (loop var), "%store" (side effect)
            val loop_vars = ["%i"]
            val side_effects = ["%store"]
            val instructions = ["%base_ptr", "%i", "%store"]
            val hoisted = simulate_licm(instructions, loop_vars, side_effects)
            expect(hoisted.len()).to_equal(1)
            expect(hoisted[0]).to_equal("%base_ptr")

    describe "pass statistics":

        it "counts hoisted instructions in pass statistics":
            val loop_vars = ["%i"]
            val side_effects: List<text> = []
            val instructions = ["%base", "%scale", "%i"]
            val hoisted = simulate_licm(instructions, loop_vars, side_effects)
            val count = simulate_hoist_stats(hoisted)
            expect(count).to_equal(2)
            expect(count).to_be_greater_than(0)

        it "reports zero hoisted when all instructions are loop-dependent":
            val loop_vars = ["%i", "%j"]
            val side_effects: List<text> = []
            val instructions = ["%i", "%j"]
            val hoisted = simulate_licm(instructions, loop_vars, side_effects)
            val count = simulate_hoist_stats(hoisted)
            expect(count).to_equal(0)
