use std.spec

extern fn rt_file_read_text(path: text) -> text

fn runtime_init_text() -> text:
    rt_file_read_text("src/compiler/99.loader/runtime/__init__.spl")

fn loader_alias_init_text() -> text:
    rt_file_read_text("src/compiler/99.loader/loader/__init__.spl")

fn root_loader_init_text() -> text:
    rt_file_read_text("src/compiler/99.loader/__init__.spl")

describe "loader runtime compatibility surfaces":
    it "loader alias package is a thin alias to the curated runtime package":
        val alias_text = loader_alias_init_text()
        expect (alias_text).contains("export use compiler.loader.runtime.*")
        expect alias_text.contains("export ModuleLoader") == false
        expect alias_text.contains("export native_mmap_file") == false

    it "runtime facade keeps the curated export list and avoids duplicate jit-context instantiation exports":
        val runtime_text = runtime_init_text()
        expect (runtime_text).contains("export JitCompilationContext")
        expect (runtime_text).contains("export InstantiationRecord")
        expect runtime_text.contains("# Re-exported from jit_context.spl\nexport JitCompilationContext\nexport InstantiationRecord") == false

    it "root compatibility facade still documents compiler.loader.runtime as the preferred public surface":
        val root_text = root_loader_init_text()
        expect (root_text).contains("compiler.loader.runtime")
        expect (root_text).contains("moduleloader_load")