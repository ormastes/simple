use compiler.loader.compiler_ffi.*

describe "Compiler Ffi":
    it "creates a compiler context":
        val ctx = CompilerContext.create()
        expect ctx.alive == true

    it "builds primitive and named type info":
        expect make_int_type(64, true).type_name == "i64"
        expect make_float_type(32).type_name == "f32"
        expect make_bool_type().type_name == "bool"
        expect make_string_type().type_name == "string"
        expect make_named_type("Widget").type_name == "Widget"

    it "formats type arguments and byte lengths":
        val args = [make_named_type("Int"), make_named_type("String")]
        expect type_args_is_empty(args) == false
        expect type_args_is_empty([]) == true
        expect type_to_string(args[0]) == "Int"
        expect code_bytes_len([1, 2, 3]) == 3
        expect bytes_len([4, 5]) == 2