"""
# Module Loader

Verifies module loading, JIT symbol resolution, and cache cleanup behavior.
"""

use compiler.loader.module_loader.*
use compiler.loader.jit_instantiator.{PossibleInstantiation, LoadedMetadata}
use compiler.loader.compiler_ffi.{make_named_type}

const EXISTING_MODULE_PATH = "test/unit/compiler/loader/module_loader_spec.spl"
const SECOND_MODULE_PATH = "test/unit/compiler/parser/parser_await_spawn_spec.spl"

describe "Module Loader":
    """Focused module loader behavior checks."""

    it "creates default configuration":
        val config = ModuleLoaderConfig.default()
        expect(config.enable_jit).to_equal(true)
        expect(config.enable_cache).to_equal(true)
        expect(config.max_cache_size).to_equal(100)
        expect(config.hot_reload).to_equal(false)

    it "loads an existing path and tracks it as loaded":
        var loader = ModuleLoader.with_defaults()
        val result = loader.load(EXISTING_MODULE_PATH)

        match result:
            case LoadResult.Success(module):
                expect(module.path).to_equal(EXISTING_MODULE_PATH)
            case _:
                fail("expected load success")

        expect(loader.is_loaded(EXISTING_MODULE_PATH)).to_equal(true)
        expect(loader.loaded_modules().len()).to_equal(1)
        expect(loader.stats().module_count).to_equal(1)

    it "loads a module with a symbol and resolves it from globals":
        var loader = ModuleLoader.with_defaults()
        val loaded = loader.load(EXISTING_MODULE_PATH)

        match loaded:
            case LoadResult.Success(module):
                expect(module.path).to_equal(EXISTING_MODULE_PATH)
            case _:
                fail("expected load success")

        val symbol = LoadedSymbol(
            name: "module_exported_fn",
            address: 4096,
            size: 16,
            ty: SymbolType.Function,
            is_jit: false,
            file_offset: 8
        )
        loader.global_symbols["module_exported_fn"] = (EXISTING_MODULE_PATH, symbol)

        val resolved = loader.resolve_symbol("module_exported_fn")
        match resolved:
            case SymbolResult.Found(found, code):
                expect(found.name).to_equal("module_exported_fn")
                expect(found.address).to_equal(4096)
                expect(found.size).to_equal(16)
                expect(found.ty).to_equal(SymbolType.Function)
                expect(found.is_jit).to_equal(false)
                expect(found.file_offset).to_equal(8)
                expect(code.len()).to_equal(0)
            case _:
                fail("expected loaded module symbol")

        expect(loader.stats().symbol_count).to_equal(1)

    it "loads multiple existing paths and reports module count":
        var loader = ModuleLoader.with_defaults()
        val first = loader.load(EXISTING_MODULE_PATH)
        val second = loader.load(SECOND_MODULE_PATH)

        match first:
            case LoadResult.Success(module):
                expect(module.path).to_equal(EXISTING_MODULE_PATH)
            case _:
                fail("expected first module load success")

        match second:
            case LoadResult.Success(module):
                expect(module.path).to_equal(SECOND_MODULE_PATH)
            case _:
                fail("expected second module load success")

        expect(loader.is_loaded(EXISTING_MODULE_PATH)).to_equal(true)
        expect(loader.is_loaded(SECOND_MODULE_PATH)).to_equal(true)
        expect(loader.loaded_modules().len()).to_equal(2)
        expect(loader.stats().module_count).to_equal(2)

    it "loads modules and reports resolved symbol count":
        var loader = ModuleLoader.with_defaults()
        _ = loader.load(EXISTING_MODULE_PATH)
        _ = loader.load(SECOND_MODULE_PATH)
        val first_entry = PossibleInstantiation(
            template_name: "Vec",
            type_args: "i64",
            mangled_name: "vec_runtime_i64"
        )
        val second_entry = PossibleInstantiation(
            template_name: "Map",
            type_args: "text_i64",
            mangled_name: "map_runtime_text_i64"
        )
        loader.jit.set_metadata_for_test(EXISTING_MODULE_PATH, LoadedMetadata(possible: [first_entry], instantiations: []))
        loader.jit.set_metadata_for_test(SECOND_MODULE_PATH, LoadedMetadata(possible: [second_entry], instantiations: []))

        match loader.resolve_symbol("vec_runtime_i64"):
            case SymbolResult.JitCompiled(symbol, _):
                expect(symbol.name).to_equal("vec_runtime_i64")
            case _:
                fail("expected first JIT symbol")

        match loader.resolve_symbol("map_runtime_text_i64"):
            case SymbolResult.JitCompiled(symbol, _):
                expect(symbol.name).to_equal("map_runtime_text_i64")
            case _:
                fail("expected second JIT symbol")

        expect(loader.global_symbols.has("vec_runtime_i64")).to_equal(true)
        expect(loader.global_symbols.has("map_runtime_text_i64")).to_equal(true)
        expect(loader.stats().symbol_count).to_equal(2)

    it "returns an error when the module path does not exist":
        var loader = ModuleLoader.with_defaults()
        val result = loader.load("test/unit/compiler/loader/does_not_exist.spl")

        match result:
            case LoadResult.Error(message):
                expect(message).to_contain("module not found")
            case _:
                fail("expected load error")

    it "resolves JIT-backed symbols through the public loader API":
        var loader = ModuleLoader.with_defaults()
        val entry = PossibleInstantiation(
            template_name: "Vec",
            type_args: "i64",
            mangled_name: "vec_runtime_i64"
        )
        loader.jit.set_metadata_for_test(EXISTING_MODULE_PATH, LoadedMetadata(possible: [entry], instantiations: []))

        val result = loader.resolve_symbol("vec_runtime_i64")
        match result:
            case SymbolResult.JitCompiled(symbol, code):
                expect(symbol.name).to_equal("vec_runtime_i64")
                expect(symbol.is_jit).to_equal(true)
                expect(code.len()).to_be_greater_than(0)
            case _:
                fail("expected JIT compiled symbol")

        expect(loader.global_symbols.has("vec_runtime_i64")).to_equal(true)
        val cached = loader.resolve_symbol("vec_runtime_i64")
        match cached:
            case SymbolResult.Found(symbol, code):
                expect(symbol.name).to_equal("vec_runtime_i64")
                expect(symbol.is_jit).to_equal(true)
                expect(code.len()).to_equal(0)
            case _:
                fail("expected global symbol cache hit")

        expect(loader.jit.stats().compile_count).to_equal(1)
        expect(loader.jit.stats().cached_count).to_equal(1)
        expect(loader.stats().symbol_count).to_equal(1)

    it "mangles explicit generic type arguments":
        var loader = ModuleLoader.with_defaults()
        expect(loader.config.enable_jit).to_equal(true)
        val result = loader.resolve_generic("Vec", [make_named_type("Int"), make_named_type("String")])

        match result:
            case SymbolResult.NotFound(name):
                expect(name).to_equal("Vec$Int_String")
            case _:
                fail("expected unresolved mangled generic symbol")

        expect(loader.global_symbols.has("Vec$Int_String")).to_equal(false)
        expect(loader.jit.stats().compile_count).to_equal(0)
        expect(loader.jit.stats().cached_count).to_equal(0)
        expect(loader.stats().symbol_count).to_equal(0)

    it "resolves Vec i64 through the generic loader API":
        var loader = ModuleLoader.with_defaults()
        val entry = PossibleInstantiation(
            template_name: "Vec",
            type_args: "i64",
            mangled_name: "Vec$i64"
        )
        loader.jit.set_metadata_for_test(EXISTING_MODULE_PATH, LoadedMetadata(possible: [entry], instantiations: []))

        val result = loader.resolve_generic("Vec", [make_named_type("i64")])
        match result:
            case SymbolResult.JitCompiled(symbol, code):
                expect(symbol.name).to_equal("Vec$i64")
                expect(symbol.is_jit).to_equal(true)
                expect(code.len()).to_be_greater_than(0)
            case _:
                fail("expected Vec<i64> JIT resolution")

        expect(loader.global_symbols.has("Vec$i64")).to_equal(true)
        expect(loader.jit.stats().compile_count).to_equal(1)

    it "unloads modules and drops their JIT-owned symbols":
        var loader = ModuleLoader.with_defaults()
        val entry = PossibleInstantiation(
            template_name: "Hot",
            type_args: "reload",
            mangled_name: "hot_reload_fn"
        )
        loader.jit.set_metadata_for_test(EXISTING_MODULE_PATH, LoadedMetadata(possible: [entry], instantiations: []))
        _ = loader.load(EXISTING_MODULE_PATH)
        _ = loader.resolve_symbol("hot_reload_fn")

        moduleloader_unload(loader, EXISTING_MODULE_PATH)

        expect(loader.is_loaded(EXISTING_MODULE_PATH)).to_equal(false)
        match loader.resolve_symbol("hot_reload_fn"):
            case SymbolResult.NotFound(name):
                expect(name).to_equal("hot_reload_fn")
            case _:
                fail("expected JIT symbol to be removed on unload")
