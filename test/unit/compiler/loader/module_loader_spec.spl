use compiler.loader.module_loader.*
use compiler.loader.jit_instantiator.{PossibleInstantiation, LoadedMetadata}
use compiler.loader.compiler_ffi.{make_named_type}

const EXISTING_MODULE_PATH = "test/unit/compiler/loader/module_loader_spec.spl"

describe "Module Loader":
    it "creates default configuration":
        val config = ModuleLoaderConfig.default()
        expect(config.enable_jit).to_equal(true)
        expect(config.enable_cache).to_equal(true)
        expect(config.max_cache_size).to_equal(100)
        expect(config.hot_reload).to_equal(false)

    it "loads an existing path and tracks it as loaded":
        var loader = ModuleLoader.with_defaults()
        val result = loader.load(EXISTING_MODULE_PATH)

        match result:
            case LoadResult.Success(module):
                expect(module.path).to_equal(EXISTING_MODULE_PATH)
            case _:
                fail("expected load success")

        expect(loader.is_loaded(EXISTING_MODULE_PATH)).to_equal(true)
        expect(loader.loaded_modules().len()).to_equal(1)
        expect(loader.stats().module_count).to_equal(1)

    it "returns an error when the module path does not exist":
        var loader = ModuleLoader.with_defaults()
        val result = loader.load("test/unit/compiler/loader/does_not_exist.spl")

        match result:
            case LoadResult.Error(message):
                expect(message).to_contain("module not found")
            case _:
                fail("expected load error")

    it "resolves JIT-backed symbols through the public loader API":
        var loader = ModuleLoader.with_defaults()
        val entry = PossibleInstantiation(
            template_name: "Vec",
            type_args: "i64",
            mangled_name: "vec_runtime_i64"
        )
        loader.jit.set_metadata_for_test(EXISTING_MODULE_PATH, LoadedMetadata(possible: [entry], instantiations: []))

        val result = loader.resolve_symbol("vec_runtime_i64")
        match result:
            case SymbolResult.JitCompiled(symbol, code):
                expect(symbol.name).to_equal("vec_runtime_i64")
                expect(symbol.is_jit).to_equal(true)
                expect(code.len()).to_be_greater_than(0)
            case _:
                fail("expected JIT compiled symbol")

        expect(loader.stats().symbol_count).to_equal(1)

    it "mangles explicit generic type arguments":
        var loader = ModuleLoader.with_defaults()
        val result = loader.resolve_generic("Vec", [make_named_type("Int"), make_named_type("String")])

        match result:
            case SymbolResult.NotFound(name):
                expect(name).to_equal("Vec$Int_String")
            case _:
                fail("expected unresolved mangled generic symbol")

    it "unloads modules and drops their JIT-owned symbols":
        var loader = ModuleLoader.with_defaults()
        val entry = PossibleInstantiation(
            template_name: "Hot",
            type_args: "reload",
            mangled_name: "hot_reload_fn"
        )
        loader.jit.set_metadata_for_test(EXISTING_MODULE_PATH, LoadedMetadata(possible: [entry], instantiations: []))
        _ = loader.load(EXISTING_MODULE_PATH)
        _ = loader.resolve_symbol("hot_reload_fn")

        moduleloader_unload(loader, EXISTING_MODULE_PATH)

        expect(loader.is_loaded(EXISTING_MODULE_PATH)).to_equal(false)
        match loader.resolve_symbol("hot_reload_fn"):
            case SymbolResult.NotFound(name):
                expect(name).to_equal("hot_reload_fn")
            case _:
                fail("expected JIT symbol to be removed on unload")
