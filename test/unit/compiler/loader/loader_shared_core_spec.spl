# Loader Shared-Core Refactor Invariants — AC-10
#
# 20 tests covering shared-core invariants: unload policy, metadata priority,
# JIT state lifecycle, global ownership, and deterministic rebuild properties.
#
# **Feature IDs:** #AC-10-001 through #AC-10-020
# **Category:** Compiler / Loader
# **Design:** doc/05_design/graphics_backend_acceleration.md

use std.spec
use std.spec.{expect}

# ============================================================================
# UnloadPolicy — tracks metadata vs heuristic removal counts
# ============================================================================

class UnloadPolicy:
    path: text
    metadata_count: i32
    heuristic_count: i32
    total_removed: i32
    used_metadata: bool
    used_heuristic: bool

    static fn create(path: text) -> UnloadPolicy:
        UnloadPolicy(
            path: path,
            metadata_count: 0,
            heuristic_count: 0,
            total_removed: 0,
            used_metadata: false,
            used_heuristic: false
        )

    fn with_metadata(count: i32) -> UnloadPolicy:
        UnloadPolicy(
            path: self.path,
            metadata_count: count,
            heuristic_count: self.heuristic_count,
            total_removed: self.total_removed + count,
            used_metadata: true,
            used_heuristic: self.used_heuristic
        )

    fn with_heuristic(count: i32) -> UnloadPolicy:
        UnloadPolicy(
            path: self.path,
            metadata_count: self.metadata_count,
            heuristic_count: count,
            total_removed: self.total_removed + count,
            used_metadata: self.used_metadata,
            used_heuristic: true
        )

    fn is_noop() -> bool:
        self.total_removed == 0

    fn metadata_beats_heuristic() -> bool:
        self.metadata_count > 0

# ============================================================================
# InvariantCheck — encodes invariant results
# ============================================================================

class InvariantCheck:
    name: text
    passed: bool

    static fn unknown_path_noop(removed: i32) -> InvariantCheck:
        InvariantCheck(name: "unknown_path_noop", passed: removed == 0)

    static fn metadata_cleanup(meta: i32, removed: i32) -> InvariantCheck:
        InvariantCheck(name: "metadata_cleanup", passed: removed >= meta)

    static fn metadata_priority(has_meta: bool, used_heur: bool) -> InvariantCheck:
        val ok = if has_meta:
            used_heur == false
        else:
            true
        InvariantCheck(name: "metadata_priority", passed: ok)

    static fn reload_resolvable(pre: i32, post: i32) -> InvariantCheck:
        InvariantCheck(name: "reload_resolvable", passed: post >= pre)

    static fn deterministic_rebuild(before: i32, removed: i32, after: i32) -> InvariantCheck:
        InvariantCheck(name: "deterministic_rebuild", passed: after == before - removed)

# ============================================================================
# MetadataEntry — symbol-to-module mapping
# ============================================================================

class MetadataEntry:
    sym_name: text
    module_path: text

    static fn create(sym: text, path: text) -> MetadataEntry:
        MetadataEntry(sym_name: sym, module_path: path)

    fn belongs_to(path: text) -> bool:
        self.module_path == path

# ============================================================================
# GlobalOwnership — global symbol owner tracking
# ============================================================================

class GlobalOwnership:
    sym_name: text
    owner: text

    static fn create(sym: text, owner: text) -> GlobalOwnership:
        GlobalOwnership(sym_name: sym, owner: owner)

    fn is_owned_by(o: text) -> bool:
        self.owner == o

# ============================================================================
# JitState — JIT symbol lifecycle after unload/reload
# ============================================================================

class JitState:
    sym_name: text
    survived: bool
    reloaded: bool

    static fn tracked(name: text) -> JitState:
        JitState(sym_name: name, survived: false, reloaded: false)

    fn after_unload(s: bool) -> JitState:
        JitState(sym_name: self.sym_name, survived: s, reloaded: self.reloaded)

    fn after_reload(r: bool) -> JitState:
        JitState(sym_name: self.sym_name, survived: self.survived, reloaded: r)

    fn is_resolvable() -> bool:
        return self.reloaded

# ============================================================================
# ScenarioResult — pass/fail wrapper for named scenarios
# ============================================================================

class ScenarioResult:
    scenario: text
    passed: bool
    reason: text

    static fn pass_it(name: text, reason: text) -> ScenarioResult:
        ScenarioResult(scenario: name, passed: true, reason: reason)

    static fn fail_it(name: text, reason: text) -> ScenarioResult:
        ScenarioResult(scenario: name, passed: false, reason: reason)

describe "Loader Shared-Core Refactor Invariants — AC-10":
    context "UnloadPolicy":
        it "empty policy is noop":
            val p = UnloadPolicy.create("foo")
            assert_true(p.is_noop())

        it "policy with metadata not noop":
            val p = UnloadPolicy.create("foo").with_metadata(3)
            assert_false(p.is_noop())

        it "metadata beats heuristic":
            val p = UnloadPolicy.create("foo").with_metadata(2).with_heuristic(5)
            assert_true(p.metadata_beats_heuristic())

        it "heuristic only has no metadata priority":
            val p = UnloadPolicy.create("foo").with_heuristic(3)
            assert_false(p.metadata_beats_heuristic())

    context "InvariantCheck":
        it "unknown path noop passes":
            val ic = InvariantCheck.unknown_path_noop(0)
            assert_true(ic.passed)

        it "unknown path noop fails":
            val ic = InvariantCheck.unknown_path_noop(2)
            assert_false(ic.passed)

        it "metadata cleanup passes":
            val ic = InvariantCheck.metadata_cleanup(3, 5)
            assert_true(ic.passed)

        it "metadata priority with metadata":
            val ic = InvariantCheck.metadata_priority(true, false)
            assert_true(ic.passed)

        it "metadata priority violated":
            val ic = InvariantCheck.metadata_priority(true, true)
            assert_false(ic.passed)

    context "MetadataEntry":
        it "belongs to its module path":
            val e = MetadataEntry.create("sym_a", "mod.spl")
            assert_true(e.belongs_to("mod.spl"))

        it "does not belong to another path":
            val e = MetadataEntry.create("sym_a", "mod.spl")
            assert_false(e.belongs_to("other.spl"))

        it "keeps its symbol name field":
            val e = MetadataEntry.create("mangled_foo", "path/bar.spl")
            expect e.sym_name to eq "mangled_foo"

    context "GlobalOwnership":
        it "is owned by its owner":
            val g = GlobalOwnership.create("global_init", "main.spl")
            assert_true(g.is_owned_by("main.spl"))

        it "is not owned by another module":
            val g = GlobalOwnership.create("global_init", "main.spl")
            assert_false(g.is_owned_by("other.spl"))

    context "JitState reload":
        it "tracked state is not resolvable":
            val j = JitState.tracked("sym")
            assert_false(j.is_resolvable())

        it "resolvable after reload":
            val j = JitState.tracked("sym").after_unload(true).after_reload(true)
            assert_true(j.is_resolvable())

        it "lost after unload without reload":
            val j = JitState.tracked("sym").after_unload(false).after_reload(false)
            assert_false(j.is_resolvable())

    context "Deterministic rebuild":
        it "passes when after == before - removed":
            val ic = InvariantCheck.deterministic_rebuild(10, 3, 7)
            assert_true(ic.passed)

        it "fails when after != before - removed":
            val ic = InvariantCheck.deterministic_rebuild(10, 3, 8)
            assert_false(ic.passed)

    context "ScenarioResult":
        it "distinguishes pass from fail":
            val p = ScenarioResult.pass_it("my_scenario", "all good")
            val f = ScenarioResult.fail_it("my_scenario", "something broke")
            assert_true(p.passed and (f.passed == false))
