"""Module Loader relocation application specification tests."""

use app.io.{shell}
use compiler.backend.linker.smf_reader_memory.{SmfReaderMemory}
use compiler.driver.smf_writer.{build_smf_with_relocations, SmfBuildOptions, Target}
use compiler.loader.module_loader.*
use compiler.loader.smf_mmap_native.{native_mmap_read_bytes}
use std.io_runtime.{file_read_bytes}

extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_write_bytes(path: text, data: [u8]) -> bool
extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_delete(path: text) -> bool

fn delete_if_exists(path: text):
    if rt_file_exists(path):
        rt_file_delete(path)

fn cleanup_tmpdir(tmpdir: text):
    _ = shell("rm -rf '{tmpdir}' >/dev/null 2>&1 || true")

fn i32_to_le_bytes(value: i32) -> [u8]:
    var result: [u8] = []
    result.push((value & 0xFF) as u8)
    result.push(((value >> 8) & 0xFF) as u8)
    result.push(((value >> 16) & 0xFF) as u8)
    result.push(((value >> 24) & 0xFF) as u8)
    result

fn i64_to_le_bytes(value: i64) -> [u8]:
    var result: [u8] = []
    result.push((value & 0xFF) as u8)
    result.push(((value >> 8) & 0xFF) as u8)
    result.push(((value >> 16) & 0xFF) as u8)
    result.push(((value >> 24) & 0xFF) as u8)
    result.push(((value >> 32) & 0xFF) as u8)
    result.push(((value >> 40) & 0xFF) as u8)
    result.push(((value >> 48) & 0xFF) as u8)
    result.push(((value >> 56) & 0xFF) as u8)
    result

fn patch_first_reloc_symbol_index_zero(smf_bytes: [u8], code_len: i64) -> [u8]:
    val reloc_symbol_index_offset = code_len + 8
    val prefix = smf_bytes[0:reloc_symbol_index_offset]
    val suffix = smf_bytes[reloc_symbol_index_offset + 4:smf_bytes.len()]
    prefix + [0, 0, 0, 0] + suffix

describe "Module Loader relocation application":
    it "applies a live relocation entry from a compiled object":
        val tmpdir = shell("mktemp -d").stdout.trim()
        if tmpdir == "":
            fail("failed to create a temporary directory")

        val src_path = "{tmpdir}/reloc_fixture.c"
        val obj_path = "{tmpdir}/reloc_fixture.o"
        val smf_path = "{tmpdir}/reloc_fixture.smf"

        delete_if_exists(src_path)
        delete_if_exists(obj_path)
        delete_if_exists(smf_path)

        val source = "extern long external_value;\nlong main(void) { return (long)&external_value; }\n"
        expect(rt_file_write_text(src_path, source)).to_equal(true)

        val compile = shell("cc -c -O0 -fno-pic -fno-pie -o '{obj_path}' '{src_path}' 2>&1")
        if compile.exit_code != 0:
            cleanup_tmpdir(tmpdir)
            fail("cc failed: {compile.stdout}{compile.stderr}")

        val object_bytes = file_read_bytes(obj_path)
        val smf_bytes = build_smf_with_relocations(object_bytes, SmfBuildOptions.create(Target.x86_64_unknown_linux_gnu()))

        val parsed = SmfReaderMemory.from_data(smf_bytes)
        if parsed.is_err():
            cleanup_tmpdir(tmpdir)
            fail("failed to parse generated SMF: {parsed.unwrap_err()}")

        val reader = parsed.unwrap()
        val main_symbol = reader.lookup_symbol("main").unwrap()
        val code_bytes = reader.read_code(main_symbol).unwrap()
        val relocs = reader.read_relocations().unwrap()

        expect(relocs.len()).to_equal(1)
        expect(relocs[0].symbol_index).to_be_greater_than(0)

        val patched_smf = patch_first_reloc_symbol_index_zero(smf_bytes, code_bytes.len() as i64)
        expect(rt_file_write_bytes(smf_path, patched_smf)).to_equal(true)

        var loader = ModuleLoader.with_defaults()
        val load_result = loader.load(smf_path)
        match load_result:
            case LoadResult.Success(module):
                expect(module.path).to_equal(smf_path)
                expect(module.symbols.contains_key("main")).to_equal(true)

                val loaded_symbol = module.symbols["main"]
                val reloc = relocs[0]
                val patch_len = if reloc.reloc_type == 1: 8 else: 4
                val patch_bytes = native_mmap_read_bytes(loaded_symbol.address, reloc.offset, patch_len)

                if reloc.reloc_type == 1:
                    val expected_value = loaded_symbol.address + reloc.addend
                    expect(patch_bytes).to_equal(i64_to_le_bytes(expected_value))
                else:
                    val expected_value = reloc.addend - reloc.offset
                    expect(patch_bytes).to_equal(i32_to_le_bytes(expected_value as i32))
            case LoadResult.Error(message):
                cleanup_tmpdir(tmpdir)
                fail("loader rejected the relocation-bearing SMF: {message}")
            case _:
                cleanup_tmpdir(tmpdir)
                fail("unexpected load result")

        cleanup_tmpdir(tmpdir)
