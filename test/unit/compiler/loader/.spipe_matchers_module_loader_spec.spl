"""
# Module Loader

Verifies module loading, JIT symbol resolution, and cache cleanup behavior.
"""

use compiler.loader.module_loader.*
use compiler.loader.jit_instantiator.{PossibleInstantiation, LoadedMetadata, InstantiationRecord}
use compiler.loader.compiler_ffi.{make_named_type}

fn existing_module_path() -> text:
    "test/unit/compiler/loader/module_loader_spec.spl"

fn second_module_path() -> text:
    "test/unit/compiler/parser/parser_await_spawn_spec.spl"

describe "Module Loader":
    """Focused module loader behavior checks."""

    it "creates default configuration":
        val config = ModuleLoaderConfig.default()
        expect config.enable_jit == true
        expect config.enable_cache == true
        expect config.max_cache_size == 100
        expect config.hot_reload == false

    it "loads an existing path and tracks it as loaded":
        var loader = ModuleLoader.with_defaults()
        val path = existing_module_path()
        val result = moduleloader_load(loader, path)

        match result:
            case LoadResult.Success(module):
                expect module.path == path
            case _:
                expect "unexpected" == path

        expect loader.is_loaded(path) == true
        expect loader.loaded_modules().len() == 1
        expect loader.stats().module_count == 1

    it "loads a module with a symbol and resolves it from globals":
        var loader = ModuleLoader.with_defaults()
        val path = existing_module_path()
        val loaded = moduleloader_load(loader, path)

        match loaded:
            case LoadResult.Success(module):
                expect module.path == path
            case _:
                expect "unexpected" == path

        val symbol = LoadedSymbol(
            name: "module_exported_fn",
            address: 4096,
            size: 16,
            ty: SymbolType.Function,
            is_jit: false,
            file_offset: 8
        )
        loader.global_symbols = {"module_exported_fn": (path, symbol)}

        val resolved = moduleloader_resolve_symbol(loader, "module_exported_fn")
        match resolved:
            case SymbolResult.Found(found, code):
                expect found.name == "module_exported_fn"
                expect found.address == 4096
                expect found.size == 16
                expect found.ty == SymbolType.Function
                expect found.is_jit == false
                expect found.file_offset == 8
                expect code.len() == 0
            case _:
                expect "missing" == "module_exported_fn"

        expect loader.stats().symbol_count == 1

    it "loads multiple existing paths and reports module count":
        var loader = ModuleLoader.with_defaults()
        val first_path = existing_module_path()
        val second_path = second_module_path()
        val first = moduleloader_load(loader, first_path)
        val second = moduleloader_load(loader, second_path)

        match first:
            case LoadResult.Success(module):
                expect module.path == first_path
            case _:
                expect "unexpected" == first_path

        match second:
            case LoadResult.Success(module):
                expect module.path == second_path
            case _:
                expect "unexpected" == second_path

        expect loader.is_loaded(first_path) == true
        expect loader.is_loaded(second_path) == true
        expect loader.loaded_modules().len() == 2
        expect loader.stats().module_count == 2

    it "loads modules and reports resolved symbol count":
        var loader = ModuleLoader.with_defaults()
        val first_path = existing_module_path()
        val second_path = second_module_path()
        _ = moduleloader_load(loader, first_path)
        _ = moduleloader_load(loader, second_path)
        val first_entry = PossibleInstantiation(
            template_name: "Vec",
            type_args: "i64",
            mangled_name: "vec_runtime_i64"
        )
        val second_entry = PossibleInstantiation(
            template_name: "Map",
            type_args: "text_i64",
            mangled_name: "map_runtime_text_i64"
        )
        loader.jit.set_metadata_for_test(first_path, LoadedMetadata(possible: [first_entry], instantiations: []))
        loader.jit.set_metadata_for_test(second_path, LoadedMetadata(possible: [second_entry], instantiations: []))

        match moduleloader_resolve_symbol(loader, "vec_runtime_i64"):
            case SymbolResult.JitCompiled(symbol, _):
                expect symbol.name == "vec_runtime_i64"
            case _:
                expect "missing" == "vec_runtime_i64"

        match moduleloader_resolve_symbol(loader, "map_runtime_text_i64"):
            case SymbolResult.JitCompiled(symbol, _):
                expect symbol.name == "map_runtime_text_i64"
            case _:
                expect "missing" == "map_runtime_text_i64"

        expect loader.global_symbols.has("vec_runtime_i64") == true
        expect loader.global_symbols.has("map_runtime_text_i64") == true
        expect loader.stats().symbol_count == 2

    it "returns an error when the module path does not exist":
        var loader = ModuleLoader.with_defaults()
        val result = moduleloader_load(loader, "test/unit/compiler/loader/does_not_exist.spl")

        match result:
            case LoadResult.Error(message):
                expect (message).contains("module not found")
            case _:
                expect "unexpected" == "module not found"

    it "resolves JIT-backed symbols through the public loader API":
        var loader = ModuleLoader.with_defaults()
        val path = existing_module_path()
        val entry = PossibleInstantiation(
            template_name: "Vec",
            type_args: "i64",
            mangled_name: "vec_runtime_i64"
        )
        loader.jit.set_metadata_for_test(path, LoadedMetadata(possible: [entry], instantiations: []))

        val result = moduleloader_resolve_symbol(loader, "vec_runtime_i64")
        match result:
            case SymbolResult.JitCompiled(symbol, code):
                expect symbol.name == "vec_runtime_i64"
                expect symbol.is_jit == true
                expect code.len() > 0
            case _:
                expect "missing" == "vec_runtime_i64"

        expect loader.global_symbols.has("vec_runtime_i64") == true
        val cached = moduleloader_resolve_symbol(loader, "vec_runtime_i64")
        match cached:
            case SymbolResult.Found(symbol, code):
                expect symbol.name == "vec_runtime_i64"
                expect symbol.is_jit == true
                expect code.len() == 0
            case _:
                expect "missing" == "vec_runtime_i64"

        expect loader.jit.stats().compile_count == 1
        expect loader.jit.stats().cached_count == 1
        expect loader.stats().symbol_count == 1

    it "mangles explicit generic type arguments":
        var loader = ModuleLoader.with_defaults()
        expect loader.config.enable_jit == true
        val result = moduleloader_resolve_generic(loader, "Vec", [make_named_type("Int"), make_named_type("String")])

        match result:
            case SymbolResult.NotFound(name):
                expect name == "Vec$Int_String"
            case _:
                expect "unexpected" == "Vec$Int_String"

        expect loader.global_symbols.has("Vec$Int_String") == false
        expect loader.jit.stats().compile_count == 0
        expect loader.jit.stats().cached_count == 0
        expect loader.stats().symbol_count == 0

    it "resolves Vec i64 through the generic loader API":
        var loader = ModuleLoader.with_defaults()
        val path = existing_module_path()
        val entry = PossibleInstantiation(
            template_name: "Vec",
            type_args: "i64",
            mangled_name: "Vec$i64"
        )
        loader.jit.set_metadata_for_test(path, LoadedMetadata(possible: [entry], instantiations: []))

        val result = loader.resolve_generic("Vec", [make_named_type("i64")])
        match result:
            case SymbolResult.JitCompiled(symbol, code):
                expect symbol.name == "Vec$i64"
                expect symbol.is_jit == true
                expect code.len() > 0
            case _:
                expect "missing" == "Vec$i64"

        expect loader.global_symbols.has("Vec$i64") == true
        expect loader.jit.stats().compile_count == 1

    it "unloads modules and drops their JIT-owned symbols":
        var loader = ModuleLoader.with_defaults()
        val path = existing_module_path()
        val entry = PossibleInstantiation(
            template_name: "Hot",
            type_args: "reload",
            mangled_name: "hot_reload_fn"
        )
        loader.jit.set_metadata_for_test(path, LoadedMetadata(possible: [entry], instantiations: []))
        _ = moduleloader_load(loader, path)
        _ = moduleloader_resolve_symbol(loader, "hot_reload_fn")

        moduleloader_unload(loader, path)

        expect loader.is_loaded(path) == false
        match moduleloader_resolve_symbol(loader, "hot_reload_fn"):
            case SymbolResult.NotFound(name):
                expect name == "hot_reload_fn"
            case _:
                expect "stale" == "hot_reload_fn"

    it "unloads metadata-owned jit symbols even after owner drifted to __jit__":
        var loader = ModuleLoader.with_defaults()
        val path = existing_module_path()
        val symbol_name = "Vec$i64"
        _ = moduleloader_load(loader, path)
        loader.jit.set_metadata_for_test(
            path,
            LoadedMetadata(
                possible: [],
                instantiations: [
                    InstantiationRecord(
                        id: 0,
                        template_name: "Vec",
                        type_args: "i64",
                        mangled_name: symbol_name,
                        from_file: path,
                        from_loc: path + ":0:0",
                        to_obj: "jit_obj",
                        status: "jit_compiled"
                    )
                ]
            )
        )
        loader.jit.exec_mapper.set_record(symbol_name, "__jit__", 4096)
        loader.jit.set_cache_for_test(symbol_name, [1, 2, 3], 4096)

        match moduleloader_resolve_symbol(loader, symbol_name):
            case SymbolResult.JitCompiled(symbol, _):
                expect symbol.name == symbol_name
            case _:
                expect "missing" == symbol_name

        moduleloader_unload(loader, path)

        expect loader.global_symbols.has(symbol_name) == false
        match moduleloader_resolve_symbol(loader, symbol_name):
            case SymbolResult.NotFound(name):
                expect name == symbol_name
            case _:
                expect "stale" == symbol_name

    it "unload removes owned globals, clears metadata-owned jit symbols, preserves unrelated globals, and clears loaded metadata":
        var loader = ModuleLoader.with_defaults()
        val path = existing_module_path()
        val unrelated_path = second_module_path()
        val owned_symbol_name = "module_owned_fn"
        val unrelated_symbol_name = "other_module_fn"
        val jit_symbol_name = "Vec$i64"
        _ = moduleloader_load(loader, path)

        val owned_symbol = LoadedSymbol(
            name: owned_symbol_name,
            address: 12288,
            size: 16,
            ty: SymbolType.Function,
            is_jit: false,
            file_offset: 0
        )
        val unrelated_symbol = LoadedSymbol(
            name: unrelated_symbol_name,
            address: 16384,
            size: 16,
            ty: SymbolType.Function,
            is_jit: false,
            file_offset: 0
        )
        loader.global_symbols = {
            owned_symbol_name: (path, owned_symbol),
            unrelated_symbol_name: (unrelated_path, unrelated_symbol)
        }
        loader.jit.set_metadata_for_test(
            path,
            LoadedMetadata(
                possible: [],
                instantiations: [
                    InstantiationRecord(
                        id: 0,
                        template_name: "Vec",
                        type_args: "i64",
                        mangled_name: jit_symbol_name,
                        from_file: path,
                        from_loc: path + ":0:0",
                        to_obj: "jit_obj",
                        status: "jit_compiled"
                    )
                ]
            )
        )
        loader.jit.exec_mapper.set_record(jit_symbol_name, "__jit__", 20480)
        loader.jit.set_cache_for_test(jit_symbol_name, [1, 2, 3], 20480)

        match moduleloader_resolve_symbol(loader, jit_symbol_name):
            case SymbolResult.JitCompiled(symbol, _):
                expect symbol.name == jit_symbol_name
            case _:
                expect "missing" == jit_symbol_name

        moduleloader_unload(loader, path)

        expect loader.global_symbols.has(owned_symbol_name) == false
        expect loader.global_symbols.has(jit_symbol_name) == false
        expect loader.global_symbols.has(unrelated_symbol_name) == true
        expect loader.jit.loaded_metadata.has(path) == false
        expect loader.jit.jit_cache.has(jit_symbol_name) == false

    # =========================================================================
    # A1 — impl-method unload delegation parity
    #
    # Each test exercises loader.unload(path) (impl-method path) and compares
    # observable state against what moduleloader_unload (free-function path)
    # produces.  Before the A1 refactor the impl-method body was 38 lines of
    # copy-paste; after it is a single delegator.  These tests form the gate.
    # =========================================================================

    it "impl-method unload clears modules entry for the path":
        var loader = ModuleLoader.with_defaults()
        val path = existing_module_path()
        _ = moduleloader_load(loader, path)
        expect loader.is_loaded(path) == true

        loader.unload(path)

        expect loader.is_loaded(path) == false
        expect loader.modules.has(path) == false

    it "impl-method unload drops global symbols owned by that module":
        var loader = ModuleLoader.with_defaults()
        val path = existing_module_path()
        _ = moduleloader_load(loader, path)
        val sym = LoadedSymbol(
            name: "owned_sym",
            address: 8192,
            size: 8,
            ty: SymbolType.Function,
            is_jit: false,
            file_offset: 0
        )
        loader.global_symbols = {"owned_sym": (path, sym)}

        loader.unload(path)

        expect loader.global_symbols.has("owned_sym") == false

    it "impl-method unload clears loaded_metadata for the path":
        var loader = ModuleLoader.with_defaults()
        val path = existing_module_path()
        val entry = PossibleInstantiation(
            template_name: "Vec",
            type_args: "i64",
            mangled_name: "vec_runtime_i64"
        )
        loader.jit.set_metadata_for_test(path, LoadedMetadata(possible: [entry], instantiations: []))
        _ = moduleloader_load(loader, path)

        loader.unload(path)

        expect loader.jit.loaded_metadata.has(path) == false

    it "impl-method unload clears jit_cache entries for symbols of the module":
        var loader = ModuleLoader.with_defaults()
        val path = existing_module_path()
        val sym_name = "Vec$i64"
        _ = moduleloader_load(loader, path)
        loader.jit.set_metadata_for_test(
            path,
            LoadedMetadata(
                possible: [],
                instantiations: [
                    InstantiationRecord(
                        id: 0,
                        template_name: "Vec",
                        type_args: "i64",
                        mangled_name: sym_name,
                        from_file: path,
                        from_loc: path + ":0:0",
                        to_obj: "jit_obj",
                        status: "jit_compiled"
                    )
                ]
            )
        )
        loader.jit.exec_mapper.set_record(sym_name, "__jit__", 4096)
        loader.jit.set_cache_for_test(sym_name, [1, 2, 3], 4096)
        _ = moduleloader_resolve_symbol(loader, sym_name)

        loader.unload(path)

        expect loader.jit.jit_cache.has(sym_name) == false
        expect loader.global_symbols.has(sym_name) == false

    it "impl-method unload preserves global symbols owned by a different module":
        var loader = ModuleLoader.with_defaults()
        val path = existing_module_path()
        val other_path = second_module_path()
        _ = moduleloader_load(loader, path)
        val other_sym = LoadedSymbol(
            name: "other_fn",
            address: 32768,
            size: 8,
            ty: SymbolType.Function,
            is_jit: false,
            file_offset: 0
        )
        loader.global_symbols = {"other_fn": (other_path, other_sym)}

        loader.unload(path)

        expect loader.global_symbols.has("other_fn") == true

    it "impl-method unload of a never-loaded path is a no-op and does not panic":
        var loader = ModuleLoader.with_defaults()
        val phantom = "test/unit/compiler/loader/does_not_exist_ghost.spl"

        loader.unload(phantom)

        expect loader.modules.has(phantom) == false
        expect loader.global_symbols.len() == 0

    it "impl-method double-unload is idempotent: second call is a no-op":
        var loader = ModuleLoader.with_defaults()
        val path = existing_module_path()
        _ = moduleloader_load(loader, path)
        val sym = LoadedSymbol(
            name: "idempotent_sym",
            address: 4096,
            size: 8,
            ty: SymbolType.Function,
            is_jit: false,
            file_offset: 0
        )
        loader.global_symbols = {"idempotent_sym": (path, sym)}

        loader.unload(path)
        loader.unload(path)

        expect loader.is_loaded(path) == false
        expect loader.global_symbols.has("idempotent_sym") == false

    it "impl-method unload and free-function unload produce identical module-table state":
        var loader_a = ModuleLoader.with_defaults()
        var loader_b = ModuleLoader.with_defaults()
        val path = existing_module_path()
        val sym_name = "parity_sym"

        _ = moduleloader_load(loader_a, path)
        _ = moduleloader_load(loader_b, path)

        val sym_a = LoadedSymbol(
            name: sym_name,
            address: 8192,
            size: 8,
            ty: SymbolType.Function,
            is_jit: false,
            file_offset: 0
        )
        val sym_b = LoadedSymbol(
            name: sym_name,
            address: 8192,
            size: 8,
            ty: SymbolType.Function,
            is_jit: false,
            file_offset: 0
        )
        loader_a.global_symbols = {sym_name: (path, sym_a)}
        loader_b.global_symbols = {sym_name: (path, sym_b)}

        # Apply unload via the two paths
        loader_a.unload(path)        # impl-method path (the delegator under test)
        moduleloader_unload(loader_b, path)  # free-function path (reference)

        # Observable state must be identical
        expect loader_a.is_loaded(path) == loader_b.is_loaded(path)
        expect loader_a.global_symbols.has(sym_name) == loader_b.global_symbols.has(sym_name)
        expect loader_a.global_symbols.len() == loader_b.global_symbols.len()

    it "impl-method unload after JIT symbols are registered removes them correctly":
        var loader = ModuleLoader.with_defaults()
        val path = existing_module_path()
        val jit_sym = "jit_owned_fn"
        val entry = PossibleInstantiation(
            template_name: "JitOwned",
            type_args: "f64",
            mangled_name: jit_sym
        )
        loader.jit.set_metadata_for_test(path, LoadedMetadata(possible: [entry], instantiations: []))
        _ = moduleloader_load(loader, path)
        _ = moduleloader_resolve_symbol(loader, jit_sym)

        loader.unload(path)

        expect loader.global_symbols.has(jit_sym) == false
        match moduleloader_resolve_symbol(loader, jit_sym):
            case SymbolResult.NotFound(name):
                expect name == jit_sym
            case _:
                expect "still_present" == jit_sym

    it "reload rehydrates on-disk metadata so persisted jit symbols stay resolvable":
        var loader = ModuleLoader.with_defaults()
        val path = existing_module_path()
        val persisted_symbol = "Vec$i64"

        match moduleloader_load(loader, path):
            case LoadResult.Success(module):
                expect module.path == path
            case _:
                expect "unexpected" == path

        expect loader.jit.loaded_metadata.has(path) == true

        match moduleloader_resolve_symbol(loader, persisted_symbol):
            case SymbolResult.JitCompiled(symbol, code):
                expect symbol.name == persisted_symbol
                expect code.len() > 0
            case SymbolResult.Found(symbol, _):
                expect symbol.name == persisted_symbol
            case _:
                expect "missing" == persisted_symbol

        match moduleloader_reload(loader, path):
            case LoadResult.Success(module):
                expect module.path == path
            case _:
                expect "unexpected" == path

        expect loader.jit.loaded_metadata.has(path) == true
        match moduleloader_resolve_symbol(loader, persisted_symbol):
            case SymbolResult.JitCompiled(symbol, code):
                expect symbol.name == persisted_symbol
                expect code.len() > 0
            case SymbolResult.Found(symbol, _):
                expect symbol.name == persisted_symbol
            case _:
                expect "missing" == persisted_symbol