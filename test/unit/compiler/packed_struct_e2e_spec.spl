use std.spec.{describe, it, expect}

describe "@packed struct end-to-end":
    it "round-trips field read/write with u16:4":
        bitfield PciStatus(u32):
            vendor: u16
            command: u16:4

        var s = PciStatus.new(0)
        s.command = 5
        expect(s.command).to_equal(5)

    it "preserves adjacent fields on write":
        bitfield Flags(u32):
            a: 4
            b: 28

        var f = Flags.new(0)
        f.a = 3
        f.b = 5
        expect(f.a).to_equal(3)
        expect(f.b).to_equal(5)
