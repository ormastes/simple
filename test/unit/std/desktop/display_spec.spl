# Desktop display info API specification

use std.nogc_sync_mut.desktop.display.{DisplayInfo}

describe "Desktop Display API":
    it "creates DisplayInfo struct":
        val d = DisplayInfo(id: 0, name: "Primary", width: 1920, height: 1080, x: 0, y: 0, dpi: 96.0, scale_factor: 1.0, is_primary: true)
        expect d.width == 1920
        expect d.height == 1080
        expect d.is_primary == true
