# Desktop notification API specification

use std.nogc_sync_mut.desktop.notification.{notify, notify_with_options, NotificationOptions}

describe "Desktop Notification API":
    it "creates NotificationOptions struct":
        val opts = NotificationOptions(title: "Test", body: "Hello", icon: "", urgency: "normal", timeout_ms: 5000)
        expect opts.title == "Test"
        expect opts.body == "Hello"
        expect opts.timeout_ms == 5000

    it "exposes notify function":
        expect true == true
