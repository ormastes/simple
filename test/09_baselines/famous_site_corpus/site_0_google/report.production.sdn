  text_ink_delta: (text_ink_delta div_box: (region name: "div_box" different_pixels: 3 chrome_exact_black_pixels: 0 simple_background_mismatch_pixels: 0) overflow_text: (region name: "overflow_text" different_pixels: 0 chrome_exact_black_pixels: 0 simple_background_mismatch_pixels: 0))
  text_line_ink_delta: (text_line_ink_delta count: 4
