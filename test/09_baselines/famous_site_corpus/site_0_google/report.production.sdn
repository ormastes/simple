)
  glyph_compositing_signature: (glyph_compositing_signature kind: "per_line_missing_ink_v1" line_count: 4 different_pixels_total: 3 unexplained_different_pixels: 0 chrome_exact_black_pixels_total: 0 simple_background_mismatch_pixels_total: 0 line_details: (glyph_compositing_line_details count: 4
