use std.spec

class MacroRule:
    name: text
    parameters: [text]
    template: text

    static fn new(name: text, parameters: [text], template: text) -> MacroRule:
        MacroRule(name: name, parameters: parameters, template: template)

    fn arity() -> i64:
        self.parameters.len()

    fn expand(arguments: [text]) -> text:
        var expanded = self.template
        var i: i64 = 0
        while i < self.parameters.len() and i < arguments.len():
            expanded = expanded.replace("{"+self.parameters[i]+"}", arguments[i])
            i = i + 1
        expanded

describe "Macro":
    it "tracks macro arity":
        val rule = MacroRule.new("assert_eq", ["left", "right"], "expect({left}).to_equal({right})")
        expect(rule.arity()).to_equal(2)

    it "expands positional placeholders":
        val rule = MacroRule.new("log", ["value"], "print({value})")
        expect(rule.expand(["42"])).to_equal("print(42)")

    it "leaves unrelated text intact":
        val rule = MacroRule.new("banner", ["title"], "=== {title} ===")
        expect(rule.expand(["HELLO"])).to_equal("=== HELLO ===")
