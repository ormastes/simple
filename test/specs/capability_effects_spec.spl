"""
# Capability-Based Effects Specification
#
# This spec is executable with local doubles for capability and effect checks.
"""

fn contains_text(items: [text], needle: text) -> bool:
    var i: i64 = 0
    while i < items.len():
        if items[i] == needle:
            return true
        i = i + 1
    false

fn append_unique(items: [text], value: text) -> [text]:
    if contains_text(items, value):
        return items
    items.push(value)

fn required_capability(effect_name: text) -> text:
    if effect_name == "pure":
        return ""
    if effect_name == "io":
        return "io"
    if effect_name == "net":
        return "net"
    if effect_name == "fs":
        return "fs"
    "unknown"

fn effect_rank(effect_name: text) -> i64:
    if effect_name == "pure":
        return 0
    if effect_name == "fs":
        return 1
    if effect_name == "net":
        return 2
    if effect_name == "io":
        return 3
    4

fn normalize_effect(effect_name: text) -> text:
    if effect_name == "":
        return "pure"
    effect_name

fn infer_effect(calls: [text]) -> text:
    var best = "pure"
    var i: i64 = 0
    while i < calls.len():
        if effect_rank(calls[i]) > effect_rank(best):
            best = calls[i]
        i = i + 1
    best

fn missing_capability_message(effect_name: text) -> text:
    "missing capability: {required_capability(effect_name)}"

class CapabilityContext:
    capabilities: [text]

    static fn new() -> CapabilityContext:
        CapabilityContext([])

    static fn with_caps(caps: [text]) -> CapabilityContext:
        CapabilityContext(caps)

    me grant(capability: text) -> bool:
        self.capabilities = append_unique(self.capabilities, capability)
        true

    fn has(capability: text) -> bool:
        contains_text(self.capabilities, capability)

    fn inherit_from(parent: CapabilityContext) -> CapabilityContext:
        var merged = self.capabilities
        var i: i64 = 0
        while i < parent.capabilities.len():
            merged = append_unique(merged, parent.capabilities[i])
            i = i + 1
        CapabilityContext(capabilities: merged)

    fn can_call(effect_name: text) -> bool:
        val required = required_capability(effect_name)
        if required == "":
            return true
        self.has(required)

class EffectSignature:
    name: text
    effect_name: text
    requires: [text]

    static fn pure(name: text) -> EffectSignature:
        EffectSignature(name, "pure", [])

    static fn io(name: text) -> EffectSignature:
        EffectSignature(name, "io", ["io"])

    static fn net(name: text) -> EffectSignature:
        EffectSignature(name, "net", ["net"])

    static fn fs(name: text) -> EffectSignature:
        EffectSignature(name, "fs", ["fs"])

    fn is_pure() -> bool:
        self.effect_name == "pure"

    fn required_capability() -> text:
        required_capability(self.effect_name)

    fn can_run_in(context: CapabilityContext) -> bool:
        context.can_call(self.effect_name)

    fn describe() -> text:
        "{self.name}:{self.effect_name}"

class CapabilityReport:
    pure_calls: i64
    impure_calls: i64
    mismatches: i64

    static fn new() -> CapabilityReport:
        CapabilityReport(0, 0, 0)

    me record(effect_name: text, allowed: bool):
        if effect_name == "pure":
            self.pure_calls = self.pure_calls + 1
        else:
            self.impure_calls = self.impure_calls + 1
        if not allowed:
            self.mismatches = self.mismatches + 1

fn stdlib_read(context: CapabilityContext) -> bool:
    context.can_call("io")

fn stdlib_format(context: CapabilityContext) -> bool:
    context.can_call("pure")

fn generic_bound_allows(context: CapabilityContext, bound: text) -> bool:
    context.can_call(bound)

fn boundary_roundtrip(context: CapabilityContext) -> bool:
    val read_allowed = stdlib_read(context)
    val pure_allowed = stdlib_format(CapabilityContext.new())
    read_allowed and pure_allowed

describe "Capability Effects Spec":
    it "features_1":
        val module = CapabilityContext.with_caps(["io"])
        expect(module.can_call("io")).to_equal(true)
        expect(module.can_call("net")).to_equal(false)

    it "features_capability_inheritance":
        val parent = CapabilityContext.with_caps(["io", "fs"])
        val child = CapabilityContext.with_caps(["net"])
        val merged = child.inherit_from(parent)
        expect(merged.has("io")).to_equal(true)
        expect(merged.has("fs")).to_equal(true)
        expect(merged.has("net")).to_equal(true)

    it "features_effect_annotations":
        val pure = EffectSignature.pure("parse")
        val io = EffectSignature.io("read")
        expect(pure.is_pure()).to_equal(true)
        expect(io.is_pure()).to_equal(false)
        expect(io.required_capability()).to_equal("io")

    it "features_effect_inference":
        val inferred = infer_effect(["pure", "io", "pure"])
        expect(inferred).to_equal("io")

    it "features_pure_by_default":
        val inferred = normalize_effect("")
        expect(inferred).to_equal("pure")

    it "features_effect_propagation":
        val pure_module = CapabilityContext.new()
        expect(pure_module.can_call("pure")).to_equal(true)
        expect(pure_module.can_call("io")).to_equal(false)

    it "features_capability_requirements":
        val module = CapabilityContext.with_caps(["io", "net"])
        expect(generic_bound_allows(module, "io")).to_equal(true)
        expect(generic_bound_allows(module, "fs")).to_equal(false)

    it "features_generic_effect_constraints":
        val module = CapabilityContext.with_caps(["net"])
        expect(generic_bound_allows(module, "net")).to_equal(true)
        expect(generic_bound_allows(module, "io")).to_equal(false)

    it "features_error_messages":
        val message = missing_capability_message("net")
        expect(message).to_equal("missing capability: net")

    it "features_effect_mismatch":
        val pure = EffectSignature.pure("render")
        val io = EffectSignature.io("read")
        expect(pure.can_run_in(CapabilityContext.new())).to_equal(true)
        expect(io.can_run_in(CapabilityContext.new())).to_equal(false)

    it "features_11":
        val module = CapabilityContext.new()
        expect(module.can_call("fs")).to_equal(false)
        expect(module.can_call("pure")).to_equal(true)

    it "features_stdlib_effects":
        val io_module = CapabilityContext.with_caps(["io"])
        val pure_module = CapabilityContext.new()
        expect(stdlib_read(io_module)).to_equal(true)
        expect(stdlib_format(pure_module)).to_equal(true)

    it "examples_pure_module":
        val report = CapabilityReport.new()
        report.record("pure", true)
        report.record("io", false)
        expect(report.pure_calls).to_equal(1)
        expect(report.impure_calls).to_equal(1)
        expect(report.mismatches).to_equal(1)

    it "examples_io_boundaries":
        val io_module = CapabilityContext.with_caps(["io"])
        expect(boundary_roundtrip(io_module)).to_equal(true)
