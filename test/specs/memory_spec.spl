use std.spec

class OptionI64:
    present: bool
    value: i64

    static fn some(value: i64) -> OptionI64:
        OptionI64(present: true, value: value)

    static fn none() -> OptionI64:
        OptionI64(present: false, value: 0)

    fn is_some() -> bool:
        self.present

    fn is_none() -> bool:
        not self.present

    fn unwrap_or(default_value: i64) -> i64:
        if self.present:
            self.value
        else:
            default_value

class ReferenceBox:
    value: i64

    static fn new(value: i64) -> ReferenceBox:
        ReferenceBox(value: value)

    fn read() -> i64:
        self.value

class UniqueBox:
    value: i64
    moved: bool

    static fn new(value: i64) -> UniqueBox:
        UniqueBox(value: value, moved: false)

    me take() -> i64:
        self.moved = true
        self.value

    fn is_moved() -> bool:
        self.moved

class SharedBox:
    value: i64
    ref_count: i64

    static fn new(value: i64) -> SharedBox:
        SharedBox(value: value, ref_count: 1)

    fn clone_box() -> SharedBox:
        SharedBox(value: self.value, ref_count: self.ref_count + 1)

    fn read() -> i64:
        self.value

class WeakBox:
    value: i64
    alive: bool

    static fn new(value: i64) -> WeakBox:
        WeakBox(value: value, alive: true)

    fn upgrade() -> OptionI64:
        if self.alive:
            OptionI64.some(self.value)
        else:
            OptionI64.none()

    me invalidate():
        self.alive = false

class HandlePool:
    next_id: i64
    values: [i64]
    active: [bool]

    static fn new() -> HandlePool:
        HandlePool(next_id: 0, values: [], active: [])

    me allocate(value: i64) -> i64:
        val handle = self.next_id
        self.next_id = self.next_id + 1
        self.values = self.values.push(value)
        self.active = self.active.push(true)
        handle

    fn is_valid(handle: i64) -> bool:
        if handle < 0:
            return false
        if handle >= self.active.len():
            return false
        self.active[handle]

    fn get(handle: i64) -> OptionI64:
        if not self.is_valid(handle):
            return OptionI64.none()
        OptionI64.some(self.values[handle])

    me free(handle: i64):
        if self.is_valid(handle):
            self.active[handle] = false

class HandleBox:
    pool: HandlePool
    handle: i64

    static fn new(pool: HandlePool, value: i64) -> HandleBox:
        var copy = pool
        val handle = copy.allocate(value)
        HandleBox(pool: copy, handle: handle)

    fn read() -> OptionI64:
        self.pool.get(self.handle)

    me free():
        self.pool.free(self.handle)

class BorrowSession:
    borrowed: bool
    mutable: bool

    static fn new(mutable: bool) -> BorrowSession:
        BorrowSession(borrowed: false, mutable: mutable)

    me borrow():
        self.borrowed = true

    fn can_write() -> bool:
        self.borrowed and self.mutable

class Actor:
    name: text
    inbox: [text]

    static fn new(name: text) -> Actor:
        Actor(name: name, inbox: [])

    me send(message: text):
        self.inbox = self.inbox.push(message)

    fn receive() -> OptionI64:
        if self.inbox.len() == 0:
            return OptionI64.none()
        OptionI64.some(self.inbox.len())

class Entity:
    id: i64
    health: i64
    alive: bool

    static fn new(id: i64, health: i64) -> Entity:
        Entity(id: id, health: health, alive: true)

    me apply_damage(amount: i64):
        self.health = self.health - amount
        if self.health <= 0:
            self.alive = false

    fn is_alive() -> bool:
        self.alive

class World:
    entities: [Entity]
    next_id: i64

    static fn new() -> World:
        World(entities: [], next_id: 0)

    me spawn_entity(health: i64) -> i64:
        val id = self.next_id
        self.next_id = self.next_id + 1
        self.entities = self.entities.push(Entity.new(id, health))
        id

fn same_box_value(box_value: i64, expected: i64) -> bool:
    box_value == expected

describe "Memory Spec":
    it "reference_and_pointer_kinds_1":
        val reference = ReferenceBox.new(10)
        expect(reference.read()).to_equal(10)

    it "reference_and_pointer_kinds_2":
        var unique = UniqueBox.new(20)
        expect(unique.is_moved()).to_equal(false)
        expect(unique.take()).to_equal(20)
        expect(unique.is_moved()).to_equal(true)

    it "reference_and_pointer_kinds_3":
        val shared = SharedBox.new(30)
        val cloned = shared.clone_box()
        expect(shared.read()).to_equal(30)
        expect(cloned.read()).to_equal(30)
        expect(cloned.ref_count).to_equal(2)

    it "reference_and_pointer_kinds_4":
        var weak = WeakBox.new(40)
        expect(weak.upgrade().is_some()).to_equal(true)
        weak.invalidate()
        expect(weak.upgrade().is_none()).to_equal(true)

    it "reference_and_pointer_kinds_5":
        var pool = HandlePool.new()
        val handle = pool.allocate(50)
        expect(pool.is_valid(handle)).to_equal(true)
        expect(pool.get(handle).unwrap_or(-1)).to_equal(50)

    it "allocation_forms_new_variants_6":
        var unique = UniqueBox.new(60)
        expect(unique.take()).to_equal(60)

    it "allocation_forms_new_variants_7":
        val shared = SharedBox.new(70)
        expect(shared.read()).to_equal(70)
        expect(shared.clone_box().ref_count).to_equal(2)

    it "allocation_forms_new_variants_8":
        var weak = WeakBox.new(80)
        expect(weak.upgrade().unwrap_or(-1)).to_equal(80)

    it "allocation_forms_new_variants_9":
        val optional = OptionI64.some(90)
        expect(optional.is_some()).to_equal(true)
        expect(optional.unwrap_or(0)).to_equal(90)

    it "allocation_forms_new_variants_10":
        var pool = HandlePool.new()
        val box = HandleBox.new(pool, 100)
        expect(box.read().unwrap_or(-1)).to_equal(100)

    it "global_handle_pools_11":
        val pool = HandlePool.new()
        expect(pool.next_id).to_equal(0)

    it "global_handle_pools_12":
        var pool = HandlePool.new()
        val h1 = pool.allocate(110)
        val h2 = pool.allocate(120)
        expect(pool.is_valid(h1)).to_equal(true)
        expect(pool.is_valid(h2)).to_equal(true)

    it "global_handle_pools_13":
        var pool = HandlePool.new()
        val handle = pool.allocate(130)
        expect(pool.get(handle).unwrap_or(-1)).to_equal(130)

    it "global_handle_pools_14":
        var pool = HandlePool.new()
        val handle = pool.allocate(140)
        pool.free(handle)
        expect(pool.is_valid(handle)).to_equal(false)

    it "borrowing_15":
        var session = BorrowSession.new(true)
        session.borrow()
        expect(session.can_write()).to_equal(true)

    it "example_game_entity_system_with_handles_16":
        var world = World.new()
        val first = world.spawn_entity(5)
        val second = world.spawn_entity(8)
        expect(first).to_equal(0)
        expect(second).to_equal(1)
        expect(world.entity_count()).to_equal(2)

    it "note_on_option_types_17":
        val none_value = OptionI64.none()
        expect(none_value.is_none()).to_equal(true)
        expect(none_value.unwrap_or(17)).to_equal(17)
