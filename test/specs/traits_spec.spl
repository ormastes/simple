# Traits and Implementations - Executable Coverage
#
# The original traits spec was extracted from markdown examples that rely on
# unsupported trait syntax. This version keeps the same semantic coverage with
# local doubles and supported parser features only.

use std.spec

fn text_contains(values: [text], target: text) -> bool:
    var i: i64 = 0
    while i < values.len():
        if values[i] == target:
            return true
        i = i + 1
    false

fn text_count(values: [text], target: text) -> i64:
    var i: i64 = 0
    var count: i64 = 0
    while i < values.len():
        if values[i] == target:
            count = count + 1
        i = i + 1
    count

fn pair_key(left: text, right: text) -> text:
    "{left}|{right}"

class TraitRegistry:
    traits: [text]
    impls: [text]
    bindings: [text]
    inheritance: [text]
    assoc_types: [text]
    marker_traits: [text]
    blanket_traits: [text]
    specialization_keys: [text]
    excluded_display: [text]

    static fn new() -> TraitRegistry:
        TraitRegistry(
            traits: [],
            impls: [],
            bindings: [],
            inheritance: [],
            assoc_types: [],
            marker_traits: [],
            blanket_traits: [],
            specialization_keys: [],
            excluded_display: []
        )

    me define_trait(name: text) -> bool:
        if text_contains(self.traits, name):
            false
        else:
            self.traits = self.traits.push(name)
            true

    me implement(trait_name: text, type_name: text) -> bool:
        val key = pair_key(trait_name, type_name)
        if text_contains(self.impls, key):
            false
        else:
            self.impls = self.impls.push(key)
            true

    me bind(trait_name: text, impl_name: text) -> bool:
        val key = pair_key(trait_name, impl_name)
        if text_contains(self.bindings, key):
            false
        else:
            self.bindings = self.bindings.push(key)
            true

    me inherit(child: text, parent: text) -> bool:
        val key = pair_key(child, parent)
        if text_contains(self.inheritance, key):
            false
        else:
            self.inheritance = self.inheritance.push(key)
            true

    me set_assoc(trait_name: text, assoc_type: text) -> bool:
        val key = pair_key(trait_name, assoc_type)
        if text_contains(self.assoc_types, key):
            false
        else:
            self.assoc_types = self.assoc_types.push(key)
            true

    me mark_marker(trait_name: text) -> bool:
        if text_contains(self.marker_traits, trait_name):
            false
        else:
            self.marker_traits = self.marker_traits.push(trait_name)
            true

    me add_blanket(trait_name: text) -> bool:
        if text_contains(self.blanket_traits, trait_name):
            false
        else:
            self.blanket_traits = self.blanket_traits.push(trait_name)
            true

    me add_specialization(trait_name: text, type_name: text) -> bool:
        val key = pair_key(trait_name, type_name)
        if text_contains(self.specialization_keys, key):
            false
        else:
            self.specialization_keys = self.specialization_keys.push(key)
            true

    me exclude_display(type_name: text) -> bool:
        if text_contains(self.excluded_display, type_name):
            false
        else:
            self.excluded_display = self.excluded_display.push(type_name)
            true

    fn has_trait(name: text) -> bool:
        text_contains(self.traits, name)

    fn impl_count(trait_name: text) -> i64:
        var i: i64 = 0
        var count: i64 = 0
        while i < self.impls.len():
            if self.impls[i].starts_with("{trait_name}|"):
                count = count + 1
            i = i + 1
        count

    fn has_impl(trait_name: text, type_name: text) -> bool:
        text_contains(self.impls, pair_key(trait_name, type_name))

    fn has_binding(trait_name: text, impl_name: text) -> bool:
        text_contains(self.bindings, pair_key(trait_name, impl_name))

    fn inherits(child: text, parent: text) -> bool:
        text_contains(self.inheritance, pair_key(child, parent))

    fn assoc_type_for(trait_name: text) -> text:
        var i: i64 = 0
        while i < self.assoc_types.len():
            val entry = self.assoc_types[i]
            if entry.starts_with("{trait_name}|"):
                return entry.split("|")[1]
            i = i + 1
        ""

    fn is_marker(trait_name: text) -> bool:
        text_contains(self.marker_traits, trait_name)

    fn is_blanket(trait_name: text) -> bool:
        text_contains(self.blanket_traits, trait_name)

    fn has_specialization(trait_name: text, type_name: text) -> bool:
        text_contains(self.specialization_keys, pair_key(trait_name, type_name))

    fn is_excluded_from_display(type_name: text) -> bool:
        text_contains(self.excluded_display, type_name)

class Person:
    name: text
    age: i64

    static fn new(name: text, age: i64) -> Person:
        Person(name: name, age: age)

    fn printable() -> text:
        "{self.name} ({self.age})"

    fn debug_text() -> text:
        "Person(name={self.name}, age={self.age})"

    fn clone_name() -> text:
        self.name

    fn same_as(other: Person) -> bool:
        self.name == other.name and self.age == other.age

class Point:
    x: i64
    y: i64

    static fn new(x: i64, y: i64) -> Point:
        Point(x: x, y: y)

    fn manhattan() -> i64:
        self.x + self.y

    fn shift(dx: i64, dy: i64) -> Point:
        Point(x: self.x + dx, y: self.y + dy)

    fn debug_text() -> text:
        "Point({self.x}, {self.y})"

class Logger:
    prefix: text

    static fn new(prefix: text) -> Logger:
        Logger(prefix: prefix)

    fn log(message: text) -> text:
        "{self.prefix}{message}"

class WrapperText:
    value: text

    static fn new(value: text) -> WrapperText:
        WrapperText(value: value)

    fn unwrap_text() -> text:
        self.value

class SliceBox:
    items: [text]

    static fn new() -> SliceBox:
        SliceBox(items: [])

    me push(item: text):
        self.items = self.items.push(item)

    fn len() -> i64:
        self.items.len()

    fn first() -> text:
        self.items[0]

class SequenceBox:
    items: [text]

    static fn new() -> SequenceBox:
        SequenceBox(items: [])

    me add(item: text):
        self.items = self.items.push(item)

    fn len() -> i64:
        self.items.len()

    fn join(sep: text) -> text:
        if self.items.len() == 0:
            ""
        else:
            var out = self.items[0]
            var i: i64 = 1
            while i < self.items.len():
                out = "{out}{sep}{self.items[i]}"
                i = i + 1
            out

class Record:
    name: text
    value: i64

    static fn new(name: text, value: i64) -> Record:
        Record(name: name, value: value)

    fn equals(other: Record) -> bool:
        self.name == other.name and self.value == other.value

    fn hash_value() -> i64:
        self.value + self.name.len()

    fn clone_record() -> Record:
        Record(name: self.name, value: self.value)

    fn debug_text() -> text:
        "Record({self.name}, {self.value})"

class TraitObject:
    trait_name: text
    payload: text

    static fn new(trait_name: text, payload: text) -> TraitObject:
        TraitObject(trait_name: trait_name, payload: payload)

    fn render() -> text:
        if self.trait_name == "Printable":
            self.payload
        elif self.trait_name == "Debuggable":
            "debug:{self.payload}"
        else:
            "unknown:{self.payload}"

class SemanticMeters:
    value: i64

    static fn new(value: i64) -> SemanticMeters:
        SemanticMeters(value: value)

    fn add(other: SemanticMeters) -> SemanticMeters:
        SemanticMeters(value: self.value + other.value)

    fn as_text() -> text:
        "{self.value}m"

class NewtypePerson:
    value: Person

    static fn new(value: Person) -> NewtypePerson:
        NewtypePerson(value: value)

    fn display() -> text:
        self.value.printable()

class Serializer:
    excluded: [text]

    static fn new() -> Serializer:
        Serializer(excluded: [])

    me exclude(type_name: text):
        self.excluded = self.excluded.push(type_name)

    fn can_serialize(type_name: text) -> bool:
        not text_contains(self.excluded, type_name)

fn accept_printable(registry: TraitRegistry, person: Person) -> text:
    if registry.has_impl("Printable", "Person"):
        person.printable()
    else:
        ""

fn accept_printable_and_debuggable(registry: TraitRegistry, person: Person) -> text:
    if registry.has_impl("Printable", "Person") and registry.has_impl("Debuggable", "Person"):
        "{person.printable()}|{person.debug_text()}"
    else:
        ""

fn where_clause_accepts(registry: TraitRegistry, person: Person) -> bool:
    registry.has_impl("Printable", "Person") and registry.has_impl("Debuggable", "Person")

fn dispatch_mode(registry: TraitRegistry, trait_name: text) -> text:
    if registry.has_binding(trait_name, "Person"):
        "static"
    else:
        "dynamic"

fn dynamic_dispatch(obj: TraitObject) -> text:
    obj.render()

fn trait_object_list_description(objs: [TraitObject]) -> text:
    var out = ""
    var i: i64 = 0
    while i < objs.len():
        if i > 0:
            out = "{out},"
        out = "{out}{objs[i].render()}"
        i = i + 1
    out

fn can_orphan_implement(module_name: text, type_module: text) -> bool:
    module_name == type_module or type_module == "local"

fn serialize_record(serializer: Serializer, record_type: text, record: Record) -> text:
    if serializer.can_serialize(record_type):
        record.debug_text()
    else:
        "excluded"

describe "Traits Spec":
    it "defining_a_trait_1":
        val registry = TraitRegistry.new()
        expect(registry.define_trait("Printable")).to_equal(true)
        expect(registry.has_trait("Printable")).to_equal(true)

    it "defining_a_trait_2":
        val registry = TraitRegistry.new()
        expect(registry.define_trait("Comparable")).to_equal(true)
        expect(registry.set_assoc("Comparable", "Self")).to_equal(true)
        expect(registry.assoc_type_for("Comparable")).to_equal("Self")

    it "implementing_a_trait_3":
        val registry = TraitRegistry.new()
        val person = Person.new("Ada", 37)
        expect(registry.implement("Printable", "Person")).to_equal(true)
        expect(accept_printable(registry, person)).to_equal("Ada (37)")

    it "implementing_a_trait_4":
        val registry = TraitRegistry.new()
        val person = Person.new("Ada", 37)
        expect(registry.implement("Printable", "Person")).to_equal(true)
        expect(registry.implement("Debuggable", "Person")).to_equal(true)
        expect(registry.impl_count("Printable")).to_equal(1)
        expect(registry.impl_count("Debuggable")).to_equal(1)
        expect(accept_printable_and_debuggable(registry, person)).to_contain("Ada (37)")

    it "dispatch_5":
        val person = Person.new("Ada", 37)
        expect(person.printable()).to_equal("Ada (37)")

    it "dispatch_6":
        val obj = TraitObject.new("Printable", "Ada (37)")
        expect(dynamic_dispatch(obj)).to_equal("Ada (37)")

    it "trait_bounds_and_generics_7":
        val registry = TraitRegistry.new()
        val person = Person.new("Ada", 37)
        registry.implement("Printable", "Person")
        expect(accept_printable(registry, person)).to_equal("Ada (37)")

    it "trait_bounds_and_generics_8":
        val registry = TraitRegistry.new()
        val person = Person.new("Ada", 37)
        registry.implement("Printable", "Person")
        registry.implement("Debuggable", "Person")
        expect(accept_printable_and_debuggable(registry, person)).to_contain("Ada (37)")
        expect(where_clause_accepts(registry, person)).to_equal(true)

    it "trait_bounds_and_generics_9":
        val registry = TraitRegistry.new()
        val person = Person.new("Ada", 37)
        registry.implement("Printable", "Person")
        registry.implement("Debuggable", "Person")
        expect(where_clause_accepts(registry, person)).to_equal(true)

    it "trait_inheritance_10":
        val registry = TraitRegistry.new()
        registry.define_trait("Printable")
        registry.define_trait("Drawable")
        registry.inherit("Drawable", "Printable")
        expect(registry.inherits("Drawable", "Printable")).to_equal(true)

    it "associated_types_11":
        val registry = TraitRegistry.new()
        registry.set_assoc("Container", "Item")
        expect(registry.assoc_type_for("Container")).to_equal("Item")

    it "trait_objects_and_collections_12":
        val items = [
            TraitObject.new("Printable", "one"),
            TraitObject.new("Debuggable", "two")
        ]
        expect(trait_object_list_description(items)).to_equal("one,debug:two")

    it "common_standard_traits_13":
        val left = Record.new("alpha", 3)
        val right = Record.new("alpha", 3)
        expect(left.equals(right)).to_equal(true)
        expect(left.clone_record().debug_text()).to_equal("Record(alpha, 3)")
        expect(left.hash_value()).to_equal(right.hash_value())

    it "note_on_semantic_types_14":
        val left = SemanticMeters.new(3)
        val right = SemanticMeters.new(7)
        expect(left.add(right).as_text()).to_equal("10m")

    it "interface_bindings_static_polymorphism_15":
        val registry = TraitRegistry.new()
        registry.bind("Printable", "Person")
        expect(registry.has_binding("Printable", "Person")).to_equal(true)
        expect(dispatch_mode(registry, "Printable")).to_equal("static")

    it "interface_bindings_static_polymorphism_16":
        val registry = TraitRegistry.new()
        registry.bind("Logger", "ConsoleLogger")
        expect(registry.has_binding("Logger", "ConsoleLogger")).to_equal(true)
        val logger = Logger.new("[info] ")
        expect(logger.log("ready")).to_equal("[info] ready")

    it "collection_traits_17":
        val seq = SequenceBox.new()
        seq.add("a")
        seq.add("b")
        expect(seq.len()).to_equal(2)
        expect(seq.join(",")).to_equal("a,b")

    it "inherent_impl_blocks_18":
        val point = Point.new(2, 3)
        expect(point.manhattan()).to_equal(5)
        expect(point.shift(1, 1).debug_text()).to_equal("Point(3, 4)")

    it "inherent_impl_blocks_19":
        val text_box = WrapperText.new("hello")
        expect(text_box.unwrap_text()).to_equal("hello")

    it "inherent_impl_blocks_20":
        val person = Person.new("Ada", 37)
        val boxed = NewtypePerson.new(person)
        expect(boxed.display()).to_equal("Ada (37)")

    it "inherent_impl_blocks_21":
        val slice = SliceBox.new()
        slice.push("x")
        slice.push("y")
        expect(slice.first()).to_equal("x")
        expect(slice.len()).to_equal(2)

    it "inherent_impl_blocks_22":
        val person = Person.new("Ada", 37)
        expect(person.printable()).to_equal("Ada (37)")
        expect(person.debug_text()).to_contain("Person")

    it "trait_coherence_rules_23":
        expect(can_orphan_implement("external", "local")).to_equal(true)
        expect(can_orphan_implement("external", "external")).to_equal(false)

    it "trait_coherence_rules_24":
        val registry = TraitRegistry.new()
        expect(registry.implement("Printable", "Person")).to_equal(true)
        expect(registry.implement("Printable", "Person")).to_equal(false)

    it "trait_coherence_rules_25":
        val registry = TraitRegistry.new()
        expect(registry.add_specialization("Printable", "Admin")).to_equal(true)
        expect(registry.has_specialization("Printable", "Admin")).to_equal(true)

    it "trait_coherence_rules_26":
        val registry = TraitRegistry.new()
        expect(registry.add_blanket("Printable")).to_equal(true)
        expect(registry.is_blanket("Printable")).to_equal(true)

    it "trait_coherence_rules_27":
        val registry = TraitRegistry.new()
        registry.set_assoc("Container", "Item")
        expect(registry.assoc_type_for("Container")).to_equal("Item")

    it "trait_coherence_rules_28":
        val registry = TraitRegistry.new()
        registry.mark_marker("Clone")
        expect(registry.is_marker("Clone")).to_equal(true)
        expect(registry.is_marker("Display")).to_equal(false)

    it "trait_coherence_rules_29":
        val person = Person.new("Ada", 37)
        val newtype = NewtypePerson.new(person)
        expect(newtype.display()).to_equal("Ada (37)")

    it "trait_coherence_rules_30":
        val registry = TraitRegistry.new()
        registry.define_trait("Printable")
        registry.implement("Printable", "Person")
        expect(registry.has_impl("Printable", "Person")).to_equal(true)

    it "trait_coherence_rules_31":
        val person = Person.new("Ada", 37)
        expect(person.clone_name()).to_equal("Ada")
        expect(person.same_as(Person.new("Ada", 37))).to_equal(true)

    it "related_specifications_32":
        val registry = TraitRegistry.new()
        expect(registry.has_impl("Private", "Secret")).to_equal(false)
        expect(registry.has_trait("Private")).to_equal(false)

    it "related_specifications_33":
        val registry = TraitRegistry.new()
        registry.add_blanket("Printable")
        registry.implement("Printable", "Any")
        expect(registry.is_blanket("Printable")).to_equal(true)
        expect(registry.has_impl("Printable", "Any")).to_equal(true)

    it "related_specifications_34":
        val serializer = Serializer.new()
        serializer.exclude("DisplayOnly")
        val record = Record.new("alpha", 3)
        expect(serialize_record(serializer, "DisplayOnly", record)).to_equal("excluded")

    it "related_specifications_35":
        val registry = TraitRegistry.new()
        registry.mark_marker("Send")
        expect(registry.is_marker("Send")).to_equal(true)
        expect(registry.is_marker("Display")).to_equal(false)

    it "related_specifications_36":
        val registry = TraitRegistry.new()
        registry.define_trait("Printable")
        registry.implement("Printable", "Person")
        registry.add_specialization("Printable", "Admin")
        expect(registry.has_impl("Printable", "Person")).to_equal(true)
        expect(registry.has_specialization("Printable", "Admin")).to_equal(true)
