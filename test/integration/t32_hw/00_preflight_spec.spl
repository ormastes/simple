# T32 Hardware Preflight Checks
#
# Validates that the T32 environment is properly configured before
# running heavier hardware integration tests. Each test is isolated
# (fresh_per_test) -- no session state is shared between tests.
#
# @session-kind: trace32_board
# @tag: t32_hw
# @reuse: fresh_per_test

use std.spipe.{describe, context, it, expect}
use test.integration.t32_hw.t32_hw_helpers.{
    t32_hw_probe_available, t32_hw_t32rem_available, t32_hw_relay_available,
    t32_hw_query_version, t32_hw_connect, t32_hw_run_cmd, t32_hw_eval,
    t32_hw_relay_power_on, t32_hw_relay_power_off, t32_hw_relay_power_reset,
    t32_hw_relay_power_state, t32_hw_host, t32_hw_port,
    T32_HW_MIN_VERSION_OLD, T32_HW_MIN_VERSION_NEW
}

describe "T32 hardware preflight":
    context "tool availability":
        it "detects T32 installation":
            val available = t32_hw_t32rem_available()
            expect(available).to_equal(true)

        it "T32 RCL port is reachable":
            val reachable = t32_hw_probe_available()
            expect(reachable).to_equal(true)

    context "version checks":
        it "queries T32 version":
            val version = t32_hw_query_version()
            expect(version).to_be_greater_than(0)

        it "version meets OLD tool minimum":
            val version = t32_hw_query_version()
            expect(version).to_be_greater_than(T32_HW_MIN_VERSION_OLD - 1)

    context "relay infrastructure":
        it "relay scripts accessible":
            val available = t32_hw_relay_available()
            expect(available).to_equal(true)
