# T32 Hardware -- Session List / Info
#
# Verifies that an open session responds to basic queries: PING,
# VERSION.BUILD(), and SYStem.MODE().
#
# @session-kind: trace32_board
# @target: arm
# @tag: t32_hw, old_tools
# @reuse: exclusive_reused

use std.sspec.{describe, context, it, expect, before_all, after_all}
use test.integration.t32_hw.t32_hw_helpers.{
    t32_hw_probe_available, t32_hw_connect, t32_hw_run_cmd, t32_hw_eval,
    t32_hw_host, t32_hw_port
}

describe "T32 session list info":
    var client = nil

    before_all:
        val result = t32_hw_connect()
        match result:
            Ok(c): client = c
            Err(e): expect("connect failed: {e}").to_equal("")

    after_all:
        if client != nil:
            client.disconnect()

    context "session responsiveness":
        it "session responds after open":
            val ping = t32_hw_run_cmd(client, "PING")
            match ping:
                Ok(_): expect("ping ok").to_contain("ok")
                Err(e): expect("PING failed: {e}").to_equal("")

        it "eval works on open session":
            val result = t32_hw_eval(client, "VERSION.BUILD()")
            match result:
                Ok(v):
                    expect(v.len()).to_be_greater_than(0)
                Err(e):
                    expect("eval failed: {e}").to_equal("")

        it "can query system mode":
            val result = t32_hw_eval(client, "SYStem.MODE()")
            match result:
                Ok(_): expect("eval ok").to_contain("ok")
                Err(e): expect("SYStem.MODE failed: {e}").to_equal("")
