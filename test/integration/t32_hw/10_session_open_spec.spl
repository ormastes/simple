# T32 Hardware -- Session Open
#
# Verifies that a T32 session can be opened and remains connected,
# and that the client reflects the configured host and port.
#
# @session-kind: trace32_board
# @target: arm
# @tag: t32_hw, old_tools
# @reuse: exclusive_reused

use std.spipe.{describe, context, it, expect, before_all, after_all}
use test.integration.t32_hw.t32_hw_helpers.{
    t32_hw_probe_available, t32_hw_connect, t32_hw_run_cmd, t32_hw_eval,
    t32_hw_host, t32_hw_port
}

describe "T32 session open":
    var client = nil

    before_all:
        val result = t32_hw_connect()
        match result:
            Ok(c): client = c
            Err(e): expect("connect failed: {e}").to_equal("")

    after_all:
        if client != nil:
            client.disconnect()

    context "connection state":
        it "opens session and stays connected":
            expect(client != nil).to_equal(true)
            val ping = t32_hw_run_cmd(client, "PING")
            match ping:
                Ok(_): expect("ping ok").to_contain("ok")
                Err(e): expect("ping failed: {e}").to_equal("")

        it "session has correct host":
            expect(client.host).to_equal(t32_hw_host())

        it "session has correct port":
            expect(client.port).to_equal(t32_hw_port())
