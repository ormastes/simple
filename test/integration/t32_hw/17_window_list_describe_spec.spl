# T32 Hardware -- Window List / Describe
#
# Tests opening T32 windows (Register, Data.dump) and querying
# window position via WinPOS.
#
# @session-kind: trace32_board
# @target: arm
# @tag: t32_hw, old_tools
# @reuse: exclusive_reused

use std.sspec.{describe, context, it, expect, before_all, after_all}
use test.integration.t32_hw.t32_hw_helpers.{
    t32_hw_probe_available, t32_hw_connect, t32_hw_run_cmd, t32_hw_eval,
    t32_hw_host, t32_hw_port
}

describe "T32 window list describe":
    var client = nil

    before_all:
        val result = t32_hw_connect()
        match result:
            Ok(c): client = c
            Err(e): expect("connect failed: {e}").to_equal("")

    after_all:
        if client != nil:
            client.disconnect()

    context "window operations":
        it "window open Register":
            val result = t32_hw_run_cmd(client, "Register")
            match result:
                Ok(_): expect("cmd ok").to_contain("ok")
                Err(e): expect("Register window failed: {e}").to_equal("")

        it "window open Data.dump":
            val result = t32_hw_run_cmd(client, "Data.dump")
            match result:
                Ok(_): expect("cmd ok").to_contain("ok")
                Err(e): expect("Data.dump window failed: {e}").to_equal("")

        it "WinPOS query works":
            val result = t32_hw_run_cmd(client, "WinPOS")
            match result:
                Ok(_): expect("cmd ok").to_contain("ok")
                Err(e): expect("WinPOS failed: {e}").to_equal("")
