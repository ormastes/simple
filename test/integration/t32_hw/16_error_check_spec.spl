# T32 Hardware -- Error Check
#
# Tests the T32 error reporting mechanism: MESSAGE.STRing() after
# clean state, after a bad command, and MESSAGE.NUMber() queryability.
#
# @session-kind: trace32_board
# @target: arm
# @tag: t32_hw, old_tools
# @reuse: exclusive_reused

use std.spipe.{describe, context, it, expect, before_all, after_all}
use test.integration.t32_hw.t32_hw_helpers.{
    t32_hw_probe_available, t32_hw_connect, t32_hw_run_cmd, t32_hw_eval,
    t32_hw_host, t32_hw_port
}

describe "T32 error check":
    var client = nil

    before_all:
        val result = t32_hw_connect()
        match result:
            Ok(c): client = c
            Err(e): expect("connect failed: {e}").to_equal("")

    after_all:
        if client != nil:
            client.disconnect()

    context "error state queries":
        it "error check after clean state":
            val result = t32_hw_eval(client, "MESSAGE.STRing()")
            match result:
                Ok(_): expect("eval ok").to_contain("ok")
                Err(e): expect("MESSAGE.STRing failed: {e}").to_equal("")

        it "forces error via bad cmd":
            # Run invalid command to produce an error
            val _ = t32_hw_run_cmd(client, "NONEXISTENT.COMMAND.12345")
            # Then query the error message
            val result = t32_hw_eval(client, "MESSAGE.STRing()")
            match result:
                Ok(v):
                    # After a bad command, message string should be non-empty
                    expect(v.len()).to_be_greater_than(0)
                Err(e):
                    expect("MESSAGE.STRing after bad cmd failed: {e}").to_equal("")

        it "error state is queryable":
            val result = t32_hw_eval(client, "MESSAGE.NUMber()")
            match result:
                Ok(_): expect("eval ok").to_contain("ok")
                Err(e): expect("MESSAGE.NUMber failed: {e}").to_equal("")
