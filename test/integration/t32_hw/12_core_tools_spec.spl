# T32 Hardware -- Core Tools
#
# Tests fundamental T32 queries: CPU type, system state, and debug mode.
# These are the oldest, most stable PRACTICE commands.
#
# @session-kind: trace32_board
# @target: arm
# @tag: t32_hw, old_tools
# @reuse: exclusive_reused

use std.sspec.{describe, context, it, expect, before_all, after_all}
use test.integration.t32_hw.t32_hw_helpers.{
    t32_hw_probe_available, t32_hw_connect, t32_hw_run_cmd, t32_hw_eval,
    t32_hw_host, t32_hw_port
}

describe "T32 core tools":
    var client = nil

    before_all:
        val result = t32_hw_connect()
        match result:
            Ok(c): client = c
            Err(e): expect("connect failed: {e}").to_equal("")

    after_all:
        if client != nil:
            client.disconnect()

    context "CPU and state queries":
        it "queries CPU type":
            val result = t32_hw_run_cmd(client, "PRINT CPU()")
            match result:
                Ok(_): expect(true).to_equal(true)
                Err(e): expect("CPU query failed: {e}").to_equal("")

        it "queries system state":
            val result = t32_hw_eval(client, "STATE.RUN()")
            match result:
                Ok(_): expect(true).to_equal(true)
                Err(e): expect("STATE.RUN failed: {e}").to_equal("")

        it "queries debug mode":
            val result = t32_hw_eval(client, "DEBUGMODE()")
            match result:
                Ok(_): expect(true).to_equal(true)
                Err(e): expect("DEBUGMODE failed: {e}").to_equal("")
