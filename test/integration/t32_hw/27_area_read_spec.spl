# T32 Hardware -- AREA Read
#
# Creates, selects, writes to, and reads from a T32 AREA buffer.
# Verifies the full AREA lifecycle through the remote interface.
#
# @session-kind: trace32_board
# @target: arm
# @tag: t32_hw, new_tools
# @reuse: exclusive_reused

use std.sspec.{describe, context, it, expect, before_all, after_all}
use test.integration.t32_hw.t32_hw_helpers.{
    t32_hw_probe_available, t32_hw_connect, t32_hw_run_cmd, t32_hw_eval,
    t32_hw_host, t32_hw_port, t32_hw_version_gate_new,
    t32_hw_relay_power_on, t32_hw_relay_power_off, t32_hw_relay_power_state
}

describe "T32 AREA read":
    var client = nil

    before_all:
        val result = t32_hw_connect()
        match result:
            Ok(c): client = c
            Err(e): expect("connect failed: {e}").to_equal("")

    after_all:
        if client != nil:
            client.disconnect()

    context "AREA lifecycle":
        it "creates AREA buffer":
            val result = t32_hw_run_cmd(client, "AREA.Create T32_HW_AREA")
            match result:
                Ok(_): expect(true).to_equal(true)
                Err(e): expect("AREA.Create failed: {e}").to_equal("")

        it "selects AREA buffer":
            t32_hw_run_cmd(client, "AREA.Create T32_HW_AREA")
            val result = t32_hw_run_cmd(client, "AREA.Select T32_HW_AREA")
            match result:
                Ok(_): expect(true).to_equal(true)
                Err(e): expect("AREA.Select failed: {e}").to_equal("")

        it "writes to AREA":
            t32_hw_run_cmd(client, "AREA.Create T32_HW_AREA")
            t32_hw_run_cmd(client, "AREA.Select T32_HW_AREA")
            val result = t32_hw_run_cmd(client, "PRINT \"hw_test_output\"")
            match result:
                Ok(_): expect(true).to_equal(true)
                Err(e): expect("PRINT to AREA failed: {e}").to_equal("")

        it "AREA.view reads buffer":
            t32_hw_run_cmd(client, "AREA.Create T32_HW_AREA")
            t32_hw_run_cmd(client, "AREA.Select T32_HW_AREA")
            t32_hw_run_cmd(client, "PRINT \"hw_test_output\"")
            val result = t32_hw_run_cmd(client, "AREA.view")
            match result:
                Ok(_): expect(true).to_equal(true)
                Err(e): expect("AREA.view failed: {e}").to_equal("")
