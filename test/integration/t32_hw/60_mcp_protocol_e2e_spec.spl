# T32 MCP Protocol — End-to-End JSON-RPC Message Tests
#
# Validates JSON-RPC message construction and response structure
# for the T32 MCP server protocol layer. Tests the full message
# format without requiring a live T32 connection: builds request
# strings, validates their structure, and checks response templates.
#
# @session-kind: none
# @tag: t32_hw, mcp_protocol
# @reuse: fresh_per_test

use std.sspec.{describe, context, it, expect}

# ============================================================================
# JSON Helpers (inline, no external dependency)
# ============================================================================

fn Q() -> text: "\""
fn LB() -> text: "{"
fn RB() -> text: "}"
fn SB_L() -> text: "["
fn SB_R() -> text: "]"

fn js(s: text) -> text:
    Q() + s + Q()

fn jp(k: text, v: text) -> text:
    Q() + k + Q() + ":" + v

fn jo1(a: text) -> text:
    LB() + a + RB()

fn jo2(a: text, b: text) -> text:
    LB() + a + "," + b + RB()

fn jo3(a: text, b: text, c: text) -> text:
    LB() + a + "," + b + "," + c + RB()

fn jo4(a: text, b: text, c: text, d: text) -> text:
    LB() + a + "," + b + "," + c + "," + d + RB()

# ============================================================================
# JSON-RPC Request Builders
# ============================================================================

fn jsonrpc_request(id: i64, method: text, params: text) -> text:
    """Build a JSON-RPC 2.0 request with optional params."""
    if params != "":
        return jo4(
            jp("jsonrpc", js("2.0")),
            jp("id", str(id)),
            jp("method", js(method)),
            jp("params", params)
        )
    jo3(
        jp("jsonrpc", js("2.0")),
        jp("id", str(id)),
        jp("method", js(method))
    )

fn tools_call_request(id: i64, tool_name: text, args: text) -> text:
    """Build a tools/call JSON-RPC request."""
    val params = jo2(jp("name", js(tool_name)), jp("arguments", args))
    jsonrpc_request(id, "tools/call", params)

fn initialize_request(id: i64) -> text:
    """Build an initialize JSON-RPC request."""
    val caps = jo1(jp("roots", jo1(jp("listChanged", "true"))))
    val client_info = jo2(jp("name", js("test-client")), jp("version", js("1.0.0")))
    val params = jo3(
        jp("protocolVersion", js("2025-06-18")),
        jp("capabilities", caps),
        jp("clientInfo", client_info)
    )
    jsonrpc_request(id, "initialize", params)

fn tools_list_request(id: i64) -> text:
    """Build a tools/list JSON-RPC request."""
    jsonrpc_request(id, "tools/list", "")

fn notification(method: text) -> text:
    """Build a JSON-RPC notification (no id)."""
    jo2(jp("jsonrpc", js("2.0")), jp("method", js(method)))

# ============================================================================
# JSON-RPC Response Builders (mock responses for validation)
# ============================================================================

fn jsonrpc_result_response(id: i64, result: text) -> text:
    """Build a JSON-RPC 2.0 result response."""
    jo3(
        jp("jsonrpc", js("2.0")),
        jp("id", str(id)),
        jp("result", result)
    )

fn jsonrpc_error_response(id: i64, code: i64, message: text) -> text:
    """Build a JSON-RPC 2.0 error response."""
    val error_obj = jo2(jp("code", str(code)), jp("message", js(message)))
    jo3(
        jp("jsonrpc", js("2.0")),
        jp("id", str(id)),
        jp("error", error_obj)
    )

fn tool_result_content(text_value: text) -> text:
    """Build MCP tool result content array with a single text item."""
    val item = jo2(jp("type", js("text")), jp("text", js(text_value)))
    jo1(jp("content", SB_L() + item + SB_R()))

