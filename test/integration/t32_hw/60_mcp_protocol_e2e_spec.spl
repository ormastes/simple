# ============================================================================

describe "MCP Protocol -- JSON-RPC Message Construction":
    context "initialize":
        it "builds valid initialize request":
            val req = initialize_request(1)
            expect(req).to_contain("\"jsonrpc\":\"2.0\"")
            expect(req).to_contain("\"method\":\"initialize\"")
            expect(req).to_contain("\"id\":1")

        it "initialize request has correct method":
            val req = initialize_request(1)
            expect(req).to_contain("\"method\":\"initialize\"")

        it "initialize request has jsonrpc 2.0":
            val req = initialize_request(1)
            expect(req).to_start_with("{")
            expect(req).to_contain("\"jsonrpc\":\"2.0\"")

        it "initialize request includes protocol version":
            val req = initialize_request(1)
            expect(req).to_contain("\"protocolVersion\":\"2025-06-18\"")

        it "initialize request includes client info":
            val req = initialize_request(1)
            expect(req).to_contain("\"clientInfo\":")
            expect(req).to_contain("\"name\":\"test-client\"")
            expect(req).to_contain("\"version\":\"1.0.0\"")

    context "tools/list":
        it "builds valid tools/list request":
            val req = tools_list_request(2)
            expect(req).to_contain("\"method\":\"tools/list\"")
            expect(req).to_contain("\"id\":2")
            expect(req).to_contain("\"jsonrpc\":\"2.0\"")

        it "tools/list request has no params when empty":
            val req = tools_list_request(2)
            # Should have 3 fields: jsonrpc, id, method -- no params
            val has_params = req.contains("\"params\"")
            expect(has_params).to_equal(false)

    context "notifications":
        it "builds initialized notification":
            val notif = notification("notifications/initialized")
            expect(notif).to_contain("\"method\":\"notifications/initialized\"")
            expect(notif).to_contain("\"jsonrpc\":\"2.0\"")

        it "notification has no id field":
            val notif = notification("notifications/initialized")
            val has_id = notif.contains("\"id\"")
            expect(has_id).to_equal(false)

