# ============================================================================
# Validation Helpers
# ============================================================================

fn is_valid_identifier(name: text) -> bool:
    """Check if a tool name is a valid identifier (alphanumeric + underscore)."""
    if name.len() == 0:
        return false
    var i = 0
    while i < name.len():
        val ch = name.substring(i, i + 1)
        val valid = (ch >= "a" and ch <= "z") or (ch >= "A" and ch <= "Z") or (ch >= "0" and ch <= "9") or ch == "_"
        if not valid:
            return false
        i = i + 1
    true

fn has_duplicates(names: [text]) -> bool:
    """Check if a list has any duplicate entries."""
    var i = 0
    while i < names.len():
        var j = i + 1
        while j < names.len():
            if names[i] == names[j]:
                return true
            j = j + 1
        i = i + 1
    false

