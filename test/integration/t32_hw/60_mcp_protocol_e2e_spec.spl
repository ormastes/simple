describe "MCP Protocol -- Response Validation":
    context "JSON-RPC response structure":
        it "result response has jsonrpc field":
            val resp = jsonrpc_result_response(1, js("ok"))
            expect(resp).to_contain("\"jsonrpc\":\"2.0\"")

        it "result response has id field":
            val resp = jsonrpc_result_response(42, js("ok"))
            expect(resp).to_contain("\"id\":42")

        it "result response has result field":
            val resp = jsonrpc_result_response(1, js("hello"))
            expect(resp).to_contain("\"result\":\"hello\"")

        it "result response is valid JSON object":
            val resp = jsonrpc_result_response(1, js("ok"))
            expect(resp).to_start_with("{")
            expect(resp).to_end_with("}")

        it "error response has error object":
            val resp = jsonrpc_error_response(1, -32600, "Invalid Request")
            expect(resp).to_contain("\"error\":")

        it "error response has code and message":
            val resp = jsonrpc_error_response(1, -32601, "Method not found")
            expect(resp).to_contain("\"code\":-32601")
            expect(resp).to_contain("\"message\":\"Method not found\"")

        it "error response has jsonrpc and id":
            val resp = jsonrpc_error_response(5, -32602, "Invalid params")
            expect(resp).to_contain("\"jsonrpc\":\"2.0\"")
            expect(resp).to_contain("\"id\":5")

    context "tool result structure":
        it "tool result has content array":
            val result = tool_result_content("session opened")
            expect(result).to_contain("\"content\":[")

        it "content item has type text":
            val result = tool_result_content("session opened")
            expect(result).to_contain("\"type\":\"text\"")

        it "content item has text field":
            val result = tool_result_content("session opened")
            expect(result).to_contain("\"text\":\"session opened\"")

        it "tool result wrapped in response has all fields":
            val content = tool_result_content("done")
            val resp = jsonrpc_result_response(99, content)
            expect(resp).to_contain("\"jsonrpc\":\"2.0\"")
            expect(resp).to_contain("\"id\":99")
            expect(resp).to_contain("\"result\":")
            expect(resp).to_contain("\"content\":[")
            expect(resp).to_contain("\"type\":\"text\"")

    context "standard JSON-RPC error codes":
        it "parse error uses code -32700":
            val resp = jsonrpc_error_response(1, -32700, "Parse error")
            expect(resp).to_contain("\"code\":-32700")

        it "invalid request uses code -32600":
            val resp = jsonrpc_error_response(1, -32600, "Invalid Request")
            expect(resp).to_contain("\"code\":-32600")

        it "method not found uses code -32601":
            val resp = jsonrpc_error_response(1, -32601, "Method not found")
            expect(resp).to_contain("\"code\":-32601")

        it "invalid params uses code -32602":
            val resp = jsonrpc_error_response(1, -32602, "Invalid params")
            expect(resp).to_contain("\"code\":-32602")

describe "MCP Protocol -- Request Structure Integrity":
    context "request JSON structure":
        it "request starts with open brace":
            val req = jsonrpc_request(1, "test", "")
            expect(req).to_start_with("{")

        it "request ends with close brace":
            val req = jsonrpc_request(1, "test", "")
            expect(req).to_end_with("}")

        it "request with params includes params field":
            val req = jsonrpc_request(1, "test", jo1(jp("key", js("val"))))
            expect(req).to_contain("\"params\":")

        it "request without params omits params field":
            val req = jsonrpc_request(1, "test", "")
            val has_params = req.contains("\"params\"")
            expect(has_params).to_equal(false)

        it "tools/call request nests name inside params":
            val req = tools_call_request(1, "t32_eval", jo1(jp("expression", js("1+1"))))
            expect(req).to_contain("\"params\":")
            expect(req).to_contain("\"name\":\"t32_eval\"")
            expect(req).to_contain("\"arguments\":")

        it "request id increments correctly":
            val r1 = jsonrpc_request(100, "a", "")
            val r2 = jsonrpc_request(101, "b", "")
            expect(r1).to_contain("\"id\":100")
            expect(r2).to_contain("\"id\":101")

    context "Content-Length framing":
        it "message can be framed with Content-Length header":
            val body = jsonrpc_request(1, "initialize", "")
            val framed = "Content-Length: " + str(body.len()) + "\r\n\r\n" + body
            expect(framed).to_start_with("Content-Length: ")
            expect(framed).to_contain("\r\n\r\n")
            expect(framed).to_end_with("}")

        it "Content-Length value matches body length":
            val body = jsonrpc_request(1, "test", "")
            val length_str = str(body.len())
            val framed = "Content-Length: " + length_str + "\r\n\r\n" + body
            # Extract the header portion
            expect(framed).to_contain("Content-Length: " + length_str)

describe "MCP Protocol -- All 36 Tool Names":
    it "all tool names are valid identifiers":
        var all_valid = true
        for name in FULL_TOOLS:
            if not is_valid_identifier(name):
                all_valid = false
        expect(all_valid).to_equal(true)

    it "no duplicate tool names":
        val has_dups = has_duplicates(FULL_TOOLS)
        expect(has_dups).to_equal(false)

    it "tool count is 36":
        expect(FULL_TOOLS.len()).to_equal(36)

    it "all tools start with t32_ prefix":
        var all_prefixed = true
        for name in FULL_TOOLS:
            if not name.starts_with("t32_"):
                all_prefixed = false
        expect(all_prefixed).to_equal(true)

    it "session tools are present":
        var found_list = false
        var found_open = false
        var found_close = false
        var found_resume = false
        for name in FULL_TOOLS:
            if name == "t32_sessions_list": found_list = true
            if name == "t32_session_open": found_open = true
            if name == "t32_session_close": found_close = true
            if name == "t32_session_resume": found_resume = true
        expect(found_list).to_equal(true)
        expect(found_open).to_equal(true)
        expect(found_close).to_equal(true)
        expect(found_resume).to_equal(true)

    it "window tools are present":
        var found_list = false
        var found_open = false
        var found_capture = false
        var found_describe = false
        for name in FULL_TOOLS:
            if name == "t32_window_list": found_list = true
            if name == "t32_window_open": found_open = true
            if name == "t32_window_capture": found_capture = true
            if name == "t32_window_describe": found_describe = true
        expect(found_list).to_equal(true)
        expect(found_open).to_equal(true)
        expect(found_capture).to_equal(true)
        expect(found_describe).to_equal(true)

    it "dialog tools are present":
        var found_parse = false
        var found_get = false
        var found_set = false
        var found_click = false
        for name in FULL_TOOLS:
            if name == "t32_dialog_parse": found_parse = true
            if name == "t32_dialog_get": found_get = true
            if name == "t32_dialog_set": found_set = true
            if name == "t32_dialog_click": found_click = true
        expect(found_parse).to_equal(true)
        expect(found_get).to_equal(true)
        expect(found_set).to_equal(true)
        expect(found_click).to_equal(true)

    it "job tools are present":
        var found_list = false
        var found_get = false
        var found_cancel = false
        var found_result = false
        for name in FULL_TOOLS:
            if name == "t32_job_list": found_list = true
            if name == "t32_job_get": found_get = true
            if name == "t32_job_cancel": found_cancel = true
            if name == "t32_job_result": found_result = true
        expect(found_list).to_equal(true)
        expect(found_get).to_equal(true)
        expect(found_cancel).to_equal(true)
        expect(found_result).to_equal(true)

    it "each tool can build a valid tools/call request":
        var all_valid = true
        var idx: i64 = 100
        for name in FULL_TOOLS:
            val req = tools_call_request(idx, name, jo1(jp("dummy", js("x"))))
            val has_method = req.contains("\"method\":\"tools/call\"")
            val has_name = req.contains("\"name\":\"" + name + "\"")
            val has_jsonrpc = req.contains("\"jsonrpc\":\"2.0\"")
            if not has_method or not has_name or not has_jsonrpc:
                all_valid = false
            idx = idx + 1
        expect(all_valid).to_equal(true)
