# T32 Hardware -- Window Open / Capture
#
# Tests opening a Register window with SpotLight, capturing register
# text, reading all registers, and reading a specific register (PC).
#
# @session-kind: trace32_board
# @target: arm
# @tag: t32_hw, old_tools
# @reuse: exclusive_reused

use std.sspec.{describe, context, it, expect, before_all, after_all}
use test.integration.t32_hw.t32_hw_helpers.{
    t32_hw_probe_available, t32_hw_connect, t32_hw_run_cmd, t32_hw_eval,
    t32_hw_host, t32_hw_port
}

describe "T32 window open capture":
    var client = nil

    before_all:
        val result = t32_hw_connect()
        match result:
            Ok(c): client = c
            Err(e): expect("connect failed: {e}").to_equal("")

    after_all:
        if client != nil:
            client.disconnect()

    context "register window capture":
        it "opens Register window":
            val result = t32_hw_run_cmd(client, "Register /SpotLight")
            match result:
                Ok(_): expect("cmd ok").to_contain("ok")
                Err(e): expect("Register /SpotLight failed: {e}").to_equal("")

        it "captures Register text":
            val result = t32_hw_run_cmd(client, "Register /All")
            match result:
                Ok(v):
                    expect(v.len()).to_be_greater_than(0)
                Err(e):
                    expect("Register /All failed: {e}").to_equal("")

    context "register read API":
        it "read_all_registers returns data":
            val result = client.read_all_registers()
            match result:
                Ok(regs):
                    expect(regs.len()).to_be_greater_than(0)
                Err(e):
                    expect("read_all_registers failed: {e}").to_equal("")

        it "read PC register":
            val result = client.read_register("PC")
            match result:
                Ok(v):
                    expect(v.len()).to_be_greater_than(0)
                Err(e):
                    expect("read_register PC failed: {e}").to_equal("")
