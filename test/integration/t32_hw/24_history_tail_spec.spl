# T32 Hardware -- History / Tail
#
# Tests PRACTICE state querying, command history, and AREA buffer
# reading to verify that command history is accessible after
# executing commands.
#
# @session-kind: trace32_board
# @target: arm
# @tag: t32_hw, new_tools
# @reuse: exclusive_reused

use std.spipe.{describe, context, it, expect, before_all, after_all}
use test.integration.t32_hw.t32_hw_helpers.{
    t32_hw_probe_available, t32_hw_connect, t32_hw_run_cmd, t32_hw_eval,
    t32_hw_host, t32_hw_port, t32_hw_version_gate_new,
    t32_hw_relay_power_on, t32_hw_relay_power_off, t32_hw_relay_power_state,
    t32_hw_has_practice_state, t32_hw_has_area
}

describe "T32 history tail":
    var client = nil

    before_all:
        val result = t32_hw_connect()
        match result:
            Ok(c): client = c
            Err(e): expect("connect failed: {e}").to_equal("")
        # Run a few commands so there is history
        t32_hw_run_cmd(client, "PRINT \"history_test_1\"")
        t32_hw_run_cmd(client, "PRINT \"history_test_2\"")

    after_all:
        if client != nil:
            client.disconnect()

    context "PRACTICE state":
        it "PRACTICE.STATE() queryable":
            if not t32_hw_has_practice_state():
                expect("PRACTICE.STATE not available in this T32 version").to_contain("not available")
                return
            val result = t32_hw_eval(client, "PRACTICE.STATE()")
            match result:
                Ok(v):
                    expect(v.len()).to_be_greater_than(0)
                Err(e):
                    expect("PRACTICE.STATE() failed: {e}").to_equal("")

    context "command history":
        it "command history exists after commands":
            # After running PRINT commands above, the session should have
            # accumulated history. We verify by running another command
            # and checking the AREA buffer is accessible.
            val result = t32_hw_run_cmd(client, "PRINT \"history_check\"")
            match result:
                Ok(_): expect("cmd ok").to_contain("ok")
                Err(e): expect("history command failed: {e}").to_equal("")

    context "AREA buffer":
        it "AREA buffer readable":
            if not t32_hw_has_area():
                expect("AREA not available in this T32 version").to_contain("not available")
                return
            val result = t32_hw_run_cmd(client, "AREA.view")
            match result:
                Ok(_): expect("cmd ok").to_contain("ok")
                Err(e): expect("AREA.view failed: {e}").to_equal("")

        it "PRINT output verifiable via command success":
            # PRINT works on all T32 versions as a universal alternative
            val result = t32_hw_run_cmd(client, "PRINT \"tail_check\"")
            match result:
                Ok(_): expect("cmd ok").to_contain("ok")
                Err(e): expect("PRINT failed: {e}").to_equal("")
