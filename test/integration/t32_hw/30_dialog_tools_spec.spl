# T32 Hardware -- Dialog Tools
#
# Tests PRACTICE dialog open/close lifecycle and PRACTICE.STATE()
# detection of dialog state. Some operations may require a CMM
# script with DIALOG commands; marked pass_todo where unavailable.
#
# @session-kind: trace32_board
# @target: arm
# @tag: t32_hw, new_tools
# @reuse: exclusive_reused

use std.sspec.{describe, context, it, expect, before_all, after_all}
use test.integration.t32_hw.t32_hw_helpers.{
    t32_hw_probe_available, t32_hw_connect, t32_hw_run_cmd, t32_hw_eval,
    t32_hw_host, t32_hw_port, t32_hw_version_gate_new,
    t32_hw_relay_power_on, t32_hw_relay_power_off, t32_hw_relay_power_state
}

describe "T32 dialog tools":
    var client = nil

    before_all:
        val result = t32_hw_connect()
        match result:
            Ok(c): client = c
            Err(e): expect("connect failed: {e}").to_equal("")

    after_all:
        if client != nil:
            # Ensure any open dialog is dismissed
            t32_hw_run_cmd(client, "DIALOG.END")
            client.disconnect()

    context "dialog lifecycle":
        it "PRACTICE dialog can be opened":
            # Opening a PRACTICE dialog requires a CMM script with DIALOG
            # commands. In headless / no-CMM environments this is not
            # available, so mark as pass_todo.
            pass_todo

        it "PRACTICE.STATE() detects dialog":
            val result = t32_hw_eval(client, "PRACTICE.STATE()")
            match result:
                Ok(v):
                    # Should return a state string (e.g., "IDLE", "RUN", "DIALOG")
                    expect(v.len()).to_be_greater_than(0)
                Err(e):
                    expect("PRACTICE.STATE() failed: {e}").to_equal("")

        it "dialog can be dismissed":
            # Dismissing requires an open dialog; mark pass_todo when
            # no CMM dialog infrastructure is available
            pass_todo

        it "PRACTICE.STATE() after dismiss":
            # After dismissing a dialog, PRACTICE.STATE() should return
            # an idle/empty state. Without dialog open/close support,
            # we verify PRACTICE.STATE() still returns a valid value.
            val result = t32_hw_eval(client, "PRACTICE.STATE()")
            match result:
                Ok(v):
                    expect(v.len()).to_be_greater_than(0)
                Err(e):
                    expect("PRACTICE.STATE() after dismiss failed: {e}").to_equal("")
