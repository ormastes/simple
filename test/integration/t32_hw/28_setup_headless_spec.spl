# T32 Hardware -- Setup Headless
#
# Verifies that core T32 operations (SYStem.Up, AREA, eval) work
# correctly when running in headless / no-GUI mode.
#
# @session-kind: trace32_board
# @target: arm
# @tag: t32_hw, new_tools
# @reuse: exclusive_reused

use std.sspec.{describe, context, it, expect, before_all, after_all}
use test.integration.t32_hw.t32_hw_helpers.{
    t32_hw_probe_available, t32_hw_connect, t32_hw_run_cmd, t32_hw_eval,
    t32_hw_host, t32_hw_port, t32_hw_version_gate_new,
    t32_hw_relay_power_on, t32_hw_relay_power_off, t32_hw_relay_power_state
}

describe "T32 setup headless":
    var client = nil

    before_all:
        val result = t32_hw_connect()
        match result:
            Ok(c): client = c
            Err(e): expect("connect failed: {e}").to_equal("")

    after_all:
        if client != nil:
            client.disconnect()

    context "headless operations":
        it "SYStem.Up in headless mode":
            val result = t32_hw_run_cmd(client, "SYStem.Up")
            match result:
                Ok(_): expect(true).to_equal(true)
                Err(e): expect("SYStem.Up failed: {e}").to_equal("")

        it "AREA operations work headless":
            val create = t32_hw_run_cmd(client, "AREA.Create T32_HEADLESS")
            match create:
                Ok(_): pass_do_nothing
                Err(e): expect("AREA.Create failed: {e}").to_equal("")
            val select = t32_hw_run_cmd(client, "AREA.Select T32_HEADLESS")
            match select:
                Ok(_): pass_do_nothing
                Err(e): expect("AREA.Select failed: {e}").to_equal("")
            val print_result = t32_hw_run_cmd(client, "PRINT \"headless_test\"")
            match print_result:
                Ok(_): pass_do_nothing
                Err(e): expect("PRINT failed: {e}").to_equal("")
            val view = t32_hw_run_cmd(client, "AREA.view")
            match view:
                Ok(_): expect(true).to_equal(true)
                Err(e): expect("AREA.view failed: {e}").to_equal("")

        it "eval works in headless":
            val result = t32_hw_eval(client, "VERSION.BUILD()")
            match result:
                Ok(v):
                    expect(v.len()).to_be_greater_than(0)
                Err(e):
                    expect("VERSION.BUILD() failed: {e}").to_equal("")
