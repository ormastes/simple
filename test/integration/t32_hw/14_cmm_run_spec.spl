# T32 Hardware -- CMM / PRACTICE Run
#
# Tests inline PRACTICE script execution via run_command: PRINT,
# AREA.Create, and AREA.Select.
#
# @session-kind: trace32_board
# @target: arm
# @tag: t32_hw, old_tools
# @reuse: exclusive_reused

use std.sspec.{describe, context, it, expect, before_all, after_all}
use test.integration.t32_hw.t32_hw_helpers.{
    t32_hw_probe_available, t32_hw_connect, t32_hw_run_cmd, t32_hw_eval,
    t32_hw_host, t32_hw_port
}

describe "T32 CMM run":
    var client = nil

    before_all:
        val result = t32_hw_connect()
        match result:
            Ok(c): client = c
            Err(e): expect("connect failed: {e}").to_equal("")

    after_all:
        if client != nil:
            client.disconnect()

    context "inline PRACTICE":
        it "runs inline PRACTICE":
            val result = t32_hw_run_cmd(client, "PRINT \"hello\"")
            match result:
                Ok(_): expect(true).to_equal(true)
                Err(e): expect("PRINT failed: {e}").to_equal("")

        it "AREA.Create succeeds":
            val result = t32_hw_run_cmd(client, "AREA.Create T32_HW_TEST")
            match result:
                Ok(_): expect(true).to_equal(true)
                Err(e): expect("AREA.Create failed: {e}").to_equal("")

        it "AREA.Select succeeds":
            val result = t32_hw_run_cmd(client, "AREA.Select T32_HW_TEST")
            match result:
                Ok(_): expect(true).to_equal(true)
                Err(e): expect("AREA.Select failed: {e}").to_equal("")
