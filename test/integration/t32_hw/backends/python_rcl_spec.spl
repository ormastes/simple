# @session-kind: trace32_board
# @target: arm
# @tag: t32_hw, backend_python_rcl
# @reuse: exclusive_reused
"""
# T32 Backend: Python RCL Bridge

Tests core T32 operations using the Python RCL bridge backend.
Requires python3 and lauterbach.trace32.rcl package.
"""

use std.sspec.*
use test.integration.t32_hw.t32_hw_helpers.{
    t32_hw_probe_available, t32_hw_python_available
}
use test.integration.t32_hw.backends._shared_backend_tests.{
    shared_test_connect_and_ping, shared_test_eval_version,
    shared_test_cmd_run, shared_test_state_query,
    shared_test_register_read, shared_test_step_and_halt,
    shared_test_error_recovery
}

describe "T32 via Python RCL backend":
    context "when Python RCL is available":
        it "python binary exists":
            if not t32_hw_python_available():
                expect("python not available").to_contain("not available")
                return
            expect(t32_hw_python_available()).to_equal(true)

        it "connects and pings":
            if not t32_hw_python_available():
                return
            shared_test_connect_and_ping()

        it "evaluates VERSION.BUILD()":
            if not t32_hw_python_available():
                return
            shared_test_eval_version()

        it "runs PRACTICE command":
            if not t32_hw_python_available():
                return
            shared_test_cmd_run()

        it "queries STATE.RUN()":
            if not t32_hw_python_available():
                return
            shared_test_state_query()

        it "reads PC register":
            if not t32_hw_python_available():
                return
            shared_test_register_read()

        it "halt-step-halt cycle":
            if not t32_hw_python_available():
                return
            shared_test_step_and_halt()

        it "recovers from error":
            if not t32_hw_python_available():
                return
            shared_test_error_recovery()
