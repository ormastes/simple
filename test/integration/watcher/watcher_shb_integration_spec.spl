# Watcher SHB Integration Specification
#
# Tests end-to-end SHB cache generation and validation through the watcher.
#
# **Feature IDs:** #WATCH-INT-001 to #WATCH-INT-010
# **Category:** Integration

# ============================================================================
# Module-level state
# ============================================================================

var shb_paths: [text] = []
var shb_hashes: [i64] = []
var src_paths: [text] = []
var src_hashes: [i64] = []
var compile_log: [text] = []

fn int_reset():
    shb_paths = []
    shb_hashes = []
    src_paths = []
    src_hashes = []
    compile_log = []

fn int_find_src(path: text) -> i64:
    val paths: [text] = src_paths
    var i = 0
    while i < paths.len():
        if paths[i] == path:
            return i
        i = i + 1
    -1

fn int_find_shb(path: text) -> i64:
    val paths: [text] = shb_paths
    var i = 0
    while i < paths.len():
        if paths[i] == path:
            return i
        i = i + 1
    -1

fn int_add_source(path: text, hash: i64):
    val idx = int_find_src(path)
    if idx >= 0:
        src_hashes[idx] = hash
    else:
        src_paths = src_paths + [path]
        src_hashes = src_hashes + [hash]

fn int_get_src_hash(idx: i64) -> i64:
    val hashes: [i64] = src_hashes
    hashes[idx]

fn int_append_compile_log(source_path: text):
    compile_log = compile_log + [source_path]

fn int_store_shb(shb_key: text, iface_hash: i64):
    val shb_idx = int_find_shb(shb_key)
    if shb_idx >= 0:
        shb_hashes[shb_idx] = iface_hash
    else:
        shb_paths = shb_paths + [shb_key]
        shb_hashes = shb_hashes + [iface_hash]

fn int_compile_shb(source_path: text) -> i64:
    int_append_compile_log(source_path)
    val src_idx = int_find_src(source_path)
    var src_hash: i64 = 0
    if src_idx >= 0:
        src_hash = int_get_src_hash(src_idx)
    val iface_hash = src_hash * 7 + 13
    var tmp = source_path.replace("/", "_")
    val shb_key = tmp.replace(".spl", ".shb")
    int_store_shb(shb_key, iface_hash)
    iface_hash

fn int_check_freshness(source_path: text) -> i64:
    # Check src first to avoid type pollution from int_find_shb
    val src_found = int_find_src(source_path)
    var tmp = source_path.replace("/", "_")
    val shb_key = tmp.replace(".spl", ".shb")
    val shb_found = int_find_shb(shb_key)
    if shb_found < 0:
        return 3  # MISSING
    if src_found < 0:
        return -1  # ERROR
    0  # FRESH

# Getter functions (direct module var reads from `it` closures return stale values)
fn int_compile_log_len() -> i64:
    compile_log.len()

fn int_shb_paths_len() -> i64:
    shb_paths.len()

# ============================================================================
# Tests
# ============================================================================

fn slow_it(name: text, block: fn()):
    it(name, block)

describe "Watcher SHB Integration":
    describe "fresh SHB cache hit":
        slow_it "skips recompilation for unchanged files":
            int_reset()
            int_add_source("src/main.spl", 12345)
            int_compile_shb("src/main.spl")
            val status = int_check_freshness("src/main.spl")
            expect(status).to_equal(0)
            # Check compile log after all array-reading operations complete
            expect(int_compile_log_len()).to_equal(1)

    describe "stale SHB detection":
        slow_it "detects missing SHB":
            int_reset()
            int_add_source("src/main.spl", 12345)
            val status = int_check_freshness("src/main.spl")
            expect(status).to_equal(3)

    describe "batch processing":
        slow_it "processes multiple files":
            int_reset()
            int_add_source("src/a.spl", 100)
            int_add_source("src/b.spl", 200)
            int_add_source("src/c.spl", 300)
            int_compile_shb("src/a.spl")
            int_compile_shb("src/b.spl")
            int_compile_shb("src/c.spl")
            expect(int_compile_log_len()).to_equal(3)
            expect(int_shb_paths_len()).to_equal(3)

    describe "dependency invalidation":
        slow_it "detects when dependency interface changes":
            int_reset()
            int_add_source("src/dep.spl", 100)
            int_add_source("src/main.spl", 200)
            val dep_hash = int_compile_shb("src/dep.spl")
            int_compile_shb("src/main.spl")
            int_add_source("src/dep.spl", 999)
            val new_dep_hash = int_compile_shb("src/dep.spl")
            expect(new_dep_hash != dep_hash).to_equal(true)
