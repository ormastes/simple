# Watcher Backend Validation Specification
#
# Tests that compiling with one backend and loading with another
# is properly detected and handled.
#
# **Feature IDs:** #WATCH-INT-021 to #WATCH-INT-030
# **Category:** Integration

# ============================================================================
# Module-level state
# ============================================================================

var ldr_paths: [text] = []
var ldr_hashes: [i64] = []
var ldr_warnings: [text] = []

fn ldr_reset():
    ldr_paths = []
    ldr_hashes = []
    ldr_warnings = []

fn ldr_find(path: text) -> i64:
    val paths: [text] = ldr_paths
    var i = 0
    while i < paths.len():
        if paths[i] == path:
            return i
        i = i + 1
    -1

fn ldr_store(path: text, options_hash: i64):
    val idx = ldr_find(path)
    if idx >= 0:
        ldr_hashes[idx] = options_hash
    else:
        ldr_paths = ldr_paths + [path]
        ldr_hashes = ldr_hashes + [options_hash]

fn ldr_load_validated(path: text, current_hash: i64) -> text:
    val idx = ldr_find(path)
    if idx < 0:
        return "missing"
    if ldr_hashes[idx] == current_hash:
        return "ok"
    ldr_warnings = ldr_warnings + ["backend mismatch for {path}"]
    "mismatch"

# Getter functions (direct module var reads from `it` closures return stale values)
fn ldr_warnings_len() -> i64:
    ldr_warnings.len()

# Mock hash computation (simple, no char_at)
fn mock_compute(backend: text, opt: i64, release: bool) -> i64:
    var bk: i64 = 0
    match backend:
        case "llvm": bk = 1
        case "cranelift": bk = 2
        case "c": bk = 3
        case _: bk = 0

    var h: i64 = bk * 100000 + opt * 10000
    if release:
        h = h + 1000
    h + bk * 7919

# ============================================================================
# Tests
# ============================================================================

fn slow_it(name: text, block: fn()):
    it(name, block)

describe "Backend Validation":
    describe "matching backends":
        slow_it "LLVM compiled, LLVM loaded":
            ldr_reset()
            val hash = mock_compute("llvm", 2, true)
            ldr_store("main.smf", hash)
            val result = ldr_load_validated("main.smf", hash)
            expect(result).to_equal("ok")
            expect(ldr_warnings_len()).to_equal(0)

        slow_it "Cranelift compiled, Cranelift loaded":
            ldr_reset()
            val hash = mock_compute("cranelift", 1, false)
            ldr_store("main.smf", hash)
            val result = ldr_load_validated("main.smf", hash)
            expect(result).to_equal("ok")
            expect(ldr_warnings_len()).to_equal(0)

    describe "mismatching backends":
        slow_it "LLVM compiled, Cranelift loaded warns":
            ldr_reset()
            val llvm_hash = mock_compute("llvm", 2, true)
            val crank_hash = mock_compute("cranelift", 2, true)
            ldr_store("main.smf", llvm_hash)
            val result = ldr_load_validated("main.smf", crank_hash)
            expect(result).to_equal("mismatch")
            expect(ldr_warnings_len()).to_equal(1)

        slow_it "Cranelift compiled, LLVM loaded warns":
            ldr_reset()
            val crank_hash = mock_compute("cranelift", 1, false)
            val llvm_hash = mock_compute("llvm", 1, false)
            ldr_store("main.smf", crank_hash)
            val result = ldr_load_validated("main.smf", llvm_hash)
            expect(result).to_equal("mismatch")
            expect(ldr_warnings_len()).to_equal(1)

    describe "opt level mismatch":
        slow_it "different opt levels detected":
            ldr_reset()
            val hash_o0 = mock_compute("llvm", 0, false)
            val hash_o3 = mock_compute("llvm", 3, false)
            ldr_store("main.smf", hash_o0)
            val result = ldr_load_validated("main.smf", hash_o3)
            expect(result).to_equal("mismatch")
            expect(ldr_warnings_len()).to_equal(1)

        slow_it "same opt level is ok":
            ldr_reset()
            val hash = mock_compute("llvm", 2, false)
            ldr_store("main.smf", hash)
            val result = ldr_load_validated("main.smf", hash)
            expect(result).to_equal("ok")

    describe "release flag mismatch":
        slow_it "debug vs release detected":
            ldr_reset()
            val debug_hash = mock_compute("llvm", 2, false)
            val release_hash = mock_compute("llvm", 2, true)
            ldr_store("main.smf", debug_hash)
            val result = ldr_load_validated("main.smf", release_hash)
            expect(result).to_equal("mismatch")

    describe "missing module":
        slow_it "reports missing for unloaded module":
            ldr_reset()
            val hash = mock_compute("llvm", 2, true)
            val result = ldr_load_validated("nonexistent.smf", hash)
            expect(result).to_equal("missing")
            expect(ldr_warnings_len()).to_equal(0)

    describe "hash stability":
        slow_it "same options always produce same hash":
            val h1 = mock_compute("cranelift", 2, true)
            val h2 = mock_compute("cranelift", 2, true)
            expect(h1).to_equal(h2)

        slow_it "different options produce different hashes":
            val h1 = mock_compute("llvm", 2, true)
            val h2 = mock_compute("cranelift", 2, true)
            expect(h1 != h2).to_equal(true)
