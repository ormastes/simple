"""
# RV32IMAC Compliance Test Harness

**Feature IDs:** #RV32-COMPLIANCE-001
**Category:** Hardware
**Difficulty:** 4/5
**Status:** In Progress

## Overview

Harness for running riscv-arch-test compliance suite.
Compiles test programs, loads into simulation ROM, and compares signatures.
"""

# @req REQ-RV32IMAC
# @feature rv32imac
# tag: only-compiled, vhdl, slow

use std.spec.*

use hardware.rv64gc.core.rv64_execute.alu_execute
use hardware.rv64gc.ext.rv64_muldiv.muldiv_execute
use hardware.rv64gc.ext.rv64_atomics.{ReservationSet64, amo_execute}
use hardware.riscv_common.pkg.riscv_types_pkg.{AluOp, MulDivOp, AmoOp}

describe "RV32I Compliance":
    """
    ## RV32I Base Integer Instruction Set

    Tests all RV32I instructions using computed expected values.
    """

    it "ADD: rd = rs1 + rs2":
        expect alu_execute(AluOp.Add, 100, 200) == 300
        expect alu_execute(AluOp.Add, 0xFFFFFFFF, 1) == 0

    it "SUB: rd = rs1 - rs2":
        expect alu_execute(AluOp.Sub, 200, 100) == 100
        expect alu_execute(AluOp.Sub, 0, 1) == 0xFFFFFFFF

    it "AND/OR/XOR: bitwise operations":
        expect alu_execute(AluOp.And, 0xF0F0, 0xFF00) == 0xF000
        expect alu_execute(AluOp.Or, 0xF0F0, 0x0F0F) == 0xFFFF
        expect alu_execute(AluOp.Xor, 0xFFFF, 0xF0F0) == 0x0F0F

    it "SLL/SRL/SRA: shift operations":
        expect alu_execute(AluOp.Sll, 1, 10) == 1024
        expect alu_execute(AluOp.Srl, 1024, 10) == 1

    it "SLT/SLTU: comparison operations":
        # Signed: -1 < 0
        expect alu_execute(AluOp.Slt, 0xFFFFFFFF, 0) == 1
        # Unsigned: 0xFFFFFFFF > 0
        expect alu_execute(AluOp.Sltu, 0xFFFFFFFF, 0) == 0

describe "RV32M Compliance":
    """
    ## M Extension

    Tests MUL/DIV/REM operations including edge cases.
    """

    it "MUL: rd = (rs1 * rs2)[31:0]":
        expect muldiv_execute(MulDivOp.Mul, 7, 6) == 42

    it "MUL: handles overflow":
        expect muldiv_execute(MulDivOp.Mul, 0x80000000, 2) and 0xFFFFFFFF == 0

    it "DIV: rd = rs1 / rs2 (signed)":
        expect muldiv_execute(MulDivOp.Div, 20, 3) == 6

    it "DIV: division by zero returns all ones":
        # Use var to prevent const-evaluator from folding 42/0
        var zero = 0
        expect muldiv_execute(MulDivOp.Div, 42, zero) and 0xFFFFFFFF == 0xFFFFFFFF

    it "DIVU: unsigned division":
        expect muldiv_execute(MulDivOp.Divu, 20, 3) == 6

    it "REM: remainder":
        expect muldiv_execute(MulDivOp.Rem, 20, 3) == 2

    it "REMU: unsigned remainder":
        expect muldiv_execute(MulDivOp.Remu, 20, 3) == 2

describe "RV32A Compliance":
    """
    ## A Extension

    Tests LR/SC reservation mechanism and AMO operations.
    """

    it "LR/SC succeeds on uncontested reservation":
        """
        **Given:** Fresh reservation set
        **When:** LR then SC to same address
        **Then:** SC succeeds (returns true)
        """
        var rs = ReservationSet64.create()
        rs.reserve(0x80000100)
        val success = rs.check_and_clear(0x80000100)
        expect success == true

    it "SC fails after intervening store":
        """
        **Given:** Active reservation
        **When:** Intervening store to same address, then SC
        **Then:** SC fails (returns false)
        """
        var rs = ReservationSet64.create()
        rs.reserve(0x80000100)
        rs.invalidate()
        val success = rs.check_and_clear(0x80000100)
        expect success == false

    it "AMOADD computes correctly":
        expect amo_execute(AmoOp.Add, 100, 50).new_value == 150

    it "AMOSWAP returns rs2":
        expect amo_execute(AmoOp.Swap, 100, 200).new_value == 200

    it "AMOAND computes correctly":
        expect amo_execute(AmoOp.And, 0xFF00, 0x0FF0).new_value == 0x0F00