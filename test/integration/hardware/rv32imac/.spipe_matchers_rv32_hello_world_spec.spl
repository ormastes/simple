"""
# RV32IMAC Hello World Verification

**Feature IDs:** #RV32-HELLO-001
**Category:** Hardware
**Difficulty:** 3/5
**Status:** In Progress

## Overview

Verifies the SoC boots and produces UART output.
Tests the full pipeline from instruction fetch to UART character output.
"""

# @req REQ-RV32IMAC
# @feature rv32imac
# tag: only-compiled, vhdl, slow

use std.spec.*

use hardware.rv32gc.periph.rv32_uart.{Rv32Uart, UART_LSR, UART_THR}
use hardware.rv32gc.periph.rv32_clint.Rv32Clint
use hardware.rv32gc.mem.rv32_ram.Rv32Ram
use hardware.rv32gc.mem.rv32_bus.Rv32Bus
use hardware.riscv_common.pkg.riscv_linux_pkg.RiscvPlatformProfile

# ============================================================================
# UART Model Tests
# ============================================================================

describe "RV32 UART Model":
    """
    ## UART Peripheral Verification

    Tests the UART transmit and status register behavior.
    """

    it "starts with TX empty":
        """
        **Given:** Fresh UART model
        **When:** Reading LSR
        **Then:** TX empty and TX idle bits are set
        """
        val uart = Rv32Uart.create()
        val lsr = uart.read_reg(UART_LSR)
        expect (lsr and 0x60) == 0x60

    it "buffers transmitted bytes":
        """
        **Given:** UART model
        **When:** Writing to THR
        **Then:** Byte appears in TX output buffer
        """
        var uart = Rv32Uart.create()
        uart.write_reg(UART_THR, 0x48)  # 'H'
        uart.write_reg(UART_THR, 0x65)  # 'e'
        expect uart.tx_count == 2
        expect uart.consume_tx() == 0x48
        expect uart.consume_tx() == 0x65

# ============================================================================
# Timer Model Tests
# ============================================================================

describe "RV32 Timer Model":
    """
    ## Timer Peripheral Verification
    """

    it "increments mtime on tick":
        var timer = Rv32Clint.create(1)
        timer.tick()
        timer.tick()
        timer.tick()
        expect timer.read(0xBFF8) == 3

    it "generates interrupt when mtime >= mtimecmp":
        var timer = Rv32Clint.create(1)
        timer.write(0x4000, 5)
        timer.tick()
        timer.tick()
        expect timer.get_mtip(0) == false
        timer.tick()
        timer.tick()
        timer.tick()
        expect timer.get_mtip(0) == true

# ============================================================================
# SRAM Model Tests
# ============================================================================

describe "RV32 SRAM Model":
    """
    ## SRAM Verification
    """

    it "reads back written data":
        var sram = Rv32Ram.create(16)
        sram.write32(0, 0xDEADBEEF)
        expect sram.read32(0).value == 0xDEADBEEF

    it "supports byte-enable writes":
        var sram = Rv32Ram.create(16)
        sram.write32(0, 0x12345678)
        sram.write8(0, 0xAA)
        expect sram.read32(0).value and 0xFF == 0xAA

# ============================================================================
# Bus Decode Tests
# ============================================================================

describe "RV32 Bus Address Decode":
    """
    ## Memory Map Verification
    """

    it "routes ROM addresses correctly":
        val bus = Rv32Bus.create(0x1000, 1)
        expect bus.read32(0x00001000).fault == true

    it "routes SRAM addresses correctly":
        val bus = Rv32Bus.create(0x1000, 1)
        expect bus.write32(0x80000100, 0xABCD1234).fault == false
        expect bus.read32(0x80000100).value == 0xABCD1234

    it "routes UART addresses correctly":
        val bus = Rv32Bus.create(0x1000, 1)
        val platform = RiscvPlatformProfile.qemu_virt_rv32()
        expect bus.write8(platform.uart_base, 0x41).fault == false
        expect bus.uart.consume_tx() == 0x41

    it "routes Timer addresses correctly":
        val bus = Rv32Bus.create(0x1000, 1)
        val platform = RiscvPlatformProfile.qemu_virt_rv32()
        bus.write32(platform.clint_base + 0x4000, 3)
        bus.tick()
        bus.tick()
        expect bus.clint.get_mtip(0) == false
        bus.tick()
        expect bus.clint.get_mtip(0) == true