use std.spec.*

use hardware.riscv_common.pkg.riscv_linux_pkg.{RiscvPlatformProfile, RiscvLinuxProfile}
use hardware.rv32gc.top.rv32_soc.{rv32_soc_create}

describe "RV32 Linux platform contract":
    it "uses the QEMU virt memory map and Linux entry registers":
        val platform = RiscvPlatformProfile.qemu_virt_rv32()
        expect platform.dram_base == 0x80000000
        expect platform.uart_base == 0x10000000
        expect platform.clint_base == 0x02000000
        expect platform.plic_base == 0x0C000000
        expect platform.hartid_register == "a0"
        expect platform.dtb_register == "a1"

    it "uses ILP32D Sv32 for the first Linux milestone":
        val linux = RiscvLinuxProfile.rv32_qemu_virt_linux()
        expect linux.abi.to_text() == "ilp32d"
        expect linux.mmu_mode.to_text() == "sv32"
        expect linux.kernel_alignment == 0x200000
        expect linux.opensbi_required == true

    it "programs the Linux handoff registers with satp disabled":
        val platform = RiscvPlatformProfile.qemu_virt_rv32()
        var soc = rv32_soc_create(1, 0x1000, platform.reset_vector)
        soc.set_linux_handoff(0, 0x88000000)
        expect soc.regs.read(10) == 0
        expect soc.regs.read(11) == 0x88000000
        expect soc.csr.read_satp() == 0