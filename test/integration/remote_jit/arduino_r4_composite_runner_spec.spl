"""
# Arduino UNO R4 WiFi Remote Execution Lane — Composite Runner
#
# Integration tests for the ArduinoR4Adapter (Renesas RA4M1, Cortex-M4)
# via OpenOCD telnet over CMSIS-DAP/SWD.
#
# All tests are gated on probe_cmsis_dap() availability. If openocd is
# not found in PATH the suite skips cleanly without failing.
#
# Feature ID: #RJE-018
"""

use std.spec.{describe, it, expect}
use std.io_runtime.{print}
use std.nogc_sync_mut.debug.remote.exec.adapter_arduino_r4.{ArduinoR4Adapter}
use std.nogc_sync_mut.debug.remote.exec.capability_report.{probe_cmsis_dap}

# RA4M1 SRAM starts at 0x20000000; use a safe offset for test writes
val TEST_ADDR: i64 = 0x20000100
val TEST_REG: i64 = 0   # r0

describe "Arduino R4 Composite Runner (#RJE-018)":
    it "adapter connects via CMSIS-DAP":
        val cap = probe_cmsis_dap()
        if not cap.is_runnable():
            print("SKIP: openocd not available — {cap.detail}")
            return
        var adapter = ArduinoR4Adapter.new()
        val conn = adapter.connect()
        match conn:
            Ok(msg):
                expect(adapter.connected).to_equal(true)
                adapter.disconnect()
                expect(adapter.connected).to_equal(false)
            Err(e):
                print("SKIP: connect failed: {e}")

    it "SRAM write and readback":
        val cap = probe_cmsis_dap()
        if not cap.is_runnable():
            print("SKIP: openocd not available — {cap.detail}")
            return
        var adapter = ArduinoR4Adapter.new()
        val conn = adapter.connect()
        match conn:
            Ok(_):
                val bytes: [i32] = [0x11, 0x22, 0x33, 0x44]
                val write_result = adapter.write_code(TEST_ADDR, bytes)
                match write_result:
                    Ok(_):
                        val read_result = adapter.read_code(TEST_ADDR, 4)
                        match read_result:
                            Ok(read_bytes):
                                expect(read_bytes[0]).to_equal(0x11)
                                expect(read_bytes[1]).to_equal(0x22)
                                expect(read_bytes[2]).to_equal(0x33)
                                expect(read_bytes[3]).to_equal(0x44)
                            Err(re):
                                print("SKIP: read_code failed: {re}")
                    Err(we):
                        print("SKIP: write_code failed: {we}")
                adapter.disconnect()
            Err(e):
                print("SKIP: connect failed: {e}")

    it "register write and readback":
        val cap = probe_cmsis_dap()
        if not cap.is_runnable():
            print("SKIP: openocd not available — {cap.detail}")
            return
        var adapter = ArduinoR4Adapter.new()
        val conn = adapter.connect()
        match conn:
            Ok(_):
                val write_result = adapter.write_register(TEST_REG, 0xDEADBEEF)
                match write_result:
                    Ok(_):
                        val read_result = adapter.read_register(TEST_REG)
                        match read_result:
                            Ok(value):
                                expect(value).to_equal(0xDEADBEEF)
                            Err(re):
                                print("SKIP: read_register failed: {re}")
                    Err(we):
                        print("SKIP: write_register failed: {we}")
                adapter.disconnect()
            Err(e):
                print("SKIP: connect failed: {e}")

    it "creates execution manager":
        val cap = probe_cmsis_dap()
        if not cap.is_runnable():
            print("SKIP: openocd not available — {cap.detail}")
            return
        var adapter = ArduinoR4Adapter.new()
        val conn = adapter.connect()
        match conn:
            Ok(_):
                val mgr = adapter.create_manager()
                match mgr:
                    Ok(_):
                        expect(true).to_equal(true)
                    Err(e):
                        print("SKIP: create_manager failed: {e}")
                adapter.disconnect()
            Err(e):
                print("SKIP: connect failed: {e}")
