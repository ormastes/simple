"""
# STM32H7 Minimal Test
"""

use std.io_runtime.{shell}
 
 fn openocd_available() -> bool:
     val result = shell("command -v openocd >/dev/null 2>&1")
     result.exit_code == 0
 
 describe "STM32H7 minimal":
     slow_it "checks openocd availability":
         val available = openocd_available()
         expect(available).to_equal(true)
