"""
# QEMU RV32 Baremetal Composite Runner
Verifies the shared baremetal library workload on QEMU RISC-V 32-bit via the unified adapter.
"""

use app.io.file_ops.{file_read}
use std.io_runtime.{shell}
use std.nogc_sync_mut.debug.remote.exec.adapter_qemu_rv32.{QemuRv32Adapter}
use std.nogc_sync_mut.debug.remote.exec.types.{MemoryMap, Architecture}
use std.nogc_sync_mut.debug.remote.exec.compiler_bridge.{compile_remote_binary}

fn qemu_rv32_available() -> bool:
    val qemu = shell("command -v qemu-system-riscv32 >/dev/null 2>&1")
    val clang = shell("command -v clang >/dev/null 2>&1")
    val lld = shell("command -v ld.lld >/dev/null 2>&1")
    val objcopy = shell("command -v llvm-objcopy >/dev/null 2>&1")
    qemu.exit_code == 0 and clang.exit_code == 0 and lld.exit_code == 0 and objcopy.exit_code == 0

fn shared_workload_source() -> text:
    file_read("test/fixtures/remote_jit/baremetal_lib_workload_main.spl")

describe "QEMU RV32 Baremetal Workload":
    it "runs the shared baremetal library workload on QEMU RV32":
        if not qemu_rv32_available():
            print "[skip] QEMU RV32 tools not available"
            return
        var adapter = QemuRv32Adapter.new()
        val conn = adapter.connect()
        if conn.is_err():
            print "[skip] connect failed: {conn.err().unwrap()}"
            return
        val mgr = adapter.create_manager()
        if mgr.is_err():
            adapter.disconnect()
            print "[skip] manager failed"
            return
        val source = shared_workload_source()
        if source.trim() == "":
            adapter.disconnect()
            print "[skip] shared workload fixture unreadable"
            return
        val limits = MemoryMap.qemu_rv32()
        val compiled = compile_remote_binary(source, Architecture.RiscV32, limits.code_start)
        if compiled.is_err():
            adapter.disconnect()
            print "[skip] compile failed: {compiled.err().unwrap()}"
            return
        var manager = mgr.ok.unwrap()
        val result = manager.execute_bytes("baremetal_lib_workload_qemu_rv32", compiled.ok.unwrap(), [])
        adapter.disconnect()
        if result.is_err():
            print "[skip] exec failed: {result.err().unwrap()}"
            return
        expect(result.ok.unwrap().return_value).to_equal(0)
