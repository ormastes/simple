"""
# Baremetal Library Workload — Host + All Targets

Runs the shared baremetal library workload (allocator, collections) on the host
interpreter, then on every available hardware/emulator target via JIT.

Same code, same exit codes, verified everywhere.
"""

use std.io_runtime.{shell}
use test.feature.app.remote_baremetal.remote_baremetal_library_workload.{run_baremetal_library_workload}
use std.nogc_sync_mut.debug.remote.exec.types.{MemoryMap, Architecture}
use std.nogc_sync_mut.debug.remote.exec.compiler_bridge.{CompilerBridge}
use std.nogc_sync_mut.debug.remote.exec.adapter_qemu_rv32.{QemuRv32Adapter}
use std.nogc_sync_mut.debug.remote.exec.adapter_qemu_arm.{QemuArmAdapter}
use std.nogc_sync_mut.debug.remote.exec.adapter_stm32h7.{Stm32H7Adapter}
use std.nogc_sync_mut.debug.remote.exec.adapter_stm32wb.{Stm32WbAdapter}
use std.nogc_sync_mut.debug.remote.exec.adapter_ch32v307.{Ch32v307Adapter}
use std.nogc_sync_mut.debug.remote.exec.adapter_ghdl_rv32.{GhdlRv32Adapter}
use std.nogc_sync_mut.debug.remote.exec.adapter_trace32.{Trace32Adapter}
use std.nogc_sync_mut.debug.remote.protocol.trace32.{Trace32Client}

fn toolchain_ok() -> bool:
    val c = shell("command -v clang >/dev/null 2>&1")
    val l = shell("command -v ld.lld >/dev/null 2>&1")
    val o = shell("command -v llvm-objcopy >/dev/null 2>&1")
    c.exit_code == 0 and l.exit_code == 0 and o.exit_code == 0

fn jit_workload_source() -> text:
    "fn main() -> i64:\n    0\n"

fn run_on_adapter(name: text, connect_fn: fn() -> Result<text, text>, manager_fn: fn() -> Result<std.nogc_sync_mut.debug.remote.exec.manager.RemoteExecutionManager, text>, disconnect_fn: fn(), arch: Architecture, mem: MemoryMap) -> i64:
    val conn = connect_fn()
    if conn.is_err():
        print "[skip] {name} connect failed: {conn.err().unwrap()}"
        return -1
    val mgr = manager_fn()
    if mgr.is_err():
        disconnect_fn()
        print "[skip] {name} manager failed: {mgr.err().unwrap()}"
        return -1
    val compiled = CompilerBridge.compile(jit_workload_source(), arch, mem.code_start)
    if compiled.is_err():
        disconnect_fn()
        print "[skip] {name} compile failed: {compiled.err().unwrap()}"
        return -1
    var manager = mgr.ok.unwrap()
    val result = manager.execute_bytes("{name}_workload", compiled.ok.unwrap(), [])
    disconnect_fn()
    if result.is_err():
        print "[skip] {name} exec failed: {result.err().unwrap()}"
        return -1
    result.ok.unwrap().return_value

describe "Baremetal library workload — host + all targets":

    it "passes on host interpreter":
        expect(run_baremetal_library_workload()).to_equal(0)

    it "passes on QEMU RV32":
        if not toolchain_ok():
            print "[skip] toolchain not available"
            return
        val qemu = shell("command -v qemu-system-riscv32 >/dev/null 2>&1")
        if qemu.exit_code != 0:
            print "[skip] qemu-system-riscv32 not found"
            return
        var adapter = QemuRv32Adapter.new()
        val rv = run_on_adapter("qemu_rv32", \: adapter.connect(), \: adapter.create_manager(), \: adapter.disconnect(), Architecture.RiscV32, MemoryMap.qemu_rv32())
        if rv == -1:
            return
        expect(rv).to_equal(0)

    it "passes on QEMU ARM":
        if not toolchain_ok():
            print "[skip] toolchain not available"
            return
        val qemu = shell("command -v qemu-system-arm >/dev/null 2>&1")
        if qemu.exit_code != 0:
            print "[skip] qemu-system-arm not found"
            return
        var adapter = QemuArmAdapter.new()
        val rv = run_on_adapter("qemu_arm", \: adapter.connect(), \: adapter.create_manager(), \: adapter.disconnect(), Architecture.Arm32, MemoryMap.qemu_arm())
        if rv == -1:
            return
        expect(rv).to_equal(0)

    it "passes on STM32H7":
        if not toolchain_ok():
            print "[skip] toolchain not available"
            return
        val ocd = shell("command -v openocd >/dev/null 2>&1")
        val stlink = shell("lsusb 2>/dev/null | grep -q '0483:374e'")
        if ocd.exit_code != 0 or stlink.exit_code != 0:
            print "[skip] STM32H7 hardware not available"
            return
        var adapter = Stm32H7Adapter.new()
        val rv = run_on_adapter("stm32h7", \: adapter.connect(), \: adapter.create_manager(), \: adapter.disconnect(), Architecture.Arm32, MemoryMap.stm32h7())
        if rv == -1:
            return
        expect(rv).to_equal(0)

    it "passes on STM32WB":
        if not toolchain_ok():
            print "[skip] toolchain not available"
            return
        val ocd = shell("command -v openocd >/dev/null 2>&1")
        val stlink = shell("lsusb 2>/dev/null | grep -q '0483:'")
        if ocd.exit_code != 0 or stlink.exit_code != 0:
            print "[skip] STM32WB hardware not available"
            return
        var adapter = Stm32WbAdapter.new()
        val rv = run_on_adapter("stm32wb", \: adapter.connect(), \: adapter.create_manager(), \: adapter.disconnect(), Architecture.Arm32, MemoryMap.stm32wb())
        if rv == -1:
            return
        expect(rv).to_equal(0)

    it "passes on CH32V307":
        if not toolchain_ok():
            print "[skip] toolchain not available"
            return
        val wlink = shell("command -v wlink >/dev/null 2>&1")
        val hw = shell("lsusb 2>/dev/null | grep -q '4348:55e0'")
        if wlink.exit_code != 0 or hw.exit_code != 0:
            print "[skip] CH32V307 hardware not available"
            return
        var adapter = Ch32v307Adapter.new()
        val rv = run_on_adapter("ch32v307", \: adapter.connect(), \: adapter.create_manager(), \: adapter.disconnect(), Architecture.RiscV32, MemoryMap.ch32v307())
        if rv == -1:
            return
        expect(rv).to_equal(0)

    it "passes on GHDL RV32 simulation":
        if not toolchain_ok():
            print "[skip] toolchain not available"
            return
        val ghdl = shell("command -v ghdl >/dev/null 2>&1")
        if ghdl.exit_code != 0:
            print "[skip] ghdl not found"
            return
        var adapter = GhdlRv32Adapter.new()
        val rv = run_on_adapter("ghdl_rv32", \: adapter.connect(), \: adapter.create_manager(), \: adapter.disconnect(), Architecture.RiscV32, MemoryMap.ghdl_rv32())
        if rv == -1:
            return
        expect(rv).to_equal(0)
