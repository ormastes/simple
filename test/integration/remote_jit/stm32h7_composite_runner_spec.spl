"""
# STM32H7 Baremetal Composite Runner
Verifies the shared baremetal library workload on STM32H7 through the HAL-backed JIT path.
"""

use app.io.file_ops.{file_read}
use std.io_runtime.{shell}
use std.nogc_sync_mut.debug.remote.exec.types.{MemoryMap}
use std.nogc_sync_mut.debug.remote.exec.compiler_bridge.{compile_remote_binary_arm32}
use std.nogc_sync_mut.jit.jit_types.{JitBinary}
use std.nogc_sync_mut.jit.jit_layout.{append_halt_trampoline_arm32, plan_binary_layout_arm32, jit_entry_pc_arm32, jit_return_pc_arm32}
use std.nogc_sync_mut.jit.jit_hal_stm32h7.{stm32h7_connect, stm32h7_disconnect, stm32h7_write_code, stm32h7_write_register, stm32h7_read_register, stm32h7_resume}

fn hardware_ready() -> bool:
    val ocd = shell("command -v openocd >/dev/null 2>&1")
    val clang = shell("command -v clang >/dev/null 2>&1")
    val lld = shell("command -v ld.lld >/dev/null 2>&1")
    val objcopy = shell("command -v llvm-objcopy >/dev/null 2>&1")
    val stlink = shell("lsusb 2>/dev/null | grep -q '0483:374e'")
    ocd.exit_code == 0 and clang.exit_code == 0 and lld.exit_code == 0 and objcopy.exit_code == 0 and stlink.exit_code == 0

fn shared_workload_source() -> text:
    file_read("test/fixtures/remote_jit/baremetal_lib_workload_main.spl")

describe "STM32H7 Baremetal Workload":
    it "runs the shared baremetal library workload on STM32H7":
        if not hardware_ready():
            print "[skip] STM32H7 hardware not available"
            return

        val source = shared_workload_source()
        if source.trim() == "":
            print "[skip] shared workload fixture unreadable"
            return

        val connect_result = stm32h7_connect()
        if connect_result.is_err():
            print "[skip] connect failed: {connect_result.err().unwrap()}"
            return

        var openocd_pid: i64 = 0
        match connect_result:
            case Ok(v):
                openocd_pid = v
            case Err(_):
                openocd_pid = 0

        val limits = MemoryMap.stm32h7()
        val compile_result = compile_remote_binary_arm32(source, limits.code_start)
        if compile_result.is_err():
            stm32h7_disconnect(openocd_pid)
            print "[skip] compile failed: {compile_result.err().unwrap()}"
            return

        var compiled_bytes: [i32] = []
        match compile_result:
            case Ok(v):
                compiled_bytes = v
            case Err(_):
                compiled_bytes = []

        val bytes = append_halt_trampoline_arm32(compiled_bytes)
        val binary = JitBinary(name: "baremetal_lib_workload_stm32h7", bytes: bytes, entry_offset: 0, stack_bytes: 0)
        val layout_result = plan_binary_layout_arm32(binary, limits)
        if layout_result.is_err():
            stm32h7_disconnect(openocd_pid)
            print "[skip] layout failed: {layout_result.err().unwrap()}"
            return

        val layout = layout_result.ok.unwrap()
        val write_result = stm32h7_write_code(layout.code_base, bytes)
        if write_result.is_err():
            stm32h7_disconnect(openocd_pid)
            print "[skip] upload failed: {write_result.err().unwrap()}"
            return

        val sp_result = stm32h7_write_register(13, layout.stack_top)
        if sp_result.is_err():
            stm32h7_disconnect(openocd_pid)
            print "[skip] set SP failed: {sp_result.err().unwrap()}"
            return

        val lr_result = stm32h7_write_register(14, jit_return_pc_arm32(layout))
        if lr_result.is_err():
            stm32h7_disconnect(openocd_pid)
            print "[skip] set LR failed: {lr_result.err().unwrap()}"
            return

        val pc_result = stm32h7_write_register(15, jit_entry_pc_arm32(layout))
        if pc_result.is_err():
            stm32h7_disconnect(openocd_pid)
            print "[skip] set PC failed: {pc_result.err().unwrap()}"
            return

        val resume_result = stm32h7_resume()
        if resume_result.is_err():
            stm32h7_disconnect(openocd_pid)
            print "[skip] resume failed: {resume_result.err().unwrap()}"
            return

        shell("sleep 0.5")
        val r0_result = stm32h7_read_register(0)
        val pc_after_result = stm32h7_read_register(15)
        stm32h7_disconnect(openocd_pid)

        if r0_result.is_err():
            print "[skip] read R0 failed: {r0_result.err().unwrap()}"
            return
        if pc_after_result.is_err():
            print "[skip] read PC failed: {pc_after_result.err().unwrap()}"
            return

        val r0 = r0_result.ok.unwrap()
        val pc_after = pc_after_result.ok.unwrap()
        val expected_halt_pc = layout.halt_addr
        val expected_pc = layout.halt_addr + 2
        expect(r0).to_equal(0)
        expect(pc_after == expected_halt_pc or pc_after == expected_pc).to_equal(true)
