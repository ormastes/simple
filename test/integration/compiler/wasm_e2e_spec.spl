# WASM End-to-End Compilation Test
#
# Validates the full pipeline: .spl source → MIR → WAT output.
# Checks that the generated WAT is structurally valid.
#
# @mode: native

use compiler.backend.backend.backend_types.{BackendKind, CodegenTarget, CompileOptions, OptimizationLevel}
use compiler.backend.backend.wasm_codegen_adapter.{WasmCodegenAdapter}
use compiler.backend.codegen_types.{Codegen}
use compiler.mir.mir_data.{MirModule, MirFunction, MirBasicBlock, MirInstruction, MirInstructionKind}
use compiler.mir.mir_types.{MirType, MirTypeKind}

describe "WASM E2E Compilation":

    context "minimal module":
        it "compiles empty module to valid WAT":
            val options = CompileOptions(
                target: CodegenTarget.Wasm32,
                opt_level: OptimizationLevel.None_,
                debug_info: false,
                emit_assembly: false,
                emit_llvm_ir: false,
                emit_mir: false,
                verify_output: false
            )
            var adapter = WasmCodegenAdapter(options: options)

            # Create minimal MIR module
            val module = MirModule(
                name: "test_module",
                functions: [],
                globals: [],
                types: [],
                imports: [],
                exports: []
            )

            val result = adapter.compile_module(module)
            match result:
                case Ok(output):
                    val wat = output.text_output
                    expect(wat).to_contain("(module")
                case Err(err):
                    expect("compilation failed: {err.message}").to_equal("")

    context "target support":
        it "supports Wasm32 target":
            val options = CompileOptions(
                target: CodegenTarget.Wasm32,
                opt_level: OptimizationLevel.None_,
                debug_info: false,
                emit_assembly: false,
                emit_llvm_ir: false,
                emit_mir: false,
                verify_output: false
            )
            var adapter = WasmCodegenAdapter(options: options)
            expect(adapter.supports_target(CodegenTarget.Wasm32)).to_equal(true)

        it "rejects non-WASM targets":
            val options = CompileOptions(
                target: CodegenTarget.Wasm32,
                opt_level: OptimizationLevel.None_,
                debug_info: false,
                emit_assembly: false,
                emit_llvm_ir: false,
                emit_mir: false,
                verify_output: false
            )
            var adapter = WasmCodegenAdapter(options: options)
            expect(adapter.supports_target(CodegenTarget.X86_64)).to_equal(false)

        it "reports correct backend kind":
            val options = CompileOptions(
                target: CodegenTarget.Wasm32,
                opt_level: OptimizationLevel.None_,
                debug_info: false,
                emit_assembly: false,
                emit_llvm_ir: false,
                emit_mir: false,
                verify_output: false
            )
            var adapter = WasmCodegenAdapter(options: options)
            expect(adapter.backend_name()).to_equal("wasm")
