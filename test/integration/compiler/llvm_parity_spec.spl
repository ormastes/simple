# LLVM Backend Parity Tests
#
# Verifies that llvm-lib and llvm (CLI) backends produce functionally
# equivalent results for the supported x86_64 subset.
#
# @cover src/compiler/70.backend/backend/llvm_lib_backend.spl 60%
# @cover src/compiler/70.backend/backend/llvm_backend.spl 60%

use std.spec.*
use std.io_runtime.*
use compiler.backend.backend.backend_types.{BackendKind, CodegenTarget, OptimizationLevel, CompileOptions}
use compiler.backend.backend.backend_helpers.{compile_module_with_backend}
use compiler.backend.llvm_capability.{get_llvm_capabilities}
use compiler.mir.mir_data.*

# ============================================================================
# Parity Test Helpers
# ============================================================================

fn make_test_module(name: text) -> MirModule:
    """Create a minimal MIR module for parity testing."""
    MirModule(
        name: name,
        functions: [],
        globals: [],
        types: [],
        imports: [],
        exports: []
    )

fn skip_unless_both_backends():
    """Skip test if both LLVM backends are not available."""
    val caps = get_llvm_capabilities()
    if not caps.llvm_backend_available:
        val pending_reason = "llc not available — skipping parity test"
        expect(pending_reason.len()).to_be_greater_than(0)
    if not caps.llvm_lib_backend_available:
        val pending_reason = "libLLVM not available — skipping parity test"
        expect(pending_reason.len()).to_be_greater_than(0)

# ============================================================================
# Tests
# ============================================================================

describe "LLVM Backend Parity (llvm-lib vs llvm)":
    describe "compilation succeeds on both backends":
        it "compiles empty module via llvm":
            val caps = get_llvm_capabilities()
            if not caps.llvm_backend_available:
                val pending_reason = "llc not available"
                expect(pending_reason.len()).to_be_greater_than(0)
            val module = make_test_module("parity_empty_llvm")
            val result = compile_module_with_backend("llvm", module, true)
            expect(result.is_ok()).to_equal(true)

        it "compiles empty module via llvm-lib":
            val caps = get_llvm_capabilities()
            if not caps.llvm_lib_backend_available:
                val pending_reason = "libLLVM not available"
                expect(pending_reason.len()).to_be_greater_than(0)
            val module = make_test_module("parity_empty_llvmlib")
            val result = compile_module_with_backend("llvm-lib", module, true)
            expect(result.is_ok()).to_equal(true)

    describe "both backends produce object code":
        it "llvm produces non-empty object code":
            val caps = get_llvm_capabilities()
            if not caps.llvm_backend_available:
                val pending_reason = "llc not available"
                expect(pending_reason.len()).to_be_greater_than(0)
            val module = make_test_module("parity_obj_llvm")
            val result = compile_module_with_backend("llvm", module, true)
            if result.is_ok():
                val compiled = result.unwrap()
                expect(compiled.object_code.len() > 0).to_equal(true)

        it "llvm-lib produces non-empty object code":
            val caps = get_llvm_capabilities()
            if not caps.llvm_lib_backend_available:
                val pending_reason = "libLLVM not available"
                expect(pending_reason.len()).to_be_greater_than(0)
            val module = make_test_module("parity_obj_llvmlib")
            val result = compile_module_with_backend("llvm-lib", module, true)
            if result.is_ok():
                val compiled = result.unwrap()
                expect(compiled.object_code.len() > 0).to_equal(true)

    describe "optimization levels":
        it "llvm handles debug optimization":
            val caps = get_llvm_capabilities()
            if not caps.llvm_backend_available:
                val pending_reason = "llc not available"
                expect(pending_reason.len()).to_be_greater_than(0)
            val module = make_test_module("parity_debug_llvm")
            val result = compile_module_with_backend("llvm", module, false)
            expect(result.is_ok()).to_equal(true)

        it "llvm-lib handles debug optimization":
            val caps = get_llvm_capabilities()
            if not caps.llvm_lib_backend_available:
                val pending_reason = "libLLVM not available"
                expect(pending_reason.len()).to_be_greater_than(0)
            val module = make_test_module("parity_debug_llvmlib")
            val result = compile_module_with_backend("llvm-lib", module, false)
            expect(result.is_ok()).to_equal(true)

    describe "auto backend selection":
        it "auto selects an available LLVM backend":
            val caps = get_llvm_capabilities()
            if not caps.has_any_llvm():
                val pending_reason = "no LLVM backend available"
                expect(pending_reason.len()).to_be_greater_than(0)
            val module = make_test_module("parity_auto")
            val result = compile_module_with_backend("auto", module, true)
            expect(result.is_ok()).to_equal(true)
