use std.spec.{describe, it, expect}
use compiler.backend.llvm_support_matrix.{lookup_support, get_support_matrix}
use compiler.backend.backend.backend_types.{BackendKind, CodegenTarget}

describe "i686 closure":
    it "llvm-lib i686 is unsupported":
        val level = lookup_support(BackendKind.LlvmLib, CodegenTarget.X86)
        expect level.to_text() == "unsupported"

    it "llvm CLI i686 is unsupported":
        val level = lookup_support(BackendKind.Llvm, CodegenTarget.X86)
        expect level.to_text() == "unsupported"

    it "i686 level is a final state":
        val level = lookup_support(BackendKind.LlvmLib, CodegenTarget.X86)
        expect level.is_final_state() == true

    it "i686 unsupported has clear diagnostic":
        val matrix = get_support_matrix()
        for entry in matrix:
            if entry.target == CodegenTarget.X86:
                expect (entry.known_limits).contains("Demoted to unsupported")