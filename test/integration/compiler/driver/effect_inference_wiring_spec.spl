# Effect Inference Wiring Tests
#
# @req STUB-002
# @cover src/compiler/80.driver/driver.spl
# @cover src/compiler/30.types/type_system/effect_pass.spl
#
# Verifies that the effect inference pass is actually wired into the driver.

use std.test.*
use compiler.types.type_system.effect_pass.{run_effect_pass}
use compiler.hir.hir.*

describe "Effect Inference Pass":
    context "run_effect_pass":
        it "accepts empty module dict and returns empty warnings":
            var modules: Dict<text, HirModule> = {}
            val (result_modules, warnings) = run_effect_pass(modules)
            expect(warnings.len()).to_equal(0)
            expect(result_modules.keys().len()).to_equal(0)
