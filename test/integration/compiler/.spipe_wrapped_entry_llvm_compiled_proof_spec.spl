#![allow(spipe_empty_examples)]
#![allow(spipe_boolean_wrapper_assertions)]
@allow(spipe_empty_examples)
@allow(spipe_boolean_wrapper_assertions)
use std.io_runtime.*
use compiler.mir.mir_data.*
use compiler.backend.backend.backend_helpers.{compile_module_with_backend}
use compiler.backend.llvm_backend_tools.{compile_ir_to_object, compile_ir_to_wasm}
use compiler.backend.llvm_capability.{get_llvm_capabilities, detect_llvm_capabilities, reset_capability_cache, LlvmCapabilityReport}
use compiler.backend.llvm_version.{parse_llvm_version, check_version_compatibility, LlvmVersionStatus, LLVM_VERSION_MIN, LLVM_VERSION_MAX}
use compiler.backend.llvm_support_matrix.{get_support_matrix, lookup_support, format_support_matrix, export_matrix_sdn, LlvmSupportLevel, validate_matrix_closure, is_matrix_closed, format_closure_report}
use compiler.backend.llvm_cross_target.{toolchain_for_target, diagnose_all_targets, TargetToolchain}
use compiler.backend.backend.backend_types.{BackendKind, CodegenTarget, OptimizationLevel}
use compiler.backend.llvm_target.{LlvmTargetConfig__for_target}

extern fn rt_file_write_bytes(path: text, data: [u8]) -> bool

fn trivial_main_ir() -> text:
    "define i32 @main() {\n" +
    "entry:\n" +
    "  ret i32 0\n" +
    "}\n"

fn write_object_bytes(path: text, data: [u8]) -> bool:
    rt_file_write_bytes(path, data)

fn main():
    # LLVM Compiled Authoritative Proof Tests
    #
    # Verifies real compiled proof for each supported target class.
    # These are the authoritative proofs that LLVM backends produce
    # usable artifacts, not just capability booleans.
    #
    # Proof classes:
    # 1. Hosted native compile/link proof (x86_64 llvm-lib, x86_64 llvm)
    # 2. Bare-metal object/ELF generation (RISC-V, ARM)
    # 3. WASM artifact generation
    # 4. Cross-target compilation success
    # 5. Negative/diagnostic cases
    #
    # @cover src/compiler/70.backend/backend/llvm_backend.spl 50%
    # @cover src/compiler/70.backend/backend/llvm_lib_backend.spl 50%
    # @cover src/compiler/70.backend/backend/llvm_capability.spl 70%
    # @cover src/compiler/70.backend/backend/llvm_version.spl 80%
    # @cover src/compiler/70.backend/backend/llvm_cross_target.spl 60%
    # @cover src/compiler/70.backend/backend/llvm_support_matrix.spl 80%


    # ============================================================================
    # Phase 2: Capability Detection Proof
    # ============================================================================

    describe "LLVM Capability Detection":
        it "produces a valid capability report":
            val report = detect_llvm_capabilities()
            expect report.host_os != "" == true
            expect report.host_arch != "" == true

        it "detects host OS correctly":
            val report = get_llvm_capabilities()
            val valid_os = ["linux", "macos", "windows", "freebsd"]
            expect valid_os.contains(report.host_os) == true

        it "caches the capability report":
            reset_capability_cache()
            val r1 = get_llvm_capabilities()
            val r2 = get_llvm_capabilities()
            # Same report instance (cached)
            expect r1.host_os == r2.host_os
            expect r1.host_arch == r2.host_arch

        it "generates readable format_report":
            val report = get_llvm_capabilities()
            val text = report.format_report()
            expect text.contains("LLVM Capability Report") == true
            expect text.contains("Host:") == true
            expect text.contains("Tools:") == true
            expect text.contains("Backends:") == true

        it "reports preferred backend":
            val report = get_llvm_capabilities()
            val preferred = report.preferred_backend()
            # Must be one of the three valid choices
            val valid = (preferred == BackendKind.LlvmLib or
                         preferred == BackendKind.Llvm or
                         preferred == BackendKind.Cranelift)
            expect valid == true

        it "generates diagnostic for missing LLVM":
            val report = get_llvm_capabilities()
            if report.has_any_llvm():
                # If LLVM is available, diagnostic should be empty
                val diag = report.format_diagnostic()
                expect diag == ""
            else:
                # If LLVM is missing, diagnostic should contain install instructions
                val diag = report.format_diagnostic()
                expect diag.contains("Install LLVM") == true

    # ============================================================================
    # Phase 3: Version Compatibility Proof
    # ============================================================================

    describe "LLVM Version Compatibility":
        it "parses standard version string":
            val v = parse_llvm_version("18.1.3")
            expect v.major == 18
            expect v.minor == 1
            expect v.patch == 3

        it "parses verbose llc --version output":
            val v = parse_llvm_version("LLVM version 17.0.6\nOptimized build.\nDefault target: x86_64-linux-gnu")
            expect v.major == 17
            expect v.minor == 0
            expect v.patch == 6

        it "parses Ubuntu clang version output":
            val v = parse_llvm_version("Ubuntu clang version 18.1.3-1ubuntu1 (++20240220094142+ef68c8aed184-1~exp1~20240220214205.50)")
            expect v.major == 18

        it "handles empty version string":
            val v = parse_llvm_version("")
            expect v.is_known() == false
            expect v.to_text() == "unknown"

        it "classifies supported versions correctly":
            val v16 = parse_llvm_version("16.0.0")
            val v18 = parse_llvm_version("18.1.3")
            val v19 = parse_llvm_version("19.0.0")
            expect check_version_compatibility(v16) == LlvmVersionStatus.Supported
            expect check_version_compatibility(v18) == LlvmVersionStatus.Supported
            expect check_version_compatibility(v19) == LlvmVersionStatus.Supported

        it "rejects too-old versions":
            val v15 = parse_llvm_version("15.0.0")
            val v12 = parse_llvm_version("12.0.0")
            expect check_version_compatibility(v15) == LlvmVersionStatus.TooOld
            expect check_version_compatibility(v12) == LlvmVersionStatus.TooOld

        it "warns on too-new versions":
            val v20 = parse_llvm_version("20.0.0")
            val v25 = parse_llvm_version("25.0.0")
            expect check_version_compatibility(v20) == LlvmVersionStatus.TooNew
            expect check_version_compatibility(v25) == LlvmVersionStatus.TooNew

        it "handles unknown version":
            val vunk = parse_llvm_version("garbage")
            expect check_version_compatibility(vunk) == LlvmVersionStatus.Unknown

    # ============================================================================
    # Phase 5: Cross-Target Toolchain Proof
    # ============================================================================

    describe "Cross-Target Toolchain Descriptors":
        it "returns a toolchain for x86_64":
            val tc = toolchain_for_target(CodegenTarget.X86_64)
            expect tc.triple.contains("x86_64") == true
            expect tc.linker != "" == true

        it "returns a toolchain for aarch64":
            val tc = toolchain_for_target(CodegenTarget.AArch64)
            expect tc.triple.contains("aarch64") == true

        it "returns a toolchain for armv7":
            val tc = toolchain_for_target(CodegenTarget.Arm)
            expect tc.triple.contains("armv7") == true

        it "returns a toolchain for riscv32":
            val tc = toolchain_for_target(CodegenTarget.Riscv32)
            expect tc.triple.contains("riscv32") == true

        it "returns a toolchain for wasm32":
            val tc = toolchain_for_target(CodegenTarget.Wasm32)
            expect tc.triple.contains("wasm32") == true
            expect tc.linker_flavor == "wasm-ld"

        it "generates diagnostic report for all targets":
            val report = diagnose_all_targets()
            expect report.contains("Cross-Target Toolchain Status") == true
            expect report.contains("x86_64") == true
            expect report.contains("aarch64") == true
            expect report.contains("wasm32") == true

        it "provides install hints for cross targets":
            val tc = toolchain_for_target(CodegenTarget.AArch64)
            val caps = get_llvm_capabilities()
            if caps.host_arch != "aarch64":
                # Cross-compile scenario
                expect tc.requires_external == true
                expect tc.install_hint != "" == true

    # ============================================================================
    # Phase 6: Hosted Native Compilation Proof
    # ============================================================================

    describe "Hosted Native Compilation Proof":
        it "llvm-lib compiles for x86_64 when available":
            val caps = get_llvm_capabilities()
            if not caps.llvm_lib_backend_available:
                val pending_reason = "libLLVM not available"
                expect pending_reason.len() > 0
            val module = MirModule(
                name: "llvm_lib_x86_64_compiled_proof",
                functions: [],
                globals: [],
                types: [],
                imports: [],
                exports: []
            )
            val result = compile_module_with_backend("llvm-lib", module, true)
            expect result.is_ok() == true
            val compiled = result.unwrap()
            expect compiled.object_code.len() > 0 == true

        it "llvm (CLI) compiles for x86_64 when available":
            val caps = get_llvm_capabilities()
            if not caps.llvm_backend_available:
                val pending_reason = "llc not available"
                expect pending_reason.len() > 0
            val module = MirModule(
                name: "llvm_cli_x86_64_compiled_proof",
                functions: [],
                globals: [],
                types: [],
                imports: [],
                exports: []
            )
            val result = compile_module_with_backend("llvm", module, true)
            expect result.is_ok() == true
            val compiled = result.unwrap()
            expect compiled.object_code.len() > 0 == true

        it "llvm CLI links an aarch64 executable when cross toolchain is present":
            val (tc_out, tc_err, tc_code) = shell("command -v aarch64-linux-gnu-gcc 2>/dev/null")
            if tc_code != 0:
                val pending_reason = "aarch64-linux-gnu-gcc not available"
                expect pending_reason.len() > 0

            val config = LlvmTargetConfig__for_target(CodegenTarget.AArch64, nil)
            val obj_result = compile_ir_to_object(trivial_main_ir(), config, OptimizationLevel.Debug)
            expect obj_result.is_ok() == true
            val object = obj_result.unwrap()
            val obj_path = "/tmp/simple_llvm_aarch64_probe.o"
            val out_path = "/tmp/simple_llvm_aarch64_probe.out"
            expect write_object_bytes(obj_path, object.bytes) == true

            val (out, err, code) = shell("aarch64-linux-gnu-gcc -o {out_path} {obj_path} 2>&1")
            expect code == 0
            expect file_exists(out_path) == true

            file_delete(obj_path)
            file_delete(out_path)

        it "llvm CLI links a riscv64 executable when cross toolchain is present":
            val (tc_out, tc_err, tc_code) = shell("command -v riscv64-linux-gnu-gcc 2>/dev/null")
            if tc_code != 0:
                val pending_reason = "riscv64-linux-gnu-gcc not available"
                expect pending_reason.len() > 0

            val config = LlvmTargetConfig__for_target(CodegenTarget.Riscv64, nil)
            val obj_result = compile_ir_to_object(trivial_main_ir(), config, OptimizationLevel.Debug)
            expect obj_result.is_ok() == true
            val object = obj_result.unwrap()
            val obj_path = "/tmp/simple_llvm_riscv64_probe.o"
            val out_path = "/tmp/simple_llvm_riscv64_probe.out"
            expect write_object_bytes(obj_path, object.bytes) == true

            val (out, err, code) = shell("riscv64-linux-gnu-gcc -o {out_path} {obj_path} 2>&1")
            expect code == 0
            expect file_exists(out_path) == true

            file_delete(obj_path)
            file_delete(out_path)

        it "llvm CLI emits a wasm32 artifact when wasm linker is present":
            val (tc_out, tc_err, tc_code) = shell("command -v wasm-ld 2>/dev/null")
            if tc_code != 0:
                val pending_reason = "wasm-ld not available"
                expect pending_reason.len() > 0

            val config = LlvmTargetConfig__for_target(CodegenTarget.Wasm32, nil)
            val out_path = "/tmp/simple_llvm_wasm32_probe.wasm"
            val result = compile_ir_to_wasm(trivial_main_ir(), config, OptimizationLevel.Debug, out_path)
            expect result.is_ok() == true
            expect file_exists(out_path) == true
            expect file_size_raw(out_path) > 8
            file_delete(out_path)

        it "llvm CLI emits a wasm64 artifact when wasm linker is present":
            val (tc_out, tc_err, tc_code) = shell("command -v wasm-ld 2>/dev/null")
            if tc_code != 0:
                val pending_reason = "wasm-ld not available"
                expect pending_reason.len() > 0

            val config = LlvmTargetConfig__for_target(CodegenTarget.Wasm64, nil)
            val out_path = "/tmp/simple_llvm_wasm64_probe.wasm"
            val result = compile_ir_to_wasm(trivial_main_ir(), config, OptimizationLevel.Debug, out_path)
            expect result.is_ok() == true
            expect file_exists(out_path) == true
            expect file_size_raw(out_path) > 8
            file_delete(out_path)

    # ============================================================================
    # Phase 7: Support Matrix Proof
    # ============================================================================

    describe "Support Matrix":
        it "contains entries for all required targets":
            val matrix = get_support_matrix()
            expect matrix.len() > 0 == true
            # Must have at least 16 entries (8 targets x 2 backends)
            expect matrix.len() >= 16 == true

        it "x86_64 is stable on both backends":
            val lib_level = lookup_support(BackendKind.LlvmLib, CodegenTarget.X86_64)
            val cli_level = lookup_support(BackendKind.Llvm, CodegenTarget.X86_64)
            expect lib_level == LlvmSupportLevel.Stable
            expect cli_level == LlvmSupportLevel.Stable

        it "matches published support levels for the cross-target matrix":
            # i686: demoted to unsupported (multilib not portable)
            expect lookup_support(BackendKind.LlvmLib, CodegenTarget.X86) == LlvmSupportLevel.Unsupported
            expect lookup_support(BackendKind.Llvm, CodegenTarget.X86) == LlvmSupportLevel.Unsupported
            # aarch64: both stable (libLLVM includes AArch64 natively)
            expect lookup_support(BackendKind.LlvmLib, CodegenTarget.AArch64) == LlvmSupportLevel.Stable
            expect lookup_support(BackendKind.Llvm, CodegenTarget.AArch64) == LlvmSupportLevel.Stable
            # armv7: demoted to unsupported (hard-float ABI not portable)
            expect lookup_support(BackendKind.LlvmLib, CodegenTarget.Arm) == LlvmSupportLevel.Unsupported
            expect lookup_support(BackendKind.Llvm, CodegenTarget.Arm) == LlvmSupportLevel.Unsupported
            # riscv64: both stable (libLLVM includes RISC-V natively)
            expect lookup_support(BackendKind.LlvmLib, CodegenTarget.Riscv64) == LlvmSupportLevel.Stable
            expect lookup_support(BackendKind.Llvm, CodegenTarget.Riscv64) == LlvmSupportLevel.Stable
            # riscv32: demoted to unsupported (baremetal-only, not portable)
            expect lookup_support(BackendKind.LlvmLib, CodegenTarget.Riscv32) == LlvmSupportLevel.Unsupported
            expect lookup_support(BackendKind.Llvm, CodegenTarget.Riscv32) == LlvmSupportLevel.Unsupported
            # wasm: llvm-lib unsupported, CLI stable
            expect lookup_support(BackendKind.LlvmLib, CodegenTarget.Wasm32) == LlvmSupportLevel.Unsupported
            expect lookup_support(BackendKind.Llvm, CodegenTarget.Wasm32) == LlvmSupportLevel.Stable
            expect lookup_support(BackendKind.LlvmLib, CodegenTarget.Wasm64) == LlvmSupportLevel.Unsupported
            expect lookup_support(BackendKind.Llvm, CodegenTarget.Wasm64) == LlvmSupportLevel.Stable

        it "wasm32 is stable on llvm CLI":
            val level = lookup_support(BackendKind.Llvm, CodegenTarget.Wasm32)
            expect level == LlvmSupportLevel.Stable

        it "wasm32 is unsupported on llvm-lib":
            val level = lookup_support(BackendKind.LlvmLib, CodegenTarget.Wasm32)
            expect level == LlvmSupportLevel.Unsupported

        it "formats human-readable matrix":
            val text = format_support_matrix()
            expect text.contains("Support Matrix") == true
            expect text.contains("llvm-lib") == true
            expect text.contains("llvm (CLI)") == true
            expect text.contains("stable") == true

        it "exports SDN format":
            val sdn = export_matrix_sdn()
            expect sdn.contains("matrix {") == true
            expect sdn.contains("backend:") == true
            expect sdn.contains("target:") == true
            expect sdn.contains("level:") == true

    # ============================================================================
    # Phase 6: Negative / Diagnostic Proof
    # ============================================================================

    describe "Negative and Diagnostic Cases":
        it "unsupported version produces TooOld diagnostic":
            val v = parse_llvm_version("15.0.0")
            val status = check_version_compatibility(v)
            expect status == LlvmVersionStatus.TooOld

        it "unknown combination returns Unsupported":
            # GPU targets not in LLVM matrix
            val level = lookup_support(BackendKind.LlvmLib, CodegenTarget.CudaPtx)
            expect level == LlvmSupportLevel.Unsupported

        it "capability report includes warnings for known issues":
            val report = get_llvm_capabilities()
            # Warnings list exists (may be empty on a well-configured system)
            expect report.warnings != nil == true

        it "capability report includes errors for known issues":
            val report = get_llvm_capabilities()
            # Errors list exists
            expect report.errors != nil == true

    # ============================================================================
    # Phase 8: WASM Closure Confirmation
    # ============================================================================

    describe "wasm closure confirmation":
        it "wasm32 llvm CLI is stable":
            val level = lookup_support(BackendKind.Llvm, CodegenTarget.Wasm32)
            expect level.to_text() == "stable"

        it "wasm64 llvm CLI is stable":
            val level = lookup_support(BackendKind.Llvm, CodegenTarget.Wasm64)
            expect level.to_text() == "stable"

        it "wasm32 llvm-lib is unsupported with clear reason":
            val level = lookup_support(BackendKind.LlvmLib, CodegenTarget.Wasm32)
            expect level.to_text() == "unsupported"
            val matrix = get_support_matrix()
            for entry in matrix:
                if entry.backend == BackendKind.LlvmLib and entry.target == CodegenTarget.Wasm32:
                    expect (entry.known_limits).contains("use llvm backend")

        it "wasm64 llvm-lib is unsupported with clear reason":
            val level = lookup_support(BackendKind.LlvmLib, CodegenTarget.Wasm64)
            expect level.to_text() == "unsupported"

        it "wasm levels are all in final states":
            val w32_lib = lookup_support(BackendKind.LlvmLib, CodegenTarget.Wasm32)
            val w32_cli = lookup_support(BackendKind.Llvm, CodegenTarget.Wasm32)
            val w64_lib = lookup_support(BackendKind.LlvmLib, CodegenTarget.Wasm64)
            val w64_cli = lookup_support(BackendKind.Llvm, CodegenTarget.Wasm64)
            expect w32_lib.is_final_state() == true
            expect w32_cli.is_final_state() == true
            expect w64_lib.is_final_state() == true
            expect w64_cli.is_final_state() == true

    # ============================================================================
    # Phase 9: Matrix Closure Validation (Full-Family Completion)
    # ============================================================================

    describe "matrix closure validation":
        it "validate_matrix_closure returns no errors":
            val errors = validate_matrix_closure()
            expect errors.len() == 0

        it "is_matrix_closed returns true":
            val closed = is_matrix_closed()
            expect closed == true

        it "no row is Partial":
            val matrix = get_support_matrix()
            for entry in matrix:
                val level_text = entry.level.to_text()
                expect level_text != "partial" == true

        it "no row is SupportedExternal":
            val matrix = get_support_matrix()
            for entry in matrix:
                val level_text = entry.level.to_text()
                expect level_text != "supported (external toolchain)" == true

        it "every row is in a final state":
            val matrix = get_support_matrix()
            for entry in matrix:
                expect entry.level.is_final_state() == true

        it "stable rows have proof references":
            val matrix = get_support_matrix()
            for entry in matrix:
                if entry.level.to_text() == "stable":
                    expect entry.proof != "none" == true
                    expect entry.proof != "" == true

        it "unsupported rows have clear diagnostics":
            val matrix = get_support_matrix()
            for entry in matrix:
                if entry.level.to_text() == "unsupported":
                    expect entry.known_limits != "" == true

    describe "matrix completeness":
        it "matrix covers all 8 targets for llvm-lib":
            val targets = [
                CodegenTarget.X86_64, CodegenTarget.X86,
                CodegenTarget.AArch64, CodegenTarget.Arm,
                CodegenTarget.Riscv64, CodegenTarget.Riscv32,
                CodegenTarget.Wasm32, CodegenTarget.Wasm64
            ]
            for target in targets:
                val level = lookup_support(BackendKind.LlvmLib, target)
                # Every target must have an entry (not default Unsupported from missing)
                expect level.is_final_state() == true

        it "matrix covers all 8 targets for llvm CLI":
            val targets = [
                CodegenTarget.X86_64, CodegenTarget.X86,
                CodegenTarget.AArch64, CodegenTarget.Arm,
                CodegenTarget.Riscv64, CodegenTarget.Riscv32,
                CodegenTarget.Wasm32, CodegenTarget.Wasm64
            ]
            for target in targets:
                val level = lookup_support(BackendKind.Llvm, target)
                expect level.is_final_state() == true

        it "closure report says COMPLETE":
            val report = format_closure_report()
            expect (report).contains("COMPLETE")