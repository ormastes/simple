use std.spec.{describe, it, expect}
use compiler.backend.llvm_support_matrix.{lookup_support, get_support_matrix}
use compiler.backend.backend.backend_types.{BackendKind, CodegenTarget}

describe "armv7 closure":
    it "llvm-lib armv7 is unsupported":
        val level = lookup_support(BackendKind.LlvmLib, CodegenTarget.Arm)
        expect level.to_text() == "unsupported"

    it "llvm CLI armv7 is unsupported":
        val level = lookup_support(BackendKind.Llvm, CodegenTarget.Arm)
        expect level.to_text() == "unsupported"

    it "armv7 unsupported has clear diagnostic":
        val matrix = get_support_matrix()
        for entry in matrix:
            if entry.target == CodegenTarget.Arm:
                expect (entry.known_limits).contains("Demoted to unsupported")