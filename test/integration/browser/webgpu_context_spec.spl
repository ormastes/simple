# @tag: browser, webgpu, integration
# @cover examples/browser/entity/media/webgpu_types.spl 40%

use std.spec.{describe, context, it, expect}
use examples.browser.entity.media.webgpu_types.{GPUAdapterInfo, GPUDeviceLimits, GPURequestAdapterOptions, GPUDeviceDescriptor, GPU_FEATURE_SHADER_F16, GPU_POWER_HIGH}

describe "WebGPU Types":

    context "GPUAdapterInfo.unknown":

        it "returns vendor unknown":
            val info = GPUAdapterInfo.unknown()
            expect(info.vendor).to_equal("unknown")

    context "GPUDeviceLimits.defaults":

        it "has max_texture_dimension_2d == 8192":
            val limits = GPUDeviceLimits.defaults()
            expect(limits.max_texture_dimension_2d).to_equal(8192)

    context "GPURequestAdapterOptions.default_options":

        it "has force_fallback_adapter == false":
            val opts = GPURequestAdapterOptions.default_options()
            expect(opts.force_fallback_adapter).to_equal(false)

    context "GPUDeviceDescriptor.create":

        it "has empty required_features":
            val desc = GPUDeviceDescriptor.create()
            expect(desc.required_features.len()).to_equal(0)

    context "GPU_FEATURE_SHADER_F16":

        it "equals shader-f16":
            expect(GPU_FEATURE_SHADER_F16).to_equal("shader-f16")

    context "GPU_POWER_HIGH":

        it "equals 1":
            expect(GPU_POWER_HIGH).to_equal(1)
