# @tag: browser, webgpu, integration
# @cover examples/browser/feature/gpu/webgpu_context.spl 60%

use std.spec.{describe, context, it, expect}
use examples.browser.feature.gpu.webgpu_context.{WebGPUContext}
use examples.browser.entity.media.webgpu_types.{GPURequestAdapterOptions, GPUDeviceDescriptor, GPUDeviceLimits}

describe "WebGPU Context":

    context "WebGPUContext.create":

        it "_initialized is false":
            val ctx = WebGPUContext.create()
            expect(ctx._initialized).to_equal(false)

    context "request_adapter":

        it "with default options returns true":
            var ctx = WebGPUContext.create()
            val result = ctx.request_adapter(GPURequestAdapterOptions.default_options())
            expect(result).to_equal(true)

    context "request_device":

        it "with create descriptor returns true and is_initialized is true":
            var ctx = WebGPUContext.create()
            ctx.request_adapter(GPURequestAdapterOptions.default_options())
            val result = ctx.request_device(GPUDeviceDescriptor.create())
            expect(result).to_equal(true)
            expect(ctx.is_initialized()).to_equal(true)

    context "adapter_info":

        it "vendor is software after request_adapter":
            var ctx = WebGPUContext.create()
            ctx.request_adapter(GPURequestAdapterOptions.default_options())
            val info = ctx.adapter_info()
            expect(info.vendor).to_equal("software")

    context "device_limits":

        it "max_texture_dimension_2d is 8192 by default":
            val ctx = WebGPUContext.create()
            val limits = ctx.device_limits()
            expect(limits.max_texture_dimension_2d).to_equal(8192)

    context "has_feature":

        it "returns false for unknown feature":
            val ctx = WebGPUContext.create()
            expect(ctx.has_feature("nonexistent-feature-xyz")).to_equal(false)

    context "supported_features":

        it "empty list initially":
            val ctx = WebGPUContext.create()
            expect(ctx.supported_features().len()).to_equal(0)

    context "configure_canvas":

        it "canvas_count increments after configure_canvas":
            var ctx = WebGPUContext.create()
            ctx.request_adapter(GPURequestAdapterOptions.default_options())
            ctx.request_device(GPUDeviceDescriptor.create())
            val before = ctx.canvas_count()
            ctx.configure_canvas(1, 0, 320, 240)
            expect(ctx.canvas_count()).to_equal(before + 1)

    context "create_texture":

        it "returns positive i32":
            var ctx = WebGPUContext.create()
            ctx.request_adapter(GPURequestAdapterOptions.default_options())
            ctx.request_device(GPUDeviceDescriptor.create())
            val id = ctx.create_texture(64, 64, 0)
            expect(id).to_be_greater_than(0)

    context "create_buffer":

        it "returns positive i32":
            var ctx = WebGPUContext.create()
            ctx.request_adapter(GPURequestAdapterOptions.default_options())
            ctx.request_device(GPUDeviceDescriptor.create())
            val id = ctx.create_buffer(256, 0)
            expect(id).to_be_greater_than(0)

    context "create_render_pipeline":

        it "returns positive i32":
            var ctx = WebGPUContext.create()
            ctx.request_adapter(GPURequestAdapterOptions.default_options())
            ctx.request_device(GPUDeviceDescriptor.create())
            val id = ctx.create_render_pipeline("void main(){}", "void main(){}")
            expect(id).to_be_greater_than(0)

    context "destroy":

        it "sets initialized to false":
            var ctx = WebGPUContext.create()
            ctx.request_adapter(GPURequestAdapterOptions.default_options())
            ctx.request_device(GPUDeviceDescriptor.create())
            ctx.destroy()
            expect(ctx.is_initialized()).to_equal(false)
