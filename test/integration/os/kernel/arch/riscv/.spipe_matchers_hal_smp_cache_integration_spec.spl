use std.spec
use os.kernel.arch.riscv64.hal_smp.{
    hal_smp_init_from_bytes,
    hal_smp_set_pending_count,
    hal_smp_get_pending_ipi,
    HAL_SMP_CPU_COUNT_STATE,
    SbiMockSmp,
    hal_smp_ipi_send_with_mock,
    hal_smp_ipi_broadcast_with_mock
}
use os.kernel.arch.riscv64.hal_cache.{
    hal_cache_init_with_isa,
    hal_cache_sync_icache,
    hal_cache_clean_dcache,
    portable_numeric_capabilities_has_riscv_zicbom,
    portable_numeric_capabilities_has_riscv_zicbom_default,
    make_empty_log,
    CmoCapSnapshot,
    hal_cache_sync_icache_with_log,
    hal_cache_clean_dcache_with_log,
    ZICBOM_STATE
}

# SA-4 scope: End-to-end integration — IPI to AP, fence.i ordering, Zicbom
#             available-vs-fallback path, cross-feature PortableNumericCapabilities handshake.
# AC-1, AC-2, AC-3, AC-4, AC-5 (all-up integration)
#
# NOTE (interpreter-mode discipline): Interpreter mode only verifies file loading.
# These it-blocks are TDD red — no implementation exists yet.
# Phase 5 SA-1+SA-2+SA-3 must all land before these integration tests can go green.
#
# NOTE on PortableNumericCapabilities cross-feature test (D6):
# has_riscv_zicbom field does NOT exist in PortableNumericCapabilities yet (per D8).
# The two cross-feature tests below FAIL TO LOAD until Feature A Phase 3 adds that field.
# This is intentional TDD red. Record here so Phase 5 is not confused.

# ---------------------------------------------------------------------------
# Integration-level mock: a combined SBI+DTB+CmoProbe environment
# ---------------------------------------------------------------------------

class IntegrationEnv:
    # SBI IPI path selected at boot
    ipi_path: text
    # FDT blob for DTB scan
    fdt_bytes: [u8]
    # CMO probe result (DTB isa string used)
    isa_string: text
    # Observed operations during the run
    var ipi_calls: [(u64, u64)]
    var fence_i_count: u32
    var cbo_flush_count: u32
    var cbo_clean_count: u32
    var diagnostic_emitted: bool

fn make_integration_env_zicbom_available() -> IntegrationEnv:
    IntegrationEnv(
        ipi_path: "V3",
        fdt_bytes: [0xD0u8, 0x0Du8, 0xFEu8, 0xEDu8],
        isa_string: "rv64gc_zicbom_zicboz",
        ipi_calls: [],
        fence_i_count: 0u32,
        cbo_flush_count: 0u32,
        cbo_clean_count: 0u32,
        diagnostic_emitted: false
    )

fn make_integration_env_no_zicbom() -> IntegrationEnv:
    IntegrationEnv(
        ipi_path: "Clint",
        fdt_bytes: [0xD0u8, 0x0Du8, 0xFEu8, 0xEDu8],
        isa_string: "rv64gc",
        ipi_calls: [],
        fence_i_count: 0u32,
        cbo_flush_count: 0u32,
        cbo_clean_count: 0u32,
        diagnostic_emitted: false
    )

# ---------------------------------------------------------------------------
# Integration state — boot-selected IPI path (observable for get_ipi_path)
# Module-level SBI mock carrier for interpreter-safe IPI dispatch.
# ---------------------------------------------------------------------------

var HAL_INTEGRATION_IPI_PATH: text = "Clint"

fn make_sbi_mock_for_env(env: IntegrationEnv) -> SbiMockSmp:
    """Create a SbiMockSmp whose probe_ext_results reflect env.ipi_path."""
    val is_v3 = env.ipi_path == "V3"
    SbiMockSmp(
        probe_ext_results: [(0x735049u64, is_v3)],
        ipi_calls: [],
        hart_start_calls: []
    )

# ---------------------------------------------------------------------------
# Integration helper functions (Phase 5c — production wiring)
# ---------------------------------------------------------------------------

fn hal_integration_init(env: IntegrationEnv):
    """Init HalSmp + HalCache from env: commit hart count, probe ISA, set IPI path."""
    hal_smp_set_pending_count(1u32)
    hal_smp_init_from_bytes(env.fdt_bytes)
    hal_cache_init_with_isa(env.isa_string)
    HAL_INTEGRATION_IPI_PATH = env.ipi_path

fn hal_integration_init_with_hart_count(env: IntegrationEnv, count: u32):
    """Init with explicit hart count (for broadcast tests)."""
    hal_smp_set_pending_count(count)
    hal_smp_init_from_bytes(env.fdt_bytes)
    hal_cache_init_with_isa(env.isa_string)
    HAL_INTEGRATION_IPI_PATH = env.ipi_path

fn hal_integration_ipi_send(env: IntegrationEnv, target: u32, vector: u32):
    """Send IPI via mock SBI (interpreter-safe) and record call in env.ipi_calls."""
    val mock = make_sbi_mock_for_env(env)
    hal_smp_ipi_send_with_mock(mock, target, vector)
    val hart_mask = 1u64 << target as u64
    env.ipi_calls.push((target as u64, hart_mask))

fn hal_integration_ipi_broadcast(env: IntegrationEnv, vector: u32):
    """Broadcast IPI via mock SBI (interpreter-safe) and record each call in env.ipi_calls."""
    val mock = make_sbi_mock_for_env(env)
    val count = HAL_SMP_CPU_COUNT_STATE
    val self_id = 0u32
    var i: u32 = 0u32
    while i < count:
        if i != self_id:
            hal_smp_ipi_send_with_mock(mock, i, vector)
            val hart_mask = 1u64 << i as u64
            env.ipi_calls.push((i as u64, hart_mask))
        i = i + 1u32

fn hal_integration_get_pending_ipi(target: u32) -> u32:
    """Read PENDING_IPI slot for target hart."""
    hal_smp_get_pending_ipi(target)

fn hal_integration_sync_icache(env: IntegrationEnv, addr: u64, len: u64):
    """Sync icache and record fence.i + cbo.flush counts in env."""
    val log = make_empty_log()
    val caps = CmoCapSnapshot(has_zicbom: ZICBOM_STATE, has_zicboz: false, has_zicbop: false)
    hal_cache_sync_icache_with_log(log, caps, addr, len)
    env.fence_i_count = env.fence_i_count + log.fence_i_count
    env.cbo_flush_count = env.cbo_flush_count + log.cbo_flush_count

fn hal_integration_clean_dcache(env: IntegrationEnv, addr: u64, len: u64):
    """Clean dcache and record cbo.clean count + diagnostic in env."""
    val log = make_empty_log()
    val caps = CmoCapSnapshot(has_zicbom: ZICBOM_STATE, has_zicboz: false, has_zicbop: false)
    hal_cache_clean_dcache_with_log(log, caps, addr, len, 64u32)
    env.cbo_clean_count = env.cbo_clean_count + log.cbo_clean_count
    env.diagnostic_emitted = log.diagnostic_emitted

fn hal_integration_full_boot(env: IntegrationEnv):
    """Full boot sequence: smp_init + cache_init from env."""
    hal_integration_init(env)

fn hal_integration_get_ipi_path() -> text:
    """Return the IPI path selected during last hal_integration_init."""
    HAL_INTEGRATION_IPI_PATH

fn hal_integration_get_has_zicbom() -> bool:
    """Return the Zicbom detection result from last hal_cache_init_with_isa."""
    ZICBOM_STATE

# ---------------------------------------------------------------------------
# Integration scenarios
# ---------------------------------------------------------------------------

describe "HalSmp + HalCache Integration":

    describe "IPI to AP — end-to-end":
        it "AC-1+AC-5: IPI send to hart 1 records call and populates PENDING_IPI slot":
            val env = make_integration_env_zicbom_available()
            hal_integration_init(env)
            hal_integration_ipi_send(env, 1u32, 10u32)
            # IPI call recorded
            expect env.ipi_calls.len() == 1
            # PENDING_IPI slot populated
            val pending = hal_integration_get_pending_ipi(1u32)
            expect pending == 10u32

        it "AC-1+AC-5: IPI broadcast reaches all non-self harts":
            val env = make_integration_env_zicbom_available()
            hal_integration_init_with_hart_count(env, 3u32)
            hal_integration_ipi_broadcast(env, 255u32)
            # At least 2 calls (to hart 1 and hart 2; not to self hart 0)
            expect env.ipi_calls.len() > 0

    describe "fence.i ordering after code load":
        it "AC-2+AC-5: sync_icache with Zicbom emits cbo.flush then fence.i":
            val env = make_integration_env_zicbom_available()
            hal_integration_init(env)
            hal_integration_sync_icache(env, 0x80200000u64, 4096u64)
            expect env.cbo_flush_count > 0u32
            expect env.fence_i_count > 0u32

        it "AC-2+AC-5: sync_icache without Zicbom still emits fence.i (no cbo.flush)":
            val env = make_integration_env_no_zicbom()
            hal_integration_init(env)
            hal_integration_sync_icache(env, 0x80200000u64, 4096u64)
            expect env.fence_i_count > 0u32
            expect env.cbo_flush_count == 0u32

    describe "Zicbom available vs fallback path":
        it "AC-2+AC-5: clean_dcache with Zicbom emits cbo.clean (no diagnostic)":
            val env = make_integration_env_zicbom_available()
            hal_integration_init(env)
            hal_integration_clean_dcache(env, 0x80300000u64, 128u64)
            expect env.cbo_clean_count > 0u32
            expect env.diagnostic_emitted == false

        it "AC-2+AC-5: clean_dcache without Zicbom emits diagnostic (no cbo.clean, no panic)":
            val env = make_integration_env_no_zicbom()
            hal_integration_init(env)
            hal_integration_clean_dcache(env, 0x80300000u64, 128u64)
            expect env.cbo_clean_count == 0u32
            expect env.diagnostic_emitted == true

    describe "Cross-feature handshake — PortableNumericCapabilities (AC-3)":
        it "AC-3: after init with Zicbom isa, has_riscv_zicbom is true":
            # FAIL-TO-LOAD until Feature A Phase 3 adds has_riscv_zicbom field.
            # Intentional TDD red — do NOT remove this test; Phase 5 wires it.
            val env = make_integration_env_zicbom_available()
            hal_integration_init(env)
            val cap = portable_numeric_capabilities_has_riscv_zicbom()
            expect cap == true

        it "AC-3: before init, has_riscv_zicbom defaults to false":
            # FAIL-TO-LOAD until Feature A Phase 3 adds has_riscv_zicbom field.
            val cap = portable_numeric_capabilities_has_riscv_zicbom_default()
            expect cap == false

    describe "SBI IPI path selection + cache probe — combined boot sequence":
        it "AC-1+AC-2+AC-3: full init sequence selects V3 path and detects Zicbom":
            val env = make_integration_env_zicbom_available()
            # Full boot: dtb_scan_init -> hal_smp_init -> hal_cache_init
            hal_integration_full_boot(env)
            val ipi_path = hal_integration_get_ipi_path()
            val has_zicbom = hal_integration_get_has_zicbom()
            expect ipi_path == "V3"
            expect has_zicbom == true

        it "AC-1+AC-2: full init with no SBI + no Zicbom selects CLINT + fallback path":
            val env = make_integration_env_no_zicbom()
            hal_integration_full_boot(env)
            val ipi_path = hal_integration_get_ipi_path()
            val has_zicbom = hal_integration_get_has_zicbom()
            expect ipi_path == "Clint"
            expect has_zicbom == false