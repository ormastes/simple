use app.io.file_ops

extern fn rt_env_get(key: text) -> text
extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

fn check(condition: bool):
    expect(condition).to_equal(true)

fn slow_it(name: text, block: fn()):
    it(name, block)

fn _is_windows() -> bool:
    val (uname_out, _, _) = rt_process_run("uname", ["-s"])
    val os = uname_out.trim()
    os.starts_with("MINGW") or os.starts_with("MSYS") or os.starts_with("CYGWIN") or os.starts_with("Windows")

val tmp = rt_env_get("TEMP") ?? rt_env_get("TMPDIR") ?? "/tmp"
val _can_run = not _is_windows()

describe "Native File Ops":
    slow_it "creates and reads files":
        if not _can_run:
            expect(true).to_equal(true)
        else:
            val test_file = "{tmp}/simple_native_file_test.txt"
            val content = "Hello from native SFFI!"

            check(file_write(test_file, content))
            check(file_exists(test_file))
            expect(file_read(test_file).trim()).to_equal(content)
            check(file_delete(test_file))
            check(not file_exists(test_file))
