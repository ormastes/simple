use app.io.dir_ops

extern fn rt_env_get(key: text) -> text

fn check(condition: bool):
    expect(condition).to_equal(true)

fn slow_it(name: text, block: fn()):
    it(name, block)

val tmp = rt_env_get("TEMP") ?? rt_env_get("TMPDIR") ?? "/tmp"

describe "Native Directory Ops":
    slow_it "creates nested directories recursively":
        val test_dir = "{tmp}/simple_native_deep/sub1/sub2"

        check(dir_create(test_dir, true))
        check(is_dir(test_dir))
        check(dir_remove_all("{tmp}/simple_native_deep") == 0)

