use app.io.file_ops

extern fn rt_env_get(key: text) -> text

fn check(condition: bool):
    expect(condition).to_equal(true)

fn slow_it(name: text, block: fn()):
    it(name, block)

val tmp = rt_env_get("TEMP") ?? rt_env_get("TMPDIR") ?? "/tmp"

describe "Native File Ops":
    slow_it "copies files":
        val src = "{tmp}/simple_copy_src.txt"
        val dst = "{tmp}/simple_copy_dst.txt"

        check(file_write(src, "Copy test"))
        check(file_copy(src, dst))
        expect(file_read(dst)).to_equal("Copy test")
        check(file_delete(src))
        check(file_delete(dst))

