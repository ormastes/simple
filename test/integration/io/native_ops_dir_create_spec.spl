use std.spec
use app.io.dir_ops

fn check(condition: bool):
    expect(condition).to_equal(true)

fn slow_it(name: text, block: fn()):
    it(name, block)

describe "Native Directory Ops":
    slow_it "creates directories":
        val test_dir = "/tmp/simple_native_dir_test"

        check(dir_create(test_dir, false))
        check(is_dir(test_dir))
        check(dir_remove_all(test_dir) == 0)

