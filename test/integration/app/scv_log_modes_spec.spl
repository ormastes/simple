use std.spec.{describe, it, expect}

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

fn _run_scv(args: [text]) -> (text, text, i64):
    val joined = args.join(" ")
    rt_process_run("/bin/sh", [
        "-c",
        "REPO=$(pwd); SIMPLE_LIB=\"$REPO/src\" \"$REPO/bin/simple\" run \"$REPO/src/app/scv/main.spl\" " + joined
    ])

describe "scv log mode CLI options":
    it "shows shared log options in help":
        val (out, err, code) = _run_scv(["--help"])
        expect(code).to_equal(1)
        expect(out).to_contain("--log-mode")
        expect(out).to_contain("--progress")

    it "supports log-mode json for usage output":
        val (out, err, code) = _run_scv(["--log-mode=json"])
        expect(code).to_equal(0)
        expect(out).to_contain("\"command\":\"scv\"")
        expect(out).to_contain("\"status\":\"usage\"")

    it "supports dot progress for usage output":
        val (out, err, code) = _run_scv(["--progress=dot"])
        expect(code).to_equal(0)
        expect(out).to_start_with(".")
        expect(out).to_contain("Usage: scv")

    it "rejects invalid log mode":
        val (out, err, code) = _run_scv(["--log-mode=noisy"])
        expect(code).to_equal(1)
        expect(out).to_contain("ERROR scv")
