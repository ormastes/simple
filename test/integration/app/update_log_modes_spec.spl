use std.spec.{describe, it, expect}

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

val FIXTURE_DIR = "/tmp/simple_update_log_mode_fixture"

fn _setup_fixture():
    val (_out, _err, _code) = rt_process_run("/bin/sh", [
        "-c",
        "rm -rf " + FIXTURE_DIR + " && mkdir -p " + FIXTURE_DIR + " && cat > " + FIXTURE_DIR + "/simple.sdn <<'EOF'\nname: update-fixture\nversion: 3.4.5\ndependencies:\n  alpha: \"*\"\n  beta: \"*\"\nEOF"
    ])

fn _run_update(args: [text]) -> (text, text, i64):
    val joined = args.join(" ")
    rt_process_run("/bin/sh", [
        "-c",
        "REPO=$(pwd); cd " + FIXTURE_DIR + " && SIMPLE_LIB=\"$REPO/src\" \"$REPO/bin/simple\" run \"$REPO/src/app/update/main.spl\" " + joined
    ])

describe "update log mode CLI options":
    it "shows shared log options in help":
        _setup_fixture()
        val (out, err, code) = _run_update(["--help"])
        expect(code).to_equal(0)
        expect(out).to_contain("--log-mode")
        expect(out).to_contain("--progress")

    it "supports dry-run log-mode json":
        _setup_fixture()
        val (out, err, code) = _run_update(["--dry-run", "--log-mode=json"])
        expect(code).to_equal(0)
        expect(out).to_contain("\"dry_run\":true")
        expect(out).to_contain("\"dependencies\":[\"alpha\",\"beta\"]")

    it "supports dot progress":
        _setup_fixture()
        val (out, err, code) = _run_update(["--dry-run", "--progress=dot"])
        expect(code).to_equal(0)
        expect(out).to_start_with(".")
        expect(out).to_contain("Would update 2 dependencies")

    it "rejects invalid log mode":
        _setup_fixture()
        val (out, err, code) = _run_update(["--dry-run", "--log-mode=noisy"])
        expect(code).to_equal(1)
