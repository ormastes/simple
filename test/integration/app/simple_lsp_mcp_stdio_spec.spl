# Simple LSP MCP stdio protocol checks.

use std.spec
use app.io.mod.{shell}

extern fn rt_file_write_text(path: text, content: text) -> bool

fn lsp_mcp_msg(body: text) -> text:
    "Content-Length: " + body.len().to_string() + "\r\n\r\n" + body

fn lsp_mcp_jsonl(body: text) -> text:
    body + "\n"

fn lsp_init_body(id: text) -> text:
    "{\"jsonrpc\":\"2.0\",\"id\":\"" + id + "\",\"method\":\"initialize\",\"params\":{\"protocolVersion\":\"2025-06-18\",\"capabilities\":{},\"clientInfo\":{\"name\":\"spec\",\"version\":\"1.0\"}}}"

fn lsp_tools_body(id: text) -> text:
    "{\"jsonrpc\":\"2.0\",\"id\":\"" + id + "\",\"method\":\"tools/list\",\"params\":{}}"

fn send_lsp_mcp(messages: text) -> text:
    val tmp = "/tmp/simple_lsp_mcp_stdio_input.txt"
    rt_file_write_text(tmp, messages)
    val result = shell("cat " + tmp + " | bin/simple_lsp_mcp_server 2>/dev/null")
    result.stdout ?? ""

describe "Simple LSP MCP stdio":
    it "mirrors Claude-style JSONL requests with JSONL responses":
        val input = lsp_mcp_jsonl(lsp_init_body("1")) + lsp_mcp_jsonl(lsp_tools_body("2"))
        val output = send_lsp_mcp(input)
        expect(output.starts_with("{\"jsonrpc\":\"2.0\"")).to_equal(true)
        expect(output.contains("Content-Length:")).to_equal(false)
        expect(output.contains("\"serverInfo\":{\"name\":\"simple-lsp-mcp\"")).to_equal(true)
        expect(output.contains("\"name\":\"lsp_definition\"")).to_equal(true)
        expect(output.contains("\"error\":")).to_equal(false)

    it "keeps Content-Length framing for framed MCP clients":
        val input = lsp_mcp_msg(lsp_init_body("1")) + lsp_mcp_msg(lsp_tools_body("2"))
        val output = send_lsp_mcp(input)
        expect(output.starts_with("Content-Length: ")).to_equal(true)
        expect(output.contains("\"serverInfo\":{\"name\":\"simple-lsp-mcp\"")).to_equal(true)
        expect(output.contains("\"name\":\"lsp_definition\"")).to_equal(true)
        expect(output.contains("\"error\":")).to_equal(false)
