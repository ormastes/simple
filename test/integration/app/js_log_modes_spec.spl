use std.spec.{describe, it, expect}

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

fn _run_js(args: [text]) -> (text, text, i64):
    val joined = args.join(" ")
    rt_process_run("/bin/sh", [
        "-c",
        "REPO=$(pwd); SIMPLE_LIB=\"$REPO/src\" \"$REPO/bin/simple\" run \"$REPO/src/app/js/main.spl\" " + joined
    ])

describe "js log mode CLI options":
    it "shows shared log options in help":
        val (out, err, code) = _run_js(["--help"])
        expect(code).to_equal(0)
        expect(out).to_contain("--log-mode")
        expect(out).to_contain("--progress")

    it "supports log-mode json for usage output":
        val (out, err, code) = _run_js(["--log-mode=json"])
        expect(code).to_equal(0)
        expect(out).to_contain("\"command\":\"js\"")
        expect(out).to_contain("\"status\":\"usage\"")

    it "supports dot progress for missing file":
        val (out, err, code) = _run_js(["--progress=dot", "/tmp/simple-js-missing-file.js"])
        expect(code).to_equal(1)
        expect(out).to_start_with(".")
        expect(out).to_contain("js: file not found")

    it "rejects invalid log mode":
        val (out, err, code) = _run_js(["--log-mode=noisy"])
        expect(code).to_equal(1)
