extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

describe "Wine GUI hello command":
    it "runs the controlled GUI milestone through SimpleOS window evidence":
        val (stdout, stderr, code) = rt_process_run("bin/simple", ["run", "src/app/wine_gui_hello/main.spl"])
        expect code == 0
        expect (stdout).contains("window=SimpleOS Wine GUI Hello\n")
        expect (stdout).contains("text=Hello from SimpleOS Wine\n")
        expect (stdout).contains("checksum=")
        expect stderr == ""