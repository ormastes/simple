extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

describe "Wine process session plan command":
    it "prints a controlled Wine hello dry-run handoff":
        val (stdout, stderr, code) = rt_process_run("bin/simple", ["run", "src/app/wine_process_session_plan/main.spl"])
        expect code == 0
        expect (stdout).contains("command=hello.exe\n")
        expect (stdout).contains("readiness=controlled-hello-ready\n")
        expect (stdout).contains("status=dry-run-ready\n")
        expect stderr == ""