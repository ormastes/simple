extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

describe "Wine process session plan command":
    it "prints a controlled Wine hello handoff and execution result":
        val (stdout, stderr, code) = rt_process_run("bin/simple", ["run", "src/app/wine_process_session_plan/main.spl"])
        expect code == 0
        expect (stdout).contains("command=hello.exe\n")
        expect (stdout).contains("readiness=controlled-hello-ready\n")
        expect (stdout).contains("handoff=dry-run-ready\n")
        expect (stdout).contains("execution=executed\n")
        expect (stdout).contains("stdout=Hello from SimpleOS Wine\n")
        expect stderr == ""