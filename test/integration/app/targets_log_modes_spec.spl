use std.spec.{describe, it, expect}

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

fn _run_targets(args: [text]) -> (text, text, i64):
    val joined = args.join(" ")
    rt_process_run("/bin/sh", [
        "-c",
        "REPO=$(pwd); SIMPLE_LIB=\"$REPO/src\" \"$REPO/bin/simple\" run \"$REPO/src/app/targets/main.spl\" " + joined
    ])

describe "targets log mode CLI options":
    it "shows shared log options in help":
        val (out, err, code) = _run_targets(["--help"])
        expect(code).to_equal(0)
        expect(out).to_contain("--log-mode")
        expect(out).to_contain("--progress")

    it "supports log-mode json":
        val (out, err, code) = _run_targets(["--log-mode=json"])
        expect(code).to_equal(0)
        expect(out).to_contain("\"name\": \"x86_64-linux\"")
        expect(out).to_contain("\"support\": 1")

    it "supports dot progress":
        val (out, err, code) = _run_targets(["--progress=dot"])
        expect(code).to_equal(0)
        expect(out).to_start_with(".")
        expect(out).to_contain("Available target architectures:")

    it "rejects invalid log mode":
        val (out, err, code) = _run_targets(["--log-mode=noisy"])
        expect(code).to_equal(1)
