use std.spec.{describe, it, expect}

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

val FIXTURE_DIR = "/tmp/simple_spec_coverage_log_mode_fixture"

fn _setup_empty_fixture():
    val (_out, _err, _code) = rt_process_run("/bin/sh", [
        "-c",
        "rm -rf " + FIXTURE_DIR + " && mkdir -p " + FIXTURE_DIR
    ])

fn _setup_feature_fixture():
    val (_out, _err, _code) = rt_process_run("/bin/sh", [
        "-c",
        "rm -rf " + FIXTURE_DIR + " && mkdir -p " + FIXTURE_DIR + "/doc/02_requirements/feature && cat > " + FIXTURE_DIR + "/doc/02_requirements/feature/feature_db.sdn <<'EOF'\nfeatures |\nREQ-001,core,Sample feature,,,,,,,,complete,true\nREQ-002,core,Planned feature,,,,,,,,planned,true\nEOF"
    ])

fn _run_spec_coverage(args: [text]) -> (text, text, i64):
    val joined = args.join(" ")
    rt_process_run("/bin/sh", [
        "-c",
        "REPO=$(pwd); cd " + FIXTURE_DIR + " && SIMPLE_LIB=\"$REPO/src\" \"$REPO/bin/simple\" run \"$REPO/src/app/spec_coverage/main.spl\" " + joined
    ])

describe "spec-coverage log mode CLI options":
    it "shows shared log options in help":
        _setup_empty_fixture()
        val (out, err, code) = _run_spec_coverage(["--help"])
        expect(code).to_equal(0)
        expect(out).to_contain("--log-mode")
        expect(out).to_contain("--progress")

    it "supports log-mode json for missing feature database":
        _setup_empty_fixture()
        val (out, err, code) = _run_spec_coverage(["--log-mode=json"])
        expect(code).to_equal(1)
        expect(out).to_contain("\"command\":\"spec-coverage\"")
        expect(out).to_contain("\"status\":\"error\"")
        expect(out).to_contain("\"total\":0")

    it "supports dot progress":
        _setup_feature_fixture()
        val (out, err, code) = _run_spec_coverage(["--progress=dot"])
        expect(code).to_equal(0)
        expect(out).to_contain(".")
        expect(out).to_contain("Total features: 2")

    it "rejects invalid log mode":
        _setup_empty_fixture()
        val (out, err, code) = _run_spec_coverage(["--log-mode=noisy"])
        expect(code).to_equal(1)
