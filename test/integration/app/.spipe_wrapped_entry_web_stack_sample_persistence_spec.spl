

extern fn rt_getpid() -> i64
extern fn rt_time_now_unix_micros() -> i64
extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

val DB_PATH = "/tmp/web_stack_sample_persistence_{rt_getpid()}_{rt_time_now_unix_micros()}.sdn"
val RUNNER = "test/integration/app/web_stack_sample_persistence_runner.spl"

fn main():
    describe "web_stack_sample simpledb restart persistence":
        it "persists app-surface register create login and search across reopen":
            val (seed_stdout, _seed_stderr, seed_code) = rt_process_run("bin/simple", ["run", RUNNER, "seed", DB_PATH])
            expect seed_code == 0
            expect (seed_stdout).contains("PERSISTENCE_SEEDED")
            expect (seed_stdout).contains("item=Persistent item")

            val (verify_stdout, _verify_stderr, verify_code) = rt_process_run("bin/simple", ["run", RUNNER, "verify", DB_PATH])
            expect verify_code == 0
            expect (verify_stdout).contains("PERSISTENCE_VERIFIED")
            expect (verify_stdout).contains("item=Persistent item")