use std.spec.{describe, it, expect}

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

fn _run_repl(args: [text]) -> (text, text, i64):
    val joined = args.join(" ")
    rt_process_run("/bin/sh", [
        "-c",
        "REPO=$(pwd); SIMPLE_LIB=\"$REPO/src\" \"$REPO/bin/simple\" run \"$REPO/src/app/repl/main.spl\" " + joined
    ])

describe "repl log mode CLI options":
    it "shows shared log options in help":
        val (out, err, code) = _run_repl(["--help"])
        expect(code).to_equal(0)
        expect(out).to_contain("--log-mode")
        expect(out).to_contain("--progress")

    it "supports log-mode json for ready output":
        val (out, err, code) = _run_repl(["--log-mode=json"])
        expect(code).to_equal(0)
        expect(out).to_contain("\"command\":\"repl\"")
        expect(out).to_contain("\"status\":\"ready\"")

    it "supports dot progress for ready output":
        val (out, err, code) = _run_repl(["--progress=dot"])
        expect(code).to_equal(0)
        expect(out).to_start_with(".")

    it "supports dot progress for help output":
        val (out, err, code) = _run_repl(["--progress=dot", "--help"])
        expect(code).to_equal(0)
        expect(out).to_start_with(".")
        expect(out).to_contain("Usage:")

    it "rejects invalid log mode":
        val (out, err, code) = _run_repl(["--log-mode=noisy"])
        expect(code).to_equal(1)
