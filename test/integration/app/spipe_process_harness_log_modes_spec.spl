use std.spec.{describe, it, expect}

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

val FIXTURE_DIR = "/tmp/simple_spipe_process_harness_log_mode_fixture"

fn _setup_fixture():
    val (_out, _err, _code) = rt_process_run("/bin/sh", [
        "-c",
        "rm -rf " + FIXTURE_DIR + " && mkdir -p " + FIXTURE_DIR
    ])

fn _run_harness(args: [text]) -> (text, text, i64):
    val joined = args.join(" ")
    rt_process_run("/bin/sh", [
        "-c",
        "REPO=$(pwd); cd " + FIXTURE_DIR + " && SIMPLE_LIB=\"$REPO/src\" \"$REPO/bin/simple\" run \"$REPO/src/app/spipe_process_harness/main.spl\" " + joined
    ])

describe "spipe-process-harness log mode CLI options":
    it "shows shared log options in help":
        _setup_fixture()
        val (out, err, code) = _run_harness(["--help"])
        expect(code).to_equal(0)
        expect(out).to_contain("--log-mode")
        expect(out).to_contain("--progress")

    it "supports log-mode json for state":
        _setup_fixture()
        val (out, err, code) = _run_harness(["--log-mode=json", "state", "--feature", "sample", "--approved"])
        expect(code).to_equal(0)
        expect(out).to_contain("\"command\":\"spipe-process-harness state\"")
        expect(out).to_contain("\"status\":\"ok\"")
        expect(out).to_contain(".spipe/sample/state.md")

    it "supports dot progress for state":
        _setup_fixture()
        val (out, err, code) = _run_harness(["--progress=dot", "state", "--feature", "sample", "--approved"])
        expect(code).to_equal(0)
        expect(out).to_contain(".")
        expect(out).to_contain(".spipe/sample/state.md")

    it "rejects invalid log mode":
        _setup_fixture()
        val (out, err, code) = _run_harness(["--log-mode=noisy", "state"])
        expect(code).to_equal(1)
