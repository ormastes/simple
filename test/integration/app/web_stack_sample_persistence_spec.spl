use app.web_stack_sample.{open_web_stack_sample}

extern fn rt_getpid() -> i64
extern fn rt_time_now_unix_micros() -> i64

val DB_PATH = "/tmp/web_stack_sample_persistence_{rt_getpid()}_{rt_time_now_unix_micros()}.sdn"
val USERNAME = "persist_user"
val EMAIL = "persist@example.com"
val PASSWORD = "persist-pass-123"
val TITLE = "Persistent item"
val DETAILS = "Created before restart and found after restart"

describe "web_stack_sample simpledb restart persistence":
    it "persists app-surface register create login and search across reopen":
        val seed_app = open_web_stack_sample("simpledb", DB_PATH)?
        val register = seed_app.post_register(USERNAME, EMAIL, PASSWORD)?
        expect(register.status).to_equal(302)
        expect(register.session_id.len()).to_be_greater_than(0)

        val item = seed_app.create_item(register.session_id, TITLE, DETAILS)?
        expect(item.title).to_equal(TITLE)

        val verify_app = open_web_stack_sample("simpledb", DB_PATH)?
        val login = verify_app.post_login(USERNAME, PASSWORD)?
        expect(login.status).to_equal(302)
        expect(login.session_id.len()).to_be_greater_than(0)

        val search = verify_app.search_items(login.session_id, "Persistent")?
        expect(search.status).to_equal(200)
        expect(search.body).to_contain("LOGIN-SUCCESS:{USERNAME}")
        expect(search.body).to_contain("SEARCH-HIT:{TITLE}")
        expect(search.body).to_contain(TITLE)
        expect(search.body).to_contain(DETAILS)
