extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_getpid() -> i64
extern fn rt_time_now_unix_micros() -> i64

class HarnessResult:
    stdout: text
    stderr: text
    code: i64

val TEST_ROOT = "/tmp/web_stack_sample_persistence_{rt_getpid()}_{rt_time_now_unix_micros()}"

fn test_root() -> text:
    TEST_ROOT

fn db_path() -> text:
    test_root() + "/sample.sdn"

fn run_harness(mode: text) -> HarnessResult:
    val root = test_root()
    val stdout_path = root + "/" + mode + ".stdout"
    val stderr_path = root + "/" + mode + ".stderr"
    val script =
        "mkdir -p '" + root + "'; " +
        "bin/simple run test/integration/app/web_stack_sample_persistence_runner.spl " +
        mode + " '" + db_path() + "' >'" + stdout_path + "' 2>'" + stderr_path + "'; " +
        "code=$?; " +
        "cat '" + stdout_path + "'; " +
        "cat '" + stderr_path + "' 1>&2; " +
        "exit $code"
    val result = rt_process_run("/bin/sh", ["-c", script])
    HarnessResult(stdout: result[0], stderr: result[1], code: result[2])

describe "web_stack_sample simpledb restart persistence":
    it "persists app-surface register create login and search across restart":
        val seed = run_harness("seed")
        expect(seed.code).to_equal(0)
        expect(seed.stdout).to_contain("PERSISTENCE_SEEDED")
        expect(seed.stdout).to_contain("item=Persistent item")

        val verify = run_harness("verify")
        expect(verify.code).to_equal(0)
        expect(verify.stdout).to_contain("PERSISTENCE_VERIFIED")
        expect(verify.stdout).to_contain("item=Persistent item")
