// reason: auto-generated spipe entry wrapper; examples and assertions live in the wrapped spec body


extern fn rt_file_read_text(path: text) -> text

val APP_SOURCE = "src/app/web_stack_sample/app.spl"
val BROWSER_PAGE = "src/lib/common/web/simple_browser_page.spl"

fn read_source(path: text) -> text:
    rt_file_read_text(path) ?? ""

fn main():
    describe "web_stack_sample browser lane contracts":
        it "uses plain html forms that the simple browser page adapter can drive":
            val app = read_source(APP_SOURCE)
            val browser = read_source(BROWSER_PAGE)
            expect (browser).contains("fn simple_browser_submit_request")
            expect (browser).contains("fn simple_browser_set_field_value")
            expect (app).contains("<input type=\"text\" name=\"username\"")
            expect (app).contains("<input type=\"text\" name=\"password\"")
            expect (app).contains("<input type=\"text\" name=\"title\"")
            expect (app).contains("<textarea name=\"details\">")
            expect (app).contains("<input type=\"search\" name=\"q\"")

        it "keeps route targets explicit for login create search and logout":
            val app = read_source(APP_SOURCE)
            expect (app).contains("action=\"/login\"")
            expect (app).contains("action=\"/register\"")
            expect (app).contains("action=\"/items/new\"")
            expect (app).contains("action=\"/items/search\"")
            expect (app).contains("action=\"/logout\"")
            expect (app).contains("action=\"/items/")
            expect (app).contains("/delete\"><button type=\"submit\">Delete</button>")