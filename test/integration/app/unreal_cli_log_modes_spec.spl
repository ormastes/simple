use std.spec.{describe, it, expect}

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

fn _run_unreal(args: [text]) -> (text, text, i64):
    val joined = args.join(" ")
    rt_process_run("/bin/sh", [
        "-c",
        "REPO=$(pwd); SIMPLE_LIB=\"$REPO/src\" \"$REPO/bin/simple\" run \"$REPO/src/app/unreal_cli/main.spl\" " + joined
    ])

fn _run_unreal_temp(args: [text]) -> (text, text, i64):
    val joined = args.join(" ")
    rt_process_run("/bin/sh", [
        "-c",
        "REPO=$(pwd); TMP=/tmp/simple_unreal_cli_$$; rm -rf \"$TMP\"; mkdir -p \"$TMP\"; cd \"$TMP\"; SIMPLE_LIB=\"$REPO/src\" \"$REPO/bin/simple\" run \"$REPO/src/app/unreal_cli/main.spl\" " + joined + "; CODE=$?; test -f \"$TMP/MyGame/MyGame.uproject\" && echo scaffold-ok; rm -rf \"$TMP\"; exit $CODE"
    ])

describe "unreal cli log mode CLI options":
    it "shows shared log options in help":
        val (out, err, code) = _run_unreal(["--help"])
        expect(code).to_equal(0)
        expect(out).to_contain("Usage: simple unreal-cli")
        expect(out).to_contain("--log-mode")
        expect(out).to_contain("--progress")

    it "supports log-mode json ready output":
        val (out, err, code) = _run_unreal(["--log-mode=json"])
        expect(code).to_equal(0)
        expect(out).to_contain("\"command\":\"unreal-cli\"")
        expect(out).to_contain("\"status\":\"ready\"")

    it "supports dot progress for help output":
        val (out, err, code) = _run_unreal(["--progress=dot", "--help"])
        expect(code).to_equal(0)
        expect(out).to_start_with(".")
        expect(out).to_contain("Usage: simple unreal-cli")

    it "rejects invalid log mode":
        val (out, err, code) = _run_unreal(["--log-mode=noisy"])
        expect(code).to_equal(1)

    it "creates an isolated Unreal project scaffold":
        val (out, err, code) = _run_unreal_temp(["new", "MyGame", "--log-mode=json"])
        expect(code).to_equal(0)
        expect(out).to_contain("\"action\":\"new\"")
        expect(out).to_contain("scaffold-ok")
