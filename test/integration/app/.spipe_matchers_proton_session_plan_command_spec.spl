extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

describe "Proton session plan command":
    it "prints a non-Wine Proton launch-session plan":
        val (stdout, stderr, code) = rt_process_run("bin/simple", ["run", "src/app/proton_session_plan/main.spl"])
        expect code == 0
        expect (stdout).contains("app_id=480\n")
        expect (stdout).contains("prefix=steamapps/compatdata/480/pfx\n")
        expect (stdout).contains("command=hl2.exe -novid\n")
        expect (stdout).contains("status=dry-run-ready\n")
        expect (stdout).contains("exec_env=mdsoc-ready\n")
        expect (stdout).contains("container=pressure-vessel")
        expect (stdout).contains("steam-runtime")
        expect (stdout).contains("pressure-vessel-container")
        expect (stdout).contains("dxvk")
        expect (stdout).contains("vkd3d-proton")
        expect stderr == ""