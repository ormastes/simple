use std.spec.{describe, it, expect}

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

val FIXTURE_MANIFEST = "/tmp/simple-plugin-log-modes/missing-manifest.sdn"

fn _run_plugin(args: [text]) -> (text, text, i64):
    val joined = args.join(" ")
    rt_process_run("/bin/sh", [
        "-c",
        "rm -rf /tmp/simple-plugin-log-modes && mkdir -p /tmp/simple-plugin-log-modes && REPO=$(pwd); SIMPLE_PLUGIN_MANIFEST=\"" + FIXTURE_MANIFEST + "\" SIMPLE_LIB=\"$REPO/src\" \"$REPO/bin/simple\" run \"$REPO/src/app/plugin/main.spl\" " + joined
    ])

describe "plugin log mode CLI options":
    it "shows shared log options in help":
        val (out, err, code) = _run_plugin(["plugin", "--help"])
        expect(code).to_equal(0)
        expect(out).to_contain("--log-mode")
        expect(out).to_contain("--progress")

    it "supports log-mode json for empty plugin list":
        val (out, err, code) = _run_plugin(["plugin", "--log-mode=json", "list"])
        expect(code).to_equal(0)
        expect(out).to_contain("\"command\":\"plugin list\"")
        expect(out).to_contain("\"status\":\"ok\"")
        expect(out).to_contain("\"count\":0")

    it "supports dot progress for empty plugin list":
        val (out, err, code) = _run_plugin(["plugin", "--progress=dot", "list"])
        expect(code).to_equal(0)
        expect(out).to_start_with(".")
        expect(out).to_contain("no plugins registered")

    it "rejects invalid log mode":
        val (out, err, code) = _run_plugin(["plugin", "--log-mode=noisy", "list"])
        expect(code).to_equal(1)
