use compiler.tools.fix.main.{collect_fixes_from_source}
use compiler.tools.fix.rules.impl.lint_primitive_api.{primitive_api_audit_report, primitive_api_audit_source}

fn count_visible_primitive_api(source: text) -> i64:
    val fixes = collect_fixes_from_source("sample.spl", source)
    val allow_primitive_api = source.contains("@allow(primitive_api)")
    var count = 0

    for fix in fixes:
        val parts = fix.id.split(":")
        if parts.len() >= 2 and parts[1] == "primitive_api" and not allow_primitive_api:
            count = count + 1

    count

describe "primitive_api lint":
    it "flags bare primitive public function parameter and return types":
        val source =
            "pub fn bad(x: i64) -> i64:\n" +
            "    return x\n"

        expect count_visible_primitive_api(source) == 2

    it "does not flag newunit semantic wrapper public APIs":
        val source =
            "newunit UserId: i64 as uid\n" +
            "\n" +
            "pub fn current_user() -> UserId:\n" +
            "    return 42_uid\n"

        expect count_visible_primitive_api(source) == 0

    it "audits bool and text public primitives without changing lint count":
        val source =
            "pub fn enabled(name: text) -> bool:\n" +
            "    return name.len() > 0\n"

        val entries = primitive_api_audit_source(source, "sample.spl")
        val report = primitive_api_audit_report(source, "sample.spl")
        expect count_visible_primitive_api(source) == 0
        expect entries.len() == 2
        expect (report).contains("needs_domain_text_type")
        expect (report).contains("needs_bool_wrapper_or_enum")

    it "respects allow primitive_api at file level":
        val source =
            "@allow(primitive_api)\n" +
            "pub fn bad(x: i64) -> i64:\n" +
            "    return x\n"

        expect count_visible_primitive_api(source) == 0