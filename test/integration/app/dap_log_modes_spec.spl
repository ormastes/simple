use std.spec.{describe, it, expect}

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

fn _run_dap(args: [text]) -> (text, text, i64):
    val joined = args.join(" ")
    rt_process_run("/bin/sh", [
        "-c",
        "REPO=$(pwd); SIMPLE_LIB=\"$REPO/src\" \"$REPO/bin/simple\" run \"$REPO/src/app/dap/main.spl\" " + joined
    ])

describe "dap log mode CLI options":
    it "shows shared log options in help":
        val (out, err, code) = _run_dap(["--help"])
        expect(code).to_equal(0)
        expect(out).to_contain("Simple Debug Adapter Protocol")
        expect(out).to_contain("--log-mode")
        expect(out).to_contain("--progress")

    it "supports log-mode json ready output":
        val (out, err, code) = _run_dap(["--log-mode=json"])
        expect(code).to_equal(0)
        expect(out).to_contain("\"command\":\"dap\"")
        expect(out).to_contain("\"status\":\"ready\"")

    it "supports dot progress for help output":
        val (out, err, code) = _run_dap(["--progress=dot", "--help"])
        expect(code).to_equal(0)
        expect(out).to_start_with(".")
        expect(out).to_contain("Simple Debug Adapter Protocol")

    it "rejects invalid log mode":
        val (out, err, code) = _run_dap(["--log-mode=noisy"])
        expect(code).to_equal(1)

    it "renders json version output":
        val (out, err, code) = _run_dap(["--log-mode=json", "--version"])
        expect(code).to_equal(0)
        expect(out).to_contain("\"version\":\"0.1.0\"")
