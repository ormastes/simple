extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

describe "Wine hello command":
    it "runs the known hello.exe milestone app with modeled stdout and exit code":
        val (stdout, stderr, code) = rt_process_run("bin/simple", ["run", "src/app/wine_hello/main.spl"])
        expect code == 0
        expect stdout == "Hello from SimpleOS Wine\n"
        expect stderr == ""