use std.spec.{describe, it, expect}

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

fn _run_constr(args: [text]) -> (text, text, i64):
    val joined = args.join(" ")
    rt_process_run("/bin/sh", [
        "-c",
        "REPO=$(pwd); SIMPLE_LIB=\"$REPO/src\" \"$REPO/bin/simple\" run \"$REPO/src/app/constr/main.spl\" " + joined
    ])

describe "constr log mode CLI options":
    it "shows shared log options in help":
        val (out, err, code) = _run_constr(["--help"])
        expect(code).to_equal(0)
        expect(out).to_contain("Usage: simple constr")
        expect(out).to_contain("--log-mode")
        expect(out).to_contain("--progress")

    it "supports log-mode json for experimental output":
        val (out, err, code) = _run_constr(["--log-mode=json"])
        expect(code).to_equal(1)
        expect(out).to_contain("\"command\":\"constr\"")
        expect(out).to_contain("\"status\":\"experimental\"")

    it "supports dot progress for help output":
        val (out, err, code) = _run_constr(["--progress=dot", "--help"])
        expect(code).to_equal(0)
        expect(out).to_start_with(".")
        expect(out).to_contain("Usage: simple constr")

    it "rejects invalid log mode":
        val (out, err, code) = _run_constr(["--log-mode=noisy"])
        expect(code).to_equal(1)

    it "preserves experimental not implemented behavior":
        val (out, err, code) = _run_constr([])
        expect(code).to_equal(1)
        expect(out).to_contain("Constraint checker is not yet implemented")
