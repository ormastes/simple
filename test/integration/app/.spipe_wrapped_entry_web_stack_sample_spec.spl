

extern fn rt_file_read_text(path: text) -> text

val APP_SOURCE = "src/app/web_stack_sample/app.spl"
val APP_CONFIG = "examples/web_stack_sample/app.sdn"
val ROUTES = "examples/web_stack_sample/routes.sdn"
val PERSISTENCE = "src/lib/nogc_sync_mut/web_framework/persistence.spl"
val SESSION = "src/lib/nogc_sync_mut/web_framework/session.spl"
val WEB_APP = "src/lib/nogc_async_mut/web_framework/app.spl"

fn read_source(path: text) -> text:
    rt_file_read_text(path) ?? ""

fn main():
    describe "web_stack_sample source contracts":
        it "defines the canonical backend selector and matching storage paths":
            val config = read_source(APP_CONFIG)
            val web_app = read_source(WEB_APP)
            expect (config).contains("backend_kind: \"simpledb\"")
            expect (config).contains("simpledb_path: \"build/web_stack_sample/sample.sdn\"")
            expect (web_app).contains("backend_kind: text")
            expect (web_app).contains("simpledb_path: text")
            expect (web_app).contains("if config.backend_kind == \"simpledb\":")
            expect (web_app).contains("SessionStore.simpledb")
            expect (web_app).contains("SessionStore.sqlite")

        it "declares the required auth crud and search routes":
            val routes = read_source(ROUTES)
            expect (routes).contains("pattern: \"/\"")
            expect (routes).contains("pattern: \"/register\"")
            expect (routes).contains("pattern: \"/login\"")
            expect (routes).contains("pattern: \"/logout\"")
            expect (routes).contains("pattern: \"/items\"")
            expect (routes).contains("pattern: \"/items/new\"")
            expect (routes).contains("pattern: \"/items/:id/edit\"")
            expect (routes).contains("pattern: \"/items/:id/delete\"")
            expect (routes).contains("pattern: \"/items/search\"")

        it "implements backend-neutral record storage and dual-backend sessions":
            val persistence = read_source(PERSISTENCE)
            val session = read_source(SESSION)
            expect (persistence).contains("class WebRecordStore<T>:")
            expect (persistence).contains("backend_kind: text")
            expect (persistence).contains("static fn sql")
            expect (persistence).contains("static fn simpledb")
            expect (persistence).contains("fn find_by_field_equals")
            expect (persistence).contains("fn find_by_field_contains")
            expect (session).contains("static fn sqlite")
            expect (session).contains("static fn simpledb")
            expect (session).contains("if self.backend_kind == \"sqlite\":")
            expect (session).contains("Failed to initialize Simple DB sessions")

        it "renders stable login created-item and search-result markers":
            val app = read_source(APP_SOURCE)
            expect (app).contains("data-test=\"login-page-marker\"")
            expect (app).contains("data-test=\"login-success-marker\"")
            expect (app).contains("data-test=\"created-item-marker\"")
            expect (app).contains("data-test=\"search-result-marker\"")
            expect (app).contains("form method=\"POST\" action=\"/login\"")
            expect (app).contains("form method=\"POST\" action=\"/items/new\"")
            expect (app).contains("form method=\"GET\" action=\"/items/search\"")
            expect (app).contains("fn post_register")
            expect (app).contains("fn post_login")
            expect (app).contains("fn post_new_item")
            expect (app).contains("fn search_items")