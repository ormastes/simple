# STM32H7 via ST-Link Tools Integration Test (Combo 1)
# Requires: STM32H7 board connected via built-in STLINK-V3
# Serial: 002600213137510833333639

extern fn rt_command_output(cmd: text) -> text

fn is_stm32h7_available() -> bool:
    val output = rt_command_output("st-info --probe 2>/dev/null")
    output.contains("002600213137510833333639")

describe "STM32H7 via ST-Link tools":
    it "probe detects board":
        if not is_stm32h7_available():
            skip("STM32H7 board not connected")
        val output = rt_command_output("st-info --probe")
        expect(output.contains("002600213137510833333639")).to_equal(true)

    it "chip_id is 0x480":
        if not is_stm32h7_available():
            skip("STM32H7 board not connected")
        val output = rt_command_output("st-info --chipid --serial=002600213137510833333639")
        expect(output.contains("0x0480") or output.contains("0x480")).to_equal(true)

    it "flash size is 2MB":
        if not is_stm32h7_available():
            skip("STM32H7 board not connected")
        val output = rt_command_output("st-info --flash --serial=002600213137510833333639")
        # 2MB = 0x200000
        expect(output.contains("0x200000") or output.contains("2097152")).to_equal(true)

    it "sram size is at least 128KB":
        if not is_stm32h7_available():
            skip("STM32H7 board not connected")
        val output = rt_command_output("st-info --sram --serial=002600213137510833333639")
        expect(output.len() > 0).to_equal(true)

    it "reset succeeds":
        if not is_stm32h7_available():
            skip("STM32H7 board not connected")
        val output = rt_command_output("st-flash --serial=002600213137510833333639 reset 2>&1")
        expect(output.len() > 0).to_equal(true)
