# T32 GDB Bridge Integration Test (Combo 6)
# Requires: Lauterbach Power Debug II + T32 GDB server enabled
# Uses: GDB via T32 GDB server on port 2331
# NOTE: Uses local data-only validation since hardware may not be available.

# --- Local copies ---

class T32GdbConfig:
    t32rem_path: text
    host: text
    t32_port: i32
    gdb_port: i32

impl T32GdbConfig:
    static fn default_config() -> T32GdbConfig:
        T32GdbConfig(
            t32rem_path: "/opt/t32/bin/pc_linux64/t32rem",
            host: "localhost",
            t32_port: 20000,
            gdb_port: 2331
        )

    fn t32rem_command(cmd: text) -> text:
        "{self.t32rem_path} {self.host} port={self.t32_port} {cmd}"

    fn enable_gdb_server_command() -> text:
        self.t32rem_command("System.Option GDBSERVER ON")

    fn set_gdb_port_command() -> text:
        self.t32rem_command("GDBSERVER.PORT {self.gdb_port}")

    fn disable_gdb_server_command() -> text:
        self.t32rem_command("System.Option GDBSERVER OFF")

    fn gdb_target() -> text:
        "{self.host}:{self.gdb_port}"

class GdbBreakpointConfig:
    address: text
    bp_id: i32

impl GdbBreakpointConfig:
    static fn at_address(addr: text) -> GdbBreakpointConfig:
        GdbBreakpointConfig(address: addr, bp_id: 1)

    fn set_command() -> text:
        "break *{self.address}"

    fn delete_command() -> text:
        "delete {self.bp_id}"

# --- Tests ---

describe "T32 GDB Bridge via T32 server":
    it "enable GDB server command is well-formed":
        val cfg = T32GdbConfig.default_config()
        val cmd = cfg.enable_gdb_server_command()
        expect(cmd.contains("GDBSERVER ON")).to_equal(true)
        expect(cmd.contains("t32rem")).to_equal(true)

    it "GDB target points to port 2331":
        val cfg = T32GdbConfig.default_config()
        expect(cfg.gdb_target()).to_equal("localhost:2331")
        expect(cfg.gdb_port).to_equal(2331)

    it "set and delete breakpoint commands are well-formed":
        val bp = GdbBreakpointConfig.at_address("0x08000000")
        expect(bp.set_command()).to_equal("break *0x08000000")
        expect(bp.delete_command()).to_equal("delete 1")

    it "disable GDB server command is well-formed":
        val cfg = T32GdbConfig.default_config()
        val cmd = cfg.disable_gdb_server_command()
        expect(cmd.contains("GDBSERVER OFF")).to_equal(true)

    it "set GDB port command includes port number":
        val cfg = T32GdbConfig.default_config()
        val cmd = cfg.set_gdb_port_command()
        expect(cmd.contains("GDBSERVER.PORT 2331")).to_equal(true)
