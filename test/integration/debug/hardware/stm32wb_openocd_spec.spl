# STM32WB via OpenOCD+GDB Integration Test (Combo 4)
# Requires: STM32WB board connected, OpenOCD installed, GDB multiarch
# Uses: board/stm32wb5x_nucleo.cfg, GDB port 3334
# NOTE: Uses local data-only validation since hardware may not be available.

# --- Local copies ---

class OpenocdConfig:
    cfg_path: text
    gdb_port: i32
    telnet_port: i32
    target_name: text

impl OpenocdConfig:
    static fn stm32wb() -> OpenocdConfig:
        OpenocdConfig(
            cfg_path: "board/stm32wb5x_nucleo.cfg",
            gdb_port: 3334,
            telnet_port: 4445,
            target_name: "STM32WB"
        )

    fn start_command() -> text:
        "openocd -f {self.cfg_path} -c 'gdb_port {self.gdb_port}' -c 'telnet_port {self.telnet_port}'"

    fn gdb_target() -> text:
        "localhost:{self.gdb_port}"

class GdbConnectConfig:
    target: text
    batch_mode: bool
    commands: [text]

impl GdbConnectConfig:
    static fn for_openocd(host: text, port: i32) -> GdbConnectConfig:
        GdbConnectConfig(
            target: "{host}:{port}",
            batch_mode: true,
            commands: [
                "target remote {host}:{port}",
                "monitor reset halt",
                "info reg pc",
                "disconnect",
                "quit"
            ]
        )

    fn command_count() -> i32:
        self.commands.len()

# --- Tests ---

describe "STM32WB via OpenOCD+GDB":
    it "OpenOCD config uses correct board file":
        val cfg = OpenocdConfig.stm32wb()
        expect(cfg.cfg_path).to_equal("board/stm32wb5x_nucleo.cfg")
        expect(cfg.target_name).to_equal("STM32WB")

    it "OpenOCD start command includes config and ports":
        val cfg = OpenocdConfig.stm32wb()
        val cmd = cfg.start_command()
        expect(cmd.contains("stm32wb5x_nucleo.cfg")).to_equal(true)
        expect(cmd.contains("3334")).to_equal(true)
        expect(cmd.contains("4445")).to_equal(true)

    it "GDB port is 3334":
        val cfg = OpenocdConfig.stm32wb()
        expect(cfg.gdb_port).to_equal(3334)
        expect(cfg.gdb_target()).to_equal("localhost:3334")

    it "GDB connect config has correct commands":
        val gdb = GdbConnectConfig.for_openocd("localhost", 3334)
        expect(gdb.batch_mode).to_equal(true)
        expect(gdb.target).to_equal("localhost:3334")
        expect(gdb.command_count()).to_equal(5)

    it "telnet port is 4445":
        val cfg = OpenocdConfig.stm32wb()
        expect(cfg.telnet_port).to_equal(4445)
