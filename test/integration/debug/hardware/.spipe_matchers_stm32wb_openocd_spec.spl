# STM32WB OpenOCD Integration Test
# Verifies the repo-managed STM32WB OpenOCD smoke lane is prepared.

extern fn rt_file_exists(path: text) -> bool

class OpenocdWbConfig:
    interface_cfg: text
    target_cfg: text
    gdb_port: i32
    telnet_port: i32
    fixture_asm: text
    fixture_ld: text

impl OpenocdWbConfig:
    static fn default_config() -> OpenocdWbConfig:
        OpenocdWbConfig(
            interface_cfg: "interface/stlink.cfg",
            target_cfg: "target/stm32wbx.cfg",
            gdb_port: 3334,
            telnet_port: 4334,
            fixture_asm: "test/fixtures/baremetal/stm_semihost_smoke.s",
            fixture_ld: "test/fixtures/baremetal/stm_semihost_smoke.ld"
        )

    fn launch_command() -> text:
        "openocd -f {self.interface_cfg} -f {self.target_cfg} -c gdb_port {self.gdb_port} -c telnet_port {self.telnet_port}"

describe "STM32WB OpenOCD repo readiness":
    it "uses the expected ST-LINK interface config":
        val cfg = OpenocdWbConfig.default_config()
        expect cfg.interface_cfg == "interface/stlink.cfg"

    it "uses the expected STM32WB target config":
        val cfg = OpenocdWbConfig.default_config()
        expect cfg.target_cfg == "target/stm32wbx.cfg"

    it "uses the expected ports":
        val cfg = OpenocdWbConfig.default_config()
        expect cfg.gdb_port == 3334
        expect cfg.telnet_port == 4334

    it "ships the shared STM smoke fixture":
        val cfg = OpenocdWbConfig.default_config()
        expect rt_file_exists(cfg.fixture_asm) == true
        expect rt_file_exists(cfg.fixture_ld) == true

    it "launch command is well-formed":
        val cfg = OpenocdWbConfig.default_config()
        val cmd = cfg.launch_command()
        expect cmd.contains("openocd") == true
        expect cmd.contains("interface/stlink.cfg") == true
        expect cmd.contains("target/stm32wbx.cfg") == true