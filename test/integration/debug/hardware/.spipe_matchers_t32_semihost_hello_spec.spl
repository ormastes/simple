# T32 semihost hello-world runner spec
# Verifies the repo ships a concrete TRACE32 firmware-load smoke path.

extern fn rt_file_exists(path: text) -> bool
extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

fn shell(command: text) -> text:
    val (stdout, stderr, _code) = rt_process_run("/bin/sh", ["-c", command])
    if stdout.len() > 0:
        return stdout
    stderr

describe "T32 semihost hello-world runner":
    it "ships the runner script":
        expect rt_file_exists("scripts/t32_semihost_hello.shs") == true

    it "reuses the shared STM semihost smoke fixture":
        expect rt_file_exists("test/fixtures/baremetal/stm_semihost_smoke.s") == true
        expect rt_file_exists("test/fixtures/baremetal/stm_semihost_smoke.ld") == true

    it "runner help documents board and build-only options":
        val output = shell("scripts/t32_semihost_hello.shs --help 2>&1")
        expect (output).contains("--board")
        expect (output).contains("--build-only")
        expect (output).contains("stm32wb")
        expect (output).contains("stm32h7")

    it "build-only mode emits the STM smoke ELF":
        val output = shell("scripts/t32_semihost_hello.shs --build-only 2>&1")
        expect (output).contains("built ELF:")
        expect (output).contains("stm_semihost_smoke")

    it "documents the expected semihost marker":
        val output = shell("sed -n '1,200p' scripts/t32_semihost_hello.shs")
        expect (output).contains("simple-stm-smoke")
        expect (output).contains("WinPrint.AREA MCP_OUT")