# Hardware Availability Check
# Shared utilities for detecting connected debug hardware.
# Integration tests use these to skip when hardware is absent.

extern fn rt_command_output(cmd: text) -> text

# Check if STM32H7 board is connected (STLINK-V3, serial 0026...)
fn is_stm32h7_available() -> bool:
    val output = rt_command_output("st-info --probe 2>/dev/null")
    output.contains("002600213137510833333639")

# Check if STM32WB board is connected (ST-LINK/V2.1, serial 0671...)
fn is_stm32wb_available() -> bool:
    val output = rt_command_output("st-info --probe 2>/dev/null")
    output.contains("0671FF555755846687041216")

# Check if st-info tool is installed
fn is_stlink_tools_available() -> bool:
    val output = rt_command_output("which st-info 2>/dev/null")
    output.len() > 0

# Check if Lauterbach T32 remote tool is available
fn is_t32_available() -> bool:
    val output = rt_command_output("ls /opt/t32/bin/pc_linux64/t32rem 2>/dev/null")
    output.contains("t32rem")

# Check if OpenOCD is installed
fn is_openocd_available() -> bool:
    val output = rt_command_output("which openocd 2>/dev/null")
    output.len() > 0

# Check if GDB multiarch is installed
fn is_gdb_available() -> bool:
    val output = rt_command_output("which gdb-multiarch 2>/dev/null")
    if output.len() > 0:
        return true
    val output2 = rt_command_output("which arm-none-eabi-gdb 2>/dev/null")
    output2.len() > 0

describe "Hardware detection":
    it "st-info tool check":
        val available = is_stlink_tools_available()
        # Just verify the check function runs without error
        expect(available == true or available == false).to_equal(true)

    it "T32 tool check":
        val available = is_t32_available()
        expect(available == true or available == false).to_equal(true)

    it "OpenOCD tool check":
        val available = is_openocd_available()
        expect(available == true or available == false).to_equal(true)
