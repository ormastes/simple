# T32 Native Integration Test (Combo 5)
# Requires: Lauterbach Power Debug II connected, t32rem available
# Uses: t32rem PRACTICE commands via USB PODBUS

extern fn rt_command_output(cmd: text) -> text

fn is_t32_available() -> bool:
    val output = rt_command_output("ls /opt/t32/bin/pc_linux64/t32rem 2>/dev/null")
    output.contains("t32rem")

fn t32rem(cmd: text) -> text:
    rt_command_output("/opt/t32/bin/pc_linux64/t32rem localhost port=20000 {cmd}")

describe "T32 Native via t32rem":
    it "t32rem is available":
        if not is_t32_available():
            skip("t32rem not found at /opt/t32/bin/pc_linux64/t32rem")
        val output = rt_command_output("ls /opt/t32/bin/pc_linux64/t32rem")
        expect(output.contains("t32rem")).to_equal(true)

    it "ping T32":
        if not is_t32_available():
            skip("t32rem not found")
        val output = t32rem("PING")
        expect(output.len() > 0).to_equal(true)

    it "SYStem.Up brings target online":
        if not is_t32_available():
            skip("t32rem not found")
        val output = t32rem("SYStem.Up")
        expect(output.len() >= 0).to_equal(true)

    it "read PC register":
        if not is_t32_available():
            skip("t32rem not found")
        t32rem("SYStem.Up")
        val output = t32rem("Register.Get PC")
        expect(output.len() > 0).to_equal(true)

    it "Break halts target":
        if not is_t32_available():
            skip("t32rem not found")
        val output = t32rem("Break")
        expect(output.len() >= 0).to_equal(true)
