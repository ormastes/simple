# T32 Native Integration Test (Combo 5)
# Requires: Lauterbach Power Debug II connected, t32rem available
# Uses: t32rem PRACTICE commands via USB PODBUS
# NOTE: Uses local data-only validation since hardware may not be available.

# --- Local copies ---

class T32Config:
    t32rem_path: text
    host: text
    port: i32

impl T32Config:
    static fn default_config() -> T32Config:
        T32Config(
            t32rem_path: "/opt/t32/bin/pc_linux64/t32rem",
            host: "localhost",
            port: 20000
        )

    fn command(cmd: text) -> text:
        "{self.t32rem_path} {self.host} port={self.port} {cmd}"

    fn ping_command() -> text:
        self.command("PING")

    fn system_up_command() -> text:
        self.command("SYStem.Up")

    fn register_get_command(reg: text) -> text:
        self.command("Register.Get {reg}")

    fn break_command() -> text:
        self.command("Break")

# --- Tests ---

describe "T32 Native via t32rem":
    it "t32rem path is correct":
        val cfg = T32Config.default_config()
        expect(cfg.t32rem_path).to_equal("/opt/t32/bin/pc_linux64/t32rem")

    it "ping command is well-formed":
        val cfg = T32Config.default_config()
        val cmd = cfg.ping_command()
        expect(cmd.contains("t32rem")).to_equal(true)
        expect(cmd.contains("PING")).to_equal(true)
        expect(cmd.contains("localhost")).to_equal(true)
        expect(cmd.contains("port=20000")).to_equal(true)

    it "SYStem.Up command is well-formed":
        val cfg = T32Config.default_config()
        val cmd = cfg.system_up_command()
        expect(cmd.contains("SYStem.Up")).to_equal(true)

    it "register get PC command is well-formed":
        val cfg = T32Config.default_config()
        val cmd = cfg.register_get_command("PC")
        expect(cmd.contains("Register.Get PC")).to_equal(true)

    it "break command is well-formed":
        val cfg = T32Config.default_config()
        val cmd = cfg.break_command()
        expect(cmd.contains("Break")).to_equal(true)
