# STM32WB via ST-Link Tools Integration Test (Combo 3)
# Requires: STM32WB board connected via built-in ST-LINK/V2.1
# Serial: 0671FF555755846687041216
# NOTE: Uses local data-only validation since hardware may not be available.

# --- Local copies ---

class StLinkProbeConfig:
    serial: text
    chip_id: text
    flash_size_bytes: i64
    sram_min_bytes: i64
    description: text

impl StLinkProbeConfig:
    static fn stm32wb() -> StLinkProbeConfig:
        StLinkProbeConfig(
            serial: "0671FF555755846687041216",
            chip_id: "0x0495",
            flash_size_bytes: 1048576,
            sram_min_bytes: 262144,
            description: "STM32WB via ST-LINK/V2.1"
        )

    fn flash_size_hex() -> text:
        "0x100000"

    fn flash_size_mb() -> i64:
        self.flash_size_bytes / (1024 * 1024)

    fn sram_min_kb() -> i64:
        self.sram_min_bytes / 1024

# --- Tests ---

describe "STM32WB via ST-Link tools":
    it "probe config has correct serial":
        val cfg = StLinkProbeConfig.stm32wb()
        expect(cfg.serial).to_equal("0671FF555755846687041216")

    it "chip_id is 0x0495":
        val cfg = StLinkProbeConfig.stm32wb()
        expect(cfg.chip_id).to_equal("0x0495")

    it "flash size is 1MB":
        val cfg = StLinkProbeConfig.stm32wb()
        expect(cfg.flash_size_bytes).to_equal(1048576)
        expect(cfg.flash_size_hex()).to_equal("0x100000")
        expect(cfg.flash_size_mb()).to_equal(1)

    it "sram minimum is 256KB":
        val cfg = StLinkProbeConfig.stm32wb()
        expect(cfg.sram_min_kb()).to_equal(256)
        expect(cfg.sram_min_bytes).to_equal(262144)

    it "description includes board name":
        val cfg = StLinkProbeConfig.stm32wb()
        expect(cfg.description.contains("STM32WB")).to_equal(true)
