# STM32WB via ST-Link Tools Integration Test (Combo 3)
# Requires: STM32WB board connected via built-in ST-LINK/V2.1
# Serial: 0671FF555755846687041216

extern fn rt_command_output(cmd: text) -> text

fn is_stm32wb_available() -> bool:
    val output = rt_command_output("st-info --probe 2>/dev/null")
    output.contains("0671FF555755846687041216")

describe "STM32WB via ST-Link tools":
    it "probe detects board":
        if not is_stm32wb_available():
            skip("STM32WB board not connected")
        val output = rt_command_output("st-info --probe")
        expect(output.contains("0671FF555755846687041216")).to_equal(true)

    it "chip_id is 0x495":
        if not is_stm32wb_available():
            skip("STM32WB board not connected")
        val output = rt_command_output("st-info --chipid --serial=0671FF555755846687041216")
        expect(output.contains("0x0495") or output.contains("0x495")).to_equal(true)

    it "flash size is 1MB":
        if not is_stm32wb_available():
            skip("STM32WB board not connected")
        val output = rt_command_output("st-info --flash --serial=0671FF555755846687041216")
        # 1MB = 0x100000
        expect(output.contains("0x100000") or output.contains("1048576")).to_equal(true)

    it "sram size is at least 256KB":
        if not is_stm32wb_available():
            skip("STM32WB board not connected")
        val output = rt_command_output("st-info --sram --serial=0671FF555755846687041216")
        expect(output.len() > 0).to_equal(true)

    it "reset succeeds":
        if not is_stm32wb_available():
            skip("STM32WB board not connected")
        val output = rt_command_output("st-flash --serial=0671FF555755846687041216 reset 2>&1")
        expect(output.len() > 0).to_equal(true)
