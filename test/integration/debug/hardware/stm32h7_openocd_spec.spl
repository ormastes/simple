# STM32H7 OpenOCD Integration Test
# Verifies the repo-managed STM32H7 OpenOCD smoke lane is prepared.

extern fn rt_file_exists(path: text) -> bool

class OpenocdH7Config:
    interface_cfg: text
    target_cfg: text
    gdb_port: i32
    telnet_port: i32
    fixture_asm: text
    fixture_ld: text

impl OpenocdH7Config:
    static fn default_config() -> OpenocdH7Config:
        OpenocdH7Config(
            interface_cfg: "interface/stlink.cfg",
            target_cfg: "target/stm32h7x.cfg",
            gdb_port: 3333,
            telnet_port: 4333,
            fixture_asm: "test/fixtures/baremetal/stm_semihost_smoke.s",
            fixture_ld: "test/fixtures/baremetal/stm_semihost_smoke.ld"
        )

    fn launch_command() -> text:
        "openocd -f {self.interface_cfg} -f {self.target_cfg} -c gdb_port {self.gdb_port} -c telnet_port {self.telnet_port}"

describe "STM32H7 OpenOCD repo readiness":
    it "uses the expected ST-LINK interface config":
        val cfg = OpenocdH7Config.default_config()
        expect(cfg.interface_cfg).to_equal("interface/stlink.cfg")

    it "uses the expected STM32H7 target config":
        val cfg = OpenocdH7Config.default_config()
        expect(cfg.target_cfg).to_equal("target/stm32h7x.cfg")

    it "uses the expected ports":
        val cfg = OpenocdH7Config.default_config()
        expect(cfg.gdb_port).to_equal(3333)
        expect(cfg.telnet_port).to_equal(4333)

    it "ships the shared STM smoke fixture":
        val cfg = OpenocdH7Config.default_config()
        expect(rt_file_exists(cfg.fixture_asm)).to_equal(true)
        expect(rt_file_exists(cfg.fixture_ld)).to_equal(true)

    it "launch command is well-formed":
        val cfg = OpenocdH7Config.default_config()
        val cmd = cfg.launch_command()
        expect(cmd.contains("openocd")).to_equal(true)
        expect(cmd.contains("interface/stlink.cfg")).to_equal(true)
        expect(cmd.contains("target/stm32h7x.cfg")).to_equal(true)
