# STM32H7 via OpenOCD+GDB Integration Test (Combo 2)
# Requires: STM32H7 board connected, OpenOCD installed, GDB multiarch
# Uses: board/stm32h7x3i_eval.cfg, GDB port 3333
# NOTE: Uses local data-only validation since hardware may not be available.

# --- Local copies ---

class OpenocdConfig:
    cfg_path: text
    gdb_port: i32
    telnet_port: i32
    target_name: text

impl OpenocdConfig:
    static fn stm32h7() -> OpenocdConfig:
        OpenocdConfig(
            cfg_path: "board/stm32h7x3i_eval.cfg",
            gdb_port: 3333,
            telnet_port: 4444,
            target_name: "STM32H7"
        )

    fn start_command() -> text:
        "openocd -f {self.cfg_path} -c 'gdb_port {self.gdb_port}' -c 'telnet_port {self.telnet_port}'"

    fn gdb_target() -> text:
        "localhost:{self.gdb_port}"

class GdbConnectConfig:
    target: text
    batch_mode: bool
    commands: [text]

impl GdbConnectConfig:
    static fn for_openocd(host: text, port: i32) -> GdbConnectConfig:
        GdbConnectConfig(
            target: "{host}:{port}",
            batch_mode: true,
            commands: [
                "target remote {host}:{port}",
                "monitor reset halt",
                "info reg pc",
                "disconnect",
                "quit"
            ]
        )

    fn command_count() -> i32:
        self.commands.len()

# --- Tests ---

describe "STM32H7 via OpenOCD+GDB":
    it "OpenOCD config uses correct board file":
        val cfg = OpenocdConfig.stm32h7()
        expect(cfg.cfg_path).to_equal("board/stm32h7x3i_eval.cfg")
        expect(cfg.target_name).to_equal("STM32H7")

    it "OpenOCD start command includes config and ports":
        val cfg = OpenocdConfig.stm32h7()
        val cmd = cfg.start_command()
        expect(cmd.contains("stm32h7x3i_eval.cfg")).to_equal(true)
        expect(cmd.contains("3333")).to_equal(true)
        expect(cmd.contains("4444")).to_equal(true)

    it "GDB port is 3333":
        val cfg = OpenocdConfig.stm32h7()
        expect(cfg.gdb_port).to_equal(3333)
        expect(cfg.gdb_target()).to_equal("localhost:3333")

    it "GDB connect config has correct commands":
        val gdb = GdbConnectConfig.for_openocd("localhost", 3333)
        expect(gdb.batch_mode).to_equal(true)
        expect(gdb.target).to_equal("localhost:3333")
        expect(gdb.command_count()).to_equal(5)

    it "telnet port is 4444":
        val cfg = OpenocdConfig.stm32h7()
        expect(cfg.telnet_port).to_equal(4444)
