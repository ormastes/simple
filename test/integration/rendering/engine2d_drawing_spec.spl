# @tag: rendering, engine2d, drawing
# @cover src/lib/gc_async_mut/gpu/engine2d/backend_cpu.spl 40%
"""
Engine2D Drawing Primitives — CPU Backend

Verifies that rect, circle, line, and triangle drawing primitives produce
correct pixels in the CPU backend framebuffer. All tests use a small
viewport for fast, deterministic pixel-exact assertions.
"""

use std.spec.{describe, context, it, expect}
use std.gc_async_mut.gpu.engine2d.engine.{Engine2D}
use std.gc_async_mut.gpu.engine2d.color.{rgb, color_r, color_g, color_b}

# ============================================================================
# Helpers
# ============================================================================

fn make_cpu_engine(w: i32, h: i32) -> Engine2D:
    """Create a CPU-backend engine cleared to black."""
    var engine = Engine2D.create_with_backend(w, h, "cpu")
    engine.clear(rgb(0, 0, 0))
    engine.present()
    engine

fn pixel_at_cpu(pixels: [u32], x: i32, y: i32, w: i32) -> u32:
    """Read a single pixel from the flat [u32] buffer."""
    pixels[y * w + x]

# ============================================================================
# Tests
# ============================================================================

describe "Engine2D Drawing Primitives":

    context "cpu backend":

        it "draw_rect_filled fills correct region":
            var engine = make_cpu_engine(10, 10)
            engine.draw_rect_filled(2, 2, 3, 3, rgb(255, 0, 0))
            engine.present()
            val pixels = engine.read_pixels()
            val inside = pixel_at_cpu(pixels, 3, 3, 10)
            expect(color_r(inside)).to_equal(255)
            expect(color_g(inside)).to_equal(0)
            val outside = pixel_at_cpu(pixels, 0, 0, 10)
            expect(color_r(outside)).to_equal(0)
            engine.shutdown()

        it "draw_rect draws outline only":
            var engine = make_cpu_engine(20, 20)
            engine.draw_rect(2, 2, 16, 16, rgb(0, 255, 0))
            engine.present()
            val pixels = engine.read_pixels()
            val border = pixel_at_cpu(pixels, 2, 2, 20)
            expect(color_g(border)).to_equal(255)
            val interior = pixel_at_cpu(pixels, 10, 10, 20)
            expect(color_g(interior)).to_equal(0)
            engine.shutdown()

        it "draw_circle_filled fills circular region":
            var engine = make_cpu_engine(20, 20)
            engine.draw_circle_filled(10, 10, 5, rgb(0, 0, 255))
            engine.present()
            val pixels = engine.read_pixels()
            val center = pixel_at_cpu(pixels, 10, 10, 20)
            expect(color_b(center)).to_equal(255)
            val corner = pixel_at_cpu(pixels, 0, 0, 20)
            expect(color_b(corner)).to_equal(0)
            engine.shutdown()

        it "draw_line draws diagonal pixels":
            var engine = make_cpu_engine(10, 10)
            engine.draw_line(0, 0, 9, 9, rgb(255, 255, 0), 1)
            engine.present()
            val pixels = engine.read_pixels()
            val on_line = pixel_at_cpu(pixels, 5, 5, 10)
            expect(color_r(on_line)).to_equal(255)
            val off_line = pixel_at_cpu(pixels, 0, 9, 10)
            expect(color_r(off_line)).to_equal(0)
            engine.shutdown()

        it "draw_triangle_filled fills triangular region":
            var engine = make_cpu_engine(30, 30)
            engine.draw_triangle_filled(15, 2, 2, 27, 28, 27, rgb(255, 0, 255))
            engine.present()
            val pixels = engine.read_pixels()
            val centroid = pixel_at_cpu(pixels, 15, 18, 30)
            expect(color_r(centroid)).to_equal(255)
            expect(color_b(centroid)).to_equal(255)
            val outside = pixel_at_cpu(pixels, 0, 0, 30)
            expect(color_r(outside)).to_equal(0)
            engine.shutdown()

        it "clear fills entire framebuffer":
            var engine = make_cpu_engine(8, 8)
            engine.clear(rgb(255, 0, 0))
            engine.present()
            val pixels = engine.read_pixels()
            val tl = pixel_at_cpu(pixels, 0, 0, 8)
            expect(color_r(tl)).to_equal(255)
            expect(color_g(tl)).to_equal(0)
            val br = pixel_at_cpu(pixels, 7, 7, 8)
            expect(color_r(br)).to_equal(255)
            engine.shutdown()
