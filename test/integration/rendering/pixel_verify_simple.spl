# Minimal Pixel-Level Drawing Verification
#
# Tests the core rendering pipeline without large struct returns
# that trigger the Cranelift sret ABI issue.
#
# Build: bin/simple native-build --source src/lib --source src/os --entry test/integration/rendering/pixel_verify_simple.spl -o build/pixel_verify --entry-closure
# Run:   ./build/pixel_verify

use std.gc_async_mut.gpu.browser_engine.browser_renderer.{render_html_to_pixel_array}
use std.gc_async_mut.gpu.engine2d.color.{rgb, color_r, color_g, color_b}

var total_checks: i32 = 0
var passed_checks: i32 = 0
var failed_checks: i32 = 0

fn check(name: text, condition: bool):
    total_checks = total_checks + 1
    if condition:
        passed_checks = passed_checks + 1
        print "  PASS: {name}"
    else:
        failed_checks = failed_checks + 1
        print "  FAIL: {name}"

fn pixel_near(px: u32, target: u32, threshold: i32) -> bool:
    val dr = color_r(px) - color_r(target)
    val dg = color_g(px) - color_g(target)
    val db = color_b(px) - color_b(target)
    var adr = dr
    if adr < 0: adr = 0 - adr
    var adg = dg
    if adg < 0: adg = 0 - adg
    var adb = db
    if adb < 0: adb = 0 - adb
    adr <= threshold and adg <= threshold and adb <= threshold

fn main():
    val W: i32 = 200
    val H: i32 = 150

    # ==================================================================
    # Test 1: Solid color background
    # ==================================================================
    print "=== Test 1: Solid Red Background ==="
    val red_html = "<html><body style=\"background: #FF0000; margin: 0; width: 200px; height: 150px;\"></body></html>"
    val red_pixels = render_html_to_pixel_array(red_html, W, H)
    check("red pixels array has correct length", red_pixels.len() == W * H)

    # Check first pixel is red
    if red_pixels.len() > 0:
        val px0 = red_pixels[0]
        val r0 = color_r(px0)
        val g0 = color_g(px0)
        val b0 = color_b(px0)
        print "  Pixel[0] = R:{r0} G:{g0} B:{b0}"
        check("first pixel is red-ish", r0 > 200 and g0 < 50 and b0 < 50)

    # ==================================================================
    # Test 2: Blue background
    # ==================================================================
    print "\n=== Test 2: Solid Blue Background ==="
    val blue_html = "<html><body style=\"background: #0000FF; margin: 0; width: 200px; height: 150px;\"></body></html>"
    val blue_pixels = render_html_to_pixel_array(blue_html, W, H)
    check("blue pixels array has correct length", blue_pixels.len() == W * H)

    if blue_pixels.len() > 0:
        val bpx = blue_pixels[0]
        val br = color_r(bpx)
        val bg = color_g(bpx)
        val bb = color_b(bpx)
        print "  Pixel[0] = R:{br} G:{bg} B:{bb}"
        check("first pixel is blue-ish", br < 50 and bg < 50 and bb > 200)

    # ==================================================================
    # Test 3: Red vs Blue are different
    # ==================================================================
    print "\n=== Test 3: Red vs Blue Comparison ==="
    if red_pixels.len() > 0 and blue_pixels.len() > 0:
        var diff_count: i32 = 0
        var idx = 0
        while idx < red_pixels.len() and idx < blue_pixels.len():
            if red_pixels[idx] != blue_pixels[idx]:
                diff_count = diff_count + 1
            idx = idx + 1
        val total = red_pixels.len()
        val pct = diff_count * 100 / total
        print "  Different pixels: {diff_count}/{total} ({pct}%)"
        check("red and blue are different", diff_count > total / 2)

    # ==================================================================
    # Test 4: Deterministic rendering
    # ==================================================================
    print "\n=== Test 4: Deterministic Rendering ==="
    val px4a = render_html_to_pixel_array(red_html, W, H)
    val px4b = render_html_to_pixel_array(red_html, W, H)
    check("render a has correct length", px4a.len() == W * H)
    check("render b has correct length", px4b.len() == W * H)

    var match_count: i32 = 0
    var mi = 0
    while mi < px4a.len() and mi < px4b.len():
        if px4a[mi] == px4b[mi]:
            match_count = match_count + 1
        mi = mi + 1
    print "  Matching pixels: {match_count}/{px4a.len()}"
    check("same HTML renders identically", match_count == px4a.len())

    # ==================================================================
    # Test 5: Non-trivial content (div with specific color)
    # ==================================================================
    print "\n=== Test 5: Div Element Rendering ==="
    val div_html = "<html><body style=\"margin:0; background:#FFFFFF;\"><div style=\"background:#00FF00; width:100px; height:50px;\"></div></body></html>"
    val div_pixels = render_html_to_pixel_array(div_html, W, H)
    check("div pixels has correct length", div_pixels.len() == W * H)

    # Check top-left pixel (should be green div)
    if div_pixels.len() > 0:
        val dpx = div_pixels[0]
        val dgr = color_r(dpx)
        val dgg = color_g(dpx)
        val dgb = color_b(dpx)
        print "  Top-left pixel = R:{dgr} G:{dgg} B:{dgb}"
        check("top-left has green from div", dgg > 200)

    # Check pixel at (150, 75) — should be white background (outside div)
    val bg_idx = 75 * W + 150
    if bg_idx < div_pixels.len():
        val bgpx = div_pixels[bg_idx]
        val bgr = color_r(bgpx)
        val bgg = color_g(bgpx)
        val bgb = color_b(bgpx)
        print "  Background pixel (150,75) = R:{bgr} G:{bgg} B:{bgb}"
        check("background pixel is white-ish", bgr > 200 and bgg > 200 and bgb > 200)

    # ==================================================================
    # Test 6: Per-channel difference analysis
    # ==================================================================
    print "\n=== Test 6: Per-Channel Analysis ==="
    if red_pixels.len() > 0 and blue_pixels.len() > 0:
        var r_diff: i32 = 0
        var g_diff: i32 = 0
        var b_diff: i32 = 0
        var ci = 0
        while ci < red_pixels.len() and ci < 1000:
            val rpx = red_pixels[ci]
            val bpx2 = blue_pixels[ci]
            var rd = color_r(rpx) - color_r(bpx2)
            if rd < 0: rd = 0 - rd
            var gd = color_g(rpx) - color_g(bpx2)
            if gd < 0: gd = 0 - gd
            var bd = color_b(rpx) - color_b(bpx2)
            if bd < 0: bd = 0 - bd
            r_diff = r_diff + rd
            g_diff = g_diff + gd
            b_diff = b_diff + bd
            ci = ci + 1
        print "  Red channel total diff:   {r_diff}"
        print "  Green channel total diff:  {g_diff}"
        print "  Blue channel total diff:   {b_diff}"
        check("red channel has large difference", r_diff > 10000)
        check("blue channel has large difference", b_diff > 10000)

    # ==================================================================
    # Summary
    # ==================================================================
    print "\n========================================"
    print "  Pixel Verification Summary"
    print "========================================"
    print "  Total checks: {total_checks}"
    print "  Passed:       {passed_checks}"
    print "  Failed:       {failed_checks}"
    if failed_checks == 0:
        print "  Result: ALL PASSED"
    else:
        print "  Result: {failed_checks} FAILURES"
    print "========================================"
