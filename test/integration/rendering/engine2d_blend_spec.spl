# @tag: rendering, engine2d, blend, gradient
# @cover src/lib/gc_async_mut/gpu/engine2d/backend_cpu.spl 30%

use std.spec.{describe, context, it, expect}
use std.gc_async_mut.gpu.engine2d.engine.{Engine2D}
use std.gc_async_mut.gpu.engine2d.color.{rgb, color_r, color_g, color_b}

fn _make_red_4x4() -> [u32]:
    var pixels: [u32] = []
    var i = 0
    while i < 16:
        pixels.push(rgb(255, 0, 0))
        i = i + 1
    pixels

fn _make_checker_2x2() -> [u32]:
    var pixels: [u32] = []
    pixels.push(rgb(255, 0, 0))
    pixels.push(rgb(0, 255, 0))
    pixels.push(rgb(0, 255, 0))
    pixels.push(rgb(255, 0, 0))
    pixels

describe "Engine2D Blend and Gradient":

    context "cpu backend":

        it "draw_gradient_rect creates vertical gradient":
            var engine = Engine2D.create_with_backend(10, 10, "cpu")
            engine.clear(rgb(0, 0, 0))
            engine.draw_gradient_rect(0, 0, 10, 10, rgb(255, 0, 0), rgb(0, 0, 255))
            engine.present()
            val pixels = engine.read_pixels()
            # Top row should be mostly red
            val top = pixels[0 * 10 + 5]
            expect(color_r(top)).to_equal(255)
            # Bottom row should be mostly blue
            val bot = pixels[9 * 10 + 5]
            expect(color_b(bot)).to_equal(255)
            engine.shutdown()

        it "draw_image blits pixel data":
            var engine = Engine2D.create_with_backend(10, 10, "cpu")
            engine.clear(rgb(0, 0, 0))
            val img = _make_red_4x4()
            engine.draw_image(1, 1, 4, 4, img)
            engine.present()
            val pixels = engine.read_pixels()
            val inside = pixels[2 * 10 + 2]
            expect(color_r(inside)).to_equal(255)
            val outside = pixels[0 * 10 + 0]
            expect(color_r(outside)).to_equal(0)
            engine.shutdown()

        it "draw_image preserves pixel pattern":
            var engine = Engine2D.create_with_backend(10, 10, "cpu")
            engine.clear(rgb(0, 0, 0))
            val checker = _make_checker_2x2()
            engine.draw_image(0, 0, 2, 2, checker)
            engine.present()
            val pixels = engine.read_pixels()
            val p00 = pixels[0 * 10 + 0]
            expect(color_r(p00)).to_equal(255)
            val p01 = pixels[0 * 10 + 1]
            expect(color_g(p01)).to_equal(255)
            engine.shutdown()
