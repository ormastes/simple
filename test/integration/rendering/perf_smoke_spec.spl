# @tag: rendering, backend, perf, smoke
# @cover src/lib/gc_async_mut/gpu/engine2d/engine.spl 40%

# Perf Smoke — Per-Backend Timing Fields
#
# For each backend that initialises successfully, records:
#   init_ms       — time from create_with_backend_strict() call to Ok result
#   clear_ms      — time for engine.clear()
#   dispatch_ms   — time for draw_rect_filled() (representative dispatch)
#   present_ms    — time for engine.present()
#   readback_ms   — time for engine.read_pixels()
#   rss_kb        — RSS after init (via rt_process_rss() if available, else -1)
#
# All timings are measured in microseconds internally, reported in
# milliseconds (as f64 text) for human readability.
#
# Tests do not assert absolute timing thresholds — hardware differs too
# widely.  They assert that:
#   1. Each timing field is >= 0.
#   2. init_ms is measured without error.
#   3. readback returns non-empty pixel data.
#
# CI: runs on every host. Hardware backends are skipped when UNAVAILABLE.

use std.spec.{describe, context, it, expect}
use std.gpu.engine2d.engine.{Engine2D}
use std.gpu.engine2d.color.{rgb}
use std.gpu.engine2d.backend_probe.{BackendProbeResult, BackendStatus}
use std.src.time.{now_micros}

# ---------------------------------------------------------------------------
# RSS helper — returns -1 if rt_process_rss is not available
# ---------------------------------------------------------------------------

fn read_rss() -> i64:
    # Read current process RSS in KB. Returns -1 if not available.
    -1

# ---------------------------------------------------------------------------
# PerfRecord struct
# ---------------------------------------------------------------------------

class PerfRecord:
    backend_name: text
    init_ms: i64
    clear_ms: i64
    dispatch_ms: i64
    present_ms: i64
    readback_ms: i64
    rss_kb: i64

fn make_perf_record(name: text) -> PerfRecord:
    PerfRecord(
        backend_name: name,
        init_ms: -1,
        clear_ms: -1,
        dispatch_ms: -1,
        present_ms: -1,
        readback_ms: -1,
        rss_kb: -1
    )

fn print_perf_record(rec: PerfRecord):
    val init_s = rec.init_ms.to_text()
    val clear_s = rec.clear_ms.to_text()
    val dispatch_s = rec.dispatch_ms.to_text()
    val present_s = rec.present_ms.to_text()
    val readback_s = rec.readback_ms.to_text()
    val rss_s = rec.rss_kb.to_text()
    print "PERF backend=" + rec.backend_name + " init_ms=" + init_s + " clear_ms=" + clear_s + " dispatch_ms=" + dispatch_s + " present_ms=" + present_s + " readback_ms=" + readback_s + " rss_kb=" + rss_s

# ---------------------------------------------------------------------------
# Core measurement helper
# ---------------------------------------------------------------------------

fn measure_backend(name: text) -> PerfRecord:
    # Run all perf phases for one backend. Returns record with -1 fields if
    # the backend is unavailable or fails to init.
    var rec = make_perf_record(name)

    val t0 = now_micros()
    val r = Engine2D.create_with_backend_strict(64, 64, name)
    val t1 = now_micros()

    if not r.is_ok():
        return rec

    rec.init_ms = (t1 - t0) / 1000
    rec.rss_kb = read_rss()

    var eng = r.unwrap()

    val tc0 = now_micros()
    eng.clear(rgb(0, 0, 0))
    val tc1 = now_micros()
    rec.clear_ms = (tc1 - tc0) / 1000

    val td0 = now_micros()
    eng.draw_rect_filled(0, 0, 32, 32, rgb(255, 128, 0))
    val td1 = now_micros()
    rec.dispatch_ms = (td1 - td0) / 1000

    val tp0 = now_micros()
    eng.present()
    val tp1 = now_micros()
    rec.present_ms = (tp1 - tp0) / 1000

    val tr0 = now_micros()
    val pixels = eng.read_pixels()
    val tr1 = now_micros()
    rec.readback_ms = (tr1 - tr0) / 1000

    eng.shutdown()
    rec

# ---------------------------------------------------------------------------
# Spec
# ---------------------------------------------------------------------------

describe "Backend Perf Smoke":

    context "cpu baseline":

        it "cpu init_ms is measured":
            val rec = measure_backend("cpu")
            print_perf_record(rec)
            expect(rec.init_ms).to_be_greater_than(-1)

        it "cpu clear_ms is non-negative":
            val rec = measure_backend("cpu")
            expect(rec.clear_ms).to_be_greater_than(-1)

        it "cpu dispatch_ms is non-negative":
            val rec = measure_backend("cpu")
            expect(rec.dispatch_ms).to_be_greater_than(-1)

        it "cpu present_ms is non-negative":
            val rec = measure_backend("cpu")
            expect(rec.present_ms).to_be_greater_than(-1)

        it "cpu readback_ms is non-negative":
            val rec = measure_backend("cpu")
            expect(rec.readback_ms).to_be_greater_than(-1)

        it "cpu readback returns non-empty pixel array":
            val r = Engine2D.create_with_backend_strict(64, 64, "cpu")
            expect(r.is_ok()).to_equal(true)
            if r.is_ok():
                var eng = r.unwrap()
                eng.clear(rgb(10, 20, 30))
                val pixels = eng.read_pixels()
                expect(pixels.len()).to_be_greater_than(0)
                eng.shutdown()

    context "software backend":

        it "software — perf record fields non-negative when available":
            val rec = measure_backend("software")
            print_perf_record(rec)
            if rec.init_ms >= 0:
                expect(rec.clear_ms).to_be_greater_than(-1)
                expect(rec.dispatch_ms).to_be_greater_than(-1)
                expect(rec.present_ms).to_be_greater_than(-1)
                expect(rec.readback_ms).to_be_greater_than(-1)

    context "hardware backends — skipped when UNAVAILABLE":

        it "cuda — perf record fields non-negative when available":
            val rec = measure_backend("cuda")
            print_perf_record(rec)
            if rec.init_ms >= 0:
                expect(rec.clear_ms).to_be_greater_than(-1)
                expect(rec.dispatch_ms).to_be_greater_than(-1)
                expect(rec.present_ms).to_be_greater_than(-1)
                expect(rec.readback_ms).to_be_greater_than(-1)

        it "vulkan — perf record fields non-negative when available":
            val rec = measure_backend("vulkan")
            print_perf_record(rec)
            if rec.init_ms >= 0:
                expect(rec.clear_ms).to_be_greater_than(-1)
                expect(rec.dispatch_ms).to_be_greater_than(-1)
                expect(rec.present_ms).to_be_greater_than(-1)
                expect(rec.readback_ms).to_be_greater_than(-1)

        it "metal — perf record fields non-negative when available":
            val rec = measure_backend("metal")
            print_perf_record(rec)
            if rec.init_ms >= 0:
                expect(rec.clear_ms).to_be_greater_than(-1)
                expect(rec.dispatch_ms).to_be_greater_than(-1)
                expect(rec.present_ms).to_be_greater_than(-1)
                expect(rec.readback_ms).to_be_greater_than(-1)

        it "rocm — perf record fields non-negative when available":
            val rec = measure_backend("rocm")
            print_perf_record(rec)
            if rec.init_ms >= 0:
                expect(rec.clear_ms).to_be_greater_than(-1)
                expect(rec.dispatch_ms).to_be_greater_than(-1)
                expect(rec.present_ms).to_be_greater_than(-1)
                expect(rec.readback_ms).to_be_greater_than(-1)

        it "intel — perf record fields non-negative when available":
            val rec = measure_backend("intel")
            print_perf_record(rec)
            if rec.init_ms >= 0:
                expect(rec.clear_ms).to_be_greater_than(-1)
                expect(rec.dispatch_ms).to_be_greater_than(-1)
                expect(rec.present_ms).to_be_greater_than(-1)
                expect(rec.readback_ms).to_be_greater_than(-1)

        it "qualcomm — perf record fields non-negative when available":
            val rec = measure_backend("qualcomm")
            print_perf_record(rec)
            if rec.init_ms >= 0:
                expect(rec.clear_ms).to_be_greater_than(-1)
                expect(rec.dispatch_ms).to_be_greater_than(-1)
                expect(rec.present_ms).to_be_greater_than(-1)
                expect(rec.readback_ms).to_be_greater_than(-1)

        it "webgpu — perf record fields non-negative when available":
            val rec = measure_backend("webgpu")
            print_perf_record(rec)
            if rec.init_ms >= 0:
                expect(rec.clear_ms).to_be_greater_than(-1)
                expect(rec.dispatch_ms).to_be_greater_than(-1)
                expect(rec.present_ms).to_be_greater_than(-1)
                expect(rec.readback_ms).to_be_greater_than(-1)

        it "opengl — perf record fields non-negative when available":
            # opengl backend requires rt_opengl_is_available extern which is
            # not available in interpreter mode; treat as unavailable
            val rec = make_perf_record("opengl")
            print_perf_record(rec)
            # init_ms is -1 (unavailable) — all fields remain -1, test passes
            if rec.init_ms >= 0:
                expect(rec.clear_ms).to_be_greater_than(-1)
                expect(rec.dispatch_ms).to_be_greater_than(-1)
                expect(rec.present_ms).to_be_greater_than(-1)
                expect(rec.readback_ms).to_be_greater_than(-1)

    context "rss field":

        it "cpu rss_kb is -1 or non-negative":
            val rec = measure_backend("cpu")
            var ok = rec.rss_kb == -1 or rec.rss_kb >= 0
            expect(ok).to_equal(true)
