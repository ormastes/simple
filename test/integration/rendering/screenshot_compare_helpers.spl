# Screenshot Compare Test Helpers
#
# Shared constants and helper functions for cross-backend rendering tests.
# Not a spec file — imported by the spec files in this directory.

use os.compositor.screenshot_compare.{
    ComparisonResult, compare_pixel_buffers, compare_with_tolerance,
    print_comparison_report, print_multi_backend_report, BackendCompareEntry}
use std.gc_async_mut.gpu.engine2d.engine.{Engine2D}
use std.gc_async_mut.gpu.browser_engine.backend_screenshot_capture.{BackendCapture}

# ============================================================================
# Threshold Constants
# ============================================================================

# Software vs CPU — both deterministic integer math, must be bit-exact
val THRESHOLD_EXACT: i32 = 0
val MIN_PCT_IDENTICAL: i64 = 10000   # 100.00%

# Software vs GPU (CUDA/Vulkan/OpenGL/Metal/ROCm/Intel)
# IEEE 754 float rounding may differ by +-1 or +-2 per channel
val THRESHOLD_GPU_ROUNDING: i32 = 2
val MIN_PCT_GPU_MATCH: i64 = 9990   # 99.90%

# Int32 vs Float64 effect engine
# Fixed-point 8.8 rounding and polynomial trig approximations
val THRESHOLD_EFFECT_ENGINE: i32 = 3
val MIN_PCT_EFFECT_MATCH: i64 = 9950  # 99.50%

# Web HTML pipeline vs widget-to-DOM pipeline
# Different DOM construction paths may cause layout differences
val THRESHOLD_CROSS_PIPELINE: i32 = 5
val MIN_PCT_PIPELINE_MATCH: i64 = 9800  # 98.00%

# Standard test viewport
val TEST_WIDTH: i32 = 400
val TEST_HEIGHT: i32 = 300

# ============================================================================
# Helper Functions
# ============================================================================

fn is_backend_available(name: text) -> bool:
    """Check if a specific Engine2D backend is available."""
    val backends = Engine2D.list_backends()
    for b in backends:
        if b == name:
            return true
    false

fn assert_backends_match(a: BackendCapture, b: BackendCapture, threshold: i32, min_pct: i64) -> bool:
    """Compare two backend captures and return true if within tolerance.

    Also prints a report if the match fails.
    """
    if not a.success:
        print "Backend '{a.backend_name}' failed: {a.error}"
        return false
    if not b.success:
        print "Backend '{b.backend_name}' failed: {b.error}"
        return false

    val result = compare_pixel_buffers(a.pixels, b.pixels, a.width, a.height, threshold)
    val passed = result.match_percentage >= min_pct

    if not passed:
        print "MISMATCH: {a.backend_name} vs {b.backend_name}"
        print_comparison_report(result)

    passed

fn build_compare_entry(name: text, result: ComparisonResult, threshold: i32, min_pct: i64) -> BackendCompareEntry:
    """Build a BackendCompareEntry for the multi-backend report."""
    BackendCompareEntry(
        backend_name: name,
        result: result,
        threshold: threshold,
        passed: result.match_percentage >= min_pct
    )
