"""WebGPU Strict Smoke Tests

@tag: rendering, engine2d, webgpu, strict
@cover src/lib/gc_async_mut/gpu/engine2d/backend_webgpu.spl 70%
@cover src/lib/gc_async_mut/gpu/engine2d/engine.spl 10%

Proves that WebGPU backend diagnostics are explicit rather than silent:
- probe_webgpu() always returns a typed BackendProbeResult
- Default builds (no webgpu-real feature) return Unavailable with gate="webgpu-real"
- create_with_backend_strict("webgpu") returns Err on default builds
- When webgpu-real is enabled and an adapter is present, runs the full
  clear → draw_rect → upload_pixels → present → readback pipeline on a
  16x16 off-screen texture.
"""

use std.spec.{describe, context, it, expect}
use std.gc_async_mut.gpu.engine2d.engine.{Engine2D}
use std.gc_async_mut.gpu.engine2d.color.{rgb}
use std.gc_async_mut.gpu.engine2d.backend_probe.{BackendProbeResult, BackendStatus}
use std.gc_async_mut.gpu.engine2d.backend_webgpu.{probe_webgpu}

# ============================================================================
# Helpers
# ============================================================================

fn status_is_terminal_failure(probe: BackendProbeResult) -> bool:
    var s = probe.status
    s == BackendStatus.Failed or s == BackendStatus.Unavailable

fn color_red_u32() -> u32:
    rgb(255, 0, 0)

fn color_green_u32() -> u32:
    rgb(0, 255, 0)

# ============================================================================
# Tests
# ============================================================================

describe "WebGPU strict smoke tests":

    context "probe_webgpu diagnostics":

        it "probe_webgpu returns a typed BackendProbeResult":
            val probe = probe_webgpu()
            val ok = probe.is_ok() or status_is_terminal_failure(probe)
            expect(ok).to_equal(true)

        it "probe_webgpu reports requested_name as webgpu":
            val probe = probe_webgpu()
            expect(probe.requested_name).to_equal("webgpu")

        it "probe_webgpu on unavailable carries non-empty fallback_reason":
            val probe = probe_webgpu()
            if not probe.is_ok():
                expect(probe.fallback_reason).to_not_equal("")

        it "probe_webgpu diagnostic_text is non-empty":
            val probe = probe_webgpu()
            val txt = probe.diagnostic_text()
            expect(txt.len()).to_be_greater_than(0)

    context "default build — webgpu-real feature off":

        it "probe_webgpu returns Unavailable status when feature gate is off":
            val probe = probe_webgpu()
            if not probe.is_ok():
                expect(probe.status).to_equal(BackendStatus.Unavailable)

        it "probe_webgpu feature_gate mentions webgpu-real when unavailable":
            val probe = probe_webgpu()
            if not probe.is_ok():
                expect(probe.feature_gate).to_equal("webgpu-real")

        it "probe_webgpu fallback_reason is non-empty when unavailable":
            val probe = probe_webgpu()
            if not probe.is_ok():
                expect(probe.fallback_reason).to_not_equal("")

        it "probe_webgpu selected_name is cpu when unavailable":
            val probe = probe_webgpu()
            if not probe.is_ok():
                expect(probe.selected_name).to_equal("cpu")

    context "webgpu-real enabled — off-screen adapter smoke":

        it "probe_webgpu reports success when adapter is available":
            val probe = probe_webgpu()
            if probe.is_ok():
                expect(probe.selected_name).to_equal("webgpu")
                expect(probe.shader_format).to_equal("wgsl")

        it "create_with_backend_strict succeeds and returns Engine2D when adapter present":
            val probe = probe_webgpu()
            if probe.is_ok():
                val result = Engine2D.create_with_backend_strict(16, 16, "webgpu")
                expect(result.is_ok()).to_equal(true)
                var engine = result.unwrap()
                engine.shutdown()

        it "off-screen texture upload and readback returns 16x16 pixel buffer":
            val probe = probe_webgpu()
            if probe.is_ok():
                val result = Engine2D.create_with_backend_strict(16, 16, "webgpu")
                if result.is_ok():
                    var engine = result.unwrap()
                    engine.clear(color_red_u32())
                    engine.draw_rect_filled(4, 4, 8, 8, color_green_u32())
                    engine.present()
                    val pixels = engine.read_pixels()
                    expect(pixels.len()).to_equal(256)
                    engine.shutdown()

        it "corner pixels are red after clear with red":
            val probe = probe_webgpu()
            if probe.is_ok():
                val result = Engine2D.create_with_backend_strict(16, 16, "webgpu")
                if result.is_ok():
                    var engine = result.unwrap()
                    engine.clear(color_red_u32())
                    engine.present()
                    val pixels = engine.read_pixels()
                    expect(pixels[0]).to_equal(color_red_u32())
                    expect(pixels[255]).to_equal(color_red_u32())
                    engine.shutdown()
