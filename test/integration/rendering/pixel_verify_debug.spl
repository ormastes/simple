# Debug pixel verification — trace what the rendering pipeline produces
#
# Build: bin/simple native-build --source src/lib --source src/os --entry test/integration/rendering/pixel_verify_debug.spl -o build/pixel_verify_debug --entry-closure --runtime-bundle all
# Run:   ./build/pixel_verify_debug

use std.gc_async_mut.gpu.browser_engine.browser_renderer.{browser_renderer_html_string_to_dom, render_html_to_pixel_array}
use std.gc_async_mut.gpu.browser_engine.layout.{layout_tree}
use std.gc_async_mut.gpu.browser_engine.paint.{generate_paint_list, paint_commands_to_scene}
use std.gc_async_mut.gpu.engine2d.color.{rgb, color_r, color_g, color_b, color_a}
use common.render_scene.executor.{execute_scene_to_buffer}

fn main():
    val W: i32 = 10
    val H: i32 = 10

    print "=== Pipeline Trace ==="

    # Step 1: Parse HTML to DOM
    val html = "<html><head><style>body { background-color: #FF0000; }</style></head><body></body></html>"
    print "HTML: {html}"
    val dom = browser_renderer_html_string_to_dom(html)
    print "DOM root tag: {dom.tag}"
    print "DOM children: {dom.children.len()}"
    if dom.children.len() > 0:
        var ci = 0
        while ci < dom.children.len():
            val child = dom.children[ci]
            print "  child[{ci}] tag={child.tag} style.bg_color=0x{child.style.background_color}"
            ci = ci + 1

    # Step 2: Layout
    val layout = layout_tree(dom, W, H)
    print "\nLayout: x={layout.x} y={layout.y} w={layout.width} h={layout.height}"
    print "Layout content: cx={layout.content_x} cy={layout.content_y} cw={layout.content_width} ch={layout.content_height}"

    # Step 3: Paint commands
    val commands = generate_paint_list(layout)
    print "\nPaint commands: {commands.len()}"
    var pi = 0
    while pi < commands.len():
        val cmd = commands[pi]
        print "  cmd[{pi}] kind={cmd.kind} x={cmd.x} y={cmd.y} w={cmd.width} h={cmd.height} color=0x{cmd.color}"
        pi = pi + 1

    # Step 4: Scene commands
    val scene = paint_commands_to_scene(commands, W, H)
    print "\nScene commands: {scene.len()}"
    var si = 0
    while si < scene.len() and si < 5:
        print "  scene[{si}]"
        si = si + 1

    # Step 5: Execute to pixels
    var pixels: [u32] = []
    var i = 0
    while i < W * H:
        rt_array_push(pixels, 0xFFFFFFFF)
        i = i + 1
    execute_scene_to_buffer(scene, pixels, W, H)

    print "\nPixels (first 5):"
    var j = 0
    while j < 5 and j < pixels.len():
        val p = pixels[j]
        print "  [{j}] R:{color_r(p)} G:{color_g(p)} B:{color_b(p)} A:{color_a(p)} raw:0x{p}"
        j = j + 1

    print "\nDone."
