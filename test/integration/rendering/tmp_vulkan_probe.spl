use std.gpu.engine2d.backend_vulkan.{VulkanBackend}
use std.gpu.engine2d.color.{rgb}

fn main():
    print("probe-start")
    var backend = VulkanBackend.create()
    print("created")
    val ok = backend.init(8, 8)
    print("init=" + ok.to_text())
    backend.clear(rgb(1, 2, 3))
    backend.present()
    val pixels = backend.read_pixels()
    print("pixels=" + pixels.len().to_text())
    backend.shutdown()
