"""Helpers Parity Spec

Focused parity tests proving that the extracted shared helpers
(helpers_clip, helpers_pixel, helpers_text, helpers_availability)
produce the same results as the inline code they replace inside
the CPU/software backends.

@tag: rendering, engine2d, helpers
@cover src/lib/gc_async_mut/gpu/engine2d/helpers_clip.spl 80%
@cover src/lib/gc_async_mut/gpu/engine2d/helpers_pixel.spl 80%
@cover src/lib/gc_async_mut/gpu/engine2d/helpers_text.spl 80%
@cover src/lib/gc_async_mut/gpu/engine2d/helpers_availability.spl 70%
"""

use std.spec.{describe, it, expect}
use std.gpu.engine2d.helpers_clip.{
    clip_point_in_bounds, clip_point_in_rect,
    clip_pixel_allowed, rect_intersect_w, rect_intersect_h,
    clip_rect_to_viewport, mask_blocks_at, pixel_index
}
use std.gpu.engine2d.helpers_pixel.{
    buf_get_pixel, buf_set_pixel, buf_set_pixel_blend,
    alpha_premultiply, alpha_unpremultiply,
    pixels_to_bytes, bytes_to_pixels
}
use std.gpu.engine2d.helpers_text.{
    text_buf_width, text_buf_height, text_scale, text_render_to_buf
}
use std.gpu.engine2d.helpers_availability.{
    backend_display_name, backend_priority, backend_is_hardware,
    backend_requires_gpu, feature_gate_description,
    backend_i64, backend_bool_to_i32
}
use std.gpu.engine2d.color.{rgba, rgb, color_r, color_g, color_b, color_a, blend}

# ============================================================================
# helpers_clip parity
# ============================================================================

describe "helpers_clip — bounds checking":

    it "clip_point_in_bounds: interior point is in bounds":
        expect(clip_point_in_bounds(5, 5, 10, 10)).to_be_true()

    it "clip_point_in_bounds: (0,0) is in bounds":
        expect(clip_point_in_bounds(0, 0, 10, 10)).to_be_true()

    it "clip_point_in_bounds: right edge (exclusive) is out of bounds":
        expect(clip_point_in_bounds(10, 5, 10, 10)).to_be_false()

    it "clip_point_in_bounds: bottom edge (exclusive) is out of bounds":
        expect(clip_point_in_bounds(5, 10, 10, 10)).to_be_false()

    it "clip_point_in_bounds: negative x is out of bounds":
        expect(clip_point_in_bounds(-1, 5, 10, 10)).to_be_false()

    it "clip_point_in_rect: point inside clip rect":
        expect(clip_point_in_rect(6, 6, 5, 5, 5, 5)).to_be_true()

    it "clip_point_in_rect: point outside clip rect":
        expect(clip_point_in_rect(3, 3, 5, 5, 5, 5)).to_be_false()

    it "clip_pixel_allowed: no clip — passes bounds check":
        expect(clip_pixel_allowed(3, 3, 10, 10, false, 0, 0, 10, 10)).to_be_true()

    it "clip_pixel_allowed: clip enabled, point inside — allowed":
        expect(clip_pixel_allowed(6, 6, 10, 10, true, 5, 5, 5, 5)).to_be_true()

    it "clip_pixel_allowed: clip enabled, point outside — blocked":
        expect(clip_pixel_allowed(3, 3, 10, 10, true, 5, 5, 5, 5)).to_be_false()

    it "clip_pixel_allowed: out of framebuffer — blocked regardless of clip":
        expect(clip_pixel_allowed(-1, 5, 10, 10, false, 0, 0, 10, 10)).to_be_false()

    it "rect_intersect_w: overlapping rects":
        val w = rect_intersect_w(0, 8, 4, 8)
        expect(w).to_equal(4)

    it "rect_intersect_w: disjoint rects yields non-positive width":
        val w = rect_intersect_w(0, 5, 10, 5)
        expect(w <= 0).to_be_true()

    it "rect_intersect_h: overlapping rects":
        val h = rect_intersect_h(0, 8, 4, 8)
        expect(h).to_equal(4)

    it "clip_rect_to_viewport: rect fully inside":
        expect(clip_rect_to_viewport(1, 1, 5, 5, 10, 10)).to_be_true()

    it "clip_rect_to_viewport: rect fully outside right":
        expect(clip_rect_to_viewport(15, 0, 5, 5, 10, 10)).to_be_false()

    it "clip_rect_to_viewport: rect fully outside top":
        expect(clip_rect_to_viewport(0, -10, 5, 5, 10, 10)).to_be_false()

    it "pixel_index: correct flat index":
        expect(pixel_index(3, 2, 10)).to_equal(23)

describe "helpers_clip — mask":

    it "mask_blocks_at: empty mask never blocks":
        var empty_mask: [u8] = []
        expect(mask_blocks_at(empty_mask, 10, 5, 5)).to_be_false()

    it "mask_blocks_at: mask byte 0 blocks":
        var mask: [u8] = [1u8, 0u8, 1u8]
        expect(mask_blocks_at(mask, 3, 1, 0)).to_be_true()

    it "mask_blocks_at: mask byte 1 does not block":
        var mask: [u8] = [1u8, 0u8, 1u8]
        expect(mask_blocks_at(mask, 3, 0, 0)).to_be_false()

    it "mask_blocks_at: out-of-range coordinate does not block":
        var mask: [u8] = [0u8]
        expect(mask_blocks_at(mask, 1, 5, 5)).to_be_false()

# ============================================================================
# helpers_pixel parity
# ============================================================================

describe "helpers_pixel — buffer access":

    it "buf_get_pixel: returns 0 for out-of-bounds":
        var buf: [u32] = [0xFFFF0000u32]
        expect(buf_get_pixel(buf, 1, 0, 1, 1)).to_equal(0u32)

    it "buf_get_pixel: reads in-bounds pixel":
        var buf: [u32] = [0u32, 0u32, 0xAABBCCDDu32, 0u32]
        val got = buf_get_pixel(buf, 2, 0, 4, 1)
        expect(got).to_equal(0xAABBCCDDu32)

    it "buf_set_pixel: writes in-bounds pixel":
        var buf: [u32] = [0u32, 0u32, 0u32, 0u32]
        buf_set_pixel(buf, 2, 0, 4, 1, 0xDEADBEEFu32)
        expect(buf[2]).to_equal(0xDEADBEEFu32)

    it "buf_set_pixel: out-of-bounds write is ignored":
        var buf: [u32] = [0u32]
        buf_set_pixel(buf, 5, 5, 1, 1, 0xFFFFFFFFu32)
        expect(buf[0]).to_equal(0u32)

    it "buf_set_pixel_blend: opaque src replaces dst":
        var buf: [u32] = [rgb(0, 0, 0)]
        val src = rgb(255, 0, 0)
        buf_set_pixel_blend(buf, 0, 0, 1, 1, src)
        expect(color_r(buf[0])).to_equal(255)

    it "buf_set_pixel_blend: transparent src leaves dst unchanged":
        var buf: [u32] = [rgb(0, 255, 0)]
        val src = rgba(255, 0, 0, 0)
        buf_set_pixel_blend(buf, 0, 0, 1, 1, src)
        expect(color_g(buf[0])).to_equal(255)

describe "helpers_pixel — alpha compositing":

    it "alpha_premultiply: opaque color is unchanged":
        val c = rgb(100, 150, 200)
        expect(alpha_premultiply(c)).to_equal(c)

    it "alpha_premultiply: transparent returns 0":
        val c = rgba(255, 255, 255, 0)
        expect(alpha_premultiply(c)).to_equal(0u32)

    it "alpha_premultiply: 50% alpha halves RGB":
        val c = rgba(200, 200, 200, 128)
        val pm = alpha_premultiply(c)
        val r = color_r(pm)
        expect(r >= 98 and r <= 102).to_be_true()

    it "alpha_unpremultiply: zero alpha returns 0":
        expect(alpha_unpremultiply(0u32)).to_equal(0u32)

    it "alpha_unpremultiply: opaque color is unchanged":
        val c = rgb(80, 160, 240)
        expect(alpha_unpremultiply(c)).to_equal(c)

    it "pixels_to_bytes: 4 bytes per pixel":
        expect(pixels_to_bytes(10)).to_equal(40)

    it "bytes_to_pixels: inverse of pixels_to_bytes":
        expect(bytes_to_pixels(pixels_to_bytes(7))).to_equal(7)

# ============================================================================
# helpers_text parity
# ============================================================================

describe "helpers_text — dimensions":

    it "text_buf_height equals glyph_height at font_size 7":
        val h = text_buf_height(7)
        expect(h).to_equal(7)

    it "text_buf_height scales with font_size":
        val h = text_buf_height(14)
        expect(h).to_equal(14)

    it "text_buf_width: empty string returns 0":
        expect(text_buf_width("", 7)).to_equal(0)

    it "text_buf_width: single char at scale 1":
        # advance = 5 * scale (unified with browser paint); scale = 7/7 = 1
        expect(text_buf_width("A", 7)).to_equal(5)

    it "text_buf_width: 3 chars at scale 1":
        expect(text_buf_width("ABC", 7)).to_equal(15)

    it "text_scale: font_size 7 gives scale 1":
        expect(text_scale(7)).to_equal(1)

    it "text_scale: font_size 14 gives scale 2":
        expect(text_scale(14)).to_equal(2)

    it "text_scale: font_size < 7 is clamped to 1":
        expect(text_scale(1)).to_equal(1)

describe "helpers_text — render_to_buf":

    it "text_render_to_buf: empty text returns empty buffer":
        val buf = text_render_to_buf("", 0xFFFFFFFFu32, 0xFF000000u32, 7)
        expect(buf.len()).to_equal(0)

    it "text_render_to_buf: buffer size matches dimensions":
        val buf = text_render_to_buf("Hi", 0xFFFFFFFFu32, 0xFF000000u32, 7)
        val expected_len = text_buf_width("Hi", 7) * text_buf_height(7)
        expect(buf.len()).to_equal(expected_len)

    it "text_render_to_buf: background color fills non-glyph pixels":
        val bg = rgba(0, 0, 255, 255)
        val fg = rgba(255, 0, 0, 255)
        val buf = text_render_to_buf(" ", fg, bg, 7)
        # Space glyph has no set bits — entire buffer should be background
        var all_bg = true
        var bi = 0
        while bi < buf.len():
            if buf[bi] != bg:
                all_bg = false
            bi = bi + 1
        expect(all_bg).to_be_true()

    it "text_render_to_buf: parity with inline draw_text_bg pattern":
        # This mirrors the body in each GPU backend's draw_text_bg:
        #   fill buffer with bg, call render_text_to_buffer, blit.
        # We verify text_render_to_buf produces same buffer as the inline form.
        use std.gpu.engine2d.glyph.{glyph_height, glyph_advance, render_text_to_buffer}
        val text_val = "X"
        val font_size = 7
        val fg = rgb(255, 255, 255)
        val bg = rgb(0, 0, 0)
        val gh = glyph_height()
        var scale = font_size / gh
        if scale < 1:
            scale = 1
        val advance = glyph_advance(scale)
        val text_w = text_val.len().to_i32() * advance
        val text_h = gh * scale
        var inline_buf: [u32] = []
        var fill_i = 0
        while fill_i < text_w * text_h:
            inline_buf.push(bg)
            fill_i = fill_i + 1
        render_text_to_buffer(inline_buf, text_w, text_h, 0, 0, text_val, fg, font_size)
        val helper_buf = text_render_to_buf(text_val, fg, bg, font_size)
        expect(helper_buf.len()).to_equal(inline_buf.len())
        var match_ok = true
        var ci = 0
        while ci < inline_buf.len():
            if inline_buf[ci] != helper_buf[ci]:
                match_ok = false
            ci = ci + 1
        expect(match_ok).to_be_true()

# ============================================================================
# helpers_availability parity
# ============================================================================

describe "helpers_availability — backend names":

    it "backend_display_name: cuda":
        val n = backend_display_name("cuda")
        expect(n).to_equal("NVIDIA CUDA")

    it "backend_display_name: vulkan":
        val n = backend_display_name("vulkan")
        expect(n).to_equal("Vulkan Compute")

    it "backend_display_name: cpu":
        val n = backend_display_name("cpu")
        expect(n).to_equal("CPU Software (fallback)")

    it "backend_display_name: unknown":
        val n = backend_display_name("unknown_xyz")
        expect(n.starts_with("Unknown")).to_be_true()

    it "backend_priority: cuda is highest priority (0)":
        expect(backend_priority("cuda")).to_equal(0)

    it "backend_priority: cpu is lowest priority (9)":
        expect(backend_priority("cpu")).to_equal(9)

    it "backend_priority: vulkan < software < cpu":
        val v = backend_priority("vulkan")
        val s = backend_priority("software")
        val c = backend_priority("cpu")
        expect(v < s).to_be_true()
        expect(s < c).to_be_true()

    it "backend_is_hardware: cuda is hardware":
        expect(backend_is_hardware("cuda")).to_be_true()

    it "backend_is_hardware: cpu is not hardware":
        expect(backend_is_hardware("cpu")).to_be_false()

    it "backend_is_hardware: software is not hardware":
        expect(backend_is_hardware("software")).to_be_false()

    it "backend_requires_gpu: cuda requires GPU":
        expect(backend_requires_gpu("cuda")).to_be_true()

    it "backend_requires_gpu: vulkan does not require (can software fallback)":
        expect(backend_requires_gpu("vulkan")).to_be_false()

    it "backend_requires_gpu: cpu does not require GPU":
        expect(backend_requires_gpu("cpu")).to_be_false()

    it "feature_gate_description: returns non-empty text for all known backends":
        val names = ["cuda", "rocm", "metal", "qualcomm", "vulkan", "opengl", "intel", "webgpu", "software", "cpu"]
        var all_ok = true
        var ni = 0
        while ni < 10:
            val desc = feature_gate_description(names[ni])
            if desc.len() == 0:
                all_ok = false
            ni = ni + 1
        expect(all_ok).to_be_true()

describe "helpers_availability — numeric conversions":

    it "backend_i64: converts i32 to i64":
        expect(backend_i64(42)).to_equal(42)

    it "backend_i64: handles negative":
        expect(backend_i64(-1)).to_equal(-1)

    it "backend_bool_to_i32: true -> 1":
        expect(backend_bool_to_i32(true)).to_equal(1)

    it "backend_bool_to_i32: false -> 0":
        expect(backend_bool_to_i32(false)).to_equal(0)
