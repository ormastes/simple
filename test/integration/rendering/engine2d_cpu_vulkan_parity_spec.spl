# @tag: rendering, engine2d, cpu, vulkan, parity
# @cover src/lib/gc_async_mut/gpu/engine2d/backend_cpu.spl 20%
# @cover src/lib/gc_async_mut/gpu/engine2d/backend_vulkan.spl 20%

use std.spec.{describe, context, it, expect}
use std.gc_async_mut.gpu.engine2d.engine.{Engine2D}
use std.gc_async_mut.gpu.engine2d.backend_vulkan.{VulkanBackend}
use std.gc_async_mut.gpu.engine2d.color.{rgb}

fn parity_pixel_at(pixels: [u32], x: i32, y: i32, w: i32) -> u32:
    pixels[y * w + x]

fn parity_pixels_equal(a: [u32], b: [u32]) -> bool:
    if a.len() != b.len():
        return false
    var idx = 0
    while idx < a.len():
        if a[idx] != b[idx]:
            return false
        idx = idx + 1
    true

fn render_cpu_vulkan_core_scene(backend_name: text) -> [u32]:
    var engine = Engine2D.create_with_backend(32, 24, backend_name)
    engine.clear(rgb(3, 5, 7))
    engine.draw_rect_filled(1, 1, 8, 5, rgb(40, 70, 100))
    engine.draw_rect(11, 1, 9, 6, rgb(120, 20, 80))
    engine.draw_line(0, 12, 31, 12, rgb(220, 220, 40), 1)
    engine.draw_circle(24, 7, 4, rgb(10, 200, 30))
    engine.draw_circle_filled(6, 18, 3, rgb(200, 60, 20))
    engine.draw_triangle_filled(18, 15, 14, 22, 25, 22, rgb(90, 160, 230))
    engine.draw_gradient_rect(26, 14, 5, 8, rgb(255, 0, 0), rgb(0, 0, 255))
    engine.set_clip(25, 0, 7, 7)
    engine.draw_rect_filled(22, 0, 10, 10, rgb(8, 180, 200))
    engine.clear_clip()
    engine.present()
    val pixels = engine.read_pixels()
    engine.shutdown()
    pixels

describe "Engine2D CPU and Vulkan rendering parity baseline":

    context "core primitives":

        it "keeps cpu rendering deterministic":
            val first = render_cpu_vulkan_core_scene("cpu")
            val second = render_cpu_vulkan_core_scene("cpu")
            expect(parity_pixels_equal(first, second)).to_equal(true)
            expect(parity_pixel_at(first, 2, 2, 32)).to_equal(rgb(40, 70, 100))

        it "matches the software reference for core primitives":
            val software = render_cpu_vulkan_core_scene("software")
            val cpu = render_cpu_vulkan_core_scene("cpu")
            expect(parity_pixels_equal(software, cpu)).to_equal(true)

    context "vulkan availability path":

        it "creates the Vulkan backend object without resolving the nogc session constructor":
            var backend = VulkanBackend.create()
            expect(backend.name()).to_equal("vulkan")
            val initialized = backend.init(8, 8)
            if initialized:
                backend.shutdown()
            expect(initialized == true or initialized == false).to_equal(true)
