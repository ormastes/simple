# Integration tests for Test Formatters
# Tests progress, doc, and JSON formatters

use std.spec
use std.io_runtime.{file_read}

fn read_test_runner_source(path: text) -> text:
    file_read(path)

describe "Formatter Integration":
    it "keeps test runner output format entrypoints available":
        val source = read_test_runner_source("src/app/test_runner_new/test_runner_single.spl")

        expect(source).to_contain("fn print_summary(path: text, passed: i64, failed: i64, skipped: i64, pending: i64, duration_ms: i64)")
        expect(source).to_contain("print \"Test Summary\"")

    it "keeps stats formatter entrypoints available":
        val table_source = read_test_runner_source("src/app/stats/formatter.spl")
        val json_source = read_test_runner_source("src/app/stats/json_formatter.spl")

        expect(table_source).to_contain("fn format_stats_table(stats: ProjectStats) -> text")
        expect(json_source).to_contain("fn format_json(")
