# ============================================================================
# Test group 3 — Fat32Driver has no extension probes
# ============================================================================

describe "Capability dispatch — Fat32Driver probe returns None":
    """
    ## Fat32 probe always returns None

    Fat32Driver.probe() unconditionally returns None for every capability
    (verified in fat32_stub.spl: probe body is `None`).
    These tests exercise the CapabilitySet path that guards the probe call.
    """

    it "Fat32 capabilities do not include any COW-family capability":
        val caps = CapabilitySet.empty()
            .with(Capability.CaseFold)
            .with(Capability.LargeFiles)
            .with(Capability.UnicodeNames)
        val has_cow      = caps.has(Capability.COW)
        val has_snapshot = caps.has(Capability.Snapshot)
        val has_reflink  = caps.has(Capability.Reflink)
        val has_checksum = caps.has(Capability.Checksum)
        expect(has_cow).to_equal(false)
        expect(has_snapshot).to_equal(false)
        expect(has_reflink).to_equal(false)
        expect(has_checksum).to_equal(false)

    it "Fat32 capabilities do not include PosixCompat":
        val caps = CapabilitySet.empty()
            .with(Capability.CaseFold)
            .with(Capability.LargeFiles)
            .with(Capability.UnicodeNames)
        expect(caps.has(Capability.PosixCompat)).to_equal(false)

    it "Fat32 capabilities include CaseFold, LargeFiles, UnicodeNames":
        val caps = CapabilitySet.empty()
            .with(Capability.CaseFold)
            .with(Capability.LargeFiles)
            .with(Capability.UnicodeNames)
        expect(caps.has(Capability.CaseFold)).to_equal(true)
        expect(caps.has(Capability.LargeFiles)).to_equal(true)
        expect(caps.has(Capability.UnicodeNames)).to_equal(true)


# ============================================================================
# Test group 4 — Extension struct field access does not panic
# ============================================================================

describe "Capability dispatch — Extension struct field access":
    """
    ## Calling fields on Extension structs does not panic

    Constructs Extension handle structs directly (no driver needed) and
    reads fields to verify the types compile and are accessible.
    """

    it "ChecksumExt fields are readable without panic":
        val ext = ChecksumExt(algo_tag: 0, block_size: 4096)
        expect(ext.algo_tag).to_equal(0)
        expect(ext.block_size).to_equal(4096)

    it "ReflinkExt fields are readable without panic":
        val ext = ReflinkExt(shared_extents: 42, cow_pending: false)
        expect(ext.shared_extents).to_equal(42)
        expect(ext.cow_pending).to_equal(false)

    it "PosixCompatExt fields are readable without panic":
        val ext = PosixCompatExt(flags: 0, mode: 493)
        expect(ext.flags).to_equal(0)
        expect(ext.mode).to_equal(493)

    it "SnapshotExt fields are readable without panic":
        val ext = SnapshotExt(volume_name: "test_vol", snap_count: 3)
        expect(ext.volume_name).to_equal("test_vol")
        expect(ext.snap_count).to_equal(3)

    it "Extension.Checksum variant wraps ChecksumExt":
        val inner = ChecksumExt(algo_tag: 1, block_size: 512)
        val ext = Extension.Checksum(ext: inner)
        match ext:
            case Extension.Checksum(e):
                expect(e.algo_tag).to_equal(1)
                expect(e.block_size).to_equal(512)
            case _:
                expect(false).to_equal(true)

    it "Extension.PosixCompat variant wraps PosixCompatExt":
        val inner = PosixCompatExt(flags: 3, mode: 0o644)
        val ext = Extension.PosixCompat(ext: inner)
        match ext:
            case Extension.PosixCompat(e):
                expect(e.flags).to_equal(3)
            case _:
                expect(false).to_equal(true)
