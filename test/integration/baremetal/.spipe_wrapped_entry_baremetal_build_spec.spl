#![allow(spipe_empty_examples)]
#![allow(spipe_boolean_wrapper_assertions)]
@allow(spipe_empty_examples)
@allow(spipe_boolean_wrapper_assertions)
use app.build.baremetal.{BaremetalConfig, BaremetalBuilder, QemuRunner, baremetal_config_arm, baremetal_config_x86_64, baremetal_config_riscv, parse_test_output}
use app.io.mod.{file_exists, dir_create, file_write}


fn main():
    # Integration Tests for Bare-Metal Build System
    #
    # Tests the baremetal build integration including:
    # - Linker script usage
    # - crt0.s assembly
    # - QEMU integration
    # - Test output parsing


    describe "Bare-Metal Build System", fn():
        describe "Linker Scripts", fn():
            slow_it "ARM linker script exists", fn():
                expect file_exists("src/compiler/baremetal/arm/linker.ld") == true

            slow_it "x86_64 linker script exists", fn():
                expect file_exists("src/compiler/baremetal/x86_64/linker.ld") == true

            slow_it "RISC-V linker script exists", fn():
                expect file_exists("src/compiler/baremetal/riscv/linker.ld") == true

        describe "Startup Code", fn():
            slow_it "ARM crt0.s exists", fn():
                expect file_exists("src/compiler/baremetal/arm/crt0.s") == true

            slow_it "x86_64 crt0.s exists", fn():
                expect file_exists("src/compiler/baremetal/x86_64/crt0.s") == true

            slow_it "RISC-V crt0.s exists", fn():
                expect file_exists("src/compiler/baremetal/riscv/crt0.s") == true

        describe "Configuration", fn():
            slow_it "ARM config has correct paths", fn():
                val config = baremetal_config_arm()
                expect config.linker_script == "src/compiler/baremetal/arm/linker.ld"
                expect config.crt0_path == "src/compiler/baremetal/arm/crt0.s"
                expect config.entry_point == "reset_handler"

            slow_it "x86_64 config has correct paths", fn():
                val config = baremetal_config_x86_64()
                expect config.linker_script == "src/compiler/baremetal/x86_64/linker.ld"
                expect config.crt0_path == "src/compiler/baremetal/x86_64/crt0.s"
                expect config.entry_point == "_start"

            slow_it "RISC-V config has correct paths", fn():
                val config = baremetal_config_riscv()
                expect config.linker_script == "src/compiler/baremetal/riscv/linker.ld"
                expect config.crt0_path == "src/compiler/baremetal/riscv/crt0.s"
                expect config.entry_point == "_start"

        describe "Target Triples", fn():
            slow_it "ARM target triple", fn():
                val config = baremetal_config_arm()
                expect config.target_triple() == "armv7m-none-eabi"

            slow_it "x86_64 target triple", fn():
                val config = baremetal_config_x86_64()
                expect config.target_triple() == "x86_64-unknown-none"

            slow_it "RISC-V target triple", fn():
                val config = baremetal_config_riscv()
                expect config.target_triple() == "riscv64gc-unknown-none-elf"

        describe "Test Output Parsing", fn():
            slow_it "parses passing tests", fn():
                val output = "[TEST START]\n[PASS] test_one\n[PASS] test_two\n[TEST END] passed=2 failed=0"
                val result = parse_test_output(output, 1)
                expect result.tests_run == 2
                expect result.tests_passed == 2
                expect result.tests_failed == 0
                expect result.success == true

            slow_it "parses failing tests", fn():
                val output = "[TEST START]\n[PASS] test_one\n[FAIL] test_two: assertion failed\n[TEST END] passed=1 failed=1"
                val result = parse_test_output(output, 1)
                expect result.tests_run == 2
                expect result.tests_passed == 1
                expect result.tests_failed == 1
                expect result.success == false

            slow_it "adjusts QEMU exit codes correctly", fn():
                # isa-debug-exit: exit code 0 becomes 1
                val result1 = parse_test_output("", 1)
                expect result1.exit_code == 0

                # isa-debug-exit: exit code 1 becomes 3
                val result2 = parse_test_output("", 3)
                expect result2.exit_code == 1

        describe "QEMU Runner", fn():
            slow_it "ARM QEMU executable", fn():
                val config = baremetal_config_arm()
                val runner = QemuRunner.new(config, 30000)
                expect runner.qemu_executable() == "qemu-system-arm"

            slow_it "x86_64 QEMU executable", fn():
                val config = baremetal_config_x86_64()
                val runner = QemuRunner.new(config, 30000)
                expect runner.qemu_executable() == "qemu-system-x86_64"

            slow_it "RISC-V QEMU executable", fn():
                val config = baremetal_config_riscv()
                val runner = QemuRunner.new(config, 30000)
                expect runner.qemu_executable() == "qemu-system-riscv64"