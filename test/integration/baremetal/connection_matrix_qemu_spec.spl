# Connection Matrix QEMU Integration Tests
# Tests matrix factory for QEMU targets.

# --- Local copies ---

enum DebugTarget:
    QemuArmCortexM
    QemuRiscV32

    fn to_string() -> text:
        match self:
            QemuArmCortexM: "QEMU ARM Cortex-M"
            QemuRiscV32: "QEMU RISC-V32"

    fn eq(other: DebugTarget) -> bool:
        self.to_string() == other.to_string()

enum DebuggerKind:
    GdbDirectRemote

    fn to_string() -> text:
        match self:
            GdbDirectRemote: "GDB Direct"

class QemuSpec:
    target: DebugTarget
    debugger: DebuggerKind
    gdb_port: i32

impl QemuSpec:
    fn is_hardware() -> bool:
        false

fn qemu_specs() -> [QemuSpec]:
    [
        QemuSpec(target: DebugTarget.QemuArmCortexM, debugger: DebuggerKind.GdbDirectRemote, gdb_port: 3335),
        QemuSpec(target: DebugTarget.QemuRiscV32, debugger: DebuggerKind.GdbDirectRemote, gdb_port: 1234)
    ]

# --- Tests ---

describe "QEMU connection specs":
    slow_it "has 2 QEMU specs":
        val specs = qemu_specs()
        expect(specs.len()).to_equal(2)

    slow_it "QEMU ARM uses port 3335":
        val specs = qemu_specs()
        expect(specs[0].gdb_port).to_equal(3335)

    slow_it "QEMU RV32 uses port 1234":
        val specs = qemu_specs()
        expect(specs[1].gdb_port).to_equal(1234)

    slow_it "QEMU specs are not hardware":
        val specs = qemu_specs()
        expect(specs[0].is_hardware()).to_equal(false)
        expect(specs[1].is_hardware()).to_equal(false)
