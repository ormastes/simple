"""
# Simple launcher dispatch regression spec

Verifies `scripts/setup/bin_scripts/simple` keeps the shell-wrapper routing for
launcher-only entrypoints while avoiding duplicated release/bootstrap logic.
"""

use std.spec

val SOURCE_WRAPPER = "scripts/setup/bin_scripts/simple"
val TEST_ROOT = "/tmp/simple_launcher_dispatch_spec"

extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_exists(path: text) -> bool
extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_dir_create(path: text, recursive: bool) -> bool

fn cleanup_test_root():
    val (_out, _err, _code) = rt_process_run("/bin/sh", ["-c", "rm -rf " + TEST_ROOT])

fn setup_repo_root(name: text) -> text:
    val root = TEST_ROOT + "/" + name
    cleanup_test_root()
    expect(rt_dir_create(root + "/bin", true)).to_equal(true)
    expect(rt_dir_create(root + "/src/compiler/90.tools/duplicate_check", true)).to_equal(true)
    expect(rt_dir_create(root + "/src/app/cli", true)).to_equal(true)
    expect(rt_file_exists(SOURCE_WRAPPER)).to_equal(true)
    expect(rt_file_write_text(root + "/bin/simple", rt_file_read_text(SOURCE_WRAPPER) ?? "")).to_equal(true)
    val (_chmod_out, _chmod_err, chmod_code) = rt_process_run("chmod", ["+x", root + "/bin/simple"])
    expect(chmod_code).to_equal(0)
    root

fn make_fake_runtime(path: text):
    val body = "#!/bin/sh\n" +
        "printf 'argv0=%s\\n' \"$0\"\n" +
        "i=1\n" +
        "for arg in \"$@\"; do\n" +
        "  printf 'arg%s=%s\\n' \"$i\" \"$arg\"\n" +
        "  i=$((i+1))\n" +
        "done\n"
    expect(rt_dir_create(parent_dir(path), true)).to_equal(true)
    expect(rt_file_write_text(path, body)).to_equal(true)
    val (_chmod_out, _chmod_err, chmod_code) = rt_process_run("chmod", ["+x", path])
    expect(chmod_code).to_equal(0)

fn parent_dir(path: text) -> text:
    val idx = path.last_index_of("/") ?? -1
    if idx <= 0:
        return "."
    path.slice(0, idx)

fn run_wrapper(root: text, args: [text]) -> (text, text, i64):
    rt_process_run(root + "/bin/simple", args)

fn expect_arg(stdout: text, index: i64, value: text):
    expect(stdout).to_contain("arg{index}={value}\n")

describe "simple launcher dispatch":

    before_each:
        cleanup_test_root()

    after_each:
        cleanup_test_root()

    it "routes duplicate-check through the release runtime entrypoint":
        val root = setup_repo_root("release_duplicate_check")
        make_fake_runtime(root + "/bin/release/linux-x86_64/simple")

        val (stdout, stderr, code) = run_wrapper(root, ["duplicate-check", "src/app", "--cosine"])

        expect(code).to_equal(0)
        expect(stderr).to_equal("")
        expect_arg(stdout, 1, "run")
        expect_arg(stdout, 2, root + "/src/compiler/90.tools/duplicate_check/main.spl")
        expect_arg(stdout, 3, "duplicate-check")
        expect_arg(stdout, 4, "src/app")
        expect_arg(stdout, 5, "--cosine")

    it "routes stats through the release runtime entrypoint":
        val root = setup_repo_root("release_stats")
        make_fake_runtime(root + "/bin/release/linux-x86_64/simple")

        val (stdout, stderr, code) = run_wrapper(root, ["stats", "--brief", "--json"])

        expect(code).to_equal(0)
        expect(stderr).to_equal("")
        expect_arg(stdout, 1, "run")
        expect_arg(stdout, 2, root + "/src/app/cli/stats_entry.spl")
        expect_arg(stdout, 3, "stats")
        expect_arg(stdout, 4, "--brief")
        expect_arg(stdout, 5, "--json")

    it "routes duplicate-check through the bootstrap runtime when release is absent":
        val root = setup_repo_root("bootstrap_duplicate_check")
        make_fake_runtime(root + "/src/compiler_rust/target/bootstrap/simple")

        val (stdout, stderr, code) = run_wrapper(root, ["duplicate-check", "src/compiler"])

        expect(code).to_equal(0)
        expect(stderr).to_equal("")
        expect_arg(stdout, 1, "run")
        expect_arg(stdout, 2, root + "/src/compiler/90.tools/duplicate_check/main.spl")
        expect_arg(stdout, 3, "duplicate-check")
        expect_arg(stdout, 4, "src/compiler")

    it "routes stats through the bootstrap runtime when release is absent":
        val root = setup_repo_root("bootstrap_stats")
        make_fake_runtime(root + "/src/compiler_rust/target/bootstrap/simple")

        val (stdout, stderr, code) = run_wrapper(root, ["stats", "--quick"])

        expect(code).to_equal(0)
        expect(stderr).to_equal("")
        expect_arg(stdout, 1, "run")
        expect_arg(stdout, 2, root + "/src/app/cli/stats_entry.spl")
        expect_arg(stdout, 3, "stats")
        expect_arg(stdout, 4, "--quick")

    it "passes normal commands straight through to the selected runtime":
        val root = setup_repo_root("release_passthrough")
        make_fake_runtime(root + "/bin/release/linux-x86_64/simple")

        val (stdout, stderr, code) = run_wrapper(root, ["check", "src/app/cli/main.spl"])

        expect(code).to_equal(0)
        expect(stderr).to_equal("")
        expect(stdout.contains("arg1=run\n")).to_equal(false)
        expect_arg(stdout, 1, "check")
        expect_arg(stdout, 2, "src/app/cli/main.spl")
