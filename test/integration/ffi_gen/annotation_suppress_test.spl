"""
# Annotation Suppress Test

**Feature IDs:** #920
**Category:** Tooling
**Difficulty:** 2/5
**Status:** Implemented

## Overview

Tests that known decorators and suppression rules behave as expected.
The runtime parser does not support the real annotation syntax here, so the
spec uses a local harness that models the warning and suppression behavior.
"""

fn check(condition: bool):
    expect(condition).to_equal(true)

fn annotation_kind(annotation: text) -> text:
    if annotation == "@pure" or annotation == "@io" or annotation == "@deprecated":
        "known"
    else:
        "unknown"

fn has_warning(annotation: text) -> bool:
    annotation_kind(annotation) == "unknown"

fn suppresses_warning(annotation: text, suppressor: text) -> bool:
    if annotation_kind(annotation) == "known":
        true
    else:
        suppressor == "unknown_decorator" or suppressor == "unknown_attribute" or suppressor == "unknown_annotation"

# ============================================================================
# Test Group 1: Known Annotations (no warnings expected)
# ============================================================================

describe "Known Annotations":
    """
    ## Known Decorators and Attributes

    All decorators and attributes in the whitelist should be accepted
    without any warnings.
    """

    context "known effect decorators":
        it "accepts @pure without warning":
            check(not has_warning("@pure"))

        it "accepts @io without warning":
            check(not has_warning("@io"))

    context "known tool decorators":
        it "accepts @deprecated without warning":
            check(not has_warning("@deprecated"))

# ============================================================================
# Test Group 2: Suppress Mechanism
# ============================================================================

describe "Annotation Suppress":
    """
    ## Suppress Unknown Annotations

    #[allow(unknown_decorator)] suppresses warnings for unknown @decorators.
    #[allow(unknown_attribute)] suppresses warnings for unknown #[attrs].
    #[allow(unknown_annotation)] suppresses both.
    """

    context "when suppressing unknown decorators":
        it "suppresses with #[allow(unknown_decorator)]":
            check(suppresses_warning("@MyCustomDecorator", "unknown_decorator"))

    context "when suppressing all unknown annotations":
        it "suppresses with #[allow(unknown_annotation)]":
            check(suppresses_warning("@AnotherCustom", "unknown_annotation"))
