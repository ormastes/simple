# FFI Generator - Parser Unit Test
#
# Self-contained parser-safe coverage for FFI parser behavior.

class ParamSpec:
    name: text
    type_name: text

    static fn create(name: text, type_name: text) -> ParamSpec:
        ParamSpec(name: name, type_name: type_name)

class MethodSpec:
    name: text
    kind: text
    return_type: text
    params: [ParamSpec]

    static fn create(name: text, kind: text, return_type: text, params: [ParamSpec]) -> MethodSpec:
        MethodSpec(name: name, kind: kind, return_type: return_type, params: params)

class LibSpec:
    lib_lang: text
    lib_name: text
    lib_version: text
    lib_features: [text]
    class_name: text
    methods: [MethodSpec]

    static fn create(lib_lang: text, lib_name: text, lib_version: text, lib_features: [text], class_name: text, methods: [MethodSpec]) -> LibSpec:
        LibSpec(
            lib_lang: lib_lang,
            lib_name: lib_name,
            lib_version: lib_version,
            lib_features: lib_features,
            class_name: class_name,
            methods: methods
        )

fn trim_parens(text_value: text) -> text:
    val start = text_value.find("(")
    val end = text_value.rfind(")")
    if start == nil or end == nil or end <= start:
        ""
    else:
        text_value.substring(start + 1, end)

fn split_args(text_value: text) -> [text]:
    var parts: [text] = []
    var current = ""
    var depth = 0
    for ch in text_value:
        if ch == "," and depth == 0:
            if current.trim() != "":
                parts.push(current.trim())
            current = ""
        else:
            if ch == "[":
                depth = depth + 1
            elif ch == "]":
                depth = depth - 1
            current = current + ch
    if current.trim() != "":
        parts.push(current.trim())
    parts

fn parse_quoted(text_value: text) -> text:
    val first = text_value.find("\"")
    if first == nil:
        return ""
    val rest = text_value.substring(first + 1)
    val second = rest.find("\"")
    if second == nil:
        return ""
    rest.substring(0, second)

fn parse_lib_annotation(line: text) -> LibSpec:
    val inner = trim_parens(line)
    var lib_lang = ""
    var lib_name = ""
    var lib_version = ""
    var lib_features: [text] = []
    for item in split_args(inner):
        if item.starts_with("lang:"):
            lib_lang = parse_quoted(item)
        elif item.starts_with("name:"):
            lib_name = parse_quoted(item)
        elif item.starts_with("version:"):
            lib_version = parse_quoted(item)
        elif item.starts_with("features:"):
            val feature_text = item.substring(item.find("[") + 1, item.rfind("]"))
            for feature in split_args(feature_text):
                lib_features.push(parse_quoted(feature))
    LibSpec.create(lib_lang, lib_name, lib_version, lib_features, "", [])

fn parse_params(line: text) -> [ParamSpec]:
    val open = line.find("(")
    val close = line.rfind(")")
    var params: [ParamSpec] = []
    if open == nil or close == nil or close <= open:
        return params
    val inner = line.substring(open + 1, close)
    if inner.trim() == "":
        return params
    for item in split_args(inner):
        val colon = item.find(":")
        if colon != nil:
            val name = item.substring(0, colon).trim()
            val type_name = item.substring(colon + 1).trim()
            params.push(ParamSpec.create(name, type_name))
    params

fn parse_method_line(line: text) -> MethodSpec:
    val trimmed = line.trim()
    var kind = "immutable"
    var rest = trimmed
    if trimmed.starts_with("static fn "):
        kind = "static"
        rest = trimmed.substring(10)
    elif trimmed.starts_with("me "):
        kind = "mutable"
        rest = trimmed.substring(3)
    elif trimmed.starts_with("fn "):
        rest = trimmed.substring(3)
    val name_end = rest.find("(")
    val name = rest.substring(0, name_end).trim()
    val params = parse_params(rest)
    var return_type = ""
    val arrow = rest.find("->")
    if arrow != nil:
        return_type = rest.substring(arrow + 2).trim()
    MethodSpec.create(name, kind, return_type, params)

fn parse_lib_externs(source: text, file: text) -> [LibSpec]:
    var specs: [LibSpec] = []
    var current: LibSpec = nil
    for raw_line in source.split("\n"):
        val line = raw_line.trim()
        if line == "":
            continue
        if line.starts_with("@Lib("):
            current = parse_lib_annotation(line)
        elif line.starts_with("extern class ") and current != nil:
            val class_name = line.substring(13).trim().replace(":", "")
            current.class_name = class_name
            specs.push(current)
        elif current != nil and raw_line.starts_with("    "):
            current.methods.push(parse_method_line(line))
    specs

fn check_spec(actual: text, expected: text):
    expect(actual).to_equal(expected)

fn check_true(condition: bool):
    expect(condition).to_equal(true)

describe "FFI Parser Behavior":
    it "parses a simple rust library spec":
        val source = "@Lib(lang: \"rust\", name: \"regex\", version: \"1.10\")\nextern class Regex:\n    static fn new(pattern: text) -> Regex\n    fn is_match(input: text) -> bool\n"
        val specs = parse_lib_externs(source, "test.spl")
        check_true(specs.len() == 1)
        check_spec(specs[0].lib_lang, "rust")
        check_spec(specs[0].lib_name, "regex")
        check_spec(specs[0].lib_version, "1.10")
        check_spec(specs[0].class_name, "Regex")
        check_true(specs[0].methods.len() == 2)
        check_spec(specs[0].methods[0].name, "new")
        check_spec(specs[0].methods[0].kind, "static")
        check_spec(specs[0].methods[0].return_type, "Regex")
        check_true(specs[0].methods[0].params.len() == 1)
        check_spec(specs[0].methods[0].params[0].name, "pattern")
        check_spec(specs[0].methods[0].params[0].type_name, "text")
        check_spec(specs[0].methods[1].name, "is_match")
        check_spec(specs[0].methods[1].kind, "immutable")
        check_spec(specs[0].methods[1].return_type, "bool")

    it "parses feature lists and multiple methods":
        val source = "@Lib(lang: \"rust\", name: \"serde_json\", version: \"1.0\", features: [\"preserve_order\"])\nextern class JsonValue:\n    static fn from_str(s: text) -> JsonValue\n    fn to_string() -> text\n"
        val specs = parse_lib_externs(source, "test.spl")
        check_true(specs.len() == 1)
        check_spec(specs[0].lib_name, "serde_json")
        check_true(specs[0].lib_features.len() == 1)
        check_spec(specs[0].lib_features[0], "preserve_order")
        check_true(specs[0].methods.len() == 2)
        check_spec(specs[0].methods[0].name, "from_str")
        check_spec(specs[0].methods[1].name, "to_string")

    it "parses c libraries and methods without return types":
        val source = "@Lib(lang: \"c\", name: \"sqlite3\")\nextern class Sqlite3:\n    static fn open(path: text) -> Sqlite3\n    fn exec(sql: text) -> i32\n    fn close()\n"
        val specs = parse_lib_externs(source, "test.spl")
        check_true(specs.len() == 1)
        check_spec(specs[0].lib_lang, "c")
        check_spec(specs[0].lib_name, "sqlite3")
        check_true(specs[0].methods.len() == 3)
        check_spec(specs[0].methods[2].name, "close")
        check_spec(specs[0].methods[2].return_type, "")

    it "parses mutable methods and multiple classes":
        val source = "@Lib(lang: \"rust\", name: \"mylib\", version: \"0.1\")\nextern class Buffer:\n    static fn new(capacity: i64) -> Buffer\n    me push(value: i64)\n    fn len() -> i64\n\n@Lib(lang: \"rust\", name: \"other\", version: \"0.2\")\nextern class Helper:\n    static fn parse(s: text) -> Helper\n"
        val specs = parse_lib_externs(source, "test.spl")
        check_true(specs.len() == 2)
        check_spec(specs[0].class_name, "Buffer")
        check_spec(specs[0].methods[1].kind, "mutable")
        check_spec(specs[1].class_name, "Helper")

    it "returns no specs for files without annotations":
        val source = "fn main():\n    print \"hello\"\n"
        val specs = parse_lib_externs(source, "test.spl")
        check_true(specs.len() == 0)

    it "parses annotation fields directly":
        val spec = parse_lib_annotation("@Lib(lang: \"rust\", name: \"regex\", version: \"1.10\")")
        check_spec(spec.lib_lang, "rust")
        check_spec(spec.lib_name, "regex")
        check_spec(spec.lib_version, "1.10")

    it "parses method and parameter lines directly":
        val method = parse_method_line("static fn new(pattern: text) -> Regex")
        check_spec(method.name, "new")
        check_spec(method.kind, "static")
        check_true(method.params.len() == 1)
        check_spec(method.params[0].name, "pattern")
        check_spec(method.params[0].type_name, "text")

        val params = parse_params("fn open(path: text, mode: text) -> Sqlite3")
        check_true(params.len() == 2)
        check_spec(params[1].name, "mode")
        check_spec(params[1].type_name, "text")
