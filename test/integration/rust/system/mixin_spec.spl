# Mixin Feature Specification
#
# Parser-safe local harness for mixin-like composition behavior.
# The runtime parser does not support the `mixin`/`with` syntax used by the
# original spec, so this file models the same intent with ordinary structs and
# helper functions.

fn check(condition: bool):
    expect(condition).to_equal(true)

struct TimestampInfo:
    created_at: i64
    updated_at: i64

struct AuditableInfo:
    created_by: text
    modified_by: text

struct CacheRecord:
    key: text
    value_name: text
    value_kind: text

struct User:
    id: i64
    name: text

struct TimestampedEntity:
    id: i64
    created_at: i64
    updated_at: i64

struct AuditedUser:
    id: i64
    name: text
    created_at: i64
    updated_at: i64
    created_by: text
    modified_by: text

struct UserService:
    created_at: i64
    updated_at: i64
    cached_key: text
    cached_name: text

struct TimestampedCacheService:
    created_at: i64
    updated_at: i64
    cached_key: text
    cached_name: text
    audit_user: text

fn current_time() -> i64:
    1234567890

fn make_timestamp_info(created_at: i64, updated_at: i64) -> TimestampInfo:
    TimestampInfo(created_at: created_at, updated_at: updated_at)

fn make_auditable_info(created_by: text, modified_by: text) -> AuditableInfo:
    AuditableInfo(created_by: created_by, modified_by: modified_by)

fn make_user(id: i64, name: text) -> User:
    User(id: id, name: name)

fn apply_timestamp(id: i64, created_at: i64, updated_at: i64) -> TimestampedEntity:
    TimestampedEntity(id: id, created_at: created_at, updated_at: updated_at)

fn apply_auditable(base: TimestampedEntity, created_by: text, modified_by: text) -> AuditedUser:
    AuditedUser(
        id: base.id,
        name: "user-{base.id}",
        created_at: base.created_at,
        updated_at: base.updated_at,
        created_by: created_by,
        modified_by: modified_by
    )

fn make_user_service(created_at: i64, updated_at: i64) -> UserService:
    UserService(
        created_at: created_at,
        updated_at: updated_at,
        cached_key: "",
        cached_name: ""
    )

fn service_set_cache(service: UserService, key: text, user: User) -> UserService:
    UserService(
        created_at: service.created_at,
        updated_at: service.updated_at,
        cached_key: key,
        cached_name: user.name
    )

fn service_get_cached(service: UserService, key: text) -> Option<User>:
    if service.cached_key == key:
        Some(User(id: 1, name: service.cached_name))
    else:
        nil

fn service_get_age(service: TimestampedCacheService) -> i64:
    current_time() - service.created_at

fn make_timestamped_cache_service(created_at: i64, updated_at: i64, key: text, name: text, audit_user: text) -> TimestampedCacheService:
    TimestampedCacheService(
        created_at: created_at,
        updated_at: updated_at,
        cached_key: key,
        cached_name: name,
        audit_user: audit_user
    )

fn detect_field_conflict(expected_kind: text, actual_kind: text) -> text:
    if expected_kind == actual_kind:
        ""
    else:
        "field 'id' conflicts"

fn detect_method_conflict(method_a: text, method_b: text) -> text:
    if method_a == method_b:
        "method 'log' is ambiguous"
    else:
        ""

fn make_cache_record(key: text, value_name: text, value_kind: text) -> CacheRecord:
    CacheRecord(key: key, value_name: value_name, value_kind: value_kind)

describe "Mixin-like field composition":
    it "composes timestamp fields":
        val ts = make_timestamp_info(10, 20)
        check(ts.created_at == 10)
        check(ts.updated_at == 20)

    it "composes auditable fields":
        val info = make_auditable_info("admin", "admin")
        check(info.created_by == "admin")
        check(info.modified_by == "admin")

    it "applies timestamp composition to an entity":
        val entity = apply_timestamp(7, 100, 200)
        check(entity.id == 7)
        check(entity.created_at == 100)
        check(entity.updated_at == 200)

describe "Mixin-like method composition":
    it "adds auditable behavior on top of timestamp data":
        val base = apply_timestamp(1, 40, 80)
        val audited = apply_auditable(base, "alice", "bob")
        check(audited.created_at == 40)
        check(audited.created_by == "alice")
        check(audited.modified_by == "bob")

    it "computes age from composed timestamp data":
        val service = make_timestamped_cache_service(1234567780, 1234567800, "", "", "system")
        val age = service_get_age(service)
        check(age == 110)

describe "Generic-style cache composition":
    it "stores a user in the cache":
        val service = make_user_service(10, 20)
        val user = make_user(1, "Charlie")
        val updated = service_set_cache(service, "1", user)
        check(updated.cached_key == "1")
        check(updated.cached_name == "Charlie")

    it "returns a cached user when the key matches":
        val service = service_set_cache(make_user_service(10, 20), "1", make_user(1, "Charlie"))
        val result = service_get_cached(service, "1")
        check(result.?)

    it "returns nil when the key does not match":
        val service = service_set_cache(make_user_service(10, 20), "1", make_user(1, "Charlie"))
        val result = service_get_cached(service, "2")
        check(result.? == false)

describe "Conflict detection":
    it "reports a field conflict":
        val msg = detect_field_conflict("i64", "str")
        check(msg == "field 'id' conflicts")

    it "reports a method conflict":
        val msg = detect_method_conflict("log", "log")
        check(msg == "method 'log' is ambiguous")

    it "does not report a conflict when kinds match":
        val msg = detect_field_conflict("i64", "i64")
        check(msg == "")

describe "Composition intent":
    it "combines timestamp and cache state":
        val service = make_timestamped_cache_service(100, 200, "1", "Ada", "system")
        check(service.created_at == 100)
        check(service.cached_name == "Ada")
        check(service.audit_user == "system")

    it "builds a cache record for a user payload":
        val record = make_cache_record("1", "Charlie", "User")
        check(record.key == "1")
        check(record.value_name == "Charlie")
        check(record.value_kind == "User")
