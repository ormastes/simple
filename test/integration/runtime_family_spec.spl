# @cover src/compiler/00.common/gc_config.spl 60%
# @cover src/compiler/80.driver/build/baremetal.spl 50%
# @cover src/compiler/00.common/driver_core_types.spl 50%
#
# Integration tests for the runtime family system — verifies that target preset
# family restrictions and compile-option helpers behave consistently.
#
# No imports: all logic is replicated at module level to run in interpreter mode.

# ============================================================================
# Replicated target preset family logic (mirrors TargetPreset.allowed_families)
# ============================================================================

fn baremetal_allowed_families() -> [text]:
    ["nogc_async_mut_noalloc", "common"]

fn hosted_allowed_families() -> [text]:
    []

fn embedded_with_heap_allowed_families() -> [text]:
    ["nogc_async_mut_noalloc", "nogc_sync_mut", "nogc_async_mut", "common"]

fn is_family_allowed(allowed: [text], family: text) -> bool:
    if allowed.len() == 0:
        return true
    for af in allowed:
        if af == family:
            return true
    false

fn local_is_nogc_family(module_path: text) -> bool:
    var path = module_path
    if path.starts_with("std."):
        path = path[4:path.len()]
    elif path.starts_with("lib."):
        path = path[4:path.len()]
    path.starts_with("nogc_")

fn local_is_gc_family(module_path: text) -> bool:
    var path = module_path
    if path.starts_with("std."):
        path = path[4:path.len()]
    elif path.starts_with("lib."):
        path = path[4:path.len()]
    path.starts_with("gc_")

fn local_gc_mode_from_prefix(module_path: text) -> text:
    var path = module_path
    if path.starts_with("std."):
        path = path[4:path.len()]
    elif path.starts_with("lib."):
        path = path[4:path.len()]
    if path.starts_with("nogc_"):
        return "nogc"
    if path.starts_with("gc_"):
        return "gc"
    if path.starts_with("common"):
        return "gc"
    "unknown"

# ============================================================================
# Tests
# ============================================================================

describe "Runtime Family Integration":
    context "target preset — baremetal":
        it "baremetal allowed families has exactly two entries":
            val families = baremetal_allowed_families()
            expect(families.len()).to_equal(2)

        it "baremetal allowed families contains nogc_async_mut_noalloc":
            val families = baremetal_allowed_families()
            expect(families[0]).to_equal("nogc_async_mut_noalloc")

        it "baremetal allowed families contains common":
            val families = baremetal_allowed_families()
            expect(families[1]).to_equal("common")

        it "baremetal blocks gc_async_mut":
            val families = baremetal_allowed_families()
            expect(is_family_allowed(families, "gc_async_mut")).to_equal(false)

        it "baremetal blocks nogc_sync_mut":
            val families = baremetal_allowed_families()
            expect(is_family_allowed(families, "nogc_sync_mut")).to_equal(false)

        it "baremetal allows nogc_async_mut_noalloc":
            val families = baremetal_allowed_families()
            expect(is_family_allowed(families, "nogc_async_mut_noalloc")).to_equal(true)

        it "baremetal allows common":
            val families = baremetal_allowed_families()
            expect(is_family_allowed(families, "common")).to_equal(true)

    context "target preset — hosted":
        it "hosted allowed families is empty (no restriction)":
            val families = hosted_allowed_families()
            expect(families.len()).to_equal(0)

        it "hosted allows gc_async_mut (empty list = no restriction)":
            val families = hosted_allowed_families()
            expect(is_family_allowed(families, "gc_async_mut")).to_equal(true)

        it "hosted allows nogc_sync_mut":
            val families = hosted_allowed_families()
            expect(is_family_allowed(families, "nogc_sync_mut")).to_equal(true)

        it "hosted allows nogc_async_mut_noalloc":
            val families = hosted_allowed_families()
            expect(is_family_allowed(families, "nogc_async_mut_noalloc")).to_equal(true)

    context "target preset — embedded_with_heap":
        it "embedded_with_heap allowed families has exactly four entries":
            val families = embedded_with_heap_allowed_families()
            expect(families.len()).to_equal(4)

        it "embedded_with_heap contains nogc_async_mut_noalloc":
            val families = embedded_with_heap_allowed_families()
            expect(families[0]).to_equal("nogc_async_mut_noalloc")

        it "embedded_with_heap contains nogc_sync_mut":
            val families = embedded_with_heap_allowed_families()
            expect(families[1]).to_equal("nogc_sync_mut")

        it "embedded_with_heap contains nogc_async_mut":
            val families = embedded_with_heap_allowed_families()
            expect(families[2]).to_equal("nogc_async_mut")

        it "embedded_with_heap contains common":
            val families = embedded_with_heap_allowed_families()
            expect(families[3]).to_equal("common")

        it "embedded_with_heap blocks gc_async_mut":
            val families = embedded_with_heap_allowed_families()
            expect(is_family_allowed(families, "gc_async_mut")).to_equal(false)

    context "is_family_allowed helper":
        it "returns true when restriction list is empty":
            val families: [text] = []
            expect(is_family_allowed(families, "gc_async_mut")).to_equal(true)

        it "returns true for any family when list is empty":
            val families: [text] = []
            expect(is_family_allowed(families, "nogc_sync_mut")).to_equal(true)

        it "returns true for listed family":
            val families = ["nogc_async_mut_noalloc", "common"]
            expect(is_family_allowed(families, "nogc_async_mut_noalloc")).to_equal(true)

        it "returns false for non-listed family":
            val families = ["nogc_async_mut_noalloc", "common"]
            expect(is_family_allowed(families, "gc_async_mut")).to_equal(false)

        it "returns false for another non-listed family":
            val families = ["nogc_async_mut_noalloc", "common"]
            expect(is_family_allowed(families, "nogc_sync_mut")).to_equal(false)

    context "gc_mode_from_family_prefix":
        it "nogc_sync_mut prefix maps to nogc mode":
            expect(local_gc_mode_from_prefix("nogc_sync_mut.fs")).to_equal("nogc")

        it "nogc_async_mut prefix maps to nogc mode":
            expect(local_gc_mode_from_prefix("nogc_async_mut.thread")).to_equal("nogc")

        it "nogc_async_mut_noalloc prefix maps to nogc mode":
            expect(local_gc_mode_from_prefix("nogc_async_mut_noalloc.exec")).to_equal("nogc")

        it "gc_async_mut prefix maps to gc mode":
            expect(local_gc_mode_from_prefix("gc_async_mut.alloc")).to_equal("gc")

        it "common prefix maps to gc mode":
            expect(local_gc_mode_from_prefix("common.text")).to_equal("gc")

        it "std. prefixed nogc path maps to nogc mode":
            expect(local_gc_mode_from_prefix("std.nogc_sync_mut.fs")).to_equal("nogc")

        it "unknown prefix maps to unknown":
            expect(local_gc_mode_from_prefix("mylib.foo")).to_equal("unknown")
