        val r1 = result ?? SdnRow(fields: {"__init__": "__init__"})
        val data = r1.get("data") ?? ""
        expect(data).to_equal("test_data")

    slow_it "returns None for missing row ID":
        val table = SdnTable(name: "empty", columns: ["id"], rows: [], index: {"__init__": -1})
        val result = table.get_row("nonexistent")

        expect(result.?).to_equal(false)

    slow_it "marks row as deleted":
        var table = SdnTable(name: "deletable", columns: ["id", "valid"], rows: [], index: {"__init__": -1})




        # Mark first row deleted
        table = tbl_mark_deleted(table, "del_1")

