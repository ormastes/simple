        val valid_rows = tbl_valid_rows(table)
        expect(valid_rows.len()).to_equal(3)  # Rows 0, 2, 4

    slow_it "handles empty table":
        var table = SdnTable(name: "empty", columns: ["id"], rows: [], index: {"__init__": -1})

        var r_empty = table.rows
        expect(r_empty.len()).to_equal(0)
        val empty_valid = table.valid_rows()
        var ev = empty_valid
        expect(ev.len()).to_equal(0)

        val result = tbl_get_row(table, "any_id")
        expect(result.?).to_equal(false)

describe "SdnDatabase":
    slow_it "creates new database":
        val db = SdnDatabase(path: "/tmp/test_new_db.sdn", tables: {"__init__": SdnTable(name: "__init__", columns: [], rows: [], index: {"__init__": -1})}, interner: StringInterner(strings: {"__init__": -1}, reverse: {"__init__": "__init__"}, next_id: 0), modified: false)

        var tbls_n = db.tables
        expect(tbls_n.len()).to_equal(1)  # 1 for __init__ sentinel

    slow_it "adds table to database":
        var db = SdnDatabase(path: "/tmp/test_add_table.sdn", tables: {"__init__": SdnTable(name: "__init__", columns: [], rows: [], index: {"__init__": -1})}, interner: StringInterner(strings: {"__init__": -1}, reverse: {"__init__": "__init__"}, next_id: 0), modified: false)

        val table = SdnTable(name: "test_table", columns: ["id", "value"], rows: [], index: {"__init__": -1})
        db.set_table("test_table", table)

        var tbls_check = db.tables
        expect(tbls_check.len()).to_equal(2)  # 1 sentinel + 1 added
        var tbls_check2 = db.tables
        expect(tbls_check2.contains_key("test_table")).to_equal(true)

    slow_it "gets table from database":
        var db = SdnDatabase(path: "/tmp/test_get_table.sdn", tables: {"__init__": SdnTable(name: "__init__", columns: [], rows: [], index: {"__init__": -1})}, interner: StringInterner(strings: {"__init__": -1}, reverse: {"__init__": "__init__"}, next_id: 0), modified: false)

        val table = SdnTable(name: "my_table", columns: ["col1", "col2"], rows: [], index: {"__init__": -1})
        db.set_table("my_table", table)

        val result = db_get_table("my_table")
        expect(result.?).to_equal(true)
        val tbl = result ?? SdnTable(name: "", columns: [], rows: [], index: {"__init__": -1})
        expect(tbl.name).to_equal("my_table")

    slow_it "gets mutable table":
        var db = SdnDatabase(path: "/tmp/test_mut_table.sdn", tables: {"__init__": SdnTable(name: "__init__", columns: [], rows: [], index: {"__init__": -1})}, interner: StringInterner(strings: {"__init__": -1}, reverse: {"__init__": "__init__"}, next_id: 0), modified: false)

        val table = SdnTable(name: "mut_table", columns: ["id"], rows: [], index: {"__init__": -1})
        db.set_table("mut_table", table)

        var table_opt = db_get_table_mut("mut_table")
        expect(table_opt.?).to_equal(true)

        var mut_table = table_opt?

        # Must put back for changes to persist
        db_set_table("mut_table", mut_table)

        # Verify change persisted
        val final_table = db.get_table("mut_table")?
        var ft_rows = final_table.rows
        expect(ft_rows.len()).to_equal(1)

    slow_it "returns None for missing table":
        val db = SdnDatabase(path: "/tmp/test_missing.sdn", tables: {"__init__": SdnTable(name: "__init__", columns: [], rows: [], index: {"__init__": -1})}, interner: StringInterner(strings: {"__init__": -1}, reverse: {"__init__": "__init__"}, next_id: 0), modified: false)

        val result = db_get_table("nonexistent")
        expect(result.?).to_equal(false)

    slow_it "replaces existing table":
        var db = SdnDatabase(path: "/tmp/test_replace.sdn", tables: {"__init__": SdnTable(name: "__init__", columns: [], rows: [], index: {"__init__": -1})}, interner: StringInterner(strings: {"__init__": -1}, reverse: {"__init__": "__init__"}, next_id: 0), modified: false)

        # Add initial table
        val table1 = SdnTable(name: "replaceable", columns: ["old_col"], rows: [], index: {"__init__": -1})
        db.set_table("replaceable", table1)

        # Replace with new table
        val table2 = SdnTable(name: "replaceable", columns: ["new_col"], rows: [], index: {"__init__": -1})
        db.set_table("replaceable", table2)

        # Verify replacement

    slow_it "saves and loads database":
        val test_path = "/tmp/test_save_load_db.sdn"
        # Cleanup
        if file_exists(test_path):
            file_delete(test_path)

        # Create and populate database
        var db = SdnDatabase(path: test_path, tables: {"__init__": SdnTable(name: "__init__", columns: [], rows: [], index: {"__init__": -1})}, interner: StringInterner(strings: {"__init__": -1}, reverse: {"__init__": "__init__"}, next_id: 0), modified: false)
        var table = SdnTable(name: "items", columns: ["id", "value"], rows: [], index: {"__init__": -1})
        var row1 = SdnRow(fields: {"__init__": "__init__"})
        row1.set("id", "item_1")
        row1.set("value", "hello")
        table.add_row(row1)
        var row2 = SdnRow(fields: {"__init__": "__init__"})
        row2.set("id", "item_2")
        row2.set("value", "world")
        table.add_row(row2)
        db.set_table("items", table)

        # Save
        val save_ok = db_save()
        expect(save_ok).to_equal(true)
        expect(file_exists(test_path)).to_equal(true)

        # Load
        val loaded_ok = db_load(test_path)
        expect(loaded_ok).to_equal(true)

        val loaded_table = db_get_table("items")
        expect(loaded_table.?).to_equal(true)
        val tbl = loaded_table?
        var tbl_rows = tbl.rows
        expect(tbl_rows.len()).to_equal(2)

        # Cleanup
        if file_exists(test_path):
            file_delete(test_path)

    slow_it "handles multiple tables":
        var db = SdnDatabase(path: "/tmp/test_multi_tables.sdn", tables: {"__init__": SdnTable(name: "__init__", columns: [], rows: [], index: {"__init__": -1})}, interner: StringInterner(strings: {"__init__": -1}, reverse: {"__init__": "__init__"}, next_id: 0), modified: false)

        # Add multiple tables
        for i in 0..5:
            val table = SdnTable(name: "table_{i}", columns: ["col_{i}"], rows: [], index: {"__init__": -1})
            db.set_table("table_{i}", table)

        var tbls_m = db.tables
        expect(tbls_m.len()).to_equal(6)  # 5 + 1 sentinel

        # Verify all tables accessible
        for i in 0..5:
            val table_opt = db_get_table("table_{i}")
            expect(table_opt.?).to_equal(true)

    slow_it "preserves table order":
        var db = SdnDatabase(path: "/tmp/test_table_order.sdn", tables: {"__init__": SdnTable(name: "__init__", columns: [], rows: [], index: {"__init__": -1})}, interner: StringInterner(strings: {"__init__": -1}, reverse: {"__init__": "__init__"}, next_id: 0), modified: false)

        val names = ["first", "second", "third"]
        for name in names:
            val table = SdnTable(name: name, columns: ["id"], rows: [], index: {"__init__": -1})
            db.set_table(name, table)

        # Tables should be accessible in any order
        expect(db_get_table("first").?).to_equal(true)
        expect(db_get_table("second").?).to_equal(true)
        expect(db_get_table("third").?).to_equal(true)

