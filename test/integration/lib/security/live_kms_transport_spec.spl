use std.sys.env
use std.security.kms_provider.{HostedKmsHttpRequest, hosted_kms_execute_runtime_http}
use std.security.kms_vendor_adapters.{aws_kms_sign_request, gcp_kms_asymmetric_sign_request, azure_key_vault_sign_request, pkcs11_hsm_sign_request}

fn _live_provider() -> text:
    env.get("SIMPLE_LIVE_KMS_PROVIDER")

fn _missing(name: text) -> bool:
    env.get(name) == ""

fn _execute_live(request: HostedKmsHttpRequest) -> text:
    val response = hosted_kms_execute_runtime_http(request)
    if response.status_code >= 200 and response.status_code < 300:
        return "ok"
    "error:{response.status_code}:{response.error}"

fn _aws_live_sign_status() -> text:
    if _live_provider() != "aws":
        return "skip:aws-disabled"
    if _missing("SIMPLE_LIVE_KMS_AWS_ENDPOINT") or _missing("SIMPLE_LIVE_KMS_AWS_KEY_ID") or _missing("SIMPLE_LIVE_KMS_AWS_AUTHORIZATION"):
        return "skip:aws-missing-env"
    val request = aws_kms_sign_request(
        env.get("SIMPLE_LIVE_KMS_AWS_ENDPOINT"),
        env.get("SIMPLE_LIVE_KMS_AWS_KEY_ID"),
        env.get("SIMPLE_LIVE_KMS_PAYLOAD"),
        env.get_or("SIMPLE_LIVE_KMS_AWS_ALGORITHM", "RSASSA_PSS_SHA_256"),
        env.get("SIMPLE_LIVE_KMS_AWS_AUTHORIZATION"),
        10000,
        "system"
    )
    _execute_live(request)

fn _gcp_live_sign_status() -> text:
    if _live_provider() != "gcp":
        return "skip:gcp-disabled"
    if _missing("SIMPLE_LIVE_KMS_GCP_ENDPOINT") or _missing("SIMPLE_LIVE_KMS_GCP_KEY_VERSION") or _missing("SIMPLE_LIVE_KMS_GCP_BEARER"):
        return "skip:gcp-missing-env"
    val request = gcp_kms_asymmetric_sign_request(
        env.get("SIMPLE_LIVE_KMS_GCP_ENDPOINT"),
        env.get("SIMPLE_LIVE_KMS_GCP_KEY_VERSION"),
        env.get("SIMPLE_LIVE_KMS_DIGEST_SHA256"),
        env.get("SIMPLE_LIVE_KMS_GCP_BEARER"),
        10000,
        "system"
    )
    _execute_live(request)

fn _azure_live_sign_status() -> text:
    if _live_provider() != "azure":
        return "skip:azure-disabled"
    if _missing("SIMPLE_LIVE_KMS_AZURE_VAULT") or _missing("SIMPLE_LIVE_KMS_AZURE_KEY") or _missing("SIMPLE_LIVE_KMS_AZURE_BEARER"):
        return "skip:azure-missing-env"
    val request = azure_key_vault_sign_request(
        env.get("SIMPLE_LIVE_KMS_AZURE_VAULT"),
        env.get("SIMPLE_LIVE_KMS_AZURE_KEY"),
        env.get("SIMPLE_LIVE_KMS_DIGEST_BASE64URL"),
        env.get_or("SIMPLE_LIVE_KMS_AZURE_ALGORITHM", "PS256"),
        env.get("SIMPLE_LIVE_KMS_AZURE_BEARER"),
        10000,
        "system"
    )
    _execute_live(request)

fn _hsm_live_sign_status() -> text:
    if _live_provider() != "hsm":
        return "skip:hsm-disabled"
    if _missing("SIMPLE_LIVE_KMS_HSM_ENDPOINT") or _missing("SIMPLE_LIVE_KMS_HSM_SLOT") or _missing("SIMPLE_LIVE_KMS_HSM_KEY") or _missing("SIMPLE_LIVE_KMS_HSM_AUTHORIZATION"):
        return "skip:hsm-missing-env"
    val request = pkcs11_hsm_sign_request(
        env.get("SIMPLE_LIVE_KMS_HSM_ENDPOINT"),
        env.get("SIMPLE_LIVE_KMS_HSM_SLOT"),
        env.get("SIMPLE_LIVE_KMS_HSM_KEY"),
        env.get("SIMPLE_LIVE_KMS_PAYLOAD"),
        env.get_or("SIMPLE_LIVE_KMS_HSM_MECHANISM", "CKM_ECDSA_SHA256"),
        env.get("SIMPLE_LIVE_KMS_HSM_AUTHORIZATION"),
        10000,
        "mtls:hsm"
    )
    _execute_live(request)

fn _ok_or_skipped(status: text) -> bool:
    status == "ok" or status.starts_with("skip:")

describe "live KMS transport coverage":
    it "AWS KMS sign executes only when explicitly enabled":
        expect(_ok_or_skipped(_aws_live_sign_status())).to_equal(true)

    it "GCP Cloud KMS sign executes only when explicitly enabled":
        expect(_ok_or_skipped(_gcp_live_sign_status())).to_equal(true)

    it "Azure Key Vault sign executes only when explicitly enabled":
        expect(_ok_or_skipped(_azure_live_sign_status())).to_equal(true)

    it "PKCS11 HSM gateway sign executes only when explicitly enabled":
        expect(_ok_or_skipped(_hsm_live_sign_status())).to_equal(true)
