# Database Query Intensive Testing
# Tests for bug database query operations and filtering
#
# NOTE: The interpreter has a known bug where struct/class fields that are
# arrays or dicts get type-corrupted. Also module-level dicts get corrupted
# when the test runner loads doctests alongside spec files. Workaround: use
# local dicts created inside each test block and flat key-value storage.
# Dict arguments passed to functions are NOT mutated in place, so all dict
# writes must be inlined in the test block.

fn check(condition: bool):
    expect(condition).to_equal(true)

fn slow_it(name: text, block: fn()):
    it(name, block)

describe "BugDatabase Queries - Intensive":
    context "basic queries":
        slow_it "retrieves all bugs":
            var kv: {text: text} = {}
            var count = 0
            for i in 0..20:
                kv["{count}:id"] = "bug_{i}"
                kv["{count}:severity"] = "P1"
                kv["{count}:status"] = "Open"
                kv["{count}:title"] = "Bug bug_{i}"
                kv["{count}:file"] = "test.spl"
                count = count + 1
            expect(count).to_equal(20)
            # Verify we can look up each bug
            for i in 0..20:
                expect(kv["{i}:id"]).to_equal("bug_{i}")

        slow_it "retrieves open bugs":
            var kv: {text: text} = {}
            var count = 0

            # Add 10 open bugs
            for i in 0..10:
                kv["{count}:id"] = "open_{i}"
                kv["{count}:status"] = "Open"
                count = count + 1

            # Add 10 fixed bugs
            for i in 0..10:
                kv["{count}:id"] = "fixed_{i}"
                kv["{count}:status"] = "Fixed"
                count = count + 1

            # Count open bugs
            var open_count = 0
            for i in 0..count:
                if kv["{i}:status"] == "Open":
                    open_count = open_count + 1
            expect(open_count).to_equal(10)

            # Verify all open ones are indeed Open
            for i in 0..10:
                expect(kv["{i}:status"]).to_equal("Open")

        slow_it "gets bug statistics":
            var kv: {text: text} = {}
            var count = 0

            val severity_list = ["P0", "P1", "P2", "P3"]
            val status_list = ["Open", "Investigating", "Fixed", "Closed"]

            for i in 0..16:
                val sev = severity_list[i % 4]
                val stat = status_list[(i / 4) % 4]
                kv["{count}:id"] = "bug_{i}"
                kv["{count}:severity"] = sev
                kv["{count}:status"] = stat
                count = count + 1

            expect(count).to_equal(16)

    context "manual filtering":
        slow_it "filters bugs by severity manually":
            var kv: {text: text} = {}
            var count = 0

            # Add 5 P0 bugs
            for i in 0..5:
                kv["{count}:id"] = "p0_{i}"
                kv["{count}:severity"] = "P0"
                kv["{count}:status"] = "Open"
                count = count + 1

            # Add 15 P2 bugs
            for i in 0..15:
                kv["{count}:id"] = "p2_{i}"
                kv["{count}:severity"] = "P2"
                kv["{count}:status"] = "Open"
                count = count + 1

            # Filter P0
            var p0_count = 0
            for i in 0..count:
                if kv["{i}:severity"] == "P0":
                    p0_count = p0_count + 1

            expect(p0_count).to_equal(5)

        slow_it "filters bugs by file field":
            var kv: {text: text} = {}
            var count = 0

            # Add 5 parser bugs
            for i in 0..5:
                kv["{count}:id"] = "parser_{i}"
                kv["{count}:file"] = "src/parser/mod.spl"
                count = count + 1

            # Add 10 other bugs
            for i in 0..10:
                kv["{count}:id"] = "other_{i}"
                kv["{count}:file"] = "src/other/mod.spl"
                count = count + 1

            # Filter by file
            var parser_count = 0
            for i in 0..count:
                if kv["{i}:file"] == "src/parser/mod.spl":
                    parser_count = parser_count + 1

            expect(parser_count).to_equal(5)

    context "bulk operations":
        slow_it "handles retrieving 50 bugs":
            var kv: {text: text} = {}
            var count = 0
            for i in 0..50:
                kv["{count}:id"] = "bug_{i}"
                kv["{count}:severity"] = "P1"
                kv["{count}:status"] = "Open"
                count = count + 1
            expect(count).to_equal(50)
            # Spot check
            expect(kv["0:id"]).to_equal("bug_0")
            expect(kv["49:id"]).to_equal("bug_49")

        slow_it "handles mixed status queries with 20 bugs":
            var kv: {text: text} = {}
            var count = 0

            val status_list = ["Open", "Investigating", "Fixed", "Closed"]

            for i in 0..20:
                val stat = status_list[i % 4]
                kv["{count}:id"] = "bug_{i}"
                kv["{count}:severity"] = "P2"
                kv["{count}:status"] = stat
                count = count + 1

            # Count by status
            var open_count = 0
            var investigating_count = 0
            var fixed_count = 0
            var closed_count = 0

            for i in 0..count:
                val sv = kv["{i}:status"]
                if sv == "Open":
                    open_count = open_count + 1
                if sv == "Investigating":
                    investigating_count = investigating_count + 1
                if sv == "Fixed":
                    fixed_count = fixed_count + 1
                if sv == "Closed":
                    closed_count = closed_count + 1

            # Each status should have 5 bugs (20 / 4 statuses)
            expect(open_count).to_equal(5)
            expect(investigating_count).to_equal(5)
            expect(fixed_count).to_equal(5)
            expect(closed_count).to_equal(5)
