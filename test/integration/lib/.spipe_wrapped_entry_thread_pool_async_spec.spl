#![allow(spipe_empty_examples)]
#![allow(spipe_boolean_wrapper_assertions)]
@allow(spipe_empty_examples)
@allow(spipe_boolean_wrapper_assertions)
use std.{ThreadPool, HostFuture, HostRuntime, WorkStealingQueue, register_task_callback, get_task_callback}

# === spipe inline helpers (R2-broader fix; compile-mode only) ===
fn pending(name: text):
    print "    {name} ... pending"

fn skip(name: text, reason: text):
    print "    {name} ... skipped ({reason})"

fn skip_it(name: text, block: fn()):
    print "    {name} ... skipped (compiled-only)"

fn check(condition: bool):
    expect condition

fn check_msg(condition: bool, message: text):
    if not condition:
        print "    check failed: {message}"
    expect condition

fn fail_assertion(message: text):
    print "    assertion failed: {message}"
    expect false

fn fail_test(message: text):
    fail_assertion(message)

fn assert_eq(a, b):
    expect a == b

fn assert_ne(a, b):
    expect a != b

fn assert_true(value):
    expect value

fn assert_false(value):
    expect not value

fn assert_nil(value):
    expect value == nil

fn assert_not_nil(value):
    expect value != nil

fn pending_on(name: text, deps: text, block: fn()):
    it(name, block)

fn pending_skip(name: text, deps: text):
    print "    {name} ... pending (waiting on: {deps})"
# === end spipe inline helpers ===

var GLOBAL_CALLBACK_HITS: usize = 0

fn note_callback_hit():
    GLOBAL_CALLBACK_HITS = GLOBAL_CALLBACK_HITS + 1

fn reset_callback_hits():
    GLOBAL_CALLBACK_HITS = 0

fn main():
    # Thread Pool and Async Runtime Integration Smoke Tests
    #
    # Honest, bounded coverage for the host-side queue/runtime APIs that this spec
    # can directly observe in-process. This suite verifies:
    # - thread-pool construction, queueing, shutdown, and callback registration
    # - host runtime mode/worker configuration
    # - ready/pending future transformations
    # - work-stealing queue LIFO/FIFO behavior
    #
    # It intentionally does not claim proof of real OS-thread execution, race
    # freedom, or cross-thread work stealing under load.


    describe "Thread Pool Basic Integration":
        context "when observing queue-facing thread pool behavior":
            it "constructs a pool with the requested worker count":
                val pool = ThreadPool.new(2)
                expect pool.num_workers == 2
                expect pool.pending_tasks() == 0
                expect pool.is_idle() == true
                expect pool.is_shutdown() == false

            it "uses a non-zero worker count in the default pool":
                val pool = ThreadPool.default()
                expect pool.num_workers > 0 == true
                expect pool.pending_tasks() == 0

            it "tracks submitted tasks in the pending queue":
                var pool = ThreadPool.new(1)
                pool.submit(task_id: 11)
                expect pool.pending_tasks() == 1
                expect pool.is_idle() == false
                pool.shutdown_now()

            it "queues batch submissions in order":
                var pool = ThreadPool.new(1)
                pool.submit_batch(task_ids: [3, 5, 8])
                expect pool.pending_tasks() == 3
                expect pool.task_queue.pop() == 3
                expect pool.task_queue.pop() == 5
                expect pool.task_queue.pop() == 8
                expect pool.pending_tasks() == 0
                pool.shutdown_now()

            it "clears pending work and rejects new submissions after shutdown":
                var pool = ThreadPool.new(1)
                pool.submit_batch(task_ids: [1, 2, 3])
                pool.shutdown_now()
                pool.submit(task_id: 99)
                expect pool.is_shutdown() == true
                expect pool.pending_tasks() == 0
                expect pool.is_idle() == true

            it "waits successfully when the pool is already idle":
                var pool = ThreadPool.new(1)
                expect pool.wait_until_idle(timeout_ms: 10) == true
                pool.shutdown_now()

            it "registers callbacks by task id":
                reset_callback_hits()
                register_task_callback(task_id: 42, callback: note_callback_hit)
                val callback = get_task_callback(task_id: 42)
                expect callback.? == true

                match callback:
                    case Some(cb):
                        cb()
                    case nil:
                        pass

                expect GLOBAL_CALLBACK_HITS == 1


    describe "Thread Pool with Async Runtime":
        context "when composing host runtime and futures":
            it "creates a single-threaded runtime by default":
                val runtime = HostRuntime.new()
                expect runtime.is_multi_threaded() == false
                expect runtime.num_threads == 1

            it "keeps single-threaded mode when configured with extra work queues":
                val runtime = HostRuntime.with_workers(3)
                expect runtime.is_multi_threaded() == false
                expect runtime.num_threads == 1
                expect runtime.scheduler.worker_count == 3

            it "creates a multi-threaded runtime when explicitly requested":
                val runtime = HostRuntime.multi_threaded(2)
                expect runtime.is_multi_threaded() == true
                expect runtime.num_threads == 2
                expect runtime.scheduler.worker_count == 2

            it "blocks on an already-ready future":
                var runtime = HostRuntime.new()
                val result = runtime.block_on(HostFuture.ready(42))
                expect result == 42

            it "maps ready futures before blocking on them":
                var runtime = HostRuntime.new()
                val result = runtime.block_on(HostFuture.ready(7).map(\x: x * 6))
                expect result == 42

            it "chains ready futures with then":
                var runtime = HostRuntime.new()
                val future = HostFuture.ready(5).then(\x: HostFuture.ready(x + 8))
                val result = runtime.block_on(future)
                expect result == 13

            it "preserves pending state through map without fabricating completion":
                val future = HostFuture.pending()
                val mapped = future.map(\x: x + 1)
                expect mapped.is_ready() == false


    describe "Work Stealing and Load Balancing":
        context "when observing local versus steal-end queue semantics":
            it "pops from the local end in LIFO order":
                var queue = WorkStealingQueue.new()
                queue.push(1)
                queue.push(2)
                queue.push(3)
                expect queue.pop() == 3
                expect queue.pop() == 2
                expect queue.pop() == 1

            it "steals from the opposite end in FIFO order":
                var queue = WorkStealingQueue.new()
                queue.push(1)
                queue.push(2)
                queue.push(3)
                expect queue.steal() == 1
                expect queue.steal() == 2
                expect queue.steal() == 3

            it "updates remaining length after mixed pop and steal operations":
                var queue = WorkStealingQueue.new()
                queue.push(10)
                queue.push(20)
                queue.push(30)
                queue.push(40)
                expect queue.len() == 4
                expect queue.steal() == 10
                expect queue.pop() == 40
                expect queue.len() == 2
                expect queue.is_empty() == false

            it "reports empty once all work is drained":
                var queue = WorkStealingQueue.new()
                queue.push(99)
                expect queue.is_empty() == false
                expect queue.pop() == 99
                expect queue.is_empty() == true
                expect queue.len() == 0