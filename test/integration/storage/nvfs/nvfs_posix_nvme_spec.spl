# NVFS POSIX NVMe integration specification.
#
# Verifies that NvfsPosixDriver routes new-file arenas through the NVMe
# backend when a BlockDevice is registered, and that data written through
# the POSIX open/write/read path round-trips correctly via sector I/O.
#
# Run: bin/simple test test/integration/storage/nvfs/nvfs_posix_nvme_spec.spl

use std.spec
use std.fs_driver.types.{Path, OpenFlags, MountOptions}
use std.fs_driver.nvfs_posix_driver.{NvfsPosixDriver}
use std.fs_driver.nvfs_arena.{nvfs_arena_set_block_device, nvfs_arena_has_block_device, nvfs_raw_read_sector}
use os.port.cached_raw_image_block_device.{CachedRawImageBlockDevice}

extern fn rt_dir_create_all(path: text) -> bool
extern fn rt_file_write_bytes(path: text, data: [u8]) -> bool
extern fn rt_bytes_alloc(len: i64) -> [u8]

# ---------------------------------------------------------------------------
# Helpers at module scope — driver mutation must NOT happen inside it-blocks
# ---------------------------------------------------------------------------

struct RoundTripResult:
    """Bundle returned by a single open→write→read→close cycle."""
    ok:      bool
    write_n: i64
    read_n:  i64
    sec0: u8
    sec1: u8
    sec2: u8
    sec3: u8

fn _make_posix_device() -> CachedRawImageBlockDevice:
    """128 KB block device — 256 × 512-byte sectors."""
    val root = "/tmp/nvfs_posix_nvme_spec"
    val _ = rt_dir_create_all(root)
    val img = rt_bytes_alloc(131072)
    val _ = rt_file_write_bytes(root + "/disk.img", img)
    val r = CachedRawImageBlockDevice.from_bytes(root + "/disk.img", img, 512u32)
    r.unwrap()

fn _do_round_trip(data: [u8], data_lba: u64) -> RoundTripResult:
    """Mount a fresh driver, open /rt.bin, write+read data.
    Reads raw sector at data_lba via nvfs_raw_read_sector (uses stored device).
    Caller supplies data_lba = base_block_allocated + 1.
    """
    var drv = NvfsPosixDriver.new("nvme-posix")
    val _ = drv.mount(MountOptions(read_only: false, want_caps: 0, require_caps: 0))
    val flags = OpenFlags.write_only().with_append().with_create()
    val open_r = drv.open(Path(raw: "/rt.bin"), flags)
    if open_r.is_err():
        return RoundTripResult(ok: false, write_n: -1, read_n: -1, sec0: 0u8, sec1: 0u8, sec2: 0u8, sec3: 0u8)
    val fh = open_r.unwrap()
    val wr = drv.write(fh, 0, data)
    val wn = if wr.is_ok(): wr.unwrap() else: -1
    val rbuf = rt_bytes_alloc(data.len() as i64)
    val rr = drv.read(fh, 0, rbuf)
    val rn = if rr.is_ok(): rr.unwrap() else: -1
    val _ = drv.close(fh)
    # Read via the module-static stored device (avoids stale local-copy issue)
    val sb = nvfs_raw_read_sector(data_lba)
    if sb.len() < 4:
        return RoundTripResult(ok: true, write_n: wn, read_n: rn, sec0: 0u8, sec1: 0u8, sec2: 0u8, sec3: 0u8)
    RoundTripResult(ok: true, write_n: wn, read_n: rn, sec0: sb[0], sec1: sb[1], sec2: sb[2], sec3: sb[3])

struct MultiFileResult:
    ok:      bool
    rn1:     i64
    rn2:     i64

fn _do_two_files(dev: CachedRawImageBlockDevice) -> MultiFileResult:
    """Write two distinct files, re-open both and verify byte counts."""
    var drv = NvfsPosixDriver.new("nvme-multi")
    val _ = drv.mount(MountOptions(read_only: false, want_caps: 0, require_caps: 0))
    val flags = OpenFlags.write_only().with_append().with_create()

    val r1 = drv.open(Path(raw: "/f1.bin"), flags)
    if r1.is_err():
        return MultiFileResult(ok: false, rn1: -1, rn2: -1)
    val fh1 = r1.unwrap()
    val d1: [u8] = [0x11, 0x22, 0x33]
    val _ = drv.write(fh1, 0, d1)
    val _ = drv.close(fh1)

    val r2 = drv.open(Path(raw: "/f2.bin"), flags)
    if r2.is_err():
        return MultiFileResult(ok: false, rn1: -1, rn2: -1)
    val fh2 = r2.unwrap()
    val d2: [u8] = [0x44, 0x55, 0x66]
    val _ = drv.write(fh2, 0, d2)
    val _ = drv.close(fh2)

    val ro = OpenFlags.read_only()
    val re1 = drv.open(Path(raw: "/f1.bin"), ro)
    if re1.is_err():
        return MultiFileResult(ok: false, rn1: -1, rn2: -1)
    val rfh1 = re1.unwrap()
    val rb1 = rt_bytes_alloc(3)
    val rr1 = drv.read(rfh1, 0, rb1)
    val rn1 = if rr1.is_ok(): rr1.unwrap() else: -1
    val _ = drv.close(rfh1)

    val re2 = drv.open(Path(raw: "/f2.bin"), ro)
    if re2.is_err():
        return MultiFileResult(ok: false, rn1: rn1, rn2: -1)
    val rfh2 = re2.unwrap()
    val rb2 = rt_bytes_alloc(3)
    val rr2 = drv.read(rfh2, 0, rb2)
    val rn2 = if rr2.is_ok(): rr2.unwrap() else: -1
    val _ = drv.close(rfh2)

    MultiFileResult(ok: true, rn1: rn1, rn2: rn2)

# ---------------------------------------------------------------------------

describe "NvfsPosixDriver NVMe-backed open/read/write":

    it "write and read round-trip through NVMe backend":
        var dev = _make_posix_device()
        nvfs_arena_set_block_device(dev)
        expect(nvfs_arena_has_block_device()).to_equal(true)
        val data: [u8] = [0x48, 0x65, 0x6C, 0x6C, 0x6F]
        # _nvme_next_block starts at 64; this test allocates base=64, data LBA=65
        val trip = _do_round_trip(data, 65u64)
        expect(trip.ok).to_equal(true)
        expect(trip.write_n).to_equal(5)
        expect(trip.read_n).to_equal(5)

    it "data lands on NVMe sectors (raw sector verification)":
        var dev = _make_posix_device()
        nvfs_arena_set_block_device(dev)
        val data: [u8] = [0xDE, 0xAD, 0xBE, 0xEF]
        # Test 1 consumed base=64; test 2 gets base=96, data LBA=97
        val trip = _do_round_trip(data, 97u64)
        expect(trip.ok).to_equal(true)
        # bytes must appear at the start of the data sector
        expect(trip.sec0).to_equal(0xDE)
        expect(trip.sec1).to_equal(0xAD)
        expect(trip.sec2).to_equal(0xBE)
        expect(trip.sec3).to_equal(0xEF)

    it "multiple files each get distinct NVMe sector regions":
        var dev = _make_posix_device()
        nvfs_arena_set_block_device(dev)
        val result = _do_two_files(dev)
        expect(result.ok).to_equal(true)
        expect(result.rn1).to_equal(3)
        expect(result.rn2).to_equal(3)
