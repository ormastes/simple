# NVFS Superblock Disk I/O Specification
#
# Verifies AC-2: superblock format/probe/read via BlockDevice-backed sectors.
# Uses CachedRawImageBlockDevice as an in-memory block device mock.
#
# Run: bin/simple test test/integration/storage/nvfs/nvfs_superblock_disk_spec.spl

use std.spec
use std.fs_driver.nvfs_superblock.{
    nvfs_superblock_set_device, nvfs_superblock_has_device,
    nvfs_superblock_format_disk, nvfs_superblock_probe_disk,
    nvfs_superblock_read_from_disk, NvfsSuperblock, NVFS_MAGIC, NVFS_VERSION,
    nvfs_raw_write_sector, nvfs_raw_read_sector
}
use os.port.cached_raw_image_block_device.{CachedRawImageBlockDevice}

extern fn rt_bytes_alloc(len: i64) -> [u8]
extern fn rt_dir_create_all(path: text) -> bool
extern fn rt_file_write_bytes(path: text, data: [u8]) -> bool

fn _make_device() -> CachedRawImageBlockDevice:
    val root = "/tmp/nvfs_sb_disk_spec"
    val _ = rt_dir_create_all(root)
    val img = rt_bytes_alloc(32768)
    val _ = rt_file_write_bytes(root + "/disk.img", img)
    val r = CachedRawImageBlockDevice.from_bytes(root + "/disk.img", img, 512u32)
    r.unwrap()

describe "NVFS superblock disk I/O":

    it "device registration works":
        var dev = _make_device()
        nvfs_superblock_set_device(dev)
        expect(nvfs_superblock_has_device()).to_equal(true)

    it "probe returns false on blank disk":
        var dev = _make_device()
        nvfs_superblock_set_device(dev)
        val found = nvfs_superblock_probe_disk()
        expect(found).to_equal(false)

    it "format returns true on valid device":
        var dev = _make_device()
        nvfs_superblock_set_device(dev)
        val ok = nvfs_superblock_format_disk(0x1234u64, 0x5678u64)
        expect(ok).to_equal(true)

    it "raw sector write and read round-trips":
        var dev = _make_device()
        nvfs_superblock_set_device(dev)
        var buf = rt_bytes_alloc(512)
        buf[0] = 0xAAu8
        buf[1] = 0xBBu8
        buf[511] = 0xFFu8
        val w = nvfs_raw_write_sector(0u64, buf)
        expect(w).to_equal(true)
        val rd = nvfs_raw_read_sector(0u64)
        expect(rd.len() >= 512).to_equal(true)
        expect(rd[0]).to_equal(0xAA)
        expect(rd[1]).to_equal(0xBB)
        expect(rd[511]).to_equal(0xFF)

    it "probe returns true after format":
        var dev = _make_device()
        nvfs_superblock_set_device(dev)
        val ok = nvfs_superblock_format_disk(0xAAAAu64, 0xBBBBu64)
        expect(ok).to_equal(true)
        val found = nvfs_superblock_probe_disk()
        expect(found).to_equal(true)

    it "read-back after format has correct fields":
        var dev = _make_device()
        nvfs_superblock_set_device(dev)
        val ok = nvfs_superblock_format_disk(0x1111u64, 0x2222u64)
        expect(ok).to_equal(true)
        val sb = nvfs_superblock_read_from_disk()
        expect(sb.valid).to_equal(true)
        expect(sb.magic).to_equal(NVFS_MAGIC)
        expect(sb.version).to_equal(NVFS_VERSION)
        expect(sb.uuid_hi).to_equal(0x1111u64)
        expect(sb.uuid_lo).to_equal(0x2222u64)
        expect(sb.mount_generation).to_equal(1u64)
