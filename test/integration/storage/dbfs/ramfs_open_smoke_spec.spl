use std.spipe.*
use std.fs_driver.ramfs.{RamFsDriver}
use std.fs_driver.types.{Path, OpenFlags, MountOptions}

describe "RamFS direct open smoke":
    it "open creates a file and returns valid handle":
        var d = RamFsDriver.new()
        d.mount(MountOptions.default()).unwrap()
        val fh = d.open(Path(raw: "/x"), OpenFlags.create_write()).unwrap()
        val ok = fh.id > 0
        expect(ok).to_equal(true)
