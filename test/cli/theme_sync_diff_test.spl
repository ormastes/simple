# @cover src/lib/common/ui/theme_sync_diff.spl 80%
"""
# Theme Sync Diff Specification

**Feature IDs:** #THEME-SYNC-002
**Category:** Tooling
**Difficulty:** 2/5
**Status:** Implemented

## Overview

Verifies that `diff_stitch_design_systems` correctly identifies token drift
between local and remote ParsedStitchDesignSystem instances, and that
`format_drift_report` produces the expected output format.

## Behavior
- Returns has_drift=false when both systems are identical
- Detects drift in metadata fields (DriftKind.Metadata)
- Detects drift in typography fields (DriftKind.Typography)
- Detects drift in shape fields (DriftKind.Shape)
- Detects drift in named color fields (DriftKind.ColorNamed)
- Detects drift in color override fields (DriftKind.ColorOverride)
- Detects drift in spacing fields (DriftKind.Spacing)
- format_drift_report includes DRIFT marker for drifted fields
- format_drift_report color gate: ANSI codes present when color=true
"""

use common.ui.theme_sync_sdn.{
    ParsedStitchDesignSystem,
    ParsedStitchMetadata,
    ParsedStitchMd3Colors
}
use common.ui.theme_sync_diff.{
    diff_stitch_design_systems,
    format_drift_report
}

# ============================================================================
# Fixtures
# ============================================================================

fn make_obsidian_meta() -> ParsedStitchMetadata:
    ParsedStitchMetadata(
        display_name: "SimpleOS Obsidian",
        pulled_from: "test",
        pulled_at: "2026-04-12",
        color_mode: "DARK",
        color_variant: "FIDELITY",
        custom_color: "#1A0830",
        roundness: "ROUND_EIGHT",
        spacing_scale: "2",
        font: "SPACE_GROTESK",
        headline_font: "SPACE_GROTESK",
        body_font: "MANROPE",
        label_font: "INTER",
        override_primary_color: "#F5F5F7",
        override_secondary_color: "#1E1E23",
        override_tertiary_color: "#0F172A",
        override_neutral_color: "#060612"
    )

fn make_obsidian_colors() -> ParsedStitchMd3Colors:
    ParsedStitchMd3Colors(
        background: "#12121f",
        error: "#ffb4ab",
        error_container: "#93000a",
        inverse_on_surface: "#2f2f3d",
        inverse_primary: "#5d5e60",
        inverse_surface: "#e3e0f3",
        on_background: "#e3e0f3",
        on_error: "#690005",
        on_error_container: "#ffdad6",
        on_primary: "#2f3132",
        on_primary_container: "#7c7d7f",
        on_primary_fixed: "#1a1c1d",
        on_primary_fixed_variant: "#454749",
        on_secondary: "#303035",
        on_secondary_container: "#b6b4bb",
        on_secondary_fixed: "#1b1b20",
        on_secondary_fixed_variant: "#47464c",
        on_surface: "#e3e0f3",
        on_surface_variant: "#ccc4ce",
        on_tertiary: "#283044",
        on_tertiary_container: "#757d95",
        on_tertiary_fixed: "#131b2e",
        on_tertiary_fixed_variant: "#3f465c",
        outline: "#958e98",
        outline_variant: "#4a454d",
        primary: "#c6c6c8",
        primary_container: "#101214",
        primary_fixed: "#e2e2e4",
        primary_fixed_dim: "#c6c6c8",
        secondary: "#c8c5cc",
        secondary_container: "#47464c",
        secondary_fixed: "#e4e1e8",
        secondary_fixed_dim: "#c8c5cc",
        surface: "#12121f",
        surface_bright: "#383846",
        surface_container: "#1e1e2c",
        surface_container_high: "#292937",
        surface_container_highest: "#343342",
        surface_container_low: "#1a1a28",
        surface_container_lowest: "#0d0d1a",
        surface_dim: "#12121f",
        surface_tint: "#c6c6c8",
        surface_variant: "#343342",
        tertiary: "#bec6e0",
        tertiary_container: "#0a1225",
        tertiary_fixed: "#dae2fd",
        tertiary_fixed_dim: "#bec6e0"
    )

fn make_obsidian_ds() -> ParsedStitchDesignSystem:
    ParsedStitchDesignSystem(
        metadata: make_obsidian_meta(),
        md3: make_obsidian_colors()
    )

# ============================================================================
# Test Group 1: No drift
# ============================================================================

describe "diff_stitch_design_systems - no drift":
    it "has_drift is false when systems are identical":
        val ds = make_obsidian_ds()
        val report = diff_stitch_design_systems(ds, ds)
        expect(report.has_drift).to_equal(false)

    it "produces entries for all fields even with no drift":
        val ds = make_obsidian_ds()
        val report = diff_stitch_design_systems(ds, ds)
        # Should have entries for metadata + shape + spacing + typography + overrides + 47 colors
        expect(report.entries.len() > 0).to_equal(true)

    it "no entries are marked as drift":
        val ds = make_obsidian_ds()
        val report = diff_stitch_design_systems(ds, ds)
        var drift_count = 0
        var i = 0
        while i < report.entries.len():
            if report.entries[i].is_drift:
                drift_count = drift_count + 1
            i = i + 1
        expect(drift_count).to_equal(0)

# ============================================================================
# Test Group 2: Typography drift
# ============================================================================

describe "diff_stitch_design_systems - typography drift":
    it "detects body_font drift":
        val local_ds = make_obsidian_ds()
        val remote_meta = ParsedStitchMetadata(
            display_name: "SimpleOS Obsidian",
            pulled_from: "remote",
            pulled_at: "2026-04-12",
            color_mode: "DARK",
            color_variant: "FIDELITY",
            custom_color: "#1A0830",
            roundness: "ROUND_EIGHT",
            spacing_scale: "2",
            font: "SPACE_GROTESK",
            headline_font: "SPACE_GROTESK",
            body_font: "INTER",
            label_font: "INTER",
            override_primary_color: "#F5F5F7",
            override_secondary_color: "#1E1E23",
            override_tertiary_color: "#0F172A",
            override_neutral_color: "#060612"
        )
        val remote_ds = ParsedStitchDesignSystem(metadata: remote_meta, md3: make_obsidian_colors())
        val report = diff_stitch_design_systems(local_ds, remote_ds)
        expect(report.has_drift).to_equal(true)
        # Find the body_font entry
        var found_body_font_drift = false
        var i = 0
        while i < report.entries.len():
            val e = report.entries[i]
            if e.field == "body_font" and e.is_drift:
                found_body_font_drift = true
            i = i + 1
        expect(found_body_font_drift).to_equal(true)

