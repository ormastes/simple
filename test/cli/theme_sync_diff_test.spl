# ============================================================================
# Test Group 5: format_drift_report output format
# ============================================================================

describe "format_drift_report - no drift output":
    it "says no drift when systems are identical":
        val ds = make_obsidian_ds()
        val report = diff_stitch_design_systems(ds, ds)
        val output = format_drift_report(report, false)
        expect(output.contains("No drift detected")).to_equal(true)

describe "format_drift_report - drift output":
    it "says Drift detected with count":
        val local_ds = make_obsidian_ds()
        val remote_meta = ParsedStitchMetadata(
            display_name: "SimpleOS Obsidian",
            pulled_from: "remote",
            pulled_at: "2026-04-12",
            color_mode: "DARK",
            color_variant: "FIDELITY",
            custom_color: "#1A0830",
            roundness: "ROUND_TWELVE",
            spacing_scale: "2",
            font: "SPACE_GROTESK",
            headline_font: "SPACE_GROTESK",
            body_font: "INTER",
            label_font: "INTER",
            override_primary_color: "#F5F5F7",
            override_secondary_color: "#1E1E23",
            override_tertiary_color: "#0F172A",
            override_neutral_color: "#060612"
        )
        val remote_ds = ParsedStitchDesignSystem(metadata: remote_meta, md3: make_obsidian_colors())
        val report = diff_stitch_design_systems(local_ds, remote_ds)
        val output = format_drift_report(report, false)
        expect(output.contains("Drift detected:")).to_equal(true)

    it "includes [DRIFT] marker for drifted fields":
        val local_ds = make_obsidian_ds()
        val remote_meta = ParsedStitchMetadata(
            display_name: "SimpleOS Obsidian",
            pulled_from: "remote",
            pulled_at: "2026-04-12",
            color_mode: "DARK",
            color_variant: "FIDELITY",
            custom_color: "#1A0830",
            roundness: "ROUND_TWELVE",
            spacing_scale: "2",
            font: "SPACE_GROTESK",
            headline_font: "SPACE_GROTESK",
            body_font: "MANROPE",
            label_font: "INTER",
            override_primary_color: "#F5F5F7",
            override_secondary_color: "#1E1E23",
            override_tertiary_color: "#0F172A",
            override_neutral_color: "#060612"
        )
        val remote_ds = ParsedStitchDesignSystem(metadata: remote_meta, md3: make_obsidian_colors())
        val report = diff_stitch_design_systems(local_ds, remote_ds)
        val output = format_drift_report(report, false)
        expect(output.contains("[DRIFT]")).to_equal(true)

    it "includes local= and remote= labels for drifted fields":
        val local_ds = make_obsidian_ds()
        val remote_meta = ParsedStitchMetadata(
            display_name: "SimpleOS Obsidian",
            pulled_from: "remote",
            pulled_at: "2026-04-12",
            color_mode: "DARK",
            color_variant: "FIDELITY",
            custom_color: "#1A0830",
            roundness: "ROUND_TWELVE",
            spacing_scale: "2",
            font: "SPACE_GROTESK",
            headline_font: "SPACE_GROTESK",
            body_font: "MANROPE",
            label_font: "INTER",
            override_primary_color: "#F5F5F7",
            override_secondary_color: "#1E1E23",
            override_tertiary_color: "#0F172A",
            override_neutral_color: "#060612"
        )
        val remote_ds = ParsedStitchDesignSystem(metadata: remote_meta, md3: make_obsidian_colors())
        val report = diff_stitch_design_systems(local_ds, remote_ds)
        val output = format_drift_report(report, false)
        expect(output.contains("local=")).to_equal(true)
        expect(output.contains("remote=")).to_equal(true)

describe "format_drift_report - ANSI color mode":
    it "contains ANSI escape codes when color=true":
        val local_ds = make_obsidian_ds()
        val remote_meta = ParsedStitchMetadata(
            display_name: "SimpleOS Obsidian",
            pulled_from: "remote",
            pulled_at: "2026-04-12",
            color_mode: "DARK",
            color_variant: "FIDELITY",
            custom_color: "#1A0830",
            roundness: "ROUND_TWELVE",
            spacing_scale: "2",
            font: "SPACE_GROTESK",
            headline_font: "SPACE_GROTESK",
            body_font: "MANROPE",
            label_font: "INTER",
            override_primary_color: "#F5F5F7",
            override_secondary_color: "#1E1E23",
            override_tertiary_color: "#0F172A",
            override_neutral_color: "#060612"
        )
        val remote_ds = ParsedStitchDesignSystem(metadata: remote_meta, md3: make_obsidian_colors())
        val report = diff_stitch_design_systems(local_ds, remote_ds)
        val output_color = format_drift_report(report, true)
        val output_plain = format_drift_report(report, false)
        # Color output should be longer due to escape codes
        expect(output_color.len() > output_plain.len()).to_equal(true)
