# Boot filesystem freestanding mount path — type and initial-state tests.
#
# Verifies CNvmeBlockAdapterFs type structure and the FsMountResult/FsMountType
# types from boot_fs_mount.spl.  These tests import no hosted symbols (no
# spawn_binary, no NvmeDriver, no syscall-based DMA).
#
# Run: bin/simple test test/kernel/boot_fs_mount_spec.spl

use std.spipe.*
use os.kernel.boot.c_nvme_adapter.{CNvmeBlockAdapterFs}
use os.kernel.boot.boot_fs_mount.{
    FsMountType, FsMountResult, fs_mount_done, fs_mount_type,
    boot_fs_mount_acceptance_reason, boot_fs_mount_provider_is_pure_simple
}

describe "CNvmeBlockAdapterFs — freestanding adapter initial state":

    it "new adapter is not ready":
        val adapter = CNvmeBlockAdapterFs(sector_buf_addr: 0, ready: false)
        expect(adapter.ready).to_equal(false)

    it "new adapter has zero sector_buf_addr":
        val adapter = CNvmeBlockAdapterFs(sector_buf_addr: 0, ready: false)
        expect(adapter.sector_buf_addr).to_equal(0)

    it "static new produces same zero state":
        val adapter = CNvmeBlockAdapterFs.new()
        expect(adapter.ready).to_equal(false)
        expect(adapter.sector_buf_addr).to_equal(0)

describe "FsMountResult — result type structure":

    it "mounted NVFS result carries correct type":
        val r = FsMountResult(mounted: true, fs_type: FsMountType.Nvfs, provider: "c-boot-bridge", pure_simple: false)
        expect(r.mounted).to_equal(true)

    it "mounted DBFS result carries correct type":
        val r = FsMountResult(mounted: true, fs_type: FsMountType.Dbfs, provider: "c-boot-bridge", pure_simple: false)
        expect(r.mounted).to_equal(true)

    it "unmounted result has None_ type":
        val r = FsMountResult(mounted: false, fs_type: FsMountType.None_, provider: "none", pure_simple: false)
        expect(r.mounted).to_equal(false)

    it "rejects C bridge mount result as pure Simple boot-storage evidence":
        val c_bridge = FsMountResult(mounted: true, fs_type: FsMountType.Nvfs, provider: "c-boot-bridge", pure_simple: false)
        val pure = FsMountResult(mounted: true, fs_type: FsMountType.Nvfs, provider: "simple-driver", pure_simple: true)
        expect(boot_fs_mount_provider_is_pure_simple("c-boot-bridge")).to_equal(false)
        expect(boot_fs_mount_acceptance_reason(c_bridge)).to_equal("boot-storage-not-pure-simple:c-boot-bridge")
        expect(boot_fs_mount_acceptance_reason(pure)).to_equal("ready")

describe "boot_fs_mount module-level state — initial values":

    it "fs_mount_done starts false":
        expect(fs_mount_done()).to_equal(false)
