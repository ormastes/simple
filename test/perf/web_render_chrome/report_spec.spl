# report_spec.spl
# Chrome vs Simple web renderer performance comparison — BDD assertions.
# Uses inline synthetic baseline data (no file I/O dependency).
# Run: bin/simple test test/perf/web_render_chrome/report_spec.spl

val P95_FRAME_LIMIT_MS = 16.7
val PASS_RATIO_MAX     = 1.5
val WARN_RATIO_MAX     = 2.0
val PASS_PIXEL_MIN     = 99.0
val WARN_PIXEL_MIN     = 95.0
val FIXTURES = ["static_page", "scroll_heavy", "layout_stress", "paint_heavy"]

class ReportRow:
    fixture:               text
    simple_frame_ms:       f64
    chrome_frame_ms:       f64
    simple_vs_chrome_ratio: f64
    pixel_hash_simple:     text
    pixel_hash_chrome:     text
    pixel_match_pct:       f64
    parse_ms:     f64
    style_ms:     f64
    layout_ms:    f64
    paint_ms:     f64
    composite_ms: f64
    present_ms:   f64
    chrome_fps:            f64
    chrome_dropped_frames: f64
    chrome_gpu_raster_ms:  f64
    chrome_memory_mb:      f64
    source: text
    status: text

fn make_row(fixture: text) -> ReportRow:
    ReportRow(
        fixture: fixture, simple_frame_ms: 0.0, chrome_frame_ms: 0.0,
        simple_vs_chrome_ratio: 0.0, pixel_hash_simple: "", pixel_hash_chrome: "",
        pixel_match_pct: 0.0, parse_ms: 0.0, style_ms: 0.0, layout_ms: 0.0,
        paint_ms: 0.0, composite_ms: 0.0, present_ms: 0.0,
        chrome_fps: 0.0, chrome_dropped_frames: 0.0, chrome_gpu_raster_ms: 0.0,
        chrome_memory_mb: 0.0, source: "synthetic", status: "PENDING",
    )

fn synth_simple_ms(fixture: text) -> f64:
    if fixture == "static_page":
        return 12.0
    elif fixture == "scroll_heavy":
        return 16.5
    elif fixture == "layout_stress":
        return 16.0
    elif fixture == "paint_heavy":
        return 16.5
    12.0

fn synth_chrome_ms(fixture: text) -> f64:
    if fixture == "static_page":
        return 10.5
    elif fixture == "scroll_heavy":
        return 14.0
    elif fixture == "layout_stress":
        return 15.0
    elif fixture == "paint_heavy":
        return 16.0
    10.5

fn synth_pixel_hash(fixture: text) -> text:
    if fixture == "static_page":
        return "a1b2c3d4e5f6a7b8"
    elif fixture == "scroll_heavy":
        return "b2c3d4e5f6a7b8c9"
    elif fixture == "layout_stress":
        return "c3d4e5f6a7b8c9d0"
    elif fixture == "paint_heavy":
        return "d4e5f6a7b8c9d0e1"
    "0000000000000000"

fn synth_parse_ms(fixture: text) -> f64:
    if fixture == "static_page":
        return 1.5
    elif fixture == "scroll_heavy":
        return 2.2
    elif fixture == "layout_stress":
        return 1.8
    elif fixture == "paint_heavy":
        return 1.2
    1.0

fn synth_style_ms(fixture: text) -> f64:
    if fixture == "static_page":
        return 1.0
    elif fixture == "scroll_heavy":
        return 1.8
    elif fixture == "layout_stress":
        return 1.5
    elif fixture == "paint_heavy":
        return 1.0
    0.8

fn synth_layout_ms(fixture: text) -> f64:
    if fixture == "static_page":
        return 2.5
    elif fixture == "scroll_heavy":
        return 3.5
    elif fixture == "layout_stress":
        return 5.0
    elif fixture == "paint_heavy":
        return 2.8
    2.0

fn synth_paint_ms(fixture: text) -> f64:
    if fixture == "static_page":
        return 3.5
    elif fixture == "scroll_heavy":
        return 4.5
    elif fixture == "layout_stress":
        return 4.0
    elif fixture == "paint_heavy":
        return 6.5
    3.0

fn synth_composite_ms(fixture: text) -> f64:
    if fixture == "static_page":
        return 0.8
    elif fixture == "scroll_heavy":
        return 1.2
    elif fixture == "layout_stress":
        return 1.0
    elif fixture == "paint_heavy":
        return 1.8
    0.6

fn synth_present_ms(fixture: text) -> f64:
    if fixture == "static_page":
        return 0.7
    elif fixture == "scroll_heavy":
        return 1.0
    elif fixture == "layout_stress":
        return 0.9
    elif fixture == "paint_heavy":
        return 1.2
    0.5

fn synth_chrome_dropped(fixture: text) -> f64:
    if fixture == "static_page":
        return 0.0
    elif fixture == "scroll_heavy":
        return 1.0
    elif fixture == "layout_stress":
        return 2.0
    elif fixture == "paint_heavy":
        return 3.0
    0.0

fn synth_chrome_gpu_raster(fixture: text) -> f64:
    if fixture == "static_page":
        return 2.1
    elif fixture == "scroll_heavy":
        return 4.2
    elif fixture == "layout_stress":
        return 5.8
    elif fixture == "paint_heavy":
        return 7.5
    2.0

fn synth_chrome_memory(fixture: text) -> f64:
    if fixture == "static_page":
        return 48.0
    elif fixture == "scroll_heavy":
        return 62.0
    elif fixture == "layout_stress":
        return 70.0
    elif fixture == "paint_heavy":
        return 80.0
    48.0

fn classify_status(source: text, simple_ms: f64, ratio: f64, pixel_pct: f64) -> text:
    if source == "synthetic":
        return "PENDING"
    if simple_ms > P95_FRAME_LIMIT_MS:
        return "FAIL"
    if ratio > WARN_RATIO_MAX:
        return "FAIL"
    if pixel_pct < WARN_PIXEL_MIN:
        return "FAIL"
    if simple_ms > P95_FRAME_LIMIT_MS * 0.9:
        return "WARN"
    if ratio > PASS_RATIO_MAX:
        return "WARN"
    if pixel_pct < PASS_PIXEL_MIN:
        return "WARN"
    "PASS"

fn build_row(fixture: text) -> ReportRow:
    var row = make_row(fixture)
    row.parse_ms      = synth_parse_ms(fixture)
    row.style_ms      = synth_style_ms(fixture)
    row.layout_ms     = synth_layout_ms(fixture)
    row.paint_ms      = synth_paint_ms(fixture)
    row.composite_ms  = synth_composite_ms(fixture)
    row.present_ms    = synth_present_ms(fixture)
    row.simple_frame_ms = synth_simple_ms(fixture)
    row.chrome_frame_ms = synth_chrome_ms(fixture)
    row.pixel_hash_simple = synth_pixel_hash(fixture)
    row.pixel_hash_chrome = ""
    row.pixel_match_pct   = 95.0
    row.chrome_fps            = 60.0
    row.chrome_dropped_frames = synth_chrome_dropped(fixture)
    row.chrome_gpu_raster_ms  = synth_chrome_gpu_raster(fixture)
    row.chrome_memory_mb      = synth_chrome_memory(fixture)
    if row.chrome_frame_ms > 0.0:
        row.simple_vs_chrome_ratio = row.simple_frame_ms / row.chrome_frame_ms
    row.source = "synthetic"
    row.status = classify_status(row.source, row.simple_frame_ms, row.simple_vs_chrome_ratio, row.pixel_match_pct)
    row

fn load_all_rows() -> [ReportRow]:
    var rows: [ReportRow] = []
    var i = 0
    while i < FIXTURES.len():
        rows.push(build_row(FIXTURES[i]))
        i = i + 1
    rows

fn row_count(rows: [ReportRow]) -> i64:
    rows.len()

fn find_row(rows: [ReportRow], fixture: text) -> ReportRow:
    var i = 0
    while i < rows.len():
        if rows[i].fixture == fixture:
            return rows[i]
        i = i + 1
    make_row(fixture)

fn all_rows_have_fields(rows: [ReportRow]) -> bool:
    var ok = true
    var i = 0
    while i < rows.len():
        if rows[i].fixture == "":
            ok = false
        if rows[i].pixel_match_pct < 0.0:
            ok = false
        i = i + 1
    ok

fn all_statuses_valid(rows: [ReportRow]) -> bool:
    var ok = true
    var i = 0
    while i < rows.len():
        val s = rows[i].status
        if s != "PASS" and s != "WARN" and s != "FAIL" and s != "PENDING":
            ok = false
        i = i + 1
    ok

fn all_synthetic_are_pending(rows: [ReportRow]) -> bool:
    var ok = true
    var i = 0
    while i < rows.len():
        val r = rows[i]
        if r.source == "synthetic" and r.status != "PENDING":
            ok = false
        i = i + 1
    ok

fn ratio_correct_for(row: ReportRow) -> bool:
    if row.chrome_frame_ms == 0.0:
        return true
    val expected = row.simple_frame_ms / row.chrome_frame_ms
    val diff = expected - row.simple_vs_chrome_ratio
    val abs_diff = if diff < 0.0 then -diff else diff
    abs_diff < 0.001

fn stage_sum_near_total(row: ReportRow) -> bool:
    val sum = row.parse_ms + row.style_ms + row.layout_ms + row.paint_ms + row.composite_ms + row.present_ms
    val total = row.simple_frame_ms
    if total == 0.0:
        return true
    val diff = sum - total
    val abs_diff = if diff < 0.0 then -diff else diff
    abs_diff / total < 0.20

fn nfr_2b_ok(row: ReportRow) -> bool:
    if row.source == "synthetic":
        return row.status == "PENDING"
    row.simple_frame_ms <= P95_FRAME_LIMIT_MS

fn source_valid(row: ReportRow) -> bool:
    if row.source == "synthetic":
        return true
    if row.source == "measured":
        return true
    false

fn print_report(rows: [ReportRow]):
    print ""
    print "=== Chrome vs Simple Web Renderer — Performance Report ==="
    print "NFR 2B: p95 <= 16.7ms | ratio <= 1.5x PASS | <= 2.0x WARN | > 2.0x FAIL"
    print ""
    var i = 0
    while i < rows.len():
        val r = rows[i]
        print r.fixture + "  simple=" + r.simple_frame_ms.to_text() + "ms chrome=" + r.chrome_frame_ms.to_text() + "ms ratio=" + r.simple_vs_chrome_ratio.to_text() + " pixel=" + r.pixel_match_pct.to_text() + "% " + r.status
        print "  stages: parse=" + r.parse_ms.to_text() + " style=" + r.style_ms.to_text() + " layout=" + r.layout_ms.to_text() + " paint=" + r.paint_ms.to_text() + " composite=" + r.composite_ms.to_text() + " present=" + r.present_ms.to_text()
        print "  chrome: fps=" + r.chrome_fps.to_text() + " dropped=" + r.chrome_dropped_frames.to_text() + " gpu_raster=" + r.chrome_gpu_raster_ms.to_text() + "ms mem=" + r.chrome_memory_mb.to_text() + "MB"
        print "  pixel_hash_simple=" + r.pixel_hash_simple + "  pixel_hash_chrome=" + r.pixel_hash_chrome
        i = i + 1
    print ""

describe "Chrome vs Simple — Report Shape":
    it "loads all four fixture rows":
        val rows = load_all_rows()
        expect(row_count(rows)).to_equal(4)

    it "all rows have required fields":
        val rows = load_all_rows()
        expect(all_rows_have_fields(rows)).to_equal(true)

    it "all status values are valid":
        val rows = load_all_rows()
        expect(all_statuses_valid(rows)).to_equal(true)

    it "simple_vs_chrome_ratio is non-negative for static_page":
        val rows = load_all_rows()
        val row = find_row(rows, "static_page")
        expect(row.simple_vs_chrome_ratio >= 0.0).to_equal(true)

    it "pixel_hash_simple is non-empty for static_page":
        val rows = load_all_rows()
        val row = find_row(rows, "static_page")
        expect(row.pixel_hash_simple.len() > 0).to_equal(true)

    it "pixel_hash_chrome field is present":
        val rows = load_all_rows()
        val row = find_row(rows, "static_page")
        expect(row.pixel_hash_chrome.len() >= 0).to_equal(true)

    it "pixel_match_pct is non-negative for static_page":
        val rows = load_all_rows()
        val row = find_row(rows, "static_page")
        expect(row.pixel_match_pct >= 0.0).to_equal(true)

    it "all four fixture names appear in loaded rows":
        val rows = load_all_rows()
        val has_static  = find_row(rows, "static_page").fixture == "static_page"
        val has_scroll  = find_row(rows, "scroll_heavy").fixture == "scroll_heavy"
        val has_layout  = find_row(rows, "layout_stress").fixture == "layout_stress"
        val has_paint   = find_row(rows, "paint_heavy").fixture == "paint_heavy"
        expect(has_static and has_scroll and has_layout and has_paint).to_equal(true)

describe "Chrome vs Simple — Threshold Math":
    it "ratio = simple_frame_ms / chrome_frame_ms for static_page":
        val rows = load_all_rows()
        expect(ratio_correct_for(find_row(rows, "static_page"))).to_equal(true)

    it "ratio = simple_frame_ms / chrome_frame_ms for scroll_heavy":
        val rows = load_all_rows()
        expect(ratio_correct_for(find_row(rows, "scroll_heavy"))).to_equal(true)

    it "ratio = simple_frame_ms / chrome_frame_ms for layout_stress":
        val rows = load_all_rows()
        expect(ratio_correct_for(find_row(rows, "layout_stress"))).to_equal(true)

    it "ratio = simple_frame_ms / chrome_frame_ms for paint_heavy":
        val rows = load_all_rows()
        expect(ratio_correct_for(find_row(rows, "paint_heavy"))).to_equal(true)

    it "stage breakdown sums within 20pct of total for static_page":
        val rows = load_all_rows()
        expect(stage_sum_near_total(find_row(rows, "static_page"))).to_equal(true)

    it "stage breakdown sums within 20pct of total for scroll_heavy":
        val rows = load_all_rows()
        expect(stage_sum_near_total(find_row(rows, "scroll_heavy"))).to_equal(true)

    it "stage breakdown sums within 20pct of total for layout_stress":
        val rows = load_all_rows()
        expect(stage_sum_near_total(find_row(rows, "layout_stress"))).to_equal(true)

    it "stage breakdown sums within 20pct of total for paint_heavy":
        val rows = load_all_rows()
        expect(stage_sum_near_total(find_row(rows, "paint_heavy"))).to_equal(true)

describe "Chrome vs Simple — NFR 2B Compliance":
    it "static_page is PENDING or within 16.7ms p95":
        val rows = load_all_rows()
        expect(nfr_2b_ok(find_row(rows, "static_page"))).to_equal(true)

    it "scroll_heavy is PENDING or within 16.7ms p95":
        val rows = load_all_rows()
        expect(nfr_2b_ok(find_row(rows, "scroll_heavy"))).to_equal(true)

    it "layout_stress is PENDING or within 16.7ms p95":
        val rows = load_all_rows()
        expect(nfr_2b_ok(find_row(rows, "layout_stress"))).to_equal(true)

    it "paint_heavy is PENDING or within 16.7ms p95":
        val rows = load_all_rows()
        expect(nfr_2b_ok(find_row(rows, "paint_heavy"))).to_equal(true)

    it "synthetic rows yield PENDING status — no false greens":
        val rows = load_all_rows()
        expect(all_synthetic_are_pending(rows)).to_equal(true)

    it "source field is valid for static_page":
        val rows = load_all_rows()
        expect(source_valid(find_row(rows, "static_page"))).to_equal(true)

describe "Chrome vs Simple — classify_status":
    it "returns FAIL when measured frame_ms exceeds 16.7":
        val status = classify_status("measured", 20.0, 1.2, 99.5)
        expect(status).to_equal("FAIL")

    it "returns FAIL when measured ratio exceeds 2.0":
        val status = classify_status("measured", 10.0, 2.5, 99.5)
        expect(status).to_equal("FAIL")

    it "returns FAIL when measured pixel_match below 95":
        val status = classify_status("measured", 10.0, 1.2, 90.0)
        expect(status).to_equal("FAIL")

    it "returns PASS for healthy measured data":
        val status = classify_status("measured", 10.0, 1.2, 99.5)
        expect(status).to_equal("PASS")

    it "returns WARN when ratio between 1.5 and 2.0":
        val status = classify_status("measured", 10.0, 1.8, 99.5)
        expect(status).to_equal("WARN")

    it "returns PENDING for synthetic regardless of timings":
        val status = classify_status("synthetic", 5.0, 0.8, 100.0)
        expect(status).to_equal("PENDING")

describe "Chrome vs Simple — Report Output":
    it "prints full comparison report without error":
        val rows = load_all_rows()
        print_report(rows)
        expect(row_count(rows)).to_equal(4)
