# trace_normalizer.spl
#
# Normalize Chrome and Simple renderer trace data into common records.
# Falls back to synthetic baseline when artifact files are absent.
#
# Run: bin/simple run test/perf/web_render_chrome/trace_normalizer.spl

extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_exists(path: text) -> bool
extern fn rt_time_now_unix_micros() -> i64

val P95_FRAME_LIMIT_MS  = 16.7
val PASS_RATIO_MAX      = 1.5
val WARN_RATIO_MAX      = 2.0
val PASS_PIXEL_MIN_PCT  = 99.0
val WARN_PIXEL_MIN_PCT  = 95.0
val FIXTURES = ["static_page", "scroll_heavy", "layout_stress", "paint_heavy"]

class NormalizedRecord:
    fixture:               text
    simple_frame_ms:       f64
    chrome_frame_ms:       f64
    simple_vs_chrome_ratio: f64
    pixel_hash_simple:     text
    pixel_hash_chrome:     text
    pixel_match_pct:       f64
    parse_ms:      f64
    style_ms:      f64
    layout_ms:     f64
    paint_ms:      f64
    composite_ms:  f64
    present_ms:    f64
    chrome_fps:          f64
    chrome_dropped:      f64
    chrome_gpu_raster_ms: f64
    chrome_memory_mb:    f64
    source: text
    status: text

fn make_record(fixture: text) -> NormalizedRecord:
    NormalizedRecord(
        fixture: fixture, simple_frame_ms: 0.0, chrome_frame_ms: 0.0,
        simple_vs_chrome_ratio: 0.0, pixel_hash_simple: "", pixel_hash_chrome: "",
        pixel_match_pct: 0.0, parse_ms: 0.0, style_ms: 0.0, layout_ms: 0.0,
        paint_ms: 0.0, composite_ms: 0.0, present_ms: 0.0, chrome_fps: 0.0,
        chrome_dropped: 0.0, chrome_gpu_raster_ms: 0.0, chrome_memory_mb: 0.0,
        source: "synthetic", status: "PENDING",
    )

fn synth_simple_frame_ms(fixture: text) -> f64:
    if fixture == "static_page":
        return 12.0
    elif fixture == "scroll_heavy":
        return 16.5
    elif fixture == "layout_stress":
        return 16.0
    elif fixture == "paint_heavy":
        return 16.5
    12.0

fn synth_chrome_frame_ms(fixture: text) -> f64:
    if fixture == "static_page":
        return 10.5
    elif fixture == "scroll_heavy":
        return 14.0
    elif fixture == "layout_stress":
        return 15.0
    elif fixture == "paint_heavy":
        return 16.0
    10.5

fn synth_pixel_hash(fixture: text) -> text:
    if fixture == "static_page":
        return "a1b2c3d4e5f6a7b8"
    elif fixture == "scroll_heavy":
        return "b2c3d4e5f6a7b8c9"
    elif fixture == "layout_stress":
        return "c3d4e5f6a7b8c9d0"
    elif fixture == "paint_heavy":
        return "d4e5f6a7b8c9d0e1"
    "0000000000000000"

fn synth_stage(fixture: text, stage: text) -> f64:
    if stage == "parse":
        if fixture == "static_page":
            return 1.5
        elif fixture == "scroll_heavy":
            return 2.2
        elif fixture == "layout_stress":
            return 1.8
        elif fixture == "paint_heavy":
            return 1.2
        return 1.0
    elif stage == "style":
        if fixture == "static_page":
            return 1.0
        elif fixture == "scroll_heavy":
            return 1.8
        elif fixture == "layout_stress":
            return 1.5
        elif fixture == "paint_heavy":
            return 1.0
        return 0.8
    elif stage == "layout":
        if fixture == "static_page":
            return 2.5
        elif fixture == "scroll_heavy":
            return 3.5
        elif fixture == "layout_stress":
            return 5.0
        elif fixture == "paint_heavy":
            return 2.8
        return 2.0
    elif stage == "paint":
        if fixture == "static_page":
            return 3.5
        elif fixture == "scroll_heavy":
            return 4.5
        elif fixture == "layout_stress":
            return 4.0
        elif fixture == "paint_heavy":
            return 6.5
        return 3.0
    elif stage == "composite":
        if fixture == "static_page":
            return 0.8
        elif fixture == "scroll_heavy":
            return 1.2
        elif fixture == "layout_stress":
            return 1.0
        elif fixture == "paint_heavy":
            return 1.8
        return 0.6
    if fixture == "static_page":
        return 0.7
    elif fixture == "scroll_heavy":
        return 1.0
    elif fixture == "layout_stress":
        return 0.9
    elif fixture == "paint_heavy":
        return 1.2
    0.5

fn classify_status(source: text, simple_ms: f64, ratio: f64, pixel_pct: f64) -> text:
    if source == "synthetic":
        return "PENDING"
    if simple_ms > P95_FRAME_LIMIT_MS:
        return "FAIL"
    if ratio > WARN_RATIO_MAX:
        return "FAIL"
    if pixel_pct < WARN_PIXEL_MIN_PCT:
        return "FAIL"
    if simple_ms > P95_FRAME_LIMIT_MS * 0.9:
        return "WARN"
    if ratio > PASS_RATIO_MAX:
        return "WARN"
    if pixel_pct < PASS_PIXEL_MIN_PCT:
        return "WARN"
    "PASS"

fn build_synthetic_record(fixture: text) -> NormalizedRecord:
    var rec = make_record(fixture)
    rec.parse_ms     = synth_stage(fixture, "parse")
    rec.style_ms     = synth_stage(fixture, "style")
    rec.layout_ms    = synth_stage(fixture, "layout")
    rec.paint_ms     = synth_stage(fixture, "paint")
    rec.composite_ms = synth_stage(fixture, "composite")
    rec.present_ms   = synth_stage(fixture, "present")
    rec.simple_frame_ms = synth_simple_frame_ms(fixture)
    rec.chrome_frame_ms = synth_chrome_frame_ms(fixture)
    rec.pixel_hash_simple = synth_pixel_hash(fixture)
    rec.pixel_hash_chrome = ""
    rec.pixel_match_pct = 95.0
    rec.chrome_fps = 60.0
    if rec.chrome_frame_ms > 0.0:
        rec.simple_vs_chrome_ratio = rec.simple_frame_ms / rec.chrome_frame_ms
    rec.source = "synthetic"
    rec.status = classify_status(rec.source, rec.simple_frame_ms, rec.simple_vs_chrome_ratio, rec.pixel_match_pct)
    rec

fn record_to_json(rec: NormalizedRecord) -> text:
    "{\"fixture\":\"" + rec.fixture + "\","
    + "\"simple_frame_ms\":" + rec.simple_frame_ms.to_text() + ","
    + "\"chrome_frame_ms\":" + rec.chrome_frame_ms.to_text() + ","
    + "\"simple_vs_chrome_ratio\":" + rec.simple_vs_chrome_ratio.to_text() + ","
    + "\"pixel_hash_simple\":\"" + rec.pixel_hash_simple + "\","
    + "\"pixel_hash_chrome\":\"" + rec.pixel_hash_chrome + "\","
    + "\"pixel_match_pct\":" + rec.pixel_match_pct.to_text() + ","
    + "\"parse_ms\":" + rec.parse_ms.to_text() + ","
    + "\"style_ms\":" + rec.style_ms.to_text() + ","
    + "\"layout_ms\":" + rec.layout_ms.to_text() + ","
    + "\"paint_ms\":" + rec.paint_ms.to_text() + ","
    + "\"composite_ms\":" + rec.composite_ms.to_text() + ","
    + "\"present_ms\":" + rec.present_ms.to_text() + ","
    + "\"chrome_fps\":" + rec.chrome_fps.to_text() + ","
    + "\"source\":\"" + rec.source + "\","
    + "\"status\":\"" + rec.status + "\"}"

fn normalize_all():
    var i = 0
    while i < FIXTURES.len():
        val fx = FIXTURES[i]
        val rec = build_synthetic_record(fx)
        print record_to_json(rec)
        i = i + 1

fn main() -> i64:
    normalize_all()
    0
