# simple_runner.spl
#
# Simple web renderer fixture runner.
# Drives the Simple browser/renderer pipeline over each HTML fixture, collects
# per-stage timings (parse, style, layout, paint, composite, present), and
# writes per-fixture JSON artifacts.
#
# Pipeline stages:
#   parse_ms      — HTML tokenise + DOM tree build
#   style_ms      — CSS cascade + selector match + computed style
#   layout_ms     — block/flex/grid box tree + geometry
#   paint_ms      — display list recording (background/border/text/image)
#   composite_ms  — layer merge / GPU blit
#   present_ms    — swap buffer / OS present call
#   total_frame_ms — sum of above
#
# When the renderer library is not linked, the runner writes source="synthetic"
# artifacts so report_spec.spl can accept them as PENDING.
#
# Output: test/perf/web_render_chrome/artifacts/simple_<fixture>.json
#
# Usage:
#   bin/simple run test/perf/web_render_chrome/simple_runner.spl [base_dir]

extern fn rt_time_now_unix_micros() -> i64
extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_exists(path: text) -> bool

# ---------------------------------------------------------------------------
# Constants
# ---------------------------------------------------------------------------

val WARMUP_FRAMES  = 5
val MEASURE_FRAMES = 30
val FIXTURES = ["static_page", "scroll_heavy", "layout_stress", "paint_heavy"]

# ---------------------------------------------------------------------------
# SimpleFrameRecord: per-fixture collected timings
# ---------------------------------------------------------------------------

class SimpleFrameRecord:
    fixture:      text
    source:       text   # "measured" | "synthetic"
    parse_ms:     f64
    style_ms:     f64
    layout_ms:    f64
    paint_ms:     f64
    composite_ms: f64
    present_ms:   f64
    total_frame_ms: f64
    frame_ms_p50:   f64
    frame_ms_p95:   f64
    pixel_hash:     text
    error_msg:      text

fn make_simple_record(fixture: text) -> SimpleFrameRecord:
    SimpleFrameRecord(
        fixture:      fixture,
        source:       "synthetic",
        parse_ms:     0.0,
        style_ms:     0.0,
        layout_ms:    0.0,
        paint_ms:     0.0,
        composite_ms: 0.0,
        present_ms:   0.0,
        total_frame_ms: 0.0,
        frame_ms_p50:   0.0,
        frame_ms_p95:   0.0,
        pixel_hash:     "",
        error_msg:      "",
    )

# ---------------------------------------------------------------------------
# Timing helpers (module-level fns — avoids interpreter it-block var mutation)
# ---------------------------------------------------------------------------

fn now_ms() -> f64:
    rt_time_now_unix_micros().to_f64() / 1000.0

fn percentile_f64(values: [f64], pct: f64) -> f64:
    val n = values.len()
    if n == 0:
        return 0.0
    # Insertion sort (small n — MEASURE_FRAMES frames)
    var sorted: [f64] = []
    var vi = 0
    while vi < n:
        sorted.push(values[vi])
        vi = vi + 1
    var si = 1
    while si < sorted.len():
        val key = sorted[si]
        var j = si - 1
        while j >= 0 and sorted[j] > key:
            sorted[j + 1] = sorted[j]
            j = j - 1
        sorted[j + 1] = key
        si = si + 1
    val idx_f = pct / 100.0 * (n - 1).to_f64()
    val lo = idx_f.floor().to_i64()
    val hi = lo + 1
    if hi >= n:
        return sorted[lo]
    val frac = idx_f - lo.to_f64()
    sorted[lo] * (1.0 - frac) + sorted[hi] * frac

fn f64_sum(values: [f64]) -> f64:
    var s = 0.0
    var i = 0
    while i < values.len():
        s = s + values[i]
        i = i + 1
    s

fn f64_avg(values: [f64]) -> f64:
    if values.len() == 0:
        return 0.0
    f64_sum(values) / values.len().to_f64()

# ---------------------------------------------------------------------------
# Synthetic frame timing simulation
#
# When the actual renderer is not linked, produce stable synthetic timings
# derived from fixture name so report_spec.spl can validate report shape and
# threshold math without a live renderer.
# ---------------------------------------------------------------------------

fn synthetic_parse_ms(fixture: text) -> f64:
    if fixture == "static_page":    return 1.5
    if fixture == "scroll_heavy":   return 2.2
    if fixture == "layout_stress":  return 1.8
    if fixture == "paint_heavy":    return 1.2
    1.0

fn synthetic_style_ms(fixture: text) -> f64:
    if fixture == "static_page":    return 1.0
    if fixture == "scroll_heavy":   return 1.8
    if fixture == "layout_stress":  return 1.5
    if fixture == "paint_heavy":    return 1.0
    0.8

fn synthetic_layout_ms(fixture: text) -> f64:
    if fixture == "static_page":    return 2.5
    if fixture == "scroll_heavy":   return 3.5
    if fixture == "layout_stress":  return 5.0
    if fixture == "paint_heavy":    return 2.8
    2.0

fn synthetic_paint_ms(fixture: text) -> f64:
    if fixture == "static_page":    return 3.5
    if fixture == "scroll_heavy":   return 4.5
    if fixture == "layout_stress":  return 4.0
    if fixture == "paint_heavy":    return 6.5
    3.0

fn synthetic_composite_ms(fixture: text) -> f64:
    if fixture == "static_page":    return 0.8
    if fixture == "scroll_heavy":   return 1.2
    if fixture == "layout_stress":  return 1.0
    if fixture == "paint_heavy":    return 1.8
    0.6

fn synthetic_present_ms(fixture: text) -> f64:
    if fixture == "static_page":    return 0.7
    if fixture == "scroll_heavy":   return 1.0
    if fixture == "layout_stress":  return 0.9
    if fixture == "paint_heavy":    return 1.2
    0.5

fn synthetic_pixel_hash(fixture: text) -> text:
    if fixture == "static_page":   return "a1b2c3d4e5f6a7b8"
    if fixture == "scroll_heavy":  return "b2c3d4e5f6a7b8c9"
    if fixture == "layout_stress": return "c3d4e5f6a7b8c9d0"
    if fixture == "paint_heavy":   return "d4e5f6a7b8c9d0e1"
    "0000000000000000"

# ---------------------------------------------------------------------------
# Run one fixture — returns a fully populated SimpleFrameRecord
# ---------------------------------------------------------------------------

fn run_simple_fixture(base_dir: text, fixture: text) -> SimpleFrameRecord:
    var rec = make_simple_record(fixture)
    val html_path = base_dir + "/fixtures/" + fixture + ".html"

    if not rt_file_exists(html_path):
        rec.error_msg = "fixture not found: " + html_path
        return rec

    # TODO(renderer-integration): When the Simple renderer library is linked,
    # replace the synthetic stage below with actual pipeline calls:
    #   val parse_t0 = now_ms()
    #   val dom = html_parse(html_path)
    #   val parse_t1 = now_ms()  =>  rec.parse_ms = parse_t1 - parse_t0
    # ... and so on through style, layout, paint, composite, present stages.

    # Synthetic stage — stable values for harness validation
    rec.parse_ms     = synthetic_parse_ms(fixture)
    rec.style_ms     = synthetic_style_ms(fixture)
    rec.layout_ms    = synthetic_layout_ms(fixture)
    rec.paint_ms     = synthetic_paint_ms(fixture)
    rec.composite_ms = synthetic_composite_ms(fixture)
    rec.present_ms   = synthetic_present_ms(fixture)
    rec.total_frame_ms = rec.parse_ms + rec.style_ms + rec.layout_ms
                       + rec.paint_ms + rec.composite_ms + rec.present_ms
    rec.pixel_hash   = synthetic_pixel_hash(fixture)

    # Simulate MEASURE_FRAMES with small jitter (+/- 5% of total)
    val base = rec.total_frame_ms
    var frame_times: [f64] = []
    var fi = 0
    while fi < MEASURE_FRAMES:
        # Deterministic jitter: alternate +3%, -2%, +5%, -4%, flat
        val jitter_idx = fi - (fi / 5) * 5  # fi mod 5
        val jitter = if jitter_idx == 0 then  0.03
                     elif jitter_idx == 1 then -0.02
                     elif jitter_idx == 2 then  0.05
                     elif jitter_idx == 3 then -0.04
                     else 0.0
        frame_times.push(base * (1.0 + jitter))
        fi = fi + 1

    rec.frame_ms_p50 = percentile_f64(frame_times, 50.0)
    rec.frame_ms_p95 = percentile_f64(frame_times, 95.0)

    rec.source    = "synthetic"
    rec.error_msg = "renderer pipeline not linked — synthetic timings"
    rec

# ---------------------------------------------------------------------------
# Serialize a SimpleFrameRecord to JSON
# ---------------------------------------------------------------------------

fn simple_record_to_json(rec: SimpleFrameRecord) -> text:
    "{\"source\":\"" + rec.source + "\","
    + "\"fixture\":\"" + rec.fixture + "\","
    + "\"runner\":\"simple\","
    + "\"parse_ms\":" + rec.parse_ms.to_text() + ","
    + "\"style_ms\":" + rec.style_ms.to_text() + ","
    + "\"layout_ms\":" + rec.layout_ms.to_text() + ","
    + "\"paint_ms\":" + rec.paint_ms.to_text() + ","
    + "\"composite_ms\":" + rec.composite_ms.to_text() + ","
    + "\"present_ms\":" + rec.present_ms.to_text() + ","
    + "\"total_frame_ms\":" + rec.total_frame_ms.to_text() + ","
    + "\"frame_ms_p50\":" + rec.frame_ms_p50.to_text() + ","
    + "\"frame_ms_p95\":" + rec.frame_ms_p95.to_text() + ","
    + "\"pixel_hash\":\"" + rec.pixel_hash + "\","
    + "\"note\":\"" + rec.error_msg + "\"}"

# ---------------------------------------------------------------------------
# Run all fixtures and write artifacts
# ---------------------------------------------------------------------------

fn run_all(base_dir: text):
    val artifact_dir = base_dir + "/artifacts"
    var i = 0
    while i < FIXTURES.len():
        val fx = FIXTURES[i]
        val out_path = artifact_dir + "/simple_" + fx + ".json"

        # Skip if existing measured artifact is present
        if rt_file_exists(out_path):
            val existing = rt_file_read_text(out_path)
            val src = json_text_field_local(existing, "source")
            if src == "measured":
                print "[simple_runner] " + fx + ": using existing measured artifact"
                i = i + 1
                continue

        val rec = run_simple_fixture(base_dir, fx)
        val json = simple_record_to_json(rec)
        val ok = rt_file_write_text(out_path, json)
        if ok:
            print "[simple_runner] " + fx + ": wrote " + out_path
        else:
            print "[simple_runner] " + fx + ": ERROR writing " + out_path
        i = i + 1

fn json_text_field_local(json: text, key: text) -> text:
    val search = "\"" + key + "\":"
    val idx = json.index_of(search)
    if idx < 0:
        return ""
    val after = json.substring(idx + search.len(), json.len())
    var ci = 0
    while ci < after.len():
        val c = after.char_at(ci)
        if c != " " and c != "\t" and c != "\n" and c != "\r":
            break
        ci = ci + 1
    if ci >= after.len():
        return ""
    if after.char_at(ci) != "\"":
        return ""
    ci = ci + 1
    var result = ""
    while ci < after.len():
        val c = after.char_at(ci)
        if c == "\"":
            break
        result = result + c
        ci = ci + 1
    result

fn main() -> i64:
    run_all("test/perf/web_render_chrome")
    0
