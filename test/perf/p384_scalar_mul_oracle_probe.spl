use os.crypto.p384.{p384_keygen, p384_ecdh, p384_scalar_mult}
extern fn rt_cli_get_args() -> [text]
extern fn rt_cli_exit(code: i64)

fn _hex_nibble(n: u8) -> text:
    if n == 0: "0"
    elif n == 1: "1"
    elif n == 2: "2"
    elif n == 3: "3"
    elif n == 4: "4"
    elif n == 5: "5"
    elif n == 6: "6"
    elif n == 7: "7"
    elif n == 8: "8"
    elif n == 9: "9"
    elif n == 10: "a"
    elif n == 11: "b"
    elif n == 12: "c"
    elif n == 13: "d"
    elif n == 14: "e"
    else: "f"

fn _bytes_hex(b: [u8]) -> text:
    var s: text = ""
    var i: u64 = 0
    while i < b.len().to_u64():
        val bv = b[i]
        s = s + _hex_nibble((bv >> 4) & 0x0F)
        s = s + _hex_nibble(bv & 0x0F)
        i = i + 1
    s

fn _be48_val(last_byte: u8) -> [u8]:
    var b: [u8] = []
    var i: u64 = 0
    while i < 47:
        b.push(0x00)
        i = i + 1
    b.push(last_byte)
    b

fn _make_key(seed: u8) -> [u8]:
    var k: [u8] = []
    var i: u64 = 0
    while i < 48:
        val v: u8 = ((seed.to_u64() + i * 7 + 3) & 0xFF).to_u8()
        k.push(v)
        i = i + 1
    k

fn _gx_bytes() -> [u8]:
    [
        0xAAu8, 0x87u8, 0xCAu8, 0x22u8, 0xBEu8, 0x8Bu8, 0x05u8, 0x37u8,
        0x8Eu8, 0xB1u8, 0xC7u8, 0x1Eu8, 0xF3u8, 0x20u8, 0xADu8, 0x74u8,
        0x6Eu8, 0x1Du8, 0x3Bu8, 0x62u8, 0x8Bu8, 0xA7u8, 0x9Bu8, 0x98u8,
        0x59u8, 0xF7u8, 0x41u8, 0xE0u8, 0x82u8, 0x54u8, 0x2Au8, 0x38u8,
        0x55u8, 0x02u8, 0xF2u8, 0x5Du8, 0xBFu8, 0x55u8, 0x29u8, 0x6Cu8,
        0x3Au8, 0x54u8, 0x5Eu8, 0x38u8, 0x72u8, 0x76u8, 0x0Au8, 0xB7u8
    ]

fn _gy_bytes() -> [u8]:
    [
        0x36u8, 0x17u8, 0xDEu8, 0x4Au8, 0x96u8, 0x26u8, 0x2Cu8, 0x6Fu8,
        0x5Du8, 0x9Eu8, 0x98u8, 0xBFu8, 0x92u8, 0x92u8, 0xDCu8, 0x29u8,
        0xF8u8, 0xF4u8, 0x1Du8, 0xBDu8, 0x28u8, 0x9Au8, 0x14u8, 0x7Cu8,
        0xE9u8, 0xDAu8, 0x31u8, 0x13u8, 0xB5u8, 0xF0u8, 0xB8u8, 0xC0u8,
        0x0Au8, 0x60u8, 0xB1u8, 0xCEu8, 0x1Du8, 0x7Eu8, 0x81u8, 0x9Du8,
        0x7Au8, 0x43u8, 0x1Du8, 0x7Cu8, 0x90u8, 0xEAu8, 0x0Eu8, 0x5Fu8
    ]

fn _expect_hex(label: text, got: [u8], expected: text) -> bool:
    val got_hex = _bytes_hex(got)
    if got_hex != expected:
        print "{label} mismatch"
        print "got={got_hex}"
        print "expected={expected}"
        return false
    true

fn _pass_case(name: text) -> bool:
    print "PASS {name}"
    true

fn _fail_case(name: text, detail: text) -> bool:
    print "FAIL {name}: {detail}"
    false

fn _selected_case() -> text:
    val args = rt_cli_get_args()
    var i: i64 = 0
    while i < args.len():
        val arg = args[i]
        if arg == "--case" and i + 1 < args.len():
            return args[i + 1]
        elif arg.starts_with("--case="):
            return arg.slice(7, arg.len())
        i = i + 1
    ""

fn _run_case(selected: text, name: text) -> bool:
    selected == "" or selected == name

fn _case_k1() -> bool:
    val k1_pub = p384_scalar_mult(_be48_val(0x01), _gx_bytes(), _gy_bytes())
    if not _expect_hex("k1", k1_pub, "04aa87ca22be8b05378eb1c71ef320ad746e1d3b628ba79b9859f741e082542a385502f25dbf55296c3a545e3872760ab73617de4a96262c6f5d9e98bf9292dc29f8f41dbd289a147ce9da3113b5f0b8c00a60b1ce1d7e819d7a431d7c90ea0e5f"):
        return _fail_case("k1", "oracle mismatch")
    _pass_case("k1")

fn _case_k2() -> bool:
    val k2_pub = p384_scalar_mult(_be48_val(0x02), _gx_bytes(), _gy_bytes())
    if not _expect_hex("k2", k2_pub, "0408d999057ba3d2d969260045c55b97f089025959a6f434d651d207d19fb96e9e4fe0e86ebe0e64f85b96a9c75295df618e80f1fa5b1b3cedb7bfe8dffd6dba74b275d875bc6cc43e904e505f256ab4255ffd43e94d39e22d61501e700a940e80"):
        return _fail_case("k2", "oracle mismatch")
    _pass_case("k2")

fn _case_k3() -> bool:
    val k3_pub = p384_scalar_mult(_be48_val(0x03), _gx_bytes(), _gy_bytes())
    if not _expect_hex("k3", k3_pub, "04077a41d4606ffa1464793c7e5fdc7d98cb9d3910202dcd06bea4f240d3566da6b408bbae5026580d02d7e5c70500c831c995f7ca0b0c42837d0bbe9602a9fc998520b41c85115aa5f7684c0edc111eacc24abd6be4b5d298b65f28600a2f1df1"):
        return _fail_case("k3", "oracle mismatch")
    _pass_case("k3")

fn _case_alice_pub(alice_priv: [u8]) -> bool:
    val alice_pub = p384_keygen(alice_priv)
    if not _expect_hex("alice_pub", alice_pub, "045c1175e56418c0f978034efbdce6453f787b47b722a4c14cceee43653857895a8dce11c025295617adcafa524e07a7a34177b866d0fc47e2d83de93550664524d4cd855e2a1d178336af4a8432df0bae4d4f0e44ad58be2889fb07a13fa6fd45"):
        return _fail_case("alice_pub", "oracle mismatch")
    _pass_case("alice_pub")

fn _case_bob_pub(bob_priv: [u8]) -> bool:
    val bob_pub = p384_keygen(bob_priv)
    if not _expect_hex("bob_pub", bob_pub, "0474d29aa76737dce53e9f0061af7fd98b88e90b5673d12b0817429491a01767fb7bd9f301f615f03153ff878ba7d760fc80cb6a966b20279169cff5b2e7516f49cc97bd698102da8920744cb10cdfca1b5b99a9f3759cf38c8f80a15d9ab4fd6b"):
        return _fail_case("bob_pub", "oracle mismatch")
    _pass_case("bob_pub")

fn _case_ecdh(alice_priv: [u8], bob_priv: [u8]) -> bool:
    val bob_pub = p384_keygen(bob_priv)
    val shared = p384_ecdh(alice_priv, bob_pub)
    if not _expect_hex("ecdh", shared, "82d29493f35f463d4e55c4c56f686e041f994cd90106da667fe70877f052f2fe45c15ca1b04915c6c5ad1dc571d0abcf"):
        return _fail_case("ecdh", "oracle mismatch")
    _pass_case("ecdh")

fn main():
    val selected = _selected_case()
    var ran_case = false
    var ok = true
    print "p384_scalar_mul_oracle_probe start selected={selected}"

    if _run_case(selected, "k1"):
        ran_case = true
        ok = _case_k1() and ok

    if _run_case(selected, "k2"):
        ran_case = true
        ok = _case_k2() and ok

    if _run_case(selected, "k3"):
        ran_case = true
        ok = _case_k3() and ok

    val alice_priv = _make_key(0x6B)
    if _run_case(selected, "alice_pub"):
        ran_case = true
        ok = _case_alice_pub(alice_priv) and ok

    val bob_priv = _make_key(0x01)
    if _run_case(selected, "bob_pub"):
        ran_case = true
        ok = _case_bob_pub(bob_priv) and ok

    if _run_case(selected, "ecdh"):
        ran_case = true
        ok = _case_ecdh(alice_priv, bob_priv) and ok

    if not ran_case:
        print "FAIL p384_scalar_mul_oracle_probe: unknown case {selected}"
        rt_cli_exit(1)
        return

    if not ok:
        print "FAIL p384_scalar_mul_oracle_probe"
        rt_cli_exit(1)
        return

    print "PASS p384_scalar_mul_oracle_probe"
    rt_cli_exit(0)
