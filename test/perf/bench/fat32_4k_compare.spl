# test/perf/bench/fat32_4k_compare.spl — focused 4K FAT comparison.

use std.io_runtime.{time_now_unix_micros, file_delete}
use std.nogc_sync_mut.io.file_ops.{file_read_text_at, file_write_text_at}
use std.fs_driver.block_device.{BlockDevice}
use std.fs_driver.fat32_core.{Fat32Core, fat32_close, fat32_write}

var __bench_data: [u8] = []
var __bench_active_bank: i32 = 0

fn _alloc_bank() -> i32:
    __bench_data = []
    var i: i32 = 0
    while i < 2097152:
        __bench_data.push(0)
        i = i + 1
    0

fn _set_sec(bid: i32, sec: i32, data: [u8]):
    val base = sec * 512
    var i: i32 = 0
    while i < 512 and i < data.len():
        __bench_data[base + i] = data[i]
        i = i + 1

fn _get_sec(bid: i32, sec: i32) -> [u8]:
    val base = sec * 512
    var out: [u8] = []
    var i: i32 = 0
    while i < 512:
        out.push(__bench_data[base + i])
        i = i + 1
    out

fn _w32(buf: [u8], off: i64, v: u32):
    buf[off] = (v & 0xFF).to_u8()
    buf[off + 1] = ((v >> 8) & 0xFF).to_u8()
    buf[off + 2] = ((v >> 16) & 0xFF).to_u8()
    buf[off + 3] = ((v >> 24) & 0xFF).to_u8()

fn _init_image(bid: i32):
    var bpb = _get_sec(bid, 0)
    bpb[11] = 0x00
    bpb[12] = 0x02
    bpb[13] = 0x04
    bpb[14] = 0x20
    bpb[15] = 0x00
    bpb[16] = 0x02
    _w32(bpb, 32, 4096u32)
    _w32(bpb, 36, 1u32)
    _w32(bpb, 44, 2u32)
    bpb[510] = 0x55
    bpb[511] = 0xAA
    _set_sec(bid, 0, bpb)
    var fat = _get_sec(bid, 32)
    _w32(fat, 0, 0x0FFFFFF8u32)
    _w32(fat, 4, 0x0FFFFFFFu32)
    _w32(fat, 8, 0x0FFFFFF8u32)
    _set_sec(bid, 32, fat)

class BenchBlockDevice:
    bank_id: i32

impl BenchBlockDevice:
    static fn new() -> BenchBlockDevice:
        val bid = _alloc_bank()
        _init_image(bid)
        __bench_active_bank = bid
        BenchBlockDevice(bank_id: bid)

impl BlockDevice for BenchBlockDevice:
    fn read_sector(lba: u64, buffer: [u8]) -> Result<bool, text>:
        val idx = lba.to_i32()
        if idx < 0 or idx >= 4096:
            return Ok(true)
        val src = _get_sec(__bench_active_bank, idx)
        var i = 0
        while i < buffer.len() and i < src.len():
            buffer[i] = src[i]
            i = i + 1
        Ok(true)

    fn write_sector(lba: u64, data: [u8]) -> Result<bool, text>:
        val idx = lba.to_i32()
        if idx < 0 or idx >= 4096:
            return Err("sector out of range")
        _set_sec(__bench_active_bank, idx, data)
        Ok(true)

    fn sector_size() -> u32:
        512

struct BenchResult:
    name: text
    p50_us: i64
    p99_us: i64

fn _make_core() -> Fat32Core:
    var core: Fat32Core = Fat32Core.new(BenchBlockDevice.new())
    val rc = core.mount()
    if rc.is_err():
        print "FATAL: mount failed"
    core

fn _fill_bytes(n: i64, value: u8) -> [u8]:
    var out: [u8] = []
    var i: i64 = 0
    while i < n:
        out.push(value)
        i = i + 1
    out

fn _fill_text(n: i64) -> text:
    var chunk = "AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA"
    var s = ""
    while s.len() < n:
        s = s + chunk
    s

fn _rand_block(i: i64, block_count: i64) -> i64:
    ((i * 1103515245 + 12345) & 0x7FFFFFFF) % block_count

fn percentile(latencies: [i64], pct: i64) -> i64:
    val n = latencies.len()
    if n == 0:
        return 0
    var idx = (n * pct) / 100
    if idx >= n:
        idx = n - 1
    var i = 0
    while i < n:
        val candidate = latencies[i]
        var less = 0
        var leq = 0
        var j = 0
        while j < n:
            if latencies[j] < candidate:
                less = less + 1
            if latencies[j] <= candidate:
                leq = leq + 1
            j = j + 1
        if less <= idx and idx < leq:
            return candidate
        i = i + 1
    latencies[n - 1]

fn bench_simple_read(iters: i64, block_count: i64) -> BenchResult:
    var core: Fat32Core = _make_core()
    val cr = core.create_file("/R4KREAD.BIN")
    val h = cr.unwrap()
    val block = _fill_bytes(4096, 0x52)
    var b: i64 = 0
    while b < block_count:
        val _w = fat32_write(core, h, block, 4096)
        b = b + 1
    var latencies: [i64] = []
    var read_buf = _fill_bytes(4096, 0)
    var i: i64 = 0
    while i < iters:
        val offset = _rand_block(i, block_count) * 4096
        val _s = core.seek(h, offset)
        val t0 = time_now_unix_micros()
        val _r = core.read(h, read_buf, 4096)
        latencies.push(time_now_unix_micros() - t0)
        i = i + 1
    val _c = fat32_close(core, h)
    BenchResult(name: "simple_fat32_read4k", p50_us: percentile(latencies, 50), p99_us: percentile(latencies, 99))

fn bench_simple_write(iters: i64, block_count: i64) -> BenchResult:
    var core: Fat32Core = _make_core()
    val cr = core.create_file("/R4KWR.BIN")
    val h = cr.unwrap()
    val seed = _fill_bytes(4096, 0x41)
    val patch = _fill_bytes(4096, 0x57)
    var b: i64 = 0
    while b < block_count:
        val _w = fat32_write(core, h, seed, 4096)
        b = b + 1
    var latencies: [i64] = []
    var i: i64 = 0
    while i < iters:
        val offset = _rand_block(i, block_count) * 4096
        val _s = core.seek(h, offset)
        val t0 = time_now_unix_micros()
        val _w2 = fat32_write(core, h, patch, 4096)
        latencies.push(time_now_unix_micros() - t0)
        i = i + 1
    val _c = fat32_close(core, h)
    BenchResult(name: "simple_fat32_write4k", p50_us: percentile(latencies, 50), p99_us: percentile(latencies, 99))

fn bench_host_read(iters: i64, block_count: i64) -> BenchResult:
    val path = "/tmp/simple_fat32_4k_host_read.bin"
    val _d0 = file_delete(path)
    val _seed = file_write_text_at(path, 0, _fill_text(block_count * 4096))
    var latencies: [i64] = []
    var i: i64 = 0
    while i < iters:
        val offset = _rand_block(i, block_count) * 4096
        val t0 = time_now_unix_micros()
        val _r = file_read_text_at(path, offset, 4096)
        latencies.push(time_now_unix_micros() - t0)
        i = i + 1
    val _d = file_delete(path)
    BenchResult(name: "host_posix_read4k", p50_us: percentile(latencies, 50), p99_us: percentile(latencies, 99))

fn bench_host_write(iters: i64, block_count: i64) -> BenchResult:
    val path = "/tmp/simple_fat32_4k_host_write.bin"
    val _d0 = file_delete(path)
    val _seed = file_write_text_at(path, 0, _fill_text(block_count * 4096))
    val patch = _fill_text(4096)
    var latencies: [i64] = []
    var i: i64 = 0
    while i < iters:
        val offset = _rand_block(i, block_count) * 4096
        val t0 = time_now_unix_micros()
        val _w = file_write_text_at(path, offset, patch)
        latencies.push(time_now_unix_micros() - t0)
        i = i + 1
    val _d = file_delete(path)
    BenchResult(name: "host_posix_write4k", p50_us: percentile(latencies, 50), p99_us: percentile(latencies, 99))

fn print_result(r: BenchResult):
    print "{r.name}: p50={r.p50_us}us p99={r.p99_us}us"

fn main():
    val iters: i64 = 50
    val blocks: i64 = 64
    print "=== FAT32 4K focused comparison ==="
    print "phase simple_read"
    val sr = bench_simple_read(iters, blocks)
    print "phase simple_write"
    val sw = bench_simple_write(iters, blocks)
    print "phase host_read"
    val hr = bench_host_read(iters, blocks)
    print "phase host_write"
    val hw = bench_host_write(iters, blocks)
    print_result(sr)
    print_result(hr)
    print_result(sw)
    print_result(hw)
    if sr.p50_us < hr.p50_us:
        print "read4k: simple_fat32 faster"
    else:
        print "read4k: simple_fat32 not faster"
    if sw.p50_us < hw.p50_us:
        print "write4k: simple_fat32 faster"
    else:
        print "write4k: simple_fat32 not faster"
