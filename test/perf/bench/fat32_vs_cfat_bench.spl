# ══════════════════════════════════════════════════════════════════════════
# Workload 7: Directory Scan — list directory entries
# ══════════════════════════════════════════════════════════════════════════
fn bench_dirscan_simple(file_count: i64, iters: i64) -> BenchResult:
    var core = _make_core()
    var i: i64 = 0
    while i < file_count:
        val _fh = core.create_file("/S" + i.to_text() + ".TXT")
        i = i + 1
    var latencies: [i64] = []
    var j: i64 = 0
    while j < iters:
        val t0 = time_now_unix_micros()
        val r = core.readdir("/")
        val elapsed = time_now_unix_micros() - t0
        if r.is_ok():
            latencies = latencies.push(elapsed)
        j = j + 1
    if latencies.len() == 0:
        return skipped_result("directory_scan", "simple_fat32")
    BenchResult(workload_name: "directory_scan", driver_name: "simple_fat32", p50_us: percentile(latencies, 50), p99_us: percentile(latencies, 99))

fn bench_dirscan_host(file_count: i64, iters: i64, base_dir: text, driver_name: text) -> BenchResult:
    _host_setup(base_dir)
    var i: i64 = 0
    while i < file_count:
        write_file(base_dir + "/s" + i.to_text() + ".txt", "")
        i = i + 1
    var latencies: [i64] = []
    var j: i64 = 0
    while j < iters:
        val t0 = time_now_unix_micros()
        val _files = list_dir(base_dir)
        latencies = latencies.push(time_now_unix_micros() - t0)
        j = j + 1
    _host_clean(base_dir)
    BenchResult(workload_name: "directory_scan", driver_name: driver_name, p50_us: percentile(latencies, 50), p99_us: percentile(latencies, 99))

# ══════════════════════════════════════════════════════════════════════════
# Report Generation
# ══════════════════════════════════════════════════════════════════════════
fn _fmt_cell(r: BenchResult) -> text:
    if r.p50_us < 0:
        return "SKIP | SKIP"
    r.p50_us.to_text() + " | " + r.p99_us.to_text()

fn _ratio_text(s: BenchResult, b: BenchResult) -> text:
    if s.p50_us < 0 or b.p50_us <= 0:
        return "N/A"
    val ratio = (s.p50_us * 100) / b.p50_us
    ratio.to_text() + "%"

fn _md_row(results: [BenchResult], has_vfat: bool) -> text:
    val s = results[0]
    val p = results[1]
    var row = "| " + s.workload_name + " | " + _fmt_cell(s) + " | " + _fmt_cell(p) + " | " + _ratio_text(s, p)
    if has_vfat:
        val v = results[2]
        row = row + " | " + _fmt_cell(v) + " | " + _ratio_text(s, v)
    row + " |"

fn write_report(rows: [[BenchResult]], has_vfat: bool):
    var md = "# FAT32 vs C FAT Benchmark Results\n\n"
    md = md + "**Date:** 2026-05-27\n"
    md = md + "**Mode:** interpreter (`bin/simple run`)\n"
    md = md + "**Simple FAT32:** in-memory Fat32Core, 4096 sectors x 512 B\n"
    md = md + "**POSIX baseline:** host kernel filesystem (ext4/btrfs) via std.io_runtime\n"
    if has_vfat:
        md = md + "**VFAT baseline:** 64 MiB loopback FAT32 image via Linux VFAT mount\n"
    md = md + "\n## Per-Workload Comparison\n\n"
    var hdr = "| Workload | Simple p50 | Simple p99 | POSIX p50 | POSIX p99 | S/P Ratio"
    var sep = "|----------|-----------|-----------|----------|----------|----------"
    if has_vfat:
        hdr = hdr + " | VFAT p50 | VFAT p99 | S/V Ratio"
        sep = sep + "|---------|---------|----------"
    md = md + hdr + " |\n" + sep + "|\n"
    for row in rows:
        md = md + _md_row(row, has_vfat) + "\n"
    md = md + "\n## Interpretation\n\n"
    md = md + "- **S/P Ratio** = (Simple p50 / POSIX p50) x 100. Values > 100% mean Simple is slower.\n"
    if has_vfat:
        md = md + "- **S/V Ratio** = (Simple p50 / VFAT p50) x 100. True FAT32-vs-FAT32 comparison.\n"
    md = md + "- Simple FAT32 runs entirely in-process with in-memory block device.\n"
    md = md + "- POSIX baseline uses host kernel file operations (ext4/btrfs, not VFAT).\n"
    if has_vfat:
        md = md + "- VFAT baseline uses Linux kernel VFAT driver on loopback FAT32 image.\n"
    md = md + "- Both measurements include Simple interpreter dispatch overhead.\n"
    md = md + "\n## Known Limitations\n\n"
    md = md + "- Interpreter overhead dominates Simple FAT32 timings (~120ms for path resolve).\n"
    md = md + "- Sequential read is faster on Simple due to in-memory block device (no syscalls).\n"
    md = md + "- Compiled-mode benchmarks show ~121 us for metadata open (see vfat comparison doc).\n"
    md = md + "- Root directory limited to 64 entries (4 sectors/cluster x 512B / 32B per entry).\n"
    mkdir_p("doc/10_metrics")
    write_file("doc/10_metrics/fat32_vs_cfat_benchmark.md", md)
    print "Results written to doc/10_metrics/fat32_vs_cfat_benchmark.md"

# ══════════════════════════════════════════════════════════════════════════
# Main
# ══════════════════════════════════════════════════════════════════════════
fn main():
    print "=== FAT32 vs C FAT Benchmark ==="
    print "Simple FAT32: in-memory Fat32Core, 4096 sectors x 512 B"
    print "POSIX baseline: host filesystem via std.io_runtime"

    val has_vfat = _vfat_setup()
    if has_vfat:
        print "VFAT baseline: 64 MiB loopback FAT32 image (mounted)"
    else:
        print "VFAT baseline: SKIPPED (mount failed)"
    print ""

    val iters: i64 = 30
    val file_count: i64 = 30
    val total_bytes: i64 = 10240
    val pb = _posix_base()
    val vb = _vfat_base()

    var rows: [[BenchResult]] = []

    print "[1/7] create"
    val r1s = bench_create_simple(file_count)
    val r1p = bench_create_host(file_count, pb, "c_fat_posix")
    print result_line(r1s)
    print result_line(r1p)
    var row1 = [r1s, r1p]
    if has_vfat:
        val r1v = bench_create_host(file_count, vb, "c_fat_vfat")
        print result_line(r1v)
        row1 = row1.push(r1v)
    rows = rows.push(row1)

    print "[2/7] lookup"
    val r2s = bench_lookup_simple(iters)
