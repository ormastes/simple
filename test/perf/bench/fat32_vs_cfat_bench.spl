# ══════════════════════════════════════════════════════════════════════════
# Workload 8: 4K Random Read
# ══════════════════════════════════════════════════════════════════════════
fn bench_random4k_read_simple(iters: i64, block_count: i64) -> BenchResult:
    var core: Fat32Core = _make_core()
    val cr = core.create_file("/R4KREAD.BIN")
    if cr.is_err():
        return skipped_result("random_4k_read", "simple_fat32")
    val h = cr.unwrap()
    val block = _fill_bytes(4096, 0x52)
    var b: i64 = 0
    while b < block_count:
        val wr = fat32_write(core, h, block, 4096)
        if wr.is_err():
            return skipped_result("random_4k_read", "simple_fat32")
        b = b + 1
    var latencies: [i64] = []
    var i: i64 = 0
    while i < iters:
        val offset = _rand_block(i, block_count) * 4096
        val sr = core.seek(h, offset)
        if sr.is_err():
            return skipped_result("random_4k_read", "simple_fat32")
        val t0 = time_now_unix_micros()
        val rr = core.read_bytes(h, 4096)
        val elapsed = time_now_unix_micros() - t0
        if rr.is_err():
            return skipped_result("random_4k_read", "simple_fat32")
        latencies.push(elapsed)
        i = i + 1
    BenchResult(workload_name: "random_4k_read", driver_name: "simple_fat32", p50_us: percentile(latencies, 50), p99_us: percentile(latencies, 99))

fn bench_random4k_read_host(iters: i64, block_count: i64, base_dir: text, driver_name: text) -> BenchResult:
    _host_setup(base_dir)
    val path = base_dir + "/r4kread.bin"
    write_file(path, _fill_text(block_count * 4096))
    var latencies: [i64] = []
    var i: i64 = 0
    while i < iters:
        val offset = _rand_block(i, block_count) * 4096
        val t0 = time_now_unix_micros()
        val rr = file_read_text_at(path, offset, 4096)
        val elapsed = time_now_unix_micros() - t0
        if rr.len() < 4096:
            _host_clean(base_dir)
            return skipped_result("random_4k_read", driver_name)
        latencies.push(elapsed)
        i = i + 1
    _host_clean(base_dir)
    BenchResult(workload_name: "random_4k_read", driver_name: driver_name, p50_us: percentile(latencies, 50), p99_us: percentile(latencies, 99))

# ══════════════════════════════════════════════════════════════════════════
# Workload 9: 4K Random Overwrite
# ══════════════════════════════════════════════════════════════════════════
fn bench_random4k_overwrite_simple(iters: i64, block_count: i64) -> BenchResult:
    var core: Fat32Core = _make_core()
    val cr = core.create_file("/R4KWR.BIN")
    if cr.is_err():
        return skipped_result("random_4k_overwrite", "simple_fat32")
    val h = cr.unwrap()
    val seed_block = _fill_bytes(4096, 0x41)
    val write_block = _fill_bytes(4096, 0x57)
    var b: i64 = 0
    while b < block_count:
        val wr = fat32_write(core, h, seed_block, 4096)
        if wr.is_err():
            return skipped_result("random_4k_overwrite", "simple_fat32")
        b = b + 1
    var latencies: [i64] = []
    var i: i64 = 0
    while i < iters:
        val offset = _rand_block(i, block_count) * 4096
        val sr = core.seek(h, offset)
        if sr.is_err():
            return skipped_result("random_4k_overwrite", "simple_fat32")
        val t0 = time_now_unix_micros()
        val wr = fat32_write(core, h, write_block, 4096)
        val elapsed = time_now_unix_micros() - t0
        if wr.is_err():
            return skipped_result("random_4k_overwrite", "simple_fat32")
        latencies.push(elapsed)
        i = i + 1
    BenchResult(workload_name: "random_4k_overwrite", driver_name: "simple_fat32", p50_us: percentile(latencies, 50), p99_us: percentile(latencies, 99))

fn bench_random4k_overwrite_host(iters: i64, block_count: i64, base_dir: text, driver_name: text) -> BenchResult:
    _host_setup(base_dir)
    val path = base_dir + "/r4kwr.bin"
    val base = _fill_text(block_count * 4096)
    val patch = _fill_text(4096)
    write_file(path, base)
    var latencies: [i64] = []
    var i: i64 = 0
    while i < iters:
        val offset = _rand_block(i, block_count) * 4096
        val t0 = time_now_unix_micros()
        val wr = file_write_text_at(path, offset, patch)
        val elapsed = time_now_unix_micros() - t0
        if wr < 0:
            _host_clean(base_dir)
            return skipped_result("random_4k_overwrite", driver_name)
        latencies.push(elapsed)
        i = i + 1
    _host_clean(base_dir)
    BenchResult(workload_name: "random_4k_overwrite", driver_name: driver_name, p50_us: percentile(latencies, 50), p99_us: percentile(latencies, 99))

# ══════════════════════════════════════════════════════════════════════════
# Report Generation
# ══════════════════════════════════════════════════════════════════════════
fn _fmt_cell(r: BenchResult) -> text:
    if r.p50_us < 0:
        return "SKIP | SKIP"
    "{r.p50_us} | {r.p99_us}"

fn _ratio_text(s: BenchResult, b: BenchResult) -> text:
    if s.p50_us < 0 or b.p50_us <= 0:
        return "N/A"
    val ratio = (s.p50_us * 100) / b.p50_us
    "{ratio}%"

fn _md_row(results: [BenchResult], has_vfat: bool) -> text:
    val s = results[0]
    val p = results[1]
    var row = "| " + s.workload_name + " | " + _fmt_cell(s) + " | " + _fmt_cell(p) + " | " + _ratio_text(s, p)
    if has_vfat:
        val v = results[2]
        row = row + " | " + _fmt_cell(v) + " | " + _ratio_text(s, v)
    row + " |"

fn write_report(rows: [[BenchResult]], has_vfat: bool):
    var md = "# FAT32 vs C FAT Benchmark Results\n\n"
    md = md + "**Date:** 2026-05-27\n"
    md = md + "**Mode:** interpreter (`bin/simple run`)\n"
    md = md + "**Simple FAT32:** in-memory Fat32Core, 4096 sectors x 512 B\n"
    md = md + "**POSIX baseline:** host kernel filesystem (ext4/btrfs) via std.io_runtime\n"
    if has_vfat:
        md = md + "**VFAT baseline:** 64 MiB loopback FAT32 image via Linux VFAT mount\n"
    md = md + "\n## Per-Workload Comparison\n\n"
    var hdr = "| Workload | Simple p50 | Simple p99 | POSIX p50 | POSIX p99 | S/P Ratio"
    var sep = "|----------|-----------|-----------|----------|----------|----------"
    if has_vfat:
        hdr = hdr + " | VFAT p50 | VFAT p99 | S/V Ratio"
        sep = sep + "|---------|---------|----------"
    md = md + hdr + " |\n" + sep + "|\n"
    for row in rows:
        md = md + _md_row(row, has_vfat) + "\n"
    md = md + "\n## Interpretation\n\n"
    md = md + "- **S/P Ratio** = (Simple p50 / POSIX p50) x 100. Values > 100% mean Simple is slower.\n"
    if has_vfat:
        md = md + "- **S/V Ratio** = (Simple p50 / VFAT p50) x 100. True FAT32-vs-FAT32 comparison.\n"
    md = md + "- Simple FAT32 runs entirely in-process with in-memory block device.\n"
    md = md + "- POSIX baseline uses host kernel file operations (ext4/btrfs, not VFAT).\n"
    if has_vfat:
        md = md + "- VFAT baseline uses Linux kernel VFAT driver on loopback FAT32 image.\n"
    md = md + "- Both measurements include Simple interpreter dispatch overhead.\n"
    md = md + "\n## Known Limitations\n\n"
    md = md + "- Interpreter overhead dominates Simple FAT32 timings (~120ms for path resolve).\n"
    md = md + "- Sequential read is faster on Simple due to in-memory block device (no syscalls).\n"
    md = md + "- Compiled-mode benchmarks show ~121 us for metadata open (see vfat comparison doc).\n"
    md = md + "- Root directory limited to 64 entries (4 sectors/cluster x 512B / 32B per entry).\n"
    mkdir_p("doc/10_metrics")
    write_file("doc/10_metrics/fat32_vs_cfat_benchmark.md", md)
    print "Results written to doc/10_metrics/fat32_vs_cfat_benchmark.md"

# ══════════════════════════════════════════════════════════════════════════
# Main
# ══════════════════════════════════════════════════════════════════════════
fn main():
    print "=== FAT32 vs C FAT Benchmark ==="
    print "Simple FAT32: in-memory Fat32Core, 4096 sectors x 512 B"
    print "POSIX baseline: host filesystem via std.io_runtime"

    val has_vfat = _vfat_setup()
    if has_vfat:
        print "VFAT baseline: 64 MiB loopback FAT32 image (mounted)"
    else:
        print "VFAT baseline: SKIPPED (mount failed)"
    print ""

    val iters: i64 = 30
    val file_count: i64 = 30
    val total_bytes: i64 = 10240
    val pb = _posix_base()
    val vb = _vfat_base()

    var rows: [[BenchResult]] = []

    print "[1/9] create"
    val r1s = bench_create_simple(file_count)
    val r1p = bench_create_host(file_count, pb, "c_fat_posix")
    print result_line(r1s)
    print result_line(r1p)
    var row1 = [r1s, r1p]
    if has_vfat:
        val r1v = bench_create_host(file_count, vb, "c_fat_vfat")
        print result_line(r1v)
        row1.push(r1v)
    rows.push(row1)

    print "[2/9] lookup"
    val r2s = bench_lookup_simple(iters)
    val r2p = bench_lookup_host(iters, pb, "c_fat_posix")
    print result_line(r2s)
    print result_line(r2p)
    var row2 = [r2s, r2p]
    if has_vfat:
        val r2v = bench_lookup_host(iters, vb, "c_fat_vfat")
        print result_line(r2v)
        row2.push(r2v)
    rows.push(row2)

    print "[3/9] sequential_read"
    val r3s = bench_seq_read_simple(iters)
    val r3p = bench_seq_read_host(iters, total_bytes, pb, "c_fat_posix")
    print result_line(r3s)
    print result_line(r3p)
    var row3 = [r3s, r3p]
    if has_vfat:
        val r3v = bench_seq_read_host(iters, total_bytes, vb, "c_fat_vfat")
        print result_line(r3v)
        row3.push(r3v)
    rows.push(row3)

    print "[4/9] append"
    val r4s = bench_append_simple(iters)
    val r4p = bench_append_host(iters, total_bytes, pb, "c_fat_posix")
    print result_line(r4s)
    print result_line(r4p)
    var row4 = [r4s, r4p]
    if has_vfat:
        val r4v = bench_append_host(iters, total_bytes, vb, "c_fat_vfat")
        print result_line(r4v)
        row4.push(r4v)
    rows.push(row4)

    print "[5/9] delete"
    val r5s = bench_delete_simple(file_count)
    val r5p = bench_delete_host(file_count, pb, "c_fat_posix")
    print result_line(r5s)
    print result_line(r5p)
    var row5 = [r5s, r5p]
    if has_vfat:
        val r5v = bench_delete_host(file_count, vb, "c_fat_vfat")
        print result_line(r5v)
        row5.push(r5v)
    rows.push(row5)

    print "[6/9] stat"
    val r6s = bench_stat_simple(iters)
    val r6p = bench_stat_host(iters, pb, "c_fat_posix")
    print result_line(r6s)
    print result_line(r6p)
    var row6 = [r6s, r6p]
    if has_vfat:
        val r6v = bench_stat_host(iters, vb, "c_fat_vfat")
        print result_line(r6v)
        row6.push(r6v)
    rows.push(row6)

    print "[7/9] directory_scan"
    val r7s = bench_dirscan_simple(file_count, iters)
    val r7p = bench_dirscan_host(file_count, iters, pb, "c_fat_posix")
    print result_line(r7s)
    print result_line(r7p)
    var row7 = [r7s, r7p]
    if has_vfat:
        val r7v = bench_dirscan_host(file_count, iters, vb, "c_fat_vfat")
        print result_line(r7v)
        row7.push(r7v)
    rows.push(row7)

    val random_blocks: i64 = 32

    print "[8/9] random_4k_read"
    val r8s = bench_random4k_read_simple(iters, random_blocks)
    val r8p = bench_random4k_read_host(iters, random_blocks, pb, "c_fat_posix")
    print result_line(r8s)
    print result_line(r8p)
    var row8 = [r8s, r8p]
    if has_vfat:
        val r8v = bench_random4k_read_host(iters, random_blocks, vb, "c_fat_vfat")
        print result_line(r8v)
        row8.push(r8v)
    rows.push(row8)

    print "[9/9] random_4k_overwrite"
    val r9s = bench_random4k_overwrite_simple(iters, random_blocks)
    val r9p = bench_random4k_overwrite_host(iters, random_blocks, pb, "c_fat_posix")
    print result_line(r9s)
    print result_line(r9p)
    var row9 = [r9s, r9p]
    if has_vfat:
        val r9v = bench_random4k_overwrite_host(iters, random_blocks, vb, "c_fat_vfat")
        print result_line(r9v)
        row9.push(r9v)
    rows.push(row9)

    print ""
    write_report(rows, has_vfat)

    _host_clean(pb)
    if has_vfat:
        _vfat_teardown()
    print "=== done ==="
