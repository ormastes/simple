# test/perf/bench/fat32_vs_cfat_bench.spl — FAT32 vs C FAT (host POSIX) benchmark.
# 7 workloads: lookup, sequential_read, create, append, delete, stat, directory_scan.
# Simple FAT32: in-memory Fat32Core via BlockDevice trait.
# C FAT baseline: host kernel POSIX filesystem via std.io_runtime.
# Run: bin/simple run test/perf/bench/fat32_vs_cfat_bench.spl
#
# All 7 workloads produce results in interpreter mode.

use std.io_runtime.{
    time_now_unix_micros, write_file, read_file, file_exists,
    file_delete, file_size, mkdir_p, list_dir
}
use std.fs_driver.block_device.{BlockDevice}
use std.fs_driver.fat32_core.{Fat32Core}
use std.fs_driver.types.{FileHandle}

# ── In-memory FAT32 image (from fat32_microbench.spl) ──────────────────────
var __banks: [[[u8]]] = []

fn _alloc_bank() -> i32:
    var sectors: [[u8]] = []
    var s: i32 = 0
    while s < 4096:
        var sec: [u8] = []
        var b: i32 = 0
        while b < 512:
            sec.push(0)
            b = b + 1
        sectors.push(sec)
        s = s + 1
    __banks.push(sectors)
    __banks.len() - 1

fn _set_sec(bid: i32, sec: i32, data: [u8]):
    var bk = __banks[bid]
    bk[sec] = data
    __banks[bid] = bk

fn _get_sec(bid: i32, sec: i32) -> [u8]:
    __banks[bid][sec]

fn _w32(buf: [u8], off: i64, v: u32):
    buf[off] = (v & 0xFF).to_u8()
    buf[off + 1] = ((v >> 8) & 0xFF).to_u8()
    buf[off + 2] = ((v >> 16) & 0xFF).to_u8()
    buf[off + 3] = ((v >> 24) & 0xFF).to_u8()

fn _init_image(bid: i32):
    var bpb = _get_sec(bid, 0)
    bpb[11] = 0x00
    bpb[12] = 0x02
    bpb[13] = 0x04
    bpb[14] = 0x20
    bpb[15] = 0x00
    bpb[16] = 0x02
    _w32(bpb, 32, 4096u32)
    _w32(bpb, 36, 1u32)
    _w32(bpb, 44, 2u32)
    bpb[510] = 0x55
    bpb[511] = 0xAA
    _set_sec(bid, 0, bpb)
    var fat = _get_sec(bid, 32)
    _w32(fat, 0, 0x0FFFFFF8u32)
    _w32(fat, 4, 0x0FFFFFFFu32)
    _w32(fat, 8, 0x0FFFFFF8u32)
    _set_sec(bid, 32, fat)

class BMBlockDev:
    bank_id: i32

impl BMBlockDev:
    static fn new() -> BMBlockDev:
        val bid = _alloc_bank()
        _init_image(bid)
        BMBlockDev(bank_id: bid)

impl BlockDevice for BMBlockDev:
    fn read_sector(lba: u64, buffer: [u8]) -> Result<bool, text>:
        val idx = lba.to_i32()
        if idx < 0 or idx >= 4096:
            return Result.Ok(true)
        val src = _get_sec(self.bank_id, idx)
        var i = 0
        while i < buffer.len() and i < src.len():
            buffer[i] = src[i]
            i = i + 1
        Result.Ok(true)
    fn write_sector(lba: u64, data: [u8]) -> Result<bool, text>:
        val idx = lba.to_i32()
        if idx < 0 or idx >= 4096:
            return Result.Err("sector out of range")
        _set_sec(self.bank_id, idx, data)
        Result.Ok(true)
    fn sector_size() -> u32:
        512

fn _make_core() -> Fat32Core:
    var core = Fat32Core.new(BMBlockDev.new())
    val rc = core.mount()
    if rc.is_err():
        print "FATAL: mount failed"
    core

fn _fill_text(n: i64) -> text:
    var chunk = "AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA"
    var s = ""
    while s.len() < n:
        s = s + chunk
    s

# ── Sort + Percentile ──────────────────────────────────────────────────────
fn sort_asc(arr: [i64]) -> [i64]:
    var a = arr
    var i = 0
    while i < a.len():
        var j = i + 1
        while j < a.len():
            if a[j] < a[i]:
                val tmp = a[i]
                a[i] = a[j]
                a[j] = tmp
            j = j + 1
        i = i + 1
    a

fn percentile(latencies: [i64], pct: i64) -> i64:
    val sorted = sort_asc(latencies)
    val n = sorted.len()
    if n == 0:
        return 0
    var idx = (n * pct) / 100
    if idx >= n:
        idx = n - 1
    sorted[idx]

# ── BenchResult ────────────────────────────────────────────────────────────
struct BenchResult:
    workload_name: text
    driver_name: text
    p50_us: i64
    p99_us: i64

fn result_line(r: BenchResult) -> text:
    if r.p50_us < 0:
        return "  " + r.driver_name + ": SKIPPED (file handle bug)"
    "  " + r.driver_name + ": p50=" + r.p50_us.to_text() + " us, p99=" + r.p99_us.to_text() + " us"

fn skipped_result(workload: text, driver: text) -> BenchResult:
    BenchResult(workload_name: workload, driver_name: driver, p50_us: -1, p99_us: -1)

# ── POSIX helpers ──────────────────────────────────────────────────────────
fn _posix_base() -> text:
    "/tmp/simple_fat32_vs_cfat_bench"

fn _posix_clean():
    val base = _posix_base()
    val files = list_dir(base)
    for f in files:
        val _d = file_delete(base + "/" + f)

fn _posix_setup():
    mkdir_p(_posix_base())
    _posix_clean()

# ══════════════════════════════════════════════════════════════════════════
# Workload 1: Create — create N files
# ══════════════════════════════════════════════════════════════════════════
fn bench_create_simple(count: i64) -> BenchResult:
    var core = _make_core()
    var latencies: [i64] = []
    var i: i64 = 0
    while i < count:
        val t0 = time_now_unix_micros()
        val _fh = core.create_file("/C" + i.to_text() + ".TXT")
        latencies = latencies.push(time_now_unix_micros() - t0)
        i = i + 1
    BenchResult(workload_name: "create", driver_name: "simple_fat32", p50_us: percentile(latencies, 50), p99_us: percentile(latencies, 99))

fn bench_create_posix(count: i64) -> BenchResult:
    _posix_setup()
    var latencies: [i64] = []
    var i: i64 = 0
    while i < count:
        val path = _posix_base() + "/c" + i.to_text() + ".txt"
        val t0 = time_now_unix_micros()
        write_file(path, "")
        latencies = latencies.push(time_now_unix_micros() - t0)
        i = i + 1
    _posix_clean()
    BenchResult(workload_name: "create", driver_name: "c_fat_posix", p50_us: percentile(latencies, 50), p99_us: percentile(latencies, 99))

# ══════════════════════════════════════════════════════════════════════════
# Workload 2: Lookup — resolve a file path
# ══════════════════════════════════════════════════════════════════════════
fn bench_lookup_simple(iters: i64) -> BenchResult:
    var core = _make_core()
    val _fh = core.create_file("/LK.TXT")
    var latencies: [i64] = []
    var i: i64 = 0
    while i < iters:
        val t0 = time_now_unix_micros()
        val r = core.find_entry_in_dir(2u32, "LK.TXT")
        val elapsed = time_now_unix_micros() - t0
        if r.is_ok():
            latencies = latencies.push(elapsed)
        i = i + 1
    if latencies.len() == 0:
        return skipped_result("lookup", "simple_fat32")
    BenchResult(workload_name: "lookup", driver_name: "simple_fat32", p50_us: percentile(latencies, 50), p99_us: percentile(latencies, 99))

fn bench_lookup_posix(iters: i64) -> BenchResult:
    _posix_setup()
    val path = _posix_base() + "/lookup.txt"
    write_file(path, "x")
    var latencies: [i64] = []
    var i: i64 = 0
    while i < iters:
        val t0 = time_now_unix_micros()
        val _e = file_exists(path)
        latencies = latencies.push(time_now_unix_micros() - t0)
        i = i + 1
    _posix_clean()
    BenchResult(workload_name: "lookup", driver_name: "c_fat_posix", p50_us: percentile(latencies, 50), p99_us: percentile(latencies, 99))

# ══════════════════════════════════════════════════════════════════════════
# Workload 3: Sequential Read — read a file (requires file handles)
# ══════════════════════════════════════════════════════════════════════════
fn bench_seq_read_simple(iters: i64) -> BenchResult:
    var core = _make_core()
    val cr = core.create_file("/RD.TXT")
    if cr.is_err():
        return skipped_result("sequential_read", "simple_fat32")
    val h = cr.unwrap()
    var buf: [u8] = []
    var b: i64 = 0
    while b < 128:
        buf.push(0x41)
        b = b + 1
    val wr = core.write(h, buf, 128)
    if wr.is_err():
        return skipped_result("sequential_read", "simple_fat32")
    val cr2 = core.close(h)
    if cr2.is_err():
        return skipped_result("sequential_read", "simple_fat32")
    val oh = core.open("/RD.TXT")
    if oh.is_err():
        return skipped_result("sequential_read", "simple_fat32")
    var latencies: [i64] = []
    var i: i64 = 0
    while i < iters:
        val t0 = time_now_unix_micros()
        val _r = core.read_bytes(oh.unwrap(), 128)
        latencies = latencies.push(time_now_unix_micros() - t0)
        i = i + 1
    BenchResult(workload_name: "sequential_read", driver_name: "simple_fat32", p50_us: percentile(latencies, 50), p99_us: percentile(latencies, 99))

fn bench_seq_read_posix(iters: i64, total_bytes: i64) -> BenchResult:
    _posix_setup()
    val path = _posix_base() + "/seqrd.txt"
    val content = _fill_text(total_bytes)
    write_file(path, content)
    var latencies: [i64] = []
    var j: i64 = 0
    while j < iters:
        val t0 = time_now_unix_micros()
        val _data = read_file(path)
        latencies = latencies.push(time_now_unix_micros() - t0)
        j = j + 1
    _posix_clean()
    BenchResult(workload_name: "sequential_read", driver_name: "c_fat_posix", p50_us: percentile(latencies, 50), p99_us: percentile(latencies, 99))

# ══════════════════════════════════════════════════════════════════════════
# Workload 4: Append — write data to file (requires file handles)
# ══════════════════════════════════════════════════════════════════════════
fn bench_append_simple(iters: i64) -> BenchResult:
    var core = _make_core()
    var buf: [u8] = []
    var b: i64 = 0
    while b < 128:
        buf.push(0x41)
        b = b + 1
    var latencies: [i64] = []
    var j: i64 = 0
    while j < iters:
        val cr = core.create_file("/W" + j.to_text() + ".TXT")
        if cr.is_err():
            return skipped_result("append", "simple_fat32")
        val h = cr.unwrap()
        val t0 = time_now_unix_micros()
        val wr = core.write(h, buf, 128)
        val elapsed = time_now_unix_micros() - t0
        if wr.is_err():
            return skipped_result("append", "simple_fat32")
        latencies = latencies.push(elapsed)
        val _c = core.close(h)
        j = j + 1
    BenchResult(workload_name: "append", driver_name: "simple_fat32", p50_us: percentile(latencies, 50), p99_us: percentile(latencies, 99))

fn bench_append_posix(iters: i64, total_bytes: i64) -> BenchResult:
    _posix_setup()
    val content = _fill_text(total_bytes)
    var latencies: [i64] = []
    var j: i64 = 0
    while j < iters:
        val path = _posix_base() + "/a" + j.to_text() + ".txt"
        val t0 = time_now_unix_micros()
        write_file(path, content)
        latencies = latencies.push(time_now_unix_micros() - t0)
        j = j + 1
    _posix_clean()
    BenchResult(workload_name: "append", driver_name: "c_fat_posix", p50_us: percentile(latencies, 50), p99_us: percentile(latencies, 99))

# ══════════════════════════════════════════════════════════════════════════
# Workload 5: Delete — unlink files
# ══════════════════════════════════════════════════════════════════════════
fn bench_delete_simple(count: i64) -> BenchResult:
    var core = _make_core()
    var i: i64 = 0
    while i < count:
        val _fh = core.create_file("/D" + i.to_text() + ".TXT")
        i = i + 1
    val _warm = core.readdir("/")
    var latencies: [i64] = []
    var j: i64 = 0
    while j < count:
        val t0 = time_now_unix_micros()
        val r = core.unlink("/D" + j.to_text() + ".TXT")
        val elapsed = time_now_unix_micros() - t0
        if r.is_ok():
            latencies = latencies.push(elapsed)
        j = j + 1
    if latencies.len() == 0:
        return skipped_result("delete", "simple_fat32")
    BenchResult(workload_name: "delete", driver_name: "simple_fat32", p50_us: percentile(latencies, 50), p99_us: percentile(latencies, 99))

fn bench_delete_posix(count: i64) -> BenchResult:
    _posix_setup()
    var i: i64 = 0
    while i < count:
        write_file(_posix_base() + "/d" + i.to_text() + ".txt", "")
        i = i + 1
    var latencies: [i64] = []
    var j: i64 = 0
    while j < count:
        val path = _posix_base() + "/d" + j.to_text() + ".txt"
        val t0 = time_now_unix_micros()
        file_delete(path)
        latencies = latencies.push(time_now_unix_micros() - t0)
        j = j + 1
    BenchResult(workload_name: "delete", driver_name: "c_fat_posix", p50_us: percentile(latencies, 50), p99_us: percentile(latencies, 99))

# ══════════════════════════════════════════════════════════════════════════
# Workload 6: Stat — resolve file metadata
# ══════════════════════════════════════════════════════════════════════════
fn bench_stat_simple(iters: i64) -> BenchResult:
    var core = _make_core()
    val _fh = core.create_file("/ST.TXT")
    var latencies: [i64] = []
    var i: i64 = 0
    while i < iters:
        val t0 = time_now_unix_micros()
        val r = core.find_entry_in_dir(2u32, "ST.TXT")
        val elapsed = time_now_unix_micros() - t0
        if r.is_ok():
            latencies = latencies.push(elapsed)
        i = i + 1
    if latencies.len() == 0:
        return skipped_result("stat", "simple_fat32")
    BenchResult(workload_name: "stat", driver_name: "simple_fat32", p50_us: percentile(latencies, 50), p99_us: percentile(latencies, 99))

fn bench_stat_posix(iters: i64) -> BenchResult:
    _posix_setup()
    val path = _posix_base() + "/stat.txt"
    write_file(path, _fill_text(1024))
    var latencies: [i64] = []
    var i: i64 = 0
    while i < iters:
        val t0 = time_now_unix_micros()
        val _sz = file_size(path)
        latencies = latencies.push(time_now_unix_micros() - t0)
        i = i + 1
    _posix_clean()
    BenchResult(workload_name: "stat", driver_name: "c_fat_posix", p50_us: percentile(latencies, 50), p99_us: percentile(latencies, 99))

# ══════════════════════════════════════════════════════════════════════════
# Workload 7: Directory Scan — list directory entries
# ══════════════════════════════════════════════════════════════════════════
fn bench_dirscan_simple(file_count: i64, iters: i64) -> BenchResult:
    var core = _make_core()
    var i: i64 = 0
    while i < file_count:
        val _fh = core.create_file("/S" + i.to_text() + ".TXT")
        i = i + 1
    var latencies: [i64] = []
    var j: i64 = 0
    while j < iters:
        val t0 = time_now_unix_micros()
        val r = core.readdir("/")
        val elapsed = time_now_unix_micros() - t0
        if r.is_ok():
            latencies = latencies.push(elapsed)
        j = j + 1
    if latencies.len() == 0:
        return skipped_result("directory_scan", "simple_fat32")
    BenchResult(workload_name: "directory_scan", driver_name: "simple_fat32", p50_us: percentile(latencies, 50), p99_us: percentile(latencies, 99))

fn bench_dirscan_posix(file_count: i64, iters: i64) -> BenchResult:
    _posix_setup()
    var i: i64 = 0
    while i < file_count:
        write_file(_posix_base() + "/s" + i.to_text() + ".txt", "")
        i = i + 1
    var latencies: [i64] = []
    var j: i64 = 0
    while j < iters:
        val t0 = time_now_unix_micros()
        val _files = list_dir(_posix_base())
        latencies = latencies.push(time_now_unix_micros() - t0)
        j = j + 1
    _posix_clean()
    BenchResult(workload_name: "directory_scan", driver_name: "c_fat_posix", p50_us: percentile(latencies, 50), p99_us: percentile(latencies, 99))

# ══════════════════════════════════════════════════════════════════════════
# Report Generation
# ══════════════════════════════════════════════════════════════════════════
fn _md_row(s: BenchResult, p: BenchResult) -> text:
    if s.p50_us < 0:
        return "| " + s.workload_name + " | SKIP | SKIP | " + p.p50_us.to_text() + " | " + p.p99_us.to_text() + " | N/A |"
    val ratio = if p.p50_us > 0: (s.p50_us * 100) / p.p50_us else: 0
    "| " + s.workload_name + " | " + s.p50_us.to_text() + " | " + s.p99_us.to_text() + " | " + p.p50_us.to_text() + " | " + p.p99_us.to_text() + " | " + ratio.to_text() + "% |"

fn write_report(pairs: [[BenchResult]]):
    var md = "# FAT32 vs C FAT (POSIX) Benchmark Results\n\n"
    md = md + "**Date:** 2026-05-26\n"
    md = md + "**Mode:** interpreter (`bin/simple run`)\n"
    md = md + "**Simple FAT32:** in-memory Fat32Core, 4096 sectors x 512 B\n"
    md = md + "**C FAT baseline:** host kernel POSIX filesystem via std.io_runtime\n\n"
    md = md + "## Per-Workload Comparison\n\n"
    md = md + "| Workload | Simple p50 (us) | Simple p99 (us) | POSIX p50 (us) | POSIX p99 (us) | Ratio p50 |\n"
    md = md + "|----------|----------------|----------------|----------------|----------------|-----------|\n"
    for pair in pairs:
        md = md + _md_row(pair[0], pair[1]) + "\n"
    md = md + "\n## Interpretation\n\n"
    md = md + "- **Ratio** = (Simple p50 / POSIX p50) x 100. Values > 100% mean Simple is slower.\n"
    md = md + "- **SKIP** = workload could not complete (directory full or other runtime error).\n"
    md = md + "- Simple FAT32 runs entirely in-process with in-memory block device.\n"
    md = md + "- POSIX baseline uses host kernel file operations (ext4/btrfs, not VFAT).\n"
    md = md + "- Both measurements include Simple interpreter dispatch overhead.\n"
    md = md + "- For compiled-mode estimates, see fs_driver_vfat_comparison.md.\n"
    md = md + "\n## Known Limitations\n\n"
    md = md + "- Interpreter overhead dominates Simple FAT32 timings (~120ms for path resolve).\n"
    md = md + "- Sequential read is faster on Simple due to in-memory block device (no syscalls).\n"
    md = md + "- Compiled-mode benchmarks show ~121 us for metadata open (see vfat comparison doc).\n"
    md = md + "- Root directory limited to 64 entries (4 sectors/cluster x 512B / 32B per entry).\n"
    mkdir_p("doc/10_metrics")
    write_file("doc/10_metrics/fat32_vs_cfat_benchmark.md", md)
    print "Results written to doc/10_metrics/fat32_vs_cfat_benchmark.md"

# ══════════════════════════════════════════════════════════════════════════
# Main
# ══════════════════════════════════════════════════════════════════════════
fn main():
    print "=== FAT32 vs C FAT (POSIX) Benchmark ==="
    print "Simple FAT32: in-memory Fat32Core, 4096 sectors x 512 B"
    print "C FAT baseline: host POSIX filesystem via std.io_runtime"
    print ""

    val iters: i64 = 30
    val file_count: i64 = 30
    val total_bytes: i64 = 10240

    var pairs: [[BenchResult]] = []

    print "[1/7] create"
    val r1s = bench_create_simple(file_count)
    val r1p = bench_create_posix(file_count)
    print result_line(r1s)
    print result_line(r1p)
    pairs = pairs.push([r1s, r1p])

    print "[2/7] lookup"
    val r2s = bench_lookup_simple(iters)
    val r2p = bench_lookup_posix(iters)
    print result_line(r2s)
    print result_line(r2p)
    pairs = pairs.push([r2s, r2p])

    print "[3/7] sequential_read"
    val r3s = bench_seq_read_simple(iters)
    val r3p = bench_seq_read_posix(iters, total_bytes)
    print result_line(r3s)
    print result_line(r3p)
    pairs = pairs.push([r3s, r3p])

    print "[4/7] append"
    val r4s = bench_append_simple(iters)
    val r4p = bench_append_posix(iters, total_bytes)
    print result_line(r4s)
    print result_line(r4p)
    pairs = pairs.push([r4s, r4p])

    print "[5/7] delete"
    val r5s = bench_delete_simple(file_count)
    val r5p = bench_delete_posix(file_count)
    print result_line(r5s)
    print result_line(r5p)
    pairs = pairs.push([r5s, r5p])

    print "[6/7] stat"
    val r6s = bench_stat_simple(iters)
    val r6p = bench_stat_posix(iters)
    print result_line(r6s)
    print result_line(r6p)
    pairs = pairs.push([r6s, r6p])

    print "[7/7] directory_scan"
    val r7s = bench_dirscan_simple(file_count, iters)
    val r7p = bench_dirscan_posix(file_count, iters)
    print result_line(r7s)
    print result_line(r7p)
    pairs = pairs.push([r7s, r7p])

    print ""
    write_report(pairs)

    _posix_clean()
    print "=== done ==="
