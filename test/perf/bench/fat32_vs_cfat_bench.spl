# test/perf/bench/fat32_vs_cfat_bench.spl — FAT32 vs C FAT benchmark.
# 9 workloads: lookup, sequential_read, create, append, delete, stat, directory_scan,
#              random_4k_read, random_4k_overwrite.
# Simple FAT32: in-memory Fat32Core via BlockDevice trait.
# POSIX baseline: host kernel filesystem via std.io_runtime.
# VFAT baseline: 64 MiB loopback FAT32 image via Linux VFAT mount (optional, needs sudo).
# Run: bin/simple run test/perf/bench/fat32_vs_cfat_bench.spl

use std.io_runtime.{
    time_now_unix_micros, write_file, read_file, file_exists,
    file_delete, file_size, mkdir_p, list_dir, shell
}
use std.fs_driver.block_device.{BlockDevice}
use std.fs_driver.fat32_core.{Fat32Core, fat32_close, fat32_write}
use std.nogc_sync_mut.io.file_ops.{file_read_text_at, file_write_text_at}

extern fn rt_byte_array_new_len(len: u64) -> [u8]
extern fn rt_bytes_u8_set(array: [u8], index: i64, value: i64) -> bool
extern fn rt_typed_bytes_u8_unchecked(array: [u8], index: i64) -> i64

# ── In-memory FAT32 image (from fat32_microbench.spl) ──────────────────────
var __bench_data: [u8] = []
var __bench_active_bank: i32 = 0
var __vfat_mnt: text = "/tmp/simple_vfat_bench_mnt"
var __vfat_loop: text = ""
var __vfat_use_udisks: bool = false

fn _alloc_bank() -> i32:
    __bench_data = rt_byte_array_new_len(2097152u64)
    0

fn _set_sec(bid: i32, sec: i32, data: [u8]):
    val base = sec * 512
    var i: i32 = 0
    while i < 512 and i < data.len():
        val _s = rt_bytes_u8_set(__bench_data, (base + i).to_i64(), data[i].to_i64())
        i = i + 1

fn _get_sec(bid: i32, sec: i32) -> [u8]:
    val base = sec * 512
    var out: [u8] = rt_byte_array_new_len(512u64)
    var i: i32 = 0
    while i < 512:
        val _s = rt_bytes_u8_set(out, i.to_i64(), rt_typed_bytes_u8_unchecked(__bench_data, (base + i).to_i64()))
        i = i + 1
    out

fn _w32(mut buf: [u8], off: i64, v: u32):
    val _s0 = rt_bytes_u8_set(buf, off, (v & 0xFF).to_i64())
    val _s1 = rt_bytes_u8_set(buf, off + 1, ((v >> 8) & 0xFF).to_i64())
    val _s2 = rt_bytes_u8_set(buf, off + 2, ((v >> 16) & 0xFF).to_i64())
    val _s3 = rt_bytes_u8_set(buf, off + 3, ((v >> 24) & 0xFF).to_i64())

fn _init_image(bid: i32):
    var bpb = _get_sec(bid, 0)
    bpb[11] = 0x00
    bpb[12] = 0x02
    bpb[13] = 0x04
    bpb[14] = 0x20
    bpb[15] = 0x00
    bpb[16] = 0x02
    _w32(bpb, 32, 4096u32)
    _w32(bpb, 36, 1u32)
    _w32(bpb, 44, 2u32)
    bpb[510] = 0x55
    bpb[511] = 0xAA
    _set_sec(bid, 0, bpb)
    var fat = _get_sec(bid, 32)
    _w32(fat, 0, 0x0FFFFFF8u32)
    _w32(fat, 4, 0x0FFFFFFFu32)
    _w32(fat, 8, 0x0FFFFFF8u32)
    _set_sec(bid, 32, fat)

class BMBlockDev:
    bank_id: i32

impl BMBlockDev:
    static fn new() -> BMBlockDev:
        val bid = _alloc_bank()
        _init_image(bid)
        __bench_active_bank = bid
        BMBlockDev(bank_id: bid)

impl BlockDevice for BMBlockDev:
    fn read_sector(lba: u64, mut buffer: [u8]) -> Result<bool, text>:
        val idx = lba.to_i32()
        if idx < 0 or idx >= 4096:
            return Ok(true)
        val src = _get_sec(__bench_active_bank, idx)
        var i = 0
        while i < buffer.len() and i < src.len():
            val _s = rt_bytes_u8_set(buffer, i.to_i64(), rt_typed_bytes_u8_unchecked(src, i.to_i64()))
            i = i + 1
        Ok(true)
    fn write_sector(lba: u64, data: [u8]) -> Result<bool, text>:
        val idx = lba.to_i32()
        if idx < 0 or idx >= 4096:
            return Err("sector out of range")
        _set_sec(__bench_active_bank, idx, data)
        Ok(true)
    fn sector_size() -> u32:
        512

fn _make_core() -> Fat32Core:
    var core = Fat32Core.new(BMBlockDev.new())
    val rc = core.mount()
    if rc.is_err():
        print "FATAL: mount failed"
    core

fn _fill_text(n: i64) -> text:
    var chunk = "AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA"
    var s = ""
    while s.len() < n:
        s = s + chunk
    s

fn _fill_bytes(n: i64, value: u8) -> [u8]:
    var out: [u8] = rt_byte_array_new_len(n.to_u64())
    var i: i64 = 0
    while i < n:
        val _s = rt_bytes_u8_set(out, i, value.to_i64())
        i = i + 1
    out

fn _rand_block(i: i64, block_count: i64) -> i64:
    ((i * 1103515245 + 12345) & 0x7FFFFFFF) % block_count

fn percentile(latencies: [i64], pct: i64) -> i64:
    val n = latencies.len()
    if n == 0:
        return 0
    var idx = (n * pct) / 100
    if idx >= n:
        idx = n - 1
    var i = 0
    while i < n:
        val candidate = latencies[i]
        var less = 0
        var leq = 0
        var j = 0
        while j < n:
            if latencies[j] < candidate:
                less = less + 1
            if latencies[j] <= candidate:
                leq = leq + 1
            j = j + 1
        if less <= idx and idx < leq:
            return candidate
        i = i + 1
    latencies[n - 1]

# ── BenchResult ────────────────────────────────────────────────────────────
struct BenchResult:
    workload_name: text
    driver_name: text
    p50_us: i64
    p99_us: i64

fn result_line(r: BenchResult) -> text:
    if r.p50_us < 0:
        return "  " + r.driver_name + ": SKIPPED (file handle bug)"
    "  {r.driver_name}: p50={r.p50_us} us, p99={r.p99_us} us"

fn skipped_result(workload: text, driver: text) -> BenchResult:
    BenchResult(workload_name: workload, driver_name: driver, p50_us: -1, p99_us: -1)

# ── Host-filesystem helpers ────────────────────────────────────────────────
fn _posix_base() -> text:
    "/tmp/simple_fat32_vs_cfat_bench"

fn _vfat_image() -> text:
    "/tmp/simple_vfat_bench.img"

fn _vfat_base() -> text:
    __vfat_mnt

fn _host_clean(base: text):
    val files = list_dir(base)
    for f in files:
        val _d = file_delete(base + "/" + f)

fn _host_setup(base: text):
    mkdir_p(base)
    _host_clean(base)

fn _vfat_setup() -> bool:
    val mnt = "/tmp/simple_vfat_bench_mnt"
    val pre = shell("mountpoint -q " + mnt + " 2>/dev/null")
    if pre.exit_code == 0:
        __vfat_mnt = mnt
        print "  VFAT: pre-mounted at " + mnt
        return true
    val img = _vfat_image()
    val r1 = shell("dd if=/dev/zero of=" + img + " bs=1M count=64 2>/dev/null")
    if r1.exit_code != 0:
        print "  VFAT: dd failed"
        return false
    val r2 = shell("mkfs.fat -F 32 " + img + " 2>/dev/null")
    if r2.exit_code != 0:
        print "  VFAT: mkfs.fat failed (install dosfstools)"
        return false
    mkdir_p(mnt)
    val r3 = shell("sudo -n mount -o loop " + img + " " + mnt + " 2>/dev/null")
    if r3.exit_code == 0:
        val _ch = shell("sudo -n chmod 777 " + mnt + " 2>/dev/null")
        __vfat_mnt = mnt
        return true
    val r4 = shell("udisksctl loop-setup --file " + img + " --no-user-interaction 2>/dev/null")
    if r4.exit_code != 0:
        print "  VFAT: sudo mount and udisksctl both failed"
        val _rm = shell("rm -f " + img)
        return false
    val r5 = shell("losetup -j " + img + " 2>/dev/null | head -1 | cut -d: -f1 | tr -d '\\n'")
    if r5.exit_code != 0 or r5.stdout.len() < 5:
        print "  VFAT: cannot find loop device"
        val _rm = shell("rm -f " + img)
        return false
    __vfat_loop = r5.stdout
    __vfat_use_udisks = true
    val r6 = shell("udisksctl mount -b " + __vfat_loop + " --no-user-interaction 2>/dev/null")
    if r6.exit_code != 0:
        print "  VFAT: udisksctl mount failed"
        val _del = shell("udisksctl loop-delete -b " + __vfat_loop + " --no-user-interaction 2>/dev/null")
        val _rm = shell("rm -f " + img)
        return false
    val r7 = shell("findmnt -n -o TARGET " + __vfat_loop + " 2>/dev/null | head -1 | tr -d '\\n'")
    if r7.exit_code != 0 or r7.stdout.len() < 3:
        print "  VFAT: cannot find mount point"
        val _um = shell("udisksctl unmount -b " + __vfat_loop + " --no-user-interaction 2>/dev/null")
        val _del = shell("udisksctl loop-delete -b " + __vfat_loop + " --no-user-interaction 2>/dev/null")
        val _rm = shell("rm -f " + img)
        return false
    __vfat_mnt = r7.stdout
    print "  VFAT: mounted via udisksctl at " + __vfat_mnt
    true

fn _vfat_teardown():
    val img = _vfat_image()
    if __vfat_use_udisks:
        val _u = shell("udisksctl unmount -b " + __vfat_loop + " --no-user-interaction 2>/dev/null")
        val _d = shell("udisksctl loop-delete -b " + __vfat_loop + " --no-user-interaction 2>/dev/null")
    else:
        val _u = shell("sudo -n umount " + __vfat_mnt + " 2>/dev/null")
        val _r = shell("rmdir " + __vfat_mnt + " 2>/dev/null")
    val _rm = shell("rm -f " + img)

# ══════════════════════════════════════════════════════════════════════════
# Workload 1: Create — create N files
# ══════════════════════════════════════════════════════════════════════════
fn bench_create_simple(count: i64) -> BenchResult:
    var core: Fat32Core = _make_core()
    var latencies: [i64] = []
    var i: i64 = 0
    while i < count:
        val t0 = time_now_unix_micros()
        val fh = core.create_file("/C{i}.TXT")
        if fh.is_ok():
            val _c = fat32_close(core, fh.unwrap())
        latencies.push(time_now_unix_micros() - t0)
        i = i + 1
    BenchResult(workload_name: "create", driver_name: "simple_fat32", p50_us: percentile(latencies, 50), p99_us: percentile(latencies, 99))

fn bench_create_host(count: i64, base_dir: text, driver_name: text) -> BenchResult:
    _host_setup(base_dir)
    var latencies: [i64] = []
    var i: i64 = 0
    while i < count:
        val path = "{base_dir}/c{i}.txt"
        val t0 = time_now_unix_micros()
        write_file(path, "")
        latencies.push(time_now_unix_micros() - t0)
        i = i + 1
    _host_clean(base_dir)
    BenchResult(workload_name: "create", driver_name: driver_name, p50_us: percentile(latencies, 50), p99_us: percentile(latencies, 99))

# ══════════════════════════════════════════════════════════════════════════
# Workload 2: Lookup — resolve a file path
# ══════════════════════════════════════════════════════════════════════════
fn bench_lookup_simple(iters: i64) -> BenchResult:
    var core: Fat32Core = _make_core()
    val _fh = core.create_file("/LK.TXT")
    var latencies: [i64] = []
    var i: i64 = 0
    while i < iters:
        val t0 = time_now_unix_micros()
        val r = core.find_entry_in_dir(2u32, "LK.TXT")
        val elapsed = time_now_unix_micros() - t0
        if r.is_ok():
            latencies.push(elapsed)
        i = i + 1
    if latencies.len() == 0:
        return skipped_result("lookup", "simple_fat32")
    BenchResult(workload_name: "lookup", driver_name: "simple_fat32", p50_us: percentile(latencies, 50), p99_us: percentile(latencies, 99))

fn bench_lookup_host(iters: i64, base_dir: text, driver_name: text) -> BenchResult:
    _host_setup(base_dir)
    val path = base_dir + "/lookup.txt"
    write_file(path, "x")
    var latencies: [i64] = []
    var i: i64 = 0
    while i < iters:
        val t0 = time_now_unix_micros()
        val _e = file_exists(path)
        latencies.push(time_now_unix_micros() - t0)
        i = i + 1
    _host_clean(base_dir)
    BenchResult(workload_name: "lookup", driver_name: driver_name, p50_us: percentile(latencies, 50), p99_us: percentile(latencies, 99))

# ══════════════════════════════════════════════════════════════════════════
# Workload 3: Sequential Read — read a file (requires file handles)
# ══════════════════════════════════════════════════════════════════════════
fn bench_seq_read_simple(iters: i64) -> BenchResult:
    var core: Fat32Core = _make_core()
    val cr = core.create_file("/RD.TXT")
    if cr.is_err():
        return skipped_result("sequential_read", "simple_fat32")
    val h = cr.unwrap()
    var buf: [u8] = []
    var b: i64 = 0
    while b < 128:
        buf.push(0x41)
        b = b + 1
    val wr = fat32_write(core, h, buf, 128)
    if wr.is_err():
        return skipped_result("sequential_read", "simple_fat32")
    val cr2 = fat32_close(core, h)
    if cr2.is_err():
        return skipped_result("sequential_read", "simple_fat32")
    val oh = core.open("/RD.TXT")
    if oh.is_err():
        return skipped_result("sequential_read", "simple_fat32")
    var latencies: [i64] = []
    var i: i64 = 0
    while i < iters:
        val t0 = time_now_unix_micros()
        val _r = core.read_bytes(oh.unwrap(), 128)
        latencies.push(time_now_unix_micros() - t0)
        i = i + 1
    BenchResult(workload_name: "sequential_read", driver_name: "simple_fat32", p50_us: percentile(latencies, 50), p99_us: percentile(latencies, 99))

fn bench_seq_read_host(iters: i64, total_bytes: i64, base_dir: text, driver_name: text) -> BenchResult:
    _host_setup(base_dir)
    val path = base_dir + "/seqrd.txt"
    val content = _fill_text(total_bytes)
    write_file(path, content)
    var latencies: [i64] = []
    var j: i64 = 0
    while j < iters:
        val t0 = time_now_unix_micros()
        val _data = read_file(path)
        latencies.push(time_now_unix_micros() - t0)
        j = j + 1
    _host_clean(base_dir)
    BenchResult(workload_name: "sequential_read", driver_name: driver_name, p50_us: percentile(latencies, 50), p99_us: percentile(latencies, 99))

# ══════════════════════════════════════════════════════════════════════════
# Workload 4: Append — write data to file (requires file handles)
# ══════════════════════════════════════════════════════════════════════════
fn bench_append_simple(iters: i64) -> BenchResult:
    var core: Fat32Core = _make_core()
    var buf: [u8] = []
    var b: i64 = 0
    while b < 128:
        buf.push(0x41)
        b = b + 1
    var latencies: [i64] = []
    var j: i64 = 0
    while j < iters:
        val cr = core.create_file("/W{j}.TXT")
        if cr.is_err():
            return skipped_result("append", "simple_fat32")
        val h = cr.unwrap()
        val t0 = time_now_unix_micros()
        val wr = fat32_write(core, h, buf, 128)
        val elapsed = time_now_unix_micros() - t0
        if wr.is_err():
            return skipped_result("append", "simple_fat32")
        latencies.push(elapsed)
        val _c = fat32_close(core, h)
        j = j + 1
    BenchResult(workload_name: "append", driver_name: "simple_fat32", p50_us: percentile(latencies, 50), p99_us: percentile(latencies, 99))

fn bench_append_host(iters: i64, total_bytes: i64, base_dir: text, driver_name: text) -> BenchResult:
    _host_setup(base_dir)
    val content = _fill_text(total_bytes)
    var latencies: [i64] = []
    var j: i64 = 0
    while j < iters:
        val path = "{base_dir}/a{j}.txt"
        val t0 = time_now_unix_micros()
        write_file(path, content)
        latencies.push(time_now_unix_micros() - t0)
        j = j + 1
    _host_clean(base_dir)
    BenchResult(workload_name: "append", driver_name: driver_name, p50_us: percentile(latencies, 50), p99_us: percentile(latencies, 99))

# ══════════════════════════════════════════════════════════════════════════
# Workload 5: Delete — unlink files
# ══════════════════════════════════════════════════════════════════════════
fn bench_delete_simple(count: i64) -> BenchResult:
    var core: Fat32Core = _make_core()
    var i: i64 = 0
    while i < count:
        val _fh = core.create_file("/D{i}.TXT")
        i = i + 1
    val _warm = core.readdir("/")
    var latencies: [i64] = []
    var j: i64 = 0
    while j < count:
        val t0 = time_now_unix_micros()
        val r = core.unlink("/D{j}.TXT")
        val elapsed = time_now_unix_micros() - t0
        if r.is_ok():
            latencies.push(elapsed)
        j = j + 1
    if latencies.len() == 0:
        return skipped_result("delete", "simple_fat32")
    BenchResult(workload_name: "delete", driver_name: "simple_fat32", p50_us: percentile(latencies, 50), p99_us: percentile(latencies, 99))

fn bench_delete_host(count: i64, base_dir: text, driver_name: text) -> BenchResult:
    _host_setup(base_dir)
    var i: i64 = 0
    while i < count:
        write_file("{base_dir}/d{i}.txt", "")
        i = i + 1
    var latencies: [i64] = []
    var j: i64 = 0
    while j < count:
        val path = "{base_dir}/d{j}.txt"
        val t0 = time_now_unix_micros()
        file_delete(path)
        latencies.push(time_now_unix_micros() - t0)
        j = j + 1
    BenchResult(workload_name: "delete", driver_name: driver_name, p50_us: percentile(latencies, 50), p99_us: percentile(latencies, 99))

