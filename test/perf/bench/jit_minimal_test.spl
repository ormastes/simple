# test/perf/bench/jit_minimal_test.spl — minimal PureDatabase smoke bench.
#
# Smallest possible PureDatabase exercise: create in-memory DB, create table,
# insert one row, read it back. Run: bin/simple test test/perf/bench/jit_minimal_test.spl

use std.spec
use std.database.sql.types.{DbValue, DbRow}
use std.database.pure_sql.database.{PureDatabase}

describe "JIT minimal smoke test":
    it "creates a table and inserts a row":
        print("Creating DB...")
        val db = PureDatabase.memory().unwrap()
        print("Creating table...")
        db.exec_sql("CREATE TABLE t (id INTEGER PRIMARY KEY, name TEXT)").unwrap()
        print("Inserting...")
        db.exec_sql("INSERT INTO t VALUES (1, 'hello')").unwrap()
        print("Querying...")
        val rows = db.query("SELECT id, name FROM t WHERE id = 1", []).unwrap()
        expect(rows.len()).to_equal(1)
        expect(rows[0].values[1]).to_equal(DbValue.Text(value: "hello"))
        print("Done")
        db.close().unwrap()
