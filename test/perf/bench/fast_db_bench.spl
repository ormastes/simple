# fast_db_bench.spl — Benchmark for C-runtime-backed FastTable.
#
# Measures: PUT x200, GET x100, SCAN x100, DELETE x50 on FastTable.
# Uses bench_now_ns() (clock_gettime CLOCK_MONOTONIC).
#
# Run interpreted:  bin/simple run test/perf/bench/fast_db_bench.spl
# Run compiled:     bin/simple test --compile test/perf/bench/fast_db_bench.spl

use test.perf.bench.lib.timing.{bench_now_ns}
use nogc_sync_mut.database.fast_db.{FastTable}

# ── Helpers ────────────────────────────────────────────────────────────────────

fn elapsed_us(t0: i64, t1: i64) -> i64:
    (t1 - t0) / 1000

fn elapsed_ns(t0: i64, t1: i64) -> i64:
    t1 - t0

fn per_op_ns(t0: i64, t1: i64, ops: i64) -> i64:
    if ops <= 0:
        return 0
    (t1 - t0) / ops

# ── Main ───────────────────────────────────────────────────────────────────────

fn main():
    print "=== FastTable (C Runtime) Benchmark ==="
    print "Schema: 3 columns (id:int, name:text, score:int), pk_col=0"
    print ""

    # Create table: 3 cols, pk on col 0
    var tbl = FastTable.create("bench", 3, 0)

    # ── PUT x200 ──────────────────────────────────────────────────────────────
    val put_t0 = bench_now_ns()
    var i = 0
    while i < 200:
        val pk = "key_" + i.to_text()
        val row = tbl.put(pk)
        tbl.put_int(row, 0, i as i64)
        tbl.put_text(row, 1, "name_" + i.to_text())
        tbl.put_int(row, 2, (i * 10) as i64)
        i = i + 1
    val put_t1 = bench_now_ns()
    val put_total_us = elapsed_us(put_t0, put_t1)
    val put_per_ns = per_op_ns(put_t0, put_t1, 200)
    print "[PUT x200]  total=" + put_total_us.to_text() + " us  per_op=" + put_per_ns.to_text() + " ns"

    # Verify row count
    val rc = tbl.row_count()
    if rc != 200:
        print "FAIL: expected 200 rows, got " + rc.to_text()

    # ── GET x100 (point lookup) ───────────────────────────────────────────────
    val get_t0 = bench_now_ns()
    var found = 0
    var j = 0
    while j < 100:
        val pk = "key_" + (j * 2).to_text()
        val row = tbl.get(pk)
        if row >= 0:
            val score = tbl.get_int(row, 2)
            if score == (j * 2 * 10) as i64:
                found = found + 1
        j = j + 1
    val get_t1 = bench_now_ns()
    val get_total_us = elapsed_us(get_t0, get_t1)
    val get_per_ns = per_op_ns(get_t0, get_t1, 100)
    print "[GET x100]  total=" + get_total_us.to_text() + " us  per_op=" + get_per_ns.to_text() + " ns  found=" + found.to_text()

    # ── SCAN x100 (range on score col=2) ──────────────────────────────────────
    val scan_t0 = bench_now_ns()
    var total_scan_rows = 0
    var k = 0
    while k < 100:
        val low = (k * 10) as i64
        val high = ((k + 20) * 10) as i64
        val cnt = tbl.scan_range(2, low, high)
        total_scan_rows = total_scan_rows + cnt as i64
        k = k + 1
    val scan_t1 = bench_now_ns()
    val scan_total_us = elapsed_us(scan_t0, scan_t1)
    val scan_per_ns = per_op_ns(scan_t0, scan_t1, 100)
    print "[SCAN x100] total=" + scan_total_us.to_text() + " us  per_op=" + scan_per_ns.to_text() + " ns  total_rows=" + total_scan_rows.to_text()

    # ── DELETE x50 ────────────────────────────────────────────────────────────
    val del_t0 = bench_now_ns()
    var deleted = 0
    var d = 0
    while d < 50:
        val pk = "key_" + d.to_text()
        val ok = tbl.delete(pk)
        deleted = deleted + ok as i64
        d = d + 1
    val del_t1 = bench_now_ns()
    val del_total_us = elapsed_us(del_t0, del_t1)
    val del_per_ns = per_op_ns(del_t0, del_t1, 50)
    print "[DEL x50]   total=" + del_total_us.to_text() + " us  per_op=" + del_per_ns.to_text() + " ns  deleted=" + deleted.to_text()

    # Verify remaining count
    val remaining = tbl.row_count()
    print ""
    print "Remaining rows: " + remaining.to_text()

    # ── Summary ───────────────────────────────────────────────────────────────
    print ""
    print "=== Comparison with SQLite ground truth ==="
    print "SQLite GET:   ~800 ns/op (prepared stmt, WAL mode)"
    print "FastTable GET: " + get_per_ns.to_text() + " ns/op"
    print "SQLite PUT:   ~2000 ns/op (WAL mode)"
    print "FastTable PUT: " + put_per_ns.to_text() + " ns/op"
    print ""

    # ── Sanity checks ─────────────────────────────────────────────────────────
    var passed = true
    if found != 100:
        print "FAIL: GET should find 100 rows, found " + found.to_text()
        passed = false
    if deleted != 50:
        print "FAIL: DELETE should remove 50 rows, deleted " + deleted.to_text()
        passed = false
    if remaining != 150:
        print "FAIL: expected 150 remaining rows, got " + remaining.to_text()
        passed = false

    if passed:
        print "RESULT: PASS"
    else:
        print "RESULT: FAIL"

    tbl.destroy()
