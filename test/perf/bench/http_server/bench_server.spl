"""
# HTTP Server Benchmark — Async Server Entry Point

Starts the async HTTP server with native IoDriver (epoll/kqueue/IOCP)
for benchmarking against nginx. Run with wrk or hey from another terminal.

Usage:
    bin/simple run test/perf/bench/http_server/bench_server.spl
    bin/simple run test/perf/bench/http_server/bench_server.spl -- --workers=4 --port=9090

Then from another terminal:
    wrk -t4 -c100 -d10s http://localhost:9090/hello.txt
    wrk -t4 -c100 -d10s http://localhost:9090/1kb.html
    wrk -t4 -c100 -d30s http://localhost:9090/1mb.bin

Performance targets (from design doc):
    Hello-world RPS (1 core):  >100K  (nginx: 145K)
    Hello-world RPS (N cores): >80% linear scaling
    p99 latency under load:    <10ms at 50K RPS
    Static file throughput:    >10 Gbps
"""

use std.http_server.server.{HttpServer}
use std.http_server.types.{ServerConfig, default_server_config, LocationConfig}
use std.thread_sffi.{spl_thread_sleep, spl_thread_cpu_count}
use std.nogc_sync_mut.io.file_ops.{file_write_text, file_exists, dir_create}

extern fn rt_cli_get_args() -> [text]

fn ensure_test_data(root: text):
    """Check that test data exists (generated by run_bench.shs)."""
    if not file_exists(root + "/hello.txt"):
        print "  WARNING: Test data missing in {root}/"
        print "  Run: sh test/perf/bench/http_server/run_bench.shs"
        print "  Or create files manually:"
        print "    echo -n 'Hello, World!' > {root}/hello.txt"
        print "    dd if=/dev/zero bs=1K count=1 of={root}/1kb.html"
        print "    dd if=/dev/zero bs=1M count=1 of={root}/1mb.bin"
    else:
        print "  Test data found in {root}/"

fn parse_bench_args() -> (i64, i32, text):
    """Parse --workers=N --port=P --root=DIR from CLI args."""
    val args = rt_cli_get_args()
    var workers: i64 = 0
    var port: i32 = 9090
    var root = "/tmp/simple_bench_data"

    var i = 0
    while i < args.len():
        val arg = args[i]
        if arg.starts_with("--workers="):
            val s = arg.slice(10, arg.len())
            workers = s.to_i64()
        elif arg.starts_with("--port="):
            val s = arg.slice(7, arg.len())
            port = s.to_i64().to_i32()
        elif arg.starts_with("--root="):
            root = arg.slice(7, arg.len())
        i = i + 1

    (workers, port, root)

fn main():
    val parsed = parse_bench_args()
    val workers = parsed.0
    val port = parsed.1
    val data_root = parsed.2

    val cpus = spl_thread_cpu_count()
    val actual_workers = if workers > 0: workers else: cpus

    print "============================================"
    print "  Simple Async HTTP Server Benchmark"
    print "============================================"
    print ""
    print "  Port:    {port}"
    print "  Workers: {actual_workers} (CPUs: {cpus})"
    print "  Root:    {data_root}"
    print ""

    ensure_test_data(data_root)

    var config = default_server_config()
    config.listen_addr = "0.0.0.0:{port}"
    config.worker_count = actual_workers
    config.keepalive_timeout_ms = 65000
    config.max_connections = 10000

    val static_loc = LocationConfig(
        pattern: "/",
        match_type: "prefix",
        handler_type: "static",
        root: data_root,
        proxy_pass: "",
        middlewares: []
    )
    config.locations = [static_loc]

    print ""
    print "  Starting server..."

    var server = HttpServer.new(config)
    val result = server.start()
    match result:
        Ok(_):
            print "  Server running on 0.0.0.0:{port}"
            print ""
            print "  Benchmark commands:"
            print "    wrk -t4 -c100  -d10s http://localhost:{port}/hello.txt"
            print "    wrk -t4 -c100  -d10s http://localhost:{port}/1kb.html"
            print "    wrk -t4 -c1000 -d30s http://localhost:{port}/1mb.bin"
            print ""
            print "  Press Ctrl+C to stop."
            while true:
                spl_thread_sleep(1000)
        Err(e):
            print "  ERROR: Failed to start server"
