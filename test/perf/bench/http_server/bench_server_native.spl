"""
Minimal native-build benchmark server with hardcoded config.
Bypasses CLI arg parsing which has native codegen issues with var defaults.
"""

use std.http_server.server.{HttpServer}
use std.http_server.types.{ServerConfig, default_server_config, LocationConfig}

fn main():
    print "Simple Native HTTP Server Benchmark"
    print "  Port:    9090"
    print "  Workers: 4"
    print "  Root:    /tmp/simple_bench_data"

    var config = default_server_config()
    config.listen_addr = "0.0.0.0:9090"
    config.worker_count = 4
    config.keepalive_timeout_ms = 65000
    config.max_connections = 10000

    val static_loc = LocationConfig(
        pattern: "/",
        match_type: "prefix",
        handler_type: "static",
        root: "/tmp/simple_bench_data",
        proxy_pass: "",
        middlewares: []
    )
    config.locations = [static_loc]

    print "  Starting server..."

    var server = HttpServer.new(config)
    val result = server.start()
    match result:
        Ok(_):
            print "  Server stopped."
        Err(e):
            print "  ERROR: Failed to start server"
