"""
HTTPS server benchmark. Same as bench_server but with TLS enabled.
Requires cert/key at /tmp/simple_bench_data/{cert,key}.pem
"""

use std.http_server.server.{HttpServer}
use std.http_server.types.{ServerConfig, default_server_config, LocationConfig}

fn main():
    print "Simple HTTPS Server Benchmark"
    print "  Port:    9443"
    print "  TLS:     enabled"
    print "  Root:    /tmp/simple_bench_data"

    var config = default_server_config()
    config.listen_addr = "0.0.0.0:9443"
    config.worker_count = 1
    config.keepalive_timeout_ms = 65000
    config.max_connections = 10000
    config.tls_enabled = true
    config.tls_cert_path = "/tmp/simple_bench_data/cert.pem"
    config.tls_key_path = "/tmp/simple_bench_data/key.pem"

    val static_loc = LocationConfig(
        pattern: "/",
        match_type: "prefix",
        handler_type: "static",
        root: "/tmp/simple_bench_data",
        proxy_pass: "",
        middlewares: []
    )
    config.locations = [static_loc]

    print ""
    print "  Benchmark: wrk -t4 -c100 -d10s https://localhost:9443/hello.txt"
    print ""
    print "  Starting HTTPS server..."

    var server = HttpServer.new(config)
    val result = server.start()
    match result:
        Ok(_):
            print "  Server stopped."
        Err(e):
            print "  ERROR: {e}"
