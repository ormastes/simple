"""
Single-thread embedded HTTP server for native benchmark.
Bypasses worker threading to test native codegen performance.
"""

use std.http_server.embedded.{EmbeddedHttpServer}

fn main():
    print "Simple Native Embedded HTTP Server Benchmark"
    print "  Port:    9090"
    print "  Mode:    single-thread embedded"
    print "  Root:    /tmp/simple_bench_data"
    print ""
    print "  Benchmark: wrk -t4 -c100 -d10s http://localhost:9090/hello.txt"
    print ""
    print "  Starting server..."

    var server = EmbeddedHttpServer.new("0.0.0.0:9090")
    server.set_static_root("/tmp/simple_bench_data")
    server.start()
