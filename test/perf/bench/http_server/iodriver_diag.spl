"""Minimal IoDriver diagnostic — test accept + recv + send."""

use std.io.driver.{IoDriver}

extern fn rt_io_tcp_bind(addr: text) -> i64
extern fn rt_io_tcp_listen(fd: i64, backlog: i64) -> i64
extern fn rt_io_tcp_set_nonblocking(fd: i64, flag: bool) -> i64
extern fn rt_io_tcp_set_reuseaddr(fd: i64, flag: bool) -> i64

fn main():
    print "=== IoDriver Diagnostic ==="

    val listen_fd = rt_io_tcp_bind("0.0.0.0:9091")
    print "bind fd: {listen_fd}"
    if listen_fd < 0:
        print "FAIL: bind failed"
        return

    rt_io_tcp_set_reuseaddr(listen_fd, true)
    rt_io_tcp_set_nonblocking(listen_fd, true)
    val listen_res = rt_io_tcp_listen(listen_fd, 128)
    print "listen result: {listen_res}"

    val driver = IoDriver.new()
    var accept_op = driver.submit_accept(listen_fd)
    print "accept op id: {accept_op}"
    driver.flush()

    print "Waiting for connection on :9091 ..."

    var client_fd: i64 = -1
    var recv_op: i64 = -1
    var send_done = false
    var cycle = 0

    while cycle < 500 and not send_done:
        val count = driver.poll_count(64, 50)
        if count > 0:
            print "cycle {cycle}: {count} completions"

        var ci = 0
        while ci < count:
            val op_id = driver.poll_id(ci)
            val result = driver.poll_result(ci)
            val data = driver.poll_data(ci)

            if op_id == accept_op:
                print "  ACCEPT completed: client_fd={result}"
                if result >= 0:
                    client_fd = result
                    recv_op = driver.submit_recv(client_fd, 8192)
                    print "  submitted recv op: {recv_op}"
                    accept_op = driver.submit_accept(listen_fd)
                else:
                    print "  ACCEPT failed: {result}"

            elif op_id == recv_op:
                print "  RECV completed: result={result} data_len={data.len()}"
                if result > 0:
                    print "  DATA: [{data}]"
                    val response = "HTTP/1.1 200 OK\r\nContent-Length: 5\r\nConnection: close\r\n\r\nHello"
                    val send_op = driver.submit_send(client_fd, response)
                    print "  submitted send op: {send_op}"
                elif result == 0:
                    print "  EOF from client"
                    send_done = true
                else:
                    print "  RECV error: {result}"
                    send_done = true

            else:
                print "  op {op_id} completed: result={result}"
                send_done = true

            ci = ci + 1

        cycle = cycle + 1

    print "=== Done after {cycle} cycles ==="
    driver.close()
