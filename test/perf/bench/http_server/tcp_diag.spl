"""Minimal TCP diagnostic — test raw externs without IoDriver."""

extern fn rt_io_tcp_bind(addr: text) -> i64
extern fn rt_io_tcp_listen(fd: i64, backlog: i64) -> i64
extern fn rt_io_tcp_set_nonblocking(fd: i64, flag: bool) -> i64
extern fn rt_io_tcp_set_reuseaddr(fd: i64, flag: bool) -> i64
extern fn rt_io_tcp_accept_timeout(fd: i64, ms: i64) -> i64
extern fn rt_io_tcp_read(fd: i64, max: i64) -> [u8]
extern fn rt_io_tcp_write_text(fd: i64, data: text) -> i64
extern fn rt_io_tcp_set_read_timeout(fd: i64, ms: i64) -> i64
extern fn rt_io_tcp_close(fd: i64) -> i64
extern fn rt_bytes_to_text(data: [u8]) -> text

fn main():
    print "=== TCP Raw Diagnostic ==="

    print "step 1: bind"
    val listen_fd = rt_io_tcp_bind("0.0.0.0:9091")
    print "bind fd: {listen_fd}"
    if listen_fd < 0:
        print "FAIL: bind failed"
        return

    print "step 2: reuseaddr"
    rt_io_tcp_set_reuseaddr(listen_fd, true)

    print "step 3: listen"
    val listen_res = rt_io_tcp_listen(listen_fd, 128)
    print "listen result: {listen_res}"

    print "step 4: set nonblocking"
    rt_io_tcp_set_nonblocking(listen_fd, true)

    print "Waiting for connection on :9091..."

    var client_fd: i64 = -1
    var cycle = 0

    while cycle < 100:
        print "  accept attempt {cycle}..."
        val fd = rt_io_tcp_accept_timeout(listen_fd, 100)
        if fd >= 0:
            print "  ACCEPTED: client_fd={fd}"
            client_fd = fd
            cycle = 999
        else:
            cycle = cycle + 1

    if client_fd < 0:
        print "FAIL: no connection after 100 attempts"
        rt_io_tcp_close(listen_fd)
        return

    print "step 5: read from client"
    rt_io_tcp_set_read_timeout(client_fd, 2000)
    val bytes = rt_io_tcp_read(client_fd, 8192)
    print "read bytes.len: {bytes.len()}"

    if bytes.len() > 0:
        val txt = rt_bytes_to_text(bytes)
        print "DATA: [{txt}]"

        print "step 6: send response"
        val response = "HTTP/1.1 200 OK\r\nContent-Length: 5\r\nConnection: close\r\n\r\nHello"
        val res = rt_io_tcp_write_text(client_fd, response)
        print "write result: {res}"
    else:
        print "FAIL: no data from client"

    print "step 7: close"
    rt_io_tcp_close(client_fd)
    rt_io_tcp_close(listen_fd)
    print "=== Done ==="
