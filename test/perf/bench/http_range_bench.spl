"""
HTTP Range Request Benchmark — verifies multi-file download support.

Tests Range: bytes=X-Y requests against the full HTTP server with static
file serving. Validates 206 Partial Content responses and throughput.

Usage:
    # Start server first:
    bin/simple run /tmp/http_bench.spl &
    # Then run benchmark:
    bin/simple run test/perf/bench/http_range_bench.spl
"""

use std.nogc_sync_mut.io.tcp.{
    tcp_backend_connect,
    tcp_backend_write_text,
    tcp_backend_read_text,
    tcp_backend_close
}

extern fn rt_time_ms() -> i64

val TARGET_HOST = "127.0.0.1"
val TARGET_PORT = 9090
val ITERATIONS = 100

fn send_range_request(path: text, range_header: text) -> (i64, text):
    """Send an HTTP request with Range header. Returns (status_code, body_preview)."""
    val fd = tcp_backend_connect(TARGET_HOST, TARGET_PORT)
    if fd < 0:
        return (-1, "connect failed")

    var request = "GET {path} HTTP/1.1\r\n"
    request = request + "Host: {TARGET_HOST}\r\n"
    request = request + "Range: {range_header}\r\n"
    request = request + "Connection: close\r\n"
    request = request + "\r\n"

    tcp_backend_write_text(fd, request)
    val response = tcp_backend_read_text(fd, 8192)
    tcp_backend_close(fd)

    if response.len() == 0:
        return (-1, "empty response")

    val first_line_end = response.index_of("\r\n")
    if first_line_end < 0:
        return (-1, "malformed")

    val status_line = response.slice(0, first_line_end)
    val parts = status_line.split(" ")
    if parts.len() < 2:
        return (-1, "no status code")

    val status = parts.at(1).to_i64() ?? 0
    (status, response.slice(0, if response.len() < 200: response.len() else: 200))

fn bench_range_requests(path: text, range_header: text, label: text):
    """Benchmark a specific range request pattern."""
    val start = rt_time_ms()
    var success = 0
    var fail = 0
    var i = 0

    while i < ITERATIONS:
        val result = send_range_request(path, range_header)
        val status = result.0
        if status == 206 or status == 200:
            success = success + 1
        else:
            fail = fail + 1
        i = i + 1

    val elapsed = rt_time_ms() - start
    val rps = if elapsed > 0: (success * 1000) / elapsed else: 0
    print "  {label}: {success}/{ITERATIONS} ok, {elapsed}ms, {rps} req/s"

fn main():
    print "=== HTTP Range Request Benchmark ==="
    print "  Target: {TARGET_HOST}:{TARGET_PORT}"
    print "  Iterations per test: {ITERATIONS}"
    print ""

    val warmup = send_range_request("/1kb.html", "bytes=0-99")
    if warmup.0 < 0:
        print "FAIL: cannot connect to server at {TARGET_HOST}:{TARGET_PORT}"
        print "  Start server first: bin/simple run /tmp/http_bench.spl"
        return

    print "  Warmup response status: {warmup.0}"
    print ""

    print "--- Single Range ---"
    bench_range_requests("/1kb.html", "bytes=0-99", "First 100 bytes")
    bench_range_requests("/1kb.html", "bytes=500-999", "Middle 500 bytes")
    bench_range_requests("/1kb.html", "bytes=900-", "Last bytes (open-ended)")

    print ""
    print "--- Full File (no range, baseline) ---"
    val start = rt_time_ms()
    var ok = 0
    var j = 0
    while j < ITERATIONS:
        val fd = tcp_backend_connect(TARGET_HOST, TARGET_PORT)
        if fd >= 0:
            tcp_backend_write_text(fd, "GET /1kb.html HTTP/1.1\r\nHost: localhost\r\nConnection: close\r\n\r\n")
            val resp = tcp_backend_read_text(fd, 8192)
            tcp_backend_close(fd)
            if resp.len() > 0:
                ok = ok + 1
        j = j + 1
    val elapsed = rt_time_ms() - start
    val rps = if elapsed > 0: (ok * 1000) / elapsed else: 0
    print "  Full file: {ok}/{ITERATIONS} ok, {elapsed}ms, {rps} req/s"

    print ""
    print "=== Done ==="

main()
