# Compiler Performance Baseline Tests
#
# **Feature IDs:** Performance Audit Round 1
# **Category:** Performance | Testing
# **Status:** Implemented
#
# Measures wall-clock microseconds for critical compiler hot-path operations.
# Uses rt_time_now_unix_micros() for timing.
# Note: interpreter mode only verifies file loading (it block bodies don't execute).

extern fn rt_time_now_unix_micros() -> i64
extern fn rt_current_time_ms() -> i64

fn check(v):
    expect(v).to_equal(true)

# =========================================================================
# Struct field access benchmark
# =========================================================================

struct BenchPoint:
    x: i64
    y: i64
    z: i64
    w: i64
    r: i64
    g: i64
    b: i64
    a: i64
    u: i64
    v: i64

fn bench_struct_field_access() -> bool:
    """Access fields on a 10-field struct 1000 times, measure total microseconds."""
    val p = BenchPoint(x: 1, y: 2, z: 3, w: 4, r: 5, g: 6, b: 7, a: 8, u: 9, v: 10)
    val start = rt_time_now_unix_micros()
    var sum: i64 = 0
    var i: i64 = 0
    while i < 1000:
        sum = sum + p.x + p.y + p.z + p.w + p.r + p.g + p.b + p.a + p.u + p.v
        i = i + 1
    val elapsed = rt_time_now_unix_micros() - start
    print "[perf] struct_field_access: {elapsed} us for 1000 iterations (sum={sum})"
    # Should complete in reasonable time - 10 seconds max
    elapsed < 10000000

# =========================================================================
# Array operations benchmark
# =========================================================================

fn bench_array_push() -> bool:
    """Push 1000 elements, measure total microseconds."""
    val start = rt_time_now_unix_micros()
    var arr: [i64] = []
    var i: i64 = 0
    while i < 1000:
        arr.push(i)
        i = i + 1
    val elapsed = rt_time_now_unix_micros() - start
    print "[perf] array_push: {elapsed} us for 1000 pushes (len={arr.len()})"
    elapsed < 10000000

fn bench_array_slice() -> bool:
    """Slice a 1000-element array 100 times, measure total microseconds."""
    var arr: [i64] = []
    var i: i64 = 0
    while i < 1000:
        arr.push(i)
        i = i + 1
    val start = rt_time_now_unix_micros()
    var sum: i64 = 0
    i = 0
    while i < 100:
        val sl = arr[i:i + 10]
        sum = sum + sl.len()
        i = i + 1
    val elapsed = rt_time_now_unix_micros() - start
    print "[perf] array_slice: {elapsed} us for 100 slices (sum={sum})"
    elapsed < 10000000

# =========================================================================
# Dict operations benchmark
# =========================================================================

fn bench_dict_lookup() -> bool:
    """Insert and lookup 500 dict entries, measure total microseconds."""
    var d: {text: i64} = {}
    var i: i64 = 0
    while i < 500:
        d["key_" + i.to_string()] = i
        i = i + 1
    val start = rt_time_now_unix_micros()
    var sum: i64 = 0
    i = 0
    while i < 500:
        val key = "key_" + i.to_string()
        if d.contains_key(key):
            sum = sum + d[key]
        i = i + 1
    val elapsed = rt_time_now_unix_micros() - start
    print "[perf] dict_lookup: {elapsed} us for 500 lookups (sum={sum})"
    elapsed < 10000000

# =========================================================================
# String operations benchmark
# =========================================================================

fn bench_string_substring() -> bool:
    """Substring extraction 1000 times, measure total microseconds."""
    val base = "the_quick_brown_fox_jumps_over_the_lazy_dog_0123456789"
    val start = rt_time_now_unix_micros()
    var total_len: i64 = 0
    var i: i64 = 0
    while i < 1000:
        val sub = base.substring(4, 15)
        total_len = total_len + sub.len()
        i = i + 1
    val elapsed = rt_time_now_unix_micros() - start
    print "[perf] string_substring: {elapsed} us for 1000 substrings (total_len={total_len})"
    elapsed < 10000000

# =========================================================================
# Test execution
# =========================================================================

describe "Compiler Performance Baseline":
    """
    # Compiler Performance Baseline

    Measures wall-clock time for critical operations to track regressions.
    All thresholds are generous (10s) — the goal is detecting order-of-magnitude
    regressions, not micro-benchmarking.

    ## Operations Tested
    - Struct field access (10-field struct, 1000 iterations)
    - Array push (1000 elements)
    - Array slice (100 slices on 1000-element array)
    - Dict insert + lookup (500 entries)
    - String substring (1000 extractions)
    """

    it "struct field access completes within threshold":
        check(bench_struct_field_access())

    it "array push completes within threshold":
        check(bench_array_push())

    it "array slice completes within threshold":
        check(bench_array_slice())

    it "dict lookup completes within threshold":
        check(bench_dict_lookup())

    it "string substring completes within threshold":
        check(bench_string_substring())
