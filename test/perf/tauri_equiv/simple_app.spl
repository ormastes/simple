# Simple GUI App Benchmark
#
# Equivalent desktop app fixture for Simple GUI vs Rust+Tauri comparison.
# Implements the 9 workflow probes required by NFR 2B / Workstream 9.
#
# Run:
#   bin/simple run test/perf/tauri_equiv/simple_app.spl [--workflow=<name>] [--iters=<n>]
#
# Output format (one line per sample):
#   [tauri-equiv] workflow=<name> elapsed_us=<N> rss_kb=<N>
#
# Aggregation is done by workflow_driver.spl.
# ============================================================================

use std.io.{print, time_now_unix_micros, args_get}
use std.io.{file_exists, file_read, shell_int, shell_output_trimmed}
use std.io.{process_exit}
use nogc_sync_mut.io.window_ffi.{
    EventLoop, Window,
    event_loop_create, event_loop_is_valid,
    window_create, window_create_with_config, window_destroy,
    WindowConfig, window_show, window_hide,
    rt_sdl2_init, rt_sdl2_quit,
    rt_sdl2_create_window, rt_sdl2_destroy_window,
    rt_sdl2_show_window, rt_sdl2_hide_window,
    rt_sdl2_set_window_size, rt_sdl2_get_window_width,
    rt_sdl2_get_window_height, rt_sdl2_present_rgba,
    rt_sdl2_poll_event, rt_sdl2_clear_quit,
    rt_sdl2_window_should_close
}
use nogc_sync_mut.timing.{time_now, time_elapsed_micros, Instant}

# ============================================================================
# Constants
# ============================================================================

val WARMUP_ITERS: i64 = 3
val DEFAULT_ITERS: i64 = 20
val IDLE_DURATION_MS: i64 = 10000  # 10 seconds idle
val SCROLL_ROWS: i64 = 10000
val WINDOW_WIDTH: i64 = 1280
val WINDOW_HEIGHT: i64 = 800
val CHILD_WIDTH: i64 = 640
val CHILD_HEIGHT: i64 = 480

# ============================================================================
# Memory measurement (Linux /proc/self/status)
# ============================================================================

fn read_rss_kb() -> i64:
    """Read current process RSS from /proc/self/status. Returns 0 if unavailable."""
    val path = "/proc/self/status"
    if not file_exists(path):
        0
    else:
        val content = file_read(path)
        # Find "VmRSS:" line
        var i: i64 = 0
        var found: i64 = -1
        val needle = "VmRSS:"
        val nlen: i64 = 6
        val clen = content.length()
        while i < clen - nlen:
            if content.substring(i, i + nlen) == needle:
                found = i
                i = clen  # break
            i = i + 1
        if found < 0:
            0
        else:
            # Skip "VmRSS:" and whitespace, then read digits
            var j = found + nlen
            while j < clen and content.char_at(j) == ' ':
                j = j + 1
            var num_str = ""
            while j < clen and content.char_at(j) >= '0' and content.char_at(j) <= '9':
                num_str = num_str + content.char_at(j).to_text()
                j = j + 1
            if num_str == "":
                0
            else:
                num_str.to_i64()

# ============================================================================
# Percentile helper
# ============================================================================

fn percentile_of(samples: [i64], pct: i64) -> i64:
    """Return pct-th percentile from sorted samples array (0..100)."""
    val n = samples.length()
    if n == 0:
        0
    else:
        val idx = (n * pct) / 100
        val clamped = if idx >= n: n - 1 else idx
        samples[clamped]

fn sort_ascending(samples: [i64]) -> [i64]:
    """Insertion sort — avoids stdlib dependency."""
    val n = samples.length()
    var result: [i64] = []
    var i: i64 = 0
    while i < n:
        result = result.push(samples[i])
        i = i + 1
    # In-place insertion sort via index swaps
    var outer: i64 = 1
    while outer < n:
        var inner = outer
        while inner > 0 and result[inner - 1] > result[inner]:
            val tmp = result[inner]
            result = result.set(inner, result[inner - 1])
            result = result.set(inner - 1, tmp)
            inner = inner - 1
        outer = outer + 1
    result

# ============================================================================
# Output helpers
# ============================================================================

fn emit(workflow: text, elapsed_us: i64, rss_kb: i64):
    print "[tauri-equiv] workflow={workflow} elapsed_us={elapsed_us} rss_kb={rss_kb}"

fn emit_fps(workflow: text, fps: i64, dropped: i64, rss_kb: i64):
    print "[tauri-equiv] workflow={workflow} fps={fps} dropped_frames={dropped} rss_kb={rss_kb}"

fn emit_idle(workflow: text, cpu_pct_x100: i64, rss_kb: i64):
    print "[tauri-equiv] workflow={workflow} cpu_pct_x100={cpu_pct_x100} rss_kb={rss_kb}"

fn emit_summary(workflow: text, p50_us: i64, p95_us: i64, rss_kb: i64):
    print "[tauri-equiv-summary] workflow={workflow} p50_us={p50_us} p95_us={p95_us} rss_kb={rss_kb}"

# ============================================================================
# SDL2 availability guard
# ============================================================================

fn sdl2_init_or_skip() -> bool:
    """Initialize SDL2. Returns false if SDL2 is not available (CI stub mode)."""
    val rc = rt_sdl2_init()
    rc == 1

# ============================================================================
# Workflow 1: cold_start
#
# Time from process start to first SDL2 window present.
# The `t0` is captured at the top of main() and passed in.
# ============================================================================

fn bench_cold_start(t0: Instant, el: EventLoop, iters: i64) -> [i64]:
    """Measure time from process epoch (t0) to first window present."""
    var samples: [i64] = []
    var iter: i64 = 0
    while iter < iters:
        val win = window_create(el, WINDOW_WIDTH, WINDOW_HEIGHT, "simple-bench-coldstart")
        if win.is_valid:
            # Fill a minimal pixel buffer and present once
            var pixels: [i64] = []
            var pi: i64 = 0
            while pi < WINDOW_WIDTH * WINDOW_HEIGHT:
                pixels = pixels.push(255 * 16777216 + 255 * 65536 + 255 * 256 + 255)  # white RGBA
                pi = pi + 1
            rt_sdl2_present_rgba(win.handle, pixels, WINDOW_WIDTH, WINDOW_HEIGHT)
            val elapsed = time_elapsed_micros(t0)
            window_destroy(win)
            samples = samples.push(elapsed)
        iter = iter + 1
    samples

# ============================================================================
# Workflow 2: new_window
#
# Time to create a child window and show content.
# ============================================================================

fn bench_new_window(el: EventLoop, iters: i64) -> [i64]:
    """Measure create + show + present cycle for a child window."""
    var samples: [i64] = []
    var iter: i64 = 0
    while iter < iters:
        val t0 = time_now()
        val win = window_create(el, CHILD_WIDTH, CHILD_HEIGHT, "simple-bench-child")
        if win.is_valid:
            rt_sdl2_show_window(win.handle)
            # Minimal present to mark "first paint"
            var pixels: [i64] = []
            var pi: i64 = 0
            while pi < CHILD_WIDTH * CHILD_HEIGHT:
                pixels = pixels.push(200 * 16777216 + 220 * 65536 + 255 * 256 + 255)
                pi = pi + 1
            rt_sdl2_present_rgba(win.handle, pixels, CHILD_WIDTH, CHILD_HEIGHT)
            val elapsed = time_elapsed_micros(t0)
            window_destroy(win)
            samples = samples.push(elapsed)
        iter = iter + 1
    samples

# ============================================================================
# Workflow 3: close_window
#
# Time to destroy a window cleanly.
# ============================================================================

fn bench_close_window(el: EventLoop, iters: i64) -> [i64]:
    """Measure window_destroy latency."""
    var samples: [i64] = []
    var iter: i64 = 0
    while iter < iters:
        val win = window_create(el, CHILD_WIDTH, CHILD_HEIGHT, "simple-bench-close")
        if win.is_valid:
            rt_sdl2_show_window(win.handle)
            val t0 = time_now()
            window_destroy(win)
            val elapsed = time_elapsed_micros(t0)
            samples = samples.push(elapsed)
        iter = iter + 1
    samples

# ============================================================================
# Workflow 4: resize
#
# Time for resize + relayout (pixel buffer realloc) + repaint cycle.
# ============================================================================

fn bench_resize(el: EventLoop, iters: i64) -> [i64]:
    """Measure resize + repaint cycle."""
    var samples: [i64] = []
    val win = window_create(el, WINDOW_WIDTH, WINDOW_HEIGHT, "simple-bench-resize")
    if not win.is_valid:
        []
    else:
        rt_sdl2_show_window(win.handle)
        var iter: i64 = 0
        while iter < iters:
            val new_w = WINDOW_WIDTH + (iter & 15) * 10
            val new_h = WINDOW_HEIGHT + (iter & 7) * 10
            val t0 = time_now()
            rt_sdl2_set_window_size(win.handle, new_w, new_h)
            # Reallocate and repaint at new size
            var pixels: [i64] = []
            var pi: i64 = 0
            while pi < new_w * new_h:
                pixels = pixels.push(180 * 16777216 + 180 * 65536 + 200 * 256 + 255)
                pi = pi + 1
            rt_sdl2_present_rgba(win.handle, pixels, new_w, new_h)
            val elapsed = time_elapsed_micros(t0)
            samples = samples.push(elapsed)
            iter = iter + 1
        window_destroy(win)
        samples

# ============================================================================
# Workflow 5: scroll
#
# Continuous scroll of SCROLL_ROWS rows — report FPS and dropped frames.
# One "frame" = shift pixel buffer by one row height and re-present.
# ============================================================================

fn bench_scroll(el: EventLoop, iters: i64) -> [i64]:
    """
    Simulate scrolling SCROLL_ROWS rows.
    Returns per-frame elapsed_us samples.
    """
    var samples: [i64] = []
    val win = window_create(el, WINDOW_WIDTH, WINDOW_HEIGHT, "simple-bench-scroll")
    if not win.is_valid:
        []
    else:
        rt_sdl2_show_window(win.handle)
        val row_h: i64 = 20  # pixels per row
        val rows_visible = WINDOW_HEIGHT / row_h
        var scroll_offset: i64 = 0
        var frame: i64 = 0
        val total_frames = if iters > SCROLL_ROWS: SCROLL_ROWS else iters
        while frame < total_frames:
            val t0 = time_now()
            scroll_offset = scroll_offset + row_h
            # Build scrolled framebuffer: alternate row colors
            var pixels: [i64] = []
            var row: i64 = 0
            while row < rows_visible:
                val color = if (row + scroll_offset / row_h) & 1 == 0:
                    240 * 16777216 + 240 * 65536 + 255 * 256 + 255
                else:
                    255 * 16777216 + 255 * 65536 + 255 * 256 + 255
                var col: i64 = 0
                while col < WINDOW_WIDTH:
                    pixels = pixels.push(color)
                    col = col + 1
                row = row + 1
            rt_sdl2_present_rgba(win.handle, pixels, WINDOW_WIDTH, rows_visible * row_h)
            val elapsed = time_elapsed_micros(t0)
            samples = samples.push(elapsed)
            frame = frame + 1
        window_destroy(win)
        samples

# ============================================================================
# Workflow 6: route_change
#
# Time for full view swap (clear + repaint with different content).
# ============================================================================

fn bench_route_change(el: EventLoop, iters: i64) -> [i64]:
    """Measure full view clear + repaint representing a route/page switch."""
    var samples: [i64] = []
    val win = window_create(el, WINDOW_WIDTH, WINDOW_HEIGHT, "simple-bench-route")
    if not win.is_valid:
        []
    else:
        rt_sdl2_show_window(win.handle)
        var iter: i64 = 0
        while iter < iters:
            val t0 = time_now()
            # Simulate route switch: fill with alternating page color
            val base_color = if iter & 1 == 0:
                100 * 16777216 + 149 * 65536 + 237 * 256 + 255  # cornflower blue
            else:
                240 * 16777216 + 248 * 65536 + 255 * 256 + 255  # alice blue
            var pixels: [i64] = []
            var pi: i64 = 0
            while pi < WINDOW_WIDTH * WINDOW_HEIGHT:
                pixels = pixels.push(base_color)
                pi = pi + 1
            rt_sdl2_present_rgba(win.handle, pixels, WINDOW_WIDTH, WINDOW_HEIGHT)
            val elapsed = time_elapsed_micros(t0)
            samples = samples.push(elapsed)
            iter = iter + 1
        window_destroy(win)
        samples

# ============================================================================
# Workflow 7: ipc_roundtrip
#
# In-process channel: send message + receive response.
# Models the Tauri command pattern (frontend → backend → frontend).
# ============================================================================

struct IpcMessage:
    """Simple in-process IPC message."""
    id: i64
    payload: i64

struct IpcChannel:
    """Minimal bounded single-producer single-consumer channel stub."""
    pending_id: i64
    pending_payload: i64
    has_pending: bool

fn ipc_channel_new() -> IpcChannel:
    IpcChannel(pending_id: 0, pending_payload: 0, has_pending: false)

fn ipc_send(ch: IpcChannel, msg: IpcMessage) -> IpcChannel:
    IpcChannel(pending_id: msg.id, pending_payload: msg.payload, has_pending: true)

fn ipc_recv(ch: IpcChannel) -> (IpcChannel, IpcMessage):
    if not ch.has_pending:
        (ch, IpcMessage(id: -1, payload: 0))
    else:
        val msg = IpcMessage(id: ch.pending_id, payload: ch.pending_payload)
        (IpcChannel(pending_id: 0, pending_payload: 0, has_pending: false), msg)

fn bench_ipc_roundtrip(iters: i64) -> [i64]:
    """Measure in-process IPC send + recv roundtrip latency."""
    var samples: [i64] = []
    var ch = ipc_channel_new()
    var iter: i64 = 0
    while iter < iters:
        val t0 = time_now()
        val msg = IpcMessage(id: iter, payload: iter * 7)
        ch = ipc_send(ch, msg)
        val (ch2, reply) = ipc_recv(ch)
        ch = ch2
        val elapsed = time_elapsed_micros(t0)
        # Use reply to prevent DCE
        if reply.id >= 0:
            samples = samples.push(elapsed)
        iter = iter + 1
    samples

# ============================================================================
# Workflow 8: event_broadcast
#
# Fan-out: one event dispatched to N listeners.
# Models Tauri event broadcast to multiple windows.
# ============================================================================

struct BroadcastEvent:
    kind: i64
    data: i64

fn bench_event_broadcast(n_listeners: i64, iters: i64) -> [i64]:
    """
    Measure time to dispatch one event to n_listeners handlers.
    Each handler does minimal work (accumulates checksum).
    """
    var samples: [i64] = []
    var checksum: i64 = 0
    var iter: i64 = 0
    while iter < iters:
        val evt = BroadcastEvent(kind: iter & 7, data: iter * 3)
        val t0 = time_now()
        var listener: i64 = 0
        while listener < n_listeners:
            # Simulate handler dispatch: accumulate to prevent DCE
            checksum = checksum + evt.data + listener
            listener = listener + 1
        val elapsed = time_elapsed_micros(t0)
        samples = samples.push(elapsed)
        iter = iter + 1
    # Print checksum to prevent DCE
    print "# event-broadcast checksum={checksum}"
    samples

# ============================================================================
# Workflow 9: idle
#
# Measure RSS after IDLE_DURATION_MS of idle (event pump but no work).
# CPU% is approximated by ratio of busy ticks vs wall clock.
# ============================================================================

fn bench_idle(el: EventLoop) -> (i64, i64):
    """
    Run idle event loop for IDLE_DURATION_MS.
    Returns (cpu_pct_x100, rss_kb).
    """
    val win = window_create(el, WINDOW_WIDTH, WINDOW_HEIGHT, "simple-bench-idle")
    if not win.is_valid:
        (0, read_rss_kb())
    else:
        rt_sdl2_show_window(win.handle)
        val start = time_now()
        var busy_us: i64 = 0
        val deadline_us = IDLE_DURATION_MS * 1000
        while time_elapsed_micros(start) < deadline_us:
            val poll_t0 = time_now()
            rt_sdl2_poll_event()
            busy_us = busy_us + time_elapsed_micros(poll_t0)
        val rss = read_rss_kb()
        window_destroy(win)
        val elapsed_us = time_elapsed_micros(start)
        val cpu_pct_x100 = (busy_us * 10000) / if elapsed_us > 0: elapsed_us else 1
        (cpu_pct_x100, rss)

# ============================================================================
# Per-workflow runner
# ============================================================================

fn run_workflow(name: text, el: EventLoop, iters: i64, t0_epoch: Instant):
    if name == "cold_start":
        val raw = bench_cold_start(t0_epoch, el, iters)
        val sorted = sort_ascending(raw)
        val rss = read_rss_kb()
        emit_summary("cold_start", percentile_of(sorted, 50), percentile_of(sorted, 95), rss)
        var i: i64 = 0
        while i < sorted.length():
            emit("cold_start", sorted[i], rss)
            i = i + 1
    else if name == "new_window":
        val raw = bench_new_window(el, iters)
        val sorted = sort_ascending(raw)
        val rss = read_rss_kb()
        emit_summary("new_window", percentile_of(sorted, 50), percentile_of(sorted, 95), rss)
        var i: i64 = 0
        while i < sorted.length():
            emit("new_window", sorted[i], rss)
            i = i + 1
    else if name == "close_window":
        val raw = bench_close_window(el, iters)
        val sorted = sort_ascending(raw)
        val rss = read_rss_kb()
        emit_summary("close_window", percentile_of(sorted, 50), percentile_of(sorted, 95), rss)
        var i: i64 = 0
        while i < sorted.length():
            emit("close_window", sorted[i], rss)
            i = i + 1
    else if name == "resize":
        val raw = bench_resize(el, iters)
        val sorted = sort_ascending(raw)
        val rss = read_rss_kb()
        emit_summary("resize", percentile_of(sorted, 50), percentile_of(sorted, 95), rss)
        var i: i64 = 0
        while i < sorted.length():
            emit("resize", sorted[i], rss)
            i = i + 1
    else if name == "scroll":
        val raw = bench_scroll(el, iters)
        val sorted = sort_ascending(raw)
        val rss = read_rss_kb()
        val n = sorted.length()
        val total_us: i64 = if n > 0: sorted[n - 1] * n else 0  # rough
        val fps = if total_us > 0: (n * 1000000) / total_us else 0
        val frame_budget_us: i64 = 16667  # 60 Hz
        var dropped: i64 = 0
        var di: i64 = 0
        while di < n:
            if sorted[di] > frame_budget_us:
                dropped = dropped + 1
            di = di + 1
        emit_fps("scroll", fps, dropped, rss)
        emit_summary("scroll", percentile_of(sorted, 50), percentile_of(sorted, 95), rss)
    else if name == "route_change":
        val raw = bench_route_change(el, iters)
        val sorted = sort_ascending(raw)
        val rss = read_rss_kb()
        emit_summary("route_change", percentile_of(sorted, 50), percentile_of(sorted, 95), rss)
    else if name == "ipc_roundtrip":
        val raw = bench_ipc_roundtrip(iters * 100)
        val sorted = sort_ascending(raw)
        val rss = read_rss_kb()
        emit_summary("ipc_roundtrip", percentile_of(sorted, 50), percentile_of(sorted, 95), rss)
    else if name == "event_broadcast":
        val raw = bench_event_broadcast(2, iters * 10)
        val sorted = sort_ascending(raw)
        val rss = read_rss_kb()
        emit_summary("event_broadcast", percentile_of(sorted, 50), percentile_of(sorted, 95), rss)
    else if name == "idle":
        val (cpu_pct_x100, rss) = bench_idle(el)
        emit_idle("idle", cpu_pct_x100, rss)
    else:
        print "# unknown workflow: {name}"

# ============================================================================
# Main
# ============================================================================

fn main():
    # Capture process epoch for cold_start measurement
    val t0_epoch = time_now()

    # Parse --workflow= and --iters= args
    val arg_list = args_get()
    var workflow = "all"
    var iters = DEFAULT_ITERS
    var ai: i64 = 0
    while ai < arg_list.length():
        val a = arg_list[ai]
        if a.starts_with("--workflow="):
            workflow = a.substring(11, a.length())
        else if a.starts_with("--iters="):
            iters = a.substring(8, a.length()).to_i64()
        ai = ai + 1

    print "# simple-app-bench renderer=sdl2 workflow={workflow} iters={iters}"

    # Init SDL2
    if not sdl2_init_or_skip():
        print "# SDL2 init failed — emitting stub results for CI"
        # Emit zero-latency stubs so report_spec.spl can parse output
        val workflows = ["cold_start", "new_window", "close_window", "resize",
                         "scroll", "route_change", "ipc_roundtrip", "event_broadcast"]
        var wi: i64 = 0
        while wi < workflows.length():
            emit_summary(workflows[wi], 0, 0, 0)
            wi = wi + 1
        emit_idle("idle", 0, 0)
        process_exit(0)

    val el = event_loop_create()

    if workflow == "all":
        val all_workflows = ["cold_start", "new_window", "close_window", "resize",
                             "scroll", "route_change", "ipc_roundtrip", "event_broadcast",
                             "idle"]
        var wi: i64 = 0
        while wi < all_workflows.length():
            run_workflow(all_workflows[wi], el, iters, t0_epoch)
            wi = wi + 1
    else:
        run_workflow(workflow, el, iters, t0_epoch)

    rt_sdl2_quit()
