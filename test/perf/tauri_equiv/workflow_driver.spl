# Simple GUI vs Tauri Workflow Driver
#
# Runs both benchmark apps, parses their [tauri-equiv-summary] lines,
# computes simple_vs_tauri_ratio for each workflow, and prints the
# comparison table.
#
# Run:
#   bin/simple run test/perf/tauri_equiv/workflow_driver.spl [--iters=<n>]
#
# The driver:
#   1. Spawns simple_app.spl and tauri_reference binary sequentially.
#   2. Parses their stdout for [tauri-equiv-summary] lines.
#   3. Computes ratios and emits the report table.
#   4. Exits non-zero if any NFR 2B ratio threshold is violated.
# ============================================================================

use std.io.{print, args_get, process_exit, shell_output_trimmed, shell_int}
use std.io.{file_exists}

# ============================================================================
# Constants — NFR 2B thresholds
# ============================================================================

# Workflows where Simple must be ≤ 1.25x Tauri p95
val RATIO_THRESHOLD_X100: i64 = 125  # 1.25 × 100

# ============================================================================
# Data structures
# ============================================================================

struct WorkflowResult:
    """Parsed result for one workflow from one app."""
    workflow: text
    p50_us: i64
    p95_us: i64
    rss_kb: i64
    is_idle: bool
    cpu_pct_x100: i64  # only for idle

struct ComparisonRow:
    """Side-by-side comparison for one workflow."""
    workflow: text
    simple_p50_us: i64
    simple_p95_us: i64
    tauri_p50_us: i64
    tauri_p95_us: i64
    simple_rss_kb: i64
    tauri_rss_kb: i64
    ratio_x100: i64          # (simple_p95 / tauri_p95) * 100; 0 if tauri=0
    nfr_pass: bool

# ============================================================================
# Output line parser
# ============================================================================

fn parse_field(line: text, key: text) -> text:
    """Extract value from 'key=value' substring in line."""
    val klen = key.length()
    val llen = line.length()
    var i: i64 = 0
    while i < llen - klen:
        if line.substring(i, i + klen) == key:
            # Find end of value (space or end of string)
            var j = i + klen
            while j < llen and line.char_at(j) != ' ':
                j = j + 1
            return line.substring(i + klen, j)
        i = i + 1
    ""

fn parse_i64_field(line: text, key: text) -> i64:
    val s = parse_field(line, key)
    if s == "":
        0
    else:
        s.to_i64()

fn parse_summary_line(line: text) -> WorkflowResult:
    """Parse a [tauri-equiv-summary] line into WorkflowResult."""
    WorkflowResult(
        workflow: parse_field(line, "workflow="),
        p50_us: parse_i64_field(line, "p50_us="),
        p95_us: parse_i64_field(line, "p95_us="),
        rss_kb: parse_i64_field(line, "rss_kb="),
        is_idle: false,
        cpu_pct_x100: 0
    )

fn parse_idle_line(line: text) -> WorkflowResult:
    """Parse a [tauri-equiv] workflow=idle line."""
    WorkflowResult(
        workflow: "idle",
        p50_us: 0,
        p95_us: 0,
        rss_kb: parse_i64_field(line, "rss_kb="),
        is_idle: true,
        cpu_pct_x100: parse_i64_field(line, "cpu_pct_x100=")
    )

fn extract_results(output: text) -> [WorkflowResult]:
    """Extract all summary + idle results from multiline output."""
    var results: [WorkflowResult] = []
    var i: i64 = 0
    val lines_raw = output.split("\n")
    while i < lines_raw.length():
        val line = lines_raw[i]
        if line.starts_with("[tauri-equiv-summary]"):
            results = results.push(parse_summary_line(line))
        else if line.starts_with("[tauri-equiv]") and line.contains("workflow=idle"):
            results = results.push(parse_idle_line(line))
        i = i + 1
    results

fn find_result(results: [WorkflowResult], name: text) -> WorkflowResult:
    """Find workflow result by name, or return zero result."""
    var i: i64 = 0
    while i < results.length():
        if results[i].workflow == name:
            return results[i]
        i = i + 1
    WorkflowResult(workflow: name, p50_us: 0, p95_us: 0, rss_kb: 0,
                   is_idle: false, cpu_pct_x100: 0)

# ============================================================================
# Ratio computation
# ============================================================================

fn compute_ratio_x100(simple_val: i64, tauri_val: i64) -> i64:
    """
    Returns (simple / tauri) * 100 as integer.
    Returns 0 if tauri_val is 0 (indeterminate).
    Returns 10000 (100x) if simple_val is huge and tauri_val tiny.
    """
    if tauri_val == 0:
        if simple_val == 0:
            100  # 1.00x — both zero, equal
        else:
            10000  # undefined — treat as worst case
    else:
        (simple_val * 100) / tauri_val

# ============================================================================
# Report printer
# ============================================================================

fn print_header():
    print ""
    print "=== Simple GUI vs Rust+Tauri — Workflow Benchmark Report ==="
    print ""
    print "Workflow          | simple_p50 | simple_p95 | tauri_p50  | tauri_p95  | simple_rss | tauri_rss  | ratio  | NFR"
    print "------------------|------------|------------|------------|------------|------------|------------|--------|----"

fn ratio_str(ratio_x100: i64) -> text:
    val integer = ratio_x100 / 100
    val frac = ratio_x100 - (integer * 100)
    if frac < 10:
        "{integer}.0{frac}x"
    else:
        "{integer}.{frac}x"

fn pad_right(s: text, width: i64) -> text:
    var result = s
    while result.length() < width:
        result = result + " "
    result

fn print_row(row: ComparisonRow):
    val nfr_mark = if row.nfr_pass: "PASS" else: "FAIL"
    val ratio_label = ratio_str(row.ratio_x100)
    print "{pad_right(row.workflow, 17)}| {pad_right(row.simple_p50_us.to_text() + "us", 11)}| {pad_right(row.simple_p95_us.to_text() + "us", 11)}| {pad_right(row.tauri_p50_us.to_text() + "us", 11)}| {pad_right(row.tauri_p95_us.to_text() + "us", 11)}| {pad_right(row.simple_rss_kb.to_text() + "KB", 11)}| {pad_right(row.tauri_rss_kb.to_text() + "KB", 11)}| {pad_right(ratio_label, 7)}| {nfr_mark}"

fn print_idle_row(simple_r: WorkflowResult, tauri_r: WorkflowResult):
    val simple_cpu = simple_r.cpu_pct_x100
    val tauri_cpu = tauri_r.cpu_pct_x100
    val rss_ratio = compute_ratio_x100(simple_r.rss_kb, tauri_r.rss_kb)
    # NFR 2B: Simple must be equal-or-better on idle memory OR cold_start
    val idle_rss_pass = rss_ratio <= 100  # simple_rss <= tauri_rss
    print "idle (CPU)        | {simple_cpu}           |            | {tauri_cpu}           |            | {simple_r.rss_kb}KB      | {tauri_r.rss_kb}KB      | {ratio_str(rss_ratio)}  | {if idle_rss_pass: "PASS" else: "—"}"

# ============================================================================
# Main comparison logic
# ============================================================================

fn build_comparison(simple_results: [WorkflowResult],
                    tauri_results: [WorkflowResult]) -> [ComparisonRow]:
    val workflows = ["cold_start", "new_window", "close_window", "resize",
                     "scroll", "route_change", "ipc_roundtrip", "event_broadcast"]
    var rows: [ComparisonRow] = []
    var i: i64 = 0
    while i < workflows.length():
        val name = workflows[i]
        val sr = find_result(simple_results, name)
        val tr = find_result(tauri_results, name)
        val ratio = compute_ratio_x100(sr.p95_us, tr.p95_us)
        # NFR 2B: within 1.25x (cold_start has additional "equal or better" check)
        val nfr_pass = ratio <= RATIO_THRESHOLD_X100
        rows = rows.push(ComparisonRow(
            workflow: name,
            simple_p50_us: sr.p50_us,
            simple_p95_us: sr.p95_us,
            tauri_p50_us: tr.p50_us,
            tauri_p95_us: tr.p95_us,
            simple_rss_kb: sr.rss_kb,
            tauri_rss_kb: tr.rss_kb,
            ratio_x100: ratio,
            nfr_pass: nfr_pass
        ))
        i = i + 1
    rows

fn check_nfr_2b(rows: [ComparisonRow],
                simple_idle: WorkflowResult,
                tauri_idle: WorkflowResult) -> bool:
    """
    NFR 2B gates:
    - Simple must be equal-or-better than Tauri on at least one of:
        cold_start p95  OR  idle RSS
    - All other workflow p95 ratios must be <= 1.25x
    Returns true if all gates pass.
    """
    var cold_start_ratio: i64 = 10000
    var ratio_violations: i64 = 0
    var i: i64 = 0
    while i < rows.length():
        val row = rows[i]
        if row.workflow == "cold_start":
            cold_start_ratio = row.ratio_x100
        if not row.nfr_pass:
            ratio_violations = ratio_violations + 1
        i = i + 1

    val idle_rss_ratio = compute_ratio_x100(simple_idle.rss_kb, tauri_idle.rss_kb)
    val equal_or_better = cold_start_ratio <= 100 or idle_rss_ratio <= 100

    print ""
    print "=== NFR 2B Summary ==="
    print "cold_start ratio : {ratio_str(cold_start_ratio)} (need ≤ 1.00x for 'equal or better')"
    print "idle RSS ratio   : {ratio_str(idle_rss_ratio)} (need ≤ 1.00x for 'equal or better')"
    print "equal-or-better gate : {if equal_or_better: "PASS" else: "FAIL"}"
    print "1.25x ratio violations : {ratio_violations}"
    print "overall NFR 2B : {if equal_or_better and ratio_violations == 0: "PASS" else: "FAIL"}"

    equal_or_better and ratio_violations == 0

fn run_app(cmd: text) -> text:
    """Run a shell command and return its stdout."""
    shell_output_trimmed(cmd)

# ============================================================================
# Main
# ============================================================================

fn main():
    val arg_list = args_get()
    var iters: i64 = 20
    var ai: i64 = 0
    while ai < arg_list.length():
        val a = arg_list[ai]
        if a.starts_with("--iters="):
            iters = a.substring(8, a.length()).to_i64()
        ai = ai + 1

    print "# workflow_driver: iters={iters}"
    print "# Running Simple GUI benchmark..."

    val simple_cmd = "bin/simple run test/perf/tauri_equiv/simple_app.spl --iters={iters}"
    val simple_out = run_app(simple_cmd)
    print "# Simple output captured ({simple_out.length()} chars)"

    print "# Running Tauri reference benchmark..."
    val tauri_bin = "test/perf/tauri_equiv/tauri_reference/target/release/tauri-bench"
    val tauri_cmd = if file_exists(tauri_bin):
        "{tauri_bin} --iters={iters}"
    else:
        # Fall back to cargo run in debug for CI environments without pre-built binary
        "cargo run --manifest-path test/perf/tauri_equiv/tauri_reference/Cargo.toml --quiet -- --iters={iters}"
    val tauri_out = run_app(tauri_cmd)
    print "# Tauri output captured ({tauri_out.length()} chars)"

    val simple_results = extract_results(simple_out)
    val tauri_results = extract_results(tauri_out)

    val rows = build_comparison(simple_results, tauri_results)
    val simple_idle = find_result(simple_results, "idle")
    val tauri_idle = find_result(tauri_results, "idle")

    print_header()
    var ri: i64 = 0
    while ri < rows.length():
        print_row(rows[ri])
        ri = ri + 1
    print_idle_row(simple_idle, tauri_idle)

    val all_pass = check_nfr_2b(rows, simple_idle, tauri_idle)

    if not all_pass:
        process_exit(1)
