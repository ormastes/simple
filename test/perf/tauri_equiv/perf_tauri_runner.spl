# Tauri-Equivalent Performance Runner
#
# Benchmarks Simple GUI app workflows against equivalent Tauri metrics.
# Simulates operations (no actual windowing needed).
#
# Run:
#   bin/simple run test/perf/tauri_equiv/perf_tauri_runner.spl
# ============================================================================

use std.io.{print}

extern fn rt_time_now_micros() -> i64

# ============================================================================
# WorkflowMetrics
# ============================================================================

struct WorkflowMetrics:
    name: text
    p50_us: i64
    p95_us: i64
    rss_kb: i64
    idle_cpu_pct: i64
    samples: [i64]

fn make_workflow_metrics(name: text) -> WorkflowMetrics:
    WorkflowMetrics(
        name: name,
        p50_us: 0,
        p95_us: 0,
        rss_kb: 0,
        idle_cpu_pct: 0,
        samples: []
    )

fn wm_record(m: WorkflowMetrics, latency_us: i64) -> WorkflowMetrics:
    WorkflowMetrics(
        name: m.name,
        p50_us: m.p50_us,
        p95_us: m.p95_us,
        rss_kb: m.rss_kb,
        idle_cpu_pct: m.idle_cpu_pct,
        samples: m.samples.push(latency_us)
    )

fn percentile(sorted: [i64], pct: i64) -> i64:
    val n = sorted.length()
    if n == 0:
        return 0
    val idx = (n * pct) / 100
    val clamped = if idx >= n: n - 1 else: idx
    sorted[clamped]

fn sort_samples(arr: [i64]) -> [i64]:
    # Insertion sort (small N perf benchmarks)
    var result = arr
    var i: i64 = 1
    while i < result.length():
        val key = result[i]
        var j = i - 1
        while j >= 0 and result[j] > key:
            result = result.set(j + 1, result[j])
            j = j - 1
        result = result.set(j + 1, key)
        i = i + 1
    result

fn wm_finalize(m: WorkflowMetrics) -> WorkflowMetrics:
    val sorted = sort_samples(m.samples)
    WorkflowMetrics(
        name: m.name,
        p50_us: percentile(sorted, 50),
        p95_us: percentile(sorted, 95),
        rss_kb: m.rss_kb,
        idle_cpu_pct: m.idle_cpu_pct,
        samples: m.samples
    )

fn wm_summary(m: WorkflowMetrics) -> text:
    "[tauri-equiv-summary] workflow={m.name} p50_us={m.p50_us} p95_us={m.p95_us} rss_kb={m.rss_kb} idle_cpu_pct={m.idle_cpu_pct}"

# ============================================================================
# TauriEquivRunner
# ============================================================================

struct TauriEquivRunner:
    renderer_identity: text
    tauri_renderer: text
    workflow_count: i64

fn make_tauri_equiv_runner(renderer: text) -> TauriEquivRunner:
    TauriEquivRunner(
        renderer_identity: renderer,
        tauri_renderer: "webkit",
        workflow_count: 0
    )

val BENCH_ITERS: i64 = 20

fn do_bench(name: text, simulate_work_us: i64) -> WorkflowMetrics:
    var m = make_workflow_metrics(name)
    var i: i64 = 0
    while i < BENCH_ITERS:
        val t0 = rt_time_now_micros()
        # Simulate work: spin until simulate_work_us elapsed
        var elapsed: i64 = 0
        while elapsed < simulate_work_us:
            elapsed = rt_time_now_micros() - t0
        val t1 = rt_time_now_micros()
        m = wm_record(m, t1 - t0)
        i = i + 1
    wm_finalize(m)

fn runner_bench_startup(r: TauriEquivRunner) -> WorkflowMetrics:
    do_bench("cold_start", 5000)

fn runner_bench_new_window(r: TauriEquivRunner) -> WorkflowMetrics:
    do_bench("new_window", 1000)

fn runner_bench_close_window(r: TauriEquivRunner) -> WorkflowMetrics:
    do_bench("close_window", 500)

fn runner_bench_resize(r: TauriEquivRunner, w: i64, h: i64) -> WorkflowMetrics:
    do_bench("resize", 800)

fn runner_bench_scroll(r: TauriEquivRunner, distance: i64) -> WorkflowMetrics:
    do_bench("scroll", 2000)

fn runner_bench_route_change(r: TauriEquivRunner) -> WorkflowMetrics:
    do_bench("route_change", 1500)

fn runner_bench_ipc_roundtrip(r: TauriEquivRunner) -> WorkflowMetrics:
    do_bench("ipc_roundtrip", 300)

fn runner_bench_event_broadcast(r: TauriEquivRunner, count: i64) -> WorkflowMetrics:
    do_bench("event_broadcast", 600)

fn runner_bench_idle(r: TauriEquivRunner) -> WorkflowMetrics:
    var m = make_workflow_metrics("idle")
    m = wm_record(m, 0)
    WorkflowMetrics(
        name: m.name,
        p50_us: 0,
        p95_us: 0,
        rss_kb: 0,
        idle_cpu_pct: 0,
        samples: m.samples
    )

fn runner_full_report(r: TauriEquivRunner) -> text:
    val startup   = runner_bench_startup(r)
    val new_win   = runner_bench_new_window(r)
    val close_win = runner_bench_close_window(r)
    val resize    = runner_bench_resize(r, 1920, 1080)
    val scroll    = runner_bench_scroll(r, 1000)
    val route     = runner_bench_route_change(r)
    val ipc       = runner_bench_ipc_roundtrip(r)
    val broadcast = runner_bench_event_broadcast(r, 10)
    val idle      = runner_bench_idle(r)

    "=== Full Report: {r.renderer_identity} vs {r.tauri_renderer} ===\n" +
    wm_summary(startup) + "\n" +
    wm_summary(new_win) + "\n" +
    wm_summary(close_win) + "\n" +
    wm_summary(resize) + "\n" +
    wm_summary(scroll) + "\n" +
    wm_summary(route) + "\n" +
    wm_summary(ipc) + "\n" +
    wm_summary(broadcast) + "\n" +
    wm_summary(idle)

# ============================================================================
# Main
# ============================================================================

fn main():
    print("=== Tauri-Equivalent Performance Runner ===")
    val runner = make_tauri_equiv_runner("simple_cpu")

    val startup = runner_bench_startup(runner)
    print(wm_summary(startup))

    val win = runner_bench_new_window(runner)
    print(wm_summary(win))

    val resize = runner_bench_resize(runner, 1920, 1080)
    print(wm_summary(resize))

    val ipc = runner_bench_ipc_roundtrip(runner)
    print(wm_summary(ipc))

    val idle = runner_bench_idle(runner)
    print(wm_summary(idle))

    print(runner_full_report(runner))
    print("DONE")
