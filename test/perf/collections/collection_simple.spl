extern fn rt_time_now_unix_micros() -> i64

fn data_size() -> u64:
    65536u64

fn traverse_iters() -> u64:
    1800u64

fn push_size() -> u64:
    32768u64

fn push_iters() -> u64:
    120u64

fn set_size() -> u64:
    1024u64

fn set_iters() -> u64:
    200u64

fn make_data() -> [u64]:
    var out: [u64] = []
    var i = 0u64
    while i < data_size():
        out.push((i * 131u64 + 17u64) & 0xffffu64)
        i = i + 1u64
    out

fn report(bench: text, ops: u64, micros_in: i64, checksum: u64):
    var micros = micros_in
    if micros <= 0:
        micros = 1
    val ops_per_ms = (ops * 1000u64) / micros.to_u64()
    print "[collectionbench] lang=simple bench={bench} ops={ops} micros={micros} ops_per_ms={ops_per_ms} checksum={checksum}"

fn bench_list_traverse(data: [u64]):
    var checksum = 0u64
    val start = rt_time_now_unix_micros()
    var iter = 0u64
    val length = data.len().to_u64()
    while iter < traverse_iters():
        var i = 0u64
        while i < length:
            checksum = checksum + (data[i] ^ iter)
            i = i + 1u64
        iter = iter + 1u64
    report("list_traverse", length * traverse_iters(), rt_time_now_unix_micros() - start, checksum)

fn bench_list_push():
    var checksum = 0u64
    val start = rt_time_now_unix_micros()
    var iter = 0u64
    while iter < push_iters():
        var data: [u64] = []
        var i = 0u64
        while i < push_size():
            val value = i ^ iter
            data.push(value)
            checksum = checksum + value
            i = i + 1u64
        iter = iter + 1u64
    report("list_push", push_size() * push_iters(), rt_time_now_unix_micros() - start, checksum)

fn make_set_keys() -> [u64]:
    var keys: [u64] = []
    var i = 0u64
    while i < set_size():
        keys.push((i * 131u64 + 7u64) | 1u64)
        i = i + 1u64
    keys

fn set_contains(keys: [u64], key: u64) -> bool:
    var slot = 0u64
    val length = keys.len().to_u64()
    while slot < length:
        if keys[slot] == key:
            return true
        slot = slot + 1u64
    false

fn bench_set_contains():
    val keys = make_set_keys()
    var checksum = 0u64
    val start = rt_time_now_unix_micros()
    var iter = 0u64
    while iter < set_iters():
        var i = 0u64
        while i < set_size():
            val key = (i * 131u64 + 7u64) | 1u64
            if set_contains(keys, key):
                checksum = checksum + (key ^ iter)
            i = i + 1u64
        iter = iter + 1u64
    report("set_contains", set_size() * set_iters(), rt_time_now_unix_micros() - start, checksum)

fn main():
    val data = make_data()
    bench_list_traverse(data)
    bench_list_push()
    bench_set_contains()
