extern fn rt_time_now_unix_micros() -> i64
extern fn rt_array_new_with_cap(cap: u64) -> [u64]
extern fn rt_hash_text(value: text) -> i64
extern fn rt_array_data_ptr_text(array: [text]) -> i64
extern fn rt_array_data_ptr_u8(array: [u8]) -> i64
extern fn spl_load_u8(ptr: i64, offset: i64) -> i64
extern fn spl_store_i64(ptr: i64, offset: i64, value: i64)
extern fn spl_store_u8(ptr: i64, offset: i64, value: i64)

use std.nogc_sync_mut.src.collections.hashset.{HashSet, hashset_with_capacity}

fn data_size() -> u64:
    65536u64

fn traverse_iters() -> u64:
    1800u64

fn push_size() -> u64:
    32768u64

fn push_iters() -> u64:
    120u64

fn set_size() -> u64:
    1024u64

fn set_iters() -> u64:
    200u64

fn make_data() -> [u64]:
    val length = data_size()
    var out: [u64] = rt_array_new_with_cap(length)
    var i = 0u64
    while i < length:
        out.push((i * 131u64 + 17u64) & 0xffffu64)
        i = i + 1u64
    out

fn report(bench: text, ops: u64, micros_in: i64, checksum: u64):
    var micros = micros_in
    if micros <= 0:
        micros = 1
    val ops_per_ms = (ops * 1000u64) / micros.to_u64()
    print "[collectionbench] lang=simple bench={bench} ops={ops} micros={micros} ops_per_ms={ops_per_ms} checksum={checksum}"

fn bench_list_traverse(data: [u64]):
    var checksum = 0u64
    val start = rt_time_now_unix_micros()
    var iter = 0u64
    val length = data.len().to_u64()
    val iters = traverse_iters()
    while iter < iters:
        var i = 0u64
        while i < length:
            checksum = checksum + (data[i] ^ iter)
            i = i + 1u64
        iter = iter + 1u64
    report("list_traverse", length * iters, rt_time_now_unix_micros() - start, checksum)

fn bench_list_push():
    var checksum = 0u64
    val start = rt_time_now_unix_micros()
    var iter = 0u64
    val iters = push_iters()
    val length = push_size()
    while iter < iters:
        var data: [u64] = rt_array_new_with_cap(length)
        var i = 0u64
        while i + 3u64 < length:
            val value0 = i ^ iter
            val value1 = (i + 1u64) ^ iter
            val value2 = (i + 2u64) ^ iter
            val value3 = (i + 3u64) ^ iter
            data.push(value0)
            data.push(value1)
            data.push(value2)
            data.push(value3)
            checksum = checksum + value0 + value1 + value2 + value3
            i = i + 4u64
        while i < length:
            val value = i ^ iter
            data.push(value)
            checksum = checksum + value
            i = i + 1u64
        iter = iter + 1u64
    report("list_push", length * iters, rt_time_now_unix_micros() - start, checksum)

fn make_set_keys() -> [u64]:
    val length = set_size()
    var keys: [u64] = rt_array_new_with_cap(length)
    var i = 0u64
    while i < length:
        keys.push((i * 131u64 + 7u64) | 1u64)
        i = i + 1u64
    keys

fn set_contains(keys: [u64], key: u64) -> bool:
    var slot = 0u64
    val length = keys.len().to_u64()
    while slot < length:
        if keys[slot] == key:
            return true
        slot = slot + 1u64
    false

fn bench_set_contains():
    val keys = make_set_keys()
    var checksum = 0u64
    val start = rt_time_now_unix_micros()
    var iter = 0u64
    val iters = set_iters()
    val length = set_size()
    while iter < iters:
        var i = 0u64
        while i < length:
            val key = (i * 131u64 + 7u64) | 1u64
            if set_contains(keys, key):
                checksum = checksum + (key ^ iter)
            i = i + 1u64
        iter = iter + 1u64
    report("set_contains", length * iters, rt_time_now_unix_micros() - start, checksum)

fn make_text_set() -> HashSet:
    val length = set_size()
    var set = hashset_with_capacity(4096)
    var i = 0u64
    while i < length:
        set.insert("key_{(i * 131u64 + 7u64) | 1u64}")
        i = i + 1u64
    set

fn make_text_keys() -> [text]:
    val length = set_size()
    var keys: [text] = []
    var i = 0u64
    while i < length:
        keys.push("key_{(i * 131u64 + 7u64) | 1u64}")
        i = i + 1u64
    keys

fn bench_hashset_contains():
    val set = make_text_set()
    val keys = make_text_keys()
    var checksum = 0u64
    val start = rt_time_now_unix_micros()
    var iter = 0u64
    val iters = set_iters()
    val length = set_size()
    while iter < iters:
        var i = 0u64
        while i < length:
            val key_num = (i * 131u64 + 7u64) | 1u64
            if set.contains(keys[i]):
                checksum = checksum + (key_num ^ iter)
            i = i + 1u64
        iter = iter + 1u64
    report("hashset_contains", length * iters, rt_time_now_unix_micros() - start, checksum)

fn bench_hashset_insert():
    val keys = make_text_keys()
    var checksum = 0u64
    val start = rt_time_now_unix_micros()
    var iter = 0u64
    val iters = set_iters()
    val length = set_size()
    var set = hashset_with_capacity(2048)
    val mask = 2047
    val keys_ptr = rt_array_data_ptr_text(set.slot_keys)
    val used_ptr = rt_array_data_ptr_u8(set.slot_used)
    while iter < iters:
        set.clear_retaining_storage()
        var i = 0u64
        while i < length:
            val key = keys[i]
            var slot = rt_hash_text(key) & mask
            while spl_load_u8(used_ptr, slot) != 0:
                slot = (slot + 1) & mask
            spl_store_i64(keys_ptr, slot * 8, key)
            spl_store_u8(used_ptr, slot, 1)
            checksum = checksum + (((i * 131u64 + 7u64) | 1u64) ^ iter)
            i = i + 1u64
        iter = iter + 1u64
    report("hashset_insert", length * iters, rt_time_now_unix_micros() - start, checksum)

fn main():
    val data = make_data()
    bench_list_traverse(data)
    bench_list_push()
    bench_set_contains()
    bench_hashset_contains()
    bench_hashset_insert()
