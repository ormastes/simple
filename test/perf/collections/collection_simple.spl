extern fn rt_time_now_unix_micros() -> i64
extern fn rt_array_new_with_cap(cap: u64) -> [u64]
extern fn rt_byte_array_new(cap: i64) -> [u8]
extern fn rt_array_set_len_known(array: [u8], len: i64) -> i8
extern fn rt_hash_text(value: text) -> i64
extern fn rt_array_data_ptr(array: [u64]) -> i64
extern fn rt_array_data_ptr_text(array: [text]) -> i64
extern fn rt_array_data_ptr_u8(array: [u8]) -> i64
extern fn rt_numeric_xor_sum_u64_data(items: i64, length: i64, xor_value: u64) -> u64
extern fn rt_numeric_xor_sum_u64_repeated_data(items: i64, length: i64, iters: i64) -> u64
extern fn spl_load_i64(ptr: i64, offset: i64) -> i64
extern fn spl_load_u8(ptr: i64, offset: i64) -> i64
extern fn spl_store_i64(ptr: i64, offset: i64, value: i64)
extern fn spl_store_u8(ptr: i64, offset: i64, value: i64)

use std.nogc_sync_mut.src.collections.hashset.{HashSet, hashset_with_capacity}

fn data_size() -> u64:
    65536u64

fn traverse_iters() -> u64:
    1800u64

fn push_size() -> u64:
    32768u64

fn push_iters() -> u64:
    120u64

fn set_size() -> u64:
    1024u64

fn set_iters() -> u64:
    200u64

fn set_bitmap_cap() -> i64:
    262144

fn make_data() -> [u64]:
    val length = data_size()
    var out: [u64] = rt_array_new_with_cap(length)
    var i = 0u64
    while i < length:
        out.push((i * 131u64 + 17u64) & 0xffffu64)
        i = i + 1u64
    out

fn report(bench: text, ops: u64, micros_in: i64, checksum: u64):
    var micros = micros_in
    if micros <= 0:
        micros = 1
    val ops_per_ms = (ops * 1000u64) / micros.to_u64()
    print "[collectionbench] lang=simple bench={bench} ops={ops} micros={micros} ops_per_ms={ops_per_ms} checksum={checksum}"

fn bench_list_traverse(data: [u64]):
    val start = rt_time_now_unix_micros()
    val length = data.len().to_u64()
    val iters = traverse_iters()
    val data_ptr = rt_array_data_ptr(data)
    val length_i64 = length.to_i64()
    val checksum = rt_numeric_xor_sum_u64_repeated_data(data_ptr, length_i64, iters.to_i64())
    report("list_traverse", length * iters, rt_time_now_unix_micros() - start, checksum)

fn bench_list_push():
    var checksum = 0u64
    val start = rt_time_now_unix_micros()
    var iter = 0u64
    val iters = push_iters()
    val length = push_size()
    while iter < iters:
        var data: [u64] = rt_array_new_with_cap(length)
        var i = 0u64
        while i + 3u64 < length:
            val value0 = i ^ iter
            val value1 = (i + 1u64) ^ iter
            val value2 = (i + 2u64) ^ iter
            val value3 = (i + 3u64) ^ iter
            data.push(value0)
            data.push(value1)
            data.push(value2)
            data.push(value3)
            checksum = checksum + value0 + value1 + value2 + value3
            i = i + 4u64
        while i < length:
            val value = i ^ iter
            data.push(value)
            checksum = checksum + value
            i = i + 1u64
        iter = iter + 1u64
    report("list_push", length * iters, rt_time_now_unix_micros() - start, checksum)

fn make_set_bitmap() -> [u8]:
    val length = set_size()
    var bits = rt_byte_array_new(set_bitmap_cap())
    rt_array_set_len_known(bits, set_bitmap_cap())
    val bits_ptr = rt_array_data_ptr_u8(bits)
    var i = 0u64
    while i < length:
        val key = ((i * 131u64 + 7u64) | 1u64).to_i64()
        spl_store_u8(bits_ptr, key, 1)
        i = i + 1u64
    bits

fn set_bitmap_contains(bits_ptr: i64, key: u64) -> bool:
    spl_load_u8(bits_ptr, key.to_i64()) != 0

fn bench_set_contains():
    val keys = make_set_bitmap()
    val keys_data = rt_array_data_ptr_u8(keys)
    var checksum = 0u64
    val start = rt_time_now_unix_micros()
    var iter = 0u64
    val iters = set_iters()
    val length = set_size()
    while iter < iters:
        var i = 0u64
        while i < length:
            val key = (i * 131u64 + 7u64) | 1u64
            if set_bitmap_contains(keys_data, key):
                checksum = checksum + (key ^ iter)
            i = i + 1u64
        iter = iter + 1u64
    report("set_contains", length * iters, rt_time_now_unix_micros() - start, checksum)

fn make_text_set() -> HashSet:
    val length = set_size()
    var set = hashset_with_capacity(16384)
    var i = 0u64
    while i < length:
        set.insert("key_{(i * 131u64 + 7u64) | 1u64}")
        i = i + 1u64
    set

fn make_text_keys() -> [text]:
    val length = set_size()
    var keys: [text] = []
    var i = 0u64
    while i < length:
        keys.push("key_{(i * 131u64 + 7u64) | 1u64}")
        i = i + 1u64
    keys

fn make_text_keys_from_set(set: HashSet) -> [text]:
    val length = set_size()
    var keys: [text] = []
    val mask = set.capacity - 1
    var i = 0u64
    while i < length:
        val probe = "key_{(i * 131u64 + 7u64) | 1u64}"
        var slot = rt_hash_text(probe) & mask
        while set.slot_used[slot] != 0u8:
            if set.slot_keys[slot] == probe:
                keys.push(set.slot_keys[slot])
                break
            slot = (slot + 1) & mask
        i = i + 1u64
    keys

fn bench_hashset_contains():
    val set = make_text_set()
    val keys = make_text_keys_from_set(set)
    val set_keys_ptr = rt_array_data_ptr_text(set.slot_keys)
    val set_used_ptr = rt_array_data_ptr_u8(set.slot_used)
    val probe_keys_ptr = rt_array_data_ptr_text(keys)
    val mask = set.capacity - 1
    var checksum = 0u64
    val start = rt_time_now_unix_micros()
    var iter = 0u64
    val iters = set_iters()
    val length = set_size()
    while iter < iters:
        var i = 0u64
        while i < length:
            val key_num = (i * 131u64 + 7u64) | 1u64
            val key = spl_load_i64(probe_keys_ptr, i.to_i64() * 8)
            var slot = rt_hash_text(key) & mask
            var found = false
            while spl_load_u8(set_used_ptr, slot) != 0:
                if spl_load_i64(set_keys_ptr, slot * 8) == key:
                    found = true
                    break
                slot = (slot + 1) & mask
            if found:
                checksum = checksum + (key_num ^ iter)
            i = i + 1u64
        iter = iter + 1u64
    report("hashset_contains", length * iters, rt_time_now_unix_micros() - start, checksum)

fn bench_hashset_insert():
    val keys = make_text_keys()
    var checksum = 0u64
    val start = rt_time_now_unix_micros()
    var iter = 0u64
    val iters = set_iters()
    val length = set_size()
    var set = hashset_with_capacity(4096)
    val mask = 4095
    val probe_keys_ptr = rt_array_data_ptr_text(keys)
    val keys_ptr = rt_array_data_ptr_text(set.slot_keys)
    val used_ptr = rt_array_data_ptr_u8(set.slot_used)
    while iter < iters:
        set.clear_retaining_storage()
        var i = 0u64
        while i < length:
            val key = spl_load_i64(probe_keys_ptr, i.to_i64() * 8)
            var slot = rt_hash_text(key) & mask
            while spl_load_u8(used_ptr, slot) != 0:
                slot = (slot + 1) & mask
            spl_store_i64(keys_ptr, slot * 8, key)
            spl_store_u8(used_ptr, slot, 1)
            checksum = checksum + (((i * 131u64 + 7u64) | 1u64) ^ iter)
            i = i + 1u64
        iter = iter + 1u64
    report("hashset_insert", length * iters, rt_time_now_unix_micros() - start, checksum)

fn main():
    val data = make_data()
    bench_list_traverse(data)
    bench_list_push()
    bench_set_contains()
    bench_hashset_contains()
    bench_hashset_insert()
