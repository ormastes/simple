#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../../.." && pwd)"
BENCH_DIR="$ROOT/test/perf/collections"
BUILD_DIR="$ROOT/build/perf/collections"
SIMPLE_BIN="${SIMPLE_BIN:-$ROOT/bin/simple}"
SIMPLE_NATIVE_RUNTIME_BUNDLE="${SIMPLE_NATIVE_RUNTIME_BUNDLE:-core-c}"
SIMPLE_COLLECTION_BENCH_SAMPLES="${SIMPLE_COLLECTION_BENCH_SAMPLES:-1}"
SIMPLE_COLLECTION_BENCH_MIN_C_RATIO="${SIMPLE_COLLECTION_BENCH_MIN_C_RATIO:-0.50}"
SIMPLE_COLLECTION_BENCH_MIN_RUST_RATIO="${SIMPLE_COLLECTION_BENCH_MIN_RUST_RATIO:-0.50}"
SIMPLE_COLLECTION_BENCH_ENFORCE="${SIMPLE_COLLECTION_BENCH_ENFORCE:-0}"

mkdir -p "$BUILD_DIR"

if [[ ! -x "$SIMPLE_BIN" && -x "$ROOT/src/compiler_rust/target/debug/simple" ]]; then
    SIMPLE_BIN="$ROOT/src/compiler_rust/target/debug/simple"
fi

echo "=================================================================="
echo "  Collection C/Rust/Simple Benchmark"
echo "=================================================================="
echo "Simple: $SIMPLE_BIN"
echo "Runtime bundle: $SIMPLE_NATIVE_RUNTIME_BUNDLE"
echo "Build:  $BUILD_DIR"
echo "Samples: $SIMPLE_COLLECTION_BENCH_SAMPLES"
echo "Warn below: C ${SIMPLE_COLLECTION_BENCH_MIN_C_RATIO}x, Rust ${SIMPLE_COLLECTION_BENCH_MIN_RUST_RATIO}x"
echo ""

gcc -O3 -march=native -std=c11 "$BENCH_DIR/collection_ref.c" -o "$BUILD_DIR/collection_c"
rustc -C opt-level=3 -C target-cpu=native "$BENCH_DIR/collection_ref.rs" -o "$BUILD_DIR/collection_rust"

run_samples() {
    local label="$1"
    local out_file="$2"
    shift 2
    rm -f "$out_file"
    local sample=1
    while [[ "$sample" -le "$SIMPLE_COLLECTION_BENCH_SAMPLES" ]]; do
        if [[ "$SIMPLE_COLLECTION_BENCH_SAMPLES" -gt 1 ]]; then
            echo "[collectionbench-sample] impl=$label sample=$sample/$SIMPLE_COLLECTION_BENCH_SAMPLES"
        fi
        "$@" | tee "$out_file.sample_$sample"
        cat "$out_file.sample_$sample" >> "$out_file"
        sample=$((sample + 1))
    done
}

median_ops_per_ms() {
    local out_file="$1"
    local bench="$2"
    grep "bench=$bench " "$out_file" \
        | sed -n 's/.*ops_per_ms=\([0-9][0-9]*\).*/\1/p' \
        | sort -n \
        | awk '
            { values[NR] = $1 }
            END {
                if (NR == 0) exit 1
                if (NR % 2 == 1) printf "%d", values[(NR + 1) / 2]
                else printf "%.0f", (values[NR / 2] + values[(NR / 2) + 1]) / 2
            }
        '
}

checksum_value() {
    local out_file="$1"
    local bench="$2"
    grep "bench=$bench " "$out_file" \
        | sed -n 's/.*checksum=\([0-9]*\).*/\1/p' \
        | sort -u \
        | awk '{ values[NR] = $1 } END { if (NR != 1) exit 1; print values[1] }'
}

ratio() {
    awk -v n="$1" -v d="$2" 'BEGIN { if (d == 0) printf "n/a"; else printf "%.2fx", n / d }'
}

ratio_below() {
    awk -v n="$1" -v d="$2" -v min="$3" 'BEGIN { if (d == 0) exit 1; exit ((n / d) < min ? 0 : 1) }'
}

echo "--- C reference ---"
run_samples c "$BUILD_DIR/c.out" "$BUILD_DIR/collection_c"

echo "--- Rust reference ---"
run_samples rust "$BUILD_DIR/rust.out" "$BUILD_DIR/collection_rust"

echo "--- Simple reference ---"
compile_log="$BUILD_DIR/simple_compile.log"
if SIMPLE_NATIVE_RUNTIME_BUNDLE="$SIMPLE_NATIVE_RUNTIME_BUNDLE" \
    "$SIMPLE_BIN" compile "$BENCH_DIR/collection_simple.spl" --native --cpu native --opt-level aggressive -o "$BUILD_DIR/collection_simple" >"$compile_log" 2>&1; then
    run_samples simple "$BUILD_DIR/simple.out" "$BUILD_DIR/collection_simple"
else
    echo "[collectionbench-note] simple_native_compile=failed log=$compile_log"
    sed -n '1,24p' "$compile_log"
    exit 1
fi

warnings="$BUILD_DIR/perf_warnings.txt"
rm -f "$warnings"
touch "$warnings"

echo "benchmark	c_ops_per_ms	rust_ops_per_ms	simple_ops_per_ms	simple_vs_c	simple_vs_rust"
for bench in list_traverse list_push set_contains hashset_contains; do
    c_sum="$(checksum_value "$BUILD_DIR/c.out" "$bench")"
    rust_sum="$(checksum_value "$BUILD_DIR/rust.out" "$bench")"
    simple_sum="$(checksum_value "$BUILD_DIR/simple.out" "$bench")"
    if [[ "$c_sum" != "$rust_sum" || "$c_sum" != "$simple_sum" ]]; then
        echo "[collectionbench-error] checksum mismatch bench=$bench c=$c_sum rust=$rust_sum simple=$simple_sum" >&2
        exit 1
    fi
    c_ops="$(median_ops_per_ms "$BUILD_DIR/c.out" "$bench")"
    rust_ops="$(median_ops_per_ms "$BUILD_DIR/rust.out" "$bench")"
    simple_ops="$(median_ops_per_ms "$BUILD_DIR/simple.out" "$bench")"
    printf "%s\t%s\t%s\t%s\t%s\t%s\n" \
        "$bench" "$c_ops" "$rust_ops" "$simple_ops" \
        "$(ratio "$simple_ops" "$c_ops")" "$(ratio "$simple_ops" "$rust_ops")"
    if ratio_below "$simple_ops" "$c_ops" "$SIMPLE_COLLECTION_BENCH_MIN_C_RATIO"; then
        echo "[collectionbench-warn] bench=$bench simple_vs_c=$(ratio "$simple_ops" "$c_ops") below=${SIMPLE_COLLECTION_BENCH_MIN_C_RATIO}x" >> "$warnings"
    fi
    if ratio_below "$simple_ops" "$rust_ops" "$SIMPLE_COLLECTION_BENCH_MIN_RUST_RATIO"; then
        echo "[collectionbench-warn] bench=$bench simple_vs_rust=$(ratio "$simple_ops" "$rust_ops") below=${SIMPLE_COLLECTION_BENCH_MIN_RUST_RATIO}x" >> "$warnings"
    fi
done | tee "$BUILD_DIR/speed_ratios.tsv"

if [[ -s "$warnings" ]]; then
    cat "$warnings"
    if [[ "$SIMPLE_COLLECTION_BENCH_ENFORCE" == "1" ]]; then
        echo "[collectionbench-error] speed ratio floor failed; set SIMPLE_COLLECTION_BENCH_ENFORCE=0 to warn only" >&2
        exit 1
    fi
fi

echo "[collectionbench-ok] checksum parity passed for list_traverse, list_push, set_contains, and hashset_contains"
