"""
B2 perf gate (compiler_bugs_for_crypto_2026-04-25.md):
  rt_bytes_alloc(n) must produce a 1 MiB zero-filled [u8] in <1 s,
  and 32 MiB in <30 s, in interpreter mode.

Avoids the per-element `buf.push(0u8)` loop that's quadratic in the
interpreter (memory: feedback_interpreter_bulk_buffer.md).
"""

extern fn rt_bytes_alloc(len: u64) -> [u8]
extern fn rt_time_now_unix_micros() -> i64

fn measure(label: text, n: u64):
    val t0 = rt_time_now_unix_micros()
    val buf = rt_bytes_alloc(n)
    val t1 = rt_time_now_unix_micros()
    val elapsed_ms = (t1 - t0) / 1000
    print "{label}: len={buf.len()} elapsed_ms={elapsed_ms}"

fn main():
    measure("1 MiB", 1048576)
    measure("4 MiB", 4194304)
    measure("32 MiB", 33554432)
