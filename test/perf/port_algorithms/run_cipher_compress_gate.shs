#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../../.." && pwd)"
SIMPLE_BIN="${SIMPLE_BIN:-$ROOT/src/compiler_rust/target/release/simple}"
SCOPE="${CIPHER_COMPRESS_SCOPE:-core}"
ALLOW_KNOWN_FAIL="${CIPHER_COMPRESS_ALLOW_KNOWN_FAIL:-0}"
CONTINUE_ON_FAIL="${CIPHER_COMPRESS_CONTINUE_ON_FAIL:-0}"

if [[ ! -x "$SIMPLE_BIN" ]]; then
    SIMPLE_BIN="$ROOT/bin/simple"
fi

core_specs=(
    "test/unit/lib/crypto/poly1305_rfc8439_spec.spl"
    "test/unit/os/crypto/chacha20_poly1305_spec.spl"
    "test/unit/lib/crypto/chacha20_poly1305_rfc8439_spec.spl"
    "test/unit/os/crypto/crc32_kat_spec.spl"
    "test/unit/os/crypto/adler32_spec.spl"
    "test/unit/lib/common/hash/adler32_spec.spl"
    "test/unit/lib/common/compress/deflate_spec.spl"
    "test/unit/lib/common/compress/gzip_spec.spl"
    "test/unit/lib/common/compress/lz4_spec.spl"
    "test/unit/lib/common/compress/snappy_spec.spl"
    "test/unit/lib/crypto/aes_gcm_rfc_vectors_spec.spl"
    "test/unit/lib/common/zstd_frame_variants_spec.spl"
    "test/unit/os/kernel/loader/zstd_decompress_spec.spl"
)

known_fail_specs=(
)

is_known_fail() {
    local spec="$1"
    local known
    for known in "${known_fail_specs[@]}"; do
        [[ "$spec" == "$known" ]] && return 0
    done
    return 1
}

discover_all_specs() {
    (
        cd "$ROOT"
        rg --files test/unit \
            | rg '(^|/)(crypto|compress|compression|huffman|lz77|zstd).*_spec\.spl$|/(crypto|compress|compression|huffman|lz77|zstd)[^/]*_spec\.spl$' \
            | sort
    )
}

list_specs() {
    local spec
    if [[ "$SCOPE" == "all" ]]; then
        discover_all_specs
    else
        for spec in "${core_specs[@]}"; do
            echo "$spec"
        done
    fi
}

if [[ "${1:-}" == "--list" ]]; then
    list_specs
    exit 0
fi

echo "=================================================================="
echo "  Cipher and Compression Algorithm Gate"
echo "=================================================================="
echo "Simple: $SIMPLE_BIN"
echo "Scope:  $SCOPE"
echo "Allow known failures: $ALLOW_KNOWN_FAIL"
echo ""

failures=0
skipped=0
passed=0

while IFS= read -r spec; do
    [[ -z "$spec" ]] && continue
    if [[ "$ALLOW_KNOWN_FAIL" == "1" ]] && is_known_fail "$spec"; then
        echo "[alg-gate-skip] known-fail $spec"
        skipped=$((skipped + 1))
        continue
    fi

    echo "[alg-gate-run] $spec"
    if SIMPLE_LIB="$ROOT/src" "$SIMPLE_BIN" test "$ROOT/$spec" --mode=interpreter --no-cache; then
        passed=$((passed + 1))
    else
        failures=$((failures + 1))
        echo "[alg-gate-fail] $spec" >&2
        if [[ "$CONTINUE_ON_FAIL" != "1" ]]; then
            break
        fi
    fi
done < <(list_specs)

echo ""
echo "[alg-gate-summary] passed=$passed skipped=$skipped failed=$failures"
if [[ "$failures" -ne 0 ]]; then
    exit 1
fi
