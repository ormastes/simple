# Pure Simple algorithm benchmark for Phase 6 port parity.

use os.crypto.xxhash.{xxhash64}

extern fn rt_time_now_unix_micros() -> i64

fn data_size() -> u64:
    65536u64

fn xxh_iters() -> u64:
    80u64

fn chacha_iters() -> u64:
    30u64

fn make_data(n: u64) -> [u8]:
    var out: [u8] = []
    var i: u64 = 0u64
    while i < n:
        out.push(((i * 131u64 + 17u64) & 0xFFu64).to_u8())
        i = i + 1u64
    out

fn make_empty_output(n: u64) -> [u8]:
    var out: [u8] = []
    var i: u64 = 0u64
    while i < n:
        out.push(0u8)
        i = i + 1u64
    out

fn checksum_bytes(data: [u8]) -> u64:
    var sum: u64 = 0u64
    var i: u64 = 0u64
    val n = data.len()
    while i + 8u64 <= n:
        sum = ((sum << 5u64) ^ (sum >> 2u64)) + data[i].to_u64()
        sum = ((sum << 5u64) ^ (sum >> 2u64)) + data[i + 1u64].to_u64()
        sum = ((sum << 5u64) ^ (sum >> 2u64)) + data[i + 2u64].to_u64()
        sum = ((sum << 5u64) ^ (sum >> 2u64)) + data[i + 3u64].to_u64()
        sum = ((sum << 5u64) ^ (sum >> 2u64)) + data[i + 4u64].to_u64()
        sum = ((sum << 5u64) ^ (sum >> 2u64)) + data[i + 5u64].to_u64()
        sum = ((sum << 5u64) ^ (sum >> 2u64)) + data[i + 6u64].to_u64()
        sum = ((sum << 5u64) ^ (sum >> 2u64)) + data[i + 7u64].to_u64()
        i = i + 8u64
    while i < n:
        sum = ((sum << 5u64) ^ (sum >> 2u64)) + data[i].to_u64()
        i = i + 1u64
    sum

fn chacha20_xor_words4_local(output: [u8], plaintext: [u8], pos: u64, word0: u32, word1: u32, word2: u32, word3: u32) -> u64:
    var p = pos
    output[p] = plaintext[p] ^ (word0 & 0xFFu32).to_u8()
    output[p + 1u64] = plaintext[p + 1u64] ^ ((word0 >> 8u32) & 0xFFu32).to_u8()
    output[p + 2u64] = plaintext[p + 2u64] ^ ((word0 >> 16u32) & 0xFFu32).to_u8()
    output[p + 3u64] = plaintext[p + 3u64] ^ ((word0 >> 24u32) & 0xFFu32).to_u8()
    p = p + 4u64
    output[p] = plaintext[p] ^ (word1 & 0xFFu32).to_u8()
    output[p + 1u64] = plaintext[p + 1u64] ^ ((word1 >> 8u32) & 0xFFu32).to_u8()
    output[p + 2u64] = plaintext[p + 2u64] ^ ((word1 >> 16u32) & 0xFFu32).to_u8()
    output[p + 3u64] = plaintext[p + 3u64] ^ ((word1 >> 24u32) & 0xFFu32).to_u8()
    p = p + 4u64
    output[p] = plaintext[p] ^ (word2 & 0xFFu32).to_u8()
    output[p + 1u64] = plaintext[p + 1u64] ^ ((word2 >> 8u32) & 0xFFu32).to_u8()
    output[p + 2u64] = plaintext[p + 2u64] ^ ((word2 >> 16u32) & 0xFFu32).to_u8()
    output[p + 3u64] = plaintext[p + 3u64] ^ ((word2 >> 24u32) & 0xFFu32).to_u8()
    p = p + 4u64
    output[p] = plaintext[p] ^ (word3 & 0xFFu32).to_u8()
    output[p + 1u64] = plaintext[p + 1u64] ^ ((word3 >> 8u32) & 0xFFu32).to_u8()
    output[p + 2u64] = plaintext[p + 2u64] ^ ((word3 >> 16u32) & 0xFFu32).to_u8()
    output[p + 3u64] = plaintext[p + 3u64] ^ ((word3 >> 24u32) & 0xFFu32).to_u8()
    p + 4u64

fn chacha20_xor_block_local(output: [u8], plaintext: [u8], counter: u32, start: u64) -> u64:
    val s0 = 0x61707865u32
    val s1 = 0x3320646eu32
    val s2 = 0x79622d32u32
    val s3 = 0x6b206574u32
    val s4 = 0x03020100u32
    val s5 = 0x07060504u32
    val s6 = 0x0b0a0908u32
    val s7 = 0x0f0e0d0cu32
    val s8 = 0x13121110u32
    val s9 = 0x17161514u32
    val s10 = 0x1b1a1918u32
    val s11 = 0x1f1e1d1cu32
    val s12 = counter
    val s13 = 0x09000000u32
    val s14 = 0x4a000000u32
    val s15 = 0u32

    var w0 = s0
    var w1 = s1
    var w2 = s2
    var w3 = s3
    var w4 = s4
    var w5 = s5
    var w6 = s6
    var w7 = s7
    var w8 = s8
    var w9 = s9
    var w10 = s10
    var w11 = s11
    var w12 = s12
    var w13 = s13
    var w14 = s14
    var w15 = s15

    var round: u64 = 0u64
    while round < 10u64:
        w0 = w0 + w4
        w12 = ((w12 ^ w0) << 16u32) | ((w12 ^ w0) >> 16u32)
        w8 = w8 + w12
        w4 = ((w4 ^ w8) << 12u32) | ((w4 ^ w8) >> 20u32)
        w0 = w0 + w4
        w12 = ((w12 ^ w0) << 8u32) | ((w12 ^ w0) >> 24u32)
        w8 = w8 + w12
        w4 = ((w4 ^ w8) << 7u32) | ((w4 ^ w8) >> 25u32)

        w1 = w1 + w5
        w13 = ((w13 ^ w1) << 16u32) | ((w13 ^ w1) >> 16u32)
        w9 = w9 + w13
        w5 = ((w5 ^ w9) << 12u32) | ((w5 ^ w9) >> 20u32)
        w1 = w1 + w5
        w13 = ((w13 ^ w1) << 8u32) | ((w13 ^ w1) >> 24u32)
        w9 = w9 + w13
        w5 = ((w5 ^ w9) << 7u32) | ((w5 ^ w9) >> 25u32)

        w2 = w2 + w6
        w14 = ((w14 ^ w2) << 16u32) | ((w14 ^ w2) >> 16u32)
        w10 = w10 + w14
        w6 = ((w6 ^ w10) << 12u32) | ((w6 ^ w10) >> 20u32)
        w2 = w2 + w6
        w14 = ((w14 ^ w2) << 8u32) | ((w14 ^ w2) >> 24u32)
        w10 = w10 + w14
        w6 = ((w6 ^ w10) << 7u32) | ((w6 ^ w10) >> 25u32)

        w3 = w3 + w7
        w15 = ((w15 ^ w3) << 16u32) | ((w15 ^ w3) >> 16u32)
        w11 = w11 + w15
        w7 = ((w7 ^ w11) << 12u32) | ((w7 ^ w11) >> 20u32)
        w3 = w3 + w7
        w15 = ((w15 ^ w3) << 8u32) | ((w15 ^ w3) >> 24u32)
        w11 = w11 + w15
        w7 = ((w7 ^ w11) << 7u32) | ((w7 ^ w11) >> 25u32)

        w0 = w0 + w5
        w15 = ((w15 ^ w0) << 16u32) | ((w15 ^ w0) >> 16u32)
        w10 = w10 + w15
        w5 = ((w5 ^ w10) << 12u32) | ((w5 ^ w10) >> 20u32)
        w0 = w0 + w5
        w15 = ((w15 ^ w0) << 8u32) | ((w15 ^ w0) >> 24u32)
        w10 = w10 + w15
        w5 = ((w5 ^ w10) << 7u32) | ((w5 ^ w10) >> 25u32)

        w1 = w1 + w6
        w12 = ((w12 ^ w1) << 16u32) | ((w12 ^ w1) >> 16u32)
        w11 = w11 + w12
        w6 = ((w6 ^ w11) << 12u32) | ((w6 ^ w11) >> 20u32)
        w1 = w1 + w6
        w12 = ((w12 ^ w1) << 8u32) | ((w12 ^ w1) >> 24u32)
        w11 = w11 + w12
        w6 = ((w6 ^ w11) << 7u32) | ((w6 ^ w11) >> 25u32)

        w2 = w2 + w7
        w13 = ((w13 ^ w2) << 16u32) | ((w13 ^ w2) >> 16u32)
        w8 = w8 + w13
        w7 = ((w7 ^ w8) << 12u32) | ((w7 ^ w8) >> 20u32)
        w2 = w2 + w7
        w13 = ((w13 ^ w2) << 8u32) | ((w13 ^ w2) >> 24u32)
        w8 = w8 + w13
        w7 = ((w7 ^ w8) << 7u32) | ((w7 ^ w8) >> 25u32)

        w3 = w3 + w4
        w14 = ((w14 ^ w3) << 16u32) | ((w14 ^ w3) >> 16u32)
        w9 = w9 + w14
        w4 = ((w4 ^ w9) << 12u32) | ((w4 ^ w9) >> 20u32)
        w3 = w3 + w4
        w14 = ((w14 ^ w3) << 8u32) | ((w14 ^ w3) >> 24u32)
        w9 = w9 + w14
        w4 = ((w4 ^ w9) << 7u32) | ((w4 ^ w9) >> 25u32)
        round = round + 1u64

    var pos = start
    val o0 = w0 + s0
    val o1 = w1 + s1
    val o2 = w2 + s2
    val o3 = w3 + s3
    pos = chacha20_xor_words4_local(output, plaintext, pos, o0, o1, o2, o3)
    val o4 = w4 + s4
    val o5 = w5 + s5
    val o6 = w6 + s6
    val o7 = w7 + s7
    pos = chacha20_xor_words4_local(output, plaintext, pos, o4, o5, o6, o7)
    val o8 = w8 + s8
    val o9 = w9 + s9
    val o10 = w10 + s10
    val o11 = w11 + s11
    pos = chacha20_xor_words4_local(output, plaintext, pos, o8, o9, o10, o11)
    val o12 = w12 + s12
    val o13 = w13 + s13
    val o14 = w14 + s14
    val o15 = w15 + s15
    chacha20_xor_words4_local(output, plaintext, pos, o12, o13, o14, o15)

fn chacha20_encrypt_local(counter: u32, plaintext: [u8], output: [u8]):
    var block_counter = counter
    var pos: u64 = 0u64
    while pos < plaintext.len():
        pos = chacha20_xor_block_local(output, plaintext, block_counter, pos)
        block_counter = block_counter + 1u32

fn report(alg: text, bytes_per_iter: u64, iters: u64, elapsed_us: i64, checksum: u64):
    val total_bytes = bytes_per_iter * iters
    val safe_us = if elapsed_us <= 0: 1 else: elapsed_us
    val mbps = total_bytes / safe_us.to_u64()
    print "[algbench] lang=simple alg={alg} bytes={bytes_per_iter} iters={iters} micros={elapsed_us} mbps={mbps} checksum={checksum}"

fn bench_xxhash(data: [u8]):
    var checksum: u64 = 0u64
    var i: u64 = 0u64
    val iters = xxh_iters()
    val start = rt_time_now_unix_micros()
    while i < iters:
        checksum = checksum ^ xxhash64(data, i)
        i = i + 1u64
    val elapsed = rt_time_now_unix_micros() - start
    report("xxhash64", data.len(), iters, elapsed, checksum)

fn bench_chacha(data: [u8]):
    val out = make_empty_output(data.len())
    var checksum: u64 = 0u64
    var i: u64 = 0u64
    val iters = chacha_iters()
    val start = rt_time_now_unix_micros()
    while i < iters:
        chacha20_encrypt_local(i.to_u32(), data, out)
        checksum = checksum ^ checksum_bytes(out)
        i = i + 1u64
    val elapsed = rt_time_now_unix_micros() - start
    report("chacha20", data.len(), iters, elapsed, checksum)

fn main() -> i32:
    val data = make_data(data_size())
    bench_xxhash(data)
    bench_chacha(data)
    0
