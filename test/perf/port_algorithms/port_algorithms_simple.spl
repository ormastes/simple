# Pure Simple algorithm benchmark for Phase 6 port parity.

use os.crypto.xxhash.{xxhash64}

extern fn rt_time_now_unix_micros() -> i64

fn data_size() -> u64:
    65536u64

fn xxh_iters() -> u64:
    80u64

fn chacha_iters() -> u64:
    30u64

fn make_data(n: u64) -> [u8]:
    var out: [u8] = []
    var i: u64 = 0u64
    while i < n:
        out.push(((i * 131u64 + 17u64) & 0xFFu64).to_u8())
        i = i + 1u64
    out

fn key32() -> [u8]:
    var out: [u8] = []
    var i: u64 = 0u64
    while i < 32u64:
        out.push(i.to_u8())
        i = i + 1u64
    out

fn nonce12() -> [u8]:
    [0x00u8, 0x00u8, 0x00u8, 0x09u8, 0x00u8, 0x00u8,
     0x00u8, 0x4au8, 0x00u8, 0x00u8, 0x00u8, 0x00u8]

fn checksum_bytes(data: [u8]) -> u64:
    var sum: u64 = 0u64
    var i: u64 = 0u64
    while i < data.len():
        sum = ((sum << 5u64) ^ (sum >> 2u64)) + data[i].to_u64()
        i = i + 1u64
    sum

fn chacha20_block_local(key: [u8], counter: u32, nonce: [u8]) -> [u8]:
    val s0 = 0x61707865u32
    val s1 = 0x3320646eu32
    val s2 = 0x79622d32u32
    val s3 = 0x6b206574u32
    val s4 = key[0u64].to_u32() | (key[1u64].to_u32() << 8u32) | (key[2u64].to_u32() << 16u32) | (key[3u64].to_u32() << 24u32)
    val s5 = key[4u64].to_u32() | (key[5u64].to_u32() << 8u32) | (key[6u64].to_u32() << 16u32) | (key[7u64].to_u32() << 24u32)
    val s6 = key[8u64].to_u32() | (key[9u64].to_u32() << 8u32) | (key[10u64].to_u32() << 16u32) | (key[11u64].to_u32() << 24u32)
    val s7 = key[12u64].to_u32() | (key[13u64].to_u32() << 8u32) | (key[14u64].to_u32() << 16u32) | (key[15u64].to_u32() << 24u32)
    val s8 = key[16u64].to_u32() | (key[17u64].to_u32() << 8u32) | (key[18u64].to_u32() << 16u32) | (key[19u64].to_u32() << 24u32)
    val s9 = key[20u64].to_u32() | (key[21u64].to_u32() << 8u32) | (key[22u64].to_u32() << 16u32) | (key[23u64].to_u32() << 24u32)
    val s10 = key[24u64].to_u32() | (key[25u64].to_u32() << 8u32) | (key[26u64].to_u32() << 16u32) | (key[27u64].to_u32() << 24u32)
    val s11 = key[28u64].to_u32() | (key[29u64].to_u32() << 8u32) | (key[30u64].to_u32() << 16u32) | (key[31u64].to_u32() << 24u32)
    val s12 = counter
    val s13 = nonce[0u64].to_u32() | (nonce[1u64].to_u32() << 8u32) | (nonce[2u64].to_u32() << 16u32) | (nonce[3u64].to_u32() << 24u32)
    val s14 = nonce[4u64].to_u32() | (nonce[5u64].to_u32() << 8u32) | (nonce[6u64].to_u32() << 16u32) | (nonce[7u64].to_u32() << 24u32)
    val s15 = nonce[8u64].to_u32() | (nonce[9u64].to_u32() << 8u32) | (nonce[10u64].to_u32() << 16u32) | (nonce[11u64].to_u32() << 24u32)

    var w0 = s0
    var w1 = s1
    var w2 = s2
    var w3 = s3
    var w4 = s4
    var w5 = s5
    var w6 = s6
    var w7 = s7
    var w8 = s8
    var w9 = s9
    var w10 = s10
    var w11 = s11
    var w12 = s12
    var w13 = s13
    var w14 = s14
    var w15 = s15

    var round: u64 = 0u64
    while round < 10u64:
        w0 = w0 + w4
        w12 = ((w12 ^ w0) << 16u32) | ((w12 ^ w0) >> 16u32)
        w8 = w8 + w12
        w4 = ((w4 ^ w8) << 12u32) | ((w4 ^ w8) >> 20u32)
        w0 = w0 + w4
        w12 = ((w12 ^ w0) << 8u32) | ((w12 ^ w0) >> 24u32)
        w8 = w8 + w12
        w4 = ((w4 ^ w8) << 7u32) | ((w4 ^ w8) >> 25u32)

        w1 = w1 + w5
        w13 = ((w13 ^ w1) << 16u32) | ((w13 ^ w1) >> 16u32)
        w9 = w9 + w13
        w5 = ((w5 ^ w9) << 12u32) | ((w5 ^ w9) >> 20u32)
        w1 = w1 + w5
        w13 = ((w13 ^ w1) << 8u32) | ((w13 ^ w1) >> 24u32)
        w9 = w9 + w13
        w5 = ((w5 ^ w9) << 7u32) | ((w5 ^ w9) >> 25u32)

        w2 = w2 + w6
        w14 = ((w14 ^ w2) << 16u32) | ((w14 ^ w2) >> 16u32)
        w10 = w10 + w14
        w6 = ((w6 ^ w10) << 12u32) | ((w6 ^ w10) >> 20u32)
        w2 = w2 + w6
        w14 = ((w14 ^ w2) << 8u32) | ((w14 ^ w2) >> 24u32)
        w10 = w10 + w14
        w6 = ((w6 ^ w10) << 7u32) | ((w6 ^ w10) >> 25u32)

        w3 = w3 + w7
        w15 = ((w15 ^ w3) << 16u32) | ((w15 ^ w3) >> 16u32)
        w11 = w11 + w15
        w7 = ((w7 ^ w11) << 12u32) | ((w7 ^ w11) >> 20u32)
        w3 = w3 + w7
        w15 = ((w15 ^ w3) << 8u32) | ((w15 ^ w3) >> 24u32)
        w11 = w11 + w15
        w7 = ((w7 ^ w11) << 7u32) | ((w7 ^ w11) >> 25u32)

        w0 = w0 + w5
        w15 = ((w15 ^ w0) << 16u32) | ((w15 ^ w0) >> 16u32)
        w10 = w10 + w15
        w5 = ((w5 ^ w10) << 12u32) | ((w5 ^ w10) >> 20u32)
        w0 = w0 + w5
        w15 = ((w15 ^ w0) << 8u32) | ((w15 ^ w0) >> 24u32)
        w10 = w10 + w15
        w5 = ((w5 ^ w10) << 7u32) | ((w5 ^ w10) >> 25u32)

        w1 = w1 + w6
        w12 = ((w12 ^ w1) << 16u32) | ((w12 ^ w1) >> 16u32)
        w11 = w11 + w12
        w6 = ((w6 ^ w11) << 12u32) | ((w6 ^ w11) >> 20u32)
        w1 = w1 + w6
        w12 = ((w12 ^ w1) << 8u32) | ((w12 ^ w1) >> 24u32)
        w11 = w11 + w12
        w6 = ((w6 ^ w11) << 7u32) | ((w6 ^ w11) >> 25u32)

        w2 = w2 + w7
        w13 = ((w13 ^ w2) << 16u32) | ((w13 ^ w2) >> 16u32)
        w8 = w8 + w13
        w7 = ((w7 ^ w8) << 12u32) | ((w7 ^ w8) >> 20u32)
        w2 = w2 + w7
        w13 = ((w13 ^ w2) << 8u32) | ((w13 ^ w2) >> 24u32)
        w8 = w8 + w13
        w7 = ((w7 ^ w8) << 7u32) | ((w7 ^ w8) >> 25u32)

        w3 = w3 + w4
        w14 = ((w14 ^ w3) << 16u32) | ((w14 ^ w3) >> 16u32)
        w9 = w9 + w14
        w4 = ((w4 ^ w9) << 12u32) | ((w4 ^ w9) >> 20u32)
        w3 = w3 + w4
        w14 = ((w14 ^ w3) << 8u32) | ((w14 ^ w3) >> 24u32)
        w9 = w9 + w14
        w4 = ((w4 ^ w9) << 7u32) | ((w4 ^ w9) >> 25u32)
        round = round + 1u64

    var block_out: [u8] = []
    val o0 = w0 + s0
    block_out.push((o0 & 0xFFu32).to_u8())
    block_out.push(((o0 >> 8u32) & 0xFFu32).to_u8())
    block_out.push(((o0 >> 16u32) & 0xFFu32).to_u8())
    block_out.push(((o0 >> 24u32) & 0xFFu32).to_u8())
    val o1 = w1 + s1
    block_out.push((o1 & 0xFFu32).to_u8())
    block_out.push(((o1 >> 8u32) & 0xFFu32).to_u8())
    block_out.push(((o1 >> 16u32) & 0xFFu32).to_u8())
    block_out.push(((o1 >> 24u32) & 0xFFu32).to_u8())
    val o2 = w2 + s2
    block_out.push((o2 & 0xFFu32).to_u8())
    block_out.push(((o2 >> 8u32) & 0xFFu32).to_u8())
    block_out.push(((o2 >> 16u32) & 0xFFu32).to_u8())
    block_out.push(((o2 >> 24u32) & 0xFFu32).to_u8())
    val o3 = w3 + s3
    block_out.push((o3 & 0xFFu32).to_u8())
    block_out.push(((o3 >> 8u32) & 0xFFu32).to_u8())
    block_out.push(((o3 >> 16u32) & 0xFFu32).to_u8())
    block_out.push(((o3 >> 24u32) & 0xFFu32).to_u8())
    val o4 = w4 + s4
    block_out.push((o4 & 0xFFu32).to_u8())
    block_out.push(((o4 >> 8u32) & 0xFFu32).to_u8())
    block_out.push(((o4 >> 16u32) & 0xFFu32).to_u8())
    block_out.push(((o4 >> 24u32) & 0xFFu32).to_u8())
    val o5 = w5 + s5
    block_out.push((o5 & 0xFFu32).to_u8())
    block_out.push(((o5 >> 8u32) & 0xFFu32).to_u8())
    block_out.push(((o5 >> 16u32) & 0xFFu32).to_u8())
    block_out.push(((o5 >> 24u32) & 0xFFu32).to_u8())
    val o6 = w6 + s6
    block_out.push((o6 & 0xFFu32).to_u8())
    block_out.push(((o6 >> 8u32) & 0xFFu32).to_u8())
    block_out.push(((o6 >> 16u32) & 0xFFu32).to_u8())
    block_out.push(((o6 >> 24u32) & 0xFFu32).to_u8())
    val o7 = w7 + s7
    block_out.push((o7 & 0xFFu32).to_u8())
    block_out.push(((o7 >> 8u32) & 0xFFu32).to_u8())
    block_out.push(((o7 >> 16u32) & 0xFFu32).to_u8())
    block_out.push(((o7 >> 24u32) & 0xFFu32).to_u8())
    val o8 = w8 + s8
    block_out.push((o8 & 0xFFu32).to_u8())
    block_out.push(((o8 >> 8u32) & 0xFFu32).to_u8())
    block_out.push(((o8 >> 16u32) & 0xFFu32).to_u8())
    block_out.push(((o8 >> 24u32) & 0xFFu32).to_u8())
    val o9 = w9 + s9
    block_out.push((o9 & 0xFFu32).to_u8())
    block_out.push(((o9 >> 8u32) & 0xFFu32).to_u8())
    block_out.push(((o9 >> 16u32) & 0xFFu32).to_u8())
    block_out.push(((o9 >> 24u32) & 0xFFu32).to_u8())
    val o10 = w10 + s10
    block_out.push((o10 & 0xFFu32).to_u8())
    block_out.push(((o10 >> 8u32) & 0xFFu32).to_u8())
    block_out.push(((o10 >> 16u32) & 0xFFu32).to_u8())
    block_out.push(((o10 >> 24u32) & 0xFFu32).to_u8())
    val o11 = w11 + s11
    block_out.push((o11 & 0xFFu32).to_u8())
    block_out.push(((o11 >> 8u32) & 0xFFu32).to_u8())
    block_out.push(((o11 >> 16u32) & 0xFFu32).to_u8())
    block_out.push(((o11 >> 24u32) & 0xFFu32).to_u8())
    val o12 = w12 + s12
    block_out.push((o12 & 0xFFu32).to_u8())
    block_out.push(((o12 >> 8u32) & 0xFFu32).to_u8())
    block_out.push(((o12 >> 16u32) & 0xFFu32).to_u8())
    block_out.push(((o12 >> 24u32) & 0xFFu32).to_u8())
    val o13 = w13 + s13
    block_out.push((o13 & 0xFFu32).to_u8())
    block_out.push(((o13 >> 8u32) & 0xFFu32).to_u8())
    block_out.push(((o13 >> 16u32) & 0xFFu32).to_u8())
    block_out.push(((o13 >> 24u32) & 0xFFu32).to_u8())
    val o14 = w14 + s14
    block_out.push((o14 & 0xFFu32).to_u8())
    block_out.push(((o14 >> 8u32) & 0xFFu32).to_u8())
    block_out.push(((o14 >> 16u32) & 0xFFu32).to_u8())
    block_out.push(((o14 >> 24u32) & 0xFFu32).to_u8())
    val o15 = w15 + s15
    block_out.push((o15 & 0xFFu32).to_u8())
    block_out.push(((o15 >> 8u32) & 0xFFu32).to_u8())
    block_out.push(((o15 >> 16u32) & 0xFFu32).to_u8())
    block_out.push(((o15 >> 24u32) & 0xFFu32).to_u8())
    block_out

fn chacha20_encrypt_local(key: [u8], counter: u32, nonce: [u8], plaintext: [u8]) -> [u8]:
    var output: [u8] = []
    var block_counter = counter
    var pos: u64 = 0u64
    while pos < plaintext.len():
        val block = chacha20_block_local(key, block_counter, nonce)
        var j: u64 = 0u64
        while j < 64u64 and pos < plaintext.len():
            output.push(plaintext[pos] ^ block[j])
            pos = pos + 1u64
            j = j + 1u64
        block_counter = block_counter + 1u32
    output

fn report(alg: text, bytes_per_iter: u64, iters: u64, elapsed_us: i64, checksum: u64):
    val total_bytes = bytes_per_iter * iters
    val safe_us = if elapsed_us <= 0: 1 else: elapsed_us
    val mbps = total_bytes / safe_us.to_u64()
    print "[algbench] lang=simple alg={alg} bytes={bytes_per_iter} iters={iters} micros={elapsed_us} mbps={mbps} checksum={checksum}"

fn bench_xxhash(data: [u8]):
    var checksum: u64 = 0u64
    var i: u64 = 0u64
    val iters = xxh_iters()
    val start = rt_time_now_unix_micros()
    while i < iters:
        checksum = checksum ^ xxhash64(data, i)
        i = i + 1u64
    val elapsed = rt_time_now_unix_micros() - start
    report("xxhash64", data.len(), iters, elapsed, checksum)

fn bench_chacha(data: [u8]):
    val key = key32()
    val nonce = nonce12()
    var checksum: u64 = 0u64
    var i: u64 = 0u64
    val iters = chacha_iters()
    val start = rt_time_now_unix_micros()
    while i < iters:
        val out = chacha20_encrypt_local(key, i.to_u32(), nonce, data)
        checksum = checksum ^ checksum_bytes(out)
        i = i + 1u64
    val elapsed = rt_time_now_unix_micros() - start
    report("chacha20", data.len(), iters, elapsed, checksum)

fn main() -> i32:
    val data = make_data(data_size())
    bench_xxhash(data)
    bench_chacha(data)
    0
