# Pure Simple algorithm benchmark for Phase 6 port parity.

use os.crypto.crc32.{crc32}
use os.crypto.adler32.{adler32}
use os.crypto.xxhash.{xxhash64}

extern fn rt_time_now_unix_micros() -> i64
extern fn rt_typed_bytes_u32_le_at(arr: [u8], idx: u64) -> u64
extern fn rt_typed_bytes_u32_le_set(arr: [u8], idx: u64, value: u32) -> bool

fn data_size() -> u64:
    65536u64

fn xxh_iters() -> u64:
    80u64

fn chacha_iters() -> u64:
    30u64

fn crc32_iters() -> u64:
    80u64

fn adler32_iters() -> u64:
    80u64

fn make_data(n: u64) -> [u8]:
    var out: [u8] = []
    var i: u64 = 0u64
    while i < n:
        out.push(((i * 131u64 + 17u64) & 0xFFu64).to_u8())
        i = i + 1u64
    out

fn make_empty_output(n: u64) -> [u8]:
    var out: [u8] = []
    var i: u64 = 0u64
    while i < n:
        out.push(0u8)
        i = i + 1u64
    out

fn chacha20_xor_block_checksum_local(output: [u8], plaintext: [u8], counter: u32, start: u64, sum_in: u64) -> u64:
    val s0 = 0x61707865u32
    val s1 = 0x3320646eu32
    val s2 = 0x79622d32u32
    val s3 = 0x6b206574u32
    val s4 = 0x03020100u32
    val s5 = 0x07060504u32
    val s6 = 0x0b0a0908u32
    val s7 = 0x0f0e0d0cu32
    val s8 = 0x13121110u32
    val s9 = 0x17161514u32
    val s10 = 0x1b1a1918u32
    val s11 = 0x1f1e1d1cu32
    val s12 = counter
    val s13 = 0x09000000u32
    val s14 = 0x4a000000u32
    val s15 = 0u32

    var w0 = s0
    var w1 = s1
    var w2 = s2
    var w3 = s3
    var w4 = s4
    var w5 = s5
    var w6 = s6
    var w7 = s7
    var w8 = s8
    var w9 = s9
    var w10 = s10
    var w11 = s11
    var w12 = s12
    var w13 = s13
    var w14 = s14
    var w15 = s15

    var round: u64 = 0u64
    var t: u32 = 0u32
    while round < 10u64:
        w0 = w0 + w4
        t = w12 ^ w0
        w12 = (t << 16u32) | (t >> 16u32)
        w8 = w8 + w12
        t = w4 ^ w8
        w4 = (t << 12u32) | (t >> 20u32)
        w0 = w0 + w4
        t = w12 ^ w0
        w12 = (t << 8u32) | (t >> 24u32)
        w8 = w8 + w12
        t = w4 ^ w8
        w4 = (t << 7u32) | (t >> 25u32)

        w1 = w1 + w5
        t = w13 ^ w1
        w13 = (t << 16u32) | (t >> 16u32)
        w9 = w9 + w13
        t = w5 ^ w9
        w5 = (t << 12u32) | (t >> 20u32)
        w1 = w1 + w5
        t = w13 ^ w1
        w13 = (t << 8u32) | (t >> 24u32)
        w9 = w9 + w13
        t = w5 ^ w9
        w5 = (t << 7u32) | (t >> 25u32)

        w2 = w2 + w6
        t = w14 ^ w2
        w14 = (t << 16u32) | (t >> 16u32)
        w10 = w10 + w14
        t = w6 ^ w10
        w6 = (t << 12u32) | (t >> 20u32)
        w2 = w2 + w6
        t = w14 ^ w2
        w14 = (t << 8u32) | (t >> 24u32)
        w10 = w10 + w14
        t = w6 ^ w10
        w6 = (t << 7u32) | (t >> 25u32)

        w3 = w3 + w7
        t = w15 ^ w3
        w15 = (t << 16u32) | (t >> 16u32)
        w11 = w11 + w15
        t = w7 ^ w11
        w7 = (t << 12u32) | (t >> 20u32)
        w3 = w3 + w7
        t = w15 ^ w3
        w15 = (t << 8u32) | (t >> 24u32)
        w11 = w11 + w15
        t = w7 ^ w11
        w7 = (t << 7u32) | (t >> 25u32)

        w0 = w0 + w5
        t = w15 ^ w0
        w15 = (t << 16u32) | (t >> 16u32)
        w10 = w10 + w15
        t = w5 ^ w10
        w5 = (t << 12u32) | (t >> 20u32)
        w0 = w0 + w5
        t = w15 ^ w0
        w15 = (t << 8u32) | (t >> 24u32)
        w10 = w10 + w15
        t = w5 ^ w10
        w5 = (t << 7u32) | (t >> 25u32)

        w1 = w1 + w6
        t = w12 ^ w1
        w12 = (t << 16u32) | (t >> 16u32)
        w11 = w11 + w12
        t = w6 ^ w11
        w6 = (t << 12u32) | (t >> 20u32)
        w1 = w1 + w6
        t = w12 ^ w1
        w12 = (t << 8u32) | (t >> 24u32)
        w11 = w11 + w12
        t = w6 ^ w11
        w6 = (t << 7u32) | (t >> 25u32)

        w2 = w2 + w7
        t = w13 ^ w2
        w13 = (t << 16u32) | (t >> 16u32)
        w8 = w8 + w13
        t = w7 ^ w8
        w7 = (t << 12u32) | (t >> 20u32)
        w2 = w2 + w7
        t = w13 ^ w2
        w13 = (t << 8u32) | (t >> 24u32)
        w8 = w8 + w13
        t = w7 ^ w8
        w7 = (t << 7u32) | (t >> 25u32)

        w3 = w3 + w4
        t = w14 ^ w3
        w14 = (t << 16u32) | (t >> 16u32)
        w9 = w9 + w14
        t = w4 ^ w9
        w4 = (t << 12u32) | (t >> 20u32)
        w3 = w3 + w4
        t = w14 ^ w3
        w14 = (t << 8u32) | (t >> 24u32)
        w9 = w9 + w14
        t = w4 ^ w9
        w4 = (t << 7u32) | (t >> 25u32)
        round = round + 1u64

    val o0 = w0 + s0
    val o1 = w1 + s1
    val o2 = w2 + s2
    val o3 = w3 + s3
    val o4 = w4 + s4
    val o5 = w5 + s5
    val o6 = w6 + s6
    val o7 = w7 + s7
    val o8 = w8 + s8
    val o9 = w9 + s9
    val o10 = w10 + s10
    val o11 = w11 + s11
    val o12 = w12 + s12
    val o13 = w13 + s13
    val o14 = w14 + s14
    val o15 = w15 + s15

    var pos = start
    var sum = sum_in
    var mixed = rt_typed_bytes_u32_le_at(plaintext, pos).to_u32() ^ o0
    rt_typed_bytes_u32_le_set(output, pos, mixed)
    var byte = (mixed & 0xFFu32).to_u8()
    sum = ((sum << 5u64) ^ (sum >> 2u64)) + byte.to_u64()
    byte = ((mixed >> 8u32) & 0xFFu32).to_u8()
    sum = ((sum << 5u64) ^ (sum >> 2u64)) + byte.to_u64()
    byte = ((mixed >> 16u32) & 0xFFu32).to_u8()
    sum = ((sum << 5u64) ^ (sum >> 2u64)) + byte.to_u64()
    byte = ((mixed >> 24u32) & 0xFFu32).to_u8()
    sum = ((sum << 5u64) ^ (sum >> 2u64)) + byte.to_u64()

    pos = pos + 4u64
    mixed = rt_typed_bytes_u32_le_at(plaintext, pos).to_u32() ^ o1
    rt_typed_bytes_u32_le_set(output, pos, mixed)
    byte = (mixed & 0xFFu32).to_u8()
    sum = ((sum << 5u64) ^ (sum >> 2u64)) + byte.to_u64()
    byte = ((mixed >> 8u32) & 0xFFu32).to_u8()
    sum = ((sum << 5u64) ^ (sum >> 2u64)) + byte.to_u64()
    byte = ((mixed >> 16u32) & 0xFFu32).to_u8()
    sum = ((sum << 5u64) ^ (sum >> 2u64)) + byte.to_u64()
    byte = ((mixed >> 24u32) & 0xFFu32).to_u8()
    sum = ((sum << 5u64) ^ (sum >> 2u64)) + byte.to_u64()

    pos = pos + 4u64
    mixed = rt_typed_bytes_u32_le_at(plaintext, pos).to_u32() ^ o2
    rt_typed_bytes_u32_le_set(output, pos, mixed)
    byte = (mixed & 0xFFu32).to_u8()
    sum = ((sum << 5u64) ^ (sum >> 2u64)) + byte.to_u64()
    byte = ((mixed >> 8u32) & 0xFFu32).to_u8()
    sum = ((sum << 5u64) ^ (sum >> 2u64)) + byte.to_u64()
    byte = ((mixed >> 16u32) & 0xFFu32).to_u8()
    sum = ((sum << 5u64) ^ (sum >> 2u64)) + byte.to_u64()
    byte = ((mixed >> 24u32) & 0xFFu32).to_u8()
    sum = ((sum << 5u64) ^ (sum >> 2u64)) + byte.to_u64()

    pos = pos + 4u64
    mixed = rt_typed_bytes_u32_le_at(plaintext, pos).to_u32() ^ o3
    rt_typed_bytes_u32_le_set(output, pos, mixed)
    byte = (mixed & 0xFFu32).to_u8()
    sum = ((sum << 5u64) ^ (sum >> 2u64)) + byte.to_u64()
    byte = ((mixed >> 8u32) & 0xFFu32).to_u8()
    sum = ((sum << 5u64) ^ (sum >> 2u64)) + byte.to_u64()
    byte = ((mixed >> 16u32) & 0xFFu32).to_u8()
    sum = ((sum << 5u64) ^ (sum >> 2u64)) + byte.to_u64()
    byte = ((mixed >> 24u32) & 0xFFu32).to_u8()
    sum = ((sum << 5u64) ^ (sum >> 2u64)) + byte.to_u64()

    pos = pos + 4u64
    mixed = rt_typed_bytes_u32_le_at(plaintext, pos).to_u32() ^ o4
    rt_typed_bytes_u32_le_set(output, pos, mixed)
    byte = (mixed & 0xFFu32).to_u8()
    sum = ((sum << 5u64) ^ (sum >> 2u64)) + byte.to_u64()
    byte = ((mixed >> 8u32) & 0xFFu32).to_u8()
    sum = ((sum << 5u64) ^ (sum >> 2u64)) + byte.to_u64()
    byte = ((mixed >> 16u32) & 0xFFu32).to_u8()
    sum = ((sum << 5u64) ^ (sum >> 2u64)) + byte.to_u64()
    byte = ((mixed >> 24u32) & 0xFFu32).to_u8()
    sum = ((sum << 5u64) ^ (sum >> 2u64)) + byte.to_u64()

    pos = pos + 4u64
    mixed = rt_typed_bytes_u32_le_at(plaintext, pos).to_u32() ^ o5
    rt_typed_bytes_u32_le_set(output, pos, mixed)
    byte = (mixed & 0xFFu32).to_u8()
    sum = ((sum << 5u64) ^ (sum >> 2u64)) + byte.to_u64()
    byte = ((mixed >> 8u32) & 0xFFu32).to_u8()
    sum = ((sum << 5u64) ^ (sum >> 2u64)) + byte.to_u64()
    byte = ((mixed >> 16u32) & 0xFFu32).to_u8()
    sum = ((sum << 5u64) ^ (sum >> 2u64)) + byte.to_u64()
    byte = ((mixed >> 24u32) & 0xFFu32).to_u8()
    sum = ((sum << 5u64) ^ (sum >> 2u64)) + byte.to_u64()

    pos = pos + 4u64
    mixed = rt_typed_bytes_u32_le_at(plaintext, pos).to_u32() ^ o6
    rt_typed_bytes_u32_le_set(output, pos, mixed)
    byte = (mixed & 0xFFu32).to_u8()
    sum = ((sum << 5u64) ^ (sum >> 2u64)) + byte.to_u64()
    byte = ((mixed >> 8u32) & 0xFFu32).to_u8()
    sum = ((sum << 5u64) ^ (sum >> 2u64)) + byte.to_u64()
    byte = ((mixed >> 16u32) & 0xFFu32).to_u8()
    sum = ((sum << 5u64) ^ (sum >> 2u64)) + byte.to_u64()
    byte = ((mixed >> 24u32) & 0xFFu32).to_u8()
    sum = ((sum << 5u64) ^ (sum >> 2u64)) + byte.to_u64()

    pos = pos + 4u64
    mixed = rt_typed_bytes_u32_le_at(plaintext, pos).to_u32() ^ o7
    rt_typed_bytes_u32_le_set(output, pos, mixed)
    byte = (mixed & 0xFFu32).to_u8()
    sum = ((sum << 5u64) ^ (sum >> 2u64)) + byte.to_u64()
    byte = ((mixed >> 8u32) & 0xFFu32).to_u8()
    sum = ((sum << 5u64) ^ (sum >> 2u64)) + byte.to_u64()
    byte = ((mixed >> 16u32) & 0xFFu32).to_u8()
    sum = ((sum << 5u64) ^ (sum >> 2u64)) + byte.to_u64()
    byte = ((mixed >> 24u32) & 0xFFu32).to_u8()
    sum = ((sum << 5u64) ^ (sum >> 2u64)) + byte.to_u64()

    pos = pos + 4u64
    mixed = rt_typed_bytes_u32_le_at(plaintext, pos).to_u32() ^ o8
    rt_typed_bytes_u32_le_set(output, pos, mixed)
    byte = (mixed & 0xFFu32).to_u8()
    sum = ((sum << 5u64) ^ (sum >> 2u64)) + byte.to_u64()
    byte = ((mixed >> 8u32) & 0xFFu32).to_u8()
    sum = ((sum << 5u64) ^ (sum >> 2u64)) + byte.to_u64()
    byte = ((mixed >> 16u32) & 0xFFu32).to_u8()
    sum = ((sum << 5u64) ^ (sum >> 2u64)) + byte.to_u64()
    byte = ((mixed >> 24u32) & 0xFFu32).to_u8()
    sum = ((sum << 5u64) ^ (sum >> 2u64)) + byte.to_u64()

    pos = pos + 4u64
    mixed = rt_typed_bytes_u32_le_at(plaintext, pos).to_u32() ^ o9
    rt_typed_bytes_u32_le_set(output, pos, mixed)
    byte = (mixed & 0xFFu32).to_u8()
    sum = ((sum << 5u64) ^ (sum >> 2u64)) + byte.to_u64()
    byte = ((mixed >> 8u32) & 0xFFu32).to_u8()
    sum = ((sum << 5u64) ^ (sum >> 2u64)) + byte.to_u64()
    byte = ((mixed >> 16u32) & 0xFFu32).to_u8()
    sum = ((sum << 5u64) ^ (sum >> 2u64)) + byte.to_u64()
    byte = ((mixed >> 24u32) & 0xFFu32).to_u8()
    sum = ((sum << 5u64) ^ (sum >> 2u64)) + byte.to_u64()

    pos = pos + 4u64
    mixed = rt_typed_bytes_u32_le_at(plaintext, pos).to_u32() ^ o10
    rt_typed_bytes_u32_le_set(output, pos, mixed)
    byte = (mixed & 0xFFu32).to_u8()
    sum = ((sum << 5u64) ^ (sum >> 2u64)) + byte.to_u64()
    byte = ((mixed >> 8u32) & 0xFFu32).to_u8()
    sum = ((sum << 5u64) ^ (sum >> 2u64)) + byte.to_u64()
    byte = ((mixed >> 16u32) & 0xFFu32).to_u8()
    sum = ((sum << 5u64) ^ (sum >> 2u64)) + byte.to_u64()
    byte = ((mixed >> 24u32) & 0xFFu32).to_u8()
    sum = ((sum << 5u64) ^ (sum >> 2u64)) + byte.to_u64()

    pos = pos + 4u64
    mixed = rt_typed_bytes_u32_le_at(plaintext, pos).to_u32() ^ o11
    rt_typed_bytes_u32_le_set(output, pos, mixed)
    byte = (mixed & 0xFFu32).to_u8()
    sum = ((sum << 5u64) ^ (sum >> 2u64)) + byte.to_u64()
    byte = ((mixed >> 8u32) & 0xFFu32).to_u8()
    sum = ((sum << 5u64) ^ (sum >> 2u64)) + byte.to_u64()
    byte = ((mixed >> 16u32) & 0xFFu32).to_u8()
    sum = ((sum << 5u64) ^ (sum >> 2u64)) + byte.to_u64()
    byte = ((mixed >> 24u32) & 0xFFu32).to_u8()
    sum = ((sum << 5u64) ^ (sum >> 2u64)) + byte.to_u64()

    pos = pos + 4u64
    mixed = rt_typed_bytes_u32_le_at(plaintext, pos).to_u32() ^ o12
    rt_typed_bytes_u32_le_set(output, pos, mixed)
    byte = (mixed & 0xFFu32).to_u8()
    sum = ((sum << 5u64) ^ (sum >> 2u64)) + byte.to_u64()
    byte = ((mixed >> 8u32) & 0xFFu32).to_u8()
    sum = ((sum << 5u64) ^ (sum >> 2u64)) + byte.to_u64()
    byte = ((mixed >> 16u32) & 0xFFu32).to_u8()
    sum = ((sum << 5u64) ^ (sum >> 2u64)) + byte.to_u64()
    byte = ((mixed >> 24u32) & 0xFFu32).to_u8()
    sum = ((sum << 5u64) ^ (sum >> 2u64)) + byte.to_u64()

    pos = pos + 4u64
    mixed = rt_typed_bytes_u32_le_at(plaintext, pos).to_u32() ^ o13
    rt_typed_bytes_u32_le_set(output, pos, mixed)
    byte = (mixed & 0xFFu32).to_u8()
    sum = ((sum << 5u64) ^ (sum >> 2u64)) + byte.to_u64()
    byte = ((mixed >> 8u32) & 0xFFu32).to_u8()
    sum = ((sum << 5u64) ^ (sum >> 2u64)) + byte.to_u64()
    byte = ((mixed >> 16u32) & 0xFFu32).to_u8()
    sum = ((sum << 5u64) ^ (sum >> 2u64)) + byte.to_u64()
    byte = ((mixed >> 24u32) & 0xFFu32).to_u8()
    sum = ((sum << 5u64) ^ (sum >> 2u64)) + byte.to_u64()

    pos = pos + 4u64
    mixed = rt_typed_bytes_u32_le_at(plaintext, pos).to_u32() ^ o14
    rt_typed_bytes_u32_le_set(output, pos, mixed)
    byte = (mixed & 0xFFu32).to_u8()
    sum = ((sum << 5u64) ^ (sum >> 2u64)) + byte.to_u64()
    byte = ((mixed >> 8u32) & 0xFFu32).to_u8()
    sum = ((sum << 5u64) ^ (sum >> 2u64)) + byte.to_u64()
    byte = ((mixed >> 16u32) & 0xFFu32).to_u8()
    sum = ((sum << 5u64) ^ (sum >> 2u64)) + byte.to_u64()
    byte = ((mixed >> 24u32) & 0xFFu32).to_u8()
    sum = ((sum << 5u64) ^ (sum >> 2u64)) + byte.to_u64()

    pos = pos + 4u64
    mixed = rt_typed_bytes_u32_le_at(plaintext, pos).to_u32() ^ o15
    rt_typed_bytes_u32_le_set(output, pos, mixed)
    byte = (mixed & 0xFFu32).to_u8()
    sum = ((sum << 5u64) ^ (sum >> 2u64)) + byte.to_u64()
    byte = ((mixed >> 8u32) & 0xFFu32).to_u8()
    sum = ((sum << 5u64) ^ (sum >> 2u64)) + byte.to_u64()
    byte = ((mixed >> 16u32) & 0xFFu32).to_u8()
    sum = ((sum << 5u64) ^ (sum >> 2u64)) + byte.to_u64()
    byte = ((mixed >> 24u32) & 0xFFu32).to_u8()
    sum = ((sum << 5u64) ^ (sum >> 2u64)) + byte.to_u64()
    return sum

fn chacha20_encrypt_checksum_local(counter: u32, plaintext: [u8], output: [u8]) -> u64:
    var block_counter = counter
    var pos: u64 = 0u64
    var sum: u64 = 0u64
    while pos < plaintext.len():
        sum = chacha20_xor_block_checksum_local(output, plaintext, block_counter, pos, sum)
        pos = pos + 64u64
        block_counter = block_counter + 1u32
    sum

fn report(alg: text, bytes_per_iter: u64, iters: u64, elapsed_us: i64, checksum: u64):
    val total_bytes = bytes_per_iter * iters
    val safe_us = if elapsed_us <= 0: 1 else: elapsed_us
    val mbps = total_bytes / safe_us.to_u64()
    print "[algbench] lang=simple alg={alg} bytes={bytes_per_iter} iters={iters} micros={elapsed_us} mbps={mbps} checksum={checksum}"

fn bench_xxhash(data: [u8]):
    var checksum: u64 = 0u64
    var i: u64 = 0u64
    val iters = xxh_iters()
    val start = rt_time_now_unix_micros()
    while i < iters:
        checksum = checksum ^ xxhash64(data, i)
        i = i + 1u64
    val elapsed = rt_time_now_unix_micros() - start
    report("xxhash64", data.len(), iters, elapsed, checksum)

fn bench_chacha(data: [u8]):
    val out = make_empty_output(data.len())
    var checksum: u64 = 0u64
    var i: u64 = 0u64
    val iters = chacha_iters()
    val start = rt_time_now_unix_micros()
    while i < iters:
        checksum = checksum ^ chacha20_encrypt_checksum_local(i.to_u32(), data, out)
        i = i + 1u64
    val elapsed = rt_time_now_unix_micros() - start
    report("chacha20", data.len(), iters, elapsed, checksum)

fn bench_crc32(data: [u8]):
    var checksum: u64 = 0u64
    var i: u64 = 0u64
    val iters = crc32_iters()
    val start = rt_time_now_unix_micros()
    while i < iters:
        checksum = checksum ^ (crc32(data).to_u64() + i)
        i = i + 1u64
    val elapsed = rt_time_now_unix_micros() - start
    report("crc32", data.len(), iters, elapsed, checksum)

fn bench_adler32(data: [u8]):
    var checksum: u64 = 0u64
    var i: u64 = 0u64
    val iters = adler32_iters()
    val start = rt_time_now_unix_micros()
    while i < iters:
        checksum = checksum ^ (adler32(data).to_u64() + i)
        i = i + 1u64
    val elapsed = rt_time_now_unix_micros() - start
    report("adler32", data.len(), iters, elapsed, checksum)

fn main() -> i32:
    val data = make_data(data_size())
    bench_xxhash(data)
    bench_crc32(data)
    bench_adler32(data)
    bench_chacha(data)
    0
