# Pure Simple algorithm benchmark for Phase 6 port parity.

use os.crypto.xxhash.{xxhash64}

extern fn rt_time_now_unix_micros() -> i64

fn data_size() -> u64:
    65536u64

fn xxh_iters() -> u64:
    80u64

fn chacha_iters() -> u64:
    30u64

fn make_data(n: u64) -> [u8]:
    var out: [u8] = []
    var i: u64 = 0u64
    while i < n:
        out.push(((i * 131u64 + 17u64) & 0xFFu64).to_u8())
        i = i + 1u64
    out

fn key32() -> [u8]:
    var out: [u8] = []
    var i: u64 = 0u64
    while i < 32u64:
        out.push(i.to_u8())
        i = i + 1u64
    out

fn nonce12() -> [u8]:
    [0x00u8, 0x00u8, 0x00u8, 0x09u8, 0x00u8, 0x00u8,
     0x00u8, 0x4au8, 0x00u8, 0x00u8, 0x00u8, 0x00u8]

fn checksum_bytes(data: [u8]) -> u64:
    var sum: u64 = 0u64
    var i: u64 = 0u64
    while i < data.len():
        sum = ((sum << 5u64) ^ (sum >> 2u64)) + data[i].to_u64()
        i = i + 1u64
    sum

struct QRWords:
    a: u32
    b: u32
    c: u32
    d: u32

fn rotl32(x: u32, n: u32) -> u32:
    (x << n) | (x >> (32u32 - n))

fn load32(data: [u8], off: u64) -> u32:
    data[off].to_u32() |
        (data[off + 1u64].to_u32() << 8u32) |
        (data[off + 2u64].to_u32() << 16u32) |
        (data[off + 3u64].to_u32() << 24u32)

fn quarter(a0: u32, b0: u32, c0: u32, d0: u32) -> QRWords:
    var a = a0 + b0
    var d = rotl32(d0 ^ a, 16u32)
    var c = c0 + d
    var b = rotl32(b0 ^ c, 12u32)
    a = a + b
    d = rotl32(d ^ a, 8u32)
    c = c + d
    b = rotl32(b ^ c, 7u32)
    QRWords(a: a, b: b, c: c, d: d)

fn push_word(buf: [u8], word: u32) -> [u8]:
    buf.push((word & 0xFFu32).to_u8())
    buf.push(((word >> 8u32) & 0xFFu32).to_u8())
    buf.push(((word >> 16u32) & 0xFFu32).to_u8())
    buf.push(((word >> 24u32) & 0xFFu32).to_u8())
    buf

fn chacha20_block_local(key: [u8], counter: u32, nonce: [u8]) -> [u8]:
    val s0 = 0x61707865u32
    val s1 = 0x3320646eu32
    val s2 = 0x79622d32u32
    val s3 = 0x6b206574u32
    val s4 = load32(key, 0u64)
    val s5 = load32(key, 4u64)
    val s6 = load32(key, 8u64)
    val s7 = load32(key, 12u64)
    val s8 = load32(key, 16u64)
    val s9 = load32(key, 20u64)
    val s10 = load32(key, 24u64)
    val s11 = load32(key, 28u64)
    val s12 = counter
    val s13 = load32(nonce, 0u64)
    val s14 = load32(nonce, 4u64)
    val s15 = load32(nonce, 8u64)

    var w0 = s0
    var w1 = s1
    var w2 = s2
    var w3 = s3
    var w4 = s4
    var w5 = s5
    var w6 = s6
    var w7 = s7
    var w8 = s8
    var w9 = s9
    var w10 = s10
    var w11 = s11
    var w12 = s12
    var w13 = s13
    var w14 = s14
    var w15 = s15

    var round: u64 = 0u64
    while round < 10u64:
        val q0 = quarter(w0, w4, w8, w12)
        w0 = q0.a
        w4 = q0.b
        w8 = q0.c
        w12 = q0.d
        val q1 = quarter(w1, w5, w9, w13)
        w1 = q1.a
        w5 = q1.b
        w9 = q1.c
        w13 = q1.d
        val q2 = quarter(w2, w6, w10, w14)
        w2 = q2.a
        w6 = q2.b
        w10 = q2.c
        w14 = q2.d
        val q3 = quarter(w3, w7, w11, w15)
        w3 = q3.a
        w7 = q3.b
        w11 = q3.c
        w15 = q3.d
        val d0 = quarter(w0, w5, w10, w15)
        w0 = d0.a
        w5 = d0.b
        w10 = d0.c
        w15 = d0.d
        val d1 = quarter(w1, w6, w11, w12)
        w1 = d1.a
        w6 = d1.b
        w11 = d1.c
        w12 = d1.d
        val d2 = quarter(w2, w7, w8, w13)
        w2 = d2.a
        w7 = d2.b
        w8 = d2.c
        w13 = d2.d
        val d3 = quarter(w3, w4, w9, w14)
        w3 = d3.a
        w4 = d3.b
        w9 = d3.c
        w14 = d3.d
        round = round + 1u64

    var block_out: [u8] = []
    block_out = push_word(block_out, w0 + s0)
    block_out = push_word(block_out, w1 + s1)
    block_out = push_word(block_out, w2 + s2)
    block_out = push_word(block_out, w3 + s3)
    block_out = push_word(block_out, w4 + s4)
    block_out = push_word(block_out, w5 + s5)
    block_out = push_word(block_out, w6 + s6)
    block_out = push_word(block_out, w7 + s7)
    block_out = push_word(block_out, w8 + s8)
    block_out = push_word(block_out, w9 + s9)
    block_out = push_word(block_out, w10 + s10)
    block_out = push_word(block_out, w11 + s11)
    block_out = push_word(block_out, w12 + s12)
    block_out = push_word(block_out, w13 + s13)
    block_out = push_word(block_out, w14 + s14)
    block_out = push_word(block_out, w15 + s15)
    block_out

fn chacha20_encrypt_local(key: [u8], counter: u32, nonce: [u8], plaintext: [u8]) -> [u8]:
    var output: [u8] = []
    var block_counter = counter
    var pos: u64 = 0u64
    while pos < plaintext.len():
        val block = chacha20_block_local(key, block_counter, nonce)
        var j: u64 = 0u64
        while j < 64u64 and pos < plaintext.len():
            output.push(plaintext[pos] ^ block[j])
            pos = pos + 1u64
            j = j + 1u64
        block_counter = block_counter + 1u32
    output

fn report(alg: text, bytes_per_iter: u64, iters: u64, elapsed_us: i64, checksum: u64):
    val total_bytes = bytes_per_iter * iters
    val safe_us = if elapsed_us <= 0: 1 else: elapsed_us
    val mbps = total_bytes / safe_us.to_u64()
    print "[algbench] lang=simple alg={alg} bytes={bytes_per_iter} iters={iters} micros={elapsed_us} mbps={mbps} checksum={checksum}"

fn bench_xxhash(data: [u8]):
    var checksum: u64 = 0u64
    var i: u64 = 0u64
    val iters = xxh_iters()
    val start = rt_time_now_unix_micros()
    while i < iters:
        checksum = checksum ^ xxhash64(data, i)
        i = i + 1u64
    val elapsed = rt_time_now_unix_micros() - start
    report("xxhash64", data.len(), iters, elapsed, checksum)

fn bench_chacha(data: [u8]):
    val key = key32()
    val nonce = nonce12()
    var checksum: u64 = 0u64
    var i: u64 = 0u64
    val iters = chacha_iters()
    val start = rt_time_now_unix_micros()
    while i < iters:
        val out = chacha20_encrypt_local(key, i.to_u32(), nonce, data)
        checksum = checksum ^ checksum_bytes(out)
        i = i + 1u64
    val elapsed = rt_time_now_unix_micros() - start
    report("chacha20", data.len(), iters, elapsed, checksum)

fn main() -> i32:
    val data = make_data(data_size())
    bench_xxhash(data)
    bench_chacha(data)
    0
