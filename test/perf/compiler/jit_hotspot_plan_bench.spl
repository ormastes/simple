# JIT hotspot plan microbenchmark.
#
# Measures the pure Simple planning boundary before native code emission:
# profile fact extraction, eligibility checks, and invalidation bookkeeping.

use test.perf.bench.lib.timing.{BenchResult, bench_print, bench_csv, bench_csv_header, bench_now_ns}
use compiler.interp.execution.tiered_jit.{
    FunctionProfile, JitTier, TieredJitConfig,
    jit_hotspot_plan_from_profile,
    jit_hotspot_plan_invalidate,
    jit_hotspot_rebuild_choice,
    jit_hotspot_optimization_plan,
    jit_hotspot_specialization_provider,
    jit_hotspot_consume_plan_with_provider
}

fn hotspot_bench_config() -> TieredJitConfig:
    TieredJitConfig(tier1_threshold: 64, tier2_threshold: 1024, debug_mode: false)

fn hotspot_bench_profile(name: text, count: i64) -> FunctionProfile:
    FunctionProfile(
        name: name,
        call_count: count,
        tier: JitTier.Interpreted,
        compile_time_ms: 0.0,
        source: "fn " + name + "(x: i64) -> i64: x + 1",
        typed_mir: true,
        safe_deopt: true,
        hotspot_specialized_source: "",
        hotspot_semantic_proof: false
    )

fn hotspot_bench_result(label: text, iters: i64, total_ns: i64, checksum: i64) -> BenchResult:
    val avg = if iters > 0: total_ns / iters else: 0
    val tput = if total_ns > 0: (iters * 1000000) / total_ns else: 0
    BenchResult(
        label: label + "_checksum_" + checksum.to_text(),
        iters: iters,
        p50_ns: avg,
        p99_ns: avg,
        p99_9_ns: avg,
        min_ns: avg,
        max_ns: avg,
        total_ns: total_ns,
        throughput_ops_per_s: tput
    )

fn bench_hotspot_cold_plan(iters: i64) -> BenchResult:
    val config = hotspot_bench_config()
    val profile = hotspot_bench_profile("cold_loop", 8)
    var checksum: i64 = 0
    val t0 = bench_now_ns()
    var i: i64 = 0
    while i < iters:
        val plan = jit_hotspot_plan_from_profile(profile, config, true, true)
        if plan.eligible:
            checksum = checksum + 1
        checksum = checksum + plan.facts.len() as i64
        i = i + 1
    hotspot_bench_result("jit_hotspot_cold_plan", iters, bench_now_ns() - t0, checksum)

fn bench_hotspot_ready_plan(iters: i64) -> BenchResult:
    val config = hotspot_bench_config()
    val profile = hotspot_bench_profile("hot_loop", 4096)
    var checksum: i64 = 0
    val t0 = bench_now_ns()
    var i: i64 = 0
    while i < iters:
        val plan = jit_hotspot_plan_from_profile(profile, config, true, true)
        if plan.eligible:
            checksum = checksum + 1
        checksum = checksum + plan.facts.len() as i64
        i = i + 1
    hotspot_bench_result("jit_hotspot_ready_plan", iters, bench_now_ns() - t0, checksum)

fn bench_hotspot_invalidated_plan(iters: i64) -> BenchResult:
    val config = hotspot_bench_config()
    val profile = hotspot_bench_profile("guarded_loop", 4096)
    var checksum: i64 = 0
    val t0 = bench_now_ns()
    var i: i64 = 0
    while i < iters:
        val plan = jit_hotspot_plan_from_profile(profile, config, true, true)
        val invalidated = jit_hotspot_plan_invalidate(plan, "guard changed")
        if invalidated.invalidated:
            checksum = checksum + 1
        if invalidated.eligible:
            checksum = checksum + 100
        checksum = checksum + invalidated.facts.len() as i64
        i = i + 1
    hotspot_bench_result("jit_hotspot_invalidated_plan", iters, bench_now_ns() - t0, checksum)

fn bench_hotspot_specialized_decision(iters: i64) -> BenchResult:
    val config = hotspot_bench_config()
    val profile = hotspot_bench_profile("specialized_loop", 4096)
    val provider = jit_hotspot_specialization_provider("bench.hotspot.specialized", "fn specialized_loop(x: i64) -> i64: x + 1", true)
    var checksum: i64 = 0
    val t0 = bench_now_ns()
    var i: i64 = 0
    while i < iters:
        val plan = jit_hotspot_plan_from_profile(profile, config, true, true)
        val decision = jit_hotspot_consume_plan_with_provider(plan, profile.source, provider)
        if decision.provider_used:
            checksum = checksum + 1
        checksum = checksum + decision.compile_source.len() as i64
        i = i + 1
    hotspot_bench_result("jit_hotspot_specialized_decision", iters, bench_now_ns() - t0, checksum)

fn bench_hotspot_cranelift_medium_optimization_plan(iters: i64) -> BenchResult:
    val config = hotspot_bench_config()
    val profile = hotspot_bench_profile("cranelift_plan_loop", 4096)
    var checksum: i64 = 0
    val t0 = bench_now_ns()
    var i: i64 = 0
    while i < iters:
        val plan = jit_hotspot_optimization_plan(profile, config, true, true, "medium")
        if plan.eligible and plan.backend == "cranelift":
            checksum = checksum + 1
        checksum = checksum + plan.passes.len() as i64
        checksum = checksum + plan.plugin_recommendations.len() as i64
        checksum = checksum + plan.skipped_plugin_recommendations.len() as i64
        i = i + 1
    hotspot_bench_result("jit_hotspot_cranelift_medium_optimization_plan", iters, bench_now_ns() - t0, checksum)

fn bench_hotspot_llvm_high_optimization_plan(iters: i64) -> BenchResult:
    val config = hotspot_bench_config()
    val profile = hotspot_bench_profile("llvm_plan_loop", 4096)
    var checksum: i64 = 0
    val t0 = bench_now_ns()
    var i: i64 = 0
    while i < iters:
        val plan = jit_hotspot_optimization_plan(profile, config, true, true, "high")
        if plan.eligible and plan.backend == "llvm":
            checksum = checksum + 1
        checksum = checksum + plan.passes.len() as i64
        checksum = checksum + plan.plugin_recommendations.len() as i64
        checksum = checksum + plan.skipped_plugin_recommendations.len() as i64
        i = i + 1
    hotspot_bench_result("jit_hotspot_llvm_high_optimization_plan", iters, bench_now_ns() - t0, checksum)

fn bench_hotspot_medium_budget_backend_choice(iters: i64) -> BenchResult:
    val config = hotspot_bench_config()
    val profile = hotspot_bench_profile("budget_choice_loop", 4096)
    var checksum: i64 = 0
    val t0 = bench_now_ns()
    var i: i64 = 0
    while i < iters:
        val choice = jit_hotspot_rebuild_choice(profile, config, true, true, "medium")
        if choice.eligible and choice.selected_backend == "cranelift":
            checksum = checksum + 1
        checksum = checksum + choice.attempted_backends.len() as i64
        checksum = checksum + choice.required_count
        i = i + 1
    hotspot_bench_result("jit_hotspot_medium_budget_backend_choice", iters, bench_now_ns() - t0, checksum)

fn main():
    val iters: i64 = 500
    print "=== JIT hotspot plan benchmark ==="
    print "note: pure planning only; no native JIT compilation is invoked."

    val cold = bench_hotspot_cold_plan(iters)
    val ready = bench_hotspot_ready_plan(iters)
    val invalidated = bench_hotspot_invalidated_plan(iters)
    val specialized = bench_hotspot_specialized_decision(iters)
    val cranelift_medium = bench_hotspot_cranelift_medium_optimization_plan(iters)
    val llvm_high = bench_hotspot_llvm_high_optimization_plan(iters)
    val budget_choice = bench_hotspot_medium_budget_backend_choice(iters)

    bench_print(cold)
    bench_print(ready)
    bench_print(invalidated)
    bench_print(specialized)
    bench_print(cranelift_medium)
    bench_print(llvm_high)
    bench_print(budget_choice)

    print ""
    print bench_csv_header()
    print bench_csv(cold)
    print bench_csv(ready)
    print bench_csv(invalidated)
    print bench_csv(specialized)
    print bench_csv(cranelift_medium)
    print bench_csv(llvm_high)
    print bench_csv(budget_choice)
