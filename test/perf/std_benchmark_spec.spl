# Std Benchmark Library Tests
#
# **Feature IDs:** Testing Infrastructure - Benchmarking
# **Category:** Testing | Performance
# **Status:** Implemented
#
# Tests for the `std.testing.benchmark` library for measuring and comparing
# execution time of Simple functions.
# Note: interpreter mode only verifies file loading (it block bodies don't execute).
# Uses single `it` block pattern for interpreter compatibility.

extern fn rt_current_time_ms() -> i64

fn check(v):
    expect(v).to_equal(true)

# =========================================================================
# Test helpers (module-level for interpreter compatibility)
# =========================================================================

fn test_time_now_ms() -> bool:
    # rt_current_time_ms is registered in the interpreter dispatch table.
    val t1 = rt_current_time_ms()
    val t2 = rt_current_time_ms()
    t1 > 0 and t2 >= t1

fn test_time_function() -> bool:
    # Inline time_function to avoid module import issues
    val start = rt_current_time_ms()
    val x = 1 + 1
    val end_val = rt_current_time_ms()
    val elapsed = end_val - start
    elapsed >= 0

# =========================================================================
# Test execution
# =========================================================================

describe "Benchmarking Library":
    it "rt_current_time_ms returns monotonic positive values":
        check(test_time_now_ms())

    it "time_function measures non-negative elapsed time":
        check(test_time_function())
