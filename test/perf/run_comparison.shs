#!/bin/bash
# Rust vs Simple Performance Comparison Runner
#
# Runs the benchmark spec under both the Rust bootstrap and self-hosted
# Simple binaries, then prints a side-by-side comparison table.
#
# Usage:
#   bash test/perf/run_comparison.ssh
#   bash test/perf/run_comparison.ssh --profile   # Also show resolve stats

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"

RUST_BIN="$PROJECT_ROOT/src/compiler_rust/target/bootstrap/simple"
SIMPLE_BIN="$PROJECT_ROOT/bin/release/simple"
BENCH_FILE="$SCRIPT_DIR/rust_vs_simple_comparison_spec.spl"

PROFILE_FLAG=""
if [[ "${1:-}" == "--profile" ]]; then
    PROFILE_FLAG="SIMPLE_PROFILE=1"
fi

# Check binaries exist
if [[ ! -x "$RUST_BIN" ]]; then
    echo "ERROR: Rust bootstrap not found at $RUST_BIN"
    echo "Build with: cd src/compiler_rust && cargo build --profile bootstrap -p simple-driver"
    exit 1
fi

if [[ ! -x "$SIMPLE_BIN" ]]; then
    echo "ERROR: Self-hosted binary not found at $SIMPLE_BIN"
    echo "Build with: bin/simple build --release"
    exit 1
fi

if [[ ! -f "$BENCH_FILE" ]]; then
    echo "ERROR: Benchmark file not found at $BENCH_FILE"
    exit 1
fi

echo "=================================================================="
echo "  Rust vs Simple Performance Comparison"
echo "=================================================================="
echo ""
echo "Rust bootstrap:  $RUST_BIN"
echo "Self-hosted:     $SIMPLE_BIN"
echo "Benchmark file:  $BENCH_FILE"
echo ""

# Run Rust benchmark
echo "--- Running Rust bootstrap benchmark ---"
RUST_OUTPUT_FILE=$(mktemp)
RUST_START=$(date +%s%N)
if [[ -n "$PROFILE_FLAG" ]]; then
    env $PROFILE_FLAG "$RUST_BIN" "$BENCH_FILE" > "$RUST_OUTPUT_FILE" 2>&1 || true
else
    "$RUST_BIN" "$BENCH_FILE" > "$RUST_OUTPUT_FILE" 2>&1 || true
fi
RUST_END=$(date +%s%N)
RUST_WALL_MS=$(( (RUST_END - RUST_START) / 1000000 ))
echo "Rust wall clock: ${RUST_WALL_MS}ms"
echo ""

# Run Simple benchmark
echo "--- Running Self-hosted benchmark ---"
SIMPLE_OUTPUT_FILE=$(mktemp)
SIMPLE_START=$(date +%s%N)
if [[ -n "$PROFILE_FLAG" ]]; then
    env $PROFILE_FLAG "$SIMPLE_BIN" "$BENCH_FILE" > "$SIMPLE_OUTPUT_FILE" 2>&1 || true
else
    "$SIMPLE_BIN" "$BENCH_FILE" > "$SIMPLE_OUTPUT_FILE" 2>&1 || true
fi
SIMPLE_END=$(date +%s%N)
SIMPLE_WALL_MS=$(( (SIMPLE_END - SIMPLE_START) / 1000000 ))
echo "Simple wall clock: ${SIMPLE_WALL_MS}ms"
echo ""

# Parse [bench] lines and build comparison
echo "=================================================================="
echo "  Results Comparison"
echo "=================================================================="
echo ""
printf "%-35s %12s %12s %8s\n" "Benchmark" "Rust (us)" "Simple (us)" "Ratio"
printf "%-35s %12s %12s %8s\n" "-----------------------------------" "------------" "------------" "--------"

# Extract [bench] lines from both outputs
declare -A RUST_AVG
declare -A SIMPLE_AVG
declare -a BENCH_NAMES

while IFS= read -r line; do
    if [[ "$line" =~ ^\[bench\]\ (.+):\ avg=([0-9]+)us ]]; then
        name="${BASH_REMATCH[1]}"
        avg="${BASH_REMATCH[2]}"
        RUST_AVG["$name"]="$avg"
        BENCH_NAMES+=("$name")
    fi
done < "$RUST_OUTPUT_FILE"

while IFS= read -r line; do
    if [[ "$line" =~ ^\[bench\]\ (.+):\ avg=([0-9]+)us ]]; then
        name="${BASH_REMATCH[1]}"
        avg="${BASH_REMATCH[2]}"
        SIMPLE_AVG["$name"]="$avg"
    fi
done < "$SIMPLE_OUTPUT_FILE"

# Print comparison table
TOTAL_RUST=0
TOTAL_SIMPLE=0

for name in "${BENCH_NAMES[@]}"; do
    rust_val="${RUST_AVG[$name]:-0}"
    simple_val="${SIMPLE_AVG[$name]:-0}"

    TOTAL_RUST=$((TOTAL_RUST + rust_val))
    TOTAL_SIMPLE=$((TOTAL_SIMPLE + simple_val))

    if [[ "$rust_val" -gt 0 && "$simple_val" -gt 0 ]]; then
        # Calculate ratio (integer arithmetic — multiply first for precision)
        ratio_x10=$((simple_val * 10 / rust_val))
        ratio_int=$((ratio_x10 / 10))
        ratio_frac=$((ratio_x10 % 10))
        ratio_str="${ratio_int}.${ratio_frac}x"
    elif [[ "$simple_val" -eq 0 ]]; then
        ratio_str="N/A"
    else
        ratio_str="N/A"
    fi

    printf "%-35s %12s %12s %8s\n" "$name" "$rust_val" "$simple_val" "$ratio_str"
done

echo ""
printf "%-35s %12s %12s\n" "--- Totals ---" "" ""
printf "%-35s %12s %12s" "Sum of avg times" "$TOTAL_RUST" "$TOTAL_SIMPLE"
if [[ "$TOTAL_RUST" -gt 0 ]]; then
    total_ratio_x10=$((TOTAL_SIMPLE * 10 / TOTAL_RUST))
    total_int=$((total_ratio_x10 / 10))
    total_frac=$((total_ratio_x10 % 10))
    printf " %8s" "${total_int}.${total_frac}x"
fi
echo ""

echo ""
printf "%-35s %12s %12s" "Wall clock (ms)" "$RUST_WALL_MS" "$SIMPLE_WALL_MS"
if [[ "$RUST_WALL_MS" -gt 0 ]]; then
    wall_ratio_x10=$((SIMPLE_WALL_MS * 10 / RUST_WALL_MS))
    wall_int=$((wall_ratio_x10 / 10))
    wall_frac=$((wall_ratio_x10 % 10))
    printf " %8s" "${wall_int}.${wall_frac}x"
fi
echo ""

# Show resolve stats if profiled
if [[ -n "$PROFILE_FLAG" ]]; then
    echo ""
    echo "=================================================================="
    echo "  Resolution Stats"
    echo "=================================================================="
    echo ""
    echo "--- Rust bootstrap ---"
    grep -E "\[resolve|profile|stats\]" "$RUST_OUTPUT_FILE" 2>/dev/null || echo "(no resolve stats)"
    echo ""
    echo "--- Self-hosted ---"
    grep -E "\[resolve|profile|stats\]" "$SIMPLE_OUTPUT_FILE" 2>/dev/null || echo "(no resolve stats)"
fi

# Save raw output
RESULTS_DIR="$PROJECT_ROOT/doc/report"
mkdir -p "$RESULTS_DIR"

echo ""
echo "=================================================================="
echo "  Raw Output Files"
echo "=================================================================="
echo "Rust output:   $RUST_OUTPUT_FILE"
echo "Simple output: $SIMPLE_OUTPUT_FILE"

# Cleanup
# rm -f "$RUST_OUTPUT_FILE" "$SIMPLE_OUTPUT_FILE"
