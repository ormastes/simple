# Direct typed-u64 push/length repro.

extern fn rt_array_new_with_cap_u64(cap: i64) -> [u64]
extern fn rt_typed_words_u64_push(array: [u64], value: i64) -> bool
extern fn rt_typed_words_u64_at(array: [u64], index: i64) -> i64
extern fn rt_array_len(array: [u64]) -> i64

fn main():
    var data: [u64] = rt_array_new_with_cap_u64(8)
    var i: i64 = 0
    while i < 8:
        rt_typed_words_u64_push(data, 0xFF000000 + i)
        print "TYPED_U64_PUSH i={i} len={rt_array_len(data)}"
        i = i + 1
    print "TYPED_U64_PUSH_FINAL len={rt_array_len(data)} p0={data[0]} at0={rt_typed_words_u64_at(data, 0)} p1={data[1]} p7={data[7]}"
