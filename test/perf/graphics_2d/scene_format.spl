# test/perf/graphics_2d/scene_format.spl
#
# Shared scene fixture definitions for the C vs Simple 2D CPU benchmark.
# Canonical source: this file. bench_2d.c mirrors these definitions.
#
# Pixel format: RGBA8888, byte order R,G,B,A per pixel, row-major.
# Packed as (A<<24)|(B<<16)|(G<<8)|R in an integer constant.
#
# 3 mandatory scenes for NFR-2B:
#   fill_1080p      — clear 1920x1080 + 100 filled rects
#   blit_tiles      — 1920x1080 tiled blit of 64x64 sprites
#   clipped_scroll  — 1920x1080 viewport with clipped scrolling content

val SCENE_FRAME_W: i64 = 1920
val SCENE_FRAME_H: i64 = 1080
val SCENE_SPRITE_W: i64 = 64
val SCENE_SPRITE_H: i64 = 64

val SCENE_FILL:   text = "fill_1080p"
val SCENE_BLIT:   text = "blit_tiles"
val SCENE_SCROLL: text = "clipped_scroll"

val CANONICAL_SCENE_NAMES: [text] = ["fill_1080p", "blit_tiles", "clipped_scroll"]

# NFR-2B threshold: simple_p50_ns / c_p50_ns * 1000 must be <= 1250 (1.25x)
val NFR_RATIO_THRESHOLD: i64 = 1250
