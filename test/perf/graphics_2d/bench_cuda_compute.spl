# Simple CUDA Compute Benchmark — sum of squares on GPU
#
# Compares Simple interpreter calling CUDA kernel vs CPU-only.
# Same computation as bench_2d_tiered_jit.spl: sum(i*i for i in 0..N)

extern fn rt_cuda_init() -> i64
extern fn rt_cuda_device_count() -> i64
extern fn rt_cuda_device_get(id: i64) -> i64
extern fn rt_cuda_ctx_create(device: i64) -> i64
extern fn rt_cuda_ctx_destroy(ctx: i64) -> i64
extern fn rt_cuda_mem_alloc(size: i64) -> i64
extern fn rt_cuda_mem_free(ptr: i64) -> i64
extern fn rt_cuda_memset(ptr: i64, value: i64, size: i64) -> i64
extern fn rt_cuda_memcpy_dtoh(dst: i64, src: i64, size: i64) -> i64
extern fn rt_cuda_module_load_data(ptx: text) -> i64
extern fn rt_cuda_module_unload(module: i64) -> i64
extern fn rt_cuda_launch_kernel(module: i64, func_name: text, grid_x: i64, grid_y: i64, grid_z: i64, block_x: i64, block_y: i64, block_z: i64, args_ptr: i64) -> i64
extern fn rt_cuda_sync() -> i64
extern fn rt_time_now_seconds() -> f64
extern fn rt_alloc(size: i64) -> i64
extern fn rt_ptr_write_i64(ptr: i64, offset: i64, value: i64) -> i64
extern fn rt_ptr_read_i64(ptr: i64, offset: i64) -> i64

val PTX_SUM_SQUARES = ".version 7.5\n.target sm_75\n.address_size 64\n\n.visible .entry sum_squares(\n    .param .u64 param_result,\n    .param .u64 param_n\n) {\n    .reg .u64 %rd<12>;\n    .reg .u32 %r<6>;\n    .reg .pred %p1, %p2;\n    .shared .align 8 .u64 sdata[256];\n\n    mov.u32 %r0, %tid.x;\n    mov.u32 %r1, %ctaid.x;\n    mov.u32 %r2, %ntid.x;\n    mov.u32 %r3, %nctaid.x;\n\n    // idx = blockIdx * blockDim + threadIdx\n    mul.wide.u32 %rd10, %r1, %r2;\n    cvt.u64.u32 %rd0, %r0;\n    add.u64 %rd0, %rd10, %rd0;\n    // stride = gridDim * blockDim\n    mul.wide.u32 %rd1, %r3, %r2;\n\n    ld.param.u64 %rd2, [param_n];\n    mov.u64 %rd3, 0;\n\nloop:\n    setp.ge.u64 %p1, %rd0, %rd2;\n    @%p1 bra end_loop;\n    mul.lo.u64 %rd4, %rd0, %rd0;\n    add.u64 %rd3, %rd3, %rd4;\n    add.u64 %rd0, %rd0, %rd1;\n    bra loop;\n\nend_loop:\n    cvt.u64.u32 %rd5, %r0;\n    shl.b64 %rd5, %rd5, 3;\n    mov.u64 %rd6, sdata;\n    add.u64 %rd6, %rd6, %rd5;\n    st.shared.u64 [%rd6], %rd3;\n    bar.sync 0;\n\n    mov.u32 %r4, 128;\nreduce:\n    setp.eq.u32 %p2, %r4, 0;\n    @%p2 bra done_reduce;\n    setp.ge.u32 %p1, %r0, %r4;\n    @%p1 bra skip_reduce;\n    cvt.u64.u32 %rd7, %r4;\n    shl.b64 %rd7, %rd7, 3;\n    add.u64 %rd8, %rd6, %rd7;\n    ld.shared.u64 %rd9, [%rd8];\n    ld.shared.u64 %rd4, [%rd6];\n    add.u64 %rd4, %rd4, %rd9;\n    st.shared.u64 [%rd6], %rd4;\nskip_reduce:\n    bar.sync 0;\n    shr.u32 %r4, %r4, 1;\n    bra reduce;\n\ndone_reduce:\n    setp.ne.u32 %p1, %r0, 0;\n    @%p1 bra done;\n    ld.shared.u64 %rd3, [sdata];\n    ld.param.u64 %rd4, [param_result];\n    atom.global.add.u64 %rd5, [%rd4], %rd3;\ndone:\n    ret;\n}\n"

fn hot_compute(n: i64) -> i64:
    var sum = 0
    var i = 0
    while i < n:
        sum = sum + i * i
        i = i + 1
    sum

fn main():
    print("=== Simple CUDA Compute Benchmark ===")
    print("")

    var err = rt_cuda_init()
    if err != 0:
        print("FAIL: CUDA init error=" + err.to_string())
        return

    var count = rt_cuda_device_count()
    if count == 0:
        print("FAIL: No CUDA devices")
        return

    var dev = rt_cuda_device_get(0)
    var ctx = rt_cuda_ctx_create(dev)
    if ctx < 0:
        print("FAIL: ctx_create error=" + ctx.to_string())
        return
    print("  CUDA context created on device 0")

    var module = rt_cuda_module_load_data(PTX_SUM_SQUARES)
    if module <= 0:
        print("FAIL: module_load_data error=" + module.to_string())
        rt_cuda_ctx_destroy(ctx)
        return
    print("  PTX module loaded")

    var d_result = rt_cuda_mem_alloc(8)
    if d_result <= 0:
        print("FAIL: mem_alloc error")
        rt_cuda_module_unload(module)
        rt_cuda_ctx_destroy(ctx)
        return

    val N = 100000
    val MEASURED_CALLS = 200

    # Setup kernel params: double-indirection for cuLaunchKernel
    # param_result (u64) and param_n (u64)
    var val_buf = rt_alloc(16)
    rt_ptr_write_i64(val_buf, 0, d_result)
    rt_ptr_write_i64(val_buf, 8, N)
    var ptrs_buf = rt_alloc(16)
    rt_ptr_write_i64(ptrs_buf, 0, val_buf)
    rt_ptr_write_i64(ptrs_buf, 8, val_buf + 8)

    # Warmup + correctness check
    rt_cuda_memset(d_result, 0, 8)
    rt_cuda_launch_kernel(module, "sum_squares", 256, 1, 1, 256, 1, 1, ptrs_buf)
    rt_cuda_sync()

    var h_buf = rt_alloc(8)
    rt_cuda_memcpy_dtoh(h_buf, d_result, 8)
    var gpu_result = rt_ptr_read_i64(h_buf, 0)
    var cpu_result = hot_compute(N)

    print("")
    print("--- Correctness (N=" + N.to_string() + ") ---")
    print("  GPU result: " + gpu_result.to_string())
    print("  CPU result: " + cpu_result.to_string())
    if gpu_result == cpu_result:
        print("  PASS: results match")
    else:
        print("  MISMATCH!")

    # Benchmark GPU
    print("")
    print("--- GPU Benchmark (" + MEASURED_CALLS.to_string() + " calls) ---")
    var t0 = rt_time_now_seconds()
    var j = 0
    while j < MEASURED_CALLS:
        rt_cuda_memset(d_result, 0, 8)
        rt_cuda_launch_kernel(module, "sum_squares", 256, 1, 1, 256, 1, 1, ptrs_buf)
        rt_cuda_sync()
        j = j + 1
    var t1 = rt_time_now_seconds()
    var gpu_s = t1 - t0

    # Benchmark CPU (interpreter)
    print("--- CPU Benchmark (interpreter, " + MEASURED_CALLS.to_string() + " calls) ---")
    var t2 = rt_time_now_seconds()
    j = 0
    while j < MEASURED_CALLS:
        hot_compute(N)
        j = j + 1
    var t3 = rt_time_now_seconds()
    var cpu_s = t3 - t2

    # Results
    print("")
    print("=== Results (sum(i*i) for i in 0.." + N.to_string() + ") ===")
    print("  GPU (Simple+CUDA): " + MEASURED_CALLS.to_string() + " calls in " + gpu_s.to_string() + " s")
    print("  CPU (interpreter): " + MEASURED_CALLS.to_string() + " calls in " + cpu_s.to_string() + " s")
    if gpu_s > 0.0:
        var ratio = cpu_s / gpu_s
        print("  GPU speedup over interpreter: " + ratio.to_string() + "x")

    # Cleanup
    rt_cuda_mem_free(d_result)
    rt_cuda_module_unload(module)
    rt_cuda_ctx_destroy(ctx)
