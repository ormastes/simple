# test/perf/graphics_2d/cpu_simd_spec.spl
#
# **Feature IDs:** AC-6 — CPU SIMD kernels declared to optimization plugin metadata;
#                  provider hit counts reported per frame.
#                  AC-12 — auto_vectorize + simd_lowering provider hit/change counts.
# **Category:** Graphics | SIMD | CPU
# **Status:** Pending implementation (Phase 5)
#
# Verifies:
#   - SIMD kernels (fill, copy, alpha_blend, blit, scroll) are declared
#   - SimdProvider hit counts are reported per frame (not zero after a frame)
#   - Scalar and SIMD paths produce identical results (same pixel hash)
#   - Target features (x86 AVX2, ARM NEON, RISC-V V or scalar fallback) are reported
#   - vectorize_changes count is reported per frame
#
# @cover src/lib/gc_async_mut/gpu/engine2d/simd_kernels.spl
# @cover src/lib/gc_async_mut/gpu/engine2d/simd_provider.spl
# @cover src/compiler/60.mir_opt/mir_opt/auto_vectorize.spl

val KERNEL_FILL:        text = "fill"
val KERNEL_COPY:        text = "copy"
val KERNEL_ALPHA_BLEND: text = "alpha_blend"
val KERNEL_BLIT:        text = "blit"
val KERNEL_SCROLL:      text = "scroll"

struct SimdHitCountsSentinel:
    fill_hits:          i64
    copy_hits:          i64
    alpha_hits:         i64
    blit_hits:          i64
    scroll_hits:        i64
    vectorize_changes:  i64

struct SimdTargetSentinel:
    arch:               text   # "x86_64" | "aarch64" | "riscv64" | "unknown"
    feature:            text   # "avx2" | "neon" | "rvv" | "scalar"
    scalar_hash:        i64
    simd_hash:          i64

fn make_simd_hit_counts(fills: i64, copies: i64, alphas: i64, blits: i64, scrolls: i64, changes: i64) -> SimdHitCountsSentinel:
    SimdHitCountsSentinel(
        fill_hits:         fills,
        copy_hits:         copies,
        alpha_hits:        alphas,
        blit_hits:         blits,
        scroll_hits:       scrolls,
        vectorize_changes: changes
    )

fn make_simd_target_x86(scalar_h: i64, simd_h: i64) -> SimdTargetSentinel:
    SimdTargetSentinel(
        arch:        "x86_64",
        feature:     "avx2",
        scalar_hash: scalar_h,
        simd_hash:   simd_h
    )

fn make_simd_target_arm(scalar_h: i64, simd_h: i64) -> SimdTargetSentinel:
    SimdTargetSentinel(
        arch:        "aarch64",
        feature:     "neon",
        scalar_hash: scalar_h,
        simd_hash:   simd_h
    )

fn make_simd_target_scalar(scalar_h: i64, simd_h: i64) -> SimdTargetSentinel:
    SimdTargetSentinel(
        arch:        "unknown",
        feature:     "scalar",
        scalar_hash: scalar_h,
        simd_hash:   simd_h
    )

fn simd_parity_ok(t: SimdTargetSentinel) -> bool:
    t.scalar_hash == t.simd_hash

describe "cpu_simd — AC-6/AC-12: SIMD kernels, provider hit counts, target features":

    describe "kernel name constants":

        it "AC-6: fill kernel name is fill":
            expect(KERNEL_FILL).to_equal("fill")

        it "AC-6: copy kernel name is copy":
            expect(KERNEL_COPY).to_equal("copy")

        it "AC-6: alpha_blend kernel name is alpha_blend":
            expect(KERNEL_ALPHA_BLEND).to_equal("alpha_blend")

        it "AC-6: blit kernel name is blit":
            expect(KERNEL_BLIT).to_equal("blit")

        it "AC-6: scroll kernel name is scroll":
            expect(KERNEL_SCROLL).to_equal("scroll")

        it "AC-6: five distinct kernel names exist":
            val kernels: [text] = [KERNEL_FILL, KERNEL_COPY, KERNEL_ALPHA_BLEND, KERNEL_BLIT, KERNEL_SCROLL]
            expect(kernels.len()).to_equal(5)

    describe "SimdHitCounts fields after one frame":

        it "AC-6: fill_hits is greater than zero after a frame with fill":
            val c: SimdHitCountsSentinel = make_simd_hit_counts(1, 0, 0, 0, 0, 1)
            expect(c.fill_hits > 0).to_equal(true)

        it "AC-6: copy_hits is greater than zero after a frame with copy":
            val c: SimdHitCountsSentinel = make_simd_hit_counts(0, 1, 0, 0, 0, 1)
            expect(c.copy_hits > 0).to_equal(true)

        it "AC-6: alpha_hits is greater than zero after a frame with alpha_blend":
            val c: SimdHitCountsSentinel = make_simd_hit_counts(0, 0, 1, 0, 0, 1)
            expect(c.alpha_hits > 0).to_equal(true)

        it "AC-6: blit_hits is greater than zero after a frame with blit":
            val c: SimdHitCountsSentinel = make_simd_hit_counts(0, 0, 0, 1, 0, 1)
            expect(c.blit_hits > 0).to_equal(true)

        it "AC-6: scroll_hits is greater than zero after a frame with scroll":
            val c: SimdHitCountsSentinel = make_simd_hit_counts(0, 0, 0, 0, 1, 1)
            expect(c.scroll_hits > 0).to_equal(true)

        it "AC-12: vectorize_changes is reported (not negative)":
            val c: SimdHitCountsSentinel = make_simd_hit_counts(1, 1, 1, 1, 1, 3)
            expect(c.vectorize_changes >= 0).to_equal(true)

        it "AC-12: vectorize_changes count is greater than zero after vectorized frame":
            val c: SimdHitCountsSentinel = make_simd_hit_counts(1, 1, 1, 1, 1, 3)
            expect(c.vectorize_changes > 0).to_equal(true)

    describe "scalar vs SIMD parity":

        it "AC-6: x86 AVX2 SIMD hash matches scalar hash":
            val t: SimdTargetSentinel = make_simd_target_x86(0xABCD1234, 0xABCD1234)
            expect(simd_parity_ok(t)).to_equal(true)

        it "AC-6: ARM NEON SIMD hash matches scalar hash":
            val t: SimdTargetSentinel = make_simd_target_arm(0xDEADBEEF, 0xDEADBEEF)
            expect(simd_parity_ok(t)).to_equal(true)

        it "AC-6: scalar fallback hash matches scalar reference":
            val t: SimdTargetSentinel = make_simd_target_scalar(0xCAFEBABE, 0xCAFEBABE)
            expect(simd_parity_ok(t)).to_equal(true)

        it "AC-6: differing hashes on x86 indicates a parity failure":
            val t: SimdTargetSentinel = make_simd_target_x86(0xABCD1234, 0xFFFF0000)
            expect(simd_parity_ok(t)).to_equal(false)

    describe "target feature reporting":

        it "AC-6: x86_64 target reports avx2 feature":
            val t: SimdTargetSentinel = make_simd_target_x86(1, 1)
            expect(t.arch).to_equal("x86_64")
            expect(t.feature).to_equal("avx2")

        it "AC-6: aarch64 target reports neon feature":
            val t: SimdTargetSentinel = make_simd_target_arm(1, 1)
            expect(t.arch).to_equal("aarch64")
            expect(t.feature).to_equal("neon")

        it "AC-6: unknown arch falls back to scalar feature":
            val t: SimdTargetSentinel = make_simd_target_scalar(1, 1)
            expect(t.feature).to_equal("scalar")
