# test/perf/graphics_2d/bench_2d_metal_simple_jit.spl
#
# JIT-compiled Metal blit benchmark.
# Hypothesis: the 2.85x interpreter overhead for blit_tiles comes from
# per-iteration interpreter dispatch. By JIT-compiling the hot inner loop
# to native ARM64 (Cranelift), we expect to close this gap to ~1.2x or better.
#
# Technique: resource handles (i64 pointers) are baked as integer literals
# into the generated JIT source string. This lets us use the single-arg
# rt_jit_call_i64 API (Cranelift JIT only supports 0/1/2 args from Simple).
# The hot function loops `iters` times, calling rt_metal_run_blit_frame each
# iter, and returns the total elapsed nanoseconds.
#
# NOTE: p50_ns is reported as (total_ns / iters) — an arithmetic mean, not a
# true percentile. Blit jitter is small so mean ≈ p50 for this workload.
#
# Output format matches bench_2d_metal_simple.spl (SCENE_RESULT lines).
# backend=simple_metal_gpu_jit

use compiler.interp.execution.tiered_jit.{TieredJitConfig, JitTier, default_config}
use compiler.interp.execution.tiered_jit_manager.{TieredJitManager}

# ─── Metal FFI ───────────────────────────────────────────────────────────────

extern fn rt_metal_is_available() -> i64
extern fn rt_metal_create_device(idx: i64) -> i64
extern fn rt_metal_destroy_device(dev: i64) -> i64
extern fn rt_metal_create_command_queue(dev: i64) -> i64
extern fn rt_metal_destroy_command_queue(q: i64) -> i64
extern fn rt_metal_alloc_buffer(dev: i64, size: i64) -> i64
extern fn rt_metal_free_buffer(buf: i64) -> i64
extern fn rt_metal_compile_shader(dev: i64, source: text) -> i64
extern fn rt_metal_create_compute_pipeline(dev: i64, lib: i64, entry: text) -> i64
extern fn rt_metal_destroy_pipeline(p: i64) -> i64
extern fn rt_metal_destroy_shader(s: i64) -> i64
extern fn rt_metal_run_blit_frame(queue: i64, pipeline: i64, buf0: i64, buf1: i64, buf2: i64, params_ptr: i64, params_size: i64, gx: i64, gy: i64, gz: i64, bx: i64, by: i64, bz: i64) -> i64

# ─── Memory helpers ──────────────────────────────────────────────────────────

extern fn rt_alloc(size: i64) -> i64
extern fn rt_free(ptr: i64) -> i64
extern fn rt_ptr_write_i32(ptr: i64, offset: i64, value: i64) -> i64
extern fn rt_metal_buffer_upload(buf: i64, data: i64, size: i64) -> i64

# ─── Timing ──────────────────────────────────────────────────────────────────

extern fn rt_time_now_nanos() -> i64

# ─── Constants ───────────────────────────────────────────────────────────────

val FRAME_W:       i64 = 1920
val FRAME_H:       i64 = 1080
val BYTES_PER_PX:  i64 = 4
val FB_SIZE:       i64 = 1920 * 1080 * 4
val TILE_W:        i64 = 64
val TILE_H:        i64 = 64
val N_TILES:       i64 = 30
val WARMUP_ITERS:  i64 = 128
val TIMED_ITERS:   i64 = 200

# ─── MSL source (blit_kernel only) ───────────────────────────────────────────

val MSL_SOURCE: text = "#include <metal_stdlib>\nusing namespace metal;\n\nstruct TileDesc { uint src_byte_off; uint dst_byte_off; };\nkernel void blit_kernel(\n    device const uint8_t *src [[ buffer(0) ]],\n    device uint8_t *dst [[ buffer(1) ]],\n    device const TileDesc *tiles [[ buffer(2) ]],\n    constant uint &fb_w [[ buffer(3) ]],\n    uint3 gtid [[ thread_position_in_grid ]])\n{\n    uint tile_idx = gtid.z; uint px = gtid.x; uint py = gtid.y;\n    TileDesc td = tiles[tile_idx];\n    uint src_off = td.src_byte_off + (py * 64u + px) * 4u;\n    uint dst_off = td.dst_byte_off + (py * fb_w + px) * 4u;\n    dst[dst_off+0] = src[src_off+0]; dst[dst_off+1] = src[src_off+1];\n    dst[dst_off+2] = src[src_off+2]; dst[dst_off+3] = src[src_off+3];\n}\n"

# ─── Setup ────────────────────────────────────────────────────────────────────

var g_dev:       i64 = 0
var g_queue:     i64 = 0
var g_blit_pso:  i64 = 0
var g_src_buf:   i64 = 0
var g_dst_buf:   i64 = 0
var g_tiles_buf: i64 = 0
var g_params:    i64 = 0

fn setup() -> bool:
    g_dev = rt_metal_create_device(0)
    if g_dev == 0:
        print("ERROR: rt_metal_create_device returned 0")
        return false

    g_queue = rt_metal_create_command_queue(g_dev)
    if g_queue == 0:
        print("ERROR: rt_metal_create_command_queue returned 0")
        return false

    var lib = rt_metal_compile_shader(g_dev, MSL_SOURCE)
    if lib == 0:
        print("ERROR: rt_metal_compile_shader returned 0")
        return false

    g_blit_pso = rt_metal_create_compute_pipeline(g_dev, lib, "blit_kernel")
    rt_metal_destroy_shader(lib)
    if g_blit_pso == 0:
        print("ERROR: blit pipeline creation failed")
        return false

    g_src_buf = rt_metal_alloc_buffer(g_dev, FB_SIZE)
    g_dst_buf = rt_metal_alloc_buffer(g_dev, FB_SIZE)
    if g_src_buf == 0 or g_dst_buf == 0:
        print("ERROR: framebuffer alloc failed")
        return false

    var tiles_size: i64 = N_TILES * 8
    g_tiles_buf = rt_metal_alloc_buffer(g_dev, tiles_size)
    if g_tiles_buf == 0:
        print("ERROR: tiles buffer alloc failed")
        return false

    var tiles_cpu = rt_alloc(tiles_size)
    var tiles_per_row: i64 = FRAME_W / TILE_W
    var ti: i64 = 0
    while ti < N_TILES:
        var src_off: i64 = ti * TILE_W * TILE_H * BYTES_PER_PX
        var col: i64 = ti mod tiles_per_row
        var row: i64 = ti / tiles_per_row
        var dst_off: i64 = (row * FRAME_W * TILE_H + col * TILE_W) * BYTES_PER_PX
        rt_ptr_write_i32(tiles_cpu, ti * 8,     src_off)
        rt_ptr_write_i32(tiles_cpu, ti * 8 + 4, dst_off)
        ti = ti + 1
    rt_metal_buffer_upload(g_tiles_buf, tiles_cpu, tiles_size)
    rt_free(tiles_cpu)

    # fb_w param: 4-byte block holding FRAME_W as u32
    g_params = rt_alloc(4)
    rt_ptr_write_i32(g_params, 0, FRAME_W)

    true

# ─── Teardown ─────────────────────────────────────────────────────────────────

fn teardown():
    rt_free(g_params)
    rt_metal_free_buffer(g_src_buf)
    rt_metal_free_buffer(g_dst_buf)
    rt_metal_free_buffer(g_tiles_buf)
    rt_metal_destroy_pipeline(g_blit_pso)
    rt_metal_destroy_command_queue(g_queue)
    rt_metal_destroy_device(g_dev)

# ─── Build JIT source with baked-in handles ──────────────────────────────────
#
# We embed the actual runtime handle values as integer literals so the JIT
# function needs only `iters: i64` — fitting the single-arg rt_jit_call_i64 API.
# Timing is done OUTSIDE the JIT call (wall-clock around the call_i64 invocation)
# rather than inside, to avoid needing rt_time_now_nanos inside the JIT module.
# The JIT function just runs the blit loop and returns a dummy 0.

fn build_jit_source(queue: i64, pipeline: i64, buf0: i64, buf1: i64, buf2: i64, params_ptr: i64, params_size: i64, gx: i64, gy: i64, gz: i64, bx: i64, by: i64, bz: i64) -> text:
    "extern fn rt_metal_run_blit_frame(queue: i64, pipeline: i64, buf0: i64, buf1: i64, buf2: i64, params_ptr: i64, params_size: i64, gx: i64, gy: i64, gz: i64, bx: i64, by: i64, bz: i64) -> i64\n" +
    "fn hot_blit(iters: i64) -> i64:\n" +
    "    val Q = " + queue.to_string() + "\n" +
    "    val P = " + pipeline.to_string() + "\n" +
    "    val B0 = " + buf0.to_string() + "\n" +
    "    val B1 = " + buf1.to_string() + "\n" +
    "    val B2 = " + buf2.to_string() + "\n" +
    "    val PARAMS = " + params_ptr.to_string() + "\n" +
    "    val PSIZE = " + params_size.to_string() + "\n" +
    "    val GX = " + gx.to_string() + "\n" +
    "    val GY = " + gy.to_string() + "\n" +
    "    val GZ = " + gz.to_string() + "\n" +
    "    val BX = " + bx.to_string() + "\n" +
    "    val BY = " + by.to_string() + "\n" +
    "    val BZ = " + bz.to_string() + "\n" +
    "    var i = 0\n" +
    "    while i < iters:\n" +
    "        rt_metal_run_blit_frame(Q, P, B0, B1, B2, PARAMS, PSIZE, GX, GY, GZ, BX, BY, BZ)\n" +
    "        i = i + 1\n" +
    "    0\n"

# ─── Main ─────────────────────────────────────────────────────────────────────

fn main():
    if rt_metal_is_available() == 0:
        print("Metal not available on this system")
        return

    if not setup():
        print("Setup failed")
        return

    var gx: i64 = 1
    var gy: i64 = 1
    var gz: i64 = N_TILES
    var bx: i64 = TILE_W
    var by: i64 = TILE_H
    var bz: i64 = 1

    # ── Interpreted warmup (direct call) to confirm baseline ─────────────────
    print("--- Interpreted warmup (30 iters) ---")
    var w: i64 = 0
    while w < 30:
        rt_metal_run_blit_frame(g_queue, g_blit_pso, g_src_buf, g_dst_buf, g_tiles_buf, g_params, 4, gx, gy, gz, bx, by, bz)
        w = w + 1

    # ── Build + register JIT source ───────────────────────────────────────────
    print("--- Building JIT source with baked handles ---")
    var jit_src = build_jit_source(g_queue, g_blit_pso, g_src_buf, g_dst_buf, g_tiles_buf, g_params, 4, gx, gy, gz, bx, by, bz)

    var config = default_config()
    var jit = TieredJitManager.create(config)
    jit.register_function("hot_blit", jit_src)

    # Force tier promotion: record_call until threshold (default 100)
    var rc: i64 = 0
    while rc < 105:
        jit.record_call("hot_blit")
        rc = rc + 1

    print("  hot_blit native: " + jit.is_native("hot_blit").to_string())

    if not jit.is_native("hot_blit"):
        print("ERROR: JIT compilation did not promote hot_blit to native — STOP")
        jit.cleanup()
        teardown()
        return

    # ── JIT warmup: one call with WARMUP_ITERS blits ──────────────────────────
    print("--- JIT warmup (" + WARMUP_ITERS.to_string() + " blits) ---")
    jit.call_i64("hot_blit", WARMUP_ITERS)

    # ── JIT measured: TIMED_ITERS blits, wall-clock around the call ───────────
    print("--- JIT measured (" + TIMED_ITERS.to_string() + " blits) ---")
    var t0 = rt_time_now_nanos()
    jit.call_i64("hot_blit", TIMED_ITERS)
    var t1 = rt_time_now_nanos()
    var total_ns = t1 - t0
    var avg_ns = total_ns / TIMED_ITERS

    # ── SCENE_RESULT (mean reported as p50 approximation — see file header) ────
    var ppf: i64 = FRAME_W * FRAME_H
    var pps: i64 = 0
    if avg_ns > 0:
        pps = ppf * 1000000000 / avg_ns
    var dps: i64 = 0
    if avg_ns > 0:
        dps = 1000000000 / avg_ns
    print("SCENE_RESULT scene=blit_tiles backend=simple_metal_gpu_jit frame_count=" + TIMED_ITERS.to_string() + " p50_ms=" + (avg_ns / 1000000).to_string() + " p95_ms=0 pixels_per_sec=" + pps.to_string() + " draws_per_sec=" + dps.to_string() + " rss_kb=0 pixel_hash=0 p50_ns=" + avg_ns.to_string() + " p99_ms=0 p99_ns=0 mode=jit_mean")

    jit.print_stats()
    jit.cleanup()
    teardown()

main()
