# test/perf/graphics_2d/bench_harness.spl
#
# Shared benchmark schema for graphics_2d, tauri_equiv, and web_render_chrome
# perf suites.  All benchmark runners write BenchFrameRecord rows; all report
# specs read them through write_report / json helpers here.
#
# Usage:
#   use perf.graphics_2d.bench_harness.{BenchFrameRecord, write_report}

extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_time_now_nanos() -> i64

# ============================================================================
# BenchFrameRecord — shared schema
# ============================================================================

class BenchFrameRecord:
    """One measured frame across any 2D benchmark scene."""
    scene:      text   # fixture / scene name, e.g. "scroll_heavy"
    backend:    text   # "gpu" | "cpu" | "vulkan" | "cuda" | "software" | ...
    frame_ms:   i64    # median frame time in whole milliseconds
    pixel_hash: text   # hex string for correctness verification
    simd_hits:  i64    # SIMD provider hit count for this frame

fn make_bench_frame_record(scene: text, backend: text) -> BenchFrameRecord:
    BenchFrameRecord(
        scene:      scene,
        backend:    backend,
        frame_ms:   0,
        pixel_hash: "",
        simd_hits:  0,
    )

# ============================================================================
# JSON serialisation
# ============================================================================

fn bench_frame_record_to_json(r: BenchFrameRecord) -> text:
    "{\"scene\":\"" + r.scene + "\","
    + "\"backend\":\"" + r.backend + "\","
    + "\"frame_ms\":" + r.frame_ms.to_text() + ","
    + "\"pixel_hash\":\"" + r.pixel_hash + "\","
    + "\"simd_hits\":" + r.simd_hits.to_text() + "}"

fn records_to_json_array(records: [BenchFrameRecord]) -> text:
    var out = "["
    var i = 0
    while i < records.len():
        if i > 0:
            out = out + ","
        out = out + bench_frame_record_to_json(records[i])
        i = i + 1
    out + "]"

# ============================================================================
# Report writer
# ============================================================================

fn write_report(records: [BenchFrameRecord], path: text):
    """Write a JSON array of BenchFrameRecord to path.

    Creates or overwrites the file.  Returns silently on success; prints an
    error line on failure so CI can surface it without a hard exit.
    """
    val json = records_to_json_array(records)
    val ok = rt_file_write_text(path, json)
    if ok:
        print "[bench_harness] wrote {records.len()} records to {path}"
    else:
        print "[bench_harness] ERROR: could not write {path}"

# ============================================================================
# Print helpers
# ============================================================================

fn print_bench_record(r: BenchFrameRecord):
    print "scene={r.scene}  backend={r.backend}  frame_ms={r.frame_ms}  simd_hits={r.simd_hits}  pixel_hash={r.pixel_hash}"

fn print_report(records: [BenchFrameRecord]):
    print "=== BenchFrameRecord report ({records.len()} records) ==="
    var i = 0
    while i < records.len():
        print_bench_record(records[i])
        i = i + 1
    print "=== end ==="
