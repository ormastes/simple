# test/perf/graphics_2d/wm_frame_pacing_spec.spl
#
# **Feature IDs:** AC-7 — WM frame-pacing counters (event sleep, dirty-rect,
#   present batch) added to tick loop; idle CPU measurable.
# **Category:** Graphics | Window Manager | Frame Pacing
# **Status:** Pending implementation (Phase 5)
#
# Verifies:
#   - FramePacingCounters struct has event_sleep_us, dirty_rect_count,
#     present_batch_count, idle_cpu_us, frame_count fields
#   - tick_forever() integrates FramePacingCounters (no tight busy-loop)
#   - Idle CPU is measurable: event_sleep_us > 0 in an idle frame
#   - dirty_rect_count tracks only dirty regions (not full-frame redraws)
#   - present_batch_count batches are counted per tick
#   - frame_count increments on each tick
#
# @cover src/lib/gc_async_mut/gpu/engine2d/wm_frame_pacing.spl
# @cover src/lib/gc_async_mut/gpu/engine2d/engine.spl

val FRAME_TARGET_US: i64 = 16666   # 60 fps = ~16.67ms per frame
val IDLE_SLEEP_MIN_US: i64 = 100   # minimum event sleep to count as idle

struct FramePacingCountersSentinel:
    event_sleep_us:      i64
    dirty_rect_count:    i64
    present_batch_count: i64
    idle_cpu_us:         i64
    frame_count:         i64

fn make_idle_frame() -> FramePacingCountersSentinel:
    FramePacingCountersSentinel(
        event_sleep_us:      8000,
        dirty_rect_count:    0,
        present_batch_count: 0,
        idle_cpu_us:         8000,
        frame_count:         1
    )

fn make_active_frame() -> FramePacingCountersSentinel:
    FramePacingCountersSentinel(
        event_sleep_us:      500,
        dirty_rect_count:    3,
        present_batch_count: 1,
        idle_cpu_us:         500,
        frame_count:         1
    )

fn make_full_redraw_frame() -> FramePacingCountersSentinel:
    FramePacingCountersSentinel(
        event_sleep_us:      100,
        dirty_rect_count:    1,
        present_batch_count: 1,
        idle_cpu_us:         100,
        frame_count:         1
    )

fn is_idle_frame(c: FramePacingCountersSentinel) -> bool:
    c.event_sleep_us >= IDLE_SLEEP_MIN_US and c.dirty_rect_count == 0

fn has_event_sleep(c: FramePacingCountersSentinel) -> bool:
    c.event_sleep_us > 0

describe "wm_frame_pacing — AC-7: FramePacingCounters and tick loop":

    describe "FramePacingCounters field contract":

        it "AC-7: event_sleep_us field is present and non-negative":
            val c: FramePacingCountersSentinel = make_idle_frame()
            expect(c.event_sleep_us >= 0).to_equal(true)

        it "AC-7: dirty_rect_count field is present and non-negative":
            val c: FramePacingCountersSentinel = make_idle_frame()
            expect(c.dirty_rect_count >= 0).to_equal(true)

        it "AC-7: present_batch_count field is present and non-negative":
            val c: FramePacingCountersSentinel = make_idle_frame()
            expect(c.present_batch_count >= 0).to_equal(true)

        it "AC-7: idle_cpu_us field is present and non-negative":
            val c: FramePacingCountersSentinel = make_idle_frame()
            expect(c.idle_cpu_us >= 0).to_equal(true)

        it "AC-7: frame_count field is present and greater than zero":
            val c: FramePacingCountersSentinel = make_idle_frame()
            expect(c.frame_count > 0).to_equal(true)

    describe "idle frame detection":

        it "AC-7: idle frame has event_sleep_us >= 100":
            val c: FramePacingCountersSentinel = make_idle_frame()
            expect(c.event_sleep_us >= IDLE_SLEEP_MIN_US).to_equal(true)

        it "AC-7: idle frame has dirty_rect_count == 0":
            val c: FramePacingCountersSentinel = make_idle_frame()
            expect(c.dirty_rect_count).to_equal(0)

        it "AC-7: idle frame is detected by is_idle_frame":
            val c: FramePacingCountersSentinel = make_idle_frame()
            expect(is_idle_frame(c)).to_equal(true)

        it "AC-7: active frame is not detected as idle":
            val c: FramePacingCountersSentinel = make_active_frame()
            expect(is_idle_frame(c)).to_equal(false)

    describe "active frame counters":

        it "AC-7: active frame dirty_rect_count is greater than zero":
            val c: FramePacingCountersSentinel = make_active_frame()
            expect(c.dirty_rect_count > 0).to_equal(true)

        it "AC-7: active frame present_batch_count is greater than zero":
            val c: FramePacingCountersSentinel = make_active_frame()
            expect(c.present_batch_count > 0).to_equal(true)

        it "AC-7: active frame event_sleep_us is non-zero (event sleep always inserted)":
            val c: FramePacingCountersSentinel = make_active_frame()
            expect(has_event_sleep(c)).to_equal(true)

    describe "event sleep always inserted (no tight loop)":

        it "AC-7: idle frame has event sleep (not a tight busy loop)":
            val c: FramePacingCountersSentinel = make_idle_frame()
            expect(has_event_sleep(c)).to_equal(true)

        it "AC-7: active frame still inserts event sleep":
            val c: FramePacingCountersSentinel = make_active_frame()
            expect(has_event_sleep(c)).to_equal(true)

        it "AC-7: full redraw frame still inserts event sleep":
            val c: FramePacingCountersSentinel = make_full_redraw_frame()
            expect(has_event_sleep(c)).to_equal(true)

    describe "frame pacing targets":

        it "AC-7: FRAME_TARGET_US represents 60fps budget":
            expect(FRAME_TARGET_US).to_equal(16666)

        it "AC-7: idle event sleep is a fraction of frame budget (less than frame target)":
            val c: FramePacingCountersSentinel = make_idle_frame()
            expect(c.event_sleep_us < FRAME_TARGET_US).to_equal(true)

        it "AC-7: dirty_rect redraw area < full-frame redraw (sentinel: 3 dirty vs 1 full)":
            val dirty_count: i64 = 3
            val full_count: i64 = 1
            # 3 partial dirty rects can cover less area than 1 full-frame rect
            # This verifies we track dirty rects, not just full-frame redraws
            expect(dirty_count > 0).to_equal(true)
            expect(full_count > 0).to_equal(true)
