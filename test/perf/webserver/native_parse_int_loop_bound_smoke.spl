# Native hosted smoke for parse_int result used as a while-loop bound.

extern fn rt_env_get(key: text) -> text
extern fn rt_env_get_i64(key: text, default_value: i64) -> i64

fn env_text(key: text, default_value: text) -> text:
    val value = rt_env_get(key) ?? ""
    if value.len() > 0:
        value
    else:
        default_value

fn env_i64(key: text, default_value: i64) -> i64:
    rt_env_get_i64(key, default_value)

fn main():
    val raw = env_text("SIMPLE_PARSE_INT_LIMIT", "")
    val first = if raw.len() > 0: raw[0:1] else: "?"
    val limit = env_i64("SIMPLE_PARSE_INT_LIMIT", 4)
    var i: i64 = 0
    var sum: i64 = 0
    while i < limit:
        sum = sum + i
        i = i + 1
    print "[native-parse-int-loop-bound-smoke] raw={raw} raw_len={raw.len()} first={first} limit={limit} sum={sum}"
