# Native hosted smoke for parse_int result used as a while-loop bound.

extern fn rt_env_get(key: text) -> text

fn env_text(key: text, default_value: text) -> text:
    val value = rt_env_get(key) ?? ""
    if value.len() > 0:
        value
    else:
        default_value

fn env_i64(key: text, default_value: i64) -> i64:
    val value = env_text(key, "")
    val n = value.len()
    if n == 0:
        return default_value
    var i: i64 = 0
    var result: i64 = 0
    var saw_digit = false
    while i < n:
        val ch = value[i:i+1]
        if ch < '0' or ch > '9':
            if saw_digit:
                i = n
            else:
                return default_value
        else:
            saw_digit = true
            val digit: i64 = if ch == "0": 0
                elif ch == "1": 1
                elif ch == "2": 2
                elif ch == "3": 3
                elif ch == "4": 4
                elif ch == "5": 5
                elif ch == "6": 6
                elif ch == "7": 7
                elif ch == "8": 8
                else: 9
            result = result * 10 + digit
            i = i + 1
    if saw_digit:
        result
    else:
        default_value

fn main():
    val raw = env_text("SIMPLE_PARSE_INT_LIMIT", "")
    val first = if raw.len() > 0: raw[0:1] else: "?"
    val limit = env_i64("SIMPLE_PARSE_INT_LIMIT", 4)
    var i: i64 = 0
    var sum: i64 = 0
    while i < limit:
        sum = sum + i
        i = i + 1
    print "[native-parse-int-loop-bound-smoke] raw={raw} raw_len={raw.len()} first={first} limit={limit} sum={sum}"
