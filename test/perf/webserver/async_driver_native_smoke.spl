use std.io.driver.{IoDriver}

fn main():
    val driver = IoDriver.new()
    if driver.handle < 0:
        print "async-driver-smoke error=handle"
        return

    val backend = driver.backend_name()
    if backend.len() == 0:
        driver.close()
        print "async-driver-smoke error=backend"
        return

    val op = driver.submit_timeout(1)
    if op <= 0:
        driver.close()
        print "async-driver-smoke error=submit_timeout"
        return

    val flushed = driver.flush()
    if flushed < 0:
        driver.close()
        print "async-driver-smoke error=flush"
        return

    val completions = driver.poll_count(8, 10)
    driver.close()

    if completions == 0:
        print "async-driver-smoke error=completion"
        return

    print "async-driver-smoke backend={backend} op={op}"
