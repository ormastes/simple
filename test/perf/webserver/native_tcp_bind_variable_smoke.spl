# Native hosted smoke for binding TCP with a non-literal text value.

extern fn rt_env_get(key: text) -> text
extern fn rt_io_tcp_bind(addr: text) -> i64
extern fn rt_io_tcp_close(fd: i64) -> bool

fn env_text(key: text, default_value: text) -> text:
    val value = rt_env_get(key) ?? ""
    if value.len() > 0:
        value
    else:
        default_value

fn main():
    val addr = env_text("SIMPLE_STATIC_SERVER_ADDR", "127.0.0.1:18084")
    val listener = rt_io_tcp_bind(addr)
    if listener < 0:
        print "[native-tcp-bind-variable-smoke] bind_error addr={addr}"
        return
    val _closed = rt_io_tcp_close(listener)
    print "[native-tcp-bind-variable-smoke] ok addr={addr}"
