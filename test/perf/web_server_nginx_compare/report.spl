# Benchmark Comparison Report Formatter
#
# Formats a side-by-side comparison table of Simple vs nginx benchmark results.
# Flags any file-size bucket where Simple is more than 2x slower than nginx.
#
# Depends on: harness.spl (BenchmarkResult)

use test.perf.web_server_nginx_compare.harness.{BenchmarkResult}

# ============================================================================
# Internal helpers
# ============================================================================

fn _f64_to_text(v: f64, decimals: i64) -> text:
    """Format a float to `decimals` decimal places as text."""
    if decimals == 0:
        return (v as i64).to_text()
    val scale: i64 = if decimals == 1: 10 else: if decimals == 2: 100 else: 1000
    val int_part = v as i64
    val frac_part = ((v - (int_part as f64)) * (scale as f64)) as i64
    val frac_text = frac_part.to_text()
    val pad = if decimals == 1: "0" else: if decimals == 2: "00" else: "000"
    val padded = (pad + frac_text).slice(frac_text.len(), pad.len() + 1)
    "{int_part}.{padded}"

fn _pad_right(s: text, width: i64) -> text:
    """Right-pad `s` with spaces to `width` characters."""
    var result = s
    while result.len() < width:
        result = result + " "
    result

fn _find_result(results: [BenchmarkResult], sz: i64) -> BenchmarkResult:
    """Find the BenchmarkResult for the given file size, or a zero result."""
    var i = 0
    while i < results.len():
        if results[i].file_size == sz:
            return results[i]
        i = i + 1
    BenchmarkResult(server: "?", rps: 0.0, p99_latency_ms: 0.0, throughput_mbps: 0.0, file_size: sz)

fn _size_label(sz: i64) -> text:
    """Human-readable label for a byte size."""
    if sz >= 1048576:
        return "{sz / 1048576}MB"
    if sz >= 1024:
        return "{sz / 1024}KB"
    "{sz}B"

# ============================================================================
# Public API
# ============================================================================

pub fn format_comparison(simple_results: [BenchmarkResult], nginx_results: [BenchmarkResult]) -> text:
    """Format a side-by-side comparison table.

    For each file size present in either result set, emits a row comparing
    Simple and nginx. Flags rows where Simple RPS is more than 2x below nginx.
    """
    # Collect all unique file sizes
    var sizes: [i64] = []
    var i = 0
    while i < simple_results.len():
        sizes.push(simple_results[i].file_size)
        i = i + 1
    # Add nginx sizes not already included
    i = 0
    while i < nginx_results.len():
        val sz = nginx_results[i].file_size
        var found = false
        var j = 0
        while j < sizes.len():
            if sizes[j] == sz:
                found = true
                break
            j = j + 1
        if not found:
            sizes.push(sz)
        i = i + 1

    # Sort sizes ascending (insertion sort — small list)
    var n = sizes.len()
    var si = 1
    while si < n:
        val key = sizes[si]
        var sj = si - 1
        while sj >= 0 and sizes[sj] > key:
            sizes[sj + 1] = sizes[sj]
            sj = sj - 1
        sizes[sj + 1] = key
        si = si + 1

    # Build report
    val sep = "+----------+--------------+--------------+-------------+--------------+--------------+-------------+-------+\n"
    val header = "| Size     | Simple RPS   | Nginx RPS    | RPS ratio   | Simple p99ms | Nginx p99ms  | TP ratio    | Flag  |\n"

    var out = sep + header + sep

    i = 0
    while i < sizes.len():
        val sz = sizes[i]
        val sr = _find_result(simple_results, sz)
        val nr = _find_result(nginx_results, sz)

        val size_lbl = _pad_right(_size_label(sz), 8)
        val s_rps = _pad_right(_f64_to_text(sr.rps, 1), 12)
        val n_rps = _pad_right(_f64_to_text(nr.rps, 1), 12)
        val s_p99 = _pad_right(_f64_to_text(sr.p99_latency_ms, 2), 12)
        val n_p99 = _pad_right(_f64_to_text(nr.p99_latency_ms, 2), 12)

        # RPS ratio: simple / nginx (higher = Simple is faster)
        var rps_ratio_text = "N/A         "
        var tp_ratio_text = "N/A         "
        var flag = "     "

        if nr.rps > 0.0:
            val ratio = sr.rps / nr.rps
            rps_ratio_text = _pad_right(_f64_to_text(ratio, 3), 11)
            # Flag if Simple is more than 2x slower (ratio < 0.5)
            if ratio < 0.5:
                flag = "SLOW "

        if nr.throughput_mbps > 0.0:
            val tp_ratio = sr.throughput_mbps / nr.throughput_mbps
            tp_ratio_text = _pad_right(_f64_to_text(tp_ratio, 3), 11)

        out = out + "| {size_lbl} | {s_rps} | {n_rps} | {rps_ratio_text} | {s_p99} | {n_p99} | {tp_ratio_text} | {flag} |\n"
        out = out + sep

        i = i + 1

    out = out + "\nLegend: RPS ratio = Simple/Nginx (< 0.5 means Simple is >2x slower — flagged SLOW)\n"
    out
