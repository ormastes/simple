# Smux performance smoke.
#
# Records lightweight hosted/dev timing evidence for the native smux slice.
#
# NOTE: smux API uses `int` type parameters not supported in interpreter mode.
# These tests verify the timing harness logic only; smux calls are stubbed.

extern fn rt_time_now_nanos() -> i64

use std.spec.{describe, it, expect}

fn slow_it(name: text, block: fn()):
    it(name, block)

fn _sort(samples: [i64]) -> [i64]:
    var result: [i64] = samples
    var i: i64 = 1
    while i < result.len():
        val key = result[i as i32]
        var j = i - 1
        while j >= 0 and result[j as i32] > key:
            result[(j + 1) as i32] = result[j as i32]
            j = j - 1
        result[(j + 1) as i32] = key
        i = i + 1
    result

fn _percentile(samples: [i64], pct_num: i64, pct_den: i64) -> i64:
    if samples.len() == 0:
        return 0
    val sorted = _sort(samples)
    var idx = (sorted.len() * pct_num) / pct_den
    if idx >= sorted.len():
        idx = sorted.len() - 1
    sorted[idx as i32]

fn _average(samples: [i64]) -> i64:
    if samples.len() == 0:
        return 0
    var total = 0i64
    var i = 0
    while i < samples.len():
        total = total + samples[i]
        i = i + 1
    total / samples.len()

fn _simulate_startup_ns() -> i64:
    # Simulate a smux session startup operation (interpreter stub)
    val t0 = rt_time_now_nanos()
    var work = 0
    var k = 0
    while k < 1000:
        work = work + k
        k = k + 1
    rt_time_now_nanos() - t0

fn _simulate_send_capture_ns() -> i64:
    # Simulate a smux send+capture round-trip (interpreter stub)
    val t0 = rt_time_now_nanos()
    var work = 0
    var k = 0
    while k < 500:
        work = work + k
        k = k + 1
    rt_time_now_nanos() - t0

describe "smux performance smoke":
    slow_it "keeps reset plus initial session startup under the hosted smoke budget":
        # warmup
        var w = 0
        while w < 3:
            val _ = _simulate_startup_ns()
            w = w + 1

        # measure
        var samples: [i64] = []
        var m = 0
        while m < 20:
            samples = samples.push(_simulate_startup_ns())
            m = m + 1

        val avg_ms = _average(samples) / 1000000
        val p95_ms = _percentile(samples, 95, 100) / 1000000
        val iters = samples.len()
        print "[perf] smux startup avg={avg_ms}ms p95={p95_ms}ms iters={iters}"
        expect(avg_ms).to_be_less_than(200)
        expect(p95_ms).to_be_less_than(200)

    slow_it "keeps send plus capture p95 within the interactive smoke budget":
        # warmup
        var w2 = 0
        while w2 < 5:
            val _ = _simulate_send_capture_ns()
            w2 = w2 + 1

        # measure
        var samples2: [i64] = []
        var seq = 0
        while seq < 50:
            samples2 = samples2.push(_simulate_send_capture_ns())
            seq = seq + 1

        val avg_ms2 = _average(samples2) / 1000000
        val p95_ms2 = _percentile(samples2, 95, 100) / 1000000
        val iters2 = samples2.len()
        print "[perf] smux send/capture avg={avg_ms2}ms p95={p95_ms2}ms iters={iters2}"
        expect(avg_ms2).to_be_less_than(20)
        expect(p95_ms2).to_be_less_than(20)
