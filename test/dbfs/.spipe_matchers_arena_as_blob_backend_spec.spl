# Maps to: AC-4, AC-9
# Run: bin/simple test test/dbfs/arena_as_blob_backend_spec.spl

"""
Arena as BlobBackend Conformance Specification

Verifies that both NvfsArena and the new RawNvmeArena pass the same
Arena trait conformance suite (7 verbs: create/append/readv/seal/
discard/clone_range/preferred_granule).
"""

use std.spipe.*
use std.storage.arena.{Arena, ArenaHandle, StorageClass, Durability}
use std.storage.nvfs_arena.{NvfsArena}
use std.storage.raw_nvme_arena.{RawNvmeArena}
use std.os.drivers.block.null_block.{NullBlockDevice}

fn make_nvfs_arena() -> NvfsArena:
    NvfsArena.new_hosted()

fn make_raw_nvme_arena() -> RawNvmeArena:
    val dev = NullBlockDevice.new(sector_count: 65536, sector_size: 512)
    RawNvmeArena.new(dev)

fn run_conformance_suite<A: Arena>(arena: A):
    # create
    val h = arena.arena_create(StorageClass.GeneralMutable, 65536).unwrap()
    expect h.is_valid() == true

    # append + readv
    val data: [u8] = [0x01, 0x02, 0x03, 0x04]
    arena.arena_append(h, data, Durability.Relaxed).unwrap()
    var buf: [u8] = [0, 0, 0, 0]
    arena.arena_readv(h, 0, buf).unwrap()
    expect buf[0] == 0x01
    expect buf[3] == 0x04

    # preferred_granule
    val gran = arena.arena_preferred_granule(h)
    expect gran > 0 == true

    # seal
    val gen: i64 = 1
    arena.arena_seal(h, gen).unwrap()

    # discard
    val h2 = arena.arena_create(StorageClass.GeneralMutable, 4096).unwrap()
    arena.arena_discard(h2).unwrap()

describe "Arena Conformance — NvfsArena":
    it "NvfsArena passes full conformance suite":
        val arena = make_nvfs_arena()
        run_conformance_suite(arena)

    it "NvfsArena clone_range copies data correctly":
        val arena = make_nvfs_arena()
        val src = arena.arena_create(StorageClass.GeneralMutable, 4096).unwrap()
        val payload: [u8] = [0xAB, 0xCD]
        arena.arena_append(src, payload, Durability.Relaxed).unwrap()
        val dst = arena.arena_create(StorageClass.GeneralMutable, 4096).unwrap()
        arena.arena_clone_range(src, 0, dst, 0, 2).unwrap()
        var out: [u8] = [0, 0]
        arena.arena_readv(dst, 0, out).unwrap()
        expect out[0] == 0xAB

describe "Arena Conformance — RawNvmeArena":
    it "RawNvmeArena passes full conformance suite":
        val arena = make_raw_nvme_arena()
        run_conformance_suite(arena)

    it "RawNvmeArena clone_range copies data correctly":
        val arena = make_raw_nvme_arena()
        val src = arena.arena_create(StorageClass.GeneralMutable, 4096).unwrap()
        val payload: [u8] = [0x11, 0x22]
        arena.arena_append(src, payload, Durability.Relaxed).unwrap()
        val dst = arena.arena_create(StorageClass.GeneralMutable, 4096).unwrap()
        arena.arena_clone_range(src, 0, dst, 0, 2).unwrap()
        var out: [u8] = [0, 0]
        arena.arena_readv(dst, 0, out).unwrap()
        expect out[0] == 0x11

describe "Arena Conformance — both impls preferred_granule":
    it "NvfsArena preferred_granule >= 512":
        val arena = make_nvfs_arena()
        val h = arena.arena_create(StorageClass.GeneralMutable, 4096).unwrap()
        expect arena.arena_preferred_granule(h) >= 512 == true

    it "RawNvmeArena preferred_granule >= 512":
        val arena = make_raw_nvme_arena()
        val h = arena.arena_create(StorageClass.GeneralMutable, 4096).unwrap()
        expect arena.arena_preferred_granule(h) >= 512 == true