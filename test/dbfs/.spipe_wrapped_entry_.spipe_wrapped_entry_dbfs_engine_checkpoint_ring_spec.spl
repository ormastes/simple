#![allow(spipe_empty_examples)]
#![allow(spipe_boolean_wrapper_assertions)]
@allow(spipe_empty_examples)
@allow(spipe_boolean_wrapper_assertions)
use std.spipe.*
use std.db.dbfs_engine.checkpoint_ring.{CheckpointRing, RingSlot, RING_SIZE}
use std.storage.arena.{StorageClass}

fn main():
    # Maps to: AC-3, AC-5, AC-9
    # Run: bin/simple test test/dbfs/dbfs_engine_checkpoint_ring_spec.spl
    # Phase 5 prerequisite: checkpoint_ring.spl must persist ring to META_DURABLE arena
    # (currently in-memory only — R2 HIGH-risk gap from D12)

    """
    DBFS Checkpoint Ring Disk Persistence Specification
    
    Verifies R2 HIGH-risk gap: checkpoint ring is written to META_DURABLE
    and remount reads the correct slot.
    
      1. ring slot is present after remount
      2. correct (latest clean=true) slot is selected on remount
      3. ring slot is written to META_DURABLE arena
      4. stale dirty slots are not returned as current
    """


    describe "DBFS Checkpoint Ring — disk persistence":
        """Ring slot survives simulated remount."""
    
        it "ring slot written before remount is readable after":
            val ring = CheckpointRing.new_persistent()
            val slot = RingSlot(gen: 5, clean: true, btree_root_page: 100)
            ring.write_slot(0, slot).unwrap()
            ring.flush().unwrap()
            ring.close().unwrap()
            val ring2 = CheckpointRing.reopen()
            val got = ring2.read_slot(0).unwrap()
            expect got.gen == 5
            expect got.clean == true
    
        it "all ring slots survive remount":
            val ring = CheckpointRing.new_persistent()
            var i: i64 = 0
            while i < RING_SIZE:
                ring.write_slot(i, RingSlot(gen: i + 1, clean: true, btree_root_page: i * 8)).unwrap()
                i = i + 1
            ring.flush().unwrap()
            ring.close().unwrap()
            val ring2 = CheckpointRing.reopen()
            val slot = ring2.read_slot(RING_SIZE - 1).unwrap()
            expect slot.gen == RING_SIZE
    
    describe "DBFS Checkpoint Ring — best slot selection":
        """Remount picks the slot with highest gen and clean=true."""

        it "current_slot returns slot with highest gen and clean=true":
            val ring = CheckpointRing.new_persistent()
            ring.write_slot(0, RingSlot(gen: 3, clean: true, btree_root_page: 30)).unwrap()
            ring.write_slot(1, RingSlot(gen: 5, clean: true, btree_root_page: 50)).unwrap()
            ring.write_slot(2, RingSlot(gen: 4, clean: false, btree_root_page: 40)).unwrap()
            ring.flush().unwrap()
            ring.close().unwrap()
            val ring2 = CheckpointRing.reopen()
            val best = ring2.current_slot().unwrap()
            expect best.gen == 5

        it "dirty slots are not selected as current":
            val ring = CheckpointRing.new_persistent()
            ring.write_slot(0, RingSlot(gen: 10, clean: false, btree_root_page: 10)).unwrap()
            ring.write_slot(1, RingSlot(gen: 2, clean: true, btree_root_page: 20)).unwrap()
            ring.flush().unwrap()
            ring.close().unwrap()
            val ring2 = CheckpointRing.reopen()
            val best = ring2.current_slot().unwrap()
            expect best.gen == 2

    describe "DBFS Checkpoint Ring — storage class":
        """Ring writes must target META_DURABLE arena."""
    
        it "ring write uses META_DURABLE storage class":
            val ring = CheckpointRing.new_persistent()
            ring.write_slot(0, RingSlot(gen: 1, clean: true, btree_root_page: 0)).unwrap()
            ring.flush().unwrap()
            val sc = ring.last_write_storage_class()
            expect sc == StorageClass.MetaDurable
    
        it "ring size constant is at least 4":
            expect RING_SIZE >= 4 == true
fn main():
    #![allow(spipe_empty_examples)]
    #![allow(spipe_boolean_wrapper_assertions)]
    @allow(spipe_empty_examples)
    @allow(spipe_boolean_wrapper_assertions)

