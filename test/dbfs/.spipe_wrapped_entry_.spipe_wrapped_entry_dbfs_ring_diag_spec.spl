#![allow(spipe_empty_examples)]
#![allow(spipe_boolean_wrapper_assertions)]
@allow(spipe_empty_examples)
@allow(spipe_boolean_wrapper_assertions)
use std.spipe.*
use std.db.dbfs_engine.checkpoint_ring.{CheckpointRing, RingSlot, RING_SIZE}
use std.io_runtime

fn main():

    describe "DBFS Ring Diagnostic":

        it "single write_slot then read_slot works":
            val ring = CheckpointRing.new_persistent()
            ring.write_slot(0, RingSlot(gen: 42, clean: true, btree_root_page: 100)).unwrap()
            val slot = ring.read_slot(0).unwrap()
            expect slot.gen == 42

        it "loop write_slot 5 times then read_slot works":
            val ring = CheckpointRing.new_persistent()
            var i: i64 = 0
            while i < 5:
                ring.write_slot(i, RingSlot(gen: i + 10, clean: true, btree_root_page: i)).unwrap()
                i = i + 1
            val store = ring.current_store()
            # First check how many entries are in the store
            expect store.len() == 5
            val s0 = ring.read_slot(0).unwrap()
            val s4 = ring.read_slot(4).unwrap()
            expect s0.gen == 10
            expect s4.gen == 14

        it "two separate writes then read_slot 1 works":
            val ring = CheckpointRing.new_persistent()
            ring.write_slot(0, RingSlot(gen: 10, clean: true, btree_root_page: 0)).unwrap()
            ring.write_slot(1, RingSlot(gen: 11, clean: true, btree_root_page: 1)).unwrap()
            val s1 = ring.read_slot(1).unwrap()
            expect s1.gen == 11

        it "current_store has entries after writes":
            val ring = CheckpointRing.new_persistent()
            ring.write_slot(0, RingSlot(gen: 1, clean: true, btree_root_page: 0)).unwrap()
            ring.write_slot(1, RingSlot(gen: 2, clean: true, btree_root_page: 1)).unwrap()
            val store = ring.current_store()
            expect store.len() >= 2 == true

        it "flush then reopen: read slot 0":
            val ring = CheckpointRing.new_persistent()
            ring.write_slot(0, RingSlot(gen: 7, clean: true, btree_root_page: 70)).unwrap()
            ring.flush().unwrap()
            ring.close().unwrap()
            val ring2 = CheckpointRing.reopen()
            val s = ring2.read_slot(0).unwrap()
            expect s.gen == 7

        it "loop writes all RING_SIZE slots then reopen finds slot 15":
            val ring = CheckpointRing.new_persistent()
            var i: i64 = 0
            while i < RING_SIZE:
                ring.write_slot(i, RingSlot(gen: i + 1, clean: true, btree_root_page: i * 8)).unwrap()
                i = i + 1
            ring.flush().unwrap()
            ring.close().unwrap()
            val ring2 = CheckpointRing.reopen()
            val slot = ring2.read_slot(RING_SIZE - 1).unwrap()
            expect slot.gen == RING_SIZE
fn main():
    #![allow(spipe_empty_examples)]
    #![allow(spipe_boolean_wrapper_assertions)]
    @allow(spipe_empty_examples)
    @allow(spipe_boolean_wrapper_assertions)

