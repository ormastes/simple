#![allow(spipe_empty_examples)]
#![allow(spipe_boolean_wrapper_assertions)]
@allow(spipe_empty_examples)
@allow(spipe_boolean_wrapper_assertions)
use std.spipe.*
use std.fs_driver.ops.{FsDriver}
use std.fs_driver.types.{OpenFlags, MountOptions, StatInfo}
use std.fs_driver.error.{FsError}
use std.fs_driver.instance.{DriverInstance}
use std.fs_driver.mount_table.{MountTable}
use os.services.fat32.fat32.{Fat32Driver}

fn make_fat32_mounted() -> MountTable:
    val mt = MountTable.new()
    val fat32 = Fat32Driver.new_ram_backed()
    mt.mount("/boot", DriverInstance.Fat32(fat32), MountOptions.read_only()).unwrap()
    mt

fn main():
    # Maps to: AC-7, AC-9
    # Run: bin/simple test test/dbfs/fat32_no_regression_spec.spl

    """
    FAT32 No-Regression Specification
    
    Verifies kernel FAT32 mount, readdir("/"), open, read, stat still work
    after DBFS and NVFS refactor. Boot path must remain unaffected.
    """


    describe "FAT32 no-regression — mount and stat":
        it "FAT32 volume mounts without error":
            val mt = make_fat32_mounted()
            val stat = mt.stat("/boot").unwrap()
            expect stat.is_dir == true

        it "stat on FAT32 root returns is_dir=true":
            val mt = make_fat32_mounted()
            val stat = mt.stat("/boot/").unwrap()
            expect stat.is_dir == true

    describe "FAT32 no-regression — readdir":
        it "readdir on FAT32 root returns at least 0 entries (no crash)":
            val mt = make_fat32_mounted()
            val dh = mt.opendir("/boot").unwrap()
            val entries = mt.readdir(dh).unwrap()
            # An empty FAT32 volume is valid; just must not error
            expect entries.len() >= 0 == true

    describe "FAT32 no-regression — open and read":
        it "open existing FAT32 file succeeds":
            val fat32 = Fat32Driver.new_ram_backed_with_file("TEST    TXT", "hello fat32")
            val mt = MountTable.new()
            mt.mount("/boot", DriverInstance.Fat32(fat32), MountOptions.read_only()).unwrap()
            val fh = mt.open("/boot/TEST    TXT", OpenFlags.read_only()).unwrap()
            expect fh.id > 0 == true

        it "read FAT32 file content round-trips":
            val fat32 = Fat32Driver.new_ram_backed_with_file("README  TXT", "fat32-content")
            val mt = MountTable.new()
            mt.mount("/boot", DriverInstance.Fat32(fat32), MountOptions.read_only()).unwrap()
            val fh = mt.open("/boot/README  TXT", OpenFlags.read_only()).unwrap()
            val got = mt.read(fh, 13).unwrap()
            expect got == "fat32-content"

    describe "FAT32 no-regression — stat file":
        it "stat FAT32 file returns is_file=true":
            val fat32 = Fat32Driver.new_ram_backed_with_file("STAT    TXT", "data")
            val mt = MountTable.new()
            mt.mount("/boot", DriverInstance.Fat32(fat32), MountOptions.read_only()).unwrap()
            val stat = mt.stat("/boot/STAT    TXT").unwrap()
            expect stat.is_file == true

    describe "FAT32 no-regression — DBFS co-existence":
        it "FAT32 and DBFS can both be mounted simultaneously":
            val mt = MountTable.new()
            val fat32 = Fat32Driver.new_ram_backed()
            mt.mount("/boot", DriverInstance.Fat32(fat32), MountOptions.read_only()).unwrap()
            val dbfs = std.db.dbfs_driver.DbFsDriver.new_hosted()
            mt.mount("/data", DriverInstance.DbFs(dbfs), MountOptions.default()).unwrap()
            val boot_stat = mt.stat("/boot").unwrap()
            val data_stat = mt.stat("/data").unwrap()
            expect boot_stat.is_dir == true
            expect data_stat.is_dir == true
fn main():
    #![allow(spipe_empty_examples)]
    #![allow(spipe_boolean_wrapper_assertions)]
    @allow(spipe_empty_examples)
    @allow(spipe_boolean_wrapper_assertions)
