use std.io_runtime
use std.spec.{describe, it, expect}
use std.database.sql.types.{DbValue, DbRow, DbError}
use nogc_sync_mut.database.pure_sql.database.{PureDatabase, PureSearchAlgorithm}

describe "PureDatabase":
    it "creates in-memory database":
        val r = PureDatabase.memory()
        expect(r.is_ok()).to_be(true)
    it "creates table":
        val r = PureDatabase.memory()
        var db = r.unwrap()
        val cr = db.exec_sql("CREATE TABLE users (id INTEGER, name TEXT)")
        expect(cr.is_ok()).to_be(true)
        expect(db.table_exists("users")).to_be(true)
    it "rejects duplicate table":
        val r = PureDatabase.memory()
        var db = r.unwrap()
        val c1 = db.exec_sql("CREATE TABLE t (id INTEGER)")
        expect(c1.is_ok()).to_be(true)
        val c2 = db.exec_sql("CREATE TABLE t (id INTEGER)")
        expect(c2.is_err()).to_be(true)
    it "allows CREATE TABLE IF NOT EXISTS":
        val r = PureDatabase.memory()
        var db = r.unwrap()
        val c1 = db.exec_sql("CREATE TABLE IF NOT EXISTS t (id INTEGER)")
        expect(c1.is_ok()).to_be(true)
        val c2 = db.exec_sql("CREATE TABLE IF NOT EXISTS t (id INTEGER)")
        expect(c2.is_ok()).to_be(true)
    it "inserts and selects rows":
        val r = PureDatabase.memory()
        var db = r.unwrap()
        val cr = db.exec_sql("CREATE TABLE t (id INTEGER, name TEXT)")
        cr.unwrap()
        val i1 = db.exec_sql("INSERT INTO t (id, name) VALUES (1, 'Alice')")
        i1.unwrap()
        val i2 = db.exec_sql("INSERT INTO t (id, name) VALUES (2, 'Bob')")
        i2.unwrap()
        val qr = db.query("SELECT * FROM t", [])
        expect(qr.is_ok()).to_be(true)
        val rows = qr.unwrap()
        expect(rows.len()).to_equal(2)
    it "selects with WHERE clause":
        val r = PureDatabase.memory()
        var db = r.unwrap()
        val cr = db.exec_sql("CREATE TABLE t (id INTEGER, name TEXT)")
        cr.unwrap()
        val i1 = db.exec_sql("INSERT INTO t (id, name) VALUES (1, 'Alice')")
        i1.unwrap()
        val i2 = db.exec_sql("INSERT INTO t (id, name) VALUES (2, 'Bob')")
        i2.unwrap()
        val qr = db.query("SELECT * FROM t WHERE id = 1", [])
        val rows = qr.unwrap()
        expect(rows.len()).to_equal(1)
    it "selects specific columns":
        val r = PureDatabase.memory()
        var db = r.unwrap()
        val cr = db.exec_sql("CREATE TABLE t (id INTEGER, name TEXT, age INTEGER)")
        cr.unwrap()
        val i1 = db.exec_sql("INSERT INTO t (id, name, age) VALUES (1, 'Alice', 30)")
        i1.unwrap()
        val qr = db.query("SELECT name FROM t", [])
        val rows = qr.unwrap()
        expect(rows.len()).to_equal(1)
        expect(rows[0].columns.len()).to_equal(1)
    it "deletes with WHERE clause":
        val r = PureDatabase.memory()
        var db = r.unwrap()
        val cr = db.exec_sql("CREATE TABLE t (id INTEGER, name TEXT)")
        cr.unwrap()
        val i1 = db.exec_sql("INSERT INTO t (id, name) VALUES (1, 'Alice')")
        i1.unwrap()
        val i2 = db.exec_sql("INSERT INTO t (id, name) VALUES (2, 'Bob')")
        i2.unwrap()
        val dr = db.exec_sql("DELETE FROM t WHERE id = 1")
        dr.unwrap()
        val qr = db.query("SELECT * FROM t", [])
        val rows = qr.unwrap()
        expect(rows.len()).to_equal(1)
    it "updates rows":
        val r = PureDatabase.memory()
        var db = r.unwrap()
        val cr = db.exec_sql("CREATE TABLE t (id INTEGER, name TEXT)")
        cr.unwrap()
        val ir = db.exec_sql("INSERT INTO t (id, name) VALUES (1, 'Alice')")
        ir.unwrap()
        val ur = db.exec_sql("UPDATE t SET name = 'Bob' WHERE id = 1")
        ur.unwrap()
        val qr = db.query("SELECT * FROM t WHERE name = 'Bob'", [])
        val rows = qr.unwrap()
        expect(rows.len()).to_equal(1)
    it "round-trip create-insert-select-delete":
        val r = PureDatabase.memory()
        var db = r.unwrap()
        val cr = db.exec_sql("CREATE TABLE items (id INTEGER, val TEXT)")
        cr.unwrap()
        val i1 = db.exec_sql("INSERT INTO items (id, val) VALUES (1, 'a')")
        i1.unwrap()
        val i2 = db.exec_sql("INSERT INTO items (id, val) VALUES (2, 'b')")
        i2.unwrap()
        val i3 = db.exec_sql("INSERT INTO items (id, val) VALUES (3, 'c')")
        i3.unwrap()
        expect(db.table_exists("items")).to_be(true)
        val all_r = db.query("SELECT * FROM items", [])
        val all_rows = all_r.unwrap()
        expect(all_rows.len()).to_equal(3)
        val dr = db.exec_sql("DELETE FROM items WHERE id = 2")
        dr.unwrap()
        val after_r = db.query("SELECT * FROM items", [])
        val after = after_r.unwrap()
        expect(after.len()).to_equal(2)
    it "reports table_exists correctly":
        val r = PureDatabase.memory()
        var db = r.unwrap()
        expect(db.table_exists("nope")).to_be(false)
        val cr = db.exec_sql("CREATE TABLE yes_tbl (id INTEGER)")
        cr.unwrap()
        expect(db.table_exists("yes_tbl")).to_be(true)
    it "rejects query on closed database":
        val r = PureDatabase.memory()
        var db = r.unwrap()
        val cl = db.close()
        cl.unwrap()
        val qr = db.query("SELECT 1 FROM t", [])
        expect(qr.is_err()).to_be(true)
    it "searches text columns with BM25 ranking":
        val r = PureDatabase.memory()
        var db = r.unwrap()
        db.exec_sql("CREATE TABLE docs (id INTEGER, title TEXT, body TEXT)").unwrap()
        db.exec_sql("INSERT INTO docs (id, title, body) VALUES (1, 'SQLite FTS5', 'embedded search engine bm25 ranking')").unwrap()
        db.exec_sql("INSERT INTO docs (id, title, body) VALUES (2, 'Other Storage', 'plain key value storage')").unwrap()
        db.exec_sql("INSERT INTO docs (id, title, body) VALUES (3, 'BM25 Search', 'bm25 bm25 search ranking support')").unwrap()

        val sr = db.bm25_search("docs", ["title", "body"], "bm25 search", 10)
        expect(sr.is_ok()).to_be(true)
        val rows = sr.unwrap()
        expect(rows.len()).to_equal(2)
        val first = rows[0]
        val second = rows[1]
        expect(first.score).to_be_greater_than(second.score)
        val first_row = first.row
        val first_id = first_row.values[0]
        expect(first_id.to_text()).to_equal("3")
    it "supports FTS5-compatible search alias":
        val r = PureDatabase.memory()
        var db = r.unwrap()
        db.exec_sql("CREATE TABLE docs (id INTEGER, body TEXT)").unwrap()
        db.exec_sql("INSERT INTO docs (id, body) VALUES (1, 'alpha beta beta')").unwrap()
        db.exec_sql("INSERT INTO docs (id, body) VALUES (2, 'gamma delta')").unwrap()

        val sr = db.fts5_search("docs", ["body"], "beta", 5)
        expect(sr.is_ok()).to_be(true)
        val rows = sr.unwrap()
        expect(rows.len()).to_equal(1)
        val fts_first = rows[0]
        val fts_first_row = fts_first.row
        val fts_first_id = fts_first_row.values[0]
        expect(fts_first_id.to_text()).to_equal("1")
    it "search reflects updated and deleted rows":
        val r = PureDatabase.memory()
        var db = r.unwrap()
        db.exec_sql("CREATE TABLE docs (id INTEGER, body TEXT)").unwrap()
        db.exec_sql("INSERT INTO docs (id, body) VALUES (1, 'alpha draft')").unwrap()
        db.exec_sql("INSERT INTO docs (id, body) VALUES (2, 'beta live')").unwrap()
        db.exec_sql("UPDATE docs SET body = 'alpha live' WHERE id = 1").unwrap()
        db.exec_sql("DELETE FROM docs WHERE id = 2").unwrap()

        val sr = db.fts5_search("docs", ["body"], "live", 5)
        expect(sr.is_ok()).to_be(true)
        val rows = sr.unwrap()
        expect(rows.len()).to_equal(1)
        val first = rows[0]
        val first_row = first.row
        val first_id = first_row.values[0]
        expect(first_id.to_text()).to_equal("1")
    it "invalidates cached FTS search index after writes":
        val r = PureDatabase.memory()
        var db = r.unwrap()
        db.exec_sql("CREATE TABLE docs (id INTEGER, body TEXT)").unwrap()
        db.exec_sql("INSERT INTO docs (id, body) VALUES (1, 'alpha seed')").unwrap()

        val warm = db.fts5_search("docs", ["body"], "omega", 5)
        expect(warm.is_ok()).to_be(true)
        expect(warm.unwrap().len()).to_equal(0)
        db.exec_sql("INSERT INTO docs (id, body) VALUES (2, 'omega inserted')").unwrap()
        val after_insert = db.fts5_search("docs", ["body"], "omega", 5)
        expect(after_insert.is_ok()).to_be(true)
        val inserted_rows = after_insert.unwrap()
        expect(inserted_rows.len()).to_equal(1)
        expect(inserted_rows[0].row.values[0].to_text()).to_equal("2")
        db.exec_sql("UPDATE docs SET body = 'alpha updated' WHERE id = 1").unwrap()
        val after_update = db.fts5_search("docs", ["body"], "updated", 5)
        expect(after_update.is_ok()).to_be(true)
        val updated_rows = after_update.unwrap()
        expect(updated_rows.len()).to_equal(1)
        expect(updated_rows[0].row.values[0].to_text()).to_equal("1")
    it "supports alternate lightweight search algorithms":
        val r = PureDatabase.memory()
        var db = r.unwrap()
        db.exec_sql("CREATE TABLE docs (id INTEGER, body TEXT)").unwrap()
        db.exec_sql("INSERT INTO docs (id, body) VALUES (1, 'trace trace hardware')").unwrap()
        db.exec_sql("INSERT INTO docs (id, body) VALUES (2, 'trace external access')").unwrap()

        val sr = db.search("docs", ["body"], "trace", PureSearchAlgorithm.TermFrequency, 5)
        expect(sr.is_ok()).to_be(true)
        val rows = sr.unwrap()
        expect(rows.len()).to_equal(2)
        val tf_first = rows[0]
        val tf_first_row = tf_first.row
        val tf_first_id = tf_first_row.values[0]
        expect(tf_first_id.to_text()).to_equal("1")
    it "supports DROP TABLE":
        val r = PureDatabase.memory()
        var db = r.unwrap()
        val cr = db.exec_sql("CREATE TABLE drop_me (id INTEGER, name TEXT)")
        cr.unwrap()
        expect(db.table_exists("drop_me")).to_be(true)
        val dr = db.exec_sql("DROP TABLE drop_me")
        dr.unwrap()
        expect(db.table_exists("drop_me")).to_be(false)
    it "supports DISTINCT":
        val r = PureDatabase.memory()
        var db = r.unwrap()
        val cr = db.exec_sql("CREATE TABLE d (color TEXT)")
        cr.unwrap()
        val i1 = db.exec_sql("INSERT INTO d (color) VALUES ('red')")
        i1.unwrap()
        val i2 = db.exec_sql("INSERT INTO d (color) VALUES ('blue')")
        i2.unwrap()
        val i3 = db.exec_sql("INSERT INTO d (color) VALUES ('red')")
        i3.unwrap()
        val qr = db.query("SELECT DISTINCT color FROM d", [])
        val drows = qr.unwrap()
        expect(drows.len()).to_equal(2)
    it "supports LIKE":
        val r = PureDatabase.memory()
        var db = r.unwrap()
        val cr = db.exec_sql("CREATE TABLE lk (id INTEGER, name TEXT)")
        cr.unwrap()
        val i1 = db.exec_sql("INSERT INTO lk (id, name) VALUES (1, 'Alice')")
        i1.unwrap()
        val i2 = db.exec_sql("INSERT INTO lk (id, name) VALUES (2, 'Bob')")
        i2.unwrap()
        val i3 = db.exec_sql("INSERT INTO lk (id, name) VALUES (3, 'Alicia')")
        i3.unwrap()
        val qr = db.query("SELECT * FROM lk WHERE name LIKE 'Al%'", [])
        val lrows = qr.unwrap()
        expect(lrows.len()).to_equal(2)
    it "supports COUNT aggregate":
        val r = PureDatabase.memory()
        var db = r.unwrap()
        val cr = db.exec_sql("CREATE TABLE cnt (id INTEGER, val TEXT)")
        cr.unwrap()
        val i1 = db.exec_sql("INSERT INTO cnt (id, val) VALUES (1, 'a')")
        i1.unwrap()
        val i2 = db.exec_sql("INSERT INTO cnt (id, val) VALUES (2, 'b')")
        i2.unwrap()
        val i3 = db.exec_sql("INSERT INTO cnt (id, val) VALUES (3, 'c')")
        i3.unwrap()
        val qr = db.query("SELECT COUNT(*) FROM cnt", [])
        val crows = qr.unwrap()
        expect(crows.len()).to_equal(1)
        val count_val = crows[0].values[0]
        expect(count_val.to_text()).to_equal("3")
    it "supports INNER JOIN":
        val r = PureDatabase.memory()
        var db = r.unwrap()
        val c1 = db.exec_sql("CREATE TABLE users2 (uid INTEGER, name TEXT)")
        c1.unwrap()
        val c2 = db.exec_sql("CREATE TABLE orders2 (oid INTEGER, user_id INTEGER, item TEXT)")
        c2.unwrap()
        val i1 = db.exec_sql("INSERT INTO users2 (uid, name) VALUES (1, 'Alice')")
        i1.unwrap()
        val i2 = db.exec_sql("INSERT INTO users2 (uid, name) VALUES (2, 'Bob')")
        i2.unwrap()
        val i3 = db.exec_sql("INSERT INTO orders2 (oid, user_id, item) VALUES (10, 1, 'book')")
        i3.unwrap()
        val i4 = db.exec_sql("INSERT INTO orders2 (oid, user_id, item) VALUES (11, 1, 'pen')")
        i4.unwrap()
        val i5 = db.exec_sql("INSERT INTO orders2 (oid, user_id, item) VALUES (12, 2, 'hat')")
        i5.unwrap()
        val qr = db.query("SELECT * FROM users2 JOIN orders2 ON uid = user_id", [])
        val jrows = qr.unwrap()
        expect(jrows.len()).to_equal(3)
    it "supports ORDER BY ASC":
        val r = PureDatabase.memory()
        var db = r.unwrap()
        val cr = db.exec_sql("CREATE TABLE ob_asc (id INTEGER, name TEXT)")
        cr.unwrap()
        val i1 = db.exec_sql("INSERT INTO ob_asc (id, name) VALUES (3, 'C')")
        i1.unwrap()
        val i2 = db.exec_sql("INSERT INTO ob_asc (id, name) VALUES (1, 'A')")
        i2.unwrap()
        val i3 = db.exec_sql("INSERT INTO ob_asc (id, name) VALUES (2, 'B')")
        i3.unwrap()
        val qr = db.query("SELECT * FROM ob_asc ORDER BY id ASC", [])
        val rows = qr.unwrap()
        expect(rows.len()).to_equal(3)
        val first = rows[0]
        val first_vals = first.values
        val first_id = first_vals[0]
        expect(first_id.to_text()).to_equal("1")
        val second = rows[1]
        val second_vals = second.values
        val second_id = second_vals[0]
        expect(second_id.to_text()).to_equal("2")
        val third = rows[2]
        val third_vals = third.values
        val third_id = third_vals[0]
        expect(third_id.to_text()).to_equal("3")
    it "supports IS NULL":
        val r = PureDatabase.memory()
        var db = r.unwrap()
        val cr = db.exec_sql("CREATE TABLE null_t (id INTEGER, name TEXT)")
        cr.unwrap()
        val i1 = db.exec_sql("INSERT INTO null_t (id, name) VALUES (1, NULL)")
        i1.unwrap()
        val i2 = db.exec_sql("INSERT INTO null_t (id, name) VALUES (2, 'Bob')")
        i2.unwrap()
        val qr = db.query("SELECT * FROM null_t WHERE name IS NULL", [])
        val rows = qr.unwrap()
        expect(rows.len()).to_equal(1)
        val row0 = rows[0]
        val row0_vals = row0.values
        val row0_id = row0_vals[0]
        expect(row0_id.to_text()).to_equal("1")
    it "supports IS NOT NULL":
        val r = PureDatabase.memory()
        var db = r.unwrap()
        val cr = db.exec_sql("CREATE TABLE notnull_t (id INTEGER, name TEXT)")
        cr.unwrap()
        val i1 = db.exec_sql("INSERT INTO notnull_t (id, name) VALUES (1, NULL)")
        i1.unwrap()
        val i2 = db.exec_sql("INSERT INTO notnull_t (id, name) VALUES (2, 'Bob')")
        i2.unwrap()
        val qr = db.query("SELECT * FROM notnull_t WHERE name IS NOT NULL", [])
        val rows = qr.unwrap()
        expect(rows.len()).to_equal(1)
        val row0 = rows[0]
        val row0_vals = row0.values
        val row0_id = row0_vals[0]
        expect(row0_id.to_text()).to_equal("2")
    it "supports NOT in WHERE":
        val r = PureDatabase.memory()
        var db = r.unwrap()
        val cr = db.exec_sql("CREATE TABLE not_t (id INTEGER, name TEXT)")
        cr.unwrap()
        val i1 = db.exec_sql("INSERT INTO not_t (id, name) VALUES (1, 'Alice')")
        i1.unwrap()
        val i2 = db.exec_sql("INSERT INTO not_t (id, name) VALUES (2, 'Bob')")
        i2.unwrap()
        val i3 = db.exec_sql("INSERT INTO not_t (id, name) VALUES (3, 'Charlie')")
        i3.unwrap()
        val qr = db.query("SELECT * FROM not_t WHERE NOT (id = 1)", [])
        val rows = qr.unwrap()
        expect(rows.len()).to_equal(2)
    it "supports LIMIT":
        val r = PureDatabase.memory()
        var db = r.unwrap()
        val cr = db.exec_sql("CREATE TABLE lim_t (id INTEGER, name TEXT)")
        cr.unwrap()
        val i1 = db.exec_sql("INSERT INTO lim_t (id, name) VALUES (1, 'A')")
        i1.unwrap()
        val i2 = db.exec_sql("INSERT INTO lim_t (id, name) VALUES (2, 'B')")
        i2.unwrap()
        val i3 = db.exec_sql("INSERT INTO lim_t (id, name) VALUES (3, 'C')")
        i3.unwrap()
        val i4 = db.exec_sql("INSERT INTO lim_t (id, name) VALUES (4, 'D')")
        i4.unwrap()
        val i5 = db.exec_sql("INSERT INTO lim_t (id, name) VALUES (5, 'E')")
        i5.unwrap()
        val qr = db.query("SELECT * FROM lim_t LIMIT 3", [])
        val rows = qr.unwrap()
        expect(rows.len()).to_equal(3)
    it "supports LIMIT OFFSET":
        val r = PureDatabase.memory()
        var db = r.unwrap()
        val cr = db.exec_sql("CREATE TABLE limoff_t (id INTEGER, name TEXT)")
        cr.unwrap()
        val i1 = db.exec_sql("INSERT INTO limoff_t (id, name) VALUES (1, 'A')")
        i1.unwrap()
        val i2 = db.exec_sql("INSERT INTO limoff_t (id, name) VALUES (2, 'B')")
        i2.unwrap()
        val i3 = db.exec_sql("INSERT INTO limoff_t (id, name) VALUES (3, 'C')")
        i3.unwrap()
        val i4 = db.exec_sql("INSERT INTO limoff_t (id, name) VALUES (4, 'D')")
        i4.unwrap()
        val i5 = db.exec_sql("INSERT INTO limoff_t (id, name) VALUES (5, 'E')")
        i5.unwrap()
        val qr = db.query("SELECT * FROM limoff_t LIMIT 2 OFFSET 1", [])
        val rows = qr.unwrap()
        expect(rows.len()).to_equal(2)
        val row0 = rows[0]
        val row0_vals = row0.values
        val row0_id = row0_vals[0]
        expect(row0_id.to_text()).to_equal("2")
        val row1 = rows[1]
        val row1_vals = row1.values
        val row1_id = row1_vals[0]
        expect(row1_id.to_text()).to_equal("3")
    it "supports parameterized queries":
        val r = PureDatabase.memory()
        var db = r.unwrap()
        val cr = db.exec_sql("CREATE TABLE param_t (id INTEGER, name TEXT)")
        cr.unwrap()
        val i1 = db.exec_sql("INSERT INTO param_t (id, name) VALUES (1, 'Alice')")
        i1.unwrap()
        val i2 = db.exec_sql("INSERT INTO param_t (id, name) VALUES (2, 'Bob')")
        i2.unwrap()
        var p: [DbValue] = []
        p.push(DbValue.Integer(value: 1))
        val qr = db.query("SELECT * FROM param_t WHERE id = ?", p)
        val rows = qr.unwrap()
        expect(rows.len()).to_equal(1)
        val row0 = rows[0]
        val row0_vals = row0.values
        val row0_name = row0_vals[1]
        expect(row0_name.to_text()).to_equal("Alice")
    it "supports LENGTH function":
        val r = PureDatabase.memory()
        var db = r.unwrap()
        val cr = db.exec_sql("CREATE TABLE len_t (id INTEGER, name TEXT)")
        cr.unwrap()
        val i1 = db.exec_sql("INSERT INTO len_t (id, name) VALUES (1, 'Hello')")
        i1.unwrap()
        val qr = db.query("SELECT LENGTH(name) FROM len_t", [])
        val rows = qr.unwrap()
        expect(rows.len()).to_equal(1)
        val row0 = rows[0]
        val row0_vals = row0.values
        val v0 = row0_vals[0]
        expect(v0.to_text()).to_equal("5")
    it "supports UPPER and LOWER functions":
        val r = PureDatabase.memory()
        var db = r.unwrap()
        val cr = db.exec_sql("CREATE TABLE case_t (id INTEGER, name TEXT)")
        cr.unwrap()
        val i1 = db.exec_sql("INSERT INTO case_t (id, name) VALUES (1, 'Hello')")
        i1.unwrap()
        val qr = db.query("SELECT UPPER(name) FROM case_t", [])
        val rows = qr.unwrap()
        expect(rows.len()).to_equal(1)
        val row0 = rows[0]
        val row0_vals = row0.values
        val v0 = row0_vals[0]
        expect(v0.to_text()).to_equal("HELLO")
        val qr2 = db.query("SELECT LOWER(name) FROM case_t", [])
        val rows2 = qr2.unwrap()
        val row2_0 = rows2[0]
        val row2_0_vals = row2_0.values
        val v2_0 = row2_0_vals[0]
        expect(v2_0.to_text()).to_equal("hello")
    it "supports TRIM function":
        val r = PureDatabase.memory()
        var db = r.unwrap()
        val cr = db.exec_sql("CREATE TABLE trim_t (id INTEGER, name TEXT)")
        cr.unwrap()
        var p: [DbValue] = []
        p.push(DbValue.Integer(value: 1))
        p.push(DbValue.Text(value: "  hello  "))
        val i1 = db.exec("INSERT INTO trim_t (id, name) VALUES (?, ?)", p)
        i1.unwrap()
        val qr = db.query("SELECT TRIM(name) FROM trim_t", [])
        val rows = qr.unwrap()
        expect(rows.len()).to_equal(1)
        val row0 = rows[0]
        val row0_vals = row0.values
        val v0 = row0_vals[0]
        expect(v0.to_text()).to_equal("hello")
    it "supports SUBSTR function":
        val r = PureDatabase.memory()
        var db = r.unwrap()
        val cr = db.exec_sql("CREATE TABLE sub_t (id INTEGER, name TEXT)")
        cr.unwrap()
        val i1 = db.exec_sql("INSERT INTO sub_t (id, name) VALUES (1, 'Hello World')")
        i1.unwrap()
        val qr = db.query("SELECT SUBSTR(name, 1, 5) FROM sub_t", [])
        val rows = qr.unwrap()
        expect(rows.len()).to_equal(1)
        val row0 = rows[0]
        val row0_vals = row0.values
        val v0 = row0_vals[0]
        expect(v0.to_text()).to_equal("Hello")
    it "supports REPLACE function":
        val r = PureDatabase.memory()
        var db = r.unwrap()
        val cr = db.exec_sql("CREATE TABLE rep_t (id INTEGER, name TEXT)")
        cr.unwrap()
        val i1 = db.exec_sql("INSERT INTO rep_t (id, name) VALUES (1, 'old world')")
        i1.unwrap()
        val qr = db.query("SELECT REPLACE(name, 'old', 'new') FROM rep_t", [])
        val rows = qr.unwrap()
        expect(rows.len()).to_equal(1)
        val row0 = rows[0]
        val row0_vals = row0.values
        val v0 = row0_vals[0]
        expect(v0.to_text()).to_equal("new world")
    it "supports ABS function":
        val r = PureDatabase.memory()
        var db = r.unwrap()
        val cr = db.exec_sql("CREATE TABLE abs_t (id INTEGER, val INTEGER)")
        cr.unwrap()
        var p: [DbValue] = []
        p.push(DbValue.Integer(value: 1))
        p.push(DbValue.Integer(value: -5))
        val i1 = db.exec("INSERT INTO abs_t (id, val) VALUES (?, ?)", p)
        i1.unwrap()
        val qr = db.query("SELECT ABS(val) FROM abs_t", [])
        val rows = qr.unwrap()
        expect(rows.len()).to_equal(1)
        val row0 = rows[0]
        val row0_vals = row0.values
        val v0 = row0_vals[0]
        expect(v0.to_text()).to_equal("5")
    it "supports COALESCE function":
        val r = PureDatabase.memory()
        var db = r.unwrap()
        val cr = db.exec_sql("CREATE TABLE coal_t (id INTEGER, name TEXT)")
        cr.unwrap()
        val i1 = db.exec_sql("INSERT INTO coal_t (id, name) VALUES (1, NULL)")
        i1.unwrap()
        val qr = db.query("SELECT COALESCE(name, 'default') FROM coal_t", [])
        val rows = qr.unwrap()
        expect(rows.len()).to_equal(1)
        val row0 = rows[0]
        val row0_vals = row0.values
        val v0 = row0_vals[0]
        expect(v0.to_text()).to_equal("default")
    it "supports IFNULL function":
        val r = PureDatabase.memory()
        var db = r.unwrap()
        val cr = db.exec_sql("CREATE TABLE ifn_t (id INTEGER, name TEXT)")
        cr.unwrap()
        val i1 = db.exec_sql("INSERT INTO ifn_t (id, name) VALUES (1, NULL)")
        i1.unwrap()
        val qr = db.query("SELECT IFNULL(name, 'fallback') FROM ifn_t", [])
        val rows = qr.unwrap()
        expect(rows.len()).to_equal(1)
        val row0 = rows[0]
        val row0_vals = row0.values
        val v0 = row0_vals[0]
        expect(v0.to_text()).to_equal("fallback")
    it "supports multiple aggregates":
        val r = PureDatabase.memory()
        var db = r.unwrap()
        val cr = db.exec_sql("CREATE TABLE magg_t (id INTEGER, val INTEGER)")
        cr.unwrap()
        val i1 = db.exec_sql("INSERT INTO magg_t (id, val) VALUES (1, 10)")
        i1.unwrap()
        val i2 = db.exec_sql("INSERT INTO magg_t (id, val) VALUES (2, 20)")
        i2.unwrap()
        val i3 = db.exec_sql("INSERT INTO magg_t (id, val) VALUES (3, 30)")
        i3.unwrap()
        val qr = db.query("SELECT COUNT(*), SUM(val), AVG(val) FROM magg_t", [])
        val rows = qr.unwrap()
        expect(rows.len()).to_equal(1)
        val row0 = rows[0]
        val row0_vals = row0.values
        val cnt = row0_vals[0]
        expect(cnt.to_text()).to_equal("3")
        val sm = row0_vals[1]
        expect(sm.to_text()).to_equal("60")
        val av = row0_vals[2]
        expect(av.to_text()).to_equal("20")
    it "supports column alias AS":
        val r = PureDatabase.memory()
        var db = r.unwrap()
        val cr = db.exec_sql("CREATE TABLE alias_t (id INTEGER, name TEXT)")
        cr.unwrap()
        val i1 = db.exec_sql("INSERT INTO alias_t (id, name) VALUES (1, 'Alice')")
        i1.unwrap()
        val qr = db.query("SELECT name AS n FROM alias_t", [])
        val rows = qr.unwrap()
        expect(rows.len()).to_equal(1)
        val row0 = rows[0]
        val row0_cols = row0.columns
        val col0 = row0_cols[0]
        expect(col0).to_equal("n")
    it "supports BEGIN and COMMIT":
        val r = PureDatabase.memory()
        var db = r.unwrap()
        val cr = db.exec_sql("CREATE TABLE txn_t (id INTEGER, name TEXT)")
        cr.unwrap()
        val b = db.exec_sql("BEGIN")
        b.unwrap()
        val i1 = db.exec_sql("INSERT INTO txn_t (id, name) VALUES (1, 'Alice')")
        i1.unwrap()
        val i2 = db.exec_sql("INSERT INTO txn_t (id, name) VALUES (2, 'Bob')")
        i2.unwrap()
        val c = db.exec_sql("COMMIT")
        c.unwrap()
        val qr = db.query("SELECT * FROM txn_t", [])
        val rows = qr.unwrap()
        expect(rows.len()).to_equal(2)
    it "supports ROLLBACK":
        val r = PureDatabase.memory()
        var db = r.unwrap()
        val cr = db.exec_sql("CREATE TABLE rb_t (id INTEGER, name TEXT)")
        cr.unwrap()
        val b = db.exec_sql("BEGIN")
        b.unwrap()
        val i1 = db.exec_sql("INSERT INTO rb_t (id, name) VALUES (1, 'Alice')")
        i1.unwrap()
        val rb = db.exec_sql("ROLLBACK")
        rb.unwrap()
        val qr = db.query("SELECT * FROM rb_t", [])
        val rows = qr.unwrap()
        expect(rows.len()).to_equal(0)
    it "supports ALTER TABLE ADD COLUMN":
        val r = PureDatabase.memory()
        var db = r.unwrap()
        val cr = db.exec_sql("CREATE TABLE alt_t (id INTEGER, name TEXT)")
        cr.unwrap()
        val i1 = db.exec_sql("INSERT INTO alt_t (id, name) VALUES (1, 'Alice')")
        i1.unwrap()
        val ar = db.exec_sql("ALTER TABLE alt_t ADD COLUMN age INTEGER")
        ar.unwrap()
        val qr = db.query("SELECT * FROM alt_t", [])
        val rows = qr.unwrap()
        expect(rows.len()).to_equal(1)
        val row0 = rows[0]
        val row0_cols = row0.columns
        expect(row0_cols.len()).to_equal(3)
        val col2 = row0_cols[2]
        expect(col2).to_equal("age")
        val row0_vals = row0.values
        val v2 = row0_vals[2]
        expect(v2.is_null()).to_be(true)
    it "supports nested operations in transaction":
        val r = PureDatabase.memory()
        var db = r.unwrap()
        val cr = db.exec_sql("CREATE TABLE nest_t (id INTEGER, name TEXT)")
        cr.unwrap()
        val i0 = db.exec_sql("INSERT INTO nest_t (id, name) VALUES (1, 'Alice')")
        i0.unwrap()
        val i0b = db.exec_sql("INSERT INTO nest_t (id, name) VALUES (2, 'Bob')")
        i0b.unwrap()
        val i0c = db.exec_sql("INSERT INTO nest_t (id, name) VALUES (3, 'Charlie')")
        i0c.unwrap()
        val b = db.exec_sql("BEGIN")
        b.unwrap()
        val i1 = db.exec_sql("INSERT INTO nest_t (id, name) VALUES (4, 'Dave')")
        i1.unwrap()
        val u1 = db.exec_sql("UPDATE nest_t SET name = 'ALICE' WHERE id = 1")
        u1.unwrap()
        val d1 = db.exec_sql("DELETE FROM nest_t WHERE id = 2")
        d1.unwrap()
        val c = db.exec_sql("COMMIT")
        c.unwrap()
        val qr = db.query("SELECT * FROM nest_t ORDER BY id ASC", [])
        val rows = qr.unwrap()
        expect(rows.len()).to_equal(3)
        val r0 = rows[0]
        val r0_vals = r0.values
        val r0_name = r0_vals[1]
        expect(r0_name.to_text()).to_equal("ALICE")
        val r1 = rows[1]
        val r1_vals = r1.values
        val r1_id = r1_vals[0]
        expect(r1_id.to_text()).to_equal("3")
        val r2 = rows[2]
        val r2_vals = r2.values
        val r2_id = r2_vals[0]
        expect(r2_id.to_text()).to_equal("4")
    it "supports arithmetic in SELECT":
        val r = PureDatabase.memory()
        var db = r.unwrap()
        val cr = db.exec_sql("CREATE TABLE arith_t (id INTEGER, val INTEGER)")
        cr.unwrap()
        val i1 = db.exec_sql("INSERT INTO arith_t (id, val) VALUES (1, 10)")
        i1.unwrap()
        val i2 = db.exec_sql("INSERT INTO arith_t (id, val) VALUES (2, 20)")
        i2.unwrap()
        val qr = db.query("SELECT id + 1 FROM arith_t", [])
        val rows = qr.unwrap()
        expect(rows.len()).to_equal(2)
        val row0 = rows[0]
        val row0_vals = row0.values
        val row0_v = row0_vals[0]
        expect(row0_v.to_text()).to_equal("2")
        val row1 = rows[1]
        val row1_vals = row1.values
        val row1_v = row1_vals[0]
        expect(row1_v.to_text()).to_equal("3")
