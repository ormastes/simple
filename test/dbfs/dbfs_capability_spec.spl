# Maps to: AC-2, AC-8, AC-9
# Run: bin/simple test test/dbfs/dbfs_capability_spec.spl

"""
DBFS Capability Extension Probe Specification

Verifies DbFsDriver reports capabilities correctly:
  Positive: POSIX-shim, xattr, ACL, snapshot, COW, LargeFiles
  Negative: no dedup, no hard-links, no DirectIo
"""

use std.spipe.*
use std.fs_driver.capability.{Capability, CapabilitySet}
use std.db.dbfs_driver.{DbFsDriver}

fn make_driver() -> DbFsDriver:
    DbFsDriver.new_hosted()

describe "DBFS Capability — positive probes":
    it "PosixCompat capability is present":
        val d = make_driver()
        expect(d.probe(Capability.PosixCompat).?).to_equal(true)

    it "Xattr capability is present":
        val d = make_driver()
        expect(d.probe(Capability.Xattr).?).to_equal(true)

    it "Acl capability is present":
        val d = make_driver()
        expect(d.probe(Capability.Acl).?).to_equal(true)

    it "Snapshot capability is present":
        val d = make_driver()
        expect(d.probe(Capability.Snapshot).?).to_equal(true)

    it "COW capability is present":
        val d = make_driver()
        expect(d.probe(Capability.COW).?).to_equal(true)

    it "LargeFiles capability is present":
        val d = make_driver()
        expect(d.probe(Capability.LargeFiles).?).to_equal(true)

describe "DBFS Capability — negative probes (out-of-scope ops)":
    it "Dedup capability is absent":
        val d = make_driver()
        expect(d.probe(Capability.Dedup).?).to_equal(false)

    it "Hardlinks capability is absent":
        val d = make_driver()
        expect(d.probe(Capability.Hardlinks).?).to_equal(false)

    it "DirectIo capability is absent":
        val d = make_driver()
        expect(d.probe(Capability.DirectIo).?).to_equal(false)

describe "DBFS Capability — capabilities() set":
    it "capabilities() returns a CapabilitySet containing PosixCompat":
        val d = make_driver()
        val caps = d.capabilities()
        expect(caps.has(Capability.PosixCompat)).to_equal(true)

    it "capabilities() does not contain Dedup":
        val d = make_driver()
        val caps = d.capabilities()
        expect(caps.has(Capability.Dedup)).to_equal(false)
