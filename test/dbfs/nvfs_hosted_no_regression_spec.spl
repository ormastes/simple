# Maps to: AC-4, AC-9
# Run: bin/simple test test/dbfs/nvfs_hosted_no_regression_spec.spl

"""
NVFS Hosted Seam Specification

Runs the same hosted mount-table contract as FAT32 so NVFS can share the
filesystem regression seam used by FAT32 and DBFS.
"""

use std.spipe.*
use std.fs_driver.types.{MountOptions}
use std.fs_driver.instance.{DriverInstance}
use std.fs_driver.mount_table.{MountTable}
use examples.nvfs.src.driver.fs_driver_impl.{NvfsDriver}
use test.dbfs.hosted_fs_no_regression_shared.{
    assert_mount_root_is_dir,
    assert_mount_root_slash_is_dir,
    assert_readdir_on_root_is_stable,
    assert_open_returns_handle,
    assert_read_returns_empty_or_better
}

fn make_nvfs_mounted() -> MountTable:
    val mt = MountTable.new()
    var nvfs = NvfsDriver.new("nvfs-hosted")
    nvfs.mount(MountOptions.default()).unwrap()
    mt.mount("/nvfs", DriverInstance.Nvfs(nvfs), MountOptions.default()).unwrap()
    mt

describe "NVFS hosted seam — mount and stat":
    it "NVFS volume mounts without error":
        val mt = make_nvfs_mounted()
        assert_mount_root_is_dir(mt, "/nvfs")

    it "stat on NVFS root returns is_dir=true":
        val mt = make_nvfs_mounted()
        assert_mount_root_slash_is_dir(mt, "/nvfs")

describe "NVFS hosted seam — readdir and open":
    it "readdir on NVFS root returns a stable empty-or-better listing":
        val mt = make_nvfs_mounted()
        assert_readdir_on_root_is_stable(mt, "/nvfs")

    it "open on an NVFS path returns a valid handle":
        val mt = make_nvfs_mounted()
        assert_open_returns_handle(mt, "/nvfs/README.TXT")

    it "read on NVFS returns empty content rather than erroring":
        val mt = make_nvfs_mounted()
        assert_read_returns_empty_or_better(mt, "/nvfs/README.TXT")
