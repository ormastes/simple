#![allow(spipe_empty_examples)]
#![allow(spipe_boolean_wrapper_assertions)]
@allow(spipe_empty_examples)
@allow(spipe_boolean_wrapper_assertions)
use std.spipe.*
use std.fs_driver.ops.{FsDriver}
use std.fs_driver.types.{Path, OpenFlags, MountOptions, StatInfo}
use std.fs_driver.error.{FsError}
use std.storage.nvfs.nvfs_driver.{NvfsDriver}
use std.storage.nvfs.nvfs_posix.{NvfsPosixDriver}

fn make_nvfs() -> NvfsDriver:
    NvfsDriver.new_hosted()

fn make_nvfs_posix() -> NvfsPosixDriver:
    NvfsPosixDriver.new_hosted()

fn main():
    # Maps to: AC-4, AC-9
    # Run: bin/simple test test/dbfs/nvfs_no_regression_spec.spl

    """
    NVFS No-Regression Specification
    
    Verifies existing NvfsDriver + NvfsPosix mount/open/read/write/stat
    are unchanged after the NVFS BlobBackend refactor (AC-4).
    """


    describe "NVFS no-regression — NvfsDriver":
        it "NvfsDriver can be mounted and returns a root stat":
            val d = make_nvfs()
            val stat = d.stat("/").unwrap()
            expect stat.is_dir == true

        it "NvfsDriver open + write + read round-trips":
            val d = make_nvfs()
            val fh = d.open("/nvfs_reg.bin", OpenFlags.create_write()).unwrap()
            d.write(fh, "nvfs-ok").unwrap()
            val fh2 = d.open("/nvfs_reg.bin", OpenFlags.read_only()).unwrap()
            val got = d.read(fh2, 7).unwrap()
            expect got == "nvfs-ok"

        it "NvfsDriver stat returns correct size after write":
            val d = make_nvfs()
            val fh = d.open("/size_test.bin", OpenFlags.create_write()).unwrap()
            d.write(fh, "12345").unwrap()
            d.close(fh).unwrap()
            val stat = d.stat("/size_test.bin").unwrap()
            expect stat.size == 5

    describe "NVFS no-regression — NvfsPosixDriver":
        it "NvfsPosixDriver can be mounted":
            val d = make_nvfs_posix()
            val stat = d.stat("/").unwrap()
            expect stat.is_dir == true

        it "NvfsPosixDriver open + write + read round-trips":
            val d = make_nvfs_posix()
            val fh = d.open("/posix_reg.txt", OpenFlags.create_write()).unwrap()
            d.write(fh, "posix-ok").unwrap()
            val fh2 = d.open("/posix_reg.txt", OpenFlags.read_only()).unwrap()
            val got = d.read(fh2, 8).unwrap()
            expect got == "posix-ok"

        it "NvfsPosixDriver stat returns is_file for created file":
            val d = make_nvfs_posix()
            val fh = d.open("/file.txt", OpenFlags.create_write()).unwrap()
            d.close(fh).unwrap()
            val stat = d.stat("/file.txt").unwrap()
            expect stat.is_file == true

    describe "NVFS no-regression — Arena trait unchanged":
        it "NvfsArena arena_append still works after refactor":
            val d = make_nvfs()
            val arena = d.primary_arena()
            val h = arena.arena_create(0, 4096).unwrap()
            val data: [u8] = [1, 2, 3]
            val r = arena.arena_append(h, data, 0)
            expect r.is_ok() == true
fn main():
    #![allow(spipe_empty_examples)]
    #![allow(spipe_boolean_wrapper_assertions)]
    @allow(spipe_empty_examples)
    @allow(spipe_boolean_wrapper_assertions)
