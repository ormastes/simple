# Multi-arch harden: AC-4 — six-arch QEMU boot + smoke gate.
#
# The spec does NOT boot QEMU. Phase 5/7 produces per-arch result files
# at build/multiarch/<triple>/smoke_result.json after running
# `bin/simple test --arch=<triple>`. The spec asserts each result.
#
# Run:
#   bin/simple test test/os/multiarch/six_arch_boot_spec.spl
#
# @cover src/os/qemu_runner.spl
# @cover src/os/kernel/main.spl
# @cover test/os/smoke/

use std.spec
use std.io_runtime.{file_exists, file_read}

fn _smoke_path(triple: text) -> text:
    "build/multiarch/" + triple + "/smoke_result.json"

fn _baseline_path(triple: text) -> text:
    "build/multiarch/" + triple + "/baseline_smoke.json"

describe "AC-4 — x86_64-unknown-simpleos boots + smoke green":
    it "smoke result file exists":
        expect(file_exists(_smoke_path("x86_64"))).to_equal(true)
    it "boot banner printed":
        val r: text = file_read(_smoke_path("x86_64"))
        expect(r.contains("\"banner\": true")).to_equal(true)
    it "NVFS mounted":
        val r: text = file_read(_smoke_path("x86_64"))
        expect(r.contains("\"nvfs_mounted\": true")).to_equal(true)
    it "smoke suite green":
        val r: text = file_read(_smoke_path("x86_64"))
        expect(r.contains("\"status\": \"pass\"")).to_equal(true)

