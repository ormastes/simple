describe "AC-4 — x86_64 baseline regression gate":
    """Pre-feature smoke output captured into baseline_smoke.json the
    first time Phase 5 runs the smoke; this gate asserts the same
    suite still passes after the multiarch refactor lands."""

    it "x86_64 baseline checkpoint file exists":
        expect(file_exists(_baseline_path("x86_64"))).to_equal(true)

    it "x86_64 baseline matches current smoke result":
        val current:  text = file_read(_smoke_path("x86_64"))
        val baseline: text = file_read(_baseline_path("x86_64"))
        expect(current.contains("\"baseline_match\": true")).to_equal(true)
        expect(baseline.contains("\"status\": \"pass\"")).to_equal(true)
