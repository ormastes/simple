# Multi-arch harden: AC-3 + R7 — HAL trait surface (16 traits LOCKED).
#
# Run:
#   bin/simple test test/os/multiarch/hal_trait_surface_spec.spl
#
# Strategy: read src files as text and grep for trait declarations rather
# than `use` the symbols (the new traits don't exist yet, so importing
# them would cause a parse failure instead of a clean RED).
#
# @cover src/os/kernel/arch/hal.spl
# @cover src/os/kernel/arch/x86_64/
# @cover src/os/kernel/arch/x86_32/
# @cover src/os/kernel/arch/arm32/
# @cover src/os/kernel/arch/arm64/
# @cover src/os/kernel/arch/riscv32/
# @cover src/os/kernel/arch/riscv64/

use std.spec
use std.io_runtime.{file_exists, file_read}

val HAL_PATH:    text = "src/os/kernel/arch/hal.spl"
val LOC_REPORT:  text = "build/multiarch/arch_loc_report.json"

describe "AC-3 — 16 HAL traits declared in arch/hal.spl":
    """The locked surface (Phase 3): 8 existing + 6 NEW-with-impl
    + 2 reserved-only. Phase 5 adds the 8 new declarations."""

    it "hal.spl exists":
        expect(file_exists(HAL_PATH)).to_equal(true)

    it "declares HalConsole (existing)":
        val body: text = file_read(HAL_PATH)
        expect(body.contains("trait HalConsole")).to_equal(true)

    it "declares HalBoot (existing)":
        val body: text = file_read(HAL_PATH)
        expect(body.contains("trait HalBoot")).to_equal(true)

    it "declares HalCpu (existing)":
        val body: text = file_read(HAL_PATH)
        expect(body.contains("trait HalCpu")).to_equal(true)

    it "declares HalPower (existing)":
        val body: text = file_read(HAL_PATH)
        expect(body.contains("trait HalPower")).to_equal(true)

    it "declares HalPaging (existing)":
        val body: text = file_read(HAL_PATH)
        expect(body.contains("trait HalPaging")).to_equal(true)

    it "declares HalInterrupt (existing)":
        val body: text = file_read(HAL_PATH)
        expect(body.contains("trait HalInterrupt")).to_equal(true)

    it "declares HalTimer (existing)":
        val body: text = file_read(HAL_PATH)
        expect(body.contains("trait HalTimer")).to_equal(true)

    it "declares HalContext (existing)":
        val body: text = file_read(HAL_PATH)
        expect(body.contains("trait HalContext")).to_equal(true)

    it "declares HalEntropy (NEW — R6 canary entropy)":
        val body: text = file_read(HAL_PATH)
        expect(body.contains("trait HalEntropy")).to_equal(true)

    it "declares HalCstart (NEW — replaces simpleos_crt0.S/setjmp.S)":
        val body: text = file_read(HAL_PATH)
        expect(body.contains("trait HalCstart")).to_equal(true)

    it "declares HalSyscall (NEW — capability-checked trampoline)":
        val body: text = file_read(HAL_PATH)
        expect(body.contains("trait HalSyscall")).to_equal(true)

    it "declares HalCanary (NEW — per-boot stack guard)":
        val body: text = file_read(HAL_PATH)
        expect(body.contains("trait HalCanary")).to_equal(true)

    it "declares HalBarrier (NEW — MMIO ordering)":
        val body: text = file_read(HAL_PATH)
        expect(body.contains("trait HalBarrier")).to_equal(true)

    it "declares HalCache (NEW — i/d-cache maintenance)":
        val body: text = file_read(HAL_PATH)
        expect(body.contains("trait HalCache")).to_equal(true)

    it "declares HalSmp (NEW — RESERVED, shape only)":
        val body: text = file_read(HAL_PATH)
        expect(body.contains("trait HalSmp")).to_equal(true)

    it "declares HalPerCpu (NEW — RESERVED, shape only)":
        val body: text = file_read(HAL_PATH)
        expect(body.contains("trait HalPerCpu")).to_equal(true)

describe "AC-3 — per-arch impls present for 14 implementable traits":
    """SMP/PerCpu are shape-only this round; the other 14 must have
    impls in every arch directory."""

    it "x86_64 cstart.spl exists":
        expect(file_exists("src/os/kernel/arch/x86_64/cstart.spl")).to_equal(true)

    it "x86_32 cstart.spl exists":
        expect(file_exists("src/os/kernel/arch/x86_32/cstart.spl")).to_equal(true)

    it "arm32 cstart.spl exists":
        expect(file_exists("src/os/kernel/arch/arm32/cstart.spl")).to_equal(true)

    it "arm64 cstart.spl exists":
        expect(file_exists("src/os/kernel/arch/arm64/cstart.spl")).to_equal(true)

    it "riscv32 cstart.spl exists":
        expect(file_exists("src/os/kernel/arch/riscv32/cstart.spl")).to_equal(true)

    it "riscv64 cstart.spl exists":
        expect(file_exists("src/os/kernel/arch/riscv64/cstart.spl")).to_equal(true)

    it "x86_64 entropy.spl exists":
        expect(file_exists("src/os/kernel/arch/x86_64/entropy.spl")).to_equal(true)

    it "arm64 entropy.spl exists":
        expect(file_exists("src/os/kernel/arch/arm64/entropy.spl")).to_equal(true)

    it "riscv64 entropy.spl exists":
        expect(file_exists("src/os/kernel/arch/riscv64/entropy.spl")).to_equal(true)

describe "AC-3 — arch-neutral kernel uses only os.kernel.arch.hal":
    """Audit script must show zero direct
    `import os.kernel.arch.x86_64` (or any specific arch) outside the
    arch/ tree itself. Wave 5 emits arch_loc_report.json with the
    audit result."""

    it "loc report exists":
        expect(file_exists(LOC_REPORT)).to_equal(true)

    it "report shows zero arch-specific imports outside arch/":
        val report: text = file_read(LOC_REPORT)
        expect(report.contains("\"direct_arch_imports_outside_arch\": 0")).to_equal(true)

describe "AC-3 — per-arch LoC delta ≥40% (or ≥25% with rationale)":
    """Phase 2 baseline: x86_64=2746, x86_32=1760, arm32=1806,
    arm64≈1801, riscv64=2644, riscv32=1533. Floor: ≥40% reduction or
    ≥25% with paging-walker rationale documented in arch doc."""

    it "loc report contains per-arch delta_pct field":
        val report: text = file_read(LOC_REPORT)
        expect(report.contains("\"x86_64\"")).to_equal(true)
        expect(report.contains("\"delta_pct\"")).to_equal(true)

    it "x86_64 delta_pct meets the floor":
        """Read the report and assert x86_64 hit ≥40 (preferred) or
        ≥25 with documented walker fallback."""
        val report: text = file_read(LOC_REPORT)
        expect(report.contains("\"x86_64_meets_floor\": true")).to_equal(true)

    it "all six archs meet the floor":
        val report: text = file_read(LOC_REPORT)
        expect(report.contains("\"all_archs_meet_floor\": true")).to_equal(true)
