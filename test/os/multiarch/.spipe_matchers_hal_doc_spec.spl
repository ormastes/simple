# Multi-arch harden: AC-7 — architecture doc artefact.
#
# Run:
#   bin/simple test test/os/multiarch/hal_doc_spec.spl
#
# @cover doc/04_architecture/simpleos_multiarch_hal.md
# @cover doc/04_architecture/mdsoc_architecture_tobe.md

use std.spec
use std.io_runtime.{file_exists, file_read}

val ARCH_DOC: text = "doc/04_architecture/simpleos_multiarch_hal.md"
val MDSOC_DOC: text = "doc/04_architecture/mdsoc_architecture_tobe.md"

describe "AC-7 — multi-arch HAL architecture doc exists":
    it "doc file exists":
        expect file_exists(ARCH_DOC) == true

    it "doc is non-empty":
        val body: text = file_read(ARCH_DOC)
        expect body.length() > 0 == true

    it "doc declares the 16-trait surface as LOCKED":
        val body: text = file_read(ARCH_DOC)
        expect body.contains("HAL Trait Surface") == true
        expect body.contains("16 traits") == true

describe "AC-7 — doc names every locked trait":
    it "names HalConsole":
        val b: text = file_read(ARCH_DOC)
        expect b.contains("HalConsole") == true
    it "names HalBoot":
        val b: text = file_read(ARCH_DOC)
        expect b.contains("HalBoot") == true
    it "names HalCpu":
        val b: text = file_read(ARCH_DOC)
        expect b.contains("HalCpu") == true
    it "names HalPower":
        val b: text = file_read(ARCH_DOC)
        expect b.contains("HalPower") == true
    it "names HalPaging":
        val b: text = file_read(ARCH_DOC)
        expect b.contains("HalPaging") == true
    it "names HalInterrupt":
        val b: text = file_read(ARCH_DOC)
        expect b.contains("HalInterrupt") == true
    it "names HalTimer":
        val b: text = file_read(ARCH_DOC)
        expect b.contains("HalTimer") == true
    it "names HalContext":
        val b: text = file_read(ARCH_DOC)
        expect b.contains("HalContext") == true
    it "names HalEntropy":
        val b: text = file_read(ARCH_DOC)
        expect b.contains("HalEntropy") == true
    it "names HalCstart":
        val b: text = file_read(ARCH_DOC)
        expect b.contains("HalCstart") == true
    it "names HalSyscall":
        val b: text = file_read(ARCH_DOC)
        expect b.contains("HalSyscall") == true
    it "names HalCanary":
        val b: text = file_read(ARCH_DOC)
        expect b.contains("HalCanary") == true
    it "names HalBarrier":
        val b: text = file_read(ARCH_DOC)
        expect b.contains("HalBarrier") == true
    it "names HalCache":
        val b: text = file_read(ARCH_DOC)
        expect b.contains("HalCache") == true
    it "names HalSmp":
        val b: text = file_read(ARCH_DOC)
        expect b.contains("HalSmp") == true
    it "names HalPerCpu":
        val b: text = file_read(ARCH_DOC)
        expect b.contains("HalPerCpu") == true

describe "AC-7 — doc contains the hardening matrix and six-arch contract":
    it "documents the hardening matrix":
        val b: text = file_read(ARCH_DOC)
        expect b.contains("Hardening Matrix") == true

    it "lists all six architecture triples":
        val b: text = file_read(ARCH_DOC)
        expect b.contains("x86_64") == true
        expect b.contains("x86_32") == true
        expect b.contains("aarch64") or b.contains("arm64") == true
        expect b.contains("armv7") or b.contains("arm32") == true
        expect b.contains("riscv64") or b.contains("rv64gc") == true
        expect b.contains("riscv32") or b.contains("rv32imac") == true

    it "documents the AC-3 LoC floor rationale (40% / 25% fallback)":
        val b: text = file_read(ARCH_DOC)
        val ok: bool = b.contains("40%") or b.contains("≥40")
        expect ok == true
        val fallback_ok: bool = b.contains("25%") or b.contains("walker")
        expect fallback_ok == true

describe "AC-7 — doc is linked from mdsoc_architecture_tobe.md":
    it "mdsoc tobe doc exists":
        expect file_exists(MDSOC_DOC) == true

    it "mdsoc tobe doc references simpleos_multiarch_hal":
        val b: text = file_read(MDSOC_DOC)
        expect b.contains("simpleos_multiarch_hal") == true

describe "AC-7 — doc records test results table":
    """The doc must summarise the verification status of each AC."""
    it "doc contains a Test Results section":
        val b: text = file_read(ARCH_DOC)
        val ok: bool = b.contains("Test Results") or b.contains("Verification")
        expect ok == true