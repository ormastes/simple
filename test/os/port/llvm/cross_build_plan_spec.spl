## Static smoke test for Wave 2's --print-plan scaffolding in
## src/os/port/llvm/build.spl.
##
## `bin/simple run ...build.spl` cannot exercise the CLI today due to
## a cli.args() interpreter bug, so this spec does a static check:
## it reads build.spl as text and asserts the expected constants,
## function definitions, CLI flags, and per-target expansion patterns
## that Wave 2 introduced are present.
##
## Run:
##   bin/simple test test/os/port/llvm/cross_build_plan_spec.spl

use std.fs
use std.text
use std.spec

val BUILD_SPL = "src/os/port/llvm/build.spl"

fn build_source() -> text:
    fs.read_to_text(BUILD_SPL)

describe "SimpleOS LLVM cross-build --print-plan scaffolding":
    """Static checks on build.spl for Wave 2's multi-target scaffolding."""

    it "defines CROSS_SUPPORTED_TARGETS with 4 triples":
        """CROSS_SUPPORTED_TARGETS constant must be declared."""
        val src = build_source()
        src.contains("val CROSS_SUPPORTED_TARGETS").to_equal(true)

    it "includes x86_64-unknown-simpleos triple":
        """x86_64 triple must appear in the supported-targets list."""
        val src = build_source()
        src.contains("x86_64-unknown-simpleos").to_equal(true)

    it "includes aarch64-unknown-simpleos triple":
        val src = build_source()
        src.contains("aarch64-unknown-simpleos").to_equal(true)

    it "includes riscv64gc-unknown-simpleos triple":
        val src = build_source()
        src.contains("riscv64gc-unknown-simpleos").to_equal(true)

    it "includes riscv32imac-unknown-simpleos triple":
        val src = build_source()
        src.contains("riscv32imac-unknown-simpleos").to_equal(true)

    it "maps triples via cross_llvm_arch_for":
        val src = build_source()
        src.contains("fn cross_llvm_arch_for").to_equal(true)

    it "defines cross_build_print_plan":
        val src = build_source()
        src.contains("fn cross_build_print_plan").to_equal(true)

    it "defines cross_build_stage_for_target":
        val src = build_source()
        src.contains("fn cross_build_stage_for_target").to_equal(true)

    it "cross_build_status iterates all targets":
        val src = build_source()
        src.contains("fn cross_build_status").to_equal(true)
        src.contains("for triple in CROSS_SUPPORTED_TARGETS").to_equal(true)

    it "exposes --targets CLI flag":
        val src = build_source()
        src.contains("--targets").to_equal(true)

    it "exposes --all CLI flag":
        val src = build_source()
        src.contains("--all").to_equal(true)

    it "exposes --print-plan CLI flag":
        val src = build_source()
        src.contains("--print-plan").to_equal(true)

    it "per-target stage passes SIMPLEOS_TARGET_TRIPLE env var":
        val src = build_source()
        src.contains("SIMPLEOS_TARGET_TRIPLE").to_equal(true)

    it "per-target build dir is cross-<triple>":
        val src = build_source()
        src.contains("cross-{triple}").to_equal(true)
