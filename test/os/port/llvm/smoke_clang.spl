## QEMU smoke-test harness for the LLVM/Clang cross-toolchain on
## SimpleOS. Builds a QEMU command line that boots the SimpleOS kernel
## with the packaged initramfs image, pipes serial to stdout, and scans
## for the `SMOKE_CLANG_OK` marker written by the guest /sbin/init.
##
## Usage:
##   bin/simple run test/os/port/llvm/smoke_clang.spl -- --help
##   bin/simple run test/os/port/llvm/smoke_clang.spl -- --dry-run
##   bin/simple run test/os/port/llvm/smoke_clang.spl -- --run
##   bin/simple run test/os/port/llvm/smoke_clang.spl -- --run --kernel <p> --initrd <p>
##
## This file is also a spec; the embedded `describe`/`it` block checks
## the command builder against expected flags when the file is run
## under `bin/simple test`.

use std.fs
use std.text
use std.process
use std.cli
use std.spec

val DEFAULT_KERNEL = "build/os/kernel/simpleos"
val DEFAULT_INITRD = "build/os/initramfs.img.zst"
val MARKER = "SMOKE_CLANG_OK"

class SmokeConfig:
    kernel: text
    initrd: text
    run: bool

fn default_config() -> SmokeConfig:
    SmokeConfig(kernel: DEFAULT_KERNEL, initrd: DEFAULT_INITRD, run: false)

fn usage():
    print "Usage: bin/simple run test/os/port/llvm/smoke_clang.spl -- [options]"
    print ""
    print "Options:"
    print "  --dry-run            Print the QEMU command only (default)"
    print "  --run                Launch QEMU and scan for {MARKER}"
    print "  --kernel <p>         Kernel path (default: {DEFAULT_KERNEL})"
    print "  --initrd <p>         Initrd path (default: {DEFAULT_INITRD})"
    print "  --help               Show this help"

fn parse_args(args: List<text>) -> SmokeConfig:
    var kernel = DEFAULT_KERNEL
    var initrd = DEFAULT_INITRD
    var run = false

    var i = 0
    while i < args.len():
        val arg = args[i]
        if arg == "--help" or arg == "-h":
            usage()
            process.exit(0)
        else if arg == "--dry-run":
            run = false
        else if arg == "--run":
            run = true
        else if arg == "--kernel":
            i = i + 1
            kernel = args[i]
        else if arg == "--initrd":
            i = i + 1
            initrd = args[i]
        i = i + 1

    SmokeConfig(kernel: kernel, initrd: initrd, run: run)

fn build_qemu_args(config: SmokeConfig) -> List<text>:
    [
        "-m", "1G",
        "-kernel", config.kernel,
        "-initrd", config.initrd,
        "-append", "init=/sbin/init console=ttyS0",
        "-nographic",
        "-serial", "stdio",
    ]

fn render_command(config: SmokeConfig) -> text:
    var out = "qemu-system-x86_64"
    for arg in build_qemu_args(config):
        out = out + " " + arg
    out

fn run_qemu(config: SmokeConfig) -> bool:
    if not fs.exists(config.kernel):
        print "error: kernel missing: {config.kernel}"
        return false
    if not fs.exists(config.initrd):
        print "error: initrd missing: {config.initrd}"
        return false

    val cmd = render_command(config)
    print "[smoke] launching: {cmd}"
    val result = process.run("qemu-system-x86_64", build_qemu_args(config))
    print result.stdout
    if result.stdout.contains(MARKER):
        print "[smoke] PASS — saw {MARKER}"
        return true
    print "[smoke] FAIL — marker {MARKER} not found in serial output"
    false

fn main():
    val config = parse_args(cli.args())
    val cmd = render_command(config)
    if not config.run:
        print "[smoke] dry-run command:"
        print cmd
        return
    val ok = run_qemu(config)
    if not ok:
        process.exit(1)

describe "SimpleOS clang smoke-test harness":
    """Static checks on build_qemu_args and CLI parsing."""

    it "dry-run is the default mode":
        val c = parse_args([])
        c.run.to_equal(false)

    it "--run flag enables QEMU launch":
        val c = parse_args(["--run"])
        c.run.to_equal(true)

    it "--kernel overrides default kernel path":
        val c = parse_args(["--kernel", "/tmp/k"])
        c.kernel.to_equal("/tmp/k")

    it "--initrd overrides default initrd path":
        val c = parse_args(["--initrd", "/tmp/i.zst"])
        c.initrd.to_equal("/tmp/i.zst")

    it "qemu command includes -nographic":
        val cmd = render_command(default_config())
        cmd.contains("-nographic").to_equal(true)

    it "qemu command includes -serial stdio":
        val cmd = render_command(default_config())
        cmd.contains("-serial stdio").to_equal(true)

    it "qemu command passes init=/sbin/init in -append":
        val cmd = render_command(default_config())
        cmd.contains("init=/sbin/init").to_equal(true)

    it "qemu command references the default kernel":
        val cmd = render_command(default_config())
        cmd.contains(DEFAULT_KERNEL).to_equal(true)

    it "qemu command references the default initrd":
        val cmd = render_command(default_config())
        cmd.contains(DEFAULT_INITRD).to_equal(true)
