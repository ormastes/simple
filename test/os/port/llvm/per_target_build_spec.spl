## Per-target cross-build scaffolding spec (A4/A5).
##
## Static checks that build.spl, build.shs, compiler_rt_cmake.cmake, and
## the SimpleOS ToolChain README are wired up so the cross-build pipeline
## iterates every SimpleOS triple and stages compiler-rt builtins into the
## clang resource dir.
##
## Run:
##   bin/simple test test/os/port/llvm/per_target_build_spec.spl

use std.fs
use std.text
use std.spec

val BUILD_SPL = "src/os/port/llvm/build.spl"
val BUILD_SHS = "src/os/port/llvm/build.shs"
val RT_CMAKE  = "src/os/port/llvm/compiler_rt_cmake.cmake"
val TOOLCHAIN_README = "src/os/port/llvm/patches/simpleos_toolchain_cpp/README.md"

fn build_spl_src() -> text:
    fs.read_to_text(BUILD_SPL)

fn build_shs_src() -> text:
    fs.read_to_text(BUILD_SHS)

fn rt_cmake_src() -> text:
    fs.read_to_text(RT_CMAKE)

describe "SimpleOS LLVM per-target build (A4/A5)":
    """Scaffolding checks for the multi-target cross-build + compiler-rt stage."""

    it "declares CROSS_SUPPORTED_TARGETS":
        val src = build_spl_src()
        src.contains("val CROSS_SUPPORTED_TARGETS").to_equal(true)

    it "CROSS_SUPPORTED_TARGETS lists all four SimpleOS triples":
        val src = build_spl_src()
        src.contains("x86_64-unknown-simpleos").to_equal(true)
        src.contains("aarch64-unknown-simpleos").to_equal(true)
        src.contains("riscv64gc-unknown-simpleos").to_equal(true)
        src.contains("riscv32imac-unknown-simpleos").to_equal(true)

    it "honours SIMPLE_TARGET env override":
        val src = build_spl_src()
        src.contains("SIMPLE_TARGET").to_equal(true)
        src.contains("cross_selected_targets").to_equal(true)

    it "cross_build_all iterates CROSS_SUPPORTED_TARGETS":
        val src = build_spl_src()
        src.contains("fn cross_build_all").to_equal(true)
        src.contains("cross_build_stage_for_target").to_equal(true)

    it "exports build_compiler_rt(triple)":
        val src = build_spl_src()
        src.contains("fn build_compiler_rt(triple: text)").to_equal(true)

    it "exports build_compiler_rt_for_target":
        val src = build_spl_src()
        src.contains("fn build_compiler_rt_for_target").to_equal(true)

    it "registers compiler-rt subcommand in cross_build_main":
        val src = build_spl_src()
        src.contains("\"compiler-rt\"").to_equal(true)
        src.contains("subcommand").to_equal(true)

    it "exposes --print-plan CLI flag":
        val src = build_spl_src()
        src.contains("--print-plan").to_equal(true)

    it "stages builtins into clang resource dir":
        val src = build_spl_src()
        src.contains("lib/clang/").to_equal(true)
        src.contains("CLANG_RESOURCE_VERSION").to_equal(true)

    it "gates compiler-rt behind -simpleos triples":
        val src = build_spl_src()
        src.contains("ends_with(\"-simpleos\")").to_equal(true)

    it "per-target build dir is cross-<triple>":
        val src = build_spl_src()
        src.contains("cross-{triple}").to_equal(true)

    it "compiler-rt build dir is compiler-rt-<triple>":
        val src = build_spl_src()
        src.contains("compiler-rt-{triple}").to_equal(true)

    it "build.shs threads SIMPLEOS_TARGET_TRIPLE":
        val src = build_shs_src()
        src.contains("SIMPLEOS_TARGET_TRIPLE").to_equal(true)
        src.contains("SIMPLE_TARGET").to_equal(true)

    it "build.shs uses per-triple CROSS_DIR / RT_DIR":
        val src = build_shs_src()
        src.contains("CROSS_DIR=").to_equal(true)
        src.contains("RT_DIR=").to_equal(true)

    it "build.shs still dispatches compiler-rt subcommand":
        val src = build_shs_src()
        src.contains("compiler-rt)").to_equal(true)
        src.contains("stage3_compiler_rt").to_equal(true)

    it "build.shs stages builtins into resource dir":
        val src = build_shs_src()
        src.contains("RES_LIB_DIR").to_equal(true)
        src.contains("lib/clang/").to_equal(true)

    it "compiler_rt_cmake.cmake exists":
        fs.exists(RT_CMAKE).to_equal(true)

    it "compiler_rt_cmake.cmake enables COMPILER_RT_BUILD_BUILTINS":
        val src = rt_cmake_src()
        src.contains("COMPILER_RT_BUILD_BUILTINS").to_equal(true)

    it "compiler_rt_cmake.cmake disables sanitizers / xray / profile":
        val src = rt_cmake_src()
        src.contains("COMPILER_RT_BUILD_SANITIZERS").to_equal(true)
        src.contains("COMPILER_RT_BUILD_XRAY").to_equal(true)
        src.contains("COMPILER_RT_BUILD_PROFILE").to_equal(true)

    it "compiler_rt_cmake.cmake sets COMPILER_RT_OS_DIR to simpleos":
        val src = rt_cmake_src()
        src.contains("COMPILER_RT_OS_DIR simpleos").to_equal(true)

    it "SimpleOS ToolChain README exists":
        fs.exists(TOOLCHAIN_README).to_equal(true)
