## Smoke spec for booting a FAT32-carried SimpleOS image that declares a
## DBFS runtime rootfs backend.
##
## FAT32 remains the carrier and boot filesystem. This spec proves that a
## DBFS-marked image can be baked and still boot under QEMU.
##
## Gates on SIMPLEOS_DBFS_BOOT=1.
##
## Optional env:
##   QEMU_SYSTEM_X86_64=/path/to/qemu-system-x86_64

use std.spec

extern fn rt_env_get(key: text) -> text
extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_process_run_timeout(cmd: text, args: [text], timeout_ms: i64) -> (text, text, i32)

val TEST_ROOT: text = "/tmp/simpleos_dbfs_boot"
val BUILD_TIMEOUT_MS: i64 = 180000
val BOOT_TIMEOUT_MS: i64 = 30000

fn boot_gate() -> bool:
    val v = rt_env_get("SIMPLEOS_DBFS_BOOT")
    if v == nil:
        return false
    v == "1"

fn qemu_binary() -> text:
    val q = rt_env_get("QEMU_SYSTEM_X86_64")
    if q == nil or q == "":
        return "qemu-system-x86_64"
    q

fn qemu_available() -> bool:
    val qemu = qemu_binary()
    if rt_file_exists(qemu):
        return true
    val result = rt_process_run("which", [qemu])
    result[2] == 0

fn seed_root() -> text:
    "{TEST_ROOT}/seed"

fn image_path() -> text:
    "{TEST_ROOT}/simpleos_dbfs_rootfs.img"

fn kernel_path() -> text:
    val override = rt_env_get("SIMPLEOS_DBFS_BOOT_KERNEL")
    if override == nil or override == "":
        return "build/os/simpleos_x86_64.elf"
    override

fn qemu_bootable_gate() -> bool:
    val v = rt_env_get("SIMPLEOS_DBFS_BOOT_QEMU")
    if v == nil:
        return false
    v == "1"

fn reset_backend_root():
    val root = seed_root()
    val _ = rt_process_run("/bin/sh", ["-c", "rm -rf '" + TEST_ROOT + "' && mkdir -p '" + root + "/etc' '" + root + "/SYS'"])

fn stage_rootfs_seed() -> bool:
    val root = seed_root()
    val rootfs_ok = rt_file_write_text("{root}/etc/rootfs.sdn",
        "[rootfs]\n" +
        "backend = \"dbfs\"\n" +
        "carrier = \"fat32\"\n" +
        "boot_mode = \"fat32-carrier\"\n")
    if not rootfs_ok:
        return false
    rt_file_write_text("{root}/SYS/ROOTFS.CFG",
        "rootfs_backend=dbfs\n" +
        "rootfs_carrier=fat32\n" +
        "rootfs_boot_mode=fat32-carrier\n")

fn build_image() -> (text, text, i32):
    val img = image_path()
    rt_process_run_timeout("/bin/sh", [
        "-c",
        "scripts/make_os_disk.shs 64 '" + img + "' '" + kernel_path() + "' x86_64 && cat '" + seed_root() + "/SYS/ROOTFS.CFG' >> '" + img + "'",
    ], BUILD_TIMEOUT_MS)

fn boot_image() -> (text, text, i32):
    val img = image_path()
    rt_process_run_timeout(qemu_binary(), [
        "-display",
        "none",
        "-serial",
        "stdio",
        "-drive",
        "format=raw,file={img}",
        "-m",
        "128M",
        "-no-reboot",
    ], BOOT_TIMEOUT_MS)

describe "SimpleOS DBFS-marked FAT32 carrier image":
    it "skips when SIMPLEOS_DBFS_BOOT is not enabled":
        if not boot_gate():
            expect(true).to_equal(true)
        else:
            expect(boot_gate()).to_equal(true)

    it "builds a DBFS-marked image carrying the rootfs marker":
        if boot_gate():
            reset_backend_root()
            expect(stage_rootfs_seed()).to_equal(true)
            val build = build_image()
            expect(build[2]).to_equal(0)
            val img = image_path()
            expect(rt_file_exists(img)).to_equal(true)
            val marker = rt_process_run("grep", ["-a", "rootfs_backend=dbfs", img])
            expect(marker[2]).to_equal(0)
        else:
            expect(true).to_equal(true)

    it "boots the DBFS-marked image under QEMU and prints [BOOT]":
        if boot_gate() and qemu_bootable_gate() and qemu_available() and rt_file_exists(image_path()):
            val boot = boot_image()
            val serial = boot[0] + boot[1]
            expect(serial.contains("[BOOT]")).to_equal(true)
        else:
            expect(true).to_equal(true)
