use std.spec
use os.kernel.loader.x86_64_fs_exec_spawn.{x86_64_fs_exec_spawn_hello_world_smf}

extern fn rt_env_get(key: text) -> text

fn simpleos_runtime() -> text:
    val sr = rt_env_get("SIMPLEOS_RUNTIME")
    if sr == nil:
        ""
    else:
        sr

