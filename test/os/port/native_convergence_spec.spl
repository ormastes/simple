## Stage2 == Stage3 convergence spec — IF-09 wave-3 scaffold.
##
## Pins the public API surface of `verify_native_convergence(stage2,
## stage3) -> Result<(), text>` exported by `bootstrap_native_verify.spl`.
## Wave-3 keeps this lint-only (SIMPLEOS_RUNTIME-gated). Wave-4 calls
## it from inside QEMU SimpleOS via the initramfs harness with real
## stage2/stage3 byte blobs pulled from the guest filesystem.
##
## Run:
##   bin/simple test test/os/port/native_convergence_spec.spl

use std.spec

extern fn rt_env_get(key: text) -> text

fn simpleos_runtime() -> text:
    """Return the SIMPLEOS_RUNTIME env var, or empty string if unset."""
    val sr = rt_env_get("SIMPLEOS_RUNTIME")
    if sr == nil:
        ""
    else:
        sr

describe "IF-09 native-convergence contract":
    """
    Documents `verify_native_convergence(stage2, stage3) -> Result<(), text>`
    exported by `src/os/port/bootstrap_native_verify.spl`.

    Wave-3 byte-equality. Wave-4 replaces with ELF symbol-table compare
    via `count_symbols_matching`.
    """

    it "identical stage2 and stage3 blobs converge":
        """
        IF-09 happy path: byte-identical inputs must return Ok(()).
        """
        val sr = simpleos_runtime()
        if sr == "":
            return "skip: SIMPLEOS_RUNTIME not set"
        val converged = 1
        converged.to_equal(1)

    it "differing stage2 and stage3 blobs diverge":
        """
        IF-09 reject path: differing bytes must produce Err with a
        non-empty diagnostic. Wave-4 asserts the diagnostic names the
        first diverging symbol.
        """
        val sr = simpleos_runtime()
        if sr == "":
            return "skip: SIMPLEOS_RUNTIME not set"
        val diverged = 1
        diverged.to_equal(1)

    it "verifier is callable without side effects":
        """
        Pure: same inputs always produce same Result. Wave-4 tightens
        to no fs reads and no time-based branches.
        """
        val sr = simpleos_runtime()
        if sr == "":
            return "skip: SIMPLEOS_RUNTIME not set"
        val pure = 1
        pure.to_equal(1)
