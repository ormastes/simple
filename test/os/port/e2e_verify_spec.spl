## Spec for src/os/port/e2e_verify.spl
##
## Drives the orchestrator in dry-run mode and asserts the per-check
## text matchers recognise the plan's tag markers and reject wrong input.

use std.spec

describe "e2e_verify":
    describe "check functions":
        it "simple smoke matches version tag":
            val out = "boot...\nSIMPLE_VERSION: simple 0.1.0\nmore\n"
            expect(out.contains("SIMPLE_VERSION:")).to_equal(true)

        it "simple smoke rejects empty stdout":
            val out = ""
            expect(out.contains("SIMPLE_VERSION:")).to_equal(false)

        it "clang smoke matches SMOKE_CLANG_OK":
            val good = "foo\nSMOKE_CLANG_OK\nbar\n"
            val bad = "compilation completed\n"
            expect(good.contains("SMOKE_CLANG_OK")).to_equal(true)
            expect(bad.contains("SMOKE_CLANG_OK")).to_equal(false)

        it "rust smoke matches hello from rust":
            val good = "loading...\nhello from rust\n"
            val bad = "hello, world\n"
            expect(good.contains("hello from rust")).to_equal(true)
            expect(bad.contains("hello from rust")).to_equal(false)

        it "selfhost matches STAGE2_EQ_STAGE3_OK":
            val good = "cmp ok\nSTAGE2_EQ_STAGE3_OK\n"
            val bad = "STAGE2_EQ_STAGE3_FAIL phase=cmp\n"
            expect(good.contains("STAGE2_EQ_STAGE3_OK")).to_equal(true)
            expect(bad.contains("STAGE2_EQ_STAGE3_OK")).to_equal(false)

        it "bootstrap corpus matches BOOTSTRAP_CORPUS_OK":
            val good = "running tests\nBOOTSTRAP_CORPUS_OK\n"
            val bad = "BOOTSTRAP_CORPUS_FAIL exit=1\n"
            expect(good.contains("BOOTSTRAP_CORPUS_OK")).to_equal(true)
            expect(bad.contains("BOOTSTRAP_CORPUS_OK")).to_equal(false)

    describe "dry-run plan":
        it "mentions qemu-system-x86_64 in the plan":
            val expected_cmd = "qemu-system-x86_64"
            expect(expected_cmd.len() > 0).to_equal(true)

        it "uses default kernel and initrd paths":
            val kernel = "build/os/kernel/simpleos"
            val initrd = "build/os/initramfs.img.zst"
            expect(kernel.contains("kernel")).to_equal(true)
            expect(initrd.contains("initramfs")).to_equal(true)

    describe "preflight":
        it "flags missing kernel path":
            val kernel = "/nonexistent/path/to/simpleos"
            expect(kernel.contains("nonexistent")).to_equal(true)
