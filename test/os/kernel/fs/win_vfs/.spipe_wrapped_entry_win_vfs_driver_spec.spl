#![allow(spipe_empty_examples)]
#![allow(spipe_boolean_wrapper_assertions)]
@allow(spipe_empty_examples)
@allow(spipe_boolean_wrapper_assertions)
use std.spipe.*
use std.fs.{read_file}
use lib.common.privilege.id_path.{id_path_intern}
use lib.common.privilege.principal.{Principal, PrincipalKind}
use lib.common.privilege.authority_token.{AuthorityToken, AuthorityLevel}
use lib.common.win_fs.window_record.{WindowRecord, WindowState, Rect, BufferRef}
use os.services.vfs.vfs.{FileFlags}
use os.kernel.fs.win_vfs.win_vfs_driver.{WinVfsDriver, win_vfs_make_for_test}
use os.kernel.fs.win_vfs.win_vfs_mount.{register_win_vfs}


fn main():
    # @cover src/os/kernel/fs/win_vfs/win_vfs_driver.spl 80%
    # @cover src/os/kernel/fs/win_vfs/win_vfs_mount.spl 60%
    """
    # Win-VFS Kernel Driver Specification
    
    **Feature:** spm-winfs-llm-suite / AC-4
    **Status:** Red (no impl yet)
    
    Mount at `/win`, readdir, read title bytes, destroy→ENOENT, ACL-denied→EACCES.
    Grep sentinel: driver imports from shared encoder; no inlined encoding in
    `src/os/kernel/fs/win_vfs/`.
    """


    describe "Win-VFS kernel driver":
        describe "mount":
            it "AC-4: mount at /win succeeds":
                val drv = win_vfs_make_for_test()
                val result = drv.mount("win", "")
                expect result.ok == true

            it "AC-4: register_win_vfs publishes driver under /win":
                val status = register_win_vfs()
                expect status.ok == true
                expect status.value == "/win"

        describe "readdir":
            it "AC-4: /win lists <app> directories":
                val drv = win_vfs_make_for_test()
                drv.mount("win", "")
                drv.test_insert(WindowRecord(
                    wid: 1, generation: 1, app: "banking", title: "Acct",
                    state: WindowState.Normal,
                    geometry: Rect(x: 0, y: 0, w: 1, h: 1),
                    buffer_ref: BufferRef(kind: "shm", handle: 0, bytes: 0),
                    acl_id_path: id_path_intern("id.user.public")))
                val result = drv.readdir("/")
                expect result.ok == true
                val names = drv.test_entry_names(result.value)
                expect (names).contains("banking")

            it "AC-4: /win/<app>/<wid> lists schema entries":
                val drv = win_vfs_make_for_test()
                drv.mount("win", "")
                drv.test_insert(WindowRecord(
                    wid: 1, generation: 1, app: "banking", title: "Acct",
                    state: WindowState.Normal,
                    geometry: Rect(x: 0, y: 0, w: 1, h: 1),
                    buffer_ref: BufferRef(kind: "shm", handle: 0, bytes: 0),
                    acl_id_path: id_path_intern("id.user.public")))
                val result = drv.readdir("/banking/1")
                expect result.ok == true
                val names = drv.test_entry_names(result.value)
                expect (names).contains("title")
                expect (names).contains("state")
                expect (names).contains("geometry")

        describe "read title":
            it "AC-4: read(/banking/1/title) returns window title bytes":
                val drv = win_vfs_make_for_test()
                drv.mount("win", "")
                drv.test_insert(WindowRecord(
                    wid: 1, generation: 1, app: "banking", title: "Acct",
                    state: WindowState.Normal,
                    geometry: Rect(x: 0, y: 0, w: 1, h: 1),
                    buffer_ref: BufferRef(kind: "shm", handle: 0, bytes: 0),
                    acl_id_path: id_path_intern("id.user.public")))
                val fd = drv.open("/banking/1/title", FileFlags.read_only())
                expect fd.ok == true
                val data = drv.read(fd.value, 64)
                expect data.ok == true
                val text = data.value.as_text()
                expect text == "Acct"

        describe "destroy → ENOENT":
            it "AC-4: after destroy, open returns ENOENT":
                val drv = win_vfs_make_for_test()
                drv.mount("win", "")
                drv.test_insert(WindowRecord(
                    wid: 1, generation: 1, app: "banking", title: "Acct",
                    state: WindowState.Normal,
                    geometry: Rect(x: 0, y: 0, w: 1, h: 1),
                    buffer_ref: BufferRef(kind: "shm", handle: 0, bytes: 0),
                    acl_id_path: id_path_intern("id.user.public")))
                drv.test_destroy(1)
                val fd = drv.open("/banking/1/title", FileFlags.read_only())
                expect fd.ok == false
                expect (fd.error).contains("ENOENT")

        describe "ACL denial":
            it "AC-4: denied caller gets EACCES on open":
                val drv = win_vfs_make_for_test()
                drv.mount("win", "")
                drv.test_insert(WindowRecord(
                    wid: 1, generation: 1, app: "banking", title: "Acct",
                    state: WindowState.Normal,
                    geometry: Rect(x: 0, y: 0, w: 1, h: 1),
                    buffer_ref: BufferRef(kind: "shm", handle: 0, bytes: 0),
                    acl_id_path: id_path_intern("id.user.banking.view")))
                val principal = Principal(kind: PrincipalKind.Local, id: "eve")
                val token = AuthorityToken.mock(
                    id_path: id_path_intern("id.user.mail"),
                    level: AuthorityLevel.Internal,
                    principal: principal)
                drv.test_set_current_token(token)
                val fd = drv.open("/banking/1/title", FileFlags.read_only())
                expect fd.ok == false
                expect (fd.error).contains("EACCES")

        describe "grep sentinel (no inlined encoding)":
            it "AC-4: win_vfs_driver.spl imports from common/win_fs/fs_encoder":
                val source = read_file("src/os/kernel/fs/win_vfs/win_vfs_driver.spl")
                expect (source).contains("use lib.common.win_fs.fs_encoder")

            it "AC-4: win_vfs_driver.spl imports from common/win_fs/acl":
                val source = read_file("src/os/kernel/fs/win_vfs/win_vfs_driver.spl")
                expect (source).contains("use lib.common.win_fs.acl")