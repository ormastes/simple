# Spec for kernel_thread + kevent + kfutex — M1 thread primitives (REQ-3).
#
# These specs lock the public API surface for:
#   src/lib/nogc_async_mut_noalloc/baremetal/kernel_thread.spl
#   src/lib/nogc_async_mut_noalloc/baremetal/kevent.spl
#   src/lib/nogc_async_mut_noalloc/baremetal/kfutex.spl
#
# Note: actual blocking behavior (kevent_wait, kfutex_wait) requires kernel
# context and cannot be verified in interpreter mode. These specs verify the
# public API surface is callable and type-correct.
#
# Tests are in the red phase: implementations do not yet exist.
# Run with:
#   bin/simple test test/os/kernel/wine/kernel_thread_primitives_spec.spl
#
# @cover src/lib/nogc_async_mut_noalloc/baremetal/kernel_thread.spl
# @cover src/lib/nogc_async_mut_noalloc/baremetal/kevent.spl
# @cover src/lib/nogc_async_mut_noalloc/baremetal/kfutex.spl

use std.spec
use std.nogc_async_mut_noalloc.baremetal.kevent.{
    kevent_create,
    kevent_set,
    kevent_reset,
    kevent_wait
}
use std.nogc_async_mut_noalloc.baremetal.kfutex.{
    kfutex_wait,
    kfutex_wake
}
use std.nogc_async_mut_noalloc.baremetal.kernel_thread.{
    kernel_thread_create,
    kernel_thread_tls_set,
    kernel_thread_tls_get
}

describe "kernel_thread primitives — M1":

    describe "AC-3: kevent — kernel event object":
        it "AC-3: kevent_create with auto_reset=false returns a valid handle":
            val h = kevent_create(false)
            expect(h).to_be_greater_than(0)

        it "AC-3: kevent_create with auto_reset=true returns a valid handle":
            val h = kevent_create(true)
            expect(h).to_be_greater_than(0)

        it "AC-3: kevent_create returns distinct handles for separate calls":
            val h1 = kevent_create(false)
            val h2 = kevent_create(false)
            expect(h1 == h2).to_equal(false)

        it "AC-3: kevent_set is callable without error on a valid handle":
            val h = kevent_create(false)
            kevent_set(h)
            # If we reach here, set did not panic
            expect(h).to_be_greater_than(0)

        it "AC-3: kevent_reset is callable without error on a valid handle":
            val h = kevent_create(false)
            kevent_set(h)
            kevent_reset(h)
            expect(h).to_be_greater_than(0)

        it "AC-3: kevent_wait with timeout_ns=0 returns immediately with WaitResult value":
            val h = kevent_create(false)
            kevent_set(h)
            # Wait on a set event with 0 timeout: expect signaled
            val result = kevent_wait(h, 0)
            expect(result).to_equal("signaled")

        it "AC-3: kevent_wait on unset event with timeout_ns=0 returns timeout":
            val h = kevent_create(false)
            # Event is not set; timeout immediately
            val result = kevent_wait(h, 0)
            expect(result).to_equal("timeout")

        it "AC-3: auto-reset kevent_wait resets the handle after signaled":
            val h = kevent_create(true)
            kevent_set(h)
            val r1 = kevent_wait(h, 0)
            expect(r1).to_equal("signaled")
            # Second wait on auto-reset event: should be timeout (reset already happened)
            val r2 = kevent_wait(h, 0)
            expect(r2).to_equal("timeout")

    describe "AC-3: kfutex — futex-like wait/wake":
        it "AC-3: kfutex_wake with count=1 returns the number of woken waiters":
            # No waiters: wake returns 0
            val addr: u32 = 0
            val woken = kfutex_wake(addr, 1)
            expect(woken).to_equal(0)

        it "AC-3: kfutex_wait with mismatched expected returns immediately":
            # If *addr != expected, futex returns immediately with WaitResult.aborted
            val addr: u32 = 0
            val result = kfutex_wait(addr, 99, 0)
            expect(result).to_equal("aborted")

        it "AC-3: kfutex_wait with matching expected and timeout_ns=0 returns timeout":
            val addr: u32 = 42
            val result = kfutex_wait(addr, 42, 0)
            expect(result).to_equal("timeout")

    describe "AC-3: kernel_thread — TLS segment (FS.base)":
        it "AC-3: kernel_thread_tls_set and tls_get round-trip a value":
            # key=1 (arbitrary), store a sentinel pattern
            kernel_thread_tls_set(1, 0xDEADBEEF)
            val got = kernel_thread_tls_get(1)
            expect(got).to_equal(0xDEADBEEF)

        it "AC-3: kernel_thread_tls_get for unset key returns null (0)":
            val got = kernel_thread_tls_get(255)
            expect(got).to_equal(0)

        it "AC-3: kernel_thread_tls_set with key=0 stores and retrieves":
            kernel_thread_tls_set(0, 0x1234)
            val got = kernel_thread_tls_get(0)
            expect(got).to_equal(0x1234)

        it "AC-3: kernel_thread_create returns a positive Tid":
            # We supply a no-op entry function and stack_size=4096
            fn noop_entry() -> void:
                val _ = 0
            val tid = kernel_thread_create(noop_entry, 4096)
            expect(tid).to_be_greater_than(0)
