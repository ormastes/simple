# Spec for kernel_vm_fault — demand-paging page-fault handler (M1, REQ-4).
#
# These specs lock the public API surface and invariants for:
#   src/lib/nogc_async_mut_noalloc/baremetal/vm_fault.spl
#
# Tests are in the red phase: the implementation does not yet exist.
# Run with:
#   bin/simple test test/os/kernel/wine/kernel_vm_fault_spec.spl
#
# @cover src/lib/nogc_async_mut_noalloc/baremetal/vm_fault.spl

use std.spec
use std.nogc_async_mut_noalloc.baremetal.vm_fault.{
    vm_fault_handle,
    vm_fault_map_anonymous,
    vm_fault_register_vma,
    vm_fault_unregister_vma,
    VmaKind
}

describe "kernel_vm_fault — demand-paging handler":

    describe "AC-4: VmaKind constants":
        it "AC-4: anonymous VMA kind value is defined":
            val k = VmaKind.anonymous
            expect(k).to_equal(0)

        it "AC-4: guard VMA kind value is defined":
            val k = VmaKind.guard
            expect(k).to_equal(1)

        it "AC-4: copy-on-write VMA kind value is defined":
            val k = VmaKind.copy_on_write
            expect(k).to_equal(2)

        it "AC-4: file-backed VMA kind value is defined":
            val k = VmaKind.file_backed
            expect(k).to_equal(3)

    describe "AC-4: vm_fault_register_vma — VMA region registration":
        it "AC-4: register_vma accepts base, size, and kind without error":
            # base=0x10000, size=4096 (one page), kind=anonymous
            val ok = vm_fault_register_vma(0x10000, 4096, VmaKind.anonymous)
            expect(ok).to_equal(true)

        it "AC-4: register_vma with guard kind marks the region as guard":
            val ok = vm_fault_register_vma(0x20000, 4096, VmaKind.guard)
            expect(ok).to_equal(true)

        it "AC-4: register_vma with copy-on-write kind succeeds":
            val ok = vm_fault_register_vma(0x30000, 4096, VmaKind.copy_on_write)
            expect(ok).to_equal(true)

        it "AC-4: register_vma rejects zero-size region":
            val ok = vm_fault_register_vma(0x40000, 0, VmaKind.anonymous)
            expect(ok).to_equal(false)

    describe "AC-4: vm_fault_map_anonymous — page allocation":
        it "AC-4: map_anonymous returns a non-zero physical frame address":
            val frame_pa = vm_fault_map_anonymous(0x10000)
            expect(frame_pa).to_be_greater_than(0)

        it "AC-4: map_anonymous for same vaddr in guard region returns zero (fault)":
            # Guard region: expected to return 0 (access fault / kill signal)
            vm_fault_register_vma(0x50000, 4096, VmaKind.guard)
            val result = vm_fault_map_anonymous(0x50000)
            expect(result).to_equal(0)

    describe "AC-4: vm_fault_handle — fault dispatch":
        it "AC-4: handle on registered anonymous region succeeds with FaultResult.mapped":
            vm_fault_register_vma(0x60000, 4096, VmaKind.anonymous)
            val result = vm_fault_handle(0x60000, false)
            expect(result).to_equal("mapped")

        it "AC-4: handle on guard region returns FaultResult.kill":
            vm_fault_register_vma(0x70000, 4096, VmaKind.guard)
            val result = vm_fault_handle(0x70000, false)
            expect(result).to_equal("kill")

        it "AC-4: handle on unregistered region returns FaultResult.unhandled":
            # An address with no VMA registered
            val result = vm_fault_handle(0xDEAD0000, false)
            expect(result).to_equal("unhandled")

        it "AC-4: handle on copy-on-write region with write fault returns FaultResult.mapped":
            vm_fault_register_vma(0x80000, 4096, VmaKind.copy_on_write)
            val result = vm_fault_handle(0x80000, true)
            expect(result).to_equal("mapped")

    describe "AC-4: vm_fault_unregister_vma — VMA deregistration":
        it "AC-4: unregister removes the region so faults become unhandled":
            vm_fault_register_vma(0x90000, 4096, VmaKind.anonymous)
            val before = vm_fault_handle(0x90000, false)
            expect(before).to_equal("mapped")
            vm_fault_unregister_vma(0x90000, 4096)
            val after = vm_fault_handle(0x90000, false)
            expect(after).to_equal("unhandled")
