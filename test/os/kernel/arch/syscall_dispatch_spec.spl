# syscall_dispatch_spec.spl — Wave 10B
#
# Locks the canonical syscall number assignments used by the SimpleOS kernel.
# These must match the switch cases in rt_syscall_dispatch (baremetal_stubs.c)
# and the match arms in syscall_handler (src/os/kernel/ipc/syscall.spl).
#
# No FFI is used. We assert the numeric values are distinct small integers and
# match the expected constants so that any future renumbering is caught here.

use std.spec.{describe, it, expect_eq, expect_true}

# Canonical syscall numbers — must stay in sync with syscall.spl and
# baremetal_stubs.c rt_syscall_dispatch.
val SYS_EXIT:              u64 = 0
val SYS_YIELD:             u64 = 1
val SYS_SPAWN:             u64 = 2
val SYS_WAIT:              u64 = 3
val SYS_GETPID:            u64 = 4
val SYS_LIST_TASKS:        u64 = 5
val SYS_GET_TASK_INFO:     u64 = 6
val SYS_SIGNAL:            u64 = 7
val SYS_SET_PRIORITY:      u64 = 8
val SYS_GET_PARENT_PID:    u64 = 9
val SYS_MMAP:              u64 = 10
val SYS_MUNMAP:            u64 = 11
val SYS_MPROTECT:          u64 = 12
val SYS_SPAWN_BINARY:      u64 = 13
val SYS_IPC_SEND:          u64 = 20
val SYS_IPC_RECV:          u64 = 21
val SYS_IPC_CREATE_PORT:   u64 = 22
val SYS_IPC_CONNECT:       u64 = 23
val SYS_NOTIF_CREATE:      u64 = 24
val SYS_NOTIF_SIGNAL:      u64 = 25
val SYS_NOTIF_WAIT:        u64 = 26
val SYS_NOTIF_POLL:        u64 = 27
val SYS_NOTIF_DESTROY:     u64 = 28
val SYS_NOTIF_WAIT_ANY:    u64 = 29
val SYS_FILE_OPEN:         u64 = 30
val SYS_FILE_READ:         u64 = 31
val SYS_FILE_WRITE:        u64 = 32
val SYS_FILE_CLOSE:        u64 = 33
val SYS_FILE_STAT:         u64 = 34
val SYS_FILE_MKDIR:        u64 = 35
val SYS_FILE_READDIR:      u64 = 36
val SYS_MOUNT:             u64 = 37
val SYS_UNMOUNT:           u64 = 38
val SYS_UNLINK:            u64 = 39
val SYS_PLEDGE:            u64 = 40
val SYS_UNVEIL:            u64 = 41
val SYS_CAP_GRANT:         u64 = 42
val SYS_FTRUNCATE:         u64 = 43
val SYS_RENAME:            u64 = 44
val SYS_RMDIR:             u64 = 45
val SYS_LSEEK:             u64 = 46
val SYS_GETCWD:            u64 = 47
val SYS_CHDIR:             u64 = 48
val SYS_CLOCK_GETTIME:     u64 = 50
val SYS_SLEEP:             u64 = 51
val SYS_DEBUG_WRITE:       u64 = 60
val SYS_NET_SOCKET:        u64 = 70
val SYS_NET_BIND:          u64 = 71
val SYS_NET_LISTEN:        u64 = 72
val SYS_NET_CONNECT:       u64 = 73
val SYS_NET_ACCEPT:        u64 = 74
val SYS_NET_SEND_TO:       u64 = 75
val SYS_NET_RECV_FROM:     u64 = 76
val SYS_NET_IF_CONFIG:     u64 = 77
val SYS_DEV_ENUMERATE:     u64 = 80
val SYS_DEV_GET_INFO:      u64 = 81
val SYS_DEVICE_GRANT:      u64 = 82
val SYS_MAP_BAR:           u64 = 83
val SYS_ALLOC_DMA:         u64 = 84
val SYS_FREE_DMA:          u64 = 85
val SYS_LOG_WRITE:         u64 = 90
val SYS_LOG_READ:          u64 = 91
val SYS_SYSINFO:           u64 = 95
val SYS_GET_HOSTNAME:      u64 = 96
val SYS_SET_HOSTNAME:      u64 = 97

describe("syscall dispatch numbers"):
    it("core process syscalls have expected values"):
        expect_eq(SYS_EXIT,           0)
        expect_eq(SYS_YIELD,          1)
        expect_eq(SYS_SPAWN,          2)
        expect_eq(SYS_WAIT,           3)
        expect_eq(SYS_GETPID,         4)
        expect_eq(SYS_SPAWN_BINARY,   13)

    it("SYS_EXIT, SYS_YIELD, and SYS_SPAWN_BINARY are distinct"):
        expect_true(SYS_EXIT != SYS_YIELD)
        expect_true(SYS_EXIT != SYS_SPAWN_BINARY)
        expect_true(SYS_YIELD != SYS_SPAWN_BINARY)

    it("memory syscalls are in the 10-12 range"):
        expect_eq(SYS_MMAP,     10)
        expect_eq(SYS_MUNMAP,   11)
        expect_eq(SYS_MPROTECT, 12)
        expect_true(SYS_MMAP < SYS_MUNMAP)
        expect_true(SYS_MUNMAP < SYS_MPROTECT)

    it("IPC syscalls start at 20"):
        expect_eq(SYS_IPC_SEND,        20)
        expect_eq(SYS_IPC_RECV,        21)
        expect_eq(SYS_IPC_CREATE_PORT, 22)
        expect_eq(SYS_IPC_CONNECT,     23)

    it("file syscalls are in the 30-48 range"):
        expect_eq(SYS_FILE_OPEN,  30)
        expect_eq(SYS_FILE_READ,  31)
        expect_eq(SYS_FILE_WRITE, 32)
        expect_true(SYS_FILE_OPEN < SYS_FILE_WRITE)
        expect_true(SYS_FILE_WRITE < SYS_CHDIR)

    it("debug_write is 60"):
        expect_eq(SYS_DEBUG_WRITE, 60)

    it("network syscalls are in the 70-77 range"):
        expect_eq(SYS_NET_SOCKET,    70)
        expect_eq(SYS_NET_IF_CONFIG, 77)
        expect_true(SYS_NET_SOCKET < SYS_NET_IF_CONFIG)

    it("device syscalls are in the 80-85 range"):
        expect_eq(SYS_DEV_ENUMERATE, 80)
        expect_eq(SYS_FREE_DMA,      85)
        expect_true(SYS_DEV_ENUMERATE < SYS_FREE_DMA)

    it("log and sysinfo syscalls are in 90-97 range"):
        expect_eq(SYS_LOG_WRITE,     90)
        expect_eq(SYS_LOG_READ,      91)
        expect_eq(SYS_SYSINFO,       95)
        expect_eq(SYS_GET_HOSTNAME,  96)
        expect_eq(SYS_SET_HOSTNAME,  97)
        expect_true(SYS_LOG_WRITE < SYS_SYSINFO)
        expect_true(SYS_GET_HOSTNAME != SYS_SET_HOSTNAME)

    it("all primary syscall groups are non-overlapping"):
        # process group max (13) < ipc group start (20)
        expect_true(SYS_SPAWN_BINARY < SYS_IPC_SEND)
        # ipc group max (29) < file group start (30)
        expect_true(SYS_NOTIF_WAIT_ANY < SYS_FILE_OPEN)
        # file group max (51) < debug (60)
        expect_true(SYS_SLEEP < SYS_DEBUG_WRITE)
        # debug (60) < net group start (70)
        expect_true(SYS_DEBUG_WRITE < SYS_NET_SOCKET)
        # net group max (77) < dev group start (80)
        expect_true(SYS_NET_IF_CONFIG < SYS_DEV_ENUMERATE)
        # dev group max (85) < log group start (90)
        expect_true(SYS_FREE_DMA < SYS_LOG_WRITE)
