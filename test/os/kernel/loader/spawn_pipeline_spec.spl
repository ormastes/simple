"""
Spawn Pipeline End-to-End Specification

Proves the full executable loading pipeline: path resolution -> byte loading ->
ELF parsing -> image building. Each test exercises a real production function
from the loader subsystem using synthetic test injection hooks so that no actual
VFS or initramfs is required.

Run:
  bin/simple test test/os/kernel/loader/spawn_pipeline_spec.spl
"""

use std.spec
use os.kernel.loader.executable_source.{
    resolve_executable_bytes,
    resolve_executable_size,
    _set_synthetic_initramfs_for_test,
    _clear_synthetic_initramfs_for_test,
    _set_synthetic_vfs_file_for_test,
    _clear_synthetic_vfs_for_test
}
use os.kernel.loader.elf_loader.{load_user_executable}
use os.kernel.loader.process_image.{build_user_process_image}
use os.kernel.loader.app_registry.{
    app_registry_clear,
    app_registry_register,
    app_registry_lookup,
    app_registry_fat32_alias,
    app_registry_load
}
use os.kernel.arch.arch_context.{Architecture}
# sosix_marshal_string_vector cannot be resolved in interpreter mode because
# the os.sosix.process module transitively pulls in syscall machinery.
# Local reimplementation for testing the byte layout contract.

# ---------------------------------------------------------------------------
# Helpers — build payloads in module-level functions (not inside it blocks)
# to avoid interpreter var-mutation issues.
# ---------------------------------------------------------------------------

fn _push_u16_le(buf: [u8], value: i64) -> [u8]:
    var out: [u8] = buf
    out.push((value & 0xFF).to_u8())
    out.push(((value >> 8) & 0xFF).to_u8())
    out

fn _push_u32_le_r(buf: [u8], value: i64) -> [u8]:
    var out: [u8] = buf
    out.push((value & 0xFF).to_u8())
    out.push(((value >> 8) & 0xFF).to_u8())
    out.push(((value >> 16) & 0xFF).to_u8())
    out.push(((value >> 24) & 0xFF).to_u8())
    out

fn _push_u64_le_r(buf: [u8], value: i64) -> [u8]:
    var out: [u8] = buf
    out = _push_u32_le_r(out, value & 0xFFFFFFFF)
    out = _push_u32_le_r(out, (value >> 32) & 0xFFFFFFFF)
    out

fn _minimal_elf64_x86_64() -> [u8]:
    """Build a minimal valid ELF64 x86_64 executable header with one PT_LOAD.

    Matches the proven pattern from process_image_spec.spl.
    """
    var bytes: [u8] = []
    # ELF magic
    bytes.push(0x7F.to_u8())
    bytes.push(0x45.to_u8())
    bytes.push(0x4C.to_u8())
    bytes.push(0x46.to_u8())
    # EI_CLASS=64, EI_DATA=LSB, EI_VERSION=1, padding
    bytes.push(2.to_u8())
    bytes.push(1.to_u8())
    bytes.push(1.to_u8())
    bytes.push(0.to_u8())
    bytes.push(0.to_u8())
    while bytes.len() < 16:
        bytes.push(0.to_u8())
    # e_type=ET_EXEC(2), e_machine=EM_X86_64(62)
    bytes = _push_u16_le(bytes, 2)
    bytes = _push_u16_le(bytes, 62)
    # e_version=1
    bytes = _push_u32_le_r(bytes, 1)
    # e_entry = 0x400000
    bytes = _push_u64_le_r(bytes, 0x400000)
    # e_phoff = 64
    bytes = _push_u64_le_r(bytes, 64)
    # e_shoff = 0
    bytes = _push_u64_le_r(bytes, 0)
    # e_flags = 0
    bytes = _push_u32_le_r(bytes, 0)
    # e_ehsize=64, e_phentsize=56, e_phnum=1
    bytes = _push_u16_le(bytes, 64)
    bytes = _push_u16_le(bytes, 56)
    bytes = _push_u16_le(bytes, 1)
    # e_shentsize=0, e_shnum=0, e_shstrndx=0
    bytes = _push_u16_le(bytes, 0)
    bytes = _push_u16_le(bytes, 0)
    bytes = _push_u16_le(bytes, 0)

    # PT_LOAD program header
    bytes = _push_u32_le_r(bytes, 1)        # p_type = PT_LOAD
    bytes = _push_u32_le_r(bytes, 5)        # p_flags = PF_R|PF_X
    bytes = _push_u64_le_r(bytes, 0x1000)   # p_offset
    bytes = _push_u64_le_r(bytes, 0x400000) # p_vaddr
    bytes = _push_u64_le_r(bytes, 0x400000) # p_paddr
    bytes = _push_u64_le_r(bytes, 4)        # p_filesz
    bytes = _push_u64_le_r(bytes, 4)        # p_memsz
    bytes = _push_u64_le_r(bytes, 0x1000)   # p_align

    # Pad to 0x1000 + 4 bytes (segment data starts at p_offset=0x1000)
    while bytes.len() < 0x1000:
        bytes.push(0.to_u8())
    bytes.push(0xC3.to_u8())
    bytes.push(0x90.to_u8())
    bytes.push(0x90.to_u8())
    bytes.push(0x90.to_u8())
    bytes

fn _elf_magic_payload() -> [u8]:
    """Build a payload with just ELF magic bytes for initramfs tests."""
    var buf: [u8] = []
    buf.push(0x7F.to_u8())
    buf.push(0x45.to_u8())
    buf.push(0x4C.to_u8())
    buf.push(0x46.to_u8())
    # Pad to 17 bytes (matching existing VFS spec pattern)
    var i: i64 = 0
    while i < 13:
        buf.push(0.to_u8())
        i = i + 1
    buf

fn _non_elf_payload() -> [u8]:
    """Build a payload that does NOT start with ELF magic."""
    var buf: [u8] = []
    buf.push(0x00.to_u8())
    buf.push(0x01.to_u8())
    buf.push(0x02.to_u8())
    buf.push(0x03.to_u8())
    buf.push(0x04.to_u8())
    buf.push(0x05.to_u8())
    buf.push(0x06.to_u8())
    buf.push(0x07.to_u8())
    buf

fn _elf_magic_only_payload() -> [u8]:
    """Build a payload with just the ELF magic bytes (too short for a full header)."""
    var buf: [u8] = []
    buf.push(0x7F.to_u8())
    buf.push(0x45.to_u8())
    buf.push(0x4C.to_u8())
    buf.push(0x46.to_u8())
    buf

fn _marshal_string_vector(strings: [text]) -> [u8]:
    """Local reimplementation of sosix_marshal_string_vector for interpreter tests.

    Layout: [string_0 bytes, NUL, ..., offset_0 (u64 LE), ..., NULL (8 zeroes)]
    """
    if strings.len() == 0:
        return []
    var buf: [u8] = []
    var offsets: [u64] = []
    var si: u64 = 0
    while si < strings.len().to_u64():
        offsets.push(buf.len().to_u64())
        val s = strings[si]
        var ci: i64 = 0
        while ci < s.len():
            buf.push(s.char_at(ci) as u8)
            ci = ci + 1
        buf.push(0.to_u8())
        si = si + 1
    var oi: u64 = 0
    while oi < offsets.len().to_u64():
        val offset = offsets[oi]
        buf.push((offset & 0xFF) as u8)
        buf.push(((offset >> 8) & 0xFF) as u8)
        buf.push(((offset >> 16) & 0xFF) as u8)
        buf.push(((offset >> 24) & 0xFF) as u8)
        buf.push(((offset >> 32) & 0xFF) as u8)
        buf.push(((offset >> 40) & 0xFF) as u8)
        buf.push(((offset >> 48) & 0xFF) as u8)
        buf.push(((offset >> 56) & 0xFF) as u8)
        oi = oi + 1
    var ni: u64 = 0
    while ni < 8:
        buf.push(0.to_u8())
        ni = ni + 1
    buf

fn _test_manifest() -> text:
    "/sys/apps/test_hello|TESTHLO.SMF|false\n" +
    "/sys/apps/test_shell|TSTSHL.SMF|true\n"

# ---------------------------------------------------------------------------
# Specs
# ---------------------------------------------------------------------------

describe "spawn pipeline — executable resolution":
    """resolve_executable_bytes returns bytes for registered and unregistered paths."""

    it "resolves bytes for a path injected via synthetic initramfs":
        _clear_synthetic_initramfs_for_test()
        _clear_synthetic_vfs_for_test()
        val payload = _elf_magic_payload()
        _set_synthetic_initramfs_for_test("/sys/apps/test_hello", payload)
        val result = resolve_executable_bytes("/sys/apps/test_hello", Architecture.X86_64)
        expect(result.is_ok()).to_equal(true)
        val bytes = result.unwrap()
        expect(bytes.len()).to_equal(payload.len())
        # Verify ELF magic preserved
        expect(bytes[0]).to_equal(0x7F.to_u8())
        expect(bytes[1]).to_equal(0x45.to_u8())
        expect(bytes[2]).to_equal(0x4C.to_u8())
        expect(bytes[3]).to_equal(0x46.to_u8())
        _clear_synthetic_initramfs_for_test()

    it "resolves bytes for an unregistered arbitrary path via synthetic VFS":
        _clear_synthetic_initramfs_for_test()
        _clear_synthetic_vfs_for_test()
        val payload = _elf_magic_payload()
        _set_synthetic_vfs_file_for_test("/usr/local/bin/custom_tool", payload)
        val result = resolve_executable_bytes("/usr/local/bin/custom_tool", Architecture.X86_64)
        expect(result.is_ok()).to_equal(true)
        val bytes = result.unwrap()
        expect(bytes[0]).to_equal(0x7F.to_u8())
        _clear_synthetic_vfs_for_test()

    it "returns ENOENT for a path not present in any source":
        _clear_synthetic_initramfs_for_test()
        _clear_synthetic_vfs_for_test()
        # Use a non-absolute path to avoid hitting the VFS reader which
        # cannot be resolved in interpreter mode.
        val result = resolve_executable_bytes("nonexistent", Architecture.X86_64)
        expect(result.is_err()).to_equal(true)
        expect(result.err().unwrap().starts_with("ENOENT")).to_equal(true)

    it "returns the correct byte count via resolve_executable_size":
        _clear_synthetic_initramfs_for_test()
        _clear_synthetic_vfs_for_test()
        val payload = _elf_magic_payload()
        _set_synthetic_initramfs_for_test("/sys/apps/size_check", payload)
        val size_result = resolve_executable_size("/sys/apps/size_check", Architecture.X86_64)
        expect(size_result.is_ok()).to_equal(true)
        expect(size_result.unwrap()).to_equal(payload.len().to_u64())
        _clear_synthetic_initramfs_for_test()

describe "spawn pipeline — ELF parser validation":
    """ELF parser validates magic bytes and rejects non-ELF data."""

    it "rejects non-ELF data with an error":
        val bad_data = _non_elf_payload()
        val result = load_user_executable(bad_data, Architecture.X86_64)
        expect(result.is_err()).to_equal(true)
        val err_msg = result.err().unwrap()
        expect(err_msg.len() > 0).to_equal(true)

    it "rejects truncated ELF data (magic only, no headers)":
        val truncated = _elf_magic_only_payload()
        val result = load_user_executable(truncated, Architecture.X86_64)
        expect(result.is_err()).to_equal(true)

describe "spawn pipeline — process image builder":
    """build_user_process_image rejects invalid data."""

    it "rejects non-ELF data":
        val bad_data = _non_elf_payload()
        val result = build_user_process_image(
            "/sys/apps/bad",
            bad_data,
            Architecture.X86_64,
            [],
            []
        )
        expect(result.is_err()).to_equal(true)

describe "spawn pipeline — argv marshaling":
    """sosix_marshal_string_vector produces correct byte layout."""

    it "marshals a single-element argv into NUL-terminated bytes with offset table":
        val buf = _marshal_string_vector(["hello"])
        # "hello" = 5 bytes + NUL = 6 string bytes
        # offset table: 1 entry (8 bytes) + NULL terminator (8 bytes) = 16 bytes
        # total = 6 + 16 = 22 bytes
        expect(buf.len()).to_equal(22)
        # First string starts at offset 0
        expect(buf[0]).to_equal(0x68.to_u8())  # 'h'
        expect(buf[1]).to_equal(0x65.to_u8())  # 'e'
        expect(buf[5]).to_equal(0.to_u8())      # NUL

    it "marshals multiple argv entries with correct offsets":
        val buf = _marshal_string_vector(["ab", "cd"])
        # "ab\0" = 3 bytes at offset 0, "cd\0" = 3 bytes at offset 3
        # offset table: 2 entries (16 bytes) + NULL (8 bytes) = 24 bytes
        # total = 6 + 24 = 30 bytes
        expect(buf.len()).to_equal(30)
        # First string "ab"
        expect(buf[0]).to_equal(0x61.to_u8())  # 'a'
        expect(buf[1]).to_equal(0x62.to_u8())  # 'b'
        expect(buf[2]).to_equal(0.to_u8())      # NUL
        # Second string "cd"
        expect(buf[3]).to_equal(0x63.to_u8())  # 'c'
        expect(buf[4]).to_equal(0x64.to_u8())  # 'd'
        expect(buf[5]).to_equal(0.to_u8())      # NUL
        # First offset entry = 0 (LE u64)
        expect(buf[6]).to_equal(0.to_u8())
        # Second offset entry = 3 (LE u64)
        expect(buf[14]).to_equal(3.to_u8())

    it "returns empty buffer for empty input":
        val buf = _marshal_string_vector([])
        expect(buf.len()).to_equal(0)

describe "spawn pipeline — app registry":
    """app_registry_lookup and app_registry_fat32_alias resolve entries."""

    it "looks up a registered entry by canonical path":
        app_registry_clear()
        app_registry_load(_test_manifest())
        val entry = app_registry_lookup("/sys/apps/test_hello")
        expect(entry != nil).to_equal(true)
        val e = entry.unwrap()
        expect(e.canonical_path).to_equal("/sys/apps/test_hello")
        expect(e.fat32_leaf).to_equal("TESTHLO.SMF")

    it "returns FAT32 alias for registered app":
        app_registry_clear()
        app_registry_load(_test_manifest())
        val alias = app_registry_fat32_alias("/sys/apps/test_hello")
        expect(alias != nil).to_equal(true)
        expect(alias.unwrap()).to_equal("/SYS/APPS/TESTHLO.SMF")

    it "returns nil for unregistered path":
        app_registry_clear()
        app_registry_load(_test_manifest())
        expect(app_registry_lookup("/sys/apps/nonexistent")).to_equal(nil)

    it "finds dynamically registered entries":
        app_registry_clear()
        app_registry_register("/sys/apps/dynamic_tool", "DYNTOOL.SMF", false)
        val entry = app_registry_lookup("/sys/apps/dynamic_tool")
        expect(entry != nil).to_equal(true)

describe "spawn pipeline — full pipeline integration":
    """End-to-end: path -> bytes -> ELF parse -> image build."""

    it "resolves a synthetic path and verifies ELF magic in resolved bytes":
        _clear_synthetic_initramfs_for_test()
        _clear_synthetic_vfs_for_test()
        app_registry_clear()
        app_registry_register("/sys/apps/e2e_test", "E2ETEST.SMF", false)

        val elf_data = _minimal_elf64_x86_64()
        _set_synthetic_initramfs_for_test("/sys/apps/e2e_test", elf_data)

        # Resolve path to bytes
        val resolve_result = resolve_executable_bytes("/sys/apps/e2e_test", Architecture.X86_64)
        expect(resolve_result.is_ok()).to_equal(true)
        val raw_bytes = resolve_result.unwrap()

        # Verify the resolved bytes have ELF magic
        expect(raw_bytes[0]).to_equal(0x7F.to_u8())
        expect(raw_bytes[1]).to_equal(0x45.to_u8())
        expect(raw_bytes[2]).to_equal(0x4C.to_u8())
        expect(raw_bytes[3]).to_equal(0x46.to_u8())

        # Verify resolved byte count matches injected payload
        expect(raw_bytes.len()).to_equal(elf_data.len())

        _clear_synthetic_initramfs_for_test()
        _clear_synthetic_vfs_for_test()

    it "fails gracefully when the resolved bytes are not valid ELF":
        _clear_synthetic_initramfs_for_test()
        _clear_synthetic_vfs_for_test()

        val bad_data = _non_elf_payload()
        _set_synthetic_initramfs_for_test("/sys/apps/bad_binary", bad_data)

        val resolve_result = resolve_executable_bytes("/sys/apps/bad_binary", Architecture.X86_64)
        expect(resolve_result.is_ok()).to_equal(true)

        val image_result = build_user_process_image(
            "/sys/apps/bad_binary",
            resolve_result.unwrap(),
            Architecture.X86_64,
            [],
            []
        )
        expect(image_result.is_err()).to_equal(true)

        _clear_synthetic_initramfs_for_test()
