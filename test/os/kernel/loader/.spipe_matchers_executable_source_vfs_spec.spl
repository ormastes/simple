# Phase 4 — Filesystem-backed executable loading.
#
# Exercises `resolve_executable_bytes` / `resolve_executable_size` in their
# post-Phase-4 shape: initramfs-first lookup with an app-registry-driven alias
# layer and a synthetic-entry injection point for specs.
#
# NOTE: tests that reach `_exec_vfs_read_file_bytes` fail in interpreter mode
# because `os.services.vfs.vfs_init.g_vfs_read_executable_bytes` cannot be
# resolved transitively. Tests are structured so that synthetic entries
# intercept the lookup before the real VFS reader is invoked.

use std.spec
use os.kernel.loader.executable_source.{
    resolve_executable_bytes,
    resolve_executable_bytes_from_path_bytes,
    resolve_executable_size,
    _set_synthetic_initramfs_for_test,
    _clear_synthetic_initramfs_for_test,
    _set_synthetic_vfs_file_for_test,
    _clear_synthetic_vfs_for_test,
    RV64_PROOF_BINARY_PATH,
    RV32_PROOF_BINARY_PATH,
}
use os.kernel.arch.arch_context.{Architecture}
use os.kernel.loader.app_registry.{app_registry_load_hardcoded_fallback, app_registry_clear}

fn _elf_magic_payload() -> [u8]:
    var payload: [u8] = []
    payload.push(0x7F.to_u8())
    payload.push(0x45.to_u8())
    payload.push(0x4C.to_u8())
    payload.push(0x46.to_u8())
    payload

fn _push_u32_le(buf: [u8], value: i64) -> [u8]:
    buf.push((value & 0xFF).to_u8())
    buf.push(((value >> 8) & 0xFF).to_u8())
    buf.push(((value >> 16) & 0xFF).to_u8())
    buf.push(((value >> 24) & 0xFF).to_u8())
    buf

fn _make_17_byte_payload() -> [u8]:
    var p: [u8] = []
    p.push(0x7F.to_u8())
    p.push(0x45.to_u8())
    p.push(0x4C.to_u8())
    p.push(0x46.to_u8())
    p.push(0x04.to_u8())
    p.push(0x05.to_u8())
    p.push(0x06.to_u8())
    p.push(0x07.to_u8())
    p.push(0x08.to_u8())
    p.push(0x09.to_u8())
    p.push(0x0A.to_u8())
    p.push(0x0B.to_u8())
    p.push(0x0C.to_u8())
    p.push(0x0D.to_u8())
    p.push(0x0E.to_u8())
    p.push(0x0F.to_u8())
    p.push(0x10.to_u8())
    p

fn _exec_smf_payload(stub: [u8]) -> [u8]:
    var bytes = stub
    var header: [u8] = []
    header.push(0x53.to_u8())
    header.push(0x4D.to_u8())
    header.push(0x46.to_u8())
    header.push(0x00.to_u8())
    while header.len() < 52:
        header.push(0.to_u8())
    header = _push_u32_le(header, stub.len())
    header = _push_u32_le(header, stub.len())
    while header.len() < 128:
        header.push(0.to_u8())
    for b in header:
        bytes.push(b)
    bytes

describe "executable source — VFS-backed loading":
    """Phase 4 coverage: initramfs-first resolution and legacy stub fallback."""

    it "returns ENOENT for unknown paths":
        """Unknown non-absolute paths must surface the ENOENT errno-string."""
        _clear_synthetic_initramfs_for_test()
        val result = resolve_executable_bytes("nonexistent", Architecture.Riscv64)
        expect result.is_err() == true
        expect result.err().unwrap().starts_with("ENOENT") == true

    it "returns EINVAL for an empty path":
        """Empty paths are rejected before any lookup is attempted."""
        _clear_synthetic_initramfs_for_test()
        val result = resolve_executable_bytes("", Architecture.Riscv64)
        expect result.is_err() == true
        expect result.err().unwrap().starts_with("EINVAL") == true

    it "resolves proof binary path via initramfs synthetic":
        """Boot smoke tests depend on the RV64 stub being loadable. In
        interpreter mode the real VFS reader is unavailable, so we inject
        an ELF-magic payload via the initramfs synthetic hook and verify
        the resolve pipeline returns it."""
        _clear_synthetic_initramfs_for_test()
        _clear_synthetic_vfs_for_test()
        val payload = _elf_magic_payload()
        _set_synthetic_initramfs_for_test(RV64_PROOF_BINARY_PATH, payload)
        val result = resolve_executable_bytes(RV64_PROOF_BINARY_PATH, Architecture.Riscv64)
        expect result.is_ok() == true
        val bytes = result.unwrap()
        expect bytes[0] == 0x7F.to_u8()
        expect bytes[1] == 0x45.to_u8()
        _clear_synthetic_initramfs_for_test()
        _clear_synthetic_vfs_for_test()

    it "resolves a synthetic initramfs entry by exact path":
        """A synthetic /usr/bin/foo payload round-trips through the reader."""
        _clear_synthetic_initramfs_for_test()
        _clear_synthetic_vfs_for_test()
        var payload: [u8] = []
        payload.push(0xDE.to_u8())
        payload.push(0xAD.to_u8())
        payload.push(0xBE.to_u8())
        payload.push(0xEF.to_u8())
        _set_synthetic_initramfs_for_test("/usr/bin/foo", payload)

        val result = resolve_executable_bytes("/usr/bin/foo", Architecture.Riscv64)
        expect result.is_ok() == true
        val bytes = result.unwrap()
        expect bytes.len() == 4
        expect bytes[0] == 0xDE.to_u8()
        expect bytes[3] == 0xEF.to_u8()
        _clear_synthetic_initramfs_for_test()
        _clear_synthetic_vfs_for_test()

    it "falls back to VFS bytes when initramfs has no matching executable":
        """The mounted filesystem supplies executable bytes for desktop apps."""
        _clear_synthetic_initramfs_for_test()
        _clear_synthetic_vfs_for_test()
        val payload = _elf_magic_payload()
        _set_synthetic_vfs_file_for_test("/sys/apps/hello_world", payload)

        val result = resolve_executable_bytes("/sys/apps/hello_world", Architecture.X86_64)
        expect result.is_ok() == true
        val bytes = result.unwrap()
        expect bytes.len() == 4
        expect bytes[0] == 0x7F.to_u8()
        expect bytes[3] == 0x46.to_u8()
        _clear_synthetic_vfs_for_test()

    it "falls back to VFS bytes for arbitrary executable paths":
        """Executable source resolution is path-based, not limited to seeded apps."""
        _clear_synthetic_initramfs_for_test()
        _clear_synthetic_vfs_for_test()
        val payload = _elf_magic_payload()
        _set_synthetic_vfs_file_for_test("/home/RUNME.ELF", payload)

        val result = resolve_executable_bytes("/home/RUNME.ELF", Architecture.X86_64)
        expect result.is_ok() == true
        val bytes = result.unwrap()
        expect bytes.len() == 4
        expect bytes[0] == 0x7F.to_u8()
        expect bytes[3] == 0x46.to_u8()
        _clear_synthetic_vfs_for_test()

    it "falls back to seeded FAT32 aliases for smux":
        """smux should be runnable from the seeded filesystem app path."""
        _clear_synthetic_initramfs_for_test()
        _clear_synthetic_vfs_for_test()
        app_registry_load_hardcoded_fallback()
        val payload = _elf_magic_payload()
        _set_synthetic_vfs_file_for_test("/SYS/APPS/SMUXSMF.SMF", payload)

        val result = resolve_executable_bytes("/sys/apps/smux", Architecture.X86_64)
        expect result.is_ok() == true
        val bytes = result.unwrap()
        expect bytes.len() == 4
        expect bytes[0] == 0x7F.to_u8()
        expect bytes[3] == 0x46.to_u8()
        _clear_synthetic_vfs_for_test()
        app_registry_clear()

    it "falls back to seeded FAT32 short-name aliases for desktop apps":
        """Desktop apps keep their canonical /sys/apps path even when the
        current FAT32 image stores the ELF under the registry alias."""
        _clear_synthetic_initramfs_for_test()
        _clear_synthetic_vfs_for_test()
        app_registry_load_hardcoded_fallback()
        val payload = _elf_magic_payload()
        _set_synthetic_vfs_file_for_test("/SYS/APPS/BROWSMF.SMF", payload)

        val result = resolve_executable_bytes("/sys/apps/browser_demo", Architecture.X86_64)
        expect result.is_ok() == true
        val bytes = result.unwrap()
        expect bytes.len() == 4
        expect bytes[0] == 0x7F.to_u8()
        expect bytes[3] == 0x46.to_u8()
        _clear_synthetic_vfs_for_test()
        app_registry_clear()

    it "resolves seeded desktop app bytes without dynamic path text reconstruction":
        """The x86 baremetal spawn path can hand raw bytes across the loader
        boundary and still recover the canonical seeded app path."""
        _clear_synthetic_initramfs_for_test()
        _clear_synthetic_vfs_for_test()
        app_registry_load_hardcoded_fallback()
        val payload = _elf_magic_payload()
        _set_synthetic_vfs_file_for_test("/SYS/APPS/BROWSMF.SMF", payload)

        val result = resolve_executable_bytes_from_path_bytes("/sys/apps/browser_demo".bytes(), Architecture.X86_64)
        expect result.is_ok() == true
        val bytes = result.unwrap()
        expect bytes.len() == 4
        expect bytes[0] == 0x7F.to_u8()
        expect bytes[3] == 0x46.to_u8()
        _clear_synthetic_vfs_for_test()
        app_registry_clear()

    it "falls back to root-level aliases on seeded disk images":
        """Current FAT32 images also carry the built artifacts at the root.
        The canonical `/sys/apps/...` path resolves through the registry
        root alias."""
        _clear_synthetic_initramfs_for_test()
        _clear_synthetic_vfs_for_test()
        app_registry_load_hardcoded_fallback()
        val payload = _elf_magic_payload()
        _set_synthetic_vfs_file_for_test("/BROWSMF.SMF", payload)

        val result = resolve_executable_bytes("/sys/apps/browser_demo", Architecture.X86_64)
        expect result.is_ok() == true
        val bytes = result.unwrap()
        expect bytes.len() == 4
        expect bytes[0] == 0x7F.to_u8()
        expect bytes[3] == 0x46.to_u8()
        _clear_synthetic_vfs_for_test()
        app_registry_clear()

    it "falls back to root-level SMF aliases on seeded disk images":
        """Seeded GUI apps may now prefer executable SMF packages."""
        _clear_synthetic_initramfs_for_test()
        _clear_synthetic_vfs_for_test()
        app_registry_load_hardcoded_fallback()
        val payload = _exec_smf_payload(_elf_magic_payload())
        _set_synthetic_vfs_file_for_test("/BROWSMF.SMF", payload)

        val result = resolve_executable_bytes("/sys/apps/browser_demo.smf", Architecture.X86_64)
        expect result.is_ok() == true
        val bytes = result.unwrap()
        expect bytes.len() == 132
        expect bytes[0] == 0x7F.to_u8()
        expect bytes[3] == 0x46.to_u8()
        expect bytes[4] == 0x53.to_u8()
        _clear_synthetic_vfs_for_test()
        app_registry_clear()

    it "resolved executable byte count matches injected payload":
        """Verify resolve_executable_bytes returns the exact byte count of
        an injected initramfs payload, used by Phase 2/3 for pre-alloc."""
        _clear_synthetic_initramfs_for_test()
        _clear_synthetic_vfs_for_test()
        app_registry_clear()
        val payload = _make_17_byte_payload()
        _set_synthetic_initramfs_for_test("/usr/bin/bar", payload)

        val result = resolve_executable_bytes("/usr/bin/bar", Architecture.Riscv64)
        expect result.is_ok() == true
        val bytes = result.unwrap()
        expect bytes.len() == 17
        expect bytes[0] == 0x7F.to_u8()
        _clear_synthetic_initramfs_for_test()
        _clear_synthetic_vfs_for_test()

    it "proof binary paths are defined for boot-test fallback":
        """The proof binary path constants must be set for boot smoke tests."""
        expect RV64_PROOF_BINARY_PATH == "/sys/apps/rv64_user_proof"
        expect RV32_PROOF_BINARY_PATH == "/sys/apps/rv32_user_proof"

    it "unregistered paths without a synthetic entry fall through to ENOENT":
        """Paths not matching any proof binary or synthetic entry must surface
        ENOENT. Uses a non-absolute path to avoid the VFS reader which cannot
        be resolved in interpreter mode."""
        _clear_synthetic_initramfs_for_test()
        val result = resolve_executable_bytes("usr/bin/clang", Architecture.Riscv64)
        expect result.is_err() == true
        expect result.err().unwrap().starts_with("ENOENT") == true