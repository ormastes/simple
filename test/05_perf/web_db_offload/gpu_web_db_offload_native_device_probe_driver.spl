extern fn rt_cuda_available() -> i64
extern fn rt_cuda_device_count() -> i64
extern fn rt_vk_available() -> i64
extern fn rt_vulkan_is_available() -> i64
extern fn rt_vulkan_device_count() -> i64

val cuda_available = rt_cuda_available()
val cuda_devices = rt_cuda_device_count()
val cuda_device = 0
val cuda_name = if cuda_available > 0 and cuda_devices > 0: "cuda-device-0" else: "unavailable"
val vk_available = rt_vk_available()
val vulkan_available = rt_vulkan_is_available()
val vulkan_devices = rt_vulkan_device_count()
val vulkan_name = if vulkan_available > 0 and vulkan_devices > 0: "vulkan-device-0" else: "unavailable"

print "cuda_available={cuda_available}"
print "cuda_device_count={cuda_devices}"
print "cuda_device_handle={cuda_device}"
print "cuda_device_name={cuda_name}"
print "cuda_compute_capability=0"
print "vk_available={vk_available}"
print "vulkan_available={vulkan_available}"
print "vulkan_device_count={vulkan_devices}"
print "vulkan_device_name={vulkan_name}"
