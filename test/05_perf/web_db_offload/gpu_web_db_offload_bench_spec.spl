fn make_web_transform_validated_throughput_row() -> GpuWdbBenchRow:
    var profile = web_gpu_profile_transform("cuda", 7, 4)
    val backend = gpu_wdb_device_backend(
        "cuda",
        7,
        ["gpu_web_transform_batch"],
        true,
        "cuda-device-0"
    )
    val iterations = 4
    val docs_per_iteration = 8
    val bytes_per_item = 2048
    var gpu_hits = 0
    var cpu_fallbacks = 0
    var errors = 0
    var i = 0
    val started = rt_time_now_unix_micros()
    while i < iterations:
        val result = web_gpu_profile_execute_device_validated(
            profile,
            "/transform",
            WebGpuRouteKind.Transform,
            docs_per_iteration,
            bytes_per_item,
            200,
            "cpu-transform",
            backend,
            7,
            200,
            "cpu-transform",
            started + (i * 100),
            started + (i * 100) + 80,
            51,
            "cuda-event-contract"
        )
        profile = result.profile
        if result.gpu_candidate_validated:
            gpu_hits = gpu_hits + 1
        else:
            cpu_fallbacks = cpu_fallbacks + 1
            errors = errors + 1
        i = i + 1
    val finished_raw = rt_time_now_unix_micros()
    val elapsed = if finished_raw > started: finished_raw - started else: iterations
    GpuWdbBenchRow(
        name: "web_transform_validated_profile_throughput_contract",
        backend: "cuda",
        dataset: "web_transform_4x8x2048_response_match",
        row_count: 0,
        document_count: iterations * docs_per_iteration,
        vector_dimensions: 0,
        batch_size: iterations * docs_per_iteration,
        call_count: iterations,
        batch_bytes: iterations * docs_per_iteration * bytes_per_item,
        transfer_bytes: iterations * docs_per_iteration * bytes_per_item,
        kernel_time_us: 51 * iterations,
        completion_latency_us: elapsed,
        p50_us: if elapsed > iterations: elapsed / iterations else: 1,
        p95_us: elapsed,
        p99_us: elapsed,
        max_rss_kb: 1,
        queue_depth: profile.queue_state.queue_depth,
        gpu_hits: gpu_hits,
        cpu_fallbacks: cpu_fallbacks,
        timeout_count: 0,
        error_count: errors,
        fallback_reason: if errors == 0: "" else: "production-transform-throughput-validation-failed",
        dispatch_target: "gpu_web_transform_batch",
        device_time_us: 51 * iterations,
        device_timing_source: "cuda-event-contract",
        backend_timing_valid: gpu_hits == iterations
    )

fn bench_storage_commit_record(txn_id: i64) -> WalRecord:
    WalRecord(txn_id: txn_id, record_type: WAL_RECORD_COMMIT, payload: "")

fn bench_ssd_budget() -> GpuWdbBudget:
    GpuWdbBudget(
        max_queue_depth: 64,
        max_batch_bytes: 1024 * 1024,
        min_gpu_batch_bytes: 1024
    )

fn bench_storage_row_page(row_id: i64, payload_byte: i64) -> PageData:
    val page = PageData.zeroed()
    page.set_byte(0, row_id as u8)
    page.set_byte(1, payload_byte as u8)
    page

fn bench_ssd_materialized_scan() -> DbfsSsdScanMaterialization:
    val pager = DbfsPager.new(8)
    val first = pager.alloc_page().unwrap()
    val second = pager.alloc_page().unwrap()
    pager.write_page(first, bench_storage_row_page(12, 88), 0, 0).unwrap()
    pager.write_page(second, bench_storage_row_page(34, 99), 0, 0).unwrap()
    pager.flush_dirty().unwrap()
    val wal = DbfsWal.new()
    wal.append(bench_storage_commit_record(19)).unwrap()
    wal.flush().unwrap()
    val checkpoints = CheckpointEngine.new()
    checkpoints.checkpoint_now(1).unwrap()
    val btree = NsBTree.new()
    val snapshot = dbfs_ssd_offload_snapshot(pager, wal, checkpoints, btree, 2, 1024)
    dbfs_ssd_snapshot_materialize_scan(snapshot, pager, [first.id, second.id])

fn make_db_ssd_materialized_scan_device_validated_row() -> GpuWdbBenchRow:
    val materialized = bench_ssd_materialized_scan()
    val execution = db_storage_execute_ssd_materialized_scan_with_device_backend_validated(
        materialized,
        gpu_wdb_queue_initial(4),
        gpu_wdb_device_backend("cuda", 7, ["gpu_db_columnar_scan_batch"], true, "cuda-device-0"),
        7,
        true,
        bench_ssd_budget(),
        materialized.row_ids,
        1000,
        1080,
        37,
        "cuda-event-contract"
    )
    val accepted = db_storage_offload_used_gpu(execution.execution) and execution.execution.gpu_candidate_validated
    GpuWdbBenchRow(
        name: "db_ssd_materialized_scan_device_validated_contract",
        backend: execution.device_execution.device_result.backend.backend,
        dataset: "dbfs_ssd_materialized_scan_2x1024_row_match",
        row_count: materialized.row_count,
        document_count: 0,
        vector_dimensions: 0,
        batch_size: materialized.row_count,
        call_count: 1,
        batch_bytes: materialized.row_count * materialized.bytes_per_row,
        transfer_bytes: materialized.row_count * materialized.bytes_per_row,
        kernel_time_us: execution.device_execution.device_result.evidence.kernel_time_us,
        completion_latency_us: execution.device_execution.device_result.evidence.completion_latency_us,
        p50_us: execution.device_execution.device_result.evidence.completion_latency_us,
        p95_us: execution.device_execution.device_result.evidence.completion_latency_us,
        p99_us: execution.device_execution.device_result.evidence.completion_latency_us,
        max_rss_kb: 1,
        queue_depth: execution.execution.queue_depth_after,
        gpu_hits: if accepted: 1 else: 0,
        cpu_fallbacks: if accepted: 0 else: 1,
        timeout_count: 0,
        error_count: if accepted: 0 else: 1,
        fallback_reason: if accepted: "" else: execution.execution.validation_reason,
        dispatch_target: execution.execution.dispatch_target,
        device_time_us: execution.device_execution.device_result.evidence.device_time_us,
        device_timing_source: execution.device_execution.device_result.evidence.device_timing_source,
        backend_timing_valid: execution.device_execution.device_result.evidence.backend_timing_valid and accepted
    )

fn make_db_ssd_materialized_scan_profile_throughput_row() -> GpuWdbBenchRow:
    val materialized = bench_ssd_materialized_scan()
    var profile = db_offload_profile(
        "ssd-materialized-throughput",
        "cuda",
        7,
        4,
        ["gpu_db_columnar_scan_batch"],
        bench_ssd_budget(),
        true,
        true
    )
    val backend = gpu_wdb_device_backend("cuda", 7, ["gpu_db_columnar_scan_batch"], true, "cuda-device-0")
    val iterations = 3
    var gpu_hits = 0
    var cpu_fallbacks = 0
    var errors = 0
    var device_time = 0
    var i = 0
    val started = rt_time_now_unix_micros()
    while i < iterations:
        val result = db_offload_profile_execute_ssd_materialized_scan_device(
            profile,
            materialized,
            backend,
            7,
            materialized.row_ids,
            started + (i * 100),
            started + (i * 100) + 80,
            37,
            "cuda-event-contract"
        )
        profile = result.profile
        device_time = device_time + result.device_result.evidence.device_time_us
        if db_storage_offload_used_gpu(result.execution) and result.execution.gpu_candidate_validated:
            gpu_hits = gpu_hits + 1
        else:
            cpu_fallbacks = cpu_fallbacks + 1
            errors = errors + 1
        i = i + 1
    val finished_raw = rt_time_now_unix_micros()
    val elapsed = if finished_raw > started: finished_raw - started else: iterations
    GpuWdbBenchRow(
        name: "db_ssd_materialized_scan_profile_throughput_contract",
        backend: "cuda",
        dataset: "dbfs_ssd_materialized_scan_3x2x1024_row_match",
        row_count: iterations * materialized.row_count,
        document_count: 0,
        vector_dimensions: 0,
        batch_size: iterations * materialized.row_count,
        call_count: iterations,
        batch_bytes: iterations * materialized.row_count * materialized.bytes_per_row,
        transfer_bytes: iterations * materialized.row_count * materialized.bytes_per_row,
        kernel_time_us: device_time,
        completion_latency_us: elapsed,
        p50_us: if elapsed > iterations: elapsed / iterations else: 1,
        p95_us: elapsed,
        p99_us: elapsed,
        max_rss_kb: 1,
        queue_depth: profile.queue_state.queue_depth,
        gpu_hits: gpu_hits,
        cpu_fallbacks: cpu_fallbacks,
        timeout_count: 0,
        error_count: errors,
        fallback_reason: if errors == 0: "" else: "production-db-ssd-profile-throughput-validation-failed",
        dispatch_target: "gpu_db_columnar_scan_batch",
        device_time_us: device_time,
        device_timing_source: "cuda-event-contract",
        backend_timing_valid: gpu_hits == iterations and device_time == 37 * iterations
    )

fn make_db_ssd_materialized_scan_runtime_queue_throughput_row() -> GpuWdbBenchRow:
    val materialized = bench_ssd_materialized_scan()
    var profile = db_offload_profile(
        "ssd-materialized-runtime-queue",
        "native-device-probe",
        7,
        4,
        ["gpu_db_columnar_scan_batch"],
        bench_ssd_budget(),
        true,
        true
    )
    val backend = gpu_wdb_device_backend("native-device-probe", 7, ["gpu_db_columnar_scan_batch"], true, "native-device-queue")
    val iterations = 2
    var gpu_hits = 0
    var cpu_fallbacks = 0
    var errors = 0
    var device_time = 0
    var i = 0
    val started = rt_time_now_unix_micros()
    while i < iterations:
        val payload_bytes = materialized.row_count * materialized.bytes_per_row
        rt_host_gpu_queue_reset()
        val emitted = rt_host_gpu_queue_emit(2, 1, payload_bytes, 7)
        val submitted = rt_host_gpu_queue_submit(1)
        val completed = rt_host_gpu_queue_complete(1)
        val runtime_device_time = rt_host_gpu_queue_last_device_time_us()
        val result = db_offload_profile_execute_ssd_materialized_scan_device(
            profile,
            materialized,
            backend,
            7,
            materialized.row_ids,
            started + (i * 100),
            started + (i * 100) + 80,
            runtime_device_time,
            "rt_host_gpu_queue_last_device_time_us"
        )
        profile = result.profile
        device_time = device_time + result.device_result.evidence.device_time_us
        if emitted == 1 and submitted == 1 and completed == 1 and runtime_device_time > 0 and db_storage_offload_used_gpu(result.execution) and result.execution.gpu_candidate_validated:
            gpu_hits = gpu_hits + 1
        else:
            cpu_fallbacks = cpu_fallbacks + 1
            errors = errors + 1
        i = i + 1
    val finished_raw = rt_time_now_unix_micros()
    val elapsed = if finished_raw > started: finished_raw - started else: iterations
    GpuWdbBenchRow(
        name: "db_ssd_materialized_scan_runtime_queue_throughput_contract",
        backend: "native-device-probe",
        dataset: "dbfs_ssd_materialized_scan_2x2x1024_runtime_queue",
        row_count: iterations * materialized.row_count,
        document_count: 0,
        vector_dimensions: 0,
        batch_size: iterations * materialized.row_count,
        call_count: iterations,
        batch_bytes: iterations * materialized.row_count * materialized.bytes_per_row,
        transfer_bytes: iterations * materialized.row_count * materialized.bytes_per_row,
        kernel_time_us: device_time,
        completion_latency_us: elapsed,
        p50_us: if elapsed > iterations: elapsed / iterations else: 1,
        p95_us: elapsed,
        p99_us: elapsed,
        max_rss_kb: 1,
        queue_depth: profile.queue_state.queue_depth,
        gpu_hits: gpu_hits,
        cpu_fallbacks: cpu_fallbacks,
        timeout_count: 0,
        error_count: errors,
        fallback_reason: if errors == 0: "" else: "runtime-queue-db-ssd-throughput-validation-failed",
        dispatch_target: "gpu_db_columnar_scan_batch",
        device_time_us: device_time,
        device_timing_source: "rt_host_gpu_queue_last_device_time_us",
        backend_timing_valid: gpu_hits == iterations and device_time > 0
    )

fn bench_web_request(path: text) -> HttpRequestData:
    HttpRequestData(
        method: "POST",
        path: path,
        query: "",
        version: "HTTP/1.1",
        headers: [],
        body: "",
        params: {},
        peer_addr: "10.0.0.9"
    )

fn bench_web_context(path: text, params: Dict<text, text>) -> ControllerContext:
    ControllerContext(
        request: bench_web_request(path),
        session_data: {},
        flash_messages: [],
        params: params,
        current_user_id: nil
    )

fn make_web_framework_runtime_queue_inference_row() -> GpuWdbBenchRow:
    val config = web_framework_gpu_route_config("infer", "create", WebGpuRouteKind.Inference, 16, 512)
    val ctx = bench_web_context("/infer", {})
    val cpu_response = build_json("{\"ok\":true}")
    val gpu_response = build_json("{\"ok\":true}")
    rt_host_gpu_queue_reset()
    val payload_bytes = 16 * 512
    val emitted = rt_host_gpu_queue_emit(2, 1, payload_bytes, 7)
    val submitted = rt_host_gpu_queue_submit(1)
    val completed = rt_host_gpu_queue_complete(1)
    val runtime_device_time = rt_host_gpu_queue_last_device_time_us()
    val started = rt_time_now_unix_micros()
    val execution = web_framework_gpu_route_execute_device_validated(
        ctx,
        config,
        web_gpu_profile_inference("native-device-probe", 7, 4),
        gpu_wdb_device_backend("native-device-probe", 7, ["gpu_web_inference_batch"], true, "native-device-queue"),
        7,
        gpu_response,
        started,
        started + 80,
        runtime_device_time,
        "rt_host_gpu_queue_last_device_time_us",
        cpu_response
    )
    val accepted = emitted == 1 and submitted == 1 and completed == 1 and runtime_device_time > 0 and execution.validated.gpu_candidate_validated and execution.response.body == cpu_response.body
    GpuWdbBenchRow(
        name: "web_framework_inference_runtime_queue_validated_contract",
        backend: "native-device-probe",
        dataset: "web_framework_inference_16x512_runtime_queue_response_match",
        row_count: 0,
        document_count: 16,
        vector_dimensions: 0,
        batch_size: 16,
        call_count: 1,
        batch_bytes: payload_bytes,
        transfer_bytes: payload_bytes,
        kernel_time_us: runtime_device_time,
        completion_latency_us: execution.validated.device_result.evidence.completion_latency_us,
        p50_us: execution.validated.device_result.evidence.completion_latency_us,
        p95_us: execution.validated.device_result.evidence.completion_latency_us,
        p99_us: execution.validated.device_result.evidence.completion_latency_us,
        max_rss_kb: 1,
        queue_depth: execution.validated.execution.state_after.queue_depth,
        gpu_hits: if accepted: 1 else: 0,
        cpu_fallbacks: if accepted: 0 else: 1,
        timeout_count: 0,
        error_count: if accepted: 0 else: 1,
        fallback_reason: if accepted: "" else: execution.validated.validation_reason,
        dispatch_target: execution.validated.device_result.submission.dispatch_target,
        device_time_us: runtime_device_time,
        device_timing_source: "rt_host_gpu_queue_last_device_time_us",
        backend_timing_valid: accepted
    )

fn make_production_db_web_runtime_queue_throughput_row() -> GpuWdbBenchRow:
    val db_row = make_db_ssd_materialized_scan_runtime_queue_throughput_row()
    val web_row = make_web_framework_runtime_queue_inference_row()
    val accepted = db_row.backend_timing_valid and web_row.backend_timing_valid and db_row.gpu_hits > 0 and web_row.gpu_hits > 0
    val total_calls = db_row.call_count + web_row.call_count
    val total_latency = db_row.completion_latency_us + web_row.completion_latency_us
    GpuWdbBenchRow(
        name: "production_db_web_runtime_queue_throughput_contract",
        backend: "native-device-probe",
        dataset: "dbfs_ssd_and_web_framework_runtime_queue_response_match",
        row_count: db_row.row_count,
        document_count: web_row.document_count,
        vector_dimensions: 0,
        batch_size: db_row.batch_size + web_row.batch_size,
        call_count: total_calls,
        batch_bytes: db_row.batch_bytes + web_row.batch_bytes,
        transfer_bytes: db_row.transfer_bytes + web_row.transfer_bytes,
        kernel_time_us: db_row.kernel_time_us + web_row.kernel_time_us,
        completion_latency_us: total_latency,
        p50_us: if total_latency > total_calls: total_latency / total_calls else: 1,
        p95_us: total_latency,
        p99_us: total_latency,
        max_rss_kb: 1,
        queue_depth: db_row.queue_depth + web_row.queue_depth,
        gpu_hits: db_row.gpu_hits + web_row.gpu_hits,
        cpu_fallbacks: db_row.cpu_fallbacks + web_row.cpu_fallbacks,
        timeout_count: 0,
        error_count: if accepted: 0 else: 1,
        fallback_reason: if accepted: "" else: "production-db-web-runtime-queue-throughput-validation-failed",
        dispatch_target: "gpu_db_columnar_scan_batch+gpu_web_inference_batch",
        device_time_us: db_row.device_time_us + web_row.device_time_us,
        device_timing_source: "rt_host_gpu_queue_last_device_time_us",
        backend_timing_valid: accepted
    )

fn make_db_batch_admission_policy_row() -> GpuWdbBenchRow:
    val budget = gpu_wdb_default_budget()
    val open_state = gpu_wdb_queue_initial(4)
    val accepted = gpu_wdb_db_batch_admission(
        open_state,
        GpuWdbWorkKind.DbScanFilterProject,
        1024,
        0,
        0,
        64,
        true,
        true,
        true,
        budget
    )
    var full_state = gpu_wdb_queue_initial(4)
    full_state.queue_depth = budget.max_queue_depth
    val full = gpu_wdb_db_batch_admission(
        full_state,
        GpuWdbWorkKind.DbJoinAggregate,
        1024,
        0,
        0,
        96,
        true,
        true,
        true,
        budget
    )
    val tiny = gpu_wdb_db_batch_admission(
        open_state,
        GpuWdbWorkKind.DbDocumentFilter,
        0,
        1,
        0,
        256,
        true,
        true,
        true,
        budget
    )
    val valid = accepted.accepted and
        accepted.action == "dispatch-gpu" and
        accepted.dispatch_target == "gpu_db_columnar_scan_batch" and
        full.action == "run-cpu-fallback" and
        full.reason == "gpu-queue-full" and
        tiny.action == "run-cpu-fallback" and
        tiny.reason == "batch-too-small"
    GpuWdbBenchRow(
        name: "db_batch_admission_policy_contract",
        backend: "host-safe-admission-policy",
        dataset: "db_batch_admission_scan_join_document_policy",
        row_count: accepted.item_count + full.item_count,
        document_count: tiny.item_count,
        vector_dimensions: 0,
        batch_size: accepted.item_count + full.item_count + tiny.item_count,
        call_count: 3,
        batch_bytes: accepted.batch_bytes + full.batch_bytes + tiny.batch_bytes,
        transfer_bytes: if accepted.accepted: accepted.batch_bytes else: 0,
        kernel_time_us: 0,
        completion_latency_us: 1,
        p50_us: 1,
        p95_us: 1,
        p99_us: 1,
        max_rss_kb: 1,
        queue_depth: accepted.queue_depth_after,
        gpu_hits: if accepted.accepted: 1 else: 0,
        cpu_fallbacks: if full.action == "run-cpu-fallback" and tiny.action == "run-cpu-fallback": 2 else: 0,
        timeout_count: 0,
        error_count: if valid: 0 else: 1,
        fallback_reason: if valid: "queue-full+batch-too-small-covered" else: "db-batch-admission-policy-invalid",
        dispatch_target: accepted.dispatch_target,
        device_time_us: 0,
        device_timing_source: "admission-policy-contract",
        backend_timing_valid: false
    )

fn make_gpu_transfer_amortization_policy_row() -> GpuWdbBenchRow:
    val budget = gpu_wdb_default_budget()
    val amortized = gpu_wdb_transfer_amortization(4, 8, 2048, 1024, budget)
    val valid = amortized.accepted and
        amortized.logical_call_count == 4 and
        amortized.item_count == 32 and
        amortized.payload_bytes == 32 * 2048 and
        amortized.naive_transfer_bytes == (32 * 2048) + (4 * 1024) and
        amortized.amortized_transfer_bytes == (32 * 2048) + 1024 and
        amortized.saved_transfer_bytes == 3 * 1024
    GpuWdbBenchRow(
        name: "gpu_transfer_amortization_policy_contract",
        backend: "host-safe-transfer-policy",
        dataset: "gpu_transfer_amortization_4x8x2048_batch",
        row_count: 0,
        document_count: amortized.item_count,
        vector_dimensions: 0,
        batch_size: amortized.item_count,
        call_count: amortized.logical_call_count,
        batch_bytes: amortized.payload_bytes,
        transfer_bytes: amortized.amortized_transfer_bytes,
        kernel_time_us: 0,
        completion_latency_us: 1,
        p50_us: 1,
        p95_us: 1,
        p99_us: 1,
        max_rss_kb: 1,
        queue_depth: 1,
        gpu_hits: if amortized.accepted: 1 else: 0,
        cpu_fallbacks: 0,
        timeout_count: 0,
        error_count: if valid: 0 else: 1,
        fallback_reason: if valid: "amortized-transfer-saved:3072" else: "gpu-transfer-amortization-policy-invalid",
        dispatch_target: "gpu_web_transform_batch",
        device_time_us: 0,
        device_timing_source: "transfer-amortization-policy-contract",
        backend_timing_valid: false
    )

