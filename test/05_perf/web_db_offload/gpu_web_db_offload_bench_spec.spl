fn gpu_wdb_benchmark_measured_row_status(name: text, dataset: text, target: text, device_time_us: i64, timing_source: text, hardware_claim: text) -> text:
    if name == "db_vector_cuda_measured" and dataset == "oracle_vectors_1024x128" and target == "gpu_db_vector_search_batch" and device_time_us > 0 and timing_source == "cuda-measured-driver" and hardware_claim == "native-device-measured":
        return "measured"
    if name == "db_columnar_scan_cuda_measured" and dataset == "pure_sql_scan_filter_project" and target == "gpu_db_columnar_scan_batch" and device_time_us > 0 and timing_source == "cuda-measured-driver" and hardware_claim == "native-device-measured":
        return "measured"
    if name == "db_ssd_materialized_scan_device_validated_contract" and dataset == "dbfs_ssd_materialized_scan_2x1024_row_match" and target == "gpu_db_columnar_scan_batch" and device_time_us > 0 and timing_source == "cuda-event-contract" and hardware_claim == "production-device-validated-contract":
        return "measured"
    if name == "db_ssd_materialized_scan_profile_throughput_contract" and dataset == "dbfs_ssd_materialized_scan_3x2x1024_row_match" and target == "gpu_db_columnar_scan_batch" and device_time_us > 0 and timing_source == "cuda-event-contract" and hardware_claim == "production-device-validated-throughput-contract":
        return "measured"
    if name == "db_ssd_materialized_scan_runtime_queue_throughput_contract" and dataset == "dbfs_ssd_materialized_scan_2x2x1024_runtime_queue" and target == "gpu_db_columnar_scan_batch" and device_time_us > 0 and timing_source == "rt_host_gpu_queue_last_device_time_us" and hardware_claim == "runtime-queue-measured-throughput-contract":
        return "measured"
    if name == "web_framework_inference_runtime_queue_validated_contract" and dataset == "web_framework_inference_16x512_runtime_queue_response_match" and target == "gpu_web_inference_batch" and device_time_us > 0 and timing_source == "rt_host_gpu_queue_last_device_time_us" and hardware_claim == "runtime-queue-measured-framework-contract":
        return "measured"
    if name == "production_db_web_runtime_queue_throughput_contract" and dataset == "dbfs_ssd_and_web_framework_runtime_queue_response_match" and target == "gpu_db_columnar_scan_batch+gpu_web_inference_batch" and device_time_us > 0 and timing_source == "rt_host_gpu_queue_last_device_time_us" and hardware_claim == "runtime-queue-production-db-web-throughput-contract":
        return "measured"
    if name == "db_join_aggregate_cuda_measured" and dataset == "pure_sql_join_aggregate_group_count" and target == "gpu_db_join_aggregate_batch" and device_time_us > 0 and timing_source == "cuda-measured-driver" and hardware_claim == "native-device-measured":
        return "measured"
    if name == "db_document_filter_cuda_measured" and dataset == "nosql_document_filter_metadata" and target == "gpu_db_document_filter_batch" and device_time_us > 0 and timing_source == "cuda-measured-driver" and hardware_claim == "native-device-measured":
        return "measured"
    if name == "web_inference_cuda_measured" and dataset == "web_inference_16x512_response_match" and target == "gpu_web_inference_batch" and device_time_us > 0 and timing_source == "cuda-measured-driver" and hardware_claim == "native-device-measured":
        return "measured"
    if name == "web_embedding_cuda_measured" and dataset == "web_embedding_16x512_response_match" and target == "gpu_web_embedding_batch" and device_time_us > 0 and timing_source == "cuda-measured-driver" and hardware_claim == "native-device-measured":
        return "measured"
    if name == "web_rank_cuda_measured" and dataset == "web_rank_32x256_response_match" and target == "gpu_web_rank_batch" and device_time_us > 0 and timing_source == "cuda-measured-driver" and hardware_claim == "native-device-measured":
        return "measured"
    if name == "web_transform_cuda_measured" and dataset == "web_transform_8x2048_response_match" and target == "gpu_web_transform_batch" and device_time_us > 0 and timing_source == "cuda-measured-driver" and hardware_claim == "native-device-measured":
        return "measured"
    if name == "db_clickbench_clickhouse_external_measured" and dataset == "clickbench_hits_scan_filter_project_1024_row_match" and target == "clickhouse_scan_filter_project" and device_time_us > 0 and timing_source == "external-db-baseline-driver" and hardware_claim == "external-db-baseline-measured":
        return "measured"
    if name == "db_tpch_duckdb_external_measured" and dataset == "tpch_q3_join_aggregate_group_count_1024_row_match" and target == "duckdb_tpch_q3_join_aggregate" and device_time_us > 0 and timing_source == "external-db-baseline-driver" and hardware_claim == "external-db-baseline-measured":
        return "measured"
    if name == "db_tpch_postgresql_external_measured" and dataset == "tpch_q3_join_aggregate_group_count_1024_row_match" and target == "postgresql_tpch_q3_join_aggregate" and device_time_us > 0 and timing_source == "external-db-baseline-driver" and hardware_claim == "external-db-baseline-measured":
        return "measured"
    if name == "db_ycsb_mongo_external_measured" and dataset == "benchbase_ycsb_document_filter_1024_doc_match" and target == "mongo_ycsb_document_filter" and device_time_us > 0 and timing_source == "external-db-baseline-driver" and hardware_claim == "external-db-baseline-measured":
        return "measured"
    "invalid_measured"

describe "GPU web/db offload benchmark evidence":
    it "should report GPU hit metrics for coarse vector batches":
        step("Create a host-safe GPU-hit metrics row for a coarse vector batch")
        val row = make_gpu_vector_row()
        expect(row.name).to_equal("db_vector_gpu_hit")
        expect(row.backend).to_equal("host-safe-mock")
        expect(row.dataset).to_equal("oracle_vectors_1024x128")
        expect(row.row_count).to_equal(1024)
        expect(row.vector_dimensions).to_equal(128)
        expect(row.batch_size).to_equal(8)
        expect(row.batch_bytes).to_equal(gpu_wdb_default_budget().min_gpu_batch_bytes * 8)
        expect(row.transfer_bytes).to_equal(row.batch_bytes)
        expect(row.kernel_time_us).to_be_greater_than(0)
        expect(row.completion_latency_us).to_be_greater_than(0)
        expect(row.p50_us).to_be_greater_than(0)
