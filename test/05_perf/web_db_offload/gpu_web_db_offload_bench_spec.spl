"""
# GPU Web/DB Offload Benchmark Evidence

## Overview

This host-safe performance spec verifies that the reusable GPU Web/DB offload
facades emit the metrics required before any production GPU speedup claim. It
does not require GPU hardware and does not claim native throughput; it proves
the report shape for CPU fallback, GPU-hit accounting, queue pressure, batch
size, transfer bytes, kernel time, completion latency, and tiny-batch rejection.

## Examples

Use this spec as the deterministic benchmark-report contract for future native
or hardware-backed proxy and database benchmark runners.

**Requirements:** doc/02_requirements/nfr/gpu_web_db_offload.md
**Plan:** doc/03_plan/agent_tasks/gpu_web_db_offload_impl_status.md
**Design:** doc/05_design/gpu_web_db_offload.md
**Research:** doc/01_research/local/gpu_web_db_offload.md
"""

extern fn rt_time_now_unix_micros() -> i64
extern fn rt_host_gpu_queue_reset()
extern fn rt_host_gpu_queue_emit(lane_code: i64, kind_code: i64, payload_size: i64, backend_code: i64) -> i64
extern fn rt_host_gpu_queue_submit(max_packets: i64) -> i64
extern fn rt_host_gpu_queue_complete(max_packets: i64) -> i64
extern fn rt_host_gpu_queue_last_device_time_us() -> i64

struct GpuWdbBenchRow:
    name: text
    backend: text
    dataset: text
    row_count: i64
    document_count: i64
    vector_dimensions: i64
    batch_size: i64
    call_count: i64
    batch_bytes: i64
    transfer_bytes: i64
    kernel_time_us: i64
    completion_latency_us: i64
    p50_us: i64
    p95_us: i64
    p99_us: i64
    max_rss_kb: i64
    queue_depth: i64
    gpu_hits: i64
    cpu_fallbacks: i64
    timeout_count: i64
    error_count: i64
    fallback_reason: text
    dispatch_target: text
    device_time_us: i64
    device_timing_source: text
    backend_timing_valid: bool

fn bench_row_from_submission(name: text, backend: text, dataset: text,
                             row_count: i64, document_count: i64,
                             vector_dimensions: i64, batch_size: i64,
                             submission: GpuWdbQueueSubmission,
                             started_us: i64, finished_us: i64) -> GpuWdbBenchRow:
    val evidence = gpu_wdb_submission_evidence(
        submission,
        batch_size,
        if submission.accepted: submission.pinned_host_bytes else: 0,
        started_us,
        finished_us
    )
    GpuWdbBenchRow(
        name: name,
        backend: backend,
        dataset: dataset,
        row_count: row_count,
        document_count: document_count,
        vector_dimensions: vector_dimensions,
        batch_size: evidence.batch_size,
        call_count: 1,
        batch_bytes: evidence.batch_bytes,
        transfer_bytes: evidence.transfer_bytes,
        kernel_time_us: evidence.kernel_time_us,
        completion_latency_us: evidence.completion_latency_us,
        p50_us: evidence.completion_latency_us,
        p95_us: evidence.completion_latency_us,
        p99_us: evidence.completion_latency_us,
        max_rss_kb: 1,
        queue_depth: evidence.queue_depth_after,
        gpu_hits: evidence.gpu_hits,
        cpu_fallbacks: evidence.cpu_fallbacks,
        timeout_count: 0,
        error_count: 0,
        fallback_reason: evidence.fallback_reason,
        dispatch_target: evidence.dispatch_target,
        device_time_us: evidence.device_time_us,
        device_timing_source: evidence.device_timing_source,
        backend_timing_valid: evidence.backend_timing_valid
    )

fn native_timed_bench_row_from_submission(name: text, backend: text, dataset: text,
                                          row_count: i64, document_count: i64,
                                          vector_dimensions: i64, batch_size: i64,
                                          submission: GpuWdbQueueSubmission,
                                          started_us: i64, finished_us: i64,
                                          device_time_us: i64,
                                          device_timing_source: text) -> GpuWdbBenchRow:
    val evidence = gpu_wdb_submission_evidence_with_device_timing(
        submission,
        batch_size,
        if submission.accepted: submission.pinned_host_bytes else: 0,
        started_us,
        finished_us,
        device_time_us,
        device_timing_source,
        true
    )
    GpuWdbBenchRow(
        name: name,
        backend: backend,
        dataset: dataset,
        row_count: row_count,
        document_count: document_count,
        vector_dimensions: vector_dimensions,
        batch_size: evidence.batch_size,
        call_count: 1,
        batch_bytes: evidence.batch_bytes,
        transfer_bytes: evidence.transfer_bytes,
        kernel_time_us: evidence.kernel_time_us,
        completion_latency_us: evidence.completion_latency_us,
        p50_us: evidence.completion_latency_us,
        p95_us: evidence.completion_latency_us,
        p99_us: evidence.completion_latency_us,
        max_rss_kb: 1,
        queue_depth: evidence.queue_depth_after,
        gpu_hits: evidence.gpu_hits,
        cpu_fallbacks: evidence.cpu_fallbacks,
        timeout_count: 0,
        error_count: 0,
        fallback_reason: evidence.fallback_reason,
        dispatch_target: evidence.dispatch_target,
        device_time_us: evidence.device_time_us,
        device_timing_source: evidence.device_timing_source,
        backend_timing_valid: evidence.backend_timing_valid
    )

fn make_gpu_vector_row() -> GpuWdbBenchRow:
    val budget = gpu_wdb_default_budget()
    val state = gpu_wdb_queue_initial(4)
    val registry = gpu_wdb_library_with_targets("host-safe-mock", 1, ["gpu_db_vector_search_batch"])
    val started = rt_time_now_unix_micros()
    val submission = gpu_wdb_submit_registered_batch(
        state,
        registry,
        GpuWdbWorkKind.DbVectorSearch,
        budget.min_gpu_batch_bytes * 8,
        8,
        true,
        true,
        true,
        budget
    )
    val finished = rt_time_now_unix_micros()
    bench_row_from_submission(
        "db_vector_gpu_hit",
        registry.backend,
        "oracle_vectors_1024x128",
        1024,
        0,
        128,
        8,
        submission,
        started,
        finished
    )

fn make_cpu_tiny_batch_row() -> GpuWdbBenchRow:
    val budget = gpu_wdb_default_budget()
    val state = gpu_wdb_queue_initial(4)
    val registry = gpu_wdb_library_with_targets("host-safe-mock", 1, ["gpu_web_embedding_batch"])
    val started = rt_time_now_unix_micros()
    val submission = gpu_wdb_submit_registered_batch(
        state,
        registry,
        GpuWdbWorkKind.WebEmbedding,
        budget.min_gpu_batch_bytes - 1,
        1,
        true,
        true,
        true,
        budget
    )
    val finished = rt_time_now_unix_micros()
    bench_row_from_submission(
        "web_embedding_tiny_cpu_fallback",
        registry.backend,
        "web_payloads_1x_small",
        0,
        1,
        0,
        1,
        submission,
        started,
        finished
    )

fn make_web_device_validated_row(name: text,
                                 dataset: text,
                                 profile: WebGpuOffloadProfile,
                                 route: text,
                                 route_kind: WebGpuRouteKind,
                                 target: text,
                                 item_count: i64,
                                 bytes_per_item: i64,
                                 cpu_status: i64,
                                 cpu_body: text,
                                 device_time_us: i64) -> GpuWdbBenchRow:
    val backend = gpu_wdb_device_backend(
        "cuda",
        7,
        [target],
        true,
        "cuda-device-0"
    )
    val started = rt_time_now_unix_micros()
    val finished = started + 120
    val result = web_gpu_profile_execute_device_validated(
        profile,
        route,
        route_kind,
        item_count,
        bytes_per_item,
        cpu_status,
        cpu_body,
        backend,
        7,
        cpu_status,
        cpu_body,
        started,
        finished,
        device_time_us,
        "cuda-event-contract"
    )
    val evidence = result.device_result.evidence
    GpuWdbBenchRow(
        name: name,
        backend: result.device_result.backend.backend,
        dataset: dataset,
        row_count: 0,
        document_count: item_count,
        vector_dimensions: 0,
        batch_size: evidence.batch_size,
        call_count: 1,
        batch_bytes: evidence.batch_bytes,
        transfer_bytes: evidence.transfer_bytes,
        kernel_time_us: evidence.kernel_time_us,
        completion_latency_us: evidence.completion_latency_us,
        p50_us: evidence.completion_latency_us,
        p95_us: evidence.completion_latency_us,
        p99_us: evidence.completion_latency_us,
        max_rss_kb: 1,
        queue_depth: evidence.queue_depth_after,
        gpu_hits: if result.gpu_candidate_validated: 1 else: 0,
        cpu_fallbacks: if result.gpu_candidate_validated: 0 else: 1,
        timeout_count: 0,
        error_count: if result.gpu_candidate_validated: 0 else: 1,
        fallback_reason: if result.gpu_candidate_validated: "" else: result.validation_reason,
        dispatch_target: result.device_result.submission.dispatch_target,
        device_time_us: evidence.device_time_us,
        device_timing_source: evidence.device_timing_source,
        backend_timing_valid: evidence.backend_timing_valid and result.gpu_candidate_validated
    )

