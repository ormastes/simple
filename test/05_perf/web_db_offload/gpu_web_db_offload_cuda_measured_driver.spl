extern fn rt_cuda_init() -> i64
extern fn rt_cuda_device_count() -> i64
extern fn rt_cuda_device_get(id: i64) -> i64
extern fn rt_cuda_ctx_create(device: i64) -> i64
extern fn rt_cuda_ctx_destroy(ctx: i64) -> i64
extern fn rt_cuda_mem_alloc(size: i64) -> i64
extern fn rt_cuda_mem_free(ptr: i64) -> i64
extern fn rt_cuda_memset(ptr: i64, value: i64, size: i64) -> i64
extern fn rt_cuda_memcpy_dtoh(dst: i64, src: i64, size: i64) -> i64
extern fn rt_cuda_module_load_data(ptx: text) -> i64
extern fn rt_cuda_module_unload(module: i64) -> i64
extern fn rt_cuda_launch_kernel(module: i64, func_name: text, grid_x: i64, grid_y: i64, grid_z: i64, block_x: i64, block_y: i64, block_z: i64, args_ptr: i64) -> i64
extern fn rt_cuda_sync() -> i64
extern fn rt_time_now_unix_micros() -> i64
extern fn rt_alloc(size: i64) -> i64
extern fn rt_ptr_write_i64(ptr: i64, offset: i64, value: i64) -> i64
extern fn rt_ptr_read_i64(ptr: i64, offset: i64) -> i64

val PTX_SUM_SQUARES = ".version 7.5\n.target sm_75\n.address_size 64\n\n.visible .entry sum_squares(\n    .param .u64 param_result,\n    .param .u64 param_n\n) {\n    .reg .u64 %rd<12>;\n    .reg .u32 %r<6>;\n    .reg .pred %p1, %p2;\n    .shared .align 8 .u64 sdata[256];\n    mov.u32 %r0, %tid.x;\n    mov.u32 %r1, %ctaid.x;\n    mov.u32 %r2, %ntid.x;\n    mov.u32 %r3, %nctaid.x;\n    mul.wide.u32 %rd10, %r1, %r2;\n    cvt.u64.u32 %rd0, %r0;\n    add.u64 %rd0, %rd10, %rd0;\n    mul.wide.u32 %rd1, %r3, %r2;\n    ld.param.u64 %rd2, [param_n];\n    mov.u64 %rd3, 0;\nloop:\n    setp.ge.u64 %p1, %rd0, %rd2;\n    @%p1 bra end_loop;\n    mul.lo.u64 %rd4, %rd0, %rd0;\n    add.u64 %rd3, %rd3, %rd4;\n    add.u64 %rd0, %rd0, %rd1;\n    bra loop;\nend_loop:\n    cvt.u64.u32 %rd5, %r0;\n    shl.b64 %rd5, %rd5, 3;\n    mov.u64 %rd6, sdata;\n    add.u64 %rd6, %rd6, %rd5;\n    st.shared.u64 [%rd6], %rd3;\n    bar.sync 0;\n    mov.u32 %r4, 128;\nreduce:\n    setp.eq.u32 %p2, %r4, 0;\n    @%p2 bra done_reduce;\n    setp.ge.u32 %p1, %r0, %r4;\n    @%p1 bra skip_reduce;\n    cvt.u64.u32 %rd7, %r4;\n    shl.b64 %rd7, %rd7, 3;\n    add.u64 %rd8, %rd6, %rd7;\n    ld.shared.u64 %rd9, [%rd8];\n    ld.shared.u64 %rd4, [%rd6];\n    add.u64 %rd4, %rd4, %rd9;\n    st.shared.u64 [%rd6], %rd4;\nskip_reduce:\n    bar.sync 0;\n    shr.u32 %r4, %r4, 1;\n    bra reduce;\ndone_reduce:\n    setp.ne.u32 %p1, %r0, 0;\n    @%p1 bra done;\n    ld.shared.u64 %rd3, [sdata];\n    ld.param.u64 %rd4, [param_result];\n    atom.global.add.u64 %rd5, [%rd4], %rd3;\ndone:\n    ret;\n}\n"

fn cpu_sum_squares(n: i64) -> i64:
    var total = 0
    var i = 0
    while i < n:
        total = total + i * i
        i = i + 1
    total

fn emit_unavailable(reason: text):
    print "GPU_WDB_DEVICE_STATUS=unavailable"
    print "GPU_WDB_DEVICE_BACKEND=cuda"
    print "GPU_WDB_DEVICE_NAME=cuda-device-0"
    print "GPU_WDB_DEVICE_TARGET=cpu_fallback"
    print "GPU_WDB_DEVICE_DATASET=oracle_vectors_1024x128"
    print "GPU_WDB_DEVICE_TRANSFER_BYTES=0"
    print "GPU_WDB_DEVICE_KERNEL_TIME_US=0"
    print "GPU_WDB_DEVICE_COMPLETION_LATENCY_US=0"
    print "GPU_WDB_DEVICE_REASON={reason}"
    print "GPU_WDB_DEVICE_HARDWARE_CLAIM=none-device-unavailable"

fn main():
    val n = 1024
    val iterations = 3
    val init = rt_cuda_init()
    if init != 0:
        emit_unavailable("cuda-init-failed")
        return
    if rt_cuda_device_count() <= 0:
        emit_unavailable("cuda-runtime-unavailable")
        return
    val device = rt_cuda_device_get(0)
    val ctx = rt_cuda_ctx_create(device)
    if ctx < 0:
        emit_unavailable("cuda-context-create-failed")
        return
    val module = rt_cuda_module_load_data(PTX_SUM_SQUARES)
    if module <= 0:
        rt_cuda_ctx_destroy(ctx)
        emit_unavailable("cuda-module-load-failed")
        return
    val d_result = rt_cuda_mem_alloc(8)
    if d_result <= 0:
        rt_cuda_module_unload(module)
        rt_cuda_ctx_destroy(ctx)
        emit_unavailable("cuda-result-allocation-failed")
        return

    val val_buf = rt_alloc(16)
    rt_ptr_write_i64(val_buf, 0, d_result)
    rt_ptr_write_i64(val_buf, 8, n)
    val ptrs_buf = rt_alloc(16)
    rt_ptr_write_i64(ptrs_buf, 0, val_buf)
    rt_ptr_write_i64(ptrs_buf, 8, val_buf + 8)
    val host_result = rt_alloc(8)

    rt_cuda_memset(d_result, 0, 8)
    rt_cuda_launch_kernel(module, "sum_squares", 1, 1, 1, 256, 1, 1, ptrs_buf)
    rt_cuda_sync()
    rt_cuda_memcpy_dtoh(host_result, d_result, 8)
    val gpu_result = rt_ptr_read_i64(host_result, 0)
    val cpu_result = cpu_sum_squares(n)
    if gpu_result != cpu_result:
        rt_cuda_mem_free(d_result)
        rt_cuda_module_unload(module)
        rt_cuda_ctx_destroy(ctx)
        emit_unavailable("cuda-cpu-oracle-mismatch")
        return

    val start_us = rt_time_now_unix_micros()
    var i = 0
    while i < iterations:
        rt_cuda_memset(d_result, 0, 8)
        rt_cuda_launch_kernel(module, "sum_squares", 1, 1, 1, 256, 1, 1, ptrs_buf)
        rt_cuda_sync()
        i = i + 1
    val elapsed_us = rt_time_now_unix_micros() - start_us
    val kernel_time_us = if elapsed_us > 0: elapsed_us else: 1

    rt_cuda_mem_free(d_result)
    rt_cuda_module_unload(module)
    rt_cuda_ctx_destroy(ctx)

    print "GPU_WDB_DEVICE_STATUS=measured"
    print "GPU_WDB_DEVICE_BACKEND=cuda"
    print "GPU_WDB_DEVICE_NAME=cuda-device-0"
    print "GPU_WDB_DEVICE_TARGET=gpu_db_vector_search_batch"
    print "GPU_WDB_DEVICE_DATASET=oracle_vectors_1024x128"
    print "GPU_WDB_DEVICE_TRANSFER_BYTES=8"
    print "GPU_WDB_DEVICE_KERNEL_TIME_US={kernel_time_us}"
    print "GPU_WDB_DEVICE_COMPLETION_LATENCY_US={kernel_time_us}"
    print "GPU_WDB_DEVICE_REASON=cuda-measured-sum-squares-oracle"
    print "GPU_WDB_DEVICE_HARDWARE_CLAIM=native-device-measured"
