# GPU Perf Check Runner
#
# Builds and runs C CUDA/Vulkan benchmarks, parses results.
# Prereqs: gcc, libcuda.so, libvulkan.so (all present on this host)
#
# Usage:
#   bin/simple test/05_perf/local_gpu_check/run_gpu_check.spl

extern fn rt_exec(cmd: text) -> i64
extern fn rt_exec_output(cmd: text) -> text
extern fn rt_cli_get_args() -> [text]

fn gpu_output_verdict(output: text) -> text:
    if output.find("FAIL:") >= 0:
        return "unavailable-or-failed"
    if output.find("WARN: GPU slower") >= 0 or output.find("NOTE: host-visible mem slower than CPU") >= 0:
        return "measured-gpu-slower-overhead"
    if output.find("ACCEPTABLE: within 1.25x") >= 0:
        return "measured-near-cpu"
    if output.find("PASS: GPU equal or better") >= 0 or output.find("GPU speedup:") >= 0 or output.find("Speedup: >") >= 0:
        return "measured-gpu-faster"
    "unclassified-output"

fn first_matching_line(output: text, a: text, b: text) -> text:
    var idx = output.find(a)
    if idx < 0 and b.len() > 0:
        idx = output.find(b)
    if idx < 0:
        return "missing"
    val rest = output.slice(idx, output.len())
    val newline = rest.find("\n")
    if newline < 0:
        return rest.trim()
    rest.slice(0, newline).trim()

fn self_check_gpu_summary_classifier() -> bool:
    gpu_output_verdict("Speedup: 2.0x\nPASS: GPU equal or better") == "measured-gpu-faster" and
        gpu_output_verdict("Speedup: 0.8x\nACCEPTABLE: within 1.25x") == "measured-near-cpu" and
        gpu_output_verdict("Speedup: 0.2x\nWARN: GPU slower (sync overhead)") == "measured-gpu-slower-overhead" and
        gpu_output_verdict("Speedup: 0.2x") == "unclassified-output" and
        gpu_output_verdict("GPU speedup: 4x") == "measured-gpu-faster" and
        gpu_output_verdict("Speedup: >100x (sub-ms GPU)") == "measured-gpu-faster" and
        gpu_output_verdict("NOTE: host-visible mem slower than CPU") == "measured-gpu-slower-overhead" and
        gpu_output_verdict("FAIL: no devices") == "unavailable-or-failed" and
        gpu_output_verdict("FAIL: no devices\nPASS: GPU equal or better\nWARN: GPU slower") == "unavailable-or-failed"

fn self_check_metal_summary_classifier() -> bool:
    gpu_output_verdict("Metal GPU avg: 0.40 ms\nGPU speedup: 3x") == "measured-gpu-faster" and
        gpu_output_verdict("Metal GPU avg: 4.20 ms\nWARN: GPU slower (sync overhead)") == "measured-gpu-slower-overhead" and
        gpu_output_verdict("FAIL: Metal unavailable\nGPU speedup: 3x") == "unavailable-or-failed" and
        first_matching_line("Metal GPU avg: 0.40 ms\nCPU memset avg: 1.20 ms", "Metal GPU avg:", "GPU fill avg:") == "Metal GPU avg: 0.40 ms"

fn has_arg(args: [text], needle: text) -> bool:
    var i = 0
    val count = args.len()
    while i < count:
        if args[i] == needle:
            return true
        i = i + 1
    false

fn self_test_summary_contract() -> i64:
    if not self_check_gpu_summary_classifier():
        print "gpu_perf_summary_self_test=fail reason=classifier"
        return 1
    if not self_check_metal_summary_classifier():
        print "gpu_perf_summary_self_test=fail reason=metal-classifier"
        return 1
    if gpu_output_verdict("ACCEPTABLE: within 1.25x") != "measured-near-cpu":
        print "gpu_perf_summary_self_test=fail reason=near-cpu"
        return 1
    if first_matching_line("before\nGPU fill avg: 2.66 ms\nafter", "GPU fill avg:", "") != "GPU fill avg: 2.66 ms":
        print "gpu_perf_summary_self_test=fail reason=timing-line"
        return 1
    if first_matching_line("nothing useful", "GPU fill avg:", "Avg kernel:") != "missing":
        print "gpu_perf_summary_self_test=fail reason=missing-line"
        return 1
    print "gpu_perf_summary_self_test=pass"
    print "gpu_perf_summary_contract=verdict-timing-overhead"
    print "gpu_perf_summary_case_faster=pass"
    print "gpu_perf_summary_case_near_cpu=pass"
    print "gpu_perf_summary_case_slower_overhead=pass"
    print "gpu_perf_summary_case_metal_output=pass"
    print "gpu_perf_summary_case_unclassified=pass"
    print "gpu_perf_summary_case_timing_line=pass"
    print "gpu_perf_summary_case_fail_precedence=pass"
    return 0

fn main():
    val args = rt_cli_get_args()
    if has_arg(args, "--self-test"):
        return self_test_summary_contract()

    if not self_check_gpu_summary_classifier():
        print "FAIL: gpu summary classifier self-check"
        return pass_dn

    print "========================================"
    print "GPU Performance Check — Build & Run"
    print "========================================"
    print ""

    var base = "test/05_perf/local_gpu_check/c_cuda"

    # Build CUDA bench
    print "[1/4] Building CUDA benchmark..."
    var build_cuda = rt_exec("gcc -O2 -o " + base + "/cuda_bench " + base + "/cuda_bench.c -ldl")
    if build_cuda != 0:
        print "  FAIL: gcc cuda_bench.c returned " + build_cuda.to_text()
        return pass_dn
    print "  OK"

    # Build Vulkan bench
    print "[2/4] Building Vulkan benchmark..."
    var build_vk = rt_exec("gcc -O2 -o " + base + "/vulkan_bench " + base + "/vulkan_bench.c -ldl")
    if build_vk != 0:
        print "  FAIL: gcc vulkan_bench.c returned " + build_vk.to_text()
        return pass_dn
    print "  OK"

    # Run CUDA
    print ""
    print "[3/4] Running CUDA benchmark..."
    var cuda_out = rt_exec_output(base + "/cuda_bench")
    print cuda_out

    # Run Vulkan
    print ""
    print "[4/4] Running Vulkan benchmark..."
    var vk_out = rt_exec_output(base + "/vulkan_bench")
    print vk_out

    print ""
    print "========================================"
    print "SUMMARY"
    print "========================================"
    print "  CUDA verdict: " + gpu_output_verdict(cuda_out)
    print "  CUDA GPU timing: " + first_matching_line(cuda_out, "GPU kernel clear:", "Avg kernel:")
    print "  CUDA CPU timing: " + first_matching_line(cuda_out, "CPU memset clear:", "Avg CPU memset:")
    print "  Vulkan verdict: " + gpu_output_verdict(vk_out)
    print "  Vulkan GPU timing: " + first_matching_line(vk_out, "GPU fill avg:", "Avg:")
    print "  Vulkan CPU timing: " + first_matching_line(vk_out, "CPU memset avg:", "CPU memset comparison")
    print "  Offload proof: measured subprocess output only; slower verdict means sync/host-visible communication overhead beat GPU work."
    print "========================================"

main()
