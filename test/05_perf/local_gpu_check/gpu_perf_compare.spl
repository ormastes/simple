# Pure Simple GPU Perf Check — CUDA + Vulkan via dlopen SFFI
#
# No Rust cuda/vulkan feature needed. Uses spl_dlopen/spl_dlsym to call
# libcuda.so and libvulkan.so directly, same as the C benchmarks do.
#
# Usage:
#   bin/simple test/perf/local_gpu_check/gpu_perf_compare.spl

extern fn spl_dlopen(path: text) -> i64
extern fn spl_dlsym(handle: i64, name: text) -> i64
extern fn spl_dlclose(handle: i64) -> i64
extern fn spl_wffi_call_i64(fptr: i64, args: [i64], nargs: i64) -> i64
extern fn rt_cstring_to_text(ptr: i64) -> text
extern fn rt_alloc(size: i64) -> i64
extern fn rt_free(ptr: i64) -> i64
extern fn rt_ptr_read_i32(addr: i64, offset: i64) -> i64
extern fn rt_ptr_read_i64(addr: i64, offset: i64) -> i64
extern fn rt_ptr_write_i32(addr: i64, offset: i64, v: i64) -> i64
extern fn rt_ptr_write_i64(addr: i64, offset: i64, v: i64) -> i64
extern fn rt_time_now_monotonic_ms() -> i64

# ============================================================================
# SFFI call helpers (thin wrappers around spl_wffi_call_i64)
# ============================================================================

fn ffi0(fptr: i64) -> i64:
    var a: [i64] = []
    spl_wffi_call_i64(fptr, a, 0)

fn ffi1(fptr: i64, a0: i64) -> i64:
    var a: [i64] = []
    a.push(a0)
    spl_wffi_call_i64(fptr, a, 1)

fn ffi2(fptr: i64, a0: i64, a1: i64) -> i64:
    var a: [i64] = []
    a.push(a0)
    a.push(a1)
    spl_wffi_call_i64(fptr, a, 2)

fn ffi3(fptr: i64, a0: i64, a1: i64, a2: i64) -> i64:
    var a: [i64] = []
    a.push(a0)
    a.push(a1)
    a.push(a2)
    spl_wffi_call_i64(fptr, a, 3)

fn ffi4(fptr: i64, a0: i64, a1: i64, a2: i64, a3: i64) -> i64:
    var a: [i64] = []
    a.push(a0)
    a.push(a1)
    a.push(a2)
    a.push(a3)
    spl_wffi_call_i64(fptr, a, 4)

fn ffi5(fptr: i64, a0: i64, a1: i64, a2: i64, a3: i64, a4: i64) -> i64:
    var a: [i64] = []
    a.push(a0)
    a.push(a1)
    a.push(a2)
    a.push(a3)
    a.push(a4)
    spl_wffi_call_i64(fptr, a, 5)

fn ffi6(fptr: i64, a0: i64, a1: i64, a2: i64, a3: i64, a4: i64, a5: i64) -> i64:
    var a: [i64] = []
    a.push(a0)
    a.push(a1)
    a.push(a2)
    a.push(a3)
    a.push(a4)
    a.push(a5)
    spl_wffi_call_i64(fptr, a, 6)

# Format elapsed/iterations as "X.YY ms"
fn fmt_avg(elapsed_ms: i64, iters: i64) -> text:
    if iters == 0:
        return "N/A"
    var whole = elapsed_ms / iters
    var frac = ((elapsed_ms * 100) / iters) % 100
    var frac_text = frac.to_text()
    if frac < 10:
        frac_text = "0" + frac_text
    whole.to_text() + "." + frac_text

# ASCII lookup: index 0 = space (32), index 94 = tilde (126)
var _ascii = " !\"#$%&'()*+,-./0123456789:;<=>?@ABCDEFGHIJKLMNOPQRSTUVWXYZ[\\]^_`abcdefghijklmnopqrstuvwxyz{|}~"

fn byte_to_char(b: i64) -> text:
    if b >= 32 and b <= 126:
        return _ascii[b - 32]
    ""

fn decode_cstring(ptr: i64, max_len: i64) -> text:
    var result = ""
    var off = 0
    while off < max_len:
        var word = rt_ptr_read_i32(ptr, off)
        var b0 = word & 255
        if b0 == 0:
            return result
        result = result + byte_to_char(b0)
        var b1 = (word >> 8) & 255
        if b1 == 0:
            return result
        result = result + byte_to_char(b1)
        var b2 = (word >> 16) & 255
        if b2 == 0:
            return result
        result = result + byte_to_char(b2)
        var b3 = (word >> 24) & 255
        if b3 == 0:
            return result
        result = result + byte_to_char(b3)
        off = off + 4
    result

# Zero a region of memory (8-byte aligned writes)
fn zero_mem(ptr: i64, bytes: i64):
    var off = 0
    while off < bytes:
        rt_ptr_write_i64(ptr, off, 0)
        off = off + 8

# Find a memory type index matching required type bits and property flags
fn find_mem_type(mem_props_ptr: i64, type_bits: i64, flags: i64) -> i64:
    var count = rt_ptr_read_i32(mem_props_ptr, 0)
    var idx = 0
    while idx < count:
        var pf = rt_ptr_read_i32(mem_props_ptr, 4 + idx * 8)
        var bit = type_bits >> idx
        if (bit & 1) == 1:
            if (pf & flags) == flags:
                return idx
        idx = idx + 1
    -1

# ============================================================================
# CUDA Benchmark
# ============================================================================

fn run_cuda() -> i64:
    print "[CUDA — dlopen SFFI]"
    var lib = spl_dlopen("libcuda.so.1")
    if lib == 0:
        lib = spl_dlopen("libcuda.so")
    if lib == 0:
        print "  SKIP: cannot load libcuda.so"
        return -1

    var p_init = spl_dlsym(lib, "cuInit")
    var p_dev_count = spl_dlsym(lib, "cuDeviceGetCount")
    var p_dev_get = spl_dlsym(lib, "cuDeviceGet")
    var p_dev_name = spl_dlsym(lib, "cuDeviceGetName")
    var p_ctx_create = spl_dlsym(lib, "cuCtxCreate_v2")
    var p_ctx_destroy = spl_dlsym(lib, "cuCtxDestroy_v2")
    var p_ctx_sync = spl_dlsym(lib, "cuCtxSynchronize")
    var p_mem_alloc = spl_dlsym(lib, "cuMemAlloc_v2")
    var p_mem_free = spl_dlsym(lib, "cuMemFree_v2")
    var p_memset32 = spl_dlsym(lib, "cuMemsetD32_v2")
    var p_memcpy_dth = spl_dlsym(lib, "cuMemcpyDtoH_v2")

    if p_init == 0 or p_mem_alloc == 0 or p_memset32 == 0:
        print "  FAIL: missing CUDA symbols"
        spl_dlclose(lib)
        return -1

    var res = ffi1(p_init, 0)
    if res != 0:
        print "  FAIL: cuInit = " + res.to_text()
        spl_dlclose(lib)
        return -1

    var out4 = rt_alloc(4)
    ffi1(p_dev_count, out4)
    var count = rt_ptr_read_i32(out4, 0)
    rt_free(out4)
    print "  Devices: " + count.to_text()
    if count <= 0:
        print "  FAIL: no devices"
        spl_dlclose(lib)
        return -1

    var out_dev = rt_alloc(4)
    ffi2(p_dev_get, out_dev, 0)
    var dev = rt_ptr_read_i32(out_dev, 0)
    rt_free(out_dev)

    # rt_cstring_to_text returns empty in interpreter mode (known bug);
    # decode device name manually from raw i32 reads
    var nbuf = rt_alloc(256)
    ffi3(p_dev_name, nbuf, 255, dev)
    var dname = decode_cstring(nbuf, 64)
    rt_free(nbuf)
    print "  Device: " + dname

    var out_ctx = rt_alloc(8)
    res = ffi3(p_ctx_create, out_ctx, 0, dev)
    var ctx = rt_ptr_read_i64(out_ctx, 0)
    rt_free(out_ctx)
    if res != 0:
        print "  FAIL: cuCtxCreate = " + res.to_text()
        spl_dlclose(lib)
        return -1
    print "  Context: OK"

    # Allocate 1080p framebuffer on device
    var pixels = 1920 * 1080
    var bytes = pixels * 4
    var out_fb = rt_alloc(8)
    res = ffi2(p_mem_alloc, out_fb, bytes)
    var d_fb = rt_ptr_read_i64(out_fb, 0)
    rt_free(out_fb)
    if res != 0:
        print "  FAIL: cuMemAlloc = " + res.to_text()
        ffi1(p_ctx_destroy, ctx)
        spl_dlclose(lib)
        return -1
    print "  Allocated: " + bytes.to_text() + " bytes on device"

    # Warmup
    ffi3(p_memset32, d_fb, 255, pixels)
    ffi0(p_ctx_sync)

    # --- Test 1: Timed memset clears (hoisted args — zero allocs in loop) ---
    print ""
    print "  --- GPU memset 1080p (100 iterations, hoisted) ---"
    var args_ms: [i64] = []
    args_ms.push(d_fb)
    args_ms.push(255)
    args_ms.push(pixels)
    var args_sync: [i64] = []
    var t0 = rt_time_now_monotonic_ms()
    var i = 0
    while i < 100:
        spl_wffi_call_i64(p_memset32, args_ms, 3)
        spl_wffi_call_i64(p_ctx_sync, args_sync, 0)
        i = i + 1
    var gpu_ms = rt_time_now_monotonic_ms() - t0
    print "  Total: " + gpu_ms.to_text() + " ms"
    print "  Avg:   " + fmt_avg(gpu_ms, 100) + " ms/frame"

    # --- Test 2: Readback ---
    print ""
    print "  --- Readback ---"
    ffi3(p_memset32, d_fb, 171, pixels)
    ffi0(p_ctx_sync)
    var host = rt_alloc(bytes)
    var tr0 = rt_time_now_monotonic_ms()
    ffi3(p_memcpy_dth, host, d_fb, bytes)
    var rb_ms = rt_time_now_monotonic_ms() - tr0
    print "  Readback " + bytes.to_text() + " bytes: " + rb_ms.to_text() + " ms"
    var px0 = rt_ptr_read_i32(host, 0)
    print "  First pixel (u32): " + px0.to_text()
    rt_free(host)

    # Cleanup GPU
    ffi1(p_mem_free, d_fb)
    ffi1(p_ctx_destroy, ctx)
    spl_dlclose(lib)

    # --- CPU comparison via libc memset ---
    print ""
    print "  --- CPU memset comparison (100 iterations) ---"
    var libc = spl_dlopen("libc.so.6")
    if libc == 0:
        print "  SKIP: cannot load libc.so.6"
        return gpu_ms

    var p_memset = spl_dlsym(libc, "memset")
    if p_memset == 0:
        print "  SKIP: memset symbol not found"
        return gpu_ms

    var cpu_buf = rt_alloc(bytes)
    t0 = rt_time_now_monotonic_ms()
    i = 0
    while i < 100:
        ffi3(p_memset, cpu_buf, 30, bytes)
        i = i + 1
    var cpu_ms = rt_time_now_monotonic_ms() - t0
    print "  Total: " + cpu_ms.to_text() + " ms"
    print "  Avg:   " + fmt_avg(cpu_ms, 100) + " ms/frame"
    rt_free(cpu_buf)

    # --- CUDA Verdict ---
    print ""
    print "  ========================================"
    print "  CUDA VERDICT"
    print "  ========================================"
    print "  GPU memset avg: " + fmt_avg(gpu_ms, 100) + " ms"
    print "  CPU memset avg: " + fmt_avg(cpu_ms, 100) + " ms"
    if cpu_ms > 0 and gpu_ms >= 0:
        if gpu_ms == 0:
            print "  Speedup: >100x (sub-ms GPU)"
        else:
            var ratio = cpu_ms / gpu_ms
            print "  Speedup: " + ratio.to_text() + "x"
    if gpu_ms < 2:
        print "  PASS: GPU sub-ms per frame -> 60Hz capable"
    else:
        var avg = gpu_ms / 100
        if avg < 17:
            print "  PASS: GPU < 16.7ms/frame -> 60Hz capable"
        else:
            print "  WARN: GPU > 16.7ms/frame"
    print "  GPU equal or better than CPU: " + (gpu_ms <= cpu_ms).to_text()
    print "  ========================================"
    gpu_ms

# ============================================================================
# Vulkan Benchmark — Compute (vkCmdFillBuffer)
# ============================================================================

fn run_vulkan():
    print "[VULKAN — dlopen SFFI + Compute]"
    var lib = spl_dlopen("libvulkan.so.1")
    if lib == 0:
        lib = spl_dlopen("libvulkan.so")
    if lib == 0:
        print "  SKIP: cannot load libvulkan.so"
        return pass_dn

    # --- Load Vulkan symbols ---
    var p_create_inst = spl_dlsym(lib, "vkCreateInstance")
    var p_destroy_inst = spl_dlsym(lib, "vkDestroyInstance")
    var p_enum_devs = spl_dlsym(lib, "vkEnumeratePhysicalDevices")
    var p_dev_props = spl_dlsym(lib, "vkGetPhysicalDeviceProperties")
    var p_dev_mem_props = spl_dlsym(lib, "vkGetPhysicalDeviceMemoryProperties")
    var p_create_dev = spl_dlsym(lib, "vkCreateDevice")
    var p_destroy_dev = spl_dlsym(lib, "vkDestroyDevice")
    var p_get_queue = spl_dlsym(lib, "vkGetDeviceQueue")
    var p_create_buf = spl_dlsym(lib, "vkCreateBuffer")
    var p_destroy_buf = spl_dlsym(lib, "vkDestroyBuffer")
    var p_buf_mem_req = spl_dlsym(lib, "vkGetBufferMemoryRequirements")
    var p_alloc_mem = spl_dlsym(lib, "vkAllocateMemory")
    var p_free_mem = spl_dlsym(lib, "vkFreeMemory")
    var p_bind_buf_mem = spl_dlsym(lib, "vkBindBufferMemory")
    var p_map_mem = spl_dlsym(lib, "vkMapMemory")
    var p_unmap_mem = spl_dlsym(lib, "vkUnmapMemory")
    var p_create_pool = spl_dlsym(lib, "vkCreateCommandPool")
    var p_destroy_pool = spl_dlsym(lib, "vkDestroyCommandPool")
    var p_alloc_cmds = spl_dlsym(lib, "vkAllocateCommandBuffers")
    var p_begin_cmd = spl_dlsym(lib, "vkBeginCommandBuffer")
    var p_end_cmd = spl_dlsym(lib, "vkEndCommandBuffer")
    var p_cmd_fill = spl_dlsym(lib, "vkCmdFillBuffer")
    var p_create_fence = spl_dlsym(lib, "vkCreateFence")
    var p_destroy_fence = spl_dlsym(lib, "vkDestroyFence")
    var p_reset_fences = spl_dlsym(lib, "vkResetFences")
    var p_queue_submit = spl_dlsym(lib, "vkQueueSubmit")
    var p_wait_fences = spl_dlsym(lib, "vkWaitForFences")
    var p_dev_idle = spl_dlsym(lib, "vkDeviceWaitIdle")

    if p_create_inst == 0 or p_create_dev == 0 or p_cmd_fill == 0 or p_queue_submit == 0:
        print "  FAIL: missing Vulkan symbols"
        spl_dlclose(lib)
        return pass_dn

    # --- Create instance ---
    var ici = rt_alloc(64)
    zero_mem(ici, 64)
    rt_ptr_write_i32(ici, 0, 1)
    var out_inst = rt_alloc(8)
    var t0 = rt_time_now_monotonic_ms()
    var res = ffi3(p_create_inst, ici, 0, out_inst)
    var init_ms = rt_time_now_monotonic_ms() - t0
    var instance = rt_ptr_read_i64(out_inst, 0)
    rt_free(out_inst)
    rt_free(ici)
    if res != 0:
        print "  FAIL: vkCreateInstance = " + res.to_text()
        spl_dlclose(lib)
        return pass_dn
    print "  Instance created: " + init_ms.to_text() + " ms"

    # --- Enumerate physical devices ---
    var out4 = rt_alloc(4)
    ffi3(p_enum_devs, instance, out4, 0)
    var dev_count = rt_ptr_read_i32(out4, 0)
    print "  Physical devices: " + dev_count.to_text()
    if dev_count <= 0:
        print "  FAIL: no physical devices"
        rt_free(out4)
        ffi2(p_destroy_inst, instance, 0)
        spl_dlclose(lib)
        return pass_dn

    var devs_buf = rt_alloc(dev_count * 8)
    ffi3(p_enum_devs, instance, out4, devs_buf)
    rt_free(out4)
    var phys_dev = rt_ptr_read_i64(devs_buf, 0)

    if p_dev_props != 0:
        var props_buf = rt_alloc(1024)
        var d = 0
        while d < dev_count and d < 4:
            var dh = rt_ptr_read_i64(devs_buf, d * 8)
            zero_mem(props_buf, 1024)
            ffi2(p_dev_props, dh, props_buf)
            var devname = decode_cstring(props_buf + 20, 64)
            print "    Device " + d.to_text() + ": " + devname
            d = d + 1
        rt_free(props_buf)
    rt_free(devs_buf)

    # --- Create logical device (queue family 0) ---
    var priority_f = rt_alloc(4)
    rt_ptr_write_i32(priority_f, 0, 1065353216)

    var dqci = rt_alloc(48)
    zero_mem(dqci, 48)
    rt_ptr_write_i32(dqci, 0, 2)
    rt_ptr_write_i32(dqci, 20, 0)
    rt_ptr_write_i32(dqci, 24, 1)
    rt_ptr_write_i64(dqci, 32, priority_f)

    var dci = rt_alloc(80)
    zero_mem(dci, 80)
    rt_ptr_write_i32(dci, 0, 3)
    rt_ptr_write_i32(dci, 20, 1)
    rt_ptr_write_i64(dci, 24, dqci)

    var out_vkd = rt_alloc(8)
    res = ffi4(p_create_dev, phys_dev, dci, 0, out_vkd)
    var vk_dev = rt_ptr_read_i64(out_vkd, 0)
    rt_free(out_vkd)
    rt_free(dci)
    rt_free(dqci)
    rt_free(priority_f)
    if res != 0:
        print "  FAIL: vkCreateDevice = " + res.to_text()
        ffi2(p_destroy_inst, instance, 0)
        spl_dlclose(lib)
        return pass_dn
    print "  Logical device: OK"

    # --- Get queue ---
    var out_q = rt_alloc(8)
    ffi4(p_get_queue, vk_dev, 0, 0, out_q)
    var queue = rt_ptr_read_i64(out_q, 0)
    rt_free(out_q)

    # --- Create buffer (1080p, transfer_dst for vkCmdFillBuffer) ---
    var pixels = 1920 * 1080
    var bytes = pixels * 4

    var bci = rt_alloc(64)
    zero_mem(bci, 64)
    rt_ptr_write_i32(bci, 0, 12)
    rt_ptr_write_i64(bci, 24, bytes)
    rt_ptr_write_i32(bci, 32, 130)

    var out_buf = rt_alloc(8)
    res = ffi4(p_create_buf, vk_dev, bci, 0, out_buf)
    var vk_buf = rt_ptr_read_i64(out_buf, 0)
    rt_free(out_buf)
    rt_free(bci)
    if res != 0:
        print "  FAIL: vkCreateBuffer = " + res.to_text()
        ffi2(p_destroy_dev, vk_dev, 0)
        ffi2(p_destroy_inst, instance, 0)
        spl_dlclose(lib)
        return pass_dn

    # --- Get memory requirements + find host-visible type ---
    var mem_req = rt_alloc(24)
    ffi3(p_buf_mem_req, vk_dev, vk_buf, mem_req)
    var req_size = rt_ptr_read_i64(mem_req, 0)
    var req_bits = rt_ptr_read_i32(mem_req, 16)
    rt_free(mem_req)

    var mprops = rt_alloc(528)
    zero_mem(mprops, 528)
    ffi2(p_dev_mem_props, phys_dev, mprops)
    var mem_type = find_mem_type(mprops, req_bits, 6)
    rt_free(mprops)
    if mem_type < 0:
        print "  FAIL: no host-visible memory type"
        ffi3(p_destroy_buf, vk_dev, vk_buf, 0)
        ffi2(p_destroy_dev, vk_dev, 0)
        ffi2(p_destroy_inst, instance, 0)
        spl_dlclose(lib)
        return pass_dn
    print "  Memory type: " + mem_type.to_text() + " (host-visible)"

    # --- Allocate + bind memory ---
    var mai = rt_alloc(32)
    zero_mem(mai, 32)
    rt_ptr_write_i32(mai, 0, 5)
    rt_ptr_write_i64(mai, 16, req_size)
    rt_ptr_write_i32(mai, 24, mem_type)

    var out_mem = rt_alloc(8)
    res = ffi4(p_alloc_mem, vk_dev, mai, 0, out_mem)
    var vk_mem = rt_ptr_read_i64(out_mem, 0)
    rt_free(out_mem)
    rt_free(mai)
    if res != 0:
        print "  FAIL: vkAllocateMemory = " + res.to_text()
        ffi3(p_destroy_buf, vk_dev, vk_buf, 0)
        ffi2(p_destroy_dev, vk_dev, 0)
        ffi2(p_destroy_inst, instance, 0)
        spl_dlclose(lib)
        return pass_dn

    res = ffi4(p_bind_buf_mem, vk_dev, vk_buf, vk_mem, 0)
    if res != 0:
        print "  FAIL: vkBindBufferMemory = " + res.to_text()
        ffi3(p_free_mem, vk_dev, vk_mem, 0)
        ffi3(p_destroy_buf, vk_dev, vk_buf, 0)
        ffi2(p_destroy_dev, vk_dev, 0)
        ffi2(p_destroy_inst, instance, 0)
        spl_dlclose(lib)
        return pass_dn
    print "  Buffer: " + bytes.to_text() + " bytes allocated + bound"

    # --- Command pool + command buffer ---
    var cpci = rt_alloc(24)
    zero_mem(cpci, 24)
    rt_ptr_write_i32(cpci, 0, 39)
    rt_ptr_write_i32(cpci, 16, 2)
    rt_ptr_write_i32(cpci, 20, 0)

    var out_pool = rt_alloc(8)
    res = ffi4(p_create_pool, vk_dev, cpci, 0, out_pool)
    var cmd_pool = rt_ptr_read_i64(out_pool, 0)
    rt_free(out_pool)
    rt_free(cpci)
    if res != 0:
        print "  FAIL: vkCreateCommandPool = " + res.to_text()
        ffi3(p_free_mem, vk_dev, vk_mem, 0)
        ffi3(p_destroy_buf, vk_dev, vk_buf, 0)
        ffi2(p_destroy_dev, vk_dev, 0)
        ffi2(p_destroy_inst, instance, 0)
        spl_dlclose(lib)
        return pass_dn

    var cbai = rt_alloc(32)
    zero_mem(cbai, 32)
    rt_ptr_write_i32(cbai, 0, 40)
    rt_ptr_write_i64(cbai, 16, cmd_pool)
    rt_ptr_write_i32(cbai, 24, 0)
    rt_ptr_write_i32(cbai, 28, 1)

    var out_cmd = rt_alloc(8)
    res = ffi3(p_alloc_cmds, vk_dev, cbai, out_cmd)
    var cmd = rt_ptr_read_i64(out_cmd, 0)
    rt_free(out_cmd)
    rt_free(cbai)
    if res != 0:
        print "  FAIL: vkAllocateCommandBuffers = " + res.to_text()
        ffi3(p_destroy_pool, vk_dev, cmd_pool, 0)
        ffi3(p_free_mem, vk_dev, vk_mem, 0)
        ffi3(p_destroy_buf, vk_dev, vk_buf, 0)
        ffi2(p_destroy_dev, vk_dev, 0)
        ffi2(p_destroy_inst, instance, 0)
        spl_dlclose(lib)
        return pass_dn

    # --- Fence ---
    var fci = rt_alloc(24)
    zero_mem(fci, 24)
    rt_ptr_write_i32(fci, 0, 8)

    var out_fence = rt_alloc(8)
    res = ffi4(p_create_fence, vk_dev, fci, 0, out_fence)
    var fence = rt_ptr_read_i64(out_fence, 0)
    rt_free(out_fence)
    rt_free(fci)
    if res != 0:
        print "  FAIL: vkCreateFence = " + res.to_text()
        ffi3(p_destroy_pool, vk_dev, cmd_pool, 0)
        ffi3(p_free_mem, vk_dev, vk_mem, 0)
        ffi3(p_destroy_buf, vk_dev, vk_buf, 0)
        ffi2(p_destroy_dev, vk_dev, 0)
        ffi2(p_destroy_inst, instance, 0)
        spl_dlclose(lib)
        return pass_dn
    print "  Command pool + fence: OK"

    # --- Record command buffer once: vkCmdFillBuffer ---
    var cbbi = rt_alloc(32)
    zero_mem(cbbi, 32)
    rt_ptr_write_i32(cbbi, 0, 42)

    res = ffi2(p_begin_cmd, cmd, cbbi)
    rt_free(cbbi)
    if res != 0:
        print "  FAIL: vkBeginCommandBuffer = " + res.to_text()
        ffi3(p_destroy_fence, vk_dev, fence, 0)
        ffi3(p_destroy_pool, vk_dev, cmd_pool, 0)
        ffi3(p_free_mem, vk_dev, vk_mem, 0)
        ffi3(p_destroy_buf, vk_dev, vk_buf, 0)
        ffi2(p_destroy_dev, vk_dev, 0)
        ffi2(p_destroy_inst, instance, 0)
        spl_dlclose(lib)
        return pass_dn

    ffi5(p_cmd_fill, cmd, vk_buf, 0, bytes, 255)
    ffi1(p_end_cmd, cmd)

    # --- Build submit info (reused across all iterations) ---
    var cmd_ptr = rt_alloc(8)
    rt_ptr_write_i64(cmd_ptr, 0, cmd)

    var si = rt_alloc(72)
    zero_mem(si, 72)
    rt_ptr_write_i32(si, 0, 4)
    rt_ptr_write_i32(si, 40, 1)
    rt_ptr_write_i64(si, 48, cmd_ptr)

    var fence_ptr = rt_alloc(8)
    rt_ptr_write_i64(fence_ptr, 0, fence)
    var timeout = 10000000000

    # --- Warmup ---
    ffi4(p_queue_submit, queue, 1, si, fence)
    ffi5(p_wait_fences, vk_dev, 1, fence_ptr, 1, timeout)
    ffi3(p_reset_fences, vk_dev, 1, fence_ptr)

    # --- Timed fill loop (100 iterations, hoisted args) ---
    print ""
    print "  --- GPU vkCmdFillBuffer 1080p (100 iterations, hoisted) ---"

    var args_submit: [i64] = []
    args_submit.push(queue)
    args_submit.push(1)
    args_submit.push(si)
    args_submit.push(fence)

    var args_wait: [i64] = []
    args_wait.push(vk_dev)
    args_wait.push(1)
    args_wait.push(fence_ptr)
    args_wait.push(1)
    args_wait.push(timeout)

    var args_reset: [i64] = []
    args_reset.push(vk_dev)
    args_reset.push(1)
    args_reset.push(fence_ptr)

    t0 = rt_time_now_monotonic_ms()
    var i = 0
    while i < 100:
        spl_wffi_call_i64(p_queue_submit, args_submit, 4)
        spl_wffi_call_i64(p_wait_fences, args_wait, 5)
        spl_wffi_call_i64(p_reset_fences, args_reset, 3)
        i = i + 1
    var gpu_ms = rt_time_now_monotonic_ms() - t0
    print "  Total: " + gpu_ms.to_text() + " ms"
    print "  Avg:   " + fmt_avg(gpu_ms, 100) + " ms/frame"

    # --- Readback via vkMapMemory ---
    print ""
    print "  --- Readback ---"
    var out_data = rt_alloc(8)
    res = ffi6(p_map_mem, vk_dev, vk_mem, 0, bytes, 0, out_data)
    if res == 0:
        var mapped = rt_ptr_read_i64(out_data, 0)
        var px0 = rt_ptr_read_i32(mapped, 0)
        print "  First pixel (u32): " + px0.to_text()
        ffi2(p_unmap_mem, vk_dev, vk_mem)
    else:
        print "  WARN: vkMapMemory failed = " + res.to_text()
    rt_free(out_data)

    # --- CPU baseline ---
    print ""
    print "  --- CPU memset comparison (100 iterations) ---"
    var cpu_ms = 0
    var libc = spl_dlopen("libc.so.6")
    if libc != 0:
        var p_memset = spl_dlsym(libc, "memset")
        if p_memset != 0:
            var cpu_buf = rt_alloc(bytes)
            t0 = rt_time_now_monotonic_ms()
            i = 0
            while i < 100:
                ffi3(p_memset, cpu_buf, 30, bytes)
                i = i + 1
            cpu_ms = rt_time_now_monotonic_ms() - t0
            print "  Total: " + cpu_ms.to_text() + " ms"
            print "  Avg:   " + fmt_avg(cpu_ms, 100) + " ms/frame"
            rt_free(cpu_buf)

    # --- Cleanup ---
    rt_free(fence_ptr)
    rt_free(cmd_ptr)
    rt_free(si)
    if p_dev_idle != 0:
        ffi1(p_dev_idle, vk_dev)
    ffi3(p_destroy_fence, vk_dev, fence, 0)
    ffi3(p_destroy_pool, vk_dev, cmd_pool, 0)
    ffi3(p_free_mem, vk_dev, vk_mem, 0)
    ffi3(p_destroy_buf, vk_dev, vk_buf, 0)
    ffi2(p_destroy_dev, vk_dev, 0)
    ffi2(p_destroy_inst, instance, 0)
    spl_dlclose(lib)

    # --- Verdict ---
    print ""
    print "  ========================================"
    print "  VULKAN VERDICT"
    print "  ========================================"
    print "  Vulkan available: YES (" + dev_count.to_text() + " devices)"
    print "  Init time: " + init_ms.to_text() + " ms (target < 500 ms)"
    if init_ms < 500:
        print "  PASS: init within NFR target"
    else:
        print "  WARN: init exceeds 500ms target"
    print "  GPU fill avg: " + fmt_avg(gpu_ms, 100) + " ms"
    if cpu_ms > 0:
        print "  CPU memset avg: " + fmt_avg(cpu_ms, 100) + " ms"
        if gpu_ms > 0 and cpu_ms > gpu_ms:
            var ratio = cpu_ms / gpu_ms
            print "  GPU speedup: " + ratio.to_text() + "x"
        if gpu_ms > 0 and gpu_ms >= cpu_ms:
            print "  NOTE: host-visible mem slower than CPU (expected on discrete GPU)"
    var avg_fill = gpu_ms / 100
    if avg_fill < 17:
        print "  PASS: GPU < 16.7ms/frame -> 60Hz capable"
    else:
        print "  WARN: GPU > 16.7ms/frame"
    print "  ========================================"

# ============================================================================
# Main
# ============================================================================

fn main():
    print "========================================"
    print "Pure Simple GPU Perf Check (dlopen SFFI)"
    print "========================================"
    print ""

    run_cuda()

    print ""
    print ""

    run_vulkan()

    print ""
    print "========================================"
    print "SUMMARY"
    print "========================================"
    print "  All GPU operations performed via pure Simple"
    print "  No Rust feature flags required"
    print "  Uses spl_dlopen -> libcuda.so / libvulkan.so"
    print "========================================"

main()
