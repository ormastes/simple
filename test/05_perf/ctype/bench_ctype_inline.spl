# Microbenchmark: pure Simple ctype — inlined (same-file) for native benchmarking.
# Works around the cross-module ABI bug (native_cross_module_call_abi_broken_2026-05-18).
# Run interpreter: bin/simple run test/perf/ctype/bench_ctype_inline.spl
# Run native:      bin/simple native-build --entry test/perf/ctype/bench_ctype_inline.spl \
#                    --entry-closure -o build/bench_ctype_inline --backend cranelift
#                  ./build/bench_ctype_inline

extern fn rt_time_now_unix_micros() -> i64

# --- inlined ctype (identical logic to src/lib/common/ctype.spl) ---

fn c_is_digit(ch: i64) -> bool:
    ch >= 48 and ch <= 57

fn c_is_upper(ch: i64) -> bool:
    ch >= 65 and ch <= 90

fn c_is_lower(ch: i64) -> bool:
    ch >= 97 and ch <= 122

fn c_is_alpha(ch: i64) -> bool:
    (ch >= 65 and ch <= 90) or (ch >= 97 and ch <= 122)

fn c_is_alnum(ch: i64) -> bool:
    (ch >= 65 and ch <= 90) or (ch >= 97 and ch <= 122) or (ch >= 48 and ch <= 57)

fn c_is_xdigit(ch: i64) -> bool:
    (ch >= 48 and ch <= 57) or (ch >= 65 and ch <= 70) or (ch >= 97 and ch <= 102)

fn c_is_space(ch: i64) -> bool:
    ch == 32 or ch == 9 or ch == 10 or ch == 13 or ch == 11 or ch == 12

fn c_to_lower(ch: i64) -> i64:
    if ch >= 65 and ch <= 90:
        ch + 32
    else:
        ch

fn c_to_upper(ch: i64) -> i64:
    if ch >= 97 and ch <= 122:
        ch - 32
    else:
        ch

# --- config ---

fn iters_count() -> i64:
    1000000

fn ascii_range() -> i64:
    128

# --- report ---

fn report(bench: text, ops: i64, micros_in: i64, checksum: i64):
    var micros = micros_in
    if micros <= 0:
        micros = 1
    val ops_per_ms = (ops * 1000) / micros
    print "[ctypebench] lang=simple_native bench={bench} ops={ops} micros={micros} ops_per_ms={ops_per_ms} checksum={checksum}"

# --- benchmarks ---

fn bench_is_digit() -> i64:
    val iters = iters_count()
    val range = ascii_range()
    val start = rt_time_now_unix_micros()
    var i = 0
    var chk = 0
    while i < iters:
        var ch = 0
        while ch < range:
            if c_is_digit(ch):
                chk = chk + 1
            ch = ch + 1
        i = i + 1
    val elapsed = rt_time_now_unix_micros() - start
    report("is_digit", iters * range, elapsed, chk)
    chk

fn bench_is_upper() -> i64:
    val iters = iters_count()
    val range = ascii_range()
    val start = rt_time_now_unix_micros()
    var i = 0
    var chk = 0
    while i < iters:
        var ch = 0
        while ch < range:
            if c_is_upper(ch):
                chk = chk + 1
            ch = ch + 1
        i = i + 1
    val elapsed = rt_time_now_unix_micros() - start
    report("is_upper", iters * range, elapsed, chk)
    chk

fn bench_is_lower() -> i64:
    val iters = iters_count()
    val range = ascii_range()
    val start = rt_time_now_unix_micros()
    var i = 0
    var chk = 0
    while i < iters:
        var ch = 0
        while ch < range:
            if c_is_lower(ch):
                chk = chk + 1
            ch = ch + 1
        i = i + 1
