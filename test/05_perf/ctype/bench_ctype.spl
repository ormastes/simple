# Microbenchmark: pure Simple ctype vs C runtime ctype
# Run: bin/simple run test/perf/ctype/bench_ctype.spl
# For native-compiled comparison: bin/simple build && ./build/bench_ctype (see bench_ctype_ref.c)

use std.common.ctype

extern fn rt_time_now_unix_micros() -> i64

# --- iteration counts (module-level to avoid interpreter var-mutation issues) ---

fn iters_count() -> i64:
    1000

fn ascii_range() -> i64:
    128

# --- report helper ---

fn report(bench: text, ops: i64, micros_in: i64, checksum: i64):
    var micros = micros_in
    if micros <= 0:
        micros = 1
    val ops_per_ms = (ops * 1000) / micros
    print "[ctypebench] lang=simple bench={bench} ops={ops} micros={micros} ops_per_ms={ops_per_ms} checksum={checksum}"

# --- individual bench functions (module-level so var mutations persist) ---

fn bench_is_digit() -> i64:
    val iters = iters_count()
    val range = ascii_range()
    val start = rt_time_now_unix_micros()
    var i = 0
    var chk = 0
    while i < iters:
        var ch = 0
        while ch < range:
            if ctype.is_digit(ch):
                chk = chk + 1
            ch = ch + 1
        i = i + 1
    val elapsed = rt_time_now_unix_micros() - start
    report("is_digit", iters * range, elapsed, chk)
    chk

fn bench_is_upper() -> i64:
    val iters = iters_count()
    val range = ascii_range()
    val start = rt_time_now_unix_micros()
    var i = 0
    var chk = 0
    while i < iters:
        var ch = 0
        while ch < range:
            if ctype.is_upper(ch):
                chk = chk + 1
            ch = ch + 1
        i = i + 1
    val elapsed = rt_time_now_unix_micros() - start
    report("is_upper", iters * range, elapsed, chk)
    chk

