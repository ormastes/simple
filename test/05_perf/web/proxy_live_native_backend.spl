# Native loopback backend for cached proxy throughput evidence.

extern fn rt_io_tcp_bind(addr: text) -> i64
extern fn rt_io_tcp_listen(fd: i64, backlog: i64) -> i64
extern fn rt_io_tcp_accept(fd: i64) -> i64
extern fn rt_io_tcp_read_line(fd: i64) -> text?
extern fn rt_io_tcp_write_text(fd: i64, data: text) -> i64
extern fn rt_io_tcp_close(fd: i64) -> bool

val NATIVE_PROXY_BACKEND_ADDR: text = "127.0.0.1:18191"
val NATIVE_PROXY_BENCH_ITERS: i64 = 50

fn native_backend_drain_headers(fd: i64):
    var done = false
    while not done:
        val line = rt_io_tcp_read_line(fd)
        if line == nil:
            done = true
        else:
            val text_line = line as text
            if text_line == "" or text_line == "\n" or text_line == "\r\n":
                done = true

fn main():
    val listener = rt_io_tcp_bind(NATIVE_PROXY_BACKEND_ADDR)
    if listener < 0:
        print "[simple-proxy-native-backend-error] bind"
        return
    val listening = rt_io_tcp_listen(listener, 8)
    if listening <= 0:
        val _listener_closed = rt_io_tcp_close(listener)
        print "[simple-proxy-native-backend-error] listen"
        return

    print "[simple-proxy-native-backend-ready] addr={NATIVE_PROXY_BACKEND_ADDR} requests={NATIVE_PROXY_BENCH_ITERS}"
    val fd = rt_io_tcp_accept(listener)
    if fd < 0:
        val _listener_closed = rt_io_tcp_close(listener)
        print "[simple-proxy-native-backend-error] accept"
        return

    val response = "HTTP/1.1 200 OK\r\nServer: SimpleNativeProxyBackend\r\nContent-Type: text/plain\r\nContent-Length: 3\r\nConnection: keep-alive\r\n\r\nok\n"
    var served: i64 = 0
    var done = false
    while served < NATIVE_PROXY_BENCH_ITERS and not done:
        val request_line = rt_io_tcp_read_line(fd)
        if request_line == nil:
            done = true
        else:
            native_backend_drain_headers(fd)
            val written = rt_io_tcp_write_text(fd, response)
            if written <= 0:
                done = true
            else:
                served = served + 1

    val _closed = rt_io_tcp_close(fd)
    val _listener_closed = rt_io_tcp_close(listener)
    print "[simple-proxy-native-backend-done] served={served}"
