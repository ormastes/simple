# Native real HttpServer static fixture for live socket baseline evidence.

use std.http_server.server.{HttpServer}
use std.http_server.types.{LocationConfig, default_server_config}

val LIVE_STATIC_LISTEN: text = "0.0.0.0:18195"

fn main():
    var config = default_server_config()
    config.listen_addr = LIVE_STATIC_LISTEN
    config.worker_count = 1
    config.max_connections = 128
    config.keepalive_timeout_ms = 5000
    config.read_timeout_ms = 5000
    config.write_timeout_ms = 5000
    config.idle_timeout_ms = 5000
    config.drain_timeout_ms = 1000
    config.locations = [
        LocationConfig(
            pattern: "/",
            match_type: "prefix",
            handler_type: "static",
            root: "/tmp/simple-live-static",
            proxy_pass: "",
            middlewares: []
        )
    ]

    print "[simple-httpserver-static-ready] addr={LIVE_STATIC_LISTEN}"
    var server = HttpServer.new(config)
    val result = server.start()
    match result:
        Ok(_):
            print "[simple-httpserver-static-stopped]"
        Err(_):
            print "[simple-httpserver-static-error] start"
