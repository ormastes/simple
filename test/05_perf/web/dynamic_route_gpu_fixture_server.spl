# GPU-tagged dynamic route fixture for external web comparison rows.

extern fn rt_io_tcp_bind(addr: text) -> i64
extern fn rt_io_tcp_listen(fd: i64, backlog: i64) -> i64
extern fn rt_io_tcp_accept(fd: i64) -> i64
extern fn rt_io_tcp_read_line(fd: i64) -> text?
extern fn rt_io_tcp_write_text(fd: i64, data: text) -> i64
extern fn rt_io_tcp_close(fd: i64) -> bool

val DYNAMIC_GPU_FIXTURE_ADDR: text = "0.0.0.0:8080"
val DYNAMIC_FIXTURE_MAX_REQUESTS: i64 = 20000

fn drain_headers(fd: i64):
    var done = false
    while not done:
        val line = rt_io_tcp_read_line(fd)
        if line == nil:
            done = true
        else:
            val text_line = line as text
            if text_line == "" or text_line == "\n" or text_line == "\r\n":
                done = true

fn write_response(fd: i64, body: text, content_type: text, evidence: text):
    val length = body.len()
    val response = "HTTP/1.1 200 OK\r\nServer: SimpleDynamicGpuFixture\r\nContent-Type: {content_type}\r\nX-Simple-GPU-Evidence: {evidence}\r\nContent-Length: {length}\r\nConnection: close\r\n\r\n{body}"
    val _written = rt_io_tcp_write_text(fd, response)

fn handle_client(fd: i64):
    val request_line = rt_io_tcp_read_line(fd)
    if request_line == nil:
        return
    val line = request_line as text
    drain_headers(fd)
    if line.contains("/json"):
        write_response(fd, "{\"route\":\"dynamic_gpu_json\",\"gpu_hits\":0,\"cpu_fallbacks\":1,\"evidence\":\"cpu_fallback_fixture\"}\n", "application/json", "gpu_hits=0;cpu_fallbacks=1;fixture=dynamic_gpu_json")
    else:
        write_response(fd, "dynamic gpu plaintext cpu_fallback_fixture gpu_hits=0 cpu_fallbacks=1\n", "text/plain", "gpu_hits=0;cpu_fallbacks=1;fixture=dynamic_gpu_plaintext")

fn main():
    val listener = rt_io_tcp_bind(DYNAMIC_GPU_FIXTURE_ADDR)
    if listener < 0:
        print "[simple-dynamic-gpu-fixture-error] bind"
        return
    val listening = rt_io_tcp_listen(listener, 128)
    if listening <= 0:
        val _listener_closed = rt_io_tcp_close(listener)
        print "[simple-dynamic-gpu-fixture-error] listen"
        return

    print "[simple-dynamic-gpu-fixture-ready] addr={DYNAMIC_GPU_FIXTURE_ADDR} requests={DYNAMIC_FIXTURE_MAX_REQUESTS} gpu_hits=0 cpu_fallbacks=1"
    var served: i64 = 0
    while served < DYNAMIC_FIXTURE_MAX_REQUESTS:
        val fd = rt_io_tcp_accept(listener)
        if fd >= 0:
            handle_client(fd)
            val _closed = rt_io_tcp_close(fd)
            served = served + 1

    val _listener_closed = rt_io_tcp_close(listener)
    print "[simple-dynamic-gpu-fixture-done] served={served}"
