# CPU oracle dynamic route fixture for external web comparison rows.

extern fn rt_io_tcp_bind(addr: text) -> i64
extern fn rt_io_tcp_listen(fd: i64, backlog: i64) -> i64
extern fn rt_io_tcp_accept(fd: i64) -> i64
extern fn rt_io_tcp_read_line(fd: i64) -> text?
extern fn rt_io_tcp_write_text(fd: i64, data: text) -> i64
extern fn rt_io_tcp_close(fd: i64) -> bool

val DYNAMIC_CPU_FIXTURE_ADDR: text = "0.0.0.0:8081"
val DYNAMIC_FIXTURE_MAX_REQUESTS: i64 = 20000

fn drain_headers(fd: i64):
    var done = false
    while not done:
        val line = rt_io_tcp_read_line(fd)
        if line == nil:
            done = true
        else:
            val text_line = line as text
            if text_line == "" or text_line == "\n" or text_line == "\r\n":
                done = true

fn write_response(fd: i64, body: text, content_type: text):
    val length = body.len()
    val response = "HTTP/1.1 200 OK\r\nServer: SimpleDynamicCpuFixture\r\nContent-Type: {content_type}\r\nX-Simple-CPU-Oracle: true\r\nContent-Length: {length}\r\nConnection: close\r\n\r\n{body}"
    val _written = rt_io_tcp_write_text(fd, response)

fn handle_client(fd: i64):
    val request_line = rt_io_tcp_read_line(fd)
    if request_line == nil:
        return
    val line = request_line as text
    drain_headers(fd)
    if line.contains("/json"):
        write_response(fd, "{\"route\":\"dynamic_cpu_json\",\"oracle\":\"cpu\"}\n", "application/json")
    else:
        write_response(fd, "dynamic cpu plaintext oracle\n", "text/plain")

fn main():
    val listener = rt_io_tcp_bind(DYNAMIC_CPU_FIXTURE_ADDR)
    if listener < 0:
        print "[simple-dynamic-cpu-fixture-error] bind"
        return
    val listening = rt_io_tcp_listen(listener, 128)
    if listening <= 0:
        val _listener_closed = rt_io_tcp_close(listener)
        print "[simple-dynamic-cpu-fixture-error] listen"
        return

    print "[simple-dynamic-cpu-fixture-ready] addr={DYNAMIC_CPU_FIXTURE_ADDR} requests={DYNAMIC_FIXTURE_MAX_REQUESTS}"
    var served: i64 = 0
    while served < DYNAMIC_FIXTURE_MAX_REQUESTS:
        val fd = rt_io_tcp_accept(listener)
        if fd >= 0:
            handle_client(fd)
            val _closed = rt_io_tcp_close(fd)
            served = served + 1

    val _listener_closed = rt_io_tcp_close(listener)
    print "[simple-dynamic-cpu-fixture-done] served={served}"
