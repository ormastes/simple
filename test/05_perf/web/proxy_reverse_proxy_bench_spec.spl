use std.spec.*
use std.http_server.types.{HttpRequestData, LocationConfig, UpstreamConfig, UpstreamServer, LoadBalanceStrategy}
use std.http_server.proxy.*
use std.nogc_sync_mut.http_server.types.{HttpRequest, HttpMethod}
use std.nogc_sync_mut.http_server.proxy.*

"""
# Reverse Proxy Production Benchmark Evidence

## Overview

This host-safe performance spec records deterministic benchmark rows for the
production reverse-proxy helper path. It exercises route planning, upstream
request serialization, response dechunk/forward policy, pooling, backpressure,
and sync helper parity without opening sockets or claiming native throughput.

## Requirements

**Requirements:** doc/02_requirements/nfr/gpu_web_db_offload.md

- Proxy benchmark evidence must report latency-shaped rows before production
  proxy throughput claims.
- CPU-owned proxy control-plane work remains separate from GPU/offload metrics.
- Large-response helpers must expose response bytes and backpressure state.

## Plan

**Plan:** doc/03_plan/agent_tasks/gpu_web_db_offload_impl_status.md

## Design

**Design:** doc/05_design/gpu_web_db_offload.md

## Research

**Research:** doc/01_research/local/gpu_web_db_offload.md
"""

extern fn rt_time_now_unix_micros() -> i64

val PROXY_BENCH_ITERS: i64 = 100

struct ProxyBenchRow:
    name: text
    mode: text
    metric: text
    value_us: i64
    iterations: i64
    request_bytes: i64
    response_bytes: i64
    upstream_reuse: i64
    backpressure_pauses: i64
    errors: i64

fn async_bench_location(proxy_pass: text) -> LocationConfig:
    LocationConfig(
        pattern: "/api/",
        match_type: "prefix",
        handler_type: "proxy",
        root: "",
        proxy_pass: proxy_pass,
        middlewares: []
    )

fn async_bench_request(method: text, path: text, query: text,
                       headers: [(text, text)], body: text) -> HttpRequestData:
    HttpRequestData(
        method: method,
        path: path,
        query: query,
        version: "HTTP/1.1",
        headers: headers,
        body: body,
        params: {},
        peer_addr: "10.0.0.8"
    )

fn async_bench_upstream() -> UpstreamConfig:
    UpstreamConfig(
        name: "backend",
        servers: [
            UpstreamServer(addr: "127.0.0.1:3000", weight: 1, max_fails: 0, fail_timeout_ms: 0),
            UpstreamServer(addr: "127.0.0.1:3001", weight: 1, max_fails: 0, fail_timeout_ms: 0)
        ],
        strategy: LoadBalanceStrategy.RoundRobin,
        health_check_interval_ms: 0,
        health_check_max_probes: 1
    )

fn sync_bench_request(method: HttpMethod, path: text, query: text,
                      headers: [(text, text)], body: text) -> HttpRequest:
    HttpRequest(
        method: method,
        path: path,
        query: query,
        version: "HTTP/1.1",
        headers: headers,
        body: body,
        remote_addr: "10.0.0.7"
    )

fn proxy_bench_row(name: text, mode: text, metric: text, elapsed_us: i64,
                   request_bytes: i64, response_bytes: i64, upstream_reuse: i64,
                   backpressure_pauses: i64, errors: i64) -> ProxyBenchRow:
    val value = if elapsed_us > 0: elapsed_us else: 1
    ProxyBenchRow(
        name: name,
        mode: mode,
        metric: metric,
        value_us: value,
        iterations: PROXY_BENCH_ITERS,
        request_bytes: request_bytes,
        response_bytes: response_bytes,
        upstream_reuse: upstream_reuse,
        backpressure_pauses: backpressure_pauses,
        errors: errors
    )

fn make_async_proxy_policy_row() -> ProxyBenchRow:
    val loc = async_bench_location("backend")
    val upstreams = [async_bench_upstream()]
    val started = rt_time_now_unix_micros()
    var request_bytes: i64 = 0
    var response_bytes: i64 = 0
    var upstream_reuse: i64 = 0
    var pauses: i64 = 0
    var errors: i64 = 0
    var i: i64 = 0
    while i < PROXY_BENCH_ITERS:
        val req = async_bench_request(
            "GET",
            "/api/items",
            "page=1",
            [("Host", "public.example"), ("Accept", "application/json")],
            ""
        )
        val plan = async_proxy_plan(loc, req, upstreams, i)
        if plan.ok:
            val wire = async_proxy_serialize_request(req, plan.upstream_addr)
            request_bytes = request_bytes + wire.len()
            var conn = async_proxy_connection(10, plan.upstream_addr, wire, i)
            conn.upstream_fd = 20
            val first = async_proxy_prepare_client_chunk(
                conn,
                "HTTP/1.1 200 OK\r\nTransfer-Encoding: chunked\r\nContent-Type: text/plain\r\n\r\n2\r\nok\r\n0\r\n\r\n",
                i + 1
            )
            response_bytes = response_bytes + first.body_bytes_forwarded
            if async_proxy_response_reusable(first):
                upstream_reuse = upstream_reuse + 1
            if not async_proxy_should_recv_upstream(first):
                pauses = pauses + 1
        else:
            errors = errors + 1
        i = i + 1
    val finished = rt_time_now_unix_micros()
    proxy_bench_row("async_proxy_policy_100", "async", "latency_us", finished - started,
                    request_bytes, response_bytes, upstream_reuse, pauses, errors)

fn make_async_proxy_request_stream_row() -> ProxyBenchRow:
    val started = rt_time_now_unix_micros()
    var request_bytes: i64 = 0
    var pauses: i64 = 0
    var errors: i64 = 0
    var i: i64 = 0
    while i < PROXY_BENCH_ITERS:
        val req = async_bench_request(
            "POST",
            "/api/upload",
            "",
            [("Content-Length", "10"), ("Content-Type", "text/plain")],
            ""
        )
        val stream = async_proxy_request_body_stream_begin(req, "127.0.0.1:3000", 8)
        val first = async_proxy_request_stream_receive_fixed(stream, "hello")
        if not async_proxy_should_recv_client_body(first):
            pauses = pauses + 1
        val drained = async_proxy_request_stream_mark_upstream_sent(first, 5)
        val done = async_proxy_request_stream_receive_fixed(drained, "world")
        if done.valid and done.complete:
            request_bytes = request_bytes + done.header_wire.len() + done.bytes_received
        else:
            errors = errors + 1
        i = i + 1
    val finished = rt_time_now_unix_micros()
    proxy_bench_row("async_proxy_request_stream_100", "async", "latency_us", finished - started,
                    request_bytes, 0, 0, pauses, errors)

fn make_async_proxy_tunnel_row() -> ProxyBenchRow:
    val loc = async_bench_location("backend")
    val upstreams = [async_bench_upstream()]
    val started = rt_time_now_unix_micros()
    var request_bytes: i64 = 0
    var response_bytes: i64 = 0
    var pauses: i64 = 0
    var errors: i64 = 0
    var i: i64 = 0
    while i < PROXY_BENCH_ITERS:
        val req = async_bench_request(
            "GET",
            "/api/ws",
            "",
            [
                ("Host", "public.example"),
                ("Connection", "keep-alive, Upgrade"),
                ("Upgrade", "websocket"),
                ("Sec-WebSocket-Key", "bench")
            ],
            ""
        )
        val plan = async_proxy_tunnel_plan(loc, req, upstreams, i)
        if plan.ok:
            val setup = async_proxy_serialize_tunnel_request(req, plan.upstream_addr)
            request_bytes = request_bytes + setup.len()
            var tunnel = async_proxy_tunnel_connection(10, 20, plan.upstream_addr, plan.tunnel_kind, setup, i)
            tunnel = async_proxy_tunnel_mark_setup_sent(tunnel, setup.len(), i + 1)
            val response = "HTTP/1.1 101 Switching Protocols\r\nUpgrade: websocket\r\nConnection: Upgrade\r\n\r\n"
            val prepared = async_proxy_tunnel_prepare_upstream_handshake(
                tunnel,
                response,
                [72, 84, 84, 80, 47, 49, 46, 49, 32, 49, 48, 49, 32, 83, 119, 105, 116, 99, 104, 105, 110, 103, 32, 80, 114, 111, 116, 111, 99, 111, 108, 115, 13, 10, 85, 112, 103, 114, 97, 100, 101, 58, 32, 119, 101, 98, 115, 111, 99, 107, 101, 116, 13, 10, 67, 111, 110, 110, 101, 99, 116, 105, 111, 110, 58, 32, 85, 112, 103, 114, 97, 100, 101, 13, 10, 13, 10],
                i + 2
            )
            if prepared.upstream_handshake_valid and prepared.upstream_handshake_complete:
                response_bytes = response_bytes + prepared.pending_upstream_to_client.len()
                val drained = async_proxy_tunnel_mark_upstream_data_sent(prepared, response.len(), i + 3)
                if async_proxy_tunnel_should_recv_client(drained):
                    pauses = pauses + 1
            else:
                errors = errors + 1
        else:
            errors = errors + 1
        i = i + 1
    val finished = rt_time_now_unix_micros()
    proxy_bench_row("async_proxy_tunnel_handshake_100", "async", "latency_us", finished - started,
                    request_bytes, response_bytes, 0, pauses, errors)

fn make_async_proxy_hardening_evidence_row() -> ProxyBenchRow:
    val started = rt_time_now_unix_micros()
    var request_bytes: i64 = 0
    var response_bytes: i64 = 0
    var pool_pressure: i64 = 0
    var pressure_signals: i64 = 0
    var errors: i64 = 0
    var i: i64 = 0
    while i < PROXY_BENCH_ITERS:
        var healthy = async_proxy_connection_with_limits(
            10,
            "127.0.0.1:3000",
            "GET / HTTP/1.1\r\n\r\n",
            i,
            1024,
            4096,
            50,
            500
        )
        healthy.upstream_fd = 20
        healthy.bytes_from_upstream = 2048
        healthy.last_activity_ms = i + 1
        val empty_stream = async_proxy_request_stream("POST / HTTP/1.1\r\n\r\n", 0, false, 8)
        val ok = async_proxy_connection_production_hardening(
            healthy,
            empty_stream,
            [],
            async_proxy_pool_default_config(),
            i + 100
        )
        if ok.ok and ok.reason == "ok":
            response_bytes = response_bytes + ok.throughput_bytes_per_sec
        else:
            errors = errors + 1

        val timeout = async_proxy_connection_production_hardening(
            async_proxy_connection_with_limits(11, "127.0.0.1:3000", "GET / HTTP/1.1\r\n\r\n", i, 1024, 4096, 50, 500),
            empty_stream,
            [],
            async_proxy_pool_default_config(),
            i + 51
        )
        if timeout.timed_out and timeout.reason == "timeout":
            pressure_signals = pressure_signals + 1
        else:
            errors = errors + 1

        var upload_stream = async_proxy_request_stream("POST / HTTP/1.1\r\n\r\n", 10, false, 4)
        upload_stream.pending_upstream_data = "abcdef"
        val request_pressure = async_proxy_connection_production_hardening(healthy, upload_stream, [], async_proxy_pool_default_config(), i + 2)
        if request_pressure.request_backpressure:
            request_bytes = request_bytes + upload_stream.pending_upstream_data.len()
            pressure_signals = pressure_signals + 1
        else:
            errors = errors + 1

        var response_pressure_conn = healthy
        response_pressure_conn.pending_client_data = "abcdef"
        response_pressure_conn.max_pending_client_bytes = 4
        val response_pressure = async_proxy_connection_production_hardening(response_pressure_conn, empty_stream, [], async_proxy_pool_default_config(), i + 2)
        if response_pressure.response_backpressure:
            pressure_signals = pressure_signals + 1
        else:
            errors = errors + 1

        val pool_config = AsyncProxyPoolConfig(max_idle_per_upstream: 1, idle_timeout_ms: 1000, max_reuse_count: 100)
        val pool_pressure_evidence = async_proxy_connection_production_hardening(
            healthy,
            empty_stream,
            [async_proxy_pool_entry("127.0.0.1:3000", 30, i)],
            pool_config,
            i + 1
        )
        if pool_pressure_evidence.pool_stressed:
            pool_pressure = pool_pressure + 1
        else:
            errors = errors + 1
        i = i + 1
    val finished = rt_time_now_unix_micros()
    proxy_bench_row("async_proxy_hardening_evidence_100", "async", "latency_us", finished - started,
                    request_bytes, response_bytes, pool_pressure, pressure_signals, errors)

fn make_sync_proxy_helper_row() -> ProxyBenchRow:
    val route = reverse_proxy_route("/api/", "127.0.0.1:3000")
    val started = rt_time_now_unix_micros()
    var request_bytes: i64 = 0
    var response_bytes: i64 = 0
    var errors: i64 = 0
    var i: i64 = 0
    while i < PROXY_BENCH_ITERS:
        val req = sync_bench_request(
            HttpMethod.Post,
            "/api/items",
            "",
            [("Content-Type", "application/json"), ("Connection", "keep-alive")],
            "{\"name\":\"Ada\"}"
        )
        if reverse_proxy_matches_request(route, req):
            val wire = reverse_proxy_serialize_request(req, route)
            request_bytes = request_bytes + wire.len()
            if reverse_proxy_response_header_allowed("Content-Type: text/plain", route, 1):
                response_bytes = response_bytes + 2
        else:
            errors = errors + 1
        i = i + 1
    val finished = rt_time_now_unix_micros()
    proxy_bench_row("sync_proxy_helper_100", "sync", "latency_us", finished - started,
                    request_bytes, response_bytes, 0, 0, errors)

describe "reverse proxy production benchmark evidence":
    it "should report host-safe async proxy policy benchmark metrics":
        step("Measure async proxy planning, serialization, dechunking, reuse, and backpressure policy")
        val row = make_async_proxy_policy_row()
        expect(row.name).to_equal("async_proxy_policy_100")
        expect(row.mode).to_equal("async")
        expect(row.metric).to_equal("latency_us")
        expect(row.value_us).to_be_greater_than(0)
        expect(row.iterations).to_equal(PROXY_BENCH_ITERS)
        expect(row.request_bytes).to_be_greater_than(0)
        expect(row.response_bytes).to_equal(PROXY_BENCH_ITERS * 2)
        expect(row.upstream_reuse).to_equal(PROXY_BENCH_ITERS)
        expect(row.backpressure_pauses).to_equal(PROXY_BENCH_ITERS)
        expect(row.errors).to_equal(0)

    it "should report host-safe sync proxy helper benchmark metrics":
        step("Measure sync proxy matching and fixed-length request serialization")
        val row = make_sync_proxy_helper_row()
        expect(row.name).to_equal("sync_proxy_helper_100")
        expect(row.mode).to_equal("sync")
        expect(row.metric).to_equal("latency_us")
        expect(row.value_us).to_be_greater_than(0)
        expect(row.iterations).to_equal(PROXY_BENCH_ITERS)
        expect(row.request_bytes).to_be_greater_than(0)
        expect(row.response_bytes).to_equal(PROXY_BENCH_ITERS * 2)
        expect(row.upstream_reuse).to_equal(0)
        expect(row.backpressure_pauses).to_equal(0)
        expect(row.errors).to_equal(0)

    it "should report host-safe async request streaming benchmark metrics":
        step("Measure fixed request-body streaming, upstream writes, and backpressure policy")
        val row = make_async_proxy_request_stream_row()
        expect(row.name).to_equal("async_proxy_request_stream_100")
        expect(row.mode).to_equal("async")
        expect(row.metric).to_equal("latency_us")
        expect(row.value_us).to_be_greater_than(0)
        expect(row.iterations).to_equal(PROXY_BENCH_ITERS)
        expect(row.request_bytes).to_be_greater_than(PROXY_BENCH_ITERS * 10)
        expect(row.response_bytes).to_equal(0)
        expect(row.upstream_reuse).to_equal(0)
        expect(row.backpressure_pauses).to_equal(PROXY_BENCH_ITERS)
        expect(row.errors).to_equal(0)

    it "should report host-safe async tunnel handshake benchmark metrics":
        step("Measure tunnel planning, setup serialization, upstream 101 validation, and relay readiness")
        val row = make_async_proxy_tunnel_row()
        expect(row.name).to_equal("async_proxy_tunnel_handshake_100")
        expect(row.mode).to_equal("async")
        expect(row.metric).to_equal("latency_us")
        expect(row.value_us).to_be_greater_than(0)
        expect(row.iterations).to_equal(PROXY_BENCH_ITERS)
        expect(row.request_bytes).to_be_greater_than(PROXY_BENCH_ITERS * 80)
        expect(row.response_bytes).to_be_greater_than(PROXY_BENCH_ITERS * 70)
        expect(row.upstream_reuse).to_equal(0)
        expect(row.backpressure_pauses).to_equal(PROXY_BENCH_ITERS)
        expect(row.errors).to_equal(0)

    it "should report host-safe async production hardening benchmark metrics":
        step("Measure timeout, request backpressure, response backpressure, pool pressure, and throughput evidence")
        val row = make_async_proxy_hardening_evidence_row()
        expect(row.name).to_equal("async_proxy_hardening_evidence_100")
        expect(row.mode).to_equal("async")
        expect(row.metric).to_equal("latency_us")
        expect(row.value_us).to_be_greater_than(0)
        expect(row.iterations).to_equal(PROXY_BENCH_ITERS)
        expect(row.request_bytes).to_equal(PROXY_BENCH_ITERS * 6)
        expect(row.response_bytes).to_be_greater_than(0)
        expect(row.upstream_reuse).to_equal(PROXY_BENCH_ITERS)
        expect(row.backpressure_pauses).to_equal(PROXY_BENCH_ITERS * 3)
        expect(row.errors).to_equal(0)
