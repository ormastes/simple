# web_bench_driver.spl — Runnable WEB-domain benchmark driver.
#
# Drives test/05_perf/web/web_smf_workload.spl in BOTH planes:
#   - script: `<simple_bin> run web_smf_workload.spl`              (interpreter)
#   - smf:    `<simple_bin> compile web_smf_workload.spl -o x.smf
#              && <simple_bin> run x.smf`                          (two-step, supported)
# and parses its self-timed `RESULT|<name>|<elapsed_us>|5000` rows.
#
# The web-domain representative ops are the in-memory HTTP parse + serialize
# seam (no socket): http_parse_request_line and http_serialize_response.
# ns/op = elapsed_us * 1000 / 5000.
#
# REAL numbers only — if a capture is empty, that plane's rows are SKIPPED
# (never faked). Modeled on src/app/test/bench/bench_baseline_driver.spl.
#
# Run:  bin/simple run test/05_perf/web/web_bench_driver.spl
#
# Writes:
#   doc/09_report/perf/perf_baseline_web_2026-06-14.md  — dated run report
#   doc/10_metrics/perf/perf_baseline_web_table.md       — persistent table

use app.test.bench.bench_report.{bench_emit_rows}
use app.test.bench.bench_report.{bench_find_simple_bin}
use app.test.bench.bench_report.{bench_script_capture}
use app.test.bench.bench_report.{bench_smf_capture}
use app.test.bench.bench_report.{bench_extract_us}

val ITERS: i64 = 5000

fn _push_plane(names: [text], modes: [text], metrics: [text], values: [i64], units: [text], mode: text, parse_us: i64, serial_us: i64):
    # parse row
    names.push("http_parse_request_line")
    modes.push(mode)
    metrics.push("ns/op")
    values.push((parse_us * 1000) / ITERS)
    units.push("ns/op")
    # serialize row
    names.push("http_serialize_response")
    modes.push(mode)
    metrics.push("ns/op")
    values.push((serial_us * 1000) / ITERS)
    units.push("ns/op")

fn main():
    val date_str = "2026-06-14"
    val arch = "x86_64"

    val report_path = "doc/09_report/perf/perf_baseline_web_2026-06-14.md"
    val table_path  = "doc/10_metrics/perf/perf_baseline_web_table.md"

    val workload = "test/05_perf/web/web_smf_workload.spl"
    val smf_path = "/tmp/web_bench_workload.smf"

    val simple_bin = bench_find_simple_bin()
    if simple_bin.len() == 0:
        print("ERROR: no simple binary found (bin/simple or seed) — cannot run workloads.")
        return

    var names:   [text] = []
    var modes:   [text] = []
    var metrics: [text] = []
    var values:  [i64]  = []
    var units:   [text] = []

    # --- script plane (interpreter) ---
    print("Running web workload (script) ...")
    val script_out = bench_script_capture(simple_bin, workload)
    val sc_parse = bench_extract_us(script_out, "http_parse_request_line")
    val sc_serial = bench_extract_us(script_out, "http_serialize_response")
    if sc_parse > 0 and sc_serial > 0:
        _push_plane(names, modes, metrics, values, units, "script", sc_parse, sc_serial)
        print("  script rows added.")
    else:
        print("  WARN: script rows skipped (capture empty).")

    # --- smf plane (compile -o x.smf && run x.smf) ---
    print("Compiling + running web workload (smf) ...")
    val smf_out = bench_smf_capture(simple_bin, workload, smf_path)
    val smf_parse = bench_extract_us(smf_out, "http_parse_request_line")
    val smf_serial = bench_extract_us(smf_out, "http_serialize_response")
    if smf_parse > 0 and smf_serial > 0:
        _push_plane(names, modes, metrics, values, units, "smf", smf_parse, smf_serial)
        print("  smf rows added.")
    else:
        print("  WARN: smf rows skipped (capture empty) — script rows only.")

    if names.len() == 0:
        print("ERROR: no rows captured in either plane — nothing written.")
        return

    print("Writing web benchmark docs ...")
    val ok = bench_emit_rows(names, modes, metrics, values, units, arch, date_str, report_path, table_path)
    if ok:
        print("Done. Both docs written.")
    else:
        print("ERROR: one or both docs failed to write.")
