"""
# Multicore Green Cross-Language Profile Gate

**Feature IDs:** #green-perf-cross-language-gate
**Category:** Performance / Concurrency
**Status:** Implemented

## Overview

This spec parses the checked-in Docker-isolated cross-language performance report and
keeps the numeric concurrency rows honest. It gates the current Simple
OS-thread and multicore-green native rows against both Go goroutines and C
pthreads while keeping cooperative green classified as a current-carrier
queue, not as Go-style M:N CPU parallelism.

## Requirements

**Requirements:** N/A

## Plan

**Plan:** doc/03_plan/sys_test/multicore_green.md

## Design

**Design:** N/A

## Research

**Research:** doc/01_research/local/multicore_green.md

## Syntax

The parser reads Markdown table rows generated by
`scripts/check/check-cross-language-perf.shs`.

## Examples

- `Simple (native)` in the OS-thread section must currently remain an explicit
  `fail` row until the native `thread_spawn` worker regression is closed.
- `Simple multicore green (native)` is compared to the faster available Go/C
  native baseline with a 4x smoke threshold in the small-worker section and a
  3x smoke threshold in the large-fanout section while the report still proves
  `used_runtime_pool()` evidence.
- The Simple-vs-Go-vs-C stress section must show Go goroutines and Simple
  multicore green both beating one-pthread-per-task C at the same task count.

## TUI Capture

```text
Simple Test Runner v1.0.0-beta
Running: test/05_perf/stress/multicore_green_cross_language_gate_spec.spl
Multicore green cross-language profile gate PASSED
Files: 1
Passed: 3
Failed: 0
```

## Traceability Expectations

- The checked-in Docker contract report must come from
  `scripts/check/check-cross-language-perf.shs`.
- The profile report must keep OS-thread, cooperative-green, multicore-green,
  C pthread, and Go goroutine rows separate.
- The profile report must pin Go `GOMAXPROCS` to `CPU_WORKERS` unless a caller
  explicitly overrides it, so Go and Simple multicore-green rows use the same
  scheduler-width limit.
- `Simple (native)` in the OS-thread worker section must remain the
  `thread_spawn` fork-join row, and the checked-in report currently records that
  native row as `fail`.
- `thread_spawn_with_args` must remain covered by the focused native smoke, not
  by the scheduler/fanout profile row.
- Cooperative green rows must stay labeled as current-carrier cooperative queue
  work.
- Cooperative green rows must not be described as Go-style M:N CPU parallelism.
- Multicore green rows must contain `parallelism=` evidence.
- Multicore green rows must contain `pool_used=` evidence before being used as
  M:N evidence.
- Multicore green rows must contain exactly the work-stealing queue model in
  the generated report contract.
- The large fanout section must include Go and C rows so goroutine fanout can be
  compared with one-pthread-per-task C.
- The Simple-vs-Go-vs-C stress section must include C pthread, Go goroutine, and
  Simple multicore-green native rows at the same stress task count.
- Go stress fanout must beat or match C pthread stress fanout in the smoke gate.
- Simple multicore-green stress fanout must beat C pthread stress fanout in the
  smoke gate.
- Simple multicore-green stress fanout must also carry pool, parallelism, and
  work-stealing evidence so an inline fallback cannot pass the comparison.
- The dated large profile has a stricter companion gate in
  `test/05_perf/stress/multicore_green_large_profile_gate_spec.spl`.
- The shared profile report contract has a shell-level copy of the Go-vs-C and
  Simple-vs-C stress checks so newly generated reports fail before docs drift.

## Verification Expectations

- Run this SSpec after changing the cross-language smoke report, parser helper,
  or profile script.
- Regenerate
  `doc/06_spec/test/05_perf/stress/multicore_green_cross_language_gate_spec.md`
  after changing this SSpec.
- Run `test/05_perf/profile_scripts/profile_report_contract_test.shs` against
  the checked-in smoke report after changing profile report shape.
- Run the same profile report contract against the large dated report when
  changing stress comparison semantics.
- Run the large-profile SSpec when strengthening Simple-vs-C or Go-vs-C fanout
  expectations.
- Run the optimizer app on touched `.spl` files as advisory evidence; do not
  rewrite clear parser helpers solely for low-value test-path micro-optimizers.
"""

use std.spec.{describe, it, expect}

extern fn rt_file_read_text(path: text) -> text

fn section_named(report: text, heading: text) -> text:
    val lines = report.split("\n")
    val line_count = lines.len()
    var active = false
    var out = ""
    var i = 0
    while i < line_count:
        val line = lines[i]
        if line.starts_with("## ") and line.contains(heading):
            active = true
        elif active and line.starts_with("## "):
            return out
        elif active:
            out = out + line + "\n"
        i = i + 1
    out

fn row_for_label(section: text, label: text) -> text:
    val lines = section.split("\n")
    val line_count = lines.len()
    var i = 0
    while i < line_count:
        val line = lines[i]
        if line.starts_with("| ") and line.contains("| {label}"):
            return line
        i = i + 1
    ""

fn cell_at(row: text, index: i64) -> text:
    val parts = row.split("|")
    if index >= 0 and index < parts.len():
        parts[index].trim()
    else:
        ""

fn metric_text(row: text) -> text:
    cell_at(row, 2)

fn model_text(row: text) -> text:
    cell_at(row, 3)

fn millis_scaled(metric: text) -> i64:
    val trimmed = metric.trim()
    if trimmed == "" or trimmed == "n/a" or trimmed == "fail":
        return -1
    val pieces = trimmed.split(".")
    val whole = pieces[0].trim().to_i64() ?? -1
    if whole < 0:
        return -1
    var frac = "000"
    if pieces.len() > 1:
        frac = pieces[1].trim()
    if frac.len() == 0:
        frac = "000"
    elif frac.len() == 1:
        frac = frac + "00"
    elif frac.len() == 2:
        frac = frac + "0"
    elif frac.len() > 3:
        frac = frac.substring(0, 3)
    val frac_value = frac.to_i64() ?? 0
    whole * 1000 + frac_value

fn row_ms_scaled(section: text, label: text) -> i64:
    millis_scaled(metric_text(row_for_label(section, label)))

fn min_positive(a: i64, b: i64) -> i64:
    if a < 0:
        return b
    if b < 0:
        return a
    if a < b:
        a
    else:
        b

fn step(name: text) -> i64:
    name.len()

describe "multicore green cross-language profile gate":
    it "gates multicore-green native rows and preserves explicit OS-thread failure evidence":
        step("Load the checked-in Docker contract report")
        val report = rt_file_read_text("doc/09_report/cross_language_perf_2026-06-08_docker_contract.md") ?? ""
        step("Select the OS-thread parallel worker section")
        val parallel = section_named(report, "OS Thread Parallel Workers")

        step("Read Simple, multicore-green, Go, and C worker timings")
        val simple_os = row_ms_scaled(parallel, "Simple (native)")
        val multicore = row_ms_scaled(parallel, "Simple multicore green (native)")
        val go_ms = row_ms_scaled(parallel, "Go")
        val c_ms = row_ms_scaled(parallel, "C (pthreads)")
        val native_baseline = min_positive(go_ms, c_ms)

        step("Verify the checked-in contract keeps the OS-thread native row as an explicit fail")
        expect(metric_text(row_for_label(parallel, "Simple (native)"))).to_equal("fail")
        expect(model_text(row_for_label(parallel, "Simple (native)"))).to_contain("thread_spawn fork-join OS threads")

        step("Verify multicore-green, Go, and C worker rows have positive timing evidence")
        expect(multicore).to_be_greater_than(0)
        expect(go_ms).to_be_greater_than(0)
        expect(c_ms).to_be_greater_than(0)
        step("Verify multicore-green stays inside the current native smoke threshold")
        expect(multicore).to_be_less_than(native_baseline * 4 + 1)
        step("Verify concurrency model labels preserve semantic distinctions")
        expect(model_text(row_for_label(parallel, "Simple cooperative green (native)"))).to_contain("cooperative")
        expect(model_text(row_for_label(parallel, "Simple multicore green (native)"))).to_contain("parallelism=")
        expect(report).to_contain("Go GOMAXPROCS:** 2")
        expect(report).to_contain("Go scheduler: `GOMAXPROCS=2")
        expect(report).to_contain("not a Go M:N goroutine equivalent")
        expect(report).to_contain("used_runtime_pool()")

    it "gates large fanout rows against Go goroutine and C pthread fanout":
        step("Load the checked-in Docker contract report")
        val report = rt_file_read_text("doc/09_report/cross_language_perf_2026-06-08_docker_contract.md") ?? ""
        step("Select the large fanout scheduling section")
        val fanout = section_named(report, "Large Fanout Scheduling")

        step("Read Simple, multicore-green, Go, and C fanout timings")
        val simple_os = row_ms_scaled(fanout, "Simple (native)")
        val multicore = row_ms_scaled(fanout, "Simple multicore green (native)")
        val go_ms = row_ms_scaled(fanout, "Go")
        val c_ms = row_ms_scaled(fanout, "C (pthreads)")
        val native_baseline = min_positive(go_ms, c_ms)

        step("Verify the checked-in contract keeps the OS-thread fanout native row as an explicit fail")
        expect(metric_text(row_for_label(fanout, "Simple (native)"))).to_equal("fail")
        expect(model_text(row_for_label(fanout, "Simple (native)"))).to_contain("checksum mismatch")

        step("Verify multicore-green, Go, and C fanout rows have positive timing evidence")
        expect(multicore).to_be_greater_than(0)
        expect(go_ms).to_be_greater_than(0)
        expect(c_ms).to_be_greater_than(0)
        step("Verify multicore-green fanout stays inside the native smoke threshold")
        expect(multicore).to_be_less_than(native_baseline * 3 + 1)
        step("Verify fanout model labels are explicit")
        expect(model_text(row_for_label(fanout, "C (pthreads)"))).to_contain("one OS thread per tiny task")
        expect(model_text(row_for_label(fanout, "Go"))).to_contain("goroutine per tiny task + channel")
        expect(model_text(row_for_label(fanout, "Simple cooperative green (native)"))).to_contain("cooperative queue fanout")
        expect(model_text(row_for_label(fanout, "Simple multicore green (native)"))).to_contain("parallelism=")

    it "proves large-fanout multicore-green evidence and goroutine stress behavior":
        step("Load the checked-in Docker contract report")
        val report = rt_file_read_text("doc/09_report/cross_language_perf_2026-06-08_docker_contract.md") ?? ""
        step("Select the Simple versus Go versus C stress section")
        val stress = section_named(report, "Simple vs Go vs C Large Fanout Stress")

        step("Read stress fanout timings")
        val simple_multicore = row_ms_scaled(stress, "Simple multicore green (native)")
        val go_ms = row_ms_scaled(stress, "Go")
        val c_ms = row_ms_scaled(stress, "C (pthreads)")

        step("Verify stress rows have positive timing evidence")
        expect(simple_multicore).to_be_greater_than(0)
        expect(go_ms).to_be_greater_than(0)
        expect(c_ms).to_be_greater_than(0)
        step("Verify Go beats or matches C pthread stress fanout")
        expect(go_ms).to_be_less_than(c_ms + 1)
        step("Verify Simple multicore-green beats C pthread stress fanout")
        expect(simple_multicore).to_be_less_than(c_ms)
        step("Verify stress row model labels prove runtime-pool and queue evidence")
        expect(model_text(row_for_label(stress, "Simple multicore green (native)"))).to_contain("multicore_green stress fanout")
        expect(model_text(row_for_label(stress, "Simple multicore green (native)"))).to_contain("pool_used=")
        expect(model_text(row_for_label(stress, "Simple multicore green (native)"))).to_contain("parallelism=")
        expect(model_text(row_for_label(stress, "Simple multicore green (native)"))).to_contain("queue_model=work_stealing")
        expect(model_text(row_for_label(stress, "Go"))).to_contain("goroutine per stress task")
        expect(model_text(row_for_label(stress, "C (pthreads)"))).to_contain("pthread per stress task")
