"""
# Multicore Green Fanout Stress Specification

**Feature IDs:** #green-perf-fanout
**Category:** Performance / Concurrency
**Status:** Implemented

## Overview

This perf stress spec keeps the Simple concurrency rows comparable: OS threads,
cooperative green, and multicore green all run the same deterministic fanout
workload and must produce the same checksum. The multicore-green row separately
reports runtime-pool and work-stealing evidence, so inline fallback or a single
FIFO queue cannot be mistaken for Go-like M:N CPU-parallel evidence.

## Requirements

**Requirements:** N/A

## Plan

**Plan:** doc/03_plan/sys_test/multicore_green.md

## Design

**Design:** N/A

## Research

**Research:** doc/01_research/local/multicore_green.md
"""

use std.spec.{describe, slow_it, expect}
use std.concurrent.thread.{thread_spawn}
use std.concurrent.cooperative_green.{cooperative_green_spawn_value, cooperative_green_run_all}
use std.concurrent.multicore_green.{multicore_green_spawn, multicore_green_uses_global_fifo_queue, multicore_green_uses_work_stealing}
extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_delete(path: text) -> bool
extern fn rt_getpid() -> i64
extern fn rt_time_now_unix_micros() -> i64

fn fanout_work(seed: i64, iterations: i64) -> i64:
    var x = seed + 1
    var i = 0
    while i < iterations:
        x = (x * 1103515245 + 12345) % 2147483648
        i = i + 1
    x

fn fanout_expected(worker_count: i64, iterations: i64) -> i64:
    var total = 0
    var worker = 0
    while worker < worker_count:
        total = total + fanout_work(worker, iterations)
        worker = worker + 1
    total

fn step(name: text) -> i64:
    name.len()

fn repo_root() -> text:
    val (stdout, _stderr, code) = rt_process_run("/bin/sh", ["-c", "pwd"])
    if code == 0:
        return stdout.trim()
    "."

fn unique_probe_path(tag: text) -> text:
    "{repo_root()}/build/tmp/{tag}_{rt_getpid().to_text()}_{rt_time_now_unix_micros().to_text()}.spl"

fn run_probe(path: text, source: text) -> (text, text, i64):
    if not rt_file_write_text(path, source):
        return ("", "probe_write_failed", 98)
    val binary = "{repo_root()}/src/compiler_rust/target/debug/simple"
    val result = rt_process_run("/usr/bin/env", [
        "-i",
        "PATH=/usr/bin:/bin",
        "HOME=" + repo_root(),
        binary,
        "run",
        path
    ])
    val _deleted = rt_file_delete(path)
    result

fn thread_probe_source() -> text:
    "use std.concurrent.thread.{{thread_spawn}}\n" +
    "extern fn rt_exit(code: i64)\n" +
    "fn fanout_work(seed: i64, iterations: i64) -> i64:\n" +
    "    var x = seed + 1\n" +
    "    var i = 0\n" +
    "    while i < iterations:\n" +
    "        x = (x * 1103515245 + 12345) % 2147483648\n" +
    "        i = i + 1\n" +
    "    x\n" +
    "fn fanout_expected(worker_count: i64, iterations: i64) -> i64:\n" +
    "    var total = 0\n" +
    "    var worker = 0\n" +
    "    while worker < worker_count:\n" +
    "        total = total + fanout_work(worker, iterations)\n" +
    "        worker = worker + 1\n" +
    "    total\n" +
    "fn worker0() -> i64: fanout_work(0, 512)\n" +
    "fn worker1() -> i64: fanout_work(1, 512)\n" +
    "fn worker2() -> i64: fanout_work(2, 512)\n" +
    "fn worker3() -> i64: fanout_work(3, 512)\n" +
    "fn worker4() -> i64: fanout_work(4, 512)\n" +
    "fn worker5() -> i64: fanout_work(5, 512)\n" +
    "fn worker6() -> i64: fanout_work(6, 512)\n" +
    "fn worker7() -> i64: fanout_work(7, 512)\n" +
    "fn main() -> i64:\n" +
    "    val expected = fanout_expected(8, 512)\n" +
    "    val h0 = thread_spawn(worker0)\n" +
    "    val h1 = thread_spawn(worker1)\n" +
    "    val h2 = thread_spawn(worker2)\n" +
    "    val h3 = thread_spawn(worker3)\n" +
    "    val h4 = thread_spawn(worker4)\n" +
    "    val h5 = thread_spawn(worker5)\n" +
    "    val h6 = thread_spawn(worker6)\n" +
    "    val h7 = thread_spawn(worker7)\n" +
    "    val got = h0.join() + h1.join() + h2.join() + h3.join() + h4.join() + h5.join() + h6.join() + h7.join()\n" +
    "    if got != expected:\n" +
    "        rt_exit(11)\n" +
    "    rt_exit(0)\n" +
    "    0\n"

fn cooperative_probe_source() -> text:
    "use std.concurrent.cooperative_green.{{cooperative_green_spawn_value, cooperative_green_run_all}}\n" +
    "extern fn rt_exit(code: i64)\n" +
    "fn fanout_work(seed: i64, iterations: i64) -> i64:\n" +
    "    var x = seed + 1\n" +
    "    var i = 0\n" +
    "    while i < iterations:\n" +
    "        x = (x * 1103515245 + 12345) % 2147483648\n" +
    "        i = i + 1\n" +
    "    x\n" +
    "fn fanout_expected(worker_count: i64, iterations: i64) -> i64:\n" +
    "    var total = 0\n" +
    "    var worker = 0\n" +
    "    while worker < worker_count:\n" +
    "        total = total + fanout_work(worker, iterations)\n" +
    "        worker = worker + 1\n" +
    "    total\n" +
    "fn main() -> i64:\n" +
    "    val expected = fanout_expected(8, 512)\n" +
    "    val h0 = cooperative_green_spawn_value(fanout_work(0, 512))\n" +
    "    val h1 = cooperative_green_spawn_value(fanout_work(1, 512))\n" +
    "    val h2 = cooperative_green_spawn_value(fanout_work(2, 512))\n" +
    "    val h3 = cooperative_green_spawn_value(fanout_work(3, 512))\n" +
    "    val h4 = cooperative_green_spawn_value(fanout_work(4, 512))\n" +
    "    val h5 = cooperative_green_spawn_value(fanout_work(5, 512))\n" +
    "    val h6 = cooperative_green_spawn_value(fanout_work(6, 512))\n" +
    "    val h7 = cooperative_green_spawn_value(fanout_work(7, 512))\n" +
    "    val ran = cooperative_green_run_all()\n" +
    "    val got = h0.join() + h1.join() + h2.join() + h3.join() + h4.join() + h5.join() + h6.join() + h7.join()\n" +
    "    if ran <= 7:\n" +
    "        rt_exit(12)\n" +
    "    if got != expected:\n" +
    "        rt_exit(13)\n" +
    "    rt_exit(0)\n" +
    "    0\n"

fn multicore_queue_model() -> text:
    if multicore_green_uses_work_stealing():
        "work_stealing"
    elif multicore_green_uses_global_fifo_queue():
        "global_fifo"
    else:
        "inline_or_unavailable"

describe "multicore green fanout stress":
    slow_it "matches OS-thread fanout/fanin checksum":
        step("Write and run the OS-thread fanout probe through direct simple run")
        val probe_path = unique_probe_path("mcg_thread_fanout")
        val (stdout, stderr, code) = run_probe(probe_path, thread_probe_source())
        expect(stderr).to_equal("")
        expect(stdout.trim()).to_equal("")
        expect(code).to_equal(0)

    slow_it "matches cooperative-green fanout checksum on the current carrier":
        step("Write and run the cooperative-green fanout probe through direct simple run")
        val probe_path = unique_probe_path("mcg_coop_fanout")
        val (stdout, stderr, code) = run_probe(probe_path, cooperative_probe_source())
        expect(stderr).to_equal("")
        expect(stdout.trim()).to_equal("")
        expect(code).to_equal(0)

    slow_it "matches multicore-green fanout checksum and reports M:N evidence":
        step("Prepare deterministic multicore-green fanout inputs")
        val iterations = 512
        val expected = fanout_expected(8, iterations)

        step("Spawn eight multicore-green workers")
        val h0 = multicore_green_spawn(\: fanout_work(0, iterations))
        val h1 = multicore_green_spawn(\: fanout_work(1, iterations))
        val h2 = multicore_green_spawn(\: fanout_work(2, iterations))
        val h3 = multicore_green_spawn(\: fanout_work(3, iterations))
        val h4 = multicore_green_spawn(\: fanout_work(4, iterations))
        val h5 = multicore_green_spawn(\: fanout_work(5, iterations))
        val h6 = multicore_green_spawn(\: fanout_work(6, iterations))
        val h7 = multicore_green_spawn(\: fanout_work(7, iterations))

        var pool_used = 0
        var inline_fallback = 0
        step("Count runtime-pool and inline-fallback evidence")
        if h0.used_runtime_pool(): pool_used = pool_used + 1
        if h1.used_runtime_pool(): pool_used = pool_used + 1
        if h2.used_runtime_pool(): pool_used = pool_used + 1
        if h3.used_runtime_pool(): pool_used = pool_used + 1
        if h4.used_runtime_pool(): pool_used = pool_used + 1
        if h5.used_runtime_pool(): pool_used = pool_used + 1
        if h6.used_runtime_pool(): pool_used = pool_used + 1
        if h7.used_runtime_pool(): pool_used = pool_used + 1
        if h0.ran_inline_fallback(): inline_fallback = inline_fallback + 1
        if h1.ran_inline_fallback(): inline_fallback = inline_fallback + 1
        if h2.ran_inline_fallback(): inline_fallback = inline_fallback + 1
        if h3.ran_inline_fallback(): inline_fallback = inline_fallback + 1
        if h4.ran_inline_fallback(): inline_fallback = inline_fallback + 1
        if h5.ran_inline_fallback(): inline_fallback = inline_fallback + 1
        if h6.ran_inline_fallback(): inline_fallback = inline_fallback + 1
        if h7.ran_inline_fallback(): inline_fallback = inline_fallback + 1

        step("Join multicore-green workers and classify evidence")
        val got = h0.join() + h1.join() + h2.join() + h3.join() + h4.join() + h5.join() + h6.join() + h7.join()
        val has_mn_evidence = pool_used == 8
        val evidence_count = if has_mn_evidence: pool_used else: inline_fallback

        step("Verify checksum and runtime evidence accounting")
        expect(got).to_equal(expected)
        expect(pool_used + inline_fallback).to_equal(8)
        expect(evidence_count).to_equal(8)
        if has_mn_evidence:
            step("Verify runtime-pool fanout uses work stealing")
            expect(multicore_queue_model()).to_equal("work_stealing")
