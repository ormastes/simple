"""
# Multicore Green Fanout Stress Specification

**Feature IDs:** #green-perf-fanout
**Category:** Performance / Concurrency
**Status:** Implemented

## Overview

This perf stress spec keeps the Simple concurrency rows comparable: OS threads,
cooperative green, and multicore green all run the same deterministic fanout
workload and must produce the same checksum. The multicore-green row separately
reports whether every handle used the runtime pool, so inline fallback cannot be
mistaken for Go-like M:N CPU-parallel evidence.

## Requirements

**Requirements:** N/A

## Plan

**Plan:** doc/03_plan/sys_test/multicore_green.md

## Design

**Design:** N/A

## Research

**Research:** doc/01_research/local/multicore_green.md
"""

use std.spec.{describe, slow_it, expect, step}
use std.nogc_sync_mut.concurrent.thread.{thread_spawn, ThreadHandle}
use std.concurrent.cooperative_green.{cooperative_green_spawn_value, cooperative_green_run_all, GreenThreadHandle}
use std.concurrent.multicore_green.{multicore_green_spawn, MulticoreGreenHandle}

fn fanout_work(seed: i64, iterations: i64) -> i64:
    var x = seed + 1
    var i = 0
    while i < iterations:
        x = (x * 1103515245 + 12345) % 2147483648
        i = i + 1
    x

fn fanout_expected(worker_count: i64, iterations: i64) -> i64:
    var total = 0
    var worker = 0
    while worker < worker_count:
        total = total + fanout_work(worker, iterations)
        worker = worker + 1
    total

fn spawn_os_thread_handles(worker_count: i64, iterations: i64) -> [ThreadHandle]:
    var handles: [ThreadHandle] = []
    for worker in 0..worker_count:
        handles.push(thread_spawn(\: fanout_work(worker, iterations)))
    handles

fn join_os_thread_handles(handles: [ThreadHandle]) -> i64:
    var total = 0
    for index in 0..handles.len():
        val handle = handles[index]
        total = total + handle.join()
    total

fn spawn_cooperative_green_handles(worker_count: i64, iterations: i64) -> [GreenThreadHandle]:
    var handles: [GreenThreadHandle] = []
    for worker in 0..worker_count:
        handles.push(cooperative_green_spawn_value(fanout_work(worker, iterations)))
    handles

fn join_cooperative_green_handles(handles: [GreenThreadHandle]) -> i64:
    var total = 0
    for index in 0..handles.len():
        val handle = handles[index]
        total = total + handle.join()
    total

class MulticoreGreenFanoutEvidence:
    got: i64
    pool_used: i64
    inline_fallback: i64

fn spawn_multicore_green_handles(worker_count: i64, iterations: i64) -> [MulticoreGreenHandle]:
    var handles: [MulticoreGreenHandle] = []
    for worker in 0..worker_count:
        handles.push(multicore_green_spawn(\: fanout_work(worker, iterations)))
    handles

fn join_multicore_green_handles(handles: [MulticoreGreenHandle]) -> MulticoreGreenFanoutEvidence:
    var pool_used = 0
    var inline_fallback = 0
    var total = 0
    for index in 0..handles.len():
        val handle = handles[index]
        if handle.used_runtime_pool():
            pool_used = pool_used + 1
        if handle.ran_inline_fallback():
            inline_fallback = inline_fallback + 1
        total = total + handle.join()
    MulticoreGreenFanoutEvidence(got: total, pool_used: pool_used, inline_fallback: inline_fallback)

describe "multicore green fanout stress":
    slow_it "matches OS-thread fanout/fanin checksum":
        val iterations = 512
        val worker_count = 8
        val expected = fanout_expected(worker_count, iterations)

        step("Spawn OS-thread fanout handles with a compact handle array")
        val handles = spawn_os_thread_handles(worker_count, iterations)

        step("Join OS-thread handles and compare the deterministic checksum")
        val got = join_os_thread_handles(handles)
        expect(got).to_equal(expected)

    slow_it "matches cooperative-green fanout checksum on the current carrier":
        val iterations = 512
        val worker_count = 8
        val expected = fanout_expected(worker_count, iterations)

        step("Queue cooperative-green value handles on the current carrier")
        val handles = spawn_cooperative_green_handles(worker_count, iterations)

        step("Drain the cooperative queue and join every handle")
        val ran = cooperative_green_run_all()
        val got = join_cooperative_green_handles(handles)

        expect(ran >= worker_count).to_equal(true)
        expect(got).to_equal(expected)

    slow_it "matches multicore-green fanout checksum and reports M:N evidence":
        val iterations = 512
        val worker_count = 8
        val expected = fanout_expected(worker_count, iterations)

        step("Spawn multicore-green handles through the runtime-pool facade")
        val handles = spawn_multicore_green_handles(worker_count, iterations)

        step("Join multicore-green handles and count runtime-pool evidence")
        val evidence = join_multicore_green_handles(handles)
        val has_mn_evidence = evidence.pool_used == worker_count

        expect(evidence.got).to_equal(expected)
        expect(evidence.pool_used + evidence.inline_fallback).to_equal(worker_count)
        expect(has_mn_evidence or evidence.inline_fallback == worker_count).to_equal(true)
