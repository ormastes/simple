#!/bin/sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../../.." && pwd)"
cd "$ROOT_DIR"

SIMPLE_BIN="${SIMPLE_BIN:-./src/compiler_rust/target/debug/simple}"
WORK_DIR="${WORK_DIR:-build/test-artifacts/concurrency_api_contract}"

fail() {
    echo "concurrency_api_contract=false"
    echo "error=$1"
    exit 1
}

[ -x "$SIMPLE_BIN" ] || fail "missing SIMPLE_BIN: $SIMPLE_BIN"

mkdir -p "$WORK_DIR"
rm -f "$WORK_DIR"/*.spl "$WORK_DIR"/*.out

write_fixture() {
    name="$1"
    shift
    cat >"$WORK_DIR/$name.spl"
}

expect_check_fails() {
    name="$1"
    if "$SIMPLE_BIN" check "$WORK_DIR/$name.spl" >"$WORK_DIR/$name.out" 2>&1; then
        fail "expected check failure for $name"
    fi
}

expect_check_passes() {
    name="$1"
    if ! "$SIMPLE_BIN" check "$WORK_DIR/$name.spl" >"$WORK_DIR/$name.out" 2>&1; then
        cat "$WORK_DIR/$name.out"
        fail "expected check success for $name"
    fi
}

expect_run_contains() {
    name="$1"
    expected="$2"
    if ! "$SIMPLE_BIN" run "$WORK_DIR/$name.spl" --mode=interpreter >"$WORK_DIR/$name.out" 2>&1; then
        cat "$WORK_DIR/$name.out"
        fail "expected run success for $name"
    fi
    if ! grep -Fq "$expected" "$WORK_DIR/$name.out"; then
        cat "$WORK_DIR/$name.out"
        fail "missing run marker for $name: $expected"
    fi
}

write_fixture public_thread_spawn <<'SIMPLE'
use std.concurrent.thread.{thread_spawn}

fn main():
    val handle = thread_spawn(\: 7)
SIMPLE

write_fixture public_thread_spawn_with_args <<'SIMPLE'
use std.concurrent.thread.{thread_spawn_with_args}

fn add_pair(left: i64, right: i64) -> i64:
    left + right

fn main():
    val handle = thread_spawn_with_args(10, 32, add_pair)
SIMPLE

write_fixture public_cooperative_green <<'SIMPLE'
use std.concurrent.cooperative_green.{cooperative_green_spawn_value, cooperative_green_run_all}

fn main():
    val handle = cooperative_green_spawn_value(11)
    cooperative_green_run_all()
    if handle.join() == 11:
        println("cooperative_green_public=true")
SIMPLE

write_fixture public_multicore_green <<'SIMPLE'
use std.concurrent.multicore_green.{multicore_green_spawn, multicore_green_set_parallelism, multicore_green_parallelism}

fn main():
    multicore_green_set_parallelism(2)
    val handle = multicore_green_spawn(\: 13)
    if handle.join() == 13 and multicore_green_parallelism() >= 1:
        println("multicore_green_public=true")
SIMPLE

write_fixture public_task_spawn <<'SIMPLE'
use std.nogc_async_mut.thread_pool.{task_spawn}

fn main():
    val handle = task_spawn(\: 17)
SIMPLE

write_fixture thread_spawn2_import <<'SIMPLE'
use std.concurrent.thread.{thread_spawn2}

fn main():
    val x = 1
SIMPLE

write_fixture wrong_surface_import <<'SIMPLE'
use std.concurrent.multicore_green.{thread_spawn}

fn main():
    val x = 1
SIMPLE

write_fixture numbered_runtime_extern <<'SIMPLE'
extern fn rt_thread_spawn_isolated2(closure: Any, data1: Any, data2: Any) -> i64

fn main():
    val x = 1
SIMPLE

write_fixture numbered_limited_runtime_extern <<'SIMPLE'
extern fn rt_thread_spawn_limited2(closure: Any, data1: Any, data2: Any) -> i64

fn main():
    val x = 1
SIMPLE

write_fixture direct_runtime_pool_extern <<'SIMPLE'
extern fn rt_pool_submit(closure: Any) -> i64

fn main():
    val x = 1
SIMPLE

fixtures=0
positive_fixtures=0
expect_check_passes public_thread_spawn
positive_fixtures=$((positive_fixtures + 1))
expect_check_passes public_thread_spawn_with_args
positive_fixtures=$((positive_fixtures + 1))
expect_run_contains public_cooperative_green "cooperative_green_public=true"
positive_fixtures=$((positive_fixtures + 1))
expect_run_contains public_multicore_green "multicore_green_public=true"
positive_fixtures=$((positive_fixtures + 1))
expect_check_passes public_task_spawn
positive_fixtures=$((positive_fixtures + 1))

for name in \
    thread_spawn2_import \
    wrong_surface_import \
    numbered_runtime_extern \
    numbered_limited_runtime_extern \
    direct_runtime_pool_extern
do
    expect_check_fails "$name"
    fixtures=$((fixtures + 1))
done

if rg -n "(rt_thread_spawn_isolated|rt_thread_spawn_limited|thread_spawn|spawn_isolated|spawn_limited)[0-9]+" \
    src/lib src/runtime src/compiler_rust/common/src/runtime_symbols.rs \
    src/compiler_rust/compiler/src/codegen/runtime_sffi.rs \
    src/compiler_rust/compiler/src/interpreter_extern scripts/check/check-cross-language-perf.shs \
    >"$WORK_DIR/forbidden_names.out"
then
    cat "$WORK_DIR/forbidden_names.out"
    fail "forbidden numbered concurrency name in active source/profile surface"
fi

echo "concurrency_api_contract=true"
echo "fixtures=$fixtures"
echo "positive_fixtures=$positive_fixtures"
