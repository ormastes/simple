#!/bin/sh
set -eu

# Common contract test for profile scripts that generate Markdown reports.
# Profile wrappers call this after writing a report so report shape failures are
# caught at the evidence boundary instead of discovered later in docs review.

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../../.." && pwd)"
cd "$ROOT_DIR"

kind="${1:-}"
script_path="${2:-}"
report_path="${3:-}"

fail() {
    echo "profile_report_contract=false"
    echo "error=$1"
    exit 1
}

require_arg() {
    [ -n "$1" ] || fail "$2"
}

require_file() {
    [ -f "$1" ] || fail "missing file: $1"
}

require_contains() {
    file="$1"
    needle="$2"
    if ! grep -Fq "$needle" "$file"; then
        fail "missing '$needle' in $file"
    fi
}

require_not_contains() {
    file="$1"
    needle="$2"
    if grep -Fq "$needle" "$file"; then
        fail "forbidden '$needle' in $file"
    fi
}

require_multicore_green_rows_valid() {
    file="$1"
    if ! awk -F'|' '
        /Simple multicore green \((native|SMF)\)/ {
            value = $3
            notes = $4
            gsub(/^[ \t]+|[ \t]+$/, "", value)
            gsub(/^[ \t]+|[ \t]+$/, "", notes)
            if (notes !~ /multicore_green/) {
                next
            }
            if (notes !~ /multicore_green (runtime pool|stress fanout)/) {
                bad = 1
            }
            if (value == "fail" || value == "n/a" ||
                notes ~ /(checksum mismatch|segfault|compile failed|missing runtime pool|pool_used=fail|pool_used=missing|queue_model=invalid|queue_model=ambiguous)/) {
                bad = 1
            }
            pool = notes
            sub(/^.*pool_used=/, "", pool)
            sub(/[^0-9\/].*$/, "", pool)
            split(pool, pool_parts, "/")
            if (pool_parts[1] == "" || pool_parts[1] != pool_parts[2]) {
                bad = 1
            }
            if (notes ~ /queue_model=(global_fifo|scheduler_owned)/) {
                bad = 1
            }
            queue_notes = notes
            if (gsub(/queue_model=work_stealing/, "", queue_notes) != 1) {
                bad = 1
            }
            if (notes !~ /parallelism=[0-9]+\/[0-9]+/) {
                bad = 1
            }
        }
        END { exit bad ? 1 : 0 }
    ' "$file"; then
        fail "invalid Simple multicore green evidence row in $file"
    fi
}

require_multicore_green_generator_fail_closed() {
    file="$1"
    if ! awk '
        /echo '\''        rt_exit\((75|76)\)'\''/ {
            if (getline next_line <= 0 || next_line !~ /echo '\''        return'\''/) {
                bad = 1
            }
        }
        END { exit bad ? 1 : 0 }
    ' "$file"; then
        fail "multicore green queue-model generator exits must be followed by return in $file"
    fi
}

require_go_stress_beats_c() {
    file="$1"
    if ! awk -F'|' '
        /^## / {
            stress = ($0 ~ /Simple vs Go vs C Large Fanout Stress/)
            next
        }
        stress && /C \(pthreads\)/ {
            c = $3
            gsub(/^[ \t]+|[ \t]+$/, "", c)
        }
        stress && /\| Go[ \t]*\|/ {
            go = $3
            gsub(/^[ \t]+|[ \t]+$/, "", go)
        }
        END {
            if (go == "" || c == "" || go == "fail" || c == "fail" || go == "n/a" || c == "n/a") {
                exit 1
            }
            exit ((go + 0) < (c + 0)) ? 0 : 1
        }
    ' "$file"; then
        fail "Go stress fanout row must be faster than C pthread stress row in $file"
    fi
}

require_simple_multicore_stress_beats_c() {
    file="$1"
    if ! awk -F'|' '
        /^## / {
            stress = ($0 ~ /Simple vs Go vs C Large Fanout Stress/)
            next
        }
        stress && /C \(pthreads\)/ {
            c = $3
            gsub(/^[ \t]+|[ \t]+$/, "", c)
        }
        stress && /Simple multicore green \(native\)/ {
            simple = $3
            notes = $4
            gsub(/^[ \t]+|[ \t]+$/, "", simple)
            gsub(/^[ \t]+|[ \t]+$/, "", notes)
            if (notes !~ /pool_used=[0-9]+\/[0-9]+/ ||
                notes !~ /parallelism=[0-9]+\/[0-9]+/ ||
                notes !~ /queue_model=work_stealing/) {
                bad = 1
            }
        }
        END {
            if (bad || simple == "" || c == "" || simple == "fail" || c == "fail" || simple == "n/a" || c == "n/a") {
                exit 1
            }
            exit ((simple + 0) < (c + 0)) ? 0 : 1
        }
    ' "$file"; then
        fail "Simple multicore-green stress fanout row must be faster than C pthread stress row with pool evidence in $file"
    fi
}

require_large_simple_multicore_fanout_beats_c() {
    file="$1"
    if ! grep -Fq "Fanout workers:** 1000" "$file"; then
        return
    fi
    if ! awk -F'|' '
        /^## / {
            fanout = ($0 ~ /Large Fanout Scheduling/)
            next
        }
        fanout && /C \(pthreads\)/ {
            c = $3
            gsub(/^[ \t]+|[ \t]+$/, "", c)
        }
        fanout && /Simple multicore green \(native\)/ {
            simple = $3
            notes = $4
            gsub(/^[ \t]+|[ \t]+$/, "", simple)
            gsub(/^[ \t]+|[ \t]+$/, "", notes)
            if (notes !~ /pool_used=[0-9]+\/[0-9]+/ ||
                notes !~ /parallelism=[0-9]+\/[0-9]+/ ||
                notes !~ /queue_model=work_stealing/) {
                bad = 1
            }
        }
        END {
            if (bad || simple == "" || c == "" || simple == "fail" || c == "fail" || simple == "n/a" || c == "n/a") {
                exit 1
            }
            exit ((simple + 0) < (c + 0)) ? 0 : 1
        }
    ' "$file"; then
        fail "large Simple multicore-green fanout row must be faster than C pthread fanout row with pool evidence in $file"
    fi
}

require_go_scheduler_matches_cpu_workers() {
    file="$1"
    cpu_workers=$(sed -n 's/.*CPU workers:\*\* \([0-9][0-9]*\).*/\1/p' "$file" | head -1)
    go_gomaxprocs=$(sed -n 's/.*Go scheduler: `GOMAXPROCS=\([0-9][0-9]*\).*/\1/p' "$file" | head -1)
    if [ -z "$cpu_workers" ] || [ -z "$go_gomaxprocs" ] || [ "$cpu_workers" != "$go_gomaxprocs" ]; then
        fail "Go scheduler GOMAXPROCS must match CPU workers in $file"
    fi
}

require_arg "$kind" "missing profile kind"
require_arg "$script_path" "missing script path"
require_arg "$report_path" "missing report path"
require_file "$script_path"
require_file "$report_path"

case "$report_path" in
    doc/09_report/*.md|"$ROOT_DIR"/doc/09_report/*.md) ;;
    *) fail "report path must be a Markdown file under doc/09_report: $report_path" ;;
esac

case "$report_path" in
    *.md) ;;
    *) fail "report path must end in .md: $report_path" ;;
esac

if [ ! -s "$report_path" ]; then
    fail "empty report: $report_path"
fi

require_contains "$report_path" "## Methodology"
require_contains "$report_path" "## Reproducibility"
require_contains "$report_path" "Profile script:"
require_contains "$report_path" "Report path:"
require_contains "$report_path" "Environment"
require_contains "$report_path" "Limitations"

case "$kind" in
    cross_language)
        require_contains "$report_path" "# Cross-Language Performance Profile"
        require_contains "$report_path" "Profile contract:** enforced by"
        require_contains "$report_path" "Docker isolation:"
        require_contains "$report_path" "PROFILE_DOCKER_ISOLATION=1"
        require_contains "$report_path" "PROFILE_DOCKER_SIMPLE_BINARY"
        require_contains "$report_path" "Cold Startup"
        require_contains "$report_path" "Warm Throughput"
        require_contains "$report_path" "OS Thread Parallel Workers"
        require_contains "$report_path" "Large Fanout Scheduling"
        require_contains "$report_path" "Simple vs Go vs C Large Fanout Stress"
        require_contains "$report_path" "Parallel Artifact Footprint"
        require_contains "$report_path" "Parallel Peak RSS"
        require_contains "$report_path" "OS thread workers"
        require_contains "$report_path" "Cooperative green workers"
        require_contains "$report_path" "Multicore green workers"
        require_contains "$report_path" "Fanout workers"
        require_contains "$report_path" "Fanout stress workers"
        require_contains "$report_path" "Go runtime:"
        require_contains "$report_path" "Go scheduler:"
        require_contains "$report_path" "GOMAXPROCS="
        require_go_scheduler_matches_cpu_workers "$report_path"
        require_contains "$report_path" "expected checksum"
        require_contains "$report_path" "Simple (native)"
        require_contains "$report_path" "thread_spawn fork-join OS threads"
        require_contains "$report_path" "std thread_spawn"
        require_contains "$report_path" "OS-thread fanout"
        require_contains "$report_path" "Simple cooperative green"
        require_contains "$report_path" "cooperative_green_spawn_value"
        require_contains "$report_path" "cooperative queue fanout"
        require_contains "$report_path" "not a Go M:N goroutine equivalent"
        require_contains "$report_path" "Simple multicore green"
        require_contains "$report_path" "multicore_green runtime pool candidate"
        require_contains "$report_path" "multicore_green runtime pool fanout"
        require_contains "$report_path" "multicore_green stress fanout"
        require_contains "$report_path" "used_runtime_pool()"
        require_contains "$report_path" "pool_used="
        require_contains "$report_path" "queue_model=work_stealing"
        require_contains "$report_path" "inline fallback cannot masquerade"
        require_multicore_green_rows_valid "$report_path"
        require_contains "$report_path" "C (pthreads)"
        require_contains "$report_path" "one OS thread per tiny task"
        require_contains "$report_path" "pthread per stress task"
        require_contains "$report_path" "Go"
        require_contains "$report_path" "goroutines + chan result (M:N)"
        require_contains "$report_path" "goroutine per tiny task + channel"
        require_contains "$report_path" "goroutine per stress task (M:N)"
        require_go_stress_beats_c "$report_path"
        require_simple_multicore_stress_beats_c "$report_path"
        require_large_simple_multicore_fanout_beats_c "$report_path"
        require_not_contains "$report_path" "thread_spawn2"
        require_not_contains "$report_path" "Simple task_spawn"
        require_not_contains "$report_path" "task_spawn runtime pool candidate"
        require_not_contains "$report_path" "spawn_isolated2"
        require_not_contains "$report_path" "spawn_limited2"
        require_not_contains "$report_path" "rt_thread_spawn_isolated2"
        require_not_contains "$report_path" "rt_thread_spawn_limited2"
        require_not_contains "$script_path" "thread_spawn2"
        require_not_contains "$script_path" "spawn_isolated2"
        require_not_contains "$script_path" "spawn_limited2"
        require_not_contains "$script_path" "rt_thread_spawn_isolated2"
        require_not_contains "$script_path" "rt_thread_spawn_limited2"
        require_not_contains "$script_path" "val ITERS: i64"
        require_not_contains "$script_path" "val WORKERS: i64"
        require_not_contains "$script_path" "val LCG_A: i64"
        require_not_contains "$script_path" "val LCG_C: i64"
        require_not_contains "$script_path" "val LCG_M: i64"
        require_multicore_green_generator_fail_closed "$script_path"
        require_contains "$report_path" "TUI startup scope"
        require_contains "$report_path" "scripts/check/check-startup-size-performance-audit.shs"
        ;;
    gui)
        require_contains "$report_path" "# GUI Performance Profile"
        require_contains "$report_path" "Backend Results"
        require_contains "$report_path" "Resolution"
        require_contains "$report_path" "TUI startup speed"
        require_contains "$report_path" "not measured by this GUI profile"
        require_contains "$report_path" "scripts/check/check-startup-size-performance-audit.shs"
        ;;
    *)
        fail "unknown profile kind: $kind"
        ;;
esac

echo "profile_report_contract=true"
echo "profile_kind=$kind"
echo "profile_script=$script_path"
echo "report_path=$report_path"
