#!/bin/sh
set -eu

# Negative coverage for the cross-language profile report contract. This keeps
# the Go-vs-C, Simple-vs-C, and runtime-pool evidence rules from silently
# becoming no-ops.

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../../.." && pwd)"
cd "$ROOT_DIR"

contract="test/05_perf/profile_scripts/profile_report_contract_test.shs"
script_path="scripts/check/check-cross-language-perf.shs"
source_report="doc/09_report/cross_language_perf_2026-06-08_docker_contract.md"
tmp_report="doc/09_report/.profile_contract_negative_$$.md"
tmp_edit="${tmp_report}.tmp"

cleanup() {
    rm -f "$tmp_report" "$tmp_edit"
}
trap cleanup EXIT INT TERM

fail() {
    echo "profile_report_contract_negative=false"
    echo "error=$1"
    exit 1
}

cp "$source_report" "$tmp_report"

awk '
    /\*\*Fanout workers:\*\*/ {
        sub(/\*\*Fanout workers:\*\* [0-9]+/, "**Fanout workers:** 1000")
    }
    /^## / {
        in_fanout = ($0 ~ /^## Large Fanout Scheduling/)
    }
    in_fanout && /\| Simple multicore green \(native\)/ {
        sub(/\|[ \t]*[0-9]+\.[0-9]+[ \t]*\|/, "|      999.999 |")
    }
    { print }
' "$tmp_report" >"$tmp_edit"
mv "$tmp_edit" "$tmp_report"

set +e
output="$(sh "$contract" cross_language "$script_path" "$tmp_report" 2>&1)"
code=$?
set -e

if [ "$code" -eq 0 ]; then
    fail "mutated large Simple multicore-green fanout row unexpectedly passed"
fi

printf '%s\n' "$output" | grep -Fq "large Simple multicore-green fanout row must be faster than C pthread fanout row" ||
    fail "missing expected large-fanout failure message"

cp "$source_report" "$tmp_report"

awk '
    /^## / {
        in_stress = ($0 ~ /^## Simple vs Go vs C Large Fanout Stress/)
    }
    in_stress && /\| Simple multicore green \(native\)/ {
        sub(/\|[ \t]*[0-9]+\.[0-9]+[ \t]*\|/, "|      999.999 |")
    }
    { print }
' "$tmp_report" >"$tmp_edit"
mv "$tmp_edit" "$tmp_report"

set +e
output="$(sh "$contract" cross_language "$script_path" "$tmp_report" 2>&1)"
code=$?
set -e

if [ "$code" -eq 0 ]; then
    fail "mutated Simple multicore-green stress row unexpectedly passed"
fi

printf '%s\n' "$output" | grep -Fq "Simple multicore-green stress fanout row must be faster than C pthread stress row" ||
    fail "missing expected stress failure message"

cp "$source_report" "$tmp_report"

awk '
    /^## / {
        in_stress = ($0 ~ /^## Simple vs Go vs C Large Fanout Stress/)
    }
    in_stress && /\| Go[ \t]*\|/ {
        sub(/\|[ \t]*[0-9]+\.[0-9]+[ \t]*\|/, "|      999.999 |")
    }
    { print }
' "$tmp_report" >"$tmp_edit"
mv "$tmp_edit" "$tmp_report"

set +e
output="$(sh "$contract" cross_language "$script_path" "$tmp_report" 2>&1)"
code=$?
set -e

if [ "$code" -eq 0 ]; then
    fail "mutated Go stress row unexpectedly passed"
fi

printf '%s\n' "$output" | grep -Fq "Go stress fanout row must be faster than C pthread stress row" ||
    fail "missing expected Go stress failure message"

cp "$source_report" "$tmp_report"

awk '
    /^## / {
        in_fanout = ($0 ~ /^## Large Fanout Scheduling/)
    }
    in_fanout && /\| Simple multicore green \(native\)/ {
        sub(/queue_model=work_stealing/, "queue_model=global_fifo")
    }
    { print }
' "$tmp_report" >"$tmp_edit"
mv "$tmp_edit" "$tmp_report"

set +e
output="$(sh "$contract" cross_language "$script_path" "$tmp_report" 2>&1)"
code=$?
set -e

if [ "$code" -eq 0 ]; then
    fail "mutated Simple multicore-green queue model unexpectedly passed"
fi

printf '%s\n' "$output" | grep -Fq "invalid Simple multicore green evidence row" ||
    fail "missing expected runtime-pool evidence failure message"

cp "$source_report" "$tmp_report"

awk '
    /^## / {
        in_fanout = ($0 ~ /^## Large Fanout Scheduling/)
    }
    in_fanout && /\| Simple multicore green \(native\)/ {
        sub(/pool_used=[0-9]+\/[0-9]+/, "pool_used=999/1000")
    }
    { print }
' "$tmp_report" >"$tmp_edit"
mv "$tmp_edit" "$tmp_report"

set +e
output="$(sh "$contract" cross_language "$script_path" "$tmp_report" 2>&1)"
code=$?
set -e

if [ "$code" -eq 0 ]; then
    fail "mutated Simple multicore-green pool usage unexpectedly passed"
fi

printf '%s\n' "$output" | grep -Fq "invalid Simple multicore green evidence row" ||
    fail "missing expected pool-used evidence failure message"

cp "$source_report" "$tmp_report"

awk '
    /^## / {
        in_fanout = ($0 ~ /^## Large Fanout Scheduling/)
    }
    in_fanout && /\| Simple multicore green \(native\)/ {
        sub(/, parallelism=[0-9]+\/[0-9]+/, "")
    }
    { print }
' "$tmp_report" >"$tmp_edit"
mv "$tmp_edit" "$tmp_report"

set +e
output="$(sh "$contract" cross_language "$script_path" "$tmp_report" 2>&1)"
code=$?
set -e

if [ "$code" -eq 0 ]; then
    fail "mutated Simple multicore-green parallelism evidence unexpectedly passed"
fi

printf '%s\n' "$output" | grep -Fq "invalid Simple multicore green evidence row" ||
    fail "missing expected parallelism evidence failure message"

cp "$source_report" "$tmp_report"

awk '
    /Go scheduler: `GOMAXPROCS=/ {
        sub(/GOMAXPROCS=[0-9]+/, "GOMAXPROCS=32")
    }
    { print }
' "$tmp_report" >"$tmp_edit"
mv "$tmp_edit" "$tmp_report"

set +e
output="$(sh "$contract" cross_language "$script_path" "$tmp_report" 2>&1)"
code=$?
set -e

if [ "$code" -eq 0 ]; then
    fail "mutated Go scheduler width unexpectedly passed"
fi

printf '%s\n' "$output" | grep -Fq "Go scheduler GOMAXPROCS must match CPU workers" ||
    fail "missing expected Go scheduler width failure message"

echo "profile_report_contract_negative=true"
echo "case=large_simple_multicore_fanout_slower_than_c"
echo "case=simple_multicore_stress_slower_than_c"
echo "case=go_stress_slower_than_c"
echo "case=simple_multicore_queue_model_global_fifo"
echo "case=simple_multicore_pool_used_partial"
echo "case=simple_multicore_parallelism_missing"
echo "case=go_scheduler_width_mismatch"
