# HTTP server hot-path benchmark.
#
# This is a local microbenchmark, not an nginx comparison. It measures the
# Simple HTTP parser and response serializer paths that every request uses.

use test.perf.bench.lib.timing.{BenchResult, bench_print, bench_csv, bench_csv_header, bench_now_ns}

fn request_keepalive() -> text:
    "GET /static/index.html HTTP/1.1\r\n" +
    "Host: localhost\r\n" +
    "User-Agent: simple-webserver-perf\r\n" +
    "Accept: */*\r\n" +
    "Connection: keep-alive\r\n" +
    "\r\n"

fn parse_request_once() -> i64:
    val request = request_keepalive()
    val line_end = request.find("\n")
    if line_end < 0:
        return -1
    val line = request.slice(0, line_end)
    val first_space = line.find(" ")
    if first_space <= 0:
        return -1
    val rest_line = line.slice(first_space + 1, line.len())
    val second_space_rel = rest_line.find(" ")
    if second_space_rel <= 0:
        return -1
    val method = line.slice(0, first_space)
    val path = rest_line.slice(0, second_space_rel)
    val version = rest_line.slice(second_space_rel + 1, rest_line.len())

    var header_count: i64 = 0
    var pos = line_end + 1
    while pos < request.len():
        val rest = request.slice(pos, request.len())
        val next = rest.find("\n")
        if next <= 1:
            return method.len() + path.len() + version.len() + header_count
        header_count = header_count + 1
        pos = pos + next + 1
    -1

fn serialize_response_once() -> i64:
    val body = "simple-webserver-hot-path"
    val wire = "HTTP/1.1 200 OK\r\n" +
        "Content-Type: text/plain; charset=utf-8\r\n" +
        "Server: SimpleServer\r\n" +
        "Content-Length: {body.len()}\r\n" +
        "\r\n" +
        body
    wire.len()

fn _sort(samples: [i64]) -> [i64]:
    var result: [i64] = samples
    var n: i64 = result.len() as i64
    var i: i64 = 1
    while i < n:
        val key: i64 = result[i as i32]
        var j: i64 = i - 1
        while j >= 0 and result[j as i32] > key:
            result[(j + 1) as i32] = result[j as i32]
            j = j - 1
        result[(j + 1) as i32] = key
        i = i + 1
    result

fn _pct(sorted: [i64], num: i64, den: i64) -> i64:
    val n: i64 = sorted.len() as i64
    if n == 0:
        return 0
    var idx: i64 = (n * num) / den
    if idx >= n:
        idx = n - 1
    sorted[idx as i32]

fn _result(label: text, iters: i64, samples: [i64], total: i64, sink: i64) -> BenchResult:
    val sorted = _sort(samples)
    val max_idx = (sorted.len() - 1) as i32
    val throughput: i64 = if total > 0: (iters * 1000000) / total else: 0
    if sink < 0:
        print "# sink={sink}"

    BenchResult(
        label: label,
        iters: iters,
        p50_ns: _pct(sorted, 50, 100),
        p99_ns: _pct(sorted, 99, 100),
        p99_9_ns: _pct(sorted, 999, 1000),
        min_ns: if sorted.len() > 0: sorted[0] else: 0,
        max_ns: if sorted.len() > 0: sorted[max_idx] else: 0,
        total_ns: total,
        throughput_ops_per_s: throughput,
    )

fn measure_parse(label: text, iters: i64) -> BenchResult:
    var samples: [i64] = []
    var total: i64 = 0
    var sink: i64 = 0
    var i: i64 = 0
    while i < iters:
        val t0: i64 = bench_now_ns()
        sink = sink + parse_request_once()
        val t1: i64 = bench_now_ns()
        val elapsed = t1 - t0
        samples.push(elapsed)
        total = total + elapsed
        i = i + 1
    _result(label, iters, samples, total, sink)

fn measure_serialize(label: text, iters: i64) -> BenchResult:
    var samples: [i64] = []
    var total: i64 = 0
    var sink: i64 = 0
    var i: i64 = 0
    while i < iters:
        val t0: i64 = bench_now_ns()
        sink = sink + serialize_response_once()
        val t1: i64 = bench_now_ns()
        val elapsed = t1 - t0
        samples.push(elapsed)
        total = total + elapsed
        i = i + 1
    _result(label, iters, samples, total, sink)

fn main():
    print "=== Simple HTTP hot-path benchmark ==="
    print "DISCLAIMER: parser/serializer microbenchmark, not live socket throughput and not nginx parity."
    print ""

    val parse_result = measure_parse("http_parse_keepalive_get_x1000", 1000)
    bench_print(parse_result)
    print ""

    val serialize_result = measure_serialize("http_serialize_text_200_x1000", 1000)
    bench_print(serialize_result)
    print ""

    print "=== CSV ==="
    print bench_csv_header()
    print bench_csv(parse_result)
    print bench_csv(serialize_result)
