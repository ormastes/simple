# db_bench_driver.spl — DB benchmark driver (AC-3 / AC-5).
#
# Runs a FIXED workload (N=100 inserts + point lookup + row-count oracle)
# against three DB configurations, records REAL timing rows by mode, and
# emits two benchmark docs.
#
# Writes:
#   doc/09_report/perf/perf_baseline_db_2026-06-13.md   — dated run report
#   doc/10_metrics/perf/perf_baseline_db_table.md        — persistent table
#
# Modes (AC-5 — always separate rows, never collapsed):
#   "ram"        — PureDatabase.memory()
#   "persistent" — PureDatabase.open_deferred(path) + checkpoint()
#   "wal"        — MvccTable (in-process MVCC core; disk-WAL replay omitted: P0 bug)
#
# N=100: persistent deferred+checkpoint safe within interpreter limits.
# (Research: open() auto-checkpoint on 200 rows = timeout; deferred is safe.)
#
# Run:  bin/simple run test/05_perf/db/db_bench_driver.spl
#
# Note: bench_emit_rows (app.test.bench.bench_report) cannot be imported from
# test/ paths — its rt_file_write_text/rt_file_read_text externs are flagged as
# undefined-symbol on export, causing unwrap-on-None at call time.  The emit
# logic is therefore inlined here using locally-declared externs (same pattern
# as the model driver avoids cross-module BenchResult struct passing).
# use std.io_runtime is required to resolve extern symbols before PureDatabase loads.

use std.io_runtime
use std.database.sql.types.{DbValue, DbRow, DbError}
use nogc_sync_mut.database.pure_sql.database.{PureDatabase}
use nogc_sync_mut.db.dbfs_engine.mvcc.{
    MvccTable, MvccTxnManager, MvccSnapshot
}

extern fn rt_time_now_unix_micros() -> i64
extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_delete(path: text) -> bool
extern fn rt_dir_create_all(path: text) -> bool
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_read_text(path: text) -> text

# ============================================================================
# Constants
# ============================================================================

val BENCH_N: i64 = 100
val BENCH_POINT_ID: i64 = 42

# ============================================================================
# Integer-to-text helper (no import to avoid cycle)
# ============================================================================

fn _i64_to_text_local(n: i64) -> text:
    if n == 0:
        return "0"
    var digits: [text] = []
    var v = n
    val negative = v < 0
    if negative:
        v = 0 - v
    while v > 0:
        val d = v % 10
        val ch: text = if d == 0: "0"
            elif d == 1: "1"
            elif d == 2: "2"
            elif d == 3: "3"
            elif d == 4: "4"
            elif d == 5: "5"
            elif d == 6: "6"
            elif d == 7: "7"
            elif d == 8: "8"
            else: "9"
        digits.push(ch)
        v = v / 10
    var result = if negative: "-" else: ""
    var di: i64 = digits.len() - 1
    while di >= 0:
        result = result + digits[di]
        di = di - 1
    result

# ============================================================================
# Inline markdown emit — avoids cross-module extern resolution bug
# ============================================================================

fn _join_lines(lines: [text]) -> text:
    var result = ""
    var i: i64 = 0
    while i < lines.len():
        if i > 0:
            result = result + "\n"
        result = result + lines[i]
        i = i + 1
    result

fn _emit_docs(names: [text], modes: [text], metrics: [text], values: [i64], units: [text], arch: text, date_str: text, report_path: text, table_path: text) -> bool:
    rt_dir_create_all("doc/09_report/perf")
    rt_dir_create_all("doc/10_metrics/perf")

    # Build GFM table block
    var table_lines: [text] = []
    table_lines.push("| name | mode | metric | value | unit | arch |")
    table_lines.push("|------|------|--------|------:|------|------|")
    var ti: i64 = 0
    while ti < names.len():
        val row = "| " + names[ti] + " | " + modes[ti] + " | " + metrics[ti] + " | " + _i64_to_text_local(values[ti]) + " | " + units[ti] + " | " + arch + " |"
        table_lines.push(row)
        ti = ti + 1
    val table_block = _join_lines(table_lines)

    # Build report
    var report_parts: [text] = []
    report_parts.push("# DB Benchmark Run")
    report_parts.push("")
    report_parts.push("Date: " + date_str)
    report_parts.push("")
    report_parts.push("## Results")
    report_parts.push("")
    report_parts.push(table_block)
    report_parts.push("")
    report_parts.push("---")
    report_parts.push("*Generated by db_bench_driver.spl*")
    val report_md = _join_lines(report_parts)

    val report_ok = rt_file_write_text(report_path, report_md)
    if report_ok:
        print("db_bench_driver: wrote report -> " + report_path)
    else:
        print("db_bench_driver: ERROR writing report -> " + report_path)

    # Build append block for persistent table
    var append_parts: [text] = []
    append_parts.push("## Run: " + date_str)
    append_parts.push("")
    append_parts.push(table_block)
    append_parts.push("")
    val append_block = _join_lines(append_parts)

    # Use temp var for file-exists branch (avoid inline-if parser edge cases)
    var existing = ""
    val tbl_exists = rt_file_exists(table_path)
    if tbl_exists:
        existing = rt_file_read_text(table_path)
    val new_content = existing + "\n" + append_block
    val table_ok = rt_file_write_text(table_path, new_content)
    if table_ok:
        print("db_bench_driver: updated metrics -> " + table_path)
    else:
        print("db_bench_driver: ERROR writing metrics -> " + table_path)

    report_ok and table_ok

# ============================================================================
# Helpers — RAM config (PureDatabase.memory)
# ============================================================================

fn run_ram_insert_count() -> i64:
    val r = PureDatabase.memory()
    if r.is_err():
        return -1
    var db = r.unwrap()
    val cr = db.exec_sql("CREATE TABLE bench (id INTEGER, val TEXT)")
    if cr.is_err():
        return -2
    var i: i64 = 0
    while i < BENCH_N:
        val v = "val_" + (i * 10).to_text()
        val sql = "INSERT INTO bench (id, val) VALUES (" + i.to_text() + ", '" + v + "')"
        val ir = db.exec_sql(sql)
        if ir.is_err():
            return -3
        i = i + 1
    val qr = db.query("SELECT * FROM bench", [])
    if qr.is_err():
        return -4
    val rows = qr.unwrap()
    rows.len()

fn run_ram_timing_us() -> i64:
    val t0 = rt_time_now_unix_micros()
    val n = run_ram_insert_count()
    val t1 = rt_time_now_unix_micros()
    if n < 0:
        return -1
    t1 - t0

# ============================================================================
# Helpers — persistent config (PureDatabase.open_deferred + checkpoint)
# ============================================================================

fn run_persistent_insert_count(db_path: text) -> i64:
    # open_deferred: no per-mutation persist; single checkpoint at end.
    val r = PureDatabase.open_deferred(db_path)
    if r.is_err():
        return -1
    var db = r.unwrap()
    val cr = db.exec_sql("CREATE TABLE bench (id INTEGER, val TEXT)")
    if cr.is_err():
        return -2
    var i: i64 = 0
    while i < BENCH_N:
        val v = "val_" + (i * 10).to_text()
        val sql = "INSERT INTO bench (id, val) VALUES (" + i.to_text() + ", '" + v + "')"
        val ir = db.exec_sql(sql)
        if ir.is_err():
            return -3
        i = i + 1
    # Single checkpoint: writes _serialize_disk() to file once.
    val ck = db.checkpoint()
    if ck.is_err():
        return -4
    val qr = db.query("SELECT * FROM bench", [])
    if qr.is_err():
        return -5
    val rows = qr.unwrap()
    rows.len()

fn run_persistent_timing_us(db_path: text) -> i64:
    val t0 = rt_time_now_unix_micros()
    val n = run_persistent_insert_count(db_path)
    val t1 = rt_time_now_unix_micros()
    if n < 0:
        return -1
    t1 - t0

# ============================================================================
# Helpers — WAL config (MvccTable in-process MVCC core)
# Note: disk-WAL replay has a P0 blank-row bug (simple-db-hardening);
# this driver measures the in-memory MVCC core only.
# ============================================================================

fn run_wal_insert_count() -> i64:
    var tbl = MvccTable.new()
    var mgr = MvccTxnManager.new()
    # Insert N rows under a committed transaction per row (simple isolation).
    var i: i64 = 0
    while i < BENCH_N:
        val h = mgr.begin()
        val tid = h.txn_id
        val data = i.to_text() + "|val_" + (i * 10).to_text()
        tbl.insert(tid, data)
        mgr.commit(tid)
        i = i + 1
    val snap = mgr.snapshot()
    tbl.count_visible(snap)

fn run_wal_timing_us() -> i64:
    val t0 = rt_time_now_unix_micros()
    val n = run_wal_insert_count()
    val t1 = rt_time_now_unix_micros()
    if n < 0:
        return -1
    t1 - t0

# ============================================================================
# main
# ============================================================================

fn main():
    val date_str = "2026-06-13"
    val arch = "x86_64"

    val report_path = "doc/09_report/perf/perf_baseline_db_2026-06-13.md"
    val table_path  = "doc/10_metrics/perf/perf_baseline_db_table.md"

    rt_dir_create_all("/tmp/bench_db")

    var names:   [text] = []
    var modes:   [text] = []
    var metrics: [text] = []
    var values:  [i64]  = []
    var units:   [text] = []

    # --- Mode: ram ---
    print("Running ram (PureDatabase.memory) N=" + _i64_to_text_local(BENCH_N) + " ...")
    val ram_count = run_ram_insert_count()
    if ram_count == BENCH_N:
        val ram_us = run_ram_timing_us()
        val ram_ns_per_op: i64 = if ram_us > 0:
            (ram_us * 1000) / BENCH_N
        else:
            0
        val ram_ops: i64 = if ram_us > 0:
            (BENCH_N * 1000000) / ram_us
        else:
            0
        print("  ram: elapsed_us=" + _i64_to_text_local(ram_us) + "  ns/op=" + _i64_to_text_local(ram_ns_per_op) + "  ops/sec=" + _i64_to_text_local(ram_ops))
        names.push("db_insert_N100")
        modes.push("ram")
        metrics.push("ns/op")
        values.push(ram_ns_per_op)
        units.push("ns/op")
        names.push("db_insert_N100")
        modes.push("ram")
        metrics.push("ops/sec")
        values.push(ram_ops)
        units.push("ops/sec")
    else:
        print("  ram: ORACLE FAIL count=" + _i64_to_text_local(ram_count) + " expected=" + _i64_to_text_local(BENCH_N) + " — row OMITTED")

    # --- Mode: persistent ---
    print("Running persistent (PureDatabase.open_deferred+checkpoint) N=" + _i64_to_text_local(BENCH_N) + " ...")
    val db_path = "/tmp/bench_db/bench_driver_persistent.db"
    rt_file_delete(db_path)
    val persistent_count = run_persistent_insert_count(db_path)
    if persistent_count == BENCH_N:
        rt_file_delete(db_path)
        val persistent_us = run_persistent_timing_us(db_path)
        val persistent_ns_per_op: i64 = if persistent_us > 0:
            (persistent_us * 1000) / BENCH_N
        else:
            0
        val persistent_ops: i64 = if persistent_us > 0:
            (BENCH_N * 1000000) / persistent_us
        else:
            0
        print("  persistent: elapsed_us=" + _i64_to_text_local(persistent_us) + "  ns/op=" + _i64_to_text_local(persistent_ns_per_op) + "  ops/sec=" + _i64_to_text_local(persistent_ops))
        names.push("db_insert_N100")
        modes.push("persistent")
        metrics.push("ns/op")
        values.push(persistent_ns_per_op)
        units.push("ns/op")
        names.push("db_insert_N100")
        modes.push("persistent")
        metrics.push("ops/sec")
        values.push(persistent_ops)
        units.push("ops/sec")
    else:
        print("  persistent: ORACLE FAIL count=" + _i64_to_text_local(persistent_count) + " expected=" + _i64_to_text_local(BENCH_N) + " — row OMITTED")

    # --- Mode: wal ---
    # Note: disk-WAL replay has a P0 blank-row bug (simple-db-hardening).
    # This driver measures in-memory MVCC core only (no disk replay).
    print("Running wal (MvccTable in-process MVCC) N=" + _i64_to_text_local(BENCH_N) + " ...")
    val wal_count = run_wal_insert_count()
    if wal_count == BENCH_N:
        val wal_us = run_wal_timing_us()
        val wal_ns_per_op: i64 = if wal_us > 0:
            (wal_us * 1000) / BENCH_N
        else:
            0
        val wal_ops: i64 = if wal_us > 0:
            (BENCH_N * 1000000) / wal_us
        else:
            0
        print("  wal: elapsed_us=" + _i64_to_text_local(wal_us) + "  ns/op=" + _i64_to_text_local(wal_ns_per_op) + "  ops/sec=" + _i64_to_text_local(wal_ops))
        names.push("db_insert_N100")
        modes.push("wal")
        metrics.push("ns/op")
        values.push(wal_ns_per_op)
        units.push("ns/op")
        names.push("db_insert_N100")
        modes.push("wal")
        metrics.push("ops/sec")
        values.push(wal_ops)
        units.push("ops/sec")
    else:
        print("  wal: ORACLE FAIL count=" + _i64_to_text_local(wal_count) + " expected=" + _i64_to_text_local(BENCH_N) + " — row OMITTED")

    print("Writing benchmark docs ...")
    val ok = _emit_docs(names, modes, metrics, values, units, arch, date_str, report_path, table_path)
    if ok:
        print("Done. Both docs written.")
    else:
        print("ERROR: one or both docs failed to write.")
