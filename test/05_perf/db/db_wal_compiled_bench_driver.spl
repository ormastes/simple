# Standalone compiled WAL benchmark driver.
#
# Run through scripts/check/check-db-wal-compiled-benchmark-report.shs. This is
# intentionally a main() program instead of an SSpec because the native test
# harness can fail before surfacing per-assertion output for this lane.

use nogc_sync_mut.db.dbfs_engine.mvcc.{MvccTable, MvccTxnManager}

extern fn rt_time_now_unix_micros() -> i64
extern fn rt_dir_create_all(path: text) -> bool
extern fn rt_file_write_text(path: text, content: text) -> bool

val BENCH_N: i64 = 100
val REPORT_PATH: text = "doc/09_report/perf/perf_baseline_db_wal_compiled_2026-06-16.md"
val TABLE_PATH: text = "doc/10_metrics/perf/perf_baseline_db_wal_compiled_table.md"

fn join_lines(lines: [text]) -> text:
    var result = ""
    var i: i64 = 0
    while i < lines.len():
        if i > 0:
            result = result + "\n"
        result = result + lines[i]
        i = i + 1
    result

fn run_wal_insert_count() -> i64:
    var table = MvccTable.new()
    var manager = MvccTxnManager.new()
    var i: i64 = 0
    while i < BENCH_N:
        val handle = manager.begin()
        val txn_id = handle.txn_id
        table.insert(txn_id, i.to_text() + "|val_" + (i * 10).to_text())
        manager.commit(txn_id)
        i = i + 1
    val snapshot = manager.snapshot()
    table.count_visible(snapshot)

fn run_wal_timing_us() -> i64:
    val start_us = rt_time_now_unix_micros()
    val count = run_wal_insert_count()
    val elapsed_us = rt_time_now_unix_micros() - start_us
    if count != BENCH_N:
        return -1
    elapsed_us

fn emit_compiled_wal_docs(elapsed_us: i64) -> bool:
    rt_dir_create_all("doc/09_report/perf")
    rt_dir_create_all("doc/10_metrics/perf")
    val row = "| db_wal_insert100 | wal | insert+count_visible | " + elapsed_us.to_text() + " | us | x86_64 | native |"
    val table = join_lines([
        "| name | mode | metric | value | unit | arch | plane |",
        "|------|------|--------|------:|------|------|-------|",
        row
    ])
    val report = join_lines([
        "# DB WAL Compiled Benchmark",
        "",
        "Date: 2026-06-16",
        "",
        "This report is generated by the native-built `test/05_perf/db/db_wal_compiled_bench_driver.spl` wrapper.",
        "",
        "## Results",
        "",
        table,
        "",
        "The workload inserts 100 MVCC WAL-core rows, commits each transaction, then validates `count_visible == 100` before recording timing.",
        ""
    ])
    val report_ok = rt_file_write_text(REPORT_PATH, report)
    val table_ok = rt_file_write_text(TABLE_PATH, table + "\n")
    report_ok and table_ok

fn main():
    val elapsed_us = run_wal_timing_us()
    if elapsed_us < 0:
        print("STATUS: FAIL db wal compiled benchmark count mismatch")
        return
    val wrote = emit_compiled_wal_docs(elapsed_us)
    if not wrote:
        print("STATUS: FAIL db wal compiled benchmark write failed")
        return
    print("RESULT|db_wal_insert100|wal|insert+count_visible|{elapsed_us}|us|x86_64|native")
    print("STATUS: PASS db wal compiled benchmark")
