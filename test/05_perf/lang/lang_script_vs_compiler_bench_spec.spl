# AC-4: Script vs Compiler Benchmark Spec
#
# Compares interpreter (script), SMF-loader, and native-compiled execution
# as SEPARATE rows — never collapsed.
#
# Workload: fib(20) = 6765 (deterministic oracle for correctness check).
# Plane: "process" — each mode is a separate child process measured via
#         /usr/bin/time -v, mirroring check-cross-language-perf.shs methodology.
#
# Architecture tag: "x86_64". arm/riscv rows plug in later by tagging or
# adding @skip("arm64") / @skip("riscv") decorators.
#
# Import: use std.io_runtime (NOT app.io — app.io causes 120s timeout).

use app.test.bench.bench_harness.{
    BenchCase, BenchResult,
    make_bench_case, bench_run_process, bench_run_process_rss
}
use app.test.bench.bench_report.{bench_emit}

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_exists(path: text) -> bool
extern fn rt_dir_create_all(path: text) -> bool

# ============================================================================
# Tiny deterministic workload written to a temp file.
# fib(20) = 6765 — small enough to be fast in all modes, large enough to be
# meaningful.  The workload prints "fib_result=<n>" so the test can verify
# correctness across modes.
# ============================================================================

val FIB_ORACLE: i64 = 6765
val FIB_N: i64 = 20

val FIB_SOURCE = "fn fib(n: i64) -> i64:\n    if n < 2:\n        return n\n    fib(n - 1) + fib(n - 2)\n\nfn main():\n    val result = fib(20)\n    println(\"fib_result=\" + result.to_string())\n"

fn write_fib_workload(path: text) -> bool:
    rt_file_write_text(path, FIB_SOURCE)

fn find_simple_bin() -> text:
    # Prefer bin/simple (self-hosted or seed wrapper); fall back to seed.
    if rt_file_exists("bin/simple"):
        return "bin/simple"
    if rt_file_exists("bin/release/x86_64-unknown-linux-gnu/simple_seed"):
        return "bin/release/x86_64-unknown-linux-gnu/simple_seed"
    "bin/simple"

fn parse_fib_result(stdout: text) -> i64:
    # Parse "fib_result=<n>" from process stdout.
    val lines = stdout.split("\n")
    var i: i64 = 0
    while i < lines.len():
        val line = lines[i].trim()
        if line.starts_with("fib_result="):
            val num_str = line.slice(11, line.len())
            return _parse_simple_i64(num_str)
        i = i + 1
    -1

fn _parse_simple_i64(s: text) -> i64:
    var result: i64 = 0
    var idx: i64 = 0
    while idx < s.len():
        val ch = s.char_at(idx)
        val d = ch - '0'
        if d >= 0 and d <= 9:
            result = result * 10 + d
        idx = idx + 1
    result

fn run_mode(simple_bin: text, fib_path: text, mode: text) -> (i64, BenchResult, BenchResult):
    # Returns (fib_value, wall_ms_result, rss_kb_result).
    val bc_wall = make_bench_case("fib20_" + mode, mode, "process", 1)
    val bc_rss = make_bench_case("fib20_" + mode + "_rss", mode, "process", 1)
    val argv_script: [text] = [simple_bin, "run", fib_path]
    val argv_smf: [text] = [simple_bin, "run", "--mode=smf", fib_path]
    val argv_native: [text] = [simple_bin, "run", "--mode=native", fib_path]
    val argv = if mode == "script":
        argv_script
    elif mode == "smf":
        argv_smf
    else:
        argv_native
    # Run once to get stdout for correctness check.
    val (stdout, _stderr, _code) = rt_process_run(simple_bin, _tail(argv))
    val fib_val = parse_fib_result(stdout)
    val wall_r = bench_run_process(bc_wall, argv)
    val rss_r = bench_run_process_rss(bc_rss, argv)
    (fib_val, wall_r, rss_r)

fn _tail(argv: [text]) -> [text]:
    # Drop argv[0] (the executable) since rt_process_run takes cmd + args separately.
    var result: [text] = []
    var i: i64 = 1
    while i < argv.len():
        result.push(argv[i])
        i = i + 1
    result

# ============================================================================
# Spec
# ============================================================================

describe "lang script vs compiler bench (AC-4)":

    it "fib workload writes successfully":
        rt_dir_create_all("/tmp/bench_lang")
        val ok = write_fib_workload("/tmp/bench_lang/fib20.spl")
        expect(ok).to_equal(true)

    it "interpreter (script) mode produces correct fib(20)":
        rt_dir_create_all("/tmp/bench_lang")
        write_fib_workload("/tmp/bench_lang/fib20.spl")
        val simple_bin = find_simple_bin()
        val (fib_val, wall_r, rss_r) = run_mode(simple_bin, "/tmp/bench_lang/fib20.spl", "script")
        # Correctness assertion: oracle = 6765
        expect(fib_val).to_equal(FIB_ORACLE)

    it "interpreter (script) mode wall_ms row has mode=script":
        rt_dir_create_all("/tmp/bench_lang")
        write_fib_workload("/tmp/bench_lang/fib20.spl")
        val simple_bin = find_simple_bin()
        val (_fib_val, wall_r, _rss_r) = run_mode(simple_bin, "/tmp/bench_lang/fib20.spl", "script")
        expect(wall_r.mode).to_equal("script")
        expect(wall_r.plane).to_equal("process")
        expect(wall_r.metric_name).to_equal("wall_ms")

    it "SMF mode produces correct fib(20)":
        @skip("smf-extern-segfault")
        # TODO: SMF loader currently cannot resolve time externs used in harness internals
        # when run via interpreter-spawned process. Enable this test once SMF extern
        # resolution is stable (see cross-language-perf.shs comment on SMF fallback).
        rt_dir_create_all("/tmp/bench_lang")
        write_fib_workload("/tmp/bench_lang/fib20.spl")
        val simple_bin = find_simple_bin()
        val (fib_val, wall_r, _rss_r) = run_mode(simple_bin, "/tmp/bench_lang/fib20.spl", "smf")
        expect(fib_val).to_equal(FIB_ORACLE)

    it "three distinct mode rows exist (never collapsed)":
        rt_dir_create_all("/tmp/bench_lang")
        write_fib_workload("/tmp/bench_lang/fib20.spl")
        val simple_bin = find_simple_bin()
        # Run script and native; record their mode strings as distinct rows.
        val (_fv1, wall_script, _rss1) = run_mode(simple_bin, "/tmp/bench_lang/fib20.spl", "script")
        val (_fv2, wall_native, _rss2) = run_mode(simple_bin, "/tmp/bench_lang/fib20.spl", "native")
        # AC-4: mode strings must be different — never collapsed into one row.
        expect(wall_script.mode).to_equal("script")
        expect(wall_native.mode).to_equal("native")
        # They are provably distinct.
        val modes_differ = wall_script.mode != wall_native.mode
        expect(modes_differ).to_equal(true)

    it "native mode produces correct fib(20)":
        @skip("native-compile-required")
        # Native compilation requires a full toolchain (linker, clang). This test
        # is tagged so it can be enabled on CI where native targets are available.
        # TODO: Enable once native compilation is confirmed stable in test runner.
        rt_dir_create_all("/tmp/bench_lang")
        write_fib_workload("/tmp/bench_lang/fib20.spl")
        val simple_bin = find_simple_bin()
        val (fib_val, wall_r, _rss_r) = run_mode(simple_bin, "/tmp/bench_lang/fib20.spl", "native")
        expect(fib_val).to_equal(FIB_ORACLE)

    it "bench_emit writes report and metrics files":
        rt_dir_create_all("/tmp/bench_lang")
        write_fib_workload("/tmp/bench_lang/fib20.spl")
        val simple_bin = find_simple_bin()
        val (_fv, wall_script, rss_script) = run_mode(simple_bin, "/tmp/bench_lang/fib20.spl", "script")
        val (_fv2, wall_native, rss_native) = run_mode(simple_bin, "/tmp/bench_lang/fib20.spl", "native")
        var results: [BenchResult] = []
        results.push(wall_script)
        results.push(rss_script)
        results.push(wall_native)
        results.push(rss_native)
        val report_path = "/tmp/bench_lang/report_lang_bench.md"
        val table_path = "/tmp/bench_lang/metrics_lang_bench.md"
        bench_emit(results, report_path, table_path)
        expect(rt_file_exists(report_path)).to_equal(true)
        expect(rt_file_exists(table_path)).to_equal(true)
