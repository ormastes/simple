# @cover src/lib/common/ui/scroll_surface.spl 70%
# @cover src/lib/common/ui/dirty_region.spl 70%
#
# Dirty-region partial-redraw correctness + accounting.
#
# The load-bearing check: after a scroll step, the optimized ON path (scroll-blit
# + exposed-band raster + thumb) must produce the SAME framebuffer as the OFF
# baseline (full repaint). If retained content is not translated, ON != OFF and
# the optimization is wrong. We also assert ON's dirty-pixel accounting is far
# below a full repaint.

use std.spec.{describe, it, expect}
use common.ui.dirty_region.{DirtyTracker, clamp_rect, make_dirty_rect}
use common.ui.scroll_surface.{FrameBuffer, ScrollModel, paint_full, step_off, step_on, max_scroll}

fn buffers_equal(a: [i64], b: [i64]) -> bool:
    if a.len() != b.len():
        return false
    var i = 0
    while i < a.len():
        if a[i] != b[i]:
            return false
        i = i + 1
    return true

fn first_diff(a: [i64], b: [i64]) -> i64:
    var i = 0
    while i < a.len() and i < b.len():
        if a[i] != b[i]:
            return i.to_i64()
        i = i + 1
    return (0 - 1)

describe("dirty_region", fn():
    it("clamps rects to the viewport bounds", fn():
        val r = clamp_rect(make_dirty_rect(0 - 10, 0 - 10, 40, 40), 20, 20)
        expect(r.x).to_equal(0)
        expect(r.y).to_equal(0)
        expect(r.w).to_equal(20)
        expect(r.h).to_equal(20)
    )

    it("drops fully out-of-bounds rects to empty", fn():
        val r = clamp_rect(make_dirty_rect(100, 100, 10, 10), 20, 20)
        expect(r.is_empty()).to_equal(true)
    )

    it("sums dirty pixels across marked rects", fn():
        var t = DirtyTracker.create(64, 64)
        t.mark(0, 0, 10, 10)
        t.mark(20, 20, 5, 5)
        expect(t.dirty_pixels()).to_equal(125)
        expect(t.count()).to_equal(2)
    )
)

describe("scroll_surface partial redraw", fn():
    # 64x64 viewport, content much taller than the surface.
    it("ON scroll step yields the same image as OFF full repaint", fn():
        val m = ScrollModel(total_rows: 100, view_w: 64, view_h: 64)
        val step = 16
        # OFF reference: full repaint at scroll=step.
        var fb_off = FrameBuffer.create(64, 64)
        var trk_off = DirtyTracker.create(64, 64)
        val p0 = paint_full(fb_off, m, 0)
        val w_off = step_off(fb_off, m, step, trk_off)
        # ON: prime at scroll=0, then scroll-blit to scroll=step.
        var fb_on = FrameBuffer.create(64, 64)
        var trk_on = DirtyTracker.create(64, 64)
        val p1 = paint_full(fb_on, m, 0)
        val w_on = step_on(fb_on, m, 0, step, trk_on)
        val diff = first_diff(fb_on.buf, fb_off.buf)
        expect(diff).to_equal(0 - 1)
        expect(buffers_equal(fb_on.buf, fb_off.buf)).to_equal(true)
    )

    it("ON scroll-up step matches OFF too", fn():
        val m = ScrollModel(total_rows: 100, view_w: 64, view_h: 64)
        var fb_off = FrameBuffer.create(64, 64)
        var trk_off = DirtyTracker.create(64, 64)
        val p0 = paint_full(fb_off, m, 32)
        val w_off = step_off(fb_off, m, 16, trk_off)
        var fb_on = FrameBuffer.create(64, 64)
        var trk_on = DirtyTracker.create(64, 64)
        val p1 = paint_full(fb_on, m, 32)
        val w_on = step_on(fb_on, m, 32, 16, trk_on)
        expect(buffers_equal(fb_on.buf, fb_off.buf)).to_equal(true)
    )

    it("ON idle step (delta=0) leaves the buffer unchanged and marks 0 dirty", fn():
        val m = ScrollModel(total_rows: 100, view_w: 64, view_h: 64)
        var fb_on = FrameBuffer.create(64, 64)
        var trk = DirtyTracker.create(64, 64)
        val p1 = paint_full(fb_on, m, 32)
        var snapshot = fb_on.buf
        val w = step_on(fb_on, m, 32, 32, trk)
        expect(trk.dirty_pixels()).to_equal(0)
        expect(buffers_equal(fb_on.buf, snapshot)).to_equal(true)
    )

    it("ON dirty pixels are far below a full repaint", fn():
        val m = ScrollModel(total_rows: 100, view_w: 64, view_h: 64)
        var fb_on = FrameBuffer.create(64, 64)
        var trk = DirtyTracker.create(64, 64)
        val p1 = paint_full(fb_on, m, 0)
        val w = step_on(fb_on, m, 0, 16, trk)
        val full = trk.full_pixels()
        expect(trk.dirty_pixels()).to_be_less_than(full)
    )
)
