# Native Simple static server for local NGINX comparison evidence.

extern fn rt_io_tcp_bind(addr: text) -> i64
extern fn rt_io_tcp_listen(fd: i64, backlog: i64) -> i64
extern fn rt_io_tcp_accept(fd: i64) -> i64
extern fn rt_io_tcp_read_line(fd: i64) -> text?
extern fn rt_io_tcp_write_text(fd: i64, data: text) -> i64
extern fn rt_io_tcp_close(fd: i64) -> bool

val LIVE_STATIC_ADDR: text = "127.0.0.1:19080"

fn repeat_text(chunk: text, count: i64) -> text:
    var out = ""
    var i: i64 = 0
    while i < count:
        out = out + chunk
        i = i + 1
    out

fn drain_headers(fd: i64):
    var done = false
    while not done:
        val line = rt_io_tcp_read_line(fd)
        if line == nil:
            done = true
        else:
            val text_line = line as text
            if text_line == "" or text_line == "\n" or text_line == "\r\n":
                done = true

fn write_static_response(fd: i64, chunk: text, chunk_count: i64, content_len: i64):
    val header = "HTTP/1.1 200 OK\r\nServer: SimpleNativeStaticCompare\r\nContent-Type: text/plain\r\nContent-Length: {content_len}\r\nConnection: close\r\n\r\n"
    val _header_written = rt_io_tcp_write_text(fd, header)
    var i: i64 = 0
    while i < chunk_count:
        val _chunk_written = rt_io_tcp_write_text(fd, chunk)
        i = i + 1

fn main():
    val body_1kb = repeat_text("A", 1024)
    val block_1kb = repeat_text("B", 1024)

    val listener = rt_io_tcp_bind(LIVE_STATIC_ADDR)
    if listener < 0:
        print "[simple-nginx-compare-error] bind"
        return
    val listening = rt_io_tcp_listen(listener, 128)
    if listening <= 0:
        val _listener_closed = rt_io_tcp_close(listener)
        print "[simple-nginx-compare-error] listen"
        return

    print "[simple-nginx-compare-ready] addr={LIVE_STATIC_ADDR}"
    while true:
        val fd = rt_io_tcp_accept(listener)
        if fd >= 0:
            val request_line = rt_io_tcp_read_line(fd)
            if request_line != nil:
                val line = request_line as text
                drain_headers(fd)
                if line.contains("1mb"):
                    write_static_response(fd, block_1kb, 1024, 1048576)
                else:
                    write_static_response(fd, body_1kb, 1, 1024)
            val _closed = rt_io_tcp_close(fd)
