# Graphics 2D backend preference startup perf gate.
#
# Verifies the Pure Simple GUI/Engine2D backend preference order and keeps the
# startup-order helper path bounded without requiring local GPU hardware.

extern fn rt_time_now_unix_micros() -> i64

use std.spec.{describe, it, expect}
use std.gpu.engine2d.backend_lane.{
    engine2d_backend_lane_drawing_preference_order,
    engine2d_backend_lane_full_preference_order,
    engine2d_backend_lane_preference_summary,
    engine2d_backend_lane_preferred_candidate,
    engine2d_backend_lane_preferred_font_offload_candidate,
    engine2d_font_offload_backend_order
}

fn _bench_preference_helpers(iterations: i64) -> i64:
    var i = 0
    val start = rt_time_now_unix_micros()
    while i < iterations:
        val drawing = engine2d_backend_lane_drawing_preference_order()
        val full = engine2d_backend_lane_full_preference_order()
        val font = engine2d_font_offload_backend_order()
        val selected = engine2d_backend_lane_preferred_candidate(["cpu", "vulkan", "cuda"], false)
        val font_selected = engine2d_backend_lane_preferred_font_offload_candidate(["software", "cpu_simd", "vulkan"])
        if drawing[0] != "metal" or full[0] != "baremetal" or font[0] != "metal":
            return 999999999i64
        if selected != "cuda" or font_selected != "vulkan":
            return 999999999i64
        i = i + 1
    rt_time_now_unix_micros() - start

describe "graphics_2d backend preference startup":
    it "keeps explicit-native and auto drawing order stable":
        val drawing = engine2d_backend_lane_drawing_preference_order()
        val full = engine2d_backend_lane_full_preference_order()

        expect(drawing[0]).to_equal("metal")
        expect(drawing[1]).to_equal("cuda")
        expect(drawing[2]).to_equal("rocm")
        expect(drawing[4]).to_equal("vulkan")
        expect(drawing[5]).to_equal("directx")
        expect(full[0]).to_equal("baremetal")
        expect(full[1]).to_equal("virtio_gpu")
        expect(full[2]).to_equal("metal")
        expect(engine2d_backend_lane_preference_summary()).to_contain("vulkan > directx > opencl")

    it "keeps vector and bitmap font offload order GPU-first":
        val font = engine2d_font_offload_backend_order()

        expect(font[0]).to_equal("metal")
        expect(font[1]).to_equal("cuda")
        expect(font[2]).to_equal("rocm")
        expect(font[4]).to_equal("vulkan")
        expect(font[10]).to_equal("cpu_simd")
        expect(font[11]).to_equal("software")
        expect(font[12]).to_equal("cpu")
        expect(engine2d_backend_lane_preferred_font_offload_candidate(["software", "cpu_simd", "vulkan"])).to_equal("vulkan")
        expect(engine2d_backend_lane_preferred_font_offload_candidate(["cpu", "amd-hip", "cuda"])).to_equal("cuda")

    it "keeps preference helper startup path bounded":
        val elapsed_us = _bench_preference_helpers(1000)
        print "[perf] backend preference helpers: {elapsed_us} us for 1000 iterations"

        expect(elapsed_us).to_be_less_than(2000000i64)
