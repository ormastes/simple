# Metal Engine2D Smoke Tests
#
# @tag: perf, graphics, engine2d, metal, hardware
# @cover src/lib/gc_async_mut/gpu/engine2d/backend_metal.spl 45%
#
# Uses the real Metal backend. Linux proves the typed macOS-unavailable result;
# macOS initializes Metal, renders, and verifies device-backed pixels.

use std.spec.{describe, context, it, expect}
use std.gc_async_mut.gpu.engine2d.backend_metal.{MetalBackend, probe_metal}
use std.gc_async_mut.gpu.engine2d.backend_probe.{BackendStatus}
use std.nogc_sync_mut.env.platform.{is_macos}

describe "Metal Engine2D smoke tests":

    context "probe":

        it "reports the real Metal API and shader format":
            val probe = probe_metal()
            expect(probe.requested_name).to_equal("metal")
            expect(probe.api_name).to_equal("metal")
            expect(probe.shader_format).to_equal("msl")

        it "reports macOS as unavailable on non-macOS hosts":
            if not is_macos():
                val probe = probe_metal()
                expect(probe.status).to_equal(BackendStatus.Unavailable)
                expect(probe.feature_gate).to_equal("macos")

    context "device readback":

        it "initializes the real Metal backend when macOS is available":
            if is_macos():
                var backend = MetalBackend.create()
                expect(backend.init(16, 16)).to_equal(true)
                backend.shutdown()

        it "reads back rendered Metal pixels when macOS is available":
            if is_macos():
                var backend = MetalBackend.create()
                expect(backend.init(16, 16)).to_equal(true)
                val background = 0xFF102030 as u32
                val foreground = 0xFF405060 as u32
                backend.clear(background)
                backend.draw_rect_filled(4, 4, 4, 4, foreground)
                val readback = backend.read_pixels_with_source()
                expect(readback.source).to_equal("device_readback")
                expect(readback.pixels.len()).to_equal(256)
                expect(readback.pixels[0]).to_equal(background)
                expect(readback.pixels[4 + (4 * 16)]).to_equal(foreground)
                backend.shutdown()
