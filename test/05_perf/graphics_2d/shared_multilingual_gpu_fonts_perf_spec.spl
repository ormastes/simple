# @tag: rendering, font, performance
# @req NFR-002 NFR-004 NFR-005 NFR-006 NFR-007 NFR-008

"""# Shared Multilingual Font Performance Evidence

Shapes the ten selected language witnesses through three pinned live faces,
materializes them in one FontRenderer atlas, and measures identical warm CPU
and Vulkan run sequences. One discarded frame warms shaping material, glyph
cache entries, and the backend atlas before the retained eleven samples.
The same prepared batch identity is captured before and after controlled Vulkan
surface poison, then the unchanged 4,096-glyph CPU route retains eleven samples.
Schema v5 also retains seven 4,096-glyph Vulkan stage arrays and the final
compiled-artifact, batch/payload, handle, fence, changed-pixel, and parity
observation. `queue_device` is the fused submit-through-completion interval;
`sync` is the later fence observation, and present is not applicable offscreen.

The 2D rows are real measurements. Four fresh child processes provide paired
legacy/multiface RSS rows for 2D and Engine3D Vulkan HUD/world material; a
missing device or malformed child record remains unavailable.
"""

use std.spec.{describe, it, expect, step}
use std.io_runtime.{file_hash_sha256, file_read_bytes}
use app.io.mod.{process_run_timeout}
use std.common.encoding.utf8.{text_codepoints}
use std.gc_async_mut.gpu.engine2d.engine.{Engine2D}
use std.gc_async_mut.gpu.engine2d.backend_vulkan.{VulkanBackend}
use std.gc_async_mut.gpu.engine2d.color.{rgb}
use std.gc_async_mut.io.time_ops.{time_now_nanos}
use std.nogc_sync_mut.io.font_sffi.{FontHandle, load_font, free_font}
use std.nogc_sync_mut.text_layout.font_renderer.{FontRenderer}
use std.nogc_sync_mut.text_layout.font_types.{FontGlyphRun}
use std.skia.entity.font.{SkFont, sk_font_new, sk_font_style_normal, sk_typeface_from_attached_font}
use std.skia.feature.glyph.ot_parser.{parse_offset_table}
use std.skia.feature.shaper.font_fallback.{fallback_chain_new, fallback_chain_add}
use std.skia.feature.shaper.shaper.{
    Shaper, shaper_new, shaper_with_ot_face, shaper_shape_with_language,
    shaped_run_to_font_glyph_run
}
use test.helpers.shared_multilingual_gpu_fonts_perf_evidence.{
    FONT_PERF_FACE_SC_PATH, FONT_PERF_FACE_SC_SHA256,
    FONT_PERF_FACE_DEVANAGARI_PATH, FONT_PERF_FACE_DEVANAGARI_SHA256,
    FONT_PERF_FACE_ARABIC_PATH, FONT_PERF_FACE_ARABIC_SHA256,
    FONT_PERF_RSS_PROBE_PATH, FontPerfBudgetEvidence, FontPerfRssEvidence,
    unavailable_font_perf_evidence, expect_font_perf_budget, font_perf_p95,
    font_perf_rss_growth_percent, font_perf_samples_text,
    write_font_perf_evidence, read_font_perf_evidence
}

val SAMPLE_COUNT: i64 = 11
val MULTIFACE_UNIT_GLYPHS: i64 = 68
val MULTIFACE_UNIT = "English|中文|Español|हिन्दी|العربية|français|Português|Русский|اردو|Indonesia"

class MultiFacePerfFixture:
    sc_handle: FontHandle
    devanagari_handle: FontHandle
    arabic_handle: FontHandle
    primary_font: SkFont
    shaper: Shaper
    renderer: FontRenderer

class _PerfRunBuilder:
    face_id: i64
    face_generation: i64
    glyph_ids: [u32]
    xs: [i32]
    ys: [i32]
    clusters: [i64]

    static fn from_handle(handle: FontHandle) -> _PerfRunBuilder:
        _PerfRunBuilder(face_id: handle.handle, face_generation: handle.generation,
            glyph_ids: [], xs: [], ys: [], clusters: [])

    fn append(run: FontGlyphRun, cluster_offset: i64):
        var index: i64 = 0
        while index < run.glyph_ids.len():
            self.glyph_ids.push(run.glyph_ids[index])
            self.xs.push(run.xs[index])
            self.ys.push(run.ys[index])
            self.clusters.push(run.clusters[index] + cluster_offset)
            index = index + 1

    fn build() -> FontGlyphRun:
        FontGlyphRun(valid: self.glyph_ids.len() > 0, face_id: self.face_id,
            face_generation: self.face_generation, glyph_ids: self.glyph_ids,
            xs: self.xs, ys: self.ys, clusters: self.clusters)

class _FontPerfRouteEvidence:
    ok: bool
    p95_ns: i64
    hits: i64
    misses: i64
    unchanged_upload: bool
    gpu_resource_high_water_bytes: i64
    samples_ns: [i64]
    reason: text
    device_name: text
    driver_identity: text
    device_loss_status: text = ""
    batch_identity_before: text = ""
    batch_identity_after: text = ""
    stage_shaping_samples_ns: [i64] = []
    stage_material_samples_ns: [i64] = []
    stage_dirty_upload_samples_ns: [i64] = []
    stage_queue_device_samples_ns: [i64] = []
    stage_sync_samples_ns: [i64] = []
    stage_present_readback_samples_ns: [i64] = []
    stage_cpu_oracle_samples_ns: [i64] = []
    promotion_artifact_identity: text = ""
    promotion_entry_name: text = ""
    promotion_program_version: i64 = 0
    stage_emission_compile_ns: i64 = 0
    promotion_batch_identity: text = ""
    promotion_atlas_payload_sha256: text = ""
    promotion_shader_handle: i64 = 0
    promotion_pipeline_handle: i64 = 0
    promotion_atlas_buffer_handle: i64 = 0
    promotion_params_buffer_handle: i64 = 0
    promotion_command_handle: i64 = 0
    promotion_fence_handle: i64 = 0
    promotion_readback_buffer_handle: i64 = 0
    promotion_quad_count: i64 = 0
    promotion_dispatch_count: i64 = 0
    promotion_submitted: bool = false
    promotion_completion_waited: bool = false
    promotion_fence_evidence_available: bool = false
    promotion_fence_destroyed: bool = false
    promotion_readback_source: text = ""
    promotion_readback_byte_count: i64 = 0
    promotion_readback_nonblank_pixels: i64 = 0
    promotion_device_checksum: i64 = 0
    promotion_oracle_checksum: i64 = 0
    promotion_parity: bool = false
    promotion_device_executed: bool = false
    promotion_ready: bool = false
    promotion_present_mode: text = ""

class _FontPerfRssProbeRecord:
    valid: bool
    mode: text
    status: text
    rss_kb: i64
    reason: text

var _multiface_perf_fixture: MultiFacePerfFixture? = nil
var _multiface_perf_reason = "multiface-fixture-not-initialized"
var _multiface_last_evidence_overhead_ns: i64 = 0
var _multiface_last_material_ns: i64 = 0
var _multiface_last_dirty_upload_ns: i64 = 0
var _multiface_last_queue_device_ns: i64 = 0
var _multiface_last_sync_ns: i64 = 0
var _multiface_last_present_readback_ns: i64 = 0
var _multiface_last_cpu_oracle_ns: i64 = 0

fn _failed_route(reason: text, samples: [i64]) -> _FontPerfRouteEvidence:
    _FontPerfRouteEvidence(ok: false, p95_ns: 0, hits: 0, misses: 0,
        unchanged_upload: false, gpu_resource_high_water_bytes: 0,
        samples_ns: samples, reason: reason, device_name: "", driver_identity: "")

fn _failed_rss(reason: text) -> FontPerfRssEvidence:
    FontPerfRssEvidence(legacy_2d_kb: 0, multiface_2d_kb: 0,
        legacy_3d_kb: 0, multiface_3d_kb: 0, available: false, reason: reason)

fn _rss_record_value(field: text, prefix: text) -> text:
    if not field.starts_with(prefix): return ""
    field.substring(prefix.len(), field.len())

fn _parse_rss_probe_record(stdout: text, expected_mode: text) -> _FontPerfRssProbeRecord:
    val record = stdout.trim()
    val fields = record.split(" ")
    if record == "" or record.contains("\n") or record.contains("\r") or fields.len() != 5:
        return _FontPerfRssProbeRecord(valid: false, mode: expected_mode,
            status: "unavailable", rss_kb: 0, reason: "malformed-record")
    val mode = _rss_record_value(fields[1], "mode=")
    val status = _rss_record_value(fields[2], "status=")
    val rss = _rss_record_value(fields[3], "rss_kb=").to_i64() ?? -1
    val reason = _rss_record_value(fields[4], "reason=")
    val valid = fields[0] == "font-perf-rss/v1" and mode == expected_mode and
        (status == "pass" or status == "unavailable") and reason != "" and
        not reason.contains("=") and
        ((status == "pass" and rss > 0 and reason == "pass") or
         (status == "unavailable" and rss == 0 and reason != "pass"))
    _FontPerfRssProbeRecord(valid: valid, mode: mode, status: status,
        rss_kb: if valid: rss else: 0,
        reason: if valid: reason else: "malformed-record")

fn _collect_rss_probe(mode: text) -> _FontPerfRssProbeRecord:
    val (stdout, _stderr, exit_code) = process_run_timeout(
        "bin/simple", ["run", FONT_PERF_RSS_PROBE_PATH, mode], 120000)
    if exit_code != 0:
        return _FontPerfRssProbeRecord(valid: false, mode: mode,
            status: "unavailable", rss_kb: 0, reason: "child-process-failed")
    _parse_rss_probe_record(stdout, mode)

fn collect_font_perf_rss_isolated() -> FontPerfRssEvidence:
    val legacy_2d = _collect_rss_probe("legacy-2d")
    if not legacy_2d.valid or legacy_2d.status != "pass":
        return _failed_rss("legacy-2d-" + legacy_2d.reason)
    val multiface_2d = _collect_rss_probe("multiface-2d")
    if not multiface_2d.valid or multiface_2d.status != "pass":
        return _failed_rss("multiface-2d-" + multiface_2d.reason)
    val legacy_3d = _collect_rss_probe("legacy-3d")
    if not legacy_3d.valid or legacy_3d.status != "pass":
        return _failed_rss("legacy-3d-" + legacy_3d.reason)
    val multiface_3d = _collect_rss_probe("multiface-3d")
    if not multiface_3d.valid or multiface_3d.status != "pass":
        return _failed_rss("multiface-3d-" + multiface_3d.reason)
    FontPerfRssEvidence(legacy_2d_kb: legacy_2d.rss_kb,
        multiface_2d_kb: multiface_2d.rss_kb,
        legacy_3d_kb: legacy_3d.rss_kb,
        multiface_3d_kb: multiface_3d.rss_kb,
        available: true, reason: "pass")

fn _free_optional_font(handle: FontHandle?):
    if handle != nil: free_font(handle.?)

fn _close_multiface_perf_fixture():
    val active = _multiface_perf_fixture
    _multiface_perf_fixture = nil
    if active != nil:
        free_font(active.?.sc_handle)
        free_font(active.?.devanagari_handle)
        free_font(active.?.arabic_handle)

fn setup_multiface_perf_fixture() -> MultiFacePerfFixture?:
    _close_multiface_perf_fixture()
    if (file_hash_sha256(FONT_PERF_FACE_SC_PATH) != FONT_PERF_FACE_SC_SHA256 or
        file_hash_sha256(FONT_PERF_FACE_DEVANAGARI_PATH) != FONT_PERF_FACE_DEVANAGARI_SHA256 or
        file_hash_sha256(FONT_PERF_FACE_ARABIC_PATH) != FONT_PERF_FACE_ARABIC_SHA256):
        _multiface_perf_reason = "multiface-font-hash-mismatch"
        return nil
    val sc_loaded = load_font(FONT_PERF_FACE_SC_PATH)
    if sc_loaded == nil:
        _multiface_perf_reason = "noto-sans-sc-unavailable"
        return nil
    val devanagari_loaded = load_font(FONT_PERF_FACE_DEVANAGARI_PATH)
    if devanagari_loaded == nil:
        _free_optional_font(sc_loaded)
        _multiface_perf_reason = "noto-sans-devanagari-unavailable"
        return nil
    val arabic_loaded = load_font(FONT_PERF_FACE_ARABIC_PATH)
    if arabic_loaded == nil:
        _free_optional_font(sc_loaded)
        _free_optional_font(devanagari_loaded)
        _multiface_perf_reason = "noto-sans-arabic-unavailable"
        return nil
    val sc_parsed = parse_offset_table(file_read_bytes(FONT_PERF_FACE_SC_PATH))
    val devanagari_parsed = parse_offset_table(file_read_bytes(FONT_PERF_FACE_DEVANAGARI_PATH))
    val arabic_parsed = parse_offset_table(file_read_bytes(FONT_PERF_FACE_ARABIC_PATH))
    if sc_parsed == nil or devanagari_parsed == nil or arabic_parsed == nil:
        _free_optional_font(sc_loaded)
        _free_optional_font(devanagari_loaded)
        _free_optional_font(arabic_loaded)
        _multiface_perf_reason = "multiface-offset-table-unavailable"
        return nil
    val sc_handle = sc_loaded.?
    val devanagari_handle = devanagari_loaded.?
    val arabic_handle = arabic_loaded.?
    val sc_font = sk_font_new(sk_typeface_from_attached_font("Noto Sans SC",
        sk_font_style_normal(), FONT_PERF_FACE_SC_PATH, sc_handle.handle), 32.0)
    val devanagari_font = sk_font_new(sk_typeface_from_attached_font("Noto Sans Devanagari",
        sk_font_style_normal(), FONT_PERF_FACE_DEVANAGARI_PATH, devanagari_handle.handle), 32.0)
    val arabic_font = sk_font_new(sk_typeface_from_attached_font("Noto Sans Arabic",
        sk_font_style_normal(), FONT_PERF_FACE_ARABIC_PATH, arabic_handle.handle), 32.0)
    var chain = fallback_chain_new(sc_font)
    chain = fallback_chain_add(chain, devanagari_font)
    chain = fallback_chain_add(chain, arabic_font)
    var shaper = shaper_new(chain)
    shaper = shaper_with_ot_face(shaper, sc_handle.handle, sc_parsed.unwrap())
    shaper = shaper_with_ot_face(shaper, devanagari_handle.handle, devanagari_parsed.unwrap())
    shaper = shaper_with_ot_face(shaper, arabic_handle.handle, arabic_parsed.unwrap())
    val fixture = MultiFacePerfFixture(sc_handle: sc_handle,
        devanagari_handle: devanagari_handle, arabic_handle: arabic_handle,
        primary_font: sc_font, shaper: shaper, renderer: FontRenderer.new())
    _multiface_perf_fixture = fixture
    _multiface_perf_reason = "pass"
    fixture

fn _append_fixture_segment(current: text, segment: text) -> text:
    if current == "": segment else: current + "|" + segment

fn _mixed_fixture(glyph_count: i64) -> text:
    var content = ""
    var emitted: i64 = 0
    while emitted + MULTIFACE_UNIT_GLYPHS <= glyph_count:
        content = _append_fixture_segment(content, MULTIFACE_UNIT)
        emitted = emitted + MULTIFACE_UNIT_GLYPHS
    while emitted < glyph_count:
        content = _append_fixture_segment(content, "A")
        emitted = emitted + 1
    content

fn _witness_language(segment: text) -> text:
    if segment == "English" or segment == "A": return "en"
    if segment == "中文": return "zh"
    if segment == "Español": return "es"
    if segment == "हिन्दी": return "hi"
    if segment == "العربية": return "ar"
    if segment == "français": return "fr"
    if segment == "Português": return "pt"
    if segment == "Русский": return "ru"
    if segment == "اردو": return "ur"
    if segment == "Indonesia": return "id"
    ""

fn _expected_face_id(fixture: MultiFacePerfFixture, language: text) -> i64:
    if language == "hi": return fixture.devanagari_handle.handle
    if language == "ar" or language == "ur": return fixture.arabic_handle.handle
    fixture.sc_handle.handle

fn prepare_multiface_runs(content: text, size: i32) -> [FontGlyphRun]:
    val active = _multiface_perf_fixture
    if active == nil or content == "" or size <= 0:
        _multiface_perf_reason = "multiface-fixture-or-content-invalid"
        return []
    val fixture = active.?
    var sc = _PerfRunBuilder.from_handle(fixture.sc_handle)
    var devanagari = _PerfRunBuilder.from_handle(fixture.devanagari_handle)
    var arabic = _PerfRunBuilder.from_handle(fixture.arabic_handle)
    var cursor = 0.0
    var cluster_offset: i64 = 0
    for segment in content.split("|"):
        val language = _witness_language(segment)
        if language == "":
            _multiface_perf_reason = "multiface-witness-unrecognized"
            return []
        var codepoints: [u32] = []
        for codepoint in text_codepoints(segment): codepoints.push(codepoint as u32)
        val shaped = shaper_shape_with_language(fixture.shaper, codepoints,
            fixture.primary_font, cursor, 0.0, language)
        if shaped.len() != 1:
            _multiface_perf_reason = "multiface-shaping-run-count-mismatch"
            return []
        val run = shaped[0]
        val material = shaped_run_to_font_glyph_run(run)
        if (not material.valid or material.face_id != _expected_face_id(fixture, language) or
            material.glyph_ids.len() == 0):
            _multiface_perf_reason = "multiface-exact-shaping-unavailable"
            return []
        if material.face_id == fixture.sc_handle.handle:
            sc.append(material, cluster_offset)
        elif material.face_id == fixture.devanagari_handle.handle:
            devanagari.append(material, cluster_offset)
        elif material.face_id == fixture.arabic_handle.handle:
            arabic.append(material, cluster_offset)
        else:
            _multiface_perf_reason = "multiface-unexpected-face"
            return []
        for glyph in run.glyphs: cursor = cursor + glyph.x_advance
        cluster_offset = cluster_offset + codepoints.len() + 1
    _multiface_perf_reason = "pass"
    [sc.build(), devanagari.build(), arabic.build()]

fn draw_multiface_runs(engine: Engine2D, runs: [FontGlyphRun], color: u32, size: i32) -> bool:
    if runs.len() != 3:
        _multiface_perf_reason = "multiface-material-run-count-mismatch"
        return false
    _multiface_last_evidence_overhead_ns = 0
    _multiface_last_material_ns = 0
    _multiface_last_dirty_upload_ns = 0
    _multiface_last_queue_device_ns = 0
    _multiface_last_sync_ns = 0
    _multiface_last_present_readback_ns = 0
    _multiface_last_cpu_oracle_ns = 0
    var fonts = engine.fonts()
    for run in runs:
        val material_started = time_now_nanos()
        val batch = fonts.prepare_glyph_run(run, color, size)
        _multiface_last_material_ns = _multiface_last_material_ns + (time_now_nanos() - material_started)
        engine.font_renderer = fonts
        if not run.valid or not batch.material_supported() or not engine._draw_font_batch(0, 0, batch):
            _multiface_perf_reason = "multiface-draw-failed"
            return false
        if engine.backend_name() == "vulkan":
            val evidence = engine.vulkan_font_performance_evidence()
            if evidence == nil or not evidence.?.promotion_ready:
                if evidence == nil:
                    _multiface_perf_reason = "missing-vulkan-font-evidence"
                else:
                    _multiface_perf_reason = evidence.?.reason
                return false
            _multiface_last_evidence_overhead_ns = _multiface_last_evidence_overhead_ns + evidence.?.evidence_overhead_ns
            _multiface_last_dirty_upload_ns = _multiface_last_dirty_upload_ns + evidence.?.dirty_upload_ns
            _multiface_last_queue_device_ns = _multiface_last_queue_device_ns + evidence.?.queue_device_ns
            _multiface_last_sync_ns = _multiface_last_sync_ns + evidence.?.sync_wait_ns
            _multiface_last_present_readback_ns = _multiface_last_present_readback_ns + evidence.?.present_readback_ns
            _multiface_last_cpu_oracle_ns = _multiface_last_cpu_oracle_ns + evidence.?.cpu_oracle_ns
    _multiface_perf_reason = "pass"
    true

fn _run_glyph_count(runs: [FontGlyphRun]) -> i64:
    var count: i64 = 0
    for run in runs: count = count + run.glyph_ids.len()
    count

fn _measure_route(width: i32, height: i32, backend: text,
                  content: text, glyph_count: i64,
                  controlled_device_loss: bool) -> _FontPerfRouteEvidence:
    val active = _multiface_perf_fixture
    if active == nil: return _failed_route("multiface-fixture-not-initialized", [])
    var fixture = active.?
    fixture.renderer = FontRenderer.new()
    _multiface_perf_fixture = fixture
    var engine = Engine2D.create_with_backend(width, height, backend)
    engine.font_renderer = fixture.renderer
    if backend == "vulkan":
        if engine.backend_name() != "vulkan" or engine.vulkan_backend == nil:
            engine.shutdown()
            return _failed_route("vulkan-backend-unavailable", [])
        val selected = engine.vulkan_backend
        var vulkan = selected.?
        val pipeline = vulkan.font_atlas_pipeline_evidence()
        engine.vulkan_backend = vulkan
        if pipeline.status != "ready" or pipeline.artifact_mode != "precompiled-spirv":
            engine.shutdown()
            val reason = if pipeline.status != "ready": pipeline.reason else: "precompiled-spirv-required"
            return _failed_route(reason, [])
    val warm_runs = prepare_multiface_runs(content, 32)
    if _run_glyph_count(warm_runs) != glyph_count:
        engine.shutdown()
        return _failed_route("multiface-glyph-count-mismatch", [])
    engine.clear(rgb(0, 0, 0))
    if not draw_multiface_runs(engine, warm_runs, 0xffffffffu32, 32):
        engine.shutdown()
        return _failed_route(_multiface_perf_reason, [])
    var device_loss_status = ""
    var batch_identity_before = ""
    var batch_identity_after = ""
    if controlled_device_loss:
        var recovery_fonts = engine.fonts()
        val recovery_batch = recovery_fonts.prepare_glyph_run(warm_runs[0], 0xffffffffu32, 32)
        engine.font_renderer = recovery_fonts
        if not recovery_batch.material_supported():
            engine.shutdown()
            return _failed_route("controlled-poison-batch-identity-unavailable", [])
        batch_identity_before = recovery_batch.atlas_cache_identity()
        engine.selected_backend_name = "vulkan-controlled-poison"
        engine.vulkan_backend = VulkanBackend.create()
        engine._poison_vulkan_font_surface(engine.read_pixels())
        if not engine._draw_font_batch(0, 0, recovery_batch):
            engine.shutdown()
            return _failed_route("controlled-poison-cpu-replay-failed", [])
        batch_identity_after = recovery_batch.atlas_cache_identity()
        if batch_identity_after != batch_identity_before:
            engine.shutdown()
            return _failed_route("controlled-poison-batch-identity-changed", [])
        device_loss_status = "controlled-poison-cpu-fallback"
    var warm_fonts = engine.fonts()
    val warm_generation = warm_fonts.atlas_generation
    warm_fonts.reset_cache_stats()
    engine.font_renderer = warm_fonts
    var uploads_before: i64 = 0
    if backend == "vulkan":
        val warm_evidence = engine.vulkan_font_performance_evidence()
        if warm_evidence == nil:
            engine.shutdown()
            return _failed_route("missing-vulkan-font-evidence", [])
        uploads_before = warm_evidence.?.atlas_upload_count
    var samples: [i64] = []
    var stage_shaping_samples: [i64] = []
    var stage_material_samples: [i64] = []
    var stage_dirty_upload_samples: [i64] = []
    var stage_queue_device_samples: [i64] = []
    var stage_sync_samples: [i64] = []
    var stage_present_readback_samples: [i64] = []
    var stage_cpu_oracle_samples: [i64] = []
    var stable_artifact_identity = ""
    var stable_batch_identity = ""
    var stable_atlas_payload_sha256 = ""
    var stable_pipeline_handle: i64 = 0
    var sample: i64 = 0
    while sample < SAMPLE_COUNT:
        engine.clear(rgb(0, 0, 0))
        val started = time_now_nanos()
        val shaping_started = time_now_nanos()
        val runs = prepare_multiface_runs(content, 32)
        val shaping_ns = time_now_nanos() - shaping_started
        if (_run_glyph_count(runs) != glyph_count or
            not draw_multiface_runs(engine, runs, 0xffffffffu32, 32)):
            engine.shutdown()
            return _failed_route(_multiface_perf_reason, samples)
        if backend == "vulkan":
            val sample_evidence = engine.vulkan_font_performance_evidence()
            if sample_evidence == nil or not sample_evidence.?.promotion_ready:
                engine.shutdown()
                return _failed_route("incomplete-vulkan-stage-evidence", samples)
            if stable_artifact_identity == "":
                stable_artifact_identity = sample_evidence.?.artifact_identity
                stable_batch_identity = sample_evidence.?.batch_identity
                stable_atlas_payload_sha256 = sample_evidence.?.atlas_payload_sha256
                stable_pipeline_handle = sample_evidence.?.pipeline_handle
            elif (sample_evidence.?.artifact_identity != stable_artifact_identity or
                sample_evidence.?.batch_identity != stable_batch_identity or
                sample_evidence.?.atlas_payload_sha256 != stable_atlas_payload_sha256 or
                sample_evidence.?.pipeline_handle != stable_pipeline_handle):
                engine.shutdown()
                return _failed_route("unstable-vulkan-stage-identity", samples)
        val total_elapsed = time_now_nanos() - started
        var elapsed = total_elapsed
        if backend == "vulkan" and total_elapsed > _multiface_last_evidence_overhead_ns:
            elapsed = total_elapsed - _multiface_last_evidence_overhead_ns
        if elapsed <= 0:
            engine.shutdown()
            return _failed_route("multiface-elapsed-time-invalid", samples)
        samples.push(elapsed)
        stage_shaping_samples.push(shaping_ns)
        stage_material_samples.push(_multiface_last_material_ns)
        if backend == "vulkan":
            stage_dirty_upload_samples.push(_multiface_last_dirty_upload_ns)
            stage_queue_device_samples.push(_multiface_last_queue_device_ns)
            stage_sync_samples.push(_multiface_last_sync_ns)
            stage_present_readback_samples.push(_multiface_last_present_readback_ns)
            stage_cpu_oracle_samples.push(_multiface_last_cpu_oracle_ns)
        sample = sample + 1
    val stats = engine.font_cache_stats()
    val final_fonts = engine.fonts()
    var unchanged_upload = final_fonts.atlas_generation == warm_generation
    var resources: i64 = 0
    var device = ""
    var driver = ""
    var promotion_artifact_identity = ""
    var promotion_entry_name = ""
    var promotion_program_version: i64 = 0
    var stage_emission_compile_ns: i64 = 0
    var promotion_batch_identity = ""
    var promotion_atlas_payload_sha256 = ""
    var promotion_shader_handle: i64 = 0
    var promotion_pipeline_handle: i64 = 0
    var promotion_atlas_buffer_handle: i64 = 0
    var promotion_params_buffer_handle: i64 = 0
    var promotion_command_handle: i64 = 0
    var promotion_fence_handle: i64 = 0
    var promotion_readback_buffer_handle: i64 = 0
    var promotion_quad_count: i64 = 0
    var promotion_dispatch_count: i64 = 0
    var promotion_submitted = false
    var promotion_completion_waited = false
    var promotion_fence_evidence_available = false
    var promotion_fence_destroyed = false
    var promotion_readback_source = ""
    var promotion_readback_byte_count: i64 = 0
    var promotion_readback_nonblank_pixels: i64 = 0
    var promotion_device_checksum: i64 = 0
    var promotion_oracle_checksum: i64 = 0
    var promotion_parity = false
    var promotion_device_executed = false
    var promotion_ready = false
    var promotion_present_mode = ""
    if backend == "vulkan":
        val final_evidence = engine.vulkan_font_performance_evidence()
        if final_evidence == nil:
            engine.shutdown()
            return _failed_route("missing-vulkan-font-evidence", samples)
        unchanged_upload = unchanged_upload and
            final_evidence.?.atlas_upload_count == uploads_before
        resources = final_evidence.?.gpu_resource_high_water_bytes
        device = final_evidence.?.device_name
        driver = final_evidence.?.driver_identity
        promotion_artifact_identity = final_evidence.?.artifact_identity
        promotion_entry_name = final_evidence.?.entry_name
        promotion_program_version = final_evidence.?.program_version
        stage_emission_compile_ns = final_evidence.?.emission_compile_ns
        promotion_batch_identity = final_evidence.?.batch_identity
        promotion_atlas_payload_sha256 = final_evidence.?.atlas_payload_sha256
        promotion_shader_handle = final_evidence.?.shader_handle
        promotion_pipeline_handle = final_evidence.?.pipeline_handle
        promotion_atlas_buffer_handle = final_evidence.?.atlas_buffer_handle
        promotion_params_buffer_handle = final_evidence.?.params_buffer_handle
        promotion_command_handle = final_evidence.?.command_handle
        promotion_fence_handle = final_evidence.?.fence_handle
        promotion_readback_buffer_handle = final_evidence.?.readback_buffer_handle
        promotion_quad_count = final_evidence.?.quad_count
        promotion_dispatch_count = final_evidence.?.dispatch_count
        promotion_submitted = final_evidence.?.submitted
        promotion_completion_waited = final_evidence.?.completion_waited
        promotion_fence_evidence_available = final_evidence.?.fence_evidence_available
        promotion_fence_destroyed = final_evidence.?.fence_destroyed
        promotion_readback_source = final_evidence.?.readback_source
        promotion_readback_byte_count = final_evidence.?.readback_byte_count
        promotion_readback_nonblank_pixels = final_evidence.?.readback_nonblank_pixels
        promotion_device_checksum = final_evidence.?.device_checksum
        promotion_oracle_checksum = final_evidence.?.oracle_checksum
        promotion_parity = final_evidence.?.parity
        promotion_device_executed = final_evidence.?.device_executed
        promotion_ready = final_evidence.?.promotion_ready
        promotion_present_mode = final_evidence.?.present_mode
    engine.shutdown()
    _FontPerfRouteEvidence(ok: true, p95_ns: font_perf_p95(samples),
        hits: stats.hits, misses: stats.misses, unchanged_upload: unchanged_upload,
        gpu_resource_high_water_bytes: resources, samples_ns: samples,
        reason: "pass", device_name: device, driver_identity: driver,
        device_loss_status: device_loss_status,
        batch_identity_before: batch_identity_before,
        batch_identity_after: batch_identity_after,
        stage_shaping_samples_ns: stage_shaping_samples,
        stage_material_samples_ns: stage_material_samples,
        stage_dirty_upload_samples_ns: stage_dirty_upload_samples,
        stage_queue_device_samples_ns: stage_queue_device_samples,
        stage_sync_samples_ns: stage_sync_samples,
        stage_present_readback_samples_ns: stage_present_readback_samples,
        stage_cpu_oracle_samples_ns: stage_cpu_oracle_samples,
        promotion_artifact_identity: promotion_artifact_identity,
        promotion_entry_name: promotion_entry_name,
        promotion_program_version: promotion_program_version,
        stage_emission_compile_ns: stage_emission_compile_ns,
        promotion_batch_identity: promotion_batch_identity,
        promotion_atlas_payload_sha256: promotion_atlas_payload_sha256,
        promotion_shader_handle: promotion_shader_handle,
        promotion_pipeline_handle: promotion_pipeline_handle,
        promotion_atlas_buffer_handle: promotion_atlas_buffer_handle,
        promotion_params_buffer_handle: promotion_params_buffer_handle,
        promotion_command_handle: promotion_command_handle,
        promotion_fence_handle: promotion_fence_handle,
        promotion_readback_buffer_handle: promotion_readback_buffer_handle,
        promotion_quad_count: promotion_quad_count,
        promotion_dispatch_count: promotion_dispatch_count,
        promotion_submitted: promotion_submitted,
        promotion_completion_waited: promotion_completion_waited,
        promotion_fence_evidence_available: promotion_fence_evidence_available,
        promotion_fence_destroyed: promotion_fence_destroyed,
        promotion_readback_source: promotion_readback_source,
        promotion_readback_byte_count: promotion_readback_byte_count,
        promotion_readback_nonblank_pixels: promotion_readback_nonblank_pixels,
        promotion_device_checksum: promotion_device_checksum,
        promotion_oracle_checksum: promotion_oracle_checksum,
        promotion_parity: promotion_parity,
        promotion_device_executed: promotion_device_executed,
        promotion_ready: promotion_ready,
        promotion_present_mode: promotion_present_mode)

fn _measure_font_perf_budget() -> FontPerfBudgetEvidence:
    if setup_multiface_perf_fixture() == nil:
        return unavailable_font_perf_evidence(_multiface_perf_reason)
    val content_1024 = _mixed_fixture(1024)
    val content_4096 = _mixed_fixture(4096)
    val warm_1080 = _measure_route(1920, 1080, "vulkan", content_1024, 1024, false)
    val warm_4k = _measure_route(3840, 2160, "vulkan", content_1024, 1024, false)
    val cpu_4096 = _measure_route(1920, 1080, "software", content_4096, 4096, false)
    val gpu_4096 = _measure_route(1920, 1080, "vulkan", content_4096, 4096, false)
    val cpu_after_device_loss = _measure_route(1920, 1080, "software", content_4096, 4096, true)
    _close_multiface_perf_fixture()
    val routes_ready = warm_1080.ok and warm_4k.ok and cpu_4096.ok and gpu_4096.ok and cpu_after_device_loss.ok
    val rss = if routes_ready: collect_font_perf_rss_isolated()
        else: _failed_rss("2d-route-unavailable")
    val route_reason = if not warm_1080.ok: warm_1080.reason
        elif not warm_4k.ok: warm_4k.reason
        elif not cpu_4096.ok: cpu_4096.reason
        elif not gpu_4096.ok: gpu_4096.reason
        elif not cpu_after_device_loss.ok: cpu_after_device_loss.reason
        elif not rss.available: rss.reason
        else: "pass"
    var resources = warm_1080.gpu_resource_high_water_bytes
    if warm_4k.gpu_resource_high_water_bytes > resources:
        resources = warm_4k.gpu_resource_high_water_bytes
    if gpu_4096.gpu_resource_high_water_bytes > resources:
        resources = gpu_4096.gpu_resource_high_water_bytes
    val rss_growth_2d = font_perf_rss_growth_percent(rss.legacy_2d_kb, rss.multiface_2d_kb)
    val rss_growth_3d = font_perf_rss_growth_percent(rss.legacy_3d_kb, rss.multiface_3d_kb)
    val rss_growth = if rss_growth_2d > rss_growth_3d: rss_growth_2d else: rss_growth_3d
    var measured = FontPerfBudgetEvidence(
        status: if routes_ready and rss.available: "pass" else: "unavailable",
        reason: route_reason,
        warm_1080_p95_ns: warm_1080.p95_ns,
        warm_4k_p95_ns: warm_4k.p95_ns,
        cpu_4096_p95_ns: cpu_4096.p95_ns,
        gpu_4096_p95_ns: gpu_4096.p95_ns,
        warm_hits: warm_1080.hits + warm_4k.hits,
        warm_requests: 1024 * SAMPLE_COUNT * 2,
        unchanged_upload: warm_1080.unchanged_upload and warm_4k.unchanged_upload and
            cpu_4096.unchanged_upload and gpu_4096.unchanged_upload,
        rss_growth_percent: rss_growth,
        gpu_resource_high_water_bytes: resources,
        rss_available: rss.available,
        legacy_2d_kb: rss.legacy_2d_kb,
        multiface_2d_kb: rss.multiface_2d_kb,
        legacy_3d_kb: rss.legacy_3d_kb,
        multiface_3d_kb: rss.multiface_3d_kb,
        gpu_device_name: gpu_4096.device_name,
        gpu_driver_identity: gpu_4096.driver_identity,
        warm_1080_samples_ns: warm_1080.samples_ns,
        warm_4k_samples_ns: warm_4k.samples_ns,
        cpu_4096_samples_ns: cpu_4096.samples_ns,
        gpu_4096_samples_ns: gpu_4096.samples_ns,
        device_loss_status: cpu_after_device_loss.device_loss_status,
        device_loss_batch_identity_before: cpu_after_device_loss.batch_identity_before,
        device_loss_batch_identity_after: cpu_after_device_loss.batch_identity_after,
        cpu_after_device_loss_p95_ns: cpu_after_device_loss.p95_ns,
        cpu_after_device_loss_samples_ns: cpu_after_device_loss.samples_ns,
        stage_shaping_p95_ns: font_perf_p95(gpu_4096.stage_shaping_samples_ns),
        stage_material_p95_ns: font_perf_p95(gpu_4096.stage_material_samples_ns),
        stage_emission_compile_ns: gpu_4096.stage_emission_compile_ns,
        stage_dirty_upload_p95_ns: font_perf_p95(gpu_4096.stage_dirty_upload_samples_ns),
        stage_queue_device_p95_ns: font_perf_p95(gpu_4096.stage_queue_device_samples_ns),
        stage_sync_p95_ns: font_perf_p95(gpu_4096.stage_sync_samples_ns),
        stage_present_readback_p95_ns: font_perf_p95(gpu_4096.stage_present_readback_samples_ns),
        stage_cpu_oracle_p95_ns: font_perf_p95(gpu_4096.stage_cpu_oracle_samples_ns),
        stage_shaping_samples_ns: gpu_4096.stage_shaping_samples_ns,
        stage_material_samples_ns: gpu_4096.stage_material_samples_ns,
        stage_dirty_upload_samples_ns: gpu_4096.stage_dirty_upload_samples_ns,
        stage_queue_device_samples_ns: gpu_4096.stage_queue_device_samples_ns,
        stage_sync_samples_ns: gpu_4096.stage_sync_samples_ns,
        stage_present_readback_samples_ns: gpu_4096.stage_present_readback_samples_ns,
        stage_cpu_oracle_samples_ns: gpu_4096.stage_cpu_oracle_samples_ns,
        promotion_artifact_identity: gpu_4096.promotion_artifact_identity,
        promotion_entry_name: gpu_4096.promotion_entry_name,
        promotion_program_version: gpu_4096.promotion_program_version,
        promotion_batch_identity: gpu_4096.promotion_batch_identity,
        promotion_atlas_payload_sha256: gpu_4096.promotion_atlas_payload_sha256,
        promotion_shader_handle: gpu_4096.promotion_shader_handle,
        promotion_pipeline_handle: gpu_4096.promotion_pipeline_handle,
        promotion_atlas_buffer_handle: gpu_4096.promotion_atlas_buffer_handle,
        promotion_params_buffer_handle: gpu_4096.promotion_params_buffer_handle,
        promotion_command_handle: gpu_4096.promotion_command_handle,
        promotion_fence_handle: gpu_4096.promotion_fence_handle,
        promotion_readback_buffer_handle: gpu_4096.promotion_readback_buffer_handle,
        promotion_quad_count: gpu_4096.promotion_quad_count,
        promotion_dispatch_count: gpu_4096.promotion_dispatch_count,
        promotion_submitted: gpu_4096.promotion_submitted,
        promotion_completion_waited: gpu_4096.promotion_completion_waited,
        promotion_fence_evidence_available: gpu_4096.promotion_fence_evidence_available,
        promotion_fence_destroyed: gpu_4096.promotion_fence_destroyed,
        promotion_readback_source: gpu_4096.promotion_readback_source,
        promotion_readback_byte_count: gpu_4096.promotion_readback_byte_count,
        promotion_readback_nonblank_pixels: gpu_4096.promotion_readback_nonblank_pixels,
        promotion_device_checksum: gpu_4096.promotion_device_checksum,
        promotion_oracle_checksum: gpu_4096.promotion_oracle_checksum,
        promotion_parity: gpu_4096.promotion_parity,
        promotion_device_executed: gpu_4096.promotion_device_executed,
        promotion_ready: gpu_4096.promotion_ready,
        promotion_present_mode: gpu_4096.promotion_present_mode)
    if measured.status == "pass" and not expect_font_perf_budget(measured):
        measured.status = "failed"
        measured.reason = "performance-budget-exceeded"
    measured

describe "shared multilingual font performance evidence":
    it "measures true multi-face warm routes and isolated paired 2D/3D RSS":
        step("Measure three-face shaping, shared atlas reuse, native resources, and isolated RSS")
        expect(write_font_perf_evidence(
            unavailable_font_perf_evidence("measurement-started"))).to_be(true)
        val evidence = _measure_font_perf_budget()
        expect(write_font_perf_evidence(evidence)).to_be(true)
        val durable = read_font_perf_evidence()
        print "font_perf status={evidence.status} reason={evidence.reason} fixture=top-10-language-witnesses faces=3 glyphs_1080=1024 glyphs_4k=1024 glyphs_compare=4096 warm_backend=vulkan warm_1080_p95_ns={evidence.warm_1080_p95_ns} warm_4k_p95_ns={evidence.warm_4k_p95_ns} cpu_4096_p95_ns={evidence.cpu_4096_p95_ns} gpu_4096_p95_ns={evidence.gpu_4096_p95_ns} device_loss_status={evidence.device_loss_status} cpu_after_device_loss_p95_ns={evidence.cpu_after_device_loss_p95_ns} warm_hits={evidence.warm_hits}/{evidence.warm_requests} unchanged_upload={evidence.unchanged_upload} rss_available={evidence.rss_available} legacy_2d_kb={evidence.legacy_2d_kb} multiface_2d_kb={evidence.multiface_2d_kb} legacy_3d_kb={evidence.legacy_3d_kb} multiface_3d_kb={evidence.multiface_3d_kb} rss_growth_percent={evidence.rss_growth_percent} gpu_resource_high_water_bytes={evidence.gpu_resource_high_water_bytes} gpu_device={evidence.gpu_device_name} gpu_driver={evidence.gpu_driver_identity}"
        print "font_perf_samples warm_1080_ns={font_perf_samples_text(evidence.warm_1080_samples_ns)} warm_4k_ns={font_perf_samples_text(evidence.warm_4k_samples_ns)} cpu_4096_ns={font_perf_samples_text(evidence.cpu_4096_samples_ns)} gpu_4096_ns={font_perf_samples_text(evidence.gpu_4096_samples_ns)} cpu_after_device_loss_ns={font_perf_samples_text(evidence.cpu_after_device_loss_samples_ns)}"
        print "font_perf_stages shaping_p95_ns={evidence.stage_shaping_p95_ns} material_p95_ns={evidence.stage_material_p95_ns} emission_compile_ns={evidence.stage_emission_compile_ns} dirty_upload_p95_ns={evidence.stage_dirty_upload_p95_ns} queue_device_p95_ns={evidence.stage_queue_device_p95_ns} sync_p95_ns={evidence.stage_sync_p95_ns} present_readback_p95_ns={evidence.stage_present_readback_p95_ns} cpu_oracle_p95_ns={evidence.stage_cpu_oracle_p95_ns} artifact={evidence.promotion_artifact_identity} entry={evidence.promotion_entry_name} batch={evidence.promotion_batch_identity} payload={evidence.promotion_atlas_payload_sha256} present_mode={evidence.promotion_present_mode}"
        expect(durable.status).to_equal("pass")
        expect(expect_font_perf_budget(durable)).to_be(true)
