# Minimal blit-tile native-build repro.
#
# Expected row-0 samples for a 256x64 tiled row:
#   x=0   -> sprite 0 -> 0xFF0000FF
#   x=64  -> sprite 1 -> 0xFF00FF00
#   x=128 -> sprite 2 -> 0xFFFF0000
#   x=192 -> sprite 3 -> 0xFF00FFFF
#   x=240 -> sprite 3 -> 0xFF00FFFF

struct TinyFb:
    data: [i64]
    width: i32
    height: i32
    stride: i32

fn sprite_pixel(id: i64) -> i64:
    if id == 0: 0xFF0000FF
    else if id == 1: 0xFF00FF00
    else if id == 2: 0xFFFF0000
    else: 0xFF00FFFF

fn make_fb() -> TinyFb:
    var data: [i64] = []
    var i: i64 = 0
    while i < 256 * 64:
        data.push(0xFF000000)
        i = i + 1
    TinyFb(data: data, width: 256, height: 64, stride: 256)

fn render_row(mut fb: TinyFb):
    var tx: i64 = 0
    while tx < fb.width:
        val sid: i64 = (tx / 64) % 4
        val color = sprite_pixel(sid)
        print "BLIT_TILE_CALL x={tx} y=0 w=64 h=64 color={color}"
        var yy: i64 = 0
        while yy < 64:
            var xx: i64 = tx
            var off: i64 = yy * (fb.stride as i64) + tx
            while xx < tx + 64:
                fb.data[off as i32] = color
                off = off + 1
                xx = xx + 1
            yy = yy + 1
        tx = tx + 64

fn main():
    var fb = make_fb()
    render_row(fb)
    print "BLIT_TILE_REPRO sid0={(0 / 64) % 4} sid64={(64 / 64) % 4} sid128={(128 / 64) % 4} sid192={(192 / 64) % 4}"
    print "BLIT_TILE_REPRO p0={fb.data[0]} p64={fb.data[64]} p128={fb.data[128]} p192={fb.data[192]} p240={fb.data[240]}"
