# Stable bitmap-only probe used unchanged in pre-feature and current trees.

use std.gc_async_mut.gpu.engine2d.engine.{Engine2D}
use std.gc_async_mut.gpu.engine2d.color.{rgb}
use std.gc_async_mut.io.time_ops.{time_now_nanos}

val SAMPLE_COUNT: i64 = 31
val CONTENT = "A A A A"

fn sort_i64(values: [i64]) -> [i64]:
    var sorted = values
    var i: i64 = 1
    while i < sorted.len():
        val key = sorted[i]
        var j = i - 1
        while j >= 0 and sorted[j] > key:
            sorted[j + 1] = sorted[j]
            j = j - 1
        sorted[j + 1] = key
        i = i + 1
    sorted

fn checksum(pixels: [u32]) -> i64:
    var total: i64 = 0
    var i: i64 = 0
    while i < pixels.len():
        total = (total + pixels[i].to_i64() * (i + 1)) % 2147483647
        i = i + 1
    total

var engine = Engine2D.create_with_backend(128, 72, "cpu")
val bg = rgb(3, 7, 11)
val fg = rgb(240, 220, 180)
var samples: [i64] = []
var expected_checksum: i64 = 0
var mismatches: i64 = 0
var i: i64 = 0
while i < SAMPLE_COUNT:
    engine.clear(bg)
    val started = time_now_nanos()
    engine.draw_text(8, 8, CONTENT, fg, 24)
    samples.push(time_now_nanos() - started)
    val current_checksum = checksum(engine.read_pixels())
    if i == 0:
        expected_checksum = current_checksum
    elif current_checksum != expected_checksum:
        mismatches = mismatches + 1
    print "bitmap_text_sample"
    print i
    print samples[samples.len() - 1]
    print current_checksum
    i = i + 1
engine.shutdown()
val sorted = sort_i64(samples)
print "bitmap_text_summary"
print 31
print sorted[15]
print sorted[29]
print expected_checksum
print mismatches
