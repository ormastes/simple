# test/perf/graphics_2d/optimization_plugin_spec.spl
#
# **Feature IDs:** AC-10 (state.md) — optimization plugin metadata:
#   auto_vectorize + simd_lowering report rendering vectorization provider
#   hit/change counts per frame.
# **Category:** Graphics | Compiler | Optimization Plugin
# **Status:** Pending implementation (Phase 5)
#
# Verifies:
#   - plugin_hook_vectorize_event is called with (kernel_id, changed) per frame
#   - SimdHitCounts accumulates hit and change events
#   - provider metadata is accessible from the benchmark report
#   - active_providers list is reported in BenchFrameRecord
#
# @cover src/compiler/60.mir_opt/mir_opt/auto_vectorize.spl
# @cover src/lib/gc_async_mut/gpu/engine2d/simd_provider.spl

val PROVIDER_AUTO_VECTORIZE: text = "auto_vectorize"
val PROVIDER_SIMD_LOWERING:  text = "simd_lowering"

struct ProviderEventSentinel:
    kernel_id:  text
    changed:    bool
    provider:   text

struct ProviderReportSentinel:
    frame_id:           i64
    active_providers:   [text]
    events:             [ProviderEventSentinel]
    total_hits:         i64
    total_changes:      i64

fn make_provider_event(kid: text, ch: bool, prov: text) -> ProviderEventSentinel:
    ProviderEventSentinel(kernel_id: kid, changed: ch, provider: prov)

fn make_provider_report_ok() -> ProviderReportSentinel:
    val evts: [ProviderEventSentinel] = [
        make_provider_event("fill",        true,  PROVIDER_AUTO_VECTORIZE),
        make_provider_event("blit",        true,  PROVIDER_SIMD_LOWERING),
        make_provider_event("alpha_blend", false, PROVIDER_AUTO_VECTORIZE),
        make_provider_event("scroll",      true,  PROVIDER_AUTO_VECTORIZE),
        make_provider_event("copy",        true,  PROVIDER_SIMD_LOWERING)
    ]
    val providers: [text] = [PROVIDER_AUTO_VECTORIZE, PROVIDER_SIMD_LOWERING]
    ProviderReportSentinel(
        frame_id:         1,
        active_providers: providers,
        events:           evts,
        total_hits:       5,
        total_changes:    4
    )

fn count_changes(r: ProviderReportSentinel) -> i64:
    var cnt: i64 = 0
    var i: i64 = 0
    while i < r.events.len() as i64:
        if r.events[i as i32].changed:
            cnt = cnt + 1
        i = i + 1
    cnt

describe "optimization_plugin — AC-10: provider hit/change metadata":

    describe "provider name constants":

        it "AC-10: auto_vectorize provider name is correct":
            expect(PROVIDER_AUTO_VECTORIZE).to_equal("auto_vectorize")

        it "AC-10: simd_lowering provider name is correct":
            expect(PROVIDER_SIMD_LOWERING).to_equal("simd_lowering")

        it "AC-10: two optimization providers are defined":
            val providers: [text] = [PROVIDER_AUTO_VECTORIZE, PROVIDER_SIMD_LOWERING]
            expect(providers.len()).to_equal(2)

    describe "provider event structure":

        it "AC-10: event carries kernel_id field":
            val e: ProviderEventSentinel = make_provider_event("fill", true, PROVIDER_AUTO_VECTORIZE)
            expect(e.kernel_id).to_equal("fill")

        it "AC-10: event carries changed field":
            val e: ProviderEventSentinel = make_provider_event("fill", true, PROVIDER_AUTO_VECTORIZE)
            expect(e.changed).to_equal(true)

        it "AC-10: event carries provider field":
            val e: ProviderEventSentinel = make_provider_event("fill", true, PROVIDER_AUTO_VECTORIZE)
            expect(e.provider).to_equal(PROVIDER_AUTO_VECTORIZE)

        it "AC-10: unchanged event has changed == false":
            val e: ProviderEventSentinel = make_provider_event("alpha_blend", false, PROVIDER_AUTO_VECTORIZE)
            expect(e.changed).to_equal(false)

    describe "ProviderReport accumulation":

        it "AC-10: report frame_id is greater than zero":
            val r: ProviderReportSentinel = make_provider_report_ok()
            expect(r.frame_id > 0).to_equal(true)

        it "AC-10: active_providers contains auto_vectorize":
            val r: ProviderReportSentinel = make_provider_report_ok()
            expect(r.active_providers[0]).to_equal(PROVIDER_AUTO_VECTORIZE)

        it "AC-10: active_providers contains simd_lowering":
            val r: ProviderReportSentinel = make_provider_report_ok()
            expect(r.active_providers[1]).to_equal(PROVIDER_SIMD_LOWERING)

        it "AC-10: five events are recorded in one frame":
            val r: ProviderReportSentinel = make_provider_report_ok()
            expect(r.events.len()).to_equal(5)

        it "AC-10: total_hits is greater than zero after a frame":
            val r: ProviderReportSentinel = make_provider_report_ok()
            expect(r.total_hits > 0).to_equal(true)

        it "AC-10: total_changes matches events with changed == true":
            val r: ProviderReportSentinel = make_provider_report_ok()
            val counted: i64 = count_changes(r)
            expect(counted).to_equal(r.total_changes)

        it "AC-10: total_changes is less than or equal to total_hits":
            val r: ProviderReportSentinel = make_provider_report_ok()
            expect(r.total_changes <= r.total_hits).to_equal(true)
