use std.database.sql.types.{DbValue, DbRow}
use nogc_sync_mut.database.pure_sql.database.{PureDatabase}

fn local_optional_row() -> DbRow?:
    Some(DbRow(columns: ["id", "name", "score"], values: [DbValue.Integer(value: 8), DbValue.Text(value: "eight"), DbValue.Integer(value: 80)]))

fn local_row() -> DbRow:
    DbRow(columns: ["id", "name", "score"], values: [DbValue.Integer(value: 9), DbValue.Text(value: "nine"), DbValue.Integer(value: 90)])

fn main():
    val direct = DbValue.Integer(value: 70)
    print("direct_int=" + direct.to_text())
    print("direct_as_int=" + direct.as_int().unwrap().to_text())
    val direct_arr = [DbValue.Integer(value: 7), DbValue.Text(value: "seven"), DbValue.Integer(value: 70)]
    print("arr_len=" + direct_arr.len().to_text())
    print("arr_v2=" + direct_arr[2].to_text())
    val local = DbRow(columns: ["id", "name", "score"], values: [DbValue.Integer(value: 7), DbValue.Text(value: "seven"), DbValue.Integer(value: 70)])
    print("local_len=" + local.values.len().to_text())
    print("local_v2=" + local.values[2].to_text())
    val local_ret = local_row()
    print("local_ret_len=" + local_ret.values.len().to_text())
    print("local_ret_v2=" + local_ret.values[2].to_text())
    var db = PureDatabase.memory_deferred().unwrap()
    db.exec_sql("CREATE TABLE probe (id INTEGER PRIMARY KEY, name TEXT, score INTEGER)").unwrap()
    db.put("probe", [DbValue.Integer(value: 1), DbValue.Text(value: "one"), DbValue.Integer(value: 10)]).unwrap()
    print("probe_count_text=" + db.count_by_key_text("probe", "id", DbValue.Integer(value: 1)))
    val rows = db.query("SELECT * FROM probe WHERE id = ?", [DbValue.Integer(value: 1)]).unwrap()
    print("probe_rows_len=" + rows.len().to_text())
    if rows.len() > 0:
        print("probe_rows_cols_len=" + rows[0].columns.len().to_text())
        print("probe_rows_values_len=" + rows[0].values.len().to_text())
    val row = db.get("probe", "id", DbValue.Integer(value: 1)).unwrap()
    print("probe_present=" + row.?.to_text())
    if row.?:
        print("probe_cols_len=" + row!.columns.len().to_text())
        print("probe_len=" + row!.values.len().to_text())
        if row!.values.len() >= 3:
            print("probe_v0=" + row!.values[0].to_text())
            print("probe_v1=" + row!.values[1].to_text())
            print("probe_v2=" + row!.values[2].to_text())
