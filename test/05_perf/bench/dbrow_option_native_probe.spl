use std.database.sql.types.{DbValue, DbRow, DbError}

fn local_optional_row() -> DbRow?:
    Some(DbRow(columns: ["id", "score"], values: [DbValue.Integer(value: 1), DbValue.Integer(value: 10)]))

fn local_row() -> DbRow:
    DbRow(columns: ["id", "score"], values: [DbValue.Integer(value: 2), DbValue.Integer(value: 20)])

fn local_optional_from_row_fn() -> DbRow?:
    Some(local_row())

fn local_result_optional_row() -> Result<DbRow?, DbError>:
    Ok(Some(local_row()))

class RowBox:
    me get() -> Result<DbRow?, DbError>:
        Ok(Some(local_row()))

    me query() -> Result<[DbRow], DbError>:
        Ok([local_row()])

    me count() -> Result<i64, DbError>:
        Ok(1)

    me count_value() -> Result<DbValue, DbError>:
        Ok(DbValue.Integer(value: 1))

fn main():
    print("direct_len=" + local_optional_row()!.values.len().to_text())
    print("from_fn_len=" + local_optional_from_row_fn()!.values.len().to_text())
    val result_row = local_result_optional_row().unwrap()
    print("result_present=" + result_row.?.to_text())
    if result_row.?:
        print("result_cols_len=" + result_row!.columns.len().to_text())
        print("result_len=" + result_row!.values.len().to_text())
    val box = RowBox()
    val method_row = box.get().unwrap()
    print("method_present=" + method_row.?.to_text())
    if method_row.?:
        print("method_cols_len=" + method_row!.columns.len().to_text())
        print("method_len=" + method_row!.values.len().to_text())
    val method_rows = box.query().unwrap()
    print("method_rows_len=" + method_rows.len().to_text())
    print("method_rows_v1=" + method_rows[0].values[1].to_text())
    print("method_count=" + box.count().unwrap().to_text())
    print("method_count_eq=" + (box.count().unwrap() == 1).to_text())
    print("literal_i64=" + (1 as i64).to_text())
    print("method_count_value=" + box.count_value().unwrap().to_text())
    val row = local_optional_row()
    print("present=" + row.?.to_text())
    if row.?:
        print("len=" + row!.values.len().to_text())
        print("score=" + row!.values[1].to_text())
