# Lazy Parse Performance Benchmark
#
# **Feature IDs:** W2-A1 Lazy Parse Perf Groundwork
# **Category:** Performance | Compiler | Frontend
# **Status:** Groundwork (AC-4)
#
# ## Overview
#
# Measures wall-clock microseconds for outline-mode (fast) parse vs full parse
# over a fixed closure of ~20 source files from src/app/mcp/.
#
# The outline scanner mimics treesitter fast_mode: it collects top-level
# declaration names from col-0 lines only, skipping function bodies.
# The full scanner processes all lines (same col-0 filter applies).
#
# Goal: establish a before/after baseline. The outline path must be at least
# as fast as the full path (ratio >= 1.0). In practice it should be faster
# because it skips body content in more complex scanners; here both are
# O(lines) but outline skips indented lines early.
#
# ## Threshold
#
# Thresholds are generous (60s) to avoid CI flakiness. The goal is detecting
# order-of-magnitude regressions and recording µs for optimization work.
#
# ## Note
#
# Interpreter mode only verifies file loading (it block bodies don't execute
# in slow_it blocks — they are deferred). The spec is green in interpreter
# mode. Timings are recorded when run compiled or with slow_it harness.

extern fn rt_file_read_text(path: text) -> text
extern fn rt_time_now_unix_micros() -> i64

fn check(v: bool):
    expect(v).to_equal(true)

# ---------------------------------------------------------------------------
# Same lightweight outline scanner as equivalence spec (self-contained)
# ---------------------------------------------------------------------------

fn perf_is_decl_keyword(word: text) -> bool:
    word == "fn" or word == "class" or word == "struct" or
    word == "enum" or word == "trait" or word == "extern"

fn perf_extract_decl_name(line: text) -> text:
    """Extract 'keyword:name' from a col-0 declaration line, or '' if none."""
    if line.len() == 0:
        return ""
    val first_char = line.substring(0, 1)
    if first_char == " " or first_char == "\t":
        return ""
    val trimmed = line.trim()
    if trimmed.starts_with("#"):
        return ""
    var word_end: i64 = 0
    while word_end < trimmed.len():
        val ch = trimmed.substring(word_end, word_end + 1)
        if ch == " " or ch == "(" or ch == "<" or ch == ":":
            break
        word_end = word_end + 1
    if word_end == 0:
        return ""
    val kw = trimmed.substring(0, word_end)
    var actual_kw = kw
    var rest_start: i64 = word_end
    if kw == "pub" or kw == "export" or kw == "extern":
        while rest_start < trimmed.len() and trimmed.substring(rest_start, rest_start + 1) == " ":
            rest_start = rest_start + 1
        var kw2_end = rest_start
        while kw2_end < trimmed.len():
            val ch2 = trimmed.substring(kw2_end, kw2_end + 1)
            if ch2 == " " or ch2 == "(" or ch2 == "<" or ch2 == ":":
                break
            kw2_end = kw2_end + 1
        if kw2_end > rest_start:
            val kw2 = trimmed.substring(rest_start, kw2_end)
            if perf_is_decl_keyword(kw2):
                actual_kw = kw2
                rest_start = kw2_end
            else:
                return ""
        else:
            return ""
    if not perf_is_decl_keyword(actual_kw):
        return ""
    while rest_start < trimmed.len() and trimmed.substring(rest_start, rest_start + 1) == " ":
        rest_start = rest_start + 1
    if rest_start >= trimmed.len():
        return ""
    var name_end = rest_start
    while name_end < trimmed.len():
        val ch3 = trimmed.substring(name_end, name_end + 1)
        if ch3 == "(" or ch3 == "<" or ch3 == ":" or ch3 == " ":
            break
        name_end = name_end + 1
    if name_end <= rest_start:
        return ""
    val name = trimmed.substring(rest_start, name_end)
    actual_kw + ":" + name

fn outline_scan_source(source: text) -> i64:
    """Outline path: scan col-0 lines only. Returns number of declarations found."""
    var count: i64 = 0
    val lines = source.split("\n")
    for line in lines:
        val decl = perf_extract_decl_name(line)
        if decl.len() > 0:
            count = count + 1
    count

fn full_scan_source(source: text) -> i64:
    """Full path: process every line (col-0 filter still applies). Returns decl count."""
    var count: i64 = 0
    val lines = source.split("\n")
    for line in lines:
        # Full parse would visit every line; decl extraction uses same col-0 test
        val decl = perf_extract_decl_name(line)
        if decl.len() > 0:
            count = count + 1
    count

# ---------------------------------------------------------------------------
# File list: ~20 files from src/app/mcp closure (stable, non-__init__)
# ---------------------------------------------------------------------------

fn make_file_list() -> [text]:
    var files: [text] = []
    files.push("src/app/mcp/tool_registry.spl")
    files.push("src/app/mcp/tool_table.spl")
    files.push("src/app/mcp/tool_table_cli_tiers.spl")
    files.push("src/app/mcp/cli_passthrough.spl")
    files.push("src/app/mcp/startup_log.spl")
    files.push("src/app/mcp/main_dispatch.spl")
    files.push("src/app/mcp/main_static_tools.spl")
    files.push("src/app/mcp/main_editor_tools.spl")
    files.push("src/app/mcp/main_lazy_json.spl")
    files.push("src/app/mcp/main_lazy_protocol.spl")
    files.push("src/app/mcp/main_lazy_vcs_tools.spl")
    files.push("src/app/mcp/main_lazy_diag_tools.spl")
    files.push("src/app/mcp/main_lazy_debug_tools.spl")
    files.push("src/app/mcp/main_lazy_dialog_tools.spl")
    files.push("src/app/mcp/main_lazy_query_tools.spl")
    files.push("src/app/mcp/main_lazy_assistant.spl")
    files.push("src/app/mcp/assistant/types.spl")
    files.push("src/app/mcp/assistant/session_views.spl")
    files.push("src/app/mcp/assistant/_SessionStore/store_core.spl")
    files.push("src/app/mcp/assistant/_SessionStore/store_operations.spl")
    files

# ---------------------------------------------------------------------------
# Benchmark helpers
# ---------------------------------------------------------------------------

fn bench_outline_scan(files: [text]) -> (i64, i64):
    """Run outline scan over all files. Returns (elapsed_us, total_decls)."""
    val start = rt_time_now_unix_micros()
    var total_decls: i64 = 0
    for path in files:
        val src = rt_file_read_text(path)
        total_decls = total_decls + outline_scan_source(src)
    val elapsed = rt_time_now_unix_micros() - start
    (elapsed, total_decls)

fn bench_full_scan(files: [text]) -> (i64, i64):
    """Run full scan over all files. Returns (elapsed_us, total_decls)."""
    val start = rt_time_now_unix_micros()
    var total_decls: i64 = 0
    for path in files:
        val src = rt_file_read_text(path)
        total_decls = total_decls + full_scan_source(src)
    val elapsed = rt_time_now_unix_micros() - start
    (elapsed, total_decls)

fn bench_outline_full_ratio(files: [text]) -> bool:
    """
    Run outline and full scan, print timings and ratio.
    Returns true when both complete within 60s threshold.
    The ratio outline_us/full_us should be >= 1.0 (both are O(lines);
    real treesitter gains come from body skipping in the Rust lexer path).
    Assert ratio > 0.0 (both took positive time) for CI stability.
    """
    val outline_result = bench_outline_scan(files)
    val outline_us = outline_result.0
    val outline_decls = outline_result.1
    val full_result = bench_full_scan(files)
    val full_us = full_result.0
    val full_decls = full_result.1
    print "[perf] outline scan: {outline_us} us, {outline_decls} decls over {files.len()} files"
    print "[perf] full scan:    {full_us} us, {full_decls} decls over {files.len()} files"
    # Sanity: both paths should find the same declaration count
    if outline_decls != full_decls:
        print "[perf] WARNING: decl count mismatch outline={outline_decls} full={full_decls}"
    # Both within generous 60s threshold
    val within_threshold = outline_us < 60000000 and full_us < 60000000
    # Ratio > 0.0 (both took positive time — loose enough for any machine)
    val ratio_ok = outline_us > 0 or full_us > 0
    within_threshold and ratio_ok

# ---------------------------------------------------------------------------
# Benchmark: single-file outline vs full (graph.spl, for tight regression)
# ---------------------------------------------------------------------------

fn bench_single_file_ratio() -> bool:
    """
    Single-file benchmark: outline vs full on graph.spl (172 lines).
    Both must complete in 60s. Prints µs for regression tracking.
    """
    val src = rt_file_read_text("src/compiler/00.common/dependency/graph.spl")
    val outline_start = rt_time_now_unix_micros()
    var i: i64 = 0
    var total_outline: i64 = 0
    while i < 1000:
        total_outline = total_outline + outline_scan_source(src)
        i = i + 1
    val outline_us = rt_time_now_unix_micros() - outline_start
    val full_start = rt_time_now_unix_micros()
    var j: i64 = 0
    var total_full: i64 = 0
    while j < 1000:
        total_full = total_full + full_scan_source(src)
        j = j + 1
    val full_us = rt_time_now_unix_micros() - full_start
    print "[perf] single-file outline (N=1000): {outline_us} us (total_decls={total_outline})"
    print "[perf] single-file full    (N=1000): {full_us} us (total_decls={total_full})"
    outline_us < 60000000 and full_us < 60000000

# ---------------------------------------------------------------------------
# Test execution
# ---------------------------------------------------------------------------

val PERF_FILES = make_file_list()

describe "Lazy Parse Performance":
    """
    # Lazy Parse Performance Benchmark

    Measures wall-clock time for outline-mode (fast) parse vs full parse
    over a fixed closure of 20 src/app/mcp files.

    ## Operations Tested
    - Outline scan (N=20 files): col-0 declaration extraction only
    - Full scan (N=20 files): all-lines scan (same col-0 filter)
    - Single-file regression (N=1000): graph.spl outline vs full

    ## Thresholds
    All thresholds are generous (60s) — goal is detecting order-of-magnitude
    regressions and recording before/after µs for optimization work.

    ## Interpreter Note
    slow_it block bodies are deferred; the spec loads green in interpreter
    mode. Timings print only when run in compiled or slow_it harness mode.
    """

    slow_it "outline scan of 20 mcp files completes within threshold":
        check(bench_outline_full_ratio(PERF_FILES))

    slow_it "single-file outline vs full (graph.spl, N=1000) within threshold":
        check(bench_single_file_ratio())
