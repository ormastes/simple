use std.spec.{describe, it, expect}

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

fn _run_itf(args: [text]) -> (text, text, i64):
    val joined = args.join(" ")
    rt_process_run("/bin/sh", [
        "-c",
        "REPO=$(pwd); SIMPLE_LIB=\"$REPO/src\" \"$REPO/bin/simple\" run \"$REPO/src/app/devhub/main.spl\" " + joined
    ])

describe "itf log mode CLI options":
    it "shows shared log options in help":
        val (out, err, code) = _run_itf(["--help"])
        expect(code).to_equal(0)
        expect(out).to_contain("--log-mode")
        expect(out).to_contain("--progress")

    it "supports log-mode json for usage output":
        val (out, err, code) = _run_itf(["--log-mode=json"])
        expect(code).to_equal(0)
        expect(out).to_contain("\"command\":\"itf\"")
        expect(out).to_contain("\"status\":\"usage\"")

    it "supports dot progress for usage output":
        val (out, err, code) = _run_itf(["--progress=dot"])
        expect(code).to_equal(0)
        expect(out).to_start_with(".")
        expect(out).to_contain("itf")

    it "rejects invalid global log mode":
        val (out, err, code) = _run_itf(["--log-mode=noisy"])
        expect(code).to_equal(1)

    it "emits json for version preflight":
        val (out, err, code) = _run_itf(["--log-mode=json", "version"])
        expect(code).to_equal(0)
        expect(out).to_contain("\"command\":\"itf\"")
        expect(out).to_contain("\"status\":\"ok\"")
        expect(out).to_contain("\"version\":\"0.1.0\"")

    it "preserves subcommand json flags after command name":
        val (out, err, code) = _run_itf(["version", "--json"])
        expect(code).to_equal(0)
        # Human-readable banner follows the devhub rename; the machine-readable
        # JSON envelope keeps "command":"itf" (asserted above) so existing
        # consumers of --log-mode=json are unaffected.
        expect(out).to_contain("devhub 0.1.0")
