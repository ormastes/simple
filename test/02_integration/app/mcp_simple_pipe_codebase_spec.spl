"""
# MCP Simple Pipe Codebase Execution Specification

## Overview

This focused check proves `simple_pipe surface=codebase` uses the existing
embedded-SQL context DB and still includes the Simple LSP symbol view.

**Requirements:** doc/02_requirements/feature/llm_tooling_context_ponytail_mimic.md
"""

use std.spec
use std.io_runtime.{dir_create_all}
use app.io.context_ops.{context_sql_index_packs}
use app.mcp.main_dispatch.{dispatch_tool_content}

describe "MCP simple_pipe codebase":
    it "queries the context DB and includes LSP workspace symbols":
        dir_create_all("build/test/mcp_simple_pipe_codebase")
        val source_path = "src/app/mcp/main_lazy_query_tools.spl"
        val db_path = "build/test/mcp_simple_pipe_codebase/codebase.db"
        val index_output = context_sql_index_packs([source_path], "ctx", db_path, "text")
        expect(index_output).to_contain("status: ready")

        val args = "{\"surface\":\"codebase\",\"sql\":\"true\",\"query\":\"handle_simple_pipe_codebase\",\"db\":\"" + db_path + "\",\"requester\":\"" + source_path + "\",\"format\":\"text\"}"
        val response = dispatch_tool_content("simple_pipe", args)
        expect(response).to_contain("-- simple_pipe codebase query=handle_simple_pipe_codebase --")
        expect(response).to_contain("mode: hybrid-codebase-db-search-plus-lsp")
        expect(response).to_contain("--- Codebase DB query ---")
        expect(response).to_contain("--- Codebase text search")
        expect(response).to_contain("--- LSP workspace symbols ---")
        expect(response).to_contain("handle_simple_pipe_codebase")
