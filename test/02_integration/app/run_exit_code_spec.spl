"""
# `simple run` main() exit-code propagation (task #90)

Regression coverage for `bin/simple run <file.spl>`: the process exit code
must equal the value returned from `fn main() -> i32` / `fn main() -> int`
(trailing-expression or explicit `return` form), while a unit-returning
`fn main()` keeps the interpreter's own success/crash exit code untouched.

Locks in the currently-correct behavior verified manually across many
variants (trailing expression, `return N`, `-> i32` vs `-> int`, values
0/1/42, and unit main) on the deployed self-hosted binary.

No drop point was found in src/app/cli/** or src/compiler_rust/** for the
current deployed binary: "run" always takes the Rust handle_run path
(src/app/run/main.spl is excluded from dispatch_to_simple_app's allow-list,
so it is never actually invoked for the "run" command).
"""

use std.spec.{describe, it, expect}

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

fn _run_script(body: text) -> (text, text, i64):
    rt_process_run("/bin/sh", [
        "-c",
        "TMP=/tmp/simple_run_exit_code_$$.spl; printf '%b' \"" + body + "\" > \"$TMP\"; REPO=$(pwd); \"$REPO/bin/simple\" run \"$TMP\"; CODE=$?; rm -f \"$TMP\"; exit $CODE"
    ])

describe "simple run propagates main() return value as process exit code":
    it "trailing expression: fn main() -> i32 returning 1 exits 1":
        val (out, err, code) = _run_script("fn main() -> i32:\\n    print(\\\"x\\\")\\n    1\\n")
        expect(code).to_equal(1)
        expect(out).to_contain("x")

    it "explicit return: fn main() -> i32 with return 1 exits 1":
        val (out, err, code) = _run_script("fn main() -> i32:\\n    print(\\\"x\\\")\\n    return 1\\n")
        expect(code).to_equal(1)
        expect(out).to_contain("x")

    it "fn main() -> int with return 1 exits 1":
        val (out, err, code) = _run_script("fn main() -> int:\\n    print(\\\"x\\\")\\n    return 1\\n")
        expect(code).to_equal(1)
        expect(out).to_contain("x")

    it "fn main() -> i32 returning 0 exits 0":
        val (out, err, code) = _run_script("fn main() -> i32:\\n    print(\\\"ok\\\")\\n    0\\n")
        expect(code).to_equal(0)
        expect(out).to_contain("ok")

    it "fn main() -> i32 returning a non-trivial value (42) exits 42":
        val (out, err, code) = _run_script("fn main() -> i32:\\n    print(\\\"forty-two\\\")\\n    42\\n")
        expect(code).to_equal(42)

    it "unit-returning fn main() keeps the success exit code (0)":
        val (out, err, code) = _run_script("fn main():\\n    print(\\\"unit-main\\\")\\n")
        expect(code).to_equal(0)
        expect(out).to_contain("unit-main")
