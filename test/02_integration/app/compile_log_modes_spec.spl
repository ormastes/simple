use std.spec.{describe, it, expect}

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

fn _run_compile(args: [text]) -> (text, text, i64):
    val joined = args.join(" ")
    rt_process_run("/bin/sh", [
        "-c",
        "REPO=$(pwd); SIMPLE_LIB=\"$REPO/src\" \"$REPO/bin/simple\" run \"$REPO/src/app/compile/main.spl\" " + joined
    ])

describe "compile log mode CLI options":
    it "shows shared log options in help":
        val (out, err, code) = _run_compile(["--help"])
        expect(code).to_equal(0)
        expect(out).to_contain("Usage: simple compile")
        expect(out).to_contain("--log-mode")
        expect(out).to_contain("--progress")

    it "supports log-mode json for missing source output":
        val (out, err, code) = _run_compile(["--log-mode=json"])
        expect(code).to_equal(1)
        expect(out).to_contain("\"command\":\"compile\"")
        expect(out).to_contain("\"error\":\"compile requires a source file\"")

    it "supports dot progress for help output":
        val (out, err, code) = _run_compile(["--progress=dot", "--help"])
        expect(code).to_equal(0)
        expect(out).to_start_with(".")
        expect(out).to_contain("Usage: simple compile")

    it "rejects invalid log mode":
        val (out, err, code) = _run_compile(["--log-mode=noisy"])
        expect(code).to_equal(1)

    it "delegates compile option queries to the rust CLI":
        val (out, err, code) = _run_compile(["--list-optimizations"])
        expect(code).to_equal(0)
        expect(out).to_contain("Simple optimization guide")
