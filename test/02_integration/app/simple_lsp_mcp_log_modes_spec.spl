use std.spec.{describe, it, expect}

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

fn _run_simple_lsp_mcp(args: [text]) -> (text, text, i64):
    val joined = args.join(" ")
    rt_process_run("/bin/sh", [
        "-c",
        "REPO=$(pwd); SIMPLE_LIB=\"$REPO/src\" \"$REPO/bin/simple\" run \"$REPO/src/app/simple_lsp_mcp/main.spl\" " + joined
    ])

fn _ping_simple_lsp_mcp() -> (text, text, i64):
    rt_process_run("/bin/sh", [
        "-c",
        "REPO=$(pwd); printf '{\"jsonrpc\":\"2.0\",\"id\":1,\"method\":\"ping\"}\\n' | SIMPLE_LIB=\"$REPO/src\" \"$REPO/bin/simple\" run \"$REPO/src/app/simple_lsp_mcp/main.spl\""
    ])

describe "simple lsp mcp log mode CLI options":
    it "shows shared log options in help":
        val (out, err, code) = _run_simple_lsp_mcp(["--help"])
        expect(code).to_equal(0)
        expect(out).to_contain("--log-mode")
        expect(out).to_contain("--progress")

    it "supports log-mode json for ready output":
        val (out, err, code) = _run_simple_lsp_mcp(["--log-mode=json"])
        expect(code).to_equal(0)
        expect(out).to_contain("\"command\":\"simple-lsp-mcp\"")
        expect(out).to_contain("\"status\":\"ready\"")

    it "supports dot progress for help output":
        val (out, err, code) = _run_simple_lsp_mcp(["--progress=dot", "--help"])
        expect(code).to_equal(0)
        expect(out).to_start_with(".")
        expect(out).to_contain("simple-lsp-mcp")

    it "rejects invalid log mode":
        val (out, err, code) = _run_simple_lsp_mcp(["--log-mode=noisy"])
        expect(code).to_equal(1)

    it "preserves normal MCP ping handling":
        val (out, err, code) = _ping_simple_lsp_mcp()
        expect(code).to_equal(0)
        expect(out).to_contain("\"jsonrpc\":\"2.0\"")
        expect(out).to_contain("\"result\":{}")
