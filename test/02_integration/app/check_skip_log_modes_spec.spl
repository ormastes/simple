use std.spec.{describe, it, expect}

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

val FIXTURE_DIR = "/tmp/simple_check_skip_log_mode_fixture"

fn _setup_fixture():
    val (_out, _err, _code) = rt_process_run("/bin/sh", [
        "-c",
        "rm -rf " + FIXTURE_DIR + " && mkdir -p " + FIXTURE_DIR + "/test/unit && cat > " + FIXTURE_DIR + "/test/unit/sample_spec.spl <<'EOF'\n# temporarily disabled\n# @skip\ndescribe \"sample\":\n    it \"works\":\n        assert true\nEOF"
    ])

fn _run_check_skip(args: [text]) -> (text, text, i64):
    val joined = args.join(" ")
    rt_process_run("/bin/sh", [
        "-c",
        "REPO=$(pwd); cd " + FIXTURE_DIR + " && SIMPLE_LIB=\"$REPO/src\" \"$REPO/bin/simple\" run \"$REPO/src/app/check_skip/main.spl\" " + joined
    ])

describe "check-skip log mode CLI options":
    it "shows shared log options in help":
        _setup_fixture()
        val (out, err, code) = _run_check_skip(["--help"])
        expect(code).to_equal(0)
        expect(out).to_contain("--log-mode")
        expect(out).to_contain("--progress")

    it "supports log-mode json":
        _setup_fixture()
        val (out, err, code) = _run_check_skip(["--log-mode=json"])
        expect(code).to_equal(0)
        expect(out).to_contain("\"command\":\"check-skip\"")
        expect(out).to_contain("\"total\":1")
        expect(out).to_contain("\"skipped\":1")

    it "supports dot progress":
        _setup_fixture()
        val (out, err, code) = _run_check_skip(["--progress=dot"])
        expect(code).to_equal(0)
        expect(out).to_contain(".")
        expect(out).to_contain("Skip/Pending Test Report")

    it "rejects invalid log mode":
        _setup_fixture()
        val (out, err, code) = _run_check_skip(["--log-mode=noisy"])
        expect(code).to_equal(1)
