use std.spec.{describe, it, expect}

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

val FIXTURE_DIR = "/tmp/simple_todo_scan_log_mode_fixture"

fn _setup_fixture():
    val (_out, _err, _code) = rt_process_run("/bin/sh", [
        "-c",
        "rm -rf " + FIXTURE_DIR + " && mkdir -p " + FIXTURE_DIR + "/src && cat > " + FIXTURE_DIR + "/src/main.spl <<'EOF'\n# TODO: [runtime][P1] fix scanner fixture [#42]\nfn main() -> i32:\n    0\nEOF"
    ])

fn _run_todo_scan(args: [text]) -> (text, text, i64):
    val joined = args.join(" ")
    rt_process_run("/bin/sh", [
        "-c",
        "REPO=$(pwd); cd " + FIXTURE_DIR + " && SIMPLE_LIB=\"$REPO/src\" \"$REPO/bin/simple\" run \"$REPO/src/app/todo_scan/main.spl\" " + joined
    ])

describe "todo-scan log mode CLI options":
    it "shows shared log options in help":
        _setup_fixture()
        val (out, err, code) = _run_todo_scan(["--help"])
        expect(code).to_equal(0)
        expect(out).to_contain("--log-mode")
        expect(out).to_contain("--progress")

    it "supports log-mode json":
        _setup_fixture()
        val (out, err, code) = _run_todo_scan(["--log-mode=json"])
        expect(code).to_equal(0)
        expect(out).to_contain("\"command\":\"todo-scan\"")
        expect(out).to_contain("\"files\":1")
        expect(out).to_contain("\"todos\":1")

    it "supports dot progress":
        _setup_fixture()
        val (out, err, code) = _run_todo_scan(["--progress=dot"])
        expect(code).to_equal(0)
        expect(out).to_contain(".")
        expect(out).to_contain("Scan complete: 1 TODOs found")

    it "rejects invalid log mode":
        _setup_fixture()
        val (out, err, code) = _run_todo_scan(["--log-mode=noisy"])
        expect(code).to_equal(1)
