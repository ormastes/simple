use std.spec.{describe, it, expect}

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

val FIXTURE_DIR = "/tmp/simple_check_log_mode_fixture"

fn _setup_fixture():
    val (_out, _err, _code) = rt_process_run("/bin/sh", [
        "-c",
        "rm -rf " + FIXTURE_DIR + " && mkdir -p " + FIXTURE_DIR + " && cat > " + FIXTURE_DIR + "/sample.spl <<'EOF'\nfn answer() -> i64:\n    42\nEOF\ncat > " + FIXTURE_DIR + "/sample_spec.spl <<'EOF'\nuse std.spec.{describe, it, expect}\n\ndescribe \"sample\":\n    it \"works\":\n        expect(1).to_equal(1)\nEOF\ncat > " + FIXTURE_DIR + "/not_spec.spl <<'EOF'\nuse std.specification\n\nval example = \"\"\"\nuse std.spec\ndescribe \"inside string\":\n\"\"\"\n\ndescribe \"ordinary non-spec source\":\n\nfn example_body():\n    use std.spec\n    describe \"indented\":\nEOF"
    ])

fn _run_check(args: [text]) -> (text, text, i64):
    val joined = args.join(" ")
    rt_process_run("/bin/sh", [
        "-c",
        "REPO=$(pwd); cd " + FIXTURE_DIR + " && SIMPLE_LIB=\"$REPO/src\" \"$REPO/bin/simple\" run \"$REPO/src/app/check/main.spl\" " + joined
    ])

describe "check log mode CLI options":
    it "shows shared log options in help":
        _setup_fixture()
        val (out, err, code) = _run_check(["--help"])
        expect(code).to_equal(0)
        expect(out).to_contain("--log-mode")
        expect(out).to_contain("--progress")

    it "supports log-mode json":
        _setup_fixture()
        val (out, err, code) = _run_check(["--log-mode=json", "missing.spl"])
        expect(code).to_equal(1)
        expect(out).to_contain("\"command\":\"check\"")
        expect(out).to_contain("\"status\":\"error\"")
        expect(out).to_contain("\"files\":1")

    it "supports dot progress":
        _setup_fixture()
        val (out, err, code) = _run_check(["--progress=dot", "missing.spl"])
        expect(code).to_equal(1)
        expect(out).to_contain(".")
        expect(out).to_contain("ERROR: file not found: missing.spl")

    it "directs SSpec command blocks to the test runner before parsing":
        _setup_fixture()
        val (out, err, code) = _run_check(["sample_spec.spl"])
        val combined = out + "\n" + err
        expect(code).to_equal(1)
        expect(combined).to_contain("bin/simple test sample_spec.spl --mode=interpreter")
        expect(combined.contains("unexpected token in expression: : ':'")).to_equal(false)

    it "does not classify prefixes, strings, or indented text as SSpec":
        _setup_fixture()
        val (out, err, code) = _run_check(["not_spec.spl"])
        val combined = out + "\n" + err
        expect(code).to_equal(1)
        expect(combined.contains("error[E-SSPEC-CHECK]")).to_equal(false)

    it "rejects invalid log mode":
        _setup_fixture()
        val (out, err, code) = _run_check(["--log-mode=noisy", "sample.spl"])
        expect(code).to_equal(1)
