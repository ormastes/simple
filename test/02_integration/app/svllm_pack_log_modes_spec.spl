use std.spec.{describe, it, expect}
use app.io.mod.{process_run}

fn _run_svllm_pack(args: [text]) -> (text, text, i64):
    val joined = args.join(" ")
    process_run("/bin/sh", [
        "-c",
        "REPO=$(pwd); SIMPLE_BIN=\"$SIMPLE_BINARY\"; if [ -z \"$SIMPLE_BIN\" ]; then if [ -x \"$REPO/bin/simple\" ]; then SIMPLE_BIN=\"$REPO/bin/simple\"; else SIMPLE_BIN=\"$REPO/release/x86_64-unknown-linux-gnu/simple\"; fi; fi; SIMPLE_LIB=\"$REPO/src\" \"$SIMPLE_BIN\" run \"$REPO/src/app/svllm_pack/main.spl\" " + joined
    ])

describe "svllm pack log mode CLI options":
    it "shows shared log options in help":
        val (out, err, code) = _run_svllm_pack(["--help"])
        expect(code).to_equal(0)
        expect(out).to_contain("--log-mode")
        expect(out).to_contain("--progress")

    it "supports log-mode json for usage output":
        val (out, err, code) = _run_svllm_pack(["--log-mode=json"])
        expect(code).to_equal(0)
        expect(out).to_contain("\"command\":\"svllm-pack\"")
        expect(out).to_contain("\"status\":\"usage\"")

    it "supports dot progress for help output":
        val (out, err, code) = _run_svllm_pack(["--progress=dot", "--help"])
        expect(code).to_equal(0)
        expect(out).to_contain(".")
        expect(out).to_contain("svllm-pack")

    it "rejects invalid log mode":
        val (out, err, code) = _run_svllm_pack(["--log-mode=noisy"])
        expect(code).to_equal(1)

    it "emits json for unknown options":
        val (out, err, code) = _run_svllm_pack(["--log-mode=json", "--bogus"])
        expect(code).to_equal(1)
        expect(out).to_contain("\"command\":\"svllm-pack\"")
        expect(out).to_contain("\"status\":\"error\"")
