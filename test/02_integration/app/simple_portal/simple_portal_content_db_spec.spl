use std.spec
use std.db.dbfs_driver.{DbFsDriver}
use std.fs_driver.instance.{DriverInstance}
use std.fs_driver.mount_table.{MountTable}
use std.fs_driver.types.{MountOptions, OpenFlags}
use app.simple_portal.content_db.{
    portal_content_db_load, portal_content_db_from_text,
    portal_content_db_load_from_mount, portal_content_db_load_resolved,
    portal_example_by_id, portal_page_by_slug,
    portal_read_example_source_from_mount, portal_read_page_body_from_mount,
    simple_portal_default_app_root
}

fn _write_mount_file(mt: MountTable, path: text, body: text) -> MountTable:
    val fh = mt.open(path, OpenFlags.create_write()).unwrap()
    mt.write(fh, body).unwrap()
    mt.close(fh).unwrap()
    mt

fn _make_portal_dbfs_mount() -> MountTable:
    var mt = MountTable.new()
    val dbfs = DbFsDriver.new_hosted()
    mt.mount("/portal", DriverInstance.DbFs(dbfs), MountOptions.default()).unwrap()
    mt = _write_mount_file(mt, "/portal/content/pages.db", "ops|Ops|Mounted DBFS content|pages/ops.html\n")
    mt = _write_mount_file(mt, "/portal/content/examples.db", "hello|Hello|simple|client|Example|examples/hello.simple\n")
    mt = _write_mount_file(mt, "/portal/content/releases.db", "1.0.0|stable|Stable|https://example.com\n")
    mt = _write_mount_file(mt, "/portal/content/links.db", "repo|Repo|repo|https://example.com\n")
    mt = _write_mount_file(mt, "/portal/content/pages/ops.html", "<h1>DBFS mounted portal</h1>\n")
    mt = _write_mount_file(mt, "/portal/content/examples/hello.simple", "print \"hello\"\n")
    mt

describe "simple_portal content db":
    it "loads the packaged portal content root":
        val result = portal_content_db_load(simple_portal_default_app_root())
        expect(result.is_ok()).to_equal(true)

    it "prefers a complete filesystem-backed data root over a missing app root":
        val data_root = simple_portal_default_app_root()
        val result = portal_content_db_load_resolved("/tmp/simple_portal_missing_app_root", data_root)
        expect(result.is_ok()).to_equal(true)
        val source = result.unwrap()
        expect(source.root).to_equal(data_root)
        expect(source.db.pages[0].slug).to_equal("docs")

    it "loads portal content from a DBFS-backed mount table root":
        val mt = _make_portal_dbfs_mount()
        val result = portal_content_db_load_from_mount(mt, "/portal")
        expect(result.is_ok()).to_equal(true)
        val source = result.unwrap()
        expect(source.root).to_equal("/portal")
        expect(source.db.pages.len()).to_equal(1)
        expect(source.db.examples.len()).to_equal(1)
        val page = portal_page_by_slug(source.db, "ops")
        expect(page.?).to_equal(true)
        val body = portal_read_page_body_from_mount(mt, source.root, source.db.pages[0])
        expect(body).to_contain("DBFS mounted portal")
        val example = portal_example_by_id(source.db, "hello")
        expect(example.?).to_equal(true)
        val source_text = portal_read_example_source_from_mount(mt, source.root, source.db.examples[0])
        expect(source_text).to_contain("print \"hello\"")

    it "rejects malformed page body paths":
        val result = portal_content_db_from_text(
            "docs|Docs|Summary|../escape.html",
            "hello-world|Hello|simple|client|Summary|examples/hello.simple",
            "1.0.0|stable|Stable|https://example.com",
            "repo|Repo|repo|https://example.com"
        )
        expect(result.is_err()).to_equal(true)

    it "rejects unsupported example execution modes":
        val result = portal_content_db_from_text(
            "docs|Docs|Summary|pages/docs.html",
            "hello-world|Hello|simple|shell|Summary|examples/hello.simple",
            "1.0.0|stable|Stable|https://example.com",
            "repo|Repo|repo|https://example.com"
        )
        expect(result.is_err()).to_equal(true)
