## Static smoke test for Wave 2's --print-plan scaffolding in
## src/os/port/llvm/build.spl.
##
## The executable `--cross --print-plan` path is covered by the current
## evidence report. This spec keeps a static backstop for the constants,
## function definitions, CLI flags, and per-target expansion patterns that
## Wave 2 introduced.
##
## Run:
##   bin/simple test test/integration/os/port/llvm/cross_build_plan_spec.spl

use std.text
use std.process
use std.spec

val BUILD_SPL = "src/os/port/llvm/build.spl"

fn build_source() -> text:
    process.run("cat", [BUILD_SPL]).stdout

fn check(condition: bool):
    expect(condition).to_equal(true)

describe "SimpleOS LLVM cross-build --print-plan scaffolding":
    """Static checks on build.spl for Wave 2's multi-target scaffolding."""

    it "defines CROSS_SUPPORTED_TARGETS with 5 triples":
        """CROSS_SUPPORTED_TARGETS constant must be declared."""
        val src = build_source()
        check(src.contains("val CROSS_SUPPORTED_TARGETS"))

    it "includes x86_64-unknown-simpleos triple":
        """x86_64 triple must appear in the supported-targets list."""
        val src = build_source()
        check(src.contains("x86_64-unknown-simpleos"))

    it "includes aarch64-unknown-simpleos triple":
        val src = build_source()
        check(src.contains("aarch64-unknown-simpleos"))

    it "includes riscv64gc-unknown-simpleos triple":
        val src = build_source()
        check(src.contains("riscv64gc-unknown-simpleos"))

    it "includes riscv32imac-unknown-simpleos triple":
        val src = build_source()
        check(src.contains("riscv32imac-unknown-simpleos"))

    it "includes armv7-unknown-simpleos triple":
        val src = build_source()
        check(src.contains("armv7-unknown-simpleos"))

    it "maps triples via cross_llvm_arch_for":
        val src = build_source()
        check(src.contains("fn cross_llvm_arch_for"))

    it "maps armv7 to LLVM ARM":
        val src = build_source()
        check(src.contains("triple.starts_with(\"armv7\")"))
        check(src.contains("\"ARM\""))

    it "normalizes runner separator before --cross dispatch":
        val src = build_source()
        check(src.contains("args[0] == \"--\""))
        check(src.contains("args = args.slice(1, args.len())"))

    it "defines cross_build_print_plan":
        val src = build_source()
        check(src.contains("fn cross_build_print_plan"))

    it "defines cross_build_stage_for_target":
        val src = build_source()
        check(src.contains("fn cross_build_stage_for_target"))

    it "cross_build_status iterates all targets":
        val src = build_source()
        check(src.contains("fn cross_build_status"))
        check(src.contains("for triple in CROSS_SUPPORTED_TARGETS"))

    it "exposes --targets CLI flag":
        val src = build_source()
        check(src.contains("--targets"))

    it "parses --targets as comma-separated triples":
        val src = build_source()
        check(src.contains("override.split(\",\")"))
        check(src.contains("selected.push(trimmed)"))

    it "exposes --all CLI flag":
        val src = build_source()
        check(src.contains("--all"))

    it "exposes --print-plan CLI flag":
        val src = build_source()
        check(src.contains("--print-plan"))

    it "per-target stage passes SIMPLEOS_TARGET_TRIPLE env var":
        val src = build_source()
        check(src.contains("SIMPLEOS_TARGET_TRIPLE"))

    it "per-target build dir is cross-<triple>":
        val src = build_source()
        check(src.contains("cross-"))
