## Per-target cross-build scaffolding spec (A4/A5).
##
## Static checks that build.spl, build.shs, compiler_rt_cmake.cmake, and
## the SimpleOS ToolChain README are wired up so the cross-build pipeline
## iterates every SimpleOS triple and stages compiler-rt builtins into the
## clang resource dir.
##
## Run:
##   bin/simple test test/integration/os/port/llvm/per_target_build_spec.spl

use std.text
use std.process
use std.spec

val BUILD_SPL = "src/os/port/llvm/build.spl"
val BUILD_SHS = "src/os/port/llvm/build.shs"
val RT_CMAKE  = "src/os/port/llvm/compiler_rt_cmake.cmake"
val TOOLCHAIN_README = "src/os/port/llvm/patches/simpleos_toolchain_cpp/README.md"

fn build_spl_src() -> text:
    process.run("cat", [BUILD_SPL]).stdout

fn build_shs_src() -> text:
    process.run("cat", [BUILD_SHS]).stdout

fn rt_cmake_src() -> text:
    process.run("cat", [RT_CMAKE]).stdout

fn check(condition: bool):
    expect(condition).to_equal(true)

fn regular_file_exists(path: text) -> bool:
    process.run("test", ["-f", path]).exit_code == 0

describe "SimpleOS LLVM per-target build (A4/A5)":
    """Scaffolding checks for the multi-target cross-build + compiler-rt stage."""

    it "declares CROSS_SUPPORTED_TARGETS":
        """The SimpleOS target list constant must be present."""
        val src = build_spl_src()
        check(src.contains("val CROSS_SUPPORTED_TARGETS"))

    it "CROSS_SUPPORTED_TARGETS lists all five SimpleOS triples":
        """All 5 triples required by A4 must appear in build.spl."""
        val src = build_spl_src()
        check(src.contains("x86_64-unknown-simpleos"))
        check(src.contains("aarch64-unknown-simpleos"))
        check(src.contains("armv7-unknown-simpleos"))
        check(src.contains("riscv64gc-unknown-simpleos"))
        check(src.contains("riscv32imac-unknown-simpleos"))

    it "honours SIMPLE_TARGET env override":
        """Single-target override must be wired into selection."""
        val src = build_spl_src()
        check(src.contains("SIMPLE_TARGET"))
        check(src.contains("cross_selected_targets"))

    it "cross_build_all iterates CROSS_SUPPORTED_TARGETS":
        """Full cross-build must loop via the per-target stage helper."""
        val src = build_spl_src()
        check(src.contains("fn cross_build_all"))
        check(src.contains("cross_build_stage_for_target"))

    it "exports build_compiler_rt(triple)":
        """A5's public compiler-rt builder must be present with a triple parameter."""
        val src = build_spl_src()
        check(src.contains("fn build_compiler_rt(triple: text)"))

    it "exports build_compiler_rt_for_target":
        """Internal per-target helper must also be exposed for callers/tests."""
        val src = build_spl_src()
        check(src.contains("fn build_compiler_rt_for_target"))

    it "registers compiler-rt subcommand in cross_build_main":
        """The new `compiler-rt` subcommand keyword must be wired up."""
        val src = build_spl_src()
        check(src.contains("\"compiler-rt\""))
        check(src.contains("subcommand"))

    it "exposes --print-plan CLI flag":
        val src = build_spl_src()
        check(src.contains("--print-plan"))

    it "stages builtins into clang resource dir":
        val src = build_spl_src()
        check(src.contains("lib/clang/"))
        check(src.contains("CLANG_RESOURCE_VERSION"))

    it "gates compiler-rt behind -simpleos triples":
        val src = build_spl_src()
        check(src.contains("ends_with(\"-simpleos\")"))

    it "per-target build dir is cross-<triple>":
        val src = build_spl_src()
        check(src.contains("cross-"))

    it "compiler-rt build dir is compiler-rt-<triple>":
        val src = build_spl_src()
        check(src.contains("compiler-rt-"))

    it "build.shs threads SIMPLEOS_TARGET_TRIPLE":
        val src = build_shs_src()
        check(src.contains("SIMPLEOS_TARGET_TRIPLE"))
        check(src.contains("SIMPLE_TARGET"))

    it "build.shs uses per-triple CROSS_DIR / RT_DIR":
        val src = build_shs_src()
        check(src.contains("CROSS_DIR="))
        check(src.contains("RT_DIR="))

    it "build.shs still dispatches compiler-rt subcommand":
        val src = build_shs_src()
        check(src.contains("compiler-rt)"))
        check(src.contains("stage3_compiler_rt"))

    it "build.shs stages builtins into resource dir":
        val src = build_shs_src()
        check(src.contains("RES_LIB_DIR"))
        check(src.contains("lib/clang/"))

    it "compiler_rt_cmake.cmake exists":
        check(regular_file_exists(RT_CMAKE))

    it "compiler_rt_cmake.cmake enables COMPILER_RT_BUILD_BUILTINS":
        val src = rt_cmake_src()
        check(src.contains("COMPILER_RT_BUILD_BUILTINS"))

    it "compiler_rt_cmake.cmake disables sanitizers / xray / profile":
        val src = rt_cmake_src()
        check(src.contains("COMPILER_RT_BUILD_SANITIZERS"))
        check(src.contains("COMPILER_RT_BUILD_XRAY"))
        check(src.contains("COMPILER_RT_BUILD_PROFILE"))

    it "compiler_rt_cmake.cmake sets COMPILER_RT_OS_DIR to simpleos":
        val src = rt_cmake_src()
        check(src.contains("COMPILER_RT_OS_DIR simpleos"))

    it "SimpleOS ToolChain README exists":
        check(regular_file_exists(TOOLCHAIN_README))
