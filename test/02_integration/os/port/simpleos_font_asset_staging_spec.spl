use std.spec
use std.io_runtime.{file_read}
use std.common.encoding.font_registry.{selected_font_asset_candidates, selected_font_bundle_asset_pins, simpleos_default_font_asset_candidate, simpleos_font_asset_guest_path, simpleos_font_asset_short_guest_path, simpleos_font_asset_short_name}
use os.port.font_bundle.{simpleos_font_bundle_entries}

fn bundle_pin_sha256(path: text) -> text:
    for pin in selected_font_bundle_asset_pins():
        if pin.path == path: return pin.sha256
    ""

fn expect_simpleos_font_asset():
    val font = simpleos_default_font_asset_candidate()
    expect(font.local_path).to_equal("assets/fonts/google-fonts/ofl/notosansmono/NotoSansMono[wdth,wght].ttf")
    expect(font.byte_len).to_equal(1708408)
    expect(font.sha256).to_equal("2cb2adb378a8f574213e23df697050b83c54c27df465a2015552740b2769a081")
    val image_builder = file_read("src/os/installer/image_builder.spl")
    val initramfs = file_read("src/os/port/initramfs_pack.spl")
    val legacy_bake = file_read("src/os/port/disk_image_bake.spl")
    val disk_writer = file_read("src/os/port/disk_image.spl")
    val direct_script = file_read("scripts/os/make_os_disk.shs")
    val direct_builder = file_read("scripts/os/make_os_disk.c")
    val companion_manifest = file_read("scripts/os/simpleos_font_bundle_companion.sha256")
    val guest = file_read("examples/09_embedded/simple_os/arch/x86_64/gui_entry_desktop.spl")
    val arm_guest = file_read("examples/09_embedded/simple_os/arch/arm64/gui_entry_desktop.spl")
    val rv_guest = file_read("examples/09_embedded/simple_os/arch/riscv64/gui_entry_desktop.spl")
    val desktop_bootstrap = file_read("src/os/desktop/font_bootstrap.spl")
    val vfs_boot = file_read("src/os/services/vfs/vfs_boot_init.spl")
    val vfs_hub = file_read("src/os/services/vfs/vfs_init.spl")
    val runner_targets = file_read("src/os/_QemuRunner/runner_targets.spl")
    val scenario_exec = file_read("src/os/_QemuRunner/scenario_exec.spl")
    val browser = file_read("src/os/apps/simple_browser/main.spl")
    val vfs = file_read("src/os/services/vfs/vfs_init.spl")
    val adapter = file_read("src/os/services/vfs/c_nvme_block_adapter.spl")
    val boot_vfs = file_read("src/os/services/vfs/vfs_boot_init.spl")
    val x86_stubs = file_read("examples/09_embedded/simple_os/arch/x86_64/boot/baremetal_stubs.c")
    val arm64_stubs = file_read("examples/09_embedded/simple_os/arch/arm64/boot/baremetal_stubs.c")
    expect(selected_font_asset_candidates().len()).to_equal(16)
    expect(simpleos_font_bundle_entries().len()).to_equal(53)
    expect(image_builder).to_contain("for entry in simpleos_font_bundle_entries()")
    expect(image_builder).to_contain("font_guest_paths.push(entry.guest_long_path)")
    expect(image_builder).to_contain("font_blobs.push(loaded.data)")
    expect(image_builder).to_contain("_ensure_parent_dirs(rootfs_root, font_path)")
    expect(image_builder).to_contain("rt_file_write_bytes(rootfs_root + font_path, font_blobs[font_index])")
    expect(image_builder).to_contain("val kind = if font_path.ends_with(\".ttf\"): \"font-asset\" else: \"font-notice\"")
    expect(image_builder).to_contain("_manifest_file(font_path, kind, \"simpleos-core\")")
    expect(image_builder.contains("rootfs_root, \"/\" + font_path")).to_equal(false)
    expect(image_builder.contains("{rootfs_root}/\" + font_path")).to_equal(false)
    expect(initramfs).to_contain("for entry in simpleos_font_bundle_entries()")
    expect(initramfs).to_contain("file_write_bytes(font_dst, loaded.data)")
    expect(legacy_bake).to_contain("for entry in simpleos_font_bundle_entries()")
    expect(legacy_bake).to_contain("path: entry.guest_short_name")
    expect(legacy_bake).to_contain("data: loaded.data")
    expect(legacy_bake).to_contain("nested_payloads.push(PayloadEntry(")
    expect(legacy_bake.index_of("val config = PackConfig(") < legacy_bake.index_of("for entry in simpleos_font_bundle_entries()")).to_be(true)
    expect(legacy_bake).to_contain("var size_mb: u64 = 128u64")
    expect(legacy_bake).to_contain("val required_mb = (payload_bytes + 1048575u64) / 1048576u64 + 16u64")
    expect(legacy_bake.contains("bake_disk_via_mkfs_fat")).to_equal(false)
    expect(disk_writer).to_contain("fn _build_vfat_lfn_slot(")
    expect(disk_writer).to_contain("fn _build_named_dir_entry_attr(")
    expect(disk_writer).to_contain("val dir_cluster_count = cluster_counts[")
    expect(disk_writer.contains("nested leaf name must be 1-8 chars")).to_equal(false)
    expect(direct_script).to_contain("validate_font_asset \"$SIMPLEOS_FONT_ASSET_NSANSSC\" 17772300")
    expect(direct_script).to_contain("validate_font_asset \"$SIMPLEOS_FONT_ASSET_NOTOEMOJ\" 1982596")
    expect(direct_script).to_contain("if [ \"$size_bits\" -lt 128 ]")
    expect(direct_script).to_contain("shasum -a 256")
    expect(direct_script).to_contain("2cb2adb378a8f574213e23df697050b83c54c27df465a2015552740b2769a081")
    expect(direct_script).to_contain("53 files / 51,932,530 bytes")
    expect(direct_script).to_contain("sha256sum --check \"$font_companion_manifest\"")
    expect(direct_script).to_contain("shasum -a 256 --check \"$font_companion_manifest\"")
    expect(direct_builder).to_contain("FONT_ASSET_COUNT = 16")
    expect(direct_builder).to_contain("SIMPLEOS_FONT_ASSET_NSANSSC")
    expect(direct_builder).to_contain("SIMPLEOS_FONT_ASSET_NOTOEMOJ")
    expect(direct_builder).to_contain("SIMPLEOS_FONT_ASSET_COUNT=16")
    expect(direct_builder).to_contain("SIMPLEOS_FONT_BUNDLE_COUNT=53")
    expect(direct_builder).to_contain("SIMPLEOS_FONT_ASSET_PATH=/SYS/FONTS/NOTOSANS")
    expect(direct_builder.contains("2cb2adb378a8f574213e23df697050b83c54c27df465a2015552740b2769a081")).to_equal(false)
    expect(direct_builder).to_contain("SIMPLEOS_FONT_NOTICES_PATH=/SYS/FONTS/NOTICES.MD")
    expect(direct_builder).to_contain("font_long_names[FONT_ASSET_COUNT]")
    expect(direct_builder).to_contain("NotoSansMono[wdth,wght].ttf")
    expect(direct_builder).to_contain("put_named_dir_entry(fonts, &fonts_n, font_fat_names[i], font_long_names[i]")
    expect(direct_builder).to_contain("read_sibling_file(font_companion_anchor_paths[i], \"METADATA.pb\")")
    expect(direct_builder).to_contain("assets/fonts/google-fonts/ofl/notosansmono/NotoSansMono[wdth,wght].ttf")
    expect(direct_builder.contains("read_sibling_file(font_asset_path")).to_equal(false)
    expect(direct_builder).to_contain("assets/fonts/cldr/release-48-2/LICENSE")
    expect(direct_builder).to_contain("THIRD_PARTY_NOTICES.md")
    expect(direct_builder).to_contain("if (fonts_n != 91)")
    expect(direct_builder).to_contain("fonts[4096]")
    expect(4096 / 32).to_equal(128)
    expect(91).to_be_less_than(4096 / 32)

    var companion_manifest_count: i64 = 0
    for line in companion_manifest.split("\n"):
        if line.trim() != "": companion_manifest_count = companion_manifest_count + 1
    expect(companion_manifest_count).to_equal(35)
    for entry in simpleos_font_bundle_entries():
        val pin_sha256 = bundle_pin_sha256(entry.source_path)
        if pin_sha256 != "":
            if entry.source_path.ends_with(".ttf"):
                expect(direct_script).to_contain(entry.source_path)
                expect(direct_script).to_contain(pin_sha256)
                expect(direct_builder).to_contain(entry.source_path)
            else:
                expect(companion_manifest).to_contain(pin_sha256 + "  " + entry.source_path)
    expect(desktop_bootstrap).to_contain("val candidates = selected_font_asset_candidates()")
    expect(desktop_bootstrap).to_contain("for candidate in candidates:")
    expect(desktop_bootstrap.contains("vfs_is_ready")).to_equal(false)
    expect(desktop_bootstrap).to_contain("g_vfs_read_file_bytes(simpleos_font_asset_guest_path(candidate))")
    expect(desktop_bootstrap).to_contain("g_vfs_read_file_bytes(simpleos_font_asset_short_guest_path(candidate))")
    expect(desktop_bootstrap).to_contain("font_renderer_use_registered_selected_bytes_only()")
    expect(desktop_bootstrap).to_contain("registered_candidate = canonical_blob.len() > 0 and font_renderer_register_selected_bytes(candidate.local_path, canonical_blob)")
    expect(desktop_bootstrap).to_contain("if not registered_candidate:\n            val short_blob = g_vfs_read_file_bytes(simpleos_font_asset_short_guest_path(candidate))")
    expect(desktop_bootstrap).to_contain("registered_candidate = short_blob.len() > 0 and font_renderer_register_selected_bytes(candidate.local_path, short_blob)")
    expect(desktop_bootstrap).to_contain("registered == candidates.len()")
    val read_fn = vfs.substring(vfs.index_of("pub fn g_vfs_read_file_bytes"), vfs.len())
    val direct_read = read_fn.index_of("val direct_scalar_bytes = vfs_boot_read_pure_nvme_fat32_path_bytes(name)")
    val mounted_gate = read_fn.index_of("if not g_vfs_initialized:")
    expect(direct_read).to_be_greater_than(0)
    expect(direct_read).to_be_less_than(mounted_gate)
    expect(guest).to_contain("simpleos_desktop_register_selected_fonts_from_vfs()")
    expect(arm_guest).to_contain("simpleos_desktop_register_selected_fonts_from_vfs()")
    expect(rv_guest.contains("simpleos_desktop_register_selected_fonts_from_vfs()")).to_equal(false)
    expect(rv_guest.contains("vfs_boot_init_virtio_fat32()")).to_equal(false)
    expect(vfs_boot).to_contain("pub fn vfs_boot_init_virtio_fat32() -> bool:")
    expect(vfs_boot).to_contain("_vfs_boot_reset_storage_state()\n    val dev_opt = VirtioBlkDriver.probe()")
    expect(vfs_boot).to_contain("if probe.len() <= 4:\n        log_raw_println(\"[vfs-init] executable load probe failed path=/SYS/APPS/HELLOSMF.SMF\")\n        _vfs_boot_reset_storage_state()\n        return false")
    expect(vfs_hub).to_contain("vfs_boot_init_virtio_fat32")
    val arm_mount = arm_guest.index_of("    vfs_boot_init_virtio_fat32()")
    val arm_register = arm_guest.index_of("val font_loaded = simpleos_desktop_register_selected_fonts_from_vfs()")
    expect(arm_mount).to_be_greater_than(0)
    expect(arm_mount).to_be_less_than(arm_register)
    expect(arm_guest).to_contain("if font_loaded:")
    expect(arm_guest).to_contain("font registered source=virtio-fat32")
    expect(runner_targets).to_contain("_arm_virtio_blk_exec_disk_args(Architecture.Arm64)")
    expect(scenario_exec).to_contain("scenario.name == \"arm64-wm-ramfb\" or scenario.name == \"arm64-desktop-engine2d\"")
    expect(scenario_exec).to_contain("return ensure_arm_fs_exec_disk_image(Architecture.Arm64)")
    expect(scenario_exec).to_contain("mtype -i \\\"{{img_path}}\\\" ::/SYS/FONTS/NOTOSANS")
    expect(scenario_exec).to_contain("[ \\\"$(wc -c <\\\"$font_tmp\\\" | tr -d ' ')\\\" = 1708408 ]")
    expect(scenario_exec).to_contain("sha256sum \\\"$font_tmp\\\"")
    expect(scenario_exec).to_contain("shasum -a 256 \\\"$font_tmp\\\"")
    expect(scenario_exec).to_contain("else exit 1;")
    expect(scenario_exec.contains("grep -a -q 'SIMPLEOS_FONT_ASSET_NOTOSANS_BYTES=1708408'")).to_equal(false)
    expect(vfs_boot).to_contain("g_root_fat32 = nil")
    expect(vfs_boot).to_contain("g_root_nvfs_hosted = nil")
    expect(vfs_boot).to_contain("g_vfs_initialized = false")
    expect(vfs_boot).to_contain("g_mount_table = MountTable.new()")
    expect(vfs_boot).to_contain("g_vfs = VfsManager.new()")
    expect(vfs_boot).to_contain("fn _vfs_boot_reset_storage_state():\n    g_root_fat32 = nil\n    g_root_nvfs_hosted = nil\n    g_vfs_initialized = false\n    g_mount_table = MountTable.new()\n    g_vfs = VfsManager.new()")
    expect(guest.contains("font_renderer_register_selected_bytes(")).to_equal(false)
    expect(guest).to_contain("route=shared-wm-draw-ir component_id=taskbar-clock")
    expect(guest.contains("engine.draw_text(64, 64")).to_equal(false)
    expect(guest.contains("/SYS/FONTS/NOTOSANS.TTF")).to_equal(false)
    expect(browser).to_contain("for candidate in selected_font_asset_candidates()")
    expect(browser).to_contain("_read_bytes_via_vfs(simpleos_font_asset_guest_path(candidate))")
    expect(browser).to_contain("_read_bytes_via_vfs(simpleos_font_asset_short_guest_path(candidate))")
    expect(browser).to_contain("font_renderer_register_selected_bytes(candidate.local_path, blob)")
    expect(browser).to_contain("if registered_fonts != required_fonts:")
    expect(vfs).to_contain("FAT32_PATH_READ_BUFFER_MAX: u64 = 33554432")
    expect(vfs).to_contain("driver.read(handle, FAT32_PATH_READ_BUFFER_MAX)")
    expect(vfs).to_contain("C_FAT32_PATH_READ_BUFFER_MAX: u64 = 33554432")
    expect(adapter).to_contain("FAT32_PATH_READ_BUFFER_MAX: u64 = 33554432")
    expect(boot_vfs).to_contain("PURE_FAT32_FILE_READ_MAX: u64 = 33554432")
    expect(x86_stubs).to_contain("simpleos_fat32_path_read_buf[33554432]")
    expect(x86_stubs).to_contain("simpleos_fat32_path_read_buf_size = 33554432")
    expect(arm64_stubs).to_contain("simpleos_fat32_path_read_buf[33554432]")
    expect(arm64_stubs).to_contain("simpleos_fat32_path_read_buf_size = 33554432")
    expect(25125512).to_be_less_than(33554432)
    expect(boot_vfs).to_contain("driver.read(handle, PURE_FAT32_FILE_READ_MAX)")

fn expect_simpleos_font_guest_paths():
    var paths: [text] = []
    var short_paths: [text] = []
    for candidate in selected_font_asset_candidates():
        val path = simpleos_font_asset_guest_path(candidate)
        expect(path).to_start_with("/SYS/FONTS/")
        expect(paths.contains(path)).to_equal(false)
        paths.push(path)
        val short_path = simpleos_font_asset_short_guest_path(candidate)
        expect(short_path).to_start_with("/SYS/FONTS/")
        expect(short_paths.contains(short_path)).to_equal(false)
        expect(simpleos_font_asset_short_name(candidate).len()).to_be_less_than(9)
        short_paths.push(short_path)
    expect(paths.len()).to_equal(16)
    expect(short_paths.len()).to_equal(16)
    expect(paths[8]).to_equal("/SYS/FONTS/NotoSansMono[wdth,wght].ttf")
    expect(short_paths[8]).to_equal("/SYS/FONTS/NOTOSANS")

describe "SimpleOS pinned font asset staging":
    it "should use the pinned Noto Sans Mono path length and hash":
        step("Inspect the default SimpleOS font identity")
        val font = simpleos_default_font_asset_candidate()
        expect(font.local_path).to_equal("assets/fonts/google-fonts/ofl/notosansmono/NotoSansMono[wdth,wght].ttf")
        expect(font.byte_len).to_equal(1708408)
        expect(font.sha256).to_equal("2cb2adb378a8f574213e23df697050b83c54c27df465a2015552740b2769a081")

    it "should stage the selected catalog through every Simple image tree builder":
        step("Inspect the shared 53-file SimpleOS font/legal projection")
        expect_simpleos_font_asset()
        step("Preserve every existing guest font registry path")
        expect_simpleos_font_guest_paths()
