# T32 Hardware -- Job Manager
#
# Tests that eval calls complete synchronously, that long-running
# evals return, that sequential evals all succeed, and that the
# session recovers from a failed eval.
#
# @session-kind: trace32_board
# @target: arm
# @tag: t32_hw, new_tools
# @reuse: exclusive_reused

use std.spipe.{describe, context, it, expect, before_all, after_all}
use test.integration.t32_hw.t32_hw_helpers.{
    t32_hw_probe_available, t32_hw_connect, t32_hw_run_cmd, t32_hw_eval,
    t32_hw_host, t32_hw_port, t32_hw_version_gate_new,
    t32_hw_relay_power_on, t32_hw_relay_power_off, t32_hw_relay_power_state
}

describe "T32 job manager":
    var client = nil

    before_all:
        val result = t32_hw_connect()
        match result:
            Ok(c): client = c
            Err(e): expect("connect failed: {e}").to_equal("")

    after_all:
        if client != nil:
            client.disconnect()

    context "synchronous eval":
        it "eval completes synchronously":
            val result = t32_hw_eval(client, "1+1")
            match result:
                Ok(v):
                    # Should return a value immediately
                    expect(v.len()).to_be_greater_than(0)
                Err(e):
                    expect("eval 1+1 failed: {e}").to_equal("")

        it "long eval completes":
            val result = t32_hw_eval(client, "VERSION.BUILD()")
            match result:
                Ok(v):
                    expect(v.len()).to_be_greater_than(0)
                Err(e):
                    expect("VERSION.BUILD() failed: {e}").to_equal("")

    context "sequential evals":
        it "multiple evals in sequence":
            val r1 = t32_hw_eval(client, "1+1")
            val r2 = t32_hw_eval(client, "2+2")
            val r3 = t32_hw_eval(client, "3+3")
            val ok1 = match r1:
                Ok(_): true
                Err(_): false
            val ok2 = match r2:
                Ok(_): true
                Err(_): false
            val ok3 = match r3:
                Ok(_): true
                Err(_): false
            val all_ok = ok1 and ok2 and ok3
            expect(all_ok).to_equal(true)

    context "error recovery":
        it "eval after error recovers":
            # Send a bad expression first
            val bad = t32_hw_eval(client, "ZZZNOTEXPR.ZZZZ()")
            # bad may be Ok or Err depending on T32 behavior
            # Now send a good expression and verify it works
            val good = t32_hw_eval(client, "VERSION.BUILD()")
            match good:
                Ok(v):
                    expect(v.len()).to_be_greater_than(0)
                Err(e):
                    expect("recovery eval failed: {e}").to_equal("")
