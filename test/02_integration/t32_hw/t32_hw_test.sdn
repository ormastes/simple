# T32 Hardware Integration Test Configuration
# Copy and customize for your setup.
# Environment variables override these values:
#   T32_HW_HOST, T32_HW_PORT, T32_PATH, T32_BACKEND_PREFERENCE,
#   T32_PYTHON_BINARY, T32_API_LIB_PATH, RELAY_DEVICE

connection
  default_host: localhost
  default_port: 20000
  backend_preference: t32rem

target
  architecture: arm
  # t32_config:
  # practice_startup:
  # elf_binary:

power
  relay_on_script: scripts/relay_on.shs
  relay_off_script: scripts/relay_off.shs
  relay_reset_script: scripts/relay_reset.shs
  relay_state_script: scripts/relay_state.shs
  # relay_device: /dev/ttyACM0

timeouts
  startup_wait_ms: 3000
  max_retries: 15
  retry_interval_ms: 500
  reset_settle_ms: 1000
  flash_settle_ms: 1000
  command_timeout_ms: 5000

version_gates
  min_version_old_tools: 120000
  min_version_new_tools: 130000
