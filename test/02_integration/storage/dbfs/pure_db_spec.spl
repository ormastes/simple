    it "supports CREATE INDEX":
        val r = PureDatabase.memory()
        var db = r.unwrap()
        db.exec_sql("CREATE TABLE idx_t (id INTEGER, name TEXT)").unwrap()
        db.exec_sql("INSERT INTO idx_t (id, name) VALUES (1, 'Alice')").unwrap()
        db.exec_sql("INSERT INTO idx_t (id, name) VALUES (2, 'Bob')").unwrap()
        val cr = db.exec_sql("CREATE INDEX idx_name ON idx_t (name)")
        expect(cr.is_ok()).to_be(true)
        # Queries should still work after index creation
        val qr = db.query("SELECT * FROM idx_t WHERE name = 'Alice'", [])
        val rows = qr.unwrap()
        expect(rows.len()).to_equal(1)
    it "supports CREATE UNIQUE INDEX":
        val r = PureDatabase.memory()
        var db = r.unwrap()
        db.exec_sql("CREATE TABLE uq_t (id INTEGER, name TEXT)").unwrap()
        db.exec_sql("INSERT INTO uq_t (id, name) VALUES (1, 'Alice')").unwrap()
        val cr = db.exec_sql("CREATE UNIQUE INDEX uq_name ON uq_t (name)")
        expect(cr.is_ok()).to_be(true)
        # Insert duplicate should fail
        val dup = db.exec_sql("INSERT INTO uq_t (id, name) VALUES (2, 'Alice')")
        expect(dup.is_err()).to_be(true)
        # Insert different value should succeed
        val ok = db.exec_sql("INSERT INTO uq_t (id, name) VALUES (3, 'Bob')")
        expect(ok.is_ok()).to_be(true)
    it "supports DROP INDEX":
        val r = PureDatabase.memory()
        var db = r.unwrap()
        db.exec_sql("CREATE TABLE di_t (id INTEGER, name TEXT)").unwrap()
        val cr = db.exec_sql("CREATE INDEX di_idx ON di_t (name)")
        expect(cr.is_ok()).to_be(true)
        val dr = db.exec_sql("DROP INDEX di_idx")
        expect(dr.is_ok()).to_be(true)
        # Dropping non-existent index should fail
        val dr2 = db.exec_sql("DROP INDEX di_idx")
        expect(dr2.is_err()).to_be(true)
    it "FTS uses shared engine for bm25_search":
        val r = PureDatabase.memory()
        var db = r.unwrap()
        db.exec_sql("CREATE TABLE fts_t (id INTEGER, title TEXT, body TEXT)").unwrap()
        db.exec_sql("INSERT INTO fts_t (id, title, body) VALUES (1, 'SQLite FTS5', 'embedded search engine bm25 ranking')").unwrap()
        db.exec_sql("INSERT INTO fts_t (id, title, body) VALUES (2, 'Other Storage', 'plain key value storage')").unwrap()
        db.exec_sql("INSERT INTO fts_t (id, title, body) VALUES (3, 'BM25 Search', 'bm25 bm25 search ranking support')").unwrap()
        val sr = db.bm25_search("fts_t", ["title", "body"], "bm25 search", 10)
        expect(sr.is_ok()).to_be(true)
        val rows = sr.unwrap()
        expect(rows.len()).to_equal(2)
        val first = rows[0]
        val second = rows[1]
        expect(first.score).to_be_greater_than(second.score)
        val first_row = first.row
        val first_id = first_row.values[0]
        expect(first_id.to_text()).to_equal("3")
    it "update_by_key updates a row via typed API":
        val r = PureDatabase.memory()
        var db = r.unwrap()
        db.exec_sql("CREATE TABLE ubk (id INTEGER PRIMARY KEY, name TEXT)").unwrap()
        db.exec_sql("INSERT INTO ubk (id, name) VALUES (1, 'Alice')").unwrap()
        db.exec_sql("INSERT INTO ubk (id, name) VALUES (2, 'Bob')").unwrap()
        var updates: Dict<text, DbValue> = {}
        updates["name"] = DbValue.Text(value: "Zara")
        val ur = db.update_by_key("ubk", "id", DbValue.Integer(value: 1), updates)
        expect(ur.is_ok()).to_be(true)
        expect(ur.unwrap()).to_equal(1)
        # Verify updated row via SQL
        val qr = db.query("SELECT * FROM ubk WHERE id = 1", [])
        val rows2 = qr.unwrap()
        expect(rows2.len()).to_equal(1)
        val row = rows2[0]
        expect(row.values[1].to_text()).to_equal("Zara")
        # Verify other row untouched
        val qr2 = db.query("SELECT * FROM ubk WHERE id = 2", [])
        val rows3 = qr2.unwrap()
        expect(rows3.len()).to_equal(1)
        expect(rows3[0].values[1].to_text()).to_equal("Bob")
    it "update_by_key returns 0 for non-existent key":
        val r = PureDatabase.memory()
        var db = r.unwrap()
        db.exec_sql("CREATE TABLE ubk2 (id INTEGER PRIMARY KEY, name TEXT)").unwrap()
        db.exec_sql("INSERT INTO ubk2 (id, name) VALUES (1, 'Alice')").unwrap()
        var upd2: Dict<text, DbValue> = {}
        upd2["name"] = DbValue.Text(value: "Zara")
        val ur = db.update_by_key("ubk2", "id", DbValue.Integer(value: 99), upd2)
        expect(ur.is_ok()).to_be(true)
        expect(ur.unwrap()).to_equal(0)
    it "update_by_key updates PK column and fixes PK map":
        val r = PureDatabase.memory()
        var db = r.unwrap()
        db.exec_sql("CREATE TABLE ubk3 (id INTEGER PRIMARY KEY, name TEXT)").unwrap()
        db.exec_sql("INSERT INTO ubk3 (id, name) VALUES (10, 'Alice')").unwrap()
        db.exec_sql("INSERT INTO ubk3 (id, name) VALUES (20, 'Bob')").unwrap()
        # Change PK value 10 -> 99
        var upd3: Dict<text, DbValue> = {}
        upd3["id"] = DbValue.Integer(value: 99)
        val ur = db.update_by_key("ubk3", "id", DbValue.Integer(value: 10), upd3)
        expect(ur.is_ok()).to_be(true)
        expect(ur.unwrap()).to_equal(1)
        # Old PK should return 0 rows
        val qr_old = db.query("SELECT * FROM ubk3 WHERE id = 10", [])
        expect(qr_old.unwrap().len()).to_equal(0)
        # New PK should return 1 row with name Alice
        val qr_new = db.query("SELECT * FROM ubk3 WHERE id = 99", [])
        val rows_new = qr_new.unwrap()
        expect(rows_new.len()).to_equal(1)
        expect(rows_new[0].values[1].to_text()).to_equal("Alice")
        # Other row untouched
        val qr_bob = db.query("SELECT * FROM ubk3 WHERE id = 20", [])
        expect(qr_bob.unwrap().len()).to_equal(1)
    it "exec_sql UPDATE uses PK fast path for literal WHERE":
        val r = PureDatabase.memory()
        var db = r.unwrap()
        db.exec_sql("CREATE TABLE pk_upd (id INTEGER PRIMARY KEY, name TEXT)").unwrap()
        db.exec_sql("INSERT INTO pk_upd (id, name) VALUES (1, 'Alice')").unwrap()
        db.exec_sql("INSERT INTO pk_upd (id, name) VALUES (2, 'Bob')").unwrap()
        val ur = db.exec_sql("UPDATE pk_upd SET name = 'Alicia' WHERE id = 1")
        expect(ur.is_ok()).to_equal(true)
        expect(ur.unwrap()).to_equal(1)
        val qr = db.query("SELECT * FROM pk_upd WHERE id = 1", [])
        val rows = qr.unwrap()
        expect(rows.len()).to_equal(1)
        expect(rows[0].values[1].to_text()).to_equal("Alicia")
        val qr2 = db.query("SELECT * FROM pk_upd WHERE id = 2", [])
        expect(qr2.unwrap().len()).to_equal(1)
        expect(qr2.unwrap()[0].values[1].to_text()).to_equal("Bob")
    it "exec_sql UPDATE PK fast path returns 0 for missing key":
        val r2 = PureDatabase.memory()
        var db2 = r2.unwrap()
        db2.exec_sql("CREATE TABLE pk_upd2 (id INTEGER PRIMARY KEY, val TEXT)").unwrap()
        db2.exec_sql("INSERT INTO pk_upd2 (id, val) VALUES (10, 'x')").unwrap()
        val ur2 = db2.exec_sql("UPDATE pk_upd2 SET val = 'y' WHERE id = 99")
        expect(ur2.is_ok()).to_equal(true)
        expect(ur2.unwrap()).to_equal(0)
        val qr3 = db2.query("SELECT * FROM pk_upd2 WHERE id = 10", [])
        expect(qr3.unwrap()[0].values[1].to_text()).to_equal("x")
    it "exec_sql DELETE uses PK fast path for literal WHERE":
        val r3 = PureDatabase.memory()
        var db3 = r3.unwrap()
        db3.exec_sql("CREATE TABLE pk_del (id INTEGER PRIMARY KEY, name TEXT)").unwrap()
        db3.exec_sql("INSERT INTO pk_del (id, name) VALUES (1, 'Alice')").unwrap()
        db3.exec_sql("INSERT INTO pk_del (id, name) VALUES (2, 'Bob')").unwrap()
        val dr = db3.exec_sql("DELETE FROM pk_del WHERE id = 1")
        expect(dr.is_ok()).to_equal(true)
        expect(dr.unwrap()).to_equal(1)
        val qr4 = db3.query("SELECT * FROM pk_del", [])
        val rows4 = qr4.unwrap()
        expect(rows4.len()).to_equal(1)
        expect(rows4[0].values[1].to_text()).to_equal("Bob")
    it "exec_sql DELETE PK fast path returns 0 for missing key":
        val r4 = PureDatabase.memory()
        var db4 = r4.unwrap()
        db4.exec_sql("CREATE TABLE pk_del2 (id INTEGER PRIMARY KEY, name TEXT)").unwrap()
        db4.exec_sql("INSERT INTO pk_del2 (id, name) VALUES (5, 'Eve')").unwrap()
        val dr2 = db4.exec_sql("DELETE FROM pk_del2 WHERE id = 99")
        expect(dr2.is_ok()).to_equal(true)
        expect(dr2.unwrap()).to_equal(0)
        val qr5 = db4.query("SELECT * FROM pk_del2", [])
        expect(qr5.unwrap().len()).to_equal(1)
