        db.exec_sql("CREATE TABLE empty (id INTEGER)").unwrap()
        val qr = db.query("SELECT * FROM empty", [])
        val rows = qr.unwrap()
        expect(rows.len()).to_equal(0)
        val cr = db.query("SELECT COUNT(*) FROM empty", [])
        val crows = cr.unwrap()
        val first = crows[0]
        val vals = first.values
        val count_val = vals[0]
        expect(count_val.to_text()).to_equal("0")
