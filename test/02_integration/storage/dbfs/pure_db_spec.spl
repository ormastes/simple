        val c1 = rows[1]
        val c1_vals = c1.values
        val c1_v = c1_vals[0]
        expect c1_v.to_text() == "two"
        val c2 = rows[2]
        val c2_vals = c2.values
        val c2_v = c2_vals[0]
        expect c2_v.to_text() == "other"
