        i2.unwrap()
        val i3 = db.exec_sql("INSERT INTO case_t (id, name) VALUES (3, 'Charlie')")
        i3.unwrap()
        val qr = db.query("SELECT CASE WHEN id = 1 THEN 'one' WHEN id = 2 THEN 'two' ELSE 'other' END FROM case_t ORDER BY id ASC", [])
        val rows = qr.unwrap()
        expect rows.len() == 3
        val c0 = rows[0]
        val c0_vals = c0.values
        val c0_v = c0_vals[0]
