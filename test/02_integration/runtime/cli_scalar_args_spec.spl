# @cover src/lib/nogc_sync_mut/io_runtime.spl 80%
# @tag: integration, runtime, cli, scalar_args

use std.spec.*
use std.io_runtime.{get_args, cli_arg_count, cli_arg_at}

describe "scalar CLI argument access":
    it "returns empty text for negative and out-of-bounds indices":
        val count = cli_arg_count()
        expect(count).to_be_greater_than(0)
        expect(cli_arg_at(-1)).to_equal("")
        expect(cli_arg_at(count)).to_equal("")
        expect(cli_arg_at(count + 100)).to_equal("")

    it "reads the focused test command suffix without constructing an argument array":
        val count = cli_arg_count()
        expect(count).to_be_greater_than(1)
        var found_spec = false
        var i = 0
        while i < count:
            val arg = cli_arg_at(i)
            if arg.contains("cli_scalar_args_spec.spl"):
                found_spec = true
            i = i + 1
        expect(found_spec).to_equal(true)

    it "reconstructs the public argument array from scalar entries":
        val count = cli_arg_count()
        val args = get_args()
        expect(args.len().to_i64()).to_equal(count)
        var i = 0
        while i < count:
            expect(args[i]).to_equal(cli_arg_at(i))
            i = i + 1
