    it "falls back to CPU when no Metal glyph payload is present":
        step("Rasterize a bitmap glyph with the Metal payload cleared")
        assert_bitmap_no_payload("METAL", 65)

    it "accepts a matching Metal glyph payload before CPU fallback":
        step("Publish a checksum-valid Metal glyph payload and rasterize it")
