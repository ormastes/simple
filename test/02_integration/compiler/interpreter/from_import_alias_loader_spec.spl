use compiler.core.ast.{ast_reset, module_decl_count_get}
use compiler.core.interpreter.eval_tables.{func_lookup_return_type, func_table_lookup, func_table_reset, struct_table_get_module, struct_table_lookup, struct_table_reset}
use compiler.core.interpreter.interp_resource_tracker.{irt_get_func_count, irt_get_struct_count}
use compiler.core.interpreter.module_loader_core.{interp_unload_module, load_module, load_module_register_only, load_module_selective, module_is_loaded, module_loader_init}

fn check_cached_module_aliases() -> text:
    ast_reset()
    func_table_reset()
    struct_table_reset()
    module_loader_init()

    val current_file = "test/fixtures/cross_module_struct/mod_b_main.spl"
    if load_module("mod_a", current_file) != 1:
        return "initial module load failed"

    val original_fn = func_table_lookup("make_foo")
    val original_struct = struct_table_lookup("Foo")
    val original_struct_module = struct_table_get_module("Foo")
    if original_fn < 0 or original_struct < 0:
        return "initial symbols were not registered"

    if load_module("mod_collision", current_file) != 1:
        return "collision module load failed"
    val collision_decl_count = module_decl_count_get()
    if func_table_lookup("make_foo") == original_fn:
        return "collision function did not replace the global table entry"
    if struct_table_lookup("Foo") == original_struct:
        return "collision struct did not replace the global table entry"

    if load_module_register_only("mod_a", ["make_foo:make_foo_alias"], current_file) != 1:
        return "cached function alias load failed"
    if module_decl_count_get() != collision_decl_count:
        return "cached function alias reparsed the module"
    if func_table_lookup("make_foo_alias") != original_fn:
        return "function alias did not reuse the original declaration"

    if load_module_selective("mod_a", ["Foo:FooAlias"], current_file) != 1:
        return "cached struct alias load failed"
    if module_decl_count_get() != collision_decl_count:
        return "cached struct alias reparsed the module"
    if struct_table_lookup("FooAlias") != original_struct:
        return "struct alias did not reuse the original declaration"
    if struct_table_get_module("FooAlias") != original_struct_module:
        return "struct alias did not preserve the original owner path"
    if load_module_register_only("mod_a", ["make_foo:make_foo_alias"], current_file) != 1:
        return "repeated cached alias load failed"
    if load_module_register_only("mod_a", ["make_foo:shared_alias"], current_file) != 1:
        return "initial shared alias load failed"
    if load_module_register_only("mod_collision", ["make_foo:shared_alias"], current_file) != 1:
        return "collision shared alias load failed"
    if load_module_register_only("mod_a", ["make_foo:shared_alias"], current_file) != 1:
        return "interleaved shared alias reload failed"
    if func_table_lookup("shared_alias") != original_fn:
        return "interleaved alias did not restore the requested owner"
    if irt_get_func_count("mod_a") != 3 or irt_get_struct_count("mod_a") != 2:
        return "repeated alias tracking was not idempotent"

    val collision_fn = func_table_lookup("make_foo")
    val collision_struct = struct_table_lookup("Foo")
    val collision_struct_module = struct_table_get_module("Foo")
    if interp_unload_module("mod_a") < 3:
        return "cached owner unload removed no aliases"
    if module_is_loaded("mod_a") != 0 or module_is_loaded("mod_collision") != 1:
        return "module load state was not isolated during unload"
    if func_table_lookup("make_foo") != collision_fn or struct_table_lookup("Foo") != collision_struct:
        return "unloading the cached owner removed the collision owner"
    if func_table_lookup("shared_alias") != collision_fn:
        return "unload did not restore the interleaved alias owner"

    if load_module("mod_a", current_file) != 1:
        return "cached owner reload failed"
    val reloaded_fn = func_table_lookup("make_foo")
    val reloaded_struct = struct_table_lookup("Foo")
    if reloaded_fn == collision_fn or reloaded_struct == collision_struct:
        return "reload did not replace collision bindings"
    if interp_unload_module("mod_a") < 2:
        return "reloaded owner unload removed no canonical bindings"
    if func_table_lookup("make_foo") != collision_fn or struct_table_lookup("Foo") != collision_struct:
        return "unload did not restore the surviving collision owner"
    if struct_table_get_module("Foo") != collision_struct_module:
        return "struct restoration changed the surviving owner path"

    if load_module_register_only("std.option", ["Some"], current_file) != 1:
        return "initial resolved-path module load failed"
    val option_decl_count = module_decl_count_get()
    val original_some = func_table_lookup("Some")
    if original_some < 0:
        return "initial resolved-path symbol was not registered"

    if load_module_register_only("lib.option", ["Some:SomeAlias"], current_file) != 1:
        return "resolved-path alias load failed"
    if module_decl_count_get() != option_decl_count:
        return "resolved-path alias reparsed the module"
    if func_table_lookup("SomeAlias") != original_some:
        return "resolved-path alias did not reuse the original declaration"
    interp_unload_module("std.option")
    if module_is_loaded("std.option") != 0 or module_is_loaded("lib.option") != 0:
        return "same-file aliases were not unloaded together"
    if func_table_lookup("Some") >= 0 or func_table_lookup("SomeAlias") >= 0:
        return "same-file alias bindings survived unload"

    ""

fn check_extern_metadata_ownership() -> text:
    ast_reset()
    func_table_reset()
    struct_table_reset()
    module_loader_init()

    val current_file = "test/fixtures/cross_module_struct/mod_b_main.spl"
    if load_module("mod_a", current_file) != 1:
        return "regular owner load failed"
    val regular_decl = func_table_lookup("make_foo")
    val regular_ret = func_lookup_return_type("make_foo")

    if load_module("mod_extern_collision", current_file) != 1:
        return "extern owner load failed"
    val extern_ret = func_lookup_return_type("make_foo")
    if extern_ret == regular_ret:
        return "extern collision did not replace return metadata"

    if load_module("mod_collision", current_file) != 1:
        return "second regular owner load failed"
    if interp_unload_module("mod_collision") < 2:
        return "second regular owner unload failed"
    if func_table_lookup("make_foo") != regular_decl:
        return "extern metadata prevented callable restoration"
    if func_lookup_return_type("make_foo") != extern_ret:
        return "extern return metadata was not restored"

    interp_unload_module("mod_extern_collision")
    if func_table_lookup("make_foo") != regular_decl:
        return "extern unload removed the regular callable"
    if func_lookup_return_type("make_foo") != regular_ret:
        return "extern unload did not restore regular return metadata"
    ""

describe "from-import alias module loading":
    it "binds aliases from a loaded module without reparsing it":
        expect(check_cached_module_aliases()).to_equal("")

    it "tracks extern return metadata independently from callable ownership":
        expect(check_extern_metadata_ownership()).to_equal("")
