"""Simple Web CSS Variable Spec

Focused coverage for CSS custom-property resolution in the pure-Simple HTML
layout renderer.

@tag: rendering, simple-web, css, perf
@cover src/lib/gc_async_mut/gpu/browser_engine/simple_web_html_layout_renderer.spl 10%
"""

use std.spec.{describe, it, expect, step}
use std.gc_async_mut.gpu.browser_engine.simple_web_html_layout_renderer.{
    simple_web_layout_debug_style_by_id
}

fn _css_var_fixture() -> text:
    "<html><head><style>" +
        ":root{--unused0:1px;--unused1:2px;--unused2:3px;--target-height:27px}" +
        ".target{height:var(--target-height)}" +
        "</style></head><body><div id=\"target\" class=\"target\">row</div></body></html>"

fn _multi_style_css_var_fixture() -> text:
    "<html><head>" +
        "<style>:root{--target-height:31px}</style>" +
        "<style>.target{height:var(--target-height)}</style>" +
        "</head><body><div id=\"target\" class=\"target\">row</div></body></html>"

describe "simple web css variables":
    it "resolves used CSS variables while skipping unused root variables":
        step("Build a CSS fixture with several unused root variables and one used height variable")
        val html = _css_var_fixture()
        step("Resolve the computed target height through the Simple Web style path")
        val height = simple_web_layout_debug_style_by_id(html, "target", "height")
        step("Assert the used variable still resolves after unused variables are skipped")
        expect(height).to_equal("27")

    it "resolves CSS variables collected across separate style blocks":
        step("Build a CSS fixture with root variables and use sites split across style tags")
        val html = _multi_style_css_var_fixture()
        step("Resolve the computed target height through the joined custom property path")
        val height = simple_web_layout_debug_style_by_id(html, "target", "height")
        step("Assert split style blocks still share collected custom properties")
        expect(height).to_equal("31")
