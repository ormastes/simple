"""
# Simple Web Iframe Embedding (Rendering-Inside-Rendering, Lane B)

## Overview

Covers the hidden/private `<iframe>` embedding capability in the production
Simple Web layout renderer (`simple_web_html_layout_renderer.spl`). An
`<iframe>` is a replaced element: its own DOM subtree (fallback content) is
never laid out or painted; instead its child document (from `srcdoc`) is
rendered through the SAME pipeline into an offscreen `[u32]` buffer and
blitted over the iframe's content box. Nesting is capped at
`WEB_IFRAME_DEPTH_CAP` (3) with an opaque grey placeholder beyond the cap, and
the `space` attribute controls whether the child inherits the parent
document's collected CSS rules (`shared`) or is styled only by its own
markup (`separate`, the default).

**Requirements:** N/A — hidden/private capability, not a standards-tracked
feature; verified here as implementation evidence for the
rendering-inside-rendering initiative.

**Design:** doc/04_architecture (rendering-inside-rendering arc, Lane B)

## Syntax

Pixel assertions are the rendering oracle: HTML is rendered via
`simple_web_layout_render_html_software_pixels` and specific pixel indices
(`x + y * width`) are sampled to confirm child-document content appears at
the iframe's computed box, parent content elsewhere is unaffected, fallback
content never paints, nested depth renders correctly, the depth cap
terminates with a placeholder, and the `space` attribute switches CSS scope.
"""

use std.spec.*
use std.gc_async_mut.gpu.browser_engine.simple_web_html_layout_renderer.{
    simple_web_layout_render_html_software_pixels}

fn _count_color(pixels: [u32], color: u32) -> i32:
    var count: i32 = 0
    var idx: i32 = 0
    while idx < pixels.len():
        if pixels[idx] == color:
            count = count + 1
        idx = idx + 1
    count

# Minimal HTML-attribute entity encoder used to build nested `srcdoc` values
# programmatically: each level of iframe nesting needs exactly one more
# round of encoding than its parent so the renderer's single decode pass per
# `srcdoc` extraction (see attr_value_by_key/decode_html_entities in
# simple_web_html_layout_renderer.spl) peels off exactly one layer at a time.
# `&` must be escaped FIRST so this function's own `&lt;`/`&gt;`/`&quot;`
# output never gets re-escaped by a later call.
fn _html_escape(s: text) -> text:
    var out = s.replace("&", "&amp;")
    out = out.replace("<", "&lt;")
    out = out.replace(">", "&gt;")
    out.replace("\"", "&quot;")

describe "Simple Web iframe embedding":

    it "renders an iframe srcdoc child at its content box and leaves the rest of the page unchanged":
        val html = "<html><body style='margin:0;padding:0;background-color:#ffffff'><div style='width:10px;height:10px;background-color:#ef4444'></div><iframe width='40' height='20' srcdoc=\"&lt;body style='margin:0;background-color:#22c55e'&gt;&lt;/body&gt;\"></iframe></body></html>"
        val pixels = simple_web_layout_render_html_software_pixels(html, 100, 60)
        expect(pixels.len()).to_equal(100 * 60)
        # marker div at (0,0)-(10,10), unaffected by the iframe
        expect(pixels[5 + 5 * 100]).to_equal(0xFFEF4444u32)
        # iframe box is (0,10)-(40,30): sampled point inside is the child's color
        expect(pixels[20 + 20 * 100]).to_equal(0xFF22C55Eu32)
        # far outside both the marker and the iframe box: untouched page background
        expect(pixels[80 + 50 * 100]).to_equal(0xFFFFFFFFu32)

    it "never paints iframe fallback content, inline or otherwise":
        val html = "<html><body style='margin:0;padding:0;background-color:#ffffff'><iframe width='30' height='15' style='display:block'><div style='width:10px;height:10px;background-color:#7c3aed'></div>Fallback</iframe></body></html>"
        val pixels = simple_web_layout_render_html_software_pixels(html, 60, 40)
        expect(pixels.len()).to_equal(60 * 40)
        expect(_count_color(pixels, 0xFF7C3AEDu32)).to_equal(0)
        # no srcdoc -> empty child document -> blitted child canvas is the
        # renderer's own default background, not garbage
        expect(pixels[5 + 5 * 60]).to_equal(0xFFFFFFFFu32)

    it "renders a nested iframe two levels deep":
        # Depth 0 (top) embeds iframe1 (renders at depth 1), which embeds
        # iframe2 (renders at depth 2) whose body is solid amber. Each level
        # fully fills its parent's content box, so a top-level sample proves
        # the SECOND level of recursion actually ran.
        val level2_doc = "<body style='margin:0;background-color:#f59e0b'></body>"
        val iframe2_tag = "<iframe width='40' height='30' style='display:block' srcdoc=\"" + _html_escape(level2_doc) + "\"></iframe>"
        val level1_doc = "<body style='margin:0'>" + iframe2_tag + "</body>"
        val iframe1_tag = "<iframe width='40' height='30' style='display:block' srcdoc=\"" + _html_escape(level1_doc) + "\"></iframe>"
        val html = "<html><body style='margin:0;padding:0'>" + iframe1_tag + "</body></html>"
        val pixels = simple_web_layout_render_html_software_pixels(html, 40, 30)
        expect(pixels.len()).to_equal(40 * 30)
        expect(pixels[5 + 5 * 40]).to_equal(0xFFF59E0Bu32)
        expect(_count_color(pixels, 0xFFF59E0Bu32)).to_equal(40 * 30)

    it "hits the embedding depth cap at level 4 and paints the placeholder instead of recursing further":
        # top=depth0 -> iframe1=depth1 -> iframe2=depth2 -> iframe3=depth3 all
        # render; iframe3's own child (iframe4) would be depth 4, which
        # exceeds WEB_IFRAME_DEPTH_CAP(3), so it is replaced by the flat grey
        # placeholder and its (blue) content is never reached or rendered.
        val level4_doc = "<body style='margin:0;background-color:#3b82f6'></body>"
        val iframe4_tag = "<iframe width='40' height='30' style='display:block' srcdoc=\"" + _html_escape(level4_doc) + "\"></iframe>"
        val level3_doc = "<body style='margin:0'>" + iframe4_tag + "</body>"
        val iframe3_tag = "<iframe width='40' height='30' style='display:block' srcdoc=\"" + _html_escape(level3_doc) + "\"></iframe>"
        val level2_doc = "<body style='margin:0'>" + iframe3_tag + "</body>"
        val iframe2_tag = "<iframe width='40' height='30' style='display:block' srcdoc=\"" + _html_escape(level2_doc) + "\"></iframe>"
        val level1_doc = "<body style='margin:0'>" + iframe2_tag + "</body>"
        val iframe1_tag = "<iframe width='40' height='30' style='display:block' srcdoc=\"" + _html_escape(level1_doc) + "\"></iframe>"
        val html = "<html><body style='margin:0;padding:0'>" + iframe1_tag + "</body></html>"
        val pixels = simple_web_layout_render_html_software_pixels(html, 40, 30)
        expect(pixels.len()).to_equal(40 * 30)
        expect(pixels[5 + 5 * 40]).to_equal(0xFF888888u32)
        expect(_count_color(pixels, 0xFF3B82F6u32)).to_equal(0)

    it "keeps space=separate isolated from the parent's CSS while space=shared inherits it":
        # NOTE: the CSS rule below uses a trailing `;` before the closing `}`
        # (`background-color:#ef4444;`) to dodge a known interpreter footgun:
        # a brace span shaped like `{ident:#hex}` (no space, no trailing `;`)
        # inside a plain double-quoted literal is misparsed as string
        # interpolation and throws `semantic: variable 'ident' not found` at
        # run time — see doc/08_tracking/bug/string_interpolation_css_brace_footgun_2026-07-03.md.
        val separate_html = "<html><head><style>.marked{background-color:#ef4444;}</style></head><body style='margin:0;padding:0'><iframe width='40' height='24' style='display:block' srcdoc=\"&lt;body style='margin:0'&gt;&lt;div class='marked' style='width:40px;height:24px'&gt;&lt;/div&gt;&lt;/body&gt;\"></iframe></body></html>"
        val shared_html = "<html><head><style>.marked{background-color:#ef4444;}</style></head><body style='margin:0;padding:0'><iframe width='40' height='24' style='display:block' space='shared' srcdoc=\"&lt;body style='margin:0'&gt;&lt;div class='marked' style='width:40px;height:24px'&gt;&lt;/div&gt;&lt;/body&gt;\"></iframe></body></html>"
        val separate_pixels = simple_web_layout_render_html_software_pixels(separate_html, 40, 24)
        val shared_pixels = simple_web_layout_render_html_software_pixels(shared_html, 40, 24)
        expect(_count_color(separate_pixels, 0xFFEF4444u32)).to_equal(0)
        expect(_count_color(shared_pixels, 0xFFEF4444u32)).to_equal(40 * 24)

    it "sizes the iframe replaced-element box from width and height HTML attributes":
        val html = "<html><body style='margin:0;padding:0;background-color:#ffffff'><iframe width='25' height='15' style='display:block' srcdoc=\"&lt;body style='margin:0;background-color:#22c55e'&gt;&lt;/body&gt;\"></iframe></body></html>"
        val pixels = simple_web_layout_render_html_software_pixels(html, 40, 24)
        expect(pixels.len()).to_equal(40 * 24)
        # inside the 25x15 box
        expect(pixels[24 + 14 * 40]).to_equal(0xFF22C55Eu32)
        # just past the right edge (x=25) and bottom edge (y=15): background, not child color
        expect(pixels[26 + 14 * 40]).to_equal(0xFFFFFFFFu32)
        expect(pixels[24 + 16 * 40]).to_equal(0xFFFFFFFFu32)
        expect(_count_color(pixels, 0xFF22C55Eu32)).to_equal(25 * 15)
