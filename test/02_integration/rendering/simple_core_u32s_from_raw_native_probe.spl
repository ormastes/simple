# Native ABI probe for simple-core-owned GPU readback array construction.

extern fn malloc(size: i64) -> i64
extern fn free(ptr: i64)
extern fn spl_store_u8(ptr: i64, offset: i64, value: i64)
extern fn rt_u32s_from_raw(data_ptr: i64, count: i64) -> [u32]

fn store_u32_le(ptr: i64, offset: i64, value: u32):
    val word = value.to_i64()
    spl_store_u8(ptr, offset, word & 255)
    spl_store_u8(ptr, offset + 1, (word >> 8) & 255)
    spl_store_u8(ptr, offset + 2, (word >> 16) & 255)
    spl_store_u8(ptr, offset + 3, (word >> 24) & 255)

fn main() -> i64:
    val raw = malloc(12)
    if raw <= 0:
        return 1
    store_u32_le(raw, 0, 0x00000000u32)
    store_u32_le(raw, 4, 0x7fffffffu32)
    store_u32_le(raw, 8, 0xffffffffu32)
    val values = rt_u32s_from_raw(raw, 3)
    free(raw)
    if values.len() != 3:
        return 2
    if values[0] != 0x00000000u32:
        return 3
    if values[1] != 0x7fffffffu32:
        return 4
    if values[2] != 0xffffffffu32:
        return 5
    print("simple-core-u32-readback: pass")
    0
