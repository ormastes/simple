"""Engine2D Shared-Raster Parity Harness — emu vs software per-op oracle.

This is the bit-exact parity gate that must pass before the Draw-IR backend
unification (design D2, doc/05_design/ui/rendering/draw_ir_multibackend_design.md).

For every core op it renders the operation two ways over the SAME core surface
(a fresh 48x48 SoftwareBackend cleared to opaque black) and compares the two
[u32] framebuffers pixel-for-pixel:

  * SOFTWARE path  — SoftwareBackend's own hand-written method (e.g. draw_circle).
  * EMU path       — the stateless emu_draw_* free function, which composes the
                     same op out of core.draw_rect_filled / draw_image on a
                     fresh SoftwareBackend core.

emu_draw_* is the reference algorithm (each free function takes `core:
RenderBackend` and builds ops from core primitives). backend_software re-writes
~9 of these core ops independently and is NOT proven equal to emu — this harness
is the permanent oracle that pins which ops are byte-identical and which diverge.

Three op families:
  A. Core primitives (clear / draw_rect_filled / draw_image) — emu builds ON
     these; there is no independent emu reimplementation, so parity is identity
     by construction.
  B. Emu-delegating ops (draw_gradient_rect_h / draw_rect_blend /
     draw_image_blend) — the SoftwareBackend method body literally calls the emu
     free function, so parity is exact.
  C. Independently hand-written ops — the real parity question. Some are
     byte-exact (opaque rect outline, thin line, opaque gradient); several
     DIVERGE and block unification until a single canonical algorithm is chosen.

Alpha anchor: src-over 0x01020304 over 0x10203040 == 0x101F2F3F, verified
directly through both blend ops (both route through _emu_blend_over at
src/lib/gc_async_mut/gpu/engine2d/backend_emu_math.spl:33).

@tag: gpu, engine2d, rendering, parity, draw-ir
@cover src/lib/gc_async_mut/gpu/engine2d/backend_software.spl 55%
@cover src/lib/gc_async_mut/gpu/engine2d/backend_emu.spl 40%
@cover src/lib/gc_async_mut/gpu/engine2d/backend_emu_adv.spl 10%
@cover src/lib/gc_async_mut/gpu/engine2d/backend_emu_math.spl 30%
"""

# @req D2 Draw-IR multi-backend unification — per-op bit-exact parity gate
#      (doc/05_design/ui/rendering/draw_ir_multibackend_design.md)

use std.spec.{describe, context, it, expect}
use std.gc_async_mut.gpu.engine2d.backend_software.{SoftwareBackend}
use std.gc_async_mut.gpu.engine2d.backend_emu.{
    emu_draw_rect, emu_draw_line, emu_draw_circle, emu_draw_circle_filled,
    emu_draw_rounded_rect, emu_draw_triangle_filled, emu_draw_gradient_rect,
    emu_draw_gradient_rect_h, emu_draw_rect_blend, emu_draw_image_blend,
    emu_draw_text, emu_draw_text_bg
}

# ============================================================================
# Fixtures — kept as functions (no module globals) so spec blocks never read
# stale interpreter state.
# ============================================================================

fn _bg() -> u32:
    0xFF000000u32

fn _fresh() -> SoftwareBackend:
    var b = SoftwareBackend.create()
    b.init(48, 48)
    b.clear(_bg())
    b

fn _fresh_fill(c: u32) -> SoftwareBackend:
    var b = SoftwareBackend.create()
    b.init(48, 48)
    b.clear(c)
    b

fn _mism(a: [u32], b: [u32]) -> i32:
    var n = 0
    var i = 0
    while i < a.len():
        if a[i] != b[i]:
            n = n + 1
        i = i + 1
    n

fn _img(w: i32, h: i32, c: u32) -> [u32]:
    var px: [u32] = [0u32; w * h]
    var i = 0
    while i < w * h:
        px[i] = c
        i = i + 1
    px

# ============================================================================
# Family A — core primitives (shared surface; identity by construction)
# ============================================================================

fn cmp_clear() -> i32:
    var a = _fresh()
    a.clear(0xFFFF0000u32)
    var b = _fresh()
    b.clear(0xFFFF0000u32)
    _mism(a.read_pixels(), b.read_pixels())

fn cmp_rect_filled_core() -> i32:
    var a = _fresh()
    a.draw_rect_filled(6, 6, 20, 15, 0xFFFF0000u32)
    var b = _fresh()
    b.draw_rect_filled(6, 6, 20, 15, 0xFFFF0000u32)
    _mism(a.read_pixels(), b.read_pixels())

fn cmp_image_core() -> i32:
    val img = _img(16, 16, 0xFF00FFFFu32)
    var a = _fresh()
    a.draw_image(8, 8, 16, 16, img)
    var b = _fresh()
    b.draw_image(8, 8, 16, 16, img)
    _mism(a.read_pixels(), b.read_pixels())

# ============================================================================
# Family B — emu-delegating ops (SoftwareBackend method forwards to emu free fn)
# ============================================================================

fn cmp_gradient_rect_h() -> i32:
    var a = _fresh()
    a.draw_gradient_rect_h(4, 4, 30, 30, 0xFFFF0000u32, 0xFF0000FFu32)
    var b = _fresh()
    emu_draw_gradient_rect_h(b, 4, 4, 30, 30, 0xFFFF0000u32, 0xFF0000FFu32)
    _mism(a.read_pixels(), b.read_pixels())

fn cmp_rect_blend() -> i32:
    var a = _fresh_fill(0x10203040u32)
    a.draw_rect_blend(4, 4, 30, 30, 0x01020304u32)
    var b = _fresh_fill(0x10203040u32)
    emu_draw_rect_blend(b, 4, 4, 30, 30, 0x01020304u32)
    _mism(a.read_pixels(), b.read_pixels())

fn anchor_rect_blend() -> u32:
    var a = _fresh_fill(0x10203040u32)
    a.draw_rect_blend(4, 4, 30, 30, 0x01020304u32)
    val p = a.read_pixels()
    p[24 * 48 + 20]

fn cmp_image_blend() -> i32:
    val img = _img(16, 16, 0x01020304u32)
    var a = _fresh_fill(0x10203040u32)
    a.draw_image_blend(8, 8, 16, 16, img)
    var b = _fresh_fill(0x10203040u32)
    emu_draw_image_blend(b, 8, 8, 16, 16, img)
    _mism(a.read_pixels(), b.read_pixels())

fn anchor_image_blend() -> u32:
    val img = _img(16, 16, 0x01020304u32)
    var a = _fresh_fill(0x10203040u32)
    a.draw_image_blend(8, 8, 16, 16, img)
    val p = a.read_pixels()
    p[16 * 48 + 16]

# ============================================================================
# Family C — independently hand-written ops
# ============================================================================

fn cmp_rect_opaque() -> i32:
    var a = _fresh()
    a.draw_rect(6, 6, 30, 20, 0xFFFF0000u32)
    var b = _fresh()
    emu_draw_rect(b, 6, 6, 30, 20, 0xFFFF0000u32)
    _mism(a.read_pixels(), b.read_pixels())

fn cmp_rect_alpha() -> i32:
    var a = _fresh_fill(0xFF203040u32)
    a.draw_rect(6, 6, 30, 20, 0x80FF0000u32)
    var b = _fresh_fill(0xFF203040u32)
    emu_draw_rect(b, 6, 6, 30, 20, 0x80FF0000u32)
    _mism(a.read_pixels(), b.read_pixels())

fn cmp_line_thin() -> i32:
    var a = _fresh()
    a.draw_line(3, 4, 40, 30, 0xFF00FF00u32, 1)
    var b = _fresh()
    emu_draw_line(b, 3, 4, 40, 30, 0xFF00FF00u32, 1)
    _mism(a.read_pixels(), b.read_pixels())

fn cmp_line_thick() -> i32:
    var a = _fresh()
    a.draw_line(3, 4, 40, 30, 0xFF00FF00u32, 3)
    var b = _fresh()
    emu_draw_line(b, 3, 4, 40, 30, 0xFF00FF00u32, 3)
    _mism(a.read_pixels(), b.read_pixels())

fn cmp_circle() -> i32:
    # r=9 lands on a midpoint decision-variable tie where sw's `d <= 0` and
    # emu's textbook `d < 0` diverge.
    var a = _fresh()
    a.draw_circle(24, 24, 9, 0xFFFF0000u32)
    var b = _fresh()
    emu_draw_circle(b, 24, 24, 9, 0xFFFF0000u32)
    _mism(a.read_pixels(), b.read_pixels())

fn cmp_circle_r0() -> i32:
    var a = _fresh()
    a.draw_circle(24, 24, 0, 0xFFFF0000u32)
    var b = _fresh()
    emu_draw_circle(b, 24, 24, 0, 0xFFFF0000u32)
    _mism(a.read_pixels(), b.read_pixels())

fn cmp_circle_filled() -> i32:
    var a = _fresh()
    a.draw_circle_filled(24, 24, 15, 0xFF00FF00u32)
    var b = _fresh()
    emu_draw_circle_filled(b, 24, 24, 15, 0xFF00FF00u32)
    _mism(a.read_pixels(), b.read_pixels())

fn cmp_circle_filled_r0() -> i32:
    var a = _fresh()
    a.draw_circle_filled(24, 24, 0, 0xFF00FF00u32)
    var b = _fresh()
    emu_draw_circle_filled(b, 24, 24, 0, 0xFF00FF00u32)
    _mism(a.read_pixels(), b.read_pixels())

fn cmp_rounded_rect() -> i32:
    var a = _fresh()
    a.draw_rounded_rect(6, 6, 30, 24, 6, 0xFFFF0000u32)
    var b = _fresh()
    emu_draw_rounded_rect(b, 6, 6, 30, 24, 6, 0xFFFF0000u32)
    _mism(a.read_pixels(), b.read_pixels())

fn cmp_triangle() -> i32:
    var a = _fresh()
    a.draw_triangle_filled(24, 5, 5, 40, 42, 38, 0xFF00FF00u32)
    var b = _fresh()
    emu_draw_triangle_filled(b, 24, 5, 5, 40, 42, 38, 0xFF00FF00u32)
    _mism(a.read_pixels(), b.read_pixels())

fn cmp_triangle_degen() -> i32:
    # Collinear vertices: barycentric determinant d == 0.
    var a = _fresh()
    a.draw_triangle_filled(5, 5, 10, 10, 20, 20, 0xFF00FF00u32)
    var b = _fresh()
    emu_draw_triangle_filled(b, 5, 5, 10, 10, 20, 20, 0xFF00FF00u32)
    _mism(a.read_pixels(), b.read_pixels())

fn cmp_gradient_rect_opaque() -> i32:
    var a = _fresh()
    a.draw_gradient_rect(4, 4, 30, 30, 0xFFFF0000u32, 0xFF0000FFu32)
    var b = _fresh()
    emu_draw_gradient_rect(b, 4, 4, 30, 30, 0xFFFF0000u32, 0xFF0000FFu32)
    _mism(a.read_pixels(), b.read_pixels())

fn cmp_text() -> i32:
    var a = _fresh()
    a.draw_text(4, 8, "Hi", 0xFFFFFFFFu32, 8)
    var b = _fresh()
    emu_draw_text(b, 4, 8, "Hi", 0xFFFFFFFFu32, 8)
    _mism(a.read_pixels(), b.read_pixels())

fn cmp_text_bg() -> i32:
    var a = _fresh()
    a.draw_text_bg(4, 8, "Hi", 0xFFFFFFFFu32, 0xFF202020u32, 8)
    var b = _fresh()
    emu_draw_text_bg(b, 4, 8, "Hi", 0xFFFFFFFFu32, 0xFF202020u32, 8)
    _mism(a.read_pixels(), b.read_pixels())

# ============================================================================
# Specification
# ============================================================================

describe "Engine2D shared-raster parity (emu vs software) — D2 unification gate":

    context "Family A — core primitives are byte-identical (shared surface)":

        it "clear paints an identical surface on both backends":
            expect(cmp_clear()).to_equal(0)

        it "draw_rect_filled — the primitive emu itself composes from — is identical":
            expect(cmp_rect_filled_core()).to_equal(0)

        it "draw_image blits an identical surface":
            expect(cmp_image_core()).to_equal(0)

    context "Family B — emu-delegating ops stay byte-exact":

        it "draw_gradient_rect_h matches its emu delegate":
            expect(cmp_gradient_rect_h()).to_equal(0)

        it "draw_rect_blend matches emu and hits the src-over anchor 0x101F2F3F":
            expect(cmp_rect_blend()).to_equal(0)
            expect(anchor_rect_blend()).to_equal(0x101F2F3Fu32)

        it "draw_image_blend matches emu and hits the src-over anchor 0x101F2F3F":
            expect(cmp_image_blend()).to_equal(0)
            expect(anchor_image_blend()).to_equal(0x101F2F3Fu32)

    context "Family C — independently written ops that ARE byte-exact":

        it "draw_rect (opaque outline) is byte-identical to emu":
            expect(cmp_rect_opaque()).to_equal(0)

        it "draw_line (thickness 1, Bresenham) is byte-identical to emu":
            expect(cmp_line_thin()).to_equal(0)

        it "draw_gradient_rect (opaque, integer lerp) is byte-identical to emu":
            expect(cmp_gradient_rect_opaque()).to_equal(0)

        it "draw_rounded_rect is byte-identical to emu — sw now FILLS (was a 1px OUTLINE bug) [de-faked; canonical: emu]":
            expect(cmp_rounded_rect()).to_equal(0)

        it "draw_text is byte-identical to emu — emu delegates to the real 5x7 glyph blit (was a placeholder box) [de-faked; canonical: sw]":
            expect(cmp_text()).to_equal(0)

        it "draw_text_bg is byte-identical to emu — emu delegates to the real AA blit (was bg-fill + placeholder box) [de-faked; canonical: sw]":
            expect(cmp_text_bg()).to_equal(0)

    context "Family C — DIVERGENT ops (unification blocked until unified)":
        # Each `expect(... > 0)` pins a KNOWN divergence. If a future change
        # unifies the op, its mismatch drops to 0 and this flips RED — the
        # signal to move the op into the byte-exact set above and pick the
        # single canonical algorithm named in each block.

        it "draw_rect (alpha outline) diverges — emu blends the edge, sw writes raw [canonical: emu]":
            expect(cmp_rect_alpha() > 0).to_equal(true)

        it "draw_line (thick) diverges — sw parallel-offset lines vs emu per-point txt square [canonical: design review]":
            expect(cmp_line_thick() > 0).to_equal(true)

        it "draw_circle (outline) diverges at midpoint-tie radii — sw `d<=0` vs emu textbook `d<0` [canonical: emu body]":
            expect(cmp_circle() > 0).to_equal(true)

        it "draw_circle (r<=0) diverges — emu stamps a stray center pixel, sw no-ops [canonical: sw guard]":
            expect(cmp_circle_r0() > 0).to_equal(true)

        it "draw_circle_filled diverges — sw exact distance-test disk (Metal-exact) vs emu midpoint scanline [canonical: sw]":
            expect(cmp_circle_filled() > 0).to_equal(true)

        it "draw_circle_filled (r<=0) diverges — emu stamps a stray center pixel, sw no-ops [canonical: sw]":
            expect(cmp_circle_filled_r0() > 0).to_equal(true)

        it "draw_triangle_filled diverges by a boundary pixel — sw barycentric (Metal-exact) vs emu scanline [canonical: sw]":
            expect(cmp_triangle() > 0).to_equal(true)

        it "draw_triangle_filled (collinear, d==0) diverges — sw no-ops, emu fills a line [canonical: sw]":
            expect(cmp_triangle_degen() > 0).to_equal(true)

    context "equality matrix":

        it "prints the full per-op equality matrix":
            print("=== ENGINE2D SHARED-RASTER PARITY MATRIX (emu vs software) ===")
            print("clear                | EQUAL   | mism={cmp_clear()}      | core primitive (shared)")
            print("draw_rect_filled     | EQUAL   | mism={cmp_rect_filled_core()}      | core primitive (shared)")
            print("draw_image           | EQUAL   | mism={cmp_image_core()}      | core primitive (shared)")
            print("draw_gradient_rect_h | EQUAL   | mism={cmp_gradient_rect_h()}      | delegates to emu")
            print("draw_rect_blend      | EQUAL   | mism={cmp_rect_blend()}      | delegates to emu; anchor={anchor_rect_blend()}")
            print("draw_image_blend     | EQUAL   | mism={cmp_image_blend()}      | delegates to emu; anchor={anchor_image_blend()}")
            print("draw_rect (opaque)   | EQUAL   | mism={cmp_rect_opaque()}      | independent, byte-exact")
            print("draw_line (thin)     | EQUAL   | mism={cmp_line_thin()}      | independent, byte-exact")
            print("draw_gradient_rect   | EQUAL   | mism={cmp_gradient_rect_opaque()}      | independent, byte-exact (opaque)")
            print("draw_rect (alpha)    | DIVERGE | mism={cmp_rect_alpha()}   | canonical=emu (blend edge)")
            print("draw_line (thick)    | DIVERGE | mism={cmp_line_thick()}   | canonical=design review")
            print("draw_circle          | DIVERGE | mism={cmp_circle()}   | canonical=emu body + sw r<=0 guard")
            print("draw_circle r<=0     | DIVERGE | mism={cmp_circle_r0()}   | canonical=sw (no-op)")
            print("draw_circle_filled   | DIVERGE | mism={cmp_circle_filled()}   | canonical=sw (distance-test, Metal-exact)")
            print("draw_circle_filled r0| DIVERGE | mism={cmp_circle_filled_r0()}   | canonical=sw (no-op)")
            print("draw_rounded_rect    | EQUAL   | mism={cmp_rounded_rect()} | de-faked: sw now FILLS (canonical=emu)")
            print("draw_triangle_filled | DIVERGE | mism={cmp_triangle()}   | canonical=sw (barycentric, Metal-exact)")
            print("draw_triangle degen  | DIVERGE | mism={cmp_triangle_degen()}  | canonical=sw (no-op)")
            print("draw_text            | EQUAL   | mism={cmp_text()}   | de-faked: emu delegates to real glyphs (canonical=sw)")
            print("draw_text_bg         | EQUAL   | mism={cmp_text_bg()}   | de-faked: emu delegates to AA blit (canonical=sw)")
            print("=== END MATRIX ===")
            expect(true).to_equal(true)
