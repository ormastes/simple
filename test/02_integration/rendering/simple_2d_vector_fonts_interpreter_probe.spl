# Direct interpreter probe for the public Simple 2D vector-font path.
# @req REQ-009

use std.gc_async_mut.gpu.engine2d.engine.{Engine2D}
use std.gc_async_mut.gpu.engine2d.color.{rgb}
use std.nogc_sync_mut.io_runtime.{exit}
use std.nogc_sync_mut.sffi.io.{dir_create_all, file_write_bytes}
use test.fixtures.fonts.simple_2d_vector.font_fixture.{simple_2d_ascii_font_bytes}

val DIR = "build/test-artifacts/02_integration/rendering/simple_2d_vector_fonts"
val FONT = "build/test-artifacts/02_integration/rendering/simple_2d_vector_fonts/simple_ascii.ttf"

fn require(condition: bool, message: text):
    if not condition:
        print "FAIL: {message}"
        exit(1)

dir_create_all(DIR)
require(file_write_bytes(FONT, simple_2d_ascii_font_bytes()), "fixture write")

var engine = Engine2D.create_with_backend(64, 48, "cpu")
require(engine.load_font(FONT), "public font load")
engine.clear(rgb(3, 7, 11))
engine.draw_text(4, 4, "A A", rgb(240, 220, 180), 24)
val pixels = engine.read_pixels()
var painted = 0
for pixel in pixels:
    if pixel != rgb(3, 7, 11):
        painted = painted + 1
val stats = engine.font_cache_stats()
require(painted > 0, "vector pixels")
require(stats.entries > 0, "glyph cache")
engine.unload_font()
engine.shutdown()
print "PASS: Simple 2D vector-font interpreter probe"
exit(0)
