fn build_cpu_polyline_reference(w: i32, h: i32, bg: u32, fg: u32, xs: [i32], ys: [i32], count: i32) -> [u32]:
    var buf = [bg; w * h]
    if count < 2:
        return buf
    var i = 0
    while i < count - 1:
        draw_line_into(buf, w, h, fg, xs[i], ys[i], xs[i + 1], ys[i + 1])
        i = i + 1
    buf

