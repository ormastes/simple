"""Vulkan Strict Smoke Tests

@tag: rendering, engine2d, vulkan, strict, hardware
@cover src/lib/gc_async_mut/gpu/engine2d/backend_vulkan.spl 70%
@cover src/lib/gc_async_mut/gpu/engine2d/backend_vulkan_spirv.spl 80%
@cover src/lib/gc_async_mut/gpu/engine2d/engine.spl 20%

Strictly gates real hardware execution when Vulkan initializes: shader module
load, compute pipeline creation, kernel dispatch, device sync, and pixel
readback must all work before parity assertions run. Surfaces device
diagnostics via BackendProbeResult.

On non-Vulkan hosts, asserts the BackendProbeResult carries a typed
Failed status rather than silently succeeding.
On Vulkan hosts where initialization succeeds, runs the clear, filled-rect,
rect-outline, line, circle, rounded-rect, triangle, gradient, and image-blit
draw/readback pipeline against CPU or software references for a 16x16
framebuffer. It is still not proof of parity for advanced/emulated families
such as text, ellipse, polygon, blur, or shadow.
"""

use std.spec.*
use std.gc_async_mut.gpu.engine2d.engine.{Engine2D}
use std.gc_async_mut.gpu.engine2d.color.{rgb}
use std.gc_async_mut.gpu.engine2d.backend_probe.{BackendProbeResult, BackendStatus}

# ============================================================================
# Helpers
# ============================================================================

fn status_is_terminal_failure(probe: BackendProbeResult) -> bool:
    """True when the probe status is Failed or Unavailable (not Initialized)."""
    probe.status == BackendStatus.Failed or probe.status == BackendStatus.Unavailable

fn color_blue_u32() -> u32:
    """ARGB packed blue: 0xFF0000FF"""
    0xFF0000FFu32

fn color_red_u32() -> u32:
    """ARGB packed red: 0xFFFF0000"""
    0xFFFF0000u32

fn build_cpu_reference(w: i32, h: i32, bg: u32, fg: u32, rx: i32, ry: i32, rw: i32, rh: i32) -> [u32]:
    """Build a CPU reference framebuffer for parity comparison."""
    var buf = [bg; w * h]
    var py = ry
    while py < ry + rh:
        var px = rx
        while px < rx + rw:
            if px >= 0 and px < w and py >= 0 and py < h:
                buf[py * w + px] = fg
            px = px + 1
        py = py + 1
    buf

fn build_cpu_rect_outline_reference(w: i32, h: i32, bg: u32, fg: u32, rx: i32, ry: i32, rw: i32, rh: i32) -> [u32]:
    """Build a CPU framebuffer for a 1px rectangle outline."""
    var buf = [bg; w * h]
    var py = ry
    while py < ry + rh:
        var px = rx
        while px < rx + rw:
            if px >= 0 and px < w and py >= 0 and py < h:
                val on_border = px == rx or px == rx + rw - 1 or py == ry or py == ry + rh - 1
                if on_border:
                    buf[py * w + px] = fg
            px = px + 1
        py = py + 1
    buf

fn _abs_i32(v: i32) -> i32:
    if v < 0:
        return -v
    v

fn build_cpu_line_reference(w: i32, h: i32, bg: u32, fg: u32, x0_in: i32, y0_in: i32, x1: i32, y1: i32) -> [u32]:
    """Build a CPU framebuffer for a 1px Bresenham line."""
    var buf = [bg; w * h]
    draw_line_into(buf, w, h, fg, x0_in, y0_in, x1, y1)
    buf

fn draw_line_into(mut buf: [u32], w: i32, h: i32, fg: u32, x0_in: i32, y0_in: i32, x1: i32, y1: i32):
    """Overlay a 1px Bresenham line into an existing framebuffer."""
    var x0 = x0_in
    var y0 = y0_in
    val dx = _abs_i32(x1 - x0)
    val sx = if x0 < x1: 1 else: -1
    val dy = -_abs_i32(y1 - y0)
    val sy = if y0 < y1: 1 else: -1
    var err = dx + dy
    while true:
        if x0 >= 0 and x0 < w and y0 >= 0 and y0 < h:
            buf[y0 * w + x0] = fg
        if x0 == x1 and y0 == y1:
            break
        val e2 = 2 * err
        if e2 >= dy:
            err = err + dy
            x0 = x0 + sx
        if e2 <= dx:
            err = err + dx
            y0 = y0 + sy

fn count_pixel_mismatches(a: [u32], b: [u32]) -> i32:
    if a.len() != b.len():
        return -1
    var mismatches = 0
    var i = 0
    while i < a.len():
        if a[i] != b[i]:
            mismatches = mismatches + 1
        i = i + 1
    mismatches

fn build_cpu_circle_outline_reference(w: i32, h: i32, bg: u32, fg: u32, cx: i32, cy: i32, r: i32) -> [u32]:
    var buf = [bg; w * h]
    val r_sq = r * r
    val r_inner = (r - 1) * (r - 1)
    var py = 0
    while py < h:
        var px = 0
        while px < w:
            val dx = px - cx
            val dy = py - cy
            val dist_sq = dx * dx + dy * dy
            if dist_sq <= r_sq and dist_sq >= r_inner:
                buf[py * w + px] = fg
            px = px + 1
        py = py + 1
    buf

fn render_software_circle_reference(bg: u32, fg: u32, cx: i32, cy: i32, r: i32) -> [u32]:
    var engine = Engine2D.create_with_backend(16, 16, "software")
    engine.clear(bg)
    engine.draw_circle_filled(cx, cy, r, fg)
    engine.present()
    val pixels = engine.read_pixels()
    engine.shutdown()
    pixels

fn build_cpu_rounded_rect_reference(wb: i32, hb: i32, bg: u32, fg: u32, x: i32, y: i32, w: i32, h: i32, radius: i32) -> [u32]:
    var buf = [bg; wb * hb]
    var py = 0
    while py < hb:
        var px = 0
        while px < wb:
            if px >= x and px < x + w and py >= y and py < y + h:
                val lx = px - x
                val ly = py - y
                var inside = true
                val r_sq = radius * radius
                if lx < radius and ly < radius:
                    val dx = radius - lx - 1
                    val dy = radius - ly - 1
                    if dx * dx + dy * dy > r_sq:
                        inside = false
                if lx >= w - radius and ly < radius:
                    val dx = lx - (w - radius)
                    val dy = radius - ly - 1
                    if dx * dx + dy * dy > r_sq:
                        inside = false
                if lx < radius and ly >= h - radius:
                    val dx = radius - lx - 1
                    val dy = ly - (h - radius)
                    if dx * dx + dy * dy > r_sq:
                        inside = false
                if lx >= w - radius and ly >= h - radius:
                    val dx = lx - (w - radius)
                    val dy = ly - (h - radius)
                    if dx * dx + dy * dy > r_sq:
                        inside = false
                if inside:
                    buf[py * wb + px] = fg
            px = px + 1
        py = py + 1
    buf

fn render_software_triangle_reference(bg: u32, fg: u32, x1: i32, y1: i32, x2: i32, y2: i32, x3: i32, y3: i32) -> [u32]:
