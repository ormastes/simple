fn render_software_clip_rect_reference(bg: u32, fg: u32, clip_x: i32, clip_y: i32, clip_w: i32, clip_h: i32, rect_x: i32, rect_y: i32, rect_w: i32, rect_h: i32) -> [u32]:
    var engine = Engine2D.create_with_backend(24, 24, "software")
    engine.clear(bg)
    engine.set_clip(clip_x, clip_y, clip_w, clip_h)
    engine.draw_rect_filled(rect_x, rect_y, rect_w, rect_h, fg)
    engine.clear_clip()
    engine.present()
    val pixels = engine.read_pixels()
    engine.shutdown()
    pixels

fn render_software_mask_rect_reference(bg: u32, fg: u32, mask: [u8], mask_w: i32, mask_h: i32, rect_x: i32, rect_y: i32, rect_w: i32, rect_h: i32) -> [u32]:
