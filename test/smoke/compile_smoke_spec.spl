# Minimal sspec that the --compile / --mode=native pipeline should handle
# end-to-end without touching the known-broken wrapper paths:
#   - no class definitions
#   - no skip() / pending
#   - no top-level let/val bindings outside fn/describe
# If this fails under `bin/simple test --compile`, the native-mode exec
# wiring itself is broken. If it passes, the wiring is correct and any
# larger failure is in preprocess_sspec_for_smf or sspec runtime linkage.

describe "Compile smoke":
    it "evaluates literal equality":
        expect 1 + 1 == 2

    it "evaluates string equality":
        expect "ok" == "ok"
