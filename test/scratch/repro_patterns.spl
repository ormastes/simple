# Test multiple generic patterns to find exact failure modes

class Pair<A, B>:
    val first: A
    val second: B

# Pattern 1: direct generic constructor (works per repro_generic_method)
val p1 = Pair<i64, text>(first: 1, second: "hello")
print p1.first

# Pattern 2: generic function call
fn identity<T>(x: T) -> T:
    x

val v2 = identity<i64>(42)
print v2
