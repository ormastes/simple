# Reproducer: Type alias method dispatch
# Bug: method not found when called through type alias

class MyVec:
    var items: [i64]

    fn push(item: i64):
        me.items.push(item)

    fn length() -> i64:
        me.items.length

type IntVec = MyVec

val v = IntVec(items: [])
v.push(10)
val n = v.length()
print n
