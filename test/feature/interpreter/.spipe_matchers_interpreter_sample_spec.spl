"""
# Interpreter Sample Programs

**Category:** Runtime
**Status:** In Progress

## Overview

Tests the Simple language interpreter with representative sample programs covering
arithmetic operations, comparison operators, boolean logic, and string handling.
Verifies that complete programs execute correctly in interpreted mode.
"""
# System test for the Simple language interpreter.
#
# Tests core interpreter functionality including arithmetic operations,
# comparison operators, boolean logic, and string handling.


describe "Simple Interpreter":
    # Verifies the interpreter correctly evaluates expressions, handles
    # operators, and processes string operations including interpolation.
    context "when evaluating expressions":
        it "handles arithmetic operations":
            expect 1 + 1 == 2
            expect 10 - 3 == 7
            expect 4 * 5 == 20
            expect 15 / 3 == 5

        it "handles comparison operations":
            expect 5 > 3 == true
            expect 2 < 10 == true
            expect 5 == 5 == true
            expect 3 != 4 == true

        it "handles boolean operations":
            expect true and true == true
            expect true and false == false
            expect true or false == true
            expect not false == true

    context "when working with strings":
        it "supports string concatenation":
            val s = "Hello" + " " + "World"
            expect s == "Hello World"

        it "supports string interpolation":
            val name = "Alice"
            val age = 30
            val msg = "Name: {name}, Age: {age}"
            expect msg == "Name: Alice, Age: 30"