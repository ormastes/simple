"""
Enum probe 7
"""
use std.spec
use std.spec.{expect}

enum Maybe:
    Some(value: i64)
    None

impl Maybe:
    fn qualified_match() -> i64:
        match self:
            case Maybe.Some(value): value
            case Maybe.None: -1

    fn unqualified_match() -> i64:
        match self:
            case Some(value): value
            case None: -1

describe "enum_probes7":
    it "qualified":
        val v = Maybe.Some(9)
        print("qualified={v.qualified_match()}")

    it "unqualified":
        val v = Maybe.Some(9)
        print("unqualified={v.unqualified_match()}")
