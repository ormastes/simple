"""
Enum probe 8
"""
use std.spec
use std.spec.{expect}

enum Maybe:
    Some(value: i64)
    None

impl Maybe:
    fn const_match() -> i64:
        match self:
            case Some(_): 42
            case None: -1

    fn bind_match() -> i64:
        match self:
            case Some(value): value
            case None: -1

    fn bind_qual_match() -> i64:
        match self:
            case Maybe.Some(value): value
            case Maybe.None: -1

describe "enum_probes8":
    it "const_test":
        val v = Maybe.Some(9)
        print("const={v.const_match()}")

    it "bind_test":
        val v = Maybe.Some(9)
        print("bind={v.bind_match()}")

    it "qual_test":
        val v = Maybe.Some(9)
        print("qual={v.bind_qual_match()}")
