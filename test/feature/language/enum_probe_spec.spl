"""
Enum probe spec
"""
use std.spec
use std.spec.{expect}

enum MaybeNumber:
    Some(value: i64)
    None

impl MaybeNumber:
    fn is_some() -> bool:
        match self:
            case Some(_): true
            case None: false

    fn always_true() -> bool:
        true

enum TrafficLight:
    Red
    Amber
    Green

impl TrafficLight:
    fn next() -> TrafficLight:
        match self:
            case Red: TrafficLight.Amber
            case Amber: TrafficLight.Green
            case Green: TrafficLight.Red
    fn label() -> text:
        match self:
            case Red: "red"
            case Amber: "amber"
            case Green: "green"

describe "enum_probes":
    it "probe_match_and_methods":
        val value = MaybeNumber.Some(9)
        val r = match value:
            case Some(x): x
            case None: -1
        print("match={r}")
        print("is_some={value.is_some()}")
        print("always_true={value.always_true()}")
        print("tl={TrafficLight.Green.label()}")

    it "probe_registration":
        val value = MaybeNumber.Some(9)
        print("always_true_result={value.always_true()}")
