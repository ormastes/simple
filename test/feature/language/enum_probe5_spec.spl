"""
Enum probe 5 - test if Some/None name collision is the issue
"""
use std.spec
use std.spec.{expect}

enum MaybeNum:
    HasValue(value: i64)
    Empty

impl MaybeNum:
    fn has_val() -> bool:
        match self:
            case HasValue(_): true
            case Empty: false
    fn get_val(default: i64) -> i64:
        match self:
            case HasValue(value): value
            case Empty: default

describe "enum_probes5":
    it "has_val_test":
        val v = MaybeNum.HasValue(9)
        expect(v.has_val()).to_equal(true)

    it "get_val_test":
        val v = MaybeNum.HasValue(9)
        expect(v.get_val(0)).to_equal(9)
