"""
Enum probe 3
"""
use std.spec
use std.spec.{expect}

enum MaybeNumber:
    Some(value: i64)
    None

fn test_outside() -> i64:
    val value = MaybeNumber.Some(9)
    match value:
        case Some(x): x
        case None: -1

describe "enum_probes3":
    it "outside_fn_match":
        val r = test_outside()
        print("outside={r}")

    it "inline_match_in_it":
        val value = MaybeNumber.Some(9)
        val r = match value:
            case Some(x): x
            case None: -1
        print("inline={r}")
