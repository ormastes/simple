"""
Enum probe 6 - confirm Some/None conflict
"""
use std.spec
use std.spec.{expect}

enum Maybe:
    Some(value: i64)
    None

impl Maybe:
    fn is_some() -> bool:
        match self:
            case Some(_): true
            case None: false
    fn unwrap_or(default: i64) -> i64:
        match self:
            case Some(value): value
            case None: default

describe "enum_probes6":
    it "is_some":
        val v = Maybe.Some(9)
        expect(v.is_some()).to_equal(true)
    it "unwrap":
        val v = Maybe.Some(9)
        expect(v.unwrap_or(0)).to_equal(9)

    it "qualified_pattern":
        val v = Maybe.Some(9)
        val r = match v:
            case Maybe.Some(x): x
            case Maybe.None: -1
        expect(r).to_equal(9)
