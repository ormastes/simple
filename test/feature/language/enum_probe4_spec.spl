"""
Enum probe 4
"""
use std.spec
use std.spec.{expect}

enum Foo:
    Bar(x: i64)
    Baz

describe "enum_probes4":
    it "wildcard_pattern":
        val v = Foo.Bar(9)
        val r = match v:
            case Bar(_): 42
            case Baz: 0
        print("wildcard={r}")

    it "binding_pattern":
        val v = Foo.Bar(9)
        val r = match v:
            case Bar(x): x
            case Baz: 0
        print("binding={r}")

    it "unit_pattern":
        val v = Foo.Baz
        val r = match v:
            case Bar(_): 42
            case Baz: 0
        print("unit={r}")

    it "qualified_pattern":
        val v = Foo.Bar(9)
        val r = match v:
            case Foo.Bar(x): x
            case Foo.Baz: 0
        print("qualified={r}")
