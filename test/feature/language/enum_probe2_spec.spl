"""
Enum probe 2
"""
use std.spec
use std.spec.{expect}

enum MaybeNumber:
    Some(value: i64)
    None

describe "enum_probes2":
    it "bare_match":
        val value = MaybeNumber.Some(9)
        val r = match value:
            case Some(_): 1
            case None: 0
        print("wildcard match={r}")

    it "binding_match":
        val value = MaybeNumber.Some(9)
        val r = match value:
            case Some(x): x
            case None: -1
        print("binding match={r}")

    it "qualified_match":
        val value = MaybeNumber.Some(9)
        val r = match value:
            case MaybeNumber.Some(x): x
            case MaybeNumber.None: -1
        print("qualified match={r}")
