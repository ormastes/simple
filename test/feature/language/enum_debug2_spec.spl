"""
Enum method debug spec 2
"""
use std.spec
use std.spec.{expect}

enum MaybeNumber:
    Some(value: i64)
    None

impl MaybeNumber:
    fn is_some() -> bool:
        match self:
            case Some(_): true
            case None: false

describe "enum_debug2":
    it "direct_call_no_expect":
        val value = MaybeNumber.Some(9)
        val result = value.is_some()
        print("is_some result: {result}")

    it "inline_no_expect":
        val result = MaybeNumber.Some(9).is_some()
        print("inline result: {result}")

    it "with_expect":
        expect(MaybeNumber.Some(9).is_some()).to_equal(true)
