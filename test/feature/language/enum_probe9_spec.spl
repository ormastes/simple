"""
Enum probe 9 - print self in match
"""
use std.spec
use std.spec.{expect}

enum Maybe:
    Some(value: i64)
    None

impl Maybe:
    fn debug_match() -> text:
        match self:
            case Some(value): "some:{value}"
            case None: "none"
            case _: "other"

    fn debug_match_qual() -> text:
        match self:
            case Maybe.Some(value): "q_some:{value}"
            case Maybe.None: "q_none"

describe "enum_probes9":
    it "debug_unqual":
        val v = Maybe.Some(9)
        print("unqual={v.debug_match()}")

    it "debug_qual":
        val v = Maybe.Some(9)
        print("qual={v.debug_match_qual()}")

    it "debug_none_unqual":
        val v = Maybe.None
        print("none_unqual={v.debug_match()}")
