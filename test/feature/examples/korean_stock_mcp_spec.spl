# Korean Stock MCP Server Tests
#
# Tests JSON helpers, formatting utilities, cache, and URL building.
# Integration test: start server subprocess, send JSON-RPC, verify tools/list.

# --- Inline test helpers (same as MCP server uses) ---

fn Q() -> text: "\""
fn LB() -> text: "{"
fn RB() -> text: "}"
fn SB_L() -> text: "["
fn SB_R() -> text: "]"

fn escape_json(s: text) -> text:
    var result = s
    result = result.replace(r"\", r"\\")
    result = result.replace(Q(), r"\" + Q())
    result = result.replace("\n", r"\n")
    result = result.replace("\r", r"\r")
    result = result.replace("\t", r"\t")
    result

fn js(s: text) -> text:
    Q() + escape_json(s) + Q()

fn jp(key: text, value: text) -> text:
    Q() + key + Q() + ":" + value

fn jo1(p1: text) -> text:
    LB() + p1 + RB()

fn jo2(p1: text, p2: text) -> text:
    LB() + p1 + "," + p2 + RB()

fn jo3(p1: text, p2: text, p3: text) -> text:
    LB() + p1 + "," + p2 + "," + p3 + RB()

fn mcp_substr(s: text, start: i64, end_pos: i64) -> text:
    var buf: [text] = []
    var idx = 0
    for ch in s:
        if idx >= start and idx < end_pos:
            buf.push(ch)
        idx = idx + 1
    buf.join("")

fn mcp_char_at(s: text, index: i64) -> text:
    var idx = 0
    for ch in s:
        if idx == index:
            return ch
        idx = idx + 1
    ""

fn extract_field(json: text, key: text) -> text:
    val search = Q() + key + Q() + ":"
    val idx_result = json.index_of(search)
    var idx = -1
    match idx_result:
        Some(i): idx = i
        nil: return ""
    if idx < 0:
        return ""
    val start = idx + search.len()
    val after = mcp_substr(json, start, json.len())
    val trimmed = after.trim()
    if trimmed.starts_with(Q()):
        val after_quote = mcp_substr(trimmed, 1, trimmed.len())
        val end_idx_result = after_quote.index_of(Q())
        var end_idx = -1
        match end_idx_result:
            Some(i): end_idx = i
            nil: return ""
        if end_idx < 0:
            return ""
        return mcp_substr(trimmed, 1, end_idx + 1)
    else:
        var parts: [text] = []
        for ch in trimmed:
            if ch == "," or ch == RB() or ch == SB_R() or ch == " " or ch == "\n":
                break
            parts.push(ch)
        return parts.join("")

# --- Formatting helpers (inline for testing) ---

fn format_krw(amount_str: text) -> text:
    if amount_str == "" or amount_str == "0":
        return "0"
    var clean = amount_str.replace(",", "")
    val amount = int(clean) ?? 0
    if amount == 0:
        return amount_str
    val abs_amount = if amount < 0 then -amount else amount
    var s = str(abs_amount)
    var result: [text] = []
    var count = 0
    var i = s.len() - 1
    while i >= 0:
        if count > 0 and count % 3 == 0:
            result.push(",")
        result.push(mcp_char_at(s, i))
        count = count + 1
        i = i - 1
    result.reverse()
    var formatted = result.join("")
    if amount < 0:
        formatted = "-" + formatted
    formatted

fn format_volume(vol_str: text) -> text:
    if vol_str == "":
        return "0"
    var clean = vol_str.replace(",", "")
    val vol = int(clean) ?? 0
    if vol == 0:
        return vol_str
    if vol >= 1000000:
        val m = vol / 1000000
        return str(m) + "M"
    elif vol >= 1000:
        val k = vol / 1000
        return str(k) + "K"
    str(vol)

# ============================================================================
# Tests
# ============================================================================

describe "Korean Stock MCP - JSON Helpers":
    it "provides brace helpers":
        expect(LB()).to_equal("{")
        expect(RB()).to_equal("}")
        expect(Q()).to_equal("\"")
        expect(SB_L()).to_equal("[")
        expect(SB_R()).to_equal("]")

    it "escapes JSON strings":
        expect(escape_json("hello")).to_equal("hello")
        expect(escape_json("line1\nline2")).to_equal(r"line1\nline2")
        expect(escape_json("tab\there")).to_equal(r"tab\there")

    it "builds JSON string values":
        expect(js("hello")).to_equal("\"hello\"")
        expect(js("")).to_equal("\"\"")

    it "builds JSON pairs":
        expect(jp("key", "123")).to_equal("\"key\":123")
        expect(jp("name", js("test"))).to_equal("\"name\":\"test\"")

    it "builds JSON objects":
        val obj1 = jo1(jp("a", "1"))
        expect(obj1).to_equal("{\"a\":1}")

        val obj2 = jo2(jp("a", "1"), jp("b", "2"))
        expect(obj2).to_equal("{\"a\":1,\"b\":2}")

        val obj3 = jo3(jp("x", js("y")), jp("a", "1"), jp("b", "2"))
        expect(obj3).to_contain("\"x\":\"y\"")
        expect(obj3).to_contain("\"a\":1")

    it "extracts fields from JSON":
        val json = "{\"method\":\"initialize\",\"id\":1}"
        expect(extract_field(json, "method")).to_equal("initialize")
        expect(extract_field(json, "id")).to_equal("1")
        expect(extract_field(json, "missing")).to_equal("")

    it "extracts nested string values":
        val json = "{\"name\":\"Samsung\",\"ticker\":\"005930\"}"
        expect(extract_field(json, "name")).to_equal("Samsung")
        expect(extract_field(json, "ticker")).to_equal("005930")

describe "Korean Stock MCP - Formatting":
    it "formats KRW amounts with commas":
        expect(format_krw("1000")).to_equal("1,000")
        expect(format_krw("1000000")).to_equal("1,000,000")
        expect(format_krw("500")).to_equal("500")
        expect(format_krw("0")).to_equal("0")
        expect(format_krw("")).to_equal("0")

    it "formats volume with K/M suffixes":
        expect(format_volume("1500000")).to_equal("1M")
        expect(format_volume("50000")).to_equal("50K")
        expect(format_volume("500")).to_equal("500")
        expect(format_volume("")).to_equal("0")

    it "handles comma-separated input":
        expect(format_krw("1,000,000")).to_equal("1,000,000")
        expect(format_volume("1,500,000")).to_equal("1M")

describe "Korean Stock MCP - Safe String Helpers":
    it "substrings correctly":
        expect(mcp_substr("hello", 0, 3)).to_equal("hel")
        expect(mcp_substr("hello", 1, 4)).to_equal("ell")
        expect(mcp_substr("hello", 0, 5)).to_equal("hello")

    it "gets char at index":
        expect(mcp_char_at("hello", 0)).to_equal("h")
        expect(mcp_char_at("hello", 4)).to_equal("o")
        expect(mcp_char_at("hello", 10)).to_equal("")

describe "Korean Stock MCP - KRX URL Building":
    it "builds form body with bld parameter":
        val body = "bld=dbms/MDC/STAT/standard/MDCSTAT01501&trdDd=20240315"
        expect(body).to_contain("bld=dbms/MDC/STAT/standard/MDCSTAT01501")
        expect(body).to_contain("trdDd=20240315")

    it "uses correct KRX API URL":
        val url = "http://data.krx.co.kr/comm/bldAttendant/getJsonData.cmd"
        expect(url).to_contain("data.krx.co.kr")
        expect(url).to_contain("getJsonData")

    it "builds market index params":
        val params = "trdDd=20240315&idxIndMidclssCd=1001"
        expect(params).to_contain("idxIndMidclssCd=1001")

    it "maps market names to KRX codes":
        var mkt_id = "STK"
        val market = "KOSDAQ"
        if market == "KOSDAQ":
            mkt_id = "KSQ"
        expect(mkt_id).to_equal("KSQ")

describe "Korean Stock MCP - Tool Schema":
    it "builds tool schema JSON":
        val schema = jo3(
            jp("type", js("object")),
            jp("properties", jo1(jp("ticker", jo2(jp("type", js("string")), jp("description", js("Stock ticker")))))),
            jp("required", "[" + js("ticker") + "]")
        )
        expect(schema).to_contain("\"type\":\"object\"")
        expect(schema).to_contain("\"ticker\"")
        expect(schema).to_contain("\"required\"")

    it "builds complete tool entry":
        val tool = jo3(
            jp("name", js("stock_price")),
            jp("description", js("Get stock price")),
            jp("inputSchema", jo1(jp("type", js("object"))))
        )
        expect(tool).to_contain("\"name\":\"stock_price\"")
        expect(tool).to_contain("\"description\"")
        expect(tool).to_contain("\"inputSchema\"")
