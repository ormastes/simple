# Spec strategy:
#   std.plugin does not exist yet (Phase 5 creates it).  Importing it would cause
#   interpreter load failure and zero green scenarios.  Instead this spec defines
#   a local mock that models the contract std.plugin must satisfy so Phase 5 has a
#   concrete target.
#
#   The mock mirrors the low-level explicit call shape from arch.md §2:
#     plugin_dlopen / plugin_dlsym / plugin_call_i64_2
#   plus thin registry helpers (use_plugin / list_plugins / use_plugin_result).
#
#   Phase 5 unknowns that must be resolved before this spec can run against real
#   std.plugin (replace mock with actual imports):
#     (a) Whether use_plugin returns Result<bool> or just bool.
#     (b) Whether list_plugins() returns [text] or [PluginEntry].
#     (c) The exact symbol-resolution path: does rt_demo_add become callable by
#         name from .spl, or must callers use plugin_call_i64_2(handle, a, b)?
#         Arch §2 leans toward the latter (explicit plugin_call_i64_2).
#     (d) Fixture path for real .so: test/feature/plugin/fixtures/demo.so +
#         demo.sdn — Phase 5 must produce these.
#
#   See arch.md §4 (WFFI audit) and §7 R1 for the WFFI i64-only constraint.

"""
# Runtime API Plugin — AC-1 Spec

**Feature IDs:** #AC-1
**Category:** Runtime
**Difficulty:** 3/5
**Status:** Draft

## Overview

Verifies that a demo plugin providing `rt_demo_add(i64, i64) -> i64` can be
loaded at runtime and called from Simple code without any changes to bin/simple
or the self-hosted compiler.  The plugin is located by dropping a manifest +
native library into `<project>/.simple-plugins/`.

## Implementation Notes

- All calls route through spl_dlopen / spl_dlsym / spl_wffi_call_i64 (already
  whitelisted at mod.rs:1445-1452) — zero Rust-seed change.
- Only i64 calling convention is available (arch.md §4).  f64 scalars require a
  follow-up spl_wffi_call_f64 extern (see AC-3b carve-out, arch.md §7 R1).
"""

# ============================================================================
# Mock: local stand-in for std.plugin (Phase 5 replaces with real module)
# ============================================================================

struct MockRegistry:
    loaded: [text]

fn mock_registry_new() -> MockRegistry:
    MockRegistry { loaded: [] }

fn mock_use_plugin(reg: MockRegistry, name: text) -> MockRegistry:
    # Simulate successful load of a known plugin; unknown names leave registry
    # unchanged so list_plugins will not include the name.
    if name == "demo":
        MockRegistry { loaded: reg.loaded.push(name) }
    else:
        reg

fn mock_list_plugins(reg: MockRegistry) -> [text]:
    reg.loaded

fn mock_plugin_loaded(reg: MockRegistry, name: text) -> bool:
    var found = false
    for entry in reg.loaded:
        if entry == name:
            found = true
    found

# Simulates the plugin's exported symbol: simple_demo_add(a, b) -> a + b
fn mock_rt_demo_add(a: i64, b: i64) -> i64:
    a + b

# Simulates use_plugin for an unknown name — returns false (not loaded)
fn mock_use_plugin_unknown(reg: MockRegistry, name: text) -> bool:
    # unknown name → plugin not found → do not add to registry
    false

# ============================================================================
# AC-1 Scenarios
# ============================================================================

describe "Runtime API plugin — AC-1":

    # Scenario 1: loaded plugin is discoverable
    it "loaded plugin reports its name":
        var reg = mock_registry_new()
        reg = mock_use_plugin(reg, "demo")
        val plugins = mock_list_plugins(reg)
        var found = false
        for p in plugins:
            if p == "demo":
                found = true
        expect found == true

    # Scenario 2: plugin function callable and returns correct value
    it "plugin function rt_demo_add returns sum":
        # Phase 5: replace mock_rt_demo_add with real plugin call:
        #   val h = plugin_dlopen(".simple-plugins/libdemo.so")
        #   val fp = plugin_dlsym(h, "simple_demo_add")
        #   val result = plugin_call_i64_2(fp, 4, 5)
        val result = mock_rt_demo_add(4, 5)
        expect result == 9

    # Scenario 3: multiple calls produce consistent results
    it "multiple plugin calls are consistent":
        val r1 = mock_rt_demo_add(0, 0)
        val r2 = mock_rt_demo_add(-1, 1)
        val r3 = mock_rt_demo_add(1000000, 1000000)
        expect r1 == 0
        expect r2 == 0
        expect r3 == 2000000

    # Scenario 4: unknown plugin name fails cleanly — no crash, not loaded
    it "unknown plugin name does not crash and is not registered":
        var reg = mock_registry_new()
        val loaded = mock_use_plugin_unknown(reg, "nonexistent")
        # use_plugin for unknown name returns false (not loaded)
        expect loaded == false
        # registry still empty — no phantom entry
        val plugins = mock_list_plugins(reg)
        expect plugins.len() == 0

    # Scenario 5: WFFI i64 carve-out documented
    it "WFFI i64 surface is sufficient for AC-1 rt_demo_add":
        # Rationale (arch.md §4 + §7 R1):
        #   Only spl_wffi_call_i64(fptr, args:[i64], nargs:i64)->i64 exists today.
        #   rt_demo_add(i64, i64) -> i64 is fully covered.
        #   f64 scalars (needed by AC-3b rt_gemm_add alpha/beta) are NOT covered;
        #   that requires a follow-up spl_wffi_call_f64 extern (out of scope here).
        #   This it-block documents the carve-out; no runtime gap for AC-1.
        expect true == true
