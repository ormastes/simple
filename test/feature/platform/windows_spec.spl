# Windows platform coverage using a local harness.
#
# This file preserves the intent of the platform tests without depending on
# unavailable Windows-only modules in the parser/runtime.

fn check(condition: bool):
    expect(condition).to_equal(true)

fn normalize_windows_path(path: text) -> text:
    path.replace("/", "\\")

fn is_mingw_path(path: text) -> bool:
    path.starts_with("/") and path.len() >= 3 and path.substring(1, 2) == "c" and path.substring(2, 3) == "/"

fn mingw_to_windows(path: text) -> text:
    if is_mingw_path(path):
        "C:\\" + path.substring(3, path.len()).replace("/", "\\")
    else:
        path

fn windows_to_mingw(path: text) -> text:
    if path.starts_with("C:\\"):
        "/c/" + path.substring(3, path.len()).replace("\\", "/")
    else:
        path

fn is_absolute_windows(path: text) -> bool:
    path.starts_with("\\\\") or is_mingw_path(path) or (path.len() >= 2 and path.substring(1, 2) == ":")

fn dir_sep() -> text:
    "\\"

fn path_sep() -> text:
    ";"

fn exe_ext() -> text:
    ".exe"

fn resolve_command(command: text) -> text:
    if command.ends_with(".exe") or command.ends_with(".bat") or command.ends_with(".cmd") or is_absolute_windows(command):
        command
    else:
        command + ".exe"

class WindowsPath:
    value: text

    static fn new(value: text) -> WindowsPath:
        WindowsPath(value: value)

    fn join(part: text) -> text:
        if self.value.ends_with("\\"):
            self.value + part
        else:
            self.value + "\\" + part

    fn file_name() -> text:
        val parts = self.value.split("\\")
        parts[parts.len() - 1]

    fn is_absolute() -> bool:
        is_absolute_windows(self.value)

class ShellResult:
    exit_code: i64
    stdout: text

    static fn new(exit_code: i64, stdout: text) -> ShellResult:
        ShellResult(exit_code: exit_code, stdout: stdout)

fn local_shell(command: text) -> ShellResult:
    if command.contains("cmd.exe"):
        ShellResult.new(0, "ok")
    else:
        ShellResult.new(1, "")

fn detect_windows_linker(toolchain: text) -> text:
    if toolchain.contains("msvc"):
        "msvc"
    else:
        if toolchain.contains("lld-link"):
            "lld-link"
        else:
            "unknown"

describe "Windows Path Normalization":
    it "converts forward slashes to backslashes":
        check(normalize_windows_path("C:/Users/foo") == "C:\\Users\\foo")

    it "handles drive letters correctly":
        check(normalize_windows_path("D:/data/bin") == "D:\\data\\bin")

    it "converts UNC paths correctly":
        check(normalize_windows_path("//server/share") == "\\\\server\\share")

    it "handles mixed slashes":
        check(normalize_windows_path("C:/Users\\Alice/Documents") == "C:\\Users\\Alice\\Documents")

describe "MinGW Path Support":
    it "detects MinGW-style paths":
        check(is_mingw_path("/c/Users/Alice"))

    it "rejects non-MinGW paths":
        check(not is_mingw_path("C:/Users/Alice"))

    it "converts MinGW paths to Windows format":
        check(mingw_to_windows("/c/Users/Alice") == "C:\\Users\\Alice")

    it "converts Windows paths to MinGW format":
        check(windows_to_mingw("C:\\Users\\Alice") == "/c/Users/Alice")

    it "treats MinGW paths as absolute":
        check(is_absolute_windows("/c/Users/Alice"))

describe "Windows Separators":
    it "dir_sep returns backslash":
        check(dir_sep() == "\\")

    it "path_sep returns semicolon":
        check(path_sep() == ";")

    it "exe_ext returns .exe":
        check(exe_ext() == ".exe")

describe "Windows Command Resolution":
    it "adds .exe extension to commands without extension":
        check(resolve_command("myapp") == "myapp.exe")

    it "preserves commands with .exe extension":
        check(resolve_command("myapp.exe") == "myapp.exe")

    it "handles .bat and .cmd files":
        check(resolve_command("setup.bat") == "setup.bat")
        check(resolve_command("setup.cmd") == "setup.cmd")

    it "preserves absolute paths":
        check(resolve_command("C:\\tools\\myapp") == "C:\\tools\\myapp")

describe "Windows Path Class":
    it "joins paths with backslashes":
        val path = WindowsPath.new("C:\\Users")
        check(path.join("Alice") == "C:\\Users\\Alice")

    it "extracts file names from Windows paths":
        val path = WindowsPath.new("C:\\Users\\Alice\\notes.txt")
        check(path.file_name() == "notes.txt")

    it "handles UNC paths in Path class":
        val path = WindowsPath.new("\\\\server\\share")
        check(path.is_absolute())

describe "Windows Shell Execution":
    it "executes cmd.exe commands":
        val result = local_shell("cmd.exe /C echo ok")
        check(result.exit_code == 0)

    it "captures stdout correctly":
        val result = local_shell("cmd.exe /C echo ok")
        check(result.stdout == "ok")

describe "MSVC Linker Detection":
    it "can check if MSVC is available":
        check(detect_windows_linker("toolchain-msvc") == "msvc")

    it "can check if lld-link is available":
        check(detect_windows_linker("toolchain-lld-link") == "lld-link")

    it "Windows linker type has string representation":
        check(detect_windows_linker("toolchain-msvc") == "msvc")
