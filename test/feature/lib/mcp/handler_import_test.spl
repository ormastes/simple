# Test that handler modules can be imported with new lib.mcp paths

use std.nogc_async_mut.mcp.helpers.{jp, js, make_tool_result, make_error_response}

fn main():
    print("Testing handler imports...")

    # Test basic JSON building
    val pair = jp("key", "value")
    print("jp result: {pair}")
    if pair.contains("key") and pair.contains("value"):
        print("✓ jp works")
    else:
        print("✗ jp returned unexpected value: {pair}")

    # Test make_tool_result
    val result = make_tool_result("1", "test content")
    if result.contains("result") and result.contains("test content"):
        print("✓ make_tool_result works")
    else:
        print("✗ make_tool_result returned unexpected value: {result}")

    # Test make_error_response
    val error = make_error_response("2", -32601, "test error")
    if error.contains("error") and error.contains("-32601"):
        print("✓ make_error_response works")
    else:
        print("✗ make_error_response returned unexpected value: {error}")

    print("All handler imports working!")

main()
