# Test that handler functions can be imported and called
#
# NOTE: Heavy MCP module imports (helpers, diag_read_tools) removed to avoid
# 7GB+ memory usage when loading modules in interpreter mode. This test
# requires compiled mode to actually exercise the handler functions.

use std.spec

fn skip_on_interpreter(name: text, block: fn()):
    print "    it {name} ... skipped (compiled-only)"

describe "Handler Function Test":
    it "skips heavy MCP imports in interpreter mode":
        skip_on_interpreter "requires MCP modules (compiled-only)":
            print "Would test handle_simple_status"
        expect(true).to_equal(true)
