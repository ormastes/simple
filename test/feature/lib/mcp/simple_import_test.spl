# Simple import test for lib.mcp
# Direct imports from submodules (runtime compatible)

use std.nogc_async_mut.mcp.helpers.{jp, js, make_result_response, make_error_response, extract_arg}

fn main():
    print("Testing lib.mcp imports...")

    # Test 1: JSON building
    val pair = jp("key", "value")
    print("jp result: {pair}")
    if pair.contains("key") and pair.contains("value"):
        print("✓ jp works")
    else:
        print("✗ jp returned unexpected value: {pair}")

    # Test 2: JSON string
    val str_val = js("text")
    print("js result: {str_val}")
    if str_val.contains("text"):
        print("✓ js works")
    else:
        print("✗ js returned unexpected value: {str_val}")

    # Test 3: Result response
    val response = make_result_response("1", """{"status":"ok"}""")
    print("Response created: {response.len()} bytes")
    if response.contains("result") and response.contains("status"):
        print("✓ make_result_response works")
    else:
        print("✗ make_result_response returned unexpected value: {response}")

    # Test 4: Error response
    val error = make_error_response("2", -32600, "Test error")
    print("Error created: {error.len()} bytes")
    if error.contains("error") and error.contains("-32600"):
        print("✓ make_error_response works")
    else:
        print("✗ make_error_response returned unexpected value: {error}")

    print("All imports working!")

main()
