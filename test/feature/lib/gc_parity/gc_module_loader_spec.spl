"""
# GC-Mode Module Resolution

**Feature IDs:** N/A
**Category:** Infrastructure
**Difficulty:** 4/5
**Status:** Implemented
**Requirements:** N/A
**Plan:** N/A
**Design:** N/A
**Research:** N/A

## Overview

Verifies that the module loader resolves modules from the correct
variant directories. Tests that common/ modules are accessible
and that the fallback chain works after migration.
"""

use std.spec

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

fn _has_gc_sync_mut_source_dir() -> bool:
    val (_stdout, _stderr, code) = rt_process_run("/bin/sh", ["-c", "test -d src/lib/gc_sync_mut"])
    code == 0

# ============================================================================
# Module Resolution Verification
# ============================================================================

describe "Module Resolution Fallback":
    """
    ## Fallback Chain

    Modules in common/ should be accessible from any variant context.
    Modules migrated from nogc_sync_mut to common/ must still resolve.
    """

    context "when importing array utilities from common":
        """
        ### Migrated Module Access

        array.spl was moved from nogc_sync_mut to common/.
        It should still be importable via the standard path.
        """

        it "accesses array utilities after migration":
            """
            Basic array operations should work after migration.
            """
            val items = [3, 1, 2]
            expect(items[0]).to_equal(3)
            expect(items.len()).to_equal(3)

    context "when verifying omitted sync GC family":
        """
        ### Deferred Variant Directory

        gc_sync_mut/ is intentionally not a public variant directory.
        Sync GC-related contracts are covered by nogc_sync_mut/gc and
        nogc_sync_mut/ptr until a future family is explicitly designed.
        """

        it "does not expose an unimplemented gc_sync_mut family":
            """
            The runtime-family matrix marks gc_sync_mut as not implemented.
            The source tree should not contain a stub family that reverses
            the no-GC-first direction.
            """
            expect(_has_gc_sync_mut_source_dir()).to_equal(false)
