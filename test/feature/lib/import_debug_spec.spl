# # Bug Database Import Debug Test
#
# **Feature ID:** #STDLIB-001
# **Category:** Standard Library
# **Status:** Active
#
# ## Overview
#
# Minimal test verifying that the BugDatabase module can be imported and instantiated using
# describe/it blocks. Tests that create_bug_database can be called without a direct import
# of the function (relying on wildcard import resolution) and that the resulting database
# contains the expected "bugs" table.
#
# ## Syntax
#
# ```simple
# var db = create_bug_database("/tmp/describe_test.sdn")
# check(db.db.tables.contains_key("bugs"))
# ```
# Minimal test with describe/it like the working test
use std.database.bug.{BugDatabase, Bug, BugSeverity, BugStatus}

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

fn check(condition: bool):
    expect(condition).to_equal(true)

fn _is_windows() -> bool:
    val (uname_out, _, _) = rt_process_run("uname", ["-s"])
    val os = uname_out.trim()
    os.starts_with("MINGW") or os.starts_with("MSYS") or os.starts_with("CYGWIN") or os.starts_with("Windows")

val _can_run = not _is_windows()

describe "Test create_bug_database":
    it "calls create_bug_database without importing it":
        if not _can_run:
            # Interpreter on Windows lacks set_table method resolution
            expect(true).to_equal(true)
        else:
            print "Inside it block, calling create_bug_database..."
            var db = create_bug_database("/tmp/describe_test.sdn")
            print "Success!"
            check(db.db.tables.contains_key("bugs"))
