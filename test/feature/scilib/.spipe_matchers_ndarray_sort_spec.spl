# @cover src/lib/nogc_async_mut/ndarray/mod.spl 80%
"""
# NDArray Sort And Argsort Specification

**Feature IDs:** science-math-lib-set-numpy-core-sort
**Plan:** doc/03_plan/agent_tasks/science_math_lib_set.md
**DF dependency:** doc/03_plan/agent_tasks/scilib_port_df.md T-DF-19/T-DF-21

Validates stable 1-D sort and argsort infrastructure used by later DataFrame
sort/groupby work.
"""

use std.spipe.*
use std.ndarray.*


describe "NDArray argsort":
    it "returns stable ascending indices for Float64 values":
        val a = array([Float64.new(3.0), Float64.new(1.0), Float64.new(3.0), Float64.new(2.0)])
        val idx = a.argsort()
        expect idx.dtype == DType.I64
        expect idx.get(Index.new(0)) == Int64.new(1)
        expect idx.get(Index.new(1)) == Int64.new(3)
        expect idx.get(Index.new(2)) == Int64.new(0)
        expect idx.get(Index.new(3)) == Int64.new(2)

    it "returns ascending indices for Int64 values":
        val a = array_i64([Int64.new(9), Int64.new(-2), Int64.new(4)])
        val idx = a.argsort()
        expect idx.get(Index.new(0)) == Int64.new(1)
        expect idx.get(Index.new(1)) == Int64.new(2)
        expect idx.get(Index.new(2)) == Int64.new(0)


describe "NDArray sort":
    it "sorts Float64 values using argsort and gather":
        val sorted = array([Float64.new(3.0), Float64.new(1.0), Float64.new(2.0)]).sort()
        expect sorted.get(Index.new(0)) == Float64.new(1.0)
        expect sorted.get(Index.new(1)) == Float64.new(2.0)
        expect sorted.get(Index.new(2)) == Float64.new(3.0)

    it "sorts Int64 values without changing dtype":
        val sorted = array_i64([Int64.new(3), Int64.new(1), Int64.new(2)]).sort()
        expect sorted.dtype == DType.I64
        expect sorted.get(Index.new(0)) == Int64.new(1)
        expect sorted.get(Index.new(2)) == Int64.new(3)

    it "returns UnsupportedDType for Bool argsort":
        val result = array_bool([Bool.new(true), Bool.new(false)]).try_argsort()
        expect result.is_err() == true
