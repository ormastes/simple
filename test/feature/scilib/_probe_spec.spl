use std.spipe.*
use std.ndarray.*

describe "probe":
    it "checks add_scalar":
        val a = array([Float64.new(1.0), Float64.new(2.0), Float64.new(3.0)])
        expect(a.get(Index.new(0))).to_equal(Float64.new(1.0))
        val r = a.add_scalar(Float64.new(5.0))
        expect(r.shape).to_equal(Shape.new([Index.new(3)]))
        expect(r.get(Index.new(0))).to_equal(Float64.new(6.0))
