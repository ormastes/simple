# @cover src/lib/nogc_sync_mut/ndarray/index.spl 80%
"""
# NDArray Indexing Specification

**Feature IDs:** scilib-ndarray-index
**Category:** Stdlib
**Difficulty:** 3/5
**Status:** Draft
**Plan:** doc/03_plan/agent_tasks/scilib_port_ndarray.md
**Design:** doc/05_design/scilib_port_architecture.md

## Overview

NDArray<T> indexing API: scalar, multi-dim, fancy (index-array), boolean
masking, with bounds-checked error paths. Public surface uses typed
wrappers Index, Float64 — never raw integer or float primitives.

Tasks covered: T-NDARRAY-13 (basic indexing), T-NDARRAY-15 (fancy/boolean).

## Behavior

- `a.get(Index(i))` — scalar 1-D access
- `a.get_at([Index(i), Index(j)])` — 2-D access
- `a.gather(idx_array)` — fancy indexing (returns new array)
- `a.mask(bool_array)` — boolean indexing (returns new compacted array)
- Out-of-bounds returns `Result<_, NdarrayError>`

## Implementation Notes

Boolean masking and fancy indexing allocate; they go through
`rt_f64_array_alloc` (T-PERFSUGAR-01 gate). Specs fail until impl ships.
"""

use std.spipe.*
use std.ndarray.*


# ============================================================================
# Test Group 1: Basic 1-D and 2-D indexing
# ============================================================================

describe "NDArray scalar indexing":
    """
    ## Basic scalar access

    `get(Index(i))` and `get_at([Index(i), Index(j)])` for 1-D and N-D.
    """

    context "1-D access":
        it "returns the i-th element of a 1-D Float64 array":
            val a = NDArray.from_seq([Float64(10.0), Float64(20.0), Float64(30.0)], Shape(3), Device.CPU)
            expect(a.get(Index(0))).to_equal(Float64(10.0))
            expect(a.get(Index(1))).to_equal(Float64(20.0))
            expect(a.get(Index(2))).to_equal(Float64(30.0))

    context "2-D access":
        it "returns the (i,j) element of a 2x3 array":
            # Build [[1,2,3],[4,5,6]]
            val flat = [Float64(1.0), Float64(2.0), Float64(3.0),
                        Float64(4.0), Float64(5.0), Float64(6.0)]
            val a = NDArray.from_seq(flat, Shape(2, 3), Device.CPU)
            expect(a.get_at([Index(0), Index(0)])).to_equal(Float64(1.0))
            expect(a.get_at([Index(0), Index(2)])).to_equal(Float64(3.0))
            expect(a.get_at([Index(1), Index(0)])).to_equal(Float64(4.0))
            expect(a.get_at([Index(1), Index(2)])).to_equal(Float64(6.0))


# ============================================================================
# Test Group 2: Fancy (index-array) indexing
# ============================================================================

describe "NDArray fancy indexing (gather)":
    """
    ## Fancy indexing

    `a.gather(idx)` selects elements at the positions given by `idx`,
    returning a new array. Mirrors NumPy `a[idx]` for an integer index array.
    """

    it "returns elements at the given index positions":
        val a = NDArray.from_seq([Float64(10.0), Float64(20.0), Float64(30.0),
                       Float64(40.0), Float64(50.0)], Shape(5), Device.CPU)
        val idx = NDArray.from_seq([Int64(0), Int64(2), Int64(4)], Shape(3), Device.CPU)
        val r = a.gather(idx)
        expect(r.len()).to_equal(Index(3))
        expect(r.get(Index(0))).to_equal(Float64(10.0))
        expect(r.get(Index(1))).to_equal(Float64(30.0))
        expect(r.get(Index(2))).to_equal(Float64(50.0))

    it "may repeat positions in the index array":
        val a = NDArray.from_seq([Float64(7.0), Float64(8.0), Float64(9.0)], Shape(3), Device.CPU)
        val idx = NDArray.from_seq([Int64(0), Int64(0), Int64(2)], Shape(3), Device.CPU)
        val r = a.gather(idx)
        expect(r.len()).to_equal(Index(3))
        expect(r.get(Index(0))).to_equal(Float64(7.0))
        expect(r.get(Index(1))).to_equal(Float64(7.0))
        expect(r.get(Index(2))).to_equal(Float64(9.0))


# ============================================================================
# Test Group 3: Boolean masking
# ============================================================================

describe "NDArray boolean masking":
    """
    ## Boolean masking

    `a.mask(bool_array)` returns a new compacted array containing only
    the elements where the mask is true. Mirrors NumPy `a[mask]`.
    """

    it "compacts to elements where mask is true":
        val a = NDArray.from_seq([Float64(1.0), Float64(2.0), Float64(3.0), Float64(4.0)], Shape(4), Device.CPU)
        val m = NDArray.from_seq([Bool(true), Bool(false), Bool(true), Bool(false)], Shape(4), Device.CPU)
        val r = a.mask(m)
        expect(r.len()).to_equal(Index(2))
        expect(r.get(Index(0))).to_equal(Float64(1.0))
        expect(r.get(Index(1))).to_equal(Float64(3.0))

    it "returns an empty array when mask is all-false":
        val a = NDArray.from_seq([Float64(1.0), Float64(2.0)], Shape(2), Device.CPU)
        val m = NDArray.from_seq([Bool(false), Bool(false)], Shape(2), Device.CPU)
        val r = a.mask(m)
        expect(r.len()).to_equal(Index(0))


# ============================================================================
# Test Group 4: Out-of-bounds error paths
# ============================================================================

describe "NDArray indexing error paths":
    """
    ## Bounds checking

    Out-of-range index returns `Result<_, NdarrayError>` — never panics.
    """

    it "returns an error for index beyond length in 1-D":
        val a = NDArray.from_seq([Float64(1.0), Float64(2.0), Float64(3.0)], Shape(3), Device.CPU)
        val r = a.try_get(Index(3))
        expect(r.error?).to_equal(true)

    it "returns an error for negative index":
        val a = NDArray.from_seq([Float64(1.0), Float64(2.0)], Shape(2), Device.CPU)
        val r = a.try_get(Index(-1))
        expect(r.error?).to_equal(true)

    it "returns an error for out-of-range row in 2-D":
        val flat = [Float64(1.0), Float64(2.0), Float64(3.0), Float64(4.0)]
        val a = NDArray.from_seq(flat, Shape(2, 2), Device.CPU)
        val r = a.try_get_at([Index(2), Index(0)])
        expect(r.error?).to_equal(true)

    it "returns an error when fancy-index contains an out-of-range position":
        val a = NDArray.from_seq([Float64(1.0), Float64(2.0), Float64(3.0)], Shape(3), Device.CPU)
        val idx = NDArray.from_seq([Int64(0), Int64(5)], Shape(2), Device.CPU)
        val r = a.try_gather(idx)
        expect(r.error?).to_equal(true)

    it "returns an error when mask length mismatches array length":
        val a = NDArray.from_seq([Float64(1.0), Float64(2.0), Float64(3.0)], Shape(3), Device.CPU)
        val m = NDArray.from_seq([Bool(true), Bool(false)], Shape(2), Device.CPU)
        val r = a.try_mask(m)
        expect(r.error?).to_equal(true)
