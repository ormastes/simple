# @cover src/lib/nogc_sync_mut/df/mod.spl 80%
"""
# DataFrame Head And Tail Specification

**Feature IDs:** T-DF-18, T-DF-19, science-math-lib-set-pandas-core-head-tail
**Plan:** doc/03_plan/agent_tasks/scilib_port_df.md

Validates row inspection helpers using the same row-gather path as
`sort_values`.
"""

use std.spipe.*
use std.df.*
use std.ndarray.*


describe "DataFrame head and tail":
    it "head returns the first n rows across all columns":
        val df = DataFrame.from_columns([
            SeriesErased.F64Series(Series.from_values(
                name: Symbol.from("price"),
                values: [Float64.new(1.0), Float64.new(2.0), Float64.new(3.0)]
            )),
            SeriesErased.I64Series(Series.from_values(
                name: Symbol.from("qty"),
                values: [Int64.new(10), Int64.new(20), Int64.new(30)]
            )),
        ]).unwrap()
        val h = df.head(Index.new(2)).unwrap()
        expect h.num_rows() == Index.new(2)
        expect h.col(Symbol.from("price")).unwrap().get(Index.new(1)) == Float64.new(2.0)
        expect h.col(Symbol.from("qty")).unwrap().get(Index.new(1)) == Int64.new(20)

    it "tail returns the last n rows across all columns":
        val df = DataFrame.from_columns([
            SeriesErased.F64Series(Series.from_values(
                name: Symbol.from("price"),
                values: [Float64.new(1.0), Float64.new(2.0), Float64.new(3.0)]
            )),
            SeriesErased.I64Series(Series.from_values(
                name: Symbol.from("qty"),
                values: [Int64.new(10), Int64.new(20), Int64.new(30)]
            )),
        ]).unwrap()
        val t = df.tail(Index.new(2)).unwrap()
        expect t.num_rows() == Index.new(2)
        expect t.col(Symbol.from("price")).unwrap().get(Index.new(0)) == Float64.new(2.0)
        expect t.col(Symbol.from("qty")).unwrap().get(Index.new(1)) == Int64.new(30)

    it "clamps counts larger than the frame length":
        val df = DataFrame.from_columns([
            SeriesErased.F64Series(Series.from_values(
                name: Symbol.from("price"),
                values: [Float64.new(1.0), Float64.new(2.0)]
            )),
        ]).unwrap()
        expect df.head(Index.new(99)).unwrap().num_rows() == Index.new(2)
        expect df.tail(Index.new(99)).unwrap().num_rows() == Index.new(2)

    it "returns ShapeMismatch for negative counts":
        val df = DataFrame.from_columns([
            SeriesErased.F64Series(Series.from_values(
                name: Symbol.from("price"),
                values: [Float64.new(1.0)]
            )),
        ]).unwrap()
        expect df.head(Index.new(-1)).is_err() == true
        expect df.tail(Index.new(-1)).is_err() == true
