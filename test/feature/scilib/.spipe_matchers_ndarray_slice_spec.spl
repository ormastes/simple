# @cover src/lib/nogc_sync_mut/ndarray/slice.spl 80%
"""
# NDArray Slicing Specification

**Feature IDs:** scilib-ndarray-slice
**Category:** Stdlib
**Difficulty:** 3/5
**Status:** Draft
**Plan:** doc/03_plan/agent_tasks/scilib_port_ndarray.md
**Design:** doc/05_design/scilib_port_architecture.md

## Overview

NDArray<T> slicing — `Slice.new(start, stop, step)` typed wrapper, view-vs-copy
semantics, negative indices, multi-dim slicing. v1 returns COPIES; strided
views are v1.1 (T-NDARRAY-24, gated on PERF-SUGAR-005).

Tasks covered: T-NDARRAY-14 (basic slice), T-NDARRAY-24 (strided view, v1.1
— specs MARKED in preamble but assertions are concrete; they FAIL until v1.1
ships, per `feedback_no_coverups` no skip()).

## Behavior

- `a.slice(Slice.new(start, stop, step))` — half-open range, 1-D
- `a.slice_2d(Slice.new(...), Slice.new(...))` — 2-D row+col slice
- Negative `start`/`stop` count from the end (NumPy parity)
- v1: returns a COPY (cheap; predictable lifetime)
- v1.1: same call returns a strided VIEW (zero-copy)

## Implementation Notes

The view-vs-copy switch in v1.1 is invisible to callers — the same API,
better perf. Specs in this file assert the OBSERVABLE behavior (correct
elements, correct length); they do NOT assert allocator behavior, so they
pass under both v1 (copy) and v1.1 (view).
"""

use std.spipe.*
use std.ndarray.*


# ============================================================================
# Test Group 1: Basic 1-D slicing
# ============================================================================

describe "NDArray 1-D slicing":
    """
    ## 1-D slice

    `a.slice(Slice.new(start, stop, step))` mirrors `a[start:stop:step]`.
    Half-open: `stop` is exclusive.
    """

    context "simple range":
        it "returns a[1:3] for length-5 array":
            val a = array([Float64.new(10.0), Float64.new(20.0), Float64.new(30.0),
                           Float64.new(40.0), Float64.new(50.0)])
            val r = a.slice(Slice.new(Index.new(1), Index.new(3), Index.new(1)))
            expect r.len() == Index.new(2)
            expect r.get(Index.new(0)) == Float64.new(20.0)
            expect r.get(Index.new(1)) == Float64.new(30.0)

    context "step > 1":
        it "returns a[0:5:2] (every-other element)":
            val a = array([Float64.new(0.0), Float64.new(1.0), Float64.new(2.0),
                           Float64.new(3.0), Float64.new(4.0)])
            val r = a.slice(Slice.new(Index.new(0), Index.new(5), Index.new(2)))
            expect r.len() == Index.new(3)
            expect r.get(Index.new(0)) == Float64.new(0.0)
            expect r.get(Index.new(1)) == Float64.new(2.0)
            expect r.get(Index.new(2)) == Float64.new(4.0)

    context "negative bounds":
        it "treats Index.new(-1) as 'last element'":
            val a = array([Float64.new(10.0), Float64.new(20.0), Float64.new(30.0)])
            expect a.get(Index.new(-1)) == Float64.new(30.0)
            expect a.get(Index.new(-2)) == Float64.new(20.0)

        it "returns a[-2:] (last two elements)":
            val a = array([Float64.new(1.0), Float64.new(2.0), Float64.new(3.0), Float64.new(4.0)])
            val r = a.slice(Slice.new(Index.new(-2), Index.new(4), Index.new(1)))
            expect r.len() == Index.new(2)
            expect r.get(Index.new(0)) == Float64.new(3.0)
            expect r.get(Index.new(1)) == Float64.new(4.0)

    context "empty slice":
        it "returns a length-0 array for slice(2, 2)":
            val a = array([Float64.new(1.0), Float64.new(2.0), Float64.new(3.0)])
            val r = a.slice(Slice.new(Index.new(2), Index.new(2), Index.new(1)))
            expect r.len() == Index.new(0)


# ============================================================================
# Test Group 2: 2-D slicing
# ============================================================================

describe "NDArray 2-D slicing":
    """
    ## 2-D slice

    `slice_2d(rows, cols)` mirrors `a[r0:r1, c0:c1]`.
    """

    it "returns a 2x2 sub-block of a 3x3 matrix":
        # 3x3:  1 2 3
        #       4 5 6
        #       7 8 9
        val flat = [Float64.new(1.0), Float64.new(2.0), Float64.new(3.0),
                    Float64.new(4.0), Float64.new(5.0), Float64.new(6.0),
                    Float64.new(7.0), Float64.new(8.0), Float64.new(9.0)]
        val a = array(flat).reshape(Shape.new([Index.new(3), Index.new(3)]))
        val r = a.slice_2d(Slice.new(Index.new(0), Index.new(2), Index.new(1)),
                           Slice.new(Index.new(0), Index.new(2), Index.new(1)))
        expect r.shape == Shape.new([Index.new(2), Index.new(2)])
        expect r.get_at([Index.new(0), Index.new(0)]) == Float64.new(1.0)
        expect r.get_at([Index.new(0), Index.new(1)]) == Float64.new(2.0)
        expect r.get_at([Index.new(1), Index.new(0)]) == Float64.new(4.0)
        expect r.get_at([Index.new(1), Index.new(1)]) == Float64.new(5.0)

    it "selects a single column as a 3x1 slice":
        val flat = [Float64.new(1.0), Float64.new(2.0), Float64.new(3.0),
                    Float64.new(4.0), Float64.new(5.0), Float64.new(6.0),
                    Float64.new(7.0), Float64.new(8.0), Float64.new(9.0)]
        val a = array(flat).reshape(Shape.new([Index.new(3), Index.new(3)]))
        val r = a.slice_2d(Slice.new(Index.new(0), Index.new(3), Index.new(1)),
                           Slice.new(Index.new(2), Index.new(3), Index.new(1)))
        expect r.shape == Shape.new([Index.new(3), Index.new(1)])
        expect r.get_at([Index.new(0), Index.new(0)]) == Float64.new(3.0)
        expect r.get_at([Index.new(1), Index.new(0)]) == Float64.new(6.0)
        expect r.get_at([Index.new(2), Index.new(0)]) == Float64.new(9.0)


# ============================================================================
# Test Group 3: View-vs-copy invariants
# ============================================================================

describe "NDArray slice view invariants":
    """
    ## async-NoGC view contract

    The async-NoGC SciLib core uses stride-carrying views for slice and
    transpose. View creation is metadata-only: same storage, adjusted shape,
    stride, and offset.
    """

    it "slice keeps shared storage and updates metadata only":
        val a = array([Float64.new(1.0), Float64.new(2.0), Float64.new(3.0), Float64.new(4.0)])
        val s = a.slice(Slice.new(Index.new(1), Index.new(3), Index.new(1)))
        expect s.get(Index.new(0)) == Float64.new(2.0)
        expect s.get(Index.new(1)) == Float64.new(3.0)
        expect s.offset == Index.new(1)
        expect s.strides == Stride.new([Index.new(1)])


# ============================================================================
# Test Group 4: Error paths
# ============================================================================

describe "NDArray slice error paths":
    it "returns an error for step=0":
        val a = array([Float64.new(1.0), Float64.new(2.0), Float64.new(3.0)])
        val r = a.try_slice(Slice.new(Index.new(0), Index.new(3), Index.new(0)))
        expect r.is_err() == true

    it "returns an error for stop > len":
        val a = array([Float64.new(1.0), Float64.new(2.0)])
        val r = a.try_slice(Slice.new(Index.new(0), Index.new(5), Index.new(1)))
        expect r.is_err() == true