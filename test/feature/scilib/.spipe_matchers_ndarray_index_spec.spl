# @cover src/lib/nogc_sync_mut/ndarray/index.spl 80%
"""
# NDArray Indexing Specification

**Feature IDs:** scilib-ndarray-index
**Category:** Stdlib
**Difficulty:** 3/5
**Status:** Draft
**Plan:** doc/03_plan/agent_tasks/scilib_port_ndarray.md
**Design:** doc/05_design/scilib_port_architecture.md

## Overview

NDArray<T> indexing API: scalar, multi-dim, fancy (index-array), boolean
masking, with bounds-checked error paths. Public surface uses typed
wrappers Index, Float64 — never raw integer or float primitives.

Tasks covered: T-NDARRAY-13 (basic indexing), T-NDARRAY-15 (fancy/boolean).

## Behavior

- `a.get(Index.new(i))` — scalar 1-D access
- `a.get_at([Index.new(i), Index.new(j)])` — 2-D access
- `a.gather(idx_array)` — fancy indexing (returns new array)
- `a.mask(bool_array)` — boolean indexing (returns new compacted array)
- Out-of-bounds returns `Result<_, NdarrayError>`

## Implementation Notes

Boolean masking and fancy indexing allocate; they go through
`rt_f64_array_alloc` (T-PERFSUGAR-01 gate). Specs fail until impl ships.
"""

use std.spipe.*
use std.ndarray.*


# ============================================================================
# Test Group 1: Basic 1-D and 2-D indexing
# ============================================================================

describe "NDArray scalar indexing":
    """
    ## Basic scalar access

    `get(Index.new(i))` and `get_at([Index.new(i), Index.new(j)])` for 1-D and N-D.
    """

    context "1-D access":
        it "returns the i-th element of a 1-D Float64 array":
            val a = array([Float64.new(10.0), Float64.new(20.0), Float64.new(30.0)])
            expect a.get(Index.new(0)) == Float64.new(10.0)
            expect a.get(Index.new(1)) == Float64.new(20.0)
            expect a.get(Index.new(2)) == Float64.new(30.0)

    context "2-D access":
        it "returns the (i,j) element of a 2x3 array":
            # Build [[1,2,3],[4,5,6]]
            val flat = [Float64.new(1.0), Float64.new(2.0), Float64.new(3.0),
                        Float64.new(4.0), Float64.new(5.0), Float64.new(6.0)]
            val a = array(flat).reshape(Shape.new([Index.new(2), Index.new(3)]))
            expect a.get_at([Index.new(0), Index.new(0)]) == Float64.new(1.0)
            expect a.get_at([Index.new(0), Index.new(2)]) == Float64.new(3.0)
            expect a.get_at([Index.new(1), Index.new(0)]) == Float64.new(4.0)
            expect a.get_at([Index.new(1), Index.new(2)]) == Float64.new(6.0)


# ============================================================================
# Test Group 2: Fancy (index-array) indexing
# ============================================================================

describe "NDArray fancy indexing (gather)":
    """
    ## Fancy indexing

    `a.gather(idx)` selects elements at the positions given by `idx`,
    returning a new array. Mirrors NumPy `a[idx]` for an integer index array.
    """

    it "returns elements at the given index positions":
        val a = array([Float64.new(10.0), Float64.new(20.0), Float64.new(30.0),
                       Float64.new(40.0), Float64.new(50.0)])
        val idx = array([Int64.new(0), Int64.new(2), Int64.new(4)])
        val r = a.gather(idx)
        expect r.len() == Index.new(3)
        expect r.get(Index.new(0)) == Float64.new(10.0)
        expect r.get(Index.new(1)) == Float64.new(30.0)
        expect r.get(Index.new(2)) == Float64.new(50.0)

    it "may repeat positions in the index array":
        val a = array([Float64.new(7.0), Float64.new(8.0), Float64.new(9.0)])
        val idx = array([Int64.new(0), Int64.new(0), Int64.new(2)])
        val r = a.gather(idx)
        expect r.len() == Index.new(3)
        expect r.get(Index.new(0)) == Float64.new(7.0)
        expect r.get(Index.new(1)) == Float64.new(7.0)
        expect r.get(Index.new(2)) == Float64.new(9.0)


# ============================================================================
# Test Group 3: Boolean masking
# ============================================================================

describe "NDArray boolean masking":
    """
    ## Boolean masking

    `a.mask(bool_array)` returns a new compacted array containing only
    the elements where the mask is true. Mirrors NumPy `a[mask]`.
    """

    it "compacts to elements where mask is true":
        val a = array([Float64.new(1.0), Float64.new(2.0), Float64.new(3.0), Float64.new(4.0)])
        val m = array([Bool.new(true), Bool.new(false), Bool.new(true), Bool.new(false)])
        val r = a.mask(m)
        expect r.len() == Index.new(2)
        expect r.get(Index.new(0)) == Float64.new(1.0)
        expect r.get(Index.new(1)) == Float64.new(3.0)

    it "returns an empty array when mask is all-false":
        val a = array([Float64.new(1.0), Float64.new(2.0)])
        val m = array([Bool.new(false), Bool.new(false)])
        val r = a.mask(m)
        expect r.len() == Index.new(0)


# ============================================================================
# Test Group 4: Out-of-bounds error paths
# ============================================================================

describe "NDArray indexing error paths":
    """
    ## Bounds checking

    Out-of-range index returns `Result<_, NdarrayError>` — never panics.
    """

    it "returns an error for index beyond length in 1-D":
        val a = array([Float64.new(1.0), Float64.new(2.0), Float64.new(3.0)])
        val r = a.try_get(Index.new(3))
        expect r.is_err() == true

    it "returns an error for negative index":
        val a = array([Float64.new(1.0), Float64.new(2.0)])
        val r = a.try_get(Index.new(-1))
        expect r.is_err() == true

    it "returns an error for out-of-range row in 2-D":
        val flat = [Float64.new(1.0), Float64.new(2.0), Float64.new(3.0), Float64.new(4.0)]
        val a = array(flat).reshape(Shape.new([Index.new(2), Index.new(2)]))
        val r = a.try_get_at([Index.new(2), Index.new(0)])
        expect r.is_err() == true

    it "returns an error when fancy-index contains an out-of-range position":
        val a = array([Float64.new(1.0), Float64.new(2.0), Float64.new(3.0)])
        val idx = array([Int64.new(0), Int64.new(5)])
        val r = a.try_gather(idx)
        expect r.is_err() == true

    it "returns an error when mask length mismatches array length":
        val a = array([Float64.new(1.0), Float64.new(2.0), Float64.new(3.0)])
        val m = array([Bool.new(true), Bool.new(false)])
        val r = a.try_mask(m)
        expect r.is_err() == true