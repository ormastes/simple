# @cover src/lib/common/linalg/lapack.spl 80%
"""
# LAPACK gesv / solve Specification

**Feature IDs:** scilib-lapack-gesv
**Category:** Stdlib
**Difficulty:** 3/5
**Status:** Draft
**Plan:** doc/03_plan/agent_tasks/scilib_port_lapack.md
**Design:** doc/05_design/scilib_port_architecture.md

## Overview

`solve(A, b)` solves the linear system Ax = b for x (LAPACK dgesv).
Public API is primitive-free: `Matrix<Float64>`, `Vector<Float64>`,
`Result<Vector<Float64>, LinalgError>`. The pivot array is fully hidden inside
Layer B (T-LAPACK-07: no raw `int*` leak at Layer C).

## Behavior

- Solves `A * x = b`; returns `Result.Ok(x)` where `x` is `Vector<Float64>`
- A must be square (n×n); b must have length n
- Singular A (det≈0) returns `Result.Err(LinalgError.Singular)` — info != 0 path
- Non-square A returns `Result.Err(LinalgError.DimensionMismatch(...))`
- Identity-matrix shortcut: solution is exactly b

## Numerical Verification

Lower-triangular 3×3 system (det=1, no cancellation):
  A = [[1,0,0],[2,1,0],[3,4,1]], b = [1,4,15]
  Forward-substitution:
    x[0] = 1
    x[1] = 4 - 2*1 = 2
    x[2] = 15 - 3*1 - 4*2 = 4
  Answer: x = [1, 2, 4]  (all integer-exact in Float64)

## Implementation Notes

Specs run under `SIMPLE_BLAS_BACKEND=mock` (set by `bin/simple test` for
`test/feature/scilib/` paths). Mock computes correct small-N results (T-CUDA-02).
These specs fail until T-LAPACK-07 (gesv Layer B) + T-LAPACK-12 (solve Layer C) land — TDD.
No `skip()`, no `--mode=native` bypass (AC-7 / feedback_no_coverups).
Pivot type is `Pivot` (wrapped); no raw int* visible at Layer C boundary.

Tasks covered: T-LAPACK-07 (gesv Layer B, pivot hidden),
T-LAPACK-12 (solve Layer C public API), T-LAPACK-15 (gesv interp-mode spec).
"""

use std.spipe.*
use std.linalg.*
use std.ndarray.*


# ============================================================================
# Test Group 1: 3×3 system — hand-computed answer
# ============================================================================

describe "linalg.solve — 3x3 lower-triangular system":
    """
    ## Correctness — 3×3 lower-triangular A

    A = [[1,0,0],[2,1,0],[3,4,1]], b = [1,4,15]
    Expected solution x = [1, 2, 4] (integer-exact; safe with to_equal).
    Lower-triangular A has det=1, so it is non-singular; mock must return
    correct result, not zeros.
    """

    context "A lower-triangular, b = [1,4,15]":
        it "solves and returns x[0]=1.0":
            # T-LAPACK-07, T-LAPACK-15
            val a = matrix_from_rows([
                [Float64(1.0), Float64(0.0), Float64(0.0)],
                [Float64(2.0), Float64(1.0), Float64(0.0)],
                [Float64(3.0), Float64(4.0), Float64(1.0)]])
            val b = NDArray.from_seq([Float64(1.0), Float64(4.0), Float64(15.0)], Shape(3), Device.CPU)
            val result = solve(a, b)
            expect(result.ok?).to_equal(true)
            val x = result.unwrap()
            expect(x.get(Index(0))).to_equal(Float64(1.0))

        it "solves and returns x[1]=2.0":
            val a = matrix_from_rows([
                [Float64(1.0), Float64(0.0), Float64(0.0)],
                [Float64(2.0), Float64(1.0), Float64(0.0)],
                [Float64(3.0), Float64(4.0), Float64(1.0)]])
            val b = NDArray.from_seq([Float64(1.0), Float64(4.0), Float64(15.0)], Shape(3), Device.CPU)
            val result = solve(a, b)
            val x = result.unwrap()
            expect(x.get(Index(1))).to_equal(Float64(2.0))

        it "solves and returns x[2]=4.0":
            val a = matrix_from_rows([
                [Float64(1.0), Float64(0.0), Float64(0.0)],
                [Float64(2.0), Float64(1.0), Float64(0.0)],
                [Float64(3.0), Float64(4.0), Float64(1.0)]])
            val b = NDArray.from_seq([Float64(1.0), Float64(4.0), Float64(15.0)], Shape(3), Device.CPU)
            val result = solve(a, b)
            val x = result.unwrap()
            expect(x.get(Index(2))).to_equal(Float64(4.0))

        it "result vector has length 3":
            val a = matrix_from_rows([
                [Float64(1.0), Float64(0.0), Float64(0.0)],
                [Float64(2.0), Float64(1.0), Float64(0.0)],
                [Float64(3.0), Float64(4.0), Float64(1.0)]])
            val b = NDArray.from_seq([Float64(1.0), Float64(4.0), Float64(15.0)], Shape(3), Device.CPU)
            val result = solve(a, b)
            val x = result.unwrap()
            expect(x.len()).to_equal(Index(3))


# ============================================================================
# Test Group 2: Identity-matrix shortcut
# ============================================================================

describe "linalg.solve — identity matrix shortcut":
    """
    ## Identity shortcut

    If A = I then A*x = b has the unique solution x = b.
    Tests that the mock correctly handles the trivial case and returns b.
    """

    context "A = 3x3 identity, b = [7, 3, 9]":
        it "returns x equal to b":
            # T-LAPACK-12: identity shortcut path
            val a = eye_matrix(Index(3))
            val b = NDArray.from_seq([Float64(7.0), Float64(3.0), Float64(9.0)], Shape(3), Device.CPU)
            val result = solve(a, b)
            expect(result.ok?).to_equal(true)
            val x = result.unwrap()
            expect(x.get(Index(0))).to_equal(Float64(7.0))
            expect(x.get(Index(1))).to_equal(Float64(3.0))
            expect(x.get(Index(2))).to_equal(Float64(9.0))


# ============================================================================
# Test Group 3: Error paths — singular and non-square
# ============================================================================

describe "linalg.solve — error paths":
    """
    ## Error handling

    Singular A: dgesv sets info != 0; Layer B decodes to LinalgError.Singular.
    Non-square A: Layer C dimension guard fires before FFI dispatch.
    Pivot array stays hidden (T-LAPACK-07); no raw int* leaks to caller.
    """

    context "singular A":
        """
        ### Scenario: A has a zero row — rank-deficient

        A = [[1,2,3],[0,0,0],[4,5,6]] — row 1 is all zeros → singular.
        Mock must propagate info != 0 (not silently return zeros).
        """

        it "returns an error with Singular variant for rank-deficient A":
            # T-LAPACK-07: info != 0 path; pivot wrapper hidden
            val a = matrix_from_rows([
                [Float64(1.0), Float64(2.0), Float64(3.0)],
                [Float64(0.0), Float64(0.0), Float64(0.0)],
                [Float64(4.0), Float64(5.0), Float64(6.0)]])
            val b = NDArray.from_seq([Float64(1.0), Float64(0.0), Float64(1.0)], Shape(3), Device.CPU)
            val r = solve(a, b)
            expect(r.error?).to_equal(true)

    context "non-square A":
        """
        ### Scenario: A is 2×3 — cannot solve square system

        Layer C dimension guard must fire before any FFI call.
        LinalgError.DimensionMismatch returned.
        """

        it "returns an error for non-square A":
            # T-LAPACK-12: non-square guard
            val a = matrix_from_rows([
                [Float64(1.0), Float64(2.0), Float64(3.0)],
                [Float64(4.0), Float64(5.0), Float64(6.0)]])
            val b = NDArray.from_seq([Float64(1.0), Float64(2.0)], Shape(2), Device.CPU)
            val r = solve(a, b)
            expect(r.error?).to_equal(true)

    context "dimension mismatch between A and b":
        """
        ### Scenario: A is 3×3 but b has length 2

        Layer C must catch n(A) != len(b) before dispatching.
        """

        it "returns an error when b length does not match A order":
            # T-LAPACK-12: A.rows != b.len guard
            val a = eye_matrix(Index(3))
            val b = NDArray.from_seq([Float64(1.0), Float64(2.0)], Shape(2), Device.CPU)
            val r = solve(a, b)
            expect(r.error?).to_equal(true)
