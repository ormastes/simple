# @cover src/lib/nogc_sync_mut/ndarray/slice.spl 80%
"""
# NDArray Slicing Specification

**Feature IDs:** scilib-ndarray-slice
**Category:** Stdlib
**Difficulty:** 3/5
**Status:** Draft
**Plan:** doc/03_plan/agent_tasks/scilib_port_ndarray.md
**Design:** doc/05_design/scilib_port_architecture.md

## Overview

NDArray<T> slicing — `Slice(start, stop, step)` typed wrapper, view-vs-copy
semantics, negative indices, multi-dim slicing. v1 returns COPIES; strided
views are v1.1 (T-NDARRAY-24, gated on PERF-SUGAR-005).

Tasks covered: T-NDARRAY-14 (basic slice), T-NDARRAY-24 (strided view, v1.1
— specs MARKED in preamble but assertions are concrete; they FAIL until v1.1
ships, per `feedback_no_coverups` no skip()).

## Behavior

- `a.slice(Slice(start, stop, step))` — half-open range, 1-D
- `a.slice_2d(Slice(...), Slice(...))` — 2-D row+col slice
- Negative `start`/`stop` count from the end (NumPy parity)
- v1: returns a COPY (cheap; predictable lifetime)
- v1.1: same call returns a strided VIEW (zero-copy)

## Implementation Notes

The view-vs-copy switch in v1.1 is invisible to callers — the same API,
better perf. Specs in this file assert the OBSERVABLE behavior (correct
elements, correct length); they do NOT assert allocator behavior, so they
pass under both v1 (copy) and v1.1 (view).
"""

use std.spipe.*
use std.ndarray.*


# ============================================================================
# Test Group 1: Basic 1-D slicing
# ============================================================================

describe "NDArray 1-D slicing":
    """
    ## 1-D slice

    `a.slice(Slice(start, stop, step))` mirrors `a[start:stop:step]`.
    Half-open: `stop` is exclusive.
    """

    context "simple range":
        it "returns a[1:3] for length-5 array":
            val a = NDArray.from_seq([Float64(10.0), Float64(20.0), Float64(30.0),
                           Float64(40.0), Float64(50.0)], Shape(5), Device.CPU)
            val r = a.slice(Slice(Index(1), Index(3), Index(1)))
            expect(r.len()).to_equal(Index(2))
            expect(r.get(Index(0))).to_equal(Float64(20.0))
            expect(r.get(Index(1))).to_equal(Float64(30.0))

    context "step > 1":
        it "returns a[0:5:2] (every-other element)":
            val a = NDArray.from_seq([Float64(0.0), Float64(1.0), Float64(2.0),
                           Float64(3.0), Float64(4.0)], Shape(5), Device.CPU)
            val r = a.slice(Slice(Index(0), Index(5), Index(2)))
            expect(r.len()).to_equal(Index(3))
            expect(r.get(Index(0))).to_equal(Float64(0.0))
            expect(r.get(Index(1))).to_equal(Float64(2.0))
            expect(r.get(Index(2))).to_equal(Float64(4.0))

    context "negative bounds":
        it "treats Index(-1) as 'last element'":
            val a = NDArray.from_seq([Float64(10.0), Float64(20.0), Float64(30.0)], Shape(3), Device.CPU)
            expect(a.get(Index(-1))).to_equal(Float64(30.0))
            expect(a.get(Index(-2))).to_equal(Float64(20.0))

        it "returns a[-2:] (last two elements)":
            val a = NDArray.from_seq([Float64(1.0), Float64(2.0), Float64(3.0), Float64(4.0)], Shape(4), Device.CPU)
            val r = a.slice(Slice(Index(-2), Index(4), Index(1)))
            expect(r.len()).to_equal(Index(2))
            expect(r.get(Index(0))).to_equal(Float64(3.0))
            expect(r.get(Index(1))).to_equal(Float64(4.0))

    context "empty slice":
        it "returns a length-0 array for slice(2, 2)":
            val a = NDArray.from_seq([Float64(1.0), Float64(2.0), Float64(3.0)], Shape(3), Device.CPU)
            val r = a.slice(Slice(Index(2), Index(2), Index(1)))
            expect(r.len()).to_equal(Index(0))


# ============================================================================
# Test Group 2: 2-D slicing
# ============================================================================

describe "NDArray 2-D slicing":
    """
    ## 2-D slice

    `slice_2d(rows, cols)` mirrors `a[r0:r1, c0:c1]`.
    """

    it "returns a 2x2 sub-block of a 3x3 matrix":
        # 3x3:  1 2 3
        #       4 5 6
        #       7 8 9
        val flat = [Float64(1.0), Float64(2.0), Float64(3.0),
                    Float64(4.0), Float64(5.0), Float64(6.0),
                    Float64(7.0), Float64(8.0), Float64(9.0)]
        val a = NDArray.from_seq(flat, Shape(3, 3), Device.CPU)
        val r = a.slice_2d(Slice(Index(0), Index(2), Index(1)),
                           Slice(Index(0), Index(2), Index(1)))
        expect(r.shape).to_equal(Shape(2, 2))
        expect(r.get_at([Index(0), Index(0)])).to_equal(Float64(1.0))
        expect(r.get_at([Index(0), Index(1)])).to_equal(Float64(2.0))
        expect(r.get_at([Index(1), Index(0)])).to_equal(Float64(4.0))
        expect(r.get_at([Index(1), Index(1)])).to_equal(Float64(5.0))

    it "selects a single column as a 3x1 slice":
        val flat = [Float64(1.0), Float64(2.0), Float64(3.0),
                    Float64(4.0), Float64(5.0), Float64(6.0),
                    Float64(7.0), Float64(8.0), Float64(9.0)]
        val a = NDArray.from_seq(flat, Shape(3, 3), Device.CPU)
        val r = a.slice_2d(Slice(Index(0), Index(3), Index(1)),
                           Slice(Index(2), Index(3), Index(1)))
        expect(r.shape).to_equal(Shape(3, 1))
        expect(r.get_at([Index(0), Index(0)])).to_equal(Float64(3.0))
        expect(r.get_at([Index(1), Index(0)])).to_equal(Float64(6.0))
        expect(r.get_at([Index(2), Index(0)])).to_equal(Float64(9.0))


# ============================================================================
# Test Group 3: View-vs-copy invariants
# ============================================================================

describe "NDArray slice view-vs-copy invariants (v1 = copy; v1.1 = view)":
    """
    ## v1 contract

    In v1, `slice` returns a COPY. Mutating the slice MUST NOT mutate the
    parent. In v1.1 (T-NDARRAY-24, gated on PERF-SUGAR-005), the same call
    becomes a strided view; that v1.1 semantics is covered by a separate
    `_view_spec.spl` and is OUT OF SCOPE here.
    """

    it "v1 slice does not alias parent storage":
        val a = NDArray.from_seq([Float64(1.0), Float64(2.0), Float64(3.0), Float64(4.0)], Shape(4), Device.CPU)
        val s = a.slice(Slice(Index(1), Index(3), Index(1)))
        # Mutating s (if mutable) MUST NOT alter a in v1.
        expect(s.get(Index(0))).to_equal(Float64(2.0))
        expect(a.get(Index(1))).to_equal(Float64(2.0))


# ============================================================================
# Test Group 4: Error paths
# ============================================================================

describe "NDArray slice error paths":
    it "returns an error for step=0":
        val a = NDArray.from_seq([Float64(1.0), Float64(2.0), Float64(3.0)], Shape(3), Device.CPU)
        val r = a.try_slice(Slice(Index(0), Index(3), Index(0)))
        expect(r.error?).to_equal(true)

    it "returns an error for stop > len":
        val a = NDArray.from_seq([Float64(1.0), Float64(2.0)], Shape(2), Device.CPU)
        val r = a.try_slice(Slice(Index(0), Index(5), Index(1)))
        expect(r.error?).to_equal(true)
