# @cover src/lib/scipy/integrate/mod.spl 80%
"""
# SciPy Integrate Facade Specification

**Feature IDs:** science-math-lib-set-scipy-integrate-core
**Plan:** doc/03_plan/agent_tasks/science_math_lib_set.md
**Design:** doc/05_design/science_math_lib_set.md

Validates the first SciPy-style integration namespace slice over typed
`NDArray` values.
"""

use std.spipe.*
use std.ndarray.*
use std.scipy.integrate.*


describe "scipy.integrate trapezoid":
    it "integrates y=x over [0, 2] using sampled points":
        val x = array([Float64.new(0.0), Float64.new(1.0), Float64.new(2.0)])
        val y = array([Float64.new(0.0), Float64.new(1.0), Float64.new(2.0)])
        expect trapezoid(y, x).unwrap() == Float64.new(2.0)

    it "integrates constant values with non-unit spacing":
        val x = array([Float64.new(0.0), Float64.new(2.0), Float64.new(5.0)])
        val y = array([Float64.new(3.0), Float64.new(3.0), Float64.new(3.0)])
        expect trapezoid(y, x).unwrap() == Float64.new(15.0)

    it "returns errors for mismatched lengths and unsupported dtypes":
        val x = array([Float64.new(0.0), Float64.new(1.0)])
        val y = array([Float64.new(0.0)])
        expect trapezoid(y, x).is_err() == true
        expect trapezoid(array_i64([Int64.new(1), Int64.new(2)]), x).is_err() == true


describe "scipy.integrate cumulative_trapezoid":
    it "returns cumulative area with an initial zero":
        val x = array([Float64.new(0.0), Float64.new(1.0), Float64.new(2.0)])
        val y = array([Float64.new(0.0), Float64.new(1.0), Float64.new(2.0)])
        val result = cumulative_trapezoid(y, x).unwrap()
        expect result.len() == Index.new(3)
        expect result.flat_f64(0) == Float64.new(0.0)
        expect result.flat_f64(1) == Float64.new(0.5)
        expect result.flat_f64(2) == Float64.new(2.0)

    it "returns errors for mismatched lengths and unsupported dtypes":
        val x = array([Float64.new(0.0), Float64.new(1.0)])
        expect cumulative_trapezoid(array([Float64.new(0.0)]), x).is_err() == true
        expect cumulative_trapezoid(array_i64([Int64.new(1), Int64.new(2)]), x).is_err() == true