# @cover src/lib/nogc_async_mut/ndarray/mod.spl 80%
"""
# NDArray Shape Operation Specification

**Feature IDs:** science-math-lib-set-ndarray-shape-ops
**Plan:** doc/03_plan/agent_tasks/science_math_lib_set.md
**Design:** doc/05_design/science_math_lib_set.md

Validates reshape, flatten, squeeze, and transpose shape metadata operations.
"""

use std.spipe.*
use std.ndarray.*


describe "NDArray reshape":
    it "reshapes a contiguous vector without changing logical values":
        val values = array([Float64.new(1.0), Float64.new(2.0), Float64.new(3.0), Float64.new(4.0)])
        val matrix = values.reshape(Shape.new([Index.new(2), Index.new(2)]))
        expect matrix.shape == Shape.new([Index.new(2), Index.new(2)])
        expect matrix.get_at([Index.new(1), Index.new(0)]) == Float64.new(3.0)

    it "returns errors for invalid reshape requests":
        val values = array([Float64.new(1.0), Float64.new(2.0), Float64.new(3.0)])
        expect values.try_reshape(Shape.new([Index.new(2), Index.new(2)])).is_err() == true
        expect values.try_reshape(Shape.new([Index.new(-3)])).is_err() == true


describe "NDArray flatten and squeeze":
    it "flattens a strided view in logical order":
        val matrix = array([Float64.new(1.0), Float64.new(2.0), Float64.new(3.0), Float64.new(4.0)]).reshape(
            Shape.new([Index.new(2), Index.new(2)])
        )
        val transposed = matrix.transpose()
        val flattened = transposed.flatten()
        expect flattened.shape == Shape.new([Index.new(4)])
        expect flattened.get(Index.new(0)) == Float64.new(1.0)
        expect flattened.get(Index.new(1)) == Float64.new(3.0)
        expect flattened.get(Index.new(2)) == Float64.new(2.0)
        expect flattened.get(Index.new(3)) == Float64.new(4.0)

    it "removes size-one dimensions with squeeze":
        val values = array([Float64.new(7.0), Float64.new(8.0)]).reshape(
            Shape.new([Index.new(1), Index.new(2), Index.new(1)])
        )
        val squeezed = values.squeeze()
        expect squeezed.shape == Shape.new([Index.new(2)])
        expect squeezed.get(Index.new(1)) == Float64.new(8.0)


describe "NDArray transpose":
    it "transposes a two-dimensional matrix as a strided view":
        val matrix = array([Float64.new(1.0), Float64.new(2.0), Float64.new(3.0), Float64.new(4.0), Float64.new(5.0), Float64.new(6.0)]).reshape(
            Shape.new([Index.new(2), Index.new(3)])
        )
        val transposed = matrix.transpose()
        expect transposed.shape == Shape.new([Index.new(3), Index.new(2)])
        expect transposed.get_at([Index.new(0), Index.new(1)]) == Float64.new(4.0)
        expect transposed.get_at([Index.new(2), Index.new(1)]) == Float64.new(6.0)
        expect transposed.layout == Layout.Strided

    it "returns errors for invalid transpose axes":
        val values = array([Float64.new(1.0), Float64.new(2.0)])
        expect values.try_transpose_axes(Axis.new(0), Axis.new(1)).is_err() == true