use std.testing.*
use std.ndarray.*

fn first_value(values: [Float64]) -> Float64:
    values[0]

fn array_float(values: [Float64]) -> NDArray:
    make_f64_array(values, Shape.new([Index.new(values.len())]))

describe "ndarray ctor probe":
    it "local inline array yields readable vector":
        val input = array([Float64.new(1.0), Float64.new(2.0), Float64.new(3.0)])
        expect(input.get_f64(Index.new(0)).value).to_equal(1.0)
        expect(input.get_f64(Index.new(2)).value).to_equal(3.0)

    it "local inline reshape yields readable matrix":
        val input = array([Float64.new(1.0), Float64.new(2.0), Float64.new(3.0), Float64.new(4.0)]).reshape(
            Shape.new([Index.new(2), Index.new(2)])
        )
        expect(input.get_f64_at([Index.new(0), Index.new(0)]).value).to_equal(1.0)
        expect(input.get_f64_at([Index.new(1), Index.new(1)]).value).to_equal(4.0)

    it "direct make_f64_array yields readable vector":
        val input = make_f64_array([Float64.new(1.0), Float64.new(2.0), Float64.new(3.0)], Shape.new([Index.new(3)]))
        expect(input.get_f64(Index.new(0)).value).to_equal(1.0)
        expect(input.get_f64(Index.new(2)).value).to_equal(3.0)

    it "array literal argument arrives intact in [Float64] parameter":
        val first = first_value([Float64.new(1.0), Float64.new(2.0)])
        expect(first.value).to_equal(1.0)

    it "non-overloaded array_float helper yields readable vector":
        val input = array_float([Float64.new(1.0), Float64.new(2.0), Float64.new(3.0)])
        expect(input.get_f64(Index.new(0)).value).to_equal(1.0)
        expect(input.get_f64(Index.new(2)).value).to_equal(3.0)
