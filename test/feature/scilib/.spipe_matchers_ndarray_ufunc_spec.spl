# @cover src/lib/nogc_async_mut/ndarray/mod.spl 80%
"""
# NDArray Unary Ufunc Specification

**Feature IDs:** science-math-lib-set-numpy-core-ufuncs
**Plan:** doc/03_plan/agent_tasks/science_math_lib_set.md
**Design:** doc/05_design/science_math_lib_set.md

Validates the first F64 unary ufunc slice.
"""

use std.spipe.*
use std.ndarray.*


describe "NDArray unary ufuncs":
    it "computes abs over Float64 arrays":
        val out = array([Float64.new(-2.0), Float64.new(0.0), Float64.new(3.0)]).abs()
        expect out.get(Index.new(0)) == Float64.new(2.0)
        expect out.get(Index.new(1)) == Float64.new(0.0)
        expect out.get(Index.new(2)) == Float64.new(3.0)

    it "computes abs over contiguous Float64 SIMD chunks with a scalar tail":
        val out = array([
            Float64.new(-2.0),
            Float64.new(3.0),
            Float64.new(-4.0),
            Float64.new(5.0),
            Float64.new(-6.0),
            Float64.new(7.0)
        ]).abs()
        expect out.get(Index.new(0)) == Float64.new(2.0)
        expect out.get(Index.new(1)) == Float64.new(3.0)
        expect out.get(Index.new(2)) == Float64.new(4.0)
        expect out.get(Index.new(3)) == Float64.new(5.0)
        expect out.get(Index.new(4)) == Float64.new(6.0)
        expect out.get(Index.new(5)) == Float64.new(7.0)

    it "computes square over Float64 arrays":
        val out = array([Float64.new(-2.0), Float64.new(3.0)]).square()
        expect out.get(Index.new(0)) == Float64.new(4.0)
        expect out.get(Index.new(1)) == Float64.new(9.0)

    it "computes square over contiguous Float64 SIMD chunks with a scalar tail":
        val out = array([
            Float64.new(-2.0),
            Float64.new(3.0),
            Float64.new(4.0),
            Float64.new(-5.0),
            Float64.new(6.0),
            Float64.new(-7.0)
        ]).square()
        expect out.get(Index.new(0)) == Float64.new(4.0)
        expect out.get(Index.new(1)) == Float64.new(9.0)
        expect out.get(Index.new(2)) == Float64.new(16.0)
        expect out.get(Index.new(3)) == Float64.new(25.0)
        expect out.get(Index.new(4)) == Float64.new(36.0)
        expect out.get(Index.new(5)) == Float64.new(49.0)

    it "computes neg over Float64 arrays and preserves shape":
        val out = array([Float64.new(1.0), Float64.new(-4.0)]).reshape(Shape.new([Index.new(1), Index.new(2)])).neg()
        expect out.shape == Shape.new([Index.new(1), Index.new(2)])
        expect out.get_at([Index.new(0), Index.new(0)]) == Float64.new(-1.0)
        expect out.get_at([Index.new(0), Index.new(1)]) == Float64.new(4.0)

    it "computes neg over contiguous Float64 SIMD chunks with a scalar tail":
        val out = array([
            Float64.new(1.0),
            Float64.new(-2.0),
            Float64.new(3.0),
            Float64.new(-4.0),
            Float64.new(5.0),
            Float64.new(-6.0)
        ]).neg()
        expect out.get(Index.new(0)) == Float64.new(-1.0)
        expect out.get(Index.new(1)) == Float64.new(2.0)
        expect out.get(Index.new(2)) == Float64.new(-3.0)
        expect out.get(Index.new(3)) == Float64.new(4.0)
        expect out.get(Index.new(4)) == Float64.new(-5.0)
        expect out.get(Index.new(5)) == Float64.new(6.0)

    it "computes square over contiguous Float32 SIMD chunks with a scalar tail":
        val out = array_f32([
            Float32.new(-2.0),
            Float32.new(3.0),
            Float32.new(4.0),
            Float32.new(-5.0),
            Float32.new(6.0),
            Float32.new(-7.0)
        ]).square_f32()
        expect out.dtype == DType.F32
        expect out.get_f32(Index.new(0)) == Float32.new(4.0)
        expect out.get_f32(Index.new(1)) == Float32.new(9.0)
        expect out.get_f32(Index.new(2)) == Float32.new(16.0)
        expect out.get_f32(Index.new(3)) == Float32.new(25.0)
        expect out.get_f32(Index.new(4)) == Float32.new(36.0)
        expect out.get_f32(Index.new(5)) == Float32.new(49.0)

    it "computes abs over contiguous Float32 SIMD chunks with a scalar tail":
        val out = array_f32([
            Float32.new(-2.0),
            Float32.new(3.0),
            Float32.new(-4.0),
            Float32.new(5.0),
            Float32.new(-6.0),
            Float32.new(7.0)
        ]).abs_f32()
        expect out.dtype == DType.F32
        expect out.get_f32(Index.new(0)) == Float32.new(2.0)
        expect out.get_f32(Index.new(1)) == Float32.new(3.0)
        expect out.get_f32(Index.new(2)) == Float32.new(4.0)
        expect out.get_f32(Index.new(3)) == Float32.new(5.0)
        expect out.get_f32(Index.new(4)) == Float32.new(6.0)
        expect out.get_f32(Index.new(5)) == Float32.new(7.0)

    it "computes neg over contiguous Float32 SIMD chunks with a scalar tail":
        val out = array_f32([
            Float32.new(1.0),
            Float32.new(-2.0),
            Float32.new(3.0),
            Float32.new(-4.0),
            Float32.new(5.0),
            Float32.new(-6.0)
        ]).neg_f32()
        expect out.dtype == DType.F32
        expect out.get_f32(Index.new(0)) == Float32.new(-1.0)
        expect out.get_f32(Index.new(1)) == Float32.new(2.0)
        expect out.get_f32(Index.new(2)) == Float32.new(-3.0)
        expect out.get_f32(Index.new(3)) == Float32.new(4.0)
        expect out.get_f32(Index.new(4)) == Float32.new(-5.0)
        expect out.get_f32(Index.new(5)) == Float32.new(6.0)

    it "computes sqrt over Float64 arrays":
        val out = array([Float64.new(0.0), Float64.new(4.0), Float64.new(9.0)]).sqrt()
        expect out.get(Index.new(0)) == Float64.new(0.0)
        expect out.get(Index.new(1)) == Float64.new(2.0)
        expect out.get(Index.new(2)) == Float64.new(3.0)

    it "computes relu over Float64 arrays and preserves shape":
        val out = array([Float64.new(-2.0), Float64.new(0.0), Float64.new(5.0)]).reshape(Shape.new([Index.new(3), Index.new(1)])).relu()
        expect out.shape == Shape.new([Index.new(3), Index.new(1)])
        expect out.get_at([Index.new(0), Index.new(0)]) == Float64.new(0.0)
        expect out.get_at([Index.new(1), Index.new(0)]) == Float64.new(0.0)
        expect out.get_at([Index.new(2), Index.new(0)]) == Float64.new(5.0)

    it "clips Float64 arrays to inclusive bounds and preserves shape":
        val out = array([Float64.new(-2.0), Float64.new(2.0), Float64.new(9.0)]).reshape(Shape.new([Index.new(3), Index.new(1)])).clip(
            Float64.new(0.0),
            Float64.new(5.0)
        )
        expect out.shape == Shape.new([Index.new(3), Index.new(1)])
        expect out.get_at([Index.new(0), Index.new(0)]) == Float64.new(0.0)
        expect out.get_at([Index.new(1), Index.new(0)]) == Float64.new(2.0)
        expect out.get_at([Index.new(2), Index.new(0)]) == Float64.new(5.0)

    it "returns UnsupportedDType for Int64 inputs":
        val values = array_i64([Int64.new(1), Int64.new(-2)])
        expect values.try_abs().is_err() == true
        expect values.try_abs_f32().is_err() == true
        expect values.try_square().is_err() == true
        expect values.try_neg().is_err() == true
        expect values.try_sqrt().is_err() == true
        expect values.try_relu().is_err() == true
        expect values.try_clip(Float64.new(0.0), Float64.new(1.0)).is_err() == true

    it "returns errors for invalid clip bounds":
        val values = array([Float64.new(1.0)])
        expect values.try_clip(Float64.new(2.0), Float64.new(1.0)).is_err() == true


describe "NDArray where_bool":
    it "selects Float64 values by Bool mask and preserves shape":
        val mask_values = array_bool([Bool.new(true), Bool.new(false), Bool.new(true), Bool.new(false)]).reshape(Shape.new([Index.new(2), Index.new(2)]))
        val left = array([Float64.new(1.0), Float64.new(2.0), Float64.new(3.0), Float64.new(4.0)]).reshape(Shape.new([Index.new(2), Index.new(2)]))
        val right = array([Float64.new(10.0), Float64.new(20.0), Float64.new(30.0), Float64.new(40.0)]).reshape(Shape.new([Index.new(2), Index.new(2)]))
        val out = where_bool(mask_values, left, right).unwrap()
        expect out.shape == Shape.new([Index.new(2), Index.new(2)])
        expect out.get_at([Index.new(0), Index.new(0)]) == Float64.new(1.0)
        expect out.get_at([Index.new(0), Index.new(1)]) == Float64.new(20.0)
        expect out.get_at([Index.new(1), Index.new(0)]) == Float64.new(3.0)
        expect out.get_at([Index.new(1), Index.new(1)]) == Float64.new(40.0)

    it "selects Int64 values without changing dtype":
        val mask_values = array_bool([Bool.new(false), Bool.new(true)])
        val left = array_i64([Int64.new(1), Int64.new(2)])
        val right = array_i64([Int64.new(10), Int64.new(20)])
        val out = where_bool(mask_values, left, right).unwrap()
        expect out.dtype == DType.I64
        expect out.get_i64_at([Index.new(0)]) == Int64.new(10)
        expect out.get_i64_at([Index.new(1)]) == Int64.new(2)

    it "selects Bool values without changing dtype":
        val mask_values = array_bool([Bool.new(true), Bool.new(false)])
        val left = array_bool([Bool.new(true), Bool.new(true)])
        val right = array_bool([Bool.new(false), Bool.new(false)])
        val out = where_bool(mask_values, left, right).unwrap()
        expect out.get_bool_at([Index.new(0)]) == Bool.new(true)
        expect out.get_bool_at([Index.new(1)]) == Bool.new(false)

    it "returns errors for invalid mask, dtype mismatch, and shape mismatch":
        val mask_values = array_bool([Bool.new(true)])
        expect where_bool(array_i64([Int64.new(1)]), array([Float64.new(1.0)]), array([Float64.new(2.0)])).is_err() == true
        expect where_bool(mask_values, array([Float64.new(1.0)]), array_i64([Int64.new(2)])).is_err() == true
        expect where_bool(mask_values, array([Float64.new(1.0), Float64.new(2.0)]), array([Float64.new(3.0), Float64.new(4.0)])).is_err() == true