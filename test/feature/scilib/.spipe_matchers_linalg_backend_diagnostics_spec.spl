use std.linalg.*

describe "linalg backend diagnostics":
    it "reports the configured backend without requiring native libraries":
        val status = linalg_backend_status()
        if status.requested == "mock":
            expect status.selected == "mock"
            expect status.available == true
            expect status.real_native == false
        if status.requested == "cuda":
            match require_linalg_backend("cuda"):
                case Ok(required):
                    expect required.selected == "cuda"
                case Err(BackendError.BackendUnavailable(name)):
                    expect name == "cuda"
                case _:
                    expect false == true
        if status.requested == "torch" or status.requested == "pytorch":
            match require_linalg_backend(status.requested):
                case Ok(required):
                    expect required.selected == "pytorch"
                case Err(BackendError.BackendUnavailable(name)):
                    expect name == status.requested
                case _:
                    expect false == true
        if status.requested == "auto":
            expect status.selected == "scalar"
            expect status.available == true
        if status.requested == "openblas":
            match require_linalg_backend("openblas"):
                case Ok(required):
                    expect required.selected == "openblas"
                case Err(BackendError.BackendUnavailable(name)):
                    expect name == "openblas"
                case _:
                    expect false == true

    it "returns typed unavailable errors for optional accelerator backends":
        val openblas = require_linalg_backend("openblas")
        match openblas:
            case Ok(status):
                expect status.selected == "openblas"
                expect status.available == true
            case Err(BackendError.BackendUnavailable(name)):
                expect name == "openblas"
            case _:
                expect false == true

        val cuda = require_linalg_backend("cuda")
        match cuda:
            case Err(BackendError.BackendUnavailable(name)):
                expect name == "cuda"
            case _:
                expect false == true

    it "returns typed missing-symbol errors for backend symbol probes":
        val missing = check_linalg_symbol("mock", "rt_blas_dgemm", false)
        match missing:
            case Err(BackendError.MissingRuntimeSymbol(symbol)):
                expect symbol == "rt_blas_dgemm"
            case _:
                expect false == true

    it "returns typed unsupported errors for unknown backend names":
        val unknown = require_linalg_backend("not-a-backend")
        match unknown:
            case Err(BackendError.UnsupportedBackend(name)):
                expect name == "not-a-backend"
            case _:
                expect false == true