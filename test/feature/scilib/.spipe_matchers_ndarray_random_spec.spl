# @cover src/lib/nogc_async_mut/ndarray/mod.spl 80%
"""
# NDArray Random Basics Specification

**Feature IDs:** science-math-lib-set-numpy-core-random-basics
**Plan:** doc/03_plan/agent_tasks/science_math_lib_set.md

Validates deterministic random vector generation for the first NumPy-random
slice. This is not a cryptographic RNG.
"""

use std.spipe.*
use std.ndarray.*


describe "NDArray random_uniform":
    it "returns a deterministic Float64 vector for a seed":
        val a = random_uniform(Int64.new(123), Index.new(3)).unwrap()
        val b = random_uniform(Int64.new(123), Index.new(3)).unwrap()
        expect a.dtype == DType.F64
        expect a.shape == Shape.new([Index.new(3)])
        expect a.get(Index.new(0)) == b.get(Index.new(0))
        expect a.get(Index.new(1)) == b.get(Index.new(1))
        expect a.get(Index.new(2)) == b.get(Index.new(2))

    it "keeps generated values in the half-open range [0, 1)":
        val a = random_uniform(Int64.new(7), Index.new(4)).unwrap()
        expect a.min().value >= 0.0 == true
        expect a.max().value < 1.0 == true

    it "returns an error for negative counts":
        expect random_uniform(Int64.new(1), Index.new(-1)).is_err() == true
