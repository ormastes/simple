# @cover src/lib/nogc_async_mut/cuda/mod.spl 80%
"""
# CUDA Device Buffer Specification

**Feature IDs:** REQ-SCILIB-C-002, REQ-SCILIB-C-004, REQ-SCILIB-C-005, NFR-SCILIB-C-001, NFR-SCILIB-C-002

Validates explicit CUDA device-buffer allocation and transfer helpers. The test
is availability-gated: CPU-only or non-CUDA builds must report typed unavailable
codes instead of failing scalar science-lib verification.
"""

use std.spipe.*
use std.nogc_async_mut.cuda.*
use std.ndarray.*


describe "CUDA explicit device buffer transfers":
    it "round-trips host i64 values through a device buffer when CUDA is available":
        val result = CudaBuffer.allocate(16)
        if cuda_available():
            match result:
                case Ok(buffer):
                    val copied = buffer.copy_from_i64_values([11, 22])
                    match copied:
                        case Ok(bytes):
                            expect bytes == 16
                        case _:
                            expect false == true
                    val values = buffer.copy_to_i64_values(2)
                    match values:
                        case Ok(out):
                            expect out[0] == 11
                            expect out[1] == 22
                        case _:
                            expect false == true
                    expect buffer.free() == CUDA_SUCCESS
                case _:
                    expect false == true
        else:
            match result:
                case Err(code):
                    expect code < 0
                case Ok(buffer):
                    expect buffer.free() == CUDA_SUCCESS

    it "copies between device buffers without an implicit host fallback":
        val left = CudaBuffer.allocate(16)
        val right = CudaBuffer.allocate(16)
        if cuda_available():
            match left:
                case Ok(src):
                    match right:
                        case Ok(dst):
                            expect src.copy_from_i64_values([7, 9]).unwrap() == 16
                            expect src.copy_to(dst, 16).unwrap() == 16
                            val out = dst.copy_to_i64_values(2).unwrap()
                            expect out[0] == 7
                            expect out[1] == 9
                            expect src.free() == CUDA_SUCCESS
                            expect dst.free() == CUDA_SUCCESS
                        case _:
                            expect false == true
                case _:
                    expect false == true
        else:
            match left:
                case Err(code):
                    expect code < 0
                case Ok(buffer):
                    expect buffer.free() == CUDA_SUCCESS
            match right:
                case Err(code):
                    expect code < 0
                case Ok(buffer):
                    expect buffer.free() == CUDA_SUCCESS

    it "rejects invalid transfer sizes before backend execution":
        val result = CudaBuffer(ptr: 1, size: 8).copy_from_i64_values([1, 2])
        match result:
            case Err(code):
                expect code == CUDA_ERROR_INVALID_VALUE
            case _:
                expect false == true

describe "CUDA NDArray-owned storage":
    it "round-trips a Float64 host NDArray through CUDA-owned storage when available":
        val host = make_f64_array(
            [Float64.new(1.5), Float64.new(-2.25), Float64.new(3.75), Float64.new(4.5)],
            Shape.new([Index.new(2), Index.new(2)])
        )
        val result = CudaNDArray.from_f64_array(host, 0)
        if cuda_available():
            match result:
                case Ok(device_array):
                    expect device_array.shape == host.shape
                    expect device_array.dtype == DType.F64
                    expect device_array.device == Device.CUDA(index: 0)
                    val round_trip = device_array.to_host_f64().unwrap()
                    expect round_trip.shape == host.shape
                    expect round_trip.get_f64_at([Index.new(0), Index.new(0)]) == Float64.new(1.5)
                    expect round_trip.get_f64_at([Index.new(0), Index.new(1)]) == Float64.new(-2.25)
                    expect round_trip.get_f64_at([Index.new(1), Index.new(0)]) == Float64.new(3.75)
                    expect round_trip.get_f64_at([Index.new(1), Index.new(1)]) == Float64.new(4.5)
                    expect device_array.free() == CUDA_SUCCESS
                case _:
                    expect false == true
        else:
            match result:
                case Err(code):
                    expect code < 0
                case Ok(device_array):
                    expect device_array.free() == CUDA_SUCCESS

    it "rejects non-Float64 host arrays before device allocation":
        val host = make_i64_array([Int64.new(1), Int64.new(2)], Shape.new([Index.new(2)]))
        val result = CudaNDArray.from_f64_array(host, 0)
        match result:
            case Err(code):
                expect code == CUDA_ERROR_INVALID_VALUE
            case _:
                expect false == true

describe "CUDA NDArray explicit arithmetic":
    it "adds, subtracts, multiplies, and divides Float64 CUDA-owned arrays with device-side kernels":
        val left_host = make_f64_array(
            [Float64.new(8.0), Float64.new(6.0), Float64.new(4.0), Float64.new(2.0)],
            Shape.new([Index.new(4)])
        )
        val right_host = make_f64_array(
            [Float64.new(2.0), Float64.new(3.0), Float64.new(4.0), Float64.new(1.0)],
            Shape.new([Index.new(4)])
        )
        val left_result = CudaNDArray.from_f64_array(left_host, 0)
        val right_result = CudaNDArray.from_f64_array(right_host, 0)
        if cuda_available():
            match left_result:
                case Ok(left):
                    match right_result:
                        case Ok(right):
                            val added = left.add_f64(right).unwrap()
                            val subbed = left.sub_f64(right).unwrap()
                            val multiplied = left.mul_f64(right).unwrap()
                            val divided = left.div_f64(right).unwrap()
                            expect added.to_host_f64().unwrap().get_f64(Index.new(0)) == Float64.new(10.0)
                            expect added.to_host_f64().unwrap().get_f64(Index.new(3)) == Float64.new(3.0)
                            expect subbed.to_host_f64().unwrap().get_f64(Index.new(1)) == Float64.new(3.0)
                            expect multiplied.to_host_f64().unwrap().get_f64(Index.new(2)) == Float64.new(16.0)
                            expect divided.to_host_f64().unwrap().get_f64(Index.new(0)) == Float64.new(4.0)
                            expect added.device == Device.CUDA(index: 0)
                            expect added.free() == CUDA_SUCCESS
                            expect subbed.free() == CUDA_SUCCESS
                            expect multiplied.free() == CUDA_SUCCESS
                            expect divided.free() == CUDA_SUCCESS
                            expect left.free() == CUDA_SUCCESS
                            expect right.free() == CUDA_SUCCESS
                        case _:
                            expect false == true
                case _:
                    expect false == true
        else:
            match left_result:
                case Err(code):
                    expect code < 0
                case Ok(left):
                    expect left.free() == CUDA_SUCCESS
            match right_result:
                case Err(code):
                    expect code < 0
                case Ok(right):
                    expect right.free() == CUDA_SUCCESS

    it "rejects shape and device mismatches before CUDA arithmetic transfers":
        val left = CudaNDArray(
            buffer: CudaBuffer(ptr: 1, size: 8),
            shape: Shape.new([Index.new(1)]),
            dtype: DType.F64,
            device: Device.CUDA(index: 0)
        )
        val shape_mismatch = CudaNDArray(
            buffer: CudaBuffer(ptr: 1, size: 16),
            shape: Shape.new([Index.new(2)]),
            dtype: DType.F64,
            device: Device.CUDA(index: 0)
        )
        val device_mismatch = CudaNDArray(
            buffer: CudaBuffer(ptr: 1, size: 8),
            shape: Shape.new([Index.new(1)]),
            dtype: DType.F64,
            device: Device.CUDA(index: 1)
        )
        match left.add_f64(shape_mismatch):
            case Err(code):
                expect code == CUDA_ERROR_INVALID_VALUE
            case _:
                expect false == true
        match left.add_f64(device_mismatch):
            case Err(code):
                expect code == CUDA_ERROR_INVALID_VALUE
            case _:
                expect false == true

    it "applies scalar Float64 arithmetic to CUDA-owned arrays":
        val host = make_f64_array(
            [Float64.new(8.0), Float64.new(6.0), Float64.new(4.0), Float64.new(2.0)],
            Shape.new([Index.new(4)])
        )
        val result = CudaNDArray.from_f64_array(host, 0)
        if cuda_available():
            match result:
                case Ok(device_array):
                    val added = device_array.add_scalar_f64(Float64.new(2.0)).unwrap()
                    val subbed = device_array.sub_scalar_f64(Float64.new(1.0)).unwrap()
                    val multiplied = device_array.mul_scalar_f64(Float64.new(3.0)).unwrap()
                    val divided = device_array.div_scalar_f64(Float64.new(2.0)).unwrap()
                    val added_host = added.to_host_f64().unwrap()
                    val subbed_host = subbed.to_host_f64().unwrap()
                    val multiplied_host = multiplied.to_host_f64().unwrap()
                    val divided_host = divided.to_host_f64().unwrap()
                    expect added_host.get_f64(Index.new(0)) == Float64.new(10.0)
                    expect subbed_host.get_f64(Index.new(1)) == Float64.new(5.0)
                    expect multiplied_host.get_f64(Index.new(2)) == Float64.new(12.0)
                    expect divided_host.get_f64(Index.new(3)) == Float64.new(1.0)
                    expect added.free() == CUDA_SUCCESS
                    expect subbed.free() == CUDA_SUCCESS
                    expect multiplied.free() == CUDA_SUCCESS
                    expect divided.free() == CUDA_SUCCESS
                    expect device_array.free() == CUDA_SUCCESS
                case _:
                    expect false == true
        else:
            match result:
                case Err(code):
                    expect code < 0
                case Ok(device_array):
                    expect device_array.free() == CUDA_SUCCESS

    it "rejects scalar arithmetic for non-Float64 CUDA owners before backend execution":
        val ints = CudaNDArray(
            buffer: CudaBuffer(ptr: 1, size: 16),
            shape: Shape.new([Index.new(2)]),
            dtype: DType.I64,
            device: Device.CUDA(index: 0)
        )
        match ints.add_scalar_f64(Float64.new(1.0)):
            case Err(code):
                expect code == CUDA_ERROR_INVALID_VALUE
            case _:
                expect false == true

describe "CUDA NDArray explicit shape operations":
    it "reshapes, flattens, and transposes CUDA-owned Float64 arrays with device copies":
        val host = make_f64_array(
            [
                Float64.new(1.0), Float64.new(2.0), Float64.new(3.0),
                Float64.new(4.0), Float64.new(5.0), Float64.new(6.0)
            ],
            Shape.new([Index.new(2), Index.new(3)])
        )
        val result = CudaNDArray.from_f64_array(host, 0)
        if cuda_available():
            match result:
                case Ok(device_array):
                    val reshaped = device_array.reshape_f64(Shape.new([Index.new(3), Index.new(2)])).unwrap()
                    val flattened = device_array.flatten_f64().unwrap()
                    val transposed = device_array.transpose_2d_f64().unwrap()
                    val reshaped_host = reshaped.to_host_f64().unwrap()
                    val flattened_host = flattened.to_host_f64().unwrap()
                    val transposed_host = transposed.to_host_f64().unwrap()
                    expect reshaped_host.shape == Shape.new([Index.new(3), Index.new(2)])
                    expect reshaped_host.get_f64_at([Index.new(0), Index.new(0)]) == Float64.new(1.0)
                    expect reshaped_host.get_f64_at([Index.new(2), Index.new(1)]) == Float64.new(6.0)
                    expect flattened_host.shape == Shape.new([Index.new(6)])
                    expect flattened_host.get_f64(Index.new(4)) == Float64.new(5.0)
                    expect transposed_host.shape == Shape.new([Index.new(3), Index.new(2)])
                    expect transposed_host.get_f64_at([Index.new(0), Index.new(1)]) == Float64.new(4.0)
                    expect transposed_host.get_f64_at([Index.new(2), Index.new(1)]) == Float64.new(6.0)
                    expect reshaped.free() == CUDA_SUCCESS
                    expect flattened.free() == CUDA_SUCCESS
                    expect transposed.free() == CUDA_SUCCESS
                    expect device_array.free() == CUDA_SUCCESS
                case _:
                    expect false == true
        else:
            match result:
                case Err(code):
                    expect code < 0
                case Ok(device_array):
                    expect device_array.free() == CUDA_SUCCESS

    it "keeps empty CUDA-owned Float64 shape operations typed and allocation-free":
        val device_array = CudaNDArray(
            buffer: CudaBuffer(ptr: 0, size: 0),
            shape: Shape.new([Index.new(0), Index.new(3)]),
            dtype: DType.F64,
            device: Device.CUDA(index: 0)
        )
        expect device_array.buffer.ptr == 0
        expect device_array.buffer.size == 0
        match device_array.flatten_f64():
            case Ok(flattened):
                expect flattened.shape == Shape.new([Index.new(0)])
                expect flattened.to_host_f64().unwrap().len().value == 0
                expect flattened.free() == CUDA_SUCCESS
            case _:
                expect false == true
        match device_array.transpose_2d_f64():
            case Ok(transposed):
                expect transposed.shape == Shape.new([Index.new(3), Index.new(0)])
                expect transposed.to_host_f64().unwrap().len().value == 0
                expect transposed.free() == CUDA_SUCCESS
            case _:
                expect false == true
        expect device_array.free() == CUDA_SUCCESS

    it "rejects invalid CUDA reshape and transpose requests before backend execution":
        val vector = CudaNDArray(
            buffer: CudaBuffer(ptr: 1, size: 24),
            shape: Shape.new([Index.new(3)]),
            dtype: DType.F64,
            device: Device.CUDA(index: 0)
        )
        val matrix = CudaNDArray(
            buffer: CudaBuffer(ptr: 1, size: 32),
            shape: Shape.new([Index.new(2), Index.new(2)]),
            dtype: DType.I64,
            device: Device.CUDA(index: 0)
        )
        match vector.reshape_f64(Shape.new([Index.new(2), Index.new(2)])):
            case Err(code):
                expect code == CUDA_ERROR_INVALID_VALUE
            case _:
                expect false == true
        match vector.reshape_f64(Shape.new([Index.new(-3)])):
            case Err(code):
                expect code == CUDA_ERROR_INVALID_VALUE
            case _:
                expect false == true
        match vector.transpose_2d_f64():
            case Err(code):
                expect code == CUDA_ERROR_INVALID_VALUE
            case _:
                expect false == true
        match matrix.reshape_f64(Shape.new([Index.new(4)])):
            case Err(code):
                expect code == CUDA_ERROR_INVALID_VALUE
            case _:
                expect false == true

describe "CUDA NDArray explicit combine operations":
    it "concatenates and stacks one-dimensional CUDA-owned Float64 arrays with device copies":
        val left_host = make_f64_array(
            [Float64.new(1.0), Float64.new(2.0)],
            Shape.new([Index.new(2)])
        )
        val right_host = make_f64_array(
            [Float64.new(3.0), Float64.new(4.0)],
            Shape.new([Index.new(2)])
        )
        val left_result = CudaNDArray.from_f64_array(left_host, 0)
        val right_result = CudaNDArray.from_f64_array(right_host, 0)
        if cuda_available():
            match left_result:
                case Ok(left):
                    match right_result:
                        case Ok(right):
                            val concatenated = CudaNDArray.concatenate_1d_f64([left, right]).unwrap()
                            val stacked = CudaNDArray.stack_1d_f64([left, right]).unwrap()
                            val concatenated_host = concatenated.to_host_f64().unwrap()
                            val stacked_host = stacked.to_host_f64().unwrap()
                            expect concatenated_host.shape == Shape.new([Index.new(4)])
                            expect concatenated_host.get_f64(Index.new(0)) == Float64.new(1.0)
                            expect concatenated_host.get_f64(Index.new(3)) == Float64.new(4.0)
                            expect stacked_host.shape == Shape.new([Index.new(2), Index.new(2)])
                            expect stacked_host.get_f64_at([Index.new(0), Index.new(1)]) == Float64.new(2.0)
                            expect stacked_host.get_f64_at([Index.new(1), Index.new(0)]) == Float64.new(3.0)
                            expect concatenated.free() == CUDA_SUCCESS
                            expect stacked.free() == CUDA_SUCCESS
                            expect left.free() == CUDA_SUCCESS
                            expect right.free() == CUDA_SUCCESS
                        case _:
                            expect false == true
                case _:
                    expect false == true
        else:
            match left_result:
                case Err(code):
                    expect code < 0
                case Ok(left):
                    expect left.free() == CUDA_SUCCESS
            match right_result:
                case Err(code):
                    expect code < 0
                case Ok(right):
                    expect right.free() == CUDA_SUCCESS

    it "rejects invalid CUDA concatenate and stack requests before backend execution":
        val vector = CudaNDArray(
            buffer: CudaBuffer(ptr: 1, size: 16),
            shape: Shape.new([Index.new(2)]),
            dtype: DType.F64,
            device: Device.CUDA(index: 0)
        )
        val short = CudaNDArray(
            buffer: CudaBuffer(ptr: 1, size: 8),
            shape: Shape.new([Index.new(1)]),
            dtype: DType.F64,
            device: Device.CUDA(index: 0)
        )
        val matrix = CudaNDArray(
            buffer: CudaBuffer(ptr: 1, size: 32),
            shape: Shape.new([Index.new(2), Index.new(2)]),
            dtype: DType.F64,
            device: Device.CUDA(index: 0)
        )
        val other_device = CudaNDArray(
            buffer: CudaBuffer(ptr: 1, size: 16),
            shape: Shape.new([Index.new(2)]),
            dtype: DType.F64,
            device: Device.CUDA(index: 1)
        )
        match CudaNDArray.concatenate_1d_f64([]):
            case Err(code):
                expect code == CUDA_ERROR_INVALID_VALUE
            case _:
                expect false == true
        match CudaNDArray.concatenate_1d_f64([vector, matrix]):
            case Err(code):
                expect code == CUDA_ERROR_INVALID_VALUE
            case _:
                expect false == true
        match CudaNDArray.concatenate_1d_f64([vector, other_device]):
            case Err(code):
                expect code == CUDA_ERROR_INVALID_VALUE
            case _:
                expect false == true
        match CudaNDArray.stack_1d_f64([vector, short]):
            case Err(code):
                expect code == CUDA_ERROR_INVALID_VALUE
            case _:
                expect false == true

describe "CUDA NDArray explicit reductions":
    it "computes device-side Float64 scalar reductions for CUDA-owned arrays":
        val host = make_f64_array(
            [Float64.new(1.0), Float64.new(-2.0), Float64.new(3.0), Float64.new(4.0)],
            Shape.new([Index.new(4)])
        )
        val result = CudaNDArray.from_f64_array(host, 0)
        if cuda_available():
            match result:
                case Ok(device_array):
                    expect device_array.sum_f64().unwrap() == Float64.new(6.0)
                    expect device_array.mean_f64().unwrap() == Float64.new(1.5)
                    expect device_array.min_f64().unwrap() == Float64.new(-2.0)
                    expect device_array.max_f64().unwrap() == Float64.new(4.0)
                    expect device_array.free() == CUDA_SUCCESS
                case _:
                    expect false == true
        else:
            match result:
                case Err(code):
                    expect code < 0
                case Ok(device_array):
                    expect device_array.free() == CUDA_SUCCESS

    it "rejects empty CUDA mean/min/max before transfer":
        val empty = CudaNDArray(
            buffer: CudaBuffer(ptr: 1, size: 0),
            shape: Shape.new([Index.new(0)]),
            dtype: DType.F64,
            device: Device.CUDA(index: 0)
        )
        match empty.mean_f64():
            case Err(code):
                expect code == CUDA_ERROR_INVALID_VALUE
            case _:
                expect false == true
        match empty.min_f64():
            case Err(code):
                expect code == CUDA_ERROR_INVALID_VALUE
            case _:
                expect false == true
        match empty.max_f64():
            case Err(code):
                expect code == CUDA_ERROR_INVALID_VALUE
            case _:
                expect false == true

    it "computes device-side Float64 axis sums and means for two-dimensional CUDA-owned arrays":
        val host = make_f64_array(
            [
                Float64.new(1.0), Float64.new(2.0), Float64.new(3.0),
                Float64.new(4.0), Float64.new(5.0), Float64.new(6.0)
            ],
            Shape.new([Index.new(2), Index.new(3)])
        )
        val result = CudaNDArray.from_f64_array(host, 0)
        if cuda_available():
            match result:
                case Ok(device_array):
                    val axis0 = device_array.sum_axis_f64(Axis.new(0)).unwrap()
                    val axis1 = device_array.sum_axis_f64(Axis.new(1)).unwrap()
                    val axis_neg = device_array.sum_axis_f64(Axis.new(-1)).unwrap()
                    val mean0 = device_array.mean_axis_f64(Axis.new(0)).unwrap()
                    val mean1 = device_array.mean_axis_f64(Axis.new(1)).unwrap()
                    val axis0_host = axis0.to_host_f64().unwrap()
                    val axis1_host = axis1.to_host_f64().unwrap()
                    val axis_neg_host = axis_neg.to_host_f64().unwrap()
                    val mean0_host = mean0.to_host_f64().unwrap()
                    val mean1_host = mean1.to_host_f64().unwrap()
                    expect axis0_host.shape == Shape.new([Index.new(3)])
                    expect axis0_host.get_f64(Index.new(0)) == Float64.new(5.0)
                    expect axis0_host.get_f64(Index.new(1)) == Float64.new(7.0)
                    expect axis0_host.get_f64(Index.new(2)) == Float64.new(9.0)
                    expect axis1_host.shape == Shape.new([Index.new(2)])
                    expect axis1_host.get_f64(Index.new(0)) == Float64.new(6.0)
                    expect axis1_host.get_f64(Index.new(1)) == Float64.new(15.0)
                    expect axis_neg_host.get_f64(Index.new(1)) == Float64.new(15.0)
                    expect mean0_host.get_f64(Index.new(0)) == Float64.new(2.5)
                    expect mean0_host.get_f64(Index.new(2)) == Float64.new(4.5)
                    expect mean1_host.get_f64(Index.new(0)) == Float64.new(2.0)
                    expect mean1_host.get_f64(Index.new(1)) == Float64.new(5.0)
                    expect axis0.free() == CUDA_SUCCESS
                    expect axis1.free() == CUDA_SUCCESS
                    expect axis_neg.free() == CUDA_SUCCESS
                    expect mean0.free() == CUDA_SUCCESS
                    expect mean1.free() == CUDA_SUCCESS
                    expect device_array.free() == CUDA_SUCCESS
                case _:
                    expect false == true
        else:
            match result:
                case Err(code):
                    expect code < 0
                case Ok(device_array):
                    expect device_array.free() == CUDA_SUCCESS

    it "rejects invalid CUDA axis reductions before backend execution":
        val vector = CudaNDArray(
            buffer: CudaBuffer(ptr: 1, size: 16),
            shape: Shape.new([Index.new(2)]),
            dtype: DType.F64,
            device: Device.CUDA(index: 0)
        )
        val matrix = CudaNDArray(
            buffer: CudaBuffer(ptr: 1, size: 32),
            shape: Shape.new([Index.new(2), Index.new(2)]),
            dtype: DType.F64,
            device: Device.CUDA(index: 0)
        )
        match vector.sum_axis_f64(Axis.new(0)):
            case Err(code):
                expect code == CUDA_ERROR_INVALID_VALUE
            case _:
                expect false == true
        match matrix.sum_axis_f64(Axis.new(2)):
            case Err(code):
                expect code == CUDA_ERROR_INVALID_VALUE
            case _:
                expect false == true
        match matrix.mean_axis_f64(Axis.new(2)):
            case Err(code):
                expect code == CUDA_ERROR_INVALID_VALUE
            case _:
                expect false == true

describe "CUDA NDArray explicit slicing":
    it "slices one-dimensional and two-dimensional CUDA-owned Float64 arrays":
        val vector_host = make_f64_array(
            [Float64.new(1.0), Float64.new(2.0), Float64.new(3.0), Float64.new(4.0)],
            Shape.new([Index.new(4)])
        )
        val matrix_host = make_f64_array(
            [
                Float64.new(1.0), Float64.new(2.0), Float64.new(3.0),
                Float64.new(4.0), Float64.new(5.0), Float64.new(6.0),
                Float64.new(7.0), Float64.new(8.0), Float64.new(9.0)
            ],
            Shape.new([Index.new(3), Index.new(3)])
        )
        val vector_result = CudaNDArray.from_f64_array(vector_host, 0)
        val matrix_result = CudaNDArray.from_f64_array(matrix_host, 0)
        if cuda_available():
            match vector_result:
                case Ok(vector):
                    match matrix_result:
                        case Ok(matrix):
                            val contiguous_vector_slice = vector.slice_1d_f64(Slice.new(Index.new(1), Index.new(3), Index.new(1))).unwrap()
                            val strided_vector_slice = vector.slice_1d_f64(Slice.new(Index.new(1), Index.new(4), Index.new(2))).unwrap()
                            val negative_vector_slice = vector.slice_1d_f64(Slice.new(Index.new(-3), Index.new(-1), Index.new(1))).unwrap()
                            val negative_strided_vector_slice = vector.slice_1d_f64(Slice.new(Index.new(-4), Index.new(4), Index.new(2))).unwrap()
                            val reverse_vector_slice = vector.slice_1d_f64(Slice.new(Index.new(3), Index.new(0), Index.new(-1))).unwrap()
                            val matrix_slice = matrix.slice_2d_f64(
                                Slice.new(Index.new(0), Index.new(2), Index.new(1)),
                                Slice.new(Index.new(1), Index.new(3), Index.new(1))
                            ).unwrap()
                            val strided_matrix_slice = matrix.slice_2d_f64(
                                Slice.new(Index.new(0), Index.new(3), Index.new(2)),
                                Slice.new(Index.new(0), Index.new(3), Index.new(2))
                            ).unwrap()
                            val negative_matrix_slice = matrix.slice_2d_f64(
                                Slice.new(Index.new(-2), Index.new(3), Index.new(1)),
                                Slice.new(Index.new(-2), Index.new(3), Index.new(1))
                            ).unwrap()
                            val negative_strided_matrix_slice = matrix.slice_2d_f64(
                                Slice.new(Index.new(-3), Index.new(3), Index.new(2)),
                                Slice.new(Index.new(-3), Index.new(3), Index.new(2))
                            ).unwrap()
                            val reverse_matrix_slice = matrix.slice_2d_f64(
                                Slice.new(Index.new(2), Index.new(0), Index.new(-1)),
                                Slice.new(Index.new(2), Index.new(0), Index.new(-1))
                            ).unwrap()
                            val empty_vector_slice = vector.slice_1d_f64(Slice.new(Index.new(2), Index.new(2), Index.new(1))).unwrap()
                            val empty_row_matrix_slice = matrix.slice_2d_f64(
                                Slice.new(Index.new(1), Index.new(1), Index.new(1)),
                                Slice.new(Index.new(0), Index.new(2), Index.new(1))
                            ).unwrap()
                            val empty_col_matrix_slice = matrix.slice_2d_f64(
                                Slice.new(Index.new(0), Index.new(2), Index.new(1)),
                                Slice.new(Index.new(2), Index.new(2), Index.new(1))
                            ).unwrap()
                            val contiguous_host_slice = contiguous_vector_slice.to_host_f64().unwrap()
                            val strided_host_slice = strided_vector_slice.to_host_f64().unwrap()
                            val negative_host_slice = negative_vector_slice.to_host_f64().unwrap()
                            val negative_strided_host_slice = negative_strided_vector_slice.to_host_f64().unwrap()
                            val reverse_host_slice = reverse_vector_slice.to_host_f64().unwrap()
                            val matrix_host_slice = matrix_slice.to_host_f64().unwrap()
                            val strided_matrix_host_slice = strided_matrix_slice.to_host_f64().unwrap()
                            val negative_matrix_host_slice = negative_matrix_slice.to_host_f64().unwrap()
                            val negative_strided_matrix_host_slice = negative_strided_matrix_slice.to_host_f64().unwrap()
                            val reverse_matrix_host_slice = reverse_matrix_slice.to_host_f64().unwrap()
                            val empty_host_slice = empty_vector_slice.to_host_f64().unwrap()
                            val empty_row_host_slice = empty_row_matrix_slice.to_host_f64().unwrap()
                            val empty_col_host_slice = empty_col_matrix_slice.to_host_f64().unwrap()
                            expect contiguous_host_slice.shape == Shape.new([Index.new(2)])
                            expect contiguous_host_slice.get_f64(Index.new(0)) == Float64.new(2.0)
                            expect contiguous_host_slice.get_f64(Index.new(1)) == Float64.new(3.0)
                            expect strided_host_slice.shape == Shape.new([Index.new(2)])
                            expect strided_host_slice.get_f64(Index.new(0)) == Float64.new(2.0)
                            expect strided_host_slice.get_f64(Index.new(1)) == Float64.new(4.0)
                            expect negative_host_slice.shape == Shape.new([Index.new(2)])
                            expect negative_host_slice.get_f64(Index.new(0)) == Float64.new(2.0)
                            expect negative_host_slice.get_f64(Index.new(1)) == Float64.new(3.0)
                            expect negative_strided_host_slice.shape == Shape.new([Index.new(2)])
                            expect negative_strided_host_slice.get_f64(Index.new(0)) == Float64.new(1.0)
                            expect negative_strided_host_slice.get_f64(Index.new(1)) == Float64.new(3.0)
                            expect reverse_host_slice.shape == Shape.new([Index.new(3)])
                            expect reverse_host_slice.get_f64(Index.new(0)) == Float64.new(4.0)
                            expect reverse_host_slice.get_f64(Index.new(1)) == Float64.new(3.0)
                            expect reverse_host_slice.get_f64(Index.new(2)) == Float64.new(2.0)
                            expect matrix_host_slice.shape == Shape.new([Index.new(2), Index.new(2)])
                            expect matrix_host_slice.get_f64_at([Index.new(0), Index.new(0)]) == Float64.new(2.0)
                            expect matrix_host_slice.get_f64_at([Index.new(1), Index.new(1)]) == Float64.new(6.0)
                            expect strided_matrix_host_slice.shape == Shape.new([Index.new(2), Index.new(2)])
                            expect strided_matrix_host_slice.get_f64_at([Index.new(0), Index.new(0)]) == Float64.new(1.0)
                            expect strided_matrix_host_slice.get_f64_at([Index.new(1), Index.new(1)]) == Float64.new(9.0)
                            expect negative_matrix_host_slice.shape == Shape.new([Index.new(2), Index.new(2)])
                            expect negative_matrix_host_slice.get_f64_at([Index.new(0), Index.new(0)]) == Float64.new(5.0)
                            expect negative_matrix_host_slice.get_f64_at([Index.new(1), Index.new(1)]) == Float64.new(9.0)
                            expect negative_strided_matrix_host_slice.shape == Shape.new([Index.new(2), Index.new(2)])
                            expect negative_strided_matrix_host_slice.get_f64_at([Index.new(0), Index.new(0)]) == Float64.new(1.0)
                            expect negative_strided_matrix_host_slice.get_f64_at([Index.new(1), Index.new(1)]) == Float64.new(9.0)
                            expect reverse_matrix_host_slice.shape == Shape.new([Index.new(2), Index.new(2)])
                            expect reverse_matrix_host_slice.get_f64_at([Index.new(0), Index.new(0)]) == Float64.new(9.0)
                            expect reverse_matrix_host_slice.get_f64_at([Index.new(1), Index.new(1)]) == Float64.new(5.0)
                            expect empty_host_slice.shape == Shape.new([Index.new(0)])
                            expect empty_host_slice.len().value == 0
                            expect empty_row_host_slice.shape == Shape.new([Index.new(0), Index.new(2)])
                            expect empty_row_host_slice.len().value == 0
                            expect empty_col_host_slice.shape == Shape.new([Index.new(2), Index.new(0)])
                            expect empty_col_host_slice.len().value == 0
                            expect contiguous_vector_slice.free() == CUDA_SUCCESS
                            expect strided_vector_slice.free() == CUDA_SUCCESS
                            expect negative_vector_slice.free() == CUDA_SUCCESS
                            expect negative_strided_vector_slice.free() == CUDA_SUCCESS
                            expect reverse_vector_slice.free() == CUDA_SUCCESS
                            expect matrix_slice.free() == CUDA_SUCCESS
                            expect strided_matrix_slice.free() == CUDA_SUCCESS
                            expect negative_matrix_slice.free() == CUDA_SUCCESS
                            expect negative_strided_matrix_slice.free() == CUDA_SUCCESS
                            expect reverse_matrix_slice.free() == CUDA_SUCCESS
                            expect empty_vector_slice.free() == CUDA_SUCCESS
                            expect empty_row_matrix_slice.free() == CUDA_SUCCESS
                            expect empty_col_matrix_slice.free() == CUDA_SUCCESS
                            expect vector.free() == CUDA_SUCCESS
                            expect matrix.free() == CUDA_SUCCESS
                        case _:
                            expect false == true
                case _:
                    expect false == true
        else:
            match vector_result:
                case Err(code):
                    expect code < 0
                case Ok(vector):
                    expect vector.free() == CUDA_SUCCESS
            match matrix_result:
                case Err(code):
                    expect code < 0
                case Ok(matrix):
                    expect matrix.free() == CUDA_SUCCESS

    it "rejects invalid CUDA slice requests before transfer":
        val vector = CudaNDArray(
            buffer: CudaBuffer(ptr: 1, size: 32),
            shape: Shape.new([Index.new(4)]),
            dtype: DType.F64,
            device: Device.CUDA(index: 0)
        )
        val matrix = CudaNDArray(
            buffer: CudaBuffer(ptr: 1, size: 32),
            shape: Shape.new([Index.new(2), Index.new(2)]),
            dtype: DType.F64,
            device: Device.CUDA(index: 0)
        )
        match vector.slice_1d_f64(Slice.new(Index.new(0), Index.new(4), Index.new(0))):
            case Err(code):
                expect code == CUDA_ERROR_INVALID_VALUE
            case _:
                expect false == true
        match matrix.slice_2d_f64(
            Slice.new(Index.new(0), Index.new(3), Index.new(1)),
            Slice.new(Index.new(0), Index.new(2), Index.new(1))
        ):
            case Err(code):
                expect code == CUDA_ERROR_INVALID_VALUE
            case _:
                expect false == true