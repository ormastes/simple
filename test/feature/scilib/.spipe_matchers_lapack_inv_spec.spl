# @cover src/lib/nogc_async_mut/linalg/mod.spl 80%
"""
# LAPACK inv / inverse Specification

**Feature IDs:** scilib-lapack-inv
**Plan:** doc/03_plan/agent_tasks/science_math_lib_set.md
**Design:** doc/05_design/science_math_lib_set.md

Validates the public inverse operation used by the planned math-block and
Fortran-compatible linalg surfaces.
"""

use std.spipe.*
use std.linalg.*
use std.ndarray.*


describe "linalg.inv":
    it "returns identity for identity input":
        val a = eye_matrix(Index.new(3))
        val result = inv(a).unwrap()
        expect result.rows() == Index.new(3)
        expect result.cols() == Index.new(3)
        expect result.get_f64_at([Index.new(0), Index.new(0)]) == Float64.new(1.0)
        expect result.get_f64_at([Index.new(1), Index.new(1)]) == Float64.new(1.0)
        expect result.get_f64_at([Index.new(2), Index.new(2)]) == Float64.new(1.0)

    it "inverts a 2x2 matrix with integer-exact inverse":
        val a = matrix_from_rows([
            [Float64.new(2.0), Float64.new(0.0)],
            [Float64.new(0.0), Float64.new(4.0)]])
        val result = inv(a).unwrap()
        expect result.get_f64_at([Index.new(0), Index.new(0)]) == Float64.new(0.5)
        expect result.get_f64_at([Index.new(0), Index.new(1)]) == Float64.new(0.0)
        expect result.get_f64_at([Index.new(1), Index.new(0)]) == Float64.new(0.0)
        expect result.get_f64_at([Index.new(1), Index.new(1)]) == Float64.new(0.25)

    it "returns errors for non-square and singular matrices":
        val non_square = matrix_from_rows([
            [Float64.new(1.0), Float64.new(2.0), Float64.new(3.0)],
            [Float64.new(4.0), Float64.new(5.0), Float64.new(6.0)]])
        val singular = matrix_from_rows([
            [Float64.new(1.0), Float64.new(2.0)],
            [Float64.new(2.0), Float64.new(4.0)]])
        expect inv(non_square).is_err() == true
        expect inv(singular).is_err() == true
