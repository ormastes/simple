# @cover src/lib/nogc_sync_mut/ndarray/broadcast.spl 80%
"""
# NDArray Broadcasting Specification

**Feature IDs:** scilib-ndarray-broadcast
**Category:** Stdlib
**Difficulty:** 4/5
**Status:** Draft
**Plan:** doc/03_plan/agent_tasks/scilib_port_ndarray.md
**Design:** doc/05_design/scilib_port_architecture.md
**Research:** doc/01_research/scilib_fortran_port/02_python_api_surface.md

## Overview

NumPy-style broadcasting for binary ufuncs. Broadcasting is the GATING
SUBSTRATE for all 9 NumPy ufuncs (per Phase 2 finding) — every elementwise
op routes through the same shape-resolution rules.

Tasks covered: T-NDARRAY-16 (broadcast engine), T-NDARRAY-17 (binary
ufunc dispatch).

## Broadcasting rules (NumPy parity)

Two shapes are compatible iff, when right-aligned, every dim pair is
either (a) equal or (b) one of them is 1. Resulting shape takes the max
of each dim pair.

Examples:
- `(2,1) + (1,3) → (2,3)`
- `(3,)  + scalar → (3,)`
- `(2,3) + (3,)   → (2,3)` (vector broadcast across rows)
- `(2,3) + (2,)   → ERROR` (right-align: 3 vs 2 mismatch)

## Implementation Notes

`broadcast_shapes(s1, s2)` is a pure function on Shape — no allocation;
must run unmodified in interp mode (no PERF-SUGAR gate).
The actual elementwise op DOES allocate (T-PERFSUGAR-01 gate applies to the
ufunc, not to the shape resolver).
"""

use std.spipe.*
use std.ndarray.*


# ============================================================================
# Test Group 1: Pure shape-resolution
# ============================================================================

describe "Broadcasting shape resolution":
    """
    ## broadcast_shapes(s1, s2) -> Result<Shape, NdarrayError>

    Pure shape function — does not depend on element data.
    """

    context "compatible shapes":
        it "(2,1) and (1,3) -> (2,3)":
            val r = broadcast_shapes(Shape.new([Index.new(2), Index.new(1)]),
                                     Shape.new([Index.new(1), Index.new(3)]))
            expect r.unwrap() == Shape.new([Index.new(2), Index.new(3)])

        it "(2,3) and (3,) -> (2,3) (right-align)":
            val r = broadcast_shapes(Shape.new([Index.new(2), Index.new(3)]),
                                     Shape.new([Index.new(3)]))
            expect r.unwrap() == Shape.new([Index.new(2), Index.new(3)])

        it "(3,) and scalar -> (3,)":
            val r = broadcast_shapes(Shape.new([Index.new(3)]), Shape.new([]))
            expect r.unwrap() == Shape.new([Index.new(3)])

        it "is symmetric: broadcast_shapes(a,b) == broadcast_shapes(b,a)":
            val ab = broadcast_shapes(Shape.new([Index.new(2), Index.new(1)]),
                                      Shape.new([Index.new(1), Index.new(3)])).unwrap()
            val ba = broadcast_shapes(Shape.new([Index.new(1), Index.new(3)]),
                                      Shape.new([Index.new(2), Index.new(1)])).unwrap()
            expect ab == ba

    context "incompatible shapes":
        it "(2,3) and (2,) -> error (right-align: 3 vs 2 mismatch)":
            val r = broadcast_shapes(Shape.new([Index.new(2), Index.new(3)]),
                                     Shape.new([Index.new(2)]))
            expect r.is_err() == true

        it "(4,) and (3,) -> error":
            val r = broadcast_shapes(Shape.new([Index.new(4)]),
                                     Shape.new([Index.new(3)]))
            expect r.is_err() == true


# ============================================================================
# Test Group 2: Elementwise add — broadcast in action
# ============================================================================

describe "Broadcasting in binary add":
    """
    ## a + b under broadcasting

    Asserts numerical correctness on the small canonical cases —
    every numpy ufunc lowers to this same dispatch.
    """

    it "(2,1) + (1,3) produces a (2,3) outer-sum":
        # a = [[1],[2]]   b = [[10,20,30]]
        # expected:
        #   [[11,21,31],
        #    [12,22,32]]
        val a = array([Float64.new(1.0), Float64.new(2.0)]).reshape(
                    Shape.new([Index.new(2), Index.new(1)]))
        val b = array([Float64.new(10.0), Float64.new(20.0), Float64.new(30.0)]).reshape(
                    Shape.new([Index.new(1), Index.new(3)]))
        val r = a.add(b)
        expect r.shape == Shape.new([Index.new(2), Index.new(3)])
        expect r.get_at([Index.new(0), Index.new(0)]) == Float64.new(11.0)
        expect r.get_at([Index.new(0), Index.new(2)]) == Float64.new(31.0)
        expect r.get_at([Index.new(1), Index.new(0)]) == Float64.new(12.0)
        expect r.get_at([Index.new(1), Index.new(2)]) == Float64.new(32.0)

    it "(2,3) + (3,) broadcasts the vector across rows":
        # a = [[1,2,3],[4,5,6]]    b = [10,20,30]
        # expected:
        #   [[11,22,33],
        #    [14,25,36]]
        val a = array([Float64.new(1.0), Float64.new(2.0), Float64.new(3.0),
                       Float64.new(4.0), Float64.new(5.0), Float64.new(6.0)]
                     ).reshape(Shape.new([Index.new(2), Index.new(3)]))
        val b = array([Float64.new(10.0), Float64.new(20.0), Float64.new(30.0)])
        val r = a.add(b)
        expect r.shape == Shape.new([Index.new(2), Index.new(3)])
        expect r.get_at([Index.new(0), Index.new(0)]) == Float64.new(11.0)
        expect r.get_at([Index.new(0), Index.new(2)]) == Float64.new(33.0)
        expect r.get_at([Index.new(1), Index.new(2)]) == Float64.new(36.0)

    it "computes exact-shape four-lane F64 add":
        val a = array([Float64.new(1.0), Float64.new(-2.0), Float64.new(3.5), Float64.new(8.0)])
        val b = array([Float64.new(10.0), Float64.new(4.0), Float64.new(-1.5), Float64.new(0.25)])
        val r = a.add(b)
        expect r.shape == Shape.new([Index.new(4)])
        expect r.get(Index.new(0)) == Float64.new(11.0)
        expect r.get(Index.new(1)) == Float64.new(2.0)
        expect r.get(Index.new(2)) == Float64.new(2.0)
        expect r.get(Index.new(3)) == Float64.new(8.25)

    it "computes exact-shape four-lane F64 multiply":
        val a = array([Float64.new(2.0), Float64.new(-3.0), Float64.new(0.5), Float64.new(8.0)])
        val b = array([Float64.new(4.0), Float64.new(5.0), Float64.new(-6.0), Float64.new(0.25)])
        val r = a.mul(b)
        expect r.shape == Shape.new([Index.new(4)])
        expect r.get(Index.new(0)) == Float64.new(8.0)
        expect r.get(Index.new(1)) == Float64.new(-15.0)
        expect r.get(Index.new(2)) == Float64.new(-3.0)
        expect r.get(Index.new(3)) == Float64.new(2.0)

    it "computes exact-shape four-lane F64 subtract":
        val a = array([Float64.new(10.0), Float64.new(-2.0), Float64.new(3.5), Float64.new(8.0)])
        val b = array([Float64.new(1.0), Float64.new(4.0), Float64.new(-1.5), Float64.new(0.25)])
        val r = a.sub(b)
        expect r.shape == Shape.new([Index.new(4)])
        expect r.get(Index.new(0)) == Float64.new(9.0)
        expect r.get(Index.new(1)) == Float64.new(-6.0)
        expect r.get(Index.new(2)) == Float64.new(5.0)
        expect r.get(Index.new(3)) == Float64.new(7.75)

    it "computes exact-shape four-lane F64 divide":
        val a = array([Float64.new(8.0), Float64.new(-15.0), Float64.new(3.0), Float64.new(2.0)])
        val b = array([Float64.new(4.0), Float64.new(5.0), Float64.new(-6.0), Float64.new(0.25)])
        val r = a.div(b)
        expect r.shape == Shape.new([Index.new(4)])
        expect r.get(Index.new(0)) == Float64.new(2.0)
        expect r.get(Index.new(1)) == Float64.new(-3.0)
        expect r.get(Index.new(2)) == Float64.new(-0.5)
        expect r.get(Index.new(3)) == Float64.new(8.0)

    it "computes exact-shape four-lane F32 add":
        val a = array_f32([Float32.new(1.0), Float32.new(-2.0), Float32.new(3.5), Float32.new(8.0)])
        val b = array_f32([Float32.new(10.0), Float32.new(4.0), Float32.new(-1.5), Float32.new(0.25)])
        val r = a.add(b)
        expect r.dtype == DType.F32
        expect r.shape == Shape.new([Index.new(4)])
        expect r.get(Index.new(0)) == Float32.new(11.0)
        expect r.get(Index.new(1)) == Float32.new(2.0)
        expect r.get(Index.new(2)) == Float32.new(2.0)
        expect r.get(Index.new(3)) == Float32.new(8.25)

    it "computes exact-shape four-lane F32 multiply":
        val a = array_f32([Float32.new(2.0), Float32.new(-3.0), Float32.new(0.5), Float32.new(8.0)])
        val b = array_f32([Float32.new(4.0), Float32.new(5.0), Float32.new(-6.0), Float32.new(0.25)])
        val r = a.mul(b)
        expect r.dtype == DType.F32
        expect r.shape == Shape.new([Index.new(4)])
        expect r.get(Index.new(0)) == Float32.new(8.0)
        expect r.get(Index.new(1)) == Float32.new(-15.0)
        expect r.get(Index.new(2)) == Float32.new(-3.0)
        expect r.get(Index.new(3)) == Float32.new(2.0)

    it "computes exact-shape four-lane F32 subtract":
        val a = array_f32([Float32.new(10.0), Float32.new(-2.0), Float32.new(3.5), Float32.new(8.0)])
        val b = array_f32([Float32.new(1.0), Float32.new(4.0), Float32.new(-1.5), Float32.new(0.25)])
        val r = a.sub(b)
        expect r.dtype == DType.F32
        expect r.shape == Shape.new([Index.new(4)])
        expect r.get(Index.new(0)) == Float32.new(9.0)
        expect r.get(Index.new(1)) == Float32.new(-6.0)
        expect r.get(Index.new(2)) == Float32.new(5.0)
        expect r.get(Index.new(3)) == Float32.new(7.75)

    it "computes exact-shape four-lane F32 divide":
        val a = array_f32([Float32.new(8.0), Float32.new(-15.0), Float32.new(3.0), Float32.new(2.0)])
        val b = array_f32([Float32.new(4.0), Float32.new(5.0), Float32.new(-6.0), Float32.new(0.25)])
        val r = a.div(b)
        expect r.dtype == DType.F32
        expect r.shape == Shape.new([Index.new(4)])
        expect r.get(Index.new(0)) == Float32.new(2.0)
        expect r.get(Index.new(1)) == Float32.new(-3.0)
        expect r.get(Index.new(2)) == Float32.new(-0.5)
        expect r.get(Index.new(3)) == Float32.new(8.0)

    it "broadcasts F32 vectors through scalar fallback semantics":
        val a = array_f32([Float32.new(1.0), Float32.new(2.0), Float32.new(3.0),
                           Float32.new(4.0), Float32.new(5.0), Float32.new(6.0)]
                         ).reshape(Shape.new([Index.new(2), Index.new(3)]))
        val b = array_f32([Float32.new(10.0), Float32.new(20.0), Float32.new(30.0)])
        val r = a.add(b)
        expect r.dtype == DType.F32
        expect r.shape == Shape.new([Index.new(2), Index.new(3)])
        expect r.get_at([Index.new(0), Index.new(0)]) == Float32.new(11.0)
        expect r.get_at([Index.new(0), Index.new(2)]) == Float32.new(33.0)
        expect r.get_at([Index.new(1), Index.new(2)]) == Float32.new(36.0)

    it "uses SIMD chunking plus scalar tail for longer F64 vectors":
        val a = array([Float64.new(1.0), Float64.new(2.0), Float64.new(3.0),
                       Float64.new(4.0), Float64.new(5.0), Float64.new(6.0)])
        val b = array([Float64.new(10.0), Float64.new(20.0), Float64.new(30.0),
                       Float64.new(40.0), Float64.new(50.0), Float64.new(60.0)])
        val r = a.add(b)
        expect r.shape == Shape.new([Index.new(6)])
        expect r.get(Index.new(0)) == Float64.new(11.0)
        expect r.get(Index.new(3)) == Float64.new(44.0)
        expect r.get(Index.new(4)) == Float64.new(55.0)
        expect r.get(Index.new(5)) == Float64.new(66.0)

    it "uses SIMD chunking plus scalar tail for longer F32 vectors":
        val a = array_f32([Float32.new(1.0), Float32.new(2.0), Float32.new(3.0),
                           Float32.new(4.0), Float32.new(5.0), Float32.new(6.0)])
        val b = array_f32([Float32.new(10.0), Float32.new(20.0), Float32.new(30.0),
                           Float32.new(40.0), Float32.new(50.0), Float32.new(60.0)])
        val r = a.add(b)
        expect r.dtype == DType.F32
        expect r.shape == Shape.new([Index.new(6)])
        expect r.get(Index.new(0)) == Float32.new(11.0)
        expect r.get(Index.new(3)) == Float32.new(44.0)
        expect r.get(Index.new(4)) == Float32.new(55.0)
        expect r.get(Index.new(5)) == Float32.new(66.0)


# ============================================================================
# Test Group 3: Scalar broadcast
# ============================================================================

describe "Scalar broadcast":
    """
    ## a + scalar

    A typed Float64 scalar broadcasts to every element of `a`.
    """

    it "(3,) + Float64.new(5.0) adds 5 to each element":
        val a = array([Float64.new(1.0), Float64.new(2.0), Float64.new(3.0)])
        val r = a.add_scalar(Float64.new(5.0))
        expect r.len() == Index.new(3)
        expect r.get(Index.new(0)) == Float64.new(6.0)
        expect r.get(Index.new(1)) == Float64.new(7.0)
        expect r.get(Index.new(2)) == Float64.new(8.0)

    it "(2,2) * Float64.new(2.0) doubles each element":
        val a = array([Float64.new(1.0), Float64.new(2.0),
                       Float64.new(3.0), Float64.new(4.0)]
                     ).reshape(Shape.new([Index.new(2), Index.new(2)]))
        val r = a.mul_scalar(Float64.new(2.0))
        expect r.get_at([Index.new(0), Index.new(0)]) == Float64.new(2.0)
        expect r.get_at([Index.new(1), Index.new(1)]) == Float64.new(8.0)

    it "uses SIMD chunks plus scalar tail for one-dimensional Float64 scalar arithmetic":
        val a = array([
            Float64.new(2.0),
            Float64.new(4.0),
            Float64.new(6.0),
            Float64.new(8.0),
            Float64.new(10.0),
            Float64.new(12.0)
        ])
        val added = a.add_scalar(Float64.new(1.5))
        val subbed = a.sub_scalar(Float64.new(1.0))
        val multiplied = a.mul_scalar(Float64.new(2.0))
        val divided = a.div_scalar(Float64.new(2.0))
        expect added.get(Index.new(0)) == Float64.new(3.5)
        expect added.get(Index.new(5)) == Float64.new(13.5)
        expect subbed.get(Index.new(0)) == Float64.new(1.0)
        expect subbed.get(Index.new(5)) == Float64.new(11.0)
        expect multiplied.get(Index.new(0)) == Float64.new(4.0)
        expect multiplied.get(Index.new(5)) == Float64.new(24.0)
        expect divided.get(Index.new(0)) == Float64.new(1.0)
        expect divided.get(Index.new(5)) == Float64.new(6.0)

    it "uses SIMD chunks plus scalar tail for one-dimensional Float32 scalar add":
        val a = array_f32([
            Float32.new(2.0),
            Float32.new(4.0),
            Float32.new(6.0),
            Float32.new(8.0),
            Float32.new(10.0),
            Float32.new(12.0)
        ])
        val added = a.add_scalar_f32(Float32.new(1.5))
        expect added.dtype == DType.F32
        expect added.get_f32(Index.new(0)) == Float32.new(3.5)
        expect added.get_f32(Index.new(5)) == Float32.new(13.5)

    it "uses SIMD chunks plus scalar tail for one-dimensional Float32 scalar sub":
        val a = array_f32([
            Float32.new(2.0),
            Float32.new(4.0),
            Float32.new(6.0),
            Float32.new(8.0),
            Float32.new(10.0),
            Float32.new(12.0)
        ])
        val subbed = a.sub_scalar_f32(Float32.new(1.0))
        expect subbed.get_f32(Index.new(0)) == Float32.new(1.0)
        expect subbed.get_f32(Index.new(5)) == Float32.new(11.0)

    it "uses SIMD chunks plus scalar tail for one-dimensional Float32 scalar mul":
        val a = array_f32([
            Float32.new(2.0),
            Float32.new(4.0),
            Float32.new(6.0),
            Float32.new(8.0),
            Float32.new(10.0),
            Float32.new(12.0)
        ])
        val multiplied = a.mul_scalar_f32(Float32.new(2.0))
        expect multiplied.get_f32(Index.new(0)) == Float32.new(4.0)
        expect multiplied.get_f32(Index.new(5)) == Float32.new(24.0)

    it "uses SIMD chunks plus scalar tail for one-dimensional Float32 scalar div":
        val a = array_f32([
            Float32.new(2.0),
            Float32.new(4.0),
            Float32.new(6.0),
            Float32.new(8.0),
            Float32.new(10.0),
            Float32.new(12.0)
        ])
        val divided = a.div_scalar_f32(Float32.new(2.0))
        expect divided.get_f32(Index.new(0)) == Float32.new(1.0)
        expect divided.get_f32(Index.new(5)) == Float32.new(6.0)

    it "rejects Float32 scalar arithmetic on non-Float32 arrays through Result APIs":
        val ints = array_i64([Int64.new(1), Int64.new(2)])
        expect ints.try_add_scalar_f32(Float32.new(1.0)).is_err() == true
        expect ints.try_sub_scalar_f32(Float32.new(1.0)).is_err() == true
        expect ints.try_mul_scalar_f32(Float32.new(1.0)).is_err() == true
        expect ints.try_div_scalar_f32(Float32.new(1.0)).is_err() == true


# ============================================================================
# Test Group 4: Error paths in elementwise ops
# ============================================================================

describe "Broadcast error paths in elementwise ops":
    it "returns an error for incompatible shapes (2,3) + (2,)":
        val a = array([Float64.new(1.0), Float64.new(2.0), Float64.new(3.0),
                       Float64.new(4.0), Float64.new(5.0), Float64.new(6.0)]
                     ).reshape(Shape.new([Index.new(2), Index.new(3)]))
        val b = array([Float64.new(10.0), Float64.new(20.0)])
        val r = a.try_add(b)
        expect r.is_err() == true