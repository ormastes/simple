# @cover src/lib/nogc_sync_mut/ndarray/broadcast.spl 80%
"""
# NDArray Broadcasting Specification

**Feature IDs:** scilib-ndarray-broadcast
**Category:** Stdlib
**Difficulty:** 4/5
**Status:** Draft
**Plan:** doc/03_plan/agent_tasks/scilib_port_ndarray.md
**Design:** doc/05_design/scilib_port_architecture.md
**Research:** doc/01_research/scilib_fortran_port/02_python_api_surface.md

## Overview

NumPy-style broadcasting for binary ufuncs. Broadcasting is the GATING
SUBSTRATE for all 9 NumPy ufuncs (per Phase 2 finding) — every elementwise
op routes through the same shape-resolution rules.

Tasks covered: T-NDARRAY-16 (broadcast engine), T-NDARRAY-17 (binary
ufunc dispatch).

## Broadcasting rules (NumPy parity)

Two shapes are compatible iff, when right-aligned, every dim pair is
either (a) equal or (b) one of them is 1. Resulting shape takes the max
of each dim pair.

Examples:
- `(2,1) + (1,3) → (2,3)`
- `(3,)  + scalar → (3,)`
- `(2,3) + (3,)   → (2,3)` (vector broadcast across rows)
- `(2,3) + (2,)   → ERROR` (right-align: 3 vs 2 mismatch)

## Implementation Notes

`broadcast_shapes(s1, s2)` is a pure function on Shape — no allocation;
must run unmodified in interp mode (no PERF-SUGAR gate).
The actual elementwise op DOES allocate (T-PERFSUGAR-01 gate applies to the
ufunc, not to the shape resolver).
"""

use std.spipe.*
use std.ndarray.*


# ============================================================================
# Test Group 1: Pure shape-resolution
# ============================================================================

describe "Broadcasting shape resolution":
    """
    ## broadcast_shapes(s1, s2) -> Result<Shape, NdarrayError>

    Pure shape function — does not depend on element data.
    """

    context "compatible shapes":
        it "(2,1) and (1,3) -> (2,3)":
            val r = broadcast_shapes(Shape(2, 1),
                                     Shape(1, 3))
            expect(r.unwrap()).to_equal(Shape(2, 3))

        it "(2,3) and (3,) -> (2,3) (right-align)":
            val r = broadcast_shapes(Shape(2, 3),
                                     Shape(3))
            expect(r.unwrap()).to_equal(Shape(2, 3))

        it "(3,) and scalar -> (3,)":
            val r = broadcast_shapes(Shape(3), Shape())
            expect(r.unwrap()).to_equal(Shape(3))

        it "is symmetric: broadcast_shapes(a,b) == broadcast_shapes(b,a)":
            val ab = broadcast_shapes(Shape(2, 1),
                                      Shape(1, 3)).unwrap()
            val ba = broadcast_shapes(Shape(1, 3),
                                      Shape(2, 1)).unwrap()
            expect(ab).to_equal(ba)

    context "incompatible shapes":
        it "(2,3) and (2,) -> error (right-align: 3 vs 2 mismatch)":
            val r = broadcast_shapes(Shape(2, 3),
                                     Shape(2))
            expect(r.error?).to_equal(true)

        it "(4,) and (3,) -> error":
            val r = broadcast_shapes(Shape(4),
                                     Shape(3))
            expect(r.error?).to_equal(true)


# ============================================================================
# Test Group 2: Elementwise add — broadcast in action
# ============================================================================

describe "Broadcasting in binary add":
    """
    ## a + b under broadcasting

    Asserts numerical correctness on the small canonical cases —
    every numpy ufunc lowers to this same dispatch.
    """

    it "(2,1) + (1,3) produces a (2,3) outer-sum":
        # a = [[1],[2]]   b = [[10,20,30]]
        # expected:
        #   [[11,21,31],
        #    [12,22,32]]
        val a = NDArray.from_seq([Float64(1.0), Float64(2.0)], Shape(2, 1), Device.CPU)
        val b = NDArray.from_seq([Float64(10.0), Float64(20.0), Float64(30.0)], Shape(1, 3), Device.CPU)
        val r = a.add(b)
        expect(r.shape).to_equal(Shape(2, 3))
        expect(r.get_at([Index(0), Index(0)])).to_equal(Float64(11.0))
        expect(r.get_at([Index(0), Index(2)])).to_equal(Float64(31.0))
        expect(r.get_at([Index(1), Index(0)])).to_equal(Float64(12.0))
        expect(r.get_at([Index(1), Index(2)])).to_equal(Float64(32.0))

    it "(2,3) + (3,) broadcasts the vector across rows":
        # a = [[1,2,3],[4,5,6]]    b = [10,20,30]
        # expected:
        #   [[11,22,33],
        #    [14,25,36]]
        val a = NDArray.from_seq([Float64(1.0), Float64(2.0), Float64(3.0),
                       Float64(4.0), Float64(5.0), Float64(6.0)], Shape(2, 3), Device.CPU)
        val b = NDArray.from_seq([Float64(10.0), Float64(20.0), Float64(30.0)], Shape(3), Device.CPU)
        val r = a.add(b)
        expect(r.shape).to_equal(Shape(2, 3))
        expect(r.get_at([Index(0), Index(0)])).to_equal(Float64(11.0))
        expect(r.get_at([Index(0), Index(2)])).to_equal(Float64(33.0))
        expect(r.get_at([Index(1), Index(2)])).to_equal(Float64(36.0))


# ============================================================================
# Test Group 3: Scalar broadcast
# ============================================================================

describe "Scalar broadcast":
    """
    ## a + scalar

    A typed Float64 scalar broadcasts to every element of `a`.
    """

    it "(3,) + Float64(5.0) adds 5 to each element":
        val a = NDArray.from_seq([Float64(1.0), Float64(2.0), Float64(3.0)], Shape(3), Device.CPU)
        val r = a.add_scalar(Float64(5.0))
        expect(r.len()).to_equal(Index(3))
        expect(r.get(Index(0))).to_equal(Float64(6.0))
        expect(r.get(Index(1))).to_equal(Float64(7.0))
        expect(r.get(Index(2))).to_equal(Float64(8.0))

    it "(2,2) * Float64(2.0) doubles each element":
        val a = NDArray.from_seq([Float64(1.0), Float64(2.0),
                       Float64(3.0), Float64(4.0)], Shape(2, 2), Device.CPU)
        val r = a.mul_scalar(Float64(2.0))
        expect(r.get_at([Index(0), Index(0)])).to_equal(Float64(2.0))
        expect(r.get_at([Index(1), Index(1)])).to_equal(Float64(8.0))


# ============================================================================
# Test Group 4: Error paths in elementwise ops
# ============================================================================

describe "Broadcast error paths in elementwise ops":
    it "returns an error for incompatible shapes (2,3) + (2,)":
        val a = NDArray.from_seq([Float64(1.0), Float64(2.0), Float64(3.0),
                       Float64(4.0), Float64(5.0), Float64(6.0)], Shape(2, 3), Device.CPU)
        val b = NDArray.from_seq([Float64(10.0), Float64(20.0)], Shape(2), Device.CPU)
        val r = a.try_add(b)
        expect(r.error?).to_equal(true)
