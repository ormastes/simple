# @cover src/lib/nogc_async_mut/ndarray/mod.spl 80%
"""
# NDArray Concatenate And Stack Specification

**Feature IDs:** science-math-lib-set-numpy-core-concat-stack
**Plan:** doc/03_plan/agent_tasks/science_math_lib_set.md
**Design:** doc/05_design/science_math_lib_set.md

Validates the first NumPy-core shape-composition slice. This intentionally
covers 1-D inputs only; axis-general concatenate/stack is a later phase.
"""

use std.spipe.*
use std.ndarray.*


describe "NDArray concatenate":
    it "concatenates Float64 1-D arrays":
        val a = array([Float64.new(1.0), Float64.new(2.0)])
        val b = array([Float64.new(3.0)])
        val c = concatenate([a, b])
        expect c.shape == Shape.new([Index.new(3)])
        expect c.get(Index.new(0)) == Float64.new(1.0)
        expect c.get(Index.new(2)) == Float64.new(3.0)

    it "concatenates Int64 arrays without changing dtype":
        val c = concatenate([
            array_i64([Int64.new(1), Int64.new(2)]),
            array_i64([Int64.new(3), Int64.new(4)])
        ])
        expect c.dtype == DType.I64
        expect c.get(Index.new(3)) == Int64.new(4)

    it "rejects empty input and mixed dtypes":
        val empty: [NDArray] = []
        expect try_concatenate(empty).is_err() == true
        val mixed = try_concatenate([
            array([Float64.new(1.0)]),
            array_i64([Int64.new(1)])
        ])
        expect mixed.is_err() == true


describe "NDArray stack":
    it "stacks equal-length Float64 vectors into a 2-D array":
        val s = stack([
            array([Float64.new(1.0), Float64.new(2.0)]),
            array([Float64.new(3.0), Float64.new(4.0)])
        ])
        expect s.shape == Shape.new([Index.new(2), Index.new(2)])
        expect s.get_at([Index.new(0), Index.new(1)]) == Float64.new(2.0)
        expect s.get_at([Index.new(1), Index.new(0)]) == Float64.new(3.0)

    it "returns UnsupportedDType for Bool stack in this 1-D v1 slice":
        val result = try_stack([
            array_bool([Bool.new(true), Bool.new(false)]),
            array_bool([Bool.new(false), Bool.new(true)])
        ])
        expect result.is_err() == true

    it "rejects mismatched vector lengths":
        val result = try_stack([
            array([Float64.new(1.0)]),
            array([Float64.new(2.0), Float64.new(3.0)])
        ])
        expect result.is_err() == true