# @cover src/compiler_rust/compiler/src/interpreter_extern/file_io.rs 80%
"""
# T-PERFSUGAR-01 Smoke Spec — typed numeric buffer alloc externs

**Feature IDs:** T-PERFSUGAR-01
**Category:** Runtime
**Difficulty:** 1/5
**Status:** Draft
**Plan:** doc/03_plan/agent_tasks/scilib_port_perf_sugar.md
**Design:** doc/05_design/scilib_port_architecture.md

## Overview

Smoke test for the four typed numeric buffer alloc externs that gate
the v1 NDArray ctors (per arch §10 OQ-F):

- `rt_f64_array_alloc(len) -> [f64]`
- `rt_f32_array_alloc(len) -> [f32]`
- `rt_i64_array_alloc(len) -> [i64]`
- `rt_i32_array_alloc(len) -> [i32]`

Sibling of `rt_bytes_alloc` (per `feedback_interpreter_bulk_buffer.md`
precedent — that fix transformed `[u8]` ctor from "never completes" to
~1.5s for 32 MiB). These externs do the same for typed numeric buffers
that NDArray<T>.zeros() and friends will use.

## Behavior

- Returns a length-N array zero-filled.
- Returns an empty array on `len == 0`.
- Returns an empty array on negative `len` (consistent with rt_bytes_alloc).

## Bootstrap requirement

Per `feedback_extern_bootstrap_rebuild.md`: extern additions take effect
only after `scripts/bootstrap/bootstrap-from-scratch.sh --deploy`. Running
`bin/simple build bootstrap` silently no-ops (the wrapper whitelist
intercepts and skips the rebuild).
"""

use std.spipe.*


# ============================================================================
# Test Group 1: Length and zero-fill correctness
# ============================================================================

describe "rt_f64_array_alloc smoke":
    """
    ## f64 buffer alloc

    1024-element zero-filled array; first/last element equal 0.0.
    """

    it "returns a 1024-element zero-filled array":
        val a = rt_f64_array_alloc(1024)
        expect(a.len()).to_equal(1024)
        expect(a.get(0)).to_equal(0.0)
        expect(a.get(1023)).to_equal(0.0)

    it "returns an empty array for len=0":
        val a = rt_f64_array_alloc(0)
        expect(a.len()).to_equal(0)

    it "returns an empty array for negative len":
        val a = rt_f64_array_alloc(-1)
        expect(a.len()).to_equal(0)


describe "rt_f32_array_alloc smoke":
    it "returns a 256-element zero-filled array":
        val a = rt_f32_array_alloc(256)
        expect(a.len()).to_equal(256)
        expect(a.get(0)).to_equal(0.0)
        expect(a.get(255)).to_equal(0.0)


describe "rt_i64_array_alloc smoke":
    it "returns a 512-element zero-filled array":
        val a = rt_i64_array_alloc(512)
        expect(a.len()).to_equal(512)
        expect(a.get(0)).to_equal(0)
        expect(a.get(511)).to_equal(0)


describe "rt_i32_array_alloc smoke":
    it "returns a 128-element zero-filled array":
        val a = rt_i32_array_alloc(128)
        expect(a.len()).to_equal(128)
        expect(a.get(0)).to_equal(0)
        expect(a.get(127)).to_equal(0)
