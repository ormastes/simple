# @cover src/lib/nogc_async_mut/ndarray/mod.spl 80%
"""
# NDArray Axis Reduction Specification

**Feature IDs:** science-math-lib-set-numpy-core-axis-reductions
**Plan:** doc/03_plan/agent_tasks/science_math_lib_set.md
**Design:** doc/05_design/science_math_lib_set.md

Validates the first axis-aware reduction slice: 2-D Float64 `sum_axis`.
"""

use std.spipe.*
use std.ndarray.*


describe "NDArray sum_axis":
    it "sums a 2-D matrix over axis 0 into column totals":
        val a = array([
            Float64.new(1.0), Float64.new(2.0), Float64.new(3.0),
            Float64.new(4.0), Float64.new(5.0), Float64.new(6.0)
        ]).reshape(Shape.new([Index.new(2), Index.new(3)]))
        val out = a.sum_axis(Axis.new(0))
        expect out.shape == Shape.new([Index.new(3)])
        expect out.get(Index.new(0)) == Float64.new(5.0)
        expect out.get(Index.new(1)) == Float64.new(7.0)
        expect out.get(Index.new(2)) == Float64.new(9.0)

    it "sums a 2-D matrix over axis 1 into row totals":
        val a = array([
            Float64.new(1.0), Float64.new(2.0), Float64.new(3.0),
            Float64.new(4.0), Float64.new(5.0), Float64.new(6.0)
        ]).reshape(Shape.new([Index.new(2), Index.new(3)]))
        val out = a.sum_axis(Axis.new(1))
        expect out.shape == Shape.new([Index.new(2)])
        expect out.get(Index.new(0)) == Float64.new(6.0)
        expect out.get(Index.new(1)) == Float64.new(15.0)

    it "supports negative axis indexing":
        val a = array([
            Float64.new(1.0), Float64.new(2.0),
            Float64.new(3.0), Float64.new(4.0)
        ]).reshape(Shape.new([Index.new(2), Index.new(2)]))
        val out = a.sum_axis(Axis.new(-1))
        expect out.get(Index.new(0)) == Float64.new(3.0)
        expect out.get(Index.new(1)) == Float64.new(7.0)

    it "returns errors for non-2D input, bad axis, and unsupported dtype":
        val one_d = array([Float64.new(1.0), Float64.new(2.0)])
        expect one_d.try_sum_axis(Axis.new(0)).is_err() == true
        val two_d = one_d.reshape(Shape.new([Index.new(1), Index.new(2)]))
        expect two_d.try_sum_axis(Axis.new(2)).is_err() == true
        val ints = array_i64([Int64.new(1), Int64.new(2)]).reshape(Shape.new([Index.new(1), Index.new(2)]))
        expect ints.try_sum_axis(Axis.new(1)).is_err() == true


describe "NDArray mean_axis":
    it "computes column means over axis 0":
        val a = array([
            Float64.new(1.0), Float64.new(2.0),
            Float64.new(3.0), Float64.new(4.0)
        ]).reshape(Shape.new([Index.new(2), Index.new(2)]))
        val out = a.mean_axis(Axis.new(0))
        expect out.get(Index.new(0)) == Float64.new(2.0)
        expect out.get(Index.new(1)) == Float64.new(3.0)

    it "computes row means over axis 1":
        val a = array([
            Float64.new(1.0), Float64.new(3.0),
            Float64.new(5.0), Float64.new(7.0)
        ]).reshape(Shape.new([Index.new(2), Index.new(2)]))
        val out = a.mean_axis(Axis.new(1))
        expect out.get(Index.new(0)) == Float64.new(2.0)
        expect out.get(Index.new(1)) == Float64.new(6.0)