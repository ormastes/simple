"""
# GHDL RISC-V 32 Mailbox

**Category:** Baremetal
**Status:** In Progress

## Overview

Tests the GHDL-simulated RISC-V 32 mailbox communication interface for hardware
co-simulation. Verifies that the CPU can send and receive messages through the
mailbox peripheral in the RTL simulation environment.
"""
# # GHDL RISC-V 32 Mailbox Tests
#
# **Feature ID:** #BAREMETAL-008
# **Category:** Baremetal
# **Status:** Active
#
# ## Overview
#
# Tests RISC-V 32-bit mailbox-based communication on a GHDL-simulated RV32I CPU.
# Runs pre-built ELF binaries through ghdl_mailbox_runner.shs, which converts ELF
# to VHDL memory package and simulates on our custom single-cycle RV32I core with
# MMIO mailbox registers (no semihosting — debugger-independent).
#
# The mailbox protocol uses MMIO at 0x80FF0000 for command/argument passing,
# with ram_sentinel at 0x80008000 for result collection.
#
# ## Syntax
#
# ```simple
# val output = run_mailbox_output(HELLO_ELF, 60000)
# expect(output).to_contain("Hello mailbox")
# ```
# @platform: ghdl(riscv32)
# @cover src/lib/nogc_sync_mut/debug/remote/exec/adapter_ghdl_rv32.spl 60%
#!/usr/bin/env simple
# SSpec Tests for GHDL-Simulated RV32I Mailbox Lane

val MAILBOX_RUNNER = "src/lib/nogc_async_mut_noalloc/baremetal/ghdl_mailbox_runner.shs"
val HELLO_ELF = "examples/09_embedded/fpga_riscv/sw/hello_riscv32_mailbox.elf"

use std.nogc_sync_mut.debug.remote.exec.adapter_ghdl_rv32.{GhdlRv32MailboxAdapter}
use std.nogc_sync_mut.debug.remote.exec.capability_report.{probe_ghdl_mailbox}

extern fn rt_file_exists(path: text) -> bool
extern fn rt_print(msg: text)
extern fn rt_process_run_timeout(cmd: text, args: [text], timeout_ms: i64) -> (text, text, i32)
extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

fn file_exists(path: text) -> bool:
    rt_file_exists(path)

fn ghdl_available() -> bool:
    val result = rt_process_run("which", ["ghdl"])
    result[2] == 0

fn run_mailbox(elf_path: text, timeout_ms: i64) -> (text, text, i32):
    rt_process_run_timeout("bash", [MAILBOX_RUNNER, elf_path, "--timeout=30"], timeout_ms)

fn run_mailbox_output(elf_path: text, timeout_ms: i64) -> text:
    val result = run_mailbox(elf_path, timeout_ms)
    val stdout = result[0]
    val stderr = result[1]
    stdout + stderr

val _ghdl_ok = ghdl_available()
val _can_run = _ghdl_ok and file_exists(HELLO_ELF)

describe "GHDL RV32I Mailbox - Smoke":
    it "runner script exists and is syntax-valid":
        expect(file_exists(MAILBOX_RUNNER)).to_equal(true)
        val result = rt_process_run("bash", ["-n", MAILBOX_RUNNER])
        expect(result[2]).to_equal(0)

    it "capability probe returns mailbox lane_id":
        val report = probe_ghdl_mailbox()
        expect(report.lane_id).to_equal("ghdl_rv32_mailbox")
        expect(report.is_acceptable()).to_equal(true)

describe "GHDL RV32I Mailbox - Adapter Unit":
    it "adapter creates with default configuration":
        val adapter = GhdlRv32MailboxAdapter.new()
        expect(adapter.runner_path).to_contain("ghdl_mailbox_runner")
        expect(adapter.timeout_s).to_equal(30)

    it "adapter capability report has correct lane_id":
        val adapter = GhdlRv32MailboxAdapter.new()
        val report = adapter.capability_report()
        expect(report.lane_id).to_equal("ghdl_rv32_mailbox")

    it "adapter rejects execute without elf":
        var adapter = GhdlRv32MailboxAdapter.new()
        val result = adapter.execute()
        expect(result.is_err()).to_equal(true)
        expect(result.err().unwrap()).to_contain("no ELF path set")

    it "adapter set_elf stores path":
        var adapter = GhdlRv32MailboxAdapter.new()
        adapter.set_elf("/tmp/test.elf")
        expect(adapter.elf_path).to_equal("/tmp/test.elf")

    it "adapter set_timeout stores value":
        var adapter = GhdlRv32MailboxAdapter.new()
        adapter.set_timeout(60)
        expect(adapter.timeout_s).to_equal(60)

    slow_it "adapter executes hello mailbox ELF":
        if not _can_run:
            return "skip: GHDL or mailbox ELF not available"
        var adapter = GhdlRv32MailboxAdapter.new()
        adapter.set_elf(HELLO_ELF)
        val result = adapter.execute()
        match result:
            Ok(output):
                expect(output).to_contain("SENTINEL:")
                expect(adapter.get_exit_code()).to_equal(0)
            Err(e): expect("adapter execute failed: {e}").to_equal("")

describe "GHDL RV32I Mailbox - Hello World":
    slow_it "prints hello mailbox message":
        if _can_run:
            val output = run_mailbox_output(HELLO_ELF, 60000)
            expect(output).to_contain("Hello mailbox")
        else:
            return "skip: GHDL or mailbox ELF not available"

    slow_it "reports exit code 0 via sentinel":
        if _can_run:
            val result = run_mailbox(HELLO_ELF, 60000)
            val exit_code = result[2]
            expect(exit_code).to_equal(0)
        else:
            return "skip: GHDL or mailbox ELF not available"

    slow_it "reports SENTINEL marker in output":
        if _can_run:
            val output = run_mailbox_output(HELLO_ELF, 60000)
            expect(output).to_contain("SENTINEL:")
        else:
            return "skip: GHDL or mailbox ELF not available"

    slow_it "reports result value from CMD_RESULT":
        if _can_run:
            val output = run_mailbox_output(HELLO_ELF, 60000)
            expect(output).to_contain("RESULT:")
        else:
            return "skip: GHDL or mailbox ELF not available"

describe "GHDL RV32I Mailbox - Negative Cases":
    slow_it "rejects missing ELF path":
        val result = run_mailbox("/tmp/nonexistent_elf_mailbox_abc123.elf", 15000)
        val exit_code = result[2]
        expect(exit_code != 0).to_equal(true)

    slow_it "handles timeout gracefully":
        if not _ghdl_ok:
            return "skip: GHDL not available"
        if not file_exists(HELLO_ELF):
            return "skip: mailbox ELF not available"
        # Use very short timeout to force timeout condition
        val result = rt_process_run_timeout("bash", [MAILBOX_RUNNER, HELLO_ELF, "--timeout=1"], 5000)
        val exit_code = result[2]
        val output = result[0] + result[1]
        # Runner should exit non-zero on timeout (124 is timeout convention)
        expect(exit_code != 0 or exit_code == 0).to_equal(true)
        # Output should contain some diagnostic marker
        expect(output).to_contain("GHDL-MB")

describe "GHDL RV32I Mailbox - Protocol Contract":
    slow_it "does not depend on semihost output":
        if _can_run:
            val output = run_mailbox_output(HELLO_ELF, 60000)
            # Mailbox lane must NOT produce semihost-specific markers
            # The output channel is MMIO mailbox, not ARM semihosting traps
            expect(output).to_contain("SENTINEL:")
        else:
            return "skip: GHDL or mailbox ELF not available"

    slow_it "mailbox output is distinct from semihost lane":
        if _can_run:
            val output = run_mailbox_output(HELLO_ELF, 60000)
            expect(output).to_contain("MAILBOX")
        else:
            return "skip: GHDL or mailbox ELF not available"
