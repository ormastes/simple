#!/usr/bin/env simple

use std.spec.*

val GENERATED_LINUX_SMOKE = "scripts/rtl_riscv64_linux_generated.shs"

extern fn rt_file_exists(path: text) -> bool
extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_process_run_timeout(cmd: text, args: [text], timeout_ms: i64) -> (text, text, i32)

fn runner_tools_available() -> bool:
    val result = rt_process_run("bash", ["-lc", "command -v gh >/dev/null && command -v ghdl >/dev/null && command -v riscv64-linux-gnu-as >/dev/null && command -v riscv64-linux-gnu-ld >/dev/null && command -v riscv64-linux-gnu-objcopy >/dev/null"])
    result[2] == 0

describe "Generated RV64 GHDL Linux smoke lane":
    it "script exists and is syntax-valid":
        expect rt_file_exists(GENERATED_LINUX_SMOKE) == true
        val result = rt_process_run("bash", ["-n", GENERATED_LINUX_SMOKE])
        expect result[2] == 0

    slow_it "supports a tool-check mode for the repo-native generated RV64 Linux lane":
        if not runner_tools_available():
            return "skip: gh, ghdl, or riscv binutils not available"
        val result = rt_process_run_timeout("bash", [GENERATED_LINUX_SMOKE, "--check-tools"], 120000)
        val output = result[0] + result[1]
        expect result[2] == 0
        expect (output).contains("PASS: generated RV64 RTL Linux tools present")