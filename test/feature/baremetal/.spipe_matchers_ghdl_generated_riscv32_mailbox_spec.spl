#!/usr/bin/env simple

use std.spec.*

val GENERATED_MAILBOX_RUNNER = "src/lib/nogc_async_mut_noalloc/baremetal/ghdl_generated_rv32_mailbox_runner.shs"
val GENERATED_MAILBOX_SMOKE = "examples/09_embedded/fpga_riscv/sw/generated_rv32_mailbox.s"

extern fn rt_file_exists(path: text) -> bool
extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_process_run_timeout(cmd: text, args: [text], timeout_ms: i64) -> (text, text, i32)

fn runner_tools_available() -> bool:
    val result = rt_process_run("bash", ["-lc", "command -v ghdl >/dev/null && command -v riscv64-linux-gnu-as >/dev/null && command -v riscv64-linux-gnu-ld >/dev/null && command -v riscv64-linux-gnu-objcopy >/dev/null"])
    result[2] == 0

describe "Generated RV32 GHDL mailbox":
    it "runner script exists and is syntax-valid":
        expect rt_file_exists(GENERATED_MAILBOX_RUNNER) == true
        val result = rt_process_run("bash", ["-n", GENERATED_MAILBOX_RUNNER])
        expect result[2] == 0

    slow_it "runs a generated RV32 mailbox shell-contract smoke":
        if not runner_tools_available():
            return "skip: ghdl or riscv binutils not available"
        val result = rt_process_run_timeout("bash", [GENERATED_MAILBOX_RUNNER, GENERATED_MAILBOX_SMOKE, "--timeout=30"], 120000)
        val output = result[0] + result[1]
        expect result[2] == 0
        expect (output).contains("OK")
        expect (output).contains("RESULT: pass=1 value=42")
        expect (output).contains("[GHDL-GEN-MB] PASS")