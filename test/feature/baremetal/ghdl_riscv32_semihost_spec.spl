# # GHDL RISC-V 32 Semihosting Tests
#
# **Feature ID:** #BAREMETAL-007
# **Category:** Baremetal
# **Status:** Active
#
# ## Overview
#
# Tests RISC-V 32-bit semihosting on a GHDL-simulated RV32I CPU.
# Runs pre-built ELF binaries through ghdl_runner.shs, which converts ELF to VHDL
# memory package and simulates on our custom single-cycle RV32I core with
# semihosting support (SYS_WRITE0, SYS_EXIT).
#
# ## Syntax
#
# ```simple
# fn run_ghdl(elf_path: text, timeout_ms: i64) -> (text, text, i32):
#     rt_process_run_timeout("bash", [GHDL_RUNNER, elf_path, "--timeout=30"], timeout_ms)
#
# val output = run_ghdl_output(HELLO_ELF, 60000)
# expect(output).to_contain("Hello, RISC-V 32!")
# ```
# @platform: ghdl(riscv32)
#!/usr/bin/env simple
# SSpec Tests for GHDL-Simulated RV32I Semihosting
#
# Runs bare-metal RV32I programs on GHDL-simulated CPU with semihosting.
# Only tests pure RV32I programs using SYS_WRITE0 + SYS_EXIT, linked at 0x80000000.

val GHDL_RUNNER = "src/lib/nogc_async_mut_noalloc/baremetal/ghdl_runner.shs"
val HELLO_ELF = "examples/09_embedded/baremetal/baremetal/hello_riscv32_semihost.elf"
val SSPEC_ELF = "examples/09_embedded/baremetal/baremetal/hello_riscv32_sspec.elf"

extern fn rt_file_exists(path: text) -> bool
extern fn rt_print(msg: text)
extern fn rt_process_run_timeout(cmd: text, args: [text], timeout_ms: i64) -> (text, text, i32)
extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

fn file_exists(path: text) -> bool:
    rt_file_exists(path)

fn ghdl_available() -> bool:
    val result = rt_process_run("which", ["ghdl"])
    result[2] == 0

fn run_ghdl(elf_path: text, timeout_ms: i64) -> (text, text, i32):
    rt_process_run_timeout("bash", [GHDL_RUNNER, elf_path, "--timeout=30"], timeout_ms)

fn run_ghdl_output(elf_path: text, timeout_ms: i64) -> text:
    val result = run_ghdl(elf_path, timeout_ms)
    val stdout = result[0]
    val stderr = result[1]
    stdout + stderr

val _ghdl_ok = ghdl_available()
val _can_run_hello = _ghdl_ok and file_exists(HELLO_ELF)
val _can_run_sspec = _ghdl_ok and file_exists(SSPEC_ELF)

describe "GHDL RV32I Semihosting - Hello World":
    slow_it "prints hello world message":
        if _can_run_hello:
            val output = run_ghdl_output(HELLO_ELF, 60000)
            expect(output).to_contain("Hello, RISC-V 32!")
        else:
            print "SKIP: GHDL or hello ELF not available"

    slow_it "outputs semihost test success marker":
        if _can_run_hello:
            val output = run_ghdl_output(HELLO_ELF, 60000)
            expect(output).to_contain("SEMIHOST TEST")
            expect(output).to_contain("Success")
        else:
            print "SKIP: GHDL or hello ELF not available"

    slow_it "reports test PASSED with exit code 0":
        if _can_run_hello:
            val output = run_ghdl_output(HELLO_ELF, 60000)
            expect(output).to_contain("Test PASSED")
        else:
            print "SKIP: GHDL or hello ELF not available"

    slow_it "reports cycle count":
        if _can_run_hello:
            val output = run_ghdl_output(HELLO_ELF, 60000)
            expect(output).to_contain("Cycles:")
        else:
            print "SKIP: GHDL or hello ELF not available"

describe "GHDL RV32I Semihosting - SSpec Format":
    slow_it "outputs SSpec header":
        if _can_run_sspec:
            val output = run_ghdl_output(SSPEC_ELF, 60000)
            expect(output).to_contain("Baremetal Semihosting")
        else:
            print "SKIP: GHDL or sspec ELF not available"

    slow_it "outputs test name":
        if _can_run_sspec:
            val output = run_ghdl_output(SSPEC_ELF, 60000)
            expect(output).to_contain("hello_semihost")
        else:
            print "SKIP: GHDL or sspec ELF not available"

    slow_it "outputs SSpec summary with 0 failures":
        if _can_run_sspec:
            val output = run_ghdl_output(SSPEC_ELF, 60000)
            expect(output).to_contain("1 examples, 0 failures")
        else:
            print "SKIP: GHDL or sspec ELF not available"

    slow_it "reports test PASSED with exit code 0":
        if _can_run_sspec:
            val output = run_ghdl_output(SSPEC_ELF, 60000)
            expect(output).to_contain("Test PASSED")
        else:
            print "SKIP: GHDL or sspec ELF not available"
