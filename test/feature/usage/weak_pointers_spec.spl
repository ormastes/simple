# # Weak Pointers Specification
#
# **Feature ID:** #PTR-WEAK
# **Category:** Runtime
# **Status:** Implemented
#
# ## Overview
#
# Weak references provide non-owning references to values managed by a global
# weak reference table. When the target is invalidated (or strong count drops
# to zero), weak references return -1 on upgrade.
#
# Self-contained implementation using dict-based store to avoid
# module-level array index assignment limitations.

var g_weak_store = {}
var g_weak_next_id: i64 = 0

struct WeakRef:
    target_id: i64
    generation: i64

fn weak_register(value: i64) -> i64:
    val id = g_weak_next_id
    g_weak_next_id = g_weak_next_id + 1
    val key = "{id}"
    g_weak_store[key] = {"value": value, "alive": true, "generation": 0, "strong_count": 1}
    id

fn weak_reset():
    g_weak_store = {}
    g_weak_next_id = 0

fn weak_create(target_id: i64) -> WeakRef:
    val key = "{target_id}"
    val d = g_weak_store
    if not d.contains_key(key):
        return WeakRef(target_id: -1, generation: -1)
    val entry = d[key]
    WeakRef(target_id: target_id, generation: entry["generation"])

fn weak_upgrade(ref: WeakRef) -> i64:
    if ref.target_id < 0:
        return -1
    val key = "{ref.target_id}"
    val d = g_weak_store
    if not d.contains_key(key):
        return -1
    val entry = d[key]
    if entry["alive"] == false:
        return -1
    if entry["generation"] != ref.generation:
        return -1
    entry["value"]

fn weak_is_alive(ref: WeakRef) -> bool:
    if ref.target_id < 0:
        return false
    val key = "{ref.target_id}"
    val d = g_weak_store
    if not d.contains_key(key):
        return false
    val entry = d[key]
    if entry["alive"] == false:
        return false
    entry["generation"] == ref.generation

fn weak_invalidate(target_id: i64):
    val key = "{target_id}"
    val d = g_weak_store
    if d.contains_key(key):
        val entry = d[key]
        g_weak_store[key] = {"value": entry["value"], "alive": false, "generation": entry["generation"] + 1, "strong_count": entry["strong_count"]}

fn weak_add_strong(target_id: i64):
    val key = "{target_id}"
    val d = g_weak_store
    if d.contains_key(key):
        val entry = d[key]
        g_weak_store[key] = {"value": entry["value"], "alive": entry["alive"], "generation": entry["generation"], "strong_count": entry["strong_count"] + 1}

fn weak_remove_strong(target_id: i64):
    val key = "{target_id}"
    val d = g_weak_store
    if d.contains_key(key):
        val entry = d[key]
        val new_count = entry["strong_count"] - 1
        if new_count <= 0:
            g_weak_store[key] = {"value": entry["value"], "alive": false, "generation": entry["generation"] + 1, "strong_count": 0}
        else:
            g_weak_store[key] = {"value": entry["value"], "alive": entry["alive"], "generation": entry["generation"], "strong_count": new_count}

fn weak_strong_count(target_id: i64) -> i64:
    val key = "{target_id}"
    val d = g_weak_store
    if not d.contains_key(key):
        return 0
    val entry = d[key]
    entry["strong_count"]


# ============================================================================
# Basic Weak Reference Operations
# ============================================================================

describe "Weak - create and upgrade":
    it "creates and upgrades weak reference":
        weak_reset()
        val tid = weak_register(42)
        val w = weak_create(tid)
        expect(weak_upgrade(w)).to_equal(42)
        expect(weak_is_alive(w)).to_equal(true)
        weak_reset()

describe "Weak - expired reference":
    it "returns -1 after invalidation":
        weak_reset()
        val tid = weak_register(99)
        val w = weak_create(tid)
        weak_invalidate(tid)
        expect(weak_upgrade(w)).to_equal(-1)
        expect(weak_is_alive(w)).to_equal(false)
        weak_reset()

describe "Weak - auto-invalidate":
    it "invalidates when strong count drops to zero":
        weak_reset()
        val tid = weak_register(50)
        val w = weak_create(tid)
        weak_remove_strong(tid)
        expect(weak_is_alive(w)).to_equal(false)
        weak_reset()

describe "Weak - multiple refs":
    it "both expire together":
        weak_reset()
        val tid = weak_register(77)
        val w1 = weak_create(tid)
        val w2 = weak_create(tid)
        expect(weak_upgrade(w1)).to_equal(77)
        expect(weak_upgrade(w2)).to_equal(77)
        weak_invalidate(tid)
        expect(weak_upgrade(w1)).to_equal(-1)
        expect(weak_upgrade(w2)).to_equal(-1)
        weak_reset()

describe "Weak - strong count tracking":
    it "tracks add and remove":
        weak_reset()
        val tid = weak_register(10)
        expect(weak_strong_count(tid)).to_equal(1)
        weak_add_strong(tid)
        expect(weak_strong_count(tid)).to_equal(2)
        weak_remove_strong(tid)
        expect(weak_strong_count(tid)).to_equal(1)
        weak_reset()
