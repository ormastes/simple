"""
# Bitfield Runtime Compatibility

**Category:** Language Features
**Status:** In Progress

## Overview

Tests that real bitfield syntax is accepted and parsed correctly in the feature test path.
Validates a basic bitfield declaration with a u8 backing type, including ready, mode,
and reserved fields.
"""

bitfield CompatFlags(u8):
    ready: 1
    mode: 3
    _: 4

bitfield Flags(u32):
    a: 4
    b: 28

describe "Bitfield Runtime Compatibility":
    it "accepts real bitfield syntax in feature test path":
        expect(true).to_equal(true)

    it "round-trips field writes through Flags.new packed runtime values":
        var f: Flags = Flags.new(0)
        f.a = 3
        expect(f.a).to_equal(3)

    it "preserves adjacent fields when writing one packed bitfield field":
        var f: Flags = Flags.new(0)
        f.a = 3
        f.b = 5
        expect(f.a).to_equal(3)
        expect(f.b).to_equal(5)
