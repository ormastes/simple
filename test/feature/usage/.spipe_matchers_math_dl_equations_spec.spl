"""
# Deep Learning Equation Tests for m{} Math Blocks

**Feature IDs:** #1090-1098 (DL equation coverage)
**Category:** Syntax / Math DSL
**Difficulty:** 3/5
**Status:** Implemented

## Overview

Tests that composite DL equations parse, evaluate correctly, render to LaTeX,
and render to nvim-friendly Unicode. Covers all 27 DL equations found in
`examples/simple_deeplearning_study/` and `src/lib/gc_async_mut/torch/`.
"""

use std.math_repr.{render_latex_raw, to_pretty}

# Helper for floating point comparison
fn close(a: f64, b: f64, eps: f64) -> bool:
    val diff = a - b
    val abs_diff = if diff < 0.0: 0.0 - diff else: diff
    abs_diff < eps

# ============================================================================
# DL Activations (5 equations)
# ============================================================================

describe "DL Activations":

    context "Sigmoid: frac(1, 1 + exp(-x))":
        it "evaluates sigmoid(2) correctly":
            val x = 2.0
            val result = m{ frac(1, 1 + exp(-x)) }
            expect close(result, 0.8808, 0.01) == true

        it "renders sigmoid LaTeX":
            val latex = render_latex_raw("frac(1, 1 + exp(-x))")
            expect (latex).contains("\\frac")
            expect (latex).contains("\\exp")

        it "renders sigmoid Unicode":
            val pretty = to_pretty("frac(1, 1 + exp(-x))")
            expect (pretty).contains("exp")

    context "Tanh: frac(exp(x) - exp(-x), exp(x) + exp(-x))":
        it "evaluates tanh(1) correctly":
            val x = 1.0
            val result = m{ frac(exp(x) - exp(-x), exp(x) + exp(-x)) }
            expect close(result, 0.7616, 0.01) == true

        it "renders tanh LaTeX":
            val latex = render_latex_raw("frac(exp(x) - exp(-x), exp(x) + exp(-x))")
            expect (latex).contains("\\frac")
            expect (latex).contains("\\exp")

        it "renders tanh Unicode":
            val pretty = to_pretty("frac(exp(x) - exp(-x), exp(x) + exp(-x))")
            expect (pretty).contains("exp")

    context "ReLU: max(0, x)":
        it "evaluates relu(3) correctly":
            val x = 3.0
            val result = m{ max(0, x) }
            expect result == 3.0

        it "evaluates relu(-2) correctly":
            val x = -2.0
            val result = m{ max(0, x) }
            expect result == 0.0

        it "renders relu LaTeX":
            val latex = render_latex_raw("max(0, x)")
            expect (latex).contains("\\max")

        it "renders relu Unicode":
            val pretty = to_pretty("max(0, x)")
            expect (pretty).contains("max")

    context "GELU: x * 0.5 * (1 + tanh(sqrt(frac(2, pi)) * (x + 0.044715 * x^3)))":
        it "evaluates gelu(1) correctly":
            val x = 1.0
            val result = m{ x * 0.5 * (1 + tanh(sqrt(frac(2, pi)) * (x + 0.044715 * x^3))) }
            expect close(result, 0.8412, 0.01) == true

        it "renders gelu LaTeX":
            val latex = render_latex_raw("x * 0.5 * (1 + tanh(sqrt(frac(2, pi)) * (x + 0.044715 * x^3)))")
            expect (latex).contains("\\tanh")
            expect (latex).contains("\\sqrt")
            expect (latex).contains("\\frac")

        it "renders gelu Unicode":
            val pretty = to_pretty("x * 0.5 * (1 + tanh(sqrt(frac(2, pi)) * (x + 0.044715 * x^3)))")
            expect (pretty).contains("π")

    context "Softmax denominator: exp(x) / sum(exp(x))":
        it "evaluates softmax component":
            val x = 2.0
            val result = m{ exp(x) }
            expect close(result, 7.389, 0.01) == true

        it "renders softmax LaTeX":
            val latex = render_latex_raw("exp(x - max(x)) / sum(exp(x - max(x)))")
            expect (latex).contains("\\exp")
            expect (latex).contains("\\max")

        it "renders softmax Unicode":
            val pretty = to_pretty("exp(x - max(x)) / sum(exp(x - max(x)))")
            expect (pretty).contains("exp")
            expect (pretty).contains("max")

# ============================================================================
# DL Normalization (3 equations)
# ============================================================================

describe "DL Normalization":

    context "Layer Norm: frac(x - mu, sqrt(sigma^2 + epsilon)) * gamma + beta":
        it "evaluates layer norm with concrete values":
            val x = 5.0
            val mu = 3.0
            val sigma = 2.0
            val epsilon = 0.00001
            val gamma = 1.0
            val beta = 0.0
            val result = m{ frac(x - mu, sqrt(sigma^2 + epsilon)) * gamma + beta }
            expect close(result, 1.0, 0.01) == true

        it "renders layer norm LaTeX":
            val latex = render_latex_raw("frac(x - mu, sqrt(sigma^2 + epsilon)) * gamma + beta")
            expect (latex).contains("\\frac")
            expect (latex).contains("\\sqrt")
            expect (latex).contains("\\mu")
            expect (latex).contains("\\sigma")
            expect (latex).contains("\\epsilon")
            expect (latex).contains("\\gamma")
            expect (latex).contains("\\beta")

        it "renders layer norm Unicode":
            val pretty = to_pretty("frac(x - mu, sqrt(sigma^2 + epsilon)) * gamma + beta")
            expect (pretty).contains("μ")
            expect (pretty).contains("σ")
            expect (pretty).contains("ε")
            expect (pretty).contains("γ")
            expect (pretty).contains("β")

    context "RMS Norm: x * w / sqrt(mean(x^2) + epsilon)":
        it "renders rms norm LaTeX":
            val latex = render_latex_raw("x * w / sqrt(mean(x^2) + epsilon)")
            expect (latex).contains("\\sqrt")
            expect (latex).contains("\\epsilon")

        it "renders rms norm Unicode":
            val pretty = to_pretty("x * w / sqrt(mean(x^2) + epsilon)")
            expect (pretty).contains("ε")

    context "Dropout scaling: frac(x, 1 - p)":
        it "evaluates dropout scaling":
            val x = 10.0
            val p = 0.5
            val result = m{ frac(x, 1 - p) }
            expect close(result, 20.0, 0.01) == true

        it "renders dropout LaTeX":
            val latex = render_latex_raw("frac(x, 1 - p)")
            expect (latex).contains("\\frac")

        it "renders dropout Unicode":
            val pretty = to_pretty("frac(x, 1 - p)")
            expect (pretty).contains("x")

# ============================================================================
# DL Layers (3 equations)
# ============================================================================

describe "DL Layers":

    context "Linear: matmul(x, transpose(W)) + b":
        it "renders linear LaTeX":
            val latex = render_latex_raw("matmul(x, transpose(W)) + b")
            expect (latex).contains(r"\operatorname{matmul}")
            expect (latex).contains(r"\operatorname{transpose}")

        it "renders linear Unicode":
            val pretty = to_pretty("matmul(x, transpose(W)) + b")
            expect (pretty).contains("matmul")
            expect (pretty).contains("transpose")

    context "Embedding: W[token_id]":
        it "renders embedding LaTeX with subscript":
            val latex = render_latex_raw("W[token_id]")
            expect (latex).contains("W")
            expect (latex).contains("token")

        it "renders embedding Unicode":
            val pretty = to_pretty("W[token_id]")
            expect (pretty).contains("W")

    context "FFN: matmul(relu(matmul(x, W1) + b1), W2) + b2":
        it "renders FFN LaTeX":
            val latex = render_latex_raw("matmul(relu(matmul(x, W1) + b1), W2) + b2")
            expect (latex).contains(r"\operatorname{matmul}")
            expect (latex).contains(r"\operatorname{relu}")

        it "renders FFN Unicode":
            val pretty = to_pretty("matmul(relu(matmul(x, W1) + b1), W2) + b2")
            expect (pretty).contains("matmul")
            expect (pretty).contains("relu")

# ============================================================================
# DL Attention & Architecture (4 equations)
# ============================================================================

describe "DL Attention & Architecture":

    context "Scaled Dot-Product Attention: softmax(frac(matmul(Q, K'), sqrt(d_k))) * V":
        it "renders attention LaTeX":
            val latex = render_latex_raw("softmax(frac(matmul(Q, K'), sqrt(d_k))) * V")
            expect (latex).contains(r"\operatorname{softmax}")
            expect (latex).contains("\\frac")
            expect (latex).contains("\\sqrt")

        it "renders attention Unicode":
            val pretty = to_pretty("softmax(frac(matmul(Q, K'), sqrt(d_k))) * V")
            expect (pretty).contains("softmax")

    context "Multi-Head Attention: matmul(concat_heads, W_o)":
        it "renders MHA LaTeX":
            val latex = render_latex_raw("matmul(concat_heads, W_o)")
            expect (latex).contains(r"\operatorname{matmul}")

        it "renders MHA Unicode":
            val pretty = to_pretty("matmul(concat_heads, W_o)")
            expect (pretty).contains("matmul")

    context "Transformer Block: x + sublayer(layernorm(x))":
        it "renders transformer block LaTeX":
            val latex = render_latex_raw("x + sublayer(layernorm(x))")
            expect (latex).contains(r"\operatorname{sublayer}")
            expect (latex).contains(r"\operatorname{layernorm}")

        it "renders transformer block Unicode":
            val pretty = to_pretty("x + sublayer(layernorm(x))")
            expect (pretty).contains("sublayer")
            expect (pretty).contains("layernorm")

    context "Positional Encoding: sin(frac(pos, 10000^(frac(2 * i, d))))":
        it "renders positional encoding LaTeX":
            val latex = render_latex_raw("sin(frac(pos, 10000^(frac(2 * i, d))))")
            expect (latex).contains("\\sin")
            expect (latex).contains("\\frac")

        it "renders positional encoding Unicode":
            val pretty = to_pretty("sin(frac(pos, 10000^(frac(2 * i, d))))")
            expect (pretty).contains("sin")

# ============================================================================
# DL Loss Functions (3 equations)
# ============================================================================

describe "DL Loss Functions":

    context "Cross-Entropy: frac(-1, N) * sum(i, 1..N) log(p[i])":
        it "renders cross-entropy LaTeX":
            val latex = render_latex_raw("frac(-1, N) * sum(i, 1..N) log(p[i])")
            expect (latex).contains("\\frac")
            expect (latex).contains("\\sum_{")
            expect (latex).contains("\\log")

        it "renders cross-entropy Unicode":
            val pretty = to_pretty("frac(-1, N) * sum(i, 1..N) log(p[i])")
            expect (pretty).contains("log")

    context "MSE: frac(1, N) * sum(i, 1..N) (y[i] - yhat[i])^2":
        it "renders MSE LaTeX":
            val latex = render_latex_raw("frac(1, N) * sum(i, 1..N) (y[i] - yhat[i])^2")
            expect (latex).contains("\\frac")
            expect (latex).contains("\\sum_{")

        it "renders MSE Unicode":
            val pretty = to_pretty("frac(1, N) * sum(i, 1..N) (y[i] - yhat[i])^2")
            expect (pretty).contains("N")

    context "Temperature scaling: frac(logits, T)":
        it "evaluates temperature scaling":
            val logits = 6.0
            val T = 2.0
            val result = m{ frac(logits, T) }
            expect close(result, 3.0, 0.01) == true

        it "renders temperature LaTeX":
            val latex = render_latex_raw("frac(logits, T)")
            expect (latex).contains("\\frac")

        it "renders temperature Unicode":
            val pretty = to_pretty("frac(logits, T)")
            expect (pretty).contains("logits")

# ============================================================================
# DL Optimizers (4 equations)
# ============================================================================

describe "DL Optimizers":

    context "SGD: theta - alpha * grad":
        it "evaluates SGD update":
            val theta = 5.0
            val alpha = 0.1
            val grad = 2.0
            val result = m{ theta - alpha * grad }
            expect close(result, 4.8, 0.01) == true

        it "renders SGD LaTeX":
            val latex = render_latex_raw("theta - alpha * grad")
            expect (latex).contains("\\theta")
            expect (latex).contains("\\alpha")

        it "renders SGD Unicode":
            val pretty = to_pretty("theta - alpha * grad")
            expect (pretty).contains("θ")
            expect (pretty).contains("α")

    context "SGD+Momentum: theta - alpha * (mu * v + grad)":
        it "evaluates SGD+momentum update":
            val theta = 5.0
            val alpha = 0.1
            val mu = 0.9
            val v = 1.0
            val grad = 2.0
            val result = m{ theta - alpha * (mu * v + grad) }
            expect close(result, 4.71, 0.01) == true

        it "renders SGD+momentum LaTeX":
            val latex = render_latex_raw("theta - alpha * (mu * v + grad)")
            expect (latex).contains("\\theta")
            expect (latex).contains("\\alpha")
            expect (latex).contains("\\mu")

        it "renders SGD+momentum Unicode":
            val pretty = to_pretty("theta - alpha * (mu * v + grad)")
            expect (pretty).contains("θ")
            expect (pretty).contains("α")
            expect (pretty).contains("μ")

    context "Adam bias correction: frac(m, 1 - beta^t)":
        it "evaluates adam bias correction":
            val t = 3.0
            val beta = 0.9
            val result = m{ frac(1, 1 - beta^t) }
            expect close(result, 3.69, 0.1) == true

        it "renders adam LaTeX":
            val latex = render_latex_raw("frac(m, 1 - beta^t)")
            expect (latex).contains("\\frac")
            expect (latex).contains("\\beta")

        it "renders adam Unicode":
            val pretty = to_pretty("frac(m, 1 - beta^t)")
            expect (pretty).contains("β")

    context "Gradient clip: frac(c, sqrt(dot(g, g)))":
        it "renders gradient clip LaTeX":
            val latex = render_latex_raw("frac(c, sqrt(dot(g, g)))")
            expect (latex).contains("\\frac")
            expect (latex).contains("\\sqrt")
            expect (latex).contains(r"\operatorname{dot}")

        it "renders gradient clip Unicode":
            val pretty = to_pretty("frac(c, sqrt(dot(g, g)))")
            expect (pretty).contains("dot")

# ============================================================================
# DL Learning Rate Schedules (2 equations)
# ============================================================================

describe "DL Learning Rate":

    context "Linear Warmup: alpha * frac(step, warmup)":
        it "evaluates linear warmup":
            val alpha = 0.001
            val step = 500.0
            val warmup = 1000.0
            val result = m{ alpha * frac(step, warmup) }
            expect close(result, 0.0005, 0.0001) == true

        it "renders warmup LaTeX":
            val latex = render_latex_raw("alpha * frac(step, warmup)")
            expect (latex).contains("\\alpha")
            expect (latex).contains("\\frac")

        it "renders warmup Unicode":
            val pretty = to_pretty("alpha * frac(step, warmup)")
            expect (pretty).contains("α")

    context "Cosine Decay: min_lr + (alpha - min_lr) * (1 - progress)":
        it "evaluates cosine decay at midpoint":
            val min_lr = 0.0001
            val alpha = 0.001
            val progress = 0.5
            val result = m{ min_lr + (alpha - min_lr) * (1 - progress) }
            expect close(result, 0.00055, 0.0001) == true

        it "renders cosine decay LaTeX":
            val latex = render_latex_raw("min_lr + (alpha - min_lr) * (1 - progress)")
            expect (latex).contains("\\alpha")

        it "renders cosine decay Unicode":
            val pretty = to_pretty("min_lr + (alpha - min_lr) * (1 - progress)")
            expect (pretty).contains("α")

# ============================================================================
# DL Metrics & Init (3 equations)
# ============================================================================

describe "DL Metrics & Init":

    context "Cosine Similarity: frac(dot(a, b), sqrt(dot(a, a)) * sqrt(dot(b, b)))":
        it "evaluates cosine similarity of parallel vectors":
            val result = m{ frac(dot([1, 2, 3], [2, 4, 6]), sqrt(dot([1, 2, 3], [1, 2, 3])) * sqrt(dot([2, 4, 6], [2, 4, 6]))) }
            expect close(result, 1.0, 0.01) == true

        it "renders cosine similarity LaTeX":
            val latex = render_latex_raw("frac(dot(a, b), sqrt(dot(a, a)) * sqrt(dot(b, b)))")
            expect (latex).contains("\\frac")
            expect (latex).contains(r"\operatorname{dot}")
            expect (latex).contains("\\sqrt")

        it "renders cosine similarity Unicode":
            val pretty = to_pretty("frac(dot(a, b), sqrt(dot(a, a)) * sqrt(dot(b, b)))")
            expect (pretty).contains("dot")

    context "Accuracy approx: frac(1, 1 + (pred - target)^2)":
        it "evaluates accuracy at exact match":
            val pred = 5.0
            val target = 5.0
            val result = m{ frac(1, 1 + (pred - target)^2) }
            expect close(result, 1.0, 0.01) == true

        it "evaluates accuracy with distance":
            val pred = 5.0
            val target = 6.0
            val result = m{ frac(1, 1 + (pred - target)^2) }
            expect close(result, 0.5, 0.01) == true

        it "renders accuracy LaTeX":
            val latex = render_latex_raw("frac(1, 1 + (pred - target)^2)")
            expect (latex).contains("\\frac")

        it "renders accuracy Unicode":
            val pretty = to_pretty("frac(1, 1 + (pred - target)^2)")
            expect (pretty).contains("pred")

    context "Xavier Init: sqrt(frac(6, fan_in + fan_out))":
        it "evaluates xavier init":
            val fan_in = 256.0
            val fan_out = 128.0
            val result = m{ sqrt(frac(6, fan_in + fan_out)) }
            expect close(result, 0.1250, 0.01) == true

        it "renders xavier LaTeX":
            val latex = render_latex_raw("sqrt(frac(6, fan_in + fan_out))")
            expect (latex).contains("\\sqrt")
            expect (latex).contains("\\frac")

        it "renders xavier Unicode":
            val pretty = to_pretty("sqrt(frac(6, fan_in + fan_out))")
            expect (pretty).contains("√")