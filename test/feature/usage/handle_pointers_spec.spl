describe "Handle - create and deref":
    # Skip: variable g_pool_free_indices not found — module-level var not accessible from imported module
    it "creates handle for value", tag: ["skip"]:
        handle_pool_new(16)
        val h = handle_alloc(42)
        expect(handle_deref(h)).to_equal(42)
        expect(handle_is_valid(h)).to_equal(true)
        handle_pool_reset()

describe "Handle - deref safely":
    # Skip: variable g_pool_free_indices not found — module-level var not accessible from imported module
    it "dereferences handle", tag: ["skip"]:
        handle_pool_new(16)
