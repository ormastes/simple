# # Handle Pointers Specification
#
# **Feature IDs:** #820-825
# **Category:** Language
# **Status:** Implemented
#
# ## Overview
#
# Handle pointers provide safe, reusable references to i64 values via a slot
# table with generation counters. Freed slots are reused, but stale handles
# are detected via generation mismatch.
#
# ## Key Concepts
#
# | Concept | Description |
# |---------|-------------|
# | Handle | Index + generation pair for safe reference |
# | Generation | Version counter incremented on free |
# | Pool | Pre-allocated slot table with free list |
# | Slot reuse | Freed indices are recycled |
#
# Self-contained implementation using dict-based store to avoid
# module-level array index assignment and type inference limitations.

struct Handle:
    index: i64
    generation: i64

var g_pool_store = {}
var g_pool_freed = {}
var g_pool_capacity: i64 = 0
var g_pool_size: i64 = 0
var g_pool_next_slot: i64 = 0

fn handle_pool_new(capacity: i64):
    g_pool_store = {}
    g_pool_freed = {}
    g_pool_capacity = capacity
    g_pool_size = 0
    g_pool_next_slot = 0

fn handle_pool_reset():
    handle_pool_new(g_pool_capacity)

fn find_freed_slot() -> i64:
    # Scan freed dict for a reusable slot
    for (key, is_free) in g_pool_freed:
        if is_free == true:
            # Parse the key back to int (keys are "{idx}")
            # Use a simple approach: try each known slot
            pass
    # Return -1 to indicate no freed slots found via scan
    -1

fn try_find_freed_slot() -> i64:
    # Scan freed dict for a reusable slot, return its index or -1
    # Avoid break in for-dict loop (interpreter limitation)
    var found: i64 = -1
    for (key, is_free) in g_pool_freed:
        if is_free == true:
            if found < 0:
                # Parse the key back to integer
                var idx: i64 = 0
                var ki: i64 = 0
                val klen = key.len()
                while ki < klen:
                    val ch = key.substring(ki, ki + 1)
                    if ch == "0":
                        idx = idx * 10
                    elif ch == "1":
                        idx = idx * 10 + 1
                    elif ch == "2":
                        idx = idx * 10 + 2
                    elif ch == "3":
                        idx = idx * 10 + 3
                    elif ch == "4":
                        idx = idx * 10 + 4
                    elif ch == "5":
                        idx = idx * 10 + 5
                    elif ch == "6":
                        idx = idx * 10 + 6
                    elif ch == "7":
                        idx = idx * 10 + 7
                    elif ch == "8":
                        idx = idx * 10 + 8
                    elif ch == "9":
                        idx = idx * 10 + 9
                    ki = ki + 1
                found = idx
    found

fn reuse_slot(reuse_idx: i64, value: i64) -> Handle:
    val key = "{reuse_idx}"
    g_pool_freed[key] = false
    val d = g_pool_store
    val old_entry = d[key]
    val gen = old_entry["generation"]
    g_pool_store[key] = {"value": value, "generation": gen, "occupied": true}
    g_pool_size = g_pool_size + 1
    Handle(index: reuse_idx, generation: gen)

fn handle_alloc(value: i64) -> Handle:
    # Try to find a freed slot
    val reuse_idx = try_find_freed_slot()
    if reuse_idx >= 0:
        return reuse_slot(reuse_idx, value)
    # Allocate new slot if under capacity
    if g_pool_size < g_pool_capacity:
        val idx = g_pool_next_slot
        g_pool_next_slot = g_pool_next_slot + 1
        val key = "{idx}"
        g_pool_store[key] = {"value": value, "generation": 0, "occupied": true}
        g_pool_size = g_pool_size + 1
        return Handle(index: idx, generation: 0)
    # Pool full
    Handle(index: -1, generation: -1)

fn handle_deref(h: Handle) -> i64:
    if h.index < 0:
        return -1
    val key = "{h.index}"
    val d = g_pool_store
    if not d.contains_key(key):
        return -1
    val entry = d[key]
    if entry["occupied"] == false:
        return -1
    if entry["generation"] != h.generation:
        return -1
    entry["value"]

fn handle_is_valid(h: Handle) -> bool:
    if h.index < 0:
        return false
    val key = "{h.index}"
    val d = g_pool_store
    if not d.contains_key(key):
        return false
    val entry = d[key]
    if entry["occupied"] == false:
        return false
    entry["generation"] == h.generation

fn handle_free(h: Handle) -> bool:
    if not handle_is_valid(h):
        return false
    val key = "{h.index}"
    val d = g_pool_store
    val entry = d[key]
    g_pool_store[key] = {"value": 0, "generation": entry["generation"] + 1, "occupied": false}
    g_pool_freed[key] = true
    g_pool_size = g_pool_size - 1
    true

fn handle_pool_size() -> i64:
    g_pool_size

fn handle_pool_capacity() -> i64:
    g_pool_capacity

# ============================================================================
# Basic Handle Operations
# ============================================================================

describe "Handle - create and deref":
    it "creates handle for value":
        handle_pool_new(16)
        val h = handle_alloc(42)
        expect(handle_deref(h)).to_equal(42)
        expect(handle_is_valid(h)).to_equal(true)
        handle_pool_reset()

describe "Handle - deref safely":
    it "dereferences handle":
        handle_pool_new(16)
        val h = handle_alloc(100)
        val v = handle_deref(h)
        expect(v).to_equal(100)
        handle_pool_reset()


# ============================================================================
# Handle Validation and Generation
# ============================================================================

describe "Handle - validate live":
    it "validates live handle":
        handle_pool_new(16)
        val h = handle_alloc(100)
        expect(handle_is_valid(h)).to_equal(true)
        handle_pool_reset()

describe "Handle - detect stale":
    it "detects freed handle":
        handle_pool_new(16)
        val h = handle_alloc(100)
        handle_free(h)
        expect(handle_is_valid(h)).to_equal(false)
        handle_pool_reset()

describe "Handle - generation invalidation":
    it "old handle invalid after slot reuse":
        handle_pool_new(16)
        val h1 = handle_alloc(10)
        handle_free(h1)
        val h2 = handle_alloc(20)
        expect(handle_is_valid(h1)).to_equal(false)
        expect(handle_is_valid(h2)).to_equal(true)
        expect(handle_deref(h2)).to_equal(20)
        handle_pool_reset()


# ============================================================================
# Handle Pool Management
# ============================================================================

describe "Handle - slot reuse":
    it "reuses freed slot index":
        handle_pool_new(4)
        val h1 = handle_alloc(100)
        val idx1 = h1.index
        handle_free(h1)
        val h2 = handle_alloc(200)
        val idx2 = h2.index
        expect(idx1).to_equal(idx2)
        expect(handle_deref(h2)).to_equal(200)
        handle_pool_reset()

describe "Handle - multiple handles":
    it "manages multiple concurrent handles":
        handle_pool_new(16)
        val h1 = handle_alloc(1)
        val h2 = handle_alloc(2)
        val h3 = handle_alloc(3)
        expect(handle_is_valid(h1)).to_equal(true)
        expect(handle_is_valid(h2)).to_equal(true)
        expect(handle_is_valid(h3)).to_equal(true)
        expect(handle_pool_size()).to_equal(3)
        handle_pool_reset()


# ============================================================================
# Error Handling
# ============================================================================

describe "Handle - invalid deref":
    it "returns -1 for freed handle":
        handle_pool_new(4)
        val h = handle_alloc(42)
        handle_free(h)
        val v = handle_deref(h)
        expect(v).to_equal(-1)
        handle_pool_reset()

describe "Handle - double free":
    it "second free returns false":
        handle_pool_new(4)
        val h = handle_alloc(42)
        val ok1 = handle_free(h)
        val ok2 = handle_free(h)
        expect(ok1).to_equal(true)
        expect(ok2).to_equal(false)
        handle_pool_reset()
