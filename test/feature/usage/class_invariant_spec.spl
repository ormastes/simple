# # Class Invariant Specification
#
# **Feature IDs:** #CONTRACT-INV-001 to #CONTRACT-INV-018
# **Category:** Type System | Contracts
# **Status:** Implemented
#
# Tests that class invariants are properly checked:
# - After constructor execution (even if constructor is private)
# - Before/after public method execution
# - NOT checked for private methods
#
# ## Syntax
#
# ```simple
# class Counter:
# value: i64
#
# invariant:
# self.value >= 0
#
# static fn new() -> Counter:
# Counter(value: 0)
#
# me increment():
# self.value = self.value + 1
# ```

# Define classes at module level so static methods work in it-blocks

class Counter1:
    value: i64

    invariant:
        self.value >= 0

    static fn new(initial: i64) -> Counter1:
        Counter1(value: initial)

class BoundedCounter:
    value: i64
    max: i64

    invariant:
        self.value >= 0
        self.value <= self.max
        self.max > 0

    static fn new(initial: i64, maximum: i64) -> BoundedCounter:
        BoundedCounter(value: initial, max: maximum)

class Account1:
    balance: i64

    invariant:
        self.balance >= 0

    static fn new(initial_balance: i64) -> Account1:
        Account1(balance: initial_balance)

    static fn create_with_deposit(amount: i64) -> Account1:
        Account1.new(amount)

class PositiveValue:
    value: i64

    invariant:
        self.value > 0

    static fn new(x: i64) -> PositiveValue:
        PositiveValue(value: x)

class Counter2:
    value: i64

    invariant:
        self.value >= 0

    static fn new() -> Counter2:
        Counter2(value: 0)

    me increment():
        self.value = self.value + 1

    me decrement():
        self.value = self.value - 1

class Range1:
    min: i64
    max: i64

    invariant:
        self.min <= self.max
        self.max >= 0

    static fn new(a: i64, b: i64) -> Range1:
        Range1(min: a, max: b)

    me expand(delta: i64):
        self.max = self.max + delta

class Account2:
    balance: i64

    invariant:
        self.balance >= 0

    static fn new(initial: i64) -> Account2:
        Account2(balance: initial)

class Transaction:
    amount: i64
    timestamp: i64

    invariant:
        self.amount > 0
        self.timestamp >= 0

    static fn new(amt: i64, ts: i64) -> Transaction:
        Transaction(amount: amt, timestamp: ts)

class SimpleClass:
    value: i64

    static fn new(v: i64) -> SimpleClass:
        SimpleClass(value: v)

    fn get_value() -> i64:
        self.value

class ValueHolder:
    value: i64

    fn is_positive() -> bool:
        self.value > 0

    invariant:
        self.value > 0

    static fn new(v: i64) -> ValueHolder:
        ValueHolder(value: v)

class PublicClass:
    value: i64

    invariant:
        self.value >= 0

    static fn new(v: i64) -> PublicClass:
        PublicClass(value: v)

class Counter3:
    count: i64

    invariant:
        self.count >= 0

    static fn new() -> Counter3:
        Counter3(count: 0)

    static fn from_value(v: i64) -> Counter3:
        Counter3(count: v)

class BankAccount:
    balance: i64
    owner: text

    invariant:
        self.balance >= 0

    static fn new(owner_name: text) -> BankAccount:
        BankAccount(balance: 0, owner: owner_name)

    static fn from_balance(owner_name: text, initial: i64) -> BankAccount:
        BankAccount(balance: initial, owner: owner_name)

    me deposit(amount: i64):
        self.balance = self.balance + amount

    me withdraw(amount: i64) -> bool:
        if self.balance >= amount:
            self.balance = self.balance - amount
            true
        else:
            false

    fn get_balance() -> i64:
        self.balance

class ConfigObj:
    timeout: i64
    retries: i64

    invariant:
        self.timeout > 0
        self.retries >= 0
        self.retries <= 10

    static fn create_default() -> ConfigObj:
        ConfigObj(timeout: 30, retries: 3)

    static fn from_timeout(t: i64) -> ConfigObj:
        ConfigObj(timeout: t, retries: 3)

    static fn with_retries(r: i64) -> ConfigObj:
        ConfigObj(timeout: 30, retries: r)

struct Point1:
    x: i64
    y: i64

    invariant:
        self.x >= 0
        self.y >= 0

    static fn new(x_val: i64, y_val: i64) -> Point1:
        Point1(x: x_val, y: y_val)

    static fn origin() -> Point1:
        Point1(x: 0, y: 0)

    fn distance_squared() -> i64:
        self.x * self.x + self.y * self.y


# ============================================================================
# Test Group 1: Constructor Invariant Checks
# ============================================================================

describe "Constructor Invariant Checks":
    it "checks invariant after constructor":
        val c = Counter1.new(10)
        expect(c.value).to_equal(10)

    it "checks multiple invariants after constructor":
        val bc = BoundedCounter.new(5, 100)
        expect(bc.value).to_equal(5)

    it "private constructor gets invariant check":
        val acc = Account1.create_with_deposit(100)
        expect(acc.balance).to_equal(100)

    it "constructor with precondition and invariant":
        val pv = PositiveValue.new(42)
        expect(pv.value).to_equal(42)


# ============================================================================
# Test Group 2: Public Method Invariant Checks
# ============================================================================

describe "Public Method Invariant Checks":
    it "public method checks invariants":
        var c = Counter2.new()
        c.increment()
        expect(c.value).to_equal(1)
        c.decrement()
        expect(c.value).to_equal(0)

    it "private method skips invariants":
        var c = Counter2.new()
        c.increment()
        c.increment()
        expect(c.value).to_equal(2)

    it "complex invariant with field comparison":
        var r = Range1.new(0, 10)
        r.expand(5)
        expect(r.max).to_equal(15)


# ============================================================================
# Test Group 3: Multiple Classes with Invariants
# ============================================================================

describe "Multiple Classes with Invariants":
    it "separate invariants per class":
        val acc = Account2.new(100)
        val tx = Transaction.new(50, 1234567890)
        expect(acc.balance).to_equal(100)
        expect(tx.amount).to_equal(50)


# ============================================================================
# Test Group 5: Edge Cases
# ============================================================================

describe "Class Invariant Edge Cases":
    it "class without invariant works":
        val s = SimpleClass.new(42)
        expect(s.get_value()).to_equal(42)

    it "invariant can reference pure methods":
        val vh = ValueHolder.new(42)
        expect(vh.value).to_equal(42)


# ============================================================================
# Test Group 6: Constructor Visibility Tests
# ============================================================================

describe "Constructor Visibility":
    it "explicitly public constructor gets invariants":
        val p = PublicClass.new(42)
        expect(p.value).to_equal(42)

    it "constructor detected by name":
        val c1 = Counter3.new()
        val c2 = Counter3.from_value(42)
        expect(c1.count).to_equal(0)
        expect(c2.count).to_equal(42)


# ============================================================================
# Test Group 7: Complete Integration
# ============================================================================

describe "Complete Class Contract Integration":
    it "bank account with full contracts":
        var acc = BankAccount.from_balance("Alice", 100)
        acc.deposit(50)
        expect(acc.get_balance()).to_equal(150)
        val success = acc.withdraw(30)
        expect(success).to_equal(true)
        expect(acc.get_balance()).to_equal(120)


# ============================================================================
# Test Group 8: Factory Methods
# ============================================================================

describe "Factory Method Invariants":
    it "factory methods get invariants":
        val c1 = ConfigObj.create_default()
        val c2 = ConfigObj.from_timeout(60)
        val c3 = ConfigObj.with_retries(5)
        expect(c1.timeout).to_equal(30)
        expect(c2.timeout).to_equal(60)
        expect(c3.retries).to_equal(5)


# ============================================================================
# Test Group 9: Struct with Invariants
# ============================================================================

describe "Struct Invariants":
    it "struct has invariant checks":
        val p = Point1.new(3, 4)
        expect(p.distance_squared()).to_equal(25)
