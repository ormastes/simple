# @cover src/lib/common/math_repr.spl 90%
"""
# Math Block Rendering Specification

**Feature IDs:** #1090-1102 (math block rendering)
**Category:** Syntax / Math DSL / Rendering
**Difficulty:** 3/5
**Status:** Implemented

## Overview

Intensive tests for the math expression rendering pipeline:
- `to_text()`:         Normalized plain text
- `to_debug()`:        AST structure
- `to_pretty()`:       Unicode pretty print
- `to_md()`:           Markdown LaTeX
- `render_latex_raw()`: Raw LaTeX output

Covers edge cases: nested fracs, sum/integral binders, transpose,
subscript, complex DL equations, Greek letters, operator precedence,
implicit multiplication, and LaTeX-style commands.
"""

use std.math_repr.{to_text, to_debug, to_pretty, to_md, render_latex_raw}

# ============================================================================
# to_text — Normalized Plain Text
# ============================================================================

describe "to_text rendering":

    context "arithmetic":
        it "renders addition":
            expect to_text("2 + 3") == "2 + 3"

        it "renders subtraction":
            expect to_text("10 - 3") == "10 - 3"

        it "renders multiplication":
            expect to_text("4 * 5") == "4 * 5"

        it "renders division":
            expect to_text("15 / 3") == "15 / 3"

        it "renders negation":
            expect to_text("-5") == "-5"

        it "renders parenthesized group":
            expect to_text("(2 + 3) * 4") == "(2 + 3) * 4"

        it "renders power":
            expect to_text("x^2") == "x^2"

        it "renders complex expression":
            expect to_text("2 + 3 * 4") == "2 + 3 * 4"

    context "functions":
        it "renders sqrt":
            expect to_text("sqrt(16)") == "sqrt(16)"

        it "renders abs":
            expect to_text("abs(-5)") == "abs(-5)"

        it "renders frac as division":
            expect to_text("frac(1, 2)") == "1 / 2"

        it "renders nested frac":
            expect to_text("frac(1, frac(1, 2))") == "1 / 1 / 2"

        it "renders multi-arg function":
            expect to_text("dot(a, b)") == "dot(a, b)"

    context "subscript and transpose":
        it "renders subscript":
            expect to_text("x[0]") == "x[0]"

        it "renders nested subscript":
            expect to_text("A[0][1]") == "A[0][1]"

        it "renders transpose":
            expect to_text("A'") == "A'"

    context "binders":
        it "renders sum":
            expect (to_text("sum(i, 0..10) i")).contains("sum")
            expect (to_text("sum(i, 0..10) i")).contains("0")
            expect (to_text("sum(i, 0..10) i")).contains("10")

        it "renders integral":
            expect (to_text("int(x, 0..1) x")).contains("int")
            expect (to_text("int(x, 0..1) x")).contains("0")
            expect (to_text("int(x, 0..1) x")).contains("1")


# ============================================================================
# to_debug — AST Structure
# ============================================================================

describe "to_debug rendering":

    context "literals and identifiers":
        it "renders number":
            expect to_debug("42") == "Num(42)"

        it "renders float":
            expect to_debug("3.14") == "Num(3.14)"

        it "renders identifier":
            expect to_debug("x") == "Id(x)"

    context "binary operators":
        it "renders addition":
            expect to_debug("2 + 3") == "Add(Num(2), Num(3))"

        it "renders subtraction":
            expect to_debug("10 - 3") == "Sub(Num(10), Num(3))"

        it "renders multiplication":
            expect to_debug("4 * 5") == "Mul(Num(4), Num(5))"

        it "renders division":
            expect to_debug("15 / 3") == "Div(Num(15), Num(3))"

        it "renders power":
            expect to_debug("x^2") == "Pow(Id(x), Num(2))"

    context "unary and grouping":
        it "renders negation":
            expect to_debug("-5") == "Neg(Num(5))"

        it "renders group":
            expect to_debug("(x)") == "Group(Id(x))"

    context "functions":
        it "renders frac":
            expect to_debug("frac(1, 2)") == "Frac(Num(1), Num(2))"

        it "renders nested frac":
            expect to_debug("frac(1, frac(2, 3))") == "Frac(Num(1), Frac(Num(2), Num(3)))"

        it "renders sqrt call":
            expect to_debug("sqrt(x)") == "Call(sqrt, Id(x))"

        it "renders multi-arg call":
            expect to_debug("dot(a, b)") == "Call(dot, Id(a), Id(b))"

    context "postfix":
        it "renders subscript":
            expect (to_debug("x[0]")).contains("Sub(")

        it "renders transpose":
            expect to_debug("A'") == "Transpose(Id(A))"

    context "precedence":
        it "renders add-mul precedence":
            expect to_debug("2 + 3 * 4") == "Add(Num(2), Mul(Num(3), Num(4)))"

        it "renders power right-assoc with unary":
            # x^-2 means x^(-2)
            expect to_debug("x^-2") == "Pow(Id(x), Neg(Num(2)))"

    context "complex expressions":
        it "renders sigmoid":
            val ast = to_debug("frac(1, 1 + exp(-x))")
            expect (ast).contains("Frac")
            expect (ast).contains("Add")
            expect (ast).contains("Call(exp")
            expect (ast).contains("Neg(Id(x))")

        it "renders layer norm":
            val ast = to_debug("frac(x - mu, sqrt(sigma^2 + epsilon))")
            expect (ast).contains("Frac")
            expect (ast).contains("Sub(Id(x), Id(mu))")
            expect (ast).contains("Call(sqrt")
            expect (ast).contains("Pow(Id(sigma), Num(2))")


# ============================================================================
# render_latex_raw — LaTeX Output
# ============================================================================

describe "render_latex_raw rendering":

    context "arithmetic":
        it "renders addition":
            expect render_latex_raw("2 + 3") == "2 + 3"

        it "renders subtraction":
            expect render_latex_raw("10 - 3") == "10 - 3"

        it "renders explicit multiplication as cdot":
            expect (render_latex_raw("4 * 5")).contains("\\cdot")

        it "renders division":
            expect render_latex_raw("15 / 3") == "15 / 3"

        it "renders power":
            val latex = render_latex_raw("x^2")
            expect (latex).contains("x")
            expect (latex).contains("2")

        it "renders negation":
            expect render_latex_raw("-x") == "-x"

    context "fractions":
        it "renders frac":
            val latex = render_latex_raw("frac(1, 2)")
            expect (latex).contains("\\frac")
            expect (latex).contains("{1}")
            expect (latex).contains("{2}")

        it "renders nested frac":
            val latex = render_latex_raw("frac(1, frac(2, 3))")
            expect (latex).contains("\\frac")
            expect (latex).contains("{1}")
            expect (latex).contains("{\\frac")

        it "renders frac with complex numerator":
            val latex = render_latex_raw("frac(x + 1, 2)")
            expect (latex).contains("\\frac")
            expect (latex).contains("x + 1")

        it "renders frac with complex denominator":
            val latex = render_latex_raw("frac(1, x^2 + 1)")
            expect (latex).contains("\\frac")

    context "functions":
        it "renders sqrt":
            val latex = render_latex_raw("sqrt(x)")
            expect (latex).contains("\\sqrt")

        it "renders known function sin":
            val latex = render_latex_raw("sin(x)")
            expect (latex).contains("\\sin")

        it "renders known function cos":
            val latex = render_latex_raw("cos(x)")
            expect (latex).contains("\\cos")

        it "renders known function exp":
            val latex = render_latex_raw("exp(x)")
            expect (latex).contains("\\exp")

        it "renders known function log":
            val latex = render_latex_raw("log(x)")
            expect (latex).contains("\\log")

        it "renders known function ln":
            val latex = render_latex_raw("ln(x)")
            expect (latex).contains("\\ln")

        it "renders known function tanh":
            val latex = render_latex_raw("tanh(x)")
            expect (latex).contains("\\tanh")

        it "renders unknown function as operatorname":
            val latex = render_latex_raw("relu(x)")
            expect (latex).contains(r"\operatorname{relu}")

        it "renders nested sqrt in frac":
            val latex = render_latex_raw("frac(1, sqrt(x))")
            expect (latex).contains("\\frac")
            expect (latex).contains("\\sqrt")

    context "greek letters":
        it "renders alpha":
            expect render_latex_raw("alpha") == "\\alpha"

        it "renders pi":
            expect render_latex_raw("pi") == "\\pi"

        it "renders theta":
            expect render_latex_raw("theta") == "\\theta"

        it "renders sigma":
            expect render_latex_raw("sigma") == "\\sigma"

        it "renders omega":
            expect render_latex_raw("omega") == "\\omega"

        it "renders upper Gamma":
            expect render_latex_raw("Gamma") == "\\Gamma"

        it "renders upper Sigma":
            expect render_latex_raw("Sigma") == "\\Sigma"

        it "renders upper Omega":
            expect render_latex_raw("Omega") == "\\Omega"

    context "subscript and transpose":
        it "renders subscript":
            val latex = render_latex_raw("x[i]")
            expect (latex).contains("x")
            expect (latex).contains("i")

        it "renders transpose":
            val latex = render_latex_raw("A'")
            expect (latex).contains("A")
            expect (latex).contains("T")

    context "binders":
        it "renders sum":
            val latex = render_latex_raw("sum(i, 0..10) i")
            expect (latex).contains("\\sum")
            expect (latex).contains("i")

        it "renders integral":
            val latex = render_latex_raw("int(x, 0..1) x")
            expect (latex).contains("\\int")
            expect (latex).contains("x")

    context "DL equations":
        it "renders sigmoid":
            val latex = render_latex_raw("frac(1, 1 + exp(-x))")
            expect (latex).contains("\\frac")
            expect (latex).contains("\\exp")

        it "renders MSE loss":
            val latex = render_latex_raw("frac(1, n) * sum(i, 1..n) (y[i] - pred[i])^2")
            expect (latex).contains("\\frac")
            expect (latex).contains("\\sum")

        it "renders softmax numerator":
            val latex = render_latex_raw("frac(exp(x[i]), sum(j, 1..n) exp(x[j]))")
            expect (latex).contains("\\frac")
            expect (latex).contains("\\exp")
            expect (latex).contains("\\sum")

        it "renders layer norm":
            val latex = render_latex_raw("frac(x - mu, sqrt(sigma^2 + epsilon))")
            expect (latex).contains("\\frac")
            expect (latex).contains("\\sqrt")
            expect (latex).contains("\\epsilon")

        it "renders SGD update":
            val latex = render_latex_raw("theta - alpha * nabla * J(theta)")
            expect (latex).contains("\\theta")
            expect (latex).contains("\\alpha")
            expect (latex).contains("\\nabla")

        it "renders cross entropy":
            val latex = render_latex_raw("-sum(i, 1..n) y[i] * log(pred[i])")
            expect (latex).contains("\\sum")
            expect (latex).contains("\\log")

        it "renders xavier init":
            val latex = render_latex_raw("sqrt(frac(6, fan_in + fan_out))")
            expect (latex).contains("\\sqrt")
            expect (latex).contains("\\frac")

        it "renders attention scores":
            val latex = render_latex_raw("frac(Q * K', sqrt(d_k))")
            expect (latex).contains("\\frac")
            expect (latex).contains("\\sqrt")
            expect (latex).contains("T")


# ============================================================================
# to_pretty — Unicode Pretty Print
# ============================================================================

describe "to_pretty rendering":

    context "identifiers and constants":
        it "renders plain identifier":
            expect to_pretty("x") == "x"

        it "renders greek alpha":
            expect to_pretty("alpha") == "α"

        it "renders greek pi":
            expect to_pretty("pi") == "π"

        it "renders greek theta":
            expect to_pretty("theta") == "θ"

        it "renders greek sigma":
            expect to_pretty("sigma") == "σ"

        it "renders greek omega":
            expect to_pretty("omega") == "ω"

        it "renders greek lambda":
            expect to_pretty("lambda") == "λ"

        it "renders upper Gamma":
            expect to_pretty("Gamma") == "Γ"

        it "renders upper Delta":
            expect to_pretty("Delta") == "Δ"

        it "renders upper Sigma":
            expect to_pretty("Sigma") == "Σ"

        it "renders upper Omega":
            expect to_pretty("Omega") == "Ω"

    context "arithmetic":
        it "renders addition":
            expect to_pretty("2 + 3") == "2 + 3"

        it "renders subtraction":
            expect to_pretty("10 - 3") == "10 - 3"

        it "renders negation":
            expect to_pretty("-x") == "-x"

    context "power — superscript":
        it "renders x^2":
            val p = to_pretty("x^2")
            expect (p).contains("x")
            # Should use superscript ²
            expect (p).contains("²")

        it "renders x^3":
            val p = to_pretty("x^3")
            expect (p).contains("³")

        it "renders x^n":
            val p = to_pretty("x^n")
            expect (p).contains("x")

    context "fractions":
        it "renders simple frac":
            val p = to_pretty("frac(1, 2)")
            expect p == "(1)/(2)"

        it "renders nested frac":
            val p = to_pretty("frac(1, frac(2, 3))")
            expect (p).contains("1")
            expect (p).contains("2")
            expect (p).contains("3")

    context "sqrt":
        it "renders sqrt":
            val p = to_pretty("sqrt(x)")
            expect (p).contains("√")
            expect (p).contains("x")

        it "renders sqrt of expression":
            val p = to_pretty("sqrt(x^2 + 1)")
            expect (p).contains("√")

    context "binders":
        it "renders sum with Unicode sigma":
            val p = to_pretty("sum(i, 0..10) i^2")
            expect p == "∑(i=0..10) i²"

        it "renders integral with Unicode symbol":
            val p = to_pretty("int(x, 0..1) x^2")
            expect p == "∫(x=0..1) x²"

    context "DL equations":
        it "renders sigmoid":
            val p = to_pretty("frac(1, 1 + exp(-x))")
            expect (p).contains("1")
            expect (p).contains("exp")

        it "renders layer norm":
            val p = to_pretty("frac(x - mu, sqrt(sigma^2 + epsilon))")
            expect (p).contains("√")
            expect (p).contains("μ")
            expect (p).contains("σ")
            expect (p).contains("ε")

        it "renders SGD update with greek":
            val p = to_pretty("theta - alpha * grad")
            expect (p).contains("θ")
            expect (p).contains("α")

        it "renders xavier init":
            val p = to_pretty("sqrt(frac(6, fan_in + fan_out))")
            expect (p).contains("√")


# ============================================================================
# to_md — Markdown LaTeX
# ============================================================================

describe "to_md rendering":

    it "wraps in dollar signs":
        val md = to_md("x + 1")
        expect (md).starts_with("$")
        expect (md).ends_with("$")

    it "renders frac in markdown":
        val md = to_md("frac(1, 2)")
        expect (md).contains("\\frac")
        expect (md).starts_with("$")
        expect (md).ends_with("$")

    it "renders greek in markdown":
        val md = to_md("alpha + beta")
        expect (md).contains("\\alpha")
        expect (md).contains("\\beta")
        expect (md).starts_with("$")

    it "renders complex DL equation":
        val md = to_md("frac(1, 1 + exp(-x))")
        expect (md).contains("\\frac")
        expect (md).contains("\\exp")
        expect (md).starts_with("$")
        expect (md).ends_with("$")

    it "renders sum binder":
        val md = to_md("sum(i, 1..n) x[i]^2")
        expect (md).contains("\\sum")
        expect (md).starts_with("$")


# ============================================================================
# Edge Cases — Stress Tests
# ============================================================================

describe "rendering edge cases":

    context "deeply nested":
        it "renders triple-nested frac":
            val latex = render_latex_raw("frac(frac(1, 2), frac(3, 4))")
            expect (latex).contains("\\frac")
            expect (latex).contains("{1}")
            expect (latex).contains("{2}")
            expect (latex).contains("{3}")
            expect (latex).contains("{4}")

        it "renders frac inside sqrt inside frac":
            val latex = render_latex_raw("frac(1, sqrt(frac(2, 3)))")
            expect (latex).contains("\\frac")
            expect (latex).contains("\\sqrt")

        it "renders power of frac":
            val latex = render_latex_raw("frac(1, 2)^3")
            expect (latex).contains("\\frac")

    context "implicit multiplication":
        it "renders 2x":
            val t = to_text("2x")
            expect (t).contains("2")
            expect (t).contains("x")

        it "renders 3(x + 1)":
            val t = to_text("3(x + 1)")
            expect (t).contains("3")
            expect (t).contains("x + 1")

    context "complex DL architectures":
        it "renders attention formula":
            # Attention(Q, K, V) = softmax(QK^T / sqrt(d_k)) V
            val latex = render_latex_raw("frac(Q * K', sqrt(d_k))")
            expect (latex).contains("\\frac")
            expect (latex).contains("\\sqrt")

        it "renders batch norm":
            val latex = render_latex_raw("gamma * frac(x - mu, sqrt(sigma^2 + epsilon)) + beta")
            expect (latex).contains("\\gamma")
            expect (latex).contains("\\frac")
            expect (latex).contains("\\sqrt")
            expect (latex).contains("\\beta")
            expect (latex).contains("\\epsilon")

        it "renders KL divergence":
            val latex = render_latex_raw("sum(i, 1..n) p[i] * log(frac(p[i], q[i]))")
            expect (latex).contains("\\sum")
            expect (latex).contains("\\log")
            expect (latex).contains("\\frac")

        it "renders GELU approximation":
            # 0.5 * x * (1 + tanh(sqrt(2/pi) * (x + 0.044715 * x^3)))
            val latex = render_latex_raw("0.5 * x * (1 + tanh(sqrt(frac(2, pi)) * (x + 0.044715 * x^3)))")
            expect (latex).contains("\\tanh")
            expect (latex).contains("\\sqrt")
            expect (latex).contains("\\frac")
            expect (latex).contains("\\pi")

        it "renders Adam optimizer update":
            val latex = render_latex_raw("theta - alpha * frac(m_hat, sqrt(v_hat) + epsilon)")
            expect (latex).contains("\\theta")
            expect (latex).contains("\\alpha")
            expect (latex).contains("\\frac")
            expect (latex).contains("\\sqrt")
            expect (latex).contains("\\epsilon")

    context "m{} loss{} nograd{} evaluation parity in rendering":
        it "m{} and loss{} render same to_pretty":
            val m_text = to_pretty("frac(1, 1 + exp(-x))")
            # loss{} and nograd{} use the same rendering pipeline
            # (they all pass the inner expression to math_repr)
            val l_text = to_pretty("frac(1, 1 + exp(-x))")
            expect m_text == l_text

        it "m{} and loss{} render same LaTeX":
            val m_latex = render_latex_raw("theta - alpha * grad")
            val l_latex = render_latex_raw("theta - alpha * grad")
            expect m_latex == l_latex

    context "Greek mixed with operators":
        it "renders alpha * beta + gamma":
            val latex = render_latex_raw("alpha * beta + gamma")
            expect (latex).contains("\\alpha")
            expect (latex).contains("\\beta")
            expect (latex).contains("\\gamma")

        it "renders partial derivative notation":
            val latex = render_latex_raw("partial * f / partial * x")
            expect (latex).contains("\\partial")

        it "renders nabla operator":
            val latex = render_latex_raw("nabla * f(x)")
            expect (latex).contains("\\nabla")

    context "subscript chains":
        it "renders A[i][j]":
            val latex = render_latex_raw("A[i][j]")
            expect (latex).contains("A")
            expect (latex).contains("i")
            expect (latex).contains("j")

        it "renders x[i]^2":
            val latex = render_latex_raw("x[i]^2")
            expect (latex).contains("x")
            expect (latex).contains("i")

    context "empty and minimal":
        it "renders single number":
            expect render_latex_raw("42") == "42"
            expect to_pretty("42") == "42"
            expect to_text("42") == "42"

        it "renders single identifier":
            expect render_latex_raw("x") == "x"
            expect to_pretty("x") == "x"
            expect to_text("x") == "x"

        it "renders single greek letter":
            expect render_latex_raw("pi") == "\\pi"
            expect to_pretty("pi") == "π"