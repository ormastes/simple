"""
# loss{} and nograd{} Block Tests

**Feature IDs:** #1099-1102 (loss/nograd block support)
**Category:** Syntax / Math DSL
**Difficulty:** 2/5
**Status:** Implemented

## Overview

Tests that `loss{}` and `nograd{}` blocks parse, evaluate, and render the
same supported math-expression subset as `m{}` blocks. Runtime autograd
semantics are covered by `math_autograd_runtime_spec.spl`.
"""

use std.math_repr.{render_latex_raw, to_pretty}

# Helper for floating point comparison
fn close(a: f64, b: f64, eps: f64) -> bool:
    val diff = a - b
    val abs_diff = if diff < 0.0: 0.0 - diff else: diff
    abs_diff < eps

# ============================================================================
# loss{} Block Evaluation
# ============================================================================

describe "loss{} block evaluation":

    context "basic arithmetic":
        it "evaluates addition":
            val result = loss{ 2 + 3 }
            expect result == 5

        it "evaluates subtraction":
            val result = loss{ 10 - 4 }
            expect result == 6

        it "evaluates multiplication":
            val result = loss{ 3 * 4 }
            expect result == 12

        it "evaluates division":
            val result = loss{ 10 / 2 }
            expect result == 5

    context "power operator":
        it "evaluates integer power":
            val x = 3.0
            val result = loss{ x^2 }
            expect result == 9.0

        it "evaluates fractional power":
            val x = 4.0
            val result = loss{ x^0.5 }
            expect result == 2.0

    context "fractions":
        it "evaluates frac":
            val result = loss{ frac(1, 2) }
            expect result == 0.5

        it "evaluates nested frac":
            val result = loss{ frac(1, frac(1, 2)) }
            expect result == 2.0

    context "scope variable bridging":
        it "reads outer variables":
            val x = 5.0
            val y = 3.0
            val result = loss{ x + y }
            expect result == 8.0

        it "reads multiple outer variables":
            val a = 2.0
            val b = 3.0
            val c = 4.0
            val result = loss{ a * b + c }
            expect result == 10.0

    context "math functions":
        it "evaluates sqrt":
            val result = loss{ sqrt(16) }
            expect result == 4.0

        it "evaluates exp":
            expect close(loss{ exp(0) }, 1.0, 0.01) == true

        it "evaluates abs":
            val result = loss{ abs(-5) }
            expect result == 5

# ============================================================================
# nograd{} Block Evaluation
# ============================================================================

describe "nograd{} block evaluation":

    context "basic arithmetic":
        it "evaluates addition":
            val result = nograd{ 2 + 3 }
            expect result == 5

        it "evaluates subtraction":
            val result = nograd{ 10 - 4 }
            expect result == 6

        it "evaluates multiplication":
            val result = nograd{ 3 * 4 }
            expect result == 12

        it "evaluates division":
            val result = nograd{ 10 / 2 }
            expect result == 5

    context "power operator":
        it "evaluates integer power":
            val x = 3.0
            val result = nograd{ x^2 }
            expect result == 9.0

        it "evaluates fractional power":
            val x = 4.0
            val result = nograd{ x^0.5 }
            expect result == 2.0

    context "fractions":
        it "evaluates frac":
            val result = nograd{ frac(1, 2) }
            expect result == 0.5

    context "scope variable bridging":
        it "reads outer variables":
            val x = 5.0
            val y = 3.0
            val result = nograd{ x + y }
            expect result == 8.0

    context "math functions":
        it "evaluates sqrt":
            val result = nograd{ sqrt(16) }
            expect result == 4.0

        it "evaluates exp":
            expect close(nograd{ exp(0) }, 1.0, 0.01) == true

# ============================================================================
# Rendering: LaTeX and Unicode
# ============================================================================

describe "loss{} rendering":

    it "renders LaTeX via render_latex_raw":
        val latex = render_latex_raw("frac(1, 1 + exp(-x))")
        expect (latex).contains("\\frac")
        expect (latex).contains("\\exp")

    it "renders Unicode via to_pretty":
        val pretty = to_pretty("frac(1, 1 + exp(-x))")
        expect (pretty).contains("exp")

describe "nograd{} rendering":

    it "renders LaTeX via render_latex_raw":
        val latex = render_latex_raw("sqrt(frac(6, fan_in + fan_out))")
        expect (latex).contains("\\sqrt")
        expect (latex).contains("\\frac")

    it "renders Unicode via to_pretty":
        val pretty = to_pretty("sqrt(frac(6, fan_in + fan_out))")
        expect (pretty).contains("√")