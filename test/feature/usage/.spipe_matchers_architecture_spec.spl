"""
# Multi-Architecture Support

**Feature ID:** #ARCH-002
**Category:** Compiler
**Status:** In Progress

## Overview

Tests multi-architecture support across 8-bit, 16-bit, 32-bit, and 64-bit targets
including AVR, MCS51, MSP430, x86, ARM, RISC-V, x86_64, and AArch64. Validates
architecture properties (pointer size, stack alignment, FPU, endianness),
target triple generation for bare-metal and hosted environments, and
TargetConfig generation for each bit-width class.

## Syntax

```simple
val avr = TargetArch.AVR
expect avr.bits() == 8
val config = TargetConfig.for_arch(TargetArch.X86_64)
```
Architecture Support Specification

Tests multi-architecture support (8/16/32/64-bit) including:
- Target architecture properties
- Pointer-sized types (usize/isize)
- Calling conventions
- Type layout per architecture

Feature IDs: #BM-ARCH-001
Category: Bare-Metal
Status: In Progress

NOTE: parse tests use parse_target_arch() free function wrapper
instead of TargetArch.parse() static method (not supported in interpreter)
"""

use std.common.target.{TargetArch, PointerSize, Endian, TargetConfig, parse_target_arch}

describe "Target Architecture":
    describe "8-bit Architectures":
        it "AVR has correct properties":
            val avr = TargetArch.AVR
            expect avr.bits() == 8
            expect avr.pointer_bytes() == 2
            expect avr.stack_align() == 1
            expect avr.max_atomic_width() == 8
            expect avr.has_fpu() == false
            expect avr.is_harvard() == true
            expect avr.endianness() == Endian.Little

        it "MCS51 has correct properties":
            val mcs51 = TargetArch.MCS51
            expect mcs51.bits() == 8
            expect mcs51.pointer_bytes() == 2
            expect mcs51.stack_align() == 1
            expect mcs51.has_fpu() == false
            expect mcs51.is_harvard() == true
            expect mcs51.endianness() == Endian.Big

        it "AVR parses from string":
            val parsed = parse_target_arch("avr")
            expect parsed.? == true
            expect parsed.unwrap() == TargetArch.AVR

            val parsed2 = parse_target_arch("atmega")
            expect parsed2.? == true
            expect parsed2.unwrap() == TargetArch.AVR

    describe "16-bit Architectures":
        it "MSP430 has correct properties":
            val msp = TargetArch.MSP430
            expect msp.bits() == 16
            expect msp.pointer_bytes() == 2
            expect msp.stack_align() == 2
            expect msp.max_atomic_width() == 16
            expect msp.has_fpu() == false
            expect msp.is_harvard() == false
            expect msp.endianness() == Endian.Little

        it "MSP430 parses from string":
            val parsed = parse_target_arch("msp430")
            expect parsed.? == true
            expect parsed.unwrap() == TargetArch.MSP430

    describe "32-bit Architectures":
        it "x86 has correct properties":
            val x86 = TargetArch.X86
            expect x86.bits() == 32
            expect x86.pointer_bytes() == 4
            expect x86.stack_align() == 4
            expect x86.max_atomic_width() == 64
            expect x86.has_fpu() == true
            expect x86.is_harvard() == false

        it "ARM has correct properties":
            val arm = TargetArch.Arm
            expect arm.bits() == 32
            expect arm.pointer_bytes() == 4
            expect arm.stack_align() == 4
            expect arm.has_fpu() == false

        it "RISC-V 32 has correct properties":
            val rv32 = TargetArch.Riscv32
            expect rv32.bits() == 32
            expect rv32.pointer_bytes() == 4

    describe "64-bit Architectures":
        it "x86_64 has correct properties":
            val x64 = TargetArch.X86_64
            expect x64.bits() == 64
            expect x64.pointer_bytes() == 8
            expect x64.stack_align() == 16
            expect x64.max_atomic_width() == 128
            expect x64.has_fpu() == true

        it "AArch64 has correct properties":
            val arm64 = TargetArch.Aarch64
            expect arm64.bits() == 64
            expect arm64.pointer_bytes() == 8
            expect arm64.stack_align() == 16

        it "RISC-V 64 has correct properties":
            val rv64 = TargetArch.Riscv64
            expect rv64.bits() == 64
            expect rv64.pointer_bytes() == 8

describe "Pointer Size":
    it "8-bit and 16-bit use 16-bit pointers":
        val avr = TargetArch.AVR
        val mcs51 = TargetArch.MCS51
        val msp430 = TargetArch.MSP430
        expect avr.pointer_size() == PointerSize.Bits16
        expect mcs51.pointer_size() == PointerSize.Bits16
        expect msp430.pointer_size() == PointerSize.Bits16

    it "32-bit uses 32-bit pointers":
        val x86 = TargetArch.X86
        val arm = TargetArch.Arm
        val rv32 = TargetArch.Riscv32
        expect x86.pointer_size() == PointerSize.Bits32
        expect arm.pointer_size() == PointerSize.Bits32
        expect rv32.pointer_size() == PointerSize.Bits32

    it "64-bit uses 64-bit pointers":
        val x64 = TargetArch.X86_64
        val arm64 = TargetArch.Aarch64
        val rv64 = TargetArch.Riscv64
        expect x64.pointer_size() == PointerSize.Bits64
        expect arm64.pointer_size() == PointerSize.Bits64
        expect rv64.pointer_size() == PointerSize.Bits64

    it "PointerSize returns correct byte count":
        val p16 = PointerSize.Bits16
        val p32 = PointerSize.Bits32
        val p64 = PointerSize.Bits64
        expect p16.bytes() == 2
        expect p32.bytes() == 4
        expect p64.bytes() == 8

describe "Target Triple":
    it "generates correct bare-metal triples":
        val avr = TargetArch.AVR
        val msp430 = TargetArch.MSP430
        val x86 = TargetArch.X86
        val arm = TargetArch.Arm
        val x64 = TargetArch.X86_64
        expect avr.triple_str_baremetal() == "avr-unknown-unknown"
        expect msp430.triple_str_baremetal() == "msp430-none-elf"
        expect x86.triple_str_baremetal() == "i686-unknown-none"
        expect arm.triple_str_baremetal() == "thumbv7m-none-eabi"
        expect x64.triple_str_baremetal() == "x86_64-unknown-none"

    it "generates correct hosted triples":
        val x86 = TargetArch.X86
        val x64 = TargetArch.X86_64
        val arm = TargetArch.Arm
        expect x86.triple_str() == "i686-unknown-linux-gnu"
        expect x64.triple_str() == "x86_64-unknown-linux-gnu"
        expect arm.triple_str() == "armv7-unknown-linux-gnueabihf"

describe "Target Config":
    it "configures 8-bit correctly":
        val config = TargetConfig.for_arch(TargetArch.AVR)
        expect config.pointer_bytes == 2
        expect config.value_bytes == 2
        expect config.tag_bits == 0
        expect config.heap_align == 1
        expect config.default_stack_size == 256

    it "configures 16-bit correctly":
        val config = TargetConfig.for_arch(TargetArch.MSP430)
        expect config.pointer_bytes == 2
        expect config.value_bytes == 2
        expect config.tag_bits == 1
        expect config.heap_align == 2
        expect config.default_stack_size == 512

    it "configures 32-bit correctly":
        val config = TargetConfig.for_arch(TargetArch.X86)
        expect config.pointer_bytes == 4
        expect config.value_bytes == 8
        expect config.tag_bits == 2
        expect config.heap_align == 4

    it "configures 64-bit correctly":
        val config = TargetConfig.for_arch(TargetArch.X86_64)
        expect config.pointer_bytes == 8
        expect config.value_bytes == 8
        expect config.tag_bits == 3
        expect config.heap_align == 8

describe "Architecture Bit Width Helpers":
    it "is_8bit returns true for 8-bit":
        val avr = TargetArch.AVR
        val mcs51 = TargetArch.MCS51
        val x86 = TargetArch.X86
        expect avr.is_8bit() == true
        expect mcs51.is_8bit() == true
        expect x86.is_8bit() == false

    it "is_16bit returns true for 16-bit":
        val msp430 = TargetArch.MSP430
        val avr = TargetArch.AVR
        expect msp430.is_16bit() == true
        expect avr.is_16bit() == false

    it "is_32bit returns true for 32-bit":
        val x86 = TargetArch.X86
        val arm = TargetArch.Arm
        val x64 = TargetArch.X86_64
        expect x86.is_32bit() == true
        expect arm.is_32bit() == true
        expect x64.is_32bit() == false

    it "is_64bit returns true for 64-bit":
        val x64 = TargetArch.X86_64
        val arm64 = TargetArch.Aarch64
        val x86 = TargetArch.X86
        expect x64.is_64bit() == true
        expect arm64.is_64bit() == true
        expect x86.is_64bit() == false

describe "Endianness":
    it "most architectures are little-endian":
        val avr = TargetArch.AVR
        val msp430 = TargetArch.MSP430
        val x86 = TargetArch.X86
        val x64 = TargetArch.X86_64
        expect avr.endianness() == Endian.Little
        expect msp430.endianness() == Endian.Little
        expect x86.endianness() == Endian.Little
        expect x64.endianness() == Endian.Little

    it "MCS51 is big-endian":
        val mcs51 = TargetArch.MCS51
        expect mcs51.endianness() == Endian.Big