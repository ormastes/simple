# # Unique Pointers Specification
#
# **Feature ID:** #PTR-UNIQUE
# **Category:** Runtime
# **Status:** Implemented
#
# ## Overview
#
# UniquePtr provides exclusive ownership semantics via cooperative move tracking.
# Since Simple copies on assignment, unique_move returns a new valid ptr and
# marks the old one as moved internally.
#
# Self-contained implementation using dict-based store to avoid
# module-level array index assignment limitations.

var g_unique_store = {}
var g_unique_next_id: i64 = 0

struct UniquePtr:
    id: i64
    value: i64
    tag: text

fn unique_new(value: i64, tag: text) -> UniquePtr:
    val id = g_unique_next_id
    g_unique_next_id = g_unique_next_id + 1
    val key = "{id}"
    g_unique_store[key] = {"value": value, "moved": false, "tag": tag}
    UniquePtr(id: id, value: value, tag: tag)

fn unique_reset():
    g_unique_store = {}
    g_unique_next_id = 0

fn unique_get(ptr: UniquePtr) -> i64:
    val key = "{ptr.id}"
    val d = g_unique_store
    if not d.contains_key(key):
        return -1
    val entry = d[key]
    if entry["moved"] == true:
        return -1
    entry["value"]

fn unique_is_valid(ptr: UniquePtr) -> bool:
    val key = "{ptr.id}"
    val d = g_unique_store
    if not d.contains_key(key):
        return false
    val entry = d[key]
    entry["moved"] == false

fn unique_move(ptr: UniquePtr) -> UniquePtr:
    val key = "{ptr.id}"
    val d = g_unique_store
    if not d.contains_key(key):
        return UniquePtr(id: -1, value: 0, tag: "invalid")
    val entry = d[key]
    if entry["moved"] == true:
        return UniquePtr(id: -1, value: 0, tag: "invalid")
    val value = entry["value"]
    val tag = entry["tag"]
    # Mark old as moved
    g_unique_store[key] = {"value": value, "moved": true, "tag": tag}
    # Create new entry
    unique_new(value, tag)

fn unique_invalidate(id: i64):
    val key = "{id}"
    val d = g_unique_store
    if d.contains_key(key):
        val entry = d[key]
        g_unique_store[key] = {"value": entry["value"], "moved": true, "tag": entry["tag"]}

fn unique_into_inner(ptr: UniquePtr) -> i64:
    val key = "{ptr.id}"
    val d = g_unique_store
    if not d.contains_key(key):
        return -1
    val entry = d[key]
    if entry["moved"] == true:
        return -1
    val value = entry["value"]
    g_unique_store[key] = {"value": value, "moved": true, "tag": entry["tag"]}
    value


# ============================================================================
# Basic Unique Pointer Operations
# ============================================================================

describe "Unique - create and read":
    it "creates and reads value":
        unique_reset()
        val p = unique_new(42, "test")
        expect(unique_get(p)).to_equal(42)
        expect(unique_is_valid(p)).to_equal(true)
        unique_reset()

describe "Unique - move ownership":
    it "transfers ownership on move":
        unique_reset()
        val p1 = unique_new(100, "moveable")
        val p2 = unique_move(p1)
        expect(unique_is_valid(p1)).to_equal(false)
        expect(unique_is_valid(p2)).to_equal(true)
        expect(unique_get(p2)).to_equal(100)
        unique_reset()

describe "Unique - moved returns -1":
    it "get on moved ptr returns -1":
        unique_reset()
        val p = unique_new(77, "once")
        val p2 = unique_move(p)
        expect(unique_get(p)).to_equal(-1)
        unique_reset()

describe "Unique - into_inner":
    it "consumes and returns value":
        unique_reset()
        val p = unique_new(33, "consume")
        val v = unique_into_inner(p)
        expect(v).to_equal(33)
        expect(unique_is_valid(p)).to_equal(false)
        unique_reset()

describe "Unique - manual invalidate":
    it "marks as moved":
        unique_reset()
        val p = unique_new(55, "manual")
        unique_invalidate(p.id)
        expect(unique_is_valid(p)).to_equal(false)
        unique_reset()
