# # Static Method Resolution
#
# **Feature ID:** #RESOLVE-001
# **Category:** Compiler
# **Status:** Active
#
# ## Overview
#
# Tests static method resolution and calling in interpreter mode.
# Uses ClassName.method() dot-access syntax which works in closures.
#
# ## Syntax
#
# ```simple
# class Point:
#     x: i64
#     y: i64
#     static fn origin() -> Point:
#         Point(x: 0, y: 0)
# val p = Point.origin()
# ```

class Calculator:
    value: i64
    static fn add(a: i64, b: i64) -> i64:
        a + b
    static fn multiply(a: i64, b: i64) -> i64:
        a * b
    static fn zero() -> Calculator:
        Calculator(value: 0)
    static fn from_value(v: i64) -> Calculator:
        Calculator(value: v)
    fn get_value() -> i64:
        self.value

class MathUtils:
    x: i64
    static fn max(a: i64, b: i64) -> i64:
        if a > b:
            a
        else:
            b
    static fn min(a: i64, b: i64) -> i64:
        if a < b:
            a
        else:
            b
    static fn abs(n: i64) -> i64:
        if n < 0:
            0 - n
        else:
            n
    static fn clamp(v: i64, lo: i64, hi: i64) -> i64:
        if v < lo:
            lo
        else:
            if v > hi:
                hi
            else:
                v

describe "Static Method Resolution":
    context "Basic static method resolution":
        it "resolves simple static method call":
            val result = Calculator.add(3, 4)
            expect(result).to_equal(7)

        it "resolves static method with parameters":
            val result = Calculator.multiply(5, 6)
            expect(result).to_equal(30)

        it "resolves static method returning object":
            val calc = Calculator.zero()
            expect(calc.get_value()).to_equal(0)

    context "Static vs instance method distinction":
        it "correctly resolves static method vs instance method":
            val calc = Calculator.from_value(42)
            expect(calc.get_value()).to_equal(42)

        it "allows same name for static and instance methods":
            # Static returns i64, instance returns field
            val sum = Calculator.add(10, 20)
            val calc = Calculator.from_value(100)
            expect(sum).to_equal(30)
            expect(calc.get_value()).to_equal(100)

    context "Static method chaining":
        it "chains static method call with instance method":
            val result = Calculator.from_value(10).get_value()
            expect(result).to_equal(10)

        it "calls multiple static methods in sequence":
            val a = Calculator.add(1, 2)
            val b = Calculator.multiply(3, 4)
            expect(a + b).to_equal(15)

    context "Static methods calling other methods":
        it "static method calls another static method":
            val m = MathUtils.max(10, 20)
            val n = MathUtils.min(10, 20)
            expect(m).to_equal(20)
            expect(n).to_equal(10)

        it "static method creates object and calls instance method":
            val calc = Calculator.from_value(99)
            val v = calc.get_value()
            expect(v).to_equal(99)

    context "Static method in structs":
        it "resolves static method on struct":
            val a = MathUtils.abs(0 - 42)
            expect(a).to_equal(42)

        it "resolves multiple static methods on struct":
            val clamped = MathUtils.clamp(150, 0, 100)
            expect(clamped).to_equal(100)
