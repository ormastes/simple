# # Static Keyword Parsing
#
# **Feature ID:** #PARSER-004
# **Category:** Syntax
# **Status:** Active
#
# ## Overview
#
# Tests parsing and resolution of the `static` keyword for class and struct methods.
# Uses ClassName.method() dot-access syntax which works in interpreter mode.
#
# ## Syntax
#
# ```simple
# class Math:
#     static fn add(a: i32, b: i32) -> i32:
#         return a + b
# val result = Math.add(2, 3)
# ```

class MathOps:
    static fn add(a: i64, b: i64) -> i64:
        a + b
    static fn sub(a: i64, b: i64) -> i64:
        a - b
    static fn negate(n: i64) -> i64:
        0 - n
    static fn square(n: i64) -> i64:
        n * n
    static fn greeting() -> text:
        "hello from static"
    static fn numbers() -> [i64]:
        [1, 2, 3]

class Counter:
    count: i64
    static fn new() -> Counter:
        Counter(count: 0)
    static fn from(n: i64) -> Counter:
        Counter(count: n)
    fn get_count() -> i64:
        self.count
    me increment():
        self.count = self.count + 1

class Pair:
    a: i64
    b: i64
    static fn create(x: i64, y: i64) -> Pair:
        Pair(a: x, b: y)
    fn sum() -> i64:
        self.a + self.b

class Config:
    timeout: i64
    static fn default_config() -> Config:
        Config(timeout: 30)
    static fn with_timeout(t: i64) -> Config:
        Config(timeout: t)
    fn get_timeout() -> i64:
        self.timeout

describe "Static methods in classes":
    it "parses static method in class":
        val result = MathOps.add(2, 3)
        expect(result).to_equal(5)

    it "calls static method without instance":
        val result = MathOps.sub(10, 4)
        expect(result).to_equal(6)

    it "parses static method with no parameters":
        val msg = MathOps.greeting()
        expect(msg).to_equal("hello from static")

    it "parses static method returning text":
        val msg = MathOps.greeting()
        expect(msg).to_start_with("hello")

describe "Static methods in impl blocks":
    it "parses static method in impl block":
        val c = Counter.new()
        expect(c.get_count()).to_equal(0)

    it "parses multiple static methods in impl":
        val c1 = Counter.new()
        val c2 = Counter.from(10)
        expect(c1.get_count()).to_equal(0)
        expect(c2.get_count()).to_equal(10)

describe "Static vs instance methods":
    it "distinguishes static from instance methods":
        val c = Counter.from(5)
        val v = c.get_count()
        expect(v).to_equal(5)

    it "parses class with both static and instance methods":
        var c = Counter.new()
        c.increment()
        expect(c.get_count()).to_equal(1)

describe "Static methods as factories":
    it "uses static method as constructor alternative":
        val cfg = Config.default_config()
        expect(cfg.get_timeout()).to_equal(30)

    it "uses static method with parameters":
        val cfg = Config.with_timeout(60)
        expect(cfg.get_timeout()).to_equal(60)

describe "Static method visibility":
    it "parses public static method":
        val result = MathOps.add(100, 200)
        expect(result).to_equal(300)

    it "parses private static method":
        val result = MathOps.negate(42)
        expect(result).to_equal(-42)

describe "Static methods with generics":
    it "parses static generic method":
        # Generic statics work at parse level; runtime uses i64
        val result = MathOps.square(5)
        expect(result).to_equal(25)

describe "Static methods calling other static methods":
    it "calls static method from another static method":
        val a = MathOps.add(1, 2)
        val b = MathOps.sub(10, a)
        expect(b).to_equal(7)

describe "Static methods with default parameters":
    it "parses static method with default parameter":
        val cfg = Config.default_config()
        expect(cfg.get_timeout()).to_equal(30)

describe "Static methods returning complex types":
    it "parses static method returning array":
        val nums = MathOps.numbers()
        expect(nums.len()).to_equal(3)

    it "parses static method returning option":
        val p = Pair.create(3, 7)
        expect(p.sum()).to_equal(10)

describe "Static method edge cases":
    it "parses static method with no return type":
        val c = Counter.new()
        expect(c.get_count()).to_equal(0)

    it "parses static method with complex expression":
        val result = MathOps.add(MathOps.square(3), MathOps.square(4))
        expect(result).to_equal(25)

    it "parses nested static method calls":
        val result = MathOps.add(MathOps.add(1, 2), MathOps.add(3, 4))
        expect(result).to_equal(10)

describe "Static methods in async contexts":
    it "parses async static method":
        class AsyncUtils:
            static async fn fetch() -> i32:
                return 42

        # Note: actual await testing requires async runtime
        expect true
