# CMM Lexer Specification
#
# **Feature ID:** #CMM-LEX
# **Category:** Tooling
# **Status:** Implemented
#
# ## Overview
#
# Tests for the CMM (PRACTICE Script) lexer. Validates tokenization of all
# CMM lexical elements: comments, labels, macros, numbers, strings, dot
# commands, operators, options, file channels, and full lines.
#
# Interpreter mode: it block bodies don't execute. Tests verify that
# all CMM lexer concepts are structurally valid Simple code that loads
# without errors.

use examples.10_tooling.cmm_lsp.cmm_lexer.{lex_cmm_source, lex_cmm_line}
use examples.10_tooling.cmm_lsp.cmm_tokens.{CmmTokenKind, CmmToken}

# ============================================================================
# Test Group 1: Comments
# ============================================================================

describe "CMM Lexer - Comments":
    it "lexes semicolon comment":
        val tokens = lex_cmm_line("; this is a comment", 1)
        expect(tokens.len()).to_equal(1)

    it "lexes double-slash comment":
        val tokens = lex_cmm_line("// another comment", 1)
        expect(tokens.len()).to_equal(1)

    it "lexes semicolon comment with no trailing text":
        val tokens = lex_cmm_line(";", 1)
        expect(tokens.len()).to_equal(1)

    it "lexes double-slash comment with no trailing text":
        val tokens = lex_cmm_line("//", 1)
        expect(tokens.len()).to_equal(1)

    it "lexes inline comment after whitespace":
        val tokens = lex_cmm_line("  ; inline comment", 1)
        expect(tokens.len()).to_equal(1)

# ============================================================================
# Test Group 2: Labels
# ============================================================================

describe "CMM Lexer - Labels":
    it "lexes label at column 1":
        val tokens = lex_cmm_line("start:", 1)
        expect(tokens.len()).to_equal(1)

    it "lexes label with underscore":
        val tokens = lex_cmm_line("_my_label:", 1)
        expect(tokens.len()).to_equal(1)

    it "lexes label with alphanumeric chars":
        val tokens = lex_cmm_line("FlashSetup3:", 1)
        expect(tokens.len()).to_equal(1)

    it "distinguishes label from device selector":
        # B:: is a device selector, not a label
        val tokens = lex_cmm_line("B::", 1)
        expect(tokens.len()).to_equal(1)

    it "returns empty for empty line":
        val tokens = lex_cmm_line("", 1)
        expect(tokens.len()).to_equal(0)

# ============================================================================
# Test Group 3: Macro References
# ============================================================================

describe "CMM Lexer - Macro References":
    it "lexes simple macro ref":
        val tokens = lex_cmm_line("  &myvar", 1)
        expect(tokens.len()).to_equal(1)

    it "lexes recursive macro ref":
        val tokens = lex_cmm_line("  &&myvar", 1)
        expect(tokens.len()).to_equal(1)

    it "lexes bare ampersand as operator when no identifier follows":
        # & without an identifier after it is the binary AND operator
        val tokens = lex_cmm_line("  &", 1)
        expect(tokens.len()).to_equal(1)

    it "lexes bare double-ampersand as logical AND when no identifier follows":
        # && without an identifier is the logical AND operator
        val tokens = lex_cmm_line("  &&", 1)
        expect(tokens.len()).to_equal(1)

    it "lexes macro ref with underscore in name":
        val tokens = lex_cmm_line("  &my_var_1", 1)
        expect(tokens.len()).to_equal(1)

# ============================================================================
# Test Group 4: Numbers
# ============================================================================

describe "CMM Lexer - Hex Numbers":
    it "lexes hex number with lowercase 0x":
        val tokens = lex_cmm_line("  0x1000", 1)
        expect(tokens.len()).to_equal(1)

    it "lexes hex number with uppercase 0X":
        val tokens = lex_cmm_line("  0XABCDEF", 1)
        expect(tokens.len()).to_equal(1)

    it "lexes hex mask with dont-care bits":
        # 0xFX has dont-care nibble
        val tokens = lex_cmm_line("  0xFX", 1)
        expect(tokens.len()).to_equal(1)

    it "lexes hex mask with multiple dont-care bits":
        val tokens = lex_cmm_line("  0xff1cxxxx", 1)
        expect(tokens.len()).to_equal(1)

describe "CMM Lexer - Binary Numbers":
    it "lexes binary number with 0y prefix":
        val tokens = lex_cmm_line("  0y101", 1)
        expect(tokens.len()).to_equal(1)

    it "lexes binary mask with dont-care bits":
        val tokens = lex_cmm_line("  0yX111XXX", 1)
        expect(tokens.len()).to_equal(1)

describe "CMM Lexer - Decimal and Integer Numbers":
    it "lexes decimal number with trailing dot":
        val tokens = lex_cmm_line("  100.", 1)
        expect(tokens.len()).to_equal(1)

    it "lexes plain integer":
        val tokens = lex_cmm_line("  1234", 1)
        expect(tokens.len()).to_equal(1)

    it "lexes float number":
        val tokens = lex_cmm_line("  1.3", 1)
        expect(tokens.len()).to_equal(1)

    it "lexes float with exponent":
        val tokens = lex_cmm_line("  1.3e+34", 1)
        expect(tokens.len()).to_equal(1)

describe "CMM Lexer - Time Literals":
    it "lexes millisecond time literal":
        val tokens = lex_cmm_line("  10ms", 1)
        expect(tokens.len()).to_equal(1)

    it "lexes microsecond time literal":
        val tokens = lex_cmm_line("  100us", 1)
        expect(tokens.len()).to_equal(1)

    it "lexes nanosecond time literal":
        val tokens = lex_cmm_line("  75ns", 1)
        expect(tokens.len()).to_equal(1)

    it "lexes second time literal":
        val tokens = lex_cmm_line("  10s", 1)
        expect(tokens.len()).to_equal(1)

    it "lexes float time literal":
        val tokens = lex_cmm_line("  23.24ms", 1)
        expect(tokens.len()).to_equal(1)

# ============================================================================
# Test Group 5: Strings and Characters
# ============================================================================

describe "CMM Lexer - Strings":
    it "lexes simple string":
        val tokens = lex_cmm_line("  \"hello world\"", 1)
        expect(tokens.len()).to_equal(1)

    it "lexes empty string":
        val tokens = lex_cmm_line("  \"\"", 1)
        expect(tokens.len()).to_equal(1)

    it "lexes string with escaped double quote":
        # In CMM, "" inside a string is an escaped double-quote
        val tokens = lex_cmm_line("  \"abc\"\"def\"", 1)
        expect(tokens.len()).to_equal(1)

describe "CMM Lexer - Char Literals":
    it "lexes single character literal":
        val tokens = lex_cmm_line("  'A'", 1)
        expect(tokens.len()).to_equal(1)

    it "lexes lowercase char literal":
        val tokens = lex_cmm_line("  'z'", 1)
        expect(tokens.len()).to_equal(1)

# ============================================================================
# Test Group 6: Dot Commands
# ============================================================================

describe "CMM Lexer - Dot Commands":
    it "lexes simple dot command":
        val tokens = lex_cmm_line("  Data.dump", 1)
        expect(tokens.len()).to_equal(1)

    it "lexes two-level dot command":
        val tokens = lex_cmm_line("  SYStem.CPU", 1)
        expect(tokens.len()).to_equal(1)

    it "lexes multi-level dot command":
        val tokens = lex_cmm_line("  FLASH.ReProgram.ALL", 1)
        expect(tokens.len()).to_equal(1)

    it "lexes dot command with reset":
        val tokens = lex_cmm_line("  FLASH.RESet", 1)
        expect(tokens.len()).to_equal(1)

# ============================================================================
# Test Group 7: Operators
# ============================================================================

describe "CMM Lexer - Comparison Operators":
    it "lexes equality operator":
        val tokens = lex_cmm_line("  ==", 1)
        expect(tokens.len()).to_equal(1)

    it "lexes not-equal operator":
        val tokens = lex_cmm_line("  !=", 1)
        expect(tokens.len()).to_equal(1)

    it "lexes less-than-or-equal":
        val tokens = lex_cmm_line("  <=", 1)
        expect(tokens.len()).to_equal(1)

    it "lexes greater-than-or-equal":
        val tokens = lex_cmm_line("  >=", 1)
        expect(tokens.len()).to_equal(1)

describe "CMM Lexer - Range Operators":
    it "lexes range-to operator":
        val tokens = lex_cmm_line("  --", 1)
        expect(tokens.len()).to_equal(1)

    it "lexes range-offset operator":
        val tokens = lex_cmm_line("  ++", 1)
        expect(tokens.len()).to_equal(1)

    it "lexes range-dots operator":
        val tokens = lex_cmm_line("  ..", 1)
        expect(tokens.len()).to_equal(1)

describe "CMM Lexer - Logical Operators":
    it "lexes logical AND":
        val tokens = lex_cmm_line("  &&", 1)
        expect(tokens.len()).to_equal(1)

    it "lexes logical OR":
        val tokens = lex_cmm_line("  ||", 1)
        expect(tokens.len()).to_equal(1)

    it "lexes logical XOR":
        val tokens = lex_cmm_line("  ^^", 1)
        expect(tokens.len()).to_equal(1)

describe "CMM Lexer - Shift Operators":
    it "lexes shift left":
        val tokens = lex_cmm_line("  <<", 1)
        expect(tokens.len()).to_equal(1)

    it "lexes shift right":
        val tokens = lex_cmm_line("  >>", 1)
        expect(tokens.len()).to_equal(1)

describe "CMM Lexer - Classic Operators":
    it "lexes classic AND colon form":
        val tokens = lex_cmm_line("  :A:", 1)
        expect(tokens.len()).to_equal(1)

    it "lexes classic OR colon form":
        val tokens = lex_cmm_line("  :O:", 1)
        expect(tokens.len()).to_equal(1)

    it "lexes classic XOR colon form":
        val tokens = lex_cmm_line("  :X:", 1)
        expect(tokens.len()).to_equal(1)

describe "CMM Lexer - Single-Char Operators":
    it "lexes plus":
        val tokens = lex_cmm_line("  +", 1)
        expect(tokens.len()).to_equal(1)

    it "lexes minus":
        val tokens = lex_cmm_line("  -", 1)
        expect(tokens.len()).to_equal(1)

    it "lexes star":
        val tokens = lex_cmm_line("  *", 1)
        expect(tokens.len()).to_equal(1)

    it "lexes percent":
        val tokens = lex_cmm_line("  %", 1)
        expect(tokens.len()).to_equal(1)

    it "lexes tilde":
        val tokens = lex_cmm_line("  ~", 1)
        expect(tokens.len()).to_equal(1)

    it "lexes bang":
        val tokens = lex_cmm_line("  !", 1)
        expect(tokens.len()).to_equal(1)

    it "lexes assign":
        val tokens = lex_cmm_line("  =", 1)
        expect(tokens.len()).to_equal(1)

# ============================================================================
# Test Group 8: Delimiters
# ============================================================================

describe "CMM Lexer - Delimiters":
    it "lexes left paren":
        val tokens = lex_cmm_line("  (", 1)
        expect(tokens.len()).to_equal(1)

    it "lexes right paren":
        val tokens = lex_cmm_line("  )", 1)
        expect(tokens.len()).to_equal(1)

    it "lexes left brace":
        val tokens = lex_cmm_line("  {", 1)
        expect(tokens.len()).to_equal(1)

    it "lexes right brace":
        # Using }}} to produce single } inside string interpolation
        val tokens = lex_cmm_line("  }", 1)
        expect(tokens.len()).to_equal(1)

    it "lexes comma":
        val tokens = lex_cmm_line("  ,", 1)
        expect(tokens.len()).to_equal(1)

# ============================================================================
# Test Group 9: Options and File Channels
# ============================================================================

describe "CMM Lexer - Options":
    it "lexes option token":
        val tokens = lex_cmm_line("  /Write", 1)
        expect(tokens.len()).to_equal(1)

    it "lexes read option":
        val tokens = lex_cmm_line("  /Read", 1)
        expect(tokens.len()).to_equal(1)

    it "lexes create option":
        val tokens = lex_cmm_line("  /Create", 1)
        expect(tokens.len()).to_equal(1)

describe "CMM Lexer - File Channels":
    it "lexes file channel 1":
        val tokens = lex_cmm_line("  #1", 1)
        expect(tokens.len()).to_equal(1)

    it "lexes file channel 2":
        val tokens = lex_cmm_line("  #2", 1)
        expect(tokens.len()).to_equal(1)

describe "CMM Lexer - Hash Classic Operators":
    it "lexes hash classic AND":
        val tokens = lex_cmm_line("  #A#", 1)
        expect(tokens.len()).to_equal(1)

    it "lexes hash classic OR":
        val tokens = lex_cmm_line("  #O#", 1)
        expect(tokens.len()).to_equal(1)

    it "lexes hash classic XOR":
        val tokens = lex_cmm_line("  #X#", 1)
        expect(tokens.len()).to_equal(1)

# ============================================================================
# Test Group 10: Device Selectors
# ============================================================================

describe "CMM Lexer - Device Selectors":
    it "lexes device selector B::":
        val tokens = lex_cmm_line("B::", 1)
        expect(tokens.len()).to_equal(1)

    it "lexes device selector E::":
        val tokens = lex_cmm_line("E::", 1)
        expect(tokens.len()).to_equal(1)

# ============================================================================
# Test Group 11: Identifiers
# ============================================================================

describe "CMM Lexer - Identifiers":
    it "lexes simple identifier":
        val tokens = lex_cmm_line("  Step", 1)
        expect(tokens.len()).to_equal(1)

    it "lexes uppercase identifier":
        val tokens = lex_cmm_line("  ENDDO", 1)
        expect(tokens.len()).to_equal(1)

    it "lexes identifier with underscore":
        val tokens = lex_cmm_line("  my_var", 1)
        expect(tokens.len()).to_equal(1)

# ============================================================================
# Test Group 12: Full Lines (Multiple Tokens)
# ============================================================================

describe "CMM Lexer - Full Lines":
    it "lexes command with parameter":
        val tokens = lex_cmm_line("  SYStem.CPU 78K0R", 1)
        expect(tokens.len()).to_be_greater_than(1)

    it "lexes command with hex parameter":
        val tokens = lex_cmm_line("  Data.dump 0x1000", 1)
        expect(tokens.len()).to_be_greater_than(1)

    it "lexes macro assignment":
        val tokens = lex_cmm_line("  &cpu=CPU()", 1)
        expect(tokens.len()).to_be_greater_than(1)

    it "lexes command with option":
        val tokens = lex_cmm_line("  FLASH.Create 1. 0x0--0xFFF /Write", 1)
        expect(tokens.len()).to_be_greater_than(3)

    it "lexes print with string":
        val tokens = lex_cmm_line("  PRINT \"hello world\"", 1)
        expect(tokens.len()).to_be_greater_than(1)

    it "lexes write with file channel":
        val tokens = lex_cmm_line("  WRITE #1 \"data\"", 1)
        expect(tokens.len()).to_be_greater_than(1)

    it "lexes range expression":
        val tokens = lex_cmm_line("  0x1000--0x1FFF", 1)
        expect(tokens.len()).to_be_greater_than(1)

# ============================================================================
# Test Group 13: Full Source (Multi-Line)
# ============================================================================

describe "CMM Lexer - Full Source":
    it "lexes multi-line CMM source":
        val source = "; comment\nstart:\n  SYStem.CPU ARM\n  ENDDO\n"
        val tokens = lex_cmm_source(source)
        # Should have: Comment, Newline, Label, Newline, DotCommand, Identifier, Newline, Identifier, Newline, Eof
        expect(tokens.len()).to_be_greater_than(4)

    it "lexes empty source":
        val tokens = lex_cmm_source("")
        # At minimum there should be an Eof token
        expect(tokens.len()).to_be_greater_than(0)

    it "lexes source with line continuation":
        val source = "  Data.dump \\\n  0x1000\n"
        val tokens = lex_cmm_source(source)
        expect(tokens.len()).to_be_greater_than(2)

    it "lexes real-world flash script":
        val source = "; Flash programming\nFlashSetup:\n  LOCAL &size\n  ENTRY &size\n  FLASH.RESet\n  FLASH.Create 1. 0x0--0xFFF\n  RETURN\n"
        val tokens = lex_cmm_source(source)
        expect(tokens.len()).to_be_greater_than(10)

# ============================================================================
# Test Group 14: Edge Cases
# ============================================================================

describe "CMM Lexer - Edge Cases":
    it "handles whitespace-only line":
        val tokens = lex_cmm_line("   ", 1)
        expect(tokens.len()).to_equal(0)

    it "handles tab whitespace":
        val tokens = lex_cmm_line("\tStep", 1)
        expect(tokens.len()).to_equal(1)

    it "preserves line numbers":
        val tokens = lex_cmm_line("  Step", 42)
        expect(tokens.len()).to_equal(1)

    it "handles classic NOT operator N:":
        # N: is the classic NOT prefix operator
        val tokens = lex_cmm_line("  N:", 1)
        expect(tokens.len()).to_equal(1)

    it "handles slash as division when not followed by alpha":
        # / alone (not followed by alpha) should be Slash operator, not Option
        val tokens = lex_cmm_line("  /", 1)
        expect(tokens.len()).to_equal(1)
