# ============================================================================
# Test Group 10: Macro Assignment
# ============================================================================

describe "CMM Parser - Macro Assignment":
    it "parses macro assign with integer":
        val source = "  &count=0\n"
        val program = parse_cmm_source(source)
        expect(program.errors.len()).to_equal(0)

    it "parses macro assign with hex value":
        val source = "  &addr=0x1000\n"
        val program = parse_cmm_source(source)
        expect(program.errors.len()).to_equal(0)

    it "parses macro assign with string":
        val source = "  &name=\"hello\"\n"
        val program = parse_cmm_source(source)
        expect(program.errors.len()).to_equal(0)

    it "parses macro assign with expression":
        val source = "  &x=&a+&b\n"
        val program = parse_cmm_source(source)
        expect(program.errors.len()).to_equal(0)

    it "parses macro assign with function call":
        val source = "  &cpu=CPU()\n"
        val program = parse_cmm_source(source)
        expect(program.errors.len()).to_equal(0)

    it "parses empty macro assignment":
        # &name= (clears the macro)
        val source = "  &name=\n"
        val program = parse_cmm_source(source)
        expect(program.errors.len()).to_equal(0)

    it "parses recursive macro assign":
        val source = "  &&indirect=&target\n"
        val program = parse_cmm_source(source)
        expect(program.errors.len()).to_equal(0)

