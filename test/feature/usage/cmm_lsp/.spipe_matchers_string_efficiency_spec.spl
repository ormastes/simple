"""
# String Operation Efficiency Specification

**Feature IDs:** #CMM-STR-EFF
**Category:** Tooling
**Status:** Implemented
**Requirements:** N/A
**Plan:** N/A
**Design:** N/A
**Research:** N/A

## Overview

Tests that string operations in the CMM LSP toolchain produce correct results
after being rewritten from O(n²) character-by-character concatenation to
O(n log n) segment-based approaches. Covers: escape_json, json_array,
json_object, json_get_string, json_get_int, split_lines, lex_string_literal,
to_upper_cmm, and join_parts.

These are correctness tests that verify the optimized implementations match
the behavior of the original naive implementations. They include large-input
cases that would have been noticeably slow with the old O(n²) approach.
"""

# tag: ["only-compiled"]

import std.spec

# ---------------------------------------------------------------------------
# Stubs — reimplemented helper functions matching the optimized versions
# ---------------------------------------------------------------------------

# --- join_parts (from cmm_parser.spl) ---
fn join_parts(parts: [text]) -> text:
    val n = parts.len()
    if n == 0: return ""
    if n == 1: return parts[0]
    if n == 2: return parts[0] + parts[1]
    if n == 3: return parts[0] + parts[1] + parts[2]
    if n == 4: return parts[0] + parts[1] + parts[2] + parts[3]
    var merged: [text] = []
    var i = 0
    while i + 7 < n:
        merged.push(parts[i] + parts[i+1] + parts[i+2] + parts[i+3] + parts[i+4] + parts[i+5] + parts[i+6] + parts[i+7])
        i = i + 8
    var tail = ""
    while i < n:
        tail = tail + parts[i]
        i = i + 1
    if tail.len() > 0:
        merged.push(tail)
    join_parts(merged)

# --- char_to_upper (from cmm_parser.spl) ---
fn char_to_upper(ch: text) -> text:
    if ch == "a": return "A"
    if ch == "b": return "B"
    if ch == "c": return "C"
    if ch == "d": return "D"
    if ch == "e": return "E"
    if ch == "f": return "F"
    if ch == "g": return "G"
    if ch == "h": return "H"
    if ch == "i": return "I"
    if ch == "j": return "J"
    if ch == "k": return "K"
    if ch == "l": return "L"
    if ch == "m": return "M"
    if ch == "n": return "N"
    if ch == "o": return "O"
    if ch == "p": return "P"
    if ch == "q": return "Q"
    if ch == "r": return "R"
    if ch == "s": return "S"
    if ch == "t": return "T"
    if ch == "u": return "U"
    if ch == "v": return "V"
    if ch == "w": return "W"
    if ch == "x": return "X"
    if ch == "y": return "Y"
    if ch == "z": return "Z"
    ch

# --- to_upper_cmm (from cmm_parser.spl) ---
fn to_upper_cmm(s: text) -> text:
    var needs_conversion = false
    var i = 0
    while i < s.len():
        val ch = s[i:i + 1]
        if ch >= "a" and ch <= "z":
            needs_conversion = true
            break
        i = i + 1
    if not needs_conversion:
        return s
    var parts: [text] = []
    i = 0
    while i < s.len():
        val ch = s[i:i + 1]
        parts.push(char_to_upper(ch))
        i = i + 1
    join_parts(parts)

# --- escape_json (from lsp_json.spl) ---
fn escape_json(s: text) -> text:
    val len = s.len()
    var has_special = false
    var scan = 0
    while scan < len:
        val ch = s[scan:scan + 1]
        if ch == "\\" or ch == "\"" or ch == "\n" or ch == "\r" or ch == "\t":
            has_special = true
            break
        scan = scan + 1
    if not has_special:
        return s
    var parts: [text] = []
    var seg_start = 0
    var i = 0
    while i < len:
        val ch = s[i:i + 1]
        if ch == "\\":
            if i > seg_start: parts.push(s[seg_start:i])
            parts.push("\\\\")
            i = i + 1
            seg_start = i
        else if ch == "\"":
            if i > seg_start: parts.push(s[seg_start:i])
            parts.push("\\\"")
            i = i + 1
            seg_start = i
        else if ch == "\n":
            if i > seg_start: parts.push(s[seg_start:i])
            parts.push("\\n")
            i = i + 1
            seg_start = i
        else if ch == "\r":
            if i > seg_start: parts.push(s[seg_start:i])
            parts.push("\\r")
            i = i + 1
            seg_start = i
        else if ch == "\t":
            if i > seg_start: parts.push(s[seg_start:i])
            parts.push("\\t")
            i = i + 1
            seg_start = i
        else:
            i = i + 1
    if seg_start < len:
        parts.push(s[seg_start:len])
    join_parts(parts)

# --- json helpers ---
fn json_string(s: text) -> text:
    val escaped = escape_json(s)
    val q = "\""
    q + escaped + q

struct JsonPair:
    key: text
    value: text

fn json_array(items: [text]) -> text:
    val n = items.len()
    if n == 0: return "[]"
    if n == 1: return "[" + items[0] + "]"
    var parts: [text] = []
    parts.push("[")
    var i = 0
    while i < n:
        if i > 0:
            parts.push(",")
        parts.push(items[i])
        i = i + 1
    parts.push("]")
    join_parts(parts)

fn json_object(pairs: [JsonPair]) -> text:
    val n = pairs.len()
    if n == 0: return "{}"
    var parts: [text] = []
    parts.push("{")
    var i = 0
    while i < n:
        if i > 0:
            parts.push(",")
        parts.push(json_string(pairs[i].key))
        parts.push(":")
        parts.push(pairs[i].value)
        i = i + 1
    parts.push("}")
    join_parts(parts)

# --- split_lines (from cmm_lexer.spl) ---
fn split_lines(source: text) -> [text]:
    var lines: [text] = []
    var start = 0
    var i = 0
    while i < source.len():
        if source[i:i + 1] == "\n":
            lines.push(source[start:i])
            start = i + 1
        i = i + 1
    if start <= source.len():
        lines.push(source[start:source.len()])
    lines

# Helper: build a string of N repeated characters
fn repeat_char(ch: text, n: i64) -> text:
    var parts: [text] = []
    var i = 0
    while i < n:
        parts.push(ch)
        i = i + 1
    join_parts(parts)


# ============================================================================
# Test Group 1: join_parts — the core batch-concat helper
# ============================================================================

describe "join_parts":
    """
    ## Batch String Joining

    The core helper used by all optimized string operations.
    Uses recursive batch-of-8 concatenation for O(n log n) performance.
    """

    context "basic cases":
        it "joins empty array":
            expect join_parts([]) == ""

        it "joins single element":
            expect join_parts(["hello"]) == "hello"

        it "joins two elements":
            expect join_parts(["hello", " world"]) == "hello world"

        it "joins three elements":
            expect join_parts(["a", "b", "c"]) == "abc"

        it "joins four elements":
            expect join_parts(["1", "2", "3", "4"]) == "1234"

    context "batch path (more than 4 elements)":
        it "joins 5 elements":
            expect join_parts(["a", "b", "c", "d", "e"]) == "abcde"

        it "joins 8 elements — exact batch":
            expect join_parts(["1", "2", "3", "4", "5", "6", "7", "8"]) == "12345678"

        it "joins 9 elements — batch + remainder":
            expect join_parts(["a", "b", "c", "d", "e", "f", "g", "h", "i"]) == "abcdefghi"

        it "joins 16 elements — two full batches":
            var parts: [text] = []
            var i = 0
            while i < 16:
                parts.push("x")
                i = i + 1
            expect join_parts(parts) == "xxxxxxxxxxxxxxxx"

    context "large inputs — would be slow with O(n²)":
        it "joins 100 single-char parts":
            var parts: [text] = []
            var i = 0
            while i < 100:
                parts.push("a")
                i = i + 1
            val result = join_parts(parts)
            expect result.len() == 100

        it "joins 500 single-char parts":
            var parts: [text] = []
            var i = 0
            while i < 500:
                parts.push("b")
                i = i + 1
            val result = join_parts(parts)
            expect result.len() == 500

    context "mixed-length segments":
        it "joins segments of varying length":
            expect join_parts(["hello", " ", "world", "!", " ", "foo"]) == "hello world! foo"

        it "joins with empty segments":
            expect join_parts(["a", "", "b", "", "c"]) == "abc"


# ============================================================================
# Test Group 2: to_upper_cmm — fast-path and batch conversion
# ============================================================================

describe "to_upper_cmm":
    """
    ## Case-Insensitive CMM Keyword Matching

    Tests the optimized uppercase conversion that uses a fast-path check
    and array-join for the slow path.
    """

    context "fast path — already uppercase":
        it "returns uppercase string unchanged":
            expect to_upper_cmm("IF") == "IF"

        it "returns uppercase keyword unchanged":
            expect to_upper_cmm("WHILE") == "WHILE"

        it "returns numbers/symbols unchanged":
            expect to_upper_cmm("123_ABC") == "123_ABC"

    context "conversion cases":
        it "converts lowercase to uppercase":
            expect to_upper_cmm("if") == "IF"

        it "converts mixed case":
            expect to_upper_cmm("While") == "WHILE"

        it "converts all lowercase keyword":
            expect to_upper_cmm("repeat") == "REPEAT"

        it "converts long keyword":
            expect to_upper_cmm("globalon") == "GLOBALON"

        it "converts single char":
            expect to_upper_cmm("a") == "A"

    context "edge cases":
        it "handles empty string":
            expect to_upper_cmm("") == ""

        it "preserves underscores and digits":
            expect to_upper_cmm("my_var_123") == "MY_VAR_123"

    context "large input — would be slow with O(n²)":
        it "converts 200 lowercase chars":
            val input = repeat_char("a", 200)
            val result = to_upper_cmm(input)
            expect result.len() == 200
            expect result[0:1] == "A"
            expect result[199:200] == "A"


# ============================================================================
# Test Group 3: escape_json — segment-based escaping
# ============================================================================

describe "escape_json":
    """
    ## JSON String Escaping

    Tests the optimized escape_json that uses segment collection instead
    of character-by-character concatenation.
    """

    context "fast path — no special characters":
        it "returns plain string unchanged":
            expect escape_json("hello world") == "hello world"

        it "returns empty string unchanged":
            expect escape_json("") == ""

        it "returns alphanumeric unchanged":
            expect escape_json("abc123XYZ") == "abc123XYZ"

    context "escaping individual special characters":
        it "escapes backslash":
            expect escape_json("a\\b") == "a\\\\b"

        it "escapes double quote":
            val input = "say \"hello\""
            val expected = "say \\\"hello\\\""
            expect escape_json(input) == expected

        it "escapes newline":
            expect escape_json("line1\nline2") == "line1\\nline2"

        it "escapes carriage return":
            expect escape_json("line1\rline2") == "line1\\rline2"

        it "escapes tab":
            expect escape_json("col1\tcol2") == "col1\\tcol2"

    context "multiple special characters":
        it "escapes string with multiple specials":
            expect escape_json("a\nb\\c\"d") == "a\\nb\\\\c\\\"d"

        it "escapes only-specials string":
            expect escape_json("\n\t\\") == "\\n\\t\\\\"

    context "special at boundaries":
        it "escapes special at start":
            expect escape_json("\nhello") == "\\nhello"

        it "escapes special at end":
            expect escape_json("hello\n") == "hello\\n"

        it "escapes consecutive specials":
            expect escape_json("\n\n\n") == "\\n\\n\\n"

    context "large input — would be slow with O(n²)":
        it "escapes 500 chars with scattered specials":
            # Build a string with a newline every 50 chars
            var parts: [text] = []
            var i = 0
            while i < 10:
                parts.push(repeat_char("x", 49))
                parts.push("\n")
                i = i + 1
            val input = join_parts(parts)
            val result = escape_json(input)
            # Each \n becomes \\n (2 chars), so result is 10*49 + 10*2 = 510
            expect result.len() == 510


# ============================================================================
# Test Group 4: json_array — segment-based array building
# ============================================================================

describe "json_array":
    """
    ## JSON Array Builder

    Tests the optimized json_array that collects segments instead of
    repeatedly concatenating.
    """

    context "basic arrays":
        it "builds empty array":
            expect json_array([]) == "[]"

        it "builds single-element array":
            expect json_array(["1"]) == "[1]"

        it "builds two-element array":
            expect json_array(["1", "2"]) == "[1,2]"

        it "builds multi-element array":
            expect json_array(["1", "2", "3", "4"]) == "[1,2,3,4]"

    context "with string values":
        it "builds array of JSON strings":
            val items = [json_string("a"), json_string("b")]
            expect json_array(items) == "[\"a\",\"b\"]"

    context "large array — would be slow with O(n²)":
        it "builds array with 100 elements":
            var items: [text] = []
            var i = 0
            while i < 100:
                items.push("0")
                i = i + 1
            val result = json_array(items)
            expect result[0:1] == "["
            expect result[result.len() - 1:result.len()] == "]"


# ============================================================================
# Test Group 5: json_object — segment-based object building
# ============================================================================

describe "json_object":
    """
    ## JSON Object Builder

    Tests the optimized json_object.
    """

    context "basic objects":
        it "builds empty object":
            expect json_object([]) == "{}"

        it "builds single-pair object":
            val pairs = [JsonPair(key: "a", value: "1")]
            expect json_object(pairs) == "{\"a\":1}"

        it "builds multi-pair object":
            val pairs = [
                JsonPair(key: "x", value: "1"),
                JsonPair(key: "y", value: "2")
            ]
            expect json_object(pairs) == "{\"x\":1,\"y\":2}"

    context "with string values":
        it "builds object with string values":
            val pairs = [JsonPair(key: "name", value: json_string("test"))]
            expect json_object(pairs) == "{\"name\":\"test\"}"

    context "large object — would be slow with O(n²)":
        it "builds object with 50 pairs":
            var pairs: [JsonPair] = []
            var i = 0
            while i < 50:
                pairs.push(JsonPair(key: "k", value: "0"))
                i = i + 1
            val result = json_object(pairs)
            expect result[0:1] == "{"
            expect result[result.len() - 1:result.len()] == "}"


# ============================================================================
# Test Group 6: split_lines — line splitting
# ============================================================================

describe "split_lines":
    """
    ## Line Splitting

    Tests the split_lines function used by the lexer.
    """

    context "basic splitting":
        it "splits empty string into one empty line":
            val result = split_lines("")
            expect result.len() == 1
            expect result[0] == ""

        it "splits single line without newline":
            val result = split_lines("hello")
            expect result.len() == 1
            expect result[0] == "hello"

        it "splits two lines":
            val result = split_lines("line1\nline2")
            expect result.len() == 2
            expect result[0] == "line1"
            expect result[1] == "line2"

        it "splits three lines":
            val result = split_lines("a\nb\nc")
            expect result.len() == 3
            expect result[0] == "a"
            expect result[1] == "b"
            expect result[2] == "c"

    context "trailing newline":
        it "splits with trailing newline — produces empty last line":
            val result = split_lines("hello\n")
            expect result.len() == 2
            expect result[0] == "hello"
            expect result[1] == ""

    context "empty lines":
        it "handles consecutive newlines":
            val result = split_lines("a\n\nb")
            expect result.len() == 3
            expect result[0] == "a"
            expect result[1] == ""
            expect result[2] == "b"

        it "handles only newlines":
            val result = split_lines("\n\n")
            expect result.len() == 3
            expect result[0] == ""
            expect result[1] == ""
            expect result[2] == ""

    context "CMM-like content":
        it "splits typical CMM script":
            val source = "; Setup\nSYStem.CPU CortexM4\nSYStem.Up\n; Done"
            val result = split_lines(source)
            expect result.len() == 4
            expect result[0] == "; Setup"
            expect result[1] == "SYStem.CPU CortexM4"
            expect result[2] == "SYStem.Up"
            expect result[3] == "; Done"

    context "large input":
        it "splits 200 lines":
            var parts: [text] = []
            var i = 0
            while i < 200:
                parts.push("line")
                i = i + 1
            val source = join_parts_with_sep(parts, "\n")
            val result = split_lines(source)
            expect result.len() == 200

# Helper: join with separator
fn join_parts_with_sep(parts: [text], sep: text) -> text:
    val n = parts.len()
    if n == 0: return ""
    if n == 1: return parts[0]
    var segments: [text] = []
    var i = 0
    while i < n:
        if i > 0:
            segments.push(sep)
        segments.push(parts[i])
        i = i + 1
    join_parts(segments)