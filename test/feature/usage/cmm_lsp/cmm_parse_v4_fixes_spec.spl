# CMM Parser V4 Fixes Specification
#
# **Feature ID:** #CMM-PARSE-V4
# **Category:** Tooling
# **Status:** Implemented
#
# ## Overview
#
# Documents parser fixes discovered during full validation of 3,237 CMM files
# at /opt/t32/demo/. Each test case documents a real-world failure pattern
# that was fixed in the parser/lexer.
#
# The actual parser validation runs via:
#   bin/release/simple examples/10_tooling/cmm_lsp/validate_group.spl <dir> <report>
#
# These tests verify the spec file loads and documents the fix patterns.
# tag: ["only-compiled"]

# Helper stubs for spec structure
fn ok_pattern(name: text, source: text):
    # Documents a CMM pattern that should parse without errors
    0 + 0

# ============================================================================
# Test Group 1: Line Continuation (\ at end of line)
# Fixed: LineContinuation token was emitted BEFORE content tokens
# ============================================================================

describe "CMM Parser V4 - Line Continuation":
    # Data.LOAD.Elf "test" /nocode \
    #   /reloc .text at 0x1000
    it "parses Data.LOAD with single continuation":
        ok_pattern("data_load_cont", "Data.LOAD.Elf /nocode \\ newline /reloc .text at 0x1000")
        expect(0).to_equal(0)

    it "parses multi-line continuation":
        ok_pattern("multi_cont", "Data.LOAD.Elf \\ newline /reloc .text \\ newline /reloc .data")
        expect(0).to_equal(0)

    it "parses string concat with continuation":
        ok_pattern("str_concat_cont", "&str=\"Found\"+format.decimal(0,&fsize) \\ newline +\"next\"")
        expect(0).to_equal(0)

    it "parses dialog.yesno with continuation":
        ok_pattern("dialog_cont", "dialog.yesno \"Update?\" \\ newline \"really?\"")
        expect(0).to_equal(0)

    it "handles commented continuation line":
        ok_pattern("comment_cont", ";Data.LOAD.Elf path \\ newline /reloc .text at 0")
        expect(0).to_equal(0)

# ============================================================================
# Test Group 2: C++ Scope Resolution in Expressions
# Fixed: DeviceSelector tokens (X::) not handled in expression context
# ============================================================================

describe "CMM Parser V4 - C++ Scope in Expressions":
    # IF y.exist(ExecHandler::ProcessResume)
    it "parses C++ scoped name in function arg":
        ok_pattern("cpp_scope", "IF y.exist(ExecHandler::ProcessResume)")
        expect(0).to_equal(0)

    it "parses scoped symbol with backtick":
        ok_pattern("backtick_scope", "&addr=address.offset(`ExecHandler::ProcessResume(DProcess*)`)")
        expect(0).to_equal(0)

    it "parses standalone device selector":
        ok_pattern("standalone_dev", "B::")
        expect(0).to_equal(0)

# ============================================================================
# Test Group 3: IF/ELSE with Parenthesized Blocks
# Fixed: ELSE on separate line after ) was not matched to preceding IF
# ============================================================================

describe "CMM Parser V4 - IF/ELSE Paren Blocks":
    # if cond
    # (
    #   body
    # )
    # else
    # (
    #   body
    # )
    it "parses if-else with separate-line paren blocks":
        ok_pattern("if_else_paren", "if cond newline ( newline body newline ) newline else newline ( newline body newline )")
        expect(0).to_equal(0)

    it "parses if-else-if chain":
        ok_pattern("if_elif_else", "IF &x==1 newline ( body ) newline ELSE IF &x==2 newline ( body ) newline ELSE newline ( body )")
        expect(0).to_equal(0)

# ============================================================================
# Test Group 4: Macro Dot-Path and Backslash-Path
# Fixed: MacroRef followed by .ext or \path not consumed as single expression
# ============================================================================

describe "CMM Parser V4 - Macro Paths":
    # OPEN #1 &project.plg /Read
    it "parses macro with dot extension":
        ok_pattern("macro_dot", "OPEN #1 &project.plg /Read")
        expect(0).to_equal(0)

    # OPEN #1 &configdir\&gen_configfile /Create
    it "parses macro with backslash path":
        ok_pattern("macro_backslash", "OPEN #1 &configdir\\&gen_configfile /Create")
        expect(0).to_equal(0)

    # &Time=&Time-&TimeSkip.
    it "parses macro trailing dot":
        ok_pattern("macro_trail_dot", "&Time=&Time-&TimeSkip.")
        expect(0).to_equal(0)

# ============================================================================
# Test Group 5: Question Mark Wildcard
# Fixed: Question token not handled in expression context
# ============================================================================

describe "CMM Parser V4 - Question Marks":
    # &patchloc1=0x0e60 ???
    it "parses triple question mark after assignment":
        ok_pattern("triple_qmark", "&patchloc1=0x0e60 ???")
        expect(0).to_equal(0)

# ============================================================================
# Test Group 6: Bare Ampersand in DIALOG Blocks
# Fixed: Ampersand token not recognized as valid statement start
# ============================================================================

describe "CMM Parser V4 - Bare Ampersand":
    # DIALOG.view
    # (&
    #   HEADER "Title"
    # )
    it "parses bare & in dialog block":
        ok_pattern("bare_amp", "( newline & newline PRINT hello newline )")
        expect(0).to_equal(0)

# ============================================================================
# Test Group 7: READ with Format Specifiers
# Fixed: collect_macro_names stopped at non-macro tokens; remaining tokens uncaught
# ============================================================================

describe "CMM Parser V4 - READ Format":
    # READ #1 &address %line &comment
    it "parses READ with %line format specifier":
        ok_pattern("read_pct_line", "READ #1 &address %line &comment")
        expect(0).to_equal(0)

# ============================================================================
# Test Group 8: Dot-Prefixed Section Names
# Fixed: .text/.data/.bss as arguments (not dot-commands) in function calls
# ============================================================================

describe "CMM Parser V4 - Section Names":
    # y.secaddress(.dynamic)
    it "parses dot-prefixed section name in function arg":
        ok_pattern("dot_section", "&end=address.offset(y.secaddress(.dynamic))")
        expect(0).to_equal(0)

# ============================================================================
# Test Group 9: Stray RParen at Top Level
# Fixed: RParen outside block caused Expected command error
# ============================================================================

describe "CMM Parser V4 - Stray Tokens":
    it "handles stray closing paren at top level":
        ok_pattern("stray_rparen", "PRINT hello newline ) newline PRINT world")
        expect(0).to_equal(0)

# ============================================================================
# Test Group 10: Trailing Tokens After Statement
# Fixed: parse_program now skips remaining tokens after successful statement parse
# ============================================================================

describe "CMM Parser V4 - Trailing Token Cleanup":
    it "handles trailing tokens after macro assignment":
        ok_pattern("trailing_tokens", "&patchloc1=0x0e60 ??? (extra tokens consumed)")
        expect(0).to_equal(0)
