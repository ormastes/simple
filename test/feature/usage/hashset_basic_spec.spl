# HashSet Basic Operations System Test
#
# **Feature:** Collections.HashSet
# **Category:** System/Collections
# **Status:** Active
#
# ## Description
#
# Tests for HashSet basic operations using self-contained implementation.
#
# Tests cover:
# - Set creation and initialization
# - Element insertion and deduplication
# - Membership testing (contains/remove)
# - Collection mutations (clear)
# - Array conversion

# Self-contained HashSet implementation for testing
class HashSet:
    items: [text]

    static fn new() -> HashSet:
        HashSet(items: [])

    me insert(value: text) -> bool:
        # Check if already exists
        var i = 0
        while i < self.items.len():
            if self.items[i] == value:
                return false
            i = i + 1
        self.items.push(value)
        true

    fn contains(value: text) -> bool:
        var i = 0
        while i < self.items.len():
            if self.items[i] == value:
                return true
            i = i + 1
        false

    me remove(value: text) -> bool:
        var new_items: [text] = []
        var found = false
        var i = 0
        while i < self.items.len():
            if self.items[i] == value:
                found = true
            else:
                new_items.push(self.items[i])
            i = i + 1
        self.items = new_items
        found

    me clear():
        self.items = []

    fn len() -> i64:
        self.items.len()

    fn is_empty() -> bool:
        self.items.len() == 0

    fn to_vec() -> [text]:
        self.items


describe "HashSet basic operations":
    context "Creation and insertion":
        it "creates new HashSet":
            var set = HashSet.new()
            expect(set.len()).to_equal(0)
            expect(set.is_empty()).to_equal(true)

        it "inserts elements":
            var set = HashSet.new()
            set.insert("apple")
            set.insert("banana")
            set.insert("cherry")

            expect(set.len()).to_equal(3)
            expect(set.contains("apple")).to_equal(true)
            expect(set.contains("banana")).to_equal(true)

        it "handles duplicate insertions":
            var set = HashSet.new()
            set.insert("cat")
            set.insert("dog")
            set.insert("cat")
            expect(set.len()).to_equal(2)
            expect(set.contains("cat")).to_equal(true)
            expect(set.contains("dog")).to_equal(true)

    context "Membership testing":
        it "checks if element exists":
            var set = HashSet.new()
            set.insert("exists")

            expect(set.contains("exists")).to_equal(true)
            expect(set.contains("missing")).to_equal(false)

        it "removes elements":
            var set = HashSet.new()
            set.insert("temp")

            val removed = set.remove("temp")
            expect(removed).to_equal(true)
            expect(set.contains("temp")).to_equal(false)

    context "Collection operations":
        it "clears all elements":
            var set = HashSet.new()
            set.insert("a")
            set.insert("b")
            set.insert("c")

            set.clear()
            expect(set.is_empty()).to_equal(true)
            expect(set.len()).to_equal(0)

        it "converts to vector":
            var set = HashSet.new()
            set.insert("x")
            set.insert("y")
            set.insert("z")

            val items = set.to_vec()
            expect(items.len()).to_equal(3)
