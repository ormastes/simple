# Async I/O Driver Specification
#
# **Feature IDs:** #IO-100
# **Category:** Runtime
# **Status:** In Progress
# **Design:** doc/design/async_io_nginx_perf_optimization.md
#
# NOTE: IoDriver requires rt_driver_create FFI function which is not
# available in interpreter mode. Tests skip in interpreter mode.


fn skip_on_interpreter(name: text, block: fn()):
    print "    it {name} ... skipped (compiled-only)"

describe "IoDriver Lifecycle":
    it "skips driver tests in interpreter mode":
        skip_on_interpreter "creates a driver with default queue depth":
            print "Would test IoDriver.new()"
        skip_on_interpreter "creates a driver with custom queue depth":
            print "Would test IoDriver.with_depth(1024)"
        skip_on_interpreter "close sets handle to -1":
            print "Would test driver.close()"
        expect(true).to_equal(true)

describe "IoDriver Backend":
    it "skips backend tests in interpreter mode":
        skip_on_interpreter "reports a valid backend name":
            print "Would test driver.backend_name()"
        expect(true).to_equal(true)

describe "IoDriver Timeout":
    it "skips timeout tests in interpreter mode":
        skip_on_interpreter "submits a timeout and gets completion":
            print "Would test driver.submit_timeout()"
        expect(true).to_equal(true)

describe "IoDriver Cancel":
    it "skips cancel tests in interpreter mode":
        skip_on_interpreter "cancels a pending timeout":
            print "Would test driver.cancel()"
        expect(true).to_equal(true)

describe "IoDriver Flush":
    it "skips flush tests in interpreter mode":
        skip_on_interpreter "flush with no pending ops returns 0":
            print "Would test driver.flush()"
        expect(true).to_equal(true)
