# Async I/O Driver Echo Test
#
# **Feature IDs:** #IO-101
# **Category:** Runtime
# **Status:** In Progress
# **Design:** doc/design/async_io_nginx_perf_optimization.md
#
# NOTE: IoDriver requires rt_driver_create FFI function which is not
# available in interpreter mode. Tests skip in interpreter mode.


fn skip_on_interpreter(name: text, block: fn()):
    print "    it {name} ... skipped (compiled-only)"

describe "IoDriver Echo Integration":
    it "skips echo tests in interpreter mode":
        skip_on_interpreter "driver can be created for network use":
            print "Would test IoDriver.with_depth(512)"
        skip_on_interpreter "submit_accept returns valid op_id":
            print "Would test driver.submit_accept()"
        skip_on_interpreter "submit_connect returns valid op_id":
            print "Would test driver.submit_connect()"
        expect(true).to_equal(true)
