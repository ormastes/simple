use std.spec.{describe, it, expect}

extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_read_text(path: text) -> text

val MANIFEST_PATH = "test/fixtures/webgl/corpus/manifest.sdn"

fn _read(path: text) -> text:
    if rt_file_exists(path):
        rt_file_read_text(path)
    else:
        ""

fn _is_entry_line(line: text) -> bool:
    val trimmed = line.trim()
    trimmed.starts_with("(webgl_manifest_entry ")

fn _entry_count(manifest: text) -> i32:
    var count = 0
    for line in manifest.split("\n"):
        if _is_entry_line(line):
            count = count + 1
    count

fn _has_external_url(value: text) -> bool:
    val lower = value.lower()
    lower.contains("http://") or
        lower.contains("https://") or
        lower.contains("ftp://") or
        lower.contains("//example.") or
        lower.contains("wss://") or
        lower.contains("ws://")

fn _all_entries_have_offline_contract(manifest: text) -> bool:
    for line in manifest.split("\n"):
        if _is_entry_line(line):
            if not line.contains(" source: \"inline\""):
                return false
            if not line.contains(" offline: true"):
                return false
            if not line.contains(" deterministic: true"):
                return false
            if not line.contains(" network: \"none\""):
                return false
            if not line.contains(" seed: "):
                return false
            if _has_external_url(line):
                return false
    true

fn _all_entry_ids_are_unique(manifest: text) -> bool:
    var ids: [text] = []
    for line in manifest.split("\n"):
        val trimmed = line.trim()
        if _is_entry_line(trimmed):
            val marker = " id: \""
            val start = trimmed.index_of(marker)
            if start == -1:
                return false
            val after_id = trimmed.substring(start + marker.len())
            val end = after_id.index_of("\"")
            if end == -1:
                return false
            val id = after_id.substring(0, end)
            for existing in ids:
                if existing == id:
                    return false
            ids.push(id)
    ids.len() == _entry_count(manifest)

describe "WebGL offline conformance manifest":
    it "fixture exists and declares a non-empty offline slice":
        val manifest = _read(MANIFEST_PATH)
        expect(rt_file_exists(MANIFEST_PATH)).to_equal(true)
        expect(manifest.contains("(webgl_offline_conformance_manifest")).to_equal(true)
        expect(_entry_count(manifest)).to_equal(5)

    it "keeps every manifest entry offline deterministic and inline":
        val manifest = _read(MANIFEST_PATH)
        expect(_all_entries_have_offline_contract(manifest)).to_equal(true)

    it "contains no external URL references anywhere in the fixture":
        val manifest = _read(MANIFEST_PATH)
        expect(_has_external_url(manifest)).to_equal(false)

    it "uses unique deterministic ids for each entry":
        val manifest = _read(MANIFEST_PATH)
        expect(_all_entry_ids_are_unique(manifest)).to_equal(true)
