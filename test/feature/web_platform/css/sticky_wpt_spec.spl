use std.spec.*

use std.gc_async_mut.gpu.browser_engine.browser_renderer.{render_html_to_pixels_with_viewport}
use std.gc_async_mut.gpu.browser_engine.html_string_parser.{browser_renderer_normalize_style_rules}

val WIDTH: i32 = 80
val HEIGHT: i32 = 60

fn _count_color(pixels: [u32], color: u32) -> i32:
    var count: i32 = 0
    var idx: i32 = 0
    while idx < pixels.len():
        if pixels[idx] == color:
            count = count + 1
        idx = idx + 1
    count

fn _renders_color(style: text, body: text, color: u32) -> bool:
    val css = "body { margin: 0; background-color: #ffffff; } " + browser_renderer_normalize_style_rules(style)
    val html = "<html><head><style>" + css + "</style></head><body>" + body + "</body></html>"
    val result = render_html_to_pixels_with_viewport(html, WIDTH, HEIGHT)
    val pixels = result.pixel_data
    _count_color(pixels, color) > 0

describe "WPT-derived CSS sticky positioning subset":

    context "CSS position sticky rendering coverage":

        it "position sticky element renders at scroll-adjusted position":
            val style = ".sticky { position: sticky; top: 0; width: 20px; height: 10px; background-color: #2563eb; }"
            val body = "<div class='sticky'></div>"
            expect(_renders_color(style, body, 0xFF2563EBu32)).to_equal(true)

        it "sticky element stays visible within containing block":
            val style = ".sticky { position: sticky; top: 5px; width: 20px; height: 10px; background-color: #16a34a; }"
            val body = "<div class='sticky'></div>"
            expect(_renders_color(style, body, 0xFF16A34Au32)).to_equal(true)

        it "sticky element does not affect sibling non-sticky elements":
            val style = ".sticky { position: sticky; top: 0; width: 10px; height: 8px; background-color: #dc2626; } .sibling { width: 10px; height: 8px; background-color: #16a34a; }"
            val body = "<div class='sticky'></div><div class='sibling'></div>"
            expect(_renders_color(style, body, 0xFF16A34Au32)).to_equal(true)
