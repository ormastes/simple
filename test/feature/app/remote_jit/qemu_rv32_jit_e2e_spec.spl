"""
# QEMU RV32 Remote JIT E2E

**Feature IDs:** #RJE-030
**Category:** Integration
**Difficulty:** 3/5
**Status:** Implemented

## Overview

End-to-end JIT on QEMU RISC-V 32 using the unified adapter pattern.
Uses QemuRv32Adapter for connect/disconnect/execute lifecycle,
CompilerBridge for Simple-to-binary compilation, and
RemoteExecutionManager for the full upload-execute pipeline.
"""

use std.io_runtime.{shell}
use std.nogc_sync_mut.debug.remote.exec.adapter_qemu_rv32.{QemuRv32Adapter}
use std.nogc_sync_mut.debug.remote.exec.types.{MemoryMap, Architecture}
use std.nogc_sync_mut.debug.remote.exec.compiler_bridge.{CompilerBridge}

fn qemu_available() -> bool:
    """Check that all required tools are present."""
    val q = shell("command -v qemu-system-riscv32 >/dev/null 2>&1")
    val c = shell("command -v clang >/dev/null 2>&1")
    val l = shell("command -v ld.lld >/dev/null 2>&1")
    val o = shell("command -v llvm-objcopy >/dev/null 2>&1")
    (q.exit_code == 0 and c.exit_code == 0 and l.exit_code == 0 and o.exit_code == 0)

describe "QEMU RV32 Remote JIT E2E":

    it "discovers required tools":
        if not qemu_available():
            print "SKIP: QEMU RV32 toolchain not available (need qemu-system-riscv32, clang, ld.lld, llvm-objcopy)"
        else:
            val path = shell("command -v qemu-system-riscv32").stdout.trim()
            print "qemu-system-riscv32 found at: {path}"
            expect(path.len()).to_be_greater_than(0)

    it "connects to QEMU RV32":
        if not qemu_available():
            print "SKIP: QEMU RV32 toolchain not available"
        else:
            var adapter = QemuRv32Adapter.new()
            val result = adapter.connect()
            if result.is_err():
                print "SKIP: QEMU RV32 connect failed: {result.err().unwrap()}"
            else:
                expect(result.is_ok()).to_equal(true)
                adapter.disconnect()

    it "executes return-zero via QEMU RV32":
        if not qemu_available():
            print "SKIP: QEMU RV32 toolchain not available"
        else:
            var adapter = QemuRv32Adapter.new()
            val conn = adapter.connect()
            if conn.is_err():
                print "SKIP: QEMU RV32 connect failed: {conn.err().unwrap()}"
            else:
                val source = "fn main() -> i64:\n    0\n"
                val mem = MemoryMap.qemu_rv32()
                val bytes_result = CompilerBridge.compile(source, Architecture.RiscV32, mem.code_start)
                if bytes_result.is_err():
                    print "SKIP: compilation failed: {bytes_result.err().unwrap()}"
                    adapter.disconnect()
                else:
                    val bytes = bytes_result.ok.unwrap()
                    val manager = adapter.create_manager()
                    val exec_result = manager.execute_bytes("return_zero", bytes, [])
                    if exec_result.is_err():
                        print "SKIP: execution failed: {exec_result.err().unwrap()}"
                    else:
                        val result = exec_result.ok.unwrap()
                        expect(result.return_value).to_equal(0)
                    adapter.disconnect()

    it "executes return-42 via QEMU RV32":
        if not qemu_available():
            print "SKIP: QEMU RV32 toolchain not available"
        else:
            var adapter = QemuRv32Adapter.new()
            val conn = adapter.connect()
            if conn.is_err():
                print "SKIP: QEMU RV32 connect failed: {conn.err().unwrap()}"
            else:
                val source = "fn main() -> i64:\n    42\n"
                val mem = MemoryMap.qemu_rv32()
                val bytes_result = CompilerBridge.compile(source, Architecture.RiscV32, mem.code_start)
                if bytes_result.is_err():
                    print "SKIP: compilation failed: {bytes_result.err().unwrap()}"
                    adapter.disconnect()
                else:
                    val bytes = bytes_result.ok.unwrap()
                    val manager = adapter.create_manager()
                    val exec_result = manager.execute_bytes("return_42", bytes, [])
                    if exec_result.is_err():
                        print "SKIP: execution failed: {exec_result.err().unwrap()}"
                    else:
                        val result = exec_result.ok.unwrap()
                        expect(result.return_value).to_equal(42)
                    adapter.disconnect()
