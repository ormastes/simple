"""
# TRACE32 STM32H7 Remote JIT End-to-End

**Category:** Integration
**Difficulty:** 4/5
**Status:** Implemented

## Overview

End-to-end JIT test on STM32H7 via TRACE32 PowerView + GDB bridge.
Compiles ARM Thumb-2 on host, uploads to SRAM through T32 GDB channel,
executes, reads R0 result register.

Requires running TRACE32 PowerView instance with STM32H7 target connected.
"""

use std.io_runtime.{shell}
use std.nogc_sync_mut.debug.remote.protocol.trace32.{Trace32Client}
use std.nogc_sync_mut.debug.remote.exec.adapter_trace32.{Trace32Adapter}
use std.nogc_sync_mut.debug.remote.exec.types.{MemoryMap}
use std.nogc_sync_mut.debug.remote.exec.compiler_bridge.{CompilerBridge}
use std.nogc_sync_mut.debug.remote.types.{Architecture}

fn t32rem_available() -> bool:
    val path = Trace32Client.find_t32rem()
    path != ""

fn t32_reachable() -> bool:
    if not t32rem_available():
        return false
    val t32rem = Trace32Client.find_t32rem()
    val result = shell("timeout 5 '{t32rem}' localhost port=20000 PING 2>/dev/null")
    result.exit_code == 0

fn toolchain_available() -> bool:
    val clang = shell("command -v clang >/dev/null 2>&1")
    val lld = shell("command -v ld.lld >/dev/null 2>&1")
    val objcopy = shell("command -v llvm-objcopy >/dev/null 2>&1")
    clang.exit_code == 0 and lld.exit_code == 0 and objcopy.exit_code == 0

describe "TRACE32 STM32H7 JIT E2E":
    it "discovers t32rem on system":
        val path = Trace32Client.find_t32rem()
        if path == "":
            print "[skip] t32rem not found"
            return
        expect(path.len()).to_be_greater_than(0)
        print "[ok] t32rem found at: {path}"

    it "pings TRACE32 PowerView":
        if not t32rem_available():
            print "[skip] t32rem not available"
            return
        val reachable = t32_reachable()
        if not reachable:
            print "[skip] TRACE32 PowerView not reachable on port 20000"
            return
        expect(reachable).to_equal(true)
        print "[ok] TRACE32 PowerView responds to PING"

    it "connects adapter and halts target":
        if not t32_reachable():
            print "[skip] TRACE32 not reachable"
            return
        var adapter = Trace32Adapter.for_stm32h7()
        val result = adapter.connect()
        if result.is_err():
            print "[skip] connect failed: {result.err().unwrap()}"
            return
        expect(result.is_ok()).to_equal(true)
        print "[ok] connected to TRACE32 STM32H7"
        adapter.disconnect()

    it "compiles, uploads, and executes return-zero via T32":
        if not t32_reachable() or not toolchain_available():
            print "[skip] T32 or toolchain not available"
            return

        var adapter = Trace32Adapter.for_stm32h7()
        val conn = adapter.connect()
        if conn.is_err():
            print "[skip] connect failed: {conn.err().unwrap()}"
            return

        val manager_result = adapter.create_manager()
        if manager_result.is_err():
            adapter.disconnect()
            print "[skip] manager failed: {manager_result.err().unwrap()}"
            return

        val source = "fn main() -> i64:\n    0\n"
        val limits = MemoryMap.stm32h7()
        val compile_result = CompilerBridge.compile(source, Architecture.Arm32, limits.code_start)
        if compile_result.is_err():
            adapter.disconnect()
            print "[skip] compile failed: {compile_result.err().unwrap()}"
            return

        var manager = manager_result.ok.unwrap()
        val exec_result = manager.execute_bytes("t32_return_zero", compile_result.ok.unwrap(), [])
        adapter.disconnect()

        if exec_result.is_err():
            print "[skip] exec failed: {exec_result.err().unwrap()}"
            return

        val exec = exec_result.ok.unwrap()
        expect(exec.is_ok()).to_equal(true)
        expect(exec.return_value).to_equal(0)
        print "[ok] T32 STM32H7 JIT: main() returned 0"
