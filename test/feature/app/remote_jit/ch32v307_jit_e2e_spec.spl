"""
# CH32V307 Remote JIT End-to-End (Unified Adapter)

**Feature IDs:** #RJE-020
**Category:** Integration
**Difficulty:** 3/5
**Status:** Implemented

## Overview

End-to-end JIT verification on CH32V307 via unified adapter pattern.
Uses Ch32v307Adapter for connection, CompilerBridge for compilation,
and the standard connect/disconnect lifecycle.

Limitation: wlink has NO resume/halt control, so full execute+read
is not supported. The adapter can upload code and read registers only.
"""

use std.nogc_sync_mut.debug.remote.exec.adapter_ch32v307.{Ch32v307Adapter}
use std.nogc_sync_mut.debug.remote.exec.types.{MemoryMap}
use std.nogc_sync_mut.debug.remote.exec.compiler_bridge.{CompilerBridge}
use std.nogc_sync_mut.debug.remote.types.{Architecture}
use std.io_runtime.{shell}

fn wlink_available() -> bool:
    """Check that wlink and cross-compilation tools are installed."""
    val wlink = shell("command -v wlink >/dev/null 2>&1")
    val clang = shell("command -v clang >/dev/null 2>&1")
    val lld = shell("command -v ld.lld >/dev/null 2>&1")
    val objcopy = shell("command -v llvm-objcopy >/dev/null 2>&1")
    (wlink.exit_code == 0 and clang.exit_code == 0 and
     lld.exit_code == 0 and objcopy.exit_code == 0)

fn ch32v307_detected() -> bool:
    """Check if a WCH-Link probe is connected (USB 4348:55e0)."""
    val result = shell("lsusb 2>/dev/null | grep -q '4348:55e0'")
    result.exit_code == 0

describe "CH32V307 Remote JIT E2E":

    it "discovers WCH-Link tools":
        if not wlink_available():
            print "SKIP: wlink or cross-compilation tools not installed"
        else:
            val wlink_ver = shell("wlink --version 2>&1")
            expect(wlink_ver.exit_code).to_equal(0)
            expect(wlink_ver.stdout + wlink_ver.stderr).to_contain("wlink")

    it "connects to CH32V307 via WCH-Link":
        if not wlink_available():
            print "SKIP: wlink not installed"
        else:
            if not ch32v307_detected():
                print "SKIP: WCH-Link probe not detected (USB 4348:55e0)"
            else:
                var adapter = Ch32v307Adapter.new()
                val connect_result = adapter.connect()
                expect(connect_result.is_ok()).to_equal(true)
                adapter.disconnect()

    it "executes return-zero via CH32V307":
        if not wlink_available():
            print "SKIP: wlink or cross-compilation tools not installed"
        else:
            if not ch32v307_detected():
                print "SKIP: WCH-Link probe not detected (USB 4348:55e0)"
            else:
                var adapter = Ch32v307Adapter.new()
                val connect_result = adapter.connect()
                expect(connect_result.is_ok()).to_equal(true)

                val source = "fn main() -> i64:\n    0\n"
                val compile_result = CompilerBridge.compile(source, Architecture.RiscV32, adapter.memory_map.code_start)
                if compile_result.is_err():
                    print "SKIP: compilation failed — {compile_result.err().unwrap()}"
                    adapter.disconnect()
                else:
                    val bytes = compile_result.unwrap()
                    expect(bytes.len()).to_be_greater_than(0)

                    val write_result = adapter.write_code(adapter.memory_map.code_start, bytes)
                    expect(write_result.is_ok()).to_equal(true)

                    # CH32V307 via wlink: chip runs automatically after flash.
                    # Read register a0 (x10) to verify return value.
                    # Note: resume/wait_halt unsupported on wlink — chip auto-runs after flash reset.
                    val reg_result = adapter.read_register(10)
                    if reg_result.is_ok():
                        val return_value = reg_result.unwrap()
                        expect(return_value).to_equal(0)
                    else:
                        print "NOTE: register read after flash not supported — {reg_result.err().unwrap()}"

                    adapter.disconnect()
