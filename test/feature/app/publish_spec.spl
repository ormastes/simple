"""
# Registry Publish

**Category:** Application
**Status:** In Progress

## Overview

Tests the package registry publish workflow including package validation,
version bumping, and upload to the Simple package registry. Verifies that
metadata, checksums, and dependency declarations are correctly assembled.
"""
use app.publish.main.{parse_manifest}

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

val PUBLISH_FIXTURE_DIR = "/tmp/simple_publish_feature_spec"

fn setup_publish_fixture(manifest: text):
    rt_process_run("/bin/sh", [
        "-c",
        "rm -rf " + PUBLISH_FIXTURE_DIR + " && mkdir -p " + PUBLISH_FIXTURE_DIR + " && cat > " + PUBLISH_FIXTURE_DIR + "/simple.sdn <<'EOF'\n" + manifest + "\nEOF"
    ])

fn setup_publish_empty_dir():
    rt_process_run("/bin/sh", ["-c", "rm -rf " + PUBLISH_FIXTURE_DIR + " && mkdir -p " + PUBLISH_FIXTURE_DIR])

fn run_publish(args: [text]) -> (text, text, i64):
    val joined = args.join(" ")
    rt_process_run("/bin/sh", [
        "-c",
        "REPO=$(pwd); cd " + PUBLISH_FIXTURE_DIR + " && SIMPLE_LIB=\"$REPO/src\" \"$REPO/bin/simple\" run \"$REPO/src/app/publish/main.spl\" " + joined
    ])

fn should_include_in_spk(path: text) -> bool:
    not path.starts_with(".jj/") and not path.starts_with("target/") and not path.ends_with(".env")

fn valid_sha256_checksum(checksum: text) -> bool:
    if not checksum.starts_with("sha256:"):
        return false
    checksum.len() == 71


describe "Publish Command":
    # ## Package Publishing
    # Tests for building and publishing packages to the GHCR registry.

    context "when manifest is valid":
        # ### Scenario: Valid simple.sdn manifest

        it "parses package name from manifest":
            val content = "package:\n  name: my-pkg\n  version: 1.0.0\n"
            val info = parse_manifest(content)
            expect(info[0]).to_equal("my-pkg")

        it "parses package version from manifest":
            val content = "package:\n  name: my-pkg\n  version: 2.1.0\n"
            val info = parse_manifest(content)
            expect(info[1]).to_equal("2.1.0")

    context "when manifest is missing":
        # ### Scenario: No manifest file

        it "returns error when no simple.sdn exists":
            setup_publish_empty_dir()
            val (out, err, code) = run_publish(["--dry-run"])
            expect(code).to_equal(1)
            expect((out + err).contains("Publishing ")).to_equal(false)

    context "when using --dry-run":
        # ### Scenario: Dry run mode

        it "does not push to GHCR in dry-run mode":
            setup_publish_fixture("package:\n  name: dry-pkg\n  version: 3.4.5")
            val (out, err, code) = run_publish(["--dry-run"])
            expect(code).to_equal(0)
            expect(out).to_contain("Publishing dry-pkg@3.4.5")
            expect(out).to_contain("(dry run - no changes made)")
            expect(out.contains("Pushing to GHCR")).to_equal(false)

describe "SPK Tarball":
    # ## Package Tarball Creation
    # Tests for .spk file format and contents.

    context "when building tarball":
        it "excludes .jj directory":
            expect(should_include_in_spk(".jj/store/op_heads")).to_equal(false)

        it "excludes target directory":
            expect(should_include_in_spk("target/pkg/app.spk")).to_equal(false)

        it "excludes .env files":
            expect(should_include_in_spk("local.env")).to_equal(false)

        it "includes simple.sdn manifest":
            expect(should_include_in_spk("simple.sdn")).to_equal(true)

        it "includes src directory":
            expect(should_include_in_spk("src/main.spl")).to_equal(true)

describe "Checksum":
    # ## SHA-256 Checksum
    # Tests for package integrity verification.

    it "computes sha256 checksum with prefix":
        # Checksum format: sha256:<hex>
        expect(valid_sha256_checksum("sha256:0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef")).to_equal(true)
        expect(valid_sha256_checksum("0123456789abcdef")).to_equal(false)
