"""
# Remote Baremetal Runtime Checks

**Feature IDs:** #RBRT-001
**Category:** Tooling
**Difficulty:** 3/5
**Status:** Implemented
**Requirements:** N/A
**Plan:** [doc/plan/baremetal_remote_remaining_checklist_2026-03-08.md](doc/plan/baremetal_remote_remaining_checklist_2026-03-08.md)
**Design:** [doc/design/remote_jit_architecture.md](doc/design/remote_jit_architecture.md)
**Research:** [doc/research/trace32_remote_interfaces_2026-03-08.md](doc/research/trace32_remote_interfaces_2026-03-08.md)

## Overview

Checks the current remote baremetal execution plumbing used by the Simple test
runner. The spec covers:

- composite mode parsing for `interpreter(remote(baremetal(...)))`
- QEMU RISC-V32 remote debug smoke using a temporary ELF plus GDB memory read
- TRACE32 readiness state through `t32rem` discovery and repo-managed config

This spec is intentionally host-aware. It treats missing optional host tools as
`skip:` and host/runtime blockers as `blocked:` so the test captures current
environment state without claiming a full hardware verification that the repo
does not currently provide.

## Syntax

```simple
val spec = "interpreter(remote(baremetal(riscv32)))"
val base = extract_base_runtime(spec)
val layer = extract_platform_layer(spec)
val arch = extract_arch_from_spec(spec)
```

## Examples

```simple
val qemu_status = qemu_riscv32_remote_memory_status()
val t32_status = trace32_remote_status()
expect(status_is_acceptable(t32_status)).to_equal(true)
```
"""

use app.io.{shell, file_exists, file_write, file_delete}
use app.test_runner_new.test_executor_composite.{
    extract_base_runtime,
    extract_platform_layer,
    extract_arch_from_spec,
    qemu_binary_for_arch,
    qemu_machine_for_arch,
    find_baremetal_elf
}
use std.nogc_sync_mut.debug.remote.protocol.gdb_mi.GdbMiClient
use std.nogc_sync_mut.debug.remote.protocol.openocd.OpenocdClient
use std.nogc_sync_mut.debug.remote.protocol.stlink_tools.StLinkToolsClient
use std.nogc_sync_mut.debug.remote.target.stm32h7.Stm32H7Target
use std.nogc_sync_mut.debug.remote.target.stm32wb.Stm32WbTarget
use std.nogc_sync_mut.debug.remote.types.{DebugConfig, Architecture}
use app.debug.remote.protocol.trace32.Trace32Client

val ARM_CPUID_ADDR: i64 = 0xE000ED00
val CORTEX_M7_CPUID: i64 = 0x411FC271
val CORTEX_M4_CPUID: i64 = 0x410FC241

fn command_available(cmd: text) -> bool:
    val result = shell("command -v {cmd} >/dev/null 2>&1")
    result.exit_code == 0

fn has_target_aware_riscv_gdb() -> bool:
    command_available("riscv32-unknown-elf-gdb") or command_available("riscv64-unknown-elf-gdb") or command_available("gdb-multiarch")

fn status_is_acceptable(status: text) -> bool:
    status == "ok" or status.starts_with("ready") or status.starts_with("blocked:") or status.starts_with("skip:")

fn cleanup_temp_remote_files(tmpdir: text):
    shell("rm -rf '{tmpdir}' >/dev/null 2>&1 || true")

fn stop_process_if_running(pid: i64):
    if pid > 0:
        shell("kill {pid} >/dev/null 2>&1 || true")
        shell("sleep 0.1")
        shell("kill -9 {pid} >/dev/null 2>&1 || true")

fn parse_leading_hex_address(raw: text) -> i64:
    val trimmed = raw.trim()
    val start = trimmed.index_of("0x") ?? -1
    if start < 0:
        return -1

    var end = start + 2
    while end < trimmed.len():
        val ch = trimmed[end:end + 1]
        val is_digit = ch >= "0" and ch <= "9"
        val is_lower = ch >= "a" and ch <= "f"
        val is_upper = ch >= "A" and ch <= "F"
        if not is_digit and not is_lower and not is_upper:
            break
        end = end + 1

    if end <= start + 2:
        return -1

    val hex = trimmed[start + 2:end]
    var result: i64 = 0
    var i = 0
    while i < hex.len():
        val ch = hex[i:i + 1]
        var digit: i64 = 0
        if ch >= "0" and ch <= "9":
            digit = int(ch) - int("0")
        elif ch >= "a" and ch <= "f":
            digit = 10 + (int(ch) - int("a"))
        else:
            digit = 10 + (int(ch) - int("A"))
        result = result * 16 + digit
        i = i + 1
    result

fn parse_hex_byte_pair(pair: text) -> i64:
    var result: i64 = 0
    var i = 0
    while i < pair.len():
        val ch = pair[i:i + 1]
        var digit: i64 = 0
        if ch >= "0" and ch <= "9":
            digit = int(ch) - int("0")
        elif ch >= "a" and ch <= "f":
            digit = 10 + (int(ch) - int("a"))
        else:
            digit = 10 + (int(ch) - int("A"))
        result = result * 16 + digit
        i = i + 1
    result

fn bytes_to_u32_le(bytes: [i32]) -> i64:
    if bytes.len() < 4:
        return -1
    bytes[0] + bytes[1] * 256 + bytes[2] * 65536 + bytes[3] * 16777216

fn parse_stlink_hex_dump(raw: text) -> [i32]:
    var result: [i32] = []
    val parts = raw.replace("\n", " ").split(" ")
    for part in parts:
        val trimmed = part.trim()
        if trimmed.len() != 2:
            continue
        result.push(parse_hex_byte_pair(trimmed) as i32)
    result

fn qemu_riscv32_remote_memory_status() -> text:
    if not command_available("clang"):
        return "skip: clang unavailable"
    if not command_available("qemu-system-riscv32"):
        return "skip: qemu-system-riscv32 unavailable"
    if not command_available("gdb"):
        return "skip: gdb unavailable"

    val tmpdir = shell("mktemp -d").stdout.trim()
    if tmpdir == "":
        return "error: mktemp failed"

    val asm_path = "{tmpdir}/loop.S"
    val elf_path = "{tmpdir}/loop.elf"
    val port = 1234
    val asm_source = ".section .text\n.globl _start\n_start:\n  j _start\n.section .data\n.globl marker\nmarker:\n  .word 0x12345678\n"

    if not file_write(asm_path, asm_source):
        cleanup_temp_remote_files(tmpdir)
        return "error: failed to write temporary assembly"

    val compile = shell("clang --target=riscv32-none-elf -march=rv32imac -mabi=ilp32 -nostdlib -fuse-ld=lld -Wl,-Ttext=0x80000000 -Wl,-e,_start -o '{elf_path}' '{asm_path}' 2>&1")
    if compile.exit_code != 0:
        cleanup_temp_remote_files(tmpdir)
        return "error: compile failed: {compile.stdout.trim()}"

    val qemu_start = shell("sh -c 'qemu-system-riscv32 -machine virt -bios none -kernel \"{elf_path}\" -gdb tcp::{port} -S -nographic -no-reboot >/dev/null 2>&1 & echo $!'")
    val qemu_pid_text = qemu_start.stdout.trim()
    val qemu_pid = if qemu_pid_text.len() > 0: int(qemu_pid_text) else: -1
    if qemu_start.exit_code != 0 or qemu_pid <= 0:
        cleanup_temp_remote_files(tmpdir)
        return "error: failed to launch qemu"

    val port_ready = shell("timeout 5 bash -c 'while ! ss -tln | grep -q :{port}; do sleep 0.1; done' 2>/dev/null")
    if port_ready.exit_code != 0:
        stop_process_if_running(qemu_pid)
        cleanup_temp_remote_files(tmpdir)
        return "error: qemu gdb port did not become ready"

    val config = DebugConfig(
        host: "localhost",
        port: port,
        target: Architecture.RiscV32,
        program: elf_path,
        options: {}
    )
    val gdb_result = GdbMiClient.connect(config)
    if gdb_result.is_err():
        stop_process_if_running(qemu_pid)
        cleanup_temp_remote_files(tmpdir)
        return "error: gdb-mi connect failed: {gdb_result.err().unwrap()}"

    var gdb = gdb_result.ok.unwrap()
    val addr_text = gdb.evaluate("&marker")
    if addr_text.is_err():
        gdb.disconnect()
        stop_process_if_running(qemu_pid)
        cleanup_temp_remote_files(tmpdir)
        return "error: could not evaluate marker address"

    val addr = parse_leading_hex_address(addr_text.ok.unwrap())
    if addr < 0:
        gdb.disconnect()
        stop_process_if_running(qemu_pid)
        cleanup_temp_remote_files(tmpdir)
        return "error: could not parse marker address"

    val initial = gdb.read_memory(addr, 4)
    if initial.is_err():
        gdb.disconnect()
        stop_process_if_running(qemu_pid)
        cleanup_temp_remote_files(tmpdir)
        return "error: initial memory read failed"

    val initial_bytes = initial.ok.unwrap()
    if initial_bytes.len() < 4:
        gdb.disconnect()
        stop_process_if_running(qemu_pid)
        cleanup_temp_remote_files(tmpdir)
        return "error: initial memory read too short"

    if initial_bytes[0] != 0x78 or initial_bytes[1] != 0x56 or initial_bytes[2] != 0x34 or initial_bytes[3] != 0x12:
        gdb.disconnect()
        stop_process_if_running(qemu_pid)
        cleanup_temp_remote_files(tmpdir)
        return "error: initial marker value mismatch"

    val write_result = gdb.write_memory(addr, [0x21, 0x43, 0x65, 0x87])
    if write_result.is_err():
        val write_msg = write_result.err().unwrap()
        if has_target_aware_riscv_gdb():
            val phys_mode = gdb.set_qemu_physical_memory_mode(true)
            if phys_mode.is_ok():
                val retry_write = gdb.write_memory(addr, [0x21, 0x43, 0x65, 0x87])
                if retry_write.is_ok():
                    val retry_updated = gdb.read_memory(addr, 4)
                    gdb.disconnect()
                    stop_process_if_running(qemu_pid)
                    cleanup_temp_remote_files(tmpdir)
                    if retry_updated.is_err():
                        return "error: updated memory read failed after qemu physical mode switch"
                    val retry_bytes = retry_updated.ok.unwrap()
                    if retry_bytes.len() >= 4 and retry_bytes[0] == 0x21 and retry_bytes[1] == 0x43 and retry_bytes[2] == 0x65 and retry_bytes[3] == 0x87:
                        return "ok"
                    return "blocked: qemu physical mode write retry did not persist"
        gdb.disconnect()
        stop_process_if_running(qemu_pid)
        cleanup_temp_remote_files(tmpdir)
        if write_msg.contains("Cannot access memory"):
            return "blocked: qemu gdb stub rejected memory write"
        return "error: memory write failed: {write_msg}"

    val updated = gdb.read_memory(addr, 4)
    gdb.disconnect()
    stop_process_if_running(qemu_pid)
    cleanup_temp_remote_files(tmpdir)

    if updated.is_err():
        return "error: updated memory read failed"

    val updated_bytes = updated.ok.unwrap()
    if updated_bytes.len() < 4:
        return "error: updated memory read too short"

    if updated_bytes[0] == 0x21 and updated_bytes[1] == 0x43 and updated_bytes[2] == 0x65 and updated_bytes[3] == 0x87:
        return "ok"
    "error: updated marker value mismatch"

fn trace32_remote_status() -> text:
    if not file_exists("config/t32/t32_stm_headless.t32"):
        return "error: missing config/t32/t32_stm_headless.t32"

    val t32rem = Trace32Client.find_t32rem()
    if t32rem == "":
        return "skip: t32rem unavailable"

    val ping = shell("{t32rem} localhost port=20000 PING 2>&1")
    val combined = ping.stdout + ping.stderr
    val trimmed = combined.trim()

    if ping.exit_code == 0:
        return "ready"
    if trimmed.contains("error initializing TRACE32"):
        return "blocked: trace32 session not initialized"
    if trimmed.contains("Can't open display"):
        return "blocked: trace32 display not available"
    if trimmed.contains("Authorization required"):
        return "blocked: trace32 display authorization required"
    if trimmed == "":
        return "blocked: no TRACE32 response"
    "blocked: {trimmed}"

fn openocd_live_cpuid_status(cfg_path: text, serial: text, gdb_port: i32, expected_cpuid: i64) -> text:
    if not command_available("openocd"):
        return "skip: openocd unavailable"
    if not command_available("gdb"):
        return "skip: gdb unavailable"

    val client_result = OpenocdClient.connect(cfg_path, gdb_port, gdb_port + 1000, "", serial)
    if client_result.is_err():
        return "blocked: {client_result.err().unwrap()}"

    var client = client_result.ok.unwrap()
    val cpuid_bytes = client.read_memory(ARM_CPUID_ADDR, 4)
    client.disconnect()

    if cpuid_bytes.is_err():
        return "error: openocd read_memory failed: {cpuid_bytes.err().unwrap()}"

    val cpuid = bytes_to_u32_le(cpuid_bytes.ok.unwrap())
    if cpuid == expected_cpuid:
        return "ok"
    "error: unexpected cpuid 0x{cpuid}"

fn stlink_live_cpuid_status(serial: text, expected_chip_id: i64, expected_flash: i64, expected_sram: i64, expected_cpuid: i64) -> text:
    if not command_available("st-info"):
        return "skip: st-info unavailable"
    if not command_available("st-flash"):
        return "skip: st-flash unavailable"

    val client_result = StLinkToolsClient.connect(serial)
    if client_result.is_err():
        return "blocked: {client_result.err().unwrap()}"

    val client = client_result.ok.unwrap()
    val chip_id = client.chip_id()
    if chip_id.is_err():
        return "error: st-link chip id read failed: {chip_id.err().unwrap()}"
    if chip_id.ok.unwrap() != expected_chip_id:
        return "error: unexpected st-link chip id 0x{chip_id.ok.unwrap()}"

    val flash_size = client.flash_size()
    if flash_size.is_err():
        return "error: st-link flash size read failed: {flash_size.err().unwrap()}"
    if flash_size.ok.unwrap() != expected_flash:
        return "error: unexpected st-link flash size {flash_size.ok.unwrap()}"

    val sram_size = client.sram_size()
    if sram_size.is_err():
        return "error: st-link sram size read failed: {sram_size.err().unwrap()}"
    if sram_size.ok.unwrap() != expected_sram:
        return "error: unexpected st-link sram size {sram_size.ok.unwrap()}"

    val cpuid_dump = client.read_memory(ARM_CPUID_ADDR, 4)
    if cpuid_dump.is_err():
        return "error: st-link memory read failed: {cpuid_dump.err().unwrap()}"
    val cpuid = bytes_to_u32_le(parse_stlink_hex_dump(cpuid_dump.ok.unwrap()))
    if cpuid == expected_cpuid:
        return "ok"
    "error: unexpected st-link cpuid 0x{cpuid}"

fn openocd_stm_status() -> text:
    if not command_available("openocd"):
        return "skip: openocd unavailable"
    if not command_available("gdb"):
        return "skip: gdb unavailable"

    val h7 = Stm32H7Target.default()
    val wb = Stm32WbTarget.default()
    if h7.openocd_cfg == "" or wb.openocd_cfg == "":
        return "error: stm openocd config missing"

    val probe = shell("timeout 5 openocd -f '{h7.openocd_cfg}' -c 'transport list' -c shutdown 2>&1")
    val combined = (probe.stdout + probe.stderr).trim()

    if probe.exit_code == 0:
        return "ready: {h7.openocd_cfg}"
    if combined.contains("Can't find") or combined.contains("No such file"):
        return "blocked: openocd board config unavailable"
    if combined.contains("unable to open CMSIS-DAP") or combined.contains("unable to find a matching CMSIS-DAP device") or combined.contains("unable to open ftdi device") or combined.contains("init mode failed"):
        return "blocked: stm openocd probe unavailable"
    if combined == "":
        return "blocked: openocd produced no readiness output"
    "blocked: {combined}"

fn stlink_tools_stm_status() -> text:
    if not command_available("st-info"):
        return "skip: st-info unavailable"
    if not command_available("st-flash"):
        return "skip: st-flash unavailable"

    val h7 = Stm32H7Target.default()
    val wb = Stm32WbTarget.default()
    val serials = shell("st-info --serial 2>&1")
    val combined = (serials.stdout + serials.stderr).trim()

    if serials.exit_code != 0:
        if combined.contains("Couldn't find any ST-Link") or combined.contains("No ST-Link detected"):
            return "blocked: no st-link probe detected"
        return "blocked: {combined}"
    if combined.contains(h7.stlink_serial) or combined.contains(wb.stlink_serial):
        return "ready"
    if combined == "":
        return "blocked: st-info returned no probe serials"
    "blocked: expected stm probe serials not present"

describe "Remote baremetal composite parsing":

    it "extracts runtime, platform, and arch from nested remote spec":
        val spec = "interpreter(remote(baremetal(riscv32)))"
        expect(extract_base_runtime(spec)).to_equal("interpreter")
        expect(extract_platform_layer(spec)).to_equal("remote")
        expect(extract_arch_from_spec(spec)).to_equal("riscv32")

    it "maps riscv32 to qemu-system-riscv32 and virt machine":
        expect(qemu_binary_for_arch("riscv32")).to_equal("qemu-system-riscv32")
        expect(qemu_machine_for_arch("riscv32")).to_equal("virt")

    it "documents that no checked-in rv32 baremetal elf is currently discoverable":
        val elf = find_baremetal_elf("test/feature/app/remote_baremetal/remote_baremetal_runtime_spec.spl", "riscv32")
        expect(elf).to_equal("")

describe "QEMU RISC-V32 remote smoke":

    it "can build a temporary rv32 elf and read memory through gdb remote":
        val status = qemu_riscv32_remote_memory_status()
        expect(status_is_acceptable(status)).to_equal(true)

describe "TRACE32 readiness":

    it "resolves to a non-error readiness state":
        val status = trace32_remote_status()
        expect(status_is_acceptable(status)).to_equal(true)

describe "STM debugger readiness":

    it "reports openocd readiness for stm targets without treating host blockers as hard failures":
        val status = openocd_stm_status()
        expect(status_is_acceptable(status)).to_equal(true)

    it "reports st-link tools readiness for stm targets without treating host blockers as hard failures":
        val status = stlink_tools_stm_status()
        expect(status_is_acceptable(status)).to_equal(true)

describe "STM live debugger smoke":

    it "reads the H7 cpuid through openocd plus gdb":
        val h7 = Stm32H7Target.default()
        val status = openocd_live_cpuid_status(h7.openocd_cfg, h7.stlink_serial, h7.gdb_port, CORTEX_M7_CPUID)
        expect(status_is_acceptable(status)).to_equal(true)
        if not status.starts_with("skip:") and not status.starts_with("blocked:"):
            expect(status).to_equal("ok")

    it "reads the WB cpuid through openocd plus gdb":
        val wb = Stm32WbTarget.default()
        val status = openocd_live_cpuid_status(wb.openocd_cfg, wb.stlink_serial, wb.gdb_port, CORTEX_M4_CPUID)
        expect(status_is_acceptable(status)).to_equal(true)
        if not status.starts_with("skip:") and not status.starts_with("blocked:"):
            expect(status).to_equal("ok")

    it "reads the H7 cpuid through st-link tools":
        val h7 = Stm32H7Target.default()
        val status = stlink_live_cpuid_status(h7.stlink_serial, 0x480, 2097152, 131072, CORTEX_M7_CPUID)
        expect(status_is_acceptable(status)).to_equal(true)
        if not status.starts_with("skip:") and not status.starts_with("blocked:"):
            expect(status).to_equal("ok")

    it "reads the WB cpuid through st-link tools":
        val wb = Stm32WbTarget.default()
        val status = stlink_live_cpuid_status(wb.stlink_serial, 0x495, 1048576, 262144, CORTEX_M4_CPUID)
        expect(status_is_acceptable(status)).to_equal(true)
        if not status.starts_with("skip:") and not status.starts_with("blocked:"):
            expect(status).to_equal("ok")
