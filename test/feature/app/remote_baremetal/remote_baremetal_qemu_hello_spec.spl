"""
# Remote Baremetal QEMU Hello World

**Feature IDs:** #RBQH-001
**Category:** Tooling
**Difficulty:** 2/5
**Status:** Implemented

## Overview

Pure Simple system smoke for the `interpreter(remote(baremetal(riscv32)))`
lane using prebuilt RISC-V32 hello-world ELFs.

This spec does not go through the Rust CLI mode parser. It exercises the
Pure Simple composite executor directly and verifies that:

- the Pure Simple remote/baremetal executor can run a checked-in SSpec ELF on QEMU
- the stock semihost hello-world fixture still prints short semihost markers

## Examples

```simple
val result = run_test_file_composite(HELLO_SSPEC_ELF, options, REMOTE_RISCV32_SPEC)
expect(result.failed).to_equal(0)
expect(result.passed).to_equal(1)
```
"""

use app.io.{shell, file_exists}
use app.test_runner_new.test_executor_composite.{run_test_file_composite}
use app.test_runner_new.test_runner_args.parse_test_args

val REMOTE_RISCV32_SPEC = "interpreter(remote(baremetal(riscv32)))"
val REMOTE_GHDL_RISCV32_SPEC = "interpreter(remote(baremetal(ghdl(riscv32))))"
val QEMU_BIN = "qemu-system-riscv32"
val GHDL_RUNNER = "src/lib/nogc_async_mut_noalloc/baremetal/ghdl_runner.shs"
val HELLO_SSPEC_ELF = "examples/09_embedded/baremetal/baremetal/hello_riscv32_sspec.elf"
val HELLO_SEMIHOST_ELF = "examples/09_embedded/baremetal/baremetal/hello_riscv32_semihost.elf"

fn qemu_available() -> bool:
    val result = shell("command -v {QEMU_BIN} >/dev/null 2>&1")
    result.exit_code == 0

fn ghdl_available() -> bool:
    val ghdl = shell("command -v ghdl >/dev/null 2>&1")
    val objcopy = shell("command -v riscv64-linux-gnu-objcopy >/dev/null 2>&1")
    val python = shell("command -v python3 >/dev/null 2>&1")
    val runner = file_exists(GHDL_RUNNER)
    ghdl.exit_code == 0 and objcopy.exit_code == 0 and python.exit_code == 0 and runner

fn can_run_hello_sspec() -> bool:
    qemu_available() and file_exists(HELLO_SSPEC_ELF)

fn can_run_hello_semihost() -> bool:
    qemu_available() and file_exists(HELLO_SEMIHOST_ELF)

fn can_run_hello_ghdl() -> bool:
    ghdl_available() and file_exists(HELLO_SSPEC_ELF)

fn remote_riscv32_options(path: text):
    parse_test_args([path, "--quick", "--timeout", "10"])

fn run_qemu_semihost_output(elf_path: text) -> text:
    val run = shell("timeout 8 {QEMU_BIN} -M virt -bios none -kernel '{elf_path}' -nographic -semihosting-config enable=on,target=native 2>&1")
    run.stdout + run.stderr

fn run_ghdl_semihost_output(elf_path: text) -> text:
    val run = shell("timeout 20 bash '{GHDL_RUNNER}' '{elf_path}' --timeout=15 2>&1")
    run.stdout + run.stderr

describe "Pure Simple remote baremetal QEMU hello world":

    it "runs the checked-in sspec hello elf through the pure simple composite executor":
        if can_run_hello_sspec():
            val options = remote_riscv32_options(HELLO_SSPEC_ELF)
            val result = run_test_file_composite(HELLO_SSPEC_ELF, options, REMOTE_RISCV32_SPEC)
            expect(result.failed).to_equal(0)
            expect(result.error).to_equal("")
            expect(result.passed).to_equal(1)
        else:
            print "SKIP: qemu-system-riscv32 or hello sspec elf not available"

    it "prints the short semihost hello markers on stock qemu":
        if can_run_hello_semihost():
            val output = run_qemu_semihost_output(HELLO_SEMIHOST_ELF)
            expect(output).to_contain("Hello, RISC-V 32!")
            expect(output).to_contain("SEMIHOST TEST")
        else:
            print "SKIP: qemu-system-riscv32 or hello semihost elf not available"

describe "Pure Simple remote baremetal GHDL hello world":

    it "runs the checked-in sspec hello elf through the pure simple composite executor":
        if can_run_hello_ghdl():
            val options = remote_riscv32_options(HELLO_SSPEC_ELF)
            val result = run_test_file_composite(HELLO_SSPEC_ELF, options, REMOTE_GHDL_RISCV32_SPEC)
            expect(result.failed).to_equal(0)
            expect(result.error).to_equal("")
            expect(result.passed).to_equal(1)
        else:
            print "SKIP: ghdl toolchain or hello sspec elf not available"

    it "prints the stock sspec summary on the ghdl semihosting runner":
        if can_run_hello_ghdl():
            val output = run_ghdl_semihost_output(HELLO_SSPEC_ELF)
            expect(output).to_contain("Baremetal Semihosting")
            expect(output).to_contain("1 examples, 0 failures")
            expect(output).to_contain("Test PASSED")
        else:
            print "SKIP: ghdl toolchain or hello sspec elf not available"
