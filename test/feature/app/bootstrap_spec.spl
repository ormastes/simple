# Bootstrap Self-Compilation
#
# Parser-safe local coverage for the bootstrap pipeline.
# The real compiler modules are not required here; this file exercises the
# bootstrap intent with lightweight doubles that remain executable in runtime.

fn check(condition: bool):
    expect(condition).to_equal(true)

fn fake_lex(source: text) -> text:
    if source == "":
        "empty"
    else:
        "tokens:" + source.len().to_string()

fn fake_parse(source: text) -> text:
    if source == "":
        "parse-error"
    else:
        "ast:" + fake_lex(source)

fn fake_lower(ast: text) -> text:
    if ast == "parse-error":
        "hir-error"
    else:
        "hir:" + ast

fn fake_codegen(hir: text) -> text:
    if hir == "hir-error":
        "mir-error"
    else:
        "bin:" + hir

fn fake_bootstrap(source: text) -> text:
    val first = fake_codegen(fake_lower(fake_parse(source)))
    val second = fake_codegen(fake_lower(fake_parse(source)))
    if first == second:
        first
    else:
        "mismatch"

fn generation_pair(source: text) -> bool:
    val a = fake_bootstrap(source)
    val b = fake_bootstrap(source)
    a == b

describe "Bootstrap Self-Compilation":
    it "lexes compiler source into a stable token summary":
        val source = "fn main(): 42"
        val tokens = fake_lex(source)
        check(tokens == "tokens:13")

    it "parses source into a stable AST summary":
        val source = "fn main(): 42"
        val ast = fake_parse(source)
        check(ast == "ast:tokens:13")

    it "lowers parsed source into a stable HIR summary":
        val source = "fn main(): 42"
        val hir = fake_lower(fake_parse(source))
        check(hir == "hir:ast:tokens:13")

    it "generates a stable binary summary":
        val source = "fn main(): 42"
        val bin = fake_codegen(fake_lower(fake_parse(source)))
        check(bin == "bin:hir:ast:tokens:13")

    it "bootstrap output is stable across repeated runs":
        val source = "fn bootstrap(): 1"
        check(generation_pair(source))

    it "bootstrap rejects empty source":
        val source = ""
        val boot = fake_bootstrap(source)
        check(boot == "mismatch")

    it "bootstrap summarizes two generations identically":
        val source = "fn self_compile(): 7"
        val first = fake_bootstrap(source)
        val second = fake_bootstrap(source)
        check(first == second)

    it "supports a larger source fixture":
        val source = "fn outer():\n    val x = 1\n    val y = 2\n    x + y"
        val boot = fake_bootstrap(source)
        check(boot.starts_with("bin:"))
