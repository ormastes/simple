## LLM dashboard web source contracts.
##
## The runtime-oriented version of this spec currently hits the same post-example
## semantic teardown failure seen elsewhere in the UI bucket. These checks pin the
## server/auth wiring and responsive HTML contracts directly from source.

use std.spipe.*

extern fn rt_file_read_text(path: text) -> text

val SERVER_PATH = "src/app/web_dashboard/server.spl"
val HTML_VIEWS_PATH = "src/app/llm_dashboard/gui/html_views.spl"

fn _read_source(path: text) -> text:
    rt_file_read_text(path) ?? ""

describe "LLM agent dashboard web contracts":
    it "redirects unauthenticated /agents requests to /login":
        val source = _read_source(SERVER_PATH)
        expect(source).to_contain("if clean_path == \"/agents\" or clean_path.starts_with(\"/agents\"):")
        expect(source).to_contain("if session == nil:")
        expect(source).to_contain("return http_redirect(\"/login\")")

    it "includes responsive layout rules for narrow screens":
        val html_source = _read_source(HTML_VIEWS_PATH)
        expect(html_source).to_contain("@media (max-width: 1100px)")
        expect(html_source).to_contain("@media (max-width: 720px)")
        expect(html_source).to_contain("grid-template-columns: 1fr 1fr 1fr")
        expect(html_source).to_contain("grid-template-columns: 1fr 1fr")
        expect(html_source).to_contain("grid-template-columns: 1fr;")
