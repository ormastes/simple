# Native Build SMF Co-production Specification
#
# Tests that native-build with --emit-smf produces both
# a native binary and an SMF cache file with manifest entry.
#
# **Feature IDs:** #BUILD-SMF-001 to #BUILD-SMF-005
# **Category:** Build

# ============================================================================
# Mock types (self-contained for interpreter mode)
# ============================================================================

struct MockOutputConfig:
    output: text
    emit_smf: bool
    backend: text

fn mock_output_config(output: text, emit_smf: bool) -> MockOutputConfig:
    MockOutputConfig(output: output, emit_smf: emit_smf, backend: "llvm-lib")

val MOCK_FORMAT_NATIVE: i64 = 0
val MOCK_FORMAT_SMF: i64 = 1
val MOCK_FORMAT_BOTH: i64 = 2

fn mock_select_format(config: MockOutputConfig) -> i64:
    if config.emit_smf:
        return MOCK_FORMAT_BOTH
    MOCK_FORMAT_NATIVE

fn mock_smf_cache_path(source: text) -> text:
    val base = source.replace(".spl", "").replace("/", "_")
    "build/smf/{base}.smf"

# ============================================================================
# Tests
# ============================================================================

describe "Native build output format selection":
    it "defaults to native-only format":
        val config = mock_output_config("bin/app", false)
        val format = mock_select_format(config)
        expect(format).to_equal(MOCK_FORMAT_NATIVE)

    it "selects Both format with --emit-smf":
        val config = mock_output_config("bin/app", true)
        val format = mock_select_format(config)
        expect(format).to_equal(MOCK_FORMAT_BOTH)

describe "SMF cache path generation":
    it "converts source path to cache path":
        val path = mock_smf_cache_path("src/app/cli/main.spl")
        expect(path).to_equal("build/smf/src_app_cli_main.smf")

    it "handles simple paths":
        val path = mock_smf_cache_path("src/main.spl")
        expect(path).to_equal("build/smf/src_main.smf")

    it "handles deeply nested paths":
        val path = mock_smf_cache_path("src/compiler/70.backend/backend/compiler.spl")
        expect(path).to_equal("build/smf/src_compiler_70.backend_backend_compiler.smf")

describe "Native build --emit-smf flow":
    it "produces both artifacts when emit_smf is true":
        val config = mock_output_config("bin/release/simple", true)
        val format = mock_select_format(config)
        expect(format).to_equal(MOCK_FORMAT_BOTH)
        # In Both mode, native goes to output, SMF goes to cache
        val smf_path = mock_smf_cache_path("src/app/cli/main.spl")
        expect(smf_path).to_contain("build/smf/")
        expect(smf_path).to_end_with(".smf")
