"""
# T32 MCP Server -- Tool Handler Unit Tests

**Feature IDs:** #T32-MCP-002
**Category:** Tooling
**Difficulty:** 2/5
**Status:** Implemented

## Overview

Tests for the T32 MCP server tool handlers: field mapping functions,
window catalog, headless setup command generation, and CMM command database.
All functions under test are pure (no I/O, no side effects).

## Source

`examples/10_tooling/trace32_tools/t32_mcp/action_tools.spl`
`examples/10_tooling/trace32_tools/t32_mcp/headless_tools.spl`
`examples/10_tooling/trace32_tools/t32_mcp/window_tools.spl`
"""

use app.mcp_t32.action_tools.{t32_field_to_eval, t32_field_to_set_cmd}
use app.mcp_t32.window_tools.{t32_hardcoded_window_catalog, t32_parse_window_sdn, t32_parse_catalog_entry}
use app.mcp_t32.headless_tools.{t32_build_cmm_command_db, t32_to_lower, t32_text_contains}
use app.mcp_t32.session_tools.{t32_check_blocking, t32_has_blocking}

# ============================================================================
# Field Mapping — EVAL expressions
# ============================================================================

describe "T32 MCP Field Mapping":

    context "t32_field_to_eval maps common fields":
        it "maps 'pc' to Register(PC) EVAL":
            val result = t32_field_to_eval("pc")
            expect(result).to_equal("Register(PC)")

        it "maps 'sp' to Register(SP) EVAL":
            val result = t32_field_to_eval("sp")
            expect(result).to_equal("Register(SP)")

        it "maps 'lr' to Register(LR)":
            val result = t32_field_to_eval("lr")
            expect(result).to_equal("Register(LR)")

        it "maps 'cpsr' to Register(CPSR)":
            val result = t32_field_to_eval("cpsr")
            expect(result).to_equal("Register(CPSR)")

        it "maps register.R0 to Register(R0)":
            val result = t32_field_to_eval("register.R0")
            expect(result).to_equal("Register(R0)")

        it "maps var.x to Var.VALUE(x)":
            val result = t32_field_to_eval("var.x")
            expect(result).to_equal("Var.VALUE(x)")

        it "maps memory.0x1000 to Data.Long(0x1000)":
            val result = t32_field_to_eval("memory.0x1000")
            expect(result).to_equal("Data.Long(0x1000)")

        it "returns raw expression for unknown fields":
            val result = t32_field_to_eval("PRACTICE.STATE()")
            expect(result).to_equal("PRACTICE.STATE()")

# ============================================================================
# Field Mapping — SET commands
# ============================================================================

describe "T32 MCP Field Set Commands":

    context "t32_field_to_set_cmd maps to T32 commands":
        it "maps pc set to Register.Set PC":
            val result = t32_field_to_set_cmd("pc", "0x8000")
            expect(result).to_equal("Register.Set PC 0x8000")

        it "maps sp set to Register.Set SP":
            val result = t32_field_to_set_cmd("sp", "0x20000")
            expect(result).to_equal("Register.Set SP 0x20000")

        it "maps register.R0 to Register.Set R0":
            val result = t32_field_to_set_cmd("register.R0", "42")
            expect(result).to_equal("Register.Set R0 42")

        it "maps var.count to Var.Set":
            val result = t32_field_to_set_cmd("var.count", "10")
            expect(result).to_equal("Var.Set count = 10")

        it "maps memory.0x1000 to Data.Set":
            val result = t32_field_to_set_cmd("memory.0x1000", "0xDEAD")
            expect(result).to_equal("Data.Set 0x1000 %Long 0xDEAD")

        it "returns empty for unknown fields":
            val result = t32_field_to_set_cmd("unknown_field", "value")
            expect(result).to_equal("")

# ============================================================================
# Window Catalog
# ============================================================================

describe "T32 MCP Window Catalog":

    context "hardcoded catalog":
        it "has 19 entries in hardcoded catalog":
            val catalog = t32_hardcoded_window_catalog()
            expect(catalog.len()).to_equal(19)

        it "finds register_view entry":
            val catalog = t32_hardcoded_window_catalog()
            var found = false
            for entry in catalog:
                if entry.starts_with("register_view|"):
                    found = true
            expect(found).to_equal(true)

        it "returns capture command for register_view":
            val catalog = t32_hardcoded_window_catalog()
            var found_capture = ""
            for entry in catalog:
                if entry.starts_with("register_view|"):
                    # Parse pipe-delimited: "key|title|kind|open_cmd|capture_cmd"
                    val seg = entry.split("|")
                    if seg.len() >= 5:
                        found_capture = seg[4]
            expect(found_capture).to_equal("WinPrint.Register.view")

        it "includes riscv csr view":
            val catalog = t32_hardcoded_window_catalog()
            var found = false
            for entry in catalog:
                if entry.starts_with("riscv_csr_view|"):
                    found = true
                    expect(entry).to_contain("Register.view /SpotLight /CSR")
            expect(found).to_equal(true)

        it "includes flash and system status windows":
            val catalog = t32_hardcoded_window_catalog()
            var found_flash = false
            var found_system = false
            var found_nexus = false
            for entry in catalog:
                if entry.starts_with("flash_status|"):
                    found_flash = true
                    expect(entry).to_contain("FLASH.List")
                if entry.starts_with("system_status|"):
                    found_system = true
                    expect(entry).to_contain("System.state")
                if entry.starts_with("nexus_trace|"):
                    found_nexus = true
                    expect(entry).to_contain("Trace.List /Nexus")
            expect(found_flash).to_equal(true)
            expect(found_system).to_equal(true)
            expect(found_nexus).to_equal(true)

    context "SDN parsing":
        it "parses SDN catalog format":
            val sdn = "window my_win\n  title: Test Window\n  kind: custom\n  capture_mode: print_parse\n  arch: riscv\n  open_command: MyCmd\n  capture_command: WinPrint.MyCmd\n  notes: demo\n"
            val catalog = t32_parse_window_sdn(sdn)
            expect(catalog[0]).to_contain("my_win")
            expect(catalog.len()).to_equal(1)
            expect(catalog[0]).to_contain("Test Window")
            expect(catalog[0]).to_contain("print_parse")
            expect(catalog[0]).to_contain("riscv")
            expect(catalog[0]).to_contain("demo")

# ============================================================================
# Blocking Guard
# ============================================================================

describe "T32 MCP Blocking Guard":

    context "blocking commands":
        it "blocks dialog ok":
            val warnings = t32_check_blocking("DIALOG.OK \"Continue?\"")
            expect(t32_has_blocking(warnings)).to_equal(true)
            expect(warnings.join("\n")).to_contain("DIALOG.OK")

        it "blocks enter and pause":
            val warnings = t32_check_blocking("ENTER\nPAUSE")
            expect(t32_has_blocking(warnings)).to_equal(true)
            expect(warnings.join("\n")).to_contain("ENTER")
            expect(warnings.join("\n")).to_contain("PAUSE")

        it "does not block entry symbol names":
            val warnings = t32_check_blocking("ENTRY main")
            expect(t32_has_blocking(warnings)).to_equal(false)

    context "warn and info commands":
        it "warns for wait without blocking":
            val warnings = t32_check_blocking("WAIT 100.ms")
            expect(t32_has_blocking(warnings)).to_equal(false)
            expect(warnings.join("\n")).to_contain("WAIT")

        it "adds info for screen and winpos":
            val warnings = t32_check_blocking("SCREEN.ON\nWinPOS 0. 0. 80. 40.")
            expect(t32_has_blocking(warnings)).to_equal(false)
            expect(warnings.join("\n")).to_contain("SCREEN.ON")
            expect(warnings.join("\n")).to_contain("WINPOS")

# ============================================================================
# Headless Setup Helpers
# ============================================================================

describe "T32 MCP Headless Setup":

    context "helper functions":
        it "converts to lower case":
            val result = t32_to_lower("Hello WORLD")
            expect(result).to_equal("hello world")

        it "detects substring containment":
            val result = t32_text_contains("hello world", "world")
            expect(result).to_equal(true)

        it "returns false for non-contained substring":
            val result = t32_text_contains("hello", "xyz")
            expect(result).to_equal(false)

# ============================================================================
# CMM Command Database
# ============================================================================

describe "T32 MCP CMM Command DB":

    context "database content":
        it "has 90+ commands":
            val db = t32_build_cmm_command_db()
            expect(db.len()).to_be_greater_than(90)

        it "includes Data.dump command":
            val db = t32_build_cmm_command_db()
            var found = false
            for cmd in db:
                if cmd.starts_with("Data.dump|"):
                    found = true
            expect(found).to_equal(true)

        it "includes Break.Set command":
            val db = t32_build_cmm_command_db()
            var found = false
            for cmd in db:
                if cmd.starts_with("Break.Set|"):
                    found = true
            expect(found).to_equal(true)

    context "filtering":
        it "filters by group":
            val db = t32_build_cmm_command_db()
            var data_count: i64 = 0
            for cmd in db:
                if t32_text_contains(cmd, "|Data|"):
                    data_count = data_count + 1
            expect(data_count).to_be_greater_than(5)

        it "searches by substring":
            val db = t32_build_cmm_command_db()
            var flash_count: i64 = 0
            for cmd in db:
                if t32_text_contains(t32_to_lower(cmd), "flash"):
                    flash_count = flash_count + 1
            expect(flash_count).to_be_greater_than(3)

        it "returns empty for unknown group":
            val db = t32_build_cmm_command_db()
            var unknown_count: i64 = 0
            for cmd in db:
                if t32_text_contains(cmd, "|NonExistentGroup|"):
                    unknown_count = unknown_count + 1
            expect(unknown_count).to_equal(0)
