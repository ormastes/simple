# T32 CMM GUI Pattern spec — tests that GUI CMM patterns are detected
# in ALL local CMM fixture files. Reads each .cmm file at runtime,
# scans every line, and verifies the expected GUI patterns are found.

extern fn rt_file_read_text(path: text) -> text

# --- Inlined pattern detectors ---

fn cmm_is_gui_pattern(line: text) -> bool:
    val trimmed = line.trim()
    if trimmed == "" or trimmed.starts_with(";"):
        return false
    val upper = trimmed.to_upper()
    if upper.starts_with("DIALOG"):
        return true
    if upper.starts_with("WINPOS"):
        return true
    if upper.starts_with("WINPAGE"):
        return true
    if upper.starts_with("WINCLEAR"):
        return true
    if upper.starts_with("WINTABS"):
        return true
    if upper.starts_with("TOOLBAR"):
        return true
    if upper.starts_with("STATUSBAR"):
        return true
    if upper.starts_with("FRAMEPOS"):
        return true
    if upper.starts_with("SCREEN."):
        return true
    if upper.starts_with("AREA."):
        return true
    if upper.starts_with("HEADER"):
        return true
    if upper.starts_with("POS "):
        return true
    if upper.starts_with("TEXT "):
        return true
    if upper.starts_with("BUTTON"):
        return true
    if upper.starts_with("DEFBUTTON"):
        return true
    if upper.starts_with("LINE "):
        return true
    if upper.starts_with("CLOSE"):
        return true
    if upper.starts_with("MENU."):
        return true
    if upper.starts_with("PRINTER."):
        return true
    false

fn cmm_classify_pattern(line: text) -> text:
    val trimmed = line.trim()
    val upper = trimmed.to_upper()
    if upper.starts_with("DIALOG.OK"):
        return "dialog_ok"
    if upper.starts_with("DIALOG.YESNO"):
        return "dialog_yesno"
    if upper.starts_with("DIALOG.END"):
        return "dialog_end"
    if upper.starts_with("DIALOG.STRING"):
        return "dialog_string"
    if upper.starts_with("DIALOG"):
        return "dialog_block"
    if upper.starts_with("WINPOS"):
        return "winpos"
    if upper.starts_with("WINPAGE.CREATE"):
        return "winpage_create"
    if upper.starts_with("WINPAGE.SELECT"):
        return "winpage_select"
    if upper.starts_with("WINPAGE.RESET"):
        return "winpage_reset"
    if upper.starts_with("WINCLEAR"):
        return "winclear"
    if upper.starts_with("WINTABS"):
        return "wintabs"
    if upper.starts_with("TOOLBAR"):
        return "toolbar"
    if upper.starts_with("STATUSBAR"):
        return "statusbar"
    if upper.starts_with("FRAMEPOS"):
        return "framepos"
    if upper.starts_with("SCREEN.ALWAYS"):
        return "screen_always"
    if upper.starts_with("SCREEN.ON"):
        return "screen_on"
    if upper.starts_with("SCREEN.OFF"):
        return "screen_off"
    if upper.starts_with("SCREEN.WAIT"):
        return "screen_wait"
    if upper.starts_with("AREA.CREATE"):
        return "area_create"
    if upper.starts_with("AREA.SELECT"):
        return "area_select"
    if upper.starts_with("AREA.CLEAR"):
        return "area_clear"
    if upper.starts_with("AREA.VIEW"):
        return "area_view"
    if upper.starts_with("AREA.RESET"):
        return "area_reset"
    if upper.starts_with("HEADER"):
        return "header"
    if upper.starts_with("POS "):
        return "pos"
    if upper.starts_with("TEXT "):
        return "text_label"
    if upper.starts_with("DEFBUTTON"):
        return "defbutton"
    if upper.starts_with("BUTTON"):
        return "button"
    if upper.starts_with("LINE "):
        return "line_separator"
    if upper.starts_with("CLOSE"):
        return "close_handler"
    if upper.starts_with("MENU.REPROGRAM"):
        return "menu_reprogram"
    if upper.starts_with("MENU.RP"):
        return "menu_rp"
    if upper.starts_with("PRINTER.FILE"):
        return "printer_file"
    "unknown"

# Scan a CMM file and return list of classified GUI patterns found
fn scan_cmm_gui(path: text) -> [text]:
    val content = rt_file_read_text(path) ?? ""
    var patterns: [text] = []
    if content == "":
        return patterns
    val lines = content.split("\n")
    for line in lines:
        if cmm_is_gui_pattern(line):
            val cls = cmm_classify_pattern(line)
            # Deduplicate: only add if not already seen
            var seen = false
            for p in patterns:
                if p == cls:
                    seen = true
            if not seen:
                patterns.push(cls)
    patterns

fn has_pattern(patterns: [text], target: text) -> bool:
    for p in patterns:
        if p == target:
            return true
    false

val FIXTURE_BASE = "examples/10_tooling/trace32_tools/test_fixtures"

# --- Tests ---

describe "T32 CMM GUI Patterns — live fixture scan":

    context "rcar3_window.cmm (WinPOS/WinPAGE/FramePOS/TOOLBAR)":
        it "finds all window layout patterns":
            val patterns = scan_cmm_gui(FIXTURE_BASE + "/web/rcar3_window.cmm")
            expect(has_pattern(patterns, "winpage_reset")).to_equal(true)
            expect(has_pattern(patterns, "winclear")).to_equal(true)
            expect(has_pattern(patterns, "framepos")).to_equal(true)
            expect(has_pattern(patterns, "winpos")).to_equal(true)
            expect(has_pattern(patterns, "wintabs")).to_equal(true)
            expect(has_pattern(patterns, "toolbar")).to_equal(true)
            expect(has_pattern(patterns, "statusbar")).to_equal(true)
            expect(has_pattern(patterns, "winpage_create")).to_equal(true)
            expect(has_pattern(patterns, "winpage_select")).to_equal(true)

    context "spreadtrum_main.cmm (DIALOG block + controls)":
        it "finds dialog block with all controls":
            val patterns = scan_cmm_gui(FIXTURE_BASE + "/web/spreadtrum_main.cmm")
            expect(has_pattern(patterns, "dialog_ok")).to_equal(true)
            expect(has_pattern(patterns, "dialog_block")).to_equal(true)
            expect(has_pattern(patterns, "header")).to_equal(true)
            expect(has_pattern(patterns, "pos")).to_equal(true)
            expect(has_pattern(patterns, "text_label")).to_equal(true)
            expect(has_pattern(patterns, "defbutton")).to_equal(true)
            expect(has_pattern(patterns, "button")).to_equal(true)
            expect(has_pattern(patterns, "close_handler")).to_equal(true)
            expect(has_pattern(patterns, "dialog_string")).to_equal(true)
            expect(has_pattern(patterns, "dialog_end")).to_equal(true)

    context "bl602_wifi.cmm (DIALOG + LINE separator)":
        it "finds dialog with line separator":
            val patterns = scan_cmm_gui(FIXTURE_BASE + "/riscv/bl602_wifi.cmm")
            expect(has_pattern(patterns, "dialog_block")).to_equal(true)
            expect(has_pattern(patterns, "header")).to_equal(true)
            expect(has_pattern(patterns, "defbutton")).to_equal(true)
            expect(has_pattern(patterns, "button")).to_equal(true)
            expect(has_pattern(patterns, "line_separator")).to_equal(true)
            expect(has_pattern(patterns, "close_handler")).to_equal(true)

    context "imx6sx_qspi.cmm (AREA commands)":
        it "finds all AREA operations":
            val patterns = scan_cmm_gui(FIXTURE_BASE + "/web/imx6sx_qspi.cmm")
            expect(has_pattern(patterns, "area_create")).to_equal(true)
            expect(has_pattern(patterns, "area_select")).to_equal(true)
            expect(has_pattern(patterns, "area_view")).to_equal(true)
            expect(has_pattern(patterns, "area_clear")).to_equal(true)

    context "ch32v307_kernel.cmm (AREA + MENU.ReProgram + AREA.RESet)":
        it "finds AREA with dimensions and AREA.RESet":
            val patterns = scan_cmm_gui(FIXTURE_BASE + "/riscv/ch32v307_kernel.cmm")
            expect(has_pattern(patterns, "area_create")).to_equal(true)
            expect(has_pattern(patterns, "area_view")).to_equal(true)
            expect(has_pattern(patterns, "area_select")).to_equal(true)
            expect(has_pattern(patterns, "area_reset")).to_equal(true)
            expect(has_pattern(patterns, "menu_reprogram")).to_equal(true)

    context "sifive_e31_debug.cmm (SCREEN.ALways + WinPOS)":
        it "finds SCREEN.ALways and window positions":
            val patterns = scan_cmm_gui(FIXTURE_BASE + "/riscv/sifive_e31_debug.cmm")
            expect(has_pattern(patterns, "screen_always")).to_equal(true)
            expect(has_pattern(patterns, "winpos")).to_equal(true)

    context "qnx_beagle.cmm (SCREEN.ALways + MENU.ReProgram)":
        it "finds SCREEN and MENU patterns":
            val patterns = scan_cmm_gui(FIXTURE_BASE + "/web/qnx_beagle.cmm")
            expect(has_pattern(patterns, "screen_always")).to_equal(true)
            expect(has_pattern(patterns, "menu_reprogram")).to_equal(true)

    context "linux_vm.cmm (MENU.ReProgram)":
        it "finds MENU pattern":
            val patterns = scan_cmm_gui(FIXTURE_BASE + "/web/linux_vm.cmm")
            expect(has_pattern(patterns, "menu_reprogram")).to_equal(true)

    context "stm32h7_flash.cmm (DIALOG.YESNO + TOOLBAR + WinPOS)":
        it "finds DIALOG.YESNO and layout":
            val patterns = scan_cmm_gui(FIXTURE_BASE + "/stm32/stm32h7_flash.cmm")
            expect(has_pattern(patterns, "dialog_yesno")).to_equal(true)
            expect(has_pattern(patterns, "toolbar")).to_equal(true)
            expect(has_pattern(patterns, "winpos")).to_equal(true)

    context "stm32wb_ble.cmm (DIALOG.YESNO + TOOLBAR + WinPOS)":
        it "finds BLE dialog and window layout":
            val patterns = scan_cmm_gui(FIXTURE_BASE + "/stm32/stm32wb_ble.cmm")
            expect(has_pattern(patterns, "dialog_yesno")).to_equal(true)
            expect(has_pattern(patterns, "toolbar")).to_equal(true)
            expect(has_pattern(patterns, "winpos")).to_equal(true)

    context "stm32wb_dual_core.cmm (SCREEN.ALways + TOOLBAR + STATUSBAR + multi-WinPOS)":
        it "finds multi-core debug layout":
            val patterns = scan_cmm_gui(FIXTURE_BASE + "/stm32/stm32wb_dual_core.cmm")
            expect(has_pattern(patterns, "screen_always")).to_equal(true)
            expect(has_pattern(patterns, "toolbar")).to_equal(true)
            expect(has_pattern(patterns, "statusbar")).to_equal(true)
            expect(has_pattern(patterns, "winpos")).to_equal(true)

    context "stm32h7_swd_debug.cmm (TOOLBAR + STATUSBAR + WinPOS)":
        it "finds SWD debug layout":
            val patterns = scan_cmm_gui(FIXTURE_BASE + "/stm32/stm32h7_swd_debug.cmm")
            expect(has_pattern(patterns, "toolbar")).to_equal(true)
            expect(has_pattern(patterns, "statusbar")).to_equal(true)
            expect(has_pattern(patterns, "winpos")).to_equal(true)

    context "stm32h7_peripheral.cmm (TOOLBAR + STATUSBAR + WinPOS)":
        it "finds peripheral viewer layout":
            val patterns = scan_cmm_gui(FIXTURE_BASE + "/stm32/stm32h7_peripheral.cmm")
            expect(has_pattern(patterns, "toolbar")).to_equal(true)
            expect(has_pattern(patterns, "statusbar")).to_equal(true)
            expect(has_pattern(patterns, "winpos")).to_equal(true)

    context "stm32wb_flash_otp.cmm (double DIALOG.YESNO + TOOLBAR + WinPOS)":
        it "finds OTP flash patterns":
            val patterns = scan_cmm_gui(FIXTURE_BASE + "/stm32/stm32wb_flash_otp.cmm")
            expect(has_pattern(patterns, "dialog_yesno")).to_equal(true)
            expect(has_pattern(patterns, "toolbar")).to_equal(true)
            expect(has_pattern(patterns, "winpos")).to_equal(true)

    context "esp32c3_flash.cmm (DIALOG.YESNO)":
        it "finds flash erase dialog":
            val patterns = scan_cmm_gui(FIXTURE_BASE + "/riscv/esp32c3_flash.cmm")
            expect(has_pattern(patterns, "dialog_yesno")).to_equal(true)

    context "s32k_flash.cmm (DIALOG.YESNO)":
        it "finds device secure dialog":
            val patterns = scan_cmm_gui(FIXTURE_BASE + "/web/s32k_flash.cmm")
            expect(has_pattern(patterns, "dialog_yesno")).to_equal(true)

    context "polarfire_program.cmm (DIALOG.OK)":
        it "finds design file dialog":
            val patterns = scan_cmm_gui(FIXTURE_BASE + "/web/polarfire_program.cmm")
            expect(has_pattern(patterns, "dialog_ok")).to_equal(true)

    context "expected_cli conversions have SCREEN.OFF + AREA setup":
        it "expected_cli/web/rcar3_window.cmm has SCREEN.OFF":
            val patterns = scan_cmm_gui(FIXTURE_BASE + "/expected_cli/web/rcar3_window.cmm")
            expect(has_pattern(patterns, "screen_off")).to_equal(true)
            expect(has_pattern(patterns, "area_create")).to_equal(true)
            expect(has_pattern(patterns, "area_select")).to_equal(true)

        it "expected_cli/web/spreadtrum_main.cmm has SCREEN.OFF":
            val patterns = scan_cmm_gui(FIXTURE_BASE + "/expected_cli/web/spreadtrum_main.cmm")
            expect(has_pattern(patterns, "screen_off")).to_equal(true)
            expect(has_pattern(patterns, "area_create")).to_equal(true)

        it "expected_cli/riscv/bl602_wifi.cmm has SCREEN.OFF":
            val patterns = scan_cmm_gui(FIXTURE_BASE + "/expected_cli/riscv/bl602_wifi.cmm")
            expect(has_pattern(patterns, "screen_off")).to_equal(true)
            expect(has_pattern(patterns, "area_create")).to_equal(true)

        it "expected_cli/stm32/stm32wb_dual_core.cmm has SCREEN.OFF":
            val patterns = scan_cmm_gui(FIXTURE_BASE + "/expected_cli/stm32/stm32wb_dual_core.cmm")
            expect(has_pattern(patterns, "screen_off")).to_equal(true)
            expect(has_pattern(patterns, "area_create")).to_equal(true)

    context "non-GUI fixtures have no GUI patterns":
        it "fe310_blinky.cmm has no GUI":
            val patterns = scan_cmm_gui(FIXTURE_BASE + "/riscv/fe310_blinky.cmm")
            expect(patterns.len()).to_equal(0)

    context "classifier coverage — all known types":
        it "classifies SCREEN.ALways":
            expect(cmm_classify_pattern("SCREEN.ALways")).to_equal("screen_always")

        it "classifies AREA.RESet":
            expect(cmm_classify_pattern("AREA.RESet")).to_equal("area_reset")

        it "classifies MENU.ReProgram":
            expect(cmm_classify_pattern("MENU.ReProgram ~~/demo/arm/kernel/qnx/qnx.men")).to_equal("menu_reprogram")

        it "classifies DIALOG.STRing":
            expect(cmm_classify_pattern("DIALOG.STRing(project.name)")).to_equal("dialog_string")

        it "does not classify non-GUI as GUI":
            expect(cmm_is_gui_pattern("SYStem.Up")).to_equal(false)
            expect(cmm_is_gui_pattern("Break.Set main")).to_equal(false)
            expect(cmm_is_gui_pattern("Data.dump D:0x0")).to_equal(false)
            expect(cmm_is_gui_pattern("; comment line")).to_equal(false)
            expect(cmm_is_gui_pattern("")).to_equal(false)
