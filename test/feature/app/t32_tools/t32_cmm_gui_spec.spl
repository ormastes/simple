# T32 CMM GUI Pattern spec — tests that GUI CMM patterns are recognized
# Tests inline pattern detection logic for DIALOG, WinPOS, WinPAGE,
# TOOLBAR, AREA, FramePOS, SCREEN patterns found in fixture CMM files

# --- Inlined pattern detectors ---

fn ws_trim(s: text) -> text:
    s.trim()

fn cmm_is_gui_pattern(line: text) -> bool:
    val trimmed = ws_trim(line)
    val upper = trimmed.to_upper()
    if upper.starts_with("DIALOG"):
        return true
    if upper.starts_with("WINPOS"):
        return true
    if upper.starts_with("WINPAGE"):
        return true
    if upper.starts_with("WINCLEAR"):
        return true
    if upper.starts_with("WINTABS"):
        return true
    if upper.starts_with("TOOLBAR"):
        return true
    if upper.starts_with("STATUSBAR"):
        return true
    if upper.starts_with("FRAMEPOS"):
        return true
    if upper.starts_with("SCREEN."):
        return true
    if upper.starts_with("AREA."):
        return true
    if upper.starts_with("HEADER"):
        return true
    if upper.starts_with("POS "):
        return true
    if upper.starts_with("TEXT "):
        return true
    if upper.starts_with("BUTTON"):
        return true
    if upper.starts_with("DEFBUTTON"):
        return true
    if upper.starts_with("LINE "):
        return true
    if upper.starts_with("CLOSE"):
        return true
    if upper.starts_with("MENU."):
        return true
    if upper.starts_with("PRINTER."):
        return true
    false

fn cmm_classify_pattern(line: text) -> text:
    val trimmed = ws_trim(line)
    val upper = trimmed.to_upper()
    if upper.starts_with("DIALOG.OK"):
        return "dialog_ok"
    if upper.starts_with("DIALOG.YESNO"):
        return "dialog_yesno"
    if upper.starts_with("DIALOG.END"):
        return "dialog_end"
    if upper.starts_with("DIALOG.STRING"):
        return "dialog_string"
    if upper.starts_with("DIALOG"):
        return "dialog_block"
    if upper.starts_with("WINPOS"):
        return "winpos"
    if upper.starts_with("WINPAGE.CREATE"):
        return "winpage_create"
    if upper.starts_with("WINPAGE.SELECT"):
        return "winpage_select"
    if upper.starts_with("WINPAGE.RESET"):
        return "winpage_reset"
    if upper.starts_with("WINCLEAR"):
        return "winclear"
    if upper.starts_with("WINTABS"):
        return "wintabs"
    if upper.starts_with("TOOLBAR"):
        return "toolbar"
    if upper.starts_with("STATUSBAR"):
        return "statusbar"
    if upper.starts_with("FRAMEPOS"):
        return "framepos"
    if upper.starts_with("SCREEN.ON"):
        return "screen_on"
    if upper.starts_with("SCREEN.OFF"):
        return "screen_off"
    if upper.starts_with("SCREEN.WAIT"):
        return "screen_wait"
    if upper.starts_with("AREA.CREATE"):
        return "area_create"
    if upper.starts_with("AREA.SELECT"):
        return "area_select"
    if upper.starts_with("AREA.CLEAR"):
        return "area_clear"
    if upper.starts_with("AREA.VIEW"):
        return "area_view"
    if upper.starts_with("HEADER"):
        return "header"
    if upper.starts_with("POS "):
        return "pos"
    if upper.starts_with("TEXT "):
        return "text_label"
    if upper.starts_with("DEFBUTTON"):
        return "defbutton"
    if upper.starts_with("BUTTON"):
        return "button"
    if upper.starts_with("LINE "):
        return "line_separator"
    if upper.starts_with("CLOSE"):
        return "close_handler"
    if upper.starts_with("MENU.RP"):
        return "menu_rp"
    if upper.starts_with("PRINTER.FILE"):
        return "printer_file"
    "unknown"

# --- Tests ---

describe "T32 CMM GUI Patterns":

    context "DIALOG blocks (spreadtrum_main.cmm)":
        it "detects DIALOG block":
            expect(cmm_is_gui_pattern("DIALOG")).to_equal(true)
            expect(cmm_classify_pattern("DIALOG")).to_equal("dialog_block")

        it "detects HEADER inside dialog":
            expect(cmm_is_gui_pattern("  HEADER \"Spreadtrum Debug Configuration\"")).to_equal(true)
            expect(cmm_classify_pattern("HEADER \"Spreadtrum Debug Configuration\"")).to_equal("header")

        it "detects POS directive":
            expect(cmm_is_gui_pattern("  POS 1. 1. 30.")).to_equal(true)
            expect(cmm_classify_pattern("POS 1. 1. 30.")).to_equal("pos")

        it "detects TEXT label":
            expect(cmm_is_gui_pattern("  TEXT \"Project Selection\"")).to_equal(true)
            expect(cmm_classify_pattern("TEXT \"Project Selection\"")).to_equal("text_label")

        it "detects BUTTON":
            expect(cmm_is_gui_pattern("  BUTTON \"Cancel\" \"DIALOG.END\"")).to_equal(true)
            expect(cmm_classify_pattern("BUTTON \"Cancel\" \"DIALOG.END\"")).to_equal("button")

        it "detects DEFBUTTON":
            expect(cmm_is_gui_pattern("  DEFBUTTON \"Start Debug\" \"GOTO start_debug\"")).to_equal(true)
            expect(cmm_classify_pattern("DEFBUTTON \"Start Debug\" \"GOTO start_debug\"")).to_equal("defbutton")

        it "detects LINE separator":
            expect(cmm_is_gui_pattern("  LINE \"Advanced\"")).to_equal(true)
            expect(cmm_classify_pattern("LINE \"Advanced\"")).to_equal("line_separator")

        it "detects CLOSE handler":
            expect(cmm_is_gui_pattern("  CLOSE \"GOTO cleanup\"")).to_equal(true)
            expect(cmm_classify_pattern("CLOSE \"GOTO cleanup\"")).to_equal("close_handler")

    context "DIALOG message boxes":
        it "detects DIALOG.OK":
            expect(cmm_classify_pattern("DIALOG.OK \"TRACE32 version too old.\"")).to_equal("dialog_ok")

        it "detects DIALOG.YESNO":
            expect(cmm_classify_pattern("DIALOG.YESNO \"Continue?\"")).to_equal("dialog_yesno")

        it "detects DIALOG.END":
            expect(cmm_classify_pattern("DIALOG.END")).to_equal("dialog_end")

        it "detects DIALOG.STRing()":
            expect(cmm_classify_pattern("DIALOG.STRing(project.name)")).to_equal("dialog_string")

    context "WinPOS (rcar3_window.cmm)":
        it "detects WinPOS with float parameters":
            expect(cmm_is_gui_pattern("WinPOS 0. 0. 80. 10. 0. 0. W000")).to_equal(true)
            expect(cmm_classify_pattern("WinPOS 0. 0. 80. 10. 0. 0. W000")).to_equal("winpos")

        it "detects simple WinPOS":
            expect(cmm_classify_pattern("WinPOS 0. 0. 80. 25.")).to_equal("winpos")

    context "WinPAGE (rcar3_window.cmm)":
        it "detects WinPAGE.Create":
            expect(cmm_classify_pattern("WinPAGE.Create P001")).to_equal("winpage_create")

        it "detects WinPAGE.select":
            expect(cmm_classify_pattern("WinPAGE.select P001")).to_equal("winpage_select")

        it "detects WinPAGE.RESet":
            expect(cmm_classify_pattern("WinPAGE.RESet")).to_equal("winpage_reset")

    context "Window management":
        it "detects WinCLEAR":
            expect(cmm_classify_pattern("WinCLEAR")).to_equal("winclear")

        it "detects WinTABS":
            expect(cmm_is_gui_pattern("WinTABS 10. 20. 30.")).to_equal(true)
            expect(cmm_classify_pattern("WinTABS 10. 20. 30.")).to_equal("wintabs")

    context "TOOLBAR and STATUSBAR":
        it "detects TOOLBAR ON":
            expect(cmm_classify_pattern("TOOLBAR ON")).to_equal("toolbar")

        it "detects TOOLBAR OFF":
            expect(cmm_classify_pattern("TOOLBAR OFF")).to_equal("toolbar")

        it "detects STATUSBAR ON":
            expect(cmm_classify_pattern("STATUSBAR ON")).to_equal("statusbar")

    context "FramePOS":
        it "detects FramePOS with coordinates":
            expect(cmm_is_gui_pattern("FramePOS 0. 0. 80. 50.")).to_equal(true)
            expect(cmm_classify_pattern("FramePOS 0. 0. 80. 50.")).to_equal("framepos")

    context "SCREEN commands":
        it "detects SCREEN.ON":
            expect(cmm_classify_pattern("SCREEN.ON")).to_equal("screen_on")

        it "detects SCREEN.OFF":
            expect(cmm_classify_pattern("SCREEN.OFF")).to_equal("screen_off")

        it "detects SCREEN.WAIT":
            expect(cmm_classify_pattern("SCREEN.WAIT")).to_equal("screen_wait")

    context "AREA commands":
        it "detects AREA.Create":
            expect(cmm_classify_pattern("AREA.Create MCP_OUT")).to_equal("area_create")

        it "detects AREA.Select":
            expect(cmm_classify_pattern("AREA.Select MCP_OUT")).to_equal("area_select")

        it "detects AREA.CLEAR":
            expect(cmm_classify_pattern("AREA.CLEAR")).to_equal("area_clear")

        it "detects AREA.view":
            expect(cmm_classify_pattern("AREA.view")).to_equal("area_view")

    context "Other GUI commands":
        it "detects menu.rp":
            expect(cmm_classify_pattern("menu.rp")).to_equal("menu_rp")

        it "detects PRinTer.FILE":
            expect(cmm_classify_pattern("PRinTer.FILE /tmp/output.txt")).to_equal("printer_file")

    context "Non-GUI patterns":
        it "does not match SYStem.Up":
            expect(cmm_is_gui_pattern("SYStem.Up")).to_equal(false)

        it "does not match Break.Set":
            expect(cmm_is_gui_pattern("Break.Set main")).to_equal(false)

        it "does not match Data.dump":
            expect(cmm_is_gui_pattern("Data.dump")).to_equal(false)

        it "does not match EVAL":
            expect(cmm_is_gui_pattern("EVAL Register(PC)")).to_equal(false)

    context "DIALOG block from bl602_wifi.cmm":
        it "detects all GUI lines in dialog block":
            val dialog_lines = [
                "DIALOG",
                "  HEADER \"BL602 WiFi Configuration\"",
                "  POS 1. 1. 40.",
                "  TEXT \"Select WiFi Mode:\"",
                "  DEFBUTTON \"Station\" \"GOSUB setup_sta_mode\"",
                "  BUTTON \"AP Mode\" \"GOSUB setup_ap_mode\"",
                "  LINE \"Advanced\"",
                "  CLOSE \"GOTO dialog_closed\""
            ]
            for line in dialog_lines:
                expect(cmm_is_gui_pattern(line)).to_equal(true)
