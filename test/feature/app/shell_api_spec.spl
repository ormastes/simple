# # Shell API Specification
#
# **Status:** Implementing
# **Feature IDs:** #900-905
# **Keywords:** shell, process, filesystem, io, scripting
# **Topics:** stdlib, scripting
#
# ## Overview
#
# Shell API provides access to system operations commonly used in shell scripts.
# Self-contained implementation using extern FFI functions.

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_delete(path: text) -> bool
extern fn rt_file_rename(from: text, to: text) -> bool
extern fn rt_env_get(key: text) -> text
extern fn rt_env_set(key: text, value: text) -> bool

# ShellResult type for command execution
class ShellResult:
    stdout: text
    stderr: text
    exit_code: i64

    fn ok() -> bool:
        self.exit_code == 0

# Shell API class
class ShellApi:
    fn run(command: text) -> ShellResult:
        val result = rt_process_run("/bin/sh", ["-c", command])
        ShellResult(stdout: result[0], stderr: result[1], exit_code: result[2])

    fn run_with_args(command: text, args_list: [text]) -> ShellResult:
        var full_cmd = command
        for arg in args_list:
            full_cmd = full_cmd + " " + arg
        val result = rt_process_run("/bin/sh", ["-c", full_cmd])
        ShellResult(stdout: result[0], stderr: result[1], exit_code: result[2])

    fn pipe(cmds: [[text]]) -> ShellResult:
        var pipe_cmd = ""
        var i = 0
        for cmd in cmds:
            if i > 0:
                pipe_cmd = pipe_cmd + " | "
            for part in cmd:
                if pipe_cmd.len() > 0 and not pipe_cmd.ends_with("| "):
                    pipe_cmd = pipe_cmd + " "
                pipe_cmd = pipe_cmd + part
            i = i + 1
        val result = rt_process_run("/bin/sh", ["-c", pipe_cmd])
        ShellResult(stdout: result[0], stderr: result[1], exit_code: result[2])

# File API class
class FileApi:
    fn read_text(path: text) -> text:
        rt_file_read_text(path) ?? ""

    fn write_text(path: text, content: text):
        rt_file_write_text(path, content)

    fn append_text(path: text, content: text):
        val existing = rt_file_read_text(path) ?? ""
        rt_file_write_text(path, existing + content)

    fn exists(path: text) -> bool:
        rt_file_exists(path)

    fn copy(src: text, dst: text):
        val content = rt_file_read_text(src) ?? ""
        rt_file_write_text(dst, content)

    fn delete(path: text):
        rt_file_delete(path)

    fn find_files(base: text, pattern: text) -> [text]:
        val result = rt_process_run("/bin/sh", ["-c", "find " + base + " -name '" + pattern + "' -type f 2>/dev/null | head -20"])
        val stdout = result[0]
        var files: [text] = []
        for line in stdout.split("\n"):
            if line.len() > 0:
                files.push(line)
        files

# Dir API class
class DirApi:
    fn list(dir_path: text) -> [text]:
        val result = rt_process_run("/bin/sh", ["-c", "ls " + dir_path + " | head -20"])
        val stdout = result[0]
        var entries: [text] = []
        for line in stdout.split("\n"):
            if line.len() > 0:
                entries.push(line)
        entries

    fn glob_files(base: text, pattern: text) -> [text]:
        val result = rt_process_run("/bin/sh", ["-c", "find " + base + " -maxdepth 1 -name '" + pattern + "' -type f 2>/dev/null | head -20"])
        val stdout = result[0]
        var files: [text] = []
        for line in stdout.split("\n"):
            if line.len() > 0:
                files.push(line)
        files

    fn create(dir_path: text):
        rt_process_run("/bin/sh", ["-c", "mkdir -p " + dir_path])

    fn exists(dir_path: text) -> bool:
        rt_file_exists(dir_path)

    fn remove(dir_path: text):
        rt_process_run("/bin/sh", ["-c", "rm -rf " + dir_path])

# Path API class
class PathApi:
    fn join_parts(a: text, b: text, c: text) -> text:
        var result = a
        if not result.ends_with("/"):
            result = result + "/"
        result = result + b
        if c.len() > 0:
            if not result.ends_with("/"):
                result = result + "/"
            result = result + c
        result

    fn basename(p: text) -> text:
        val result = rt_process_run("/bin/sh", ["-c", "basename '" + p + "'"])
        val out = result[0]
        out.trim()

    fn dirname(p: text) -> text:
        val result = rt_process_run("/bin/sh", ["-c", "dirname '" + p + "'"])
        val out = result[0]
        out.trim()

    fn ext(p: text) -> text:
        # Get basename first, then find last dot
        val base = self.basename(p)
        # Use shell to extract extension
        val result = rt_process_run("/bin/sh", ["-c", "echo '" + base + "' | sed 's/.*\\./\\./'"])
        val out = result[0]
        val trimmed = out.trim()
        if trimmed == base:
            ""
        else:
            trimmed

    fn absolute(p: text) -> text:
        val result = rt_process_run("/bin/sh", ["-c", "realpath -m '" + p + "'"])
        val stdout = result[0]
        stdout.trim()

# Env API class
class EnvApi:
    fn get_with_default(key: text, default_val: text) -> text:
        val val_ = rt_env_get(key)
        if val_ == nil or val_ == "":
            default_val
        else:
            val_

    fn set(key: text, value: text):
        rt_env_set(key, value)

# Global instances
val shell = ShellApi()
val file = FileApi()
val dir = DirApi()
val path = PathApi()
val env = EnvApi()

val tmp = rt_env_get("TEMP") ?? rt_env_get("TMPDIR") ?? "/tmp"

# Platform detection: this spec uses /bin/sh, ls, find, etc. — Unix only
val _os_val = rt_env_get("OS") ?? ""
val _os_lower = _os_val.lower()
val is_windows = _os_lower.contains("windows")

fn check(condition: bool):
    expect(condition).to_equal(true)
fn check_msg(condition: bool, message: text):
    if not condition:
        expect(message).to_equal("")

# ## Test: Process Execution (Unix only — uses /bin/sh)

if not is_windows:
    it "execute_command_basic":
        val result = shell.run("echo hello")
        check(result.ok())
        check(result.stdout == "hello\n")
        check(result.exit_code == 0)

    it "execute_command_with_args":
        val result = shell.run("ls -la {tmp}")
        check(result.ok())
        check(result.stdout.contains("total"))

    it "execute_command_capture_stderr":
        val result = shell.run("ls /nonexistent_path_xyz 2>&1")
        check(result.stdout.contains("No such file") or result.exit_code != 0)

# ## Test: File Operations

if not is_windows:
    it "read_file_contents":
        val content = file.read_text("/etc/hostname")
        check(content.len() > 0)

it "write_file_contents":
    file.write_text("{tmp}/simple_test_shell_api.txt", "hello world")
    val content = file.read_text("{tmp}/simple_test_shell_api.txt")
    check(content == "hello world")
    file.delete("{tmp}/simple_test_shell_api.txt")

it "append_to_file":
    file.write_text("{tmp}/simple_test_append.txt", "line 1\n")
    file.append_text("{tmp}/simple_test_append.txt", "line 2\n")
    val content = file.read_text("{tmp}/simple_test_append.txt")
    check(content == "line 1\nline 2\n")
    file.delete("{tmp}/simple_test_append.txt")

if not is_windows:
    it "check_file_exists":
        check(file.exists("/etc/hostname"))
        check(not file.exists("/nonexistent/file.txt"))

# ## Test: Directory Operations (Unix only — uses ls, find via /bin/sh)

if not is_windows:
    it "list_directory":
        val entries = dir.list(tmp)
        check(entries.len() > 0)

    it "list_directory_with_pattern":
        file.write_text("{tmp}/simple_glob_test.txt", "test")
        val txt_files = dir.glob_files(tmp, "simple_glob_test.txt")
        check(txt_files.len() > 0)
        file.delete("{tmp}/simple_glob_test.txt")

    it "create_directory":
        dir.create("{tmp}/simple_test_nested/a/b")
        check(dir.exists("{tmp}/simple_test_nested/a/b"))
        dir.remove("{tmp}/simple_test_nested")

    it "remove_directory":
        dir.create("{tmp}/simple_test_rmdir/sub")
        dir.remove("{tmp}/simple_test_rmdir")
        check(not dir.exists("{tmp}/simple_test_rmdir"))

# ## Test: Path Operations (Unix only — uses basename, dirname, realpath via /bin/sh)

if not is_windows:
    it "join_paths":
        val result = path.join_parts("/home", "user", "file.txt")
        check(result == "/home/user/file.txt")

    it "get_basename":
        check(path.basename("/home/user/file.txt") == "file.txt")
        check(path.basename("/home/user/") == "user")

    it "get_dirname":
        check(path.dirname("/home/user/file.txt") == "/home/user")

    it "get_extension":
        check(path.ext("/home/user/file.txt") == ".txt")
        check(path.ext("/home/user/archive.tar.gz") == ".gz")

    it "absolute_path":
        val abs = path.absolute("../file.txt")
        check(abs.starts_with("/"))

# ## Test: Environment Variables

it "get_environment_variable":
    val home = env.get_with_default("HOME", tmp)
    check(home.len() > 0)

    val missing = env.get_with_default("NONEXISTENT_SIMPLE_VAR_XYZ", "default")
    check(missing == "default")

if not is_windows:
    it "set_environment_variable":
        env.set("SIMPLE_TEST_VAR", "test_value")
        val result = shell.run("echo $SIMPLE_TEST_VAR")
        check(result.stdout.trim() == "test_value")

# ## Test: Error Handling

if not is_windows:
    it "command_failure_result":
        val result = shell.run("false")
        check(not result.ok())
        check(result.exit_code != 0)

it "file_not_found_error":
    val content = file.read_text("/nonexistent_xyz_path")
    check(content == "")

# ## Test: Piping and Chaining (Unix only — uses grep, wc via /bin/sh)

if not is_windows:
    it "pipe_commands":
        val result = shell.pipe([
            ["echo", "hello world"],
            ["grep", "world"],
            ["wc", "-l"]
        ])
        check(result.stdout.trim() == "1")

it "chain_operations":
    file.write_text("{tmp}/simple_chain_test.txt", "line1\nline2\nline3")
    val content = file.read_text("{tmp}/simple_chain_test.txt")
    val lines = content.split("\n")
    var count = 0
    for l in lines:
        if l.len() > 0:
            count = count + 1
    check(count == 3)
    file.delete("{tmp}/simple_chain_test.txt")

# ## Test: Script Utilities (Unix only — uses find via /bin/sh)

if not is_windows:
    it "find_files_recursive":
        file.write_text("{tmp}/simple_find_test.txt", "test")
        val files = file.find_files(tmp, "simple_find_test.txt")
        check(files.len() > 0)
        file.delete("{tmp}/simple_find_test.txt")

it "copy_file":
    file.write_text("{tmp}/simple_copy_src.txt", "content")
    file.copy("{tmp}/simple_copy_src.txt", "{tmp}/simple_copy_dst.txt")
    check(file.read_text("{tmp}/simple_copy_dst.txt") == "content")
    file.delete("{tmp}/simple_copy_src.txt")
    file.delete("{tmp}/simple_copy_dst.txt")

it "move_file":
    file.write_text("{tmp}/simple_move_old.txt", "content")
    rt_file_rename("{tmp}/simple_move_old.txt", "{tmp}/simple_move_new.txt")
    check(file.exists("{tmp}/simple_move_new.txt"))
    check(not file.exists("{tmp}/simple_move_old.txt"))
    file.delete("{tmp}/simple_move_new.txt")
