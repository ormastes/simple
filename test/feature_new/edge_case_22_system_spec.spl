"""
# Edge Case System Test

**Feature IDs:** #EDGE
**Category:** Testing
**Status:** Implemented
"""

use std.spec

fn verify(condition: bool):
    expect(condition).to_equal(true)

describe "Edge Case Testing":
    slow_it "empty input handling":
        val empty = ""
        verify(empty.len() == 0)
        
        val result = if empty.len() == 0: "empty" else: "not empty"
        verify(result == "empty")
        
    slow_it "boundary values - zero":
        val zero = 0
        verify(zero == 0)
        verify(not (zero > 0))
        verify(not (zero < 0))
        
    slow_it "boundary values - max int":
        val large = 999999999
        verify(large > 0)
        verify(large > 999999998)
        
    slow_it "boundary values - min int":
        val small = -999999999
        verify(small < 0)
        verify(small < -999999998)
        
    slow_it "null/nil propagation":
        val opt1 = nil
        val opt2 = opt1 ?? Some(42)
        verify(opt2.?)
        verify(opt2.? == 42)
        
    slow_it "empty collection operations":
        val empty_arr = []
        verify(empty_arr.len() == 0)
        
        val appended = empty_arr.append(1)
        verify(appended.len() == 1)
        
    slow_it "single element collection":
        val single = [42]
        verify(single.len() == 1)
        verify(single[0] == 42)
        verify(single[-1] == 42)
        
    slow_it "string edge cases - empty":
        val s = ""
        verify(s.len() == 0)
        verify(s + "x" == "x")
        
    slow_it "string edge cases - single char":
        val s = "a"
        verify(s.len() == 1)
        verify(s[0..1] == "a")
        
    slow_it "division edge cases":
        val a = 10
        val b = 1
        verify(a / b == 10)
        verify(a / a == 1)
        
    slow_it "modulo edge cases":
        verify(0 % 5 == 0)
        verify(5 % 5 == 0)
        verify(4 % 5 == 4)
        
    slow_it "nested option unwrapping":
        val nested = Some(Some(Some(10)))
        verify(nested.?)
        
    slow_it "deeply nested conditionals":
        val a = 1
        val b = 2
        val c = 3
        
        if a < b:
            if b < c:
                if c > a:
                    verify(true)
                else:
                    verify(false)
            else:
                verify(false)
        else:
            verify(false)
            
    slow_it "loop with zero iterations":
        var count = 0
        for i in 0..0:
            count = count + 1
        verify(count == 0)
        
    slow_it "loop with one iteration":
        var count = 0
        for i in 0..1:
            count = count + 1
        verify(count == 1)
        
    slow_it "break on first iteration":
        var count = 0
        for i in 0..100:
            count = count + 1
            break
        verify(count == 1)
        
    slow_it "continue all iterations":
        var executed = 0
        var continued = 0
        for i in 0..10:
            executed = executed + 1
            continue
            continued = continued + 1
        verify(executed == 10)
        verify(continued == 0)
        
    slow_it "match with all paths":
        for i in [1, 2, 3, 99]:
            val result = match i:
                1: "one"
                2: "two"
                3: "three"
                _: "other"
            verify(result.len() > 0)
            
    slow_it "boolean short circuit - and":
        var evaluated = false
        val result = false and evaluated
        verify(result == false)
        
    slow_it "boolean short circuit - or":
        var evaluated = false
        val result = true or evaluated
        verify(result == false)
        
    slow_it "comparison chain":
        val x = 5
        verify(0 < x)
        verify(x < 10)
        verify(0 < x and x < 10)
        
    slow_it "negative array index":
        val arr = [1, 2, 3, 4, 5]
        verify(arr[-1] == 5)
        verify(arr[-2] == 4)
        verify(arr[-5] == 1)
        
    slow_it "array slice edge cases":
        val arr = [1, 2, 3, 4, 5]
        verify(arr[0..0].len() == 0)
        verify(arr[0..5].len() == 5)
        verify(arr[2..-1].len() == 3)
        
    slow_it "dict with missing keys":
        val d = {"a": 1, "b": 2}
        verify(d.get("a").?)
        verify(not d.get("c").?)
        verify(d.get("missing") ?? 99 == 99)
        
    slow_it "string operations on empty":
        val s = ""
        verify(s.starts_with(""))
        verify(s.ends_with(""))
        verify(not s.contains("x"))
        
    slow_it "arithmetic with negatives":
        verify(-5 + 10 == 5)
        verify(-5 * -2 == 10)
        verify(-10 / 2 == -5)
        
    slow_it "power of zero":
        verify(5 ** 0 == 1)
        verify(0 ** 0 == 1)
        verify((-5) ** 0 == 1)
        
    slow_it "nested match expressions":
        val opt = Some(2)
        val result = match opt:
            Some(x):
                match x:
                    1: "one"
                    2: "two"
                    _: "other"
            nil: "none"
        verify(result == "two")
