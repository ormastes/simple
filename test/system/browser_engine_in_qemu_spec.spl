# @tag:system

use std.spec.*

use os.qemu_runner.{
    build_os,
    get_browser_probe_target_x86_32,
    get_browser_soft_target_x86_32,
    get_desktop_probe_target_x86_32,
    get_browser_probe_target_x86_64,
    get_browser_soft_target_x86_64,
    get_desktop_probe_target_x86_64,
    get_desktop_browser_target_x86_64
}
use test.qemu.os.common.qemu_os_harness.{file_exists}
use test.qemu.os.common.qemu_os_harness.{can_run_target, spawn_guest_with_qmp, stop_guest, wait_for_serial_marker, read_serial_log}

describe "Browser engine in QEMU Simple OS guest":

    it "declares the x86_32 browser probe lane":
        val target = get_browser_probe_target_x86_32()
        expect(target.arch.to_string()).to_contain("X86")
        expect(target.target_triple).to_equal("i686-unknown-none")
        expect(target.qemu_system).to_equal("qemu-system-i386")
        expect(target.qemu_cpu).to_equal("qemu32")
        expect(target.entry).to_end_with("examples/simple_os/arch/x86_32/browser_probe_entry.spl")

    it "declares the x86_32 browser-soft lane":
        val target = get_browser_soft_target_x86_32()
        expect(target.arch.to_string()).to_contain("X86")
        expect(target.target_triple).to_equal("i686-unknown-none")
        expect(target.qemu_system).to_equal("qemu-system-i386")
        expect(target.qemu_cpu).to_equal("qemu32")
        expect(target.entry).to_end_with("examples/simple_os/arch/x86_32/browser_soft_entry.spl")

    it "declares the x86_32 desktop probe lane":
        val target = get_desktop_probe_target_x86_32()
        expect(target.arch.to_string()).to_contain("X86")
        expect(target.target_triple).to_equal("i686-unknown-none")
        expect(target.qemu_system).to_equal("qemu-system-i386")
        expect(target.qemu_cpu).to_equal("qemu32")
        expect(target.entry).to_end_with("examples/simple_os/arch/x86_32/desktop_probe_entry.spl")

    it "builds the x86_64 browser probe investigation lane":
        val target = get_browser_probe_target_x86_64()
        expect(build_os(target)).to_equal(true)
        expect(file_exists(target.output)).to_equal(true)
        expect(target.qemu_system).to_equal("qemu-system-x86_64")
        expect(target.qemu_cpu).to_equal("qemu64")

    it "builds the x86_64 browser-soft investigation lane":
        val target = get_browser_soft_target_x86_64()
        expect(build_os(target)).to_equal(true)
        expect(file_exists(target.output)).to_equal(true)
        expect(target.qemu_system).to_equal("qemu-system-x86_64")
        expect(target.qemu_cpu).to_equal("qemu64")

    it "boots the x86_64 browser-soft investigation lane":
        val target = get_browser_soft_target_x86_64()
        expect(build_os(target)).to_equal(true)
        expect(file_exists(target.output)).to_equal(true)

        if not can_run_target(target):
            print "[browser_engine_in_qemu_spec] qemu-system-x86_64 not available, skipping live browser-soft boot"
            expect(true).to_equal(true)
            return

        val qmp_socket = "/tmp/simpleos_browser_soft_qmp.sock"
        val serial_log = "build/os/browser_soft_qemu_serial.log"

        match spawn_guest_with_qmp(target, qmp_socket, serial_log):
            Ok(handle) =>
                val saw_marker = wait_for_serial_marker(handle, "[PASS] browser_soft_entry", 30000)
                val serial_output = read_serial_log(handle)
                if not saw_marker:
                    print "[browser_engine_in_qemu_spec] browser-soft completion marker not seen within 30s"
                    print "[browser_engine_in_qemu_spec] serial output: {serial_output}"
                    stop_guest(handle)
                    expect(false).to_equal(true)
                    return

                if serial_output.contains("FAULT @"):
                    print "[browser_engine_in_qemu_spec] browser-soft serial contained a fault"
                    print "[browser_engine_in_qemu_spec] serial output: {serial_output}"
                    stop_guest(handle)
                    expect(false).to_equal(true)
                    return

                stop_guest(handle)
                expect(true).to_equal(true)
            Err(err) =>
                print "[browser_engine_in_qemu_spec] failed to spawn x86_64 browser-soft guest: {err}"
                expect(false).to_equal(true)

    it "builds the x86_64 desktop probe investigation lane":
        val target = get_desktop_probe_target_x86_64()
        expect(build_os(target)).to_equal(true)
        expect(file_exists(target.output)).to_equal(true)
        expect(target.qemu_system).to_equal("qemu-system-x86_64")
        expect(target.qemu_cpu).to_equal("qemu64")

    it "builds the x86_64 desktop wrapper investigation lane":
        val target = get_desktop_browser_target_x86_64()
        expect(build_os(target)).to_equal(true)
        expect(file_exists(target.output)).to_equal(true)
        expect(target.qemu_system).to_equal("qemu-system-x86_64")
        expect(target.qemu_cpu).to_equal("qemu64")
