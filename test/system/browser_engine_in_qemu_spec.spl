# @tag:system

use std.spec.*

use os.qemu_runner.{OsTarget, build_os, get_browser_probe_target, get_browser_soft_target,
    get_desktop_probe_target, get_desktop_browser_target}
use test.qemu.os.common.qemu_os_harness.{
    can_run_target, file_exists, run_os_qemu_with_target, run_os_qemu_with_target_via_timeout
}

describe "Browser engine in QEMU Simple OS guest":

    it "boots the browser baremetal probe":
        val target = get_browser_probe_target()
        expect(build_os(target)).to_equal(true)
        expect(file_exists(target.output)).to_equal(true)

        if not can_run_target(target):
            print "[browser_engine_in_qemu_spec] SKIP browser probe target unavailable"
            return

        val result = run_os_qemu_with_target_via_timeout(target, "5s", 10000)
        val output = result[0] + result[1]
        expect(output.contains("[probe] browser spl_start")).to_equal(true)

    it "boots the desktop baremetal probe":
        val target = get_desktop_probe_target()
        expect(build_os(target)).to_equal(true)
        expect(file_exists(target.output)).to_equal(true)

        if not can_run_target(target):
            print "[browser_engine_in_qemu_spec] SKIP desktop probe target unavailable"
            return

        val result = run_os_qemu_with_target_via_timeout(target, "5s", 10000)
        val output = result[0] + result[1]
        expect(output.contains("[probe] desktop spl_start")).to_equal(true)

    it "builds and boots the browser software smoke entry":
        val target = get_browser_soft_target()
        expect(build_os(target)).to_equal(true)
        expect(file_exists(target.output)).to_equal(true)

        if not can_run_target(target):
            print "[browser_engine_in_qemu_spec] SKIP browser soft target unavailable"
            return

        val target_with_vga = OsTarget(
            arch: target.arch,
            entry: target.entry,
            linker_script: target.linker_script,
            target_triple: target.target_triple,
            output: target.output,
            qemu_system: target.qemu_system,
            qemu_machine: target.qemu_machine,
            qemu_cpu: target.qemu_cpu,
            qemu_memory: target.qemu_memory,
            qemu_bios: target.qemu_bios,
            qemu_extra: target.qemu_extra + ["-vga", "std"],
            gui_mode: false
        )
        val result = run_os_qemu_with_target(target_with_vga, 15000)
        val output = result[0] + result[1]
        expect(output.contains("[browser-soft] start")).to_equal(true)
        expect(output.contains("[PASS] browser_soft_entry")).to_equal(true)
        expect(output.contains("TEST PASSED")).to_equal(true)
        expect(output.contains("[FAIL]")).to_equal(false)

    it "runs the lean desktop wrapper through launcher and wm markers":
        val target = get_desktop_browser_target()
        expect(build_os(target)).to_equal(true)
        expect(file_exists(target.output)).to_equal(true)

        if not can_run_target(target):
            print "[browser_engine_in_qemu_spec] SKIP desktop browser target unavailable"
            return

        val result = run_os_qemu_with_target(target, 15000)
        val output = result[0] + result[1]
        expect(output.contains("[desktop-e2e] spl_start")).to_equal(true)
        expect(output.contains("[desktop-e2e] launcher:ready")).to_equal(true)
        expect(output.contains("[desktop-e2e] shortcut:ok")).to_equal(true)
        expect(output.contains("[desktop-e2e] wm:ok")).to_equal(true)
        expect(output.contains("[browser_demo] render stats")).to_equal(true)
        expect(output.contains("[desktop-e2e] remote-grouping:ok")).to_equal(true)
        expect(output.contains("TEST PASSED")).to_equal(true)
        expect(output.contains("TEST FAILED")).to_equal(false)
