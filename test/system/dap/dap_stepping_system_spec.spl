# DAP System Test: Step Operations
# tag: slow, system
#
# Tests that interpreter stepping patterns work without crashes.
# Samples interpreter and frontend files, verifying they parse via lint
# without segfaults. These modules are the primary targets when stepping
# through code in a debugger.

extern fn rt_dir_list(path: text) -> [text]
extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_delete(path: text) -> bool
extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_getpid() -> i64
extern fn rt_time_now_unix_micros() -> i64

fn _check_release_binary() -> bool:
    if not rt_file_exists("bin/release/simple"):
        print "SKIP: bin/release/simple not found"
        false
    else:
        val (stdout, stderr, code) = rt_process_run("bin/release/simple", ["--version"])
        if code > 1:
            print "SKIP: bin/release/simple not executable on this platform"
            false
        else:
            true

val _can_run = _check_release_binary()

fn find_spl_files(dir: text) -> [text]:
    var result: [text] = []
    val entries = rt_dir_list(dir) ?? []
    var i = 0
    while i < entries.len():
        val name = entries[i]
        val full = "{dir}/{name}"
        if name.ends_with(".spl"):
            result.push(full)
        elif not name.starts_with("."):
            val subs = find_spl_files(full)
            var j = 0
            while j < subs.len():
                result.push(subs[j])
                j = j + 1
        i = i + 1
    result

fn tmp_dir() -> text:
    val pid = rt_getpid()
    val ts = rt_time_now_unix_micros()
    "/tmp/dap_test_{pid}_{ts}"

fn run_file(file: text) -> i64:
    val (stdout, stderr, code) = rt_process_run("bin/release/simple", [file])
    code

fn run_file_with_timeout(file: text) -> i64:
    # Run a .spl file; if it takes too long, it may hang (timeout handled by test runner)
    val (stdout, stderr, code) = rt_process_run("bin/release/simple", [file])
    code

fn report_crashes(label: text, crashes: [text]) -> i64:
    if crashes.len() == 0:
        print "  PASS: {label} — 0 crashes"
    else:
        print "  FAIL: {label} — {crashes.len()} crashes:"
        var k = 0
        while k < crashes.len():
            print "    - {crashes[k]}"
            k = k + 1
    crashes.len()

# Collect interpreter files (primary stepping targets)
var interp_files: [text] = []
val interp_all = find_spl_files("src/compiler/95.interp")
var i = 0
while i < interp_all.len():
    interp_files.push(interp_all[i])
    i = i + 1

# Sample frontend files (parser, lexer — common stepping targets)
val frontend_all = find_spl_files("src/compiler/10.frontend")
i = 0
while i < frontend_all.len():
    if i % 5 == 0:
        interp_files.push(frontend_all[i])
    i = i + 1

print "DAP System: stepping — collected {interp_files.len()} files"

# Lint-parse check: exit code > 1 means crash
fn check_lint_parse(files: [text]) -> [text]:
    var crashes: [text] = []
    var idx = 0
    while idx < files.len():
        val (stdout, stderr, code) = rt_process_run("bin/release/simple", ["lint", files[idx]])
        if code > 1:
            crashes.push(files[idx])
        idx = idx + 1
    crashes

describe "DAP System: stepping":
    slow_it "interpreter module files parse without crashes":
        if _can_run:
            val crashes = check_lint_parse(interp_files)
            report_crashes("stepping lint — interpreter", crashes)
            expect(crashes.len()).to_equal(0)
        else:
            print "SKIP: bin/release/simple not available"
