# DAP System Test: Breakpoint Set/Resolve
# tag: slow, system
#
# Tests that DAP breakpoint modules can be loaded and that running programs
# with breakpoint-representative patterns doesn't crash.
# Verifies DAP module parsing via lint and samples app files for execution safety.

extern fn rt_dir_list(path: text) -> [text]
extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_delete(path: text) -> bool
extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_getpid() -> i64
extern fn rt_time_now_unix_micros() -> i64

fn find_spl_files(dir: text) -> [text]:
    var result: [text] = []
    val entries = rt_dir_list(dir) ?? []
    var i = 0
    while i < entries.len():
        val name = entries[i]
        val full = "{dir}/{name}"
        if name.ends_with(".spl"):
            result.push(full)
        elif not name.starts_with("."):
            val subs = find_spl_files(full)
            var j = 0
            while j < subs.len():
                result.push(subs[j])
                j = j + 1
        i = i + 1
    result

fn tmp_dir() -> text:
    val pid = rt_getpid()
    val ts = rt_time_now_unix_micros()
    "/tmp/dap_test_{pid}_{ts}"

fn run_file(file: text) -> i64:
    val (stdout, stderr, code) = rt_process_run("bin/release/simple", [file])
    code

fn run_file_with_timeout(file: text) -> i64:
    # Run a .spl file; if it takes too long, it may hang (timeout handled by test runner)
    val (stdout, stderr, code) = rt_process_run("bin/release/simple", [file])
    code

fn report_crashes(label: text, crashes: [text]) -> i64:
    if crashes.len() == 0:
        print "  PASS: {label} — 0 crashes"
    else:
        print "  FAIL: {label} — {crashes.len()} crashes:"
        var k = 0
        while k < crashes.len():
            print "    - {crashes[k]}"
            k = k + 1
    crashes.len()

# Collect DAP module files to verify they parse
var dap_files = find_spl_files("src/lib/nogc_sync_mut/dap")
print "DAP System: breakpoints — found {dap_files.len()} DAP module files"

# Representative app files for breakpoint testing
var app_samples: [text] = []
val app_all = find_spl_files("src/app")
var i = 0
while i < app_all.len():
    # Sample every 10th file to keep test reasonable
    if i % 10 == 0:
        app_samples.push(app_all[i])
    i = i + 1
print "DAP System: breakpoints — sampled {app_samples.len()} app files"

# Test that DAP modules parse by running lint (they should not crash)
fn check_dap_module_parse(files: [text]) -> [text]:
    var crashes: [text] = []
    var idx = 0
    while idx < files.len():
        val (stdout, stderr, code) = rt_process_run("bin/release/simple", ["lint", files[idx]])
        if code > 1:
            crashes.push(files[idx])
        idx = idx + 1
    crashes

# Test sample app files parse via lint (exit code > 1 means crash)
fn check_app_file_parse(files: [text]) -> [text]:
    var crashes: [text] = []
    var idx = 0
    while idx < files.len():
        val (stdout, stderr, code) = rt_process_run("bin/release/simple", ["lint", files[idx]])
        if code > 1:
            crashes.push(files[idx])
        idx = idx + 1
    crashes

describe "DAP System: breakpoint resolution":
    it "DAP modules parse without crashes":
        val crashes = check_dap_module_parse(dap_files)
        report_crashes("DAP module parse", crashes)
        expect(crashes.len()).to_equal(0)

    it "sample app files parse without crashes":
        val crashes = check_app_file_parse(app_samples)
        report_crashes("app file parse", crashes)
        expect(crashes.len()).to_equal(0)
