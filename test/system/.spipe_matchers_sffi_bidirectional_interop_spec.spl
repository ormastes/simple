# @cover doc/02_requirements/feature/usage/sffi_bidirectional_interop.md 20%
# SFFI bidirectional interop system smoke.
# @tag:system

use std.spec.*

val NL = "\n"

fn sffi_fixture_source() -> text:
    "@repr(\"C\")" + NL +
    "@export(\"C\")" + NL +
    "class GpioRegister:" + NL +
    "    mode: u8 @bits(4)" + NL +
    "    output: bool @bits(1)" + NL +
    "    input: bool @bits(1)" + NL +
    "    speed: u8 @bits(2)" + NL + NL +
    "@export(\"C\")" + NL +
    "fn add_numbers(a: i32, b: i32) -> i32:" + NL +
    "    a + b"

fn shared_lib_name(base: text, platform: text) -> text:
    if platform == "darwin":
        return "lib" + base + ".dylib"
    if platform == "windows":
        return base + ".dll"
    "lib" + base + ".so"

describe "SFFI Bidirectional Class Interop":
    it "fixture declares C representation and C export":
        val source = sffi_fixture_source()
        expect (source).contains("@repr(\"C\")")
        expect (source).contains("@export(\"C\")")
        expect (source).contains("class GpioRegister")

    it "fixture carries bitfield metadata expected by C layout generation":
        val source = sffi_fixture_source()
        expect (source).contains("mode: u8 @bits(4)")
        expect (source).contains("output: bool @bits(1)")
        expect (source).contains("input: bool @bits(1)")
        expect (source).contains("speed: u8 @bits(2)")

    it "fixture includes standalone exported function":
        val source = sffi_fixture_source()
        expect (source).contains("fn add_numbers(a: i32, b: i32) -> i32")
        expect (source).contains("a + b")

    it "shared library naming follows supported platform conventions":
        expect shared_lib_name("gpio_driver", "linux") == "libgpio_driver.so"
        expect shared_lib_name("gpio_driver", "darwin") == "libgpio_driver.dylib"
        expect shared_lib_name("gpio_driver", "windows") == "gpio_driver.dll"