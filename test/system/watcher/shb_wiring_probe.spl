use compiler.driver.cache.cache_types.{CACHE_FRESH, CACHE_STALE}
use compiler.driver.watcher.watcher_client.{get_or_generate_shb, check_shb_freshness, watcher_temp_config}
use compiler.shb.shb_hash.{shb_source_hash}
use compiler.shb.shb_types.{ShbModuleInterface, shb_module_interface_new, shb_primitive_layouts, ShbFnEntry, SHB_FLAG_PUB}
use compiler.shb.shb_reader.{ShbReader}
use compiler.shb.shb_writer.{shb_write}
use compiler.shb.shb_cache.{ShbCacheManager, ShbCacheConfig, SHB_CACHE_NEW, SHB_CACHE_BODY_ONLY, SHB_CACHE_INTERFACE}

extern fn sys_get_args() -> [text]
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_dir_create_all(path: text) -> bool
extern fn rt_file_exists(path: text) -> bool
extern fn rt_getpid() -> i64
extern fn rt_time_now_unix_micros() -> i64
extern fn rt_process_run(program: text, args: [text]) -> (text, text, i64)

fn shb_test_tmpdir() -> text:
    val pid = rt_getpid()
    val ts = rt_time_now_unix_micros()
    val dir = "/tmp/shb_wiring_{pid}_{ts}"
    rt_dir_create_all(dir)
    rt_dir_create_all("{dir}/src")
    dir

fn shb_test_cleanup(dir: text):
    if dir != "":
        rt_process_run("/bin/sh", ["-c", "rm -rf '{dir}' >/dev/null 2>&1 || true"])

fn shb_test_source_v1() -> text:
    """
pub fn answer() -> i64:
    41 + 1
"""

fn shb_test_source_body_only() -> text:
    """
pub fn answer() -> i64:
    40 + 2
"""

fn shb_test_config(tmpdir: text):
    watcher_temp_config(tmpdir)

fn shb_test_source_path(tmpdir: text) -> text:
    "{tmpdir}/src/sample.spl"

fn shb_test_shb_path(shb_dir: text, source_path: text) -> text:
    val with_slashes = source_path.replace("/", "_")
    val safe = with_slashes.replace(".spl", "")
    "{shb_dir}/{safe}.shb"

fn write_sample(path: text, content: text) -> bool:
    rt_file_write_text(path, content)

fn manual_iface(source: text):
    val src_hash = shb_source_hash(source)
    val base = shb_module_interface_new(src_hash, 0)
    ShbModuleInterface(
        header: base.header,
        functions: [
            ShbFnEntry(
                name: "answer",
                params: [],
                return_type: "i64",
                flags: SHB_FLAG_PUB
            )
        ],
        structs: [],
        classes: [],
        enums: [],
        traits: [],
        reexports: [],
        type_layouts: shb_primitive_layouts(),
        dependencies: []
    )

fn write_manual_shb(source: text, source_path: text, shb_path: text) -> bool:
    val iface = manual_iface(source)
    shb_write(iface, shb_path)

fn probe_manual_write_roundtrip() -> text:
    val tmpdir = shb_test_tmpdir()
    val cfg = shb_test_config(tmpdir)
    val source_path = shb_test_source_path(tmpdir)
    val shb_path = shb_test_shb_path(cfg.shb_dir, source_path)

    if not write_sample(source_path, shb_test_source_v1()):
        shb_test_cleanup(tmpdir)
        return "failed to write source"
    rt_dir_create_all(cfg.shb_dir)
    if not write_manual_shb(shb_test_source_v1(), source_path, shb_path):
        shb_test_cleanup(tmpdir)
        return "failed to write shb"

    val reader = ShbReader.open(shb_path)
    val ok = reader.is_valid() and reader.function_count() == 1 and reader.has_function_named("answer")
    shb_test_cleanup(tmpdir)

    if ok:
        "ok"
    else:
        "roundtrip invalid"

fn probe_cached_get_or_generate() -> text:
    val tmpdir = shb_test_tmpdir()
    val cfg = shb_test_config(tmpdir)
    val source_path = shb_test_source_path(tmpdir)
    val shb_path = shb_test_shb_path(cfg.shb_dir, source_path)
    val source = shb_test_source_v1()

    if not write_sample(source_path, source):
        shb_test_cleanup(tmpdir)
        return "failed to write source"
    rt_dir_create_all(cfg.shb_dir)
    if not write_manual_shb(source, source_path, shb_path):
        shb_test_cleanup(tmpdir)
        return "failed to write shb"

    val result = get_or_generate_shb(source_path, cfg)
    val expected = manual_iface(source)
    val ok = (
        result.ok and
        result.shb_path == shb_path and
        result.source_hash == expected.header.source_hash and
        result.interface_hash == expected.header.interface_hash
    )
    shb_test_cleanup(tmpdir)

    if ok:
        "ok"
    else:
        "cached load mismatch"

fn probe_freshness_transitions() -> text:
    val tmpdir = shb_test_tmpdir()
    val cfg = shb_test_config(tmpdir)
    val source_path = shb_test_source_path(tmpdir)
    val shb_path = shb_test_shb_path(cfg.shb_dir, source_path)

    if not write_sample(source_path, shb_test_source_v1()):
        shb_test_cleanup(tmpdir)
        return "failed to write source"
    rt_dir_create_all(cfg.shb_dir)
    if not write_manual_shb(shb_test_source_v1(), source_path, shb_path):
        shb_test_cleanup(tmpdir)
        return "failed to write initial shb"

    val fresh1 = check_shb_freshness(source_path, cfg.shb_dir)
    if fresh1.status != CACHE_FRESH:
        shb_test_cleanup(tmpdir)
        return "initial freshness status={fresh1.status}"

    if not write_sample(source_path, shb_test_source_body_only()):
        shb_test_cleanup(tmpdir)
        return "failed to rewrite source"

    val stale = check_shb_freshness(source_path, cfg.shb_dir)
    if stale.status != CACHE_STALE:
        shb_test_cleanup(tmpdir)
        return "stale freshness status={stale.status}"

    if not write_manual_shb(shb_test_source_body_only(), source_path, shb_path):
        shb_test_cleanup(tmpdir)
        return "failed to rewrite shb"

    val fresh2 = check_shb_freshness(source_path, cfg.shb_dir)
    shb_test_cleanup(tmpdir)

    if fresh2.status == CACHE_FRESH:
        "ok"
    else:
        "final freshness status={fresh2.status}"

fn probe_reader_metadata() -> text:
    val tmpdir = shb_test_tmpdir()
    val cfg = shb_test_config(tmpdir)
    val source_path = shb_test_source_path(tmpdir)
    val shb_path = shb_test_shb_path(cfg.shb_dir, source_path)
    val source = shb_test_source_v1()
    val expected = manual_iface(source)

    if not write_sample(source_path, source):
        shb_test_cleanup(tmpdir)
        return "failed to write source"
    rt_dir_create_all(cfg.shb_dir)
    if not write_manual_shb(source, source_path, shb_path):
        shb_test_cleanup(tmpdir)
        return "failed to write shb"

    val reader = ShbReader.open(shb_path)
    val ok = (
        reader.is_valid() and
        reader.source_hash() == expected.header.source_hash and
        reader.interface_hash() == expected.header.interface_hash
    )
    shb_test_cleanup(tmpdir)

    if ok:
        "ok"
    else:
        "metadata mismatch"

fn probe_inline_generation() -> text:
    val tmpdir = shb_test_tmpdir()
    val cfg = shb_test_config(tmpdir)
    val source_path = shb_test_source_path(tmpdir)

    if not write_sample(source_path, shb_test_source_v1()):
        shb_test_cleanup(tmpdir)
        return "failed to write source"

    val result = get_or_generate_shb(source_path, cfg)
    if not result.ok:
        shb_test_cleanup(tmpdir)
        return result.error

    val reader = ShbReader.open(result.shb_path)
    val ok = reader.is_valid() and reader.function_count() == 1 and reader.has_function_named("answer")
    shb_test_cleanup(tmpdir)

    if ok:
        "ok"
    else:
        "generated shb invalid"

fn probe_batch_generation() -> text:
    val tmpdir = shb_test_tmpdir()
    val headers_dir = "{tmpdir}/headers"
    val source_path = shb_test_source_path(tmpdir)
    val cache = ShbCacheManager.create(ShbCacheConfig(cache_dir: headers_dir, enabled: true))

    if not write_sample(source_path, shb_test_source_v1()):
        shb_test_cleanup(tmpdir)
        return "failed to write source"

    val result = cache.process_file(source_path)
    if result.status != SHB_CACHE_NEW:
        shb_test_cleanup(tmpdir)
        return "batch status={result.status}"

    val shb_path = shb_test_shb_path(headers_dir, source_path)
    val reader = ShbReader.open(shb_path)
    val ok = reader.is_valid() and reader.function_count() == 1 and reader.has_function_named("answer")
    shb_test_cleanup(tmpdir)

    if ok:
        "ok"
    else:
        "batch shb invalid"

fn probe_body_vs_interface_generation() -> text:
    val tmpdir = shb_test_tmpdir()
    val headers_dir = "{tmpdir}/headers"
    val source_path = shb_test_source_path(tmpdir)
    val cache = ShbCacheManager.create(ShbCacheConfig(cache_dir: headers_dir, enabled: true))

    if not write_sample(source_path, shb_test_source_v1()):
        shb_test_cleanup(tmpdir)
        return "failed to write source"
    val first = cache.process_file(source_path)
    if first.status != SHB_CACHE_NEW:
        shb_test_cleanup(tmpdir)
        return "first status={first.status}"

    if not write_sample(source_path, shb_test_source_body_only()):
        shb_test_cleanup(tmpdir)
        return "failed to write body source"
    val body_only = cache.process_file(source_path)
    if body_only.status != SHB_CACHE_BODY_ONLY:
        shb_test_cleanup(tmpdir)
        return "body-only status={body_only.status}"

    val source_v2 = """
pub fn answer(x: i64) -> i64:
    x
"""
    if not write_sample(source_path, source_v2):
        shb_test_cleanup(tmpdir)
        return "failed to write interface source"
    val iface_changed = cache.process_file(source_path)
    shb_test_cleanup(tmpdir)

    if iface_changed.status == SHB_CACHE_INTERFACE:
        "ok"
    else:
        "interface-change status={iface_changed.status}"

fn main() -> i64:
    val args = sys_get_args()
    if args.len() < 2:
        print "usage: shb_wiring_probe.spl <write_read|cached_get|freshness|metadata|inline_generate|batch_generate|body_vs_interface>"
        return 1

    val command = args[1]
    val result = match command:
        case "write_read": probe_manual_write_roundtrip()
        case "cached_get": probe_cached_get_or_generate()
        case "freshness": probe_freshness_transitions()
        case "metadata": probe_reader_metadata()
        case "inline_generate": probe_inline_generation()
        case "batch_generate": probe_batch_generation()
        case "body_vs_interface": probe_body_vs_interface_generation()
        case _: "unknown command: {command}"

    if result == "ok":
        print "ok"
        0
    else:
        print result
        1
