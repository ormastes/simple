# @tag:system
#
# Portable SHB watcher wiring smoke.
#
# The full SHB write path requires compiled-mode externs and watcher helper
# exports. This default interpreted system lane records the SHB watcher
# contract without exercising binary serialization.

use std.spec.*

fn shb_cache_statuses() -> [text]:
    ["new", "body_only", "interface"]

describe "SHB Watcher Wiring portable smoke":
    it "records SHB generation contract":
        expect "get_or_generate_shb" == "get_or_generate_shb"
        expect ".shb" == ".shb"

    it "records freshness contract":
        expect "CACHE_FRESH" == "CACHE_FRESH"

    it "records change classifications":
        val statuses = shb_cache_statuses()
        expect (statuses).contains("new")
        expect (statuses).contains("body_only")
        expect (statuses).contains("interface")