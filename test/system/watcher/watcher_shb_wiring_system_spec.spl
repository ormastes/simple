# SHB Watcher Wiring System Spec
#
# Runs the SHB wiring probe through the self-hosted binary so the watcher/SHB
# pipeline executes outside the interpreter and test-runner fallback path.

extern fn rt_process_run(program: text, args: [text]) -> (text, text, i64)

fn run_probe(command: text) -> (text, text, i64):
    rt_process_run(
        "bin/release/simple",
        ["test/system/watcher/shb_wiring_probe.spl", command]
    )

describe "SHB Watcher Wiring":
    it "generates readable SHB through inline get_or_generate":
        val (stdout, stderr, code) = run_probe("inline")
        if code != 0:
            print stdout
            print stderr
        expect(code).to_equal(0)
        expect(stdout).to_contain("ok")

    it "reports fresh SHB after generation":
        val (stdout, stderr, code) = run_probe("freshness")
        if code != 0:
            print stdout
            print stderr
        expect(code).to_equal(0)
        expect(stdout).to_contain("ok")

    it "writes SHB through watcher batch cache path":
        val (stdout, stderr, code) = run_probe("batch")
        if code != 0:
            print stdout
            print stderr
        expect(code).to_equal(0)
        expect(stdout).to_contain("ok")

    it "distinguishes body-only from interface changes":
        val (stdout, stderr, code) = run_probe("body_vs_interface")
        if code != 0:
            print stdout
            print stderr
        expect(code).to_equal(0)
        expect(stdout).to_contain("ok")
