# @cover src/compiler/80.driver/watcher/watcher_client.spl 80%
# @cover src/compiler/80.driver/shb/shb_cache.spl 80%
# SHB Watcher Wiring System Spec
#
# Runs the SHB wiring probe through the self-hosted binary so the watcher/SHB
# pipeline executes outside the interpreter and test-runner fallback path.

extern fn rt_process_run(program: text, args: [text]) -> (text, text, i64)
extern fn rt_file_exists(path: text) -> bool

fn _is_windows() -> bool:
    val (uname_out, _, _) = rt_process_run("uname", ["-s"])
    val os = uname_out.trim()
    os.starts_with("MINGW") or os.starts_with("MSYS") or os.starts_with("CYGWIN") or os.starts_with("Windows")

fn _check_binary_runnable() -> bool:
    if _is_windows():
        return false
    if not rt_file_exists("bin/release/simple"):
        return false
    val (stdout, stderr, code) = rt_process_run("file", ["bin/release/simple"])
    if stdout == "" or stdout == nil:
        return false
    if stdout.contains("ELF") and not stdout.contains("Mach-O"):
        val (uname_out, _, _) = rt_process_run("uname", [])
        if uname_out.trim() == "Darwin":
            return false
    true

val _can_run = _check_binary_runnable()

fn run_probe(command: text) -> (text, text, i64):
    rt_process_run(
        "bin/release/simple",
        ["test/system/watcher/shb_wiring_probe.spl", command]
    )

describe "SHB Watcher Wiring":
    it "writes and reads a cached SHB artifact":
        if not _can_run:
            expect(true).to_equal(true)
        else:
            val result = run_probe("write_read")
            val stdout = result[0]
            val stderr = result[1]
            val code = result[2]
            if code != 0:
                print stdout
                print stderr
            expect(code).to_equal(0)
            expect(stdout).to_contain("ok")

    it "returns cached SHB metadata through get_or_generate":
        if not _can_run:
            expect(true).to_equal(true)
        else:
            val result = run_probe("cached_get")
            val stdout = result[0]
            val stderr = result[1]
            val code = result[2]
            if code != 0:
                print stdout
                print stderr
            expect(code).to_equal(0)
            expect(stdout).to_contain("ok")

    it "tracks freshness across source and SHB updates":
        if not _can_run:
            expect(true).to_equal(true)
        else:
            val result = run_probe("freshness")
            val stdout = result[0]
