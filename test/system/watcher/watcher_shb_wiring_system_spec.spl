            expect(stdout).to_contain("ok")

    it "generates SHB through cache manager batch path":
        if not _can_run:
            expect(true).to_equal(true)
        else:
            val result = run_probe("batch_generate")
            val stdout = result[0]
            val stderr = result[1]
            val code = result[2]
            if code != 0:
                print stdout
                print stderr
            expect(code).to_equal(0)
            expect(stdout).to_contain("ok")

    it "distinguishes body-only from interface changes during generation":
        if not _can_run:
            expect(true).to_equal(true)
        else:
            val result = run_probe("body_vs_interface")
            val stdout = result[0]
            val stderr = result[1]
            val code = result[2]
            if code != 0:
                print stdout
                print stderr
            expect(code).to_equal(0)
            expect(stdout).to_contain("ok")
