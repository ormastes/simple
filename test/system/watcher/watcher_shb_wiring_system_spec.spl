# SHB Watcher Wiring System Spec
#
# Interpreter-safe wrapper that executes the compiled SHB wiring spec.
# The direct SHB generation path drives the frontend parser and extractor,
# which is not reliable in interpreter mode for this import graph.

extern fn rt_process_run(program: text, args: [text]) -> (text, text, i64)

fn run_compiled_shb_wiring_spec() -> (text, text, i64):
    rt_process_run(
        "bin/simple",
        ["test", "--no-db", "--mode=smf", "test/system/watcher/watcher_shb_wiring_compiled_spec.spl"]
    )

describe "SHB Watcher Wiring":
    it "passes the compiled end-to-end SHB wiring spec":
        val (stdout, stderr, code) = run_compiled_shb_wiring_spec()
        if code != 0:
            print stdout
            print stderr
        expect(code).to_equal(0)
        expect(stdout).to_contain("4 examples, 0 failures")
