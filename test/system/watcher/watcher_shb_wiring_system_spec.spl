    it "generates SHB through watcher inline fallback":
        if not _can_run:
            expect(true).to_equal(true)
        else:
            val result = run_probe("inline_generate")
            val stdout = result[0]
            val stderr = result[1]
            val code = result[2]
            if code != 0:
                print stdout
