# SHB Watcher Wiring System Spec
#
# Runs the SHB wiring probe through the self-hosted binary so the watcher/SHB
# pipeline executes outside the interpreter and test-runner fallback path.

extern fn rt_process_run(program: text, args: [text]) -> (text, text, i64)

fn run_probe(command: text) -> (text, text, i64):
    rt_process_run(
        "bin/release/simple",
        ["test/system/watcher/shb_wiring_probe.spl", command]
    )

describe "SHB Watcher Wiring":
    it "writes and reads a cached SHB artifact":
        val (stdout, stderr, code) = run_probe("write_read")
        if code != 0:
            print stdout
            print stderr
        expect(code).to_equal(0)
        expect(stdout).to_contain("ok")

    it "returns cached SHB metadata through get_or_generate":
        val (stdout, stderr, code) = run_probe("cached_get")
        if code != 0:
            print stdout
            print stderr
        expect(code).to_equal(0)
        expect(stdout).to_contain("ok")

    it "tracks freshness across source and SHB updates":
        val (stdout, stderr, code) = run_probe("freshness")
        if code != 0:
            print stdout
            print stderr
        expect(code).to_equal(0)
        expect(stdout).to_contain("ok")

    it "preserves SHB metadata for cached readers":
        val (stdout, stderr, code) = run_probe("metadata")
        if code != 0:
            print stdout
            print stderr
        expect(code).to_equal(0)
        expect(stdout).to_contain("ok")
