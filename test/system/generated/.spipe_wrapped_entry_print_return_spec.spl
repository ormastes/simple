#![allow(spipe_empty_examples)]
#![allow(spipe_boolean_wrapper_assertions)]
@allow(spipe_empty_examples)
@allow(spipe_boolean_wrapper_assertions)



fn main():
    # @cover src/compiler/95.interp/interpreter/mod.spl 80%
    """
    System test for print statement return behavior.
    
    Tests the current print expression return contract.
    """


    describe "Print Return":
        """
        Verifies that print emits output and returns nil.
        """

        context "when printing values":
            it "returns nil after printing":
                val result = print("test")
                expect result == nil