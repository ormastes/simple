# @cover src/os/kernel/loader/dylib_registry.spl 80%
"""
# Linux ELF Dynamic Loading System Test

Exercises the full dylib_registry pipeline with synthetic ELF64 fixtures:
register -> open -> symbol resolve -> close. Runs on all platforms (ELF
parsing is pure Simple).
"""

use std.spec
use os.posix.errno.{EBADF, ENOENT, ENOEXEC}
use os.kernel.loader.dylib_registry.{
    dylib_registry_reset_for_test,
    dylib_registry_register,
    dylib_registry_close,
    dylib_registry_symbol
}

fn push_u16_le(buf: [u8], value: i64) -> [u8]:
    buf.push((value & 0xFF).to_u8())
    buf.push(((value >> 8) & 0xFF).to_u8())
    buf

fn push_u32_le(buf: [u8], value: i64) -> [u8]:
    buf.push((value & 0xFF).to_u8())
    buf.push(((value >> 8) & 0xFF).to_u8())
    buf.push(((value >> 16) & 0xFF).to_u8())
    buf.push(((value >> 24) & 0xFF).to_u8())
    buf

fn push_u64_le(buf: [u8], value: i64) -> [u8]:
    var out = buf
    out = push_u32_le(out, value & 0xFFFFFFFF)
    out = push_u32_le(out, (value >> 32) & 0xFFFFFFFF)
    out

fn _pad_to(buf: [u8], target: i64) -> [u8]:
    while buf.len() < target:
        buf.push(0.to_u8())
    buf

fn make_elf64_exec() -> [u8]:
    var bytes: [u8] = []
    bytes.push(0x7F.to_u8())
    bytes.push(0x45.to_u8())
    bytes.push(0x4C.to_u8())
    bytes.push(0x46.to_u8())
    bytes.push(2.to_u8())
    bytes.push(1.to_u8())
    bytes.push(1.to_u8())
    bytes.push(0.to_u8())
    bytes.push(0.to_u8())
    while bytes.len() < 16:
        bytes.push(0.to_u8())
    bytes = push_u16_le(bytes, 2)
    bytes = push_u16_le(bytes, 62)
    bytes = push_u32_le(bytes, 1)
    bytes = push_u64_le(bytes, 0x400000)
    bytes = push_u64_le(bytes, 64)
    bytes = push_u64_le(bytes, 0)
    bytes = push_u32_le(bytes, 0)
    bytes = push_u16_le(bytes, 64)
    bytes = push_u16_le(bytes, 56)
    bytes = push_u16_le(bytes, 1)
    bytes = push_u16_le(bytes, 0)
    bytes = push_u16_le(bytes, 0)
    bytes = push_u16_le(bytes, 0)
    bytes = push_u32_le(bytes, 1)
    bytes = push_u32_le(bytes, 5)
    bytes = push_u64_le(bytes, 0x1000)
    bytes = push_u64_le(bytes, 0x400000)
    bytes = push_u64_le(bytes, 0x400000)
    bytes = push_u64_le(bytes, 4)
    bytes = push_u64_le(bytes, 4)
    bytes = push_u64_le(bytes, 0x1000)
    while bytes.len() < 0x1000:
        bytes.push(0.to_u8())
    bytes.push(0xC3.to_u8())
    bytes.push(0x00.to_u8())
    bytes.push(0x00.to_u8())
    bytes.push(0x00.to_u8())
    bytes

fn make_elf64_with_dynsym() -> [u8]:
    var b: [u8] = []
    b.push(0x7F.to_u8())
    b.push(0x45.to_u8())
    b.push(0x4C.to_u8())
    b.push(0x46.to_u8())
    b.push(2.to_u8())
    b.push(1.to_u8())
    b.push(1.to_u8())
    b = _pad_to(b, 16)
    b = push_u16_le(b, 2)
    b = push_u16_le(b, 62)
    b = push_u32_le(b, 1)
    b = push_u64_le(b, 0x400000)
    b = push_u64_le(b, 64)
    b = push_u64_le(b, 192)
    b = push_u32_le(b, 0)
    b = push_u16_le(b, 64)
    b = push_u16_le(b, 56)
    b = push_u16_le(b, 1)
    b = push_u16_le(b, 64)
    b = push_u16_le(b, 3)
    b = push_u16_le(b, 0)
    b = push_u32_le(b, 1)
    b = push_u32_le(b, 5)
    b = push_u64_le(b, 0)
    b = push_u64_le(b, 0x400000)
    b = push_u64_le(b, 0x400000)
    b = push_u64_le(b, 120)
    b = push_u64_le(b, 120)
    b = push_u64_le(b, 0x1000)
    b = _pad_to(b, 128)
    b.push(0.to_u8())
    b.push(0x68.to_u8())
    b.push(0x65.to_u8())
    b.push(0x6C.to_u8())
    b.push(0x6C.to_u8())
    b.push(0x6F.to_u8())
    b.push(0.to_u8())
    b = _pad_to(b, 144)
    b = _pad_to(b, 168)
    b = push_u32_le(b, 1)
    b.push(0x12.to_u8())
    b.push(0.to_u8())
    b = push_u16_le(b, 1)
    b = push_u64_le(b, 0xBEEF)
    b = push_u64_le(b, 8)
    b = _pad_to(b, 192)
    b = _pad_to(b, 256)
    b = push_u32_le(b, 0)
    b = push_u32_le(b, 11)
    b = push_u64_le(b, 0)
    b = push_u64_le(b, 0)
    b = push_u64_le(b, 144)
    b = push_u64_le(b, 48)
    b = push_u32_le(b, 2)
    b = push_u32_le(b, 0)
    b = push_u64_le(b, 0)
    b = push_u64_le(b, 24)
    b = push_u32_le(b, 0)
    b = push_u32_le(b, 3)
    b = push_u64_le(b, 0)
    b = push_u64_le(b, 0)
    b = push_u64_le(b, 128)
    b = push_u64_le(b, 7)
    b = push_u32_le(b, 0)
    b = push_u32_le(b, 0)
    b = push_u64_le(b, 0)
    b = push_u64_le(b, 0)
    b

describe "linux elf system: full registry pipeline":
    it "registers ELF64, resolves entry symbol, closes":
        dylib_registry_reset_for_test()
        val elf = make_elf64_exec()
        val handle = dylib_registry_register("/lib/test.so", elf)
        expect(handle).to_be_greater_than(0)

        val entry = dylib_registry_symbol(handle, "_start")
        expect(entry).to_equal(0x400000)

        val main_sym = dylib_registry_symbol(handle, "main")
        expect(main_sym).to_equal(0x400000)

        expect(dylib_registry_close(handle)).to_equal(0)

    it "resolves arbitrary .dynsym symbols via slow path":
        dylib_registry_reset_for_test()
        val elf = make_elf64_with_dynsym()
        val handle = dylib_registry_register("/lib/dynsym.so", elf)
        expect(handle).to_be_greater_than(0)
        expect(dylib_registry_symbol(handle, "hello")).to_equal(0xBEEF)
        expect(dylib_registry_symbol(handle, "missing")).to_equal(0 - ENOENT as i64)
        expect(dylib_registry_close(handle)).to_equal(0)

    it "rejects invalid bytes with ENOEXEC":
        dylib_registry_reset_for_test()
        var bad: [u8] = [1.to_u8(), 2.to_u8(), 3.to_u8()]
        expect(dylib_registry_register("/lib/bad.so", bad)).to_equal(0 - ENOEXEC as i64)

    it "returns EBADF for symbol lookup on closed handle":
        dylib_registry_reset_for_test()
        val handle = dylib_registry_register("/lib/closed.so", make_elf64_exec())
        expect(dylib_registry_close(handle)).to_equal(0)
        expect(dylib_registry_symbol(handle, "_start")).to_equal(0 - EBADF as i64)

    it "handles multiple libraries with independent handles":
        dylib_registry_reset_for_test()
        val h1 = dylib_registry_register("/lib/a.so", make_elf64_exec())
        val h2 = dylib_registry_register("/lib/b.so", make_elf64_with_dynsym())
        expect(h1).to_be_greater_than(0)
        expect(h2).to_be_greater_than(0)
        expect(h1 == h2).to_equal(false)
        expect(dylib_registry_symbol(h1, "_start")).to_equal(0x400000)
        expect(dylib_registry_symbol(h2, "hello")).to_equal(0xBEEF)
        expect(dylib_registry_close(h1)).to_equal(0)
        expect(dylib_registry_close(h2)).to_equal(0)
