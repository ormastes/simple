# @cover src/os/kernel/loader/dylib_registry.spl 80%
"""
# SimpleOS SMF Dynamic Loading System Test

Exercises the dylib_registry pipeline with SMF-wrapped ELF64 fixtures.
Verifies that SMF containers correctly unwrap to ELF stubs for symbol
resolution. Runs on all platforms (SMF parsing is pure Simple).
"""

use std.spec
use os.posix.errno.{ENOEXEC}
use os.kernel.loader.dylib_registry.{
    dylib_registry_reset_for_test,
    dylib_registry_register,
    dylib_registry_close,
    dylib_registry_symbol
}

fn push_u16_le(buf: [u8], value: i64) -> [u8]:
    buf.push((value & 0xFF).to_u8())
    buf.push(((value >> 8) & 0xFF).to_u8())
    buf

fn push_u32_le(buf: [u8], value: i64) -> [u8]:
    buf.push((value & 0xFF).to_u8())
    buf.push(((value >> 8) & 0xFF).to_u8())
    buf.push(((value >> 16) & 0xFF).to_u8())
    buf.push(((value >> 24) & 0xFF).to_u8())
    buf

fn push_u64_le(buf: [u8], value: i64) -> [u8]:
    var out = buf
    out = push_u32_le(out, value & 0xFFFFFFFF)
    out = push_u32_le(out, (value >> 32) & 0xFFFFFFFF)
    out

fn make_elf64_exec() -> [u8]:
    var bytes: [u8] = []
    bytes.push(0x7F.to_u8())
    bytes.push(0x45.to_u8())
    bytes.push(0x4C.to_u8())
    bytes.push(0x46.to_u8())
    bytes.push(2.to_u8())
    bytes.push(1.to_u8())
    bytes.push(1.to_u8())
    bytes.push(0.to_u8())
    bytes.push(0.to_u8())
    while bytes.len() < 16:
        bytes.push(0.to_u8())
    bytes = push_u16_le(bytes, 2)
    bytes = push_u16_le(bytes, 62)
    bytes = push_u32_le(bytes, 1)
    bytes = push_u64_le(bytes, 0x400000)
    bytes = push_u64_le(bytes, 64)
    bytes = push_u64_le(bytes, 0)
    bytes = push_u32_le(bytes, 0)
    bytes = push_u16_le(bytes, 64)
    bytes = push_u16_le(bytes, 56)
    bytes = push_u16_le(bytes, 1)
    bytes = push_u16_le(bytes, 0)
    bytes = push_u16_le(bytes, 0)
    bytes = push_u16_le(bytes, 0)
    bytes = push_u32_le(bytes, 1)
    bytes = push_u32_le(bytes, 5)
    bytes = push_u64_le(bytes, 0x1000)
    bytes = push_u64_le(bytes, 0x400000)
    bytes = push_u64_le(bytes, 0x400000)
    bytes = push_u64_le(bytes, 4)
    bytes = push_u64_le(bytes, 4)
    bytes = push_u64_le(bytes, 0x1000)
    while bytes.len() < 0x1000:
        bytes.push(0.to_u8())
    bytes.push(0xC3.to_u8())
    bytes.push(0x00.to_u8())
    bytes.push(0x00.to_u8())
    bytes.push(0x00.to_u8())
    bytes

fn make_smf_wrapped_elf64_exec() -> [u8]:
    var bytes = make_elf64_exec()
    val stub_size = bytes.len()
    bytes.push(83.to_u8())
    bytes.push(77.to_u8())
    bytes.push(70.to_u8())
    bytes.push(0.to_u8())
    var i = 4
    while i < 44:
        bytes.push(0.to_u8())
        i = i + 1
    bytes = push_u64_le(bytes, 0x400000)
    bytes = push_u32_le(bytes, stub_size)
    bytes = push_u32_le(bytes, stub_size)
    while bytes.len() < stub_size + 128:
        bytes.push(0.to_u8())
    bytes

describe "simpleos smf system: smf-wrapped elf loading":
    it "registers SMF library and resolves entry via ELF stub":
        dylib_registry_reset_for_test()
        val smf = make_smf_wrapped_elf64_exec()
        val handle = dylib_registry_register("/sys/apps/demo.smf", smf)
        expect(handle).to_be_greater_than(0)
        expect(dylib_registry_symbol(handle, "_start")).to_equal(0x400000)
        expect(dylib_registry_symbol(handle, "main")).to_equal(0x400000)

    it "registers multiple SMF libraries independently":
        dylib_registry_reset_for_test()
        val smf = make_smf_wrapped_elf64_exec()
        val h1 = dylib_registry_register("/sys/apps/lib_a.smf", smf)
        val h2 = dylib_registry_register("/sys/apps/lib_b.smf", smf)
        expect(h1).to_be_greater_than(0)
        expect(h2).to_be_greater_than(0)
        expect(h1 == h2).to_equal(false)
        expect(dylib_registry_symbol(h1, "_start")).to_equal(0x400000)
        expect(dylib_registry_symbol(h2, "main")).to_equal(0x400000)
        expect(dylib_registry_close(h1)).to_equal(0)
        expect(dylib_registry_close(h2)).to_equal(0)

    it "rejects SMF with invalid ELF stub":
        dylib_registry_reset_for_test()
        var bad_smf: [u8] = [1.to_u8(), 2.to_u8(), 3.to_u8(), 4.to_u8()]
        bad_smf.push(83.to_u8())
        bad_smf.push(77.to_u8())
        bad_smf.push(70.to_u8())
        bad_smf.push(0.to_u8())
        var j = 4
        while j < 44:
            bad_smf.push(0.to_u8())
            j = j + 1
        bad_smf = push_u64_le(bad_smf, 0x400000)
        bad_smf = push_u32_le(bad_smf, 4)
        bad_smf = push_u32_le(bad_smf, 4)
        while bad_smf.len() < 132:
            bad_smf.push(0.to_u8())
        expect(dylib_registry_register("/sys/bad.smf", bad_smf)).to_equal(0 - ENOEXEC as i64)

    it "handles mixed ELF and SMF in the same registry":
        dylib_registry_reset_for_test()
        val h_elf = dylib_registry_register("/lib/native.so", make_elf64_exec())
        val h_smf = dylib_registry_register("/sys/apps/app.smf", make_smf_wrapped_elf64_exec())
        expect(h_elf).to_be_greater_than(0)
        expect(h_smf).to_be_greater_than(0)
        expect(h_elf == h_smf).to_equal(false)
        expect(dylib_registry_symbol(h_elf, "_start")).to_equal(0x400000)
        expect(dylib_registry_symbol(h_smf, "_start")).to_equal(0x400000)
        expect(dylib_registry_close(h_elf)).to_equal(0)
        expect(dylib_registry_close(h_smf)).to_equal(0)
