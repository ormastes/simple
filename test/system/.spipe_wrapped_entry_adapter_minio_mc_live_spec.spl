#![allow(spipe_empty_examples)]
#![allow(spipe_boolean_wrapper_assertions)]
@allow(spipe_empty_examples)
@allow(spipe_boolean_wrapper_assertions)
use app.itf.adapter_minio_mc.{McClient, mc_ls, mc_stat, mc_get, mc_share_download, mc_health_ready}


fn main():

    describe("adapter_minio_mc — live local MinIO", fn():
        it("health endpoint returns ready", fn():
            val ok = mc_health_ready("http://127.0.0.1:9100")
            expect ok == true
        )

        it("ls --recursive returns the seeded objects", fn():
            val client = McClient(alias_name: "localtest", mc_path: "mc")
            val (ok, entries, _raw) = mc_ls(client, "spipe-test-bucket", true)
            expect ok == true
            expect entries.len() >= 3 == true
        )

        it("stat returns metadata for firmware/v1.2.3.bin", fn():
            val client = McClient(alias_name: "localtest", mc_path: "mc")
            val (ok, _info, _raw) = mc_stat(client, "spipe-test-bucket/firmware/v1.2.3.bin")
            expect ok == true
        )

        it("get fetches notes file to local path", fn():
            val client = McClient(alias_name: "localtest", mc_path: "mc")
            val (ok, _entries, _raw) = mc_get(client, "spipe-test-bucket/notes/simple-42.md", "/tmp/notes_fetched.md")
            expect ok == true
        )

        it("share download produces a presigned URL", fn():
            val client = McClient(alias_name: "localtest", mc_path: "mc")
            val (ok, presigned, _raw) = mc_share_download(client, "spipe-test-bucket/dumps/simple-42.dmp", 3600)
            expect ok == true
            expect presigned.len() > 0 == true
        )
    )