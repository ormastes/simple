# Jupyter Kernel Error Handling System Tests
# Tests: syntax errors show error, kernel survives

# tag: slow, system

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_delete(path: text) -> bool
extern fn rt_file_exists(path: text) -> bool
extern fn rt_getpid() -> i64
extern fn rt_time_now_unix_micros() -> i64

fn _check_binary_runnable() -> bool:
    if not rt_file_exists("bin/release/simple"):
        return false
    val (stdout, stderr, code) = rt_process_run("file", ["bin/release/simple"])
    if stdout == "" or stdout == nil:
        return false
    if stdout.contains("ELF") and not stdout.contains("Mach-O"):
        val (uname_out, _, _) = rt_process_run("uname", [])
        if uname_out.trim() == "Darwin":
            return false
    true

val _can_run = _check_binary_runnable()

fn send_kernel_messages(msgs: text) -> text:
    val tmp = "/tmp/jupyter_test_{rt_getpid()}_{rt_time_now_unix_micros()}.txt"
    rt_file_write_text(tmp, msgs)
    val (stdout, stderr, code) = rt_process_run("bash", ["-c", "cat {tmp} | timeout 10 bin/release/simple src/app/jupyter_kernel/main.spl 2>/dev/null"])
    rt_file_delete(tmp)
    stdout

describe "Jupyter Kernel Error Handling":
    it "should report errors for bad code":
        if not _can_run:
            print "SKIP: bin/release/simple not runnable on this platform"
            return
        val msgs = "{\"channel\":\"shell\",\"msg_type\":\"execute_request\",\"msg_id\":\"err1\",\"session\":\"s1\",\"content\":{\"code\":\"val = \"}}\n{\"channel\":\"control\",\"msg_type\":\"shutdown_request\",\"msg_id\":\"s2\",\"session\":\"s1\",\"content\":{}}\n"
        val output = send_kernel_messages(msgs)
        # Should get error reply, not crash
        expect(output).to_contain("execute_reply")

    it "should survive error and handle next request":
        if not _can_run:
            print "SKIP: bin/release/simple not runnable on this platform"
            return
        val msgs = "{\"channel\":\"shell\",\"msg_type\":\"execute_request\",\"msg_id\":\"err2\",\"session\":\"s1\",\"content\":{\"code\":\"bad code\"}}\n{\"channel\":\"shell\",\"msg_type\":\"execute_request\",\"msg_id\":\"ok1\",\"session\":\"s1\",\"content\":{\"code\":\"print 42\"}}\n{\"channel\":\"control\",\"msg_type\":\"shutdown_request\",\"msg_id\":\"s3\",\"session\":\"s1\",\"content\":{}}\n"
        val output = send_kernel_messages(msgs)
        expect(output).to_contain("execute_reply")

    it "should handle comm_info_request":
        if not _can_run:
            print "SKIP: bin/release/simple not runnable on this platform"
            return
        val msgs = "{\"channel\":\"shell\",\"msg_type\":\"comm_info_request\",\"msg_id\":\"ci1\",\"session\":\"s1\",\"content\":{}}\n{\"channel\":\"control\",\"msg_type\":\"shutdown_request\",\"msg_id\":\"s4\",\"session\":\"s1\",\"content\":{}}\n"
        val output = send_kernel_messages(msgs)
        expect(output).to_contain("comm_info_reply")
