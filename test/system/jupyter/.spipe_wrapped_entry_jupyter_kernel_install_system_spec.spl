#![allow(spipe_empty_examples)]
#![allow(spipe_boolean_wrapper_assertions)]
@allow(spipe_empty_examples)
@allow(spipe_boolean_wrapper_assertions)


extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_read_text(path: text) -> text

fn main():
    # @cover src/app/jupyter_kernel/main.spl 60%
    # @cover src/app/jupyter_kernel/protocol.spl 60%
    # @cover src/app/jupyter_kernel/session.spl 60%
    # Jupyter Kernel Installation System Tests
    # Tests: kernel.json exists, install script works

    # tag: slow, system

    describe "Jupyter Kernel Installation":
        slow_it "should have kernel.json":
            expect rt_file_exists("tools/jupyter/kernel.json") == true

        slow_it "should have kernel_wrapper.py":
            expect rt_file_exists("tools/jupyter/kernel_wrapper.py") == true

        slow_it "should have install script":
            expect rt_file_exists("tools/jupyter/install.shs") == true

        slow_it "should have valid kernel.json with Simple language":
            val content = rt_file_read_text("tools/jupyter/kernel.json") ?? ""
            expect (content).contains("Simple")
            expect (content).contains("simple")
            expect (content).contains(".spl")

        slow_it "should have kernel main entry point":
            expect rt_file_exists("src/app/jupyter_kernel/main.spl") == true

        slow_it "should have kernel protocol module":
            expect rt_file_exists("src/app/jupyter_kernel/protocol.spl") == true

        slow_it "should have kernel session module":
            expect rt_file_exists("src/app/jupyter_kernel/session.spl") == true