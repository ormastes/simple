# Jupyter Notebook Server End-to-End System Test
#
# Tests the full Jupyter integration through Docker:
#   1. Builds Docker image with Jupyter + Simple kernel
#   2. Inside Docker: starts real Jupyter notebook server on localhost
#   3. HTTP GET /api/status — server is alive
#   4. HTTP GET /api/kernelspecs — "simple" kernel is listed
#   5. HTTP POST /api/sessions — Simple kernel session starts
#   6. ZMQ execute_request: `print "Hello from Simple!"` — output verified
#   7. ZMQ execute_request: `val x = 42\nprint x` — output "42" verified
#
# Non-Docker tests (run locally with Python deps):
#   - kernel.json static validation
#   - kernel_wrapper.py Python syntax check
#   - nbconvert --execute with hello.ipynb fixture
#
# Requirements:
#   Docker tests: docker (or podman), bin/release/simple
#   Local tests:  python3, pyzmq, jupyter_client, notebook, nbconvert

# tag: slow, system

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_file_exists(path: text) -> bool

fn get_simple_binary() -> text:
    val (uname_out, _err, _code) = rt_process_run("uname", ["-s"])
    if uname_out.trim() == "FreeBSD":
        "src/compiler_rust/target/bootstrap/simple"
    else:
        "bin/release/simple"

fn check_docker() -> bool:
    val (stdout, stderr, code) = rt_process_run("docker", ["info"])
    if stdout == "" and stderr == "" and code == 0:
        return false
    code == 0

fn check_python_jupyter() -> bool:
    val (stdout, stderr, code) = rt_process_run("python3", ["-c", "import jupyter_client; import nbconvert; print('ok')"])
    if stdout == "" and stderr == "" and code == 0:
        return false
    if code != 0:
        return false
    val (stdout2, stderr2, code2) = rt_process_run("python3", ["-c", "import zmq; print('ok')"])
    if stdout2 == "" and stderr2 == "" and code2 == 0:
        return false
    code2 == 0

fn check_notebook_package() -> bool:
    val (stdout, stderr, code) = rt_process_run("python3", ["-c", "import notebook; print('ok')"])
    if stdout == "" and stderr == "" and code == 0:
        return false
    code == 0

fn _check_binary_runnable() -> bool:
    if not rt_file_exists("bin/release/simple"):
        return false
    val (stdout, stderr, code) = rt_process_run("file", ["bin/release/simple"])
    if stdout == "" or stdout == nil:
        return false
    if stdout.contains("ELF") and not stdout.contains("Mach-O"):
        val (uname_out, _, _) = rt_process_run("uname", [])
        if uname_out.trim() == "Darwin":
            return false
    true

val _has_docker = check_docker()
val _has_jupyter = check_python_jupyter()
val _has_notebook = check_notebook_package()
val _has_binary = _check_binary_runnable()

# --- Module-level helpers to avoid tuple destructuring inside it blocks ---

class CmdResult:
    stdout: text
    stderr: text
    code: i64

fn _wrap_run(cmd: text, args: [text]) -> CmdResult:
    val (stdout, stderr, code) = rt_process_run(cmd, args)
    CmdResult(stdout: stdout, stderr: stderr, code: code)

fn _docker_image_exists() -> bool:
    val res = _wrap_run("docker", ["image", "inspect", "simple-jupyter-test"])
    res.code == 0

fn _run_docker_e2e() -> CmdResult:
    print "Running E2E test in Docker container..."
    _wrap_run("docker", ["run", "--rm", "simple-jupyter-test"])

fn _run_server_check() -> CmdResult:
    val helper = "test/system/jupyter/helpers/run_server_check.py"
    _wrap_run("python3", [helper])

fn _run_notebook_test(notebook: text) -> CmdResult:
    val helper = "test/system/jupyter/helpers/run_notebook_server_test.py"
    _wrap_run("python3", [helper, "--notebook", notebook, "--skip-server"])

fn _run_python_check(py_code: text) -> CmdResult:
    _wrap_run("python3", ["-c", py_code])

describe "Jupyter Notebook Server E2E":

    # -----------------------------------------------------------------------
    # Docker E2E: Full integration test inside container
    # Builds image, starts Jupyter server, creates kernel session via HTTP,
    # executes cells via ZMQ, verifies output
    # -----------------------------------------------------------------------
    it "should pass full E2E test in Docker container":
        if not _has_docker or not _has_binary:
            expect(true).to_equal(true)
        else:
            if not rt_file_exists("scripts/test/jupyter-docker-test.shs"):
                print "SKIP: scripts/test/jupyter-docker-test.shs not found"
                expect(true).to_equal(true)
            else:
                if not rt_file_exists("tools/docker/Dockerfile.jupyter-test"):
                    print "SKIP: tools/docker/Dockerfile.jupyter-test not found"
                    expect(true).to_equal(true)
                else:
                    if not _docker_image_exists():
                        print "SKIP: simple-jupyter-test Docker image not built (run: sh scripts/test/jupyter-docker-test.shs)"
                        expect(true).to_equal(true)
                    else:
                        val res = _run_docker_e2e()
                        print res.stdout
                        if res.code != 0 and res.stderr.trim() != "":
                            print "stderr (tail): {res.stderr.substring(res.stderr.len() - 300)}"
                        expect(res.code).to_equal(0)
                        expect(res.stdout).to_contain("ALL CHECKS PASSED")

    # -----------------------------------------------------------------------
    # Local E2E: Start real Jupyter server, HTTP + ZMQ checks
    # Same checks as Docker but runs on host (needs python deps installed)
    # -----------------------------------------------------------------------
    it "should start server and execute cell via HTTP + ZMQ locally":
        if not _has_notebook or not _has_binary or not _has_jupyter:
            expect(true).to_equal(true)
        else:
            val res = _run_server_check()
            print res.stdout
            if res.code != 0 and res.stderr.trim() != "":
                val tail_start = res.stderr.len() - 300
                if tail_start < 0:
                    print "stderr: {res.stderr}"
                else:
                    print "stderr (tail): {res.stderr.substring(tail_start)}"
            expect(res.code).to_equal(0)
            expect(res.stdout).to_contain("ALL CHECKS PASSED")

    # -----------------------------------------------------------------------
    # nbconvert E2E: Execute hello.ipynb, verify cell outputs
    # Input:
    #   Cell 0: print "Hello from Simple!"    -> expect "Hello from Simple!"
    #   Cell 1: val x = 42 / print x          -> expect "42"
    #   Cell 2: fn double(...) / print double(21) -> expect "42"
    # -----------------------------------------------------------------------
    it "should execute hello.ipynb via nbconvert and verify output":
        if not _has_jupyter or not _has_binary:
            expect(true).to_equal(true)
        else:
            val res = _run_notebook_test("test/system/jupyter/fixtures/hello.ipynb")
            print res.stdout
            if res.code != 0 and res.stderr.trim() != "":
                print "stderr: {res.stderr}"
            expect(res.code).to_equal(0)
            expect(res.stdout).to_contain("ALL CHECKS PASSED")

    # -----------------------------------------------------------------------
    # nbconvert E2E: Execute state_persistence.ipynb
    # Input:
    #   Cell 0: val x = 42                    -> no output
    #   Cell 1: print x                       -> expect "42"
    #   Cell 2: fn greet(name: text) -> text  -> no output
    #   Cell 3: print greet("World")          -> expect "Hello, World!"
    # -----------------------------------------------------------------------
    it "should execute state_persistence.ipynb and verify cross-cell state":
        if not _has_jupyter or not _has_binary:
            expect(true).to_equal(true)
        else:
            val res = _run_notebook_test("test/system/jupyter/fixtures/state_persistence.ipynb")
            print res.stdout
            if res.code != 0 and res.stderr.trim() != "":
                print "stderr: {res.stderr}"
            expect(res.code).to_equal(0)

    # -----------------------------------------------------------------------
    # Static checks
    # -----------------------------------------------------------------------
    it "should have kernel.json with display_name 'Simple'":
        val res = _run_python_check("import json; d=json.load(open('tools/jupyter/kernel.json')); print(d['display_name'])")
        expect(res.code).to_equal(0)
        expect(res.stdout.trim()).to_equal("Simple")

    it "should have kernel_wrapper.py with valid Python syntax":
        val res = _run_python_check("import ast; ast.parse(open('tools/jupyter/kernel_wrapper.py').read()); print('ok')")
        expect(res.code).to_equal(0)
        expect(res.stdout.trim()).to_equal("ok")
