# Jupyter Kernel Execution System Tests
# Tests: kernel process starts and handles messages

# tag: slow, system

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_delete(path: text) -> bool
extern fn rt_file_exists(path: text) -> bool
extern fn rt_getpid() -> i64
extern fn rt_time_now_unix_micros() -> i64

fn send_kernel_message(msg: text) -> text:
    val tmp = "/tmp/jupyter_test_{rt_getpid()}_{rt_time_now_unix_micros()}.txt"
    rt_file_write_text(tmp, msg + "\n")
    val (stdout, stderr, code) = rt_process_run("bash", ["-c", "cat {tmp} | timeout 5 bin/release/simple src/app/jupyter_kernel/main.spl 2>/dev/null"])
    rt_file_delete(tmp)
    stdout

describe "Jupyter Kernel Execution":
    it "should respond to kernel_info_request":
        val msg = "{\"channel\":\"shell\",\"msg_type\":\"kernel_info_request\",\"msg_id\":\"test1\",\"session\":\"s1\",\"content\":{}}"
        val output = send_kernel_message(msg)
        expect(output).to_contain("kernel_info_reply")
        expect(output).to_contain("simple")

    it "should respond to shutdown_request":
        val msg = "{\"channel\":\"control\",\"msg_type\":\"shutdown_request\",\"msg_id\":\"test2\",\"session\":\"s1\",\"content\":{}}"
        val output = send_kernel_message(msg)
        expect(output).to_contain("shutdown_reply")

    it "should handle is_complete_request for complete code":
        val msg = "{\"channel\":\"shell\",\"msg_type\":\"is_complete_request\",\"msg_id\":\"test3\",\"session\":\"s1\",\"content\":{\"code\":\"val x = 42\"}}"
        val output = send_kernel_message(msg)
        expect(output).to_contain("complete")

    it "should handle is_complete_request for incomplete code":
        val msg = "{\"channel\":\"shell\",\"msg_type\":\"is_complete_request\",\"msg_id\":\"test4\",\"session\":\"s1\",\"content\":{\"code\":\"fn foo():\"}}"
        val output = send_kernel_message(msg)
        expect(output).to_contain("incomplete")
