# @cover src/lib/nogc_sync_mut/test_runner/test_executor_composite.spl 80%
# Remote Interpreter Backend Routing System Tests
# @tag:system

use app.test_runner_new.{extract_base_runtime, extract_platform_layer, extract_remote_backend}

extern fn rt_file_read_text(path: text) -> text

describe "Remote interpreter backend routing":
    it "extracts interpreter as the base runtime for T32 remote specs":
        val spec = "interpreter(remote(t32(stm32wb)))"
        expect(extract_base_runtime(spec)).to_equal("interpreter")

    it "extracts remote as the platform layer for T32 remote specs":
        val spec = "interpreter(remote(t32(stm32wb)))"
        expect(extract_platform_layer(spec)).to_equal("remote")

    it "extracts t32 as the remote backend":
        val spec = "interpreter(remote(t32(stm32wb)))"
        expect(extract_remote_backend(spec)).to_equal("t32")

    it "extracts openocd as the remote backend":
        val spec = "interpreter(remote(openocd(stm32wb)))"
        expect(extract_remote_backend(spec)).to_equal("openocd")

    it "returns empty backend for legacy remote specs":
        val spec = "interpreter(remote(arm32))"
        expect(extract_remote_backend(spec)).to_equal("")

    it "runner source contains explicit t32 routing and command env":
        val source = rt_file_read_text("src/app/test_runner_new/test_executor_composite.spl")
        val remote_source = rt_file_read_text("src/app/test_runner_new/test_remote.spl")
        expect(source.contains("backend == \"t32\"")).to_equal(true)
        expect(source.contains("remote_target_with_transport(\"localhost\", 20000, arch, \"t32\"")).to_equal(true)
        expect(remote_source.contains("SIMPLE_REMOTE_T32_INTERPRETER_CMD")).to_equal(true)

    it "runner source contains explicit openocd routing and command env":
        val source = rt_file_read_text("src/app/test_runner_new/test_executor_composite.spl")
        val remote_source = rt_file_read_text("src/app/test_runner_new/test_remote.spl")
        expect(source.contains("backend == \"openocd\"")).to_equal(true)
        expect(source.contains("remote_target_with_transport(\"localhost\", 3333, arch, \"openocd\"")).to_equal(true)
        expect(remote_source.contains("SIMPLE_REMOTE_OPENOCD_INTERPRETER_CMD")).to_equal(true)
