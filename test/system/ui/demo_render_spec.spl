# Demo UI Rendering Specification
#
# System test verifying that all 10 demo .ui.sdn files parse and render
# correctly via parse_ui_file. Each test asserts the result is Ok and
# the generated HTML contains expected content strings.

use common.ui.parse.sdn.{parse_ui_file}


# ============================================================================
# Demo UI Rendering
# ============================================================================

describe "Demo UI Rendering":

    it "renders demo_basics.ui.sdn":
        val result = parse_ui_file("examples/ui/demo_basics.ui.sdn")
        match result:
            case Ok(html):
                expect html to_contain "Basic Widgets Demo"
                expect html to_contain "Hello, Simple UI!"
                expect html to_contain "Welcome"
                expect html to_contain "Text Variants"
            case Err(msg):
                expect false to_equal true

    it "renders demo_controls.ui.sdn":
        val result = parse_ui_file("examples/ui/demo_controls.ui.sdn")
        match result:
            case Ok(html):
                expect html to_contain "Interactive Controls Demo"
                expect html to_contain "Buttons"
                expect html to_contain "Checkboxes"
                expect html to_contain "Dropdown"
            case Err(msg):
                expect false to_equal true

    it "renders demo_forms.ui.sdn":
        val result = parse_ui_file("examples/ui/demo_forms.ui.sdn")
        match result:
            case Ok(html):
                expect html to_contain "Form Inputs Demo"
                expect html to_contain "Text Inputs"
                expect html to_contain "Validation States"
                expect html to_contain "Text Areas"
            case Err(msg):
                expect false to_equal true

    it "renders demo_collections.ui.sdn":
        val result = parse_ui_file("examples/ui/demo_collections.ui.sdn")
        match result:
            case Ok(html):
                expect html to_contain "Collections Demo"
                expect html to_contain "List"
                expect html to_contain "Table"
                expect html to_contain "File Browser"
            case Err(msg):
                expect false to_equal true

    it "renders demo_navigation.ui.sdn":
        val result = parse_ui_file("examples/ui/demo_navigation.ui.sdn")
        match result:
            case Ok(html):
                expect html to_contain "Navigation Demo"
                expect html to_contain "menubar"
                expect html to_contain "Dashboard"
                expect html to_contain "Quick Stats"
            case Err(msg):
                expect false to_equal true

    it "renders demo_display.ui.sdn":
        val result = parse_ui_file("examples/ui/demo_display.ui.sdn")
        match result:
            case Ok(html):
                expect html to_contain "Display Widgets Demo"
                expect html to_contain "progress"
                expect html to_contain "Progress Bars"
                expect html to_contain "Tooltip Example"
            case Err(msg):
                expect false to_equal true

    it "renders demo_layouts.ui.sdn":
        val result = parse_ui_file("examples/ui/demo_layouts.ui.sdn")
        match result:
            case Ok(html):
                expect html to_contain "Layout Demo"
                expect html to_contain "hbox"
                expect html to_contain "Grid Layout"
                expect html to_contain "Deep Nesting"
            case Err(msg):
                expect false to_equal true

    it "renders demo_overlays.ui.sdn":
        val result = parse_ui_file("examples/ui/demo_overlays.ui.sdn")
        match result:
            case Ok(html):
                expect html to_contain "Overlays Demo"
                expect html to_contain "Scroll Container"
                expect html to_contain "Log entry 1"
                expect html to_contain "Confirm Action"
            case Err(msg):
                expect false to_equal true

    it "renders demo_themes.ui.sdn":
        val result = parse_ui_file("examples/ui/demo_themes.ui.sdn")
        match result:
            case Ok(html):
                expect html to_contain "Theme Showcase"
                expect html to_contain "Navigation"
                expect html to_contain "Widget Gallery"
            case Err(msg):
                expect false to_equal true

    it "renders demo_kitchen_sink.ui.sdn":
        val result = parse_ui_file("examples/ui/demo_kitchen_sink.ui.sdn")
        match result:
            case Ok(html):
                expect html to_contain "Kitchen Sink"
                expect html to_contain "Sidebar"
                expect html to_contain "Main Content"
                expect html to_contain "Kitchen Sink Demo"
            case Err(msg):
                expect false to_equal true
