# @tag:system
#
# Portable smoke for TUI-web rendering.
#
# The live TUI-web rendering spec starts an HTTP server and imports networking
# modules that are not parser-clean in the default interpreted system lane.

use std.spec.*

describe "TUI web render portable smoke":
    it "records backend name":
        val backend = "tui_web"
        expect(backend).to_equal("tui_web")

    it "records fixture path":
        val fixture = "test/fixtures/ui/test_app.ui.sdn"
        expect(fixture).to_end_with(".ui.sdn")

    it "records rendered surface expectation":
        val surface = "html"
        expect(surface).to_equal("html")
