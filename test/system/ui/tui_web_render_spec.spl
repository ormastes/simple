# @cover src/lib/nogc_sync_mut/ui_test/client.spl 80%
# @cover src/app/ui.tui/screen.spl 80%
"""
TUI Web Proxy Rendering Specification

System test that verifies the TUI web proxy backend starts correctly,
serves the test API, and returns expected widget data through the
proxy layer.

tag: slow, system
"""

use std.ui_test.client.{UITestClient}
use std.ui_test.types.{ElementInfo, UIStateInfo}
use test.system.ui.helpers.ui_test_helpers.{start_ui_server, stop_ui_server, free_port}

val sdn_path = "test/fixtures/ui/test_app.ui.sdn"

# ============================================================================
# TUI Web Proxy
# ============================================================================

describe "TUI Web Proxy":

    slow_it "server starts and reports ready":
        val port = free_port() + 10
        val pid = start_ui_server("tui_web", sdn_path, port)
        var client = UITestClient(host: "127.0.0.1", port: port)
        val ready_result = client.wait_ready(5000)
        match ready_result:
            Ok(ready):
                expect ready to_equal true
            Err(e):
                expect e to_equal ""
        stop_ui_server(pid)

    slow_it "returns widget tree via API":
        val port = free_port() + 11
        val pid = start_ui_server("tui_web", sdn_path, port)
        var client = UITestClient(host: "127.0.0.1", port: port)
        client.wait_ready(5000)
        val elems_result = client.get_elements()
        match elems_result:
            Ok(elems):
                expect elems.length() to_be_greater_than 0
            Err(e):
                expect e to_equal ""
        stop_ui_server(pid)

    slow_it "returns state via API":
        val port = free_port() + 12
        val pid = start_ui_server("tui_web", sdn_path, port)
        var client = UITestClient(host: "127.0.0.1", port: port)
        client.wait_ready(5000)
        val state_result = client.get_state()
        match state_result:
            Ok(state):
                expect state.mode to_equal "NORMAL"
            Err(e):
                expect e to_equal ""
        stop_ui_server(pid)

    slow_it "returns screenshot with TUI HTML":
        val port = free_port() + 13
        val pid = start_ui_server("tui_web", sdn_path, port)
        var client = UITestClient(host: "127.0.0.1", port: port)
        client.wait_ready(5000)
        val html_result = client.screenshot_html()
        match html_result:
            Ok(html):
                expect html.length() to_be_greater_than 0
            Err(e):
                expect e to_equal ""
        stop_ui_server(pid)

    slow_it "click works on tui_web":
        val port = free_port() + 14
        val pid = start_ui_server("tui_web", sdn_path, port)
        var client = UITestClient(host: "127.0.0.1", port: port)
        client.wait_ready(5000)
        val click_result = client.click("action_btn")
        match click_result:
            Ok(ok):
                expect ok to_equal true
            Err(e):
                expect e to_equal ""
        stop_ui_server(pid)
