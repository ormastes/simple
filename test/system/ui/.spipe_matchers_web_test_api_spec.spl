# @tag:system
#
# Portable web UI test API smoke.
#
# Live web API checks require an HTTP server and TCP client. This default lane
# records the API contract without importing networking.

use std.spec.*

describe "Web UI Test API portable smoke":
    it "records ready and state endpoints":
        expect "/api/test/ready" == "/api/test/ready"
        expect "NORMAL" == "NORMAL"

    it "records element query contract":
        expect "action_btn" == "action_btn"
        expect "button" == "button"

    it "records supported actions":
        val actions = ["click", "type", "key"]
        expect actions.len() == 3
        expect actions[0] == "click"