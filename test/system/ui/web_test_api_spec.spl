"""
Web UI Test API Specification

System test that verifies the web backend test API endpoints work correctly.
Starts a web UI server with the test fixture, connects via UITestClient,
and exercises all query/action/assertion endpoints.

tag: slow, system
"""

use std.ui_test.client.{UITestClient}
use std.ui_test.types.{ElementInfo, UIStateInfo}
use test.system.ui.helpers.ui_test_helpers.{start_ui_server, stop_ui_server, free_port}

val sdn_path = "test/fixtures/ui/test_app.ui.sdn"

# ============================================================================
# Web UI Test API
# ============================================================================

describe "Web UI Test API":

    slow_it "server reports ready":
        val port = free_port()
        val pid = start_ui_server("web", sdn_path, port)
        var client = UITestClient(host: "127.0.0.1", port: port)
        val ready_result = client.wait_ready(5000)
        match ready_result:
            Ok(ready):
                expect ready to_equal true
            Err(e):
                expect e to_equal ""
        stop_ui_server(pid)

    slow_it "returns element info":
        val port = free_port() + 1
        val pid = start_ui_server("web", sdn_path, port)
        var client = UITestClient(host: "127.0.0.1", port: port)
        client.wait_ready(5000)
        val elem_result = client.get_element("action_btn")
        match elem_result:
            Ok(elem):
                expect elem.kind to_equal "button"
            Err(e):
                expect e to_equal ""
        stop_ui_server(pid)

    slow_it "returns all elements":
        val port = free_port() + 2
        val pid = start_ui_server("web", sdn_path, port)
        var client = UITestClient(host: "127.0.0.1", port: port)
        client.wait_ready(5000)
        val elems_result = client.get_elements()
        match elems_result:
            Ok(elems):
                expect elems.length() to_be_greater_than 0
            Err(e):
                expect e to_equal ""
        stop_ui_server(pid)

    slow_it "returns UI state":
        val port = free_port() + 3
        val pid = start_ui_server("web", sdn_path, port)
        var client = UITestClient(host: "127.0.0.1", port: port)
        client.wait_ready(5000)
        val state_result = client.get_state()
        match state_result:
            Ok(state):
                expect state.mode to_equal "NORMAL"
            Err(e):
                expect e to_equal ""
        stop_ui_server(pid)

    slow_it "returns screenshot HTML":
        val port = free_port() + 4
        val pid = start_ui_server("web", sdn_path, port)
        var client = UITestClient(host: "127.0.0.1", port: port)
        client.wait_ready(5000)
        val html_result = client.screenshot_html()
        match html_result:
            Ok(html):
                expect html.length() to_be_greater_than 0
            Err(e):
                expect e to_equal ""
        stop_ui_server(pid)

    slow_it "clicks a button element":
        val port = free_port() + 5
        val pid = start_ui_server("web", sdn_path, port)
        var client = UITestClient(host: "127.0.0.1", port: port)
        client.wait_ready(5000)
        val click_result = client.click("action_btn")
        match click_result:
            Ok(ok):
                expect ok to_equal true
            Err(e):
                expect e to_equal ""
        val exists_result = client.check_exists("action_btn")
        match exists_result:
            Ok(exists):
                expect exists to_equal true
            Err(e):
                expect e to_equal ""
        stop_ui_server(pid)

    slow_it "types text into input":
        val port = free_port() + 6
        val pid = start_ui_server("web", sdn_path, port)
        var client = UITestClient(host: "127.0.0.1", port: port)
        client.wait_ready(5000)
        val type_result = client.type_text("search_input", "hello")
        match type_result:
            Ok(ok):
                expect ok to_equal true
            Err(e):
                expect e to_equal ""
        stop_ui_server(pid)

    slow_it "sends keyboard event":
        val port = free_port() + 7
        val pid = start_ui_server("web", sdn_path, port)
        var client = UITestClient(host: "127.0.0.1", port: port)
        client.wait_ready(5000)
        val key_result = client.send_key("j")
        match key_result:
            Ok(ok):
                expect ok to_equal true
            Err(e):
                expect e to_equal ""
        stop_ui_server(pid)
