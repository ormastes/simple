describe "Shared UI Contract — State Endpoint":

    slow_it "state endpoint returns element_count on both surfaces":
        val (wp, tp) = both_ports()
        val wpid = start_ui_server("web", sdn_path, wp)
        val tpid = start_ui_server("tui_web", sdn_path, tp)
        var wc = UITestClient(host: "127.0.0.1", port: wp)
        var tc = UITestClient(host: "127.0.0.1", port: tp)
        wc.wait_ready(5000)
        tc.wait_ready(5000)

        val web_body = test_get("127.0.0.1", wp, "/api/test/state")
        val tui_body = test_get("127.0.0.1", tp, "/api/test/state")
        match web_body:
            Ok(b):
                val count = extract_field(b, "element_count")
                expect count.length() to_be_greater_than 0
                val ver = extract_field(b, "protocol_version")
                expect ver to_equal "1"
            Err(e):
                expect e to_equal ""
        match tui_body:
            Ok(b):
                val count = extract_field(b, "element_count")
                expect count.length() to_be_greater_than 0
                val ver = extract_field(b, "protocol_version")
                expect ver to_equal "1"
            Err(e):
                expect e to_equal ""

        stop_ui_server(wpid)
        stop_ui_server(tpid)

# ============================================================================
# 6. Errors (Negative Tests)
# ============================================================================

describe "Shared UI Contract — Errors":

    slow_it "element_not_found for invalid ID on both surfaces":
        val (wp, tp) = both_ports()
        val wpid = start_ui_server("web", sdn_path, wp)
        val tpid = start_ui_server("tui_web", sdn_path, tp)
        var wc = UITestClient(host: "127.0.0.1", port: wp)
        var tc = UITestClient(host: "127.0.0.1", port: tp)
        wc.wait_ready(5000)
        tc.wait_ready(5000)

        val web_body = test_get("127.0.0.1", wp, "/api/test/element?id=nonexistent_xyz")
        val tui_body = test_get("127.0.0.1", tp, "/api/test/element?id=nonexistent_xyz")
        match web_body:
            Ok(b):
                val err = extract_field(b, "error")
                expect err to_equal "element_not_found"
            Err(e):
                expect e to_equal ""
        match tui_body:
            Ok(b):
                val err = extract_field(b, "error")
                expect err to_equal "element_not_found"
            Err(e):
                expect e to_equal ""

        stop_ui_server(wpid)
        stop_ui_server(tpid)

    slow_it "missing_field for click without id on both surfaces":
        val (wp, tp) = both_ports()
        val wpid = start_ui_server("web", sdn_path, wp)
        val tpid = start_ui_server("tui_web", sdn_path, tp)
        var wc = UITestClient(host: "127.0.0.1", port: wp)
        var tc = UITestClient(host: "127.0.0.1", port: tp)
        wc.wait_ready(5000)
        tc.wait_ready(5000)

        val web_body = test_post("127.0.0.1", wp, "/api/test/click", "{}")
        val tui_body = test_post("127.0.0.1", tp, "/api/test/click", "{}")
        match web_body:
            Ok(b):
                val err = extract_field(b, "error")
                expect err to_equal "missing_field"
            Err(e):
                expect e to_equal ""
        match tui_body:
            Ok(b):
                val err = extract_field(b, "error")
                expect err to_equal "missing_field"
            Err(e):
                expect e to_equal ""

        stop_ui_server(wpid)
        stop_ui_server(tpid)

    slow_it "unknown_event_type for invalid event on both surfaces":
        val (wp, tp) = both_ports()
        val wpid = start_ui_server("web", sdn_path, wp)
        val tpid = start_ui_server("tui_web", sdn_path, tp)
        var wc = UITestClient(host: "127.0.0.1", port: wp)
        var tc = UITestClient(host: "127.0.0.1", port: tp)
        wc.wait_ready(5000)
        tc.wait_ready(5000)

        val body = "{\"event_type\":\"invalid_xyz\"}"
        val web_body = test_post("127.0.0.1", wp, "/api/test/event", body)
        val tui_body = test_post("127.0.0.1", tp, "/api/test/event", body)
        match web_body:
            Ok(b):
                val err = extract_field(b, "error")
                expect err to_equal "unknown_event_type"
            Err(e):
                expect e to_equal ""
        match tui_body:
            Ok(b):
                val err = extract_field(b, "error")
                expect err to_equal "unknown_event_type"
            Err(e):
                expect e to_equal ""

        stop_ui_server(wpid)
        stop_ui_server(tpid)

    slow_it "stale session returns connection error after server stop":
        val (wp, tp) = both_ports()
        val wpid = start_ui_server("web", sdn_path, wp)
        val tpid = start_ui_server("tui_web", sdn_path, tp)
        var wc = UITestClient(host: "127.0.0.1", port: wp)
        var tc = UITestClient(host: "127.0.0.1", port: tp)
        wc.wait_ready(5000)
        tc.wait_ready(5000)

        # Verify servers are alive first
        val web_ready = test_get("127.0.0.1", wp, "/api/test/ready")
        match web_ready:
            Ok(b):
                val ready = extract_field(b, "ready")
                expect ready to_equal "true"
            Err(e):
                expect e to_equal ""
        val tui_ready = test_get("127.0.0.1", tp, "/api/test/ready")
        match tui_ready:
            Ok(b):
                val ready = extract_field(b, "ready")
                expect ready to_equal "true"
            Err(e):
                expect e to_equal ""

        # Stop both servers — sessions are now stale
        stop_ui_server(wpid)
        stop_ui_server(tpid)

        # Requests to stopped servers must fail with connection error
        val web_stale = test_get("127.0.0.1", wp, "/api/test/ready")
        match web_stale:
            Ok(b):
                # Should not succeed — server is stopped
                expect "connection should have failed" to_equal ""
            Err(e):
                # Connection error is expected for a stale/dead session
                expect e.length() to_be_greater_than 0

        val tui_stale = test_get("127.0.0.1", tp, "/api/test/ready")
        match tui_stale:
            Ok(b):
                expect "connection should have failed" to_equal ""
            Err(e):
                expect e.length() to_be_greater_than 0

# ============================================================================
# 7. Read-After-Write Consistency
# ============================================================================

describe "Shared UI Contract — Consistency":

    slow_it "click then get_element reflects state change on both surfaces":
        val (wp, tp) = both_ports()
        val wpid = start_ui_server("web", sdn_path, wp)
        val tpid = start_ui_server("tui_web", sdn_path, tp)
        var wc = UITestClient(host: "127.0.0.1", port: wp)
        var tc = UITestClient(host: "127.0.0.1", port: tp)
        wc.wait_ready(5000)
        tc.wait_ready(5000)

        val web_before = wc.get_elements()
        wc.click("action_btn")
        val web_after = wc.get_elements()
        match web_before:
            Ok(b):
                match web_after:
                    Ok(a):
                        expect b.length() to_be_greater_than 0
                        expect a.length() to_be_greater_than 0
                    Err(e):
                        expect e to_equal ""
            Err(e):
                expect e to_equal ""

        val tui_before = tc.get_elements()
        tc.click("action_btn")
        val tui_after = tc.get_elements()
        match tui_before:
            Ok(b):
                match tui_after:
                    Ok(a):
                        expect b.length() to_be_greater_than 0
                        expect a.length() to_be_greater_than 0
                    Err(e):
                        expect e to_equal ""
            Err(e):
                expect e to_equal ""

        stop_ui_server(wpid)
        stop_ui_server(tpid)
