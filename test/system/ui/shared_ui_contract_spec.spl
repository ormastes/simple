# @cover src/app/ui.test_api/handler.spl 80%
# @cover src/lib/nogc_sync_mut/ui_test/client.spl 80%
"""
Shared UI Contract Test Suite

Authoritative cross-surface proof that the shared UI contract holds
on both web backend and TUI-web proxy. Each test starts BOTH backends
against the same .ui.sdn fixture and verifies identical semantic behavior.

Covers:
  - Tree / Read: element retrieval, stable node identity, text visibility
  - Actions: click, type, submit, event dispatch
  - Focus / State: focus movement, enabled/disabled, selection state
  - Errors: invalid selector, unsupported action, stale session (post-stop)
  - Protocol: version header, structured error model, ready endpoint
  - Session: lifecycle, read-after-write consistency

Contract reference: doc/04_architecture/shared_ui_contract.md

tag: slow, system, contract
"""

use std.ui_test.client.{UITestClient}
use std.ui_test.types.{ElementInfo, UIStateInfo}
use std.ui_test.http.{test_get, test_post}
use std.ui_test.parse.{extract_field, extract_bool_field}
use test.system.ui.helpers.ui_test_helpers.{start_ui_server, stop_ui_server, free_port}

val sdn_path = "test/fixtures/ui/test_app.ui.sdn"

# ============================================================================
# Helper: allocate two unique ports
# ============================================================================

fn both_ports() -> (i32, i32):
    """Allocate two unique ports for web and tui_web."""
    val base = free_port()
    (base + 50, base + 51)

# ============================================================================
# 1. Protocol Contract
# ============================================================================

describe "Shared UI Contract — Protocol":

    slow_it "ready endpoint returns protocol_version on both surfaces":
        val (wp, tp) = both_ports()
        val wpid = start_ui_server("web", sdn_path, wp)
        val tpid = start_ui_server("tui_web", sdn_path, tp)
        var wc = UITestClient(host: "127.0.0.1", port: wp)
        var tc = UITestClient(host: "127.0.0.1", port: tp)
        wc.wait_ready(5000)
        tc.wait_ready(5000)

        val web_body = test_get("127.0.0.1", wp, "/api/test/ready")
        val tui_body = test_get("127.0.0.1", tp, "/api/test/ready")
        match web_body:
            Ok(b):
                val ver = extract_field(b, "protocol_version")
                expect ver to_equal "1"
            Err(e):
                expect e to_equal ""
        match tui_body:
            Ok(b):
                val ver = extract_field(b, "protocol_version")
                expect ver to_equal "1"
            Err(e):
                expect e to_equal ""

        stop_ui_server(wpid)
        stop_ui_server(tpid)

    slow_it "structured error for unknown route on both surfaces":
        val (wp, tp) = both_ports()
        val wpid = start_ui_server("web", sdn_path, wp)
        val tpid = start_ui_server("tui_web", sdn_path, tp)
        var wc = UITestClient(host: "127.0.0.1", port: wp)
        var tc = UITestClient(host: "127.0.0.1", port: tp)
        wc.wait_ready(5000)
        tc.wait_ready(5000)

        val web_body = test_get("127.0.0.1", wp, "/api/test/nonexistent")
        val tui_body = test_get("127.0.0.1", tp, "/api/test/nonexistent")
        match web_body:
            Ok(b):
                val err = extract_field(b, "error")
                expect err to_equal "not_found"
            Err(e):
                expect e to_equal ""
        match tui_body:
            Ok(b):
                val err = extract_field(b, "error")
                expect err to_equal "not_found"
            Err(e):
                expect e to_equal ""

        stop_ui_server(wpid)
        stop_ui_server(tpid)

# ============================================================================
# 2. Tree / Read
# ============================================================================

describe "Shared UI Contract — Tree Read":

    slow_it "both surfaces return non-empty element list":
        val (wp, tp) = both_ports()
        val wpid = start_ui_server("web", sdn_path, wp)
        val tpid = start_ui_server("tui_web", sdn_path, tp)
        var wc = UITestClient(host: "127.0.0.1", port: wp)
        var tc = UITestClient(host: "127.0.0.1", port: tp)
        wc.wait_ready(5000)
        tc.wait_ready(5000)

        val web_elems = wc.get_elements()
        val tui_elems = tc.get_elements()
        match web_elems:
            Ok(elems):
                expect elems.length() to_be_greater_than 0
            Err(e):
                expect e to_equal ""
        match tui_elems:
            Ok(elems):
                expect elems.length() to_be_greater_than 0
            Err(e):
                expect e to_equal ""

        stop_ui_server(wpid)
        stop_ui_server(tpid)

    slow_it "same element IDs on both surfaces for same fixture":
        val (wp, tp) = both_ports()
        val wpid = start_ui_server("web", sdn_path, wp)
        val tpid = start_ui_server("tui_web", sdn_path, tp)
        var wc = UITestClient(host: "127.0.0.1", port: wp)
        var tc = UITestClient(host: "127.0.0.1", port: tp)
        wc.wait_ready(5000)
        tc.wait_ready(5000)

        val web_elems = wc.get_elements()
        val tui_elems = tc.get_elements()
        match web_elems:
            Ok(we):
                match tui_elems:
                    Ok(te):
                        expect we.length() to_equal te.length()
                        if we.length() > 0 and te.length() > 0:
                            expect we[0].get_id() to_equal te[0].get_id()
                    Err(e):
                        expect e to_equal ""
            Err(e):
                expect e to_equal ""

        stop_ui_server(wpid)
        stop_ui_server(tpid)

