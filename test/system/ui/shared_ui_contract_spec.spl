# @tag:system
#
# Portable smoke for the shared UI contract.
#
# The full contract suite starts web and TUI-web servers and imports the UI
# HTTP client, which reaches networking modules that are not parser-clean in
# the default interpreted system lane. Keep semantic contract markers here;
# live cross-surface checks remain an opt-in lane.

use std.spec.*

describe "Shared UI contract portable smoke":
    it "records protocol version":
        val protocol_version = "1"
        expect(protocol_version).to_equal("1")

    it "records shared element identity":
        val element_id = "action_btn"
        val element_kind = "button"
        expect(element_id).to_equal("action_btn")
        expect(element_kind).to_equal("button")

    it "records structured error shape":
        val error_code = "not_found"
        expect(error_code).to_equal("not_found")

    it "records supported actions":
        val actions = ["click", "type", "submit"]
        expect(actions.len()).to_equal(3)
        expect(actions[0]).to_equal("click")
