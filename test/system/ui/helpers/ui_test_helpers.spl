"""
UI Test Helpers

Shared helper functions for UI system tests. Provides server lifecycle
management (start/stop) and port allocation to avoid conflicts between
parallel test runs.

Components:
  - start_ui_server: Spawns a UI server process and waits for startup
  - stop_ui_server: Kills a running UI server process
  - free_port: Allocates a port based on PID to avoid conflicts
"""

extern fn rt_process_spawn_async(cmd: text, args: [text]) -> i64
extern fn rt_process_kill(pid: i64) -> bool
extern fn rt_thread_sleep(ms: i64)
extern fn rt_getpid() -> i64

fn start_ui_server(mode: text, sdn_file: text, port: i32) -> i64:
    """Spawn a UI server process in the background.

    Runs: bin/release/simple ui <mode> <sdn_file> --port <port>
    Waits 1500ms for server startup before returning.

    Args:
        mode: UI backend mode ("web" or "tui_web")
        sdn_file: Path to the .ui.sdn fixture file
        port: Port number for the server to listen on

    Returns:
        PID of the spawned server process
    """
    val args = ["ui", mode, sdn_file, "--port", "{port}"]
    val pid = rt_process_spawn_async("bin/release/simple", args)
    rt_thread_sleep(1500)
    return pid

fn stop_ui_server(pid: i64):
    """Kill a running UI server process.

    Args:
        pid: Process ID returned by start_ui_server
    """
    rt_process_kill(pid)

fn free_port() -> i32:
    """Allocate a unique port based on the current process ID.

    Uses PID modulo 1000 as an offset from base port 19000
    to avoid conflicts between parallel test runs.

    Returns:
        Port number in range 19000-19999
    """
    val base = 19000
    val pid = rt_getpid()
    val offset = pid % 1000
    return base + offset as i32
