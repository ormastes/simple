# @cover src/lib/nogc_sync_mut/ui_test/client.spl 80%
# @cover src/app/ui.web/server.spl 60%
"""
UI Interaction Specification

System test that verifies full interaction flows through the UI test API.
Tests keyboard navigation, element visibility/existence checks, text
content assertions, and drag operations.

tag: slow, system
"""

use std.ui_test.client.{UITestClient}
use std.ui_test.types.{ElementInfo, UIStateInfo}
use test.system.ui.helpers.ui_test_helpers.{start_ui_server, stop_ui_server, free_port}

val sdn_path = "test/fixtures/ui/test_app.ui.sdn"

# ============================================================================
# UI Interaction
# ============================================================================

describe "UI Interaction":

    slow_it "navigates with keyboard":
        val port = free_port() + 20
        val pid = start_ui_server("web", sdn_path, port)
        var client = UITestClient(host: "127.0.0.1", port: port)
        client.wait_ready(5000)
        val key_result = client.send_key("j")
        match key_result:
            Ok(ok):
                expect ok to_equal true
            Err(e):
                expect e to_equal ""
        stop_ui_server(pid)

    slow_it "checks element visibility":
        val port = free_port() + 21
        val pid = start_ui_server("web", sdn_path, port)
        var client = UITestClient(host: "127.0.0.1", port: port)
        client.wait_ready(5000)
        val visible_result = client.check_visible("action_btn")
        match visible_result:
            Ok(visible):
                expect visible to_equal true
            Err(e):
                expect e to_equal ""
        stop_ui_server(pid)

    slow_it "checks element existence":
        val port = free_port() + 22
        val pid = start_ui_server("web", sdn_path, port)
        var client = UITestClient(host: "127.0.0.1", port: port)
        client.wait_ready(5000)
        # Existing element
        val exists_result = client.check_exists("action_btn")
        match exists_result:
            Ok(exists):
                expect exists to_equal true
            Err(e):
                expect e to_equal ""
        # Non-existent element
        val missing_result = client.check_exists("nonexistent")
        match missing_result:
            Ok(exists):
                expect exists to_equal false
            Err(e):
                expect e to_equal ""
        stop_ui_server(pid)

    slow_it "check_text finds content":
        val port = free_port() + 23
        val pid = start_ui_server("web", sdn_path, port)
        var client = UITestClient(host: "127.0.0.1", port: port)
        client.wait_ready(5000)
        val text_result = client.check_text("status_label", "Ready")
        match text_result:
            Ok(found):
                expect found to_equal true
            Err(e):
                expect e to_equal ""
        stop_ui_server(pid)

    slow_it "drag between elements":
        val port = free_port() + 24
        val pid = start_ui_server("web", sdn_path, port)
        var client = UITestClient(host: "127.0.0.1", port: port)
        client.wait_ready(5000)
        val drag_result = client.drag("action_btn", "nav_list")
        match drag_result:
            Ok(ok):
                expect ok to_equal true
            Err(e):
                expect e to_equal ""
        stop_ui_server(pid)
