# @cover src/lib/common/ui/parse/sdn.spl 80%
# Demo UI Rendering Specification
#
# System test verifying that all 10 demo .ui.sdn files parse and render
# correctly via parse_ui_file. Each test asserts the result is Ok and
# the generated HTML contains expected content strings.

use common.ui.parse.sdn.{parse_ui_file}


# ============================================================================
# Demo UI Rendering
# ============================================================================

describe "Demo UI Rendering":

    it "renders demo_basics.ui.sdn":
        val result = parse_ui_file("examples/ui/demo_basics.ui.sdn")
        match result:
            case Ok(html):
                expect (html).contains("Basic Widgets Demo")
                expect (html).contains("Hello, Simple UI!")
                expect (html).contains("Welcome")
                expect (html).contains("Text Variants")
            case Err(msg):
                expect false == true

    it "renders demo_controls.ui.sdn":
        val result = parse_ui_file("examples/ui/demo_controls.ui.sdn")
        match result:
            case Ok(html):
                expect (html).contains("Interactive Controls Demo")
                expect (html).contains("Buttons")
                expect (html).contains("Checkboxes")
                expect (html).contains("Dropdown")
            case Err(msg):
                expect false == true

    it "renders demo_forms.ui.sdn":
        val result = parse_ui_file("examples/ui/demo_forms.ui.sdn")
        match result:
            case Ok(html):
                expect (html).contains("Form Inputs Demo")
                expect (html).contains("Text Inputs")
                expect (html).contains("Validation States")
                expect (html).contains("Text Areas")
            case Err(msg):
                expect false == true

    it "renders demo_collections.ui.sdn":
        val result = parse_ui_file("examples/ui/demo_collections.ui.sdn")
        match result:
            case Ok(html):
                expect (html).contains("Collections Demo")
                expect (html).contains("List")
                expect (html).contains("Table")
                expect (html).contains("File Browser")
            case Err(msg):
                expect false == true

    it "renders demo_navigation.ui.sdn":
        val result = parse_ui_file("examples/ui/demo_navigation.ui.sdn")
        match result:
            case Ok(html):
                expect (html).contains("Navigation Demo")
                expect (html).contains("menubar")
                expect (html).contains("Dashboard")
                expect (html).contains("Quick Stats")
            case Err(msg):
                expect false == true

    it "renders demo_display.ui.sdn":
        val result = parse_ui_file("examples/ui/demo_display.ui.sdn")
        match result:
            case Ok(html):
                expect (html).contains("Display Widgets Demo")
                expect (html).contains("progress")
                expect (html).contains("Progress Bars")
                expect (html).contains("Tooltip Example")
            case Err(msg):
                expect false == true

    it "renders demo_layouts.ui.sdn":
        val result = parse_ui_file("examples/ui/demo_layouts.ui.sdn")
        match result:
            case Ok(html):
                expect (html).contains("Layout Demo")
                expect (html).contains("hbox")
                expect (html).contains("Grid Layout")
                expect (html).contains("Deep Nesting")
            case Err(msg):
                expect false == true

    it "renders demo_overlays.ui.sdn":
        val result = parse_ui_file("examples/ui/demo_overlays.ui.sdn")
        match result:
            case Ok(html):
                expect (html).contains("Overlays Demo")
                expect (html).contains("Scroll Container")
                expect (html).contains("Log entry 1")
                expect (html).contains("Confirm Action")
            case Err(msg):
                expect false == true

    it "renders demo_themes.ui.sdn":
        val result = parse_ui_file("examples/ui/demo_themes.ui.sdn")
        match result:
            case Ok(html):
                expect (html).contains("Theme Showcase")
                expect (html).contains("Navigation")
                expect (html).contains("Widget Gallery")
            case Err(msg):
                expect false == true

    it "renders demo_kitchen_sink.ui.sdn":
        val result = parse_ui_file("examples/ui/demo_kitchen_sink.ui.sdn")
        match result:
            case Ok(html):
                expect (html).contains("Kitchen Sink")
                expect (html).contains("Sidebar")
                expect (html).contains("Main Content")
                expect (html).contains("Kitchen Sink Demo")
            case Err(msg):
                expect false == true