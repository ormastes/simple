"""
Unified UI Test API Specification

System test that verifies both web and tui_web backends produce equivalent
results through the test API. Starts both servers side by side and compares
their responses to ensure backend-agnostic behavior.

tag: slow, system
"""

use std.ui_test.client.{UITestClient}
use std.ui_test.types.{ElementInfo, UIStateInfo}
use test.system.ui.helpers.ui_test_helpers.{start_ui_server, stop_ui_server, free_port}

val sdn_path = "test/fixtures/ui/test_app.ui.sdn"

# ============================================================================
# Unified UI Test API
# ============================================================================

describe "Unified UI Test API":

    slow_it "both backends report ready":
        val web_port = free_port() + 30
        val tui_port = free_port() + 31
        val web_pid = start_ui_server("web", sdn_path, web_port)
        val tui_pid = start_ui_server("tui_web", sdn_path, tui_port)
        var web_client = UITestClient(host: "127.0.0.1", port: web_port)
        var tui_client = UITestClient(host: "127.0.0.1", port: tui_port)
        val web_ready = web_client.wait_ready(5000)
        val tui_ready = tui_client.wait_ready(5000)
        match web_ready:
            Ok(ready):
                expect ready to_equal true
            Err(e):
                expect e to_equal ""
        match tui_ready:
            Ok(ready):
                expect ready to_equal true
            Err(e):
                expect e to_equal ""
        stop_ui_server(web_pid)
        stop_ui_server(tui_pid)

    slow_it "both backends return elements":
        val web_port = free_port() + 32
        val tui_port = free_port() + 33
        val web_pid = start_ui_server("web", sdn_path, web_port)
        val tui_pid = start_ui_server("tui_web", sdn_path, tui_port)
        var web_client = UITestClient(host: "127.0.0.1", port: web_port)
        var tui_client = UITestClient(host: "127.0.0.1", port: tui_port)
        web_client.wait_ready(5000)
        tui_client.wait_ready(5000)
        val web_elems = web_client.get_elements()
        val tui_elems = tui_client.get_elements()
        match web_elems:
            Ok(elems):
                expect elems.length() to_be_greater_than 0
            Err(e):
                expect e to_equal ""
        match tui_elems:
            Ok(elems):
                expect elems.length() to_be_greater_than 0
            Err(e):
                expect e to_equal ""
        stop_ui_server(web_pid)
        stop_ui_server(tui_pid)

    slow_it "both backends support click":
        val web_port = free_port() + 34
        val tui_port = free_port() + 35
        val web_pid = start_ui_server("web", sdn_path, web_port)
        val tui_pid = start_ui_server("tui_web", sdn_path, tui_port)
        var web_client = UITestClient(host: "127.0.0.1", port: web_port)
        var tui_client = UITestClient(host: "127.0.0.1", port: tui_port)
        web_client.wait_ready(5000)
        tui_client.wait_ready(5000)
        val web_click = web_client.click("action_btn")
        val tui_click = tui_client.click("action_btn")
        match web_click:
            Ok(ok):
                expect ok to_equal true
            Err(e):
                expect e to_equal ""
        match tui_click:
            Ok(ok):
                expect ok to_equal true
            Err(e):
                expect e to_equal ""
        stop_ui_server(web_pid)
        stop_ui_server(tui_pid)
