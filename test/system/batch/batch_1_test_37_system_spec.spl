# @cover src/lib/nogc_sync_mut/spec/mod.spl 60%
# @cover src/compiler/80.driver/pipeline.spl 60%
"""
# System Test Batch

**Feature IDs:** #SYS
**Category:** Testing
**Status:** Implemented
"""

use std.spec

fn verify(condition: bool):
    expect(condition).to_equal(true)

describe "System Test":
    slow_it "test 1":
        verify(1 + 1 == 2)
    slow_it "test 2":
        verify("a" == "a")
    slow_it "test 3":
        val x = 5
        verify(x > 0)
    slow_it "test 4":
        val arr = [1, 2, 3]
        verify(arr.len() == 3)
    slow_it "test 5":
        for i in 0..10:
            verify(i >= 0)
    slow_it "test 6":
        val opt = Some(42)
        verify(opt.?)
    slow_it "test 7":
        match Some(1):
            Some(x): verify(x == 1)
            nil: verify(false)
    slow_it "test 8":
        if true:
            verify(true)
        else:
            verify(false)
    slow_it "test 9":
        val d = {"k": "v"}
        verify(d["k"] == "v")
    slow_it "test 10":
        var sum = 0
        for i in 0..5:
            sum = sum + i
        verify(sum == 10)
