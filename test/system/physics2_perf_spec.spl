use std.io_runtime
use std.spec.{describe, it, expect}
use std.nogc_sync_mut.engine.physics2.broadphase.bvh2d.{DynamicBvh2D, AABB2D}

fn insert_grid(bvh: DynamicBvh2D, count: i64, spacing: f64) -> i64:
    var i = 0
    while i < count:
        val row = i / 20
        val col = i % 20
        val x = (col as f64) * spacing
        val y = (row as f64) * spacing
        val aabb = AABB2D(min_x: x, min_y: y, max_x: x + 1.0, max_y: y + 1.0)
        bvh.insert(aabb, i)
        i = i + 1
    count

fn insert_cluster(bvh: DynamicBvh2D, count: i64) -> i64:
    var i = 0
    while i < count:
        val offset = (i as f64) * 0.1
        val aabb = AABB2D(min_x: offset, min_y: offset, max_x: offset + 2.0, max_y: offset + 2.0)
        bvh.insert(aabb, i)
        i = i + 1
    count

describe "Physics2 BVH Performance":
    it "BVH inserts 200 bodies without crash":
        var bvh = DynamicBvh2D.create(0.1)
        insert_grid(bvh, 200, 10.0)
        expect(bvh.node_count > 0).to_equal(true)

    it "scattered bodies produce few pairs":
        var bvh = DynamicBvh2D.create(0.1)
        insert_grid(bvh, 200, 10.0)
        val pairs = bvh.query_all_pairs()
        expect(pairs.len()).to_equal(0)

    it "clustered bodies produce many pairs":
        var bvh = DynamicBvh2D.create(0.1)
        insert_cluster(bvh, 50)
        val pairs = bvh.query_all_pairs()
        expect(pairs.len() > 100).to_equal(true)

    it "pair count below N squared":
        var bvh = DynamicBvh2D.create(0.1)
        insert_grid(bvh, 100, 3.0)
        val pairs = bvh.query_all_pairs()
        val limit = 100 * 100 / 2
        expect(pairs.len() < limit).to_equal(true)
