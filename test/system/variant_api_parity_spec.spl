# ============================================================================
# 1. CUDA Module Parity
# ============================================================================

describe "CUDA Module API Parity":
    """
    ## CUDA Module

    Verifies all 3 variants export the same CUDA API.
    CUDA is the lowest-level shared module and should be identical.
    """

    # @scenario SC-001
    it "all variants export cuda_available()":
        # All 3 variants should resolve the cuda_available function
        val gc = gc_cuda_avail()
        val nogc_async = nogc_async_cuda_avail()
        val nogc_sync = nogc_sync_cuda_avail()
        # All should return the same value (hardware-dependent but consistent)
        expect(gc).to_equal(nogc_async)
        expect(gc).to_equal(nogc_sync)


# ============================================================================
# 2. Torch Module Parity - Tensor Class
# ============================================================================

describe "Torch Tensor API Parity":
    """
    ## Torch Tensor

    Verifies all 3 variants expose the same Tensor methods.
    GAP-1: gc_async_mut Tensor should use direct FFI for sub/div/clone.
    """

    # @scenario SC-002
    it "all variants export torch_available() and torch_version()":
        val gc_avail = gc_torch_available()
        val nogc_async_avail = nogc_async_torch_available()
        val nogc_sync_avail = nogc_sync_torch_available()
        expect(gc_avail).to_equal(nogc_async_avail)
        expect(gc_avail).to_equal(nogc_sync_avail)

    # @scenario SC-003
    context "when torch is available":
        it "gc_async_mut Tensor has sub() method":
            # GAP-1: After fix, sub() should use direct FFI
            # This test verifies the method exists and is callable
            if gc_torch_available():
                val t1 = GcTensor.ones([2, 3])
                val t2 = GcTensor.ones([2, 3])
                val result = t1.sub(t2)
                expect(result.ndim()).to_equal(2)

        it "gc_async_mut Tensor has div() method":
            if gc_torch_available():
                val t1 = GcTensor.ones([2, 3])
                val t2 = GcTensor.ones([2, 3])
                val result = t1.div(t2)
                expect(result.ndim()).to_equal(2)

        it "gc_async_mut Tensor has clone() method":
            if gc_torch_available():
                val t1 = GcTensor.ones([2, 3])
                val t2 = t1.clone()
                expect(t2.ndim()).to_equal(2)

        it "nogc_async_mut Tensor has sub() method":
            if nogc_async_torch_available():
                val t1 = NogcAsyncTensor.ones([2, 3])
                val t2 = NogcAsyncTensor.ones([2, 3])
                val result = t1.sub(t2)
                expect(result.ndim()).to_equal(2)

        it "nogc_sync_mut Tensor has sub() method":
            if nogc_sync_torch_available():
                val t1 = NogcSyncTensor.ones([2, 3])
                val t2 = NogcSyncTensor.ones([2, 3])
                val result = t1.sub(t2)
                expect(result.ndim()).to_equal(2)


