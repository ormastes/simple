# ============================================================================
# 7. GPU Device Parity
# ============================================================================

describe "GPU Device API Parity":
    """
    ## GPU Device

    All variants should export GpuBackend, Gpu, detect_backends, gpu_none.
    """

    # @scenario SC-012
    it "all variants export detect_backends()":
        val gc = gc_detect_backends()
        val nogc_async = nogc_async_detect_backends()
        val nogc_sync = nogc_sync_detect_backends()
        expect(gc.len()).to_equal(nogc_async.len())
        expect(gc.len()).to_equal(nogc_sync.len())

    # @scenario SC-013
    it "all variants export gpu_none()":
        val gc = gc_gpu_none()
        val nogc_async = nogc_async_gpu_none()
        val nogc_sync = nogc_sync_gpu_none()
        # All should create a CPU fallback Gpu handle
        expect(true).to_equal(true)


# ============================================================================
# 8. GPU Context Parity
# ============================================================================

describe "GPU Context API Parity":
    """
    ## GPU Context

    GAP-3: is_valid() and default_context() should exist in all variants.
    GAP-4: launch() should exist in all variants.
    """

    # @scenario SC-014
    it "nogc_sync_mut Context has is_valid() method":
        val ctx = NogcSyncContext.default()
        val valid = ctx.is_valid()
        expect(valid).to_equal(false)  # None_ backend, not valid

    it "gc_async_mut Context has is_valid() method":
        val ctx = GcContext.default()
        val valid = ctx.is_valid()
        expect(valid).to_equal(false)

    it "nogc_async_mut Context has is_valid() method":
        val ctx = NogcAsyncContext.default()
        val valid = ctx.is_valid()
        expect(valid).to_equal(false)

    # @scenario SC-017 (GAP-4: kernel launch types)
    it "nogc_async_mut exports GpuModule, GpuLaunchConfig, GpuError":
        # Import-level check: if we got here, the types resolved
        val config = NogcAsyncGpuLaunchConfig.simple(4, 256)
        expect(config.total_threads()).to_equal(1024)

    it "nogc_sync_mut exports GpuModule, GpuLaunchConfig, GpuError":
        val config = NogcSyncGpuLaunchConfig.simple(4, 256)
        expect(config.total_threads()).to_equal(1024)

    it "GpuLaunchConfig.grid_2d works across variants":
        val config = NogcAsyncGpuLaunchConfig.grid_2d(2, 3, 16, 16)
        expect(config.total_threads()).to_equal(2 * 3 * 16 * 16)


