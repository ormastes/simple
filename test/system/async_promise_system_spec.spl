# tag: slow, system

# ============================================================
# Inline Stubs - Minimal but functional async primitives
# ============================================================

enum PromiseState:
    Pending
    Resolved(value)
    Rejected(error)

class Promise:
    state: PromiseState
    callbacks: List

    me resolve(value):
        self.state = PromiseState.Resolved(value)
        for cb in self.callbacks:
            cb(value)

    me reject(error):
        self.state = PromiseState.Rejected(error)

    me then(callback) -> Promise:
        var next = Promise(state: PromiseState.Pending, callbacks: [])
        var handler = \val:
            var result = callback(val)
            next.resolve(result)
        if val PromiseState.Resolved(v) = self.state:
            handler(v)
        else:
            self.callbacks.push(handler)
        return next

    fn is_resolved() -> bool:
        if val PromiseState.Resolved(_) = self.state:
            return true
        return false

    fn is_rejected() -> bool:
        if val PromiseState.Rejected(_) = self.state:
            return true
        return false

    fn value():
        if val PromiseState.Resolved(v) = self.state:
            return v
        return nil

    fn error() -> text:
        if val PromiseState.Rejected(e) = self.state:
            return e
        return ""

enum FutureState:
    Pending
    Ready(value)
    Failed(error)

class SimpleFuture:
    state: FutureState

    static fn ready(value) -> SimpleFuture:
        return SimpleFuture(state: FutureState.Ready(value))

    static fn pending() -> SimpleFuture:
        return SimpleFuture(state: FutureState.Pending)

    static fn failed(error) -> SimpleFuture:
        return SimpleFuture(state: FutureState.Failed(error))

    me complete(value):
        self.state = FutureState.Ready(value)

    me fail(error):
        self.state = FutureState.Failed(error)

    fn is_ready() -> bool:
        if val FutureState.Ready(_) = self.state:
            return true
        return false

    fn is_failed() -> bool:
        if val FutureState.Failed(_) = self.state:
            return true
        return false

    fn value():
        if val FutureState.Ready(v) = self.state:
            return v
        return nil

    fn error() -> text:
        if val FutureState.Failed(e) = self.state:
            return e
        return ""

enum TaskState:
    Queued
    Running
    Done(result)

class Task:
    id: i64
    work: fn()
    state: TaskState

    me run():
        self.state = TaskState.Running
        var work_fn = self.work
        var result = work_fn()
        self.state = TaskState.Done(result)
        return result

class Executor:
    tasks: List
    results: List

    me spawn(id: i64, work):
        var task = Task(id: id, work: work, state: TaskState.Queued)
        self.tasks.push(task)

    me run_all():
        for task in self.tasks:
            var result = task.run()
            self.results.push(result)

    fn task_count() -> i64:
        return self.tasks.length()

    fn all_done() -> bool:
        for task in self.tasks:
            if val TaskState.Done(_) = task.state:
                pass_dn
            else:
                return false
        return true

class Channel:
    buffer: List
    closed: bool

    me send(value):
        if self.closed:
            return
        self.buffer.push(value)

    me receive():
        if self.buffer.length() == 0:
            return nil
        var item = self.buffer[0]
        # Manual removal of first element by rebuilding array
        var new_buffer = []
        var i = 1
        while i < self.buffer.length():
            new_buffer.push(self.buffer[i])
            i = i + 1
        self.buffer = new_buffer
        return item

    fn is_empty() -> bool:
        return self.buffer.length() == 0

    fn size() -> i64:
        return self.buffer.length()

    me close():
        self.closed = true

    me drain_all() -> List:
        var items = []
        while self.buffer.length() > 0:
            var item = self.buffer[0]
            var new_buffer = []
            var i = 1
            while i < self.buffer.length():
                new_buffer.push(self.buffer[i])
                i = i + 1
            self.buffer = new_buffer
            items.push(item)
        return items

class Generator:
    current: i64
    max: i64
    transform: fn(i64)

    static fn range(start: i64, end: i64) -> Generator:
        return Generator(current: start, max: end, transform: \x: return x)

    static fn range_with(start: i64, end: i64, transform) -> Generator:
        return Generator(current: start, max: end, transform: transform)

    fn has_next() -> bool:
        return self.current < self.max

    me next():
        if self.current >= self.max:
            return nil
        var tf = self.transform
        var val = tf(self.current)
        self.current = self.current + 1
        return val

    me collect() -> List:
        var items = []
        while self.has_next():
            items.push(self.next())
        return items

class WorkStealingQueue:
    queues: List

    static fn new(num_workers: i64) -> WorkStealingQueue:
        var qs = []
        var i = 0
        while i < num_workers:
            qs.push([])
            i = i + 1
        return WorkStealingQueue(queues: qs)

    me push(worker_id: i64, task):
        self.queues[worker_id].push(task)

    me pop(worker_id: i64):
        var q = self.queues[worker_id]
        if q.length() == 0:
            return nil
        var item = q[q.length() - 1]
        # Remove last element
        var new_q = []
        var i = 0
        while i < q.length() - 1:
            new_q.push(q[i])
            i = i + 1
        self.queues[worker_id] = new_q
        return item

    me steal(from_id: i64):
        var q = self.queues[from_id]
        if q.length() == 0:
            return nil
        var item = q[0]
        # Remove first element
        var new_q = []
        var i = 1
        while i < q.length():
            new_q.push(q[i])
            i = i + 1
        self.queues[from_id] = new_q
        return item

    fn total_tasks() -> i64:
        var count = 0
        for q in self.queues:
            count = count + q.length()
        return count

# ============================================================
# Combinators
# ============================================================

fn join_all(futures) -> SimpleFuture:
    var results = []
    for f in futures:
        if f.is_failed():
            return SimpleFuture.failed(f.error())
        results.push(f.value())
    return SimpleFuture.ready(results)

fn select_first(futures) -> SimpleFuture:
    for f in futures:
        if f.is_ready():
            return f
    for f in futures:
        if f.is_failed():
            return f
    return SimpleFuture.pending()

# ============================================================
# Test Suites
# ============================================================

describe "Promise-to-Future Pipeline":
    it "should flow data from promise resolution through to future completion":
        var p = Promise(state: PromiseState.Pending, callbacks: [])
        var future = SimpleFuture.pending()

        p.resolve(42)
        expect(p.is_resolved()).to_equal(true)

        var val = p.value()
        future.complete(val)
        expect(future.is_ready()).to_equal(true)
        expect(future.value()).to_equal(42)

    it "should propagate transformed data through promise-then into a future":
        var p = Promise(state: PromiseState.Pending, callbacks: [])
        var future = SimpleFuture.pending()

        var chained = p.then(\v: return v * 2)
        p.resolve(10)

        expect(chained.is_resolved()).to_equal(true)
        future.complete(chained.value())
        expect(future.value()).to_equal(20)

describe "Executor Running Promise Tasks":
    it "should spawn and run multiple promise-creating tasks to completion":
        var exec = Executor(tasks: [], results: [])
        var results_holder = []

        exec.spawn(1, \:
            var p = Promise(state: PromiseState.Pending, callbacks: [])
            p.resolve("task1-done")
            return p.value()
        )
        exec.spawn(2, \:
            var p = Promise(state: PromiseState.Pending, callbacks: [])
            p.resolve("task2-done")
            return p.value()
        )
        exec.spawn(3, \:
            var p = Promise(state: PromiseState.Pending, callbacks: [])
            p.resolve("task3-done")
            return p.value()
        )

        exec.run_all()
        expect(exec.all_done()).to_equal(true)
        expect(exec.results.length()).to_equal(3)
        expect(exec.results[0]).to_equal("task1-done")
        expect(exec.results[1]).to_equal("task2-done")
        expect(exec.results[2]).to_equal("task3-done")

    it "should correctly track task count after spawning":
        var exec = Executor(tasks: [], results: [])
        exec.spawn(1, \: return 1)
        exec.spawn(2, \: return 2)
        expect(exec.task_count()).to_equal(2)
        exec.run_all()
        expect(exec.all_done()).to_equal(true)

describe "Channel Producer-Consumer":
    it "should deliver all messages from producer to consumer in order":
        var ch = Channel(buffer: [], closed: false)

        # Producer
        var i = 0
        while i < 5:
            ch.send(i * 10)
            i = i + 1

        expect(ch.size()).to_equal(5)

        # Consumer
        var received = ch.drain_all()
        expect(received.length()).to_equal(5)
        expect(received[0]).to_equal(0)
        expect(received[1]).to_equal(10)
        expect(received[2]).to_equal(20)
        expect(received[3]).to_equal(30)
        expect(received[4]).to_equal(40)

    it "should return nil when receiving from empty channel":
        var ch = Channel(buffer: [], closed: false)
        var result = ch.receive()
        expect(result).to_be_nil()

    it "should stop accepting messages after channel is closed":
        var ch = Channel(buffer: [], closed: false)
        ch.send("before")
        ch.close()
        ch.send("after")
        expect(ch.size()).to_equal(1)
        expect(ch.receive()).to_equal("before")

describe "Future Combinator Workflows":
    it "should join all ready futures into a single result list":
        var f1 = SimpleFuture.ready(10)
        var f2 = SimpleFuture.ready(20)
        var f3 = SimpleFuture.ready(30)

        var joined = join_all([f1, f2, f3])
        expect(joined.is_ready()).to_equal(true)
        var vals = joined.value()
        expect(vals.length()).to_equal(3)
        expect(vals[0]).to_equal(10)
        expect(vals[1]).to_equal(20)
        expect(vals[2]).to_equal(30)

    it "should select the first ready future from a mixed set":
        var f1 = SimpleFuture.pending()
        var f2 = SimpleFuture.ready("winner")
        var f3 = SimpleFuture.pending()

        var selected = select_first([f1, f2, f3])
        expect(selected.is_ready()).to_equal(true)
        expect(selected.value()).to_equal("winner")

describe "Generator-to-Channel Pipeline":
    it "should pipe generator output through channel and preserve sequence":
        var gen = Generator.range(start: 0, end: 5)
        var ch = Channel(buffer: [], closed: false)

        while gen.has_next():
            ch.send(gen.next())

        expect(ch.size()).to_equal(5)
        var items = ch.drain_all()
        expect(items[0]).to_equal(0)
        expect(items[1]).to_equal(1)
        expect(items[2]).to_equal(2)
        expect(items[3]).to_equal(3)
        expect(items[4]).to_equal(4)

    it "should apply transform in generator before sending to channel":
        var gen = Generator.range_with(start: 1, end: 4, transform: \x: return x * x)
        var ch = Channel(buffer: [], closed: false)

        while gen.has_next():
            ch.send(gen.next())

        var items = ch.drain_all()
        expect(items.length()).to_equal(3)
        expect(items[0]).to_equal(1)
        expect(items[1]).to_equal(4)
        expect(items[2]).to_equal(9)

describe "Error Propagation Through Pipeline":
    it "should propagate rejection from promise through future to combinator":
        var p = Promise(state: PromiseState.Pending, callbacks: [])
        p.reject("upstream failure")
        expect(p.is_rejected()).to_equal(true)

        var future = SimpleFuture.failed(p.error())
        expect(future.is_failed()).to_equal(true)
        expect(future.error()).to_equal("upstream failure")

        var f_ok = SimpleFuture.ready(100)
        var joined = join_all([f_ok, future])
        expect(joined.is_failed()).to_equal(true)
        expect(joined.error()).to_equal("upstream failure")

describe "Work-Stealing Task Distribution":
    it "should distribute and steal tasks across worker queues":
        var wsq = WorkStealingQueue.new(num_workers: 3)

        # Push tasks to worker 0
        var results = []
        wsq.push(0, \: return "a")
        wsq.push(0, \: return "b")
        wsq.push(0, \: return "c")
        wsq.push(1, \: return "d")

        expect(wsq.total_tasks()).to_equal(4)

        # Worker 2 steals from worker 0 (takes from front)
        var stolen = wsq.steal(from_id: 0)
        var stolen_result = stolen()
        results.push(stolen_result)
        expect(results[0]).to_equal("a")

        # Worker 0 pops from own queue (takes from back)
        var own = wsq.pop(worker_id: 0)
        var own_result = own()
        results.push(own_result)
        expect(results[1]).to_equal("c")

        expect(wsq.total_tasks()).to_equal(2)

describe "Chained Async Operations":
    it "should chain multiple then callbacks and produce correct final result":
        var p = Promise(state: PromiseState.Pending, callbacks: [])

        var step1 = p.then(\v: return v + 10)
        var step2 = step1.then(\v: return v * 2)
        var step3 = step2.then(\v: return "result:" + v.to_string())

        p.resolve(5)

        expect(step1.is_resolved()).to_equal(true)
        expect(step1.value()).to_equal(15)
        expect(step2.is_resolved()).to_equal(true)
        expect(step2.value()).to_equal(30)
        expect(step3.is_resolved()).to_equal(true)
        expect(step3.value()).to_equal("result:30")

describe "Mixed Ready and Pending Futures":
    it "should handle join_all with all ready futures":
        var futures = [
            SimpleFuture.ready("a"),
            SimpleFuture.ready("b"),
            SimpleFuture.ready("c")
        ]
        var joined = join_all(futures)
        expect(joined.is_ready()).to_equal(true)
        var vals = joined.value()
        expect(vals.length()).to_equal(3)

    it "should select first ready from mixed ready/pending set":
        var futures = [
            SimpleFuture.pending(),
            SimpleFuture.pending(),
            SimpleFuture.ready(99),
            SimpleFuture.pending()
        ]
        var result = select_first(futures)
        expect(result.is_ready()).to_equal(true)
        expect(result.value()).to_equal(99)

    it "should return pending when no futures are ready":
        var futures = [
            SimpleFuture.pending(),
            SimpleFuture.pending()
        ]
        var result = select_first(futures)
        expect(result.is_ready()).to_equal(false)

describe "Full Async Runtime Simulation":
    it "should run a complete pipeline with executor, promises, futures, and channel":
        var exec = Executor(tasks: [], results: [])
        var ch = Channel(buffer: [], closed: false)

        # Spawn tasks that create promises, resolve them, and send to channel
        exec.spawn(1, \:
            var p = Promise(state: PromiseState.Pending, callbacks: [])
            p.resolve(100)
            ch.send(p.value())
            return p.value()
        )
        exec.spawn(2, \:
            var p = Promise(state: PromiseState.Pending, callbacks: [])
            p.resolve(200)
            ch.send(p.value())
            return p.value()
        )
        exec.spawn(3, \:
            var p = Promise(state: PromiseState.Pending, callbacks: [])
            p.resolve(300)
            ch.send(p.value())
            return p.value()
        )

        exec.run_all()
        expect(exec.all_done()).to_equal(true)

        # Collect channel results into futures
        var futures = []
        while ch.is_empty() == false:
            var val = ch.receive()
            futures.push(SimpleFuture.ready(val))

        expect(futures.length()).to_equal(3)

        # Join all futures
        var joined = join_all(futures)
        expect(joined.is_ready()).to_equal(true)
        var final_vals = joined.value()
        expect(final_vals[0]).to_equal(100)
        expect(final_vals[1]).to_equal(200)
        expect(final_vals[2]).to_equal(300)

        # Verify total sum via generator-style accumulation
        var total = 0
        for v in final_vals:
            total = total + v
        expect(total).to_equal(600)
