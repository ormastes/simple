#![allow(spipe_boolean_wrapper_assertions)]
@allow(spipe_empty_examples)
@allow(spipe_boolean_wrapper_assertions)


# === spipe inline helpers (R2-broader fix; compile-mode only) ===
fn pending(name: text):
    print "    {name} ... pending"

fn skip(name: text, reason: text):
    print "    {name} ... skipped ({reason})"

fn skip_it(name: text, block: fn()):
    print "    {name} ... skipped (compiled-only)"

fn check(condition: bool):
    expect condition

fn check_msg(condition: bool, message: text):
    if not condition:
        print "    check failed: {message}"
    expect condition

fn fail_assertion(message: text):
    print "    assertion failed: {message}"
    expect false

fn fail_test(message: text):
    fail_assertion(message)

fn assert_eq(a, b):
    expect a == b

fn assert_ne(a, b):
    expect a != b

fn assert_true(value):
    expect value

fn assert_false(value):
    expect not value

fn assert_nil(value):
    expect value == nil

fn assert_not_nil(value):
    expect value != nil

fn pending_on(name: text, deps: text, block: fn()):
    it(name, block)

fn pending_skip(name: text, deps: text):
    print "    {name} ... pending (waiting on: {deps})"
# === end spipe inline helpers ===

enum PromiseState:
    Pending
    Resolved(value)
    Rejected(error)

impl PromiseState:
    fn is_pending() -> bool:
        match self:
            case Pending: true
            case _: false

    fn is_resolved() -> bool:
        match self:
            case Resolved(_): true
            case _: false

    fn is_rejected() -> bool:
        match self:
            case Rejected(_): true
            case _: false

class Promise:
    state: PromiseState

    fn is_pending() -> bool:
        return self.state.is_pending()

    fn is_resolved() -> bool:
        return self.state.is_resolved()

    fn is_rejected() -> bool:
        return self.state.is_rejected()

    fn value():
        if val PromiseState.Resolved(v) = self.state:
            return v
        return nil

    fn error() -> text:
        if val PromiseState.Rejected(e) = self.state:
            return e
        return ""

    me resolve(value):
        self.state = PromiseState.Resolved(value)

    me reject(error):
        self.state = PromiseState.Rejected(error)

enum FutureState:
    Pending
    Ready(value)
    Failed(error)

impl FutureState:
    fn is_pending() -> bool:
        match self:
            case Pending: true
            case _: false

    fn is_ready() -> bool:
        match self:
            case Ready(_): true
            case _: false

    fn is_failed() -> bool:
        match self:
            case Failed(_): true
            case _: false

class SimpleFuture:
    state: FutureState

    fn is_ready() -> bool:
        return self.state.is_ready()

    fn is_failed() -> bool:
        return self.state.is_failed()

    fn is_pending() -> bool:
        return self.state.is_pending()

    fn value():
        if val FutureState.Ready(v) = self.state:
            return v
        return nil

    fn error() -> text:
        if val FutureState.Failed(e) = self.state:
            return e
        return ""

    me complete(value):
        self.state = FutureState.Ready(value)

    me fail(error):
        self.state = FutureState.Failed(error)

fn future_ready(value) -> SimpleFuture:
    return SimpleFuture(state: FutureState.Ready(value))

fn future_pending() -> SimpleFuture:
    return SimpleFuture(state: FutureState.Pending)

fn future_failed(error) -> SimpleFuture:
    return SimpleFuture(state: FutureState.Failed(error))

class Channel:
    buffer: [i64]
    closed: bool
    count: i64

    me send(value):
        if self.closed:
            return
        self.buffer = self.buffer + [value]
        self.count = self.count + 1

    me receive():
        if self.count == 0:
            return nil
        var item = self.buffer[0]
        var new_buffer: [i64] = []
        var i = 1
        while i < self.count:
            new_buffer = new_buffer + [self.buffer[i]]
            i = i + 1
        self.buffer = new_buffer
        self.count = self.count - 1
        return item

    fn is_empty() -> bool:
        return self.count == 0

    fn size() -> i64:
        return self.count

    me close():
        self.closed = true

class TextChannel:
    buffer: [text]
    closed: bool
    count: i64

    me send(value):
        if self.closed:
            return
        self.buffer = self.buffer + [value]
        self.count = self.count + 1

    me receive():
        if self.count == 0:
            return nil
        var item = self.buffer[0]
        var new_buffer: [text] = []
        var i = 1
        while i < self.count:
            new_buffer = new_buffer + [self.buffer[i]]
            i = i + 1
        self.buffer = new_buffer
        self.count = self.count - 1
        return item

    fn is_empty() -> bool:
        return self.count == 0

    fn size() -> i64:
        return self.count

    me close():
        self.closed = true

class WorkStealingQueue:
    q0: [i64]
    q1: [i64]
    q2: [i64]

    me push(worker_id: i64, task: i64):
        if worker_id == 0:
            self.q0 = self.q0 + [task]
        if worker_id == 1:
            self.q1 = self.q1 + [task]
        if worker_id == 2:
            self.q2 = self.q2 + [task]

    me pop(worker_id: i64):
        if worker_id == 0:
            if self.q0.len() == 0:
                return nil
            var item = self.q0[self.q0.len() - 1]
            var new_q: [i64] = []
            var i = 0
            while i < self.q0.len() - 1:
                new_q = new_q + [self.q0[i]]
                i = i + 1
            self.q0 = new_q
            return item
        if worker_id == 1:
            if self.q1.len() == 0:
                return nil
            var item = self.q1[self.q1.len() - 1]
            var new_q: [i64] = []
            var i = 0
            while i < self.q1.len() - 1:
                new_q = new_q + [self.q1[i]]
                i = i + 1
            self.q1 = new_q
            return item
        if self.q2.len() == 0:
            return nil
        var item = self.q2[self.q2.len() - 1]
        var new_q: [i64] = []
        var i = 0
        while i < self.q2.len() - 1:
            new_q = new_q + [self.q2[i]]
            i = i + 1
        self.q2 = new_q
        return item

    me steal(from_id: i64):
        if from_id == 0:
            if self.q0.len() == 0:
                return nil
            var item = self.q0[0]
            var new_q: [i64] = []
            var i = 1
            while i < self.q0.len():
                new_q = new_q + [self.q0[i]]
                i = i + 1
            self.q0 = new_q
            return item
        if from_id == 1:
            if self.q1.len() == 0:
                return nil
            var item = self.q1[0]
            var new_q: [i64] = []
            var i = 1
            while i < self.q1.len():
                new_q = new_q + [self.q1[i]]
                i = i + 1
            self.q1 = new_q
            return item
        if self.q2.len() == 0:
            return nil
        var item = self.q2[0]
        var new_q: [i64] = []
        var i = 1
        while i < self.q2.len():
            new_q = new_q + [self.q2[i]]
            i = i + 1
        self.q2 = new_q
        return item

    fn total_tasks() -> i64:
        return self.q0.len() + self.q1.len() + self.q2.len()

fn join_all_futures(futures) -> SimpleFuture:
    var results = []
    for f in futures:
        if f.is_failed():
            return future_failed(f.error())
        results = results + [f.value()]
    return future_ready(results)

fn select_first_future(futures) -> SimpleFuture:
    for f in futures:
        if f.is_ready():
            return f
    for f in futures:
        if f.is_failed():
            return f
    return future_pending()

fn main():
    # @cover src/lib/nogc_async_mut/async/mod.spl 80%
    """
    # Async/Promise System Tests
    
    **Feature IDs:** #RT-020
    **Category:** Runtime
    **Difficulty:** 3/5
    **Status:** In Progress
    **Requirements:** doc/requirement/async_promise_intensive_tests.md
    **Plan:** doc/03_plan/async_promise_intensive_tests.md
    **Design:** doc/05_design/async_promise_intensive_tests.md
    
    ## Overview
    End-to-end system tests verifying complete async workflows combining
    promises, futures, channels, combinators, and work-stealing queues.
    These tests verify components work together, not in isolation.
    """

    # tag: slow, system

    # ============================================================
    # Inline Stubs - Minimal but functional async primitives
    # No function-typed fields — all logic is inline or via named fns
    # ============================================================

    # ============================================================

    # Helper constructors for SimpleFuture
    # ============================================================

    # Channel that holds any type (text variant)
    # ============================================================

    # ============================================================
    # Combinators — free functions, no stored callbacks
    # ============================================================

    # ============================================================
    # Test Suites
    # ============================================================

    describe "Promise Creation and Resolution":
        it "should create a pending promise and resolve it":
            var p = Promise(state: PromiseState.Pending)
            expect p.is_pending() == true
            expect p.is_resolved() == false

            p.resolve(42)
            expect p.is_resolved() == true
            expect p.is_pending() == false
            expect p.value() == 42

        it "should create a pending promise and reject it":
            var p = Promise(state: PromiseState.Pending)
            p.reject("something went wrong")
            expect p.is_rejected() == true
            expect p.error() == "something went wrong"

    describe "Promise-to-Future Data Flow":
        it "should flow data from promise resolution through to future completion":
            var p = Promise(state: PromiseState.Resolved(42))
            var future = future_pending()

            expect p.is_resolved() == true
            match p.state:
                case Resolved(v):
                    future.complete(v)
                case _:
                    expect "promise should already be resolved" == ""
            expect future.is_ready() == true
            expect future.value() == 42

        it "should flow rejection from promise to failed future":
            var p = Promise(state: PromiseState.Pending)
            p.reject("upstream error")

            var future = future_failed(p.error())
            expect future.is_failed() == true
            expect future.error() == "upstream error"

    describe "Channel Producer-Consumer":
        it "should deliver all messages from producer to consumer in order":
            var ch = Channel(buffer: [0, 10, 20, 30, 40], closed: false, count: 5)

            expect ch.size() == 5

            var r0 = ch.receive()
            var r1 = ch.receive()
            var r2 = ch.receive()
            var r3 = ch.receive()
            var r4 = ch.receive()
            expect r0 == 0
            expect r1 == 10
            expect r2 == 20
            expect r3 == 30
            expect r4 == 40
            expect ch.is_empty() == true

        it "should return nil when receiving from empty channel":
            var ch = Channel(buffer: [], closed: false, count: 0)
            var result = ch.receive()
            expect result == nil

    describe "Future Combinators - join_all and select":
        it "should join all ready futures into a single result list":
            var f1 = future_ready(10)
            var f2 = future_ready(20)
            var f3 = future_ready(30)

            var joined = join_all_futures([f1, f2, f3])
            expect joined.is_ready() == true
            var vals = joined.value()
            expect vals.len() == 3
            expect vals[0] == 10
            expect vals[1] == 20
            expect vals[2] == 30

        it "should select the first ready future from a mixed set":
            var f1 = future_pending()
            var f2 = future_ready(99)
            var f3 = future_pending()

            var selected = select_first_future([f1, f2, f3])
            expect selected.is_ready() == true
            expect selected.value() == 99

    describe "Error Propagation":
        it "should propagate rejection from promise through future to combinator":
            var p = Promise(state: PromiseState.Pending)
            p.reject("upstream failure")
            expect p.is_rejected() == true

            var failed_future = future_failed(p.error())
            expect failed_future.is_failed() == true
            expect failed_future.error() == "upstream failure"

            var f_ok = future_ready(100)
            var joined = join_all_futures([f_ok, failed_future])
            expect joined.is_failed() == true
            expect joined.error() == "upstream failure"

    describe "Work-Stealing Queue Distribution":
        it "should distribute and steal tasks across worker queues":
            var wsq = WorkStealingQueue(q0: [], q1: [], q2: [])

            wsq.push(0, 10)
            wsq.push(0, 20)
            wsq.push(0, 30)
            wsq.push(1, 40)

            expect wsq.total_tasks() == 4

            # Worker 2 steals from worker 0 (takes from front)
            var stolen = wsq.steal(from_id: 0)
            expect stolen == 10

            # Worker 0 pops from own queue (takes from back)
            var own = wsq.pop(worker_id: 0)
            expect own == 30

            expect wsq.total_tasks() == 2

        it "should return nil when stealing from empty queue":
            var wsq = WorkStealingQueue(q0: [], q1: [], q2: [])
            var result = wsq.steal(from_id: 0)
            expect result == nil

    describe "Promise Chaining":
        it "should chain multiple promise resolutions producing correct final result":
            # Without function-typed fields, we chain manually
            var p1 = Promise(state: PromiseState.Pending)
            var p2 = Promise(state: PromiseState.Pending)
            var p3 = Promise(state: PromiseState.Pending)

            # Step 1: resolve p1 with initial value
            p1.resolve(5)

            # Step 2: transform and resolve p2
            var v1 = p1.value()
            p2.resolve(v1 + 10)

            # Step 3: transform and resolve p3
            var v2 = p2.value()
            p3.resolve(v2 * 2)

            expect p1.value() == 5
            expect p2.value() == 15
            expect p3.value() == 30
            expect p3.is_resolved() == true

    describe "Mixed Ready and Pending Futures":
        it "should handle join_all with all ready futures":
            var futures = [
                future_ready(1),
                future_ready(2),
                future_ready(3)
            ]
            var joined = join_all_futures(futures)
            expect joined.is_ready() == true
            var vals = joined.value()
            expect vals.len() == 3

        it "should select first ready from mixed ready/pending set":
            var futures = [
                future_pending(),
                future_pending(),
                future_ready(77),
                future_pending()
            ]
            var result = select_first_future(futures)
            expect result.is_ready() == true
            expect result.value() == 77

        it "should return pending when no futures are ready":
            var futures = [
                future_pending(),
                future_pending()
            ]
            var result = select_first_future(futures)
            expect result.is_ready() == false
            expect result.is_pending() == true

    describe "Channel Close Semantics":
        it "should stop accepting messages after channel is closed":
            var ch = TextChannel(buffer: [], closed: false, count: 0)
            ch.send("before")
            ch.close()
            ch.send("after")
            expect ch.size() == 1
            expect ch.receive() == "before"

        it "should drain remaining messages after close":
            var ch = Channel(buffer: [], closed: false, count: 0)
            ch.send(1)
            ch.send(2)
            ch.send(3)
            ch.close()

            # Can still receive even after close
            var r1 = ch.receive()
            var r2 = ch.receive()
            var r3 = ch.receive()
            expect r1 == 1
            expect r2 == 2
            expect r3 == 3
            expect ch.is_empty() == true

    describe "Full Pipeline Simulation":
        it "should run a complete pipeline with promises, futures, channel, and combinator":
            var ch = Channel(buffer: [], closed: false, count: 0)

            # Simulate 3 async tasks resolving promises and sending to channel
            var p1 = Promise(state: PromiseState.Pending)
            p1.resolve(100)
            ch.send(p1.value())

            var p2 = Promise(state: PromiseState.Pending)
            p2.resolve(200)
            ch.send(p2.value())

            var p3 = Promise(state: PromiseState.Pending)
            p3.resolve(300)
            ch.send(p3.value())

            # Collect channel results into futures
            var f1 = future_ready(ch.receive())
            var f2 = future_ready(ch.receive())
            var f3 = future_ready(ch.receive())

            expect ch.is_empty() == true

            # Join all futures
            var joined = join_all_futures([f1, f2, f3])
            expect joined.is_ready() == true
            var final_vals = joined.value()
            expect final_vals[0] == 100
            expect final_vals[1] == 200
            expect final_vals[2] == 300

            # Verify total sum
            var total = 0
            for v in final_vals:
                total = total + v
            expect total == 600