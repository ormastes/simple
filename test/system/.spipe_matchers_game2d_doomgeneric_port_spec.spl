# @tag:system
# @cover examples/game2d/doomgeneric/main.spl 60%
# @cover src/lib/nogc_sync_mut/game2d/ports/doomgeneric.spl 60%

use std.spec.{describe, it, expect}
use std.nogc_sync_mut.game2d.ports.doomgeneric as dg

extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_read_text(path: text) -> text

fn _read(path: text) -> text:
    if rt_file_exists(path):
        return rt_file_read_text(path)
    ""

describe "Doomgeneric-style game port proof":
    it "keeps the example on the pure std.game2d surface":
        val src = _read("examples/game2d/doomgeneric/main.spl")
        expect src.contains("use std.game2d as g") == true
        expect src.contains("rt_sdl2_") == false
        expect src.contains("Steamworks") == false

    it "proves WAD bytes, input tick, and video frame in one path":
        val s0 = dg.DoomPortState.boot(dg.proof_wad())
        val s1 = dg.doom_tick(s0, dg.DoomPortInput(forward: true, back: false, turn_left: false, turn_right: false, fire: true))
        val frame = dg.render_frame(s1, 160, 100)
        expect s1.wad_bytes == 12
        expect s1.tick == 1
        expect s1.shots == 1
        expect frame.non_black_count() == 160 * 100