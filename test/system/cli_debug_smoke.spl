# CLI Debug Smoke Test
#
# Tests that `bin/simple debug` starts, prints the banner, and exits cleanly
# when given the quit command via stdin.
#
# Run: bin/simple run test/system/cli_debug_smoke.spl

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

fn main():
    var passed = 0
    var failed = 0

    print "=== CLI Debug Smoke Tests ==="

    # Test 1: Starts and exits cleanly on 'quit'
    print "[1] starts and exits on quit"
    val (out1, _, c1) = rt_process_run("/bin/bash", ["-c", "(sleep 1 && printf 'quit\\n') | timeout 10 bin/simple debug 2>/dev/null | cat"])
    if c1 == 0:
        print "  ok: exit 0"
        passed = passed + 1
    else:
        print "  FAIL: exit {c1}"
        failed = failed + 1

    # Test 2: Banner contains "Simple Debugger"
    print "[2] banner shows Simple Debugger"
    if out1.contains("Simple Debugger"):
        print "  ok: banner present"
        passed = passed + 1
    else:
        print "  FAIL: no banner in output"
        print "  output: {out1}"
        failed = failed + 1

    # Test 3: Prompt contains (sdb)
    print "[3] prompt contains (sdb)"
    if out1.contains("(sdb)"):
        print "  ok: (sdb) prompt found"
        passed = passed + 1
    else:
        print "  FAIL: no (sdb) prompt in output"
        failed = failed + 1

    # Test 4: 'q' alias also quits cleanly
    print "[4] 'q' alias exits"
    val (_, _, c4) = rt_process_run("/bin/bash", ["-c", "(sleep 1 && printf 'q\\n') | timeout 10 bin/simple debug 2>/dev/null | cat"])
    if c4 == 0:
        print "  ok: exit 0"
        passed = passed + 1
    else:
        print "  FAIL: exit {c4}"
        failed = failed + 1

    # Test 5: 'help' command produces output with List of commands
    print "[5] help command shows command list"
    val (out5, _, c5) = rt_process_run("/bin/bash", ["-c", "(sleep 1 && printf 'help\\nquit\\n') | timeout 10 bin/simple debug 2>/dev/null | cat"])
    if out5.contains("quit"):
        print "  ok: help output contains quit"
        passed = passed + 1
    else:
        print "  FAIL: help did not show quit in output"
        print "  output: {out5}"
        failed = failed + 1

    print ""
    print "=== Results: {passed}/{passed + failed} passed ==="
    if failed == 0:
        print "ALL TESTS PASSED"
