#![allow(spipe_empty_examples)]
#![allow(spipe_boolean_wrapper_assertions)]
@allow(spipe_empty_examples)
@allow(spipe_boolean_wrapper_assertions)
use os.qemu_runner.{get_target, build_qemu_command, arch_from_name, get_all_targets, OsTarget}
use os.kernel.arch.arch_context.{Architecture}


fn main():
    # @cover src/lib/nogc_async_mut_noalloc/math/mod.spl 80%
    """
    # SimpleOS Boot Smoke Tests
    
    **Feature IDs:** #OS-BOOT-001
    **Category:** Operating System
    **Difficulty:** 2/5
    **Status:** In Progress
    
    ## Overview
    
    Verifies each architecture can build and boot to serial output on QEMU.
    Tests target configuration, QEMU command generation, and architecture parsing.
    
    ## Prerequisites
    
    QEMU must be installed for each architecture:
      apt install qemu-system-x86 qemu-system-arm qemu-system-misc
    """

    # @req REQ-SIMPLEOS-BOOT
    # @feature simpleos-multiarch
    # tag: os, qemu, slow



    # ============================================================================
    # OS Build Configuration Tests
    # ============================================================================

    describe "OS build configuration":
        """
        ## Target Configuration
    
        Verifies that each architecture returns correct hardcoded target settings
        including entry points, linker scripts, QEMU parameters, and output paths.
        """

        slow_it "has valid x86_64 target":
            val target = get_target(Architecture.X86_64)
            expect target.entry == "examples/simple_os/arch/x86_64/os_entry.spl"
            expect target.linker_script == "examples/simple_os/arch/x86_64/linker.ld"
            expect target.target_triple == "x86_64-unknown-none"
            expect target.output == "build/os/simpleos_x86_64.elf"
            expect target.qemu_system == "qemu-system-x86_64"
            expect target.qemu_machine == "q35"
            expect target.qemu_cpu == "qemu64"
            expect target.qemu_memory == "512M"
            expect target.qemu_bios == ""

        slow_it "has valid x86_32 boot-probe target":
            val target = get_target(Architecture.X86)
            expect target.entry == "src/os/kernel/arch/x86_32/boot.spl"
            expect target.linker_script == "src/os/kernel/arch/x86_32/linker.ld"
            expect target.target_triple == "i686-unknown-none"
            expect target.output == "build/os/simpleos_x86_32.elf"
            expect target.qemu_system == "qemu-system-i386"
            expect target.qemu_machine == "pc"
            expect target.qemu_cpu == "qemu32"
            expect target.qemu_memory == "128M"

        slow_it "has valid riscv64 target":
            val target = get_target(Architecture.Riscv64)
            expect target.entry == "src/os/kernel/arch/riscv64/boot.spl"
            expect target.linker_script == "src/os/kernel/arch/riscv64/linker.ld"
            expect target.target_triple == "riscv64-unknown-none"
            expect target.output == "build/os/simpleos_riscv64.elf"
            expect target.qemu_system == "qemu-system-riscv64"
            expect target.qemu_machine == "virt"
            expect target.qemu_cpu == "rv64"
            expect target.qemu_bios == "default"

        slow_it "has valid riscv32 target":
            val target = get_target(Architecture.Riscv32)
            expect target.entry == "src/os/kernel/arch/riscv32/boot.spl"
            expect target.linker_script == "src/os/kernel/arch/riscv32/linker.ld"
            expect target.target_triple == "riscv32-unknown-none"
            expect target.output == "build/os/simpleos_riscv32.elf"
            expect target.qemu_system == "qemu-system-riscv32"
            expect target.qemu_machine == "virt"
            expect target.qemu_cpu == "rv32"
            expect target.qemu_bios == "default"

        slow_it "has valid arm64 target":
            val target = get_target(Architecture.Arm64)
            expect target.entry == "src/os/kernel/arch/arm64/boot.spl"
            expect target.linker_script == "src/os/kernel/arch/arm64/linker.ld"
            expect target.target_triple == "aarch64-unknown-none"
            expect target.output == "build/os/simpleos_aarch64.elf"
            expect target.qemu_system == "qemu-system-aarch64"
            expect target.qemu_machine == "virt"
            expect target.qemu_cpu == "cortex-a72"
            expect target.qemu_bios == ""

        slow_it "produces correct QEMU command for x86_64":
            val target = get_target(Architecture.X86_64)
            val cmd = build_qemu_command(target)
            expect cmd[0] == "qemu-system-x86_64"
            expect (cmd).contains("-machine")
            expect (cmd).contains("q35")
            expect (cmd).contains("-cpu")
            expect (cmd).contains("qemu64")
            expect (cmd).contains("-m")
            expect (cmd).contains("512M")
            expect (cmd).contains("-serial")
            expect (cmd).contains("stdio")
            expect (cmd).contains("-display")
            expect (cmd).contains("none")
            expect (cmd).contains("-no-reboot")
            expect (cmd).contains("-kernel")
            expect (cmd).contains("build/os/simpleos_x86_64.elf")
            # x86_64 has debug-exit device
            expect (cmd).contains("-device")
            expect (cmd).contains("isa-debug-exit,iobase=0xf4,iosize=0x04")

        slow_it "produces correct QEMU command for x86_32 boot-probe target":
            val target = get_target(Architecture.X86)
            val cmd = build_qemu_command(target)
            expect cmd[0] == "qemu-system-i386"
            expect (cmd).contains("-machine")
            expect (cmd).contains("pc")
            expect (cmd).contains("-cpu")
            expect (cmd).contains("qemu32")
            expect (cmd).contains("-kernel")
            expect (cmd).contains("build/os/simpleos_x86_32.elf")
            expect (cmd).contains("-device")
            expect (cmd).contains("isa-debug-exit,iobase=0xf4,iosize=0x04")

        slow_it "produces correct QEMU command for riscv64":
            val target = get_target(Architecture.Riscv64)
            val cmd = build_qemu_command(target)
            expect cmd[0] == "qemu-system-riscv64"
            expect (cmd).contains("virt")
            expect (cmd).contains("rv64")
            expect (cmd).contains("-bios")
            expect (cmd).contains("default")
            expect (cmd).contains("-kernel")
            expect (cmd).contains("build/os/simpleos_riscv64.elf")

        slow_it "produces correct QEMU command for arm64":
            val target = get_target(Architecture.Arm64)
            val cmd = build_qemu_command(target)
            expect cmd[0] == "qemu-system-aarch64"
            expect (cmd).contains("virt")
            expect (cmd).contains("cortex-a72")
            expect (cmd).contains("-kernel")
            expect (cmd).contains("build/os/simpleos_aarch64.elf")

    # ============================================================================
    # Architecture Name Parsing Tests
    # ============================================================================

    describe "Architecture name parsing":
        """
        ## Name Resolution
    
        Verifies that architecture name strings are correctly parsed
        to Architecture enum variants, including aliases.
        """

        slow_it "parses x86_64":
            val arch = arch_from_name("x86_64")
            expect arch.? == true

        slow_it "parses x86_32 aliases":
            val x86_32 = arch_from_name("x86_32")
            expect x86_32.? == true
            val i686 = arch_from_name("i686")
            expect i686.? == true
            val i386 = arch_from_name("i386")
            expect i386.? == true

        slow_it "parses riscv64":
            val arch = arch_from_name("riscv64")
            expect arch.? == true

        slow_it "parses riscv32":
            val arch = arch_from_name("riscv32")
            expect arch.? == true

        slow_it "parses arm64 and aarch64":
            val arm = arch_from_name("arm64")
            expect arm.? == true
            val aarch = arch_from_name("aarch64")
            expect aarch.? == true

        slow_it "returns nil for unknown architecture":
            val unknown = arch_from_name("mips")
            expect unknown.? == false

    # ============================================================================
    # Target Enumeration Tests
    # ============================================================================

    describe "Target enumeration":
        """
        ## All-Target Listing
    
        Verifies the convenience function returns all supported architectures.
        """

        slow_it "returns all supported targets":
            val targets = get_all_targets()
            expect targets.len() == 6