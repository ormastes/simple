use std.memory_leveling.{memory_leveling_policy_from_intent, simple_memory_iso_cpu_cold, simple_memory_placement_config_from_intent}
use os.kernel.memory.memory_leveling_manager.{simpleos_memory_leveling_config_default}
use os.kernel.memory.memory_leveling_runtime.{memory_leveling_runtime_init, memory_leveling_runtime_manager, memory_leveling_runtime_replace_manager}
use os.kernel.memory.memory_swap_runtime.{memory_swap_runtime_apply_pressure, memory_swap_runtime_clear_for_test}

fn main() -> i64:
    memory_swap_runtime_clear_for_test()
    memory_leveling_runtime_init(simpleos_memory_leveling_config_default())
    val intent = simple_memory_iso_cpu_cold()
    val manager = memory_leveling_runtime_manager()
    _ = manager.request(simple_memory_placement_config_from_intent(intent), memory_leveling_policy_from_intent(intent), 4096, 1, 1)
    memory_leveling_runtime_replace_manager(manager)

    _ = memory_swap_runtime_apply_pressure("critical")
    _ = memory_swap_runtime_apply_pressure("critical")
    val restored_manager = memory_leveling_runtime_manager()
    val retry = restored_manager.apply_pressure("critical")
    if retry.selected < 1u64 or retry.selected > 1u64:
        print "memory_leveling_runtime_requeue_direct_probe_status=fail"
        return 1
    print "memory_leveling_runtime_requeue_direct_probe_status=pass"
    0
