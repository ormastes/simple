## Smoke spec for booting a FAT32-carried SimpleOS image that declares an
## NVFS runtime rootfs backend.
##
## This does NOT boot from a raw DBFS/NVFS disk format. FAT32 remains the
## carrier and boot filesystem. The purpose of this spec is to prove that:
##   1. we can bake an image tagged for an alternate runtime rootfs backend
##   2. the image still boots under QEMU
##   3. the backend marker survives into the baked image bytes
##
## Gates on SIMPLEOS_ALT_ROOTFS_BOOT=1.
##
## Optional env:
##   QEMU_SYSTEM_X86_64=/path/to/qemu-system-x86_64

use std.spec

extern fn rt_env_get(key: text) -> text
extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_process_run_timeout(cmd: text, args: [text], timeout_ms: i64) -> (text, text, i32)

val TEST_ROOT: text = "/tmp/simpleos_alt_rootfs_boot"
val BUILD_TIMEOUT_MS: i64 = 180000
val BOOT_TIMEOUT_MS: i64 = 30000

fn boot_gate() -> bool:
    val v = rt_env_get("SIMPLEOS_ALT_ROOTFS_BOOT")
    if v == nil:
        return false
    v == "1"

fn qemu_binary() -> text:
    val q = rt_env_get("QEMU_SYSTEM_X86_64")
    if q == nil or q == "":
        return "qemu-system-x86_64"
    q

fn qemu_available() -> bool:
    val qemu = qemu_binary()
    if rt_file_exists(qemu):
        return true
    val result = rt_process_run("which", [qemu])
    result[2] == 0

fn seed_root() -> text:
    "{TEST_ROOT}/nvfs/seed"

fn image_path() -> text:
    "{TEST_ROOT}/nvfs/simpleos_alt_rootfs.img"

fn reset_backend_root():
    val root = seed_root()
    val _ = rt_process_run("/bin/sh", ["-c", "rm -rf '" + TEST_ROOT + "/nvfs' && mkdir -p '" + root + "/etc' '" + root + "/SYS'"])

fn stage_rootfs_seed() -> bool:
    val root = seed_root()
    val rootfs_ok = rt_file_write_text("{root}/etc/rootfs.sdn",
        "[rootfs]\n" +
        "backend = \"nvfs\"\n" +
        "carrier = \"fat32\"\n" +
        "boot_mode = \"fat32-carrier\"\n")
    if not rootfs_ok:
        return false
    rt_file_write_text("{root}/SYS/ROOTFS.CFG",
        "rootfs_backend=nvfs\n" +
        "rootfs_carrier=fat32\n" +
        "rootfs_boot_mode=fat32-carrier\n")

fn build_image() -> (text, text, i32):
    val img = image_path()
    val root = seed_root()
    rt_process_run_timeout("/bin/sh", [
        "scripts/make_os_disk.shs",
        "64",
        img,
        root,
        "x86_64",
    ], BUILD_TIMEOUT_MS)

fn boot_image() -> (text, text, i32):
    val img = image_path()
    rt_process_run_timeout(qemu_binary(), [
        "-display",
        "none",
        "-serial",
        "stdio",
        "-drive",
        "format=raw,file={img}",
        "-m",
        "128M",
        "-no-reboot",
    ], BOOT_TIMEOUT_MS)

describe "SimpleOS FAT32-carried alternate-rootfs boot smoke":
    it "skips when SIMPLEOS_ALT_ROOTFS_BOOT is not enabled":
        if not boot_gate():
            return "skip: SIMPLEOS_ALT_ROOTFS_BOOT not set"
        return "ok: gate enabled"

describe "SimpleOS NVFS-marked FAT32 carrier image":
    it "builds an NVFS-marked image carrying the rootfs marker":
        if not boot_gate():
            return "skip: SIMPLEOS_ALT_ROOTFS_BOOT not set"
        reset_backend_root()
        expect(stage_rootfs_seed()).to_equal(true)
        val build = build_image()
        expect(build[2]).to_equal(0)
        val img = image_path()
        expect(rt_file_exists(img)).to_equal(true)
        val marker = rt_process_run("grep", ["-a", "rootfs_backend=nvfs", img])
        expect(marker[2]).to_equal(0)

    it "boots the NVFS-marked image under QEMU and prints [BOOT]":
        if not boot_gate():
            return "skip: SIMPLEOS_ALT_ROOTFS_BOOT not set"
        if not qemu_available():
            return "skip: qemu-system-x86_64 not found"
        val img = image_path()
        if not rt_file_exists(img):
            return "skip: nvfs image not built"
        val boot = boot_image()
        val serial = boot[0] + boot[1]
        expect(serial.contains("[BOOT]")).to_equal(true)
