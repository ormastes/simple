use std.memory_leveling.{MEMORY_ALLOCATION_MAX_PAGE_COUNT, MEMORY_LEVELING_ALLOCATION_METADATA_BYTES, memory_allocation_from_intent, memory_allocation_page_count, memory_allocation_is_coherent, memory_allocation_is_reclaimable, memory_leveling_policy_from_intent, memory_tier_cpu_hot, simple_memory_iso_cpu_cold, simple_memory_placement_config_from_intent}
use os.kernel.memory.memory_leveling_manager.{memory_leveling_manager_new, simpleos_memory_leveling_config_default, simpleos_memory_leveling_config_validate}
use os.kernel.memory.memory_leveling_device_adapters.{memory_leveling_device_migration_unavailable}

fn probe_failure(reason: text) -> i64:
    print "memory_leveling_contract_direct_probe_status=fail reason={reason}"
    1

fn main() -> i64:
    var config = simpleos_memory_leveling_config_default()
    config.gpu_capacity_bytes = 8192
    config.gpu_reserved_bytes = 4096
    config.gpu_low_watermark_bytes = 1024
    config.gpu_high_watermark_bytes = 4096
    if simpleos_memory_leveling_config_validate(config) != "ok":
        return probe_failure("config")

    val manager = memory_leveling_manager_new(config)
    val intent = simple_memory_iso_cpu_cold()
    val packed = memory_allocation_from_intent(99, 9000, 3, intent)
    if MEMORY_LEVELING_ALLOCATION_METADATA_BYTES != 120 or memory_allocation_page_count(packed) != 3 or not memory_allocation_is_coherent(packed) or not memory_allocation_is_reclaimable(packed):
        return probe_failure("packed-metadata-contract")
    val allocation = manager.request(simple_memory_placement_config_from_intent(intent), memory_leveling_policy_from_intent(intent), 4096, 1, 1)
    if not allocation.ok:
        return probe_failure("cpu-allocation")
    if not manager.register_gpu_queue(10, 2, 4096, 0x8000).ok:
        return probe_failure("gpu-registration")

    val pressure = manager.apply_pressure("critical")
    if pressure.inspected != 1 or pressure.selected != 1:
        return probe_failure("pressure-bound")
    val stats = manager.snapshot()
    if stats.pressure_level != "critical" or stats.cpu_cold_bytes != 4096 or stats.dma_pinned_bytes != 4096:
        return probe_failure("tier-telemetry")
    if stats.metadata_record_count != 2 or stats.metadata_bytes != 2u64 * MEMORY_LEVELING_ALLOCATION_METADATA_BYTES:
        return probe_failure("metadata-telemetry")

    val dedup_manager = memory_leveling_manager_new(simpleos_memory_leveling_config_default())
    val dedup = dedup_manager.request(simple_memory_placement_config_from_intent(intent), memory_leveling_policy_from_intent(intent), 4096, 1, 8)
    if not dedup.ok or not dedup_manager.pin(dedup.allocation_id, 8).ok or not dedup_manager.unpin(dedup.allocation_id, 8).ok:
        return probe_failure("candidate-dedup-lifecycle")
    val dedup_stats = dedup_manager.snapshot()
    if dedup_stats.candidate_count < 1u64 or dedup_stats.candidate_count > 1u64:
        return probe_failure("candidate-dedup-count")
    val dedup_pressure = dedup_manager.apply_pressure("critical")
    if dedup_pressure.inspected != 1 or dedup_pressure.selected != 1:
        return probe_failure("candidate-dedup-pressure")
    if not dedup_manager.requeue_candidate(dedup.allocation_id) or dedup_manager.apply_pressure("critical").selected != 1:
        return probe_failure("failed-candidate-requeue")
    if dedup_manager.request(simple_memory_placement_config_from_intent(intent), memory_leveling_policy_from_intent(intent), 4096, MEMORY_ALLOCATION_MAX_PAGE_COUNT + 1, 10).reason != "invalid-request":
        return probe_failure("packed-page-count-overflow")

    val cooldown_manager = memory_leveling_manager_new(simpleos_memory_leveling_config_default())
    val cooldown = cooldown_manager.request(simple_memory_placement_config_from_intent(intent), memory_leveling_policy_from_intent(intent), 4096, 1, 9)
    if not cooldown.ok or not cooldown_manager.touch(cooldown.allocation_id, 9).ok:
        return probe_failure("cooldown-setup")
    val cooling = cooldown_manager.apply_pressure("critical")
    if cooling.inspected != 1 or cooling.selected != 0 or cooling.skipped != 1:
        return probe_failure("cooldown-skip")
    val cooled = cooldown_manager.apply_pressure("critical")
    if cooled.inspected != 1 or cooled.selected != 1:
        return probe_failure("cooldown-retained")

    val submitted = manager.device_submit(10, 2)
    if not submitted.ok:
        return probe_failure("gpu-submit-{submitted.reason}")
    val submitted_stats = manager.snapshot()
    # Native aggregate u64 equality currently routes through tagged dynamic equality.
    if submitted_stats.mapping_count < 1u64 or submitted_stats.mapping_count > 1u64 or submitted_stats.in_flight_count < 1u64 or submitted_stats.in_flight_count > 1u64:
        return probe_failure("gpu-submit-counters-mapping={submitted_stats.mapping_count}-in-flight={submitted_stats.in_flight_count}")
    val completed = manager.device_complete(10, 2)
    if not completed.ok or manager.snapshot().in_flight_count != 0:
        return probe_failure("gpu-complete-{completed.reason}")
    val unmapped = manager.device_unmap(10, 2)
    if not unmapped.ok or manager.snapshot().mapping_count != 0:
        return probe_failure("gpu-unmap-{unmapped.reason}")
    if memory_leveling_device_migration_unavailable(10).reason != "migration-unavailable":
        return probe_failure("migration-claim")
    if manager.register_nic_buffer(11, 2, 2048, 0xA000, false).reason != "invalid-request":
        return probe_failure("unproven-device-layout")

    var watermark_config = simpleos_memory_leveling_config_default()
    watermark_config.physical_capacity_bytes = 16384
    watermark_config.cpu_capacity_bytes = 16384
    watermark_config.cpu_reserved_bytes = 0
    watermark_config.cpu_low_watermark_bytes = 2048
    watermark_config.cpu_high_watermark_bytes = 8192
    watermark_config.gpu_reserved_bytes = 0
    watermark_config.nic_reserved_bytes = 0
    watermark_config.dma_reserved_bytes = 0
    val watermark_manager = memory_leveling_manager_new(watermark_config)
    val watermark_placement = simple_memory_placement_config_from_intent(intent)
    val watermark_policy = memory_leveling_policy_from_intent(intent)
    if not watermark_manager.request(watermark_placement, watermark_policy, 9000, 3, 3).ok or watermark_manager.apply_pressure("normal").level != "elevated":
        return probe_failure("elevated-watermark")
    if not watermark_manager.request(watermark_placement, watermark_policy, 6000, 2, 4).ok or watermark_manager.apply_pressure("normal").level != "critical":
        return probe_failure("critical-watermark")

    var swap_config = simpleos_memory_leveling_config_default()
    swap_config.swap_capacity_bytes = 4096
    swap_config.swap_low_watermark_bytes = 1024
    swap_config.swap_high_watermark_bytes = 2048
    val swap_manager = memory_leveling_manager_new(swap_config)
    var hot_placement = simple_memory_placement_config_from_intent(intent)
    hot_placement.preferred_tier = memory_tier_cpu_hot()
    val hot_policy = memory_leveling_policy_from_intent(intent)
    val hot = swap_manager.request(hot_placement, hot_policy, 2048, 1, 5)
    if not swap_manager.prepare_swap(hot.allocation_id, 5).ok or not swap_manager.rollback_swap(hot.allocation_id, 5).ok:
        return probe_failure("swap-rollback-tier")
    if not swap_manager.prepare_swap(hot.allocation_id, 5).ok or not swap_manager.commit_swap(hot.allocation_id, 5, 1).ok or swap_manager.snapshot().cpu_hot_bytes != 0:
        return probe_failure("swap-rollback-tier-accounting")
    if not swap_manager.request(hot_placement, hot_policy, 2048, 1, 6).ok:
        return probe_failure("swap-capacity-second-allocation")
    if not swap_manager.prepare_swap(2, 6).ok or not swap_manager.commit_swap(2, 6, 2).ok:
        return probe_failure("swap-capacity-fill")
    if not swap_manager.request(hot_placement, hot_policy, 1, 1, 7).ok:
        return probe_failure("swap-capacity-third-allocation")
    if swap_manager.prepare_swap(3, 7).reason != "swap-capacity":
        return probe_failure("swap-capacity-overcommit")

    print "memory_leveling_contract_direct_probe_status=pass metadata_bytes_per_allocation={MEMORY_LEVELING_ALLOCATION_METADATA_BYTES}"
    0
