    else:
        print("FAIL: REQ-010 pane to_text is empty")

# =========================================================================
# REQ-011 — explicit non-fatal failure handling
# =========================================================================

fn test_req011_split_invalid_pane_no_crash():
    _reset()
    val s = _create_session("err1")
    val wins = _list_windows(s.id)
    val ok = _split_pane(s.id, wins[0].id, "ghost", "vertical")
    if ok == false:
        print("PASS: REQ-011 split invalid pane returns false not crash")
    else:
        print("FAIL: REQ-011 split invalid pane should return false")

fn test_req011_resize_invalid_pane_no_crash():
    _reset()
