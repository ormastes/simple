# =========================================================================
# NFR-007 — startup/operation observability counters
# =========================================================================

fn test_nfr007_startup_count_increments():
    _reset()
    if _metrics.startup_count == 0:
        val _s1 = _create_session("obs1")
        if _metrics.startup_count == 1:
            val _s2 = _create_session("obs2")
            if _metrics.startup_count == 2:
                print("PASS: NFR-007 startup_count increments with each session")
            else:
                print("FAIL: NFR-007 startup_count after 2 sessions=" + _metrics.startup_count.to_text())
        else:
            print("FAIL: NFR-007 startup_count after 1 session=" + _metrics.startup_count.to_text())
    else:
        print("FAIL: NFR-007 initial startup_count should be 0")

fn test_nfr007_capture_count_increments():
    _reset()
    val s = _create_session("obscap")
    val wins = _list_windows(s.id)
    val panes = _list_panes(s.id, wins[0].id)
    val pid = panes[0].id
    val _c1 = _capture(pid)
    val _c2 = _capture(pid)
    if _metrics.capture_count == 2:
        print("PASS: NFR-007 capture_count increments with each capture")
    else:
        print("FAIL: NFR-007 capture_count=" + _metrics.capture_count.to_text())

fn test_nfr007_resize_count_increments():
    _reset()
    val s = _create_session("obsrez")
    val wins = _list_windows(s.id)
    val panes = _list_panes(s.id, wins[0].id)
    val _r = _resize_pane(panes[0].id, 100, 30)
    if _metrics.resize_count == 1:
        print("PASS: NFR-007 resize_count increments with each resize")
    else:
        print("FAIL: NFR-007 resize_count=" + _metrics.resize_count.to_text())

fn test_nfr007_metrics_zero_on_reset():
    _reset()
    if _metrics.startup_count == 0 and _metrics.capture_count == 0 and _metrics.resize_count == 0:
        print("PASS: NFR-007 metrics are zero after reset")
    else:
        print("FAIL: NFR-007 metrics not zero after reset")

fn test_nfr007_metrics_non_negative():
    _reset()
    val _s = _create_session("mneg")
    if _metrics.startup_count >= 0 and _metrics.capture_count >= 0 and _metrics.resize_count >= 0:
        print("PASS: NFR-007 all metric counters are non-negative")
    else:
        print("FAIL: NFR-007 metric counters have negative value")

# =========================================================================
# Entry point
# =========================================================================

fn main():
    print("=== smux system spec: REQ-001..REQ-012 + NFR-007 ===")

    print("--- REQ-001 persistent session/window/pane model ---")
    test_req001_create_session_returns_name()
    test_req001_session_has_id()
    test_req001_list_sessions_includes_created()
    test_req001_session_auto_creates_window()
    test_req001_session_auto_creates_pane()
    test_req001_multiple_sessions_all_listed()
    test_req001_new_window_adds_window()
    test_req001_new_window_auto_creates_pane()

    print("--- REQ-002 pane-backed shell execution ---")
    test_req002_initial_pane_state_running()
    test_req002_initial_pane_has_dimensions()

    print("--- REQ-003 attach/detach without session destruction ---")
    test_req003_attach_registers_client()
    test_req003_detach_returns_true()
    test_req003_session_persists_after_detach()
    test_req003_detach_unknown_returns_false()
    test_req003_reattach_after_detach_succeeds()

    print("--- REQ-004 split/layout operations ---")
    test_req004_split_vertical_creates_pane()
    test_req004_split_horizontal_creates_pane()
    test_req004_split_invalid_pane_returns_false()
    test_req004_resize_returns_true()
    test_req004_resize_invalid_pane_returns_false()

    print("--- REQ-005 input/output routing ---")
    test_req005_send_command_valid_pane()
    test_req005_send_command_invalid_pane()
    test_req005_capture_reflects_send()

    print("--- REQ-006 state query API ---")
    test_req006_list_sessions_stable()
    test_req006_list_windows_stable()
    test_req006_list_panes_stable()
    test_req006_pane_metadata_has_ids()

    print("--- REQ-007 capture API ---")
    test_req007_capture_returns_pane_identity()
    test_req007_capture_rows_greater_than_zero()
    test_req007_capture_increments_counter()
    test_req007_capture_unknown_pane_minimal()

    print("--- REQ-008 compatibility-facing tmux-shaped API ---")
    test_req008_mux_session_has_id_and_name()
    test_req008_mux_window_has_session_id()
    test_req008_mux_pane_has_all_ids()
    test_req008_mux_capture_has_pane_id()
    test_req008_session_to_text()

    print("--- REQ-009 native-first backend ---")
    test_req009_backend_name_is_smux_native()
    test_req009_service_operates_without_host_tmux()

    print("--- REQ-010 backend swap readiness boundary ---")
    test_req010_backend_name_queryable_independently()
    test_req010_pane_has_text_representation()

    print("--- REQ-011 explicit non-fatal failure handling ---")
    test_req011_split_invalid_pane_no_crash()
    test_req011_resize_invalid_pane_no_crash()
    test_req011_send_invalid_pane_no_crash()
    test_req011_detach_unknown_client_no_crash()
    test_req011_capture_unknown_pane_no_crash()

    print("--- REQ-012 declared deferrals queryable ---")
    test_req012_copy_mode_deferred()
    test_req012_mouse_deferred()
    test_req012_key_table_compat_deferred()
    test_req012_tmux_conf_deferred()
    test_req012_control_mode_deferred()
    test_req012_non_deferred_returns_false()

    print("--- NFR-007 observability counters ---")
    test_nfr007_startup_count_increments()
    test_nfr007_capture_count_increments()
    test_nfr007_resize_count_increments()
    test_nfr007_metrics_zero_on_reset()
    test_nfr007_metrics_non_negative()

    print("=== DONE ===")
