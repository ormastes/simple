fn test_req006_list_sessions_stable():
    _reset()
    val s = _create_session("stable")
    val l1 = _list_sessions()
    val l2 = _list_sessions()
    if l1.len() == l2.len() and l1[0].id == l2[0].id:
        print("PASS: REQ-006 list_sessions returns stable metadata")
    else:
        print("FAIL: REQ-006 list_sessions stability")

fn test_req006_list_windows_stable():
    _reset()
    val s = _create_session("wstable")
    val w1 = _list_windows(s.id)
    val w2 = _list_windows(s.id)
    if w1.len() == w2.len() and w1[0].id == w2[0].id:
        print("PASS: REQ-006 list_windows returns stable metadata")
    else:
        print("FAIL: REQ-006 list_windows stability")

fn test_req006_list_panes_stable():
    _reset()
    val s = _create_session("pstable")
    val wins = _list_windows(s.id)
    val p1 = _list_panes(s.id, wins[0].id)
    val p2 = _list_panes(s.id, wins[0].id)
    if p1.len() == p2.len() and p1[0].id == p2[0].id:
        print("PASS: REQ-006 list_panes returns stable metadata")
    else:
        print("FAIL: REQ-006 list_panes stability")

fn test_req006_pane_metadata_has_ids():
    _reset()
    val s = _create_session("pmeta")
    val wins = _list_windows(s.id)
    val panes = _list_panes(s.id, wins[0].id)
    val p = panes[0]
    if p.session_id == s.id and p.window_id == wins[0].id:
        print("PASS: REQ-006 pane metadata includes session and window ids")
    else:
        print("FAIL: REQ-006 pane metadata ids sid=" + p.session_id + " wid=" + p.window_id)

# =========================================================================
# REQ-007 — capture API
# =========================================================================

fn test_req007_capture_returns_pane_identity():
    _reset()
    val s = _create_session("cap")
    val wins = _list_windows(s.id)
    val panes = _list_panes(s.id, wins[0].id)
    val pid = panes[0].id
    val cap = _capture(pid)
    if cap.pane_id == pid:
        print("PASS: REQ-007 capture returns valid pane identity")
    else:
        print("FAIL: REQ-007 capture pane_id=" + cap.pane_id)

fn test_req007_capture_rows_greater_than_zero():
    _reset()
    val s = _create_session("caprows")
    val wins = _list_windows(s.id)
    val panes = _list_panes(s.id, wins[0].id)
    val cap = _capture(panes[0].id)
    if cap.rows > 0:
        print("PASS: REQ-007 capture rows is greater than zero")
    else:
        print("FAIL: REQ-007 capture rows=" + cap.rows.to_text())

fn test_req007_capture_increments_counter():
    _reset()
    val s = _create_session("capmet")
    val wins = _list_windows(s.id)
    val panes = _list_panes(s.id, wins[0].id)
    val pid = panes[0].id
    val before = _metrics.capture_count
    val _c = _capture(pid)
    val after = _metrics.capture_count
    if after == before + 1:
        print("PASS: REQ-007 capture increments capture_count")
    else:
        print("FAIL: REQ-007 capture_count before=" + before.to_text() + " after=" + after.to_text())

fn test_req007_capture_unknown_pane_minimal():
    _reset()
    val cap = _capture("no-pane")
    if cap.rows > 0:
        print("PASS: REQ-007 capture on unknown pane returns minimal non-crash result")
    else:
        print("FAIL: REQ-007 capture unknown pane rows=" + cap.rows.to_text())

