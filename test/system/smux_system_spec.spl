    val s = _create_session("split")
    val wins = _list_windows(s.id)
    val panes = _list_panes(s.id, wins[0].id)
    val ok = _split_pane(s.id, wins[0].id, panes[0].id, "vertical")
    if ok:
        print("PASS: REQ-004 split vertical creates pane")
    else:
        print("FAIL: REQ-004 split vertical")

fn test_req004_split_horizontal_creates_pane():
    _reset()
    val s = _create_session("splith")
    val wins = _list_windows(s.id)
    val panes = _list_panes(s.id, wins[0].id)
    val ok = _split_pane(s.id, wins[0].id, panes[0].id, "horizontal")
    if ok:
        print("PASS: REQ-004 split horizontal creates pane")
    else:
        print("FAIL: REQ-004 split horizontal")

fn test_req004_split_invalid_pane_returns_false():
    _reset()
    val s = _create_session("spliterr")
    val wins = _list_windows(s.id)
    val ok = _split_pane(s.id, wins[0].id, "bad-pane-id", "vertical")
    if ok == false:
        print("PASS: REQ-004 split invalid pane returns false")
    else:
        print("FAIL: REQ-004 split invalid pane should return false")

fn test_req004_resize_returns_true():
    _reset()
    val s = _create_session("resize")
    val wins = _list_windows(s.id)
    val panes = _list_panes(s.id, wins[0].id)
    val ok = _resize_pane(panes[0].id, 120, 40)
    if ok:
        print("PASS: REQ-004 resize pane returns true")
    else:
        print("FAIL: REQ-004 resize pane")

fn test_req004_resize_invalid_pane_returns_false():
    _reset()
    val ok = _resize_pane("no-such-pane", 100, 30)
    if ok == false:
        print("PASS: REQ-004 resize invalid pane returns false")
    else:
        print("FAIL: REQ-004 resize invalid pane should return false")

# =========================================================================
# REQ-005 — input/output routing
# =========================================================================

fn test_req005_send_command_valid_pane():
    _reset()
    val s = _create_session("io")
    val wins = _list_windows(s.id)
    val panes = _list_panes(s.id, wins[0].id)
    val ok = _send_command(panes[0].id, "echo hello")
    if ok:
        print("PASS: REQ-005 send_command to valid pane succeeds")
    else:
        print("FAIL: REQ-005 send_command to valid pane")

fn test_req005_send_command_invalid_pane():
    _reset()
    val ok = _send_command("bad-pane", "echo hi")
    if ok == false:
        print("PASS: REQ-005 send_command to invalid pane returns false")
    else:
        print("FAIL: REQ-005 send_command to invalid pane should return false")

fn test_req005_capture_reflects_send():
    _reset()
    val s = _create_session("iosend")
    val wins = _list_windows(s.id)
    val panes = _list_panes(s.id, wins[0].id)
    val pid = panes[0].id
    val _sent = _send_command(pid, "hello world")
    val cap = _capture(pid)
    if cap.pane_id == pid:
        print("PASS: REQ-005 capture has correct pane identity after send")
    else:
        print("FAIL: REQ-005 capture pane_id=" + cap.pane_id + " want=" + pid)

