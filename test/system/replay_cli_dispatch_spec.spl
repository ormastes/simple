# @cover src/app/cli/dispatch/table.spl 80%
# @cover src/app/qemu/main.spl 40%
# @tag: qemu, cli, dispatch, replay
"""
# Replay CLI Dispatch Specification

**Feature IDs:** #QEMU-CLI
**Category:** Tooling
**Difficulty:** 2/5
**Status:** Implemented

## Overview

Verifies that `simple qemu` is correctly registered in the CLI dispatch
table and that the qemu module's argument-parsing helper works for the
four subcommands: record, replay, checkpoint, status.

## Behavior

- The dispatch table must contain a "qemu" entry pointing at
  `src/app/qemu/main.spl`.
- `find_command("qemu")` must return a valid entry.
- `parse_flag` must extract flag values from argument arrays.
- Unknown commands must return nil from the dispatch table.
"""

use app.cli.dispatch.{find_command}
use app.cli.dispatch.table.{get_command_table}
use app.qemu.commands.{parse_flag}

# ============================================================================
# Test Group 1: Dispatch Table Registration
# ============================================================================

describe "qemu dispatch table registration":
    """
    ## Table Presence

    Validates that the qemu command exists in the CLI command table
    with correct metadata.
    """

    it "is registered in the dispatch table":
        val table = get_command_table()
        var found = false
        for entry in table:
            if entry.name == "qemu":
                found = true
        expect(found).to_equal(true)

    it "routes to the qemu app":
        val result = find_command("qemu")
        var app_path = ""
        if val entry = result:
            app_path = entry.app_path
        expect(app_path).to_equal("src/app/qemu/main.spl")

    it "has a Simple implementation":
        val result = find_command("qemu")
        var has_impl = false
        if val entry = result:
            has_impl = entry.has_simple_impl()
        expect(has_impl).to_equal(true)

    it "does not require Rust for bare invocation":
        val result = find_command("qemu")
        var needs_rust = true
        if val entry = result:
            needs_rust = entry.should_use_rust([])
        expect(needs_rust).to_equal(false)

    it "has no env_override":
        val result = find_command("qemu")
        var env_override = "non-empty"
        if val entry = result:
            env_override = entry.env_override
        expect(env_override).to_equal("")

    it "has no needs_rust_flags":
        val result = find_command("qemu")
        var flag_count = -1
        if val entry = result:
            flag_count = entry.needs_rust_flags.len()
        expect(flag_count).to_equal(0)

# ============================================================================
# Test Group 2: Unknown Command Handling
# ============================================================================

describe "dispatch table unknown command":
    """
    ## Unknown Commands

    Verifies that looking up a non-existent command returns nil.
    """

    it "find_command returns nil for unknown command":
        val result = find_command("nonexistent-qemu-xyz")
        var found = false
        if val entry = result:
            found = true
        expect(found).to_equal(false)

# ============================================================================
# Test Group 3: Subcommand Argument Parsing
# ============================================================================

describe "qemu subcommand parse_flag":
    """
    ## Argument Parsing

    Tests the parse_flag helper used by record, replay, checkpoint,
    and status subcommands.
    """

    it "parse_flag extracts --arch value":
            val args = ["--arch", "x86_64", "--kernel", "boot.elf"]
            val arch = parse_flag(args, "--arch")
            expect(arch).to_equal("x86_64")

        it "parse_flag extracts --kernel value":
            val args = ["--arch", "riscv32", "--kernel", "boot.elf", "--trace", "out.srrq"]
            val kernel = parse_flag(args, "--kernel")
            expect(kernel).to_equal("boot.elf")

        it "parse_flag extracts --trace value":
            val args = ["--arch", "x86_64", "--kernel", "boot.elf", "--trace", "recording.srrq"]
            val trace = parse_flag(args, "--trace")
            expect(trace).to_equal("recording.srrq")

    it "parse_flag extracts --gdb-port value":
            val args = ["--kernel", "boot.elf", "--trace", "rec.srrq", "--gdb-port", "5555"]
            val port = parse_flag(args, "--gdb-port")
            expect(port).to_equal("5555")

    context "missing flags":

        it "parse_flag returns empty text for missing flag":
            val args = ["--arch", "x86_64"]
            val missing = parse_flag(args, "--kernel")
            expect(missing).to_equal("")

        it "parse_flag returns empty text for empty args":
            val args: [text] = []
            val missing = parse_flag(args, "--arch")
            expect(missing).to_equal("")

    context "checkpoint and status flags":

        it "parse_flag extracts --qmp socket path":
            val args = ["save", "snap1", "--qmp", "/tmp/qemu-qmp.sock"]
            val qmp = parse_flag(args, "--qmp")
            expect(qmp).to_equal("/tmp/qemu-qmp.sock")

        it "parse_flag extracts --machine value":
            val args = ["--arch", "aarch64", "--kernel", "k.elf", "--machine", "virt"]
            val machine = parse_flag(args, "--machine")
            expect(machine).to_equal("virt")
