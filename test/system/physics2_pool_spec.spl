# Physics2 Pool/Billiards — System Test
#
# Verifies: circle-circle collision, TGS solver, friction,
# restitution, energy conservation, determinism.
# Uses module-level helper fns to avoid interpreter while-loop-in-it-block issue.

use std.io_runtime
use std.spec.{describe, it, expect}
use std.common.math.{math_sqrt, math_abs}
use std.common.engine.ids.{NodeId, RawHandle}
use std.common.engine.math2d.{Vec2}
use std.nogc_sync_mut.engine.physics2.config.{default_physics_config_2d}
use std.nogc_sync_mut.engine.physics2.world2d.{PhysicsWorld2D}

fn make_node(idx: i64) -> NodeId:
    NodeId(raw: RawHandle.new(idx, 1))

fn make_pool_world() -> PhysicsWorld2D:
    var config = default_physics_config_2d()
    config.gravity = Vec2(x: 0.0, y: 0.0)
    config.restitution = 0.9
    config.friction = 0.2
    var world = PhysicsWorld2D.create(config)
    # Table walls
    world.add_static_body(make_node(50), -5.0, 0.0)
    world.add_box_collider(make_node(50), 0.5, 4.0)
    world.add_static_body(make_node(51), 5.0, 0.0)
    world.add_box_collider(make_node(51), 0.5, 4.0)
    world.add_static_body(make_node(52), 0.0, 4.0)
    world.add_box_collider(make_node(52), 5.0, 0.5)
    world.add_static_body(make_node(53), 0.0, -4.0)
    world.add_box_collider(make_node(53), 5.0, 0.5)
    # 4 balls: cue + 3 targets
    world.add_dynamic_body(make_node(0), -3.0, 0.0, 1.0)
    world.add_circle_collider(make_node(0), 0.3)
    world.add_dynamic_body(make_node(1), 2.0, 0.0, 1.0)
    world.add_circle_collider(make_node(1), 0.3)
    world.add_dynamic_body(make_node(2), 2.6, 0.3, 1.0)
    world.add_circle_collider(make_node(2), 0.3)
    world.add_dynamic_body(make_node(3), 2.6, -0.3, 1.0)
    world.add_circle_collider(make_node(3), 0.3)
    world

fn step_n(world: PhysicsWorld2D, n: i64):
    var i = 0
    while i < n:
        world.step(0.016)
        i = i + 1

fn get_total_ke(world: PhysicsWorld2D) -> f64:
    var total = 0.0
    var i = 0
    while i < 4:
        val vel = world.get_velocity(make_node(i))
        total = total + 0.5 * (vel.x * vel.x + vel.y * vel.y)
        i = i + 1
    total

fn check_positions_finite(world: PhysicsWorld2D) -> bool:
    var i = 0
    while i < 4:
        val pos = world.get_position(make_node(i))
        if pos.x < -20.0 or pos.x > 20.0:
            return false
        if pos.y < -20.0 or pos.y > 20.0:
            return false
        i = i + 1
    true

fn run_deterministic(impulse_x: f64, impulse_y: f64, steps: i64) -> (f64, f64):
    var world = make_pool_world()
    world.apply_impulse(make_node(0), impulse_x, impulse_y)
    step_n(world, steps)
    val pos = world.get_position(make_node(0))
    world.destroy()
    (pos.x, pos.y)

describe "Physics2 Pool System":
    it "cue ball moves after impulse":
        var world = make_pool_world()
        world.apply_impulse(make_node(0), 5.0, 0.0)
        step_n(world, 30)
        val pos = world.get_position(make_node(0))
        expect(pos.x > -2.0).to_equal(true)
        world.destroy()

    it "positions remain finite after simulation":
        var world = make_pool_world()
        world.apply_impulse(make_node(0), 5.0, 0.3)
        step_n(world, 100)
        expect(check_positions_finite(world)).to_equal(true)
        world.destroy()

    it "kinetic energy bounded":
        var world = make_pool_world()
        world.apply_impulse(make_node(0), 5.0, 0.0)
        step_n(world, 100)
        val ke = get_total_ke(world)
        expect(ke < 50.0).to_equal(true)
        world.destroy()

    it "deterministic across two runs":
        val r1 = run_deterministic(5.0, 0.1, 80)
        val r2 = run_deterministic(5.0, 0.1, 80)
        expect(r1.0).to_equal(r2.0)
        expect(r1.1).to_equal(r2.1)

    it "target ball gets displaced by collision":
        var config = default_physics_config_2d()
        config.gravity = Vec2(x: 0.0, y: 0.0)
        config.restitution = 0.9
        var world = PhysicsWorld2D.create(config)
        world.add_dynamic_body(make_node(0), 0.0, 0.0, 1.0)
        world.add_circle_collider(make_node(0), 0.3)
        world.add_dynamic_body(make_node(1), 1.0, 0.0, 1.0)
        world.add_circle_collider(make_node(1), 0.3)
        val before = world.get_position(make_node(1))
        world.apply_impulse(make_node(0), 5.0, 0.0)
        step_n(world, 60)
        val after = world.get_position(make_node(1))
        val dx = after.x - before.x
        val dy = after.y - before.y
        val dist = math_sqrt(dx * dx + dy * dy)
        expect(dist > 0.1).to_equal(true)
        world.destroy()
