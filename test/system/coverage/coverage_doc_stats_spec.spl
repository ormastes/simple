# @feature coverage_doc_statistics
# tag: system
#
# System tests for public comment coverage statistics.
# Tests src/app/doc/public_check/statistics.spl — calculate, format, threshold, MDSOC.
# Requires compiled mode for full test execution.
"""
# Coverage Documentation Statistics Specification

**Feature IDs:** #COV-002
**Category:** Tooling
**Status:** Implemented

## Overview

Validates the public comment coverage statistics module used by
`bin/simple doc-coverage`. Tests struct construction, percentage calculation,
report formatting, JSON output, threshold checking, multi-module summaries,
and MDSOC capsule-specific coverage.

## Key Concepts

| Concept                | Description |
|------------------------|-------------|
| PublicCoverageStats    | Per-module stats: total/documented/undocumented exports, percentage |
| MdsocCoverageStats     | Per-capsule stats with doc violation tracking |
| calculate_public_coverage | Computes stats from export and documented symbol lists |
| meets_threshold        | Checks coverage >= minimum percentage |
| format_coverage_report | Human-readable text output |
| coverage_to_json       | JSON string output |

## Behavior

- Percentage = (documented / total) * 100; 0 total yields 0.0%
- meets_threshold uses >= comparison (at threshold = pass)
- MDSOC stats include violation messages list
- Summary report aggregates across multiple modules
"""

use std.spec
use app.doc.public_check.statistics.{PublicCoverageStats, MdsocCoverageStats, calculate_public_coverage, format_coverage_report, coverage_to_json, meets_threshold, format_summary_report, summary_to_json, calculate_mdsoc_coverage, format_mdsoc_report, mdsoc_stats_to_json}


# ============================================================================
# Test Group 1: calculate_public_coverage
# ============================================================================

describe "Coverage Documentation Statistics":

    describe "calculate_public_coverage":

        it "calculates 70% coverage for 7 of 10 documented":
            val exports = ["a", "b", "c", "d", "e", "f", "g", "h", "i", "j"]
            val documented = ["a", "b", "c", "d", "e", "f", "g"]
            val stats = calculate_public_coverage("src/lib", exports, documented)
            expect(stats.total_exports).to_equal(10)
            expect(stats.documented_exports).to_equal(7)
            expect(stats.undocumented_exports).to_equal(3)
            expect(stats.module_path).to_equal("src/lib")

        it "handles zero exports gracefully":
            var exports: [text] = []
            var documented: [text] = []
            val stats = calculate_public_coverage("src/empty", exports, documented)
            expect(stats.total_exports).to_equal(0)
            expect(stats.documented_exports).to_equal(0)
            expect(stats.undocumented_exports).to_equal(0)

        it "calculates 100% when all are documented":
            val exports = ["a", "b", "c", "d", "e"]
            val documented = ["a", "b", "c", "d", "e"]
            val stats = calculate_public_coverage("src/full", exports, documented)
            expect(stats.total_exports).to_equal(5)
            expect(stats.documented_exports).to_equal(5)
            expect(stats.undocumented_exports).to_equal(0)

        it "calculates 0% when none are documented":
            val exports = ["a", "b", "c", "d", "e"]
            var documented: [text] = []
            val stats = calculate_public_coverage("src/none", exports, documented)
            expect(stats.total_exports).to_equal(5)
            expect(stats.documented_exports).to_equal(0)
            expect(stats.undocumented_exports).to_equal(5)

    # ============================================================================
    # Test Group 2: PublicCoverageStats Construction
    # ============================================================================

    describe "PublicCoverageStats":

        it "can be constructed with all fields":
            val stats = PublicCoverageStats(
                module_path: "src/lib/math",
                total_exports: 20,
                documented_exports: 15,
                undocumented_exports: 5,
                coverage_percentage: 75.0
            )
            expect(stats.module_path).to_equal("src/lib/math")
            expect(stats.total_exports).to_equal(20)
            expect(stats.documented_exports).to_equal(15)
            expect(stats.undocumented_exports).to_equal(5)

    # ============================================================================
    # Test Group 3: format_coverage_report
    # ============================================================================

    describe "format_coverage_report":

        it "contains module path in output":
            val stats = calculate_public_coverage("src/lib/net", ["a", "b"], ["a"])
            val report = format_coverage_report(stats)
            expect(report).to_contain("src/lib/net")

        it "contains total exports count":
            val stats = calculate_public_coverage("src/lib/net", ["a", "b", "c"], ["a"])
            val report = format_coverage_report(stats)
            expect(report).to_contain("3")

        it "contains documented count":
            val stats = calculate_public_coverage("src/lib/net", ["a", "b", "c"], ["a"])
            val report = format_coverage_report(stats)
            expect(report).to_contain("1")

    # ============================================================================
    # Test Group 4: coverage_to_json
    # ============================================================================

    describe "coverage_to_json":

        it "contains module_path key":
            val stats = calculate_public_coverage("src/lib/io", ["x"], ["x"])
            val json = coverage_to_json(stats)
            expect(json).to_contain("module_path")

        it "contains total_exports key":
            val stats = calculate_public_coverage("src/lib/io", ["x", "y"], ["x"])
            val json = coverage_to_json(stats)
            expect(json).to_contain("total_exports")

        it "contains coverage_percentage key":
            val stats = calculate_public_coverage("src/lib/io", ["x"], ["x"])
            val json = coverage_to_json(stats)
            expect(json).to_contain("coverage_percentage")

    # ============================================================================
    # Test Group 5: meets_threshold
    # ============================================================================

    describe "meets_threshold":

        it "returns true when coverage is above threshold":
            val stats = PublicCoverageStats(
                module_path: "src/lib",
                total_exports: 10,
                documented_exports: 8,
                undocumented_exports: 2,
                coverage_percentage: 80.0
            )
            val result = meets_threshold(stats, 70.0)
            expect(result).to_equal(true)

        it "returns false when coverage is below threshold":
            val stats = PublicCoverageStats(
                module_path: "src/lib",
                total_exports: 10,
                documented_exports: 3,
                undocumented_exports: 7,
                coverage_percentage: 30.0
            )
            val result = meets_threshold(stats, 50.0)
            expect(result).to_equal(false)

        it "returns true when coverage equals threshold exactly":
            val stats = PublicCoverageStats(
                module_path: "src/lib",
                total_exports: 10,
                documented_exports: 5,
                undocumented_exports: 5,
                coverage_percentage: 50.0
            )
            val result = meets_threshold(stats, 50.0)
            expect(result).to_equal(true)

    # ============================================================================
    # Test Group 6: Summary Report (multi-module)
    # ============================================================================

    describe "format_summary_report":

        it "contains overall summary header":
            val s1 = calculate_public_coverage("mod_a", ["a", "b"], ["a"])
            val s2 = calculate_public_coverage("mod_b", ["c", "d", "e"], ["c", "d", "e"])
            val report = format_summary_report([s1, s2])
            expect(report).to_contain("Summary")

        it "contains per-module breakdown":
            val s1 = calculate_public_coverage("mod_a", ["a", "b"], ["a"])
            val s2 = calculate_public_coverage("mod_b", ["c"], ["c"])
            val report = format_summary_report([s1, s2])
            expect(report).to_contain("mod_a")
            expect(report).to_contain("mod_b")

    describe "summary_to_json":

        it "contains summary key":
            val s1 = calculate_public_coverage("mod_a", ["a"], ["a"])
            val json = summary_to_json([s1])
            expect(json).to_contain("summary")

        it "contains modules array key":
            val s1 = calculate_public_coverage("mod_a", ["a"], ["a"])
            val json = summary_to_json([s1])
            expect(json).to_contain("modules")

    # ============================================================================
    # Test Group 7: MDSOC Coverage
    # ============================================================================

    describe "calculate_mdsoc_coverage":

        it "calculates coverage with no violations":
            var violations: [text] = []
            val stats = calculate_mdsoc_coverage("capsule_a", ["fn1", "fn2"], ["fn1", "fn2"], violations)
            expect(stats.capsule_name).to_equal("capsule_a")
            expect(stats.total_public_exports).to_equal(2)
            expect(stats.documented_public_exports).to_equal(2)
            expect(stats.undocumented_public_exports).to_equal(0)
            expect(stats.doc_violations.len()).to_equal(0)

        it "calculates coverage with violations":
            val violations = ["fn3 missing doc comment"]
            val stats = calculate_mdsoc_coverage("capsule_b", ["fn1", "fn2", "fn3"], ["fn1"], violations)
            expect(stats.total_public_exports).to_equal(3)
            expect(stats.documented_public_exports).to_equal(1)
            expect(stats.undocumented_public_exports).to_equal(2)
            expect(stats.doc_violations.len()).to_equal(1)

    describe "MdsocCoverageStats":

        it "can be constructed with all fields":
            val stats = MdsocCoverageStats(
                capsule_name: "render_capsule",
                total_public_exports: 8,
                documented_public_exports: 6,
                undocumented_public_exports: 2,
                coverage_percentage: 75.0,
                doc_violations: ["draw missing doc", "clear missing doc"]
            )
            expect(stats.capsule_name).to_equal("render_capsule")
            expect(stats.total_public_exports).to_equal(8)
            expect(stats.documented_public_exports).to_equal(6)
            expect(stats.doc_violations.len()).to_equal(2)

    describe "format_mdsoc_report":

        it "contains capsule name":
            var violations: [text] = []
            val stats = calculate_mdsoc_coverage("my_capsule", ["fn1"], ["fn1"], violations)
            val report = format_mdsoc_report(stats)
            expect(report).to_contain("my_capsule")

        it "includes violations section when violations exist":
            val violations = ["fn2 needs documentation"]
            val stats = calculate_mdsoc_coverage("cap_x", ["fn1", "fn2"], ["fn1"], violations)
            val report = format_mdsoc_report(stats)
            expect(report).to_contain("Violations")
            expect(report).to_contain("fn2 needs documentation")

    describe "mdsoc_stats_to_json":

        it "contains capsule_name key":
            var violations: [text] = []
            val stats = calculate_mdsoc_coverage("json_cap", ["fn1"], ["fn1"], violations)
            val json = mdsoc_stats_to_json(stats)
            expect(json).to_contain("capsule_name")

        it "contains violations array":
            val violations = ["missing doc"]
            val stats = calculate_mdsoc_coverage("json_cap", ["fn1"], [], violations)
            val json = mdsoc_stats_to_json(stats)
            expect(json).to_contain("violations")
            expect(json).to_contain("missing doc")
