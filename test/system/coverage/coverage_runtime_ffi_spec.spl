# @cover src/lib/nogc_sync_mut/io/coverage_simple.spl 80%
# @feature coverage_runtime_ffi
# tag: system
#
# System tests for runtime coverage FFI wrappers.
# Tests std.io.coverage_simple and std.ffi.coverage modules.
# Requires compiled mode for full test execution.
"""
# Coverage Runtime FFI Specification

**Feature IDs:** #COV-001
**Category:** Testing
**Status:** Implemented

## Overview

Validates the Simple-side FFI wrappers for runtime code coverage.
The runtime exposes `rt_coverage_*` extern functions; these tests verify
the Simple wrapper layer in `coverage_simple.spl` and the low-level
FFI wrappers in `ffi/coverage.spl`.

## Key Concepts

| Concept         | Description |
|-----------------|-------------|
| Decision probe  | Records whether an if/match branch was taken (true/false counts) |
| Condition probe | Records boolean sub-expression evaluation |
| Path probe      | Records execution of a path segment; finalized with path_end |
| CoverageStats   | Struct summarizing totals and percentages from parsed SDN report |
| with_coverage   | High-level helper that clears data, runs a block, returns result |

## Behavior

- All probe functions are no-ops when coverage is not enabled (SIMPLE_COVERAGE != 1)
- coverage_report() returns SDN text (may be empty when no probes recorded)
- parse_coverage_stats() is section-aware: only data lines under decisions/conditions/paths count
- A decision/condition is "covered" when both true_count > 0 AND false_count > 0
"""

use std.spec
use std.io.coverage_simple.{coverage_enabled, coverage_clear, coverage_decision, coverage_condition, coverage_report, with_coverage, parse_coverage_stats, CoverageStats}
use std.ffi.coverage.{coverage_dump_sdn, coverage_dump}


# ============================================================================
# Test Group 1: Coverage State Functions
# ============================================================================

describe "Coverage Runtime FFI":

    describe "coverage_enabled":
        it "returns a bool value":
            val enabled = coverage_enabled()
            # In test environment SIMPLE_COVERAGE is typically not set
            expect(enabled).to_equal(false)

    describe "coverage_clear":
        it "clears coverage data without error":
            coverage_clear()
            # If we reach here, no crash occurred
            expect(true).to_equal(true)

        it "can be called multiple times safely":
            coverage_clear()
            coverage_clear()
            coverage_clear()
            expect(true).to_equal(true)

    # ============================================================================
    # Test Group 2: Coverage Probes
    # ============================================================================

    describe "coverage_decision":
        it "records a decision probe without error":
            coverage_clear()
            coverage_decision("test.spl", 10, 1, true)
            coverage_decision("test.spl", 10, 1, false)
            expect(true).to_equal(true)

    describe "coverage_condition":
        it "records a condition probe without error":
            coverage_clear()
            coverage_condition("test.spl", 20, 1, true)
            coverage_condition("test.spl", 20, 1, false)
            expect(true).to_equal(true)

    # NOTE: coverage_path / coverage_path_end skipped —
    # rt_coverage_path_probe extern not available in v0.9.2 runtime

    # ============================================================================
    # Test Group 3: Coverage Reports
    # ============================================================================

    describe "coverage_report":
        it "returns text":
            coverage_clear()
            val report = coverage_report()
            # Report is text type; may be empty when coverage not enabled
            val is_text = report.len() >= 0
            expect(is_text).to_equal(true)

    # ============================================================================
    # Test Group 4: with_coverage High-Level API
    # ============================================================================

    describe "with_coverage":
        it "clears data before running and returns block result":
            val r = with_coverage(\: 42)
            expect(r).to_equal(42)

        it "returns string result from block":
            val r = with_coverage(\: "hello")
            expect(r).to_equal("hello")

    # ============================================================================
    # Test Group 5: parse_coverage_stats — Section-Aware Parsing
    # ============================================================================

    describe "parse_coverage_stats":

        it "parses valid decisions SDN with covered and uncovered entries":
            val sdn = "decisions |id, file, line, column, true_count, false_count|\n    1, a.spl, 10, 5, 3, 2\n    2, a.spl, 15, 5, 1, 0\nsummary:\n"
            val stats = parse_coverage_stats(sdn)
            expect(stats.decisions_total).to_equal(2)
            expect(stats.decisions_covered).to_equal(1)

        it "parses valid conditions SDN":
            val sdn = "conditions |id, decision_id, file, line, column, true_count, false_count|\n    1, 2, a.spl, 10, 5, 3, 2\nsummary:\n"
            val stats = parse_coverage_stats(sdn)
            expect(stats.conditions_total).to_equal(1)
            expect(stats.conditions_covered).to_equal(1)

        it "returns all zeros for empty string":
            val stats = parse_coverage_stats("")
            expect(stats.decisions_total).to_equal(0)
            expect(stats.decisions_covered).to_equal(0)
            expect(stats.conditions_total).to_equal(0)
            expect(stats.conditions_covered).to_equal(0)
            expect(stats.paths_total).to_equal(0)
            expect(stats.paths_covered).to_equal(0)

        it "returns all zeros for headers only with no data lines":
            val sdn = "decisions |id, file, line, column, true_count, false_count|\nsummary:\n"
            val stats = parse_coverage_stats(sdn)
            expect(stats.decisions_total).to_equal(0)
            expect(stats.decisions_covered).to_equal(0)

        it "calculates decision coverage percentage correctly":
            val sdn = "decisions |id, file, line, column, true_count, false_count|\n    1, a.spl, 10, 5, 3, 2\n    2, a.spl, 15, 5, 1, 0\nsummary:\n"
            val stats = parse_coverage_stats(sdn)
            # 1 covered out of 2 = 50%
            expect(stats.decision_coverage_percent).to_equal(50)

    # ============================================================================
    # Test Group 6: CoverageStats Construction
    # ============================================================================

    describe "CoverageStats":
        it "can be constructed with all fields and accessed":
            val stats = CoverageStats(
                decisions_total: 10,
                decisions_covered: 7,
                conditions_total: 5,
                conditions_covered: 3,
                paths_total: 8,
                paths_covered: 6,
                decision_coverage_percent: 70,
                condition_coverage_percent: 60,
                path_coverage_percent: 75
            )
            expect(stats.decisions_total).to_equal(10)
            expect(stats.decisions_covered).to_equal(7)
            expect(stats.conditions_total).to_equal(5)
            expect(stats.conditions_covered).to_equal(3)
            expect(stats.paths_total).to_equal(8)
            expect(stats.paths_covered).to_equal(6)
            expect(stats.decision_coverage_percent).to_equal(70)
            expect(stats.condition_coverage_percent).to_equal(60)
            expect(stats.path_coverage_percent).to_equal(75)

    # ============================================================================
    # Test Group 7: Low-Level FFI (std.ffi.coverage)
    # ============================================================================

    describe "FFI coverage_dump_sdn":
        it "returns text":
            val dump = coverage_dump_sdn()
            val is_text = dump.len() >= 0
            expect(is_text).to_equal(true)

    describe "FFI coverage_dump":
        it "returns text":
            val dump = coverage_dump()
            val is_text = dump.len() >= 0
            expect(is_text).to_equal(true)
