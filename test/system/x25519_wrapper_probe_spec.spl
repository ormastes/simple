use std.sspec.*
use test.system.os_crypto_ref_helpers.{hex_to_bytes, bytes_to_hex}
use os.crypto.curve25519.{x25519, x25519_base, x25519_fe_probe, x25519_base_fe_probe}
use os.crypto.curve25519_bigint_wrapper.{x25519_bigint_probe, x25519_base_bigint_probe, x25519_bigint_roundtrip_probe, x25519_bigint_mask_probe, x25519_bigint_cswap_probe, x25519_bigint_ladder_probe}

fn _bytes_eq(a: [u8], b: [u8]) -> bool:
    if a.len() != b.len():
        return false
    var i: i64 = 0
    while i < a.len():
        if a[i] != b[i]:
            return false
        i = i + 1
    true

val X25519_A_HEX = "77076d0a7318a57d3c16c17251b26645df4c2f87ebc0992ab177fba51db92c2a"
val X25519_A_PUBLIC_HEX = "8520f0098930a754748b7ddcb43ef75a0dbf3a0d26381af4eba4a98eaa9b4e6a"
val X25519_B_PUBLIC_HEX = "de9edb7d7b7dc1b4d35b61c2ece435373f8343c85b78674dadfc7e146f882b4f"
val X25519_SHARED_HEX = "4a5d9d5ba4ce2de1728e3bf480350f25e07e21c947d19e3376f09b3c1e161742"

describe "probe wrapper":
    it "base":
        val a = hex_to_bytes(X25519_A_HEX)
        val expected = hex_to_bytes(X25519_A_PUBLIC_HEX)
        expect(_bytes_eq(x25519_base(a), expected)).to_equal(true)
    it "shared":
        val a = hex_to_bytes(X25519_A_HEX)
        val b = hex_to_bytes(X25519_B_PUBLIC_HEX)
        expect(bytes_to_hex(x25519(a, b))).to_equal(X25519_SHARED_HEX)

    it "bigint base":
        val a = hex_to_bytes(X25519_A_HEX)
        val expected = hex_to_bytes(X25519_A_PUBLIC_HEX)
        expect(_bytes_eq(x25519_base_bigint_probe(a), expected)).to_equal(true)

    it "bigint shared":
        val a = hex_to_bytes(X25519_A_HEX)
        val b = hex_to_bytes(X25519_B_PUBLIC_HEX)
        val expected = hex_to_bytes(X25519_SHARED_HEX)
        expect(_bytes_eq(x25519_bigint_probe(a, b), expected)).to_equal(true)

    it "bigint mask":
        val b = hex_to_bytes(X25519_B_PUBLIC_HEX)
        expect(x25519_bigint_mask_probe(b).len()).to_equal(32)

    it "bigint roundtrip":
        val b = hex_to_bytes(X25519_B_PUBLIC_HEX)
        expect(x25519_bigint_roundtrip_probe(b).len()).to_equal(32)

    it "bigint cswap":
        expect(x25519_bigint_cswap_probe()).to_equal(1)

    it "bigint ladder":
        expect(x25519_bigint_ladder_probe()).to_be_greater_than(0)
