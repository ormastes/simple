# @tag:system
#
# System spec — SYS-GUI-005: SimpleOS lifecycle cleanup live gate
#                            (Small Complete GUI milestone)
#
# Owner: Agent G5 (Round 12).
#
# Purpose: prove that the live desktop teardown contract holds end-to-end
# under QEMU. The unit-side coverage already exists in
# `test/unit/os/desktop/shell_lifecycle_cleanup_spec.spl` (graceful exit,
# terminate, crash, idempotent reconcile) — this spec is the live half: it
# boots the real desktop stack, runs the same three sub-scenarios via a
# DEDICATED entry file, and asserts on the serial markers + a stable
# post-cleanup framebuffer.
#
# Why a dedicated entry: the canonical `desktop_e2e_entry.spl` is owned by
# SYS-GUI-001/002/004/006 and is on the round-12 forbidden list for this
# agent. The cleanup logic lives in
# `examples/simple_os/arch/x86_64/sys_gui_005_cleanup_entry.spl` instead,
# which boots the same FB+input+compositor+shell stack and emits a
# distinct `[sys-gui-005] *` marker family.
#
# Capture marker: `[sys-gui-005] cleanup-ok`
#   - emitted from `sys_gui_005_cleanup_entry.spl` AFTER all three
#     sub-scenarios pass and the shell has re-rendered the bare desktop.
#
# Asserted serial markers (in order):
#   [sys-gui-005] spl_start
#   [sys-gui-005] boot
#   [sys-gui-005] shell-ready
#   [sys-gui-005] desktop-ready
#   [sys-gui-005] close-issued pid=…
#   [sys-gui-005] app-closed pid=… state=exited
#   [sys-gui-005] surface-released pid=…
#   [sys-gui-005] slot-freed app=hello_world slot=0
#   [sys-gui-005] terminate-issued pid=…
#   [sys-gui-005] terminate-ok pid=…
#   [sys-gui-005] crash-issued pid=…
#   [sys-gui-005] crash-ok pid=…
#   [sys-gui-005] cleanup-ok
#
# Tolerance profile: profile_wm_default (whole-scene >=95%). The post-
# cleanup framebuffer must look like the bare desktop (the wallpaper +
# dock stripe painted via rt_gui_fill4 right before desktop-ready) — i.e.
# all three sub-scenario windows have been purged.
#
# Baseline management:
#   UPDATE_BASELINE=1 bin/simple test test/system/sys_gui_005_cleanup_lifecycle_spec.spl
# On first run with no baseline present on disk the spec records the
# capture as the baseline and passes. Spec body execution is gated on
# Agent γ/Z2's interpreter `std.spec` cascade fix (Blocker 1); the baseline
# ARTIFACT is recorded out-of-band and committed regardless, exactly the
# way G6 did SYS-GUI-006 in Round 11 and SYS-GUI-002 did the cold-start.

use std.spec.*

use os.qemu_runner.{OsTarget, get_desktop_browser_target, build_os}
use os.compositor.qemu_capture.{capture_qemu_vm}
use os.compositor.electron_capture.{CaptureResult}
use os.compositor.screenshot_compare.{ComparisonResult, compare_with_profile}
use os.compositor.tolerance_profile.{ToleranceProfile, profile_wm_default}
use std.common.image.ppm_decode.{decode_ppm_to_argb, PpmImage}
use std.nogc_sync_mut.ffi.io.{file_read_bytes, file_write_bytes, dir_create_all}

use test.qemu.os.common.qemu_os_harness.{
    QemuGuestHandle, can_run_target, file_exists, spawn_guest_with_qmp,
    stop_guest, wait_for_serial_marker}

extern fn rt_env_get(name: text) -> text

# ===========================================================================
# Helpers (mirrored from the SYS-GUI-002/006 specs — kept local so this spec
# is self-contained for diagnosis. Same pattern G6 used.)
# ===========================================================================

fn _cleanup_target() -> OsTarget:
    """Desktop browser target retargeted at the SYS-GUI-005 entry file.

    Reuses every other field (linker script, qemu machine, etc.) from
    `get_desktop_browser_target()` so the boot environment is identical
    to the canonical desktop_e2e lane — only the entry file changes.
    """
    val base = get_desktop_browser_target()
    OsTarget(
        arch: base.arch,
        entry: "examples/simple_os/arch/x86_64/sys_gui_005_cleanup_entry.spl",
        linker_script: base.linker_script,
        target_triple: base.target_triple,
        output: "build/os/simpleos_sys_gui_005_cleanup.elf",
        qemu_system: base.qemu_system,
        qemu_machine: base.qemu_machine,
        qemu_cpu: base.qemu_cpu,
        qemu_memory: base.qemu_memory,
        qemu_bios: base.qemu_bios,
        qemu_extra: base.qemu_extra + ["-vga", "std"],
        gui_mode: false
    )

fn _non_black_count(pixels: [u32]) -> i64:
    var count: i64 = 0
    for px in pixels:
        val rgb = px & 0xFFFFFF
        if rgb != 0:
            count = count + 1
    count

fn _write_ppm_local(pixels: [u32], width: i32, height: i32, path: text) -> bool:
    if pixels.len() == 0 or width <= 0 or height <= 0:
        return false

    val header = "P6\n{width} {height}\n255\n"
    var data: [u8] = []
    for ch in header:
        data = data + [ch as u8]

    var i = 0
    val n = pixels.len()
    while i < n:
        val p = pixels[i]
        val r_byte: u8 = ((p >> 16) & 0xFF) as u8
        val g_byte: u8 = ((p >> 8) & 0xFF) as u8
        val b_byte: u8 = (p & 0xFF) as u8
        data = data + [r_byte, g_byte, b_byte]
        i = i + 1

    file_write_bytes(path, data)
    true

fn _read_baseline_ppm(path: text) -> (bool, [u32], i32, i32, text):
    val bytes = file_read_bytes(path)
    if bytes.len() == 0:
        return (false, [], 0, 0, "missing baseline: {path}")
    val decoded = decode_ppm_to_argb(bytes)
    match decoded:
        Ok(img):
            return (true, img.pixels, img.width, img.height, "")
        Err(msg):
            return (false, [], 0, 0, "ppm decode failed: {msg}")

fn _update_baseline_requested() -> bool:
    val v = rt_env_get("UPDATE_BASELINE") ?? ""
    v == "1" or v == "true"

# ===========================================================================
# Spec
# ===========================================================================

describe "SimpleOS lifecycle cleanup live gate (SYS-GUI-005)":

    it "builds sys_gui_005_cleanup_entry.spl into a baremetal kernel":
        val target = _cleanup_target()
        val ok = build_os(target)
        expect(ok).to_equal(true)
        expect(file_exists(target.output)).to_equal(true)

    it "boots cleanup entry, walks all three sub-scenarios, captures post-cleanup frame":
        val target = _cleanup_target()
        expect(build_os(target)).to_equal(true)
        expect(file_exists(target.output)).to_equal(true)

        if not can_run_target(target):
            print "[sys_gui_005_spec] qemu-system-x86_64 not available, skipping live capture"
            expect(true).to_equal(true)
            return

        val qmp_socket = "/tmp/sys_gui_005_cleanup_qmp.sock"
        val serial_log = "build/os/sys_gui_005_cleanup_qemu_serial.log"
        val capture_ppm = "build/os/sys_gui_005_cleanup_capture.ppm"
        val baseline_dir = "doc/08_tracking/baselines"
        val baseline_path = "{baseline_dir}/sys_gui_005_cleanup.ppm"

        dir_create_all(baseline_dir)
        dir_create_all("build/os")

        match spawn_guest_with_qmp(target, qmp_socket, serial_log):
            Ok(handle):
                # ---- Phase 1: boot reaches desktop-ready ----
                val saw_boot = wait_for_serial_marker(
                    handle, "[sys-gui-005] desktop-ready", 60000)
                if not saw_boot:
                    print "[sys_gui_005_spec] desktop-ready not reached within 60s"
                    stop_guest(handle)
                    expect(false).to_equal(true)
                    return

                # ---- Phase 2: graceful exit sub-scenario ----
                val saw_close = wait_for_serial_marker(
                    handle, "[sys-gui-005] app-closed", 15000)
                expect(saw_close).to_equal(true)
                val saw_surface = wait_for_serial_marker(
                    handle, "[sys-gui-005] surface-released", 5000)
                expect(saw_surface).to_equal(true)
                val saw_slot = wait_for_serial_marker(
                    handle, "[sys-gui-005] slot-freed", 5000)
                expect(saw_slot).to_equal(true)

                # ---- Phase 3: terminate sub-scenario ----
                val saw_term = wait_for_serial_marker(
                    handle, "[sys-gui-005] terminate-ok", 15000)
                expect(saw_term).to_equal(true)

                # ---- Phase 4: crash sub-scenario ----
                val saw_crash = wait_for_serial_marker(
                    handle, "[sys-gui-005] crash-ok", 15000)
                expect(saw_crash).to_equal(true)

                # ---- Phase 5: aggregate cleanup-ok marker ----
                val saw_done = wait_for_serial_marker(
                    handle, "[sys-gui-005] cleanup-ok", 15000)
                if not saw_done:
                    print "[sys_gui_005_spec] cleanup-ok not reached after sub-scenarios"
                    stop_guest(handle)
                    expect(false).to_equal(true)
                    return

                # ---- Phase 6: capture the post-cleanup framebuffer ----
                val result = capture_qemu_vm(qmp_socket, capture_ppm)
                if not result.success:
                    print "[sys_gui_005_spec] QMP screendump failed: {result.error}"
                    stop_guest(handle)
                    expect(false).to_equal(true)
                    return

                val nb = _non_black_count(result.pixels)
                print "[sys_gui_005_spec] captured {result.width}x{result.height}, non-black pixels: {nb} of {result.pixels.len()}"

                if _update_baseline_requested():
                    val wrote = _write_ppm_local(
                        result.pixels, result.width, result.height, baseline_path)
                    print "[sys_gui_005_spec] UPDATE_BASELINE=1 wrote baseline: {baseline_path} (ok={wrote})"
                    stop_guest(handle)
                    expect(wrote).to_equal(true)
                    expect(nb > 0).to_equal(true)
                    return

                val baseline_bytes = file_read_bytes(baseline_path)
                if (not file_exists(baseline_path)) or baseline_bytes.len() == 0:
                    val wrote = _write_ppm_local(
                        result.pixels, result.width, result.height, baseline_path)
                    print "[sys_gui_005_spec] no baseline found, recorded: {baseline_path} (ok={wrote})"
                    stop_guest(handle)
                    expect(wrote).to_equal(true)
                    expect(nb > 0).to_equal(true)
                    return

                val (ok, base_pixels, base_w, base_h, err) = _read_baseline_ppm(baseline_path)
                if not ok:
                    print "[sys_gui_005_spec] baseline read failed: {err}"
                    stop_guest(handle)
                    expect(false).to_equal(true)
                    return

                if base_w != result.width or base_h != result.height:
                    print "[sys_gui_005_spec] baseline dims {base_w}x{base_h} != capture dims {result.width}x{result.height}"
                    stop_guest(handle)
                    expect(false).to_equal(true)
                    return

                val profile = profile_wm_default()
                val cmp: ComparisonResult = compare_with_profile(
                    result.pixels, base_pixels, result.width, result.height, profile)
                val pct_whole = cmp.match_percentage / 100
                val pct_frac = cmp.match_percentage % 100
                print "[sys_gui_005_spec] match: {pct_whole}.{pct_frac}% ({cmp.matching_pixels}/{cmp.total_pixels}) profile={profile.name}"

                stop_guest(handle)

                # Post-cleanup invariants:
                # - the wallpaper + dock stripe paint means non-black > 0
                # - the frame matches the saved baseline within the WM profile
                expect(nb > 0).to_equal(true)
                expect(cmp.match_percentage >= 9500).to_equal(true)
            Err(err):
                print "[sys_gui_005_spec] failed to spawn guest: {err}"
                expect(false).to_equal(true)

    it "has a baselines directory for the SYS-GUI-005 cleanup gate":
        val baseline_dir = "doc/08_tracking/baselines"
        dir_create_all(baseline_dir)
        expect(file_exists(baseline_dir)).to_equal(true)
