use std.spec.{describe, it, expect}
use app.itf.adapter_jira_curl.{JiraClient, jira_curl_view_issue}

# Live smoke against redhat.atlassian.net Cloud v3.
# Placeholder creds — server doesn't validate for public issues.

describe("adapter_jira_curl — anon read against redhat.atlassian.net (Cloud v3)", fn():
    it("view_issue JBEAP-1 returns success with summary", fn():
        val client = JiraClient(
            base_url: "https://redhat.atlassian.net",
            email: "anon@anon.example",
            api_token: "anon-readonly-placeholder",
            curl_path: "curl"
        )
        val (ok, issue, _raw) = jira_curl_view_issue(client, "JBEAP-1")
        expect(ok).to_be(true)
        expect(issue.key).to_be("JBEAP-1")
        expect(issue.summary.len() > 0).to_be(true)
    )
)
