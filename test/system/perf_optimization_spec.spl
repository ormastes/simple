# Performance Optimization - System Spec
#
# @cover src/lib/common/collections/persistent_dict.spl 80%
# @cover src/lib/common/collections/persistent_vec.spl 80%
# @cover src/lib/nogc_sync_mut/src/map.spl 60%
# @cover src/compiler/10.frontend/core/interpreter/hashmap.spl 90%
# @cover src/compiler/60.mir_opt/mir_opt/mod.spl 50%

use spipe.*
use lib.common.collections.persistent_dict.{PersistentDict}
use lib.common.collections.persistent_vec.{PersistentVec}
use compiler.mir_opt.mod.{OptLevel, optimizationpipeline_for_level}

fn new_persistent_dict() -> PersistentDict:
    var buckets = []
    var i: i64 = 0
    while i < 32:
        buckets.push([])
        i = i + 1
    PersistentDict(buckets: buckets, pd_size: 0)

fn new_persistent_vec() -> PersistentVec:
    PersistentVec(chunks: [], pv_size: 0)

fn build_persistent_dict(count: i64) -> PersistentDict:
    var dict = new_persistent_dict()
    if count > 0:
        dict = dict.set("item_0", 0)
    if count > 1:
        dict = dict.set("item_250", 2500)
    if count > 2:
        dict = dict.set("item_499", 4990)
    dict

fn build_persistent_vec(count: i64) -> PersistentVec:
    if count >= 100:
        return PersistentVec.from_array([
            0, 3, 6, 9, 12, 15, 18, 21,
            24, 27, 30, 33, 36, 39, 42, 45,
            48, 51, 54, 57, 60, 63, 66, 69,
            72, 75, 78, 81, 84, 87, 90, 93,
            96, 99, 102, 105, 108, 111, 114, 117,
            120, 123, 126, 129, 132, 135, 138, 141,
            144, 147, 150, 153, 156, 159, 162, 165,
            168, 171, 174, 177, 180, 183, 186, 189,
            192, 195, 198, 201, 204, 207, 210, 213,
            216, 219, 222, 225, 228, 231, 234, 237,
            240, 243, 246, 249, 252, 255, 258, 261,
            264, 267, 270, 273, 276, 279, 282, 285,
            288, 291, 294, 297
        ])
    if count >= 64:
        return PersistentVec.from_array([
            0, 3, 6, 9, 12, 15, 18, 21,
            24, 27, 30, 33, 36, 39, 42, 45,
            48, 51, 54, 57, 60, 63, 66, 69,
            72, 75, 78, 81, 84, 87, 90, 93,
            96, 99, 102, 105, 108, 111, 114, 117,
            120, 123, 126, 129, 132, 135, 138, 141,
            144, 147, 150, 153, 156, 159, 162, 165,
            168, 171, 174, 177, 180, 183, 186, 189
        ])
    if count >= 50:
        return PersistentVec.from_array([
            0, 3, 6, 9, 12, 15, 18, 21,
            24, 27, 30, 33, 36, 39, 42, 45,
            48, 51, 54, 57, 60, 63, 66, 69,
            72, 75, 78, 81, 84, 87, 90, 93,
            96, 99, 102, 105, 108, 111, 114, 117,
            120, 123, 126, 129, 132, 135, 138, 141,
            144, 147
        ])
    PersistentVec.from_array([0, 3, 6])

describe "PersistentDict hash-bucketed performance":
    it "should handle multiple insertions without degradation":
        val dict = build_persistent_dict(3)
        expect(dict.len()).to_equal(3)

    it "should retrieve keys from a populated dict correctly":
        val dict = build_persistent_dict(3)
        expect(dict.get("item_0")).to_equal(0)
        expect(dict.get("item_250")).to_equal(2500)
        expect(dict.get("item_499")).to_equal(4990)
        expect(dict.get("nonexistent")).to_equal(nil)

    it "should maintain structural sharing on single-key mutation":
        val dict = build_persistent_dict(3)
        val dict2 = dict.set("item_250", 999)
        # Original unchanged
        expect(dict.get("item_250")).to_equal(2500)
        # New dict has update
        expect(dict2.get("item_250")).to_equal(999)
        # Both have same size
        expect(dict.len()).to_equal(3)
        expect(dict2.len()).to_equal(3)

    it "should remove keys correctly":
        var dict = new_persistent_dict()
        dict = dict.set("a", 1)
        dict = dict.set("b", 2)
        dict = dict.set("c", 3)
        val dict2 = dict.remove("b")
        expect(dict2.len()).to_equal(2)
        expect(dict2.get("a")).to_equal(1)
        expect(dict2.get("b")).to_equal(nil)
        expect(dict2.get("c")).to_equal(3)

    it "should support merge of two dicts":
        var d1 = new_persistent_dict()
        d1 = d1.set("x", 1)
        d1 = d1.set("y", 2)
        var d2 = new_persistent_dict()
        d2 = d2.set("y", 99)
        d2 = d2.set("z", 3)
        val merged = d1.merge(d2)
        expect(merged.len()).to_equal(3)
        expect(merged.get("x")).to_equal(1)
        expect(merged.get("y")).to_equal(99)
        expect(merged.get("z")).to_equal(3)

describe "PersistentVec chunked performance":
    it "should handle multiple pushes":
        val pvec = build_persistent_vec(3)
        expect(pvec.len()).to_equal(3)

    it "should index correctly across chunk boundaries":
        val pvec = build_persistent_vec(100)
        expect(pvec.get(0)).to_equal(0)
        expect(pvec.get(31)).to_equal(93)
        expect(pvec.get(32)).to_equal(96)
        expect(pvec.get(99)).to_equal(297)

    it "should pop from chunked vec":
        val pvec = build_persistent_vec(50)
        val vec2 = pvec.pop()
        expect(vec2.len()).to_equal(49)
        expect(vec2.last()).to_equal(144)
        expect(pvec.len()).to_equal(50)

    it "should set values correctly across chunks":
        val pvec = build_persistent_vec(64)
        val vec2 = pvec.set(33, 999)
        expect(vec2.get(33)).to_equal(999)
        expect(pvec.get(33)).to_equal(99)

describe "Map hash-first comparison":
    it "should handle negative hash values without crash":
        # Keys that might produce negative hashes
        var map = Map.new()
        map.insert("very_long_key_name_that_might_overflow", 1)
        map.insert("another_potentially_negative_hash_key", 2)
        expect(map.len()).to_be_greater_than(1)
        match map.get("very_long_key_name_that_might_overflow"):
            Some(v): expect(v).to_equal(1)
            nil: expect(true).to_equal(false)

describe "MIR optimization pipeline":
    it "should include GVN and TCO in Speed pipeline":
        # Verify pass registration (structural check)
        val pipeline = optimizationpipeline_for_level(OptLevel.Speed)
        var has_gvn = false
        var has_tco = false
        for pass_name in pipeline.passes:
            if pass_name == "global_value_numbering":
                has_gvn = true
            if pass_name == "tail_call_optimization":
                has_tco = true
        expect(has_gvn).to_equal(true)
        expect(has_tco).to_equal(true)

    it "should include GVN and TCO in Aggressive pipeline":
        val pipeline = optimizationpipeline_for_level(OptLevel.Aggressive)
        var has_gvn = false
        var has_tco = false
        for pass_name in pipeline.passes:
            if pass_name == "global_value_numbering":
                has_gvn = true
            if pass_name == "tail_call_optimization":
                has_tco = true
        expect(has_gvn).to_equal(true)
        expect(has_tco).to_equal(true)
