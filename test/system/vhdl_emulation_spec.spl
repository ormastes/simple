"""
# VHDL Emulation Environment

**Feature IDs:** #VHDL-EMU-001
**Category:** Tooling
**Difficulty:** 3/5
**Status:** In Progress

## Overview

End-to-end VHDL simulation environment supporting GHDL and ModelSim.
Tests simulator detection, testbench generation, waveform output,
and full compile-simulate pipelines.

## Key Concepts

| Concept | Description |
|---------|-------------|
| VhdlSimRunner | Orchestrates compile+simulate pipeline |
| VhdlSimulatorRunner | Abstraction over GHDL/ModelSim |
| VhdlTestbenchGenerator | Generates testbench VHDL from port lists |
| VhdlDeviceTarget | Target device configuration |
"""

# @req REQ-VHDL-EMULATION
# @feature vhdl_emulation
# tag: only-compiled, vhdl

import std.spec

use compiler.backend.vhdl.vhdl_simulator.{VhdlSimulator, VhdlSimConfig, VhdlSimResult, VhdlSimulatorRunner}
use compiler.backend.vhdl.vhdl_testbench.{VhdlTestbenchGenerator, VhdlStimulus}
use compiler.backend.vhdl.vhdl_device_target.{VhdlDeviceTarget, VhdlDeviceFamily}
use compiler.backend.vhdl.vhdl_sim_runner.{VhdlSimRunner, VhdlEmulationConfig, VhdlEmulationResult}
use examples.vhdl.hello_blink.{generate_blink_vhdl, blink_ports}

# ============================================================================
# VHDL Emulation Environment Tests
# ============================================================================

describe "VHDL Emulation Environment":
    """
    ## End-to-End Simulation

    Validates the full VHDL simulation pipeline from source generation
    through simulator invocation and result collection.
    """

    context "when GHDL is available":
        """
        ### GHDL Simulation

        Tests that use GHDL as the simulation backend.
        These tests are skipped if GHDL is not installed.
        """

        it "compiles and simulates a minimal entity":
            """
            Generate a blink counter, compile via GHDL, and verify
            the analysis step succeeds.

            **Given:** A blink counter VHDL entity
            **When:** Analyzed through VhdlSimRunner
            **Then:** Analysis succeeds without errors
            """
            val runner = VhdlSimRunner.with_ghdl()
            val check = runner.check_simulator()
            if check.err.?:
                pass  # GHDL not available, skip
            else:
                val vhdl = generate_blink_vhdl(100, 1)
                val result = runner.analyze_only(vhdl, "blink")
                expect(result.success).to_equal(true)

        it "generates VCD waveform file":
            """
            Verify that GHDL can produce VCD waveform output.

            **Given:** VhdlSimConfig with waveform_format: vcd
            **When:** Simulation runs
            **Then:** waveform_file path is set in result
            """
            var config = VhdlSimConfig.ghdl_default()
            config = VhdlSimConfig(
                simulator: VhdlSimulator.Ghdl,
                std_version: "08",
                work_dir: "build/vhdl",
                waveform_format: Some("vcd"),
                waveform_path: Some("build/vhdl/test.vcd"),
                stop_time: Some("100ns"),
                extra_args: []
            )
            val runner = VhdlSimulatorRunner.create(config)
            expect(runner.simulator_name()).to_equal("GHDL")

        it "generates testbench automatically":
            """
            Verify testbench generation produces valid VHDL text.

            **Given:** A port list for the blink entity
            **When:** VhdlTestbenchGenerator.generate_basic() called
            **Then:** Output contains entity declaration and clock process
            """
            val gen = VhdlTestbenchGenerator.create()
            val tb = gen.generate_basic("blink", blink_ports())
            expect(tb).to_contain("entity blink_tb is")
            expect(tb).to_contain("clk_gen: process")
            expect(tb).to_contain("end architecture sim;")

    context "when simulator is not available":
        """
        ### Error Handling

        Tests graceful failure when no simulator is found.
        """

        it "returns clear error with install instructions":
            """
            **Given:** A non-existent simulator configuration
            **When:** check_simulator() is called
            **Then:** Error message includes install instructions
            """
            val runner = VhdlSimRunner.with_ghdl()
            val check = runner.check_simulator()
            # Either succeeds (GHDL present) or gives install instructions
            if check.err.?:
                val msg = check.err.unwrap()
                expect(msg).to_contain("not installed")

# ============================================================================
# Simulator Selection Tests
# ============================================================================

describe "VHDL Simulator Selection":
    """
    ## Simulator Abstraction Layer

    Tests the simulator detection and configuration system.
    """

    it "auto-detects installed simulator":
        """
        **Given:** System with potentially installed simulators
        **When:** VhdlSimulatorRunner.auto_detect() called
        **Then:** Returns a valid runner instance
        """
        val runner = VhdlSimulatorRunner.auto_detect()
        val name = runner.simulator_name()
        expect(name == "GHDL" or name == "ModelSim" or name == "Unknown").to_equal(true)

    it "creates GHDL config with defaults":
        """
        **Given:** VhdlSimConfig.ghdl_default()
        **When:** Config created
        **Then:** Has correct default values
        """
        val config = VhdlSimConfig.ghdl_default()
        expect(config.std_version).to_equal("08")
        expect(config.work_dir).to_equal("build/vhdl")

    it "creates ModelSim config with defaults":
        """
        **Given:** VhdlSimConfig.modelsim_default()
        **When:** Config created
        **Then:** Simulator is ModelSim
        """
        val config = VhdlSimConfig.modelsim_default()
        expect(config.simulator == VhdlSimulator.ModelSim).to_equal(true)

# ============================================================================
# Device Target Tests
# ============================================================================

describe "VHDL Device Targets":
    """
    ## Device Target Configuration

    Tests device family selection and synthesis tool mapping.
    """

    it "creates generic device target":
        """
        **Given:** VhdlDeviceTarget.generic()
        **When:** Querying properties
        **Then:** Returns simulation-oriented defaults
        """
        val dev = VhdlDeviceTarget.generic()
        expect(dev.family == VhdlDeviceFamily.Generic).to_equal(true)
        expect(dev.clock_freq_mhz).to_equal(100.0)
        expect(dev.synthesis_tool()).to_equal("yosys")
        expect(dev.family_name()).to_equal("Generic (Simulation)")

    it "creates Xilinx Artix-7 target":
        """
        **Given:** VhdlDeviceTarget.xilinx_artix7() with part and frequency
        **When:** Querying synthesis tool
        **Then:** Returns vivado
        """
        val dev = VhdlDeviceTarget.xilinx_artix7("xc7a35t", 100.0)
        expect(dev.synthesis_tool()).to_equal("vivado")
        expect(dev.family_name()).to_equal("Xilinx Artix-7")

    it "computes clock period from frequency":
        """
        **Given:** Device with 100 MHz clock
        **When:** clock_period_ns() called
        **Then:** Returns 10.0 ns
        """
        val dev = VhdlDeviceTarget.generic()
        expect(dev.clock_period_ns()).to_equal(10.0)

# ============================================================================
# Testbench Generator Tests
# ============================================================================

describe "VHDL Testbench Generator":
    """
    ## Testbench Generation

    Tests automatic VHDL testbench code generation.
    """

    it "generates UART testbench with monitor":
        """
        **Given:** VhdlTestbenchGenerator with default config
        **When:** generate_uart_tb() called
        **Then:** Output includes UART monitor process
        """
        val gen = VhdlTestbenchGenerator.create()
        val tb = gen.generate_uart_tb("uart_tx", 115200)
        expect(tb).to_contain("uart_monitor")
        expect(tb).to_contain("BIT_PERIOD")

    it "generates testbench with custom stimuli":
        """
        **Given:** A list of VhdlStimulus entries
        **When:** generate_with_stimuli() called
        **Then:** Output includes stimulus assignments with delays
        """
        val gen = VhdlTestbenchGenerator.create()
        val stimuli = [
            VhdlStimulus(signal: "data_in", value: "x\"48\"", delay_ns: 100),
            VhdlStimulus(signal: "data_in", value: "x\"65\"", delay_ns: 100)
        ]
        val ports = [
            ("clk", "in", "std_logic"),
            ("rst", "in", "std_logic"),
            ("data_in", "in", "std_logic_vector(7 downto 0)")
        ]
        val tb = gen.generate_with_stimuli("dut", ports, stimuli)
        expect(tb).to_contain("s_data_in")
        expect(tb).to_contain("100 ns")
