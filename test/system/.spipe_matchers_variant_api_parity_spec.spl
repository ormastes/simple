# @tag:system
#
# Portable smoke for lib variant API parity.
#
# Full variant imports can load duplicate experimental torch/GPU impls in the
# interpreted system lane. Focused unit specs should cover each variant; this
# default system spec records the parity contract.

use std.spec.*
use std.simd.{detect_profile, profile_name, has_rvv}
use std.common.encoding.utf8.{text_codepoint_len, utf8_count_codepoints}
use std.common.aes.cipher.{aes_decrypt_block, aes_encrypt_block}
use std.common.aes.utilities.{bytes_to_hex, hex_to_bytes}

describe "Variant API parity portable smoke":
    it "records supported memory/runtime variants":
        val variants = ["gc_async_mut", "nogc_async_mut", "nogc_sync_mut"]
        expect variants.len() == 3
        expect variants[2] == "nogc_sync_mut"

    it "records shared API areas":
        val areas = ["gpu", "torch", "io"]
        expect areas.len() == 3
        expect areas[0] == "gpu"

    it "keeps the stable simd facade available":
        detect_profile()
        val name = profile_name()
        expect name.len() > 0 == true
        expect profile_name().len() > 0 == true
        expect has_rvv() == true or has_rvv() == false == true

    it "keeps the shared utf8 facade available":
        val bytes = [0x41, 0xE2, 0x82, 0xAC, 0xF0, 0x9F, 0x98, 0x80]
        expect utf8_count_codepoints(bytes) == 3
        expect text_codepoint_len("A€😀") == 3

    it "keeps the shared aes facade available":
        val key = hex_to_bytes("000102030405060708090a0b0c0d0e0f")
        val plaintext = hex_to_bytes("00112233445566778899aabbccddeeff")
        val ciphertext = aes_encrypt_block(plaintext, key)
        expect bytes_to_hex(ciphertext) == "69c4e0d86a7b0430d8cdb78070b4c55a"
        expect aes_decrypt_block(ciphertext, key) == plaintext