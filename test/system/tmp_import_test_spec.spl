use std.spec
use app.qemu.commands.{parse_flag}

describe "qemu subcommand parse_flag":
    it "parse_flag extracts --arch value":
        val args = ["--arch", "x86_64", "--kernel", "boot.elf"]
        val arch = parse_flag(args, "--arch")
        expect(arch).to_equal("x86_64")

    it "parse_flag extracts --kernel value":
        val args = ["--arch", "riscv32", "--kernel", "boot.elf", "--trace", "out.srrq"]
        val kernel = parse_flag(args, "--kernel")
        expect(kernel).to_equal("boot.elf")

    it "parse_flag extracts --gdb-port value":
        val args = ["--kernel", "boot.elf", "--trace", "rec.srrq", "--gdb-port", "5555"]
        val port = parse_flag(args, "--gdb-port")
        expect(port).to_equal("5555")

    it "parse_flag returns empty text for missing flag":
        val args = ["--arch", "x86_64"]
        val missing = parse_flag(args, "--kernel")
        expect(missing).to_equal("")

    it "parse_flag returns empty for unrelated args":
        val args = ["--unrelated", "value"]
        val missing = parse_flag(args, "--arch")
        expect(missing).to_equal("")

    it "parse_flag extracts --qmp socket path":
        val args = ["save", "snap1", "--qmp", "/tmp/qemu-qmp.sock"]
        val qmp = parse_flag(args, "--qmp")
        expect(qmp).to_equal("/tmp/qemu-qmp.sock")

    it "parse_flag extracts --machine value":
        val args = ["--arch", "aarch64", "--kernel", "k.elf", "--machine", "virt"]
        val machine = parse_flag(args, "--machine")
        expect(machine).to_equal("virt")
