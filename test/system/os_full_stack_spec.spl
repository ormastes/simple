# OS Full Stack Integration Test
#
# Runs all OS subsystem tests in sequence:
#   1. Storage (NVMe + FAT32 + VFS)
#   2. Network (VirtIO-net + TCP/IP + sockets)
#   3. Shell (ShellApp + VFS commands)
#   4. SSH (Ed25519, packet codec, auth, channels)
#
# QEMU scenario: x64-full-stack
# Expects: FAT32 disk image with fixture files + VirtIO-net
#
# This is the top-level integration entry point. Each subsystem reports
# its own pass/fail on serial. This test aggregates results at the end.
#
# This test runs as a baremetal OS entry point, not under the SSpec harness.

use os.kernel.boot.init_services.{init_services, services_storage_ready, services_network_ready}
use os.services.vfs.vfs_init.{g_vfs, g_vfs_initialized}
use os.posix.mod.{posix_init}
use os.posix.fd_io.{posix_open, posix_read, posix_write, posix_close}
use os.posix.fd_table.{O_RDONLY}
use os.posix.socket_compat.{posix_socket, posix_close_socket, sockaddr_any, AF_INET, SOCK_STREAM, SOCK_DGRAM}
use os.apps.shell.shell_app.{ShellApp}
use os.apps.sshd.sshd.{SshDaemon}
use os.apps.sshd.ssh_packet.{ssh_packet_build, ssh_packet_read}
use os.apps.sshd.ssh_auth.{SshUserDb}
use os.apps.sshd.ssh_channel.{ChannelTable, ChannelType, DEFAULT_WINDOW_SIZE, DEFAULT_MAX_PACKET}
use os.crypto.ed25519.{ed25519_self_test}
use os.userlib.syscall_raw.{syscall}

extern fn serial_println(msg: text)
extern fn rt_exit(code: i32)

val ISA_DEBUG_EXIT_PORT: u64 = 0xf4

var _total_pass: u32 = 0
var _total_fail: u32 = 0
var _section_pass: u32 = 0
var _section_fail: u32 = 0

fn _assert(condition: bool, name: text):
    if condition:
        serial_println("[TEST PASS] {name}")
        _section_pass = _section_pass + 1
        _total_pass = _total_pass + 1
    else:
        serial_println("[TEST FAIL: {name}]")
        _section_fail = _section_fail + 1
        _total_fail = _total_fail + 1

fn _section_start(name: text):
    _section_pass = 0
    _section_fail = 0
    serial_println("")
    serial_println("--- {name} ---")

fn _section_end(name: text):
    serial_println("[{name}] {_section_pass} passed, {_section_fail} failed")

fn os_full_stack_test():
    """Entry point for full OS integration test."""
    serial_println("=== OS Full Stack Integration Test ===")
    serial_println("")

    # Initialize POSIX and boot all services
    posix_init()
    init_services()

    # ==================================================================
    # Section 1: Storage
    # ==================================================================
    _section_start("Storage")

    _assert(g_vfs_initialized, "VFS initialized")
    _assert(services_storage_ready(), "Storage service ready")

    val fd = posix_open("/hello.txt", O_RDONLY, 0)
    _assert(fd >= 0, "Open /hello.txt")
    if fd >= 0:
        var buf: [u8; 256] = [0; 256]
        val n = posix_read(fd, buf as u64, 256)
        _assert(n > 0, "Read /hello.txt ({n} bytes)")
        posix_close(fd)

    if g_vfs != nil:
        val entries = g_vfs.readdir("/")
        _assert(entries.is_ok(), "readdir /")
    else:
        _assert(false, "readdir / (VFS nil)")

    _section_end("Storage")

    # ==================================================================
    # Section 2: Network
    # ==================================================================
    _section_start("Network")

    val tcp_fd = posix_socket(AF_INET, SOCK_STREAM, 0)
    _assert(true, "TCP socket call does not crash")
    val udp_fd = posix_socket(AF_INET, SOCK_DGRAM, 0)
    _assert(true, "UDP socket call does not crash")
    val bad_fd = posix_socket(99, SOCK_STREAM, 0)
    _assert(bad_fd < 0, "Invalid domain rejected")

    if tcp_fd >= 0:
        posix_close_socket(tcp_fd.to_i32())
    if udp_fd >= 0:
        posix_close_socket(udp_fd.to_i32())

    _section_end("Network")

    # ==================================================================
    # Section 3: Shell
    # ==================================================================
    _section_start("Shell")

    if g_vfs_initialized:
        var shell = ShellApp.with_vfs(g_vfs)
        _assert(shell.running, "Shell created and running")

        shell.output_lines = []
        shell.execute("pwd")
        _assert(shell.output_lines.len() > 0, "pwd produces output")

        shell.output_lines = []
        shell.execute("echo fullstack test")
        _assert(shell.output_lines.len() > 0, "echo produces output")

        shell.output_lines = []
        shell.execute("ls /")
        _assert(shell.output_lines.len() > 0, "ls / produces output")

        shell.execute("exit")
        _assert(not shell.running, "exit stops shell")
    else:
        serial_println("[SKIP] Shell tests (VFS not initialized)")
        _assert(false, "Shell tests skipped")

    _section_end("Shell")

    # ==================================================================
    # Section 4: SSH
    # ==================================================================
    _section_start("SSH")

    val self_test = ed25519_self_test()
    _assert(self_test.is_ok(), "Ed25519 self-test")

    # Packet round-trip
    var payload: [u8] = [0x14, 0x01, 0x02]
    val encoded = ssh_packet_build(payload, 0)
    val decoded = ssh_packet_read(encoded, 0)
    if decoded.is_ok():
        val pair = decoded.unwrap()
        _assert(pair.0.payload.len() == 3, "SSH packet round-trip")
    else:
        _assert(false, "SSH packet round-trip (decode error)")

    # Auth
    var db = SshUserDb.new()
    db.add_user("root", "simpleos")
    _assert(db.authenticate_password("root", "simpleos"), "SSH auth accept")
    _assert(not db.authenticate_password("root", "wrong"), "SSH auth reject")

    # Channel table
    var channels = ChannelTable.new()
    val ch = channels.open(ChannelType.Session, 0, DEFAULT_WINDOW_SIZE, DEFAULT_MAX_PACKET)
    _assert(channels.find(ch) != nil, "Channel open and find")

    # Daemon construction
    val daemon = SshDaemon.new(22)
    _assert(not daemon.is_running(), "SshDaemon not running before start")

    _section_end("SSH")

    # ==================================================================
    # Final Summary
    # ==================================================================
    serial_println("")
    serial_println("=========================================")
    serial_println("Full Stack: {_total_pass} passed, {_total_fail} failed")
    serial_println("=========================================")
    if _total_fail == 0:
        serial_println("[ALL TESTS PASSED]")
    else:
        serial_println("[TESTS FAILED: {_total_fail}]")

    # ISA debug-exit
    syscall(ISA_DEBUG_EXIT_PORT, 0, 0, 0, 0, 0)
