@allow(primitive_api)
"""
# SSH RSA Host-Key Signing Specification

**Feature IDs:** N/A
**Category:** Infrastructure
**Difficulty:** 3/5
**Status:** Implemented

## Overview

End-to-end test for the `rsa-sha2-256` path in `ssh_sign_exchange_hash`.
Verifies that:
  1. The function produces a correctly-framed SSH signature blob
     (algo string + raw-sig string) and that the raw signature
     verifies against the known SPKI public key.
  2. The function returns `Err` when `rsa_pkcs8` is `nil`.
  3. The algo-name header embedded in the blob is exactly `"rsa-sha2-256"`.

tag: system, crypto, ssh
"""

use std.spipe.*
use std.nogc_sync_mut.io.signature_ffi.{rsa_sha256_verify}
use os.apps.sshd.ssh_kex.{HostKeySet, ssh_sign_exchange_hash}
use os.apps.sshd.ssh_packet.{ssh_get_text, ssh_get_string, SshTextResult, SshStringResult}
use test.system.os_crypto_ref_helpers.{hex_to_bytes}

# ============================================================================
# Fixtures
# Duplicated from os_crypto_ref_signature_spec.spl — cross-spec val imports
# are not idiomatic in this repo; each spec is self-contained.
# ============================================================================

# RSA 2048-bit PKCS#8 v1 DER private key
# Source: src/compiler_rust/vendor/ring/tests/rsa_test_private_key_2048.p8
val RSA_PKCS8_HEX = ""

# RSA 2048-bit SPKI DER public key (extracted from private key via openssl pkey -pubout)
# Paired with RSA_PKCS8_HEX above; source: os_crypto_ref_signature_spec.spl.
val RSA_SPKI_HEX = ""

# A 32-byte exchange hash used as the message to sign in all tests.
# Arbitrary bytes — signing does not require a real SHA-256 digest.
fn _make_exchange_hash() -> [u8]:
    var h: [u8] = []
    var i: u64 = 0
    while i < 32:
        h.push((i + 1).to_u8())
        i = i + 1
    h

# ============================================================================
# Test Group: rsa-sha2-256 host-key signing via ssh_sign_exchange_hash
# ============================================================================

describe "ssh_sign_exchange_hash rsa-sha2-256":
    """
    ## rsa-sha2-256 Host-Key Signing

    Validates the end-to-end rsa-sha2-256 path in `ssh_sign_exchange_hash`:
    the function signs an exchange hash with an RSA PKCS#8 key,
    wraps the result in an SSH wire-format blob (algo string + raw-sig string),
    and returns Ok.  The raw signature is verified against the matching SPKI
    public key.  Absence of the key must return Err.
    """

    it "rsa-sha2-256 signs and the raw signature verifies with rsa_sha256_verify":
        # Arrange
        val pkcs8 = hex_to_bytes(RSA_PKCS8_HEX)
        val spki  = hex_to_bytes(RSA_SPKI_HEX)
        val exchange_hash = _make_exchange_hash()
        val host_keys = HostKeySet(
            ed25519_seed: nil,
            rsa_pkcs8: pkcs8,
            ecdsa_p256_pkcs8: nil
        )

        # Act
        val result = ssh_sign_exchange_hash("rsa-sha2-256", host_keys, exchange_hash)

        # Assert — signing succeeded
        expect(result.is_ok()).to_equal(true)
        var blob = result.unwrap()

        # Parse algo-name field (offset 0)
        var r_algo = ssh_get_text(blob, 0)
        expect(r_algo.is_ok()).to_equal(true)
        var algo_res = r_algo.unwrap()

        # Parse raw-signature field (immediately after algo-name)
        var r_sig = ssh_get_string(blob, algo_res.next_offset)
        expect(r_sig.is_ok()).to_equal(true)
        var sig_res = r_sig.unwrap()
        var raw_sig = sig_res.data

        # Verify raw signature against SPKI public key
        val verified = rsa_sha256_verify(spki, exchange_hash, raw_sig)
        expect(verified).to_equal(true)

    it "rsa-sha2-256 signing fails when rsa_pkcs8 is nil":
        # Arrange
        val exchange_hash = _make_exchange_hash()
        val host_keys = HostKeySet(
            ed25519_seed: nil,
            rsa_pkcs8: nil,
            rsa_public_blob: nil,
            ecdsa_p256_pkcs8: nil
        )

        # Act
        val result = ssh_sign_exchange_hash("rsa-sha2-256", host_keys, exchange_hash)

        # Assert — must return Err
        expect(result.is_ok()).to_equal(false)

    it "rsa-sha2-256 signature blob has correct algorithm name header":
        # Arrange
        val pkcs8 = hex_to_bytes(RSA_PKCS8_HEX)
        val exchange_hash = _make_exchange_hash()
        val host_keys = HostKeySet(
            ed25519_seed: nil,
            rsa_pkcs8: pkcs8,
            ecdsa_p256_pkcs8: nil
        )

        # Act
        val result = ssh_sign_exchange_hash("rsa-sha2-256", host_keys, exchange_hash)
        expect(result.is_ok()).to_equal(true)
        var blob = result.unwrap()

        # Parse and assert algo-name field
        var r_algo = ssh_get_text(blob, 0)
        expect(r_algo.is_ok()).to_equal(true)
        var algo_res = r_algo.unwrap()
        var algo_name = algo_res.value
        expect(algo_name).to_equal("rsa-sha2-256")
