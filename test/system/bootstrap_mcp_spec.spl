# @cover scripts/bootstrap/bootstrap-from-scratch.sh 30%
# @cover scripts/setup.sh 20%
"""
# Bootstrap MCP Server Native Build Specification

**Feature IDs:** #MCP-BOOT-001
**Category:** Tooling
**Difficulty:** 3/5
**Status:** Draft
**Requirements:** N/A
**Plan:** .sstack/native-mcp-build-bootstrap/state.md
**Design:** N/A
**Research:** N/A

## Overview

System tests for native MCP server compilation in the bootstrap pipeline.
Verifies that after bootstrap with --deploy, both MCP server binaries
(simple_mcp_server, simple_lsp_mcp_server) exist, are executable, and
respond to JSON-RPC initialize requests.

Shell-level integration tests (AC-1 through AC-4, AC-6, AC-7) are defined
as verification commands in the state file. This SSpec file covers AC-5:
runtime validation that MCP servers respond to JSON-RPC initialize.

## Key Concepts

| Concept              | Description                                             |
|----------------------|---------------------------------------------------------|
| native-build         | Compiler command that produces a platform-native binary  |
| MCP server           | JSON-RPC stdio server implementing Model Context Proto  |
| initialize           | First JSON-RPC request a client sends to an MCP server  |
| bootstrap pipeline   | Multi-stage build: Rust seed -> Simple compiler -> self  |
| platform triple      | Target identifier e.g. x86_64-unknown-linux-gnu         |

## Behavior

- After bootstrap --deploy, bin/simple_mcp_server is a symlink to a native binary
- After bootstrap --deploy, bin/simple_lsp_mcp_server is a symlink to a native binary
- Both servers accept JSON-RPC initialize on stdin and return capabilities
- The --no-mcp flag skips MCP server compilation entirely

## Related Specifications

- [CLI MCP Completeness](cli_mcp_completeness_spec.spl)
- [OS Compiler Bootstrap](os_compiler_bootstrap_spec.spl)
- [T32 MCP Lifecycle](t32_mcp_lifecycle_spec.spl)
"""

# @req REQ-MCP-BOOT-001
# @feature native_mcp_bootstrap
# tag: system, slow

use std.spec
use std.io_runtime.{file_exists}

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_file_read_text(path: text) -> text
extern fn rt_env_get(name: text) -> text

struct ProcessOutput:
    out_text: text
    err_text: text
    exit_code: i64

# ============================================================================
# Helpers
# ============================================================================

fn detect_platform() -> text:
    val (uname_out, _, rc) = rt_process_run("uname", ["-s"])
    if rc != 0:
        return "unknown"
    val os = uname_out.trim().to_lower()
    val (arch_out, _, rc2) = rt_process_run("uname", ["-m"])
    if rc2 != 0:
        return "unknown"
    val arch = arch_out.trim()
    if os == "linux":
        return "{arch}-unknown-linux-gnu"
    elif os == "darwin":
        return "{arch}-apple-darwin-macho"
    "unknown"

fn mcp_binary_path(name: text) -> text:
    val triple = detect_platform()
    "bin/release/{triple}/{name}"

fn send_initialize_request(binary_path: text) -> ProcessOutput:
    # JSON-RPC initialize request with Content-Length header (MCP over stdio)
    val json_body = "{\"jsonrpc\":\"2.0\",\"id\":1,\"method\":\"initialize\",\"params\":{\"protocolVersion\":\"2024-11-05\",\"capabilities\":{},\"clientInfo\":{\"name\":\"test\",\"version\":\"0.1.0\"}}}"
    val content_length = json_body.len()
    val request = "Content-Length: {content_length}\r\n\r\n{json_body}"
    # Use bash to echo the request into the MCP server stdin with a timeout
    val cmd = "echo -n '{request}' | timeout 10 {binary_path} 2>/dev/null || true"
    val (out_text, err_text, exit_code) = rt_process_run("bash", ["-c", cmd])
    ProcessOutput(out_text: out_text, err_text: err_text, exit_code: exit_code)

fn send_tool_call_request(binary_path: text, tool_name: text, arguments_json: text) -> ProcessOutput:
    val json_body = "{\"jsonrpc\":\"2.0\",\"id\":2,\"method\":\"tools/call\",\"params\":{\"name\":\"{tool_name}\",\"arguments\":{arguments_json}}}"
    val content_length = json_body.len()
    val request = "Content-Length: {content_length}\r\n\r\n{json_body}"
    val cmd = "echo -n '{request}' | timeout 20 {binary_path} 2>/dev/null || true"
    val (out_text, err_text, exit_code) = rt_process_run("bash", ["-c", cmd])
    ProcessOutput(out_text: out_text, err_text: err_text, exit_code: exit_code)


# ============================================================================
# Test Group 1: MCP Binary Existence (AC-1, AC-6)
# ============================================================================

describe "Bootstrap MCP — binary existence":
    """
    ## Binary Existence

    After bootstrap --deploy, native MCP server binaries must exist at
    bin/release/<triple>/ alongside the main CLI binary.
    """

    it "simple_mcp_server binary exists at platform release path":
        val path = mcp_binary_path("simple_mcp_server")
        expect(file_exists(path)).to_equal(true)

    it "simple_lsp_mcp_server binary exists at platform release path":
        val path = mcp_binary_path("simple_lsp_mcp_server")
        expect(file_exists(path)).to_equal(true)

    it "main CLI binary still exists at platform release path":
        val path = mcp_binary_path("simple")
        expect(file_exists(path)).to_equal(true)


# ============================================================================
# Test Group 2: Symlinks (AC-3)
# ============================================================================

describe "Bootstrap MCP — symlinks":
    """
    ## Symlink Verification

    After setup.sh, bin/simple_mcp_server and bin/simple_lsp_mcp_server
    must be symlinks (or copies) that resolve to platform-specific binaries.
    """

    it "bin/simple_mcp_server symlink exists":
        expect(file_exists("bin/simple_mcp_server")).to_equal(true)

    it "bin/simple_lsp_mcp_server symlink exists":
        expect(file_exists("bin/simple_lsp_mcp_server")).to_equal(true)

    it "bin/simple_mcp_server is executable":
        val (_, _, rc) = rt_process_run("test", ["-x", "bin/simple_mcp_server"])
        expect(rc).to_equal(0)

    it "bin/simple_lsp_mcp_server is executable":
        val (_, _, rc) = rt_process_run("test", ["-x", "bin/simple_lsp_mcp_server"])
        expect(rc).to_equal(0)


# ============================================================================
# Test Group 3: MCP Server Initialize Response (AC-5)
# ============================================================================

describe "Bootstrap MCP — JSON-RPC initialize":
    """
    ## Initialize Response

    Both MCP servers must accept a JSON-RPC initialize request and
    return a response containing "capabilities". This validates that
    the natively compiled binaries are functional MCP servers.
    """

    it "simple_mcp_server responds to initialize with capabilities":
        val binary = "bin/simple_mcp_server"
        if not file_exists(binary):
            expect(file_exists(binary)).to_equal(false)
        else:
            val result = send_initialize_request(binary)
            val output = result.out_text + result.err_text
            val has_capabilities = output.contains("capabilities")
            val has_jsonrpc = output.contains("jsonrpc")
            expect(has_capabilities or has_jsonrpc).to_equal(true)

    it "simple_lsp_mcp_server responds to initialize with capabilities":
        val binary = "bin/simple_lsp_mcp_server"
        if not file_exists(binary):
            expect(file_exists(binary)).to_equal(false)
        else:
            val result = send_initialize_request(binary)
            val output = result.out_text + result.err_text
            val has_capabilities = output.contains("capabilities")
            val has_jsonrpc = output.contains("jsonrpc")
            expect(has_capabilities or has_jsonrpc).to_equal(true)

    it "simple_mcp_server initialize response contains server info":
        val binary = "bin/simple_mcp_server"
        if not file_exists(binary):
            expect(file_exists(binary)).to_equal(false)
        else:
            val result = send_initialize_request(binary)
            val output = result.out_text + result.err_text
            val has_server_info = output.contains("serverInfo") or output.contains("server_info")
            expect(has_server_info or output.contains("simple")).to_equal(true)

    it "simple_mcp_server handles simple_status tool calls":
        val binary = "bin/simple_mcp_server"
        if not file_exists(binary):
            expect(true).to_equal(true)
        else:
            val args = "{\"paths\":\"src/app/simple_lsp_mcp/main.spl\"}"
            val result = send_tool_call_request(binary, "simple_status", args)
            val output = result.out_text + result.err_text
            expect(output.contains("Project Diagnostics")).to_equal(true)

    it "simple_lsp_mcp_server reads tool name from params":
        val binary = "bin/simple_lsp_mcp_server"
        if not file_exists(binary):
            expect(true).to_equal(true)
        else:
            val args = "{\"file\":\"src/app/simple_lsp_mcp/main.spl\"}"
            val result = send_tool_call_request(binary, "lsp_symbols", args)
            val output = result.out_text + result.err_text
            expect(output.contains("Missing tool name")).to_equal(false)
            expect(output.contains("SERVER_NAME") or output.contains("main")).to_equal(true)


# ============================================================================
# Test Group 4: CLI Regression (AC-7)
# ============================================================================

describe "Bootstrap MCP — CLI regression":
    """
    ## CLI Regression

    The main CLI binary must still function after full bootstrap with MCP.
    Verify that bin/simple responds to basic commands.
    """

    it "bin/simple --version returns exit code 0":
        val (stdout, stderr, rc) = rt_process_run("bin/simple", ["--version"])
        expect(rc).to_equal(0)

    it "bin/simple --version output contains version string":
        val (stdout, _, _) = rt_process_run("bin/simple", ["--version"])
        val has_version = stdout.contains("simple") or stdout.contains("Simple") or stdout.contains("0.")
        expect(has_version).to_equal(true)

    it "bin/simple help returns exit code 0":
        val (stdout, stderr, rc) = rt_process_run("bin/simple", ["help"])
        # help may return 0 or 1 depending on implementation
        val ok = rc == 0 or rc == 1
        expect(ok).to_equal(true)
