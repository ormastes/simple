# LLM Dashboard TUI System Test
#
# Tests the TUI dashboard by piping keys and verifying output/exit behavior.
# Run: bin/simple test test/system/llm_dashboard_tui_spec.spl

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_process_run_timeout(cmd: text, args: [text], timeout_ms: i64) -> (text, text, i64)

use std.spec.{describe, it, expect}

describe "LLM Dashboard TUI":

    it "renders initial frame and quits on 'q'":
        # Pipe 'q' immediately — dashboard should render once then exit 0
        val (out, err, code) = rt_process_run("/bin/bash", ["-c",
            "echo -n 'q' | bin/simple run src/app/llm_dashboard/main.spl 2>/dev/null"])
        expect(code).to_equal(0)
        # Output should contain the tab bar
        expect(out.contains("Research")).to_equal(true)
        expect(out.contains("Code")).to_equal(true)
        expect(out.contains("q:quit")).to_equal(true)

    it "responds to tab switching before quit":
        # Press '2' (switch to Code tab) then 'q' to quit
        val (out, _, code) = rt_process_run("/bin/bash", ["-c",
            "printf '2q' | bin/simple run src/app/llm_dashboard/main.spl 2>/dev/null"])
        expect(code).to_equal(0)
        # Should have rendered at least twice (initial + after '2')
        expect(out.contains("Code")).to_equal(true)

    it "starts, renders, and exits without crashing":
        # Non-TTY delayed input is not portable through the dashboard wrapper;
        # use a bounded immediate quit to verify startup and clean shutdown.
        val (out, err, code) = rt_process_run("/bin/bash", ["-c",
            "echo -n 'q' | bin/simple run src/app/llm_dashboard/main.spl 2>/dev/null"])
        expect(code).to_equal(0)
        expect(out.contains("Research")).to_equal(true)

    it "handles multiple rapid keypresses":
        # Rapid tab cycling + scroll + quit
        val (_, _, code) = rt_process_run("/bin/bash", ["-c",
            "printf '123456jjkkrq' | bin/simple run src/app/llm_dashboard/main.spl 2>/dev/null"])
        expect(code).to_equal(0)

    it "shows status bar with provider indicators":
        val (out, _, code) = rt_process_run("/bin/bash", ["-c",
            "echo -n 'q' | bin/simple run src/app/llm_dashboard/main.spl 2>/dev/null"])
        expect(code).to_equal(0)
        expect(out.contains("Claude")).to_equal(true)
        expect(out.contains("Codex")).to_equal(true)
        expect(out.contains("Gemini")).to_equal(true)
