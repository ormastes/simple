# @tag:system
# @tag:gui-entry-engine2d-wm-simple-web
#
# System spec — BGA WM + Simple Web + Engine2D check in QEMU.

use std.spec.*

use os.qemu_runner.{OsTarget, build_os, get_wm_simple_web_check_target}
use os.compositor.qemu_capture.{capture_qemu_vm}
use std.nogc_sync_mut.ffi.io.{dir_create_all}

use test.qemu.os.common.qemu_os_harness.{
    can_run_target, file_exists, spawn_guest_with_qmp, stop_guest,
    wait_for_serial_marker, read_serial_log, read_qemu_stderr_log}

extern fn rt_get_cwd() -> text
extern fn rt_thread_sleep(ms: i64)

fn _build_once(target: OsTarget) -> bool:
    if file_exists(target.output):
        true
    else:
        build_os(target)

fn _capture_hold_target(target: OsTarget) -> OsTarget:
    OsTarget(
        arch: target.arch,
        entry: target.entry,
        linker_script: target.linker_script,
        target_triple: target.target_triple,
        output: target.output,
        qemu_system: target.qemu_system,
        qemu_machine: target.qemu_machine,
        qemu_cpu: target.qemu_cpu,
        qemu_memory: target.qemu_memory,
        qemu_bios: target.qemu_bios,
        qemu_extra: ["-vga", "std"],
        gui_mode: target.gui_mode
    )

fn _capture_and_assert_web_ppm(qmp_socket: text, output_path: text) -> bool:
    val result = capture_qemu_vm(qmp_socket, output_path)
    if not result.success:
        print "[gui_entry_engine2d_wm_simple_web_spec] QMP capture failed: {result.error}"
        return false
    if result.width != 1024 or result.height != 768:
        print "[gui_entry_engine2d_wm_simple_web_spec] unexpected capture size {result.width}x{result.height}"
        return false

    var nonblack = 0
    for pixel in result.pixels:
        if pixel != 0xFF000000:
            nonblack = nonblack + 1

    val mmio_probe_red = _pixel_near(result.pixels, result.width, result.height, 10, 0, 0xFFFF0000, 8)
    val header_blue = _pixel_near(result.pixels, result.width, result.height, 270, 136, 0xFF2050A0, 8)
    val body_dark_a = _pixel_near(result.pixels, result.width, result.height, 270, 190, 0xFF182230, 8)
    val body_dark_b = _pixel_near(result.pixels, result.width, result.height, 270, 270, 0xFF1F2937, 8)
    print "[gui_entry_engine2d_wm_simple_web_spec] qmp ppm dims={result.width}x{result.height} nonblack={nonblack} checks=[probe={mmio_probe_red},header={header_blue},bodyA={body_dark_a},bodyB={body_dark_b}]"
    nonblack > 100000 and mmio_probe_red and header_blue and body_dark_a and body_dark_b and file_exists(output_path)

fn _capture_and_assert_web_ppm_retry(qmp_socket: text, output_path: text, max_attempts: i64) -> bool:
    var attempt: i64 = 0
    while attempt < max_attempts:
        if _capture_and_assert_web_ppm(qmp_socket, output_path):
            return true
        rt_thread_sleep(50)
        attempt = attempt + 1
    false

fn _abs_i32(v: i32) -> i32:
    if v < 0:
        return 0 - v
    v

fn _pixel_near(pixels: [u32], width: i32, height: i32, x: i32, y: i32, expected: u32, tolerance: i32) -> bool:
    if x < 0 or y < 0 or x >= width or y >= height:
        return false
    val idx = (y * width + x).to_u64()
    if idx >= pixels.len():
        return false
    val got = pixels[idx]
    val gr = ((got >> 16) & 0xFF).to_i32()
    val gg = ((got >> 8) & 0xFF).to_i32()
    val gb = (got & 0xFF).to_i32()
    val er = ((expected >> 16) & 0xFF).to_i32()
    val eg = ((expected >> 8) & 0xFF).to_i32()
    val eb = (expected & 0xFF).to_i32()
    _abs_i32(gr - er) <= tolerance and _abs_i32(gg - eg) <= tolerance and _abs_i32(gb - eb) <= tolerance

fn _print_guest_diagnostics(prefix: text, serial: text, stderr: text):
    print "{prefix} serial_len={serial.len()} stderr_len={stderr.len()}"
    if serial != "":
        print "{prefix} serial:\n{serial}"
    if stderr != "":
        print "{prefix} qemu stderr:\n{stderr}"

describe "WM Simple Web Engine2D BGA QEMU check":
    it "builds, boots, reaches render markers, and captures Simple Web pixels":
        val target = get_wm_simple_web_check_target()
        expect(_build_once(target)).to_equal(true)
        expect(file_exists(target.output)).to_equal(true)
        val capture_target = _capture_hold_target(target)

        if not can_run_target(capture_target):
            print "[gui_entry_engine2d_wm_simple_web_spec] qemu-system-x86_64 not available, skipping live capture"
            expect(file_exists(target.output)).to_equal(true)
            return

        val qmp_socket = "/tmp/gui_entry_engine2d_wm_simple_web_qmp.sock"
        val serial_log = "build/os/gui_entry_engine2d_wm_simple_web_serial.log"
        val cwd = rt_get_cwd()
        val capture_ppm = "{cwd}/build/os/gui_entry_engine2d_wm_simple_web_capture.ppm"

        dir_create_all("build/os")

        match spawn_guest_with_qmp(capture_target, qmp_socket, serial_log):
            Ok(handle):
                val saw_ready = wait_for_serial_marker(handle, "[integrated-demo] render-ready", 60000)
                val serial = read_serial_log(handle)
                val saw_wm = serial.contains("[wm-demo] wm-service-ready")
                val saw_engine = serial.contains("[e2d-demo] engine-core-ready")
                val saw_web = serial.contains("[web-demo] pixels-ready")
                val saw_probe = serial.contains("[GUI] mmio-probe-painted")

                if not saw_probe or not saw_wm or not saw_engine or not saw_web or not saw_ready:
                    print "[gui_entry_engine2d_wm_simple_web_spec] missing marker probe={saw_probe} wm={saw_wm} e2d={saw_engine} web={saw_web} ready={saw_ready}"
                    _print_guest_diagnostics("[gui_entry_engine2d_wm_simple_web_spec]", serial, read_qemu_stderr_log(handle))
                    stop_guest(handle)
                    expect(saw_probe and saw_wm and saw_engine and saw_web and saw_ready).to_equal(true)
                else:
                    val captured = _capture_and_assert_web_ppm_retry(qmp_socket, capture_ppm, 1)
                    if not captured:
                        print "[gui_entry_engine2d_wm_simple_web_spec] QMP screendump or web pixel assertion failed"
                        _print_guest_diagnostics("[gui_entry_engine2d_wm_simple_web_spec]", serial, read_qemu_stderr_log(handle))
                        stop_guest(handle)
                        expect(captured).to_equal(true)
                    else:
                        stop_guest(handle)
                        expect(file_exists(capture_ppm)).to_equal(true)
            Err(err):
                print "[gui_entry_engine2d_wm_simple_web_spec] failed to spawn guest: {err}"
                expect(false).to_equal(true)
