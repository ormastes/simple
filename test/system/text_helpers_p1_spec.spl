# @cover src/lib/common/text/mod.spl 80%
"""
# Text Helpers P1 Specification

**Feature IDs:** #TEXT-P1-001 to #TEXT-P1-009
**Category:** Stdlib
**Difficulty:** 2/5
**Status:** Draft
**Requirements:** N/A
**Plan:** N/A
**Design:** N/A
**Research:** N/A

## Overview

Text Helpers P1 adds 9 utility functions to the text standard library module.
These cover case conversion (kebab, pascal, screaming snake), character-level
mapping (chars_map, tr, gsub), splitting (split_n), searching (contains_any),
and partitioning (cut).

## Key Concepts

| Concept | Description |
|---------|-------------|
| Case conversion | Transform between naming conventions (kebab, pascal, screaming snake) |
| chars_map | Apply a function to each character and reassemble |
| tr | Character-level transliteration (like Unix tr) |
| split_n | Split into at most n parts |
| contains_any | Check if text contains any character from a set |
| cut | Partition text around first occurrence of separator |
| gsub | Global substitution with a callback function |

## Related Specifications

- [text_advanced](../../src/lib/common/text_advanced.spl) - Existing case conversion (snake, camel, title)
"""

use std.spec
use common.text_advanced.{to_kebab_case, to_pascal_case, to_screaming_snake, chars_map, tr, split_n, contains_any, cut, gsub}

# ============================================================================
# 1. to_kebab_case  (#TEXT-P1-001)
# ============================================================================

describe "to_kebab_case":
    """
    ## to_kebab_case

    Converts text to kebab-case by inserting hyphens at word boundaries
    and lowercasing all characters.
    """

    context "from PascalCase":
        it "converts HelloWorld to hello-world":
            expect(to_kebab_case("HelloWorld")).to_equal("hello-world")

    context "from snake_case":
        it "converts hello_world to hello-world":
            expect(to_kebab_case("hello_world")).to_equal("hello-world")

    context "from camelCase":
        it "converts helloWorld to hello-world":
            expect(to_kebab_case("helloWorld")).to_equal("hello-world")

    context "from SCREAMING_SNAKE":
        it "converts HELLO_WORLD to hello-world":
            expect(to_kebab_case("HELLO_WORLD")).to_equal("hello-world")

    context "when already kebab-case":
        it "returns already-kebab unchanged":
            expect(to_kebab_case("already-kebab")).to_equal("already-kebab")

    context "when empty":
        it "returns empty string":
            expect(to_kebab_case("")).to_equal("")

# ============================================================================
# 2. to_pascal_case  (#TEXT-P1-002)
# ============================================================================

describe "to_pascal_case":
    """
    ## to_pascal_case

    Converts text to PascalCase by capitalizing the first letter of each
    word and removing separators.
    """

    context "from snake_case":
        it "converts hello_world to HelloWorld":
            expect(to_pascal_case("hello_world")).to_equal("HelloWorld")

    context "from kebab-case":
        it "converts hello-world to HelloWorld":
            expect(to_pascal_case("hello-world")).to_equal("HelloWorld")

    context "from camelCase":
        it "converts helloWorld to HelloWorld":
            expect(to_pascal_case("helloWorld")).to_equal("HelloWorld")

    context "from SCREAMING_SNAKE":
        it "converts HELLO_WORLD to HelloWorld":
            expect(to_pascal_case("HELLO_WORLD")).to_equal("HelloWorld")

    context "when empty":
        it "returns empty string":
            expect(to_pascal_case("")).to_equal("")

# ============================================================================
# 3. to_screaming_snake  (#TEXT-P1-003)
# ============================================================================

describe "to_screaming_snake":
    """
    ## to_screaming_snake

    Converts text to SCREAMING_SNAKE_CASE by inserting underscores at word
    boundaries and uppercasing all characters.
    """

    context "from camelCase":
        it "converts helloWorld to HELLO_WORLD":
            expect(to_screaming_snake("helloWorld")).to_equal("HELLO_WORLD")

    context "from kebab-case":
        it "converts hello-world to HELLO_WORLD":
            expect(to_screaming_snake("hello-world")).to_equal("HELLO_WORLD")

    context "from PascalCase":
        it "converts HelloWorld to HELLO_WORLD":
            expect(to_screaming_snake("HelloWorld")).to_equal("HELLO_WORLD")

    context "from snake_case":
        it "converts hello_world to HELLO_WORLD":
            expect(to_screaming_snake("hello_world")).to_equal("HELLO_WORLD")

    context "when empty":
        it "returns empty string":
            expect(to_screaming_snake("")).to_equal("")

# ============================================================================
# 4. chars_map  (#TEXT-P1-004)
# ============================================================================

describe "chars_map":
    """
    ## chars_map

    Applies a function to each character in the text and returns the
    concatenated result.
    """

    context "with to_upper transform":
        it "uppercases every character":
            expect(chars_map("hello", \c: c.upper())).to_equal("HELLO")

    context "with conditional replacement":
        it "replaces matching characters":
            val result = chars_map("abc", \c: if c == "b": "X" else: c)
            expect(result).to_equal("aXc")

    context "when empty":
        it "returns empty string":
            expect(chars_map("", \c: c)).to_equal("")

# ============================================================================
# 5. tr  (#TEXT-P1-005)
# ============================================================================

describe "tr":
    """
    ## tr

    Character-level transliteration. Each character in `from` is replaced
    by the corresponding character in `to`.
    """

    context "with matching characters":
        it "transliterates elo to ELO":
            expect(tr("hello", "elo", "ELO")).to_equal("hELLO")

    context "with full replacement":
        it "transliterates abc to xyz":
            expect(tr("aabbcc", "abc", "xyz")).to_equal("xxyyzz")

    context "with empty from and to":
        it "returns text unchanged":
            expect(tr("hello", "", "")).to_equal("hello")

    context "when text is empty":
        it "returns empty string":
            expect(tr("", "a", "b")).to_equal("")

# ============================================================================
# 6. split_n  (#TEXT-P1-006)
# ============================================================================

describe "split_n":
    """
    ## split_n

    Splits text into at most n parts. The last part contains the remainder
    of the string.
    """

    context "when n is less than total parts":
        it "splits into exactly n parts":
            val result = split_n("a,b,c,d", ",", 2)
            expect(result.len()).to_equal(2)
            expect(result[0]).to_equal("a")
            expect(result[1]).to_equal("b,c,d")

    context "when n exceeds total parts":
        it "returns all available parts":
            val result = split_n("a,b,c", ",", 5)
            expect(result.len()).to_equal(3)
            expect(result[0]).to_equal("a")
            expect(result[1]).to_equal("b")
            expect(result[2]).to_equal("c")

    context "when separator not found":
        it "returns single-element list":
            val result = split_n("hello", ",", 2)
            expect(result.len()).to_equal(1)
            expect(result[0]).to_equal("hello")

    context "when text is empty":
        it "returns list with empty string":
            val result = split_n("", ",", 2)
            expect(result.len()).to_equal(1)
            expect(result[0]).to_equal("")

# ============================================================================
# 7. contains_any  (#TEXT-P1-007)
# ============================================================================

describe "contains_any":
    """
    ## contains_any

    Returns true if the text contains any character from the given
    character set string.
    """

    context "when text contains a matching character":
        it "returns true for vowels in hello":
            expect(contains_any("hello", "aeiou")).to_equal(true)

    context "when no characters match":
        it "returns false for vowels in xyz":
            expect(contains_any("xyz", "aeiou")).to_equal(false)

    context "when text is empty":
        it "returns false":
            expect(contains_any("", "abc")).to_equal(false)

    context "when chars is empty":
        it "returns false":
            expect(contains_any("hello", "")).to_equal(false)

# ============================================================================
# 8. cut  (#TEXT-P1-008)
# ============================================================================

describe "cut":
    """
    ## cut

    Partitions text around the first occurrence of the separator.
    Returns a tuple of (before, after, found).
    """

    context "when separator is found":
        it "splits at first occurrence":
            val (before, after, found) = cut("hello=world", "=")
            expect(before).to_equal("hello")
            expect(after).to_equal("world")
            expect(found).to_equal(true)

    context "when separator appears multiple times":
        it "splits only at first occurrence":
            val (before, after, found) = cut("hello=world=foo", "=")
            expect(before).to_equal("hello")
            expect(after).to_equal("world=foo")
            expect(found).to_equal(true)

    context "when separator is not found":
        it "returns full text with empty after and false":
            val (before, after, found) = cut("hello", "=")
            expect(before).to_equal("hello")
            expect(after).to_equal("")
            expect(found).to_equal(false)

    context "when text is empty":
        it "returns empty parts with false":
            val (before, after, found) = cut("", "=")
            expect(before).to_equal("")
            expect(after).to_equal("")
            expect(found).to_equal(false)

# ============================================================================
# 9. gsub  (#TEXT-P1-009)
# ============================================================================

describe "gsub":
    """
    ## gsub

    Global substitution: replaces every occurrence of a pattern by applying
    a callback function to each match.
    """

    context "with uppercase transform":
        it "uppercases matched characters":
            val result = gsub("hello world", "o", \m: m.upper())
            expect(result).to_equal("hellO wOrld")

    context "with constant replacement":
        it "replaces match with constant":
            val result = gsub("abc", "b", \m: "BB")
            expect(result).to_equal("aBBc")

    context "when pattern has no match":
        it "returns text unchanged":
            val result = gsub("hello", "x", \m: "Y")
            expect(result).to_equal("hello")

    context "when text is empty":
        it "returns empty string":
            val result = gsub("", "a", \m: "b")
            expect(result).to_equal("")
