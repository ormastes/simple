# editor_split_tree_spec
#
# Phase 0: Split tree, split compute, and layout integration.
# Verifies binary split tree, rect computation, neighbor finding,
# and backward-compatible layout API.

use std.spec

extern fn rt_file_read_text(path: text) -> text

fn read_text(path: text) -> text:
    rt_file_read_text(path) ?? ""

describe "split tree — data structure":

    it "defines SplitNode struct":
        val src = read_text("src/lib/editor/30.view/split_tree.spl")
        expect(src.contains("struct SplitNode:")).to_equal(true)
        expect(src.contains("kind: i64")).to_equal(true)
        expect(src.contains("group_id: i64")).to_equal(true)
        expect(src.contains("direction: i64")).to_equal(true)
        expect(src.contains("ratio: i64")).to_equal(true)
        expect(src.contains("left_id: i64")).to_equal(true)
        expect(src.contains("right_id: i64")).to_equal(true)

    it "defines SplitTree class":
        val src = read_text("src/lib/editor/30.view/split_tree.spl")
        expect(src.contains("class SplitTree:")).to_equal(true)
        expect(src.contains("nodes: [SplitNode]")).to_equal(true)
        expect(src.contains("root_id: i64")).to_equal(true)

    it "has direction and node kind constants":
        val src = read_text("src/lib/editor/30.view/split_tree.spl")
        expect(src.contains("val SPLIT_VERTICAL: i64 = 0")).to_equal(true)
        expect(src.contains("val SPLIT_HORIZONTAL: i64 = 1")).to_equal(true)
        expect(src.contains("val NODE_LEAF: i64 = 0")).to_equal(true)
        expect(src.contains("val NODE_SPLIT: i64 = 1")).to_equal(true)

    it "has constructor and factory helpers":
        val src = read_text("src/lib/editor/30.view/split_tree.spl")
        expect(src.contains("static fn new(group_id: i64) -> SplitTree")).to_equal(true)
        expect(src.contains("fn split_node_leaf(group_id: i64) -> SplitNode")).to_equal(true)
        expect(src.contains("fn split_node_split(direction: i64, ratio: i64, left_id: i64, right_id: i64) -> SplitNode")).to_equal(true)

describe "split tree — mutations":

    it "has split method":
        val src = read_text("src/lib/editor/30.view/split_tree.spl")
        expect(src.contains("me split(target_group_id: i64, direction: i64, new_group_id: i64)")).to_equal(true)

    it "has close_leaf method":
        val src = read_text("src/lib/editor/30.view/split_tree.spl")
        expect(src.contains("me close_leaf(group_id: i64)")).to_equal(true)

    it "has resize method":
        val src = read_text("src/lib/editor/30.view/split_tree.spl")
        expect(src.contains("me resize(group_id: i64, delta: i64)")).to_equal(true)

    it "has swap method":
        val src = read_text("src/lib/editor/30.view/split_tree.spl")
        expect(src.contains("me swap(group_id_a: i64, group_id_b: i64)")).to_equal(true)

    it "has equalize method":
        val src = read_text("src/lib/editor/30.view/split_tree.spl")
        expect(src.contains("me equalize()")).to_equal(true)

describe "split tree — queries":

    it "has leaf_count and find_leaf":
        val src = read_text("src/lib/editor/30.view/split_tree.spl")
        expect(src.contains("fn leaf_count() -> i64")).to_equal(true)
        expect(src.contains("fn find_leaf(group_id: i64) -> i64")).to_equal(true)

    it "has flatten for in-order traversal":
        val src = read_text("src/lib/editor/30.view/split_tree.spl")
        expect(src.contains("fn flatten() -> [i64]")).to_equal(true)

describe "split compute — rect calculation":

    it "defines SplitRect struct":
        val src = read_text("src/lib/editor/30.view/split_compute.spl")
        expect(src.contains("struct SplitRect:")).to_equal(true)
        expect(src.contains("group_id: i64")).to_equal(true)
        expect(src.contains("x: i64")).to_equal(true)
        expect(src.contains("y: i64")).to_equal(true)
        expect(src.contains("w: i64")).to_equal(true)
        expect(src.contains("h: i64")).to_equal(true)

    it "has split_compute_rects":
        val src = read_text("src/lib/editor/30.view/split_compute.spl")
        expect(src.contains("fn split_compute_rects(tree: SplitTree, x: i64, y: i64, w: i64, h: i64) -> [SplitRect]")).to_equal(true)

    it "has split_find_rect":
        val src = read_text("src/lib/editor/30.view/split_compute.spl")
        expect(src.contains("fn split_find_rect(rects: [SplitRect], group_id: i64) -> SplitRect")).to_equal(true)

    it "has split_find_neighbor for directional focus":
        val src = read_text("src/lib/editor/30.view/split_compute.spl")
        expect(src.contains("fn split_find_neighbor(rects: [SplitRect], group_id: i64, direction: text) -> i64")).to_equal(true)

    it "deducts border space in rect computation":
        val src = read_text("src/lib/editor/30.view/split_compute.spl")
        expect(src.contains("val border = 1")).to_equal(true)

describe "editor layout — split tree integration":

    it "has tree field on EditorLayout":
        val src = read_text("src/lib/editor/30.view/layout.spl")
        expect(src.contains("tree: SplitTree")).to_equal(true)
        expect(src.contains("active_group_id: i64")).to_equal(true)

    it "has editor_layout_split_h for horizontal splits":
        val src = read_text("src/lib/editor/30.view/layout.spl")
        expect(src.contains("fn editor_layout_split_h(layout: EditorLayout, next_group_id: i64) -> EditorLayout")).to_equal(true)

    it "has editor_layout_focus_direction":
        val src = read_text("src/lib/editor/30.view/layout.spl")
        expect(src.contains("fn editor_layout_focus_direction(layout: EditorLayout, direction: text, rects: [SplitRect]) -> EditorLayout")).to_equal(true)

    it "has editor_layout_compute_rects":
        val src = read_text("src/lib/editor/30.view/layout.spl")
        expect(src.contains("fn editor_layout_compute_rects(layout: EditorLayout, x: i64, y: i64, w: i64, h: i64) -> [SplitRect]")).to_equal(true)

    it "keeps backward-compatible groups array":
        val src = read_text("src/lib/editor/30.view/layout.spl")
        expect(src.contains("groups: [EditorGroup]")).to_equal(true)
        expect(src.contains("active_group_index: i64")).to_equal(true)

describe "session — horizontal split":

    it "has split_editor_horizontal method":
        val src = read_text("src/lib/editor/20.core/session.spl")
        expect(src.contains("me split_editor_horizontal()")).to_equal(true)
        expect(src.contains("editor_layout_split_h")).to_equal(true)
