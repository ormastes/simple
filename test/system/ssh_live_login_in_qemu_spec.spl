# @tag:system
use std.spec.*

use os.qemu_runner.{get_ssh_live_target, QemuScenario, build_os_with_backend, ensure_scenario_media}
use os.kernel.arch.arch_context.{Architecture}
use test.qemu.os.common.qemu_os_harness.{
    allocate_live_host_port, can_run_target, spawn_guest_with_qmp_scenario,
    stop_guest, wait_for_serial_marker, read_serial_log, read_qemu_stderr_log}
use std.nogc_sync_mut.ffi.io.{dir_create_all}

extern fn rt_process_run_timeout(cmd: text, args: [text], timeout_ms: i64) -> (text, text, i32)
extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_delete(path: text) -> bool
extern fn rt_env_get(key: text) -> text?
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_getpid() -> i64
extern fn rt_time_now_unix_micros() -> i64

fn _ssh_probe_command() -> text:
    _ssh_probe_command_for_port(2299)

fn _ssh_probe_command_for_port(port: i64) -> text:
    "sshpass -p simpleos ssh " +
        "-o StrictHostKeyChecking=no " +
        "-o UserKnownHostsFile=/tmp/simpleos_ssh_live_spec_known_hosts " +
        "-o ConnectTimeout=5 " +
        "-o PreferredAuthentications=password " +
        "-o PubkeyAuthentication=no " +
        "-o NumberOfPasswordPrompts=1 " +
        "-p {port} root@127.0.0.1 true"

fn _scenario_x64_ssh_on_port(port: i64) -> QemuScenario:
    QemuScenario(
        name: "x64-ssh-{port}",
        arch: Architecture.X86_64,
        machine: "q35",
        cpu: "qemu64",
        memory: "2G",
        qemu_extra: [
            "-device", "isa-debug-exit,iobase=0xf4,iosize=0x04",
            "-drive", "file=build/os/simpleos_disk.img,if=none,id=nvm,format=raw",
            "-device", "nvme,serial=deadbeef,drive=nvm",
            "-netdev", "user,id=n0,hostfwd=tcp::{port}-:22",
            "-device", "virtio-net-pci,netdev=n0"
        ],
        gui_mode: false,
        description: "x86_64 full-stack with SSH (host:{port} -> guest:22)"
    )

fn _run_live_ssh_login() -> (text, text, i32):
    _run_live_ssh_login_on_port(2299)

fn _run_live_ssh_login_on_port(port: i64) -> (text, text, i32):
    rt_process_run_timeout("/bin/sh", ["-c", _ssh_probe_command_for_port(port)], 15000)

fn _cleanup_known_hosts():
    val path = "/tmp/simpleos_ssh_live_spec_known_hosts"
    if rt_file_exists(path):
        rt_file_delete(path)

fn _assert_ssh_live_login(backend: text):
    val target = get_ssh_live_target()
    val port_result = allocate_live_host_port(32000)
    expect(port_result.is_ok()).to_equal(true)
    if port_result.is_err():
        return
    val host_port = port_result.unwrap()
    val scenario = _scenario_x64_ssh_on_port(host_port)
    val built = build_os_with_backend(target, backend)
    if backend == "llvm" and not built:
        print "[ssh_live_login_in_qemu_spec] LLVM backend unavailable, skipping build lane"
        expect(backend).to_equal("llvm")
        return
    expect(built).to_equal(true)
    val build_marker = rt_env_get("SIMPLE_SSH_LIVE_BUILD_MARKER") ?? ""
    expect(build_marker.len() > 0).to_equal(true)
    expect(can_run_target(target)).to_equal(true)
    expect(ensure_scenario_media(scenario)).to_equal(true)

    val run_token = "{backend}_{rt_getpid()}_{rt_time_now_unix_micros()}"
    val qmp_socket = "/tmp/simpleos_ssh_live_spec_{run_token}.sock"
    val serial_log = "build/os/ssh_live_spec_{run_token}.log"
    dir_create_all("build/os")
    _cleanup_known_hosts()

    match spawn_guest_with_qmp_scenario(target, scenario, qmp_socket, serial_log):
        Ok(handle):
            val ready = wait_for_serial_marker(handle, "[sshd] SSH daemon listening on port 22", 30000)
            val boot_serial = read_serial_log(handle)
            val boot_stderr = read_qemu_stderr_log(handle)
            if not ready:
                print "[ssh_live_login_in_qemu_spec] boot log ({backend}):"
                print boot_serial
                if boot_stderr != "":
                    print "[ssh_live_login_in_qemu_spec] qemu stderr ({backend}): {boot_stderr}"
                rt_file_write_text("build/os/ssh_live_login_failure_{backend}.log", boot_serial)
                rt_file_write_text("build/os/ssh_live_login_failure_{backend}.stderr.log", boot_stderr)

            var login = ("", "", -1)
            var final_serial = boot_serial
            if ready:
                login = _run_live_ssh_login_on_port(host_port)
                final_serial = read_serial_log(handle)
                if login[2] != 0:
                    print "[ssh_live_login_in_qemu_spec] ssh stdout ({backend}): {login[0]}"
                    print "[ssh_live_login_in_qemu_spec] ssh stderr ({backend}): {login[1]}"
                    print "[ssh_live_login_in_qemu_spec] serial log ({backend}):"
                    print final_serial
                    if boot_stderr != "":
                        print "[ssh_live_login_in_qemu_spec] qemu stderr ({backend}): {boot_stderr}"
                    rt_file_write_text("build/os/ssh_live_login_failure_{backend}.log", final_serial)
                    rt_file_write_text("build/os/ssh_live_login_failure_{backend}.stderr.log", boot_stderr)

            val stopped = stop_guest(handle)
            expect(stopped).to_equal(true)
            expect(ready).to_equal(true)
            if ready:
                expect(login[2]).to_equal(0)
                expect(final_serial.contains("[boot] Build marker: {build_marker}")).to_equal(true)
                expect(final_serial.contains("[sshd] Ed25519 self-test: PASS")).to_equal(true)
                expect(final_serial.contains("[ed25519-c] FAIL")).to_equal(false)
                expect(final_serial.contains("heap exhausted")).to_equal(false)
        Err(err):
            print "[ssh_live_login_in_qemu_spec] failed to spawn guest ({backend}): {err}"
            expect(err.len() > 0).to_equal(false)

describe "Live SSH login in QEMU":

    it "boots the Cranelift x64-ssh guest and accepts a password-authenticated login":
        _assert_ssh_live_login("cranelift")

    it "boots the LLVM x64-ssh guest and accepts a password-authenticated login":
        _assert_ssh_live_login("llvm")
