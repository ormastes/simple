"""
Root-level coverage for FR-SPOSTGRE-M2-002 canonical NVFS constants.
"""

use examples.nvfs.src.core.constants.{STORAGE_CLASS_DB_WAL, STORAGE_CLASS_META_DURABLE,
                                      STORAGE_CLASS_DB_TEMP, DURABILITY_DATA_DURABLE}

describe "NVFS shared constants":
    it "exports the canonical ordinals requested by FR-SPOSTGRE-M2-002":
        expect(STORAGE_CLASS_DB_WAL).to_equal(1)
        expect(STORAGE_CLASS_META_DURABLE).to_equal(2)
        expect(STORAGE_CLASS_DB_TEMP).to_equal(3)
        expect(DURABILITY_DATA_DURABLE).to_equal(1)
