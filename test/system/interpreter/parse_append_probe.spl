use compiler.core.frontend.{core_frontend_parse_append}
use compiler.core.ast.{ast_reset, decl_count}

fn main() -> i64:
    ast_reset()
    val ok = core_frontend_parse_append(
        """
pub fn answer() -> i64:
    42
""",
        "/tmp/parse_append_probe.spl"
    )
    if ok and decl_count() > 0:
        print "ok"
        return 0
    print "parse failed"
    1
