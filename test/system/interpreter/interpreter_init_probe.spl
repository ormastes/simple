use compiler.core.interpreter.{
    val_reset, env_init, func_table_reset, struct_table_reset,
    mono_cache_init, eval_reset, module_loader_init
}

extern fn sys_get_args() -> [text]

fn main() -> i64:
    val args = sys_get_args()
    if args.len() < 2:
        print "usage: interpreter_init_probe.spl <val|env|func|struct|mono|eval|loader>"
        return 1

    val cmd = args[1]
    if cmd == "val":
        val_reset()
    elif cmd == "env":
        env_init()
    elif cmd == "func":
        func_table_reset()
    elif cmd == "struct":
        struct_table_reset()
    elif cmd == "mono":
        mono_cache_init()
    elif cmd == "eval":
        eval_reset()
    elif cmd == "loader":
        module_loader_init()
    else:
        print "unknown"
        return 1

    print "ok"
    0
