#![allow(spipe_empty_examples)]
#![allow(spipe_boolean_wrapper_assertions)]
@allow(spipe_empty_examples)
@allow(spipe_boolean_wrapper_assertions)
use compiler.hir.hir_lowering.{imported_symbol_local_name}


fn main():
    """
    # Compiler Import Alias Resolution
    
    System-level regression check for FR-COMPILER-002. The HIR import resolver must
    register named imports under the alias when one is present.
    """


    describe "compiler import alias resolution":
        """Import aliases must choose the local symbol name used by HIR registration."""
        it "selects the alias as the local symbol name":
            expect imported_symbol_local_name("CompileOptions", true, "DriverOptions") == "DriverOptions"
            expect imported_symbol_local_name("CompileOptions", true, "BackendOptions") == "BackendOptions"
    
        it "keeps the imported name when no alias is present":
            expect imported_symbol_local_name("CompileOptions", false, "") == "CompileOptions"