# tag: ["only-compiled"]
# LSP Enhanced Diagnostics System Test
#
# Tests that the check subcommand produces correct diagnostic output
# for syntax errors and validates the check pipeline.
# Advanced lint diagnostics (unused vars, deprecated patterns) require
# query check --format=json which is only available via interpreted query.spl.

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_exists(path: text) -> bool

fn _check_binary_runnable() -> bool:
    if not rt_file_exists("bin/release/simple"):
        return false
    val (stdout, stderr, code) = rt_process_run("file", ["bin/release/simple"])
    if stdout == "" or stdout == nil:
        return false
    if stdout.contains("ELF") and not stdout.contains("Mach-O"):
        val (uname_out, _, _) = rt_process_run("uname", [])
        if uname_out.trim() == "Darwin":
            return false
    true

val _can_run = _check_binary_runnable()

# ============================================================================
# Helpers
# ============================================================================

fn get_simple_binary() -> text:
    val (uname_out, _err, _code) = rt_process_run("uname", ["-s"])
    if uname_out.trim() == "FreeBSD":
        "src/compiler_rust/target/bootstrap/simple"
    else:
        "bin/release/simple"

fn run_check(file: text) -> (text, text, i64):
    """Run check on a file and return (stdout, stderr, exit_code)."""
    rt_process_run(get_simple_binary(), ["check", file])

fn write_temp_file(name: text, content: text) -> text:
    """Write a temporary .spl file for testing."""
    val path = "/tmp/simple_lsp_test_{name}.spl"
    rt_file_write_text(path, content)
    path

# ============================================================================
# Syntax Error Diagnostics
# ============================================================================

describe "LSP Enhanced Diagnostics":
    it "syntax error produces error diagnostic with file location":
        if not _can_run:
            expect(true).to_equal(true)
        else:
            val path = write_temp_file("syntax_err", "fn broken(\n    val x = \n")
            val (stdout, stderr, exit_code) = run_check(path)
            val combined = stdout + stderr
            expect(exit_code).to_equal(1)
            val has_error = combined.contains("error")
            expect(has_error).to_equal(true)

    it "syntax error output contains line number":
        if not _can_run:
            expect(true).to_equal(true)
        else:
            val path = write_temp_file("line_num", "fn broken(\n")
            val (stdout, stderr, exit_code) = run_check(path)
            val combined = stdout + stderr
            # Error format includes file:line:col - error means check reported issue
            expect(exit_code).to_equal(1)

    it "missing closing paren detected":
        if not _can_run:
            expect(true).to_equal(true)
        else:
            val path = write_temp_file("missing_paren", "fn test(a: i64\n    a + 1\n")
            val (stdout, stderr, exit_code) = run_check(path)
            expect(exit_code).to_equal(1)

    it "clean code passes check":
        if not _can_run:
            expect(true).to_equal(true)
        else:
            val code = "fn add(a: i64, b: i64) -> i64:\n    a + b\n"
            val path = write_temp_file("clean", code)
            val (stdout, stderr, exit_code) = run_check(path)
            expect(exit_code).to_equal(0)

    it "valid function with return type passes":
        if not _can_run:
            expect(true).to_equal(true)
        else:
            val code = "fn square(x: i64) -> i64:\n    x * x\n"
            val path = write_temp_file("valid_fn", code)
            val (stdout, stderr, exit_code) = run_check(path)
            expect(exit_code).to_equal(0)

    it "multiple syntax errors are reported":
        if not _can_run:
            expect(true).to_equal(true)
        else:
            val code = "fn broken(\nfn also_broken(\n"
            val path = write_temp_file("multi_err", code)
            val (stdout, stderr, exit_code) = run_check(path)
            val combined = stdout + stderr
            expect(exit_code).to_equal(1)
            val has_error = combined.contains("error")
            expect(has_error).to_equal(true)

    it "error output mentions expected token":
        if not _can_run:
            expect(true).to_equal(true)
        else:
            val path = write_temp_file("expected_tok", "fn broken(\n")
            val (stdout, stderr, exit_code) = run_check(path)
            val combined = stdout + stderr
            val has_expected = combined.contains("expected") or combined.contains("unexpected")
            expect(has_expected).to_equal(true)

    it "check reports error count summary":
        if not _can_run:
            expect(true).to_equal(true)
        else:
            val path = write_temp_file("err_summary", "fn broken(\n")
            val (stdout, stderr, exit_code) = run_check(path)
            val combined = stdout + stderr
            val has_count = combined.contains("error(s)") or combined.contains("1 error")
            expect(has_count).to_equal(true)
