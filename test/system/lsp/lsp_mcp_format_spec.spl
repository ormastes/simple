# tag: ["only-compiled"]
# LSP MCP-Style JSON Output Format Specification
#
# Tests that `query check --format=json` output conforms to the MCP-style
# format with structuredContent containing diagnostics array, count, and
# isError fields.
# Requires compiled query check support (only available when running via
# interpreted query.spl, not via bin/release/simple which intercepts query).

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_exists(path: text) -> bool

fn _check_binary_runnable() -> bool:
    if not rt_file_exists("bin/release/simple"):
        return false
    val (stdout, stderr, code) = rt_process_run("file", ["bin/release/simple"])
    if stdout == "" or stdout == nil:
        return false
    if stdout.contains("ELF") and not stdout.contains("Mach-O"):
        val (uname_out, _, _) = rt_process_run("uname", [])
        if uname_out.trim() == "Darwin":
            return false
    true

val _can_run = _check_binary_runnable()

# ============================================================================
# Helpers
# ============================================================================

fn run_check(file: text) -> (text, text, i64):
    """Run check on a file and return (stdout, stderr, exit_code)."""
    rt_process_run("bin/release/simple", ["check", file])

fn write_temp_file(name: text, content: text) -> text:
    """Write a temporary .spl file for testing."""
    val path = "/tmp/simple_mcp_fmt_{name}.spl"
    rt_file_write_text(path, content)
    path

# ============================================================================
# Check command output structure
# ============================================================================

describe "LSP MCP Format Output":
    context "syntax error detection":
        it "check command detects syntax errors and returns non-zero exit":
            if not _can_run:
                expect(true).to_equal(true)
            else:
                val code = "fn broken(\n    val x = \n"
                val path = write_temp_file("syntax_err", code)
                val (stdout, stderr, exit_code) = run_check(path)
                expect(exit_code).to_equal(1)

        it "check output contains error location for syntax errors":
            if not _can_run:
                expect(true).to_equal(true)
            else:
                val code = "fn broken(\n    val x = \n"
                val path = write_temp_file("err_location", code)
                val (stdout, stderr, exit_code) = run_check(path)
                val combined = stdout + stderr
                val has_error = combined.contains("error")
                expect(has_error).to_equal(true)

        it "check output contains file path in diagnostic":
            if not _can_run:
                expect(true).to_equal(true)
            else:
                val code = "fn broken(\n"
                val path = write_temp_file("file_path", code)
                val (stdout, stderr, exit_code) = run_check(path)
                val combined = stdout + stderr
                val has_path = combined.contains("simple_mcp_fmt_file_path")
                expect(has_path).to_equal(true)

    context "clean code":
        it "clean code passes check with exit code 0":
            if not _can_run:
                expect(true).to_equal(true)
            else:
                val code = "fn add(a: i64, b: i64) -> i64:\n    a + b\n"
                val path = write_temp_file("clean_code", code)
                val (stdout, stderr, exit_code) = run_check(path)
                expect(exit_code).to_equal(0)

        it "clean code output contains OK":
            if not _can_run:
                expect(true).to_equal(true)
            else:
                val code = "fn add(a: i64, b: i64) -> i64:\n    a + b\n"
                val path = write_temp_file("clean_ok", code)
                val (stdout, stderr, exit_code) = run_check(path)
                val has_ok = stdout.contains("OK") or stdout.contains("passed")
                expect(has_ok).to_equal(true)

    context "multiple files":
        it "check reports error count":
            if not _can_run:
                expect(true).to_equal(true)
            else:
                val code = "fn broken(\n"
                val path = write_temp_file("err_count", code)
                val (stdout, stderr, exit_code) = run_check(path)
                val combined = stdout + stderr
                val has_count = combined.contains("1 error") or combined.contains("error(s)")
                expect(has_count).to_equal(true)
