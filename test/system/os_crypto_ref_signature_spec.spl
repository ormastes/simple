            val msg = _msg_hello()
            val sig = _sign_rsa512(pkcs8, msg)
            expect(sig.len() > 0).to_equal(true)
            val ok = _openssl_rsa_verify_sha512(spki, msg, sig)
            expect(ok).to_equal(true)

    it "negative: tampered signature -> Simple verify = false":
        if not openssl_present():
            expect(true).to_equal(true)
        else:
            val pkcs8 = hex_to_bytes(RSA_PKCS8_HEX)
            val spki = hex_to_bytes(RSA_SPKI_HEX)
            val msg = _msg_hello()
            val sig = _sign_rsa512(pkcs8, msg)
            if sig.len() == 0:
                expect(false).to_equal(true)
            else:
                var bad_sig: [u8] = []
                bad_sig.push((sig[0].to_i64() ^ 0xFF).to_u8())
                var i: u64 = 1
                while i < sig.len():
                    bad_sig.push(sig[i])
                    i = i + 1
                val ok = rsa_sha512_verify(spki, msg, bad_sig)
                expect(ok).to_equal(false)

    it "large (4 KiB) message: sign + verify succeed":
        if not openssl_present():
            expect(true).to_equal(true)
        else:
            val pkcs8 = hex_to_bytes(RSA_PKCS8_HEX)
            val spki = hex_to_bytes(RSA_SPKI_HEX)
            val msg = _make_64kb()
            val sig = _sign_rsa512(pkcs8, msg)
            expect(sig.len() > 0).to_equal(true)
            val ok = rsa_sha512_verify(spki, msg, sig)
            expect(ok).to_equal(true)


describe "os_crypto_ref_signature: ECDSA-SHA2-NISTP256 cross-check":
    """
    ## ECDSA P-256 Cross-Check

    ECDSA is non-deterministic so we cannot do byte-exact KAT on sign.
    Instead we verify:
      1. Two signatures of same input differ (randomness check).
      2. Each signature verifies correctly (Simple verify).
      3. Simple sign -> DER conversion -> openssl verify succeeds.
      4. Modified message fails verification (negative).
    """

    it "same (key, msg) signed twice produces different signatures":
        if not openssl_present():
            expect(openssl_present()).to_equal(false)
        else:
            val pkcs8 = hex_to_bytes(EC_PKCS8_HEX)
            val msg = _msg_hello()
            val sig1 = _sign_ecdsa_p256(pkcs8, msg)
            val sig2 = _sign_ecdsa_p256(pkcs8, msg)
            expect(sig1.len()).to_equal(64)
            expect(sig2.len()).to_equal(64)
            # Non-deterministic: sigs should differ (astronomically unlikely to collide)
            expect(_bytes_eq(sig1, sig2)).to_equal(false)

    it "sign then Simple verify -> true (sig1)":
        if not openssl_present():
            expect(true).to_equal(true)
        else:
            val pkcs8 = hex_to_bytes(EC_PKCS8_HEX)
            val spki = hex_to_bytes(EC_SPKI_HEX)
            val msg = _msg_hello()
            val sig = _sign_ecdsa_p256(pkcs8, msg)
            expect(sig.len()).to_equal(64)
            val ok = ecdsa_p256_verify(spki, msg, sig)
            expect(ok).to_equal(true)

    it "second independent signature also verifies via Simple":
        if not openssl_present():
            expect(true).to_equal(true)
        else:
            val pkcs8 = hex_to_bytes(EC_PKCS8_HEX)
            val spki = hex_to_bytes(EC_SPKI_HEX)
            val msg = _msg_hello()
            val sig = _sign_ecdsa_p256(pkcs8, msg)
            val sig2 = _sign_ecdsa_p256(pkcs8, msg)
            val ok1 = ecdsa_p256_verify(spki, msg, sig)
            val ok2 = ecdsa_p256_verify(spki, msg, sig2)
            expect(ok1).to_equal(true)
            expect(ok2).to_equal(true)

    it "Simple sign (fixed64) -> DER -> openssl verify -> success":
        if not openssl_present():
            expect(true).to_equal(true)
        else:
            val pkcs8 = hex_to_bytes(EC_PKCS8_HEX)
            val spki = hex_to_bytes(EC_SPKI_HEX)
            val msg = _msg_hello()
            val sig_fixed = _sign_ecdsa_p256(pkcs8, msg)
            expect(sig_fixed.len()).to_equal(64)
            val sig_der = _fixed64_to_der(sig_fixed)
            expect(sig_der.len() > 8).to_equal(true)
            val ok = openssl_ecdsa_p256_verify_der(spki, msg, sig_der)
            expect(ok).to_equal(true)

    it "DER-converted signature from 1 KB message verifies via openssl":
        if not openssl_present():
            expect(true).to_equal(true)
        else:
            val pkcs8 = hex_to_bytes(EC_PKCS8_HEX)
            val spki = hex_to_bytes(EC_SPKI_HEX)
            val msg = _make_1kb()
            val sig_fixed = _sign_ecdsa_p256(pkcs8, msg)
            val sig_der = _fixed64_to_der(sig_fixed)
            val ok = openssl_ecdsa_p256_verify_der(spki, msg, sig_der)
            expect(ok).to_equal(true)

    it "negative: flip bit in message -> Simple verify = false":
        if not openssl_present():
            expect(true).to_equal(true)
        else:
            val pkcs8 = hex_to_bytes(EC_PKCS8_HEX)
            val spki = hex_to_bytes(EC_SPKI_HEX)
            val msg = _msg_hello()
            val sig = _sign_ecdsa_p256(pkcs8, msg)
            # Corrupt first byte of message
            var bad_msg: [u8] = []
            bad_msg.push((msg[0].to_i64() ^ 0x01).to_u8())
            var i: u64 = 1
            while i < msg.len():
                bad_msg.push(msg[i])
                i = i + 1
            val ok = ecdsa_p256_verify(spki, bad_msg, sig)
            expect(ok).to_equal(false)

    it "empty message: ECDSA sign + Simple verify succeed":
        if not openssl_present():
            expect(true).to_equal(true)
        else:
            val pkcs8 = hex_to_bytes(EC_PKCS8_HEX)
            val spki = hex_to_bytes(EC_SPKI_HEX)
            val msg = _msg_empty()
            val sig = _sign_ecdsa_p256(pkcs8, msg)
            expect(sig.len()).to_equal(64)
            val ok = ecdsa_p256_verify(spki, msg, sig)
            expect(ok).to_equal(true)

    it "large (4 KiB) message: ECDSA sign + Simple verify succeed":
        if not openssl_present():
            expect(true).to_equal(true)
        else:
            val pkcs8 = hex_to_bytes(EC_PKCS8_HEX)
            val spki = hex_to_bytes(EC_SPKI_HEX)
            val msg = _make_64kb()
            val sig = _sign_ecdsa_p256(pkcs8, msg)
            expect(sig.len()).to_equal(64)
            val ok = ecdsa_p256_verify(spki, msg, sig)
            expect(ok).to_equal(true)


describe "os_crypto_ref_signature: Ed25519 verify cross-check":
    """
    ## Ed25519 Verify Cross-Check

    There is no Simple-side Ed25519 sign FFI; sign is pure-bignum (covered
    by S4).  These tests exercise `rt_ed25519_verify` (raw 32-byte pubkey)
    against RFC 8032 §7.1 TEST 2 vectors and cross-check with openssl pkeyutl.
    """

    it "RFC 8032 TEST 2: rt_ed25519_verify returns 1 for known-good vector":
        val pk = hex_to_bytes(ED25519_PK_HEX)
        val msg = hex_to_bytes(ED25519_MSG_HEX)
        val sig = hex_to_bytes(ED25519_SIG_HEX)
        val result = rt_ed25519_verify(pk, msg, sig)
        expect(result).to_equal(1)

    it "RFC 8032 TEST 2: ed25519_verify wrapper returns true":
        val pk = hex_to_bytes(ED25519_PK_HEX)
        val msg = hex_to_bytes(ED25519_MSG_HEX)
        val sig = hex_to_bytes(ED25519_SIG_HEX)
        val ok = ed25519_verify(pk, msg, sig)
        expect(ok).to_equal(true)

    it "RFC 8032 TEST 2: openssl pkeyutl -verify returns success":
        if not openssl_present():
            expect(true).to_equal(true)
        else:
            val pk = hex_to_bytes(ED25519_PK_HEX)
            val msg = hex_to_bytes(ED25519_MSG_HEX)
            val sig = hex_to_bytes(ED25519_SIG_HEX)
            val spki = hex_to_bytes(ED25519_SPKI_HEX)
            val ok = _openssl_ed25519_verify(spki, msg, sig)
            expect(ok).to_equal(true)

    it "negative: wrong public key -> ed25519_verify = false":
        val pk = hex_to_bytes(ED25519_PK_HEX)
        val msg = hex_to_bytes(ED25519_MSG_HEX)
        val sig = hex_to_bytes(ED25519_SIG_HEX)
        # Use EC pubkey bytes (wrong type/length) as wrong pubkey
        var bad_pk: [u8] = []
        var i: u64 = 0
        while i < 32:
            bad_pk.push((pk[i].to_i64() ^ 0xFF).to_u8())
            i = i + 1
        val ok = ed25519_verify(bad_pk, msg, sig)
        expect(ok).to_equal(false)

    it "negative: corrupted signature -> ed25519_verify = false":
        val pk = hex_to_bytes(ED25519_PK_HEX)
        val msg = hex_to_bytes(ED25519_MSG_HEX)
        val sig = hex_to_bytes(ED25519_SIG_HEX)
        var bad_sig: [u8] = []
        bad_sig.push((sig[0].to_i64() ^ 0x01).to_u8())
        var i: u64 = 1
        while i < sig.len():
            bad_sig.push(sig[i])
            i = i + 1
        val ok = ed25519_verify(pk, msg, bad_sig)
        expect(ok).to_equal(false)

    it "negative: modified message -> ed25519_verify = false":
        val pk = hex_to_bytes(ED25519_PK_HEX)
        val msg = hex_to_bytes(ED25519_MSG_HEX)
        val sig = hex_to_bytes(ED25519_SIG_HEX)
        var bad_msg: [u8] = []
        bad_msg.push((msg[0].to_i64() ^ 0x01).to_u8())
        val ok = ed25519_verify(pk, bad_msg, sig)
        expect(ok).to_equal(false)


describe "os_crypto_ref_signature: edge cases and negative coverage":
    """
    ## Edge and Negative Coverage

    Malformed inputs, wrong key types, undersized RSA keys.
    These must not panic — they must return empty arrays or false.
    """

    it "malformed PKCS#8 -> rsa_sha256_sign returns empty":
        val bad = hex_to_bytes(BAD_PKCS8_HEX)
        val msg = _msg_hello()
        val sig = _sign_rsa256(bad, msg)
        expect(sig.len()).to_equal(0)

    it "malformed PKCS#8 -> rsa_sha512_sign returns empty":
        val bad = hex_to_bytes(BAD_PKCS8_HEX)
        val msg = _msg_hello()
        val sig = _sign_rsa512(bad, msg)
        expect(sig.len()).to_equal(0)

    it "malformed PKCS#8 -> ecdsa_p256_sign returns empty":
        val bad = hex_to_bytes(BAD_PKCS8_HEX)
        val msg = _msg_hello()
        val sig = _sign_ecdsa_p256(bad, msg)
        expect(sig.len()).to_equal(0)

    it "wrong-type PKCS#8 (ECDSA key) -> rsa_sha256_sign returns empty":
        val ec_pkcs8 = hex_to_bytes(WRONG_TYPE_PKCS8_HEX)
        val msg = _msg_hello()
        val sig = _sign_rsa256(ec_pkcs8, msg)
        expect(sig.len()).to_equal(0)

    it "wrong-type PKCS#8 (ECDSA key) -> rsa_sha512_sign returns empty":
        val ec_pkcs8 = hex_to_bytes(WRONG_TYPE_PKCS8_HEX)
        val msg = _msg_hello()
        val sig = _sign_rsa512(ec_pkcs8, msg)
        expect(sig.len()).to_equal(0)

    it "wrong-type PKCS#8 (RSA key) -> ecdsa_p256_sign returns empty":
        val rsa_pkcs8 = hex_to_bytes(RSA_PKCS8_HEX)
        val msg = _msg_hello()
        val sig = _sign_ecdsa_p256(rsa_pkcs8, msg)
        expect(sig.len()).to_equal(0)

    it "RSA 1024-bit key -> rsa_sha256_sign returns empty (ring min-size check)":
        val small_pkcs8 = hex_to_bytes(RSA_1024_PKCS8_HEX)
        val msg = _msg_hello()
        val sig = _sign_rsa256(small_pkcs8, msg)
        expect(sig.len()).to_equal(0)

    it "RSA verify with empty signature -> false":
        val spki = hex_to_bytes(RSA_SPKI_HEX)
        val msg = _msg_hello()
        var empty_sig: [u8] = []
        val ok = rsa_sha256_verify(spki, msg, empty_sig)
        expect(ok).to_equal(false)

    it "ECDSA verify with truncated 63-byte signature -> false":
        val spki = hex_to_bytes(EC_SPKI_HEX)
        val msg = _msg_hello()
        var bad_sig: [u8] = []
        var i: u64 = 0
        while i < 63:
            bad_sig.push(0xAA)
            i = i + 1
        val ok = ecdsa_p256_verify(spki, msg, bad_sig)
        expect(ok).to_equal(false)

    it "ed25519 verify with empty signature -> false":
        val pk = hex_to_bytes(ED25519_PK_HEX)
        val msg = hex_to_bytes(ED25519_MSG_HEX)
        var empty_sig: [u8] = []
        val ok = ed25519_verify(pk, msg, empty_sig)
        expect(ok).to_equal(false)
