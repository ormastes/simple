@allow(primitive_api)
"""
# OS Crypto Reference Signature Specification

**Feature IDs:** N/A
**Category:** Infrastructure
**Difficulty:** 4/5
**Status:** Implemented

## Overview

Byte-exact cross-check of every FFI-backed signature primitive against
`/usr/bin/openssl`.  Each test calls both the Simple FFI wrapper
(`std.nogc_sync_mut.io.signature_ffi`) and the openssl CLI, then compares
results to catch regressions at the byte level.

Entire suite is gated on `openssl_present()`.  If openssl is absent the
spec prints a skip message and passes vacuously.

tag: slow, system, crypto
"""

use std.sspec.*
use std.nogc_sync_mut.io.signature_ffi.{
    rsa_sha256_sign, rsa_sha512_sign, ecdsa_p256_sign,
    rsa_sha256_verify, rsa_sha512_verify, ecdsa_p256_verify,
    ed25519_verify, rt_ed25519_verify
}
use test.system.os_crypto_ref_helpers.{
    openssl_present, openssl_major_version,
    openssl_rsa_sign_sha256, openssl_rsa_sign_sha512,
    openssl_ecdsa_p256_verify_der,
    hex_to_bytes, bytes_to_hex
}
use std.nogc_sync_mut.ffi.system.{rt_process_run}
use std.nogc_sync_mut.ffi.io.{rt_file_write_bytes}

# ============================================================================
# Fixtures — hardcoded DER key bytes (hex decoded at runtime)
# ============================================================================

# RSA 2048-bit PKCS#8 v1 DER private key
# Source: src/compiler_rust/vendor/ring/tests/rsa_test_private_key_2048.p8
val RSA_PKCS8_HEX = ""

# RSA 2048-bit SPKI DER public key (extracted from private key via openssl pkey -pubout)
val RSA_SPKI_HEX = ""

# ECDSA P-256 PKCS#8 v1 DER private key
# Source: src/compiler_rust/vendor/ring/tests/ecdsa_test_private_key_p256.p8
val EC_PKCS8_HEX = "308187020100301306072a8648ce3d020106082a8648ce3d030107046d306b0201010420578329bff057bf48c84b9fc462940c57bb509e77e443228dbd627054a1fce283a14403420004fc116698a3e3236550c4c9efa9bd4d0619602a65d2930e9150ab33e84dbc83f8a6a6b9933f35ab59245e5b5a7af5dca76b33cbe7aeee5981b3ca350bebf52ecd"

# ECDSA P-256 SPKI DER public key
# The ring test file contains a raw 65-byte uncompressed EC point.
# SPKI = fixed P-256 header (26 bytes) + 65-byte uncompressed point.
# Header: 3059301306072a8648ce3d020106082a8648ce3d030107034200
# Raw point: 04fc116698a3e3236550c4c9...
val EC_SPKI_HEX = "3059301306072a8648ce3d020106082a8648ce3d03010703420004fc116698a3e3236550c4c9efa9bd4d0619602a65d2930e9150ab33e84dbc83f8a6a6b9933f35ab59245e5b5a7af5dca76b33cbe7aeee5981b3ca350bebf52ecd"

# Ed25519 RFC 8032 §7.1 TEST 2 (1-byte message 0x72)
# Using TEST 2 because openssl pkeyutl cannot handle empty messages.
val ED25519_PK_HEX  = "3d4017c3e843895a92b70aa74d1b7ebc9c982ccf2ec4968cc0cd55f12af4660c"
val ED25519_MSG_HEX = "72"
val ED25519_SIG_HEX = "92a009a9f0d4cab8720e820b5f642540a2b27b5416503f8fb3762223ebdb69da085ac1e43e15996e458f3613d0f11d8c387b2eaeb4302aeeb00d291612bb0c00"
# SPKI form of the same pubkey for openssl (302a300506032b6570032100 + raw 32 bytes)
val ED25519_SPKI_HEX = "302a300506032b65700321003d4017c3e843895a92b70aa74d1b7ebc9c982ccf2ec4968cc0cd55f12af4660c"

# A deliberately malformed PKCS#8 (too short / corrupted)
val BAD_PKCS8_HEX = "3001000000"

# ECDSA PKCS#8 passed to an RSA sign function — wrong key type
val WRONG_TYPE_PKCS8_HEX = "308187020100301306072a8648ce3d020106082a8648ce3d030107046d306b0201010420578329bff057bf48c84b9fc462940c57bb509e77e443228dbd627054a1fce283a14403420004fc116698a3e3236550c4c9efa9bd4d0619602a65d2930e9150ab33e84dbc83f8a6a6b9933f35ab59245e5b5a7af5dca76b33cbe7aeee5981b3ca350bebf52ecd"

# RSA 1024-bit PKCS#8 (below ring's minimum; generated offline)
# ring requires >= 2048-bit RSA; this should return empty.
val RSA_1024_PKCS8_HEX = ""

# ============================================================================
# Utility helpers (local to this spec)
# ============================================================================

fn _bytes_eq(a: [u8], b: [u8]) -> bool:
    if a.len() != b.len():
        return false
    var i: u64 = 0
    while i < a.len():
        if a[i] != b[i]:
            return false
        i = i + 1
    true

fn _make_1kb() -> [u8]:
    """Build a repeating 0..255 byte sequence of 1024 bytes."""
    var out: [u8] = []
    var i: u64 = 0
    while i < 1024:
        out.push((i % 256).to_u8())
        i = i + 1
    out

fn _make_64kb() -> [u8]:
    """Build a 4096-byte payload (kept small for interpreter watchdog)."""
    var out: [u8] = []
    var i: u64 = 0
    while i < 4096:
        out.push((i % 256).to_u8())
        i = i + 1
    out

fn _msg_hello() -> [u8]:
    """'Hello World' as ASCII bytes."""
    [0x48u8, 0x65, 0x6c, 0x6c, 0x6f, 0x20, 0x57, 0x6f, 0x72, 0x6c, 0x64]

fn _msg_empty() -> [u8]:
    []

fn _sign_rsa256(pkcs8: [u8], msg: [u8]) -> [u8]:
    """Return the raw RSA-SHA256 signature bytes, or [] on error."""
    rsa_sha256_sign(pkcs8, msg)

fn _sign_rsa512(pkcs8: [u8], msg: [u8]) -> [u8]:
    """Return the raw RSA-SHA512 signature bytes, or [] on error."""
    rsa_sha512_sign(pkcs8, msg)

fn _sign_ecdsa_p256(pkcs8: [u8], msg: [u8]) -> [u8]:
    """Return the raw ECDSA P-256 fixed-width signature bytes, or [] on error."""
    ecdsa_p256_sign(pkcs8, msg)

# ============================================================================
# DER encoding helpers for ECDSA r||s -> DER SEQUENCE { INTEGER r, INTEGER s }
# ============================================================================

fn _der_integer(raw32: [u8]) -> [u8]:
    """Encode a 32-byte big-endian integer component as a DER INTEGER.

    Strips leading zero bytes from raw32, then prepends 0x00 if the high
    bit of the first byte is set (to keep the value positive in DER).
    Wraps with 0x02 <length>.
    """
    # Find first non-zero byte
    var start: u64 = 0
    while (start < 32) and (raw32[start] == 0):
        start = start + 1
    # At minimum one byte (value 0)
    if start == 32:
        start = 31
    val needs_pad = raw32[start] >= 0x80
    var content: [u8] = []
    if needs_pad:
        content.push(0x00)
    var j: u64 = start
    while j < 32:
        content.push(raw32[j])
        j = j + 1
    var result: [u8] = []
    result.push(0x02)
    result.push(content.len().to_u8())
    var k: u64 = 0
    while k < content.len():
        result.push(content[k])
        k = k + 1
    result

fn _fixed64_to_der(sig64: [u8]) -> [u8]:
    """Convert 64-byte fixed r||s ECDSA signature to DER SEQUENCE form.

    DER = 0x30 <total_len> 0x02 <r_len> r 0x02 <s_len> s
    where r and s each have a leading 0x00 iff their high bit is set.
    """
    var r_bytes: [u8] = []
    var s_bytes: [u8] = []
    var i: u64 = 0
    while i < 32:
        r_bytes.push(sig64[i])
        i = i + 1
    while i < 64:
        s_bytes.push(sig64[i])
        i = i + 1
    val r_der = _der_integer(r_bytes)
    val s_der = _der_integer(s_bytes)
    val inner_len = r_der.len() + s_der.len()
    var out: [u8] = []
    out.push(0x30)
    out.push(inner_len.to_u8())
    var j: u64 = 0
    while j < r_der.len():
        out.push(r_der[j])
        j = j + 1
    j = 0
    while j < s_der.len():
        out.push(s_der[j])
        j = j + 1
    out

# ============================================================================
# openssl verify shim for RSA (writes key+msg+sig to tmpfiles, shells out)
# ============================================================================

var _tmp_seq: u64 = 100

fn _next_seq() -> text:
    _tmp_seq = _tmp_seq + 1
    _tmp_seq.to_text()

fn _openssl_rsa_verify_sha256(spki: [u8], msg: [u8], sig: [u8]) -> bool:
    val seq = _next_seq()
    val key_path = "/tmp/spl_sig_spec_rsa_spki_" + seq + ".der"
    val msg_path = "/tmp/spl_sig_spec_rsa_msg_" + seq + ".bin"
    val sig_path = "/tmp/spl_sig_spec_rsa_sig_" + seq + ".bin"
    rt_file_write_bytes(key_path, spki)
    rt_file_write_bytes(msg_path, msg)
    rt_file_write_bytes(sig_path, sig)
    val result = rt_process_run(
        "openssl",
        ["dgst", "-sha256", "-verify", key_path, "-keyform", "DER",
         "-signature", sig_path, msg_path]
    )
    result.2 == 0

fn _openssl_rsa_verify_sha512(spki: [u8], msg: [u8], sig: [u8]) -> bool:
    val seq = _next_seq()
    val key_path = "/tmp/spl_sig_spec_rsa_spki512_" + seq + ".der"
    val msg_path = "/tmp/spl_sig_spec_rsa_msg512_" + seq + ".bin"
    val sig_path = "/tmp/spl_sig_spec_rsa_sig512_" + seq + ".bin"
    rt_file_write_bytes(key_path, spki)
    rt_file_write_bytes(msg_path, msg)
    rt_file_write_bytes(sig_path, sig)
    val result = rt_process_run(
        "openssl",
        ["dgst", "-sha512", "-verify", key_path, "-keyform", "DER",
         "-signature", sig_path, msg_path]
    )
    result.2 == 0

fn _openssl_ed25519_verify(spki: [u8], msg: [u8], sig: [u8]) -> bool:
    val seq = _next_seq()
    val key_path = "/tmp/spl_sig_spec_ed_spki_" + seq + ".der"
    val msg_path = "/tmp/spl_sig_spec_ed_msg_" + seq + ".bin"
    val sig_path = "/tmp/spl_sig_spec_ed_sig_" + seq + ".bin"
    rt_file_write_bytes(key_path, spki)
    rt_file_write_bytes(msg_path, msg)
    rt_file_write_bytes(sig_path, sig)
    val result = rt_process_run(
        "openssl",
        ["pkeyutl", "-verify", "-pubin", "-inkey", key_path,
         "-keyform", "DER", "-sigfile", sig_path, "-rawin", "-in", msg_path]
    )
    result.2 == 0

# ============================================================================
# Suite
# ============================================================================

describe "os_crypto_ref_signature: RSA-SHA2-256 byte-exact cross-check":
    """
    ## RSA-SHA2-256 Signature Cross-Check

    Verifies that the Simple FFI rsa_sha256_sign wrapper produces byte-identical
    output to openssl dgst -sha256 -sign (both use PKCS#1 v1.5, deterministic).
    """

    it "skips entire suite when openssl is absent":
        if not openssl_present():
            expect(true).to_equal(true)

    it "sign Hello World: Simple == openssl (byte-exact)":
        if not openssl_present():
            expect(true).to_equal(true)
        else:
            val pkcs8 = hex_to_bytes(RSA_PKCS8_HEX)
            val msg = _msg_hello()
            val simple_sig = _sign_rsa256(pkcs8, msg)
            val ossl_sig = openssl_rsa_sign_sha256(pkcs8, msg)
            expect(simple_sig.len() > 0).to_equal(true)
            expect(ossl_sig.len() > 0).to_equal(true)
            expect(_bytes_eq(simple_sig, ossl_sig)).to_equal(true)

    it "sign empty message: Simple == openssl (byte-exact)":
        if not openssl_present():
            expect(true).to_equal(true)
        else:
            val pkcs8 = hex_to_bytes(RSA_PKCS8_HEX)
            val msg = _msg_empty()
            val simple_sig = _sign_rsa256(pkcs8, msg)
            val ossl_sig = openssl_rsa_sign_sha256(pkcs8, msg)
            expect(simple_sig.len() > 0).to_equal(true)
            expect(_bytes_eq(simple_sig, ossl_sig)).to_equal(true)

    it "sign 1 KB: Simple == openssl (byte-exact)":
        if not openssl_present():
            expect(true).to_equal(true)
        else:
            val pkcs8 = hex_to_bytes(RSA_PKCS8_HEX)
            val msg = _make_1kb()
            val simple_sig = _sign_rsa256(pkcs8, msg)
            val ossl_sig = openssl_rsa_sign_sha256(pkcs8, msg)
            expect(simple_sig.len() > 0).to_equal(true)
            expect(_bytes_eq(simple_sig, ossl_sig)).to_equal(true)

    it "round-trip: Simple sign -> Simple verify -> true":
        if not openssl_present():
            expect(true).to_equal(true)
        else:
            val pkcs8 = hex_to_bytes(RSA_PKCS8_HEX)
            val spki = hex_to_bytes(RSA_SPKI_HEX)
            val msg = _msg_hello()
            val sig = _sign_rsa256(pkcs8, msg)
            expect(sig.len() > 0).to_equal(true)
            val ok = rsa_sha256_verify(spki, msg, sig)
            expect(ok).to_equal(true)

    it "cross-verify: Simple sign -> openssl verify -> success":
        if not openssl_present():
            expect(true).to_equal(true)
        else:
            val pkcs8 = hex_to_bytes(RSA_PKCS8_HEX)
            val spki = hex_to_bytes(RSA_SPKI_HEX)
            val msg = _msg_hello()
            val sig = _sign_rsa256(pkcs8, msg)
            expect(sig.len() > 0).to_equal(true)
            val ok = _openssl_rsa_verify_sha256(spki, msg, sig)
            expect(ok).to_equal(true)

    it "negative: tampered signature -> Simple verify = false":
        if not openssl_present():
            expect(true).to_equal(true)
        else:
            val pkcs8 = hex_to_bytes(RSA_PKCS8_HEX)
            val spki = hex_to_bytes(RSA_SPKI_HEX)
            val msg = _msg_hello()
            val sig = _sign_rsa256(pkcs8, msg)
            if sig.len() == 0:
                expect(false).to_equal(true)
            else:
                var bad_sig: [u8] = []
                bad_sig.push((sig[0].to_i64() ^ 0xFF).to_u8())
                var i: u64 = 1
                while i < sig.len():
                    bad_sig.push(sig[i])
                    i = i + 1
                val ok = rsa_sha256_verify(spki, msg, bad_sig)
                expect(ok).to_equal(false)

    it "large (4 KiB) message: sign + verify succeed":
        if not openssl_present():
            expect(openssl_present()).to_equal(false)
        else:
            val pkcs8 = hex_to_bytes(RSA_PKCS8_HEX)
            val spki = hex_to_bytes(RSA_SPKI_HEX)
            val msg = _make_64kb()
            val sig = _sign_rsa256(pkcs8, msg)
            expect(sig.len() > 0).to_equal(true)
            val ok = rsa_sha256_verify(spki, msg, sig)
            expect(ok).to_equal(true)


describe "os_crypto_ref_signature: RSA-SHA2-512 byte-exact cross-check":
    """
    ## RSA-SHA2-512 Signature Cross-Check

    Same matrix as RSA-SHA2-256 but with SHA-512 digest.
    """

    it "sign Hello World: Simple == openssl (byte-exact)":
        if not openssl_present():
            expect(true).to_equal(true)
        else:
            val pkcs8 = hex_to_bytes(RSA_PKCS8_HEX)
