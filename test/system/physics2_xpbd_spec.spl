# Physics2 XPBD Rope — System Test
#
# Verifies: XPBD solver, distance constraints, compliance,
# chain sag under gravity, fixed particle anchoring.

use std.io_runtime
use std.spec.{describe, it, expect}
use std.common.math.{math_sqrt, math_abs}
use std.nogc_sync_mut.engine.physics2.solver.xpbd_solver.{XpbdWorld}

fn make_rope(length: i64, spacing: f64, stiffness: f64) -> XpbdWorld:
    var world = XpbdWorld.create(4)
    # First particle fixed at origin
    world.add_fixed_particle(0.0, 0.0, 0.0)
    # Rest are dynamic
    var i = 1
    while i < length:
        val x = i.to_f64() * spacing
        world.add_particle(x, 0.0, 0.0, 1.0)
        i = i + 1
    # Distance constraints between adjacent particles
    var j = 0
    while j < length - 1:
        world.add_distance_constraint(j, j + 1, stiffness)
        j = j + 1
    world

fn step_rope(world: XpbdWorld, n: i64):
    var i = 0
    while i < n:
        world.step(0.02)
        i = i + 1

fn get_bottom_y(world: XpbdWorld, length: i64) -> f64:
    var min_y = 0.0
    var i = 0
    while i < length:
        val pos = world.get_position(i)
        if pos.1 < min_y:
            min_y = pos.1
        i = i + 1
    min_y

describe "Physics2 XPBD Rope System":
    it "rope sags under gravity":
        var world = make_rope(8, 0.5, 50.0)
        step_rope(world, 60)
        val bottom = get_bottom_y(world, 8)
        expect(bottom < -0.3).to_equal(true)

    it "fixed particle stays at origin":
        var world = make_rope(5, 0.5, 100.0)
        step_rope(world, 40)
        val pos = world.get_position(0)
        expect(pos.0).to_equal(0.0)
        expect(pos.1).to_equal(0.0)
        expect(pos.2).to_equal(0.0)

    it "particles stay bounded":
        var world = make_rope(6, 0.5, 50.0)
        step_rope(world, 80)
        var i = 0
        var all_bounded = true
        while i < 6:
            val pos = world.get_position(i)
            if pos.0 < -20.0 or pos.0 > 20.0:
                all_bounded = false
            if pos.1 < -20.0 or pos.1 > 20.0:
                all_bounded = false
            i = i + 1
        expect(all_bounded).to_equal(true)

    it "end particle below start":
        var world = make_rope(5, 0.5, 80.0)
        step_rope(world, 50)
        val end_pos = world.get_position(4)
        expect(end_pos.1 < 0.0).to_equal(true)
