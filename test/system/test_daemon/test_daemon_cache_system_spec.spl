# Test Daemon Cache System Test
#
# Tests real file-based change detection and caching.
# Creates actual test files, hashes them, records results,
# modifies files, and verifies cache invalidation.
#
# **Feature IDs:** #TDMN-SYS-021 to #TDMN-SYS-030
# **Category:** Infrastructure / System Test
#
# NOTE: Each test is wrapped in a standalone function to work around
# the nested closure capture bug (it blocks can't see module var mutations).

extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_delete(path: text) -> bool
extern fn rt_dir_create_all(path: text) -> bool
extern fn rt_getpid() -> i64
extern fn rt_time_now_unix_micros() -> i64

fn simple_hash(s: text) -> i64:
    val bs = s.bytes()
    var h: i64 = 5381
    var i = 0
    while i < bs.len():
        h = h * 33 + bs[i]
        i = i + 1
    if h < 0:
        h = 0 - h
    h

fn hash_file(path: text) -> i64:
    val content = rt_file_read_text(path) ?? ""
    simple_hash(content)

fn make_test_dir() -> text:
    val pid = rt_getpid()
    val ts = rt_time_now_unix_micros()
    val dir = "/tmp/tdcache_test_{pid}_{ts}"
    rt_dir_create_all(dir)
    rt_dir_create_all("{dir}/src")
    dir

fn build_big_content(n: i64) -> text:
    var parts: [text] = []
    var i: i64 = 0
    while i < n:
        parts.push("# Line {i}: Some test content that makes this file large\n")
        i = i + 1
    parts.join("")

# ============================================================================
# Self-contained test functions (no module var mutation from closures)
# ============================================================================

fn test_unchanged_file_fresh() -> bool:
    val dir = make_test_dir()
    val path = "{dir}/src/unchanged_spec.spl"
    rt_file_write_text(path, "# test file\nval x = 42\n")

    # Record hash
    val recorded_hash = hash_file(path)

    # Check freshness — file unchanged, hashes should match
    val current_hash = hash_file(path)
    val fresh = recorded_hash == current_hash

    # Cleanup
    rt_file_delete(path)
    rt_file_delete("{dir}/src")
    rt_file_delete(dir)
    fresh

fn test_modified_file_stale() -> bool:
    val dir = make_test_dir()
    val path = "{dir}/src/changing_spec.spl"
    rt_file_write_text(path, "# version 1\nval x = 1\n")

    # Record hash
    val recorded_hash = hash_file(path)

    # Modify the file
    rt_file_write_text(path, "# version 2\nval x = 2\n")

    # Check freshness — file changed, should be stale
    val current_hash = hash_file(path)
    val stale = recorded_hash != current_hash

    rt_file_delete(path)
    rt_file_delete("{dir}/src")
    rt_file_delete(dir)
    stale

fn test_new_file_not_cached() -> bool:
    val dir = make_test_dir()
    val path = "{dir}/src/new_spec.spl"
    rt_file_write_text(path, "# brand new test\n")

    # No recorded hash — cache has nothing
    # We simulate by checking a lookup in an empty list
    var cached_paths: [text] = []
    var found = false
    var i = 0
    while i < cached_paths.len():
        if cached_paths[i] == path:
            found = true
        i = i + 1

    rt_file_delete(path)
    rt_file_delete("{dir}/src")
    rt_file_delete(dir)
    not found

fn test_track_5_files() -> text:
    val dir = make_test_dir()
    val src = "{dir}/src"
    val p1 = "{src}/t1_spec.spl"
    val p2 = "{src}/t2_spec.spl"
    val p3 = "{src}/t3_spec.spl"
    val p4 = "{src}/t4_spec.spl"
    val p5 = "{src}/t5_spec.spl"
    rt_file_write_text(p1, "# test 1\n")
    rt_file_write_text(p2, "# test 2\n")
    rt_file_write_text(p3, "# test 3\n")
    rt_file_write_text(p4, "# test 4\n")
    rt_file_write_text(p5, "# test 5\n")

    # Record hashes
    var paths: [text] = [p1, p2, p3, p4, p5]
    var hashes: [i64] = []
    var i = 0
    while i < paths.len():
        hashes.push(hash_file(paths[i]))
        i = i + 1

    # All should be fresh initially
    var all_fresh_before = true
    i = 0
    while i < 3:
        val h = hash_file(paths[i])
        if h != hashes[i]:
            all_fresh_before = false
        i = i + 1

    # Modify only p3
    rt_file_write_text(p3, "# test 3 modified\n")

    # Check: p1,p2 fresh, p3 stale, p4,p5 fresh
    val p1_fresh = hash_file(p1) == hashes[0]
    val p2_fresh = hash_file(p2) == hashes[1]
    val p3_fresh = hash_file(p3) == hashes[2]
    val p4_fresh = hash_file(p4) == hashes[3]
    val p5_fresh = hash_file(p5) == hashes[4]

    # Cleanup
    i = 0
    while i < paths.len():
        rt_file_delete(paths[i])
        i = i + 1
    rt_file_delete(src)
    rt_file_delete(dir)

    # Return encoded results
    var errors: [text] = []
    if not all_fresh_before:
        errors.push("initial not all fresh")
    if not p1_fresh:
        errors.push("p1 not fresh")
    if not p2_fresh:
        errors.push("p2 not fresh")
    if p3_fresh:
        errors.push("p3 should be stale")
    if not p4_fresh:
        errors.push("p4 not fresh")
    if not p5_fresh:
        errors.push("p5 not fresh")
    if errors.len() == 0:
        "ok"
    else:
        errors.join(", ")

fn test_rerecord_after_modification() -> text:
    val dir = make_test_dir()
    val path = "{dir}/src/rerecord_spec.spl"
    rt_file_write_text(path, "# v1\n")

    # Record v1
    val hash_v1 = hash_file(path)
    val fresh_after_record = hash_file(path) == hash_v1

    # Modify
    rt_file_write_text(path, "# v2\n")
    val stale_after_modify = hash_file(path) != hash_v1

    # Re-record with v2
    val hash_v2 = hash_file(path)
    val fresh_after_rerecord = hash_file(path) == hash_v2

    rt_file_delete(path)
    rt_file_delete("{dir}/src")
    rt_file_delete(dir)

    var errors: [text] = []
    if not fresh_after_record:
        errors.push("not fresh after initial record")
    if not stale_after_modify:
        errors.push("not stale after modify")
    if not fresh_after_rerecord:
        errors.push("not fresh after re-record")
    if errors.len() == 0:
        "ok"
    else:
        errors.join(", ")

fn test_invalidation() -> text:
    val dir = make_test_dir()
    val p1 = "{dir}/src/inv1_spec.spl"
    val p2 = "{dir}/src/inv2_spec.spl"
    rt_file_write_text(p1, "# test 1\n")
    rt_file_write_text(p2, "# test 2\n")

    # Record both
    var paths: [text] = [p1, p2]
    var hashes: [i64] = [hash_file(p1), hash_file(p2)]
    val count_before = paths.len()

    # Invalidate all
    paths = []
    hashes = []
    val count_after = paths.len()

    # After invalidation, "find" should return not-found
    var found_p1 = false
    var i = 0
    while i < paths.len():
        if paths[i] == p1:
            found_p1 = true
        i = i + 1

    rt_file_delete(p1)
    rt_file_delete(p2)
    rt_file_delete("{dir}/src")
    rt_file_delete(dir)

    var errors: [text] = []
    if count_before != 2:
        errors.push("count_before={count_before}")
    if count_after != 0:
        errors.push("count_after={count_after}")
    if found_p1:
        errors.push("p1 still found after invalidation")
    if errors.len() == 0:
        "ok"
    else:
        errors.join(", ")

fn test_persistence() -> text:
    val dir = make_test_dir()
    val cache_file = "{dir}/test_cache.sdn"
    val path = "{dir}/src/persist_spec.spl"
    rt_file_write_text(path, "# persistent\n")

    # Build cache content and save
    val hash = hash_file(path)
    var parts: [text] = ["# Test Cache\n"]
    parts.push("\n[{path}]\n")
    parts.push("hash={hash}\n")
    parts.push("status=2\n")
    parts.push("passed=10\n")
    parts.push("failed=0\n")
    rt_file_write_text(cache_file, parts.join(""))

    val file_there = rt_file_exists(cache_file)
    val content = rt_file_read_text(cache_file) ?? ""
    val has_path = content.contains("persist_spec.spl")
    val has_passed = content.contains("passed=10")

    rt_file_delete(path)
    rt_file_delete(cache_file)
    rt_file_delete("{dir}/src")
    rt_file_delete(dir)

    var errors: [text] = []
    if not file_there:
        errors.push("cache file not created")
    if not has_path:
        errors.push("path not in cache")
    if not has_passed:
        errors.push("passed=10 not in cache")
    if errors.len() == 0:
        "ok"
    else:
        errors.join(", ")

fn test_empty_file() -> bool:
    val dir = make_test_dir()
    val path = "{dir}/src/empty_spec.spl"
    rt_file_write_text(path, "")
    val recorded_hash = hash_file(path)
    val fresh = hash_file(path) == recorded_hash
    rt_file_delete(path)
    rt_file_delete("{dir}/src")
    rt_file_delete(dir)
    fresh

fn test_large_content() -> text:
    val dir = make_test_dir()
    val big_content = build_big_content(100)
    val path = "{dir}/src/big_spec.spl"
    rt_file_write_text(path, big_content)
    val recorded_hash = hash_file(path)
    val fresh_before = hash_file(path) == recorded_hash

    # Add one more line
    val modified = big_content + "# one more line\n"
    rt_file_write_text(path, modified)
    val stale_after = hash_file(path) != recorded_hash

    rt_file_delete(path)
    rt_file_delete("{dir}/src")
    rt_file_delete(dir)

    var errors: [text] = []
    if not fresh_before:
        errors.push("not fresh before modification")
    if not stale_after:
        errors.push("not stale after modification")
    if errors.len() == 0:
        "ok"
    else:
        errors.join(", ")

fn test_special_chars_path() -> bool:
    val dir = make_test_dir()
    val path = "{dir}/src/test-with-dashes_and_underscores_spec.spl"
    rt_file_write_text(path, "# special\n")
    val recorded_hash = hash_file(path)
    val fresh = hash_file(path) == recorded_hash
    rt_file_delete(path)
    rt_file_delete("{dir}/src")
    rt_file_delete(dir)
    fresh

# ============================================================================
# Tests
# ============================================================================

describe "TestDaemon Cache System":
    describe "real file hashing":
        it "detects unchanged file as fresh":
            expect(test_unchanged_file_fresh()).to_equal(true)

        it "detects modified file as stale":
            expect(test_modified_file_stale()).to_equal(true)

        it "detects new file as not cached":
            expect(test_new_file_not_cached()).to_equal(true)

    describe "multi-file change detection":
        it "tracks 5 test files independently":
            expect(test_track_5_files()).to_equal("ok")

        it "re-records after modification":
            expect(test_rerecord_after_modification()).to_equal("ok")

    describe "invalidation":
        it "invalidates all cached results":
            expect(test_invalidation()).to_equal("ok")

    describe "persistence":
        it "saves cache to file":
            expect(test_persistence()).to_equal("ok")

    describe "edge cases":
        it "handles empty file":
            expect(test_empty_file()).to_equal(true)

        it "handles very large content":
            expect(test_large_content()).to_equal("ok")

        it "handles special characters in file path":
            expect(test_special_chars_path()).to_equal(true)
