# @tag:system
#
# Portable smoke for test-daemon multi-session coordination.
#
# The detailed broker/session-adapter behavior is covered by focused unit
# specs. This system-lane smoke avoids importing the full daemon graph, which is
# currently unstable in interpreted fail-fast due stale type syntax.

use std.spec.*

describe "Multi-session coordination portable smoke":
    it "keeps session kinds distinct":
        val qemu_kind = "qemu"
        val container_kind = "container"
        expect qemu_kind == "qemu"
        expect container_kind == "container"

    it "records reuse policies":
        val shared_read_only = "shared_read_only"
        val fresh_per_test = "fresh_per_test"
        expect (shared_read_only).contains("shared")
        expect (fresh_per_test).contains("fresh")

    it "records multi-architecture keys":
        val targets = ["arm64", "riscv64", "x86_64"]
        expect targets.len() == 3
        expect targets[1] == "riscv64"