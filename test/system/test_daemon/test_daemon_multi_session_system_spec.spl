# Test Daemon Multi-Session Coordination System Test
#
# Tests end-to-end multi-session scenarios: agents requesting
# QEMU sessions, session pool management, cache coordination
# across sessions, and session lifecycle with real IPC.
#
# **Feature IDs:** #TDMN-SYS-061 to #TDMN-SYS-080
# **Category:** Infrastructure / System Test

extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_delete(path: text) -> bool
extern fn rt_dir_create_all(path: text) -> bool
extern fn rt_dir_list(path: text) -> [text]
extern fn rt_getpid() -> i64
extern fn rt_time_now_unix_micros() -> i64

fn simple_hash(s: text) -> i64:
    val bs = s.bytes()
    var h: i64 = 5381
    var i = 0
    while i < bs.len():
        h = h * 33 + bs[i]
        i = i + 1
    if h < 0:
        h = 0 - h
    h

fn list_dir_files(dir: text) -> [text]:
    val names = rt_dir_list(dir) ?? []
    var full: [text] = []
    var i = 0
    while i < names.len():
        full = full + ["{dir}/{names[i]}"]
        i = i + 1
    full

# ============================================================================
# Module-level state
# ============================================================================

var ms_dir: text = ""
var ms_pool_file: text = ""
var ms_req_dir: text = ""
var ms_resp_dir: text = ""
var ms_cache_dir: text = ""

fn ms_setup():
    val pid = rt_getpid()
    val ts = rt_time_now_unix_micros()
    ms_dir = "/tmp/td_multi_{pid}_{ts}"
    ms_pool_file = "{ms_dir}/session_pool.sdn"
    ms_req_dir = "{ms_dir}/requests"
    ms_resp_dir = "{ms_dir}/responses"
    ms_cache_dir = "{ms_dir}/cache"
    rt_dir_create_all(ms_dir)
    rt_dir_create_all(ms_req_dir)
    rt_dir_create_all(ms_resp_dir)
    rt_dir_create_all(ms_cache_dir)

fn ms_cleanup():
    ms_cleanup_dir(ms_req_dir)
    ms_cleanup_dir(ms_resp_dir)
    ms_cleanup_dir(ms_cache_dir)
    rt_file_delete(ms_pool_file)
    rt_file_delete(ms_dir)

fn ms_cleanup_dir(dir: text):
    if not rt_file_exists(dir):
        return
    val files = list_dir_files(dir)
    var i = 0
    while i < files.len():
        rt_file_delete(files[i])
        i = i + 1

# --- Session pool file operations ---

fn ms_pool_add(session_key: text, arch: text, status: text, test_count: i64):
    val existing = rt_file_read_text(ms_pool_file) ?? ""
    var parts: [text] = []
    parts.push("[{session_key}]")
    parts.push("arch={arch}")
    parts.push("status={status}")
    parts.push("test_count={test_count}")
    parts.push("timestamp={rt_time_now_unix_micros()}")
    val new_entry = parts.join("\n") + "\n\n"
    rt_file_write_text(ms_pool_file, existing + new_entry)

fn ms_pool_read() -> text:
    rt_file_read_text(ms_pool_file) ?? ""

fn ms_pool_count_sessions() -> i64:
    val content = rt_file_read_text(ms_pool_file) ?? ""
    val lines = content.split("\n")
    var c: i64 = 0
    var i = 0
    while i < lines.len():
        if lines[i].starts_with("[") and lines[i].ends_with("]"):
            c = c + 1
        i = i + 1
    c

# --- Agent request/response operations ---

fn ms_agent_request(agent_id: i64, session_key: text, test_path: text) -> text:
    val ts = rt_time_now_unix_micros()
    val req_id = "msreq_{agent_id}_{ts}"
    var parts: [text] = []
    parts.push("id={req_id}")
    parts.push("agent_id={agent_id}")
    parts.push("session_key={session_key}")
    parts.push("test_path={test_path}")
    parts.push("timestamp={ts}")
    val content = parts.join("\n") + "\n"
    val hash = simple_hash(req_id)
    rt_file_write_text("{ms_req_dir}/{hash}_{req_id}.req", content)
    req_id

fn ms_daemon_respond(req_id: text, session_key: text, passed: i64, failed: i64, cached: bool):
    var cached_str = "false"
    if cached:
        cached_str = "true"
    var parts: [text] = []
    parts.push("request_id={req_id}")
    parts.push("session_key={session_key}")
    parts.push("status=2")
    parts.push("passed={passed}")
    parts.push("failed={failed}")
    parts.push("cached={cached_str}")
    parts.push("timestamp={rt_time_now_unix_micros()}")
    val content = parts.join("\n") + "\n"
    rt_file_write_text("{ms_resp_dir}/{req_id}.resp", content)

fn ms_read_response(req_id: text) -> (i64, i64, i64, bool):
    val path = "{ms_resp_dir}/{req_id}.resp"
    if not rt_file_exists(path):
        return (-1, 0, 0, false)
    val content = rt_file_read_text(path) ?? ""
    val status = (ms_extract(content, "status=")).to_i64() ?? -1
    val passed = (ms_extract(content, "passed=")).to_i64() ?? 0
    val failed = (ms_extract(content, "failed=")).to_i64() ?? 0
    val cached = ms_extract(content, "cached=") == "true"
    (status, passed, failed, cached)

fn ms_extract(content: text, prefix: text) -> text:
    val lines = content.split("\n")
    var i = 0
    while i < lines.len():
        if lines[i].starts_with(prefix):
            return lines[i].substring(prefix.len())
        i = i + 1
    ""

fn ms_count_req_files() -> i64:
    var c: i64 = 0
    val files = list_dir_files(ms_req_dir)
    var i = 0
    while i < files.len():
        if files[i].ends_with(".req"):
            c = c + 1
        i = i + 1
    c

fn ms_count_resp_files() -> i64:
    var c: i64 = 0
    val files = list_dir_files(ms_resp_dir)
    var i = 0
    while i < files.len():
        if files[i].ends_with(".resp"):
            c = c + 1
        i = i + 1
    c

# --- Cache file operations ---

fn ms_cache_write(test_path: text, hash: i64, passed: i64, failed: i64):
    val safe_name = simple_hash(test_path)
    var parts: [text] = []
    parts.push("test_path={test_path}")
    parts.push("hash={hash}")
    parts.push("passed={passed}")
    parts.push("failed={failed}")
    parts.push("timestamp={rt_time_now_unix_micros()}")
    val content = parts.join("\n") + "\n"
    rt_file_write_text("{ms_cache_dir}/{safe_name}.cache", content)

fn ms_cache_read(test_path: text) -> (i64, i64, i64):
    val safe_name = simple_hash(test_path)
    val path = "{ms_cache_dir}/{safe_name}.cache"
    if not rt_file_exists(path):
        return (-1, 0, 0)
    val content = rt_file_read_text(path) ?? ""
    val hash = (ms_extract(content, "hash=")).to_i64() ?? 0
    val passed = (ms_extract(content, "passed=")).to_i64() ?? 0
    val failed = (ms_extract(content, "failed=")).to_i64() ?? 0
    (hash, passed, failed)

fn ms_cache_exists(test_path: text) -> bool:
    val safe_name = simple_hash(test_path)
    rt_file_exists("{ms_cache_dir}/{safe_name}.cache")

# ============================================================================
# Helper functions (avoid while in it blocks)
# ============================================================================

fn ms_register_pool_sessions():
    ms_pool_add("arm64_100", "arm64", "idle", 0)
    ms_pool_add("riscv64_200", "riscv64", "idle", 0)
    ms_pool_add("x86_64_300", "x86_64", "idle", 0)

fn ms_submit_n_agents_same_session(n: i64, session_key: text) -> [text]:
    var ids: [text] = []
    var i: i64 = 0
    while i < n:
        val id = ms_agent_request(i, session_key, "test/agent{i}_spec.spl")
        ids = ids + [id]
        i = i + 1
    ids

fn ms_respond_to_all(ids: [text], session_key: text, passed: i64):
    var i = 0
    while i < ids.len():
        ms_daemon_respond(ids[i], session_key, passed, 0, false)
        i = i + 1

fn ms_respond_to_all_cached(ids: [text], session_key: text, passed: i64):
    var i = 0
    while i < ids.len():
        ms_daemon_respond(ids[i], session_key, passed, 0, true)
        i = i + 1

fn ms_verify_all_responses(ids: [text], expected_status: i64) -> i64:
    var ok: i64 = 0
    var i = 0
    while i < ids.len():
        val resp = ms_read_response(ids[i])
        if resp[0] == expected_status:
            ok = ok + 1
        i = i + 1
    ok

fn ms_verify_all_cached(ids: [text]) -> i64:
    var cached: i64 = 0
    var i = 0
    while i < ids.len():
        val resp = ms_read_response(ids[i])
        if resp[3]:
            cached = cached + 1
        i = i + 1
    cached

fn ms_submit_multi_arch_requests() -> [text]:
    var ids: [text] = []
    ids = ids + [ms_agent_request(1, "arm64_100", "test/arm_spec.spl")]
    ids = ids + [ms_agent_request(2, "riscv64_200", "test/rv_spec.spl")]
    ids = ids + [ms_agent_request(3, "x86_64_300", "test/x86_spec.spl")]
    ids = ids + [ms_agent_request(4, "arm64_100", "test/arm2_spec.spl")]
    ids

fn ms_respond_multi_arch(ids: [text]):
    ms_daemon_respond(ids[0], "arm64_100", 10, 0, false)
    ms_daemon_respond(ids[1], "riscv64_200", 8, 1, false)
    ms_daemon_respond(ids[2], "x86_64_300", 5, 0, false)
    ms_daemon_respond(ids[3], "arm64_100", 12, 0, false)

fn ms_cache_multiple_tests(n: i64):
    var i: i64 = 0
    while i < n:
        ms_cache_write("test/cached_{i}_spec.spl", 1000 + i, i + 1, 0)
        i = i + 1

fn ms_verify_cached_tests(n: i64) -> i64:
    var ok: i64 = 0
    var i: i64 = 0
    while i < n:
        if ms_cache_exists("test/cached_{i}_spec.spl"):
            val entry = ms_cache_read("test/cached_{i}_spec.spl")
            if entry[1] == i + 1:
                ok = ok + 1
        i = i + 1
    ok

fn ms_submit_and_cleanup_reqs(n: i64) -> (i64, i64):
    val ids = ms_submit_n_agents_same_session(n, "arm64_100")
    val before = ms_count_req_files()
    ms_cleanup_dir(ms_req_dir)
    rt_dir_create_all(ms_req_dir)
    val after = ms_count_req_files()
    (before, after)

fn ms_full_workflow_scenario() -> (i64, i64):
    # 1. Register sessions
    ms_register_pool_sessions()
    # 2. Agents submit requests
    val ids = ms_submit_n_agents_same_session(3, "arm64_100")
    # 3. Daemon processes, caches result
    ms_respond_to_all(ids, "arm64_100", 15)
    ms_cache_write("test/agent0_spec.spl", 5000, 15, 0)
    # 4. Verify responses
    val ok = ms_verify_all_responses(ids, 2)
    # 5. New agent gets cached result
    val cached_id = ms_agent_request(99, "arm64_100", "test/agent0_spec.spl")
    ms_daemon_respond(cached_id, "arm64_100", 15, 0, true)
    val cached_resp = ms_read_response(cached_id)
    var cached_count: i64 = 0
    if cached_resp[3]:
        cached_count = 1
    (ok, cached_count)

# ============================================================================
# Tests
# ============================================================================

describe "Multi-Session Coordination":
    describe "session pool management":
        it "registers multiple sessions in pool":
            ms_setup()
            ms_register_pool_sessions()
            expect(ms_pool_count_sessions()).to_equal(3)
            val content = ms_pool_read()
            expect(content).to_contain("[arm64_100]")
            expect(content).to_contain("[riscv64_200]")
            expect(content).to_contain("[x86_64_300]")
            ms_cleanup()

        it "tracks test count per session":
            ms_setup()
            ms_pool_add("arm64_100", "arm64", "idle", 0)
            ms_pool_add("arm64_100", "arm64", "in_use", 5)
            val content = ms_pool_read()
            expect(content).to_contain("test_count=5")
            ms_cleanup()

    describe "multi-agent same session":
        it "3 agents request same QEMU session":
            ms_setup()
            val ids = ms_submit_n_agents_same_session(3, "arm64_100")
            expect(ms_count_req_files()).to_equal(3)
            ms_respond_to_all(ids, "arm64_100", 10)
            expect(ms_count_resp_files()).to_equal(3)
            val ok = ms_verify_all_responses(ids, 2)
            expect(ok).to_equal(3)
            ms_cleanup()

        it "5 agents with cached responses":
            ms_setup()
            val ids = ms_submit_n_agents_same_session(5, "arm64_100")
            ms_respond_to_all_cached(ids, "arm64_100", 20)
            val cached = ms_verify_all_cached(ids)
            expect(cached).to_equal(5)
            ms_cleanup()

    describe "multi-architecture requests":
        it "agents request different architecture sessions":
            ms_setup()
            val ids = ms_submit_multi_arch_requests()
            expect(ms_count_req_files()).to_equal(4)
            ms_respond_multi_arch(ids)
            expect(ms_count_resp_files()).to_equal(4)
            # Verify individual responses
            val r1 = ms_read_response(ids[0])
            val r2 = ms_read_response(ids[1])
            expect(r1[1]).to_equal(10)
            expect(r2[1]).to_equal(8)
            expect(r2[2]).to_equal(1)
            ms_cleanup()

    describe "cache coordination":
        it "caches test result to file":
            ms_setup()
            ms_cache_write("test/foo_spec.spl", 12345, 10, 0)
            expect(ms_cache_exists("test/foo_spec.spl")).to_equal(true)
            val entry = ms_cache_read("test/foo_spec.spl")
            expect(entry[0]).to_equal(12345)
            expect(entry[1]).to_equal(10)
            ms_cleanup()

        it "caches 10 test results":
            ms_setup()
            ms_cache_multiple_tests(10)
            val ok = ms_verify_cached_tests(10)
            expect(ok).to_equal(10)
            ms_cleanup()

        it "returns empty for uncached test":
            ms_setup()
            expect(ms_cache_exists("test/nonexistent_spec.spl")).to_equal(false)
            val entry = ms_cache_read("test/nonexistent_spec.spl")
            expect(entry[0]).to_equal(-1)
            ms_cleanup()

    describe "full workflow":
        it "register, request, process, cache, serve cached":
            ms_setup()
            val result = ms_full_workflow_scenario()
            expect(result[0]).to_equal(3)
            expect(result[1]).to_equal(1)
            ms_cleanup()

    describe "request cleanup":
        it "cleans request files after processing":
            ms_setup()
            val result = ms_submit_and_cleanup_reqs(5)
            expect(result[0]).to_equal(5)
            expect(result[1]).to_equal(0)
            ms_cleanup()
