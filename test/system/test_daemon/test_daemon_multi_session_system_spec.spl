# @cover src/app/test_daemon/session_broker.spl 80%
# @cover src/app/test_daemon/session_types.spl 80%
# @cover src/app/test_daemon/session_adapter.spl 80%
# Test Daemon Multi-Session Coordination System Test
#
# Tests end-to-end multi-session pool management: multiple session pools
# by kind, agent coordination via broker, multi-architecture session
# requests, cache coordination, and session lifecycle across kinds.
#
# **Feature IDs:** #TDMN-SYS-061 to #TDMN-SYS-080
# **Category:** Infrastructure / System Test

use std.spec.{describe, it, expect, before_each, after_each}
use std.io_runtime

use app.test_daemon.session_types.{
    SessionKey, SessionLease, TestSessionMeta,
    SESSION_KIND_QEMU_VM, SESSION_KIND_CONTAINER, SESSION_KIND_SERVICE,
    SESSION_KIND_LOCAL, SESSION_KIND_SIMULATOR,
    REUSE_SHARED_READ_ONLY, REUSE_SHARED_WITH_RESET, REUSE_FRESH_PER_TEST,
    RESET_NONE, RESET_SOFT,
    LEASE_IDLE, LEASE_ACTIVE,
    session_key_to_id, session_lease_new, test_session_meta_default,
    meta_to_session_key, session_kind_name
}
use app.test_daemon.session_broker.{SessionBroker, session_broker_new}
use app.test_daemon.session_adapter.{SessionAdapter, session_adapter_new}

# ============================================================================
# Helpers — build test metadata for various session kinds
# ============================================================================

fn make_qemu_meta(target: text, artifact: text, reuse: i64) -> TestSessionMeta:
    TestSessionMeta(
        file_path: "test/qemu_spec.spl",
        session_kind: SESSION_KIND_QEMU_VM,
        target: target,
        reuse_mode: reuse,
        reset_policy: RESET_NONE,
        artifact: artifact,
        startup_cmd: "",
        healthcheck: ""
    )

fn make_container_meta(target: text, artifact: text, reuse: i64) -> TestSessionMeta:
    TestSessionMeta(
        file_path: "test/container_spec.spl",
        session_kind: SESSION_KIND_CONTAINER,
        target: target,
        reuse_mode: reuse,
        reset_policy: RESET_NONE,
        artifact: artifact,
        startup_cmd: "",
        healthcheck: ""
    )

fn make_service_meta(target: text, artifact: text, reuse: i64) -> TestSessionMeta:
    TestSessionMeta(
        file_path: "test/service_spec.spl",
        session_kind: SESSION_KIND_SERVICE,
        target: target,
        reuse_mode: reuse,
        reset_policy: RESET_NONE,
        artifact: artifact,
        startup_cmd: "",
        healthcheck: ""
    )

fn make_simulator_meta(target: text, artifact: text, reuse: i64) -> TestSessionMeta:
    TestSessionMeta(
        file_path: "test/sim_spec.spl",
        session_kind: SESSION_KIND_SIMULATOR,
        target: target,
        reuse_mode: reuse,
        reset_policy: RESET_NONE,
        artifact: artifact,
        startup_cmd: "",
        healthcheck: ""
    )

fn acquire_and_release(broker: SessionBroker, meta: TestSessionMeta) -> SessionLease:
    val lease = broker.acquire(meta)
    broker.release(lease.session_id)
    lease

fn acquire_n(broker: SessionBroker, meta: TestSessionMeta, n: i64) -> [SessionLease]:
    var leases: [SessionLease] = []
    var i: i64 = 0
    while i < n:
        val lease = broker.acquire(meta)
        leases = leases + [lease]
        i = i + 1
    leases

fn release_all(broker: SessionBroker, leases: [SessionLease]):
    var i = 0
    while i < leases.len():
        broker.release(leases[i].session_id)
        i = i + 1

fn acquire_release_cycle(broker: SessionBroker, meta: TestSessionMeta, n: i64) -> i64:
    """Acquire and release n times, returning final test_count of last lease."""
    var i: i64 = 0
    var last_test_count: i64 = 0
    while i < n:
        val lease = broker.acquire(meta)
        last_test_count = lease.test_count
        broker.release(lease.session_id)
        i = i + 1
    last_test_count

# ============================================================================
# Tests
# ============================================================================

describe "Multi-Session Coordination":
    describe "multiple session pools by kind":
        it "creates separate pools for different kinds":
            var broker = session_broker_new()
            val mq = make_qemu_meta("arm64", "fw.bin", REUSE_SHARED_READ_ONLY)
            val mc = make_container_meta("x86_64", "img1", REUSE_SHARED_READ_ONLY)
            val ms = make_service_meta("x86_64", "svc1", REUSE_SHARED_READ_ONLY)
            broker.acquire(mq)
            broker.acquire(mc)
            broker.acquire(ms)
            expect(broker.total_count()).to_equal(3)
            expect(broker.count_by_kind(SESSION_KIND_QEMU_VM)).to_equal(1)
            expect(broker.count_by_kind(SESSION_KIND_CONTAINER)).to_equal(1)
            expect(broker.count_by_kind(SESSION_KIND_SERVICE)).to_equal(1)

        it "each kind has independent count":
            var broker = session_broker_new()
            val mq1 = make_qemu_meta("arm64", "fw1.bin", REUSE_FRESH_PER_TEST)
            val mq2 = make_qemu_meta("riscv64", "fw2.bin", REUSE_FRESH_PER_TEST)
            val mc1 = make_container_meta("x86_64", "img1", REUSE_FRESH_PER_TEST)
            broker.acquire(mq1)
            broker.acquire(mq2)
            broker.acquire(mc1)
            expect(broker.count_by_kind(SESSION_KIND_QEMU_VM)).to_equal(2)
            expect(broker.count_by_kind(SESSION_KIND_CONTAINER)).to_equal(1)

        it "count_by_kind returns zero for unused kind":
            var broker = session_broker_new()
            val mq = make_qemu_meta("arm64", "fw.bin", REUSE_SHARED_READ_ONLY)
            broker.acquire(mq)
            expect(broker.count_by_kind(SESSION_KIND_SIMULATOR)).to_equal(0)

        it "status report includes per-kind counts":
            var broker = session_broker_new()
            broker.acquire(make_qemu_meta("arm64", "fw.bin", REUSE_SHARED_READ_ONLY))
            broker.acquire(make_container_meta("x86_64", "img", REUSE_SHARED_READ_ONLY))
            val report = broker.status_report()
            expect(report).to_contain("QEMU: 1")
            expect(report).to_contain("Container: 1")

    describe "agent coordination via broker":
        it "sequential agents reuse same session":
            var broker = session_broker_new()
            val meta = make_qemu_meta("arm64", "fw.bin", REUSE_SHARED_READ_ONLY)
            # Agent 1 acquires and releases
            val l1 = broker.acquire(meta)
            broker.release(l1.session_id)
            # Agent 2 acquires same session
            val l2 = broker.acquire(meta)
            expect(l2.session_id).to_equal(l1.session_id)
            expect(l2.test_count).to_equal(1)
            broker.release(l2.session_id)
            # Agent 3 acquires
            val l3 = broker.acquire(meta)
            expect(l3.session_id).to_equal(l1.session_id)
            expect(l3.test_count).to_equal(2)
            expect(broker.total_count()).to_equal(1)

        it "multiple agents with fresh_per_test each get own session":
            var broker = session_broker_new()
            val meta = make_qemu_meta("arm64", "fw.bin", REUSE_FRESH_PER_TEST)
            val l1 = broker.acquire(meta)
            val l2 = broker.acquire(meta)
            val l3 = broker.acquire(meta)
            expect(broker.total_count()).to_equal(3)

        it "agent release allows reuse by next agent":
            var broker = session_broker_new()
            val meta = make_qemu_meta("arm64", "fw.bin", REUSE_SHARED_WITH_RESET)
            val l1 = broker.acquire(meta)
            # While l1 is active, second acquire creates new
            val l2 = broker.acquire(meta)
            expect(broker.total_count()).to_equal(2)
            # Release both
            broker.release(l1.session_id)
            broker.release(l2.session_id)
            # Third agent reuses one of the idle sessions
            val l3 = broker.acquire(meta)
            expect(broker.total_count()).to_equal(2)

        it "test_count increments through multiple reuse cycles":
            var broker = session_broker_new()
            val meta = make_qemu_meta("arm64", "fw.bin", REUSE_SHARED_READ_ONLY)
            val count = acquire_release_cycle(broker, meta, 5)
            # After 5 cycles, last test_count should be 4 (0-indexed from first acquire)
            expect(count).to_equal(4)
            expect(broker.total_count()).to_equal(1)

    describe "multi-architecture session requests":
        it "arm64 and riscv64 sessions are separate":
            var broker = session_broker_new()
            val m_arm = make_qemu_meta("arm64", "fw.bin", REUSE_SHARED_READ_ONLY)
            val m_rv = make_qemu_meta("riscv64", "fw.bin", REUSE_SHARED_READ_ONLY)
            val l1 = broker.acquire(m_arm)
            val l2 = broker.acquire(m_rv)
            expect(l1.key.target).to_equal("arm64")
            expect(l2.key.target).to_equal("riscv64")
            expect(broker.total_count()).to_equal(2)

        it "same architecture different artifact are separate":
            var broker = session_broker_new()
            val m1 = make_qemu_meta("arm64", "fw_v1.bin", REUSE_SHARED_READ_ONLY)
            val m2 = make_qemu_meta("arm64", "fw_v2.bin", REUSE_SHARED_READ_ONLY)
            broker.acquire(m1)
            broker.acquire(m2)
            expect(broker.count_by_kind(SESSION_KIND_QEMU_VM)).to_equal(2)

        it "three architectures can coexist":
            var broker = session_broker_new()
            val m1 = make_qemu_meta("arm64", "fw.bin", REUSE_SHARED_READ_ONLY)
            val m2 = make_qemu_meta("riscv64", "fw.bin", REUSE_SHARED_READ_ONLY)
            val m3 = make_qemu_meta("x86_64", "fw.bin", REUSE_SHARED_READ_ONLY)
            broker.acquire(m1)
            broker.acquire(m2)
            broker.acquire(m3)
            expect(broker.total_count()).to_equal(3)
            expect(broker.count_by_kind(SESSION_KIND_QEMU_VM)).to_equal(3)

        it "release and reacquire preserves architecture":
            var broker = session_broker_new()
            val meta = make_qemu_meta("riscv64", "rv_fw.bin", REUSE_SHARED_READ_ONLY)
            val l1 = broker.acquire(meta)
            broker.release(l1.session_id)
            val l2 = broker.acquire(meta)
            expect(l2.key.target).to_equal("riscv64")
            expect(l2.session_id).to_equal(l1.session_id)

    describe "mixed kind session management":
        it "qemu and container pools are independent":
            var broker = session_broker_new()
            val mq = make_qemu_meta("arm64", "fw.bin", REUSE_SHARED_READ_ONLY)
            val mc = make_container_meta("x86_64", "img1", REUSE_SHARED_READ_ONLY)
            val lq = broker.acquire(mq)
            val lc = broker.acquire(mc)
            expect(lq.key.kind).to_equal(SESSION_KIND_QEMU_VM)
            expect(lc.key.kind).to_equal(SESSION_KIND_CONTAINER)
            # Releasing qemu does not affect container
            broker.release(lq.session_id)
            expect(broker.idle_count()).to_equal(1)
            expect(broker.total_count()).to_equal(2)

        it "stopping one kind does not affect another":
            var broker = session_broker_new()
            val mq = make_qemu_meta("arm64", "fw.bin", REUSE_SHARED_READ_ONLY)
            val mc = make_container_meta("x86_64", "img1", REUSE_SHARED_READ_ONLY)
            val lq = broker.acquire(mq)
            val lc = broker.acquire(mc)
            broker.stop_session(lq.session_id)
            expect(broker.total_count()).to_equal(1)
            expect(broker.count_by_kind(SESSION_KIND_QEMU_VM)).to_equal(0)
            expect(broker.count_by_kind(SESSION_KIND_CONTAINER)).to_equal(1)

        it "shutdown_all clears all kinds":
            var broker = session_broker_new()
            broker.acquire(make_qemu_meta("arm64", "fw.bin", REUSE_SHARED_READ_ONLY))
            broker.acquire(make_container_meta("x86_64", "img", REUSE_SHARED_READ_ONLY))
            broker.acquire(make_service_meta("x86_64", "svc", REUSE_SHARED_READ_ONLY))
            expect(broker.total_count()).to_equal(3)
            broker.shutdown_all()
            expect(broker.total_count()).to_equal(0)
            expect(broker.count_by_kind(SESSION_KIND_QEMU_VM)).to_equal(0)
            expect(broker.count_by_kind(SESSION_KIND_CONTAINER)).to_equal(0)
            expect(broker.count_by_kind(SESSION_KIND_SERVICE)).to_equal(0)

    describe "session counts and idle/active tracking":
        it "active_count and idle_count are accurate":
            var broker = session_broker_new()
            val m1 = make_qemu_meta("arm64", "fw1.bin", REUSE_SHARED_READ_ONLY)
            val m2 = make_qemu_meta("riscv64", "fw2.bin", REUSE_SHARED_READ_ONLY)
            val l1 = broker.acquire(m1)
            val l2 = broker.acquire(m2)
            # Both sessions created (without adapter, they start IDLE from session_lease_new)
            broker.release(l1.session_id)
            # l1 is now idle, l2 depends on adapter start behavior
            val idle = broker.idle_count()
            val total = broker.total_count()
            expect(total).to_equal(2)
            expect(idle).to_be_greater_than(0)

        it "total_count after multiple acquire-release rounds":
            var broker = session_broker_new()
            val meta = make_qemu_meta("arm64", "fw.bin", REUSE_SHARED_READ_ONLY)
            # 5 acquire-release cycles on same session
            acquire_release_cycle(broker, meta, 5)
            expect(broker.total_count()).to_equal(1)
            expect(broker.idle_count()).to_equal(1)

        it "fresh_per_test accumulates sessions":
            var broker = session_broker_new()
            val meta = make_qemu_meta("arm64", "fw.bin", REUSE_FRESH_PER_TEST)
            val leases = acquire_n(broker, meta, 3)
            expect(broker.total_count()).to_equal(3)
            release_all(broker, leases)
            expect(broker.idle_count()).to_equal(3)

    describe "full lifecycle scenario":
        it "multi-kind acquire, partial release, stop, shutdown":
            var broker = session_broker_new()
            # Acquire 3 sessions of different kinds
            val lq = broker.acquire(make_qemu_meta("arm64", "fw.bin", REUSE_SHARED_READ_ONLY))
            val lc = broker.acquire(make_container_meta("x86_64", "img", REUSE_SHARED_READ_ONLY))
            val ls = broker.acquire(make_service_meta("x86_64", "svc", REUSE_SHARED_READ_ONLY))
            expect(broker.total_count()).to_equal(3)
            # Release qemu, stop container
            broker.release(lq.session_id)
            broker.stop_session(lc.session_id)
            expect(broker.total_count()).to_equal(2)
            expect(broker.idle_count()).to_be_greater_than(0)
            # Reacquire qemu (should reuse)
            val lq2 = broker.acquire(make_qemu_meta("arm64", "fw.bin", REUSE_SHARED_READ_ONLY))
            expect(lq2.session_id).to_equal(lq.session_id)
            expect(broker.total_count()).to_equal(2)
            # Final shutdown
            broker.shutdown_all()
            expect(broker.total_count()).to_equal(0)
