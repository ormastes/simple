# Test Daemon Session Sharing System Test
#
# Tests real file-based session coordination: concurrent session
# requests via IPC, session status tracking, lock-based
# exclusive access, and multi-agent session sharing with real
# filesystem operations.
#
# **Feature IDs:** #TDMN-SYS-041 to #TDMN-SYS-060
# **Category:** Infrastructure / System Test

extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_delete(path: text) -> bool
extern fn rt_dir_create_all(path: text) -> bool
extern fn rt_dir_list(path: text) -> [text]
extern fn rt_getpid() -> i64
extern fn rt_time_now_unix_micros() -> i64

fn simple_hash(s: text) -> i64:
    val bs = s.bytes()
    var h: i64 = 5381
    var i = 0
    while i < bs.len():
        h = h * 33 + bs[i]
        i = i + 1
    if h < 0:
        h = 0 - h
    h

fn list_dir_files(dir: text) -> [text]:
    val names = rt_dir_list(dir) ?? []
    var full: [text] = []
    var i = 0
    while i < names.len():
        full = full + ["{dir}/{names[i]}"]
        i = i + 1
    full

# ============================================================================
# Module-level state
# ============================================================================

var sess_dir: text = ""
var sess_registry: text = ""
var sess_req_dir: text = ""
var sess_lock_dir: text = ""

fn sess_setup():
    val pid = rt_getpid()
    val ts = rt_time_now_unix_micros()
    sess_dir = "/tmp/td_session_{pid}_{ts}"
    sess_registry = "{sess_dir}/sessions.sdn"
    sess_req_dir = "{sess_dir}/requests"
    sess_lock_dir = "{sess_dir}/locks"
    rt_dir_create_all(sess_dir)
    rt_dir_create_all(sess_req_dir)
    rt_dir_create_all(sess_lock_dir)

fn sess_cleanup():
    sess_cleanup_dir(sess_req_dir)
    sess_cleanup_dir(sess_lock_dir)
    rt_file_delete(sess_registry)
    rt_file_delete(sess_dir)

fn sess_cleanup_dir(dir: text):
    if not rt_file_exists(dir):
        return
    val files = list_dir_files(dir)
    var i = 0
    while i < files.len():
        rt_file_delete(files[i])
        i = i + 1

# --- Session Registry (file-based) ---

fn sess_register(session_key: text, arch: text, status: text) -> bool:
    val existing = rt_file_read_text(sess_registry) ?? ""
    var parts: [text] = []
    parts.push("[{session_key}]")
    parts.push("arch={arch}")
    parts.push("status={status}")
    parts.push("created={rt_time_now_unix_micros()}")
    val new_entry = parts.join("\n") + "\n\n"
    rt_file_write_text(sess_registry, existing + new_entry)

fn sess_read_registry() -> text:
    rt_file_read_text(sess_registry) ?? ""

fn sess_update_status(session_key: text, new_status: text) -> bool:
    val content = rt_file_read_text(sess_registry) ?? ""
    val lines = content.split("\n")
    var result_parts: [text] = []
    var in_target = false
    var i = 0
    while i < lines.len():
        if lines[i] == "[{session_key}]":
            in_target = true
            result_parts.push(lines[i])
        else:
            if in_target and lines[i].starts_with("status="):
                result_parts.push("status={new_status}")
                in_target = false
            else:
                if lines[i].len() > 0:
                    result_parts.push(lines[i])
                    if not lines[i].starts_with("[") and not lines[i].contains("="):
                        in_target = false
        i = i + 1
    val result = result_parts.join("\n") + "\n"
    rt_file_write_text(sess_registry, result)

fn sess_rewrite_registry_update(session_key: text, new_status: text):
    val content = rt_file_read_text(sess_registry) ?? ""
    val lines = content.split("\n")
    var result_parts: [text] = []
    var found_target = false
    var status_replaced = false
    var i = 0
    while i < lines.len():
        if lines[i] == "[{session_key}]":
            found_target = true
            status_replaced = false
            result_parts.push(lines[i])
        else:
            if found_target and not status_replaced and lines[i].starts_with("status="):
                result_parts.push("status={new_status}")
                status_replaced = true
            else:
                result_parts.push(lines[i])
                if lines[i].starts_with("["):
                    found_target = false
        i = i + 1
    val result = result_parts.join("\n") + "\n"
    rt_file_write_text(sess_registry, result)

# --- Session Lock (per-session exclusive access) ---

fn sess_acquire_lock(session_key: text) -> bool:
    val lock_path = "{sess_lock_dir}/{session_key}.lock"
    if rt_file_exists(lock_path):
        return false
    val pid = rt_getpid()
    val ts = rt_time_now_unix_micros()
    rt_file_write_text(lock_path, "{pid}\n{ts}")

fn sess_release_lock(session_key: text) -> bool:
    val lock_path = "{sess_lock_dir}/{session_key}.lock"
    rt_file_delete(lock_path)

fn sess_is_locked(session_key: text) -> bool:
    val lock_path = "{sess_lock_dir}/{session_key}.lock"
    rt_file_exists(lock_path)

# --- Session Request (agent requests session) ---

fn sess_request_session(agent_id: i64, arch: text, binary_hash: i64) -> text:
    val ts = rt_time_now_unix_micros()
    val req_id = "agent{agent_id}_{ts}"
    val session_key = "{arch}_{binary_hash}"
    var parts: [text] = []
    parts.push("id={req_id}")
    parts.push("agent_id={agent_id}")
    parts.push("session_key={session_key}")
    parts.push("arch={arch}")
    parts.push("binary_hash={binary_hash}")
    parts.push("timestamp={ts}")
    val content = parts.join("\n") + "\n"
    val hash = simple_hash(req_id)
    val path = "{sess_req_dir}/{hash}_{req_id}.sreq"
    rt_file_write_text(path, content)
    req_id

fn sess_read_all_requests() -> [(text, text, text)]:#(req_id, session_key, arch)
    var results: [(text, text, text)] = []
    val files = list_dir_files(sess_req_dir)
    var i = 0
    while i < files.len():
        if files[i].ends_with(".sreq"):
            val content = rt_file_read_text(files[i]) ?? ""
            val id = sess_extract(content, "id=")
            val sk = sess_extract(content, "session_key=")
            val arch = sess_extract(content, "arch=")
            results = results + [(id, sk, arch)]
        i = i + 1
    results

fn sess_extract(content: text, prefix: text) -> text:
    val lines = content.split("\n")
    var i = 0
    while i < lines.len():
        if lines[i].starts_with(prefix):
            return lines[i].substring(prefix.len())
        i = i + 1
    ""

fn sess_count_req_files() -> i64:
    var c: i64 = 0
    val files = list_dir_files(sess_req_dir)
    var i = 0
    while i < files.len():
        if files[i].ends_with(".sreq"):
            c = c + 1
        i = i + 1
    c

fn sess_count_lock_files() -> i64:
    var c: i64 = 0
    val files = list_dir_files(sess_lock_dir)
    var i = 0
    while i < files.len():
        if files[i].ends_with(".lock"):
            c = c + 1
        i = i + 1
    c

fn sess_delete_all_reqs():
    val files = list_dir_files(sess_req_dir)
    var i = 0
    while i < files.len():
        if files[i].ends_with(".sreq"):
            rt_file_delete(files[i])
        i = i + 1

# ============================================================================
# Helper functions (avoid while in it blocks)
# ============================================================================

fn sess_submit_n_agents(n: i64, arch: text, hash: i64) -> [text]:
    var ids: [text] = []
    var i: i64 = 0
    while i < n:
        val id = sess_request_session(i, arch, hash)
        ids = ids + [id]
        i = i + 1
    ids

fn sess_submit_multi_arch_agents() -> [text]:
    var ids: [text] = []
    ids = ids + [sess_request_session(1, "arm64", 100)]
    ids = ids + [sess_request_session(2, "riscv64", 200)]
    ids = ids + [sess_request_session(3, "arm64", 100)]
    ids = ids + [sess_request_session(4, "x86_64", 300)]
    ids = ids + [sess_request_session(5, "arm64", 100)]
    ids

fn sess_register_multi_arch():
    sess_register("arm64_100", "arm64", "idle")
    sess_register("riscv64_200", "riscv64", "idle")
    sess_register("x86_64_300", "x86_64", "idle")

fn sess_verify_registry_contains(content: text, keys: [text]) -> i64:
    var found: i64 = 0
    var i = 0
    while i < keys.len():
        if content.contains(keys[i]):
            found = found + 1
        i = i + 1
    found

fn sess_acquire_and_release_sequence(key: text, n: i64) -> i64:
    var acquired: i64 = 0
    var i: i64 = 0
    while i < n:
        if sess_acquire_lock(key):
            acquired = acquired + 1
            sess_release_lock(key)
        i = i + 1
    acquired

fn sess_lock_contention_test() -> (bool, bool):
    # Agent 1 acquires
    val got1 = sess_acquire_lock("arm64_100")
    # Agent 2 tries to acquire same session
    val got2 = sess_acquire_lock("arm64_100")
    # Agent 1 releases
    sess_release_lock("arm64_100")
    (got1, got2)

fn sess_multi_lock_test() -> i64:
    sess_acquire_lock("arm64_100")
    sess_acquire_lock("riscv64_200")
    sess_acquire_lock("x86_64_300")
    sess_count_lock_files()

fn sess_release_multi_locks():
    sess_release_lock("arm64_100")
    sess_release_lock("riscv64_200")
    sess_release_lock("x86_64_300")

# ============================================================================
# Tests
# ============================================================================

describe "Session Sharing System":
    describe "session registry":
        it "registers and reads sessions":
            sess_setup()
            sess_register("arm64_100", "arm64", "idle")
            val content = sess_read_registry()
            expect(content).to_contain("[arm64_100]")
            expect(content).to_contain("arch=arm64")
            expect(content).to_contain("status=idle")
            sess_cleanup()

        it "registers multiple sessions":
            sess_setup()
            sess_register_multi_arch()
            val content = sess_read_registry()
            val keys = ["arm64_100", "riscv64_200", "x86_64_300"]
            val found = sess_verify_registry_contains(content, keys)
            expect(found).to_equal(3)
            sess_cleanup()

        it "updates session status":
            sess_setup()
            sess_register("arm64_100", "arm64", "idle")
            sess_rewrite_registry_update("arm64_100", "in_use")
            val content = sess_read_registry()
            expect(content).to_contain("status=in_use")
            sess_cleanup()

    describe "session locking":
        it "acquires lock for session":
            sess_setup()
            expect(sess_acquire_lock("arm64_100")).to_equal(true)
            expect(sess_is_locked("arm64_100")).to_equal(true)
            sess_cleanup()

        it "prevents double acquisition":
            sess_setup()
            val result = sess_lock_contention_test()
            expect(result[0]).to_equal(true)
            expect(result[1]).to_equal(false)
            sess_cleanup()

        it "releases lock":
            sess_setup()
            sess_acquire_lock("arm64_100")
            sess_release_lock("arm64_100")
            expect(sess_is_locked("arm64_100")).to_equal(false)
            sess_cleanup()

        it "acquires multiple session locks":
            sess_setup()
            val count = sess_multi_lock_test()
            expect(count).to_equal(3)
            sess_release_multi_locks()
            expect(sess_count_lock_files()).to_equal(0)
            sess_cleanup()

        it "sequential acquire-release cycles":
            sess_setup()
            val acquired = sess_acquire_and_release_sequence("arm64_100", 10)
            expect(acquired).to_equal(10)
            sess_cleanup()

    describe "session requests via IPC":
        it "agent submits session request":
            sess_setup()
            val id = sess_request_session(1, "arm64", 100)
            expect(sess_count_req_files()).to_equal(1)
            val reqs = sess_read_all_requests()
            expect(reqs.len()).to_equal(1)
            expect(reqs[0][0]).to_equal(id)
            expect(reqs[0][1]).to_equal("arm64_100")
            sess_cleanup()

        it "multiple agents request same session":
            sess_setup()
            val ids = sess_submit_n_agents(5, "arm64", 100)
            expect(sess_count_req_files()).to_equal(5)
            val reqs = sess_read_all_requests()
            expect(reqs.len()).to_equal(5)
            sess_cleanup()

        it "agents request different architectures":
            sess_setup()
            val ids = sess_submit_multi_arch_agents()
            expect(sess_count_req_files()).to_equal(5)
            val reqs = sess_read_all_requests()
            expect(reqs.len()).to_equal(5)
            sess_cleanup()

        it "cleans up processed requests":
            sess_setup()
            sess_submit_n_agents(3, "arm64", 100)
            expect(sess_count_req_files()).to_equal(3)
            sess_delete_all_reqs()
            expect(sess_count_req_files()).to_equal(0)
            sess_cleanup()

    describe "session sharing workflow":
        it "register, lock, use, release, unlock":
            sess_setup()
            # 1. Register session
            sess_register("arm64_100", "arm64", "idle")
            # 2. Agent acquires lock
            expect(sess_acquire_lock("arm64_100")).to_equal(true)
            # 3. Update status to in_use
            sess_rewrite_registry_update("arm64_100", "in_use")
            val content1 = sess_read_registry()
            expect(content1).to_contain("status=in_use")
            # 4. Release lock and mark idle
            sess_release_lock("arm64_100")
            sess_rewrite_registry_update("arm64_100", "idle")
            val content2 = sess_read_registry()
            expect(content2).to_contain("status=idle")
            sess_cleanup()

        it "second agent waits for locked session":
            sess_setup()
            sess_register("arm64_100", "arm64", "idle")
            # Agent 1 locks
            expect(sess_acquire_lock("arm64_100")).to_equal(true)
            # Agent 2 cannot acquire
            expect(sess_acquire_lock("arm64_100")).to_equal(false)
            # Agent 1 releases
            sess_release_lock("arm64_100")
            # Now agent 2 can acquire
            expect(sess_acquire_lock("arm64_100")).to_equal(true)
            sess_release_lock("arm64_100")
            sess_cleanup()

    describe "concurrent multi-arch sessions":
        it "different archs can be used simultaneously":
            sess_setup()
            sess_register_multi_arch()
            expect(sess_acquire_lock("arm64_100")).to_equal(true)
            expect(sess_acquire_lock("riscv64_200")).to_equal(true)
            expect(sess_acquire_lock("x86_64_300")).to_equal(true)
            expect(sess_count_lock_files()).to_equal(3)
            sess_release_multi_locks()
            sess_cleanup()

        it "same arch different binary uses separate sessions":
            sess_setup()
            sess_register("arm64_100", "arm64", "idle")
            sess_register("arm64_200", "arm64", "idle")
            expect(sess_acquire_lock("arm64_100")).to_equal(true)
            expect(sess_acquire_lock("arm64_200")).to_equal(true)
            expect(sess_count_lock_files()).to_equal(2)
            sess_release_lock("arm64_100")
            sess_release_lock("arm64_200")
            sess_cleanup()
