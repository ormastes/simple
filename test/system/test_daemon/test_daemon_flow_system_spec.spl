# Test Daemon End-to-End Flow System Test
#
# Tests the complete request flow: submit → daemon reads → process →
# respond → client reads. Verifies the full IPC cycle works with
# real filesystem operations.
#
# **Feature IDs:** #TDMN-SYS-031 to #TDMN-SYS-040
# **Category:** Infrastructure / System Test

extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_delete(path: text) -> bool
extern fn rt_dir_create_all(path: text) -> bool
extern fn rt_dir_list(path: text) -> [text]
extern fn rt_getpid() -> i64
extern fn rt_time_now_unix_micros() -> i64

fn simple_hash(s: text) -> i64:
    val bs = s.bytes()
    var h: i64 = 5381
    var i = 0
    while i < bs.len():
        h = h * 33 + bs[i]
        i = i + 1
    if h < 0:
        h = 0 - h
    h

fn list_dir_files(dir: text) -> [text]:
    val names = rt_dir_list(dir) ?? []
    var full: [text] = []
    var i = 0
    while i < names.len():
        full = full + ["{dir}/{names[i]}"]
        i = i + 1
    full

# ============================================================================
# Module-level state
# ============================================================================

var flow_dir: text = ""
var flow_req_dir: text = ""
var flow_resp_dir: text = ""
var flow_lock_path: text = ""

fn flow_setup():
    val pid = rt_getpid()
    val ts = rt_time_now_unix_micros()
    flow_dir = "/tmp/td_flow_{pid}_{ts}"
    flow_req_dir = "{flow_dir}/requests"
    flow_resp_dir = "{flow_dir}/responses"
    flow_lock_path = "{flow_dir}/daemon.lock"
    rt_dir_create_all(flow_dir)
    rt_dir_create_all(flow_req_dir)
    rt_dir_create_all(flow_resp_dir)

fn flow_cleanup():
    flow_cleanup_dir(flow_req_dir)
    flow_cleanup_dir(flow_resp_dir)
    rt_file_delete(flow_lock_path)
    rt_file_delete(flow_dir)

fn flow_cleanup_dir(dir: text):
    if not rt_file_exists(dir):
        return
    val files = list_dir_files(dir)
    var i = 0
    while i < files.len():
        rt_file_delete(files[i])
        i = i + 1

# --- Client side ---

fn client_write_lock():
    val pid = rt_getpid()
    val ts = rt_time_now_unix_micros()
    rt_file_write_text(flow_lock_path, "{pid}\n{ts}")

fn client_submit_request(kind: i64, test_path: text) -> text:
    val pid = rt_getpid()
    val ts = rt_time_now_unix_micros()
    val req_id = "{pid}_{ts}"
    var parts: [text] = []
    parts.push("id={req_id}")
    parts.push("kind={kind}")
    parts.push("timestamp={ts}")
    parts.push("field.test_path={test_path}")
    val content = parts.join("\n") + "\n"
    val hash = simple_hash(req_id)
    val path = "{flow_req_dir}/{hash}_{req_id}.req"
    rt_file_write_text(path, content)
    req_id

fn client_check_response(req_id: text) -> bool:
    val path = "{flow_resp_dir}/{req_id}.resp"
    rt_file_exists(path)

fn client_read_response(req_id: text) -> (i64, text, text):
    val path = "{flow_resp_dir}/{req_id}.resp"
    if not rt_file_exists(path):
        return (-1, "", "")
    val content = rt_file_read_text(path) ?? ""
    val status = (flow_extract(content, "status=")).to_i64() ?? -1
    val test_path = flow_extract(content, "field.test_path=")
    val output = flow_extract(content, "field.output=")
    (status, test_path, output)

# --- Daemon side ---

fn daemon_read_requests() -> [(text, i64, text)]:
    var results: [(text, i64, text)] = []
    val files = list_dir_files(flow_req_dir)
    var i = 0
    while i < files.len():
        val path = files[i]
        if path.ends_with(".req"):
            val content = rt_file_read_text(path) ?? ""
            val id = flow_extract(content, "id=")
            val kind = (flow_extract(content, "kind=")).to_i64() ?? 0
            val test_path = flow_extract(content, "field.test_path=")
            results = results + [(id, kind, test_path)]
        i = i + 1
    results

fn daemon_process_and_respond(req_id: text, test_path: text, passed: i64, failed: i64):
    var parts: [text] = []
    parts.push("request_id={req_id}")
    parts.push("status=2")
    parts.push("timestamp={rt_time_now_unix_micros()}")
    parts.push("field.test_path={test_path}")
    parts.push("field.passed={passed}")
    parts.push("field.failed={failed}")
    parts.push("field.output=Tests completed")
    val content = parts.join("\n") + "\n"
    val path = "{flow_resp_dir}/{req_id}.resp"
    rt_file_write_text(path, content)

fn daemon_cleanup_requests():
    val files = list_dir_files(flow_req_dir)
    var i = 0
    while i < files.len():
        if files[i].ends_with(".req"):
            rt_file_delete(files[i])
        i = i + 1

fn flow_extract(content: text, prefix: text) -> text:
    val lines = content.split("\n")
    var i = 0
    while i < lines.len():
        if lines[i].starts_with(prefix):
            return lines[i].substring(prefix.len())
        i = i + 1
    ""

fn flow_req_count() -> i64:
    var c: i64 = 0
    val files = list_dir_files(flow_req_dir)
    var i = 0
    while i < files.len():
        if files[i].ends_with(".req"):
            c = c + 1
        i = i + 1
    c

fn flow_resp_count() -> i64:
    var c: i64 = 0
    val files = list_dir_files(flow_resp_dir)
    var i = 0
    while i < files.len():
        if files[i].ends_with(".resp"):
            c = c + 1
        i = i + 1
    c

# ============================================================================
# Helper functions (extracted from it blocks to avoid closure mutation bugs)
# ============================================================================

fn flow_process_all_requests(reqs: [(text, i64, text)]):
    var i = 0
    while i < reqs.len():
        daemon_process_and_respond(reqs[i][0], reqs[i][2], 5, 0)
        i = i + 1

fn flow_submit_n_agents(n: i64) -> [text]:
    var agent_ids: [text] = []
    var a: i64 = 0
    while a < n:
        val id = client_submit_request(1, "test/agent{a}_spec.spl")
        agent_ids = agent_ids + [id]
        a = a + 1
    agent_ids

fn flow_process_reqs_with_offset(reqs: [(text, i64, text)]):
    var d = 0
    while d < reqs.len():
        daemon_process_and_respond(reqs[d][0], reqs[d][2], 10 + d, 0)
        d = d + 1

fn flow_verify_all_responses(agent_ids: [text], n: i64):
    var c = 0
    while c < n:
        expect(client_check_response(agent_ids[c])).to_equal(true)
        val resp = client_read_response(agent_ids[c])
        expect(resp[0]).to_equal(2)
        c = c + 1

# ============================================================================
# Tests
# ============================================================================

describe "TestDaemon Flow":
    describe "single request lifecycle":
        it "completes full submit-process-respond cycle":
            flow_setup()
            client_write_lock()
            # 1. Client submits
            val req_id = client_submit_request(1, "test/flow_spec.spl")
            expect(flow_req_count()).to_equal(1)
            # 2. Daemon reads
            val reqs = daemon_read_requests()
            expect(reqs.len()).to_equal(1)
            expect(reqs[0][0]).to_equal(req_id)
            expect(reqs[0][2]).to_equal("test/flow_spec.spl")
            # 3. Daemon processes and responds
            daemon_process_and_respond(req_id, "test/flow_spec.spl", 10, 0)
            daemon_cleanup_requests()
            expect(flow_req_count()).to_equal(0)
            expect(flow_resp_count()).to_equal(1)
            # 4. Client reads response
            expect(client_check_response(req_id)).to_equal(true)
            val resp = client_read_response(req_id)
            expect(resp[0]).to_equal(2)
            expect(resp[1]).to_equal("test/flow_spec.spl")
            expect(resp[2]).to_equal("Tests completed")
            flow_cleanup()

    describe "batch processing":
        it "processes 3 requests in one poll cycle":
            flow_setup()
            client_write_lock()
            val id1 = client_submit_request(1, "test/a_spec.spl")
            val id2 = client_submit_request(1, "test/b_spec.spl")
            val id3 = client_submit_request(1, "test/c_spec.spl")
            # Daemon reads all
            val reqs = daemon_read_requests()
            expect(reqs.len()).to_equal(3)
            # Daemon processes all
            flow_process_all_requests(reqs)
            daemon_cleanup_requests()
            # All clients get responses
            expect(client_check_response(id1)).to_equal(true)
            expect(client_check_response(id2)).to_equal(true)
            expect(client_check_response(id3)).to_equal(true)
            flow_cleanup()

    describe "multi-cycle processing":
        it "processes requests across multiple poll cycles":
            flow_setup()
            client_write_lock()
            # Cycle 1
            val id1 = client_submit_request(1, "test/cycle1_spec.spl")
            val reqs1 = daemon_read_requests()
            daemon_process_and_respond(reqs1[0][0], reqs1[0][2], 3, 0)
            daemon_cleanup_requests()
            # Cycle 2
            val id2 = client_submit_request(1, "test/cycle2_spec.spl")
            val reqs2 = daemon_read_requests()
            daemon_process_and_respond(reqs2[0][0], reqs2[0][2], 7, 1)
            daemon_cleanup_requests()
            # Both responses exist
            val r1 = client_read_response(id1)
            val r2 = client_read_response(id2)
            expect(r1[0]).to_equal(2)
            expect(r2[0]).to_equal(2)
            flow_cleanup()

    describe "error handling":
        it "client gets empty for missing response":
            flow_setup()
            val resp = client_read_response("nonexistent_id")
            expect(resp[0]).to_equal(-1)
            expect(resp[1]).to_equal("")
            flow_cleanup()

        it "daemon handles empty request directory":
            flow_setup()
            val reqs = daemon_read_requests()
            expect(reqs.len()).to_equal(0)
            flow_cleanup()

    describe "isolation":
        it "requests and responses use separate directories":
            flow_setup()
            val id = client_submit_request(1, "test/iso_spec.spl")
            expect(flow_req_count()).to_equal(1)
            expect(flow_resp_count()).to_equal(0)
            daemon_process_and_respond(id, "test/iso_spec.spl", 1, 0)
            expect(flow_resp_count()).to_equal(1)
            flow_cleanup()

    describe "concurrent agents flow":
        it "5 agents submit, daemon batch processes, all get results":
            flow_setup()
            client_write_lock()
            # 5 agents submit concurrently
            val agent_ids = flow_submit_n_agents(5)
            expect(flow_req_count()).to_equal(5)
            # Daemon reads all
            val reqs = daemon_read_requests()
            expect(reqs.len()).to_equal(5)
            # Daemon processes all
            flow_process_reqs_with_offset(reqs)
            daemon_cleanup_requests()
            # All 5 agents get responses
            flow_verify_all_responses(agent_ids, 5)
            flow_cleanup()
