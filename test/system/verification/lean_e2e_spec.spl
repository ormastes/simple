# @cover src/compiler_rust/lib/std/src/verification/lean/codegen.spl 60%
"""
# Lean Verification End-to-End Specification

**Feature IDs:** #LEAN-E2E-001
**Category:** Verification
**Difficulty:** 3/5
**Status:** In Progress

## Overview

End-to-end tests that exercise the full Lean verification workflow:
generation pipeline, state model, proof unit tracking, cache integration,
and reporting. Each test group maps to one golden example capability.
"""

use std.spec.{describe, it, expect, context}
use verification.state.{VerificationState, aggregate_states, StateCounts}
use verification.proof_unit.{ProofUnit, ProofUnitSet}
use verification.lean.codegen.{LeanCodegen, LeanCodegenOptions, LeanFunction, LeanTheorem}
use verification.report.{VerificationReport, ReportLevel}
use verification.cache.{VerificationCache}
use verification.fingerprint.{Fingerprint}

# ============================================================================
# Test Group 1: Generation Pipeline
# ============================================================================

describe "Lean Verification E2E":
    describe "Generation Pipeline":
        it "generates Lean from @verify function":
            # Create codegen, add a function + theorem, emit
            var codegen = LeanCodegen.create("BasicTheorem")
            var func = LeanFunction.new("abs")
            func = func.add_param("x", "Int")
            func = func.with_return_type("Int")
            func = func.with_body("if x < 0 then -x else x")
            codegen = codegen.add_function(func)

            var thm = LeanTheorem.new("abs_post_0", "abs x >= 0")
            thm = thm.add_param("x", "Int")
            codegen = codegen.add_theorem(thm)

            val output = codegen.generate()
            expect(output).to_contain("theorem abs_post_0")
            expect(output).to_contain("def abs")
            expect(output).to_contain("Int")

        it "generates deterministic output":
            # Same input twice -> identical output
            val output1 = build_sample_codegen().generate()
            val output2 = build_sample_codegen().generate()
            expect(output1).to_equal(output2)

    # ========================================================================
    # Test Group 2: State Model
    # ========================================================================

    describe "State Model":
        it "computes correct aggregate state":
            # Mix of Verified + Admitted -> Admitted
            val states = [VerificationState.Verified, VerificationState.Admitted]
            val agg = aggregate_states(states)
            expect(agg).to_equal(VerificationState.Admitted)

        it "Verified requires no debt":
            # All proven -> Verified
            val states = [VerificationState.Verified, VerificationState.Verified]
            val agg = aggregate_states(states)
            expect(agg).to_equal(VerificationState.Verified)

        it "Failed overrides admitted":
            # Mix with failed -> Failed
            val states = [
                VerificationState.Verified,
                VerificationState.Admitted,
                VerificationState.Failed
            ]
            val agg = aggregate_states(states)
            expect(agg).to_equal(VerificationState.Failed)

        it "empty list returns NotChecked":
            val states: List<VerificationState> = []
            val agg = aggregate_states(states)
            expect(agg).to_equal(VerificationState.NotChecked)

        it "state display strings are correct":
            expect(VerificationState.Verified.to_display()).to_equal("Verified")
            expect(VerificationState.Failed.to_display()).to_equal("FAILED")
            expect(VerificationState.Admitted.to_display()).to_equal("Admitted (sorry)")

        it "has_debt is true for Admitted and Trusted":
            expect(VerificationState.Admitted.has_debt()).to_equal(true)
            expect(VerificationState.Trusted.has_debt()).to_equal(true)
            expect(VerificationState.Verified.has_debt()).to_equal(false)
            expect(VerificationState.Failed.has_debt()).to_equal(false)

    # ========================================================================
    # Test Group 3: Proof Unit Tracking
    # ========================================================================

    describe "Proof Unit Tracking":
        it "creates proof unit with NotChecked default":
            val unit = ProofUnit.create(
                "examples/lean_verification/basic_theorem.spl",
                "abs",
                "Verification.Abs",
                "Verification/Abs.lean"
            )
            expect(unit.state).to_equal(VerificationState.NotChecked)
            expect(unit.obligations.len()).to_equal(0)
            expect(unit.admitted_count).to_equal(0)

        it "marks dependents stale on change":
            var units = ProofUnitSet.empty()

            # Unit A depends on "base_module"
            var u_a = ProofUnit.create("a.spl", "fn_a", "V.A", "V/A.lean")
            u_a = u_a.with_state(VerificationState.Verified)
            u_a = u_a.with_dependencies(["base_module"])
            units = units.add(u_a)

            # Unit B has no dependencies
            var u_b = ProofUnit.create("b.spl", "fn_b", "V.B", "V/B.lean")
            u_b = u_b.with_state(VerificationState.Verified)
            units = units.add(u_b)

            # Invalidate base_module
            units = units.invalidate_dependents("base_module")

            # A should be stale, B should remain Verified
            val a_result = units.find_by_source("a.spl")
            val b_result = units.find_by_source("b.spl")
            match a_result:
                case Some(a):
                    expect(a.state).to_equal(VerificationState.Stale)
                case nil:
                    expect(false).to_equal(true)
            match b_result:
                case Some(b):
                    expect(b.state).to_equal(VerificationState.Verified)
                case nil:
                    expect(false).to_equal(true)

        it "computes aggregate state from unit set":
            var units = ProofUnitSet.empty()
            var u1 = ProofUnit.create("x.spl", "*", "V.X", "V/X.lean")
            u1 = u1.with_state(VerificationState.Verified)
            units = units.add(u1)
            var u2 = ProofUnit.create("y.spl", "*", "V.Y", "V/Y.lean")
            u2 = u2.with_state(VerificationState.Admitted)
            units = units.add(u2)
            expect(units.aggregate_state()).to_equal(VerificationState.Admitted)

        it "filters units by state":
            var units = ProofUnitSet.empty()
            var u1 = ProofUnit.create("v.spl", "*", "V.V", "V/V.lean")
            u1 = u1.with_state(VerificationState.Verified)
            units = units.add(u1)
            var u2 = ProofUnit.create("f.spl", "*", "V.F", "V/F.lean")
            u2 = u2.with_state(VerificationState.Failed)
            units = units.add(u2)
            var u3 = ProofUnit.create("v2.spl", "*", "V.V2", "V/V2.lean")
            u3 = u3.with_state(VerificationState.Verified)
            units = units.add(u3)
            val verified = units.filter_by_state(VerificationState.Verified)
            expect(verified.len()).to_equal(2)
            val failed = units.filter_by_state(VerificationState.Failed)
            expect(failed.len()).to_equal(1)

    # ========================================================================
    # Test Group 4: Cache Integration
    # ========================================================================

    describe "Cache Integration":
        it "caches and retrieves verification results":
            var cache = VerificationCache.new("/tmp/lean-e2e-cache-hit")
            val fp = Fingerprint.from_hashes("src_abs", "lean_abs", [], "v4.x")
            cache.store("basic_theorem.spl", fp, VerificationState.Verified, {}, "v4.x")

            val result = cache.lookup("basic_theorem.spl", fp)
            match result:
                case Some(entry):
                    expect(entry.state).to_equal(VerificationState.Verified)
                    expect(entry.fingerprint).to_equal(fp.combined)
                case nil:
                    expect(false).to_equal(true)

        it "returns nil on fingerprint mismatch":
            var cache = VerificationCache.new("/tmp/lean-e2e-cache-miss")
            val fp_old = Fingerprint.from_hashes("src_v1", "lean_v1", [], "v4.x")
            cache.store("contract_verify.spl", fp_old, VerificationState.Verified, {}, "v4.x")

            # Simulate source change
            val fp_new = Fingerprint.from_hashes("src_v2_changed", "lean_v1", [], "v4.x")
            val result = cache.lookup("contract_verify.spl", fp_new)
            expect(result).to_be_nil()

        it "tracks hit and miss counts":
            var cache = VerificationCache.new("/tmp/lean-e2e-cache-stats")
            val fp = Fingerprint.from_hashes("s", "l", [], "v4.x")
            cache.store("a.spl", fp, VerificationState.Verified, {}, "v4.x")

            # 1 hit
            cache.lookup("a.spl", fp)
            # 1 miss
            cache.lookup("nonexistent.spl", fp)

            val stats = cache.stats()
            expect(stats.hits).to_equal(1)
            expect(stats.misses).to_equal(1)

    # ========================================================================
    # Test Group 5: Reporting
    # ========================================================================

    describe "Reporting":
        it "generates project summary":
            val units = build_e2e_unit_set()
            val report = VerificationReport.from_units(
                "E2E Report", "project", units, "2026-04-04T00:00:00Z"
            )
            val output = report.render(ReportLevel.Project)
            expect(output).to_contain("Lean Verification:")
            expect(output).to_contain("verified")
            expect(output).to_contain("proof units")

        it "renders file-level breakdown":
            val units = build_e2e_unit_set()
            val report = VerificationReport.from_units(
                "E2E File Report", "project", units, "2026-04-04T00:00:00Z"
            )
            val output = report.render(ReportLevel.File)
            expect(output).to_contain("Files:")
            expect(output).to_contain("basic_theorem.spl")
            expect(output).to_contain("admitted_debt.spl")
            expect(output).to_contain("failed_proof.spl")

        it "admitted never renders as verified":
            # Unit with Admitted state, verify output says "Admitted" not "Verified"
            var units = ProofUnitSet.empty()
            var u = ProofUnit.create(
                "admitted_debt.spl", "complex_algorithm",
                "Verification.Admitted", "Verification/Admitted.lean"
            )
            u = u.with_state(VerificationState.Admitted)
            u = u.with_debt(1, 0)
            u = u.with_obligations(["thm_admitted_post"])
            units = units.add(u)

            val report = VerificationReport.from_units(
                "Admitted Check", "project", units, "2026-04-04T00:00:00Z"
            )

            # Check Project level
            val project_output = report.render(ReportLevel.Project)
            expect(project_output).to_contain("admitted")

            # Check File level
            val file_output = report.render(ReportLevel.File)
            expect(file_output).to_contain("Admitted (sorry)")

            # Check Symbol level
            val sym_output = report.render(ReportLevel.Symbol)
            expect(sym_output).to_contain("Admitted (sorry)")

        it "state counts are accurate":
            val units = build_e2e_unit_set()
            val counts = units.state_counts()
            expect(counts.verified).to_equal(2)
            expect(counts.failed).to_equal(1)
            expect(counts.admitted).to_equal(1)
            expect(counts.total()).to_equal(4)

# ============================================================================
# Helper functions
# ============================================================================

fn build_sample_codegen() -> LeanCodegen:
    var codegen = LeanCodegen.create("Deterministic")
    var func = LeanFunction.new("safe_divide")
    func = func.add_param("a", "Int")
    func = func.add_param("b", "Int")
    func = func.with_return_type("Int")
    func = func.with_body("a / b")
    codegen = codegen.add_function(func)

    var thm = LeanTheorem.new("safe_divide_pre_0", "b != 0")
    thm = thm.add_param("a", "Int")
    thm = thm.add_param("b", "Int")
    codegen = codegen.add_theorem(thm)
    codegen

fn build_e2e_unit_set() -> ProofUnitSet:
    var units = ProofUnitSet.empty()

    # Verified: basic_theorem.spl
    var u1 = ProofUnit.create(
        "basic_theorem.spl", "abs",
        "Verification.Abs", "Verification/Abs.lean"
    )
    u1 = u1.with_state(VerificationState.Verified)
    u1 = u1.with_obligations(["abs_post_0"])
    units = units.add(u1)

    # Verified: contract_verify.spl
    var u2 = ProofUnit.create(
        "contract_verify.spl", "safe_divide",
        "Verification.SafeDivide", "Verification/SafeDivide.lean"
    )
    u2 = u2.with_state(VerificationState.Verified)
    u2 = u2.with_obligations(["safe_divide_pre_0", "safe_divide_post_0"])
    units = units.add(u2)

    # Admitted: admitted_debt.spl
    var u3 = ProofUnit.create(
        "admitted_debt.spl", "complex_algorithm",
        "Verification.Admitted", "Verification/Admitted.lean"
    )
    u3 = u3.with_state(VerificationState.Admitted)
    u3 = u3.with_obligations(["complex_algorithm_post_0"])
    u3 = u3.with_debt(1, 0)
    units = units.add(u3)

    # Failed: failed_proof.spl
    var u4 = ProofUnit.create(
        "failed_proof.spl", "buggy_abs",
        "Verification.BuggyAbs", "Verification/BuggyAbs.lean"
    )
    u4 = u4.with_state(VerificationState.Failed)
    u4 = u4.with_obligations(["buggy_abs_post_0"])
    units = units.add(u4)

    units
