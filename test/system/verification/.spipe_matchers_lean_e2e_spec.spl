# @tag:system
#
# Portable smoke for Lean verification E2E.

use std.spec.*

describe "Lean verification portable smoke":
    it "records proof generation stages":
        val stages = ["fingerprint", "cache", "emit", "check"]
        expect stages.len() == 4
        expect stages[0] == "fingerprint"

    it "records Lean output extension":
        val path = "build/verification/proof.lean"
        expect (path).ends_with(".lean")