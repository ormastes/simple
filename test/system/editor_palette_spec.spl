# editor_palette_spec
#
# Phase 4: Command palette service with fuzzy matching.
# Verifies palette structs, state functions, fuzzy match/score,
# and editor_all_commands registry.

use std.spec

extern fn rt_file_read_text(path: text) -> text

fn read_text(path: text) -> text:
    rt_file_read_text(path) ?? ""

describe "command palette — PaletteEntry struct":

    it "defines PaletteEntry with name, description, command_name, command_payload":
        val src = read_text("src/lib/editor/60.services/command_palette.spl")
        expect(src.contains("struct PaletteEntry:")).to_equal(true)
        expect(src.contains("name: text")).to_equal(true)
        expect(src.contains("description: text")).to_equal(true)
        expect(src.contains("command_name: text")).to_equal(true)
        expect(src.contains("command_payload: text")).to_equal(true)

describe "command palette — PaletteState struct":

    it "defines PaletteState with all_entries, filtered, query, selected_index, visible":
        val src = read_text("src/lib/editor/60.services/command_palette.spl")
        expect(src.contains("struct PaletteState:")).to_equal(true)
        expect(src.contains("all_entries: [PaletteEntry]")).to_equal(true)
        expect(src.contains("filtered: [PaletteEntry]")).to_equal(true)
        expect(src.contains("query: text")).to_equal(true)
        expect(src.contains("selected_index: i64")).to_equal(true)
        expect(src.contains("visible: bool")).to_equal(true)

describe "command palette — palette_new":

    it "defines palette_new function accepting entries":
        val src = read_text("src/lib/editor/60.services/command_palette.spl")
        expect(src.contains("fn palette_new(entries: [PaletteEntry]) -> PaletteState")).to_equal(true)

    it "initializes visible to false and selected_index to 0":
        val src = read_text("src/lib/editor/60.services/command_palette.spl")
        expect(src.contains("visible: false")).to_equal(true)
        expect(src.contains("selected_index: 0")).to_equal(true)

describe "command palette — show and hide":

    it "defines palette_show that sets visible true and resets query":
        val src = read_text("src/lib/editor/60.services/command_palette.spl")
        expect(src.contains("fn palette_show(state: PaletteState) -> PaletteState")).to_equal(true)
        expect(src.contains("visible: true")).to_equal(true)

    it "defines palette_hide that sets visible false":
        val src = read_text("src/lib/editor/60.services/command_palette.spl")
        expect(src.contains("fn palette_hide(state: PaletteState) -> PaletteState")).to_equal(true)

describe "command palette — query update":

    it "defines palette_update_query with query parameter":
        val src = read_text("src/lib/editor/60.services/command_palette.spl")
        expect(src.contains("fn palette_update_query(state: PaletteState, query: text) -> PaletteState")).to_equal(true)

    it "calls fuzzy_match to filter entries":
        val src = read_text("src/lib/editor/60.services/command_palette.spl")
        expect(src.contains("fuzzy_match(query, entry.name)")).to_equal(true)

    it "calls fuzzy_score to rank results":
        val src = read_text("src/lib/editor/60.services/command_palette.spl")
        expect(src.contains("fuzzy_score(query, entry.name)")).to_equal(true)

    it "resets selected_index to 0 on query change":
        val src = read_text("src/lib/editor/60.services/command_palette.spl")
        expect(src.contains("selected_index: 0")).to_equal(true)

describe "command palette — selection navigation":

    it "defines palette_select_next":
        val src = read_text("src/lib/editor/60.services/command_palette.spl")
        expect(src.contains("fn palette_select_next(state: PaletteState) -> PaletteState")).to_equal(true)

    it "defines palette_select_prev":
        val src = read_text("src/lib/editor/60.services/command_palette.spl")
        expect(src.contains("fn palette_select_prev(state: PaletteState) -> PaletteState")).to_equal(true)

    it "clamps select_next to filtered length minus 1":
        val src = read_text("src/lib/editor/60.services/command_palette.spl")
        expect(src.contains("idx > max_idx")).to_equal(true)
        expect(src.contains("idx = max_idx")).to_equal(true)

    it "clamps select_prev to 0":
        val src = read_text("src/lib/editor/60.services/command_palette.spl")
        expect(src.contains("idx < 0")).to_equal(true)
        expect(src.contains("idx = 0")).to_equal(true)

describe "command palette — palette_selected":

    it "defines palette_selected returning PaletteEntry":
        val src = read_text("src/lib/editor/60.services/command_palette.spl")
        expect(src.contains("fn palette_selected(state: PaletteState) -> PaletteEntry")).to_equal(true)

    it "returns empty entry when filtered is empty":
        val src = read_text("src/lib/editor/60.services/command_palette.spl")
        expect(src.contains("state.filtered.len() == 0")).to_equal(true)
        expect(src.contains("name: \"\"")).to_equal(true)

describe "command palette — fuzzy_match":

    it "defines fuzzy_match with query and candidate":
        val src = read_text("src/lib/editor/60.services/command_palette.spl")
        expect(src.contains("fn fuzzy_match(query: text, candidate: text) -> bool")).to_equal(true)

    it "returns true for empty query":
        val src = read_text("src/lib/editor/60.services/command_palette.spl")
        expect(src.contains("query.len() == 0")).to_equal(true)
        expect(src.contains("return true")).to_equal(true)

    it "performs case insensitive comparison via lower":
        val src = read_text("src/lib/editor/60.services/command_palette.spl")
        expect(src.contains("query.lower()")).to_equal(true)
        expect(src.contains("candidate.lower()")).to_equal(true)

    it "uses char_at for character-by-character subsequence matching":
        val src = read_text("src/lib/editor/60.services/command_palette.spl")
        expect(src.contains("q.char_at(qi)")).to_equal(true)
        expect(src.contains("c.char_at(ci)")).to_equal(true)
        expect(src.contains("qch == cch")).to_equal(true)

describe "command palette — fuzzy_score":

    it "defines fuzzy_score returning i64":
        val src = read_text("src/lib/editor/60.services/command_palette.spl")
        expect(src.contains("fn fuzzy_score(query: text, candidate: text) -> i64")).to_equal(true)

    it "returns 0 for empty query":
        val src = read_text("src/lib/editor/60.services/command_palette.spl")
        expect(src.contains("return 0")).to_equal(true)

    it "returns 9999 when no match":
        val src = read_text("src/lib/editor/60.services/command_palette.spl")
        expect(src.contains("return 9999")).to_equal(true)

    it "computes gap-based score":
        val src = read_text("src/lib/editor/60.services/command_palette.spl")
        expect(src.contains("gap = ci - last_match_pos - 1")).to_equal(true)
        expect(src.contains("score = score + gap")).to_equal(true)

describe "command palette — editor_all_commands":

    it "defines editor_all_commands returning PaletteEntry list":
        val src = read_text("src/app/editor/commands.spl")
        expect(src.contains("fn editor_all_commands() -> [PaletteEntry]")).to_equal(true)

    it "includes Open File command":
        val src = read_text("src/app/editor/commands.spl")
        expect(src.contains("name: \"Open File\"")).to_equal(true)
        expect(src.contains("command_name: \"open-file\"")).to_equal(true)

    it "includes Save and Save As commands":
        val src = read_text("src/app/editor/commands.spl")
        expect(src.contains("name: \"Save\"")).to_equal(true)
        expect(src.contains("name: \"Save As\"")).to_equal(true)

    it "includes Quit command":
        val src = read_text("src/app/editor/commands.spl")
        expect(src.contains("name: \"Quit\"")).to_equal(true)
        expect(src.contains("command_name: \"quit\"")).to_equal(true)

    it "includes Tab navigation commands":
        val src = read_text("src/app/editor/commands.spl")
        expect(src.contains("name: \"Tab Next\"")).to_equal(true)
        expect(src.contains("name: \"Tab Prev\"")).to_equal(true)
        expect(src.contains("name: \"Tab Close\"")).to_equal(true)

    it "includes Split command":
        val src = read_text("src/app/editor/commands.spl")
        expect(src.contains("name: \"Split\"")).to_equal(true)
        expect(src.contains("command_name: \"split\"")).to_equal(true)

    it "includes Undo and Redo commands":
        val src = read_text("src/app/editor/commands.spl")
        expect(src.contains("name: \"Undo\"")).to_equal(true)
        expect(src.contains("name: \"Redo\"")).to_equal(true)

    it "includes movement commands":
        val src = read_text("src/app/editor/commands.spl")
        expect(src.contains("name: \"Go to Top\"")).to_equal(true)
        expect(src.contains("name: \"Go to Bottom\"")).to_equal(true)
        expect(src.contains("name: \"Line Start\"")).to_equal(true)
        expect(src.contains("name: \"Line End\"")).to_equal(true)
