# @cover src/os/compositor/display_backend.spl#select_backend
# @cover TODO #29

"""
Feature: GPU backend selector (TODO #29)
Category: compositor / display
Status: RED
"""

use std.spec.*
use os.compositor.display_backend.{select_backend, PlatformCaps, CompositorBackend}

# ==========================================================================
# GPU-present path
# ==========================================================================

describe "select_backend with has_gpu=true":
    it "returns a GpuCompositorBackend":
        # Arrange
        val caps = PlatformCaps(has_gpu: true)

        # Act
        val backend = select_backend(caps)

        # Assert — backend exposes CompositorBackend trait methods without panic
        backend.clear(0xFF000000 as u32)
        backend.present()

# ==========================================================================
# No-GPU path
# ==========================================================================

describe "select_backend with has_gpu=false":
    it "returns an FbCompositorBackend":
        val caps = PlatformCaps(has_gpu: false)
        val backend = select_backend(caps)

        # Should satisfy the same interface
        backend.clear(0xFF000000 as u32)
        backend.present()

# ==========================================================================
# Trait parity — both backends must honor the same interface
# ==========================================================================

describe "CompositorBackend trait parity":
    it "both GPU and FB backends accept clear + fill_rect + present":
        val gpu_backend = select_backend(PlatformCaps(has_gpu: true))
        val fb_backend = select_backend(PlatformCaps(has_gpu: false))

        # Arrange — same inputs to both
        val color: u32 = 0xFFFF0000 as u32

        # Act — same sequence on both paths
        gpu_backend.clear(color)
        fb_backend.clear(color)
        gpu_backend.present()
        fb_backend.present()

        # Assert — neither panicked; pixel parity is covered elsewhere
        expect(true).to_equal(true)
