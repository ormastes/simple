"""SMF format validity spec for baked Simple CLI binaries.

Triage question: Is /SIMPLSTC.SMF (the Simple compiler binary baked for
SimpleOS) a syntactically valid SMF that the loader can parse?

If these tests fail, the answer is NO — the SMF backend emits broken output
and the bug is in the compiler back-end, not the loader or binary execution.
See memory: feedback_mcp_cache_off_by_default.md.

Candidate SMF: build/os/simple_cli_apps/x86_64/compile.smf
Using small reference SMF for interpreter-mode speed:
  build/mcp/t32_mcp.smf (219 bytes, same writer, same format)
"""

use compiler.backend.linker.smf_reader_memory.{SmfReaderMemory}

extern fn rt_file_read_bytes(path: text) -> [u8]
extern fn rt_file_exists(path: text) -> bool

# Path to the representative small SMF (same writer as compile.smf).
val SMALL_SMF_PATH = "build/mcp/t32_mcp.smf"

# Path to the primary compiler binary SMF (the one that would become /SIMPLSTC.SMF).
val COMPILER_SMF_PATH = "build/os/simple_cli_apps/x86_64/compile.smf"

describe "SMF format validity — baked Simple binaries":
    """
    Validates that the SMF files produced by the compiler back-end conform to
    the SMF v1.1 contract required by SmfReaderMemory (and the SimpleOS loader).

    A FAIL here confirms the SMF backend bug: compiler emits broken SMFs.
    A PASS confirms the format is valid and the remaining boot blockers are
    in loader behaviour or binary execution.
    """

    it "baked SMF files exist on disk":
        expect rt_file_exists(SMALL_SMF_PATH) == true
        expect rt_file_exists(COMPILER_SMF_PATH) == true

    it "small SMF has correct magic bytes at offset 0":
        val data = rt_file_read_bytes(SMALL_SMF_PATH) ?? []
        # Magic must be 'S' 'M' 'F' '\0'
        expect data.len() >= 4 == true
        expect data[0] == 83
        expect data[1] == 77
        expect data[2] == 70
        expect data[3] == 0

    it "small SMF is large enough to contain a full 128-byte header":
        val data = rt_file_read_bytes(SMALL_SMF_PATH) ?? []
        expect data.len() >= 128 == true

    it "small SMF parses successfully with SmfReaderMemory":
        val data = rt_file_read_bytes(SMALL_SMF_PATH) ?? []
        val result = SmfReaderMemory.from_data(data)
        # This MUST return Ok — if it fails the SMF backend is broken
        expect result.is_ok() == true

    it "small SMF header has version 1.1 (the contract version)":
        val data = rt_file_read_bytes(SMALL_SMF_PATH) ?? []
        val parse_result = SmfReaderMemory.from_data(data)
        # Verify parse succeeded first — a failure here means the format is invalid
        expect parse_result.is_ok() == true
        val reader = parse_result.unwrap()
        val header = reader.get_header()
        val (major, minor) = header.version
        # v1.1 is the only version SmfReaderMemory and the SimpleOS loader support
        expect major == 1
        expect minor == 1

    it "small SMF header has non-zero section count":
        val data = rt_file_read_bytes(SMALL_SMF_PATH) ?? []
        val parse_result = SmfReaderMemory.from_data(data)
        expect parse_result.is_ok() == true
        val reader = parse_result.unwrap()
        val header = reader.get_header()
        expect header.section_count > 0 == true

    it "small SMF has a sensible symbol count (>= 0)":
        val data = rt_file_read_bytes(SMALL_SMF_PATH) ?? []
        val parse_result = SmfReaderMemory.from_data(data)
        expect parse_result.is_ok() == true
        val reader = parse_result.unwrap()
        val header = reader.get_header()
        expect header.symbol_count >= 0 == true

    it "compiler SMF has correct magic bytes at offset 0":
        val data = rt_file_read_bytes(COMPILER_SMF_PATH) ?? []
        expect data.len() >= 4 == true
        expect data[0] == 83
        expect data[1] == 77
        expect data[2] == 70
        expect data[3] == 0

    it "compiler SMF parses successfully with SmfReaderMemory":
        val data = rt_file_read_bytes(COMPILER_SMF_PATH) ?? []
        val result = SmfReaderMemory.from_data(data)
        # This MUST return Ok — if it fails the SMF backend is broken
        expect result.is_ok() == true

    it "compiler SMF header has version 1.1":
        val data = rt_file_read_bytes(COMPILER_SMF_PATH) ?? []
        val parse_result = SmfReaderMemory.from_data(data)
        expect parse_result.is_ok() == true
        val reader = parse_result.unwrap()
        val header = reader.get_header()
        val (major, minor) = header.version
        expect major == 1
        expect minor == 1

    it "compiler SMF has a positive section count":
        val data = rt_file_read_bytes(COMPILER_SMF_PATH) ?? []
        val parse_result = SmfReaderMemory.from_data(data)
        expect parse_result.is_ok() == true
        val reader = parse_result.unwrap()
        val header = reader.get_header()
        expect header.section_count > 0 == true

    it "compiler SMF has a sensible symbol count":
        val data = rt_file_read_bytes(COMPILER_SMF_PATH) ?? []
        val parse_result = SmfReaderMemory.from_data(data)
        expect parse_result.is_ok() == true
        val reader = parse_result.unwrap()
        val header = reader.get_header()
        # A compiler binary should have at least one symbol
        expect header.symbol_count > 0 == true

    it "compiler SMF relocation table is parseable":
        val data = rt_file_read_bytes(COMPILER_SMF_PATH) ?? []
        val parse_result = SmfReaderMemory.from_data(data)
        expect parse_result.is_ok() == true
        val reader = parse_result.unwrap()
        val reloc_result = reader.read_relocations()
        expect reloc_result.is_ok() == true

    it "compiler SMF reloc count is sensible (< 10 million)":
        val data = rt_file_read_bytes(COMPILER_SMF_PATH) ?? []
        val parse_result = SmfReaderMemory.from_data(data)
        expect parse_result.is_ok() == true
        val reader = parse_result.unwrap()
        val relocs = reader.read_relocations().unwrap()
        expect relocs.len() < 10000000 == true