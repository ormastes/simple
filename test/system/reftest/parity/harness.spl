# Reftest harness — op-stream signature comparison for Phase 8 parity reftests

use std.skia.entity.picture.{SkPicture}
use std.skia.entity.geometry.{SkRect}

# ============================================================================
# SceneManifest — metadata describing a single reftest scene
# ============================================================================

class SceneManifest:
    name: text
    description: text
    chromium_ref_file: text

# ============================================================================
# SceneResult — output of running one scene through the harness
# ============================================================================

class SceneResult:
    name: text
    picture: SkPicture
    op_count: i64
    signature: i64

# ============================================================================
# scene_signature — deterministic hash of picture for op-stream comparison
# ============================================================================

fn scene_signature(picture: SkPicture) -> i64:
    val r = picture.cull_rect
    val coord_sum = r.left + r.right + r.top + r.bottom
    val coord_i64 = coord_sum as i64
    val ops = picture.approximate_op_count()
    ops ^ (coord_i64 * 1000)

# ============================================================================
# ReftestHarness — collects SceneResult entries
# ============================================================================

class ReftestHarness:
    results: [SceneResult]

fn reftest_harness_new() -> ReftestHarness:
    ReftestHarness(results: [])

impl ReftestHarness:
    fn run(manifest: SceneManifest, picture: SkPicture) -> SceneResult:
        val sig = scene_signature(picture)
        val ops = picture.approximate_op_count()
        val r = SceneResult(name: manifest.name, picture: picture, op_count: ops, signature: sig)
        self.results = self.results + [r]
        r

    fn result_count() -> i32:
        self.results.len() as i32

    fn find(name: text) -> Option<SceneResult>:
        var found: Option<SceneResult> = None
        for r in self.results:
            if r.name == name:
                found = Some(r)
        found
