# gradient_linear scene — solid red-to-blue fill (no shader API yet), cull 202x200

use std.skia.entity.picture.{SkPicture, SkPictureOp, SkPictureOpKind, sk_picture_op_draw_rect}
use std.skia.entity.paint.{SkPaint, sk_paint_fill}
use std.skia.entity.geometry.{SkRect}
use std.skia.entity.color.{sk_color_argb}

fn scene() -> SkPicture:
    val cull = SkRect(left: 0.0, top: 0.0, right: 202.0, bottom: 200.0)
    # Two side-by-side rects simulating red→blue gradient stops
    val left_rect = SkRect(left: 0.0, top: 0.0, right: 101.0, bottom: 200.0)
    val right_rect = SkRect(left: 101.0, top: 0.0, right: 202.0, bottom: 200.0)
    val paint_red = sk_paint_fill(sk_color_argb(255, 255, 0, 0))
    val paint_blue = sk_paint_fill(sk_color_argb(255, 0, 0, 255))
    val ops = [SkPictureOp]()
    ops.push(sk_picture_op_draw_rect(left_rect, paint_red))
    ops.push(sk_picture_op_draw_rect(right_rect, paint_blue))
    SkPicture(cull_rect: cull, op_count: ops.len() as i64, ops: ops)
