# Golden fixture: path_evenodd — same pentagram with EvenOdd fill

use std.skia.backend.cpu.backend.{CpuBackend, cpu_backend_new}
use std.skia.backend.cpu.raster_prims.{Bitmap}
use std.skia.entity.picture.{SkPicture, SkPictureOp, sk_picture_op_draw_path}
use std.skia.entity.path.{SkPath, sk_path_new}
use std.skia.entity.paint.{SkPaint, sk_paint_fill}
use std.skia.entity.geometry.{SkRect}
use std.skia.entity.color.{sk_color_blue}
use std.skia.entity.enums.{SkPathFillType}

fn _pentagram_evenodd_path() -> SkPath:
    val cx = 128.0
    val cy = 128.0
    val r  = 100.0
    val x0 = cx + r * 0.0
    val y0 = cy - r * 1.0
    val x1 = cx + r * (-0.809)
    val y1 = cy - r * (-0.588)
    val x2 = cx + r * 0.951
    val y2 = cy - r * (-0.309)
    val x3 = cx + r * (-0.951)
    val y3 = cy - r * (-0.309)
    val x4 = cx + r * 0.809
    val y4 = cy - r * (-0.588)
    val base = sk_path_new()
    val p0 = base.with_fill_type(SkPathFillType.EvenOdd)
    val p1 = p0.move_to(x0, y0)
    val p2 = p1.line_to(x1, y1)
    val p3 = p2.line_to(x2, y2)
    val p4 = p3.line_to(x3, y3)
    val p5 = p4.line_to(x4, y4)
    p5.close()

fn golden() -> Bitmap:
    val cull = SkRect(left: 0.0, top: 0.0, right: 256.0, bottom: 256.0)
    val path = _pentagram_evenodd_path()
    val paint = sk_paint_fill(sk_color_blue())
    val op = sk_picture_op_draw_path(path, paint)
    val ops = [op]
    val picture = SkPicture(cull_rect: cull, op_count: 1, ops: ops)
    val backend = cpu_backend_new()
    backend.render_picture(picture, cull)
