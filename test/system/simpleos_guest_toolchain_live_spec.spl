# @tag:system

use std.spec.*

use os.qemu_runner.{get_ssh_live_target, scenario_x64_ssh, ensure_scenario_media, build_os_with_backend}
use test.qemu.os.common.qemu_os_harness.{
    can_run_target, spawn_guest_with_qmp_scenario,
    stop_guest, wait_for_serial_marker, read_serial_log}
use std.nogc_sync_mut.ffi.io.{dir_create_all}

extern fn rt_process_run_timeout(cmd: text, args: [text], timeout_ms: i64) -> (text, text, i32)
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_env_get(key: text) -> text?

fn command_exists(name: text) -> bool:
    val (_out, _err, code) = rt_process_run_timeout("/bin/sh", ["-c", "command -v " + name + " >/dev/null 2>&1"], 5000)
    code == 0

fn live_guest_toolchain_enabled() -> bool:
    command_exists("sshpass") and ((rt_env_get("SIMPLEOS_QEMU_SSH_TOOLCHAIN_LIVE") ?? "") == "1")

fn ssh_command(port: i64, remote_cmd: text) -> text:
    "sshpass -p simpleos ssh " +
        "-o StrictHostKeyChecking=no " +
        "-o UserKnownHostsFile=/tmp/simpleos_guest_toolchain_live_known_hosts " +
        "-o ConnectTimeout=8 " +
        "-o PreferredAuthentications=password " +
        "-o PubkeyAuthentication=no " +
        "-o NumberOfPasswordPrompts=1 " +
        "-p {port} root@127.0.0.1 " +
        "'" + remote_cmd.replace("'", "'\"'\"'") + "'"

fn run_remote(port: i64, remote_cmd: text) -> (text, text, i32):
    rt_process_run_timeout("/bin/sh", ["-c", ssh_command(port, remote_cmd)], 60000)

fn assert_remote_ok(port: i64, remote_cmd: text, needle: text):
    val (out, err, code) = run_remote(port, remote_cmd)
    if code != 0:
        fail("remote command failed: {remote_cmd}\nstdout:\n{out}\nstderr:\n{err}")
    expect((out + err).contains(needle)).to_equal(true)

fn assert_remote_failure(port: i64, remote_cmd: text, expected_err: text):
    val (out, err, code) = run_remote(port, remote_cmd)
    expect(code == 0).to_equal(false)
    expect((out + err).contains(expected_err)).to_equal(true)

describe "SimpleOS guest toolchain live lane":

    it "boots the SSH live guest and proves the staged toolchain surface in-guest":
        if not live_guest_toolchain_enabled():
            print "[simpleos_guest_toolchain_live_spec] set SIMPLEOS_QEMU_SSH_TOOLCHAIN_LIVE=1 and install sshpass to run"
            expect(live_guest_toolchain_enabled()).to_equal(false)
        else:
            val target = get_ssh_live_target()
            val scenario = scenario_x64_ssh()
            val built = build_os_with_backend(target, "llvm")
            expect(built).to_equal(true)
            if built:
                val runnable = can_run_target(target)
                expect(runnable).to_equal(true)
                if runnable:
                    val media_ready = ensure_scenario_media(scenario)
                    expect(media_ready).to_equal(true)
                    if media_ready:
                        val qmp_socket = "/tmp/simpleos_guest_toolchain_live.sock"
                        val serial_log = "build/os/simpleos_guest_toolchain_live.log"
                        val host_port = 2222
                        dir_create_all("build/os")

                        match spawn_guest_with_qmp_scenario(target, scenario, qmp_socket, serial_log):
                            Ok(handle):
                                val ready = wait_for_serial_marker(handle, "[sshd] SSH daemon listening on port 22", 30000)
                                if not ready:
                                    val serial = read_serial_log(handle)
                                    rt_file_write_text("build/os/simpleos_guest_toolchain_live_failure.log", serial)
                                expect(ready).to_equal(true)

                                if ready:
                                    assert_remote_ok(host_port, "clang --version", "clang version")
                                    assert_remote_ok(host_port, "clang --print-target-triple", "x86_64-simpleos")
                                    assert_remote_ok(host_port,
                                        "cat >/tmp/hello.c <<'EOF'\nint main(void) { return 0; }\nEOF\n" +
                                        "clang --target=x86_64-simpleos --sysroot=/usr -c /tmp/hello.c -o /tmp/hello.o && " +
                                        "test -f /tmp/hello.o && echo OBJECT_OK",
                                        "OBJECT_OK")
                                    assert_remote_ok(host_port,
                                        "ld.lld -T /usr/share/simpleos/simpleos.ld /usr/lib/crt0.o /tmp/hello.o -L /usr/lib -lsimpleos_c -o /tmp/hello.elf && " +
                                        "test -f /tmp/hello.elf && echo LINK_OK",
                                        "LINK_OK")
                                    assert_remote_ok(host_port,
                                        "mkdir -p /tmp/cmake-smoke && " +
                                        "cat >/tmp/cmake-smoke/CMakeLists.txt <<'EOF'\ncmake_minimum_required(VERSION 3.10)\nproject(hello C)\nadd_executable(hello hello.c)\nEOF\n" +
                                        "cat >/tmp/cmake-smoke/hello.c <<'EOF'\nint main(void) { return 0; }\nEOF\n" +
                                        "cmake -S /tmp/cmake-smoke -B /tmp/cmake-build -G Ninja >/tmp/cmake.log 2>&1 && " +
                                        "ninja -C /tmp/cmake-build >/tmp/ninja.log 2>&1 && " +
                                        "test -f /tmp/cmake-build/hello && echo CMAKE_NINJA_OK",
                                        "CMAKE_NINJA_OK")
                                    assert_remote_ok(host_port, "rustc --print target-list", "x86_64-unknown-simpleos")
                                    assert_remote_ok(host_port, "rustc --print sysroot", "/usr")
                                    assert_remote_ok(host_port, "rustc --print simpleos-wrapper-status", "status=report-and-gate")
                                    assert_remote_failure(host_port,
                                        "cat >/tmp/main.rs <<'EOF'\nfn main() {}\nEOF\nrustc /tmp/main.rs",
                                        "status=report-and-gate")
                                    assert_remote_failure(host_port, "cargo build", "status=report-and-gate")

                                    val serial = read_serial_log(handle)
                                    expect(serial.contains("[boot]")).to_equal(true)
                                expect(stop_guest(handle)).to_equal(true)
                            Err(err):
                                fail("failed to spawn guest: {err}")
