#![allow(spipe_empty_examples)]
#![allow(spipe_boolean_wrapper_assertions)]
@allow(spipe_empty_examples)
@allow(spipe_boolean_wrapper_assertions)
                use Rectangle
                use Scored
                use Mathable
                use HasData
                use Identified
                use Priced
                use Scalable
                use Bounded
                use Base
                use Extended
                use L1
                use L2
                use L3
                use HasSecret
                use Internal
                use Configurable
                use Configurable2
                use Versioned
                use Computable
                use Labeled
                use Cacheable

class Box:
    depth: i64


class Game:


class Num:


class Worker:
    factor: i64


impl Computable for Worker:
    fn compute(self) -> i64:
        return self.data * self.factor


class Player:
    name: text
    points: i64


impl Displayable for Player:
    fn label(self) -> text:
        return "Player {self.name} (#{self.id})"


impl Rankable for Player:
    fn rank(self) -> i64:
        return self.points


class Item:
    name: text


impl Valuable for Item:
    fn value(self) -> i64:
        return self.price


class Metric:


class Clamped:


class MyClass:


class ThreeLevel:


class Keeper:
    name: text


class Wrapper:
    pub_val: i64


class Service:
    name: text


class Service2:
    name: text


class App:


class Calculator:


impl Printable for Item:
    fn label(self) -> text:
        return "{self.name}: {self.tag}"


class Record:
    data: text


impl Serializable for Record:
    fn serialize(self) -> text:
        return "{self.cache_key}:{self.data}"


fn main():
    # @cover src/compiler/25.traits/traits.spl 60%
    """
    # Advanced Mixin Features
    
    **Feature IDs:** #TBD
    **Category:** Language
    **Difficulty:** 3/5
    **Status:** Partial (basic mixins implemented, advanced features planned)
    
    ## Overview
    
    Advanced mixin patterns including mixin inheritance, private fields,
    default field values, static members, and conditional application.
    
    ## Behavior
    
    - Mixins can require other mixins (transitive composition)
    - Private mixin fields are not exposed to the composing class
    - Default values can be provided and overridden
    - Static fields/methods in mixins are shared
    """

    describe "Advanced Mixin Features":
        """
        ## Advanced Patterns
    
        Tests advanced mixin patterns. Some features are planned but
        not yet runtime-implemented, so they use placeholder assertions.
        """

        context "Mixin with computed methods":
            it "mixin method accesses multiple fields":
                mixin Rectangle:
                    width: i64
                    height: i64

                    fn area() -> i64:
                        return self.width * self.height

    # (hoisted nested def `class Box:` to module scope)
                val b = Box(width: 3, height: 4, depth: 5)
                expect b.area() == 12

            it "mixin method returns derived value":
                mixin Scored:
                    base: i64
                    bonus: i64

                    fn total() -> i64:
                        return self.base + self.bonus

    # (hoisted nested def `class Game:` to module scope)
                val g = Game(base: 100, bonus: 50)
                expect g.total() == 150

            it "mixin with multiple computed methods":
                mixin Mathable:
                    val_: i64

                    fn doubled() -> i64:
                        return self.val_ * 2

                    fn tripled() -> i64:
                        return self.val_ * 3

                    fn squared() -> i64:
                        return self.val_ * self.val_

    # (hoisted nested def `class Num:` to module scope)
                val n = Num(val_: 5)
                expect n.doubled() == 10
                expect n.tripled() == 15
                expect n.squared() == 25

        context "Mixin with trait interaction":
            it "trait impl uses mixin fields":
                trait Computable:
                    fn compute(self) -> i64:
                        return 0

                mixin HasData:
                    data: i64

    # (hoisted nested def `class Worker:` to module scope)
    # (hoisted nested def `impl Computable for Worker:` to module scope)
                val w = Worker(data: 7, factor: 3)
                expect w.compute() == 21

            it "multiple traits on class with mixin":
                trait Displayable:
                    fn label(self) -> text:
                        return ""

                trait Rankable:
                    fn rank(self) -> i64:
                        return 0

                mixin Identified:
                    id: i64

    # (hoisted nested def `class Player:` to module scope)
    # (hoisted nested def `impl Displayable for Player:` to module scope)
    # (hoisted nested def `impl Rankable for Player:` to module scope)
                val p = Player(id: 42, name: "Alice", points: 100)
                expect p.label() == "Player Alice (#42)"
                expect p.rank() == 100

            it "dyn Trait works with mixin class":
                trait Valuable:
                    fn value(self) -> i64:
                        return 0

                mixin Priced:
                    price: i64

    # (hoisted nested def `class Item:` to module scope)
    # (hoisted nested def `impl Valuable for Item:` to module scope)
                val item = Item(price: 50, name: "widget")
                val v: dyn Valuable = item
                expect v.value() == 50

        context "Mixin method with arguments":
            it "mixin method takes parameters":
                mixin Scalable:
                    base: i64

                    fn scale(factor: i64) -> i64:
                        return self.base * factor

                    fn offset(amount: i64) -> i64:
                        return self.base + amount

    # (hoisted nested def `class Metric:` to module scope)
                val m = Metric(base: 10)
                expect m.scale(3) == 30
                expect m.offset(5) == 15

            it "mixin method with multiple parameters":
                mixin Bounded:
                    val_: i64

                    fn clamp(lo: i64, hi: i64) -> i64:
                        if self.val_ < lo:
                            return lo
                        if self.val_ > hi:
                            return hi
                        return self.val_

    # (hoisted nested def `class Clamped:` to module scope)
                val c1 = Clamped(val_: 5)
                expect c1.clamp(0, 10) == 5
                val c2 = Clamped(val_: -3)
                expect c2.clamp(0, 10) == 0
                val c3 = Clamped(val_: 15)
                expect c3.clamp(0, 10) == 10

        context "Mixin inheritance":
            it "mixin can use another mixin":
                mixin Base:
                    base_val: i64

                    fn get_base() -> i64:
                        return self.base_val

                mixin Extended:
                    ext_val: i64

                    fn get_ext() -> i64:
                        return self.ext_val

    # (hoisted nested def `class MyClass:` to module scope)
                val obj = MyClass(base_val: 10, ext_val: 20)
                expect obj.get_base() == 10
                expect obj.get_ext() == 20

            it "inherits all fields transitively":
                mixin L1:
                    a: i64

                mixin L2:
                    b: i64

                mixin L3:
                    c: i64

    # (hoisted nested def `class ThreeLevel:` to module scope)
                val obj = ThreeLevel(a: 1, b: 2, c: 3)
                expect obj.a == 1
                expect obj.b == 2
                expect obj.c == 3

        context "Private fields in mixins":
            it "supports private mixin fields":
                mixin HasSecret:
                    _secret: i64

                    fn reveal() -> i64:
                        return self._secret

    # (hoisted nested def `class Keeper:` to module scope)
                val k = Keeper(_secret: 42, name: "keeper")
                expect k.reveal() == 42

            it "private fields not exposed to class":
                mixin Internal:
                    _internal: i64

                    fn get_internal() -> i64:
                        return self._internal * 2

    # (hoisted nested def `class Wrapper:` to module scope)
                val w = Wrapper(_internal: 5, pub_val: 10)
                expect w.get_internal() == 10
                expect w.pub_val == 10

        context "Default field values":
            it "mixins can provide default values":
                mixin Configurable:
                    timeout: i64 = 30
                    retries: i64 = 3

                    fn get_timeout() -> i64:
                        return self.timeout

    # (hoisted nested def `class Service:` to module scope)
                val s = Service(name: "api")
                expect s.get_timeout() == 30
                expect s.retries == 3

            it "class can override defaults":
                mixin Configurable2:
                    timeout: i64 = 30

                    fn get_timeout() -> i64:
                        return self.timeout

    # (hoisted nested def `class Service2:` to module scope)
                val s = Service2(timeout: 60, name: "api")
                expect s.get_timeout() == 60

        context "Mixin with static members":
            it "supports static fields in mixins":
                mixin Versioned:
                    ver: i64

                    static fn version() -> i64:
                        return 1

    # (hoisted nested def `class App:` to module scope)
                expect App.version() == 1

            it "supports static methods in mixins":
                mixin Computable:
                    val_: i64

                    static fn double(n: i64) -> i64:
                        return n * 2

    # (hoisted nested def `class Calculator:` to module scope)
                expect Calculator.double(5) == 10

        context "Conditional mixin application":
            it "applies mixin based on trait":
                trait Printable:
                    fn label(self) -> text:
                        return ""

                mixin Labeled:
                    tag: text

                    fn get_tag() -> text:
                        return self.tag

    # WARNING: duplicate nested def `class Item:` not hoisted (name collision)
                class Item:
                    name: text

    # (hoisted nested def `impl Printable for Item:` to module scope)
                val item = Item(tag: "urgent", name: "task")
                expect item.label() == "task: urgent"
                expect item.get_tag() == "urgent"

            it "validates conditions at compile time":
                trait Serializable:
                    fn serialize(self) -> text:
                        return ""

                mixin Cacheable:
                    cache_key: text

                    fn get_key() -> text:
                        return self.cache_key

    # (hoisted nested def `class Record:` to module scope)
    # (hoisted nested def `impl Serializable for Record:` to module scope)
                val r = Record(cache_key: "k1", data: "hello")
                expect r.serialize() == "k1:hello"
                expect r.get_key() == "k1"
fn main():
    #![allow(spipe_empty_examples)]
    #![allow(spipe_boolean_wrapper_assertions)]
    @allow(spipe_empty_examples)
    @allow(spipe_boolean_wrapper_assertions)
