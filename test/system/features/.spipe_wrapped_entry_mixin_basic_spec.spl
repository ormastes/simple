#![allow(spipe_empty_examples)]
#![allow(spipe_boolean_wrapper_assertions)]
@allow(spipe_empty_examples)
@allow(spipe_boolean_wrapper_assertions)
            use Trackable
            use Timestamped
            use Valuable
            use Scorable
            use HasId
            use HasName
            use Ident
            use Labeled
            use Defaultable

class Item:
    name: text


class Record:
    id: i64


class Coin:


class Player:
    name: text


class Entity:


class Widget:


class Custom:

    fn compute() -> i64:
        return self.val_ * 10


fn main():
    # @cover src/compiler/25.traits/traits.spl 80%
    """
    # Basic Mixin Declaration and Application
    
    **Feature IDs:** #TBD
    **Category:** Language
    **Difficulty:** 2/5
    **Status:** Implemented
    
    ## Overview
    
    Mixins are stateful traits — they inject fields and methods into classes
    at definition time. Unlike traits (behavioral contracts for runtime dispatch),
    mixins provide structural composition without inheritance.
    
    ## Syntax
    
    ```simple
    mixin Timestamped:
        created_at: i64
        updated_at: i64
    
        fn age() -> i64:
            self.updated_at - self.created_at
    
    class User:
        use Timestamped
        name: text
    ```
    
    ## Key Concepts
    
    | Concept | Description |
    |---------|-------------|
    | Mixin | Reusable bundle of fields and methods |
    | Field injection | Mixin fields become class fields |
    | Method injection | Mixin methods become class methods |
    | Override | Class methods override mixin methods |
    
    ## Behavior
    
    - Mixins inject fields into classes at definition time
    - Mixins inject methods into classes (unless class defines same-named method)
    - Multiple mixins can be applied to one class
    - dyn Mixin is NOT supported (mixins are structural, not behavioral)
    """

    # ============================================================================
    # Mixin Field Injection
    # ============================================================================

    describe "Mixin Field Injection":
        """
        ## Field Injection
    
        Tests that mixin fields are properly injected into classes.
        """

        it "injects mixin fields into class":
            mixin Trackable:
                created_at: i64

    # (hoisted nested def `class Item:` to module scope)
            val item = Item(created_at: 100, name: "test")
            expect item.created_at == 100
            expect item.name == "test"

        it "injects multiple fields from mixin":
            mixin Timestamped:
                created_at: i64
                updated_at: i64

    # (hoisted nested def `class Record:` to module scope)
            val r = Record(created_at: 10, updated_at: 20, id: 1)
            expect r.created_at == 10
            expect r.updated_at == 20
            expect r.id == 1

    # ============================================================================
    # Mixin Method Injection
    # ============================================================================

    describe "Mixin Method Injection":
        """
        ## Method Injection
    
        Tests that mixin methods are callable on classes that use the mixin.
        """

        it "injects mixin methods into class":
            mixin Valuable:
                amount: i64

                fn doubled() -> i64:
                    return self.amount * 2

    # (hoisted nested def `class Coin:` to module scope)
            val c = Coin(amount: 25)
            expect c.doubled() == 50

        it "injects mixin method with arguments":
            mixin Scorable:
                score: i64

                fn add_score(n) -> i64:
                    return self.score + n

    # (hoisted nested def `class Player:` to module scope)
            val p = Player(score: 10, name: "Alice")
            expect p.add_score(5) == 15

    # ============================================================================
    # Multiple Mixins
    # ============================================================================

    describe "Multiple Mixins":
        """
        ## Multiple Mixin Application
    
        Tests applying multiple mixins to a single class.
        """

        it "applies two mixins to one class":
            mixin HasId:
                id: i64

            mixin HasName:
                name: text

    # (hoisted nested def `class Entity:` to module scope)
            val e = Entity(id: 42, name: "Alice")
            expect e.id == 42
            expect e.name == "Alice"

        it "methods from both mixins available":
            mixin Ident:
                id: i64

                fn get_id() -> i64:
                    return self.id

            mixin Labeled:
                label: text

                fn get_label() -> text:
                    return self.label

    # (hoisted nested def `class Widget:` to module scope)
            val w = Widget(id: 7, label: "button")
            expect w.get_id() == 7
            expect w.get_label() == "button"

    # ============================================================================
    # Method Override
    # ============================================================================

    describe "Mixin Method Override":
        """
        ## Class Methods Override Mixin Methods
    
        When a class defines a method with the same name as a mixin method,
        the class method wins.
        """

        it "class method overrides mixin method":
            mixin Defaultable:
                val_: i64

                fn compute() -> i64:
                    return self.val_

    # (hoisted nested def `class Custom:` to module scope)
            val c = Custom(val_: 5)
            expect c.compute() == 50