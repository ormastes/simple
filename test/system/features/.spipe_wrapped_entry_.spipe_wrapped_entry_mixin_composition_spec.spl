fn main():
    # @cover src/compiler/25.traits/traits.spl 60%
    """
    # Mixin Composition and Ordering
    
    **Feature IDs:** #TBD
    **Category:** Language
    **Difficulty:** 3/5
    **Status:** Partial (basic composition implemented, advanced resolution planned)
    
    ## Overview
    
    Composing multiple mixins with proper field and method resolution.
    Tests application order, field shadowing, and method overriding.
    
    ## Behavior
    
    - Mixins are applied in declaration order
    - Later mixins can shadow fields from earlier ones
    - Class methods always override mixin methods
    - Diamond composition deduplicates shared mixins
    """

    describe "Mixin Composition":
        """
        ## Composition Behavior
    
        Tests mixin composition including ordering and method resolution.
        """

        context "Basic composition order":
            it "fields from multiple mixins are accessible":
                mixin First:
                    a: i64

                mixin Second:
                    b: i64

    # (hoisted nested def `class Combined:` to module scope)
                val obj = Combined(a: 1, b: 2, c: 3)
                expect obj.a == 1
                expect obj.b == 2
                expect obj.c == 3

            it "methods from multiple mixins resolve":
                mixin Alpha:
                    x: i64

                    fn get_x() -> i64:
                        return self.x

                mixin Beta:
                    y: i64

                    fn get_y() -> i64:
                        return self.y

    # (hoisted nested def `class Pair:` to module scope)
                val p = Pair(x: 10, y: 20)
                expect p.get_x() == 10
                expect p.get_y() == 20

            it "three mixins compose correctly":
                mixin MA:
                    a: i64
                    fn get_a() -> i64:
                        return self.a

                mixin MB:
                    b: i64
                    fn get_b() -> i64:
                        return self.b

                mixin MC:
                    c: i64
                    fn get_c() -> i64:
                        return self.c

    # (hoisted nested def `class Triple:` to module scope)
                val t = Triple(a: 1, b: 2, c: 3)
                expect t.get_a() == 1
                expect t.get_b() == 2
                expect t.get_c() == 3

        context "Method resolution order":
            it "first mixin method wins when names conflict":
                mixin M1:
                    x: i64
                    fn value() -> i64:
                        return self.x

                mixin M2:
                    y: i64
                    fn value() -> i64:
                        return self.y

    # (hoisted nested def `class Both:` to module scope)
                val b = Both(x: 10, y: 20)
                expect b.value() == 10

            it "class method beats mixin method":
                mixin Base:
                    n: i64

                    fn value() -> i64:
                        return self.n

    # (hoisted nested def `class Override:` to module scope)
                val o = Override(n: 3)
                expect o.value() == 300

            it "class method overrides even with multiple mixins":
                mixin P:
                    p: i64
                    fn result() -> i64:
                        return self.p

                mixin Q:
                    q: i64
                    fn result() -> i64:
                        return self.q

    # (hoisted nested def `class PQ:` to module scope)
                val pq = PQ(p: 3, q: 7)
                expect pq.result() == 10

        context "Cross-mixin method calls":
            it "mixin method can call methods from other mixins on same class":
                mixin HasX:
                    x: i64
                    fn get_x() -> i64:
                        return self.x

                mixin HasY:
                    y: i64
                    fn get_y() -> i64:
                        return self.y

                mixin HasSum:
                    fn compute_sum() -> i64:
                        return self.get_x() + self.get_y()

    # (hoisted nested def `class XYSum:` to module scope)
                val s = XYSum(x: 10, y: 20)
                expect s.compute_sum() == 30

        context "Mixin reuse across classes":
            it "same mixin applied to multiple classes":
                mixin Taggable:
                    tag: text

                    fn get_tag() -> text:
                        return self.tag

    # (hoisted nested def `class Doc:` to module scope)
    # (hoisted nested def `class Image:` to module scope)
                val d = Doc(tag: "important", content: "hello")
                val i = Image(tag: "photo", width: 800)
                expect d.get_tag() == "important"
                expect i.get_tag() == "photo"

        context "Diamond composition":
            it "handles diamond mixin hierarchy":
                mixin Shared:
                    id: i64

                    fn get_id() -> i64:
                        return self.id

                mixin Left:
                    left_val: i64

                mixin Right:
                    right_val: i64

    # (hoisted nested def `class Diamond:` to module scope)
                val d = Diamond(id: 1, left_val: 2, right_val: 3)
                expect d.id == 1
                expect d.left_val == 2
                expect d.right_val == 3

            it "shared mixin applied once":
                mixin Base:
                    base: i64

                    fn get_base() -> i64:
                        return self.base

                mixin A:
                    a: i64

                mixin B:
                    b: i64

    # (hoisted nested def `class AB:` to module scope)
                val obj = AB(base: 10, a: 20, b: 30)
                expect obj.get_base() == 10
                expect obj.a == 20
                expect obj.b == 30

        context "Deep composition":
            it "supports nested mixin composition":
                mixin Level1:
                    x: i64

                    fn get_x() -> i64:
                        return self.x

                mixin Level2:
                    y: i64

                    fn get_y() -> i64:
                        return self.y

    # (hoisted nested def `class Deep:` to module scope)
                val d = Deep(x: 1, y: 2)
                expect d.get_x() == 1
                expect d.get_y() == 2

            it "resolves all fields correctly":
                mixin A:
                    a: i64

                mixin B:
                    b: i64

                mixin C:
                    c: i64

    # (hoisted nested def `class Chain:` to module scope)
                val obj = Chain(a: 1, b: 2, c: 3)
                expect obj.a == 1
                expect obj.b == 2
                expect obj.c == 3
fn main():
    #![allow(spipe_empty_examples)]
    #![allow(spipe_boolean_wrapper_assertions)]
    @allow(spipe_empty_examples)
    @allow(spipe_boolean_wrapper_assertions)
