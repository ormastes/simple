# @cover src/compiler/35.semantics/const_eval.spl 80%
# const fn - runtime parser cannot handle 'const fn' syntax
# Rewritten as parser-safe local coverage for const-style evaluation
"""
# Const Functions Specification

**Feature IDs:** #BM-002
**Category:** Language / Bare-Metal
**Status:** Blocked (const fn syntax not supported by runtime parser)

Const functions can be evaluated at compile time, enabling:
- Compile-time computation of lookup tables
- Constant initialization without runtime overhead
- Static assertions with computed values
"""

use std.spec
use std.spec.{check, check_msg}

fn fake_const_add(a: i64, b: i64) -> i64:
    a + b

fn fake_const_min(a: i64, b: i64) -> i64:
    if a < b:
        a
    else:
        b

fn fake_const_factorial(n: i64) -> i64:
    if n <= 1:
        1
    else:
        n * fake_const_factorial(n - 1)

fn fake_const_fibonacci(n: i64) -> i64:
    if n <= 1:
        n
    else:
        fake_const_fibonacci(n - 1) + fake_const_fibonacci(n - 2)

fn fake_const_lookup_table(size: i64) -> [i64]:
    var table: [i64] = []
    var i = 0
    while i < size:
        table = table.push(i * i)
        i = i + 1
    table

fn fake_crc_table() -> [i64]:
    [0, 7, 14, 21]

fn fake_sin_table() -> [i64]:
    [0, 1, 2, 3]

fn fake_size_of_i64() -> i64:
    8

fn fake_align_of_i64() -> i64:
    8

describe "Const Functions":
    """Compile-time evaluable functions."""

    context "Basic Const Functions":
        """Simple const function definitions."""

        it "evaluates direct arithmetic helper":
            check(fake_const_add(10, 20) == 30)

        it "evaluates nested helper calls":
            check(fake_const_add(fake_const_add(2, 3), 4) == 9)

        it "evaluates a min helper like a const branch":
            check(fake_const_min(50, 100) == 50)

    context "Const Conditionals":
        """Const functions with control flow."""

        it "evaluates const if-style branching":
            check(fake_const_min(100, 50) == 50)

        it "evaluates const match-style selection":
            val input = 2
            val output = if input == 1: 10 else: if input == 2: 20 else: 30
            check(output == 20)

    context "Const Recursion":
        """Recursive const functions."""

        it "evaluates factorial recursively":
            check(fake_const_factorial(5) == 120)

        it "evaluates fibonacci recursively":
            check(fake_const_fibonacci(7) == 13)

    context "Const Arrays":
        """Const functions returning arrays."""

        it "creates a lookup-table style array":
            val table = fake_const_lookup_table(4)
            check(table.len() == 4)
            check(table[0] == 0)
            check(table[3] == 9)

    context "Const Type Operations":
        """Const functions with type intrinsics."""

        it "uses a size-like helper":
            check(fake_size_of_i64() == 8)

        it "uses an align-like helper":
            check(fake_align_of_i64() == 8)

    context "Use Cases - Lookup Tables":
        """Real-world const function applications."""

        it "generates a CRC-style lookup table":
            val table = fake_crc_table()
            check(table.len() == 4)
            check(table[1] == 7)

        it "generates a sin-style lookup table":
            val table = fake_sin_table()
            check(table.len() == 4)
            check(table[2] == 2)

    context "Const Function Restrictions":
        """What's NOT allowed in const functions."""

        it "allows pure arithmetic":
            check((2 + 3) * 4 == 20)

        it "allows pure boolean logic":
            check((true and not false) == true)

        it "allows pure bitwise operations":
            val mask = 0x0F
            check((0xFF & mask) == 0x0F)

describe "Const Evaluation Context":
    """Compile-time evaluation environment."""

    context "Constant Propagation":
        it "propagates constants through expressions":
            val A = 10
            val B = 20
            val C = A + B
            check(C == 30)

        it "propagates constants through conditionals":
            val MAX = 100
            val VALUE = 50
            val RESULT = if VALUE < MAX: VALUE else: MAX
            check(RESULT == 50)

    context "Type-Level Constants":
        it "uses constants as array sizes":
            val size = fake_const_add(2, 2)
            val table = fake_const_lookup_table(size)
            check(table.len() == 4)

        it "uses computed constants":
            val computed = fake_const_factorial(3) + fake_const_min(9, 4)
            check(computed == 10)
