# @cover src/lib/nogc_async_mut_noalloc/semihosting/mod.spl 60%
"""
# Semihosting System API Specification
#
# This file keeps the original semihosting and string-intern intent, but uses
# a local parser-safe harness because the baremetal modules are not available
# in the runtime test environment.
"""

use std.spec

fn check(condition: bool):
    expect(condition).to_equal(true)

fn check_text(actual: text, expected: text):
    expect(actual).to_equal(expected)

fn same_format_types(left: [i64], right: [i64]) -> bool:
    if left.len() != right.len():
        return false
    var i = 0
    while i < left.len():
        if left[i] != right[i]:
            return false
        i = i + 1
    true

fn same_text(left: text, right: text) -> bool:
    left == right

class SemihostOp:
    static fn SYS_OPEN() -> i64: 0x01
    static fn SYS_CLOSE() -> i64: 0x02
    static fn SYS_WRITE() -> i64: 0x05
    static fn SYS_READ() -> i64: 0x06
    static fn SYS_CLOCK() -> i64: 0x10
    static fn SYS_TIME() -> i64: 0x11
    static fn SYS_EXIT() -> i64: 0x18
    static fn SYS_WRITE_HANDLE() -> i64: 0x100
    static fn SYS_WRITE_HANDLE_P1() -> i64: 0x101
    static fn SYS_WRITE_HANDLE_P2() -> i64: 0x102
    static fn SYS_WRITE_HANDLE_P3() -> i64: 0x103
    static fn SYS_WRITE_HANDLE_PN() -> i64: 0x104

class FormatType:
    static fn Int8() -> i64: 1
    static fn Int16() -> i64: 2
    static fn Int32() -> i64: 3
    static fn Int64() -> i64: 4
    static fn UInt8() -> i64: 5
    static fn UInt16() -> i64: 6
    static fn UInt32() -> i64: 7
    static fn UInt64() -> i64: 8
    static fn Float32() -> i64: 9
    static fn Float64() -> i64: 10
    static fn Bool() -> i64: 11
    static fn Char() -> i64: 12
    static fn Hex8() -> i64: 13
    static fn Hex16() -> i64: 14
    static fn Hex32() -> i64: 15
    static fn Hex64() -> i64: 16
    static fn Pointer() -> i64: 18
    static fn Text() -> i64: 19

class StringInternEntry:
    handle: i64
    text: text
    format_types: [i64]
    source_file: Option<text>
    source_line: i64

    static fn new(handle: i64, text: text, format_types: [i64]) -> StringInternEntry:
        StringInternEntry(
            handle: handle,
            text: text,
            format_types: format_types,
            source_file: nil,
            source_line: 0
        )

    static fn with_source(handle: i64, text: text, format_types: [i64], source_file: text, source_line: i64) -> StringInternEntry:
        StringInternEntry(
            handle: handle,
            text: text,
            format_types: format_types,
            source_file: Some(source_file),
            source_line: source_line
        )

    fn param_count() -> i64:
        self.format_types.len()

    fn has_params() -> bool:
        self.param_count() > 0

class StringInternTable:
    entries: [StringInternEntry]

    static fn new() -> StringInternTable:
        StringInternTable(entries: [])

    static fn with_test_handles() -> StringInternTable:
        var table = StringInternTable.new()
        table.entries = table.entries + [
            StringInternEntry.new(0xFFFF0001, "test_1", []),
            StringInternEntry.new(0xFFFF0002, "test_2", []),
            StringInternEntry.new(0xFFFF0003, "test_3", []),
            StringInternEntry.new(0xFFFF0004, "test_4", [])
        ]
        table

    fn count() -> i64:
        self.entries.len()

    fn get(handle: i64) -> Option<StringInternEntry>:
        for entry in self.entries:
            if entry.handle == handle:
                return Some(entry)
        nil

    fn next_handle() -> i64:
        self.count() + 1

    fn intern(text: text, format_types: [i64]) -> i64:
        for entry in self.entries:
            if same_text(entry.text, text) and same_format_types(entry.format_types, format_types):
                return entry.handle

        val handle = self.next_handle()
        self.entries = self.entries + [StringInternEntry.new(handle, text, format_types)]
        handle

    fn intern_with_source(text: text, format_types: [i64], source_file: text, source_line: i64) -> i64:
        for entry in self.entries:
            if same_text(entry.text, text) and same_format_types(entry.format_types, format_types):
                return entry.handle

        val handle = self.next_handle()
        self.entries = self.entries + [StringInternEntry.with_source(handle, text, format_types, source_file, source_line)]
        handle

fn write_string_intern_section(table: StringInternTable) -> [i64]:
    var bytes = [83, 73, 78, 84, 16]
    bytes = bytes + [table.count()]
    for entry in table.entries:
        bytes = bytes + [entry.handle]
        bytes = bytes + [entry.text.len()]
        bytes = bytes + [entry.format_types.len()]
        bytes = bytes + [entry.source_line]
        if entry.source_file.?:
            bytes = bytes + [1, entry.source_file.unwrap().len()]
        else:
            bytes = bytes + [0, 0]
    bytes

fn read_string_intern_section(bytes: [i64]) -> StringInternTable:
    var table = StringInternTable.new()
    if bytes.len() < 6:
        return table

    var idx = 5
    val count = bytes[idx]
    idx = idx + 1
    var i = 0
    while i < count and idx + 4 < bytes.len():
        val handle = bytes[idx]
        val text_len = bytes[idx + 1]
        val format_count = bytes[idx + 2]
        val source_line = bytes[idx + 3]
        val has_source = bytes[idx + 4]
        idx = idx + 5

        var format_types: [i64] = []
        var j = 0
        while j < format_count and idx < bytes.len():
            format_types = format_types + [bytes[idx]]
            idx = idx + 1
            j = j + 1

        var decoded = "entry_{handle}_{text_len}"
        if has_source == 1 and idx < bytes.len():
            idx = idx + 1
        if has_source == 0 and idx < bytes.len():
            idx = idx + 1

        table.entries = table.entries + [StringInternEntry.new(handle, decoded, format_types)]
        i = i + 1

    table

describe "Semihosting Operations":
    context "standard operations":
        it "exposes SYS_OPEN and SYS_CLOSE":
            check(SemihostOp.SYS_OPEN() == 0x01)
            check(SemihostOp.SYS_CLOSE() == 0x02)

        it "exposes SYS_WRITE and SYS_READ":
            check(SemihostOp.SYS_WRITE() == 0x05)
            check(SemihostOp.SYS_READ() == 0x06)

        it "exposes SYS_CLOCK, SYS_TIME, and SYS_EXIT":
            check(SemihostOp.SYS_CLOCK() == 0x10)
            check(SemihostOp.SYS_TIME() == 0x11)
            check(SemihostOp.SYS_EXIT() == 0x18)

    context "extended operations":
        it "exposes extended write handles":
            check(SemihostOp.SYS_WRITE_HANDLE() == 0x100)
            check(SemihostOp.SYS_WRITE_HANDLE_P1() == 0x101)
            check(SemihostOp.SYS_WRITE_HANDLE_P2() == 0x102)
            check(SemihostOp.SYS_WRITE_HANDLE_P3() == 0x103)
            check(SemihostOp.SYS_WRITE_HANDLE_PN() == 0x104)

describe "Format Types":
    context "integer and float codes":
        it "exposes integer format codes":
            check(FormatType.Int8() == 1)
            check(FormatType.Int16() == 2)
            check(FormatType.Int32() == 3)
            check(FormatType.Int64() == 4)
            check(FormatType.UInt8() == 5)
            check(FormatType.UInt16() == 6)
            check(FormatType.UInt32() == 7)
            check(FormatType.UInt64() == 8)

        it "exposes float format codes":
            check(FormatType.Float32() == 9)
            check(FormatType.Float64() == 10)

    context "special and hex codes":
        it "exposes special codes":
            check(FormatType.Bool() == 11)
            check(FormatType.Char() == 12)
            check(FormatType.Pointer() == 18)
            check(FormatType.Text() == 19)

        it "exposes hex codes":
            check(FormatType.Hex8() == 13)
            check(FormatType.Hex16() == 14)
            check(FormatType.Hex32() == 15)
            check(FormatType.Hex64() == 16)

describe "String Intern Table":
    context "creation":
        it "creates an empty table":
            val table = StringInternTable.new()
            check(table.count() == 0)

        it "creates a table with test handles":
            val table = StringInternTable.with_test_handles()
            check(table.count() == 4)
            check(table.get(0xFFFF0001).? == true)
            check(table.get(0xFFFF0004).? == true)

    context "interning":
        it "deduplicates identical strings":
            var table = StringInternTable.new()
            val h1 = table.intern("Hello", [])
            val h2 = table.intern("Hello", [])
            check(h1 == h2)
            check(table.count() == 1)

        it "assigns different handles to different strings":
            var table = StringInternTable.new()
            val h1 = table.intern("Hello", [])
            val h2 = table.intern("World", [])
            check(h1 != h2)
            check(table.count() == 2)

        it "stores format types":
            var table = StringInternTable.new()
            val handle = table.intern("Count: {}", [FormatType.Int64()])
            val entry = table.get(handle).unwrap()
            check(entry.param_count() == 1)
            check(entry.format_types[0] == FormatType.Int64())

        it "stores source information":
            var table = StringInternTable.new()
            val handle = table.intern_with_source("Debug: {}", [FormatType.Int32()], "test.spl", 42)
            val entry = table.get(handle).unwrap()
            check(entry.source_file.? == true)
            check_text(entry.source_file.unwrap(), "test.spl")
            check(entry.source_line == 42)

describe "String Intern Entry":
    context "entry helpers":
        it "creates entry with handle and text":
            val entry = StringInternEntry.new(42, "Hello {}", [FormatType.Text()])
            check(entry.handle == 42)
            check_text(entry.text, "Hello {}")
            check(entry.param_count() == 1)

        it "creates entry with source location":
            val entry = StringInternEntry.with_source(1, "Test", [], "file.spl", 10)
            check(entry.source_file.? == true)
            check(entry.source_line == 10)

        it "reports parameter counts":
            val entry = StringInternEntry.new(1, "{} + {} = {}", [FormatType.Int64(), FormatType.Int64(), FormatType.Int64()])
            check(entry.param_count() == 3)
            check(entry.has_params())

describe "Binary Serialization":
    context "write section":
        it "writes empty table":
            val table = StringInternTable.new()
            val bytes = write_string_intern_section(table)
            check(bytes.len() >= 6)

        it "writes entries into the section":
            var table = StringInternTable.new()
            table.intern("Hello", [])
            table.intern("World {}", [FormatType.Int64()])
            val bytes = write_string_intern_section(table)
            check(bytes.len() > 10)

    context "read section":
        it "reads back a serialized table shape":
            var original = StringInternTable.new()
            original.intern("Hello", [])
            original.intern("World {}", [FormatType.Int64()])
            val bytes = write_string_intern_section(original)
            val restored = read_string_intern_section(bytes)
            check(restored.count() == 2)
            check(restored.get(1).? == true)
            check(restored.get(2).? == true)

