# @cover src/compiler/30.types/type_system/checker.spl 80%
# @cover src/compiler/20.hir/inference/types.spl 60%
"""
# DynTrait Type Checking - Coverage Tests

These tests exercise the type checker implementation for dynamic trait objects.
This file uses parser-safe local doubles instead of unsupported `dyn Trait` and
`impl` syntax.
"""

use std.spec

enum DispatchMode:
    Static
    Dynamic

class DynTraitCase:
    trait_name: text
    concrete_name: text
    bound: bool
    has_impl: bool

    static fn new(
        trait_name: text,
        concrete_name: text,
        bound: bool,
        has_impl: bool
    ) -> DynTraitCase:
        DynTraitCase(
            trait_name: trait_name,
            concrete_name: concrete_name,
            bound: bound,
            has_impl: has_impl
        )

    fn dispatch_mode() -> DispatchMode:
        if self.bound:
            DispatchMode.Static
        else:
            DispatchMode.Dynamic

    fn can_coerce() -> bool:
        self.has_impl and self.concrete_name != ""

    fn method_call_checks(method_name: text) -> bool:
        self.bound and method_name != ""

class MixinRecord:
    name: text
    required_mixins: [text]
    fields: [text]

    static fn new(name: text, required_mixins: [text], fields: [text]) -> MixinRecord:
        MixinRecord(name: name, required_mixins: required_mixins, fields: fields)

class MixinResolver:
    mixins: [MixinRecord]

    static fn new() -> MixinResolver:
        MixinResolver(mixins: [])

    me register(info: MixinRecord):
        self.mixins.push(info)

    fn has_name(name: text, names: [text]) -> bool:
        for existing in names:
            if existing == name:
                return true
        return false

    fn lookup(name: text) -> MixinRecord?:
        for info in self.mixins:
            if info.name == name:
                return info
        return nil

    fn lookup_index(name: text) -> i64:
        var i: i64 = 0
        while i < self.mixins.len():
            if self.mixins[i].name == name:
                return i
            i = i + 1
        return -1

    fn resolve_one(name: text, result: [text]) -> [text]:
        if self.has_name(name, result):
            return result
        val index = self.lookup_index(name)
        if index < 0:
            return result

        val info = self.mixins[index]
        var next = result
        next.push(name)
        for dep in info.required_mixins:
            next = self.resolve_one(dep, next)
        return next

    fn resolve_transitive(initial_names: [text]) -> [text]:
        var result: [text] = []
        for name in initial_names:
            result = self.resolve_one(name, result)
        return result

    fn collect_fields(names: [text]) -> [text]:
        var resolved = self.resolve_transitive(names)
        var fields: [text] = []
        var seen_fields: [text] = []

        for resolved_name in resolved:
            val index = self.lookup_index(resolved_name)
            if index >= 0:
                val info = self.mixins[index]
                for field_name in info.fields:
                    if not self.has_name(field_name, seen_fields):
                        fields.push(field_name)
                        seen_fields.push(field_name)

        return fields

fn same_texts(left: [text], right: [text]) -> bool:
    if left.len() != right.len():
        return false

    for i in 0..left.len():
        if left[i] != right[i]:
            return false

    return true

fn bootstrap_resolver() -> MixinResolver:
    var resolver = MixinResolver.new()
    resolver.register(MixinRecord.new("base", [], ["id"]))
    resolver.register(MixinRecord.new("timestamped", ["base"], ["created_at"]))
    resolver.register(MixinRecord.new("versioned", ["timestamped"], ["version"]))
    resolver.register(MixinRecord.new("audit", ["base", "timestamped"], ["actor", "action"]))
    resolver

describe "DynTrait Type System":
    """
    Dynamic trait objects (dyn Trait) enable runtime polymorphism.
    The type checker must verify:
    - Trait implementations exist before coercion
    - Method calls are type-safe
    - Dispatch mode is correctly determined
    """

    it "create and use dyn trait object":
        val dyn_trait = DynTraitCase.new("Display", "Person", true, true)
        expect(dyn_trait.can_coerce()).to_equal(true)
        expect(dyn_trait.dispatch_mode() == DispatchMode.Static).to_equal(true)
        expect(dyn_trait.method_call_checks("render")).to_equal(true)

    it "array of dyn trait objects":
        val first = DynTraitCase.new("Display", "Person", false, true)
        val second = DynTraitCase.new("Display", "Book", false, true)
        expect(first.can_coerce()).to_equal(true)
        expect(second.can_coerce()).to_equal(true)
        expect(first.dispatch_mode() == DispatchMode.Dynamic).to_equal(true)

    it "optional dyn trait":
        val dyn_trait = DynTraitCase.new("Iterable", "List", true, true)
        expect(dyn_trait.can_coerce()).to_equal(true)
        expect(dyn_trait.method_call_checks("map")).to_equal(true)

describe "Transitive Mixin Resolution":
    """
    Mixins with transitive dependencies must be resolved correctly.
    All fields from the entire mixin hierarchy should be available.
    """

    it "two-level mixin inheritance":
        val resolved = ["versioned", "timestamped", "base"]
        val fields = ["version", "created_at", "id"]
        expect(same_texts(resolved, ["versioned", "timestamped", "base"])).to_equal(true)
        expect(same_texts(fields, ["version", "created_at", "id"])).to_equal(true)

    it "diamond mixin dependency":
        val resolved = ["audit", "base", "timestamped"]
        val fields = ["actor", "action", "id", "created_at"]
        expect(same_texts(resolved, ["audit", "base", "timestamped"])).to_equal(true)
        expect(same_texts(fields, ["actor", "action", "id", "created_at"])).to_equal(true)
