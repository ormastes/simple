# @cover src/compiler/90.tools/aop.spl 80%
# @cover src/compiler/10.frontend/core/aop.spl 80%
# AOP Around Advice Specification
# Feature IDs: #AOP-AROUND-001 to #AOP-AROUND-010
# Category: Language
# Status: Implemented

use std.spec
use compiler.tools.aop.{AopWeaver}
use compiler.frontend.core.aop.{
    AdviceForm, DiagnosticLevel, MirBlockInfo, InstructionInfo,
    WeavingRule, WeavingConfig
}
use compiler.common.config.{BootLogger}

fn around_rule(predicate_text: text, advice_function: text, priority: i64) -> WeavingRule:
    WeavingRule(
        predicate_text: predicate_text,
        advice_function: advice_function,
        form: AdviceForm.Around,
        priority: priority
    )

fn empty_weaver() -> AopWeaver:
    val config = WeavingConfig.disabled()
    val logger = BootLogger(level: 0)
    AopWeaver(advices: [], config: config, logger: logger)

describe "AOP Around Advice":
    it "does not weave when config is disabled":
        val weaver = empty_weaver()
        val result = weaver.weave_mir_function("target_fn", "app.target", [], [], [])
        expect(result.join_points_woven).to_equal(0)
        expect(result.advices_inserted).to_equal(0)
        expect(result.advice_calls.len()).to_equal(0)
        expect(result.diagnostics.len()).to_equal(0)

    it "weaves execution join points for around advice":
        val config = WeavingConfig.from_rules([
            around_rule("*", "audit_around", 10)
        ])
        val logger = BootLogger(level: 0)
        val weaver = AopWeaver(advices: [], config: config, logger: logger)

        val result = weaver.weave_mir_function("target_fn", "app.target", [], [], [])
        expect(result.join_points_woven).to_equal(1)
        expect(result.advices_inserted).to_equal(1)
        expect(result.advice_calls.len()).to_equal(1)
        expect(result.advice_calls[0].advice_function).to_equal("audit_around")

    it "orders around advice by descending priority":
        val config = WeavingConfig.from_rules([
            around_rule("*", "inner_around", 10),
            around_rule("*", "outer_around", 50)
        ])
        val logger = BootLogger(level: 0)
        val weaver = AopWeaver(advices: [], config: config, logger: logger)

        val result = weaver.weave_mir_function("target_fn", "app.target", [], [], [])
        expect(result.advices_inserted).to_equal(2)
        expect(result.advice_calls[0].advice_function).to_equal("outer_around")
        expect(result.advice_calls[1].advice_function).to_equal("inner_around")

    it "weaves additional join points discovered from MIR block instructions":
        val config = WeavingConfig.from_rules([
            around_rule("*", "around_all", 10)
        ])
        val logger = BootLogger(level: 0)
        val weaver = AopWeaver(advices: [], config: config, logger: logger)
        val blocks = [
            MirBlockInfo(
                id: 7,
                instruction_kinds: [
                    InstructionInfo(index: 1, kind_tag: "branch"),
                    InstructionInfo(index: 2, kind_tag: "comparison"),
                    InstructionInfo(index: 3, kind_tag: "error")
                ]
            )
        ]

        val result = weaver.weave_mir_function("target_fn", "app.target", [], [], blocks)
        expect(result.join_points_woven).to_equal(4)
        expect(result.advices_inserted).to_equal(4)
        expect(result.advice_calls.len()).to_equal(4)

    it "reports ambiguous ordering diagnostics when around advice priorities collide":
        val config = WeavingConfig.from_rules([
            around_rule("*", "first_around", 20),
            around_rule("*", "second_around", 20)
        ])
        val logger = BootLogger(level: 0)
        val weaver = AopWeaver(advices: [], config: config, logger: logger)

        val result = weaver.weave_mir_function("target_fn", "app.target", [], [], [])
        expect(result.diagnostics.len()).to_equal(2)
        expect(result.diagnostics[0].level).to_equal(DiagnosticLevel.Warning)
        expect(result.diagnostics[0].message.contains("Ambiguous advice ordering")).to_equal(true)
        expect(result.diagnostics[1].level).to_equal(DiagnosticLevel.Info)
        expect(result.diagnostics[1].message.contains("Woven 2 advice calls")).to_equal(true)
