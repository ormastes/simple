# @cover src/compiler/10.frontend/treesitter.spl 80%
# @cover src/compiler/10.frontend/treesitter_types.spl 80%
"""
# TreeSitter Incremental Parsing Specification

This file now uses a self-contained local harness to model point adjustment,
edit summaries, line counting, and incremental reparse behavior without relying
on unavailable production treesitter modules.
"""

use std.spec

fn check(condition: bool):
    expect(condition).to_equal(true)

class Point:
    line: i64
    column: i64

    static fn create(line: i64, column: i64) -> Point:
        Point(line: line, column: column)

    fn compare(other: Point) -> i64:
        if self.line < other.line:
            -1
        else:
            if self.line > other.line:
                1
            else:
                if self.column < other.column:
                    -1
                else:
                    if self.column > other.column:
                        1
                    else:
                        0

    fn is_before(other: Point) -> bool:
        self.compare(other) < 0

    fn is_at_or_after(other: Point) -> bool:
        self.compare(other) >= 0

class InputEdit:
    start_byte: i64
    end_byte: i64
    new_end_byte: i64
    start_point: Point
    end_point: Point
    new_end_point: Point

    static fn create(start_byte: i64, end_byte: i64, new_end_byte: i64, start_point: Point, end_point: Point, new_end_point: Point) -> InputEdit:
        InputEdit(
            start_byte: start_byte,
            end_byte: end_byte,
            new_end_byte: new_end_byte,
            start_point: start_point,
            end_point: end_point,
            new_end_point: new_end_point
        )

    fn affects_byte(byte: i64) -> bool:
        byte >= self.start_byte and byte < self.end_byte

    fn affects_point(point: Point) -> bool:
        point.is_at_or_after(self.start_point) and point.is_before(self.end_point)

class EditSummary:
    kind: text
    byte_delta: i64
    line_delta: i64
    column_delta: i64

    static fn create(kind: text, byte_delta: i64, line_delta: i64, column_delta: i64) -> EditSummary:
        EditSummary(
            kind: kind,
            byte_delta: byte_delta,
            line_delta: line_delta,
            column_delta: column_delta
        )

fn count_lines(text: text) -> i64:
    var lines = 1
    for ch in text:
        if ch == "\n":
            lines = lines + 1
    lines

fn end_point(text: text) -> Point:
    var line = 1
    var column = 0
    for ch in text:
        if ch == "\n":
            line = line + 1
            column = 0
        else:
            column = column + 1
    Point.create(line, column)

fn apply_byte_edit(byte: i64, edit: InputEdit) -> i64:
    val delta = edit.new_end_byte - edit.end_byte
    if byte < edit.start_byte:
        byte
    else:
        if byte < edit.end_byte:
            edit.start_byte
        else:
            byte + delta

fn apply_point_edit(point: Point, edit: InputEdit) -> Point:
    if point.is_before(edit.start_point):
        Point.create(point.line, point.column)
    else:
        if point.is_before(edit.end_point):
            Point.create(edit.start_point.line, edit.start_point.column)
        else:
            val line_delta = edit.new_end_point.line - edit.end_point.line
            val column_delta = edit.new_end_point.column - edit.end_point.column
            if line_delta == 0:
                Point.create(point.line, point.column + column_delta)
            else:
                Point.create(point.line + line_delta, point.column)

fn diff_kind(old_text: text, new_text: text) -> text:
    if old_text == new_text:
        "equal"
    else:
        if old_text == "":
            "insert"
        else:
            if new_text == "":
                "delete"
            else:
                "replace"

fn summarize_edit(old_text: text, new_text: text) -> EditSummary:
    EditSummary.create(
        diff_kind(old_text, new_text),
        new_text.len() - old_text.len(),
        count_lines(new_text) - count_lines(old_text),
        end_point(new_text).column - end_point(old_text).column
    )

fn apply_text_edit(source: text, start_byte: i64, end_byte: i64, replacement: text) -> text:
    source.substring(0, start_byte) + replacement + source.substring(end_byte, source.len())

fn make_edit(old_text: text, new_text: text) -> InputEdit:
    var changed_prefix = 0
    val old_len = old_text.len()
    val new_len = new_text.len()
    val shared_len = if old_len < new_len: old_len else: new_len
    while changed_prefix < shared_len and old_text.substring(changed_prefix, changed_prefix + 1) == new_text.substring(changed_prefix, changed_prefix + 1):
        changed_prefix = changed_prefix + 1

    var old_suffix = old_len
    var new_suffix = new_len
    while old_suffix > changed_prefix and new_suffix > changed_prefix and old_text.substring(old_suffix - 1, old_suffix) == new_text.substring(new_suffix - 1, new_suffix):
        old_suffix = old_suffix - 1
        new_suffix = new_suffix - 1

    val before = old_text.substring(0, changed_prefix)
    val old_changed = old_text.substring(0, old_suffix)
    val new_changed = new_text.substring(0, new_suffix)
    InputEdit.create(
        changed_prefix,
        old_suffix,
        new_suffix,
        end_point(before),
        end_point(old_changed),
        end_point(new_changed)
    )

describe "TreeSitter Point":
    it "creates point":
        val point = Point.create(3, 7)
        check(point.line == 3)
        check(point.column == 7)

    it "compares points on same line":
        val left = Point.create(4, 1)
        val right = Point.create(4, 9)
        check(left.compare(right) < 0)

    it "compares points on different lines":
        val earlier = Point.create(2, 5)
        val later = Point.create(3, 1)
        check(earlier.compare(later) < 0)

    it "checks point equality":
        val left = Point.create(6, 2)
        val right = Point.create(6, 2)
        check(left.compare(right) == 0)

    it "compare returns negative for before":
        check(Point.create(1, 0).compare(Point.create(1, 1)) < 0)

    it "compare returns positive for after":
        check(Point.create(1, 1).compare(Point.create(1, 0)) > 0)

    it "compare returns zero for equal":
        check(Point.create(8, 4).compare(Point.create(8, 4)) == 0)

describe "TreeSitter InputEdit":
    it "creates InputEdit":
        val edit = InputEdit.create(2, 5, 7, Point.create(1, 2), Point.create(1, 5), Point.create(1, 7))
        check(edit.start_byte == 2)
        check(edit.end_byte == 5)
        check(edit.new_end_byte == 7)

    it "checks if edit affects span":
        val edit = InputEdit.create(2, 5, 7, Point.create(1, 2), Point.create(1, 5), Point.create(1, 7))
        check(edit.affects_byte(3))
        check(edit.affects_point(Point.create(1, 3)))

    it "edit does not affect span before":
        val edit = InputEdit.create(10, 15, 12, Point.create(2, 0), Point.create(2, 5), Point.create(2, 2))
        check(not edit.affects_byte(4))
        check(not edit.affects_point(Point.create(1, 9)))

describe "TreeSitter Edit Byte Adjustment":
    it "does not adjust byte before edit":
        val edit = make_edit("abcdef", "abXYef")
        check(apply_byte_edit(1, edit) == 1)

    it "maps byte inside edit to start":
        val edit = make_edit("abcdef", "abXYef")
        check(apply_byte_edit(3, edit) == 2)

    it "shifts byte after edit by delta":
        val edit = make_edit("abcdef", "abXYef")
        check(apply_byte_edit(5, edit) == 5)

describe "TreeSitter Edit Point Adjustment":
    it "does not adjust point before edit":
        val edit = InputEdit.create(4, 8, 6, Point.create(2, 2), Point.create(2, 6), Point.create(2, 4))
        val point = Point.create(1, 9)
        val adjusted = apply_point_edit(point, edit)
        check(adjusted.line == 1)
        check(adjusted.column == 9)

    it "maps point inside edit to start":
        val edit = InputEdit.create(4, 8, 6, Point.create(2, 2), Point.create(2, 6), Point.create(2, 4))
        val point = Point.create(2, 4)
        val adjusted = apply_point_edit(point, edit)
        check(adjusted.line == 2)
        check(adjusted.column == 2)

describe "TreeSitter Compute Edits":
    it "returns empty for identical texts":
        val summary = summarize_edit("abc", "abc")
        check(summary.kind == "equal")
        check(summary.byte_delta == 0)

    it "detects insertion":
        val summary = summarize_edit("abc", "abXYZc")
        check(summary.kind == "replace")
        check(summary.byte_delta == 3)

    it "detects deletion":
        val summary = summarize_edit("abXYZc", "abc")
        check(summary.kind == "replace")
        check(summary.byte_delta == -3)

    it "detects replacement":
        val summary = summarize_edit("abc", "axc")
        check(summary.kind == "replace")

    it "handles empty old text":
        val summary = summarize_edit("", "hello")
        check(summary.kind == "insert")
        check(summary.byte_delta == 5)

    it "handles empty new text":
        val summary = summarize_edit("hello", "")
        check(summary.kind == "delete")
        check(summary.byte_delta == -5)

describe "TreeSitter Diff Operations":
    it "creates Equal operation":
        check(diff_kind("same", "same") == "equal")

    it "creates Delete operation":
        check(diff_kind("gone", "") == "delete")

    it "creates Insert operation":
        check(diff_kind("", "new") == "insert")

describe "TreeSitter Line Counting":
    it "counts single line":
        check(count_lines("abc") == 1)

    it "counts multiple lines":
        check(count_lines("a\nb\nc") == 3)

    it "counts empty string as one line":
        check(count_lines("") == 1)

    it "counts trailing newline":
        check(count_lines("a\n") == 2)

describe "TreeSitter End Point":
    it "computes end point of empty string":
        val point = end_point("")
        check(point.line == 1)
        check(point.column == 0)

    it "computes end point of single line":
        val point = end_point("hello")
        check(point.line == 1)
        check(point.column == 5)

    it "computes end point of multiple lines":
        val point = end_point("ab\ncde")
        check(point.line == 2)
        check(point.column == 3)

describe "TreeSitter Incremental Parsing":
    it "parses after simple edit":
        val source = "alpha beta"
        val updated = apply_text_edit(source, 6, 10, "gamma")
        val summary = summarize_edit(source, updated)
        check(updated == "alpha gamma")
        check(summary.kind == "replace")

    it "parses after insertion":
        val source = "abcdef"
        val updated = apply_text_edit(source, 3, 3, "XYZ")
        val summary = summarize_edit(source, updated)
        check(updated == "abcXYZdef")
        check(summary.kind == "insert" or summary.kind == "replace")

    it "parses after deletion":
        val source = "abcXYZdef"
        val updated = apply_text_edit(source, 3, 6, "")
        val summary = summarize_edit(source, updated)
        check(updated == "abcdef")
        check(summary.kind == "delete" or summary.kind == "replace")

describe "TreeSitter Multi-Line Edits":
    it "handles multi-line insertion":
        val source = "one\ntwo"
        val updated = apply_text_edit(source, 4, 4, "\nthree")
        check(updated == "one\n\nthreetwo")
        check(count_lines(updated) == 3)

    it "handles multi-line deletion":
        val source = "one\ntwo\nthree"
        val updated = apply_text_edit(source, 4, 8, "")
        check(updated == "one\nthree")
        check(count_lines(updated) == 2)

    it "handles mixed edits":
        val source = "a\nb\nc"
        val updated = apply_text_edit(source, 2, 3, "X\nY")
        check(count_lines(updated) == 4)
        check(updated.contains("X"))
        check(updated.contains("Y"))

describe "TreeSitter Edit Performance":
    it "handles large identical texts quickly":
        val text = "x" * 1000
        val summary = summarize_edit(text, text)
        check(summary.kind == "equal")
        check(summary.byte_delta == 0)

    it "handles single character change in large text":
        val old_text = "x" * 500 + "a" + "x" * 500
        val new_text = "x" * 500 + "b" + "x" * 500
        val summary = summarize_edit(old_text, new_text)
        check(summary.kind == "replace")
        check(summary.byte_delta == 0)
