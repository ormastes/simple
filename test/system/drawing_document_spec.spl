# drawing_document_spec
#
# Tests DrawingDocument from std.common.drawing.document
# Verifies layer management, blend modes, and default properties.

use std.spec
use std.common.drawing.document.{DrawingDocument, DrawingLayer, BlendMode}

describe "DrawingDocument — new document":

    it "new document has 1 layer":
        val doc = DrawingDocument.new(800, 600)
        expect(doc.layer_count()).to_equal(1)

    it "default layer is named Background":
        val doc = DrawingDocument.new(800, 600)
        val layer = doc.active_layer()
        expect(layer.name).to_equal("Background")

describe "DrawingDocument — add and remove layers":

    it "add layer increases count":
        var doc = DrawingDocument.new(800, 600)
        val layer = DrawingLayer.new_raster("Layer 1", 800, 600)
        doc.add_layer(layer)
        expect(doc.layer_count()).to_equal(2)

    it "remove layer decreases count":
        var doc = DrawingDocument.new(800, 600)
        val layer = DrawingLayer.new_raster("Layer 1", 800, 600)
        doc.add_layer(layer)
        doc.remove_layer(1)
        expect(doc.layer_count()).to_equal(1)

    it "active layer index is valid":
        val doc = DrawingDocument.new(800, 600)
        expect(doc.active_layer_index >= 0).to_equal(true)
        expect(doc.active_layer_index < doc.layer_count()).to_equal(true)

describe "DrawingLayer — default properties":

    it "new raster layer is visible":
        val layer = DrawingLayer.new_raster("Test", 100, 100)
        expect(layer.visible).to_equal(true)

    it "new raster layer is not locked":
        val layer = DrawingLayer.new_raster("Test", 100, 100)
        expect(layer.locked).to_equal(false)

    it "new raster layer has opacity 1.0":
        val layer = DrawingLayer.new_raster("Test", 100, 100)
        expect(layer.opacity > 0.99).to_equal(true)
        expect(layer.opacity < 1.01).to_equal(true)

    it "new raster layer has Normal blend mode":
        val layer = DrawingLayer.new_raster("Test", 100, 100)
        expect(layer.blend_mode.to_text()).to_equal("Normal")

describe "BlendMode — to_text":

    it "Normal returns correct string":
        val mode = BlendMode.Normal
        expect(mode.to_text()).to_equal("Normal")

    it "Multiply returns correct string":
        val mode = BlendMode.Multiply
        expect(mode.to_text()).to_equal("Multiply")

    it "Screen returns correct string":
        val mode = BlendMode.Screen
        expect(mode.to_text()).to_equal("Screen")
