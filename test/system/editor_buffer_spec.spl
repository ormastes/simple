# editor_buffer_spec
#
# Phase 1: Editor buffer infrastructure.
# Verifies piece table, undo/redo, buffer operations,
# cursor movement, and command dispatch.

use std.spec

extern fn rt_file_read_text(path: text) -> text

fn read_text(path: text) -> text:
    rt_file_read_text(path) ?? ""

describe "editor types — core structs":

    it "defines EditorBufferId with value field":
        val src = read_text("src/lib/editor/00.common/types.spl")
        expect(src.contains("class EditorBufferId:")).to_equal(true)
        expect(src.contains("value: i64")).to_equal(true)

    it "defines EditorMode enum with Normal/Insert/Command":
        val src = read_text("src/lib/editor/00.common/types.spl")
        expect(src.contains("enum EditorMode:")).to_equal(true)
        expect(src.contains("Normal")).to_equal(true)
        expect(src.contains("Insert")).to_equal(true)
        expect(src.contains("Command")).to_equal(true)

    it "defines EditorCursor with row and col":
        val src = read_text("src/lib/editor/00.common/types.spl")
        expect(src.contains("struct EditorCursor:")).to_equal(true)
        expect(src.contains("row: i64")).to_equal(true)
        expect(src.contains("col: i64")).to_equal(true)

    it "defines EditorViewport with top_row, width, height":
        val src = read_text("src/lib/editor/00.common/types.spl")
        expect(src.contains("struct EditorViewport:")).to_equal(true)
        expect(src.contains("top_row: i64")).to_equal(true)
        expect(src.contains("width: i64")).to_equal(true)
        expect(src.contains("height: i64")).to_equal(true)

    it "defines EditCommand with name, payload, count":
        val src = read_text("src/lib/editor/00.common/types.spl")
        expect(src.contains("struct EditCommand:")).to_equal(true)
        expect(src.contains("name: text")).to_equal(true)
        expect(src.contains("payload: text")).to_equal(true)
        expect(src.contains("count: i64")).to_equal(true)

    it "defines EditResult with ok, message, quit":
        val src = read_text("src/lib/editor/00.common/types.spl")
        expect(src.contains("struct EditResult:")).to_equal(true)
        expect(src.contains("ok: bool")).to_equal(true)
        expect(src.contains("message: text")).to_equal(true)
        expect(src.contains("quit: bool")).to_equal(true)

    it "provides editor_clamp utility":
        val src = read_text("src/lib/editor/00.common/types.spl")
        expect(src.contains("fn editor_clamp(value: i64, low: i64, high: i64) -> i64")).to_equal(true)

describe "editor piece table — structure":

    it "defines EditorPiece with source, start, length":
        val src = read_text("src/lib/editor/10.buffer/piece_table.spl")
        expect(src.contains("struct EditorPiece:")).to_equal(true)
        expect(src.contains("source: text")).to_equal(true)
        expect(src.contains("start: i64")).to_equal(true)
        expect(src.contains("length: i64")).to_equal(true)

    it "defines EditorPieceTable class":
        val src = read_text("src/lib/editor/10.buffer/piece_table.spl")
        expect(src.contains("class EditorPieceTable:")).to_equal(true)
        expect(src.contains("original: text")).to_equal(true)
        expect(src.contains("add_buffer: text")).to_equal(true)
        expect(src.contains("pieces: [EditorPiece]")).to_equal(true)

    it "has from_text static constructor":
        val src = read_text("src/lib/editor/10.buffer/piece_table.spl")
        expect(src.contains("static fn from_text(content: text) -> EditorPieceTable")).to_equal(true)

    it "has len, to_text, insert, delete methods":
        val src = read_text("src/lib/editor/10.buffer/piece_table.spl")
        expect(src.contains("fn len() -> i64")).to_equal(true)
        expect(src.contains("fn to_text() -> text")).to_equal(true)
        expect(src.contains("me insert(offset: i64, content: text)")).to_equal(true)
        expect(src.contains("me delete(start: i64, end: i64)")).to_equal(true)

    it "has line_count, line_at, line_starts methods":
        val src = read_text("src/lib/editor/10.buffer/piece_table.spl")
        expect(src.contains("fn line_count() -> i64")).to_equal(true)
        expect(src.contains("fn line_at(row: i64) -> text")).to_equal(true)
        expect(src.contains("fn line_starts() -> [i64]")).to_equal(true)

describe "editor piece table — internals":

    it "uses _pt_slice for piece content extraction":
        val src = read_text("src/lib/editor/10.buffer/piece_table.spl")
        expect(src.contains("fn _pt_slice(table: EditorPieceTable, piece: EditorPiece) -> text")).to_equal(true)

    it "has _pt_insert_piece for piece splitting":
        val src = read_text("src/lib/editor/10.buffer/piece_table.spl")
        expect(src.contains("fn _pt_insert_piece(pieces: [EditorPiece], offset: i64, inserted: EditorPiece) -> [EditorPiece]")).to_equal(true)

    it "has _pt_delete_range for range removal":
        val src = read_text("src/lib/editor/10.buffer/piece_table.spl")
        expect(src.contains("fn _pt_delete_range(pieces: [EditorPiece], start: i64, end: i64) -> [EditorPiece]")).to_equal(true)

    it "has _pt_compute_line_starts for newline tracking":
        val src = read_text("src/lib/editor/10.buffer/piece_table.spl")
        expect(src.contains("fn _pt_compute_line_starts(content: text) -> [i64]")).to_equal(true)

    it "provides pt_row_col_to_offset and pt_offset_to_cursor":
        val src = read_text("src/lib/editor/10.buffer/piece_table.spl")
        expect(src.contains("fn pt_row_col_to_offset(line_starts: [i64], row: i64, col: i64) -> i64")).to_equal(true)
        expect(src.contains("fn pt_offset_to_cursor(line_starts: [i64], offset: i64) -> EditorCursor")).to_equal(true)

    it "provides pt_line_length utility":
        val src = read_text("src/lib/editor/10.buffer/piece_table.spl")
        expect(src.contains("fn pt_line_length(content: text, line_starts: [i64], row: i64) -> i64")).to_equal(true)

describe "editor undo — stack operations":

    it "defines UndoEntry with content, cursor_row, cursor_col":
        val src = read_text("src/lib/editor/10.buffer/undo.spl")
        expect(src.contains("struct UndoEntry:")).to_equal(true)
        expect(src.contains("content: text")).to_equal(true)
        expect(src.contains("cursor_row: i64")).to_equal(true)
        expect(src.contains("cursor_col: i64")).to_equal(true)

    it "defines UndoStack class with undo and redo lists":
        val src = read_text("src/lib/editor/10.buffer/undo.spl")
        expect(src.contains("class UndoStack:")).to_equal(true)
        expect(src.contains("undo_entries: [UndoEntry]")).to_equal(true)
        expect(src.contains("redo_entries: [UndoEntry]")).to_equal(true)
        expect(src.contains("max_depth: i64")).to_equal(true)

    it "has push, can_undo, can_redo, undo, redo methods":
        val src = read_text("src/lib/editor/10.buffer/undo.spl")
        expect(src.contains("me push(content: text, cursor_row: i64, cursor_col: i64)")).to_equal(true)
        expect(src.contains("fn can_undo() -> bool")).to_equal(true)
        expect(src.contains("fn can_redo() -> bool")).to_equal(true)
        expect(src.contains("me undo(current_content: text, current_row: i64, current_col: i64) -> UndoEntry")).to_equal(true)
        expect(src.contains("me redo(current_content: text, current_row: i64, current_col: i64) -> UndoEntry")).to_equal(true)

    it "clears redo on push":
        val src = read_text("src/lib/editor/10.buffer/undo.spl")
        expect(src.contains("self.redo_entries = []")).to_equal(true)

    it "trims undo stack beyond max_depth":
        val src = read_text("src/lib/editor/10.buffer/undo.spl")
        expect(src.contains("self.undo_entries.len() > self.max_depth")).to_equal(true)
        expect(src.contains("_undo_trim")).to_equal(true)

describe "editor buffer — wrapper":

    it "defines EditorBuffer class with piece_table and undo_stack":
        val src = read_text("src/lib/editor/10.buffer/buffer.spl")
        expect(src.contains("class EditorBuffer:")).to_equal(true)
        expect(src.contains("piece_table: EditorPieceTable")).to_equal(true)
        expect(src.contains("undo_stack: UndoStack")).to_equal(true)
        expect(src.contains("dirty: bool")).to_equal(true)

    it "has from_text and from_file constructors":
        val src = read_text("src/lib/editor/10.buffer/buffer.spl")
        expect(src.contains("static fn from_text(id: EditorBufferId, content: text) -> EditorBuffer")).to_equal(true)
        expect(src.contains("static fn from_file(id: EditorBufferId, path: text) -> EditorBuffer")).to_equal(true)

    it "has insert_at_cursor and delete_before_cursor":
        val src = read_text("src/lib/editor/10.buffer/buffer.spl")
        expect(src.contains("me insert_at_cursor(content: text)")).to_equal(true)
        expect(src.contains("me delete_before_cursor()")).to_equal(true)
        expect(src.contains("me delete_at_cursor()")).to_equal(true)

    it "has cursor movement methods":
        val src = read_text("src/lib/editor/10.buffer/buffer.spl")
        expect(src.contains("me move_cursor(row: i64, col: i64)")).to_equal(true)
        expect(src.contains("me move_relative(delta_row: i64, delta_col: i64)")).to_equal(true)
        expect(src.contains("me move_to_line_start()")).to_equal(true)
        expect(src.contains("me move_to_line_end()")).to_equal(true)

    it "has undo and redo delegating to UndoStack":
        val src = read_text("src/lib/editor/10.buffer/buffer.spl")
        expect(src.contains("me undo()")).to_equal(true)
        expect(src.contains("me redo()")).to_equal(true)
        expect(src.contains("self.undo_stack.can_undo()")).to_equal(true)
        expect(src.contains("self.undo_stack.can_redo()")).to_equal(true)

    it "has save and save_as for file persistence":
        val src = read_text("src/lib/editor/10.buffer/buffer.spl")
        expect(src.contains("me save() -> bool")).to_equal(true)
        expect(src.contains("me save_as(path: text) -> bool")).to_equal(true)
        expect(src.contains("rt_file_write_text")).to_equal(true)

    it "pushes undo snapshot before mutations":
        val src = read_text("src/lib/editor/10.buffer/buffer.spl")
        expect(src.contains("self.undo_stack.push(self.to_text(), self.cursor_row, self.cursor_col)")).to_equal(true)

    it "tracks dirty flag on edits":
        val src = read_text("src/lib/editor/10.buffer/buffer.spl")
        expect(src.contains("self.dirty = true")).to_equal(true)
        expect(src.contains("self.dirty = false")).to_equal(true)

    it "ensures cursor visible within viewport":
        val src = read_text("src/lib/editor/10.buffer/buffer.spl")
        expect(src.contains("me ensure_cursor_visible()")).to_equal(true)
        expect(src.contains("self.viewport.top_row = self.cursor_row")).to_equal(true)

describe "editor commands — dispatch":

    it "defines editor_dispatch function":
        val src = read_text("src/app/editor/commands.spl")
        expect(src.contains("fn editor_dispatch(buffer: EditorBuffer, cmd: EditCommand) -> EditResult")).to_equal(true)

    it "handles movement commands (left/right/up/down)":
        val src = read_text("src/app/editor/commands.spl")
        expect(src.contains("\"move-left\"")).to_equal(true)
        expect(src.contains("\"move-right\"")).to_equal(true)
        expect(src.contains("\"move-up\"")).to_equal(true)
        expect(src.contains("\"move-down\"")).to_equal(true)

    it "handles editing commands (insert/backspace/delete)":
        val src = read_text("src/app/editor/commands.spl")
        expect(src.contains("\"insert-text\"")).to_equal(true)
        expect(src.contains("\"backspace\"")).to_equal(true)
        expect(src.contains("\"delete\"")).to_equal(true)
        expect(src.contains("\"newline\"")).to_equal(true)

    it "handles undo and redo commands":
        val src = read_text("src/app/editor/commands.spl")
        expect(src.contains("\"undo\"")).to_equal(true)
        expect(src.contains("\"redo\"")).to_equal(true)

    it "handles save and quit commands":
        val src = read_text("src/app/editor/commands.spl")
        expect(src.contains("\"save\"")).to_equal(true)
        expect(src.contains("\"quit\"")).to_equal(true)

    it "parses commandline inputs":
        val src = read_text("src/app/editor/commands.spl")
        expect(src.contains("fn editor_parse_commandline(line: text) -> EditCommand")).to_equal(true)
        expect(src.contains("trimmed == \"w\"")).to_equal(true)
        expect(src.contains("trimmed == \"q\"")).to_equal(true)
        expect(src.contains("trimmed == \"q!\"")).to_equal(true)

describe "editor TUI shell — rendering":

    it "defines editor_tui_run entry point":
        val src = read_text("src/app/editor/tui_shell.spl")
        expect(src.contains("fn editor_tui_run(buffer: EditorBuffer)")).to_equal(true)

    it "enters and exits alt screen and raw mode":
        val src = read_text("src/app/editor/tui_shell.spl")
        expect(src.contains("terminal_enter_alt_screen()")).to_equal(true)
        expect(src.contains("terminal_exit_alt_screen()")).to_equal(true)
        expect(src.contains("terminal_enter_raw_mode()")).to_equal(true)
        expect(src.contains("terminal_exit_raw_mode()")).to_equal(true)

    it "renders line numbers and editor content":
        val src = read_text("src/app/editor/tui_shell.spl")
        expect(src.contains("buffer.line_at(file_row)")).to_equal(true)
        expect(src.contains("str(file_row + 1)")).to_equal(true)

    it "renders status bar with mode, path, position":
        val src = read_text("src/app/editor/tui_shell.spl")
        expect(src.contains("editor_mode_name(mode)")).to_equal(true)
        expect(src.contains("buffer.path")).to_equal(true)
        expect(src.contains("buffer.cursor_row + 1")).to_equal(true)

    it "handles normal mode keys (h/j/k/l/i/q)":
        val src = read_text("src/app/editor/tui_shell.spl")
        expect(src.contains("fn _tui_handle_normal_key(buffer: EditorBuffer, key: text) -> NormalKeyResult")).to_equal(true)
        expect(src.contains("key == \"h\"")).to_equal(true)
        expect(src.contains("key == \"j\"")).to_equal(true)
        expect(src.contains("key == \"i\"")).to_equal(true)

    it "handles insert mode with ESC to exit":
        val src = read_text("src/app/editor/tui_shell.spl")
        expect(src.contains("fn _tui_handle_insert_key(buffer: EditorBuffer, key: text) -> InsertKeyResult")).to_equal(true)
        expect(src.contains("exit_insert: true")).to_equal(true)

    it "handles command mode with enter to execute":
        val src = read_text("src/app/editor/tui_shell.spl")
        expect(src.contains("fn _tui_handle_command_key(key: text, commandline: text) -> CommandKeyResult")).to_equal(true)
        expect(src.contains("done: true")).to_equal(true)

describe "editor main — entry point":

    it "defines main function":
        val src = read_text("src/app/editor/main.spl")
        expect(src.contains("fn main()")).to_equal(true)

    it "reads command line args for file path":
        val src = read_text("src/app/editor/main.spl")
        expect(src.contains("rt_args()")).to_equal(true)
        expect(src.contains("args.len() > 1")).to_equal(true)

    it "creates buffer from file or empty":
        val src = read_text("src/app/editor/main.spl")
        expect(src.contains("EditorBuffer.from_text")).to_equal(true)
        expect(src.contains("EditorBuffer.from_file")).to_equal(true)

    it "calls editor_tui_run":
        val src = read_text("src/app/editor/main.spl")
        expect(src.contains("editor_tui_run(buffer)")).to_equal(true)
