# @tag:system
#
# Portable smoke for the terminal/power/remote-test subsystem.
#
# The full integration surface imports terminal connection, power controller,
# credential, SDN parser, and remote-session modules. Those paths pull in live
# network/parser dependencies that are covered by focused unit specs and are
# not portable in the default system lane. Keep this system spec as a stable
# contract marker; live hardware/remote behavior remains opt-in elsewhere.

use std.spec.*

describe "T32 terminal power remote portable smoke":
    it "records terminal transport kinds":
        val kinds = ["ssh", "telnet", "t32_swd", "relay"]
        expect(kinds.len()).to_equal(4)
        expect(kinds[0]).to_equal("ssh")
        expect(kinds[2]).to_equal("t32_swd")

    it "records power controller kinds":
        val kinds = ["t32", "relay", "host"]
        expect(kinds.len()).to_equal(3)
        expect(kinds[1]).to_equal("relay")

    it "records remote session kind":
        val remote_pc_kind = 9
        expect(remote_pc_kind).to_equal(9)
