# @cover src/hardware/rv64gc/top/rv64_soc.spl 60%
"""
# RV64GC Processor System Tests

**Feature IDs:** #RV64GC-SYS-001
**Category:** Hardware
**Difficulty:** 4/5
**Status:** In Progress

## Overview

Comprehensive BDD system tests for the RV64GC processor.
Tests instruction decode, 64-bit ALU, W-variant ALU, M/A/F/D/C extensions,
CSR operations, Sv39 MMU, privilege modes, pipeline hazards, FP CSR, and SMP.
"""

# @req REQ-RV64GC
# @feature rv64gc
# tag: only-compiled, vhdl, slow

import std.spec

use hardware.rv64gc.core.rv64_decode.*
use hardware.rv64gc.core.rv64_execute.*
use hardware.rv64gc.core.rv64_compressed.{is_compressed, decompress_rvc}
use hardware.rv64gc.core.rv64_csr.Rv64CsrFile
use hardware.rv64gc.core.rv64_pipeline_ctrl.*
use hardware.rv64gc.core.rv64_privilege.*
use hardware.rv64gc.core.rv64_mmu.*
use hardware.rv64gc.ext.rv64_muldiv.{muldiv_execute, muldiv_w_execute}
use hardware.rv64gc.ext.rv64_atomics.{ReservationSet, AmoOp, amo_execute}
use hardware.rv64gc.ext.rv64_float_s.*
use hardware.rv64gc.ext.rv64_float_d.*
use hardware.rv64gc.ext.rv64_float_csr.Rv64FpCsr
use hardware.rv64gc.smp.rv64_smp.*
use hardware.rv64gc.pkg.rv64_types_pkg.*
use hardware.rv64gc.pkg.rv64_isa_pkg.*

# ============================================================================
# Inline Model: CSR File (lightweight test model)
# ============================================================================

class _CsrFile:
    regs: Map<i64, i64>

    static fn create() -> _CsrFile:
        var regs = Map<i64, i64>()
        # misa: RV64GC — bit 6 (C), bit 3 (D), bit 5 (F), bit 8 (I), bit 12 (M), bit 0 (A)
        # MXL = 2 (64-bit) in bits [63:62]
        regs.set(CSR_MISA, 0x8000000000141169)
        _CsrFile(regs: regs)

    fn read(addr: i64) -> i64:
        self.regs.get(addr) ?? 0

    me write(addr: i64, value: i64):
        self.regs.set(addr, value)

    me csrrw(addr: i64, value: i64) -> i64:
        val old = self.read(addr)
        self.write(addr, value)
        old

    me csrrs(addr: i64, mask: i64) -> i64:
        val old = self.read(addr)
        self.write(addr, old or mask)
        old

    me csrrc(addr: i64, mask: i64) -> i64:
        val old = self.read(addr)
        self.write(addr, old and (mask xor 0xFFFFFFFFFFFFFFFF))
        old

    me trap_enter(cause: i64, epc: i64, tval: i64):
        self.write(CSR_MEPC, epc)
        self.write(CSR_MCAUSE, cause)
        self.write(CSR_MTVAL, tval)
        # Save MIE to MPIE, clear MIE
        val mstatus = self.read(CSR_MSTATUS)
        val mie_bit = (mstatus >> 3) and 1
        var new_mstatus = mstatus and (0x8 xor 0xFFFFFFFFFFFFFFFF)  # clear MIE
        new_mstatus = new_mstatus or (mie_bit << 7)  # set MPIE
        self.write(CSR_MSTATUS, new_mstatus)

    fn trap_vector() -> i64:
        self.read(CSR_MTVEC)

    me trap_return() -> i64:
        # Restore MIE from MPIE
        val mstatus = self.read(CSR_MSTATUS)
        val mpie_bit = (mstatus >> 7) and 1
        var new_mstatus = mstatus or (mpie_bit << 3)
        self.write(CSR_MSTATUS, new_mstatus)
        self.read(CSR_MEPC)

# ============================================================================
# Inline Model: Sv39 MMU (lightweight 3-level page walk)
# ============================================================================

class _Sv39Mmu:
    page_tables: Map<i64, i64>

    static fn create() -> _Sv39Mmu:
        _Sv39Mmu(page_tables: Map<i64, i64>())

    me set_pte(addr: i64, pte: i64):
        self.page_tables.set(addr, pte)

    fn read_pte(addr: i64) -> i64:
        self.page_tables.get(addr) ?? 0

    fn extract_vpn(vaddr: i64, level: i64) -> i64:
        (vaddr >> (12 + level * 9)) and 0x1FF

    fn walk(root_ppn: i64, vaddr: i64) -> Result<i64, i64>:
        var ppn = root_ppn
        var level = 2
        while level >= 0:
            val vpn_i = self.extract_vpn(vaddr, level)
            val pte_addr = ppn * 4096 + vpn_i * 8
            val pte = self.read_pte(pte_addr)
            if pte and 0x1 == 0:  # V bit not set
                return Err(1)  # Page fault
            if pte and 0xE != 0:  # Leaf PTE (R/W/X set)
                if level > 0:
                    # Superpage
                    val leaf_ppn = (pte >> 10) and 0xFFFFFFFFFFF
                    val page_offset = vaddr and ((1 << (12 + level * 9)) - 1)
                    return Ok(leaf_ppn * 4096 + page_offset)
                val leaf_ppn = (pte >> 10) and 0xFFFFFFFFFFF
                val offset = vaddr and 0xFFF
                return Ok(leaf_ppn * 4096 + offset)
            # Non-leaf: follow pointer
            ppn = (pte >> 10) and 0xFFFFFFFFFFF
            level = level - 1
        Err(1)  # Page fault

# ============================================================================
# Inline Model: FP CSR (fflags, frm, fcsr)
# ============================================================================

class _FpCsr:
    fflags: i64  # 5 bits: NV, DZ, OF, UF, NX
    frm: i64     # 3 bits: rounding mode

    static fn create() -> _FpCsr:
        _FpCsr(fflags: 0, frm: 0)

    fn read_fcsr() -> i64:
        (self.frm << 5) or self.fflags

    me write_fcsr(value: i64):
        self.fflags = value and 0x1F
        self.frm = (value >> 5) and 0x7

    me accumulate(flags: i64):
        self.fflags = self.fflags or flags

    me set_frm(mode: i64):
        self.frm = mode and 0x7

# ============================================================================
# Tests
# ============================================================================

describe "RV64GC Processor":
    """
    ## Processor System Tests

    Comprehensive BDD tests covering all major RV64GC processor features:
    64-bit base integer, M/A/F/D/C extensions, Sv39 MMU, privilege modes, and SMP.
    """

    # ========================================================================
    # Instruction Decode
    # ========================================================================

    context "instruction decode":
        """
        ### Instruction Decoding

        Verifies correct extraction of instruction fields
        for all RV64GC instruction formats (including 64-bit extensions).
        """

        it "OPCODE: extracts opcode from ADDI":
            """
            **Given:** Instruction 0x00A00513 (ADDI x10, x0, 10)
            **When:** Decoding opcode field
            **Then:** Returns OP_IMM (0x13)
            """
            val instr = 0x00A00513
            expect(decode_opcode(instr)).to_equal(OP_OP_IMM)

        it "RD: extracts destination register":
            val instr = 0x00A00513  # ADDI x10, x0, 10
            expect(decode_rd(instr)).to_equal(10)

        it "RS1: extracts source register 1":
            val instr = 0x00A00513  # ADDI x10, x0, 10
            expect(decode_rs1(instr)).to_equal(0)

        it "FUNCT3: extracts function field":
            val instr = 0x00A00513  # ADDI x10, x0, 10
            expect(decode_funct3(instr)).to_equal(0)

        it "I-TYPE: decodes I-type immediate":
            val instr = 0x00A00513  # ADDI x10, x0, 10
            expect(decode_imm_i(instr)).to_equal(10)

        it "S-TYPE: decodes S-type immediate":
            """
            **Given:** SD x5, 32(x10) — S-type encoding
            **When:** Decoding S-type immediate
            **Then:** Returns 32
            """
            val instr = 0x02553023  # SD x5, 32(x10) — funct3=011
            expect(decode_imm_s(instr)).to_equal(32)

        it "B-TYPE: decodes B-type immediate":
            """
            **Given:** BEQ x0, x0, +8
            **When:** Decoding B-type immediate
            **Then:** Returns 8 (PC-relative, even)
            """
            val instr = 0x00000463  # BEQ x0, x0, +8
            expect(decode_imm_b(instr)).to_equal(8)

        it "U-TYPE: decodes U-type immediate":
            """
            **Given:** LUI x10, 0xDEADB
            **When:** Decoding upper immediate
            **Then:** Returns 0xDEADB000
            """
            val instr = 0xDEADB537  # LUI x10, 0xDEADB
            expect(decode_imm_u(instr)).to_equal(0xDEADB000)

        it "J-TYPE: decodes J-type immediate":
            """
            **Given:** JAL x1, offset
            **When:** Decoding J-type immediate
            **Then:** Returns correct sign-extended offset
            """
            val instr = 0x008000EF  # JAL x1, +8
            expect(decode_imm_j(instr)).to_equal(8)

        it "OP-32: decodes RV64 OP-32 opcode (ADDW)":
            """
            **Given:** ADDW x10, x11, x12 (OP-32 = 0x3B)
            **When:** Decoding opcode
            **Then:** Returns OP_OP_32
            """
            val instr = 0x00C585BB  # ADDW x11, x11, x12
            expect(decode_opcode(instr)).to_equal(OP_OP_32)

    # ========================================================================
    # 64-bit ALU
    # ========================================================================

    context "64-bit ALU":
        """
        ### 64-bit ALU Operations

        Verifies full 64-bit arithmetic and logical operations.
        """

        it "ADD: 64-bit addition":
            val result = alu_execute(AluOp.Add, 0x100000000, 0x200000000)
            expect(result).to_equal(0x300000000)

        it "SUB: 64-bit subtraction":
            val result = alu_execute(AluOp.Sub, 0x300000000, 0x100000000)
            expect(result).to_equal(0x200000000)

        it "AND: 64-bit bitwise AND":
            val result = alu_execute(AluOp.And, 0xFF00FF00FF00FF00, 0x0F0F0F0F0F0F0F0F)
            expect(result).to_equal(0x0F000F000F000F00)

        it "OR: 64-bit bitwise OR":
            val result = alu_execute(AluOp.Or, 0xFF00000000000000, 0x00000000000000FF)
            expect(result).to_equal(0xFF000000000000FF)

        it "XOR: 64-bit bitwise XOR":
            val result = alu_execute(AluOp.Xor, 0xAAAAAAAAAAAAAAAA, 0x5555555555555555)
            expect(result).to_equal(0xFFFFFFFFFFFFFFFF)

        it "SLL: 64-bit shift left logical":
            val result = alu_execute(AluOp.Sll, 1, 32)
            expect(result).to_equal(0x100000000)

        it "SRL: 64-bit shift right logical":
            val result = alu_execute(AluOp.Srl, 0x100000000, 32)
            expect(result).to_equal(1)

        it "SRA: 64-bit shift right arithmetic":
            """
            **Given:** Negative 64-bit value
            **When:** Arithmetic right shift by 4
            **Then:** Sign bit is preserved
            """
            val result = alu_execute(AluOp.Sra, 0xF000000000000000, 4)
            expect(result).to_equal(0xFF00000000000000)

        it "SLT: set less than (signed 64-bit)":
            # -1 < 1 in signed comparison
            val result = alu_execute(AluOp.Slt, 0xFFFFFFFFFFFFFFFF, 1)
            expect(result).to_equal(1)

        it "SLTU: set less than unsigned (64-bit)":
            # 0xFFFFFFFFFFFFFFFF > 1 in unsigned
            val result = alu_execute(AluOp.Sltu, 1, 0xFFFFFFFFFFFFFFFF)
            expect(result).to_equal(1)

    # ========================================================================
    # W-variant ALU (32-bit ops with sign extension)
    # ========================================================================

    context "W-variant ALU":
        """
        ### W-variant ALU Operations

        RV64 *W instructions operate on the lower 32 bits
        and sign-extend the result to 64 bits.
        """

        it "ADDW: 32-bit add with sign extension":
            """
            **Given:** Two values whose 32-bit sum overflows to negative
            **When:** ADDW executed
            **Then:** Result is sign-extended 32-bit value
            """
            val result = alu_w_execute(AluOp.Add, 0x7FFFFFFF, 1)
            # 0x80000000 sign-extended to 64 bits
            expect(result).to_equal(0xFFFFFFFF80000000)

        it "SUBW: 32-bit subtract with sign extension":
            val result = alu_w_execute(AluOp.Sub, 0, 1)
            # 0xFFFFFFFF sign-extended = -1
            expect(result).to_equal(0xFFFFFFFFFFFFFFFF)

        it "SLLW: 32-bit shift left with sign extension":
            val result = alu_w_execute(AluOp.Sll, 0x40000000, 1)
            # 0x80000000 sign-extended
            expect(result).to_equal(0xFFFFFFFF80000000)

        it "SRLW: 32-bit logical right shift with sign extension":
            val result = alu_w_execute(AluOp.Srl, 0x80000000, 1)
            # 0x40000000 — positive, no sign extension needed
            expect(result).to_equal(0x40000000)

        it "SRAW: 32-bit arithmetic right shift with sign extension":
            val result = alu_w_execute(AluOp.Sra, 0x80000000, 1)
            # 0xC0000000 sign-extended
            expect(result).to_equal(0xFFFFFFFFC0000000)

        it "ADDW: positive result stays positive":
            val result = alu_w_execute(AluOp.Add, 10, 20)
            expect(result).to_equal(30)

    # ========================================================================
    # 64-bit Multiply / Divide
    # ========================================================================

    context "64-bit multiply/divide":
        """
        ### M Extension — 64-bit Multiply and Divide

        Verifies MUL, MULH, DIV, DIVU, REM for full 64-bit operands,
        plus MULW and DIVW W-variant operations.
        """

        it "MUL: 64-bit multiply low":
            expect(muldiv_execute(AluOp.Mul, 0x100000000, 3)).to_equal(0x300000000)

        it "MULH: 64-bit multiply upper (signed)":
            """
            **Given:** Two large positive 64-bit values
            **When:** MULH executed
            **Then:** Returns upper 64 bits of 128-bit product
            """
            val result = muldiv_execute(AluOp.Mulh, 0x200000000, 0x200000000)
            expect(result).to_equal(4)

        it "DIV: 64-bit signed division":
            var divisor = 3
            expect(muldiv_execute(AluOp.Div, 0x300000000, divisor)).to_equal(0x100000000)

        it "DIVU: 64-bit unsigned division by zero returns all-ones":
            """
            **Given:** DIVU with divisor = 0
            **When:** muldiv_execute called
            **Then:** Returns all-ones (0xFFFFFFFFFFFFFFFF per spec)
            """
            var divisor = 0
            expect(muldiv_execute(AluOp.Divu, 42, divisor)).to_equal(0xFFFFFFFFFFFFFFFF)

        it "REM: 64-bit signed remainder":
            var divisor = 5
            expect(muldiv_execute(AluOp.Rem, 17, divisor)).to_equal(2)

        it "MULW: 32-bit multiply with sign extension":
            val result = muldiv_w_execute(AluOp.Mul, 0x7FFFFFFF, 2)
            # 32-bit result: 0xFFFFFFFE, sign-extended
            expect(result).to_equal(0xFFFFFFFFFFFFFFFE)

        it "DIVW: 32-bit divide with sign extension":
            var divisor = 2
            val result = muldiv_w_execute(AluOp.Div, 0x80000000, divisor)
            # 0xC0000000 sign-extended
            expect(result).to_equal(0xFFFFFFFFC0000000)

    # ========================================================================
    # Atomics (A extension, 64-bit)
    # ========================================================================

    context "A extension (64-bit atomics)":
        """
        ### Atomic Operations — 64-bit

        Verifies LR.D/SC.D reservation logic and AMO.D operations.
        """

        it "LR.D/SC.D: succeeds on uncontested reservation":
            var rs = ReservationSet.create()
            rs.reserve(0x80000000)
            expect(rs.check_and_clear(0x80000000)).to_equal(true)

        it "SC.D: fails after intervening store":
            var rs = ReservationSet.create()
            rs.reserve(0x80000000)
            rs.invalidate_if_match(0x80000000)
            expect(rs.check_and_clear(0x80000000)).to_equal(false)

        it "AMOADD.D: atomic add on 64-bit value":
            """
            **Given:** Memory word = 0x100000000
            **When:** AMOADD.D with operand 0x200000000
            **Then:** Returns old value, stores sum
            """
            val result = amo_execute(AmoOp.Add, 0x100000000, 0x200000000)
            expect(result.old_value).to_equal(0x100000000)
            expect(result.new_value).to_equal(0x300000000)

        it "AMOSWAP.D: atomic swap on 64-bit value":
            val result = amo_execute(AmoOp.Swap, 0xDEADBEEFCAFEBABE, 0x1234567890ABCDEF)
            expect(result.old_value).to_equal(0xDEADBEEFCAFEBABE)
            expect(result.new_value).to_equal(0x1234567890ABCDEF)

    # ========================================================================
    # CSR Operations
    # ========================================================================

    context "CSR operations":
        """
        ### Control and Status Registers (64-bit)

        Verifies CSR read/write, atomic operations, trap entry/return,
        and misa reporting for RV64GC.
        """

        it "CSRRW: atomic read/write":
            var csr = Rv64CsrFile.create()
            csr.write(CSR_MSCRATCH, 0x123456789ABCDEF0)
            val old = csr.csrrw(CSR_MSCRATCH, 0xFEDCBA9876543210)
            expect(old).to_equal(0x123456789ABCDEF0)
            expect(csr.read(CSR_MSCRATCH)).to_equal(0xFEDCBA9876543210)

        it "CSRRS: atomic read and set bits":
            var csr = Rv64CsrFile.create()
            csr.write(CSR_MIE, 0x00)
            val old = csr.csrrs(CSR_MIE, 0x80)
            expect(old).to_equal(0x00)
            expect(csr.read(CSR_MIE)).to_equal(0x80)

        it "CSRRC: atomic read and clear bits":
            var csr = Rv64CsrFile.create()
            csr.write(CSR_MIE, 0xFF)
            val old = csr.csrrc(CSR_MIE, 0x80)
            expect(old).to_equal(0xFF)
            expect(csr.read(CSR_MIE)).to_equal(0x7F)

        it "TRAP: enters trap correctly":
            """
            **Given:** CSR file with mtvec set
            **When:** Trap with cause 11 (ECALL from M-mode)
            **Then:** mepc saved, mcause set, trap_vector returns mtvec
            """
            var csr = Rv64CsrFile.create()
            csr.write(CSR_MTVEC, 0x80000100)
            csr.trap_enter(11, 0x80001000, 0)
            expect(csr.read(CSR_MEPC)).to_equal(0x80001000)
            expect(csr.read(CSR_MCAUSE)).to_equal(11)
            expect(csr.trap_vector()).to_equal(0x80000100)

        it "MRET: returns from trap":
            """
            **Given:** CSR file in trapped state
            **When:** trap_return() called (mret)
            **Then:** Returns to mepc
            """
            var csr = Rv64CsrFile.create()
            csr.write(CSR_MSTATUS, 0x08)  # MIE=1
            csr.write(CSR_MTVEC, 0x80000100)
            csr.trap_enter(11, 0x80001000, 0)
            val return_pc = csr.trap_return()
            expect(return_pc).to_equal(0x80001000)

        it "MISA: reports RV64GC extensions":
            """
            **Given:** Fresh CSR file
            **When:** Reading misa
            **Then:** MXL=2 (64-bit) and extensions I, M, A, F, D, C set
            """
            val csr = Rv64CsrFile.create()
            val misa = csr.read(CSR_MISA)
            # MXL = 2 (bits [63:62])
            val mxl = (misa >> 62) and 0x3
            expect(mxl).to_equal(2)
            # Extension bits: I(8), M(12), A(0), F(5), D(3), C(2)
            expect((misa >> 8) and 1).to_equal(1)   # I
            expect((misa >> 12) and 1).to_equal(1)  # M
            expect(misa and 1).to_equal(1)           # A
            expect((misa >> 5) and 1).to_equal(1)   # F
            expect((misa >> 3) and 1).to_equal(1)   # D
            expect((misa >> 2) and 1).to_equal(1)   # C

    # ========================================================================
    # Compressed Extension (C)
    # ========================================================================

    context "compressed extension":
        """
        ### RVC — Compressed Instructions (16-bit)

        Verifies compressed instruction detection and decompression
        for RV64-specific compressed encodings.
        """

        it "DETECT: identifies 16-bit compressed instruction":
            """
            **Given:** A 16-bit instruction (bits [1:0] != 11)
            **When:** is_compressed() called
            **Then:** Returns true
            """
            val c_instr = 0x4501  # C.LI x10, 0
            expect(is_compressed(c_instr)).to_equal(true)

        it "C.LD: decompresses to LD":
            """
            **Given:** C.LD rd', offset(rs1') — loads 64-bit doubleword
            **When:** Decompressed
            **Then:** Returns valid 32-bit LD instruction
            """
            val c_ld = 0x6288  # C.LD — example encoding
            val decompressed = decompress_rvc(c_ld)
            expect(decode_opcode(decompressed)).to_equal(OP_LOAD)
            expect(decode_funct3(decompressed)).to_equal(F3_LD)

        it "C.SD: decompresses to SD":
            """
            **Given:** C.SD rs2', offset(rs1') — stores 64-bit doubleword
            **When:** Decompressed
            **Then:** Returns valid 32-bit SD instruction
            """
            val c_sd = 0xE288  # C.SD — example encoding
            val decompressed = decompress_rvc(c_sd)
            expect(decode_opcode(decompressed)).to_equal(OP_STORE)
            expect(decode_funct3(decompressed)).to_equal(F3_SD)

        it "C.ADDIW: decompresses to ADDIW":
            """
            **Given:** C.ADDIW rd, imm (RV64-only compressed)
            **When:** Decompressed
            **Then:** Returns valid 32-bit ADDIW instruction (OP_IMM_32)
            """
            val c_addiw = 0x2505  # C.ADDIW x10, 1
            val decompressed = decompress_rvc(c_addiw)
            expect(decode_opcode(decompressed)).to_equal(OP_OP_IMM_32)

    # ========================================================================
    # Pipeline Hazards
    # ========================================================================

    context "pipeline hazards":
        """
        ### Pipeline Hazard Handling

        Verifies correct forwarding, stalling, and flushing
        for the 64-bit pipeline.
        """

        it "LOAD-USE: detects load-use hazard":
            """
            **Given:** Load in EX stage targeting rs1 of ID stage
            **When:** detect_load_use_hazard() called
            **Then:** Returns true (pipeline must stall)
            """
            val hazard = detect_load_use_hazard(5, 0, 5, MemOp.Load, true)
            expect(hazard).to_equal(true)

        it "FORWARD: forwards from EX to ID (RAW)":
            """
            **Given:** EX stage writing to register that ID stage reads
            **When:** resolve_forward_rs1() called
            **Then:** Returns ForwardSrc.ExStage
            """
            val src = resolve_forward_rs1(5, 5, true, 0, false)
            expect(src == ForwardSrc.ExStage).to_equal(true)

        it "STALL: pipeline stalls on load-use hazard":
            val ctrl = compute_pipeline_control(true, false, false)
            expect(ctrl.stall_if).to_equal(true)
            expect(ctrl.stall_id).to_equal(true)
            expect(ctrl.flush_ex).to_equal(true)

    # ========================================================================
    # Privilege Modes
    # ========================================================================

    context "privilege modes":
        """
        ### Privilege Mode Transitions

        Verifies M/S/U mode transitions and access control.
        """

        it "MRET: transitions from M-mode to S-mode":
            """
            **Given:** Processor in M-mode, MPP set to S-mode
            **When:** mret executed
            **Then:** Privilege drops to S-mode
            """
            var priv = PrivilegeState.create(PRIV_M)
            priv.set_mpp(PRIV_S)
            val new_mode = priv.execute_mret()
            expect(new_mode).to_equal(PRIV_S)

        it "SRET: transitions from S-mode to U-mode":
            """
            **Given:** Processor in S-mode, SPP set to U-mode
            **When:** sret executed
            **Then:** Privilege drops to U-mode
            """
            var priv = PrivilegeState.create(PRIV_S)
            priv.set_spp(PRIV_U)
            val new_mode = priv.execute_sret()
            expect(new_mode).to_equal(PRIV_U)

        it "DELEGATE: trap delegation from M to S":
            """
            **Given:** medeleg bit set for cause 8 (ECALL from U-mode)
            **When:** Trap occurs with cause 8
            **Then:** Trap is delegated to S-mode handler
            """
            var priv = PrivilegeState.create(PRIV_M)
            priv.set_medeleg(1 << 8)
            val delegated = priv.is_delegated(8)
            expect(delegated).to_equal(true)

        it "ACCESS: U-mode cannot access M-mode CSR":
            """
            **Given:** Processor in U-mode
            **When:** Attempting to read M-mode CSR
            **Then:** Access check fails
            """
            val allowed = check_csr_access(CSR_MSTATUS, PRIV_U)
            expect(allowed).to_equal(false)

    # ========================================================================
    # Sv39 MMU
    # ========================================================================

    context "Sv39 MMU":
        """
        ### Sv39 Virtual Memory

        Verifies VPN extraction, 3-level page table walk,
        page faults, and superpage translation.
        """

        it "VPN: extracts VPN fields from virtual address":
            """
            **Given:** Virtual address 0x003F_FFFF_FFFF_F000
            **When:** Extracting VPN[0], VPN[1], VPN[2]
            **Then:** Each 9-bit VPN field is correct
            """
            var mmu = _Sv39Mmu.create()
            val vaddr = 0x003FFFFFFFFFF000
            expect(mmu.extract_vpn(vaddr, 0)).to_equal(0x1FF)  # VPN[0]
            expect(mmu.extract_vpn(vaddr, 1)).to_equal(0x1FF)  # VPN[1]
            expect(mmu.extract_vpn(vaddr, 2)).to_equal(0x0FF)  # VPN[2]

        it "WALK: 3-level page walk succeeds":
            """
            **Given:** Valid 3-level page table hierarchy
            **When:** Walking vaddr 0x0000_0000_0000_1000
            **Then:** Returns correct physical address
            """
            var mmu = _Sv39Mmu.create()
            val root_ppn = 0x80000
            # Level-2 PTE at root: points to level-1 table at PPN 0x80001
            val l2_pte_addr = root_ppn * 4096 + 0 * 8  # VPN[2]=0
            mmu.set_pte(l2_pte_addr, (0x80001 << 10) or 0x1)  # V=1, non-leaf
            # Level-1 PTE: points to level-0 table at PPN 0x80002
            val l1_pte_addr = 0x80001 * 4096 + 0 * 8  # VPN[1]=0
            mmu.set_pte(l1_pte_addr, (0x80002 << 10) or 0x1)  # V=1, non-leaf
            # Level-0 PTE: leaf mapping to PPN 0x90000 (R+V)
            val l0_pte_addr = 0x80002 * 4096 + 1 * 8  # VPN[0]=1
            mmu.set_pte(l0_pte_addr, (0x90000 << 10) or 0x3)  # V=1, R=1 (leaf)
            # Walk vaddr with VPN[2]=0, VPN[1]=0, VPN[0]=1, offset=0x123
            val vaddr = (0 << 30) or (0 << 21) or (1 << 12) or 0x123
            val result = mmu.walk(root_ppn, vaddr)
            match result:
                Ok(paddr): expect(paddr).to_equal(0x90000 * 4096 + 0x123)
                Err(e): expect(false).to_equal(true)  # Should not fault

        it "FAULT: invalid PTE causes page fault":
            """
            **Given:** Page table with invalid (V=0) PTE
            **When:** Walking
            **Then:** Returns page fault error
            """
            var mmu = _Sv39Mmu.create()
            val root_ppn = 0x80000
            # No PTEs set — all entries are zero (V=0)
            val result = mmu.walk(root_ppn, 0x1000)
            match result:
                Ok(paddr): expect(false).to_equal(true)  # Should fault
                Err(e): expect(e).to_equal(1)

        it "SUPERPAGE: 2 MiB superpage translation":
            """
            **Given:** Level-1 leaf PTE (2 MiB superpage)
            **When:** Walking
            **Then:** Returns physical address using superpage mapping
            """
            var mmu = _Sv39Mmu.create()
            val root_ppn = 0x80000
            # Level-2 PTE: points to level-1 table
            val l2_pte_addr = root_ppn * 4096 + 0 * 8
            mmu.set_pte(l2_pte_addr, (0x80001 << 10) or 0x1)  # V=1, non-leaf
            # Level-1 PTE: leaf (superpage) at VPN[1]=0, maps to PPN 0xA0000
            val l1_pte_addr = 0x80001 * 4096 + 0 * 8
            mmu.set_pte(l1_pte_addr, (0xA0000 << 10) or 0x3)  # V=1, R=1 (leaf)
            # Walk vaddr with VPN[0]=5, offset=0x456 (within the 2 MiB page)
            val vaddr = (0 << 30) or (0 << 21) or (5 << 12) or 0x456
            val result = mmu.walk(root_ppn, vaddr)
            match result:
                Ok(paddr):
                    # Superpage: PPN from PTE, lower bits from vaddr
                    val expected = 0xA0000 * 4096 + (5 << 12) + 0x456
                    expect(paddr).to_equal(expected)
                Err(e): expect(false).to_equal(true)

    # ========================================================================
    # Single-precision Float (F extension)
    # ========================================================================

    context "single-precision float (F)":
        """
        ### F Extension — Single-Precision Floating Point

        Verifies FADD.S, FMUL.S, FCVT, and FCLASS operations.
        """

        it "FADD.S: single-precision addition":
            """
            **Given:** 1.5f + 2.5f
            **When:** fadd_s executed
            **Then:** Returns 4.0f
            """
            val result = fadd_s(float32_from_bits(0x3FC00000), float32_from_bits(0x40200000))
            expect(float32_to_bits(result)).to_equal(0x40800000)  # 4.0f

        it "FMUL.S: single-precision multiplication":
            """
            **Given:** 3.0f * 2.0f
            **When:** fmul_s executed
            **Then:** Returns 6.0f
            """
            val result = fmul_s(float32_from_bits(0x40400000), float32_from_bits(0x40000000))
            expect(float32_to_bits(result)).to_equal(0x40C00000)  # 6.0f

        it "FCVT.W.S: float to signed integer conversion":
            """
            **Given:** 3.14f
            **When:** Converting to i32
            **Then:** Returns 3 (truncated)
            """
            val result = fcvt_w_s(float32_from_bits(0x4048F5C3))  # 3.14f
            expect(result).to_equal(3)

        it "FCLASS.S: classifies positive infinity":
            """
            **Given:** +Inf (0x7F800000)
            **When:** fclass_s executed
            **Then:** Returns bit 7 (positive infinity)
            """
            val result = fclass_s(float32_from_bits(0x7F800000))
            expect(result and (1 << 7)).to_equal(1 << 7)

    # ========================================================================
    # Double-precision Float (D extension)
    # ========================================================================

    context "double-precision float (D)":
        """
        ### D Extension — Double-Precision Floating Point

        Verifies FADD.D, FDIV.D, FCVT.D.S, and comparison operations.
        """

        it "FADD.D: double-precision addition":
            """
            **Given:** 1.5 + 2.5
            **When:** fadd_d executed
            **Then:** Returns 4.0
            """
            val result = fadd_d(float64_from_bits(0x3FF8000000000000), float64_from_bits(0x4004000000000000))
            expect(float64_to_bits(result)).to_equal(0x4010000000000000)  # 4.0

        it "FDIV.D: double-precision division":
            """
            **Given:** 10.0 / 2.0
            **When:** fdiv_d executed
            **Then:** Returns 5.0
            """
            val result = fdiv_d(float64_from_bits(0x4024000000000000), float64_from_bits(0x4000000000000000))
            expect(float64_to_bits(result)).to_equal(0x4014000000000000)  # 5.0

        it "FCVT.D.S: single to double conversion":
            """
            **Given:** 1.0f (single)
            **When:** Converting to double
            **Then:** Returns 1.0 (double)
            """
            val result = fcvt_d_s(float32_from_bits(0x3F800000))  # 1.0f
            expect(float64_to_bits(result)).to_equal(0x3FF0000000000000)  # 1.0

        it "FEQ.D: double-precision equality comparison":
            """
            **Given:** Two equal double values (2.0)
            **When:** feq_d executed
            **Then:** Returns 1 (true)
            """
            val result = feq_d(float64_from_bits(0x4000000000000000), float64_from_bits(0x4000000000000000))
            expect(result).to_equal(1)

    # ========================================================================
    # FP CSR (fflags, frm, fcsr)
    # ========================================================================

    context "floating-point CSR":
        """
        ### FP Control and Status

        Verifies fflags accumulation, frm rounding mode, and fcsr read/write.
        """

        it "FFLAGS: accumulates exception flags":
            """
            **Given:** Initial fflags = 0
            **When:** Inexact (NX=1) and overflow (OF=4) raised
            **Then:** fflags = 0x05
            """
            var fp_csr = _FpCsr.create()
            fp_csr.accumulate(0x01)  # NX (inexact)
            fp_csr.accumulate(0x04)  # OF (overflow)
            expect(fp_csr.fflags).to_equal(0x05)

        it "FRM: sets rounding mode":
            """
            **Given:** frm = 0 (RNE)
            **When:** Setting frm to 1 (RTZ)
            **Then:** frm reads as 1
            """
            var fp_csr = _FpCsr.create()
            fp_csr.set_frm(1)  # RTZ
            expect(fp_csr.frm).to_equal(1)

        it "FCSR: read/write roundtrip":
            """
            **Given:** fflags=0x03, frm=2 (RDN)
            **When:** Reading fcsr
            **Then:** Returns (frm << 5) | fflags = 0x43
            """
            var fp_csr = _FpCsr.create()
            fp_csr.write_fcsr(0x43)
            expect(fp_csr.read_fcsr()).to_equal(0x43)
            expect(fp_csr.fflags).to_equal(0x03)
            expect(fp_csr.frm).to_equal(2)

    # ========================================================================
    # SMP (Symmetric Multi-Processing)
    # ========================================================================

    context "SMP":
        """
        ### Symmetric Multi-Processing

        Verifies multi-hart initialization, inter-processor interrupts (IPI),
        and shared memory atomics.
        """

        it "HART-INIT: initializes multiple harts":
            """
            **Given:** SMP system with 4 harts
            **When:** Initializing
            **Then:** All harts exist with correct IDs
            """
            val smp = SmpState.create(4)
            expect(smp.hart_count()).to_equal(4)
            expect(smp.hart_id(0)).to_equal(0)
            expect(smp.hart_id(3)).to_equal(3)

        it "IPI: sends inter-processor interrupt via CLINT":
            """
            **Given:** Hart 0 sends IPI to hart 1
            **When:** CLINT msip[1] written
            **Then:** Hart 1 has pending software interrupt
            """
            var smp = SmpState.create(4)
            smp.send_ipi(0, 1)
            expect(smp.has_pending_ipi(1)).to_equal(true)
            expect(smp.has_pending_ipi(0)).to_equal(false)

        it "SHARED-MEMORY: atomic operation across harts":
            """
            **Given:** Shared memory location initialized to 0
            **When:** Two harts perform AMOADD.D
            **Then:** Final value reflects both additions
            """
            var smp = SmpState.create(2)
            var shared_addr = 0x80010000
            smp.write_shared(shared_addr, 0)
            smp.atomic_add(shared_addr, 100)
            smp.atomic_add(shared_addr, 200)
            expect(smp.read_shared(shared_addr)).to_equal(300)
