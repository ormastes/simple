# editor_selection_spec
#
# Tests SelectionState from std.nogc_sync_mut.editor.selection
# Verifies multi-select, deselect, clear, and primary node tracking.

use std.spec
use std.nogc_sync_mut.editor.selection.{NodeId, SelectionState}

describe "SelectionState — empty":

    it "empty selection is_empty is true":
        val sel = SelectionState.empty()
        expect(sel.is_empty()).to_equal(true)

    it "empty selection count is 0":
        val sel = SelectionState.empty()
        expect(sel.count()).to_equal(0)

describe "SelectionState — select":

    it "select node sets count to 1":
        var sel = SelectionState.empty()
        val node = NodeId(id: 1)
        sel.select(node)
        expect(sel.count()).to_equal(1)

    it "select node makes contains return true":
        var sel = SelectionState.empty()
        val node = NodeId(id: 1)
        sel.select(node)
        expect(sel.contains(node)).to_equal(true)

describe "SelectionState — add to selection":

    it "add_to_selection increases count":
        var sel = SelectionState.empty()
        val n1 = NodeId(id: 1)
        val n2 = NodeId(id: 2)
        sel.select(n1)
        sel.add_to_selection(n2)
        expect(sel.count()).to_equal(2)

describe "SelectionState — deselect":

    it "deselect decreases count":
        var sel = SelectionState.empty()
        val n1 = NodeId(id: 1)
        val n2 = NodeId(id: 2)
        sel.select(n1)
        sel.add_to_selection(n2)
        sel.deselect(n1)
        expect(sel.count()).to_equal(1)

    it "deselect makes contains return false":
        var sel = SelectionState.empty()
        val node = NodeId(id: 1)
        sel.select(node)
        sel.deselect(node)
        expect(sel.contains(node)).to_equal(false)

describe "SelectionState — clear":

    it "clear makes is_empty true":
        var sel = SelectionState.empty()
        val node = NodeId(id: 1)
        sel.select(node)
        sel.clear()
        expect(sel.is_empty()).to_equal(true)

describe "SelectionState — primary node":

    it "primary node tracks first selected":
        var sel = SelectionState.empty()
        val n1 = NodeId(id: 42)
        sel.select(n1)
        expect(sel.primary_node.id).to_equal(42)
