# command_history_spec
#
# Tests CommandHistory from std.common.command.history
# Verifies undo/redo stack, merge support, max size, and clear.

use std.spec
use std.common.command.command.{CommandEntry, CommandMeta}
use std.common.command.history.{CommandHistory}

fn make_entry(id: i64, desc: text, tool: text, before: text, after: text) -> CommandEntry:
    CommandEntry.create(id, desc, tool, before, after)

describe "CommandHistory — empty state":

    it "can_undo is false on empty history":
        val h = CommandHistory.with_defaults()
        expect(h.can_undo()).to_equal(false)

    it "can_redo is false on empty history":
        val h = CommandHistory.with_defaults()
        expect(h.can_redo()).to_equal(false)

describe "CommandHistory — push and undo":

    it "push one entry makes can_undo true":
        var h = CommandHistory.with_defaults()
        val e = make_entry(1, "draw", "brush", "before1", "after1")
        h.push(e)
        expect(h.can_undo()).to_equal(true)

    it "push one entry sets entry_count to 1":
        var h = CommandHistory.with_defaults()
        val e = make_entry(1, "draw", "brush", "before1", "after1")
        h.push(e)
        expect(h.entry_count()).to_equal(1)

    it "undo returns before_snapshot":
        var h = CommandHistory.with_defaults()
        val e = make_entry(1, "draw", "brush", "before1", "after1")
        h.push(e)
        val snap = h.undo()
        expect(snap).to_equal("before1")

    it "undo makes can_redo true":
        var h = CommandHistory.with_defaults()
        val e = make_entry(1, "draw", "brush", "before1", "after1")
        h.push(e)
        h.undo()
        expect(h.can_redo()).to_equal(true)

describe "CommandHistory — redo":

    it "redo returns after_snapshot":
        var h = CommandHistory.with_defaults()
        val e = make_entry(1, "draw", "brush", "before1", "after1")
        h.push(e)
        h.undo()
        val snap = h.redo()
        expect(snap).to_equal("after1")

describe "CommandHistory — merge":

    it "two entries with same tool and description merge into one":
        var h = CommandHistory.new(200, 300)
        val e1 = make_entry(1, "stroke", "brush", "s0", "s1")
        val e2 = make_entry(2, "stroke", "brush", "s1", "s2")
        h.push(e1)
        h.push(e2)
        expect(h.entry_count()).to_equal(1)

describe "CommandHistory — max size":

    it "count stays at max_size when exceeding limit":
        var h = CommandHistory.new(3, 0)
        var i = 0
        while i < 5:
            val e = make_entry(i, "op" + i.to_text(), "tool" + i.to_text(), "b", "a")
            h.push(e)
            i = i + 1
        expect(h.entry_count() <= 3).to_equal(true)

describe "CommandHistory — clear":

    it "after clear entry_count is 0":
        var h = CommandHistory.with_defaults()
        val e = make_entry(1, "draw", "brush", "b", "a")
        h.push(e)
        h.clear()
        expect(h.entry_count()).to_equal(0)
