#![allow(unnamed_duplicate_typed_args)]
# @tag:system
#
# System spec — TLS 1.3 System Integration (side-by-side with rustls)
#
# Starts an external tools/tls_test_server/ subprocess (rustls-based) on
# host port 4433, builds tls_system_test_entry.spl into a baremetal
# x86_64 kernel, boots it under QEMU with QEMU user-mode networking that
# forwards host port 14433 → guest port 4433, and waits for the
# [TLS HANDSHAKE COMPLETE] serial marker.
#
# The test self-spawns both the rustls server and QEMU (via
# qemu_os_harness.spawn_guest_with_qmp) and tears both down on every exit
# path — no external orchestration is required.  The regression signal is
# the [TLS HANDSHAKE COMPLETE] marker appearing on serial within 60 s.
#
# The rustls server binary is expected at:
#   tools/tls_test_server/tls_test_server
# Build it separately before running this spec if it is not already present.

use std.spec.*

use os.qemu_runner.{OsTarget, build_os}
use os.kernel.arch.arch_context.{Architecture}

use test.qemu.os.common.qemu_os_harness.{
    QemuGuestHandle, can_run_target, file_exists, spawn_guest_with_qmp,
    stop_guest, wait_for_serial_marker}

extern fn rt_process_spawn_async(cmd: text, args: [text]) -> i64
extern fn rt_process_kill(pid: i64) -> bool
extern fn rt_process_wait(pid: i64, timeout_ms: i64) -> i64
extern fn rt_thread_sleep(ms: i64)

# ===========================================================================
# Helpers
# ===========================================================================

fn _tls_system_target() -> OsTarget:
    OsTarget(
        arch: Architecture.X86_64,
        entry: "examples/simple_os/arch/x86_64/tls_system_test_entry.spl",
        linker_script: "examples/simple_os/arch/x86_64/linker.ld",
        target_triple: "x86_64-unknown-none",
        output: "build/os/simpleos_tls_system_x86_64.elf",
        qemu_system: "qemu-system-x86_64",
        qemu_machine: "q35",
        qemu_cpu: "qemu64",
        qemu_memory: "2G",
        qemu_bios: "",
        qemu_extra: [
            "-vga", "std",
            "-device", "isa-debug-exit,iobase=0xf4,iosize=0x04",
            "-netdev", "user,id=net0,hostfwd=tcp::14433-:4433",
            "-device", "virtio-net-pci,netdev=net0"
        ],
        gui_mode: false
    )

fn _kill_server(server_pid: i64):
    if server_pid > 0:
        rt_process_kill(server_pid)
        rt_process_wait(server_pid, 2000)

fn _tls_server_bin() -> text:
    val direct = "tools/tls_test_server/tls_test_server"
    if file_exists(direct):
        return direct
    val cargo_debug = "tools/tls_test_server/target/debug/tls_test_server"
    if file_exists(cargo_debug):
        return cargo_debug
    direct

# ===========================================================================
# Spec
# ===========================================================================

describe "TLS 1.3 System Integration (side-by-side with rustls)":

    it "builds tls_system_test_entry.spl into a baremetal kernel":
        val target = _tls_system_target()
        val ok = build_os(target)
        expect(ok).to_equal(true)
        expect(file_exists(target.output)).to_equal(true)

    it "handshakes with rustls server running on the host":
        val target = _tls_system_target()
        if not file_exists(target.output):
            expect(build_os(target)).to_equal(true)
        expect(file_exists(target.output)).to_equal(true)

        # Host may not have qemu-system-x86_64 — skip the live capture
        # step but leave the build assertion as the hard gate.
        if not can_run_target(target):
            print "[os_tls_system_spec] qemu-system-x86_64 not available, skipping live run"
            expect(true).to_equal(true)
            return

        val server_bin = _tls_server_bin()
        if not file_exists(server_bin):
            print "[os_tls_system_spec] rustls test server not built: {server_bin}"
            print "[os_tls_system_spec] build with: cargo build --manifest-path tools/tls_test_server/Cargo.toml"
            expect(false).to_equal(true)
            return

        val qmp_socket  = "/tmp/simpleos_tls_system_qmp.sock"
        val serial_log  = "build/os/tls_system_qemu_serial.log"

        # Start the rustls test server on host port 4433. Give it a moment
        # to bind before QEMU tries to connect through the host-forward.
        val server_pid = rt_process_spawn_async(server_bin, ["--config", "tools/tls_test_server/server.sdn"])
        if server_pid <= 0:
            print "[os_tls_system_spec] failed to spawn rustls test server"
            expect(false).to_equal(true)
            return

        # Brief settle time so the server socket is listening before the
        # guest reaches the TCP connect.
        rt_thread_sleep(500)

        match spawn_guest_with_qmp(target, qmp_socket, serial_log):
            Ok(handle):
                # Wait for the guest to complete the TLS handshake.
                val saw_handshake = wait_for_serial_marker(
                    handle,
                    "[TLS HANDSHAKE COMPLETE]",
                    60000)

                if not saw_handshake:
                    print "[os_tls_system_spec] [TLS HANDSHAKE COMPLETE] not seen within 60s"

                # Tear down QEMU and the rustls server on every path so
                # neither lingers as a zombie.
                stop_guest(handle)
                _kill_server(server_pid)

                expect(saw_handshake).to_equal(true)
            Err(err):
                print "[os_tls_system_spec] failed to spawn guest: {err}"
                _kill_server(server_pid)
                expect(false).to_equal(true)
