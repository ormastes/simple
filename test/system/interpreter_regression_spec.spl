# @cover src/compiler/95.interp/interpreter/mod.spl 80%
# @cover src/compiler/95.interp/interpreter/pattern.spl 80%
# @bug me-method-self-state, fn-typed-field, len-corruption
# @req regression tests for interpreter bugs

# ============================================================
# Bug 1: me methods + if-val pattern match on self.state
# The bug: inside a `me` method, `if val Variant(v) = self.state:`
# fails to match even when self.state IS that variant.
# `match self.state:` works correctly, `if val` does not.
# ============================================================

enum Status:
    Idle
    Active(value)
    Error(msg)

class StateMachine:
    state: Status
    log: text

    fn read_with_match() -> text:
        match self.state:
            case Active(v): "active:" + v
            case Error(m): "error:" + m
            case _: "idle"

    fn read_with_if_val() -> text:
        if val Status.Active(v) = self.state:
            return "active:" + v
        if val Status.Error(m) = self.state:
            return "error:" + m
        return "idle"

    me mutate_and_read_match(new_log: text) -> text:
        self.log = new_log
        match self.state:
            case Active(v): "active:" + v
            case Error(m): "error:" + m
            case _: "idle"

    me mutate_and_read_if_val(new_log: text) -> text:
        self.log = new_log
        if val Status.Active(v) = self.state:
            return "active:" + v
        if val Status.Error(m) = self.state:
            return "error:" + m
        return "idle"

describe "Bug 1a - fn methods read state correctly":
    it "match on self.state works in fn method":
        var sm = StateMachine(state: Status.Active("running"), log: "")
        expect(sm.read_with_match()).to_equal("active:running")

    it "if-val on self.state works in fn method":
        var sm = StateMachine(state: Status.Active("running"), log: "")
        expect(sm.read_with_if_val()).to_equal("active:running")

    it "match on Error state works in fn method":
        var sm = StateMachine(state: Status.Error("broken"), log: "")
        expect(sm.read_with_match()).to_equal("error:broken")

    it "if-val on Error state works in fn method":
        var sm = StateMachine(state: Status.Error("broken"), log: "")
        expect(sm.read_with_if_val()).to_equal("error:broken")

describe "Bug 1b - me methods read state correctly":
    it "match on self.state works in me method":
        var sm = StateMachine(state: Status.Active("running"), log: "")
        var result = sm.mutate_and_read_match("updated")
        expect(result).to_equal("active:running")

    it "if-val on self.state works in me method":
        var sm = StateMachine(state: Status.Active("running"), log: "")
        var result = sm.mutate_and_read_if_val("updated")
        expect(result).to_equal("active:running")

    it "match on Error state works in me method":
        var sm = StateMachine(state: Status.Error("broken"), log: "")
        var result = sm.mutate_and_read_match("updated")
        expect(result).to_equal("error:broken")

    it "if-val on Error state works in me method":
        var sm = StateMachine(state: Status.Error("broken"), log: "")
        var result = sm.mutate_and_read_if_val("updated")
        expect(result).to_equal("error:broken")

# ============================================================
# Bug 1c: me method in impl block (separate from class)
# ============================================================

enum PromiseState:
    Pending
    Resolved(value)
    Rejected(error)

class Promise:
    state: PromiseState
    data: i64

impl Promise:
    me resolve(value):
        self.state = PromiseState.Resolved(value)

    fn then_match(callback) -> Promise:
        match self.state:
            case Resolved(v):
                var result = callback(v)
                return Promise(state: PromiseState.Resolved(result), data: 0)
            case Rejected(e):
                return Promise(state: PromiseState.Rejected(e), data: 0)
            case _:
                return Promise(state: PromiseState.Pending, data: 0)

    fn then_if_val(callback) -> Promise:
        if val PromiseState.Resolved(v) = self.state:
            var result = callback(v)
            return Promise(state: PromiseState.Resolved(result), data: 0)
        if val PromiseState.Rejected(e) = self.state:
            return Promise(state: PromiseState.Rejected(e), data: 0)
        return Promise(state: PromiseState.Pending, data: 0)

    fn is_resolved() -> bool:
        match self.state:
            case Resolved(_): true
            case _: false

    fn get_value():
        match self.state:
            case Resolved(v): v
            case _: nil

describe "Bug 1c - impl block methods with pattern matching":
    it "then_match works on resolved promise":
        var p = Promise(state: PromiseState.Resolved(21), data: 0)
        var result = p.then_match(\v: v * 2)
        expect(result.is_resolved()).to_equal(true)
        expect(result.get_value()).to_equal(42)

    it "then_if_val works on resolved promise":
        var p = Promise(state: PromiseState.Resolved(21), data: 0)
        var result = p.then_if_val(\v: v * 2)
        expect(result.is_resolved()).to_equal(true)
        expect(result.get_value()).to_equal(42)

    it "then_match propagates rejection":
        var p = Promise(state: PromiseState.Rejected("fail"), data: 0)
        var result = p.then_match(\v: v)
        match result.state:
            case Rejected(e): expect(e).to_equal("fail")
            case _: expect(true).to_equal(false)

    it "then_if_val propagates rejection":
        var p = Promise(state: PromiseState.Rejected("fail"), data: 0)
        var result = p.then_if_val(\v: v)
        match result.state:
            case Rejected(e): expect(e).to_equal("fail")
            case _: expect(true).to_equal(false)

# ============================================================
# Bug 2: Function-typed class fields
# ============================================================

class Holder:
    value: i64
    compute: fn(i64) -> i64

describe "Bug 2 - Function-typed class fields":
    it "class with fn-typed field can be constructed":
        fn double(x: i64) -> i64:
            x * 2
        var h = Holder(value: 10, compute: double)
        expect(h.value).to_equal(10)

    it "fn-typed field can be accessed and called":
        fn triple(x: i64) -> i64:
            x * 3
        var h = Holder(value: 5, compute: triple)
        var f = h.compute
        expect(f(7)).to_equal(21)

    it "lambda in fn-typed field works":
        var h = Holder(value: 1, compute: \x: x + 100)
        var f = h.compute
        expect(f(42)).to_equal(142)

# ============================================================
# Bug 3: Array .len() corruption
# ============================================================

var module_array = [10, 20, 30, 40, 50]

fn get_len_twice() -> i64:
    var first = module_array.len()
    var second = module_array.len()
    first + second

describe "Bug 3 - Array .len() corruption":
    it "local array .len() returns correct value":
        var arr = [1, 2, 3]
        expect(arr.len()).to_equal(3)

    it "local array .len() called twice returns same value":
        var arr = [1, 2, 3, 4, 5]
        var a = arr.len()
        var b = arr.len()
        expect(a).to_equal(5)
        expect(b).to_equal(5)

    it "module-level array .len() returns correct value first call":
        expect(module_array.len()).to_equal(5)

    it "module-level array .len() called twice returns same value":
        var result = get_len_twice()
        expect(result).to_equal(10)

    it ".len() in a loop stays correct":
        var arr = [1, 2, 3, 4, 5]
        var total = 0
        for i in 0..5:
            total = total + arr.len()
        expect(total).to_equal(25)
