# Memory Cross-Architecture QEMU Tests
#
# Verifies consistent memory behavior across all 4 architectures.
# Same allocation patterns, same results.
#
# @tag: os,qemu,memory,cross

use os.qemu_runner.{get_target, build_qemu_command, arch_display_name}
use os.kernel.arch.arch_context.{Architecture}

extern fn rt_process_run_timeout(cmd: text, args: [text], timeout_ms: i64) -> (text, text, i32)
extern fn rt_file_exists(path: text) -> bool

val TIMEOUT_MS: i64 = 15000

fn _can_run(arch: Architecture) -> bool:
    val target = get_target(arch)
    val qemu_check = rt_process_run_timeout("which", [target.qemu_system], 5000)
    if qemu_check[2] != 0:
        return false
    if not rt_file_exists(target.output):
        return false
    true

fn _run_qemu(arch: Architecture) -> text:
    val target = get_target(arch)
    val cmd_parts = build_qemu_command(target)
    val qemu_bin = cmd_parts[0]
    var args: [text] = []
    for i in 1..cmd_parts.len():
        args.push(cmd_parts[i])
    val result = rt_process_run_timeout(qemu_bin, args, TIMEOUT_MS)
    result[0] + result[1]

describe "Memory Cross-Architecture Consistency":
    slow_it "all architectures initialize PMM":
        val arches = [Architecture.Arm64, Architecture.X86_64, Architecture.Riscv32, Architecture.Riscv64]
        for arch in arches:
            if _can_run(arch):
                val output = _run_qemu(arch)
                expect(output).to_contain("[PMM]")

    slow_it "all architectures report memory initialized":
        val arches = [Architecture.Arm64, Architecture.X86_64, Architecture.Riscv32, Architecture.Riscv64]
        for arch in arches:
            if _can_run(arch):
                val output = _run_qemu(arch)
                expect(output).to_contain("Memory initialized")

    slow_it "all architectures complete memory init pass":
        val arches = [Architecture.Arm64, Architecture.X86_64, Architecture.Riscv32, Architecture.Riscv64]
        for arch in arches:
            if _can_run(arch):
                val output = _run_qemu(arch)
                expect(output).to_contain("[PASS] memory_init")

    slow_it "all architectures report usable memory regions":
        val arches = [Architecture.Arm64, Architecture.X86_64, Architecture.Riscv32, Architecture.Riscv64]
        for arch in arches:
            if _can_run(arch):
                val output = _run_qemu(arch)
                expect(output).to_contain("usable")
