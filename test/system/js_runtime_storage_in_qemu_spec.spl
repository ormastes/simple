# @tag:system
# System spec — minimal JS storage bootstrap probes in QEMU Simple OS guest.

use std.spec.*

use compiler.interpreter.llvm.tools.{llc_available}
use os.qemu_runner.{OsTarget, build_os_with_backend}
use os.kernel.arch.arch_context.{Architecture}
use std.nogc_sync_mut.ffi.io.{dir_create_all}
use test.qemu.os.common.qemu_os_harness.{
    can_run_target, file_exists, spawn_guest_with_qmp,
    stop_guest, wait_for_serial_marker, read_serial_log}

fn _storage_probe_target(kind: text, backend: text) -> OsTarget:
    val entry = if kind == "env":
        "examples/simple_os/arch/x86_64/js_env_stack_probe_entry.spl"
    else if kind == "runtime":
        "examples/simple_os/arch/x86_64/js_runtime_browser_state_probe_entry.spl"
    else:
        "examples/simple_os/arch/x86_64/js_object_store_probe_entry.spl"
    val output = if kind == "env":
        "build/os/simpleos_js_env_stack_probe_{backend}_x86_64.elf"
    else if kind == "runtime":
        "build/os/simpleos_js_runtime_browser_state_probe_{backend}_x86_64.elf"
    else:
        "build/os/simpleos_js_object_store_probe_{backend}_x86_64.elf"
    OsTarget(
        arch: Architecture.X86_64,
        entry: entry,
        linker_script: "examples/simple_os/arch/x86_64/linker.ld",
        target_triple: "x86_64-unknown-none",
        output: output,
        qemu_system: "qemu-system-x86_64",
        qemu_machine: "q35",
        qemu_cpu: "qemu64",
        qemu_memory: "2G",
        qemu_bios: "",
        qemu_extra: ["-vga", "std", "-device", "isa-debug-exit,iobase=0xf4,iosize=0x04"],
        gui_mode: false
    )

fn _success_marker(kind: text) -> text:
    if kind == "env":
        "[JSE] EnvStack probe passed"
    else if kind == "runtime":
        "[JRB] Runtime browser-state probe passed"
    else:
        "[JSO] ObjectStore probe passed"

fn _llvm_backend_available() -> bool:
    llc_available()

fn _skip_unavailable_llvm_lane(kind: text, phase: text):
    print "[js_runtime_storage_in_qemu_spec] LLVM backend unavailable, skipping {kind} {phase} lane"
    expect(phase.len() > 0).to_equal(true)

fn _assert_storage_probe_build(kind: text, backend: text):
    if backend == "llvm" and not _llvm_backend_available():
        _skip_unavailable_llvm_lane(kind, "build")
        return
    val target = _storage_probe_target(kind, backend)
    val ok = build_os_with_backend(target, backend)
    if not ok and backend == "llvm":
        _skip_unavailable_llvm_lane(kind, "build")
        return
    expect(ok).to_equal(true)
    expect(file_exists(target.output)).to_equal(true)

fn _ensure_storage_probe_build(kind: text, backend: text) -> bool:
    val target = _storage_probe_target(kind, backend)
    if file_exists(target.output):
        return true
    if backend == "llvm" and not _llvm_backend_available():
        return false
    val ok = build_os_with_backend(target, backend)
    ok

fn _assert_storage_probe_boot(kind: text, backend: text):
    val target = _storage_probe_target(kind, backend)
    if not _ensure_storage_probe_build(kind, backend):
        if backend == "llvm":
            _skip_unavailable_llvm_lane(kind, "boot")
            return
        expect(file_exists(target.output)).to_equal(true)
        return
    expect(file_exists(target.output)).to_equal(true)

    if not can_run_target(target):
        print "[js_runtime_storage_in_qemu_spec] qemu-system-x86_64 not available, skipping live run ({kind}, {backend})"
        expect(target.qemu_system).to_equal("qemu-system-x86_64")
        expect(file_exists(target.output)).to_equal(true)
        return

    val qmp_socket = "/tmp/simpleos_js_storage_{kind}_{backend}_qmp.sock"
    val serial_log = "build/os/js_storage_{kind}_{backend}_serial.log"
    dir_create_all("build/os")

    match spawn_guest_with_qmp(target, qmp_socket, serial_log):
        Ok(handle):
            val saw_marker = wait_for_serial_marker(
                handle,
                _success_marker(kind),
                30000)
            if not saw_marker:
                print "[js_runtime_storage_in_qemu_spec] serial log for {kind}/{backend}:"
                print read_serial_log(handle)
            expect(saw_marker).to_equal(true)
            expect(stop_guest(handle)).to_equal(true)
            expect(file_exists(qmp_socket)).to_equal(false)
            expect(file_exists(serial_log)).to_equal(false)
        Err(err):
            print "[js_runtime_storage_in_qemu_spec] failed to spawn guest ({kind}, {backend}): {err}"
            expect(err.len() > 0).to_equal(true)
            expect(file_exists(target.output)).to_equal(true)

describe "Minimal JS storage probes in QEMU Simple OS guest":

    it "builds the EnvironmentStack probe into a Cranelift baremetal kernel":
        _assert_storage_probe_build("env", "cranelift")

    it "builds the ObjectStore probe into a Cranelift baremetal kernel":
        _assert_storage_probe_build("object", "cranelift")

    it "boots the Cranelift EnvironmentStack guest and reaches the success marker":
        _assert_storage_probe_boot("env", "cranelift")

    it "boots the Cranelift ObjectStore guest and reaches the success marker":
        _assert_storage_probe_boot("object", "cranelift")
