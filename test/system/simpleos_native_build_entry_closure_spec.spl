"""
# SimpleOS Native Build Entry Closure

System-level regression check for FR-SOS-023. The OS native-build lane must
compile the explicit entry closure instead of scanning unrelated entry modules.
"""

use os.qemu_runner.{os_native_build_args, OsTarget}
use os.kernel.arch.arch_context.{Architecture}

fn x86_64_os_entry_target() -> OsTarget:
    OsTarget(
        arch: Architecture.X86_64,
        entry: "examples/simple_os/arch/x86_64/os_entry.spl",
        linker_script: "examples/simple_os/arch/x86_64/linker.ld",
        target_triple: "x86_64-unknown-none",
        output: "build/os/simpleos_x86_64.elf",
        qemu_system: "qemu-system-x86_64",
        qemu_machine: "q35",
        qemu_cpu: "qemu64",
        qemu_memory: "128M",
        qemu_bios: "",
        qemu_extra: [],
        gui_mode: false
    )

describe "SimpleOS native-build entry closure":
    it "builds x86_64 os_entry through the explicit entry closure":
        val args = os_native_build_args(x86_64_os_entry_target(), "llvm")
        expect(args).to_contain("--entry-closure")
        expect(args).to_contain("--entry")
        expect(args).to_contain("examples/simple_os/arch/x86_64/os_entry.spl")
        expect(args).to_contain("--target")
        expect(args).to_contain("x86_64-unknown-none")
        expect(args.contains("examples/simple_os/arch/x86_64/wm_entry.spl")).to_equal(false)
