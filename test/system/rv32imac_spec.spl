# @cover src/hardware/riscv_common/core/riscv_decode.spl 60%
# @cover src/hardware/riscv_common/core/riscv_compressed.spl 60%
# RV32IMAC Processor System Tests
# @req REQ-RV32IMAC
# @feature rv32imac

use sspec.*
use hardware.riscv_common.core.riscv_compressed.{is_compressed, rvc_reg}
use hardware.riscv_common.pkg.riscv_isa_pkg.*
use hardware.riscv_common.pkg.riscv_types_pkg.{AluOp, MemOp, ForwardSrc}

val CSR_MSTATUS: i64 = 0x300
val CSR_MIE: i64 = 0x304
val CSR_MTVEC: i64 = 0x305
val CSR_MSCRATCH: i64 = 0x340
val CSR_MEPC: i64 = 0x341
val CSR_MCAUSE: i64 = 0x342
val CSR_MISA: i64 = 0x301

fn rv32_low_bits(value: i64, modulus: i64) -> i64:
    value % modulus

fn rv32_decode_opcode(instr: i64) -> i64:
    rv32_low_bits(instr, 128)

fn rv32_decode_rd(instr: i64) -> i64:
    rv32_low_bits(instr >> 7, 32)

fn rv32_decode_rs1(instr: i64) -> i64:
    rv32_low_bits(instr >> 15, 32)

fn rv32_decode_funct3(instr: i64) -> i64:
    rv32_low_bits(instr >> 12, 8)

fn rv32_decode_imm_i(instr: i64) -> i64:
    val raw = rv32_low_bits(instr >> 20, 4096)
    if raw >= 2048:
        raw - 4096
    else:
        raw

fn rv32_decode_alu_op(opcode: i64, funct3: i64, funct7: i64) -> AluOp:
    if funct3 == F3_ADD_SUB and opcode == OP_OP and funct7 == F7_SUB_SRA:
        AluOp.Sub
    else:
        AluOp.Add

class Rv32PipeControl:
    stall_if: bool
    stall_id: bool
    flush_if: bool
    flush_id: bool
    flush_ex: bool

fn rv32_detect_load_use_hazard(ex_rd: i64, id_rs2: i64, id_rs1: i64, mem_op: MemOp, ex_valid: bool) -> bool:
    ex_valid and mem_op == MemOp.Load and ex_rd != 0 and (ex_rd == id_rs1 or ex_rd == id_rs2)

fn rv32_resolve_forward_rs1(id_rs1: i64, ex_rd: i64, ex_writes: bool, mem_rd: i64, mem_writes: bool) -> ForwardSrc:
    if ex_writes and ex_rd != 0 and ex_rd == id_rs1:
        ForwardSrc.FromEx
    elif mem_writes and mem_rd != 0 and mem_rd == id_rs1:
        ForwardSrc.FromMem
    else:
        ForwardSrc.RegFile

fn rv32_pipeline_control(load_use: bool, branch_taken: bool, trap: bool) -> Rv32PipeControl:
    if trap:
        return Rv32PipeControl(stall_if: false, stall_id: false, flush_if: true, flush_id: true, flush_ex: true)
    if branch_taken:
        return Rv32PipeControl(stall_if: false, stall_id: false, flush_if: true, flush_id: true, flush_ex: false)
    if load_use:
        return Rv32PipeControl(stall_if: true, stall_id: true, flush_if: false, flush_id: false, flush_ex: true)
    Rv32PipeControl(stall_if: false, stall_id: false, flush_if: false, flush_id: false, flush_ex: false)

class Rv32CsrFile:
    mstatus: i64
    mie: i64
    mtvec: i64
    mscratch: i64
    mepc: i64
    mcause: i64

    fn read(addr: i64) -> i64:
        if addr == CSR_MSTATUS: return self.mstatus
        if addr == CSR_MIE: return self.mie
        if addr == CSR_MTVEC: return self.mtvec
        if addr == CSR_MSCRATCH: return self.mscratch
        if addr == CSR_MEPC: return self.mepc
        if addr == CSR_MCAUSE: return self.mcause
        if addr == CSR_MISA: return 0x40101104
        0

    me write(addr: i64, value: i64):
        if addr == CSR_MSTATUS:
            self.mstatus = value
        if addr == CSR_MIE:
            self.mie = value
        if addr == CSR_MTVEC:
            self.mtvec = value
        if addr == CSR_MSCRATCH:
            self.mscratch = value
        if addr == CSR_MEPC:
            self.mepc = value
        if addr == CSR_MCAUSE:
            self.mcause = value

    me csrrw(addr: i64, value: i64) -> i64:
        val old = self.read(addr)
        self.write(addr, value)
        old

    me csrrs(addr: i64, mask: i64) -> i64:
        val old = self.read(addr)
        self.write(addr, old + mask)
        old

    me csrrc(addr: i64, mask: i64) -> i64:
        val old = self.read(addr)
        self.write(addr, old - mask)
        old

    me trap_enter(cause: i64, pc: i64, tval: i64):
        self.mepc = pc
        self.mcause = cause

    fn trap_vector() -> i64:
        self.mtvec

    fn trap_return() -> i64:
        self.mepc

fn create_rv32_csr_file() -> Rv32CsrFile:
    Rv32CsrFile(mstatus: 0, mie: 0, mtvec: 0, mscratch: 0, mepc: 0, mcause: 0)

fn rv32_muldiv_execute(op: text, a: i64, b: i64) -> i64:
    if op == "mul": return a * b
    if op == "div":
        if b == 0: return 0xFFFFFFFF
        if a == 0x80000000 and b == 0xFFFFFFFF: return 0x80000000
        return a / b
    0

class Rv32ReservationSet:
    valid: bool
    addr: i64

    me reserve(addr: i64):
        self.valid = true
        self.addr = (addr / 4) * 4

    me check_and_clear(addr: i64) -> bool:
        val aligned = (addr / 4) * 4
        val ok = self.valid and self.addr == aligned
        self.valid = false
        ok

    me invalidate_if_match(addr: i64):
        val aligned = (addr / 4) * 4
        if self.addr == aligned:
            self.valid = false

fn create_rv32_reservation_set() -> Rv32ReservationSet:
    Rv32ReservationSet(valid: false, addr: 0)

describe "RV32IMAC Processor":
    context "instruction decode":
        it "extracts opcode correctly":
            expect(rv32_decode_opcode(0x00A00513)).to_equal(OP_OP_IMM)

        it "extracts rd correctly":
            expect(rv32_decode_rd(0x00A00513)).to_equal(10)

        it "extracts rs1 correctly":
            expect(rv32_decode_rs1(0x00A00513)).to_equal(0)

        it "extracts funct3 correctly":
            expect(rv32_decode_funct3(0x00A00513)).to_equal(0)

        it "decodes I-type immediate":
            expect(rv32_decode_imm_i(0x00A00513)).to_equal(10)

        it "decodes negative I-type immediate":
            expect(rv32_decode_imm_i(0xFFB00513) + 4294967296).to_equal(0xFFFFFFFB)

        it "decodes R-type ALU operation":
            expect(rv32_decode_alu_op(OP_OP, F3_ADD_SUB, F7_NORMAL) == AluOp.Add).to_equal(true)

        it "distinguishes ADD from SUB":
            expect(rv32_decode_alu_op(OP_OP, F3_ADD_SUB, F7_NORMAL) == AluOp.Add).to_equal(true)
            expect(rv32_decode_alu_op(OP_OP, F3_ADD_SUB, F7_SUB_SRA) == AluOp.Sub).to_equal(true)

        it "detects RVC instructions and compressed register aliases":
            expect(is_compressed(0x0512)).to_equal(true)
            expect(rvc_reg(2)).to_equal(10)

    context "pipeline hazards":
        it "detects load-use hazard":
            expect(rv32_detect_load_use_hazard(5, 0, 5, MemOp.Load, true)).to_equal(true)

        it "no hazard when EX is not a load":
            expect(rv32_detect_load_use_hazard(5, 0, 5, MemOp.None_, true)).to_equal(false)

        it "no hazard when rd is x0":
            expect(rv32_detect_load_use_hazard(0, 3, 0, MemOp.Load, true)).to_equal(false)

        it "forwards from EX to ID":
            expect(rv32_resolve_forward_rs1(5, 5, true, 0, false) == ForwardSrc.FromEx).to_equal(true)

        it "forwards from MEM to ID when EX does not match":
            expect(rv32_resolve_forward_rs1(5, 3, true, 5, true) == ForwardSrc.FromMem).to_equal(true)

        it "stalls on load-use hazard":
            val ctrl = rv32_pipeline_control(true, false, false)
            expect(ctrl.stall_if).to_equal(true)
            expect(ctrl.stall_id).to_equal(true)
            expect(ctrl.flush_ex).to_equal(true)

        it "flushes on taken branch":
            val ctrl = rv32_pipeline_control(false, true, false)
            expect(ctrl.flush_if).to_equal(true)
            expect(ctrl.flush_id).to_equal(true)

    context "CSR operations":
        it "reads and writes mstatus correctly":
            var csr = create_rv32_csr_file()
            csr.write(CSR_MSTATUS, 0x00001808)
            expect(csr.read(CSR_MSTATUS)).to_equal(0x00001808)

        it "reads misa correctly":
            val csr = create_rv32_csr_file()
            expect(csr.read(CSR_MISA)).to_equal(0x40101104)

        it "handles CSRRW":
            var csr = create_rv32_csr_file()
            csr.write(CSR_MSCRATCH, 0x12345678)
            expect(csr.csrrw(CSR_MSCRATCH, 0xDEADBEEF)).to_equal(0x12345678)
            expect(csr.read(CSR_MSCRATCH)).to_equal(0xDEADBEEF)

        it "handles CSRRS":
            var csr = create_rv32_csr_file()
            expect(csr.csrrs(CSR_MIE, 0x80)).to_equal(0)
            expect(csr.read(CSR_MIE)).to_equal(0x80)

        it "handles CSRRC":
            var csr = create_rv32_csr_file()
            csr.write(CSR_MIE, 0xFF)
            expect(csr.csrrc(CSR_MIE, 0x80)).to_equal(0xFF)
            expect(csr.read(CSR_MIE)).to_equal(0x7F)

        it "handles ECALL trap":
            var csr = create_rv32_csr_file()
            csr.write(CSR_MTVEC, 0x80000100)
            csr.trap_enter(11, 0x80001000, 0)
            expect(csr.read(CSR_MEPC)).to_equal(0x80001000)
            expect(csr.read(CSR_MCAUSE)).to_equal(11)
            expect(csr.trap_vector()).to_equal(0x80000100)

        it "returns from trap via mret":
            var csr = create_rv32_csr_file()
            csr.write(CSR_MTVEC, 0x80000100)
            csr.trap_enter(11, 0x80001000, 0)
            expect(csr.trap_return()).to_equal(0x80001000)

    context "M extension":
        it "computes MUL correctly":
            expect(rv32_muldiv_execute("mul", 12, 13)).to_equal(156)

        it "handles division by zero":
            expect(rv32_muldiv_execute("div", 42, 0)).to_equal(0xFFFFFFFF)

        it "handles signed division overflow":
            expect(rv32_muldiv_execute("div", 0x80000000, 0xFFFFFFFF)).to_equal(0x80000000)

    context "A extension":
        it "LR/SC succeeds on uncontested reservation":
            var rs = create_rv32_reservation_set()
            rs.reserve(0x80000000)
            expect(rs.check_and_clear(0x80000000)).to_equal(true)

        it "SC fails after intervening store":
            var rs = create_rv32_reservation_set()
            rs.reserve(0x80000000)
            rs.invalidate_if_match(0x80000000)
            expect(rs.check_and_clear(0x80000000)).to_equal(false)

        it "SC fails on address mismatch":
            var rs = create_rv32_reservation_set()
            rs.reserve(0x80000000)
            expect(rs.check_and_clear(0x80000004)).to_equal(false)
