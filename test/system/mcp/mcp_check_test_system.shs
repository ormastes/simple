#!/bin/bash
# System test: MCP simple_check and simple_test tools
# Verifies that the async bg_task_spawn conversion works correctly
# by piping framed MCP JSON-RPC messages to the server and checking responses.

set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_DIR="$(cd "$SCRIPT_DIR/../../.." && pwd)"
cd "$PROJECT_DIR"

MCP_SERVER="bin/simple_mcp_server"

echo "Using MCP server: $MCP_SERVER"

PASS=0
FAIL=0
TOTAL=0

check_result() {
    local test_name="$1"
    local output="$2"
    local expected="$3"
    TOTAL=$((TOTAL + 1))
    if echo "$output" | grep -q "$expected"; then
        PASS=$((PASS + 1))
        echo "  PASS: $test_name"
    else
        FAIL=$((FAIL + 1))
        echo "  FAIL: $test_name"
        echo "    Expected to contain: $expected"
        echo "    Got: $(echo "$output" | head -3)"
    fi
}

# Helper: frame a JSON-RPC body as an MCP stdio message.
frame_mcp() {
    local body="$1"
    local len=${#body}
    printf 'Content-Length: %s\r\n\r\n%s' "$len" "$body"
}

# Helper: send framed MCP messages to MCP server and capture output
run_mcp() {
    local bodies=("$@")
    {
        local body
        for body in "${bodies[@]}"; do
            frame_mcp "$body"
        done
    } | timeout 120 "$MCP_SERVER" 2>/dev/null || true
}

INIT='{"jsonrpc":"2.0","id":1,"method":"initialize","params":{"protocolVersion":"2025-06-18","capabilities":{},"clientInfo":{"name":"test","version":"1.0"}}}'
INITIALIZED='{"jsonrpc":"2.0","method":"notifications/initialized"}'

echo ""
echo "=== MCP System Test: simple_check and simple_test ==="
echo ""

# --- Test 1: simple_check on valid file ---
echo "Test 1: simple_check on valid file"
CHECK_VALID='{"jsonrpc":"2.0","id":2,"method":"tools/call","params":{"name":"simple_check","arguments":{"path":"test/system/mcp/fixtures/tiny_valid.spl"}}}'

OUTPUT1=$(run_mcp "$INIT" "$INITIALIZED" "$CHECK_VALID")

check_result "returns jsonrpc response" "$OUTPUT1" '"jsonrpc"'
check_result "returns id 2" "$OUTPUT1" '"id":2'
# Should contain "OK" or "no errors" or a task handle
if echo "$OUTPUT1" | grep '"id":2' | grep -qE 'OK|no errors'; then
    check_result "reports clean" "$OUTPUT1" 'no errors'
elif echo "$OUTPUT1" | grep '"id":2' | grep -q 'taskId'; then
    check_result "returns task handle (async)" "$OUTPUT1" 'taskId'
else
    check_result "returns some response for check" "$OUTPUT1" '"id":2'
fi

echo ""

# --- Test 2: simple_check with missing path ---
echo "Test 2: simple_check with missing path"
CHECK_MISSING='{"jsonrpc":"2.0","id":3,"method":"tools/call","params":{"name":"simple_check","arguments":{}}}'

OUTPUT2=$(run_mcp "$INIT" "$INITIALIZED" "$CHECK_MISSING")

check_result "missing path returns error" "$OUTPUT2" 'Missing required parameter'

echo ""

# --- Test 3: simple_test on tiny spec ---
echo "Test 3: simple_test on tiny spec"
TEST_SPEC='{"jsonrpc":"2.0","id":4,"method":"tools/call","params":{"name":"simple_test","arguments":{"path":"test/system/mcp/fixtures/tiny_test_spec.spl"}}}'

OUTPUT3=$(run_mcp "$INIT" "$INITIALIZED" "$TEST_SPEC")

check_result "test returns jsonrpc" "$OUTPUT3" '"jsonrpc"'
check_result "test returns id 4" "$OUTPUT3" '"id":4'
# Test either completes with result or returns a task handle
if echo "$OUTPUT3" | grep '"id":4' | grep -q 'passed'; then
    check_result "test reports pass" "$OUTPUT3" 'passed'
elif echo "$OUTPUT3" | grep '"id":4' | grep -q 'taskId'; then
    check_result "test returns task handle (async)" "$OUTPUT3" 'taskId'
else
    check_result "test returns some response" "$OUTPUT3" '"id":4'
fi

echo ""

# --- Test 4: simple_test --list ---
echo "Test 4: simple_test --list"
TEST_LIST='{"jsonrpc":"2.0","id":5,"method":"tools/call","params":{"name":"simple_test","arguments":{"list":"true"}}}'

OUTPUT4=$(run_mcp "$INIT" "$INITIALIZED" "$TEST_LIST")

check_result "test list returns jsonrpc" "$OUTPUT4" '"jsonrpc"'
check_result "test list returns id 5" "$OUTPUT4" '"id":5'

echo ""

# --- Test 5: Timing test — check should respond without excessive blocking ---
echo "Test 5: Response timing"
START_TIME=$(date +%s)
OUTPUT5=$(run_mcp "$INIT" "$INITIALIZED" "$CHECK_VALID")
END_TIME=$(date +%s)
ELAPSED=$((END_TIME - START_TIME))

TOTAL=$((TOTAL + 1))
if [ "$ELAPSED" -lt 90 ]; then
    PASS=$((PASS + 1))
    echo "  PASS: responded in ${ELAPSED}s (< 90s)"
else
    FAIL=$((FAIL + 1))
    echo "  FAIL: took ${ELAPSED}s (expected < 90s)"
fi

echo ""

# --- Summary ---
echo "=== Results: $PASS/$TOTAL passed, $FAIL failed ==="

if [ "$FAIL" -gt 0 ]; then
    exit 1
fi
exit 0
