# Test: Call .len() in two separate function calls (one .len() per function).
# Tests whether the corruption happens across function boundaries too.
use std.cli_output._test_len.{get_text_len, get_i64_len}

val result1 = get_text_len()
val result2 = get_i64_len()
print "text_arr.len() via get_text_len:"
print result1
print "i64_arr.len() via get_i64_len:"
print result2
