# Reproduce buffer.spl with functions - find which one corrupts arrays
extern fn rt_file_append(path: text, content: text)

var _lp_buffer: [text] = []
var _lp_starts: [i64] = []
var _lp_names: [text] = []
var _lp_ids: [i64] = []
var _lp_next_id: i64 = 1
var _lp_max: i64 = 16
var _lp_stale_count: i64 = 10000
var _log_path: text = ""

fn _lp_find(id: i64) -> i64:
    var i = 0
    while i < _lp_ids.len():
        if _lp_ids[i] == id:
            return i
        i = i + 1
    -1

fn _lp_remove_from(idx: i64):
    val start = _lp_starts[idx]
    _lp_buffer = _lp_buffer.slice(0, start)
    _lp_starts = _lp_starts.slice(0, idx)
    _lp_names = _lp_names.slice(0, idx)
    _lp_ids = _lp_ids.slice(0, idx)

fn _lp_flush_all_error(reason: text):
    print "[ERROR] [log] " + reason
    for line in _lp_buffer:
        print line
    _lp_buffer = []
    _lp_starts = []
    _lp_names = []
    _lp_ids = []

fn _lp_check_stale():
    if _lp_ids.len() == 0:
        return
    val buffered = _lp_buffer.len() - _lp_starts[0]
    if buffered > _lp_stale_count:
        _lp_flush_all_error("Log point stale: buffered too many lines")

fn _emit_or_defer(line: text):
    if _lp_ids.len() > 0:
        _lp_buffer.push(line)
    else:
        print line

fn test_buffer_len() -> i64:
    _lp_buffer.len()

fn test_ids_len() -> i64:
    _lp_ids.len()
