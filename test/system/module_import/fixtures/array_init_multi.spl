# Reproduce buffer.spl's variable layout
extern fn rt_file_append(path: text, content: text)

var _lp_buffer: [text] = []
var _lp_starts: [i64] = []
var _lp_names: [text] = []
var _lp_ids: [i64] = []
var _lp_next_id: i64 = 1
var _lp_max: i64 = 16
var _lp_stale_count: i64 = 10000
var _log_path: text = ""

fn test_buffer_len() -> i64:
    _lp_buffer.len()

fn test_starts_len() -> i64:
    _lp_starts.len()

fn test_names_len() -> i64:
    _lp_names.len()

fn test_ids_len() -> i64:
    _lp_ids.len()
