# Integration test: buffer module end-to-end via direct submodule import
use std.cli_output.buffer.{buffer_start, buffer_capture, buffer_flush, buffer_discard, buffer_is_active, log_print, log_point_start, log_point_flush, log_point_discard, log_point_has_active, log_point_clear}

# Test 1: Basic buffer start/discard
buffer_start("")
val active1 = buffer_is_active()
buffer_capture("line1")
buffer_capture("line2")
buffer_discard()
val active2 = buffer_is_active()
print "T1 active before: "
print active1
print "T1 active after discard: "
print active2

# Test 2: Buffer flush (should print captured lines)
buffer_start("")
buffer_capture("FLUSH_LINE_A")
buffer_capture("FLUSH_LINE_B")
buffer_flush()

# Test 3: Log points
val lp = log_point_start("test_point")
log_print("LP_LINE_1")
log_print("LP_LINE_2")
log_point_flush(lp)

# Test 4: Log point discard (should NOT print)
val lp2 = log_point_start("discard_point")
log_print("SHOULD_NOT_APPEAR")
log_point_discard(lp2)

print "ALL_INTEGRATION_TESTS_DONE"
