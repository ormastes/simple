# Test: Call .len() twice on a module-level array WITHOUT importing.
# This file is run directly (not via import). Expected: Works fine.
# This proves the bug only manifests when the module is imported via use.

var local_arr: [text] = []

fn local_len_twice() -> i64:
    val a = local_arr.len()
    local_arr.len()

val result = local_len_twice()
print "direct run .len() twice:"
print result
