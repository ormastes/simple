# MINIMAL REPRODUCER: Module-level i64 mutation corrupts adjacent array var
#
# Bug: When a function mutates a module-level i64 variable via assignment
# (e.g., counter = counter + 1), the adjacent module-level array variable
# becomes corrupted (changes from [text] to i64(0)).
#
# No compile error. No runtime error at mutation. Error only surfaces when
# the corrupted array var is accessed (e.g., .len() call).

var arr: [text] = []
var counter: i64 = 1

fn test_no_mutate() -> i64:
    arr.len()

fn test_with_mutate() -> i64:
    counter = counter + 1
    arr.len()
