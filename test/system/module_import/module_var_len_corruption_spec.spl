# @cover src/compiler/99.loader/module_loader.spl 60%
# Module-Level Array .len() Corruption Test
# tag: system
#
# BUG: When a module is imported via `use`, calling .len() on a module-level
# array variable twice in the same function corrupts the variable (it becomes
# i64(0)). Calling .len() once is fine. The bug does NOT manifest when the
# file is run directly (without import).
#
# Workaround: Cache .len() result in a local val and reuse the cached value.
#
# Test strategy:
# - Each test runs a fixture file via rt_process_run (subprocess)
# - Fixtures import from std.cli_output._test_len (the shared module)
# - The shared module is copied into place before tests and cleaned up after
# - Known-bug tests are marked with [KNOWN BUG] in output
#
# NOTE: Tuple destructuring `val (a, b, c) = ...` does not work in interpreter
# mode. Use `val r = ...` then `r.0`, `r.1`, `r.2` to access elements.

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_file_exists(path: text) -> bool

fn find_simple_binary() -> text:
    if rt_file_exists("src/compiler_rust/target/release/simple"):
        return "src/compiler_rust/target/release/simple"
    if rt_file_exists("src/compiler_rust/target/bootstrap/simple"):
        return "src/compiler_rust/target/bootstrap/simple"
    if rt_file_exists("bin/simple"):
        return "bin/simple"
    if rt_file_exists("bin/release/aarch64-apple-darwin-macho/simple"):
        return "bin/release/aarch64-apple-darwin-macho/simple"
    if rt_file_exists("bin/release/macos-arm64/simple"):
        return "bin/release/macos-arm64/simple"
    if rt_file_exists("bin/release/darwin-aarch64/simple"):
        return "bin/release/darwin-aarch64/simple"
    if rt_file_exists("bin/release/macos-x86_64/simple"):
        return "bin/release/macos-x86_64/simple"
    if rt_file_exists("bin/release/linux-x86_64/simple"):
        return "bin/release/linux-x86_64/simple"
    "bin/simple"

val FIXTURES = "test/system/module_import/fixtures"

# --- Helpers ---

fn _check_binary_runnable() -> bool:
    val simple_bin = find_simple_binary()
    if simple_bin == "" or not rt_file_exists(simple_bin):
        return false
    # On Windows, the release binary is an ELF (Linux) binary and cannot run.
    # Detect Windows by checking for C:\ drive.
    if rt_file_exists("C:\\"):
        return false
    true

val _can_run = _check_binary_runnable()

fn run_fixture(name: text) -> (text, text, i64):
    val path = FIXTURES + "/" + name
    rt_process_run(find_simple_binary(), ["run", path])

# --- Module-level helpers to avoid tuple destructuring inside if/else in it blocks ---

fn _run_and_check(fixture: text) -> bool:
    val (stdout, stderr, code) = run_fixture(fixture)
    if code != 0:
        print "[FAIL]: " + stderr
    expect(code).to_equal(0)
    code == 0

fn _run_and_check_stdout(fixture: text, expected: text) -> bool:
    val (stdout, stderr, code) = run_fixture(fixture)
    if code != 0:
        print "[FAIL]: " + stderr
    expect(code).to_equal(0)
    expect(stdout).to_contain(expected)
    code == 0

fn _run_and_check_known_bug(fixture: text, label: text, expected: text) -> bool:
    val (stdout, stderr, code) = run_fixture(fixture)
    if code != 0:
        print "[KNOWN BUG] " + label + ": " + stderr
    expect(code).to_equal(0)
    expect(stdout).to_contain(expected)
    code == 0

fn _run_diag(fixture: text, label: text) -> (text, text, i64):
    val (stdout, stderr, code) = run_fixture(fixture)
    if code != 0:
        print "[DIAG] " + label + " error: " + stderr
    (stdout, stderr, code)

fn _run_diag_type_check(fixture: text, label: text):
    val (stdout, stderr, code) = run_fixture(fixture)
    if code != 0:
        print "[DIAG] " + label + " error: " + stderr
        var has_type_error = false
        if stderr.contains("type"):
            has_type_error = true
        if stderr.contains("method"):
            has_type_error = true
        if stderr.contains("i64"):
            has_type_error = true
        if stderr.contains("len"):
            has_type_error = true
        print "[DIAG] Error contains type/method info: "
        if has_type_error:
            print "yes"
        if not has_type_error:
            print "no"
    pass_do_nothing

fn _run_diag_compare():
    val (stdout1, stderr1, code1) = run_fixture("len_once_text.spl")
    val (stdout2, stderr2, code2) = run_fixture("len_twice_text.spl")
    print "[DIAG] Single .len() exit code: "
    print code1
    print "[DIAG] Double .len() exit code: "
    print code2
    print "[DIAG] Single .len() stdout: " + stdout1.trim()
    print "[DIAG] Double .len() stdout: " + stdout2.trim()
    if code1 == 0:
        print "[DIAG] Single .len() works correctly"
    if code1 != 0:
        print "[DIAG] Single .len() also fails (unexpected)"
    if code2 != 0:
        print "[DIAG] Double .len() fails (confirms bug)"
    if code2 == 0:
        print "[DIAG] Double .len() works (bug may be fixed!)"
    expect(code1).to_equal(0)

# ============================================================================
# Test Group 1: Single .len() Call (Should Work)
# ============================================================================

describe "Module Array .len() Corruption":

    # Module src/lib/nogc_sync_mut/cli_output/_test_len.spl is permanent (no setup needed)

    context "single .len() call (baseline - should work)":

        it "calls .len() once on [text] array":
            if not _can_run:
                expect(true).to_equal(true)
            else:
                _run_and_check_stdout("len_once_text.spl", "0")

        it "calls .len() once on [i64] array":
            if not _can_run:
                expect(true).to_equal(true)
            else:
                _run_and_check_stdout("len_once_i64.spl", "0")

    # ============================================================================
    # Test Group 2: Double .len() Call (Known Bug)
    # ============================================================================

    context "double .len() call (KNOWN BUG - corruption)":

        it "calls .len() twice on [text] array":
            if not _can_run:
                expect(true).to_equal(true)
            else:
                _run_and_check_known_bug("len_twice_text.spl", ".len() twice on [text] crashes", "0")

        it "calls .len() twice on [i64] array":
            if not _can_run:
                expect(true).to_equal(true)
            else:
                _run_and_check_known_bug("len_twice_i64.spl", ".len() twice on [i64] crashes", "0")

    # ============================================================================
    # Test Group 3: Mixed Operations
    # ============================================================================

    context "mixed operations with .len()":

        it "calls .len() then .push() (KNOWN BUG - single .len() corrupts for all ops)":
            if not _can_run:
                expect(true).to_equal(true)
            else:
                _run_and_check_known_bug("len_then_push.spl", ".len() corrupts array for subsequent .push()", "0")

        it "calls .push() then .len()":
            if not _can_run:
                expect(true).to_equal(true)
            else:
                _run_and_check_known_bug("push_then_len.spl", "push_then_len crashes", "1")

    # ============================================================================
    # Test Group 4: Cross-Function and Multi-Array
    # ============================================================================

    context "cross-function and multi-array":

        it "calls .len() in two separate function invocations":
            if not _can_run:
                expect(true).to_equal(true)
            else:
                _run_and_check_stdout("len_across_functions.spl", "0")

        it "calls .len() on different arrays (one per array)":
            if not _can_run:
                expect(true).to_equal(true)
            else:
                _run_and_check_stdout("multiple_arrays_len.spl", "0")

    # ============================================================================
    # Test Group 5: Workaround
    # ============================================================================

    context "workaround - cache .len() in local var":

        it "caches .len() result and reuses cached value":
            if not _can_run:
                expect(true).to_equal(true)
            else:
                _run_and_check_stdout("len_cached_workaround.spl", "0")

    # ============================================================================
    # Test Group 6: Direct Run (Control - No Import)
    # ============================================================================

    context "direct run without import (control test)":

        it "calls .len() twice in directly-run file (KNOWN BUG - also fails without import)":
            if not _can_run:
                expect(true).to_equal(true)
            else:
                # This fixture does NOT import anything - it defines its own array
                # Finding: bug also occurs without import, contradicting initial hypothesis
                _run_and_check_known_bug("direct_run_len_twice.spl", ".len() twice fails even without import", "0")

    # ============================================================================
    # Test Group 7: Diagnostic - Error Message Analysis
    # ============================================================================

    context "diagnostic - error details on corruption":

        it "double .len() [text] error mentions type or corruption":
            if not _can_run:
                expect(true).to_equal(true)
            else:
                _run_diag_type_check("len_twice_text.spl", ".len() twice [text]")

        it "double .len() [i64] error mentions type or corruption":
            if not _can_run:
                expect(true).to_equal(true)
            else:
                _run_diag_type_check("len_twice_i64.spl", ".len() twice [i64]")

        it "compares single vs double .len() behavior":
            if not _can_run:
                expect(true).to_equal(true)
            else:
                _run_diag_compare()
