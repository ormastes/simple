# Module Import System Test: New Submodules in Compiled-In Packages
# tag: system
#
# Reproduces the issue where adding a new .spl file to a package that is
# compiled into bin/release/simple (e.g., std.cli_output) results in
# "function not found" errors even though the file loads without parse errors.
#
# Problems tested:
# 1. Existing compiled-in functions import fine (baseline)
# 2. New submodule file in compiled-in package: direct import fails
# 3. buffer.spl specifically: functions not found despite file loading
# 4. New file in a fresh (non-compiled) package (control test)
# 5. Diagnostic: module loading vs function registration
#
# All test scripts are in fixtures/ to avoid string interpolation issues
# with curly braces in import statements.

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_delete(path: text) -> bool
extern fn rt_dir_create_all(path: text) -> bool

val SIMPLE = "bin/release/simple"
val FIXTURES = "test/system/module_import/fixtures"

fn _check_release_binary() -> bool:
    if not rt_file_exists(SIMPLE):
        print "SKIP: bin/release/simple not found"
        return false
    val (_, _, code) = rt_process_run(SIMPLE, ["--version"])
    if code > 1:
        print "SKIP: bin/release/simple not executable"
        return false
    true

val _can_run = _check_release_binary()

# --- Helpers ---

fn run_fixture(name: text) -> (text, text, i64):
    val path = FIXTURES + "/" + name
    rt_process_run(SIMPLE, [path])

fn copy_fixture(fixture_name: text, dest_path: text):
    val src = FIXTURES + "/" + fixture_name
    val content = rt_file_read_text(src)
    rt_file_write_text(dest_path, content)

fn setup_probe_module():
    copy_fixture("probe_module.spl", "src/lib/nogc_sync_mut/cli_output/_test_probe.spl")

fn setup_probe_module_with_extern():
    copy_fixture("probe_module_with_extern.spl", "src/lib/nogc_sync_mut/cli_output/_test_probe.spl")

fn cleanup_probe_module():
    rt_file_delete("src/lib/nogc_sync_mut/cli_output/_test_probe.spl")

fn setup_fresh_package():
    rt_dir_create_all("src/lib/nogc_sync_mut/_test_fresh_pkg")
    copy_fixture("fresh_mod.spl", "src/lib/nogc_sync_mut/_test_fresh_pkg/_test_fresh_mod.spl")
    copy_fixture("fresh_init.spl", "src/lib/nogc_sync_mut/_test_fresh_pkg/__init__.spl")

fn cleanup_fresh_package():
    rt_file_delete("src/lib/nogc_sync_mut/_test_fresh_pkg/_test_fresh_mod.spl")
    rt_file_delete("src/lib/nogc_sync_mut/_test_fresh_pkg/__init__.spl")

# ============================================================================
# Test Group 1: Baseline - Existing Compiled-In Imports
# ============================================================================

describe "Module Import - Compiled-In Package":

    context "existing functions (baseline)":

        it "imports existing std.cli_output function via init":
            if not _can_run:
                return
            val (stdout, stderr, code) = run_fixture("baseline_init_import.spl")
            if code != 0:
                print "[FAIL] baseline init import: stderr=" + stderr
            expect(code).to_equal(0)

        it "imports existing std.cli_output submodule directly":
            if not _can_run:
                return
            val (stdout, stderr, code) = run_fixture("baseline_direct_import.spl")
            if code != 0:
                print "[FAIL] baseline direct import: stderr=" + stderr
            expect(code).to_equal(0)

# ============================================================================
# Test Group 2: New Submodule in Compiled-In Package
# ============================================================================

    context "new submodule file in compiled-in package":

        it "can load new spl file without parse errors (run directly)":
            if not _can_run:
                return
            setup_probe_module()
            val (stdout, stderr, code) = rt_process_run(SIMPLE, ["src/lib/nogc_sync_mut/cli_output/_test_probe.spl"])
            cleanup_probe_module()
            expect(code).to_equal(0)

        it "can import function from new submodule via direct path":
            if not _can_run:
                return
            setup_probe_module()
            val (stdout, stderr, code) = run_fixture("probe_direct_import.spl")
            cleanup_probe_module()
            if code != 0:
                print "[KNOWN BUG] New submodule direct import fails: " + stderr
            expect(code).to_equal(0)

# ============================================================================
# Test Group 3: buffer.spl Specifically
# ============================================================================

    context "buffer.spl (the actual module we need)":

        it "can import buffer_start via direct submodule path":
            if not _can_run:
                return
            val (stdout, stderr, code) = run_fixture("buffer_direct_import.spl")
            if code != 0:
                print "[KNOWN BUG] buffer.spl direct import fails: " + stderr
            expect(code).to_equal(0)

        it "can import log_print via direct submodule path":
            if not _can_run:
                return
            val (stdout, stderr, code) = run_fixture("buffer_logprint_import.spl")
            if code != 0:
                print "[KNOWN BUG] buffer.spl log_print import fails: " + stderr
            expect(code).to_equal(0)

        it "can import buffer functions via init reexport":
            if not _can_run:
                return
            val (stdout, stderr, code) = run_fixture("buffer_init_import.spl")
            if code != 0:
                print "[KNOWN BUG] buffer.spl init re-export fails: " + stderr
            expect(code).to_equal(0)

# ============================================================================
# Test Group 4: Control - Fresh Non-Compiled Package
# ============================================================================

    context "fresh non-compiled package (control test)":

        it "can import from a completely new package via direct path":
            if not _can_run:
                return
            setup_fresh_package()
            val (stdout, stderr, code) = run_fixture("fresh_pkg_direct_import.spl")
            cleanup_fresh_package()
            if code != 0:
                print "[INFO] Fresh package direct import: " + stderr
            expect(code).to_equal(0)

        it "can import from a completely new package via init":
            if not _can_run:
                return
            setup_fresh_package()
            val (stdout, stderr, code) = run_fixture("fresh_pkg_init_import.spl")
            cleanup_fresh_package()
            if code != 0:
                print "[INFO] Fresh package init import: " + stderr
            expect(code).to_equal(0)

# ============================================================================
# Test Group 5: Module Loading vs Function Registration
# ============================================================================

    context "module loading diagnostics":

        it "buffer.spl is found by resolver (not module-not-found)":
            if not _can_run:
                return
            # nonexistent module gives one error type
            val (_, stderr_bad, code_bad) = run_fixture("nonexistent_module.spl")
            # buffer gives another
            val (_, stderr_buf, code_buf) = run_fixture("buffer_direct_import.spl")

            print "[DIAG] nonexistent module error: " + stderr_bad
            print "[DIAG] buffer module error: " + stderr_buf

            # buffer.spl should NOT produce "module not found"
            var is_module_not_found = false
            if stderr_buf.contains("module not found"):
                is_module_not_found = true
            if stderr_buf.contains("file not found"):
                is_module_not_found = true
            expect(is_module_not_found).to_equal(false)

        it "extern fn in module does not prevent function registration":
            if not _can_run:
                return
            setup_probe_module_with_extern()
            val (stdout, stderr, code) = run_fixture("probe_extern_import.spl")
            cleanup_probe_module()
            if code != 0:
                print "[DIAG] extern fn in new submodule: " + stderr
            expect(code).to_equal(0)
