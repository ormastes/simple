# test/system/gui/capability_negotiation_spec.spl
# @cover src/lib/common/ui/capability.spl 80%
# @cover src/lib/common/ui/backend_factory.spl
# @cover src/lib/common/ui/backend.spl
# @tag:system
# @gui: headless

"""
# Capability Negotiation Specification

**Feature IDs:** #GUI-CAP-001
**Category:** Stdlib
**Difficulty:** 2/5
**Status:** In Progress
**Requirements:** N/A
**Plan:** N/A
**Design:** N/A
**Research:** N/A

## Overview

Verifies that each UI backend correctly advertises its supported
capabilities via `capabilities()`, and that optional trait methods
return `Err(NotSupported)` when the capability is absent.
"""

use std.spec.*

use common.ui.capability.{Capability, NotSupported, has_capability}
use common.ui.backend_factory.{create_backend}
use common.ui.widget.{WidgetNode, WidgetKind, WidgetRect}

# ============================================================================
# 1. TUI Backend Capabilities
# ============================================================================

describe "TUI backend capability negotiation":
    slow_it "reports only Color capability":
        val result = create_backend("tui", 0)
        match result:
            Ok(backend) :
                val caps = backend.capabilities()
                expect(has_capability(caps, Capability.Color)).to_equal(true)
                expect(has_capability(caps, Capability.Mouse)).to_equal(false)
                expect(has_capability(caps, Capability.Images)).to_equal(false)
                expect(has_capability(caps, Capability.Touch)).to_equal(false)
                expect(has_capability(caps, Capability.NativeDialogs)).to_equal(false)
                expect(has_capability(caps, Capability.Notification)).to_equal(false)
            Err(e) :
                expect(false).to_equal(true)

    slow_it "render_image returns Err(NotSupported)":
        val result = create_backend("tui", 0)
        match result:
            Ok(backend) :
                val node = WidgetNode.new("img1", WidgetKind.Image)
                val rect = WidgetRect.new("img1", 0, 0, 100, 100)
                val img_result = backend.render_image(node, rect)
                match img_result:
                    Err(ns) :
                        expect(ns.backend_name).to_contain("tui")
                    Ok(v) :
                        expect(false).to_equal(true)
            Err(e) :
                expect(false).to_equal(true)

# ============================================================================
# 2. Web Backend Capabilities
# ============================================================================

describe "Web backend capability negotiation":
    slow_it "reports Mouse, Color, Images, and Touch capabilities":
        val result = create_backend("web", 0)
        match result:
            Ok(backend) :
                val caps = backend.capabilities()
                expect(has_capability(caps, Capability.Mouse)).to_equal(true)
                expect(has_capability(caps, Capability.Color)).to_equal(true)
                expect(has_capability(caps, Capability.Images)).to_equal(true)
                expect(has_capability(caps, Capability.Touch)).to_equal(true)
            Err(e) :
                expect(false).to_equal(true)

    slow_it "render_image returns Ok(true)":
        val result = create_backend("web", 0)
        match result:
            Ok(backend) :
                val node = WidgetNode.new("web_img", WidgetKind.Image)
                val rect = WidgetRect.new("web_img", 0, 0, 200, 150)
                val img_result = backend.render_image(node, rect)
                match img_result:
                    Ok(v) :
                        expect(v).to_equal(true)
                    Err(ns) :
                        expect(false).to_equal(true)
            Err(e) :
                expect(false).to_equal(true)

# ============================================================================
# 3. None (Headless) Backend Capabilities
# ============================================================================

describe "None backend capability negotiation":
    slow_it "reports empty capabilities":
        val result = create_backend("none", 0)
        match result:
            Ok(backend) :
                val caps = backend.capabilities()
                expect(caps.len()).to_equal(0)
            Err(e) :
                expect(false).to_equal(true)

    slow_it "show_notification returns Err(NotSupported)":
        val result = create_backend("none", 0)
        match result:
            Ok(backend) :
                val notif_result = backend.show_notification("Test", "Body text")
                match notif_result:
                    Err(ns) :
                        expect(ns.capability).to_equal(Capability.Notification)
                    Ok(v) :
                        expect(false).to_equal(true)
            Err(e) :
                expect(false).to_equal(true)

# ============================================================================
# 4. Tauri Backend Capabilities
# ============================================================================

describe "Tauri backend capability negotiation":
    slow_it "reports Mouse, Color, Images, NativeDialogs, and Notification":
        val result = create_backend("tauri", 0)
        match result:
            Ok(backend) :
                val caps = backend.capabilities()
                expect(has_capability(caps, Capability.Mouse)).to_equal(true)
                expect(has_capability(caps, Capability.Color)).to_equal(true)
                expect(has_capability(caps, Capability.Images)).to_equal(true)
                expect(has_capability(caps, Capability.NativeDialogs)).to_equal(true)
                expect(has_capability(caps, Capability.Notification)).to_equal(true)
            Err(e) :
                expect(false).to_equal(true)

# ============================================================================
# 5. Cross-backend has_capability helper
# ============================================================================

describe "has_capability helper":
    slow_it "returns false for empty list":
        val caps: [Capability] = []
        expect(has_capability(caps, Capability.Mouse)).to_equal(false)

    slow_it "returns true when capability is present":
        val caps = [Capability.Color, Capability.Mouse]
        expect(has_capability(caps, Capability.Color)).to_equal(true)
        expect(has_capability(caps, Capability.Mouse)).to_equal(true)

    slow_it "returns false when capability is absent":
        val caps = [Capability.Color]
        expect(has_capability(caps, Capability.Images)).to_equal(false)
        expect(has_capability(caps, Capability.Touch)).to_equal(false)

# ============================================================================
# 6. Unknown backend mode
# ============================================================================

describe "Backend factory error handling":
    slow_it "returns Err for unknown mode":
        val result = create_backend("unknown_backend", 0)
        match result:
            Err(e) :
                expect(e).to_contain("Unknown backend mode")
            Ok(v) :
                expect(false).to_equal(true)
