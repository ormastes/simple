# @cover app.ui.render.widgets
# @gui: headless

# @tag:system

use std.spec.*

use common.ui.parse.sdn.{parse_ui_file}
use common.ui.state.{init_state}
use app.ui.render.widgets.{render_html_tree}

# ============================================================================
# Test Group 1: Demo UI Widget Rendering
# ============================================================================

describe "Widget HTML Rendering — Demo UI":

    it "renders demo.ui.sdn to HTML":
        val tree_result = parse_ui_file("examples/ui/demo.ui.sdn")
        match tree_result:
            Ok(tree) :
                val state = init_state(tree)
                val html = render_html_tree(state.tree.root, state)
                expect(html.len()).to_be_greater_than(50)
            Err(e) :
                expect(false).to_equal(true)

    it "contains widget CSS classes":
        val tree_result = parse_ui_file("examples/ui/demo.ui.sdn")
        match tree_result:
            Ok(tree) :
                val state = init_state(tree)
                val html = render_html_tree(state.tree.root, state)
                # HTML should contain widget type classes
                expect(html).to_contain("widget-")
            Err(e) :
                expect(false).to_equal(true)

# ============================================================================
# Test Group 2: Minimal UI Widget Rendering
# ============================================================================

describe "Widget HTML Rendering — Minimal UI":

    it "renders minimal.ui.sdn to HTML":
        val tree_result = parse_ui_file("examples/ui/minimal.ui.sdn")
        match tree_result:
            Ok(tree) :
                val state = init_state(tree)
                val html = render_html_tree(state.tree.root, state)
                expect(html.len()).to_be_greater_than(0)
            Err(e) :
                expect(false).to_equal(true)

# ============================================================================
# Test Group 3: Layout Containers
# ============================================================================

describe "Widget HTML Rendering — Layout Containers":

    it "produces layout classes":
        val tree_result = parse_ui_file("examples/ui/demo.ui.sdn")
        match tree_result:
            Ok(tree) :
                val state = init_state(tree)
                val html = render_html_tree(state.tree.root, state)
                # Layout types should produce CSS classes
                expect(html).to_contain("layout-")
            Err(e) :
                expect(false).to_equal(true)
