# @cover src/os/compositor/wm_consistency_runner.spl 90%
# @cover src/os/compositor/perceptual_compare.spl 80%
# @cover src/os/compositor/electron_capture.spl 80%
# @cover src/os/compositor/qemu_capture.spl 80%
# @cover src/os/compositor/wm_scene.spl 80%
# @cover src/os/compositor/tolerance_profile.spl 80%
# @cover src/os/compositor/diff_export.spl 60%
# @cover src/os/compositor/screenshot_compare.spl 60%
# @tag: system, rendering, pixel, golden, wm
#
# WM Pixel Consistency — Golden Test Specification
#
# End-to-end golden test: renders a standard WM scene through the unified
# host and in-process capture paths, then asserts pixel-level consistency
# (100% match) with a tolerance profile.
# On failure, diff artifacts are exported for diagnosis.
#
# This is the primary acceptance test for AC-5 (golden test) and integrates
# all modules in the wm-pixel-consistency pipeline.

use std.spec.{describe, context, it, expect}
use os.compositor.wm_consistency_runner.{
    ConsistencyReport, run_consistency_check, consistency_report_to_markdown}
use os.compositor.wm_scene.{
    WmSceneSpec, standard_wm_scene, render_scene_to_backend, scene_to_html}
use os.compositor.tolerance_profile.{
    ToleranceProfile, profile_strict, profile_wm_default, profile_glass_blur}
use os.compositor.perceptual_compare.{compare_perceptual}
use os.compositor.electron_capture.{CaptureResult, capture_electron_scene}
use os.compositor.qemu_capture.{capture_qemu_inprocess}
use os.compositor.diff_export.{export_diff_artifacts}
use os.compositor.screenshot_compare.{
    compare_with_profile, compare_pixel_buffers, generate_diff_image}

# ============================================================================
# Constants
# ============================================================================

val SCENE_W: i32 = 800
val SCENE_H: i32 = 600
val MIN_MATCH_PCT: i64 = 10000  # 100.00% minimum pixel match

# ============================================================================
# Test Group 1: Golden Test — Full Pipeline (AC-5)
# ============================================================================

describe "WM Pixel Consistency — Golden Test":

    context "standard WM scene":

        it "AC-5: reference scene renders through both capture paths":
            val scene = standard_wm_scene(SCENE_W, SCENE_H)
            val profile = profile_wm_default()
            val report = run_consistency_check(scene, profile)
            # Both captures should have succeeded and used the unified renderer
            val host_captured = report.electron_capture.success and report.electron_capture.backend_name == "browser_compositor"
            val qemu_captured = report.qemu_capture.success and report.qemu_capture.backend_name == "browser_compositor"
            expect(host_captured).to_equal(true)
            expect(qemu_captured).to_equal(true)

        it "AC-5: pixel match percentage is 100% with wm_default profile":
            val scene = standard_wm_scene(SCENE_W, SCENE_H)
            val profile = profile_wm_default()
            val report = run_consistency_check(scene, profile)
            val passes = report.overall.match_percentage >= MIN_MATCH_PCT
            expect(passes).to_equal(true)

        it "AC-5: golden test passes with tolerance profile":
            val scene = standard_wm_scene(SCENE_W, SCENE_H)
            val profile = profile_wm_default()
            val report = run_consistency_check(scene, profile)
            expect(report.passed).to_equal(true)

    context "strict comparison baseline":

        it "AC-5: strict profile comparison provides baseline metrics":
            val scene = standard_wm_scene(SCENE_W, SCENE_H)
            val profile = profile_strict()
            val report = run_consistency_check(scene, profile)
            # Strict may not pass, but should return valid metrics
            val valid_pct = report.overall.match_percentage >= 0 and report.overall.match_percentage <= 10000
            expect(valid_pct).to_equal(true)

# ============================================================================
# Test Group 2: Scene Rendering Validity (AC-2, AC-3)
# ============================================================================

describe "WM Pixel Consistency — Scene Rendering":

    context "Electron capture":

        it "AC-2: Electron captures non-empty pixel buffer for WM scene":
            val scene = standard_wm_scene(SCENE_W, SCENE_H)
            val result = capture_electron_scene(scene)
            if result.success:
                expect(result.pixels.len()).to_be_greater_than(0)
            else:
                # In environments without Electron, capture returns error
                val has_error = result.error.len() > 0
                expect(has_error).to_equal(true)

        it "AC-2: Electron capture produces correct-sized buffer":
            val scene = standard_wm_scene(SCENE_W, SCENE_H)
            val result = capture_electron_scene(scene)
            if result.success:
                val expected = SCENE_W * SCENE_H
                expect(result.pixels.len().to_i32()).to_equal(expected)
            else:
                expect(result.success).to_equal(false)

    context "QEMU in-process capture":

        it "AC-3: QEMU in-process captures non-empty pixel buffer":
            val scene = standard_wm_scene(SCENE_W, SCENE_H)
            val result = capture_qemu_inprocess(scene)
            expect(result.pixels.len()).to_be_greater_than(0)

        it "AC-3: QEMU in-process produces correct-sized buffer":
            val scene = standard_wm_scene(SCENE_W, SCENE_H)
            val result = capture_qemu_inprocess(scene)
            val expected = SCENE_W * SCENE_H
            expect(result.pixels.len().to_i32()).to_equal(expected)

# ============================================================================
# Test Group 3: Cross-Backend Comparison Details (AC-4)
# ============================================================================

describe "WM Pixel Consistency — Comparison Details":

    context "channel-level metrics":

        it "AC-4: comparison reports max channel diff":
            val scene = standard_wm_scene(SCENE_W, SCENE_H)
            val profile = profile_wm_default()
            val report = run_consistency_check(scene, profile)
            val valid_diff = report.overall.max_channel_diff >= 0
            expect(valid_diff).to_equal(true)

        it "AC-4: comparison reports per-channel results":
            val scene = standard_wm_scene(SCENE_W, SCENE_H)
            val profile = profile_wm_default()
            val report = run_consistency_check(scene, profile)
            expect(report.channels.len()).to_be_greater_than(0)

    context "diff region detection":

        it "AC-4: comparison detects diff regions (if any)":
            val scene = standard_wm_scene(SCENE_W, SCENE_H)
            val profile = profile_wm_default()
            val report = run_consistency_check(scene, profile)
            # diff_regions is a list — may be empty if perfectly matched
            val is_list = report.diff_regions.len() >= 0
            expect(is_list).to_equal(true)

    context "perceptual comparison":

        it "AC-4: perceptual result reports AA pixel count":
            val scene = standard_wm_scene(SCENE_W, SCENE_H)
            val profile = profile_wm_default()
            val report = run_consistency_check(scene, profile)
            val valid_aa = report.perceptual.aa_pixels >= 0
            expect(valid_aa).to_equal(true)

        it "AC-4: perceptual match percentage is available":
            val scene = standard_wm_scene(SCENE_W, SCENE_H)
            val profile = profile_wm_default()
            val report = run_consistency_check(scene, profile)
            val valid_pct = report.perceptual.match_percentage >= 0 and report.perceptual.match_percentage <= 10000
            expect(valid_pct).to_equal(true)

# ============================================================================
# Test Group 4: Diff Visualization on Failure (AC-6)
# ============================================================================

describe "WM Pixel Consistency — Diff Visualization":

    context "diff export on mismatch":

        it "AC-6: diff artifacts can be exported from consistency report":
            val scene = standard_wm_scene(SCENE_W, SCENE_H)
            val profile = profile_strict()
            val report = run_consistency_check(scene, profile)
            val exported = export_diff_artifacts(report, "/tmp/wm_consistency_diff")
            val is_bool = exported == true or exported == false
            expect(is_bool).to_equal(true)

        it "AC-6: diff image generation works with captured buffers":
            val scene = standard_wm_scene(SCENE_W, SCENE_H)
            val electron = capture_electron_scene(scene)
            val qemu = capture_qemu_inprocess(scene)
            if electron.success:
                val diff = generate_diff_image(
                    electron.pixels, qemu.pixels, SCENE_W, SCENE_H, 4)
                expect(diff.len()).to_be_greater_than(0)
            else:
                # Electron unavailable in test environment
                expect(electron.success).to_equal(false)

# ============================================================================
# Test Group 5: Report Generation (AC-1, AC-7)
# ============================================================================

describe "WM Pixel Consistency — Report":

    context "markdown report":

        it "AC-1: consistency report produces markdown documentation":
            val scene = standard_wm_scene(SCENE_W, SCENE_H)
            val profile = profile_wm_default()
            val report = run_consistency_check(scene, profile)
            val md = consistency_report_to_markdown(report)
            expect(md.len()).to_be_greater_than(100)

        it "AC-1: markdown includes industry comparison methodology":
            val scene = standard_wm_scene(SCENE_W, SCENE_H)
            val profile = profile_wm_default()
            val report = run_consistency_check(scene, profile)
            val md = consistency_report_to_markdown(report)
            val has_methodology = md.contains("YIQ") or md.contains("perceptual") or md.contains("pixelmatch")
            expect(has_methodology).to_equal(true)

        it "AC-7: markdown documents rendering divergence root causes":
            val scene = standard_wm_scene(SCENE_W, SCENE_H)
            val profile = profile_wm_default()
            val report = run_consistency_check(scene, profile)
            val md = consistency_report_to_markdown(report)
            val has_root_cause = md.contains("font") or md.contains("anti-alias") or md.contains("color space") or md.contains("blur")
            expect(has_root_cause).to_equal(true)

        it "AC-7: markdown documents normalization strategies":
            val scene = standard_wm_scene(SCENE_W, SCENE_H)
            val profile = profile_wm_default()
            val report = run_consistency_check(scene, profile)
            val md = consistency_report_to_markdown(report)
            val has_strategy = md.contains("normaliz") or md.contains("Normaliz") or md.contains("mitigation") or md.contains("strategy")
            expect(has_strategy).to_equal(true)
