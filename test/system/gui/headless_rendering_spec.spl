# @cover app.ui.none.app
# @cover app.ui.render.widgets
# @gui: headless

# @tag:system

use std.spec.*

use app.ui.none.app.{HeadlessApp}

# ============================================================================
# Test Group 1: Minimal UI Rendering
# ============================================================================

describe "Headless Rendering — Minimal UI":

    it "renders minimal.ui.sdn without errors":
        val result = HeadlessApp.new("examples/ui/minimal.ui.sdn")
        match result:
            Ok(app) =>
                val run_result = app.run()
                match run_result:
                    Ok(_) =>
                        expect(app.render_count()).to_be_greater_than(0)
                    Err(e) =>
                        expect(false).to_equal(true)
            Err(e) =>
                expect(false).to_equal(true)

    it "produces HTML output":
        val result = HeadlessApp.new("examples/ui/minimal.ui.sdn")
        match result:
            Ok(app) =>
                val run_result = app.run()
                match run_result:
                    Ok(_) =>
                        val html = app.last_html()
                        expect(html.len()).to_be_greater_than(0)
                    Err(e) =>
                        expect(false).to_equal(true)
            Err(e) =>
                expect(false).to_equal(true)

# ============================================================================
# Test Group 2: Demo UI Rendering
# ============================================================================

describe "Headless Rendering — Demo UI":

    it "renders demo.ui.sdn without errors":
        val result = HeadlessApp.new("examples/ui/demo.ui.sdn")
        match result:
            Ok(app) =>
                val run_result = app.run()
                match run_result:
                    Ok(_) =>
                        expect(app.render_count()).to_be_greater_than(0)
                    Err(e) =>
                        expect(false).to_equal(true)
            Err(e) =>
                expect(false).to_equal(true)

    it "contains widget IDs in HTML":
        val result = HeadlessApp.new("examples/ui/demo.ui.sdn")
        match result:
            Ok(app) =>
                val run_result = app.run()
                match run_result:
                    Ok(_) =>
                        val html = app.last_html()
                        # demo.ui.sdn should have identifiable widgets
                        expect(html.len()).to_be_greater_than(10)
                    Err(e) =>
                        expect(false).to_equal(true)
            Err(e) =>
                expect(false).to_equal(true)

# ============================================================================
# Test Group 3: Error Handling
# ============================================================================

describe "Headless Rendering — Error Handling":

    it "returns error for nonexistent file":
        val result = HeadlessApp.new("nonexistent.ui.sdn")
        match result:
            Ok(_) =>
                # May succeed with empty tree — that's ok
                expect(true).to_equal(true)
            Err(e) =>
                expect(e.len()).to_be_greater_than(0)
