# Minimal Glass Pixel Runner
# Ultra-simple standalone entry point for diagnosing native-build issues

print "=== Minimal Glass Pixel Runner ==="
print "Step 1: Basic print works"

# Try importing just the DOM
use std.gc_async_mut.gpu.browser_engine.dom.{BeDomNode}

print "Step 2: DOM import loaded"

var root = BeDomNode.element("div")
print "Step 3: DOM element created, tag={root.tag}"

root.set_style("background-color", "rgba(30,30,35,0.72)")
print "Step 4: Style set"

root.set_style("width", "200px")
root.set_style("height", "100px")
print "Step 5: Dimensions set"

var text_node = BeDomNode.text("Hello Glass")
root.add_child(text_node)
print "Step 6: Text child added, children={root.children.len()}"

use std.gc_async_mut.gpu.browser_engine.browser_renderer.{BrowserRenderer}

print "Step 7: BrowserRenderer import loaded"

var renderer = BrowserRenderer.create(200, 100)
print "Step 8: Renderer created, viewport={renderer.viewport_w}x{renderer.viewport_h}"

val result = renderer.render_dom_to_pixels(root)
print "Step 9: Rendered to pixels: {result.pixel_data.len()} pixels, {result.node_count} nodes"

use os.compositor.screenshot_compare.{compare_pixel_buffers, print_comparison_report}

print "Step 10: Comparison import loaded"

val self_cmp = compare_pixel_buffers(result.pixel_data, result.pixel_data, 200, 100, 0)
print "Step 11: Self-comparison done"
print_comparison_report(self_cmp)

print "=== DONE ==="
