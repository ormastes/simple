#![allow(spipe_empty_examples)]
#![allow(spipe_boolean_wrapper_assertions)]
@allow(spipe_empty_examples)
@allow(spipe_boolean_wrapper_assertions)
use std.gc_async_mut.gpu.browser_engine.glass_demo_registry.{GlassDemo,
use std.gc_async_mut.gpu.browser_engine.glass_pipeline_compare.{PipelineOutput,
use std.gc_async_mut.gpu.browser_engine.glass_comparison_runner.{GlassComparisonReport,
use os.compositor.screenshot_compare.{ComparisonResult, ChannelDiffResult,


fn main():
    # @cover src/lib/gc_async_mut/gpu/browser_engine/browser_renderer.spl 60%
    # @cover src/lib/gc_async_mut/gpu/browser_engine/glass_pipeline_compare.spl 80%
    # @cover src/os/compositor/screenshot_compare.spl 80%

    # @tag:system


        list_core_glass_demos, list_glass_demos, list_glass_demos_dark_only}
        render_both_pipelines, render_web_pipeline_only, render_engine_pipeline_only}
        GlassComparisonResult, run_glass_comparison, run_core_glass_comparison,
        print_glass_report, glass_report_to_markdown, identify_missing_features,
        DEFAULT_WIDTH, DEFAULT_HEIGHT, DEFAULT_THRESHOLD}
        compare_pixel_buffers, compare_per_channel, generate_diff_image,
        print_comparison_report, print_channel_report}

    # ============================================================================
    # Test Group 1: Single Demo Pipeline Comparison
    # ============================================================================

    describe "Glass pixel comparison — single demo":

        it "renders minimal.ui.sdn through both pipelines without error":
            val output = render_both_pipelines(
                "examples/ui/minimal.ui.sdn", "glass_dark",
                DEFAULT_WIDTH, DEFAULT_HEIGHT)
            expect output.error == ""
            expect output.web_pixels.len() > 0
            expect output.engine_pixels.len() > 0

        it "renders demo_basics.ui.sdn through both pipelines":
            val output = render_both_pipelines(
                "examples/ui/demo_basics.ui.sdn", "glass_dark",
                DEFAULT_WIDTH, DEFAULT_HEIGHT)
            expect output.error == ""
            expect output.web_pixels.len() > 0
            expect output.engine_pixels.len() > 0

        it "pixel buffers have correct size":
            val output = render_both_pipelines(
                "examples/ui/minimal.ui.sdn", "glass_dark",
                DEFAULT_WIDTH, DEFAULT_HEIGHT)
            val expected_len = DEFAULT_WIDTH * DEFAULT_HEIGHT
            expect output.web_pixels.len().to_i32() == expected_len
            expect output.engine_pixels.len().to_i32() == expected_len

    # ============================================================================
    # Test Group 2: Per-Channel Bit-Field Comparison
    # ============================================================================

    describe "Glass pixel comparison — per-channel bit-field diff":

        it "compares R/G/B/A channels independently":
            val output = render_both_pipelines(
                "examples/ui/minimal.ui.sdn", "glass_dark",
                DEFAULT_WIDTH, DEFAULT_HEIGHT)
            expect output.error == ""

            val channels = compare_per_channel(
                output.web_pixels, output.engine_pixels,
                DEFAULT_WIDTH, DEFAULT_HEIGHT, DEFAULT_THRESHOLD)

            expect channels.len().to_i32() == 4
            expect channels[0].channel == "R"
            expect channels[1].channel == "G"
            expect channels[2].channel == "B"
            expect channels[3].channel == "A"

            # Each channel reports valid percentages (0-10000)
            for ch in channels:
                expect ch.match_pct > -1

        it "overall comparison matches pixel buffer sizes":
            val output = render_both_pipelines(
                "examples/ui/minimal.ui.sdn", "glass_dark",
                DEFAULT_WIDTH, DEFAULT_HEIGHT)
            val result = compare_pixel_buffers(
                output.web_pixels, output.engine_pixels,
                DEFAULT_WIDTH, DEFAULT_HEIGHT, DEFAULT_THRESHOLD)
            val expected_total = DEFAULT_WIDTH.to_i64() * DEFAULT_HEIGHT.to_i64()
            expect result.total_pixels == expected_total

        it "generates diff image without crashing":
            val output = render_both_pipelines(
                "examples/ui/minimal.ui.sdn", "glass_dark",
                DEFAULT_WIDTH, DEFAULT_HEIGHT)
            val diff_img = generate_diff_image(
                output.web_pixels, output.engine_pixels,
                DEFAULT_WIDTH, DEFAULT_HEIGHT)
            val expected_len = DEFAULT_WIDTH * DEFAULT_HEIGHT
            expect diff_img.len().to_i32() == expected_len

    # ============================================================================
    # Test Group 3: Missing Feature Detection
    # ============================================================================

    describe "Glass pixel comparison — CSS feature gap detection":

        it "detects backdrop-filter in glass CSS":
            val output = render_web_pipeline_only(
                "examples/ui/demo_basics.ui.sdn", "glass_dark",
                DEFAULT_WIDTH, DEFAULT_HEIGHT)
            val missing = identify_missing_features(output.web_html)
            expect (missing).contains("backdrop-filter: blur()")

        it "detects box-shadow in glass CSS":
            val output = render_web_pipeline_only(
                "examples/ui/demo_basics.ui.sdn", "glass_dark",
                DEFAULT_WIDTH, DEFAULT_HEIGHT)
            val missing = identify_missing_features(output.web_html)
            expect (missing).contains("box-shadow (multi-layer)")

        it "detects linear-gradient in glass CSS":
            val output = render_web_pipeline_only(
                "examples/ui/demo_basics.ui.sdn", "glass_dark",
                DEFAULT_WIDTH, DEFAULT_HEIGHT)
            val missing = identify_missing_features(output.web_html)
            expect (missing).contains("linear-gradient()")

    # ============================================================================
    # Test Group 4: Core Demo Suite (Baseline)
    # ============================================================================

    describe "Glass pixel comparison — core demo suite":

        slow_it "runs core glass comparison (3 demos × 2 themes)":
            val report = run_core_glass_comparison()
            expect report.total_demos == 6
            # Baseline: all demos should run without error
            for r in report.results:
                expect r.error == ""

        slow_it "generates markdown report":
            val report = run_core_glass_comparison()
            val md = glass_report_to_markdown(report)
            expect md.len() > 100
            expect (md).contains("Glass Pipeline Comparison Report")
            expect (md).contains("Per-Demo Results")

    # ============================================================================
    # Test Group 5: Light vs Dark Theme
    # ============================================================================

    describe "Glass pixel comparison — theme variants":

        it "glass_dark and glass_light produce different pixels":
            val dark = render_engine_pipeline_only(
                "examples/ui/minimal.ui.sdn", "glass_dark",
                DEFAULT_WIDTH, DEFAULT_HEIGHT)
            val light = render_engine_pipeline_only(
                "examples/ui/minimal.ui.sdn", "glass_light",
                DEFAULT_WIDTH, DEFAULT_HEIGHT)
            expect dark.error == ""
            expect light.error == ""

            # They should differ (different background/text colors)
            val result = compare_pixel_buffers(
                dark.engine_pixels, light.engine_pixels,
                DEFAULT_WIDTH, DEFAULT_HEIGHT, 0)
            # Not identical
            expect result.different_pixels > 0

    # ============================================================================
    # Test Group 6: Full Suite (Slow)
    # ============================================================================

    describe "Glass pixel comparison — full suite":

        slow_it "runs full demo catalog dark-theme lane and produces complete report":
            val demos = list_glass_demos_dark_only()
            val report = run_glass_comparison(demos, DEFAULT_WIDTH, DEFAULT_HEIGHT)
            val md = glass_report_to_markdown(report)
            expect report.total_demos == demos.len().to_i32()
            expect (md).contains("Glass Pipeline Comparison Report")

            # All demos should parse and render without error
            for r in report.results:
                expect r.error == ""