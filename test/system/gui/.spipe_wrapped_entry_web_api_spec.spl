#![allow(spipe_empty_examples)]
#![allow(spipe_boolean_wrapper_assertions)]
@allow(spipe_empty_examples)
@allow(spipe_boolean_wrapper_assertions)
use app.ui.web.html.{generate_html_page, generate_wm_html_page, generate_css, generate_js, generate_wm_js}
use common.ui.parse.sdn_tree.{parse_ui_to_tree}
use common.ui.state.{init_state}

fn web_api_html(path: text, port: i32) -> text:
    val tree_result = parse_ui_to_tree(path)
    match tree_result:
        Ok(tree):
            val state = init_state(tree)
            return generate_html_page(state, port)
        Err(e):
            return "ERROR: {e}"

fn main():
    # @cover src/app/ui.web/html.spl 80%
    # @cover src/app/ui.render/widgets.spl 80%
    # @gui: headless

    # @tag:system


    # ============================================================================
    # Web HTML/JSON generation — system-level tests (no TCP needed)
    # ============================================================================

    describe "generate_html_page":

        slow_it "produces a full HTML page from demo.ui.sdn":
            val html = web_api_html("examples/ui/demo.ui.sdn", 3000)
            # Must start with DOCTYPE
            expect (html).starts_with("<!DOCTYPE html>")
            # Must contain essential HTML structure
            expect (html).contains("<html")
            expect (html).contains("<head>")
            expect (html).contains("<body>")
            expect (html).contains("</html>")
            # Must contain style and script tags
            expect (html).contains("<style>")
            expect (html).contains("<script>")
            # Must contain the app title
            expect (html).contains("Simple UI Demo")
            # Must contain widget content from the demo
            expect (html).contains("widget-panel")
            expect (html).contains("widget-statusbar")

        slow_it "produces a full HTML page from minimal.ui.sdn":
            val html = web_api_html("examples/ui/minimal.ui.sdn", 8080)
            expect (html).starts_with("<!DOCTYPE html>")
            expect (html).contains("<title>Minimal</title>")
            expect (html).contains("widget-panel")
            expect (html).contains("Hello from Simple UI!")

    describe "generate_css":

        slow_it "dark theme contains dark background color":
            val css = generate_css("dark")
            expect css.len() > 0
            # Dark theme uses #1e1e2e background
            expect (css).contains("#1e1e2e")
            # Dark theme text color
            expect (css).contains("#cdd6f4")
            # Must contain widget classes
            expect (css).contains(".widget-panel")
            expect (css).contains(".widget-statusbar")

        slow_it "light theme contains light background color":
            val css = generate_css("light")
            expect css.len() > 0
            # Light theme uses #ffffff background
            expect (css).contains("#ffffff")
            # Light theme text color
            expect (css).contains("#333333")

        slow_it "dark and light themes produce different output":
            val dark_css = generate_css("dark")
            val light_css = generate_css("light")
            expect dark_css != light_css == true

        slow_it "glass obsidian theme serializes real CSS color values":
            val css = generate_css("glass_obsidian_dark")
            expect (css).contains("--ui-bg: #060612")
            expect (css).contains("--ui-text: #E3E0F3")
            expect (css).contains("--glass-accent: #C6C6C8")
            expect css.contains("Object { class") == false
            expect css.contains("+ WM_TRAFFIC") == false

    describe "generate_js":

        slow_it "produces WebSocket connection code":
            val js = generate_js(3000)
            expect js.len() > 0
            expect (js).contains("WebSocket")
            expect (js).contains("connect")
            expect (js).contains("3000")
            expect (js).contains("keydown")

        slow_it "uses correct port in WebSocket URL":
            val js = generate_js(9999)
            expect (js).contains("9999")

    describe "generate_wm_js":

        slow_it "boots immediately when the document is already loaded":
            val js = generate_wm_js(3333)
            expect (js).contains("document.readyState === 'complete'")
            expect (js).contains("bootWMAfterLoad();")
            expect (js).contains("new SimpleWindowManager()")

        slow_it "retries stalled or errored websocket connections":
            val js = generate_wm_js(3333)
            expect (js).contains("let reconnectTimer = null")
            expect (js).contains("let connectDeadline = null")
            expect (js).contains("ws.readyState === 0")
            expect (js).contains("WM WebSocket still connecting after startup grace period")
            expect (js).contains("ws.onerror")
            expect (js).contains("scheduleReconnect()")

    describe "generate_wm_html_page":

        slow_it "produces the SimpleOS WM shell scaffold":
            val html = generate_wm_html_page("glass_obsidian_dark", "SimpleOS Web WM", 3333)
            expect (html).starts_with("<!DOCTYPE html>")
            expect (html).contains("<title>SimpleOS Web WM</title>")
            expect (html).contains("<div id=\"wm-desktop\"></div>")
            expect (html).contains("<div id=\"wm-taskbar\"></div>")
            expect (html).contains("WM WebSocket connected")
            expect (html).contains("scheduleReconnect()")