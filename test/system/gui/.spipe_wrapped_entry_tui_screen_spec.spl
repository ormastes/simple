#![allow(spipe_empty_examples)]
#![allow(spipe_boolean_wrapper_assertions)]
@allow(spipe_empty_examples)
@allow(spipe_boolean_wrapper_assertions)
use app.ui.tui.screen.{Screen}
use app.ui.render.widgets.{render_tui_tree}
use common.ui.widget.{UIState, UITree, WidgetNode, WidgetKind, WidgetRect}
use common.ui.layout.{compute_layout}
use common.ui.parse.sdn_tree.{parse_ui_to_tree}
use common.ui.state.{init_state}


fn main():
    # @cover src/app/ui.tui/screen.spl 80%
    # @cover src/app/ui.render/widgets.spl 80%
    # @cover src/lib/common/ui/layout.spl 80%
    # @gui: headless

    # @tag:system


    # ============================================================================
    # TUI Screen buffer rendering — system-level tests
    # ============================================================================

    describe "Screen buffer basics":

        slow_it "creates screen with correct dimensions":
            val screen = Screen.new(80, 24)
            expect screen.width == 80
            expect screen.height == 24
            expect screen.buffer.len() == 24

        slow_it "put_text writes content at position":
            var screen = Screen.new(40, 10)
            screen = screen.put_text(0, 0, "Hello")
            val line = screen.buffer[0]
            expect (line).starts_with("Hello")

        slow_it "draw_box produces box-drawing characters":
            var screen = Screen.new(40, 10)
            screen = screen.draw_box(0, 0, 20, 5, "Test")
            val rendered = screen.render()
            # Box-drawing characters: top-left corner
            expect (rendered).contains("\u{250c}")
            # Horizontal line
            expect (rendered).contains("\u{2500}")
            # Top-right corner
            expect (rendered).contains("\u{2510}")
            # Vertical border
            expect (rendered).contains("\u{2502}")
            # Bottom-left corner
            expect (rendered).contains("\u{2514}")
            # Bottom-right corner
            expect (rendered).contains("\u{2518}")

        slow_it "render produces non-empty output":
            val screen = Screen.new(80, 24)
            val output = screen.render()
            expect output.len() > 0

        slow_it "clear resets the buffer":
            var screen = Screen.new(40, 10)
            screen = screen.put_text(0, 0, "Some text")
            val cleared = screen.clear()
            # After clearing, the first line should just be spaces
            val line = cleared.buffer[0]
            expect (line).starts_with(" ")

    describe "Screen with UI tree rendering":

        slow_it "renders minimal.ui.sdn tree to screen buffer":
            val tree_result = parse_ui_to_tree("examples/ui/minimal.ui.sdn")
            match tree_result:
                Ok(tree) :
                    val state = init_state(tree)
                    val rects = compute_layout(state.tree.root, 0, 0, 80, 24)

                    var screen = Screen.new(80, 24)
                    screen = render_tui_tree(screen, state.tree.root, rects, state)

                    val output = screen.render()
                    # Output should be non-empty
                    expect output.len() > 100
                    # Should contain box-drawing for the panel
                    expect (output).contains("\u{250c}")
                    expect (output).contains("\u{2500}")
                    expect (output).contains("\u{2510}")
                Err(e) :
                    expect false == true

        slow_it "renders demo.ui.sdn tree with multiple widgets":
            val tree_result = parse_ui_to_tree("examples/ui/demo.ui.sdn")
            match tree_result:
                Ok(tree) :
                    val state = init_state(tree)
                    val rects = compute_layout(state.tree.root, 0, 0, 120, 40)

                    var screen = Screen.new(120, 40)
                    screen = render_tui_tree(screen, state.tree.root, rects, state)

                    val output = screen.render()
                    # Output should be substantial for a complex layout
                    expect output.len() > 200
                    # Should contain vertical borders from panels
                    expect (output).contains("\u{2502}")
                    # Should contain bottom corners from panels
                    expect (output).contains("\u{2518}")
                Err(e) :
                    expect false == true

    describe "Screen drawing primitives":

        slow_it "draw_hline produces a horizontal line":
            var screen = Screen.new(40, 10)
            screen = screen.draw_hline(2, 0, 20, "\u{2500}")
            val line = screen.buffer[2]
            expect (line).contains("\u{2500}")

        slow_it "draw_vline produces a vertical line":
            var screen = Screen.new(40, 10)
            screen = screen.draw_vline(0, 5, 5, "\u{2502}")
            # Each row from 0..4 should have the vertical char at col 5
            val row0 = screen.buffer[0]
            val row4 = screen.buffer[4]
            expect (row0).contains("\u{2502}")
            expect (row4).contains("\u{2502}")

        slow_it "fill_row fills entire row":
            var screen = Screen.new(20, 5)
            screen = screen.fill_row(1, "#")
            val line = screen.buffer[1]
            expect (line).starts_with("#")
            expect (line).ends_with("#")
            expect line.len() == 20

        slow_it "put_styled includes style codes":
            var screen = Screen.new(40, 5)
            screen = screen.put_styled(0, 0, "Bold", "\u{001b}[1m")
            val line = screen.buffer[0]
            # Should contain the ANSI bold escape
            expect (line).contains("\u{001b}[1m")
            # Should contain the text
            expect (line).contains("Bold")