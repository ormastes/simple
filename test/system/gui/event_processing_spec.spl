# ============================================================================
# Test Group 3: State Changes
# ============================================================================

describe "Event Processing — State Changes":

    it "tracks state after events":
        val result = HeadlessApp.new("examples/ui/minimal.ui.sdn")
        match result:
            Ok(app) :
                val state_before = app.current_state()
                app.inject_event(UIEvent.KeyPress(key: "j"))
                app.inject_event(UIEvent.Quit)
                val run_result = app.run()
                match run_result:
                    Ok(_) :
                        expect(true).to_equal(true)
                    Err(e) :
                        expect(false).to_equal(true)
            Err(e) :
                expect(false).to_equal(true)

# ============================================================================
# Test Group 4: Quit Handling
# ============================================================================

describe "Event Processing — Quit Handling":

    it "stops on Quit event":
        val result = HeadlessApp.new("examples/ui/minimal.ui.sdn")
        match result:
            Ok(app) :
                app.inject_event(UIEvent.Quit)
                val run_result = app.run()
                match run_result:
                    Ok(_) :
                        expect(true).to_equal(true)
                    Err(e) :
                        expect(false).to_equal(true)
            Err(e) :
                expect(false).to_equal(true)

# ============================================================================
# Test Group 5: Resize Events
# ============================================================================

describe "Event Processing — Resize Events":

    it "handles resize without crashing":
        val result = HeadlessApp.new("examples/ui/minimal.ui.sdn")
        match result:
            Ok(app) :
                app.inject_event(UIEvent.Resize(width: 120, height: 40))
                app.inject_event(UIEvent.Quit)
                val run_result = app.run()
                match run_result:
                    Ok(_) :
                        expect(true).to_equal(true)
                    Err(e) :
                        expect(false).to_equal(true)
            Err(e) :
                expect(false).to_equal(true)
