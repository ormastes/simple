# @cover src/lib/common/ui/app.spl 80%
# @cover src/lib/common/ui/backend_factory.spl 80%
# @cover src/app/ui.none/backend.spl 80%
# @gui: headless

use common.ui.app.{UnifiedApp, AppConfig}
use common.ui.backend_factory.{create_backend}
use common.ui.widget.{UIEvent, UIMode}
use common.ui.state.{init_state}
use common.ui.parse.sdn.{parse_ui_file}

# ============================================================================
# UnifiedApp with NoneBackend — system-level lifecycle tests
# ============================================================================

describe "UnifiedApp lifecycle":

    slow_it "runs minimal app with Quit event and completes":
        val backend_result = create_backend("none", 3000)
        match backend_result:
            Ok(backend) :
                # Inject a Quit event so the run loop terminates
                backend.inject_event(UIEvent.Quit)
                val config = AppConfig.headless()
                val app_result = UnifiedApp.new("examples/ui/minimal.ui.sdn", backend, config)
                match app_result:
                    Ok(app) :
                        val run_result = app.run()
                        match run_result:
                            Ok(v) :
                                expect v == true
                                expect app.is_running() == false
                            Err(e) :
                                expect false == true
                    Err(e) :
                        expect false == true
            Err(e) :
                expect false == true

    slow_it "processes multiple events before quitting with demo.ui.sdn":
        val backend_result = create_backend("none", 3000)
        match backend_result:
            Ok(backend) :
                # Inject FocusNext, InsertMode, NormalMode, then Quit
                backend.inject_event(UIEvent.FocusNext)
                backend.inject_event(UIEvent.InsertMode)
                backend.inject_event(UIEvent.NormalMode)
                backend.inject_event(UIEvent.Quit)
                val config = AppConfig.headless()
                val app_result = UnifiedApp.new("examples/ui/demo.ui.sdn", backend, config)
                match app_result:
                    Ok(app) :
                        val run_result = app.run()
                        match run_result:
                            Ok(v) :
                                expect v == true
                                # Backend should have rendered at least twice (initial + after events)
                                expect backend.render_count() > 1
                            Err(e) :
                                expect false == true
                    Err(e) :
                        expect false == true
            Err(e) :
                expect false == true

    slow_it "returns Err for nonexistent file":
        val backend_result = create_backend("none", 3000)
        match backend_result:
            Ok(backend) :
                val config = AppConfig.headless()
                val app_result = UnifiedApp.new("nonexistent/file.ui.sdn", backend, config)
                match app_result:
                    Ok(_) :
                        # Should not succeed
                        expect false == true
                    Err(e) :
                        expect e.len() > 0
            Err(e) :
                expect false == true

describe "UnifiedApp state inspection":

    slow_it "reports initial state from minimal.ui.sdn":
        val backend_result = create_backend("none", 3000)
        match backend_result:
            Ok(backend) :
                val config = AppConfig.headless()
                val app_result = UnifiedApp.new("examples/ui/minimal.ui.sdn", backend, config)
                match app_result:
                    Ok(app) :
                        val state = app.current_state()
                        expect state.mode_name() == "NORMAL"
                        expect state.tree.title == "Minimal"
                        expect state.tree.theme == "dark"
                    Err(e) :
                        expect false == true
            Err(e) :
                expect false == true

    slow_it "state changes after injecting events via test helper":
        val backend_result = create_backend("none", 3000)
        match backend_result:
            Ok(backend) :
                val config = AppConfig.headless()
                val app_result = UnifiedApp.new("examples/ui/demo.ui.sdn", backend, config)
                match app_result:
                    Ok(app) :
                        # Initial state
                        val s0 = app.current_state()
                        val initial_focus = s0.focused_id

                        # Inject FocusNext via the app helper
                        app.inject_event(UIEvent.FocusNext)
                        val s1 = app.current_state()
                        # Focus should have moved (demo has multiple widgets)
                        expect s1.focused_id != initial_focus == true

                        # Inject InsertMode
                        app.inject_event(UIEvent.InsertMode)
                        val s2 = app.current_state()
                        expect s2.mode_name() == "INSERT"

                        # Inject NormalMode
                        app.inject_event(UIEvent.NormalMode)
                        val s3 = app.current_state()
                        expect s3.mode_name() == "NORMAL"
                    Err(e) :
                        expect false == true
            Err(e) :
                expect false == true

    slow_it "stop helper terminates the app":
        val backend_result = create_backend("none", 3000)
        match backend_result:
            Ok(backend) :
                val config = AppConfig.headless()
                val app_result = UnifiedApp.new("examples/ui/minimal.ui.sdn", backend, config)
                match app_result:
                    Ok(app) :
                        expect app.is_running() == true
                        app.stop()
                        expect app.is_running() == false
                    Err(e) :
                        expect false == true
            Err(e) :
                expect false == true