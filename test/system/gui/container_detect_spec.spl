# test/system/gui/container_detect_spec.spl
# @cover src/lib/common/test_runner/display_detect.spl 80%
# @cover src/app/ui/detect.spl
# @cover src/lib/common/ui/backend_factory.spl
# @tag:system
# @gui: any

"""
# Container Display Detection Specification

**Feature IDs:** #GUI-DETECT-001
**Category:** Infrastructure
**Difficulty:** 2/5
**Status:** In Progress
**Requirements:** N/A
**Plan:** N/A
**Design:** N/A
**Research:** N/A

## Overview

Verifies display detection logic and backend auto-selection across
environments (macOS, X11, Wayland, Xvfb, headless). Tagged `@gui: any`
because detection behavior varies by host but the functions must always
return valid values without crashing.
"""

use std.spec.*

use common.test_runner.display_detect.{
    detect_display, has_any_display, can_show_gui, display_kind_name,
    DISPLAY_NONE, DISPLAY_X11, DISPLAY_WAYLAND, DISPLAY_MACOS, DISPLAY_XVFB
}
use app.ui.detect.{detect_gui_backend, has_display}
use common.ui.backend_factory.{create_backend}

# ============================================================================
# 1. Display Detection
# ============================================================================

describe "Display detection":
    slow_it "detect_display returns a DisplayInfo with a valid kind":
        val info = detect_display()
        # kind must be one of the known constants (0..4)
        val valid = (info.kind == DISPLAY_NONE or
            info.kind == DISPLAY_X11 or
            info.kind == DISPLAY_WAYLAND or
            info.kind == DISPLAY_MACOS or
            info.kind == DISPLAY_XVFB)
        expect(valid).to_equal(true)

    slow_it "detect_display has a display_name field":
        val info = detect_display()
        # display_name is text (may be empty for DISPLAY_NONE)
        if info.kind != DISPLAY_NONE:
            val name_len = info.display_name.len()
            expect(name_len).to_be_greater_than(0)

    slow_it "detect_display has an is_virtual field":
        val info = detect_display()
        # is_virtual is a bool; for Xvfb it is true, otherwise false
        if info.kind == DISPLAY_XVFB:
            expect(info.is_virtual).to_equal(true)
        if info.kind == DISPLAY_MACOS:
            expect(info.is_virtual).to_equal(false)

# ============================================================================
# 2. Display Kind Name Mapping
# ============================================================================

describe "display_kind_name mapping":
    slow_it "maps DISPLAY_NONE to 'none'":
        expect(display_kind_name(DISPLAY_NONE)).to_equal("none")

    slow_it "maps DISPLAY_X11 to 'X11'":
        expect(display_kind_name(DISPLAY_X11)).to_equal("X11")

    slow_it "maps DISPLAY_WAYLAND to 'Wayland'":
        expect(display_kind_name(DISPLAY_WAYLAND)).to_equal("Wayland")

    slow_it "maps DISPLAY_MACOS to 'macOS'":
        expect(display_kind_name(DISPLAY_MACOS)).to_equal("macOS")

    slow_it "maps DISPLAY_XVFB to 'Xvfb'":
        expect(display_kind_name(DISPLAY_XVFB)).to_equal("Xvfb")

    slow_it "maps unknown kind to 'unknown'":
        expect(display_kind_name(99)).to_equal("unknown")

# ============================================================================
# 3. Boolean Display Queries
# ============================================================================

describe "Display boolean queries":
    slow_it "has_any_display returns a boolean":
        val result = has_any_display()
        # Result is true or false, must not crash
        val is_bool = (result == true or result == false)
        expect(is_bool).to_equal(true)

    slow_it "can_show_gui returns a boolean":
        val result = can_show_gui()
        val is_bool = (result == true or result == false)
        expect(is_bool).to_equal(true)

    slow_it "can_show_gui is false when display is NONE":
        val info = detect_display()
        if info.kind == DISPLAY_NONE:
            expect(can_show_gui()).to_equal(false)

    slow_it "can_show_gui is false when display is virtual only":
        val info = detect_display()
        if info.is_virtual:
            expect(can_show_gui()).to_equal(false)

# ============================================================================
# 4. GUI Backend Auto-Detection
# ============================================================================

describe "GUI backend auto-detection":
    slow_it "detect_gui_backend returns a non-empty string":
        val backend_name = detect_gui_backend()
        expect(backend_name.len()).to_be_greater_than(0)

    slow_it "detect_gui_backend returns a known backend name":
        val name = detect_gui_backend()
        val known = (name == "tauri" or
            name == "web" or
            name == "headless" or
            name == "tui" or
            name == "none" or
            name == "vscode" or
            name == "electron")
        # Also allow env override to any value
        if not known:
            # If not a standard name, the env var SIMPLE_GUI_BACKEND was set
            expect(name.len()).to_be_greater_than(0)

    slow_it "has_display returns a boolean":
        val result = has_display()
        val is_bool = (result == true or result == false)
        expect(is_bool).to_equal(true)

# ============================================================================
# 5. Backend Factory with Detected Backend
# ============================================================================

describe "Backend factory with detected backend":
    slow_it "creates a headless backend successfully":
        val result = create_backend("headless", 0)
        match result:
            Ok(backend) :
                val name = backend.backend_name()
                expect(name.len()).to_be_greater_than(0)
            Err(e) :
                expect(false).to_equal(true)

    slow_it "creates a none backend successfully":
        val result = create_backend("none", 0)
        match result:
            Ok(backend) :
                val name = backend.backend_name()
                expect(name.len()).to_be_greater_than(0)
            Err(e) :
                expect(false).to_equal(true)

    slow_it "rejects invalid backend mode":
        val result = create_backend("nonexistent", 0)
        match result:
            Err(e) :
                expect(e).to_contain("Unknown backend mode")
            Ok(v) :
                expect(false).to_equal(true)
