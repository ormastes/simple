# @cover src/lib/nogc_sync_mut/mcp/__init__.spl 60%
# Daemon SDK IPC System Test
#
# Tests real file-based IPC: writes actual .req/.resp files to disk,
# verifies serialization/deserialization, atomic writes, and cleanup.
# Uses a temp directory under /tmp to avoid polluting the project.
#
# **Feature IDs:** #DSDK-SYS-001 to #DSDK-SYS-010
# **Category:** Infrastructure / System Test

extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_delete(path: text) -> bool
extern fn rt_dir_create_all(path: text) -> bool
extern fn rt_dir_list(path: text) -> [text]
extern fn rt_getpid() -> i64
extern fn rt_time_now_unix_micros() -> i64

fn simple_hash(s: text) -> i64:
    val bs = s.bytes()
    var h: i64 = 5381
    var i = 0
    while i < bs.len():
        h = h * 33 + bs[i]
        i = i + 1
    if h < 0:
        h = 0 - h
    h

fn list_dir_files(dir: text) -> [text]:
    val names = rt_dir_list(dir) ?? []
    var full: [text] = []
    var i = 0
    while i < names.len():
        full = full + ["{dir}/{names[i]}"]
        i = i + 1
    full

# ============================================================================
# Module-level state and helpers
# ============================================================================

var test_dir: text = ""
var test_req_dir: text = ""
var test_resp_dir: text = ""
var test_lock_path: text = ""

fn sys_setup():
    val pid = rt_getpid()
    val ts = rt_time_now_unix_micros()
    test_dir = "/tmp/daemon_sdk_test_{pid}_{ts}"
    test_req_dir = "{test_dir}/requests"
    test_resp_dir = "{test_dir}/responses"
    test_lock_path = "{test_dir}/daemon.lock"
    rt_dir_create_all(test_dir)
    rt_dir_create_all(test_req_dir)
    rt_dir_create_all(test_resp_dir)

fn sys_cleanup():
    # Clean up individual files
    cleanup_dir(test_req_dir)
    cleanup_dir(test_resp_dir)
    rt_file_delete(test_lock_path)
    rt_file_delete(test_dir)

fn cleanup_dir(dir: text):
    if not rt_file_exists(dir):
        return
    val files = list_dir_files(dir)
    var i = 0
    while i < files.len():
        rt_file_delete(files[i])
        i = i + 1

fn write_req_file(req_id: text, kind: i64, fields: [(text, text)]) -> text:
    var parts: [text] = []
    parts.push("id={req_id}")
    parts.push("kind={kind}")
    parts.push("timestamp={rt_time_now_unix_micros()}")
    var i = 0
    while i < fields.len():
        parts.push("field.{fields[i][0]}={fields[i][1]}")
        i = i + 1
    val content = parts.join("\n") + "\n"
    val hash = simple_hash(req_id)
    val path = "{test_req_dir}/{hash}_{req_id}.req"
    rt_file_write_text(path, content)
    path

fn write_resp_file(req_id: text, status: i64, fields: [(text, text)]) -> text:
    var parts: [text] = []
    parts.push("request_id={req_id}")
    parts.push("status={status}")
    parts.push("timestamp={rt_time_now_unix_micros()}")
    var i = 0
    while i < fields.len():
        parts.push("field.{fields[i][0]}={fields[i][1]}")
        i = i + 1
    val content = parts.join("\n") + "\n"
    val path = "{test_resp_dir}/{req_id}.resp"
    rt_file_write_text(path, content)
    path

fn read_file_content(path: text) -> text:
    rt_file_read_text(path) ?? ""

fn count_files_with_ext(dir: text, ext: text) -> i64:
    if not rt_file_exists(dir):
        return 0
    val files = list_dir_files(dir)
    var count: i64 = 0
    var i = 0
    while i < files.len():
        if files[i].ends_with(ext):
            count = count + 1
        i = i + 1
    count

fn extract_kv_from(content: text, prefix: text) -> text:
    val lines = content.split("\n")
    var i = 0
    while i < lines.len():
        if lines[i].starts_with(prefix):
            return lines[i].substring(prefix.len())
        i = i + 1
    ""

fn write_lock_file(pid: i64):
    val ts = rt_time_now_unix_micros()
    rt_file_write_text(test_lock_path, "{pid}\n{ts}")

# Getters
fn sys_get_dir() -> text:
    test_dir
fn sys_get_req_dir() -> text:
    test_req_dir
fn sys_get_resp_dir() -> text:
    test_resp_dir
fn sys_get_lock() -> text:
    test_lock_path
fn sys_req_count() -> i64:
    count_files_with_ext(test_req_dir, ".req")
fn sys_resp_count() -> i64:
    count_files_with_ext(test_resp_dir, ".resp")

fn write_rapid_requests(n: i64):
    var i: i64 = 0
    while i < n:
        write_req_file("rapid_{i}", 1, [("idx", "{i}")])
        i = i + 1

# ============================================================================
# Tests
# ============================================================================

describe "DaemonSDK System IPC":
    describe "request file I/O":
        it "writes and reads request file":
            sys_setup()
            val path = write_req_file("test_1", 1, [("test_path", "test/foo_spec.spl")])
            expect(rt_file_exists(path)).to_equal(true)
            val content = read_file_content(path)
            expect(content).to_contain("id=test_1")
            expect(content).to_contain("kind=1")
            expect(content).to_contain("field.test_path=test/foo_spec.spl")
            sys_cleanup()

        it "writes multiple request files":
            sys_setup()
            write_req_file("r1", 1, [])
            write_req_file("r2", 2, [])
            write_req_file("r3", 3, [])
            expect(sys_req_count()).to_equal(3)
            sys_cleanup()

        it "serializes multiple fields":
            sys_setup()
            val path = write_req_file("r_multi", 1, [("path", "test.spl"), ("filter", "unit"), ("clean", "true")])
            val content = read_file_content(path)
            expect(content).to_contain("field.path=test.spl")
            expect(content).to_contain("field.filter=unit")
            expect(content).to_contain("field.clean=true")
            sys_cleanup()

    describe "response file I/O":
        it "writes and reads response file":
            sys_setup()
            val path = write_resp_file("req_1", 2, [("passed", "10"), ("failed", "0")])
            expect(rt_file_exists(path)).to_equal(true)
            val content = read_file_content(path)
            expect(content).to_contain("request_id=req_1")
            expect(content).to_contain("status=2")
            expect(content).to_contain("field.passed=10")
            sys_cleanup()

        it "writes multiple response files":
            sys_setup()
            write_resp_file("r1", 2, [])
            write_resp_file("r2", 3, [])
            expect(sys_resp_count()).to_equal(2)
            sys_cleanup()

    describe "lock file":
        it "writes and reads PID from lock":
            sys_setup()
            write_lock_file(54321)
            val content = read_file_content(sys_get_lock())
            val first_line = content.split("\n")[0]
            expect(first_line).to_equal("54321")
            sys_cleanup()

        it "detects lock file existence":
            sys_setup()
            expect(rt_file_exists(sys_get_lock())).to_equal(false)
            write_lock_file(12345)
            expect(rt_file_exists(sys_get_lock())).to_equal(true)
            sys_cleanup()

    describe "cleanup":
        it "deletes request files":
            sys_setup()
            val p1 = write_req_file("r1", 1, [])
            val p2 = write_req_file("r2", 1, [])
            expect(sys_req_count()).to_equal(2)
            rt_file_delete(p1)
            expect(sys_req_count()).to_equal(1)
            rt_file_delete(p2)
            expect(sys_req_count()).to_equal(0)
            sys_cleanup()

        it "deletes response files":
            sys_setup()
            val p1 = write_resp_file("r1", 2, [])
            expect(sys_resp_count()).to_equal(1)
            rt_file_delete(p1)
            expect(sys_resp_count()).to_equal(0)
            sys_cleanup()

    describe "concurrent writes":
        it "handles rapid sequential writes":
            sys_setup()
            write_rapid_requests(20)
            expect(sys_req_count()).to_equal(20)
            sys_cleanup()

        it "handles interleaved request and response writes":
            sys_setup()
            write_req_file("ir_1", 1, [])
            write_resp_file("ir_1", 2, [])
            write_req_file("ir_2", 1, [])
            write_resp_file("ir_2", 3, [])
            write_req_file("ir_3", 1, [])
            write_resp_file("ir_3", 2, [])
            expect(sys_req_count()).to_equal(3)
            expect(sys_resp_count()).to_equal(3)
            sys_cleanup()

    describe "field extraction":
        it "extracts specific field from response":
            sys_setup()
            val path = write_resp_file("ext_1", 2, [("output", "all tests passed"), ("duration_ms", "1500")])
            val content = read_file_content(path)
            expect(extract_kv_from(content, "field.output=")).to_equal("all tests passed")
            expect(extract_kv_from(content, "field.duration_ms=")).to_equal("1500")
            sys_cleanup()

        it "returns empty for missing field":
            sys_setup()
            val path = write_resp_file("ext_2", 2, [])
            val content = read_file_content(path)
            expect(extract_kv_from(content, "field.nonexistent=")).to_equal("")
            sys_cleanup()
