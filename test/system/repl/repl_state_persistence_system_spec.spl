# @cover src/app/repl/main.spl 80%
# REPL State Persistence System Tests
# Tests: val/var definitions persist across evaluations

# tag: slow, system

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_delete(path: text) -> bool
extern fn rt_getpid() -> i64
extern fn rt_time_now_unix_micros() -> i64
extern fn rt_file_exists(path: text) -> bool

fn find_simple_binary() -> text:
    if rt_file_exists("src/compiler_rust/target/release/simple"):
        return "src/compiler_rust/target/release/simple"
    if rt_file_exists("src/compiler_rust/target/bootstrap/simple"):
        return "src/compiler_rust/target/bootstrap/simple"
    if rt_file_exists("bin/simple"):
        return "bin/simple"
    if rt_file_exists("bin/release/aarch64-apple-darwin-macho/simple"):
        return "bin/release/aarch64-apple-darwin-macho/simple"
    if rt_file_exists("bin/release/macos-arm64/simple"):
        return "bin/release/macos-arm64/simple"
    if rt_file_exists("bin/release/darwin-aarch64/simple"):
        return "bin/release/darwin-aarch64/simple"
    if rt_file_exists("bin/release/macos-x86_64/simple"):
        return "bin/release/macos-x86_64/simple"
    if rt_file_exists("bin/release/linux-x86_64/simple"):
        return "bin/release/linux-x86_64/simple"
    "bin/simple"

fn run_repl(input_text: text) -> text:
    val tmp = "/tmp/repl_test_{rt_getpid()}_{rt_time_now_unix_micros()}.txt"
    rt_file_write_text(tmp, input_text)
    val (stdout, stderr, code) = rt_process_run("bash", ["-c", "cat {tmp} | " + find_simple_binary() + " run src/app/repl/main.spl 2>/dev/null"])
    rt_file_delete(tmp)
    stdout

describe "REPL State Persistence":
    slow_it "should persist val definitions":
        val output = run_repl("val x = 42\nprint x\n:quit\n")
        expect(output).to_contain("42")

    slow_it "should persist var definitions":
        val output = run_repl("var y = 10\nprint y\n:quit\n")
        expect(output).to_contain("10")

    slow_it "should persist function definitions":
        val input_text = "fn double(n: i64) -> i64:\n    n * 2\n\nprint double(21)\n:quit\n"
        val output = run_repl(input_text)
        expect(output).to_contain("42")
