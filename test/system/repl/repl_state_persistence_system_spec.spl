# REPL State Persistence System Tests
# Tests: val/var definitions persist across evaluations

# tag: slow, system

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_delete(path: text) -> bool
extern fn rt_file_exists(path: text) -> bool
extern fn rt_getpid() -> i64
extern fn rt_time_now_unix_micros() -> i64

fn _check_binary_runnable() -> bool:
    if not rt_file_exists("bin/release/simple"):
        return false
    val (stdout, stderr, code) = rt_process_run("file", ["bin/release/simple"])
    if stdout == "" or stdout == nil:
        return false
    if stdout.contains("ELF") and not stdout.contains("Mach-O"):
        val (uname_out, _, _) = rt_process_run("uname", [])
        if uname_out.trim() == "Darwin":
            return false
    true

val _can_run = _check_binary_runnable()

fn run_repl(input_text: text) -> text:
    val tmp = "/tmp/repl_test_{rt_getpid()}_{rt_time_now_unix_micros()}.txt"
    rt_file_write_text(tmp, input_text)
    val (stdout, stderr, code) = rt_process_run("bash", ["-c", "cat {tmp} | bin/release/simple src/app/repl/main.spl 2>/dev/null"])
    rt_file_delete(tmp)
    stdout

describe "REPL State Persistence":
    it "should persist val definitions":
        if not _can_run:
            expect(true).to_equal(true)
        else:
            val output = run_repl("val x = 42\nprint x\n:quit\n")
            expect(output).to_contain("42")

    it "should persist var definitions":
        if not _can_run:
            expect(true).to_equal(true)
        else:
            val output = run_repl("var y = 10\nprint y\n:quit\n")
            expect(output).to_contain("10")

    it "should persist function definitions":
        if not _can_run:
            expect(true).to_equal(true)
        else:
            val input_text = "fn double(n: i64) -> i64:\n    n * 2\n\nprint double(21)\n:quit\n"
            val output = run_repl(input_text)
            expect(output).to_contain("42")
