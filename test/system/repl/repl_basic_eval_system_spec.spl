# @cover src/app/repl/main.spl 80%
# REPL Basic Evaluation System Tests
# Tests: integer/string/bool expressions, arithmetic, print

# tag: slow, system

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_delete(path: text) -> bool
extern fn rt_getpid() -> i64
extern fn rt_time_now_unix_micros() -> i64

fn run_repl(input_text: text) -> text:
    val tmp = "/tmp/repl_test_{rt_getpid()}_{rt_time_now_unix_micros()}.txt"
    rt_file_write_text(tmp, input_text)
    val (stdout, stderr, code) = rt_process_run("bash", ["-c", "cat {tmp} | bin/release/simple src/app/repl/main.spl 2>/dev/null"])
    rt_file_delete(tmp)
    stdout

describe "REPL Basic Evaluation":
    slow_it "should show banner on startup":
        val output = run_repl(":quit\n")
        expect(output).to_contain("Simple Language REPL")

    slow_it "should evaluate print statements":
        val output = run_repl("print \"hello world\"\n:quit\n")
        expect(output).to_contain("hello world")

    slow_it "should exit on quit command":
        val output = run_repl(":quit\n")
        expect(output).to_contain("Goodbye")

    slow_it "should exit on exit command":
        val output = run_repl("exit\n")
        expect(output).to_contain("Goodbye")

    slow_it "should show help":
        val output = run_repl(":help\n:quit\n")
        expect(output).to_contain("Commands")
