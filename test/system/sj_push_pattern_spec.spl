# @cover src/app/sj/translator.spl 0%
# @feature SJ-PUSH-001
"""
# Push Pattern Compatibility Spec

**Feature IDs:** SJ-PUSH-001
**Category:** Infrastructure
**Difficulty:** 3/5
**Status:** Draft — FAILING until Phase-5 I-C delivers sj push translation (D-7)

## Overview

Asserts the documented push pattern works through sj:
  jj bookmark set main -r @- && jj git push --bookmark main

Either as:
  sj bookmark set main -r @- && sj git push --bookmark main
  (two separate sj invocations, each serialized through daemon)

Or via the opt-in worktree path (D-7):
  sj git push --via-worktree

Covers AC-7 (push-pattern compatibility), D-7.

Note: bare sj git push (no --bookmark) is FORBIDDEN (see forbidden_verbs_spec.spl).
sj git push --via-worktree is an opt-in only (D-7).
"""

use std.spec
use std.io_runtime

# FAILING import until Phase-5 I-C/D delivers the full sj CLI.
# app.sj.client does not exist yet — resolver rejects with semantic error.
use app.sj.client

describe "Push pattern — bookmark set then git push (AC-7)":
    """
    ## Standard Two-Step Push

    The canonical push pattern uses two sequential sj calls:
      1. sj bookmark set main -r @-
      2. sj git push --bookmark main
    Each is a separate daemon request with its own exclusive lease.
    Together they must succeed without conflict.
    """

    it "sj bookmark set main -r @- succeeds (exit 0)":
        expect(exec_args(sj_client_new(".", 120000i64), ["bookmark", "set", "main", "-r", "@-"]).exit_code).to_equal(0i64)

    it "sj git push --bookmark main succeeds after bookmark set (exit 0)":
        expect(exec_args(sj_client_new(".", 120000i64), ["git", "push", "--bookmark", "main"]).exit_code).to_equal(0i64)

    it "sj git push --bookmark main is NOT forbidden":
        expect(check_forbidden(["git", "push", "--bookmark", "main"]).allowed).to_equal(true)

    it "two-step push completes without leaving orphan .git/index.lock":
        expect(should_reclaim_index_lock(false, true, 60i64, true)).to_equal(false)

describe "Push pattern — via-worktree opt-in (D-7)":
    """
    ## sj git push --via-worktree Opt-In

    The --via-worktree flag is an explicit opt-in for the push-via-worktree
    path documented in feedback_push_via_worktree.md.
    It must not be the default (D-7: auto-fallback adds maintenance burden).
    """

    it "sj git push --via-worktree is accepted (not forbidden)":
        expect(check_forbidden(["git", "push", "--via-worktree"]).allowed).to_equal(true)

    it "sj git push --via-worktree succeeds in a clean repo":
        expect(exec_args(sj_client_new(".", 120000i64), ["git", "push", "--via-worktree"]).exit_code).to_equal(0i64)

    it "sj git push (bare, no --bookmark, no --via-worktree) remains FORBIDDEN":
        expect(check_forbidden(["git", "push"]).allowed).to_equal(false)
