# @tag:system
# @cover test/system/crypto_ref_harness.spl 80%
"""
# Ed25519 Cross-Vendor All-Pairs Specification

**Feature IDs:** N/A
**Category:** Testing
**Difficulty:** 2/5
**Status:** Draft
**Requirements:** N/A
**Plan:** doc/03_plan/agent_tasks/pure_simple_crypto_tls_remains_2026-04-16.md
**Design:** N/A
**Research:** doc/01_research/local/tls13_phase2_backlog.md
**Artifacts:** N/A

## Overview

For each (signer, verifier) pair in {python, node}², sign a matrix of
messages using the signer vendor and verify the resulting signature using
the verifier vendor. Confirms byte-exact deterministic Ed25519 sign+verify
interoperability.

Also:
- RFC 8032 §7.1 test vector 1 (empty message) as a fixed known-answer.
- Tampered-signature negative path: flip one bit of the signature, expect
  verify → false from every vendor.

## Out of Scope

- Pure-Simple Ed25519 sign: wraps `rt_ed25519_sign` — not pure Simple.
  Covered elsewhere by `os_rt_ed25519_sign_spec.spl`.
- Simple-server integration: blocked until server-side TLS 1.3 lands.
"""

use std.sspec.*
use test.system.crypto_ref_harness.{
    Vendor, RefErr,
    ref_ed25519_sign_via, ref_ed25519_verify_via,
    crypto_input_matrix
}
use test.system.os_crypto_ref_helpers.{hex_to_bytes, bytes_to_hex}

# ---------------------------------------------------------------------------
# RFC 8032 §7.1 test vector 1 (TEST 1 — empty message)
# ---------------------------------------------------------------------------

val RFC8032_SK_HEX:  text = "9d61b19deffd5a60ba844af492ec2cc44449c5697b326919703bac031cae7f60"
val RFC8032_PK_HEX:  text = "d75a980182b10ab7d54bfed3c964073a0ee172f3daa62325af021a68f707511a"
val RFC8032_SIG_HEX: text = "e5564300c360ac729086e2cc806e828a84877f1eb8e5d974d873e065224901555fb8821590a33bacc61e39701cf9b46bd25bf5f0595bbe24655141438e7a100b"

fn _unwrap_bytes(r: Result<[u8], RefErr>) -> [u8]:
    match r:
        Ok(b):  b
        Err(_): []

fn _unwrap_bool(r: Result<bool, RefErr>) -> bool:
    match r:
        Ok(b):  b
        Err(_): false

fn _bytes_eq(a: [u8], b: [u8]) -> bool:
    if a.len() != b.len():
        return false
    var i: u64 = 0
    while i < a.len():
        if a[i] != b[i]:
            return false
        i = i + 1
    true

fn _flip_last_byte(b: [u8]) -> [u8]:
    """Return a copy of `b` with the last byte XORed by 0xff."""
    var out: [u8] = []
    if b.len() == 0:
        return out
    var i: u64 = 0
    while i < b.len() - 1:
        out.push(b[i])
        i = i + 1
    out.push((b[b.len() - 1].to_i64() ^ 0xff).to_u8())
    out


# ---------------------------------------------------------------------------
# RFC 8032 §7.1 test vector 1 — known-answer
# ---------------------------------------------------------------------------

describe "ed25519: RFC 8032 §7.1 TEST 1 (empty message)":
    it "python sign of empty msg matches the canonical signature":
        val sk: [u8] = hex_to_bytes(RFC8032_SK_HEX)
        val msg: [u8] = []
        val sig = _unwrap_bytes(ref_ed25519_sign_via(Vendor.PYTHON, sk, msg))
        expect(bytes_to_hex(sig)).to_equal(RFC8032_SIG_HEX)

    it "node sign of empty msg matches the canonical signature":
        val sk: [u8] = hex_to_bytes(RFC8032_SK_HEX)
        val msg: [u8] = []
        val sig = _unwrap_bytes(ref_ed25519_sign_via(Vendor.NODE, sk, msg))
        expect(bytes_to_hex(sig)).to_equal(RFC8032_SIG_HEX)

    it "python verify of the canonical signature returns true":
        val pk = hex_to_bytes(RFC8032_PK_HEX)
        val msg: [u8] = []
        val sig = hex_to_bytes(RFC8032_SIG_HEX)
        expect(_unwrap_bool(ref_ed25519_verify_via(Vendor.PYTHON, pk, msg, sig))).to_equal(true)

    it "node verify of the canonical signature returns true":
        val pk = hex_to_bytes(RFC8032_PK_HEX)
        val msg: [u8] = []
        val sig = hex_to_bytes(RFC8032_SIG_HEX)
        expect(_unwrap_bool(ref_ed25519_verify_via(Vendor.NODE, pk, msg, sig))).to_equal(true)


# ---------------------------------------------------------------------------
# All-pairs sign ↔ verify across {python, node} over the 8-input matrix
# ---------------------------------------------------------------------------

describe "ed25519: all-pairs interop over the 8-input matrix":
    it "python-sign → python-verify on every matrix entry":
        val sk = hex_to_bytes(RFC8032_SK_HEX)
        val pk = hex_to_bytes(RFC8032_PK_HEX)
        val matrix = crypto_input_matrix(block_size: 64u64)
        var i: u64 = 0
        while i < matrix.len():
            val msg = matrix[i]
            val sig = _unwrap_bytes(ref_ed25519_sign_via(Vendor.PYTHON, sk, msg))
            val ok  = _unwrap_bool(ref_ed25519_verify_via(Vendor.PYTHON, pk, msg, sig))
            expect(ok).to_equal(true)
            i = i + 1

    it "python-sign → node-verify on every matrix entry":
        val sk = hex_to_bytes(RFC8032_SK_HEX)
        val pk = hex_to_bytes(RFC8032_PK_HEX)
        val matrix = crypto_input_matrix(block_size: 64u64)
        var i: u64 = 0
        while i < matrix.len():
            val msg = matrix[i]
            val sig = _unwrap_bytes(ref_ed25519_sign_via(Vendor.PYTHON, sk, msg))
            val ok  = _unwrap_bool(ref_ed25519_verify_via(Vendor.NODE, pk, msg, sig))
            expect(ok).to_equal(true)
            i = i + 1

    it "node-sign → python-verify on every matrix entry":
        val sk = hex_to_bytes(RFC8032_SK_HEX)
        val pk = hex_to_bytes(RFC8032_PK_HEX)
        val matrix = crypto_input_matrix(block_size: 64u64)
        var i: u64 = 0
        while i < matrix.len():
            val msg = matrix[i]
            val sig = _unwrap_bytes(ref_ed25519_sign_via(Vendor.NODE, sk, msg))
            val ok  = _unwrap_bool(ref_ed25519_verify_via(Vendor.PYTHON, pk, msg, sig))
            expect(ok).to_equal(true)
            i = i + 1

    it "node-sign → node-verify on every matrix entry":
        val sk = hex_to_bytes(RFC8032_SK_HEX)
        val pk = hex_to_bytes(RFC8032_PK_HEX)
        val matrix = crypto_input_matrix(block_size: 64u64)
        var i: u64 = 0
        while i < matrix.len():
            val msg = matrix[i]
            val sig = _unwrap_bytes(ref_ed25519_sign_via(Vendor.NODE, sk, msg))
            val ok  = _unwrap_bool(ref_ed25519_verify_via(Vendor.NODE, pk, msg, sig))
            expect(ok).to_equal(true)
            i = i + 1


# ---------------------------------------------------------------------------
# Determinism: python and node must produce identical signatures
# ---------------------------------------------------------------------------

describe "ed25519: deterministic signature agreement":
    it "python and node produce byte-identical signatures over the matrix":
        val sk = hex_to_bytes(RFC8032_SK_HEX)
        val matrix = crypto_input_matrix(block_size: 64u64)
        var i: u64 = 0
        while i < matrix.len():
            val msg = matrix[i]
            val py_sig = _unwrap_bytes(ref_ed25519_sign_via(Vendor.PYTHON, sk, msg))
            val nd_sig = _unwrap_bytes(ref_ed25519_sign_via(Vendor.NODE,   sk, msg))
            expect(_bytes_eq(py_sig, nd_sig)).to_equal(true)
            i = i + 1


# ---------------------------------------------------------------------------
# Negative path: tampered signature
# ---------------------------------------------------------------------------

describe "ed25519: tampered signature is rejected":
    it "python rejects a signature with its last byte flipped":
        val pk = hex_to_bytes(RFC8032_PK_HEX)
        val msg: [u8] = []
        val good_sig = hex_to_bytes(RFC8032_SIG_HEX)
        val bad_sig = _flip_last_byte(good_sig)
        expect(_unwrap_bool(ref_ed25519_verify_via(Vendor.PYTHON, pk, msg, bad_sig))).to_equal(false)

    it "node rejects a signature with its last byte flipped":
        val pk = hex_to_bytes(RFC8032_PK_HEX)
        val msg: [u8] = []
        val good_sig = hex_to_bytes(RFC8032_SIG_HEX)
        val bad_sig = _flip_last_byte(good_sig)
        expect(_unwrap_bool(ref_ed25519_verify_via(Vendor.NODE, pk, msg, bad_sig))).to_equal(false)

    it "python rejects a signature from the wrong message":
        val pk = hex_to_bytes(RFC8032_PK_HEX)
        val wrong_msg: [u8] = [0x61u8]
        val sig = hex_to_bytes(RFC8032_SIG_HEX)
        expect(_unwrap_bool(ref_ed25519_verify_via(Vendor.PYTHON, pk, wrong_msg, sig))).to_equal(false)

    it "node rejects a signature from the wrong message":
        val pk = hex_to_bytes(RFC8032_PK_HEX)
        val wrong_msg: [u8] = [0x61u8]
        val sig = hex_to_bytes(RFC8032_SIG_HEX)
        expect(_unwrap_bool(ref_ed25519_verify_via(Vendor.NODE, pk, wrong_msg, sig))).to_equal(false)
