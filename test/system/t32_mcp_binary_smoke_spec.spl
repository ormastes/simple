# @cover examples/10_tooling/trace32_tools/t32_mcp/main.spl 80%
# @cover examples/10_tooling/trace32_tools/t32_mcp/protocol.spl 60%
"""
# T32 MCP Binary Smoke Tests

**Feature IDs:** #T32-BIN-001
**Category:** Tooling
**Difficulty:** 3/5
**Status:** Implemented

## Overview

End-to-end tests that spawn the compiled T32 MCP binary, send MCP protocol
messages via stdin (Content-Length framing), and verify responses on stdout.
No TRACE32 hardware is required.

## Key Concepts

| Concept           | Description                                                  |
|-------------------|--------------------------------------------------------------|
| Binary spawn      | Start bin/t32_mcp_server, pipe input from temp file          |
| Protocol framing  | Content-Length: N\\r\\n\\r\\n + body                         |
| MCP handshake     | initialize -> initialized -> tools/list -> tools/call        |
| Error handling    | Malformed input, unknown methods, missing sessions           |

## Behavior

- Binary responds to initialize with server info and protocol version
- Binary returns 36 tools in tools/list response
- Binary returns structured errors for tool calls without T32 connection
- Binary exits cleanly when stdin is exhausted
"""

# @req REQ-T32-BIN-001
# @feature t32_mcp_binary_smoke

use app.io.mod.{shell}

extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_delete(path: text) -> bool
extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_read_text(path: text) -> text

# --- Constants ---

val T32_MCP_BIN = "/home/ormastes/dev/pub/simple/bin/t32_mcp_server"

# --- Inlined helpers (avoid import issues with integration helper module) ---

fn mcp_msg(body: text) -> text:
    "Content-Length: " + body.len().to_string() + "\r\n\r\n" + body

fn init_request(id: text) -> text:
    val body = "{\"jsonrpc\":\"2.0\",\"id\":\"" + id + "\",\"method\":\"initialize\",\"params\":{\"protocolVersion\":\"2025-06-18\",\"capabilities\":{},\"clientInfo\":{\"name\":\"spec\",\"version\":\"1.0\"}}}"
    mcp_msg(body)

fn initialized_notification() -> text:
    val body = "{\"jsonrpc\":\"2.0\",\"method\":\"initialized\"}"
    mcp_msg(body)

fn tools_list_request(id: text) -> text:
    val body = "{\"jsonrpc\":\"2.0\",\"id\":\"" + id + "\",\"method\":\"tools/list\",\"params\":{}}"
    mcp_msg(body)

fn tools_call_request(id: text, name: text, arguments_json: text) -> text:
    val body = "{\"jsonrpc\":\"2.0\",\"id\":\"" + id + "\",\"method\":\"tools/call\",\"params\":{\"name\":\"" + name + "\",\"arguments\":" + arguments_json + "}}"
    mcp_msg(body)

fn ping_request(id: text) -> text:
    val body = "{\"jsonrpc\":\"2.0\",\"id\":\"" + id + "\",\"method\":\"ping\",\"params\":{}}"
    mcp_msg(body)

fn shutdown_request(id: text) -> text:
    val body = "{\"jsonrpc\":\"2.0\",\"id\":\"" + id + "\",\"method\":\"shutdown\",\"params\":{}}"
    mcp_msg(body)

fn custom_method_request(id: text, method: text) -> text:
    val body = "{\"jsonrpc\":\"2.0\",\"id\":\"" + id + "\",\"method\":\"" + method + "\",\"params\":{}}"
    mcp_msg(body)

fn shell_escape_text(value: text) -> text:
    "'" + value.replace("'", "'\\''") + "'"

fn run_mcp(messages: text, timeout_secs: i64) -> (text, text, i64):
    val mk = shell("mktemp /tmp/t32_mcp_smoke.XXXXXX")
    val input_path = (mk.stdout ?? "").trim()
    if input_path == "":
        return ("", "mktemp failed", 1)
    val stderr_path = input_path + ".err"
    rt_file_write_text(input_path, messages)
    val cmd = "timeout " + timeout_secs.to_string() + "s " + T32_MCP_BIN + " < " + shell_escape_text(input_path) + " 2>" + shell_escape_text(stderr_path)
    val result = shell(cmd)
    val stdout = result.stdout ?? ""
    val stderr_result = shell("cat " + shell_escape_text(stderr_path) + " 2>/dev/null")
    val stderr = stderr_result.stdout ?? ""
    rt_file_delete(input_path)
    rt_file_delete(stderr_path)
    (stdout, stderr, result.exit_code)

fn run_mcp_direct(messages: text, timeout_secs: i64, env_prefix: text) -> (text, text, i64):
    val mk = shell("mktemp /tmp/t32_mcp_smoke.XXXXXX")
    val input_path = (mk.stdout ?? "").trim()
    if input_path == "":
        return ("", "mktemp failed", 1)
    val stderr_path = input_path + ".err"
    rt_file_write_text(input_path, messages)
    val repo = "/home/ormastes/dev/pub/simple"
    val cmd = env_prefix + " SIMPLE_LIB=" + repo + "/examples/10_tooling/trace32_tools SIMPLE_TIMEOUT_SECONDS=86400 SIMPLE_LOG=error RUST_LOG=error timeout " + timeout_secs.to_string() + "s " + repo + "/bin/simple " + repo + "/examples/10_tooling/trace32_tools/t32_mcp/main.spl < " + shell_escape_text(input_path) + " 2>" + shell_escape_text(stderr_path)
    val result = shell(cmd)
    val stdout = result.stdout ?? ""
    val stderr_result = shell("cat " + shell_escape_text(stderr_path) + " 2>/dev/null")
    val stderr = stderr_result.stdout ?? ""
    rt_file_delete(input_path)
    rt_file_delete(stderr_path)
    (stdout, stderr, result.exit_code)

val BIN_EXISTS = rt_file_exists(T32_MCP_BIN)

# ============================================================================
# Test Group 1: Protocol Handshake
# ============================================================================

describe "T32 MCP Binary — Protocol Handshake":

    it "responds to initialize with server info":
        if not BIN_EXISTS: return
        val messages = init_request("1")
        val (stdout, stderr, rc) = run_mcp(messages, 20)
        expect(rc).to_equal(0)
        expect(stdout.contains("\"id\":\"1\"")).to_equal(true)
        expect(stdout.contains("\"protocolVersion\":\"2025-06-18\"")).to_equal(true)
        expect(stdout.contains("simple-mcp-t32")).to_equal(true)
        expect(stdout.contains("serverInfo")).to_equal(true)
        expect(stdout.contains("capabilities")).to_equal(true)

    it "exits cleanly on empty stdin":
        if not BIN_EXISTS: return
        val (stdout, stderr, rc) = run_mcp("", 10)
        expect(rc).to_equal(0)

    it "responds to ping after initialize":
        if not BIN_EXISTS: return
        val messages = init_request("1") + ping_request("2")
        val (stdout, stderr, rc) = run_mcp(messages, 20)
        expect(rc).to_equal(0)
        expect(stdout.contains("\"id\":\"1\"")).to_equal(true)
        expect(stdout.contains("\"id\":\"2\"")).to_equal(true)

    it "handles shutdown cleanly":
        if not BIN_EXISTS: return
        val messages = init_request("1") + initialized_notification() + shutdown_request("2")
        val (stdout, stderr, rc) = run_mcp(messages, 20)
        expect(rc).to_equal(0)
        expect(stdout.contains("\"id\":\"2\"")).to_equal(true)

# ============================================================================
# Test Group 2: Tool Catalog
# ============================================================================

describe "T32 MCP Binary — Tool Catalog":

    it "returns tools list with 36 tools":
        if not BIN_EXISTS: return
        val messages = init_request("1") + initialized_notification() + tools_list_request("2")
        val (stdout, stderr, rc) = run_mcp(messages, 20)
        expect(rc).to_equal(0)
        expect(stdout.contains("\"id\":\"2\"")).to_equal(true)
        expect(stdout.contains("\"tools\"")).to_equal(true)

    it "tools list contains session tools":
        if not BIN_EXISTS: return
        val messages = init_request("1") + initialized_notification() + tools_list_request("2")
        val (stdout, stderr, rc) = run_mcp(messages, 20)
        expect(stdout.contains("t32_sessions_list")).to_equal(true)
        expect(stdout.contains("t32_session_open")).to_equal(true)
        expect(stdout.contains("t32_session_close")).to_equal(true)
        expect(stdout.contains("t32_session_resume")).to_equal(true)

    it "tools list contains command tools":
        if not BIN_EXISTS: return
        val messages = init_request("1") + initialized_notification() + tools_list_request("2")
        val (stdout, stderr, rc) = run_mcp(messages, 20)
        expect(stdout.contains("t32_cmd_run")).to_equal(true)
        expect(stdout.contains("t32_cmm_run")).to_equal(true)
        expect(stdout.contains("t32_eval")).to_equal(true)

    it "tools list contains window and headless tools":
        if not BIN_EXISTS: return
        val messages = init_request("1") + initialized_notification() + tools_list_request("2")
        val (stdout, stderr, rc) = run_mcp(messages, 20)
        expect(stdout.contains("t32_window_list")).to_equal(true)
        expect(stdout.contains("t32_window_capture")).to_equal(true)
        expect(stdout.contains("t32_setup_headless")).to_equal(true)
        expect(stdout.contains("t32_area_read")).to_equal(true)

    it "tools list contains job and dialog tools":
        if not BIN_EXISTS: return
        val messages = init_request("1") + initialized_notification() + tools_list_request("2")
        val (stdout, stderr, rc) = run_mcp(messages, 20)
        expect(stdout.contains("t32_job_list")).to_equal(true)
        expect(stdout.contains("t32_job_get")).to_equal(true)
        expect(stdout.contains("t32_dialog_parse")).to_equal(true)
        expect(stdout.contains("t32_error_check")).to_equal(true)

# ============================================================================
# Test Group 3: Content-Length Framing
# ============================================================================

describe "T32 MCP Binary — Content-Length Framing":

    it "returns Content-Length framed responses":
        if not BIN_EXISTS: return
        val messages = init_request("1")
        val (stdout, stderr, rc) = run_mcp(messages, 20)
        expect(stdout.contains("Content-Length:")).to_equal(true)

    it "handles multi-message sequence":
        if not BIN_EXISTS: return
        val messages = init_request("1") + initialized_notification() + tools_list_request("2") + ping_request("3")
        val (stdout, stderr, rc) = run_mcp(messages, 20)
        expect(rc).to_equal(0)
        # Should have 3 responses (init, tools/list, ping) — initialized is a notification, no response
        expect(stdout.contains("\"id\":\"1\"")).to_equal(true)
        expect(stdout.contains("\"id\":\"2\"")).to_equal(true)
        expect(stdout.contains("\"id\":\"3\"")).to_equal(true)

# ============================================================================
# Test Group 4: Error Handling (No T32 Hardware)
# ============================================================================

describe "T32 MCP Binary — Error Handling":

    it "returns error for t32_session_open when no T32 running":
        if not BIN_EXISTS: return
        val messages = init_request("1") + initialized_notification() + tools_call_request("2", "t32_session_open", "{\"host\":\"127.0.0.99\",\"port\":\"19999\"}")
        val (stdout, stderr, rc) = run_mcp(messages, 20)
        expect(rc).to_equal(0)
        expect(stdout.contains("\"id\":\"2\"")).to_equal(true)
        # Should get an error about connection, not a crash
        val has_response = stdout.contains("\"id\":\"2\"")
        expect(has_response).to_equal(true)

    it "returns error for t32_cmd_run without session":
        if not BIN_EXISTS: return
        val messages = init_request("1") + initialized_notification() + tools_call_request("2", "t32_cmd_run", "{\"command\":\"PING\"}")
        val (stdout, stderr, rc) = run_mcp(messages, 20)
        expect(rc).to_equal(0)
        expect(stdout.contains("\"id\":\"2\"")).to_equal(true)

    it "returns error for unknown method":
        if not BIN_EXISTS: return
        val messages = init_request("1") + custom_method_request("2", "nonexistent/method")
        val (stdout, stderr, rc) = run_mcp(messages, 20)
        expect(rc).to_equal(0)
        # Server should return -32601 Method not found
        expect(stdout.contains("\"id\":\"2\"")).to_equal(true)
        expect(stdout.contains("-32601")).to_equal(true)

    it "handles t32_sessions_list without any open sessions":
        if not BIN_EXISTS: return
        val messages = init_request("1") + initialized_notification() + tools_call_request("2", "t32_sessions_list", "{}")
        val (stdout, stderr, rc) = run_mcp(messages, 20)
        expect(rc).to_equal(0)
        expect(stdout.contains("\"id\":\"2\"")).to_equal(true)
        expect(stdout.contains("\"items\":[]")).to_equal(true)

# ============================================================================
# Test Group 5: Environment Configuration
# ============================================================================

describe "T32 MCP Binary — Environment Configuration":

    it "T32_MCP_DEBUG enables stderr output":
        if not BIN_EXISTS: return
        val messages = init_request("1")
        val (stdout, stderr, rc) = run_mcp_direct(messages, 20, "T32_MCP_DEBUG=1")
        expect(rc).to_equal(0)
        expect(stdout.contains("\"id\":\"1\"")).to_equal(true)
        # Debug mode should produce stderr output with [t32-mcp] prefix
        expect(stderr.contains("[t32-mcp]")).to_equal(true)

    it "T32_MCP_DEBUG_FILE writes log to file":
        if not BIN_EXISTS: return
        val mk = shell("mktemp /tmp/t32_mcp_debug_log.XXXXXX")
        val log_path = (mk.stdout ?? "").trim()
        if log_path == "": return
        val messages = init_request("1")
        val (stdout, stderr, rc) = run_mcp_direct(messages, 20, "T32_MCP_DEBUG_FILE=" + log_path)
        expect(rc).to_equal(0)
        val log_content = rt_file_read_text(log_path) ?? ""
        rt_file_delete(log_path)
        expect(log_content.len() > 0).to_equal(true)
