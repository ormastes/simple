#![allow(unnamed_duplicate_typed_args)]
# @tag:system
#
# Hosted TLS interop spec:
# - loads the shared SDN config schema from Simple
# - starts the rustls test harness from the same SDN config
# - validates the exported fixtures with openssl
# - validates the live handshake with the hosted Simple TLS client

use std.spec.*
use os.tls13.mod.{load_tls_test_server_config}

extern fn rt_file_exists(path: text) -> bool
extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_process_spawn_async(cmd: text, args: [text]) -> i64
extern fn rt_process_kill(pid: i64) -> bool
extern fn rt_process_wait(pid: i64, timeout_ms: i64) -> i64
extern fn rt_thread_sleep(ms: i64)

fn _file_exists(path: text) -> bool:
    rt_file_exists(path)

fn _process_run(cmd: text, args: [text]) -> (text, text, i64):
    rt_process_run(cmd, args)

fn _server_bin() -> text:
    "tools/tls_test_server/target/debug/tls_test_server"

fn _simple_bin() -> text:
    "src/compiler_rust/target/debug/simple"

fn _kill_server(server_pid: i64):
    if server_pid > 0:
        rt_process_kill(server_pid)
        rt_process_wait(server_pid, 2000)

fn _write_server_config(path: text, fixture_dir: text, require_client_auth: bool, accept_count: i64):
    val auth_text = if require_client_auth: "true" else: "false"
    val content =
        "server:\n" +
        "  listen: \"127.0.0.1:4433\"\n" +
        "  accept_count: " + accept_count.to_text() + "\n" +
        "  require_client_auth: " + auth_text + "\n" +
        "  fixture_dir: \"" + fixture_dir + "\"\n" +
        "  greeting: \"Hello from rustls TLS 1.3\"\n"
    val cmd = "mkdir -p \"$(dirname '" + path + "')\" && cat > '" + path + "' <<'EOF'\n" + content + "EOF\n"
    val result = _process_run("/bin/sh", ["-c", cmd])
    expect(result.2).to_equal(0)

fn _spawn_server(config_path: text) -> i64:
    rt_process_spawn_async(_server_bin(), ["--config", config_path])

fn _run_openssl_client(fixture_dir: text, with_client_auth: bool) -> (text, text, i64):
    val auth_args = if with_client_auth:
        " -cert " + fixture_dir + "/client.pem -key " + fixture_dir + "/client.key.pem"
    else:
        ""
    val cmd = "printf 'pong\\n' | openssl s_client -quiet -connect 127.0.0.1:4433 -CAfile " + fixture_dir + "/ca.pem" + auth_args
    _process_run("/bin/sh", ["-c", cmd])

fn _run_simple_client(config_path: text) -> (text, text, i64):
    val cmd = "SIMPLE_TIMEOUT_SECONDS=30 TLS_TEST_SERVER_CONFIG='" + config_path + "' '" + _simple_bin() + "' run examples/tls_hosted_client/main.spl"
    _process_run("/bin/sh", ["-c", cmd])

describe "Hosted TLS interop with shared SDN config":

    it "loads the shared tls test server SDN config":
        val result = load_tls_test_server_config("tools/tls_test_server/server.sdn")
        if result.err.?:
            print "[os_tls_hosted_interop_spec] config load failed: {result.err.unwrap()}"
        expect(result.err.?).to_equal(false)
        val config = result.unwrap()
        expect(config.listen).to_equal("127.0.0.1:4433")
        expect(config.accept_count).to_equal(1)
        expect(config.require_client_auth).to_equal(false)
        expect(config.fixture_dir).to_equal("build/tls_test_server")

    it "validates exported fixtures with openssl and completes a hosted Simple client handshake":
        expect(_file_exists(_server_bin())).to_equal(true)
        expect(_file_exists(_simple_bin())).to_equal(true)

        val fixture_dir = "build/tls_hosted_interop/basic"
        val config_path = "build/tls_hosted_interop/basic.sdn"
        _process_run("/bin/sh", ["-c", "mkdir -p " + fixture_dir])
        _write_server_config(config_path, fixture_dir, false, 2)

        val server_pid = _spawn_server(config_path)
        expect(server_pid > 0).to_equal(true)
        if server_pid <= 0:
            return

        rt_thread_sleep(700)

        val openssl_result = _run_openssl_client(fixture_dir, false)
        val openssl_output = openssl_result.0 + openssl_result.1
        val simple_result = _run_simple_client(config_path)
        val simple_output = simple_result.0 + simple_result.1
        _kill_server(server_pid)

        expect(_file_exists(fixture_dir + "/ca.pem")).to_equal(true)
        expect(_file_exists(fixture_dir + "/server.pem")).to_equal(true)
        expect(openssl_result.2).to_equal(0)
        expect(openssl_output).to_contain("Hello from rustls TLS 1.3")
        expect(openssl_output).to_contain("server_ack")
        expect(simple_result.2).to_equal(0)
        expect(simple_output).to_contain("[simple-client] handshake ok")

    it "requires a client certificate when the shared SDN config enables mTLS":
        expect(_file_exists(_server_bin())).to_equal(true)
        expect(_file_exists(_simple_bin())).to_equal(true)

        val fixture_dir = "build/tls_hosted_interop/mtls"
        val config_path = "build/tls_hosted_interop/mtls.sdn"
        _process_run("/bin/sh", ["-c", "mkdir -p " + fixture_dir])
        _write_server_config(config_path, fixture_dir, true, 2)

        val server_pid = _spawn_server(config_path)
        expect(server_pid > 0).to_equal(true)
        if server_pid <= 0:
            return

        rt_thread_sleep(700)

        val missing_cert = _run_openssl_client(fixture_dir, false)
        val simple_result = _run_simple_client(config_path)
        _kill_server(server_pid)

        expect(missing_cert.2 == 0).to_equal(false)
        expect(simple_result.2).to_equal(0)
        expect(simple_result.0 + simple_result.1).to_contain("[simple-client] handshake ok")
        _process_run("/bin/sh", ["-c", "rm -rf build/tls_hosted_interop"])
