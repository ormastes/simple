# @cover src/lib/ffi/mod.spl 80%
"""
# SFFI Bidirectional Class Interop Specification

**Feature IDs:** #SFFI-BIDIR
**Category:** Runtime / Compiler Integration
**Difficulty:** 5/5
**Status:** Partial Implementation Verified
**Requirements:** doc/02_requirements/feature/usage/sffi_bidirectional_interop.md
**Architecture:** doc/04_architecture/sffi_bidirectional_interop.md
**Design:** doc/05_design/sffi_bidirectional_interop.md

## Overview

Integration-level checks for the currently implemented bidirectional SFFI
surface between Simple and C/C++:
- `@export("C")` attribute parsing
- backend C wrapper generation for exported functions and classes
- generated C and C++ headers
- `@repr("C")` layout verification
- shared-library build flags
- SFFI lint diagnostics

This spec intentionally checks the real compiler subsystems that are wired
today rather than keeping fail-first placeholders.
"""

use std.spec

use compiler.common.attributes.{ExportAttr, parse_export_attrs}
use compiler.frontend.parser_types.{Attribute, Expr, ExprKind}
use compiler.frontend.flat_ast_bridge.{parse_and_build_module}
use compiler.backend.{MirToC}
use compiler.driver.{generate_headers, aot_shared_library, CompileResult}
use compiler.mir.mir_data.*
use compiler.tools.header_gen.c_header.{emit_c_header}
use compiler.tools.header_gen.cpp_header.{emit_cpp_header}
use compiler.tools.header_gen.shared_lib_flags.{
    get_shared_lib_flags, shared_lib_output_path,
    apply_shared_compile_flags, apply_shared_link_flags
}
use compiler.semantics.lint.sffi_lint.{SffiLintWarning, lint_sffi_export}
use compiler.types.type_layout.{LayoutAttr, LayoutKind, layoutattr_c_repr, verify_c_layout}
from hir_definitions import {HirClass, HirField, HirExpr, HirExprKind}
from hir_types import {SymbolId, HirType, HirTypeKind}
from lexer import {Span}

val NL = "\n"

extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_delete(path: text) -> bool
extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)


fn empty_span() -> Span:
    Span(start: 0, end_pos: 0, line: 1, col: 1)

fn make_string_expr(value: text) -> Expr:
    Expr(kind: ExprKind.StringLit(value, nil), span: empty_span())

fn make_ident_expr(name: text) -> Expr:
    Expr(kind: ExprKind.Ident(name), span: empty_span())

fn make_assign_expr(name: text, value: Expr) -> Expr:
    val left = make_ident_expr(name)
    Expr(kind: ExprKind.Assign(left, nil, value), span: empty_span())

fn make_export_attr() -> Attribute:
    Attribute(name: "export", args: [make_string_expr("C")], span: empty_span())

fn make_export_named_attr(name: text) -> Attribute:
    Attribute(
        name: "export",
        args: [make_string_expr("C"), make_assign_expr("name", make_string_expr(name))],
        span: empty_span()
    )

fn make_hir_type(kind: HirTypeKind) -> HirType:
    HirType(kind: kind, span: empty_span())

fn make_i32_type() -> HirType:
    make_hir_type(HirTypeKind.Int(32, true))

fn make_i64_type() -> HirType:
    make_hir_type(HirTypeKind.Int(64, true))

fn make_u8_type() -> HirType:
    make_hir_type(HirTypeKind.Int(8, false))

fn make_u16_type() -> HirType:
    make_hir_type(HirTypeKind.Int(16, false))

fn make_u32_type() -> HirType:
    make_hir_type(HirTypeKind.Int(32, false))

fn make_f64_type() -> HirType:
    make_hir_type(HirTypeKind.Float(64))

fn make_bool_type() -> HirType:
    make_hir_type(HirTypeKind.Bool)

fn make_str_type() -> HirType:
    make_hir_type(HirTypeKind.Str)

fn make_array_type() -> HirType:
    make_hir_type(HirTypeKind.Array(make_i32_type(), nil))

fn make_ref_type() -> HirType:
    make_hir_type(HirTypeKind.Ref(make_i32_type(), false))

fn dummy_expr() -> HirExpr:
    HirExpr(
        kind: HirExprKind.UnitLit,
        has_type_: false,
        type_: make_hir_type(HirTypeKind.Unit),
        span: empty_span()
    )

fn make_field(name: text, type_: HirType) -> HirField:
    HirField(
        symbol: SymbolId(id: 0),
        name: name,
        type_: type_,
        has_default: false,
        default: dummy_expr(),
        is_public: true,
        is_volatile: false,
        has_bits_attr: false,
        bits_width: 0,
        has_fixed_address: false,
        fixed_address: 0,
        span: empty_span()
    )

fn make_bits_field(name: text, type_: HirType, bits_width: i64) -> HirField:
    val field = make_field(name, type_)
    field.has_bits_attr = true
    field.bits_width = bits_width
    field

fn make_exported_class(name: text, fields: [HirField], has_repr_c: bool) -> HirClass:
    val layout = if has_repr_c:
        LayoutAttr(layout_kind: LayoutKind.C, is_packed: false)
    else:
        LayoutAttr(layout_kind: LayoutKind.Simple, is_packed: false)

    HirClass(
        symbol: SymbolId(id: 1),
        name: name,
        type_params: [],
        fields: fields,
        methods: {},
        is_public: true,
        has_doc_comment: false,
        doc_comment: "",
        span: empty_span(),
        has_layout_attr: has_repr_c,
        layout_attr: layout,
        has_export_attr: true,
        export_attr: ExportAttr(is_export_c: true, export_name: ""),
        is_generic_template: false,
        has_specialization_of: false,
        specialization_of: "",
        type_bindings: {}
    )

fn make_mir_i32() -> MirType:
    MirType(kind: MirTypeKind.I32)

fn make_mir_f64() -> MirType:
    MirType(kind: MirTypeKind.F64)

fn make_mir_exported_type() -> MirTypeDef:
    MirTypeDef(
        symbol: SymbolId(id: 10),
        name: "Calculator",
        kind: MirTypeDefKind.Struct([
            MirFieldDef(name: "precision", type_: make_mir_i32(), offset: 0, has_bits_attr: false, bits_width: 0)
        ]),
        is_export_c: true,
        export_name: ""
    )

fn make_mir_method(name: text, symbol_id: i64) -> MirFunction:
    MirFunction(
        symbol: SymbolId(id: symbol_id),
        name: name,
        signature: MirSignature(
            params: [
                MirType(kind: MirTypeKind.Struct(SymbolId(id: 10))),
                make_mir_f64(),
                make_mir_f64()
            ],
            return_type: make_mir_f64(),
            is_variadic: false
        ),
        locals: [],
        blocks: [],
        entry_block: BlockId.entry(),
        span: empty_span(),
        generic_params: [],
        is_generic_template: false,
        specialization_of: nil,
        type_bindings: {},
        layout_phase: nil,
        is_kernel: false,
        is_export_c: true,
        export_name: ""
    )

fn make_exported_fn(export_name: text) -> MirFunction:
    MirFunction(
        symbol: SymbolId(id: 30),
        name: "__simple_add_numbers",
        signature: MirSignature(
            params: [make_mir_i32(), make_mir_i32()],
            return_type: make_mir_i32(),
            is_variadic: false
        ),
        locals: [],
        blocks: [],
        entry_block: BlockId.entry(),
        span: empty_span(),
        generic_params: [],
        is_generic_template: false,
        specialization_of: nil,
        type_bindings: {},
        layout_phase: nil,
        is_kernel: false,
        is_export_c: true,
        export_name: export_name
    )

fn make_mir_module() -> MirModule:
    var funcs: Dict<SymbolId, MirFunction> = {}
    val add_fn = make_mir_method("__simple_Calculator_add", 20)
    val mul_fn = make_mir_method("__simple_Calculator_multiply", 21)
    funcs[add_fn.symbol] = add_fn
    funcs[mul_fn.symbol] = mul_fn

    MirModule(
        name: "test.sffi",
        functions: funcs,
        statics: {},
        constants: {},
        types: {}
    )

fn make_mir_module_with_standalone(export_name: text) -> MirModule:
    var funcs: Dict<SymbolId, MirFunction> = {}
    val func = make_exported_fn(export_name)
    funcs[func.symbol] = func
    MirModule(
        name: "test.sffi",
        functions: funcs,
        statics: {},
        constants: {},
        types: {}
    )

fn find_by_code(warnings: [SffiLintWarning], code: text) -> [SffiLintWarning]:
    var result: [SffiLintWarning] = []
    for warning in warnings:
        if warning.code == code:
            result.push(warning)
    result

fn write_source(path: text, content: text) -> bool:
    val cmd = "cat > " + path + " << 'SIMPLE_WRITE_EOF'" + NL + content + NL + "SIMPLE_WRITE_EOF"
    val (_out, _err, code) = rt_process_run("/bin/sh", ["-c", cmd])
    code == 0

fn cleanup_path(path: text):
    val (_out, _err, _code) = rt_process_run("/bin/sh", ["-c", "rm -rf " + path])

fn assert_ok(condition: bool, message: text):
    if not condition:
        expect(message).to_equal("")


describe "SFFI Bidirectional Class Interop":
    describe "attribute parsing":
        it "parses @export(C) for default ABI export":
            val result = parse_export_attrs([make_export_attr()])
            expect(result.?).to_equal(true)
            expect(result.unwrap().is_export_c).to_equal(true)
            expect(result.unwrap().export_name).to_equal("")

        it "parses @export(C, name: ...) for custom symbol export":
            val result = parse_export_attrs([make_export_named_attr("my_calc_create")])
            expect(result.?).to_equal(true)
            expect(result.unwrap().is_export_c).to_equal(true)
            expect(result.unwrap().export_name).to_equal("my_calc_create")

        it "parses field-level @bits metadata through the active frontend path":
            val module = parse_and_build_module(
                "struct GpioRegister:\n    mode: u8 @bits(4)\n    speed: u8 @bits(2)\n",
                "test_bits.spl"
            )

            val gpio = module.structs["GpioRegister"]
            expect(gpio.fields.len()).to_equal(2)
            expect(gpio.fields[0].has_bits).to_equal(true)
            expect(gpio.fields[0].bits).to_equal(4)
            expect(gpio.fields[1].has_bits).to_equal(true)
            expect(gpio.fields[1].bits).to_equal(2)

    describe "backend C ABI generation":
        it "emits class create destroy and method wrappers with typed handles":
            val translator = MirToC.create("test.sffi")
            val module = make_mir_module()
            var full_module = module
            val type_def = make_mir_exported_type()
            full_module.types[type_def.symbol] = type_def

            val output = translator.translate_module(full_module)

            expect(output).to_contain("struct spl_Calculator {")
            expect(output).to_contain("Calculator inner;")
            expect(output).to_contain("extern \"C\" spl_Calculator_t spl_Calculator_create(")
            expect(output).to_contain("void spl_Calculator_destroy(spl_Calculator_t self)")
            expect(output).to_contain("extern \"C\" double spl_Calculator_add(spl_Calculator_t self")
            expect(output).to_contain("__simple_Calculator_add(&self->inner")

        it "prefixes standalone exports with spl unless a custom name is provided":
            val translator = MirToC.create("test.sffi")

            val default_output = translator.translate_module(make_mir_module_with_standalone(""))
            expect(default_output).to_contain("extern \"C\" int32_t spl_add_numbers(")

            val custom_output = translator.translate_module(make_mir_module_with_standalone("custom_add"))
            expect(custom_output).to_contain("extern \"C\" int32_t custom_add(")
            expect(custom_output).to_not_contain("extern \"C\" int32_t spl_add_numbers(")

    describe "C and C++ header generation":
        it "emits a C header with guards opaque handles lifecycle and layout checks":
            val module = make_mir_module()
            val header = emit_c_header("calculator", [make_exported_fn("")], [make_mir_exported_type()], module)

            expect(header).to_contain("#ifndef CALCULATOR_H")
            expect(header).to_contain("void spl_library_init(void);")
            expect(header).to_contain("typedef struct spl_Calculator* spl_Calculator_t;")
            expect(header).to_contain("spl_Calculator_create")
            expect(header).to_contain("spl_Calculator_destroy")
            expect(header).to_contain("spl_Calculator_add")
            expect(header).to_contain("spl_add_numbers")
            expect(header).to_contain("_Static_assert")

        it "emits a C++ wrapper with namespace RAII and move-only semantics":
            val module = make_mir_module()
            val header = emit_cpp_header("calculator", [make_mir_exported_type()], [make_exported_fn("")], "calculator.h", module)

            expect(header).to_contain("namespace spl")
            expect(header).to_contain("class Library")
            expect(header).to_contain("Library() { spl_library_init(); }")
            expect(header).to_contain("~Library() { spl_library_shutdown(); }")
            expect(header).to_contain("class Calculator")
            expect(header).to_contain("~Calculator()")
            expect(header).to_contain("Calculator(const Calculator&) = delete;")
            expect(header).to_contain("Calculator(Calculator&& other) noexcept")
            expect(header).to_contain("spl_Calculator_destroy(handle_)")
            expect(header).to_contain("static_assert")

    describe "driver header generation":
        it "generates real C and C++ header files from source-defined exported types and functions":
            val source_path = "/tmp/sffi_driver_header_spec.spl"
            val output_dir = "/tmp/sffi_driver_header_out"
            val header_path = output_dir + "/gpio_driver.h"
            val cpp_header_path = output_dir + "/gpio_driver.hpp"

            cleanup_path(output_dir)
            rt_file_delete(source_path)

            val source =
                "@repr(\"C\")" + NL +
                "@export(\"C\")" + NL +
                "class GpioRegister:" + NL +
                "    mode: u8 @bits(4)" + NL +
                "    output: bool @bits(1)" + NL +
                "    input: bool @bits(1)" + NL +
                "    speed: u8 @bits(2)" + NL + NL +
                "@export(\"C\")" + NL +
                "fn add_numbers(a: i32, b: i32) -> i32:" + NL +
                "    a + b"

            assert_ok(write_source(source_path, source), "failed to write SFFI driver header fixture")

            val result = generate_headers(source_path, output_dir, "gpio_driver", true, true)
            assert_ok(result.is_success(), "driver header generation failed")
            assert_ok(rt_file_exists(header_path), "generated C header missing")
            assert_ok(rt_file_exists(cpp_header_path), "generated C++ header missing")

            val header = rt_file_read_text(header_path) ?? ""
            expect(header).to_contain("typedef struct spl_GpioRegister* spl_GpioRegister_t;")
            expect(header).to_contain("spl_GpioRegister_create")
            expect(header).to_contain("spl_GpioRegister_destroy")
            expect(header).to_contain("uint8_t mode : 4;")
            expect(header).to_contain("uint8_t output : 1;")
            expect(header).to_contain("uint8_t input : 1;")
            expect(header).to_contain("uint8_t speed : 2;")
            expect(header).to_contain("int32_t spl_add_numbers(int32_t arg0, int32_t arg1);")

            val cpp_header = rt_file_read_text(cpp_header_path) ?? ""
            expect(cpp_header).to_contain("#include \"gpio_driver.h\"")
            expect(cpp_header).to_contain("namespace spl")
            expect(cpp_header).to_contain("class Library")
            expect(cpp_header).to_contain("class GpioRegister")
            expect(cpp_header).to_contain("~GpioRegister()")
            expect(cpp_header).to_contain("GpioRegister(const GpioRegister&) = delete;")

            rt_file_delete(source_path)
            cleanup_path(output_dir)

        it "builds a real shared library from the public compiler.driver helper":
            val source_path = "/tmp/sffi_driver_shared_spec.spl"
            val output_path = "/tmp/libsffi_driver_public.so"

            rt_file_delete(source_path)
            rt_file_delete(output_path)

            val source =
                "@export(\"C\")" + NL +
                "fn add_numbers(a: i32, b: i32) -> i32:" + NL +
                "    a + b"

            assert_ok(write_source(source_path, source), "failed to write shared-library fixture")
            expect(source_path).to_end_with(".spl")

            val result = aot_shared_library(source_path, output_path)
            assert_ok(result.is_success(), "public shared-library build failed")
            assert_ok(rt_file_exists(output_path), "shared-library output missing")

            rt_file_delete(source_path)
            rt_file_delete(output_path)

    describe "repr(C) layout verification":
        it "computes stable C layout for a packet header":
            val verification = verify_c_layout(
                "PacketHeader",
                [
                    make_field("version", make_u8_type()),
                    make_field("flags", make_u8_type()),
                    make_field("length", make_u16_type()),
                    make_field("sequence", make_u32_type())
                ],
                layoutattr_c_repr()
            )

            expect(verification.is_valid).to_equal(true)
            expect(verification.total_size).to_equal(8)
            expect(verification.fields[0].name).to_equal("version")
            expect(verification.fields[0].offset).to_equal(0)
            expect(verification.fields[1].offset).to_equal(1)
            expect(verification.fields[2].offset).to_equal(2)
            expect(verification.fields[3].offset).to_equal(4)

    describe "SFFI lint diagnostics":
        it "reports non-C-compatible fields and missing repr(C)":
            val warnings = lint_sffi_export(
                make_exported_class("BadPacket", [make_field("items", make_array_type())], false),
                "test.spl"
            )

            expect(find_by_code(warnings, "SFFI001").len()).to_equal(1)
            expect(find_by_code(warnings, "SFFI003").len()).to_equal(1)

        it "reports text fields bitfield-like layouts and platform-dependent refs":
            val warnings = lint_sffi_export(
                make_exported_class(
                    "MixedInterop",
                    [
                        make_field("name", make_str_type()),
                        make_field("mode", make_u8_type()),
                        make_field("output", make_u8_type()),
                        make_field("input", make_bool_type()),
                        make_field("speed", make_u8_type()),
                        make_field("count_ref", make_ref_type())
                    ],
                    true
                ),
                "test.spl"
            )

            expect(find_by_code(warnings, "SFFI002").len()).to_equal(1)
            expect(find_by_code(warnings, "SFFI004").len()).to_equal(1)
            expect(find_by_code(warnings, "SFFI005").len()).to_equal(1)

        it "accepts explicit @bits metadata with legal widths":
            val warnings = lint_sffi_export(
                make_exported_class(
                    "GpioRegister",
                    [
                        make_bits_field("mode", make_u8_type(), 4),
                        make_bits_field("output", make_bool_type(), 1),
                        make_bits_field("input", make_bool_type(), 1),
                        make_bits_field("speed", make_u8_type(), 2)
                    ],
                    true
                ),
                "test.spl"
            )

            expect(find_by_code(warnings, "SFFI004").len()).to_equal(0)

    describe "shared library build mode":
        it "exposes shared-library flags and output naming for the current platform":
            val flags = get_shared_lib_flags()
            val compile_flags = apply_shared_compile_flags([])
            val link_flags = apply_shared_link_flags([])
            val output_path = shared_lib_output_path("mylib")

            if flags.output_extension.len() == 0:
                expect("shared library output extension should not be empty").to_equal("")
            if not compile_flags.contains("-DSPL_SHARED_LIBRARY"):
                expect("shared compile flags should define SPL_SHARED_LIBRARY").to_equal("")
            expect(link_flags.len()).to_be_greater_than(0)
            expect(output_path).to_end_with(flags.output_extension)

        it "emits guarded lifecycle definitions and auto-init hooks for shared libraries":
            val translator = MirToC.create("test.sffi")
            val output = translator.translate_module(make_mir_module_with_standalone(""))

            expect(output).to_contain("static int spl_library_initialized = 0;")
            expect(output).to_contain("void spl_library_init(void) {")
            expect(output).to_contain("if (spl_library_initialized) return;")
            expect(output).to_contain("void spl_library_shutdown(void) {")
            expect(output).to_contain("if (!spl_library_initialized) return;")
            expect(output).to_contain("_spl_auto_init")
            expect(output).to_contain("_spl_auto_fini")
