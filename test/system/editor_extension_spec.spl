# editor_extension_spec
#
# Phase 6: Extension/plugin system.
# Verifies manifest parsing, extension host, and built-in extensions.

use std.spec

extern fn rt_file_read_text(path: text) -> text

fn read_text(path: text) -> text:
    rt_file_read_text(path) ?? ""

describe "editor extension — manifest":

    it "defines ExtensionManifest struct":
        val src = read_text("src/lib/editor/50.extensions/manifest.spl")
        expect(src.contains("struct ExtensionManifest:")).to_equal(true)
        expect(src.contains("name: text")).to_equal(true)
        expect(src.contains("version: text")).to_equal(true)
        expect(src.contains("main: text")).to_equal(true)
        expect(src.contains("activation_events: [text]")).to_equal(true)

    it "defines ExtensionCommand and ExtensionLanguage":
        val src = read_text("src/lib/editor/50.extensions/manifest.spl")
        expect(src.contains("struct ExtensionCommand:")).to_equal(true)
        expect(src.contains("struct ExtensionLanguage:")).to_equal(true)
        expect(src.contains("struct ExtensionKeybinding:")).to_equal(true)

    it "has extension_manifest_parse function":
        val src = read_text("src/lib/editor/50.extensions/manifest.spl")
        expect(src.contains("fn extension_manifest_parse(content: text) -> ExtensionManifest")).to_equal(true)

    it "parses name, version, main from SDN lines":
        val src = read_text("src/lib/editor/50.extensions/manifest.spl")
        expect(src.contains("starts_with(\"name:\")")).to_equal(true)
        expect(src.contains("starts_with(\"version:\")")).to_equal(true)
        expect(src.contains("starts_with(\"main:\")")).to_equal(true)

describe "editor extension — host":

    it "defines ExtensionHost class":
        val src = read_text("src/lib/editor/50.extensions/host.spl")
        expect(src.contains("class ExtensionHost:")).to_equal(true)
        expect(src.contains("extensions: [ExtensionEntry]")).to_equal(true)
        expect(src.contains("command_registry: [ExtensionCommandEntry]")).to_equal(true)

    it "has index_extension for two-phase loading":
        val src = read_text("src/lib/editor/50.extensions/host.spl")
        expect(src.contains("me index_extension(path: text)")).to_equal(true)

    it "has activate and deactivate":
        val src = read_text("src/lib/editor/50.extensions/host.spl")
        expect(src.contains("me activate(name: text) -> bool")).to_equal(true)
        expect(src.contains("me deactivate(name: text) -> bool")).to_equal(true)

    it "registers contributions on activate":
        val src = read_text("src/lib/editor/50.extensions/host.spl")
        expect(src.contains("self._register_contributions(entry.manifest)")).to_equal(true)

    it "unregisters contributions on deactivate":
        val src = read_text("src/lib/editor/50.extensions/host.spl")
        expect(src.contains("self._unregister_contributions(entry.manifest.name)")).to_equal(true)

    it "provides find_command and find_language_for_ext":
        val src = read_text("src/lib/editor/50.extensions/host.spl")
        expect(src.contains("fn find_command(command_id: text) -> ExtensionCommandEntry")).to_equal(true)
        expect(src.contains("fn find_language_for_ext(file_ext: text) -> text")).to_equal(true)

describe "editor extension — API":

    it "defines ExtensionContext struct":
        val src = read_text("src/lib/editor/50.extensions/api.spl")
        expect(src.contains("struct ExtensionContext:")).to_equal(true)
        expect(src.contains("workspace_path: text")).to_equal(true)
        expect(src.contains("commands: [text]")).to_equal(true)
        expect(src.contains("subscriptions: [text]")).to_equal(true)

    it "has register_command and subscribe helpers":
        val src = read_text("src/lib/editor/50.extensions/api.spl")
        expect(src.contains("fn extension_context_register_command")).to_equal(true)
        expect(src.contains("fn extension_context_subscribe")).to_equal(true)

describe "editor extension — built-in Simple language":

    it "defines spl_language_manifest":
        val src = read_text("src/lib/editor/50.extensions/builtin/spl_language.spl")
        expect(src.contains("fn spl_language_manifest() -> ExtensionManifest")).to_equal(true)
        expect(src.contains("\"simple-language\"")).to_equal(true)
        expect(src.contains(".spl")).to_equal(true)

describe "editor extension — built-in Markdown language":

    it "defines md_language_manifest":
        val src = read_text("src/lib/editor/50.extensions/builtin/md_language.spl")
        expect(src.contains("fn md_language_manifest() -> ExtensionManifest")).to_equal(true)
        expect(src.contains("\"markdown-language\"")).to_equal(true)
        expect(src.contains(".md")).to_equal(true)

describe "editor extension — host contribution wiring":

    it "has extension_contribute_highlighting function":
        val src = read_text("src/lib/editor/50.extensions/host.spl")
        expect(src.contains("fn extension_contribute_highlighting(host: ExtensionHost, language_id: text, line: text) -> text")).to_equal(true)
        expect(src.contains("highlight_spl_line(line)")).to_equal(true)
        expect(src.contains("highlight_render(hl)")).to_equal(true)

    it "has extension_contribute_completions function":
        val src = read_text("src/lib/editor/50.extensions/host.spl")
        expect(src.contains("fn extension_contribute_completions(host: ExtensionHost, language_id: text, prefix: text) -> [text]")).to_equal(true)
        expect(src.contains("spl_keyword_completions(prefix)")).to_equal(true)

    it "has spl_keyword_completions in spl_language":
        val src = read_text("src/lib/editor/50.extensions/builtin/spl_language.spl")
        expect(src.contains("fn spl_keyword_completions(prefix: text) -> [text]")).to_equal(true)
        expect(src.contains("starts_with(prefix)")).to_equal(true)

    it "has md_block_kinds in md_language":
        val src = read_text("src/lib/editor/50.extensions/builtin/md_language.spl")
        expect(src.contains("fn md_block_kinds() -> [text]")).to_equal(true)
        expect(src.contains("heading")).to_equal(true)
        expect(src.contains("paragraph")).to_equal(true)
        expect(src.contains("code")).to_equal(true)
