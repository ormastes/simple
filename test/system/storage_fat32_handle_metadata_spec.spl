"""FR-STORAGE-0003 — FsDriver handle-backed metadata contract."""

use std.fs_driver.types.{DirHandle, FileHandle, FileStat, Inode, Path}

describe "FsDriver handle metadata contract":
    it "file and directory handles are distinct opaque ids":
        val file = FileHandle(id: 42)
        val dir = DirHandle(id: 42)
        expect(file.id).to_equal(dir.id)
        expect(file.is_null()).to_equal(false)
        expect(dir.is_null()).to_equal(false)

    it "path stat and fstat share the same metadata shape":
        val stat = FileStat(
            inode: 7,
            size: 123,
            blocks: 1,
            block_size: 512,
            mode: 0o644,
            uid: 0,
            gid: 0,
            nlinks: 1,
            atime_ns: 0,
            mtime_ns: 0,
            ctime_ns: 0,
            birth_time_ns: 0
        )
        val path = Path(raw: "/FILE.TXT")
        expect(path.raw).to_equal("/FILE.TXT")
        expect(stat.inode).to_equal(7u64)
        expect(stat.size).to_equal(123u64)
