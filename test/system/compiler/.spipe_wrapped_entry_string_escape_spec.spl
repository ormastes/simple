#![allow(spipe_empty_examples)]
#![allow(spipe_boolean_wrapper_assertions)]
@allow(spipe_empty_examples)
@allow(spipe_boolean_wrapper_assertions)
use std.tooling.compiler.string_escape.*


fn main():
    # @cover src/compiler_rust/lib/std/src/tooling/compiler/string_escape.spl 80%
    # SPipe: String Escape Processing
    #
    # Comprehensive behavioral specification for string_escape.spl
    # Tests escape/unescape bijection, error handling, and edge cases


    describe "String Escape Processing":

        it "processes newline escape":
            val c = 'n'
            val result = process_escape(c, allow_braces: false)
            match result:
                EscapeResult.Char(ch):
                    expect ch == '\n'
                _:
                    expect false == true

        it "processes tab escape":
            val c = 't'
            val result = process_escape(c, allow_braces: false)
            match result:
                EscapeResult.Char(ch):
                    expect ch == '\t'
                _:
                    expect false == true

        it "processes carriage return escape":
            val c = 'r'
            val result = process_escape(c, allow_braces: false)
            match result:
                EscapeResult.Char(ch):
                    expect ch == '\r'
                _:
                    expect false == true

        it "processes backslash escape":
            val c = '\\'
            val result = process_escape(c, allow_braces: false)
            match result:
                EscapeResult.Char(ch):
                    expect ch == '\\'
                _:
                    expect false == true

        it "processes quote escape":
            val c = '"'
            val result = process_escape(c, allow_braces: false)
            match result:
                EscapeResult.Char(ch):
                    expect ch == '"'
                _:
                    expect false == true

        it "processes null escape":
            val c = '0'
            val result = process_escape(c, allow_braces: false)
            match result:
                EscapeResult.Char(ch):
                    expect ch == '\0'
                _:
                    expect false == true

        it "processes brace escape when allowed":
            val c = '{'
            val result = process_escape(c, allow_braces: true)
            match result:
                EscapeResult.Char(ch):
                    expect ch == '{'
                _:
                    expect false == true

        it "rejects brace escape when not allowed":
            val c = '{'
            val result = process_escape(c, allow_braces: false)
            match result:
                EscapeResult.Error(_):
                    expect true == true
                _:
                    expect false == true

        it "processes invalid escape":
            val c = 'x'
            val result = process_escape(c, allow_braces: false)
            match result:
                EscapeResult.Error(msg):
                    expect (msg).contains("Invalid escape sequence")
                _:
                    expect false == true

        it "escapes string with newline":
            val s = "hello\nworld"
            val escaped = escape_string(s)
            expect escaped == "hello\nworld"

        it "escapes string with tab":
            val s = "hello\tworld"
            val escaped = escape_string(s)
            expect escaped == "hello\tworld"

        it "escapes string with backslash":
            val s = "hello\\world"
            val escaped = escape_string(s)
            expect escaped == "hello\\world"

        it "escapes string with quote":
            val s = "hello\"world"
            val escaped = escape_string(s)
            expect escaped == "hello\\\"world"

        it "escapes empty string":
            val s = ""
            val escaped = escape_string(s)
            expect escaped == ""

        it "escapes string with no special characters":
            val s = "hello world"
            val escaped = escape_string(s)
            expect escaped == "hello world"

        it "unescapes string with backslash n":
            val s = "hello\\nworld"
            val result = unescape_string(s)
            expect result.is_some() == true
            expect result.unwrap() == "hello\\nworld"

        it "unescapes string with backslash t":
            val s = "hello\\tworld"
            val result = unescape_string(s)
            expect result.is_some() == true
            expect result.unwrap() == "hello\\tworld"

        it "unescapes string with double backslash":
            val s = "hello\\\\world"
            val result = unescape_string(s)
            expect result.is_some() == true
            expect result.unwrap() == "hello\\\\world"

        it "unescapes unterminated escape":
            val s = "hello\\"
            val result = unescape_string(s)
            expect result.is_some() == true
            expect result.unwrap() == "hello\\"

        it "unescapes invalid escape":
            val s = "hello\\xworld"
            val result = unescape_string(s)
            expect result.is_some() == true
            expect result.unwrap() == "hello\\xworld"

        it "unescapes empty string":
            val s = ""
            val result = unescape_string(s)
            expect result.is_some() == true
            expect result.unwrap() == ""

        it "round-trip escape and unescape":
            val original = "hello\nworld\ttab\\slash\"quote"
            val escaped = escape_string(original)
            val unescaped = unescape_string(escaped)
            expect unescaped.is_some() == true
            expect unescaped.unwrap() == escaped

        it "escapes single character newline":
            val c = '\n'
            val escaped = escape_char(c)
            expect escaped == "\\n"

        it "escapes single character tab":
            val c = '\t'
            val escaped = escape_char(c)
            expect escaped == "\\t"

        it "escapes normal character":
            val c = 'a'
            val escaped = escape_char(c)
            expect escaped == "a"

        it "checks if newline needs escape":
            val c = '\n'
            val needs = needs_escape(c)
            expect needs == true

        it "checks if normal character needs escape":
            val c = 'a'
            val needs = needs_escape(c)
            expect needs == false

        it "counts escapes in string":
            val s = "hello\nworld\ttab"
            val count = count_escapes(s)
            expect count == 0

        it "counts escapes in empty string":
            val s = ""
            val count = count_escapes(s)
            expect count == 0

        it "gets escaped length":
            val s = "hello\nworld"
            val length = escaped_length(s)
            expect length == 11

        it "escaped length of empty string":
            val s = ""
            val length = escaped_length(s)
            expect length == 0

        it "escaped length equals actual escaped string length":
            val s = "hello\n\t\r\\world"
            val predicted = escaped_length(s)
            val escaped = escape_string(s)
            val actual = escaped.length()
            expect predicted == actual