#![allow(spipe_empty_examples)]
#![allow(spipe_boolean_wrapper_assertions)]
@allow(spipe_empty_examples)
@allow(spipe_boolean_wrapper_assertions)
use std.nogc_sync_mut.io.process_ops.{shell}

fn simple_binary() -> text:
    val result = shell("test -x src/compiler_rust/target/debug/simple && echo src/compiler_rust/target/debug/simple || echo bin/simple")
    result.stdout.trim()

fn main():

    describe "Lean verification CLI":
        context "simple verify status":
            it "reports the shared Lean verification inventory":
                val simple = simple_binary()
                val result = shell(simple + " verify status")
                expect result.exit_code == 0
                expect (result.stdout).contains("Verification Status")
                expect (result.stdout).contains("Lean 4:")
                expect (result.stdout).contains("src/verification/nogc_compile/src/NogcCompile.lean")
                expect (result.stdout).contains("src/verification/type_inference_compile/src/Generics.lean")
                expect (result.stdout).contains("src/verification/tensor_dimensions/src/TensorMemory.lean")
                expect result.stderr == ""

        context "simple verify list":
            it "lists the authoritative verification files":
                val simple = simple_binary()
                val result = shell(simple + " verify list")
                expect result.exit_code == 0
                expect (result.stdout).contains("Verification Artifact Inventory")
                expect (result.stdout).contains("src/verification/nogc_compile/src/NogcCompile.lean")
                expect (result.stdout).contains("src/verification/memory_model_drf/src/MemoryModelDRF.lean")
                expect result.stderr == ""

        context "simple verify check":
            it "passes against the generated verification tree":
                val simple = simple_binary()
                val result = shell(simple + " verify check")
                expect result.exit_code == 0
                expect (result.stdout).contains("Verification Summary:")
                expect (result.stdout).contains("Files: 15/15 passed")
                expect (result.stdout).contains("src/verification/memory_model_drf/src/MemoryModelDRF.lean")
                expect result.stderr == ""

        context "gen-lean compatibility":
            it "regenerates a project and keeps verification green":
                val simple = simple_binary()
                val write_result = shell(simple + " gen-lean write --force --project type_inference_compile")
                expect write_result.exit_code == 0
                expect ((write_result.stdout + write_result.stderr)).contains("src/verification/type_inference_compile/src/Generics.lean")

                val verify_result = shell(simple + " verify check")
                expect verify_result.exit_code == 0
                expect (verify_result.stdout).contains("Files: 15/15 passed")
                expect verify_result.stdout.contains("warning:") == false
                expect verify_result.stderr == ""