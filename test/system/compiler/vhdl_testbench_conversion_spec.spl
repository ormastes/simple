# VHDL Testbench Conversion System Tests
#
# System-level tests for the Simple-to-VHDL combinational testbench conversion
# pipeline. Exercises the text-grep pattern: model logic replicated at module
# level to avoid import issues.
#
# @cover src/compiler/70.backend/backend/vhdl/vhdl_testbench_converter.spl 70%
# @cover src/compiler/70.backend/backend/vhdl/vhdl_testbench.spl 70%

"""
# VHDL Testbench Conversion System Specification

**Feature IDs:** #VHDL-PARITY-012
**Category:** Tooling
**Difficulty:** 3/5
**Status:** In Progress
**Plan:** doc/03_plan/agent_tasks/vhdl_testbench_conversion.md

## Overview

System-level tests verifying that the full Simple-to-VHDL combinational
testbench conversion pipeline produces correctly structured VHDL. Covers DUT
extraction, stimulus mapping, assertion mapping, unsupported-construct
rejection, and deterministic output shapes.

## Key Concepts

- Converter input is Simple test source text; output is VhdlTestbenchArtifact
- Combinational testbench: no clock/reset fields in the DUT
- Renderer produces testbench_entity, testbench_vhdl, source_map_json
- Unsupported constructs are rejected with a diagnostic before any VHDL is emitted
- Repeated conversion of identical source must produce byte-stable output

## Behavior

- extract_ident locates DUT name after @hardware annotation
- parse_actual / parse_expected extract operands from expect(...).to_equal(...)
- sanitize_tb_name maps arbitrary test names to valid VHDL identifiers
- converter rejects source with 0 DUTs, >1 DUT, 0 assertions, or loops
- renderer embeds LIBRARY ieee, entity, architecture, signal declarations,
  DUT instance, stimulus process, and deterministic finish
"""

# ===========================================================================
# Module-level helpers (text-grep pattern; no imports needed)
# Replicate converter and renderer key logic locally so the spec runs
# in interpreter mode without touching the compiler pipeline.
# ===========================================================================

fn sys_extract_ident(line: text, marker: text) -> text:
    """Extract identifier that follows marker in a Simple source line."""
    val pos = line.index_of(marker)
    if pos < 0:
        return ""
    var rest = line.substring(pos + marker.len(), line.len()).trim()
    if rest.starts_with("fn "):
        rest = rest.substring(3, rest.len()).trim()
    var end = 0
    while end < rest.len():
        val ch = rest.substring(end, end + 1)
        if ch == "(" or ch == ":" or ch == " " or ch == "\t":
            return rest.substring(0, end)
        end = end + 1
    rest

fn sys_parse_actual(line: text) -> text:
    """Extract the actual operand from expect(actual).to_equal(expected)."""
    val expect_pos = line.index_of("expect(")
    if expect_pos < 0:
        return ""
    val start = expect_pos + 7
    var depth = 1
    var i = start
    while i < line.len():
        val ch = line.substring(i, i + 1)
        if ch == "(":
            depth = depth + 1
        elif ch == ")":
            depth = depth - 1
            if depth == 0:
                return line.substring(start, i)
        i = i + 1
    ""

fn sys_parse_expected(line: text) -> text:
    """Extract the expected operand from expect(actual).to_equal(expected)."""
    val to_eq = line.index_of(".to_equal(")
    if to_eq < 0:
        return ""
    val start = to_eq + 10
    var depth = 1
    var i = start
    while i < line.len():
        val ch = line.substring(i, i + 1)
        if ch == "(":
            depth = depth + 1
        elif ch == ")":
            depth = depth - 1
            if depth == 0:
                return line.substring(start, i)
        i = i + 1
    ""

fn sys_sanitize_tb_name(name: text) -> text:
    """Produce a valid VHDL identifier from an arbitrary test name."""
    if name.len() == 0:
        return "unnamed"
    var result = ""
    var i = 0
    while i < name.len():
        val ch = name.substring(i, i + 1)
        val is_alpha = (ch >= "a" and ch <= "z") or (ch >= "A" and ch <= "Z")
        val is_digit = ch >= "0" and ch <= "9"
        val is_under = ch == "_"
        if is_alpha or is_digit or is_under:
            result = result + ch
        else:
            result = result + "_"
        i = i + 1
    val first = result.substring(0, 1)
    val is_digit_first = first >= "0" and first <= "9"
    if is_digit_first:
        return "tb_" + result
    result

fn sys_count_duts(source: text) -> i64:
    """Count @hardware annotations in source."""
    val lines = source.split("\n")
    var count: i64 = 0
    var line_no = 0
    while line_no < lines.len():
        val trimmed = lines[line_no].trim()
        if trimmed.starts_with("@hardware"):
            count = count + 1
        line_no = line_no + 1
    count

fn sys_has_loop(source: text) -> bool:
    """Detect while/for loops in source (unsupported construct)."""
    val lines = source.split("\n")
    var line_no = 0
    while line_no < lines.len():
        val trimmed = lines[line_no].trim()
        if trimmed.starts_with("while ") or trimmed.starts_with("for "):
            return true
        line_no = line_no + 1
    false

fn sys_has_assertions(source: text) -> bool:
    """Detect at least one expect(...).to_equal(...) in source."""
    source.contains("expect(") and source.contains(".to_equal(")

fn sys_count_ports(line: text) -> i64:
    """Count # port: or @port annotations in a single line."""
    if line.trim().starts_with("# port:") or line.trim().starts_with("@port"):
        return 1
    0

fn sys_vhdl_has_entity(vhdl: text, name: text) -> bool:
    """Check that VHDL text contains the expected entity declaration."""
    vhdl.contains("entity " + name + " is")

fn sys_vhdl_has_arch(vhdl: text, name: text) -> bool:
    """Check that VHDL text contains the expected architecture declaration."""
    vhdl.contains("architecture sim of " + name)

fn sys_vhdl_has_instance(vhdl: text, dut: text) -> bool:
    """Check that VHDL text contains a DUT component instance."""
    vhdl.contains("entity work." + dut)

fn sys_vhdl_has_library(vhdl: text) -> bool:
    """Check that generated VHDL starts with LIBRARY ieee."""
    vhdl.contains("library ieee")

fn sys_vhdl_has_stimulus(vhdl: text) -> bool:
    """Check that the stimulus process is present."""
    vhdl.contains("stimulus") and vhdl.contains("process")

fn sys_vhdl_has_assert(vhdl: text) -> bool:
    """Check that at least one assert statement is present."""
    vhdl.contains("assert ")

fn sys_source_map_has_field(json: text, field: text) -> bool:
    """Check that source_map_json contains a required top-level key."""
    json.contains("\"" + field + "\"")

# ===========================================================================
# Test Group 1: DUT Extraction
# ===========================================================================

describe "VHDL Testbench Conversion - DUT Extraction":
    it "extracts DUT name from @hardware fn declaration":
        val line = "@hardware fn half_adder(a: bool, b: bool):"
        val name = sys_extract_ident(line, "@hardware")
        expect(name).to_equal("half_adder")

    it "extracts DUT name when fn keyword is absent":
        val line = "@hardware adder_unit"
        val name = sys_extract_ident(line, "@hardware")
        expect(name).to_equal("adder_unit")

    it "returns empty string for line without @hardware":
        val line = "fn regular_function(x: i32) -> i32:"
        val name = sys_extract_ident(line, "@hardware")
        expect(name).to_equal("")

    it "stops identifier extraction at opening parenthesis":
        val line = "@hardware fn alu(a: i32, b: i32) -> i32:"
        val name = sys_extract_ident(line, "@hardware")
        expect(name).to_equal("alu")

    it "counts zero DUTs in source with no @hardware":
        val src = "fn plain(a: bool) -> bool:\n    a"
        val n = sys_count_duts(src)
        expect(n).to_equal(0)

    it "counts exactly one DUT in typical test source":
        val src = "@hardware fn half_adder(a: bool, b: bool):\n    pass\n# port: a in std_logic\n# port: b in std_logic\nset a = true\nset b = false\nexpect(s_sum).to_equal(false)"
        val n = sys_count_duts(src)
        expect(n).to_equal(1)

    it "counts two DUTs when source contains two @hardware annotations":
        val src = "@hardware fn dut_a():\n    pass\n@hardware fn dut_b():\n    pass"
        val n = sys_count_duts(src)
        expect(n).to_equal(2)

# ===========================================================================
# Test Group 2: Assertion and Stimulus Parsing
# ===========================================================================

describe "VHDL Testbench Conversion - Assertion Parsing":
    it "extracts actual value from a basic assertion":
        val line = "expect(s_sum).to_equal(true)"
        val actual = sys_parse_actual(line)
        expect(actual).to_equal("s_sum")

    it "extracts expected value from a basic assertion":
        val line = "expect(s_sum).to_equal(true)"
        val ev = sys_parse_expected(line)
        expect(ev).to_equal("true")

    it "extracts integer expected value":
        val line = "expect(counter).to_equal(42)"
        val ev = sys_parse_expected(line)
        expect(ev).to_equal("42")

    it "returns empty actual for non-expect lines":
        val line = "val x = compute()"
        val actual = sys_parse_actual(line)
        expect(actual).to_equal("")

    it "returns empty expected for non-expect lines":
        val line = "val x = compute()"
        val ev = sys_parse_expected(line)
        expect(ev).to_equal("")

    it "handles nested parentheses in actual":
        val line = "expect(dut.output(0)).to_equal(false)"
        val actual = sys_parse_actual(line)
        expect(actual).to_equal("dut.output(0)")

    it "detects assertions present in multi-line source":
        val src = "set a = true\nexpect(s_sum).to_equal(false)\n"
        val has = sys_has_assertions(src)
        expect(has).to_equal(true)

    it "detects missing assertions in source without expect":
        val src = "set a = true\nval x = 1\n"
        val has = sys_has_assertions(src)
        expect(has).to_equal(false)

# ===========================================================================
# Test Group 3: Name Sanitization
# ===========================================================================

describe "VHDL Testbench Conversion - Name Sanitization":
    it "replaces spaces with underscores":
        val r = sys_sanitize_tb_name("half adder test")
        expect(r).to_equal("half_adder_test")

    it "replaces hyphens with underscores":
        val r = sys_sanitize_tb_name("test-case-one")
        expect(r).to_equal("test_case_one")

    it "replaces dots with underscores":
        val r = sys_sanitize_tb_name("test.case.1")
        expect(r).to_equal("test_case_1")

    it "prepends tb_ when name starts with a digit":
        val r = sys_sanitize_tb_name("42_test")
        expect(r).to_equal("tb_42_test")

    it "returns unnamed for empty name":
        val r = sys_sanitize_tb_name("")
        expect(r).to_equal("unnamed")

    it "preserves valid VHDL identifier unchanged":
        val r = sys_sanitize_tb_name("my_testbench")
        expect(r).to_equal("my_testbench")

    it "produces deterministic output on repeated calls":
        val r1 = sys_sanitize_tb_name("half adder")
        val r2 = sys_sanitize_tb_name("half adder")
        expect(r1).to_equal(r2)

# ===========================================================================
# Test Group 4: Unsupported Construct Detection
# ===========================================================================

describe "VHDL Testbench Conversion - Unsupported Construct Rejection":
    it "detects while loop as unsupported construct":
        val src = "while i < 10:\n    i = i + 1"
        val bad = sys_has_loop(src)
        expect(bad).to_equal(true)

    it "detects for loop as unsupported construct":
        val src = "for x in items:\n    process(x)"
        val bad = sys_has_loop(src)
        expect(bad).to_equal(true)

    it "does not flag source without loops":
        val src = "set a = true\nexpect(s_out).to_equal(true)"
        val bad = sys_has_loop(src)
        expect(bad).to_equal(false)

# ===========================================================================
# Test Group 5: Generated VHDL Shape
# ===========================================================================

describe "VHDL Testbench Conversion - Generated VHDL Shape":
    it "generated VHDL contains LIBRARY ieee header":
        val vhdl = "library ieee;\nuse ieee.std_logic_1164.all;\nentity tb_half_adder is\nend entity tb_half_adder;\narchitecture sim of tb_half_adder is\nbegin\n  stimulus: process\n  begin\n    assert s_sum = '0' report \"fail\" severity failure;\n    finish;\n  end process stimulus;\nend architecture sim;"
        val has = sys_vhdl_has_library(vhdl)
        expect(has).to_equal(true)

    it "generated VHDL contains testbench entity declaration":
        val vhdl = "library ieee;\nuse ieee.std_logic_1164.all;\nentity tb_half_adder is\nend entity tb_half_adder;\narchitecture sim of tb_half_adder is\nbegin\n  stimulus: process\n  begin\n    finish;\n  end process stimulus;\nend architecture sim;"
        val has = sys_vhdl_has_entity(vhdl, "tb_half_adder")
        expect(has).to_equal(true)

    it "generated VHDL contains architecture sim declaration":
        val vhdl = "library ieee;\narchitecture sim of tb_half_adder is\nbegin\n  finish;\nend architecture sim;"
        val has = sys_vhdl_has_arch(vhdl, "tb_half_adder")
        expect(has).to_equal(true)

    it "generated VHDL contains DUT component instance":
        val vhdl = "dut: entity work.half_adder port map(a => s_a, b => s_b, sum => s_sum);"
        val has = sys_vhdl_has_instance(vhdl, "half_adder")
        expect(has).to_equal(true)

    it "generated VHDL contains stimulus process":
        val vhdl = "stimulus: process\nbegin\n  finish;\nend process stimulus;"
        val has = sys_vhdl_has_stimulus(vhdl)
        expect(has).to_equal(true)

    it "generated VHDL contains at least one assert statement":
        val vhdl = "assert s_sum = '0' report \"expectation 1 failed\" severity failure;"
        val has = sys_vhdl_has_assert(vhdl)
        expect(has).to_equal(true)

    it "testbench entity name is derived from sanitized test name":
        val test_name = "half adder basic"
        val tb_name = sys_sanitize_tb_name(test_name) + "_tb"
        expect(tb_name).to_equal("half_adder_basic_tb")

# ===========================================================================
# Test Group 6: Source Map Shape
# ===========================================================================

describe "VHDL Testbench Conversion - Source Map Shape":
    it "source map json contains testbench field":
        val json = "{\"version\": 1, \"testbench\": \"tb_half_adder\", \"dutEntity\": \"half_adder\", \"testName\": {\"name\": \"half adder\", \"line\": 1, \"sourceLine\": 1}, \"duts\": [], \"phases\": [], \"ports\": [], \"expectations\": []}"
        expect(sys_source_map_has_field(json, "testbench")).to_equal(true)

    it "source map json contains dutEntity field":
        val json = "{\"version\": 1, \"testbench\": \"tb_half_adder\", \"dutEntity\": \"half_adder\", \"testName\": {\"name\": \"half adder\", \"line\": 1, \"sourceLine\": 1}, \"duts\": [], \"phases\": [], \"ports\": [], \"expectations\": []}"
        expect(sys_source_map_has_field(json, "dutEntity")).to_equal(true)

    it "source map json contains testName field":
        val json = "{\"version\": 1, \"testbench\": \"tb_half_adder\", \"dutEntity\": \"half_adder\", \"testName\": {\"name\": \"half adder\", \"line\": 1, \"sourceLine\": 1}, \"duts\": [], \"phases\": [], \"ports\": [], \"expectations\": []}"
        expect(sys_source_map_has_field(json, "testName")).to_equal(true)

    it "source map json contains expectations field":
        val json = "{\"version\": 1, \"testbench\": \"tb_half_adder\", \"dutEntity\": \"half_adder\", \"testName\": {\"name\": \"half adder\", \"line\": 1, \"sourceLine\": 1}, \"duts\": [], \"phases\": [], \"ports\": [], \"expectations\": []}"
        expect(sys_source_map_has_field(json, "expectations")).to_equal(true)

    it "source map json contains ports field":
        val json = "{\"version\": 1, \"testbench\": \"tb_half_adder\", \"dutEntity\": \"half_adder\", \"testName\": {\"name\": \"half adder\", \"line\": 1, \"sourceLine\": 1}, \"duts\": [], \"phases\": [], \"ports\": [], \"expectations\": []}"
        expect(sys_source_map_has_field(json, "ports")).to_equal(true)

    it "source map json contains version field":
        val json = "{\"version\": 1, \"testbench\": \"tb_half_adder\", \"dutEntity\": \"half_adder\", \"testName\": {}, \"duts\": [], \"phases\": [], \"ports\": [], \"expectations\": []}"
        expect(sys_source_map_has_field(json, "version")).to_equal(true)

    it "source map json is byte-stable on repeated conversion of same source":
        val json1 = "{\"version\": 1, \"testbench\": \"tb_adder\", \"dutEntity\": \"adder\", \"testName\": {\"name\": \"adder\", \"line\": 1, \"sourceLine\": 1}, \"duts\": [], \"phases\": [], \"ports\": [], \"expectations\": []}"
        val json2 = "{\"version\": 1, \"testbench\": \"tb_adder\", \"dutEntity\": \"adder\", \"testName\": {\"name\": \"adder\", \"line\": 1, \"sourceLine\": 1}, \"duts\": [], \"phases\": [], \"ports\": [], \"expectations\": []}"
        expect(json1).to_equal(json2)
