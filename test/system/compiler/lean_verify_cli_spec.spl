use app.io.mod (shell)

fn simple_binary() -> text:
    val result = shell("test -x src/compiler_rust/target/debug/simple && echo src/compiler_rust/target/debug/simple || echo bin/simple")
    result.stdout.trim()

describe "Lean verification CLI":
    context "simple verify status":
        it "reports the shared Lean verification inventory":
            val simple = simple_binary()
            val result = shell(simple + " verify status")
            expect(result.exit_code).to_equal(0)
            expect(result.stdout).to_contain("Verification Status")
            expect(result.stdout).to_contain("Lean 4:")
            expect(result.stdout).to_contain("verification/nogc_compile/src/NogcCompile.lean")
            expect(result.stdout).to_contain("verification/type_inference_compile/src/Generics.lean")
            expect(result.stdout).to_contain("verification/tensor_dimensions/src/TensorMemory.lean")

    context "simple verify list":
        it "lists the authoritative verification files":
            val simple = simple_binary()
            val result = shell(simple + " verify list")
            expect(result.exit_code).to_equal(0)
            expect(result.stdout).to_contain("Verification Artifact Inventory")
            expect(result.stdout).to_contain("verification/nogc_compile/src/NogcCompile.lean")
            expect(result.stdout).to_contain("verification/memory_model_drf/src/MemoryModelDRF.lean")

    context "simple verify check":
        it "fails cleanly when verification artifacts are missing":
            val simple = simple_binary()
            val result = shell(simple + " verify check")
            expect(result.exit_code != 0).to_equal(true)
            expect(result.stderr).to_contain("No supported Lean verification files found")

    context "gen-lean compatibility":
        it "shares the same proof-checking failure mode":
            val simple = simple_binary()
            val result = shell(simple + " gen-lean verify")
            expect(result.exit_code != 0).to_equal(true)
            expect(result.stderr).to_contain("No supported Lean verification files found")
