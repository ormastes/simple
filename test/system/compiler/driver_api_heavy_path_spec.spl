# Driver API Heavy Path Tiers - System Tests
#
# Verifies the heavy-path tier modules introduced during Phase 6
# Driver API stabilization:
#   - Tier 0: driver_api_types (externs, find_runtime_lib_dir)
#   - Heavy:  driver_api_core  (full compiler graph: compile, interpret, codegen)
#   - Facade: driver_api       (lightweight re-exports from public_* modules)
#   - Public: driver_public_api, driver_public_compile, driver_public_shared
#
# Each test verifies that importing specific symbols from tier modules
# terminates cleanly (no hangs), scoping is correct, and backward
# compatibility through driver_api_core re-exports is preserved.

use std.spec

# --- Tier 0: driver_api_types (lightweight, no compiler graph) ---
use compiler.driver.driver_api_types.{find_runtime_lib_dir}

# --- Heavy path: driver_api_core (full compiler graph) ---
use compiler.driver.driver_api_core.{
    compile_file     as core_compile_file,
    interpret_file   as core_interpret_file,
    aot_c_file       as core_aot_c_file,
    aot_native_file_with_backend as core_aot_native_file_with_backend,
    aot_native_project_with_backend as core_aot_native_project_with_backend,
    check_file       as core_check_file
}

# --- Lightweight facade: driver_api (subprocess wrappers) ---
use compiler.driver.driver_api.{
    compile_file     as facade_compile_file,
    aot_c_file       as facade_aot_c_file
}

# --- Public tier modules (direct imports) ---
use compiler.driver.driver_public_compile.{
    compile_file     as public_compile_file,
    compile_to_smf   as public_compile_to_smf,
    check_file       as public_check_file,
    parse_sdn_file   as public_parse_sdn_file
}
use compiler.driver.driver_public_api.{
    interpret_file   as public_interpret_file,
    generate_headers as public_generate_headers
}
use compiler.driver.driver_public_shared.{
    aot_shared_library as public_aot_shared_library
}

val NL = "\n"

extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_delete(path: text) -> bool
extern fn rt_file_exists(path: text) -> bool

fn write_file(path: text, content: text) -> bool:
    rt_file_write_text(path, content)

fn delete_file(path: text) -> bool:
    rt_file_delete(path)


describe "Driver API Heavy Path Tiers":

    # ---------------------------------------------------------------
    # 1. Tier import termination tests
    # ---------------------------------------------------------------

    it "driver_api_types imports terminate cleanly":
        val _fn = find_runtime_lib_dir
        expect(true).to_equal(true)

    it "driver_api_core compile_file import terminates cleanly":
        val _fn = core_compile_file
        expect(true).to_equal(true)

    it "driver_api_core interpret_file import terminates cleanly":
        val _fn = core_interpret_file
        expect(true).to_equal(true)

    it "driver_api_core aot_c_file import terminates cleanly":
        val _fn = core_aot_c_file
        expect(true).to_equal(true)

    it "driver_api_core aot_native_file_with_backend import terminates cleanly":
        val _fn = core_aot_native_file_with_backend
        expect(true).to_equal(true)

    it "driver_api_core aot_native_project_with_backend import terminates cleanly":
        val _fn = core_aot_native_project_with_backend
        expect(true).to_equal(true)

    # ---------------------------------------------------------------
    # 2. Grouped import scope tests
    # ---------------------------------------------------------------

    it "importing find_runtime_lib_dir from driver_api_types works in isolation":
        val _fn = find_runtime_lib_dir
        expect(true).to_equal(true)

    it "importing compile_file from driver_public_compile works in isolation":
        val _fn = public_compile_file
        expect(true).to_equal(true)

    # ---------------------------------------------------------------
    # 3. Backward compatibility - driver_api_core re-exports
    # ---------------------------------------------------------------

    it "driver_api_core re-exports find_runtime_lib_dir":
        # find_runtime_lib_dir originates in driver_api_types but is
        # also exported by driver_api_core for backward compat.
        val path_from_types = find_runtime_lib_dir()
        expect(path_from_types.len() > 0).to_equal(true)

    it "driver_api_core re-exports compile_file":
        val _fn = core_compile_file
        expect(true).to_equal(true)

    it "driver_api_core re-exports check_file":
        val _fn = core_check_file
        expect(true).to_equal(true)

    # ---------------------------------------------------------------
    # 4. Facade still works (lightweight subprocess wrappers)
    # ---------------------------------------------------------------

    it "driver_api facade exposes compile_file":
        val _fn = facade_compile_file
        expect(true).to_equal(true)

    it "driver_api facade exposes aot_c_file":
        val _fn = facade_aot_c_file
        expect(true).to_equal(true)

    # ---------------------------------------------------------------
    # 5. Public tier modules - direct import tests
    # ---------------------------------------------------------------

    it "driver_public_compile exposes compile_to_smf":
        val _fn = public_compile_to_smf
        expect(true).to_equal(true)

    it "driver_public_compile exposes parse_sdn_file":
        val _fn = public_parse_sdn_file
        expect(true).to_equal(true)

    it "driver_public_api exposes interpret_file":
        val _fn = public_interpret_file
        expect(true).to_equal(true)

    it "driver_public_api exposes generate_headers":
        val _fn = public_generate_headers
        expect(true).to_equal(true)

    it "driver_public_shared exposes aot_shared_library":
        val _fn = public_aot_shared_library
        expect(true).to_equal(true)

    # ---------------------------------------------------------------
    # 6. Functional test - find_runtime_lib_dir
    # ---------------------------------------------------------------

    it "find_runtime_lib_dir returns a non-empty path":
        val path = find_runtime_lib_dir()
        expect(path.len() > 0).to_equal(true)

    it "find_runtime_lib_dir returns a consistent path across calls":
        val path1 = find_runtime_lib_dir()
        val path2 = find_runtime_lib_dir()
        expect(path1).to_equal(path2)

    # ---------------------------------------------------------------
    # 7. Functional test - check_file via driver_api_core
    # ---------------------------------------------------------------

    it "driver_api_core check_file validates a simple source file":
        val src_path = "/tmp/sml_heavy_path_check.spl"
        write_file(src_path, "fn main(): 42")

        val result = core_check_file(src_path)

        expect(result.is_success()).to_equal(true)
        delete_file(src_path)
