        check_msg(output.contains("bus_rsp_ready : in std_logic;"), output)
        check_msg(output.contains("addr <= bus_cmd_addr;"), output)
        check_msg(output.contains("ok <= bus_cmd_valid and bus_rsp_ready;"), output)
