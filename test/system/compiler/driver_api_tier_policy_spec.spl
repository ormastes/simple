# @cover src/compiler/80.driver/driver_api.spl 80%
# Driver API Tier Policy Guardrails - Structural Tests
#
# Verifies that the tiered driver API module structure follows dependency rules:
#   - Tier 0 (driver_api_types) has no compiler graph imports
#   - Facade (driver_api) does not import from driver_api_core
#   - __init__.spl uses explicit export use, not bare exports
#   - No upward tier dependencies (lower tiers must not import higher tiers)
#
# These are regression tests to prevent future helpers from quietly
# reintroducing heavy-path hangs.

use std.spec

extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_exists(path: text) -> bool

fn read_file(path: text) -> text:
    rt_file_read_text(path)

fn contains_any(content: text, patterns: [text]) -> bool:
    var i = 0
    while i < patterns.len():
        if content.contains(patterns[i]):
            return true
        i = i + 1
    false

describe "Driver API Tier Policy Guardrails":

    # ---------------------------------------------------------------
    # Tier 0: driver_api_types must be compiler-graph-free
    # ---------------------------------------------------------------

    it "tier 0 driver_api_types has no compiler graph imports":
        val content = read_file("src/compiler/80.driver/driver_api_types.spl")
        val heavy_imports = [
            "compiler.hir", "compiler.mir", "compiler.backend",
            "compiler.frontend", "compiler.types", "compiler.mono",
            "compiler.borrow", "compiler.semantics", "compiler.tools",
            "compiler.mir_opt", "CompilerDriver"
        ]
        expect(contains_any(content, heavy_imports)).to_equal(false)

    it "tier 0 driver_api_types exports find_runtime_lib_dir":
        val content = read_file("src/compiler/80.driver/driver_api_types.spl")
        expect(content).to_contain("export find_runtime_lib_dir")

    # ---------------------------------------------------------------
    # Facade: driver_api must not import driver_api_core
    # ---------------------------------------------------------------

    it "facade driver_api does not import from driver_api_core":
        val content = read_file("src/compiler/80.driver/driver_api.spl")
        expect(content.contains("driver_api_core")).to_equal(false)

    it "facade driver_api delegates to lightweight public modules":
        val content = read_file("src/compiler/80.driver/driver_api.spl")
        expect(content).to_contain("driver_public_compile")
        expect(content).to_contain("driver_public_api")
        expect(content).to_contain("driver_public_shared")

    # ---------------------------------------------------------------
    # __init__.spl uses explicit export use (no bare exports)
    # ---------------------------------------------------------------

    it "driver __init__.spl uses explicit export use statements":
        val content = read_file("src/compiler/80.driver/__init__.spl")
        val lines = content.split("\n")
        var bare_export_count = 0
        var i = 0
        while i < lines.len():
            val line = lines[i].trim()
            if line.starts_with("export ") and not line.starts_with("export use ") and not line.starts_with("export compiler_shared") and not line.starts_with("#"):
                bare_export_count = bare_export_count + 1
            i = i + 1
        expect(bare_export_count).to_equal(0)

    # ---------------------------------------------------------------
    # No upward tier dependencies
    # ---------------------------------------------------------------

    it "tier 1 driver_api_interpret does not import from tier 2+":
        val content = read_file("src/compiler/80.driver/driver_api_interpret.spl")
        val forbidden = [
            "driver_api_compile_single", "driver_api_codegen_backends",
            "driver_api_native_single", "driver_api_project_build"
        ]
        expect(contains_any(content, forbidden)).to_equal(false)

    it "tier 2 driver_api_compile_single does not import from tier 3+":
        val content = read_file("src/compiler/80.driver/driver_api_compile_single.spl")
        val forbidden = [
            "driver_api_codegen_backends", "driver_api_native_single",
            "driver_api_project_build"
        ]
        expect(contains_any(content, forbidden)).to_equal(false)

    it "tier 3 driver_api_codegen_backends does not import from tier 4+":
        val content = read_file("src/compiler/80.driver/driver_api_codegen_backends.spl")
        val forbidden = ["driver_api_native_single", "driver_api_project_build"]
        expect(contains_any(content, forbidden)).to_equal(false)

    it "tier 4 driver_api_native_single does not import from tier 5":
        val content = read_file("src/compiler/80.driver/driver_api_native_single.spl")
        expect(content.contains("driver_api_project_build")).to_equal(false)

    # ---------------------------------------------------------------
    # Backward compat: driver_api_core re-exports all tiers
    # ---------------------------------------------------------------

    it "driver_api_core re-exports from all 6 tiers":
        val content = read_file("src/compiler/80.driver/driver_api_core.spl")
        expect(content).to_contain("driver_api_types")
        expect(content).to_contain("driver_api_interpret")
        expect(content).to_contain("driver_api_compile_single")
        expect(content).to_contain("driver_api_codegen_backends")
        expect(content).to_contain("driver_api_native_single")
        expect(content).to_contain("driver_api_project_build")

    it "driver_api_core is a thin re-export file under 25 lines":
        val content = read_file("src/compiler/80.driver/driver_api_core.spl")
        val lines = content.split("\n")
        expect(lines.len() < 25).to_equal(true)
