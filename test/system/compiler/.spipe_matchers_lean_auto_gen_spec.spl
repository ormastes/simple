# @cover src/compiler_rust/lib/std/src/verification/lean/structure_gen.spl 80%
# @cover src/compiler_rust/lib/std/src/verification/lean/auto_gen.spl 80%
# SPipe: Lean Auto-Generation
#
# Tests for the Lean auto-generation helpers used by the verification workflow.

use spipe.*
use verification.lean.emitter as emitter
use verification.lean.naming as naming
use verification.lean.structure_gen as structure_gen
use verification.lean.lookup_gen as lookup_gen
use verification.lean.instantiation_gen as instantiation_gen
use verification.lean.beq_gen as beq_gen
use verification.lean.theorem_gen as theorem_gen
use verification.lean.auto_gen as auto_gen

describe "Lean Auto-Generation":
    context "AutoLeanMode":
        it "reports generation flags":
            expect structure_gen.AutoLeanMode.Full.generates_structures() == true
            expect structure_gen.AutoLeanMode.Full.generates_lookups() == true
            expect structure_gen.AutoLeanMode.Full.generates_beq() == true
            expect structure_gen.AutoLeanMode.StructureOnly.generates_structures() == true
            expect structure_gen.AutoLeanMode.StructureOnly.generates_lookups() == false
            expect structure_gen.AutoLeanMode.Skip.generates_structures() == false
            expect structure_gen.AutoLeanMode.Determinism.generates_theorems() == true

    context "StructureGenerator":
        it "generates structures and inductives":
            var class_def = structure_gen.SimpleClassDef.new("TraitDef")
            class_def = class_def.add_field(structure_gen.SimpleFieldDef.new("name", "text"))
            class_def = class_def.add_field(structure_gen.SimpleFieldDef.new("methods", "TraitMethod").with_list())

            var enum_def = structure_gen.SimpleEnumDef.new("Effect")
            enum_def = enum_def.add_variant(structure_gen.SimpleEnumVariant.unit("Pure"))
            enum_def = enum_def.add_variant(structure_gen.SimpleEnumVariant.unit("Io"))

            var generator = structure_gen.StructureGenerator.new()
            val class_out = generator.generate_structure(class_def)
            val enum_out = generator.generate_inductive(enum_def)

            expect (class_out).contains("structure TraitDef")
            expect (class_out).contains("methods : List TraitMethod")
            expect (enum_out).contains("inductive Effect")
            expect (enum_out).contains("| pure")
            expect (enum_out).contains("| io")

    context "LookupGenerator":
        it "generates lookup scaffolding":
            val registry = lookup_gen.RegistryDef.new("Trait")
            var generator = lookup_gen.LookupGenerator.new()
            val env_out = generator.generate_env_type(registry)
            val lookup_out = generator.generate_lookup(registry)
            val contains_out = generator.generate_contains(registry)

            expect (env_out).contains("def TraitEnv")
            expect (lookup_out).contains("def lookupTrait")
            expect (lookup_out).contains("Option TraitDef")
            expect (contains_out).contains("def containsTrait")
            expect (contains_out).contains("isSome")

    context "InstantiationGenerator":
        it "generates instantiation scaffolding":
            val generic_def = instantiation_gen.GenericTypeDef.new("Class")
            val generator = instantiation_gen.InstantiationGenerator.new()
            val out = generator.generate_instantiate(generic_def)

            expect (out).contains("def instantiateClass")
            expect (out).contains("typeArgs : List Ty")
            expect (out).contains("Option ClassDef")

    context "BeqGenerator":
        it "generates BEq functions and reflexivity proofs":
            var type_def = beq_gen.BeqTypeDef.new("Effect")
            type_def = type_def.add_variant(beq_gen.BeqVariant.new("Pure", []))
            type_def = type_def.add_variant(beq_gen.BeqVariant.new("Io", []))

            var generator = beq_gen.BeqGenerator.new()
            val fun_out = generator.generate_beq_function(type_def)
            val inst_out = generator.generate_beq_instance(type_def)
            val proof_out = generator.generate_reflexivity_proof(type_def)

            expect (fun_out).contains("def Effect.beq")
            expect (fun_out).contains(".pure, .pure => true")
            expect (fun_out).contains("_, _ => false")
            expect (inst_out).contains("instance : BEq Effect")
            expect (proof_out).contains("theorem effect_beq_refl")
            expect (proof_out).contains("rfl")

    context "TheoremGenerator":
        it "generates determinism and empty lookup theorems":
            val det = theorem_gen.generate_determinism_theorem("lookup_trait", [("env", "List TraitDef")], "TraitDef")
            val lookup_empty = theorem_gen.generate_standard_lookup_theorems(["Trait"])

            expect (det).contains("lookupTrait_deterministic")
            expect (det).contains("= some r1")
            expect (det).contains("= some r2")
            expect (lookup_empty).contains("lookupTrait_empty")
            expect (lookup_empty).contains("containsTrait_empty")

    context "AutoGenerator":
        it "builds a proof-clean file set":
            var registry = auto_gen.TypeRegistry.new()
            var class_def = structure_gen.SimpleClassDef.new("Person")
            class_def = class_def.add_field(structure_gen.SimpleFieldDef.new("name", "text"))
            class_def = class_def.add_field(structure_gen.SimpleFieldDef.new("age", "i32"))
            registry = registry.add_class(class_def)

            var enum_def = structure_gen.SimpleEnumDef.new("Mode")
            enum_def = enum_def.add_variant(structure_gen.SimpleEnumVariant.unit("Online"))
            enum_def = enum_def.add_variant(structure_gen.SimpleEnumVariant.unit("Offline"))
            registry = registry.add_enum(enum_def)

            var config = auto_gen.AutoGenConfig.new("build/lean-auto", "Demo")
            var generator = auto_gen.AutoGenerator.new(config)
            generator = generator.set_registry(registry)

            val files = generator.generate_all()
            expect files.len() == 4
            expect files[0].0 == "Generated_Types.lean"
            expect files[1].0 == "Generated_Lookups.lean"
            expect files[2].0 == "Generated_BEq.lean"
            expect files[3].0 == "Generated_Theorems.lean"
            expect files[0].1.contains("sorry") == false
            expect files[1].1.contains("sorry") == false
            expect files[2].1.contains("sorry") == false
            expect files[3].1.contains("sorry") == false
            expect files[0].1.contains("axiom") == false
            expect files[1].1.contains("axiom") == false
            expect files[2].1.contains("axiom") == false
            expect files[3].1.contains("axiom") == false

    context "Type translation":
        it "maps Simple types to Lean types":
            expect structure_gen.translate_type_to_lean("text", false, false) == "String"
            expect structure_gen.translate_type_to_lean("i32", false, false) == "Int"
            expect structure_gen.translate_type_to_lean("TraitDef", false, false) == "TraitDef"

    context "Convenience functions":
        it "generate lookup and BEq helper output":
            val lookups = lookup_gen.generate_standard_lookups("Trait")
            val beq_output = beq_gen.generate_simple_enum_beq("Mode", ["Online", "Offline"])

            expect (lookups).contains("lookupTrait")
            expect (beq_output).contains("instance : BEq Mode")
            expect (beq_output).contains("mode_beq_refl")