#![allow(spipe_empty_examples)]
#![allow(spipe_boolean_wrapper_assertions)]
@allow(spipe_empty_examples)
@allow(spipe_boolean_wrapper_assertions)
use std.tooling.compiler.effects_core.*


fn main():
    # @cover src/compiler_rust/lib/std/src/tooling/compiler/effects_core.spl 80%
    # SPipe: Effect Tracking Core (Lean-Aligned)
    #
    # Comprehensive tests mirroring Lean theorems from src/verification/
    # Tests async safety and GC allocation tracking


    describe "AsyncEffect - is_async predicate":

        it "Compute is async":
            val e = AsyncEffect.Compute
            val result = e.is_async()
            expect result == true

        it "Io is async":
            val e = AsyncEffect.Io
            val result = e.is_async()
            expect result == true

        it "Wait is not async":
            val e = AsyncEffect.Wait
            val result = e.is_async()
            expect result == false

    describe "AsyncEffect - pipeline_safe predicate":

        it "empty list is pipeline safe":
            val effects = []
            val safe = pipeline_safe(effects)
            expect safe == true

        it "list with only Compute is safe":
            val effects = [AsyncEffect.Compute, AsyncEffect.Compute]
            val safe = pipeline_safe(effects)
            expect safe == true

        it "list with Compute and Io is safe":
            val effects = [AsyncEffect.Compute, AsyncEffect.Io, AsyncEffect.Compute]
            val safe = pipeline_safe(effects)
            expect safe == true

        it "list with Wait is not safe":
            val effects = [AsyncEffect.Compute, AsyncEffect.Wait, AsyncEffect.Io]
            val safe = pipeline_safe(effects)
            expect safe == false

        it "singleton Wait list is not safe":
            val effects = [AsyncEffect.Wait]
            val safe = pipeline_safe(effects)
            expect safe == false

    describe "AsyncEffect - append_safe theorem":

        it "append two safe lists":
            val a = [AsyncEffect.Compute, AsyncEffect.Io]
            val b = [AsyncEffect.Compute, AsyncEffect.Compute]
            val result = append_safe(a, b)
            expect pipeline_safe(result) == true
            expect result.length() == 4

        it "append preserves order":
            val a = [AsyncEffect.Compute]
            val b = [AsyncEffect.Io]
            val result = append_safe(a, b)
            expect result[0] == AsyncEffect.Compute == true
            expect result[1] == AsyncEffect.Io == true

        it "append empty lists":
            val a = []
            val b = []
            val result = append_safe(a, b)
            expect result.length() == 0
            expect pipeline_safe(result) == true

    describe "AsyncEffect - wait_detected theorem":

        it "wait detected in unsafe singleton":
            val e = AsyncEffect.Wait
            val result = wait_detected(e)
            expect result == true

        it "no wait in safe Compute singleton":
            val e = AsyncEffect.Compute
            val result = wait_detected(e)
            expect result == true

        it "no wait in safe Io singleton":
            val e = AsyncEffect.Io
            val result = wait_detected(e)
            expect result == true

    describe "AsyncEffect - blocking detection":

        it "no blocking in pure compute":
            val effects = [AsyncEffect.Compute, AsyncEffect.Compute]
            val has_blocking = has_blocking_effects(effects)
            expect has_blocking == false

        it "blocking detected with Wait":
            val effects = [AsyncEffect.Compute, AsyncEffect.Wait]
            val has_blocking = has_blocking_effects(effects)
            expect has_blocking == true

        it "count blocking effects":
            val effects = [AsyncEffect.Wait, AsyncEffect.Compute, AsyncEffect.Wait, AsyncEffect.Io]
            val count = count_blocking(effects)
            expect count == 2

        it "filter async effects":
            val effects = [AsyncEffect.Wait, AsyncEffect.Compute, AsyncEffect.Wait, AsyncEffect.Io]
            val filtered = filter_async(effects)
            expect filtered.length() == 2
            expect pipeline_safe(filtered) == true

    describe "NogcInstr - predicate methods":

        it "GcAlloc is GC allocation":
            val instr = NogcInstr.GcAlloc
            val is_gc = instr.is_gc_alloc()
            expect is_gc == true

        it "Const is not GC allocation":
            val instr = NogcInstr.Const(42)
            val is_gc = instr.is_gc_alloc()
            expect is_gc == false

        it "Add is nogc":
            val instr = NogcInstr.Add
            val is_nogc = instr.is_nogc()
            expect is_nogc == true

    describe "NogcInstr - nogc predicate":

        it "empty list is nogc":
            val instrs = []
            val result = nogc(instrs)
            expect result == true

        it "list with only Const and Add is nogc":
            val instrs = [NogcInstr.Const(1), NogcInstr.Add, NogcInstr.Const(2)]
            val result = nogc(instrs)
            expect result == true

        it "list with GcAlloc is not nogc":
            val instrs = [NogcInstr.Const(1), NogcInstr.GcAlloc, NogcInstr.Add]
            val result = nogc(instrs)
            expect result == false

    describe "NogcInstr - nogc_append theorem":

        it "append two nogc lists":
            val a = [NogcInstr.Const(1), NogcInstr.Add]
            val b = [NogcInstr.Const(2), NogcInstr.Add]
            val result = nogc_append(a, b)
            expect nogc(result) == true
            expect result.length() == 4

        it "append preserves instruction order":
            val a = [NogcInstr.Const(1)]
            val b = [NogcInstr.Add]
            val result = nogc_append(a, b)
            match result[0]:
                NogcInstr.Const(n):
                    expect n == 1
                _:
                    expect false == true
            expect result[1] == NogcInstr.Add == true

    describe "NogcInstr - nogc_singleton theorem":

        it "singleton Const is nogc":
            val instr = NogcInstr.Const(42)
            val result = nogc_singleton(instr)
            expect result == true

        it "singleton Add is nogc":
            val instr = NogcInstr.Add
            val result = nogc_singleton(instr)
            expect result == true

        it "singleton GcAlloc is not nogc":
            val instr = NogcInstr.GcAlloc
            val result = nogc_singleton(instr)
            expect result == false

    describe "NogcInstr - GC allocation tracking":

        it "count GC allocations":
            val instrs = [NogcInstr.GcAlloc, NogcInstr.Const(1), NogcInstr.GcAlloc, NogcInstr.Add]
            val count = count_gc_allocs(instrs)
            expect count == 2

        it "filter nogc instructions":
            val instrs = [NogcInstr.GcAlloc, NogcInstr.Const(1), NogcInstr.GcAlloc, NogcInstr.Add]
            val filtered = filter_nogc(instrs)
            expect filtered.length() == 2
            expect nogc(filtered) == true

    describe "Combined Effect Properties":

        it "create properties from async effects":
            val effects = [AsyncEffect.Compute, AsyncEffect.Io]
            val props = EffectProperties.from_async(effects)
            expect props.is_pipeline_safe == true
            expect props.blocking_count == 0

        it "create properties from async with blocking":
            val effects = [AsyncEffect.Wait, AsyncEffect.Compute]
            val props = EffectProperties.from_async(effects)
            expect props.is_pipeline_safe == false
            expect props.blocking_count == 1

        it "create properties from nogc instructions":
            val instrs = [NogcInstr.Const(1), NogcInstr.Add]
            val props = EffectProperties.from_nogc(instrs)
            expect props.is_nogc == true
            expect props.gc_alloc_count == 0

        it "create properties from instructions with GC":
            val instrs = [NogcInstr.GcAlloc, NogcInstr.Const(1)]
            val props = EffectProperties.from_nogc(instrs)
            expect props.is_nogc == false
            expect props.gc_alloc_count == 1

        it "check optimizability":
            val props = EffectProperties(
                is_pipeline_safe: true,
                is_nogc: true,
                blocking_count: 0,
                gc_alloc_count: 0
            )
            val opt = props.is_optimizable()
            expect opt == true

        it "not optimizable with blocking":
            val props = EffectProperties(
                is_pipeline_safe: false,
                is_nogc: true,
                blocking_count: 1,
                gc_alloc_count: 0
            )
            val opt = props.is_optimizable()
            expect opt == false

        it "calculate effect severity":
            val props = EffectProperties(
                is_pipeline_safe: false,
                is_nogc: false,
                blocking_count: 2,
                gc_alloc_count: 3
            )
            val sev = props.severity()
            expect sev == 5