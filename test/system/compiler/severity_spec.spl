# SSpec: Diagnostic Severity Levels
#
# Comprehensive behavioral specification for severity.spl
# Tests enum behavior, color codes, sorting, and parsing

use std.spec.*
use std.tooling.compiler.severity.*

describe "Diagnostic Severity Levels":

    it "gets severity name for Error":
        val error = Severity.Error
        val name = error.name()
        expect(name).to_equal("error")

    it "gets severity color for Error":
        val error = Severity.Error
        val color = error.color()
        expect(color).to_equal("\x1b[1;31m")

    it "gets severity color for Warning":
        val warning = Severity.Warning
        val color = warning.color()
        expect(color).to_equal("\x1b[1;33m")

    it "gets severity color for Note":
        val note = Severity.Note
        val color = note.color()
        expect(color).to_equal("\x1b[1;36m")

    it "gets severity color for Help":
        val help = Severity.Help
        val color = help.color()
        expect(color).to_equal("\x1b[1;32m")

    it "gets severity color for Info":
        val info = Severity.Info
        val color = info.color()
        expect(color).to_equal("\x1b[1;34m")

    it "gets reset color code":
        val reset = Severity.reset_color()
        expect(reset).to_equal("\x1b[0m")

    it "formats colored severity":
        val warning = Severity.Warning
        val colored = warning.colored()
        expect(colored).to_equal("\x1b[1;33mwarning\x1b[0m")

    it "checks if Error is an error":
        val error = Severity.Error
        val result = error.is_error()
        expect(result).to_equal(true)

    it "checks if Warning is not an error":
        val warning = Severity.Warning
        val result = warning.is_error()
        expect(result).to_equal(false)

    it "checks if Warning is a warning":
        val warning = Severity.Warning
        val result = warning.is_warning()
        expect(result).to_equal(true)

    it "checks if Error blocks compilation":
        val error = Severity.Error
        val blocks = error.blocks_compilation()
        expect(blocks).to_equal(true)

    it "checks if Warning does not block compilation":
        val warning = Severity.Warning
        val blocks = warning.blocks_compilation()
        expect(blocks).to_equal(false)

    it "gets severity order for Error":
        val error = Severity.Error
        val order = error.order()
        expect(order).to_equal(0)

    it "gets severity order for Warning":
        val warning = Severity.Warning
        val order = warning.order()
        expect(order).to_equal(1)

    it "gets severity order for Info":
        val info = Severity.Info
        val order = info.order()
        expect(order).to_equal(4)

    it "parses error string to severity":
        val name = "error"
        val result = Severity.from_name(name)
        expect(result.is_some()).to_equal(true)
        expect(result.unwrap().is_error()).to_equal(true)

    it "parses warning string to severity":
        val name = "warning"
        val result = Severity.from_name(name)
        expect(result.is_some()).to_equal(true)
        expect(result.unwrap().is_warning()).to_equal(true)

    it "parses invalid string to severity":
        val name = "invalid"
        val result = Severity.from_name(name)
        expect(result.is_none()).to_equal(true)

    it "gets all severity levels":
        val all = Severity.all()
        expect(all.length()).to_equal(5)
        expect(all[0].is_error()).to_equal(true)
        expect(all[1].is_warning()).to_equal(true)

    it "severity ordering for sorting":
        val error = Severity.Error
        val warning = Severity.Warning
        val info = Severity.Info
        expect(error.order() < warning.order()).to_equal(true)
        expect(warning.order() < info.order()).to_equal(true)

    it "all names are unique":
        val all = Severity.all()
        val names = [for s in all: s.name()]
        expect(names.length()).to_equal(5)
        expect(names.filter(\n: n == "error").length()).to_equal(1)
        expect(names.filter(\n: n == "warning").length()).to_equal(1)
        expect(names.filter(\n: n == "note").length()).to_equal(1)
        expect(names.filter(\n: n == "help").length()).to_equal(1)
        expect(names.filter(\n: n == "info").length()).to_equal(1)

    it "parse round-trip for all severities":
        val all = Severity.all()
        for severity in all:
            val name = severity.name()
            val parsed = Severity.from_name(name)
            expect(parsed.is_some()).to_equal(true)
            expect(parsed.unwrap().name()).to_equal(name)
