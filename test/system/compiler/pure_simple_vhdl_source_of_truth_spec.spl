# PURE-SIMPLE-VHDL source-of-truth migration specs
# @cover src/compiler/**/*.spl 80%
#
# These are the acceptance specs for making the pure Simple compiler own VHDL
# generation parity. They intentionally remain pending until the implementation
# workers port the currently Rust/facade-proven behavior into structured Simple
# compiler metadata, IR, and VHDL lowering.

use std.spec

describe "pure Simple VHDL source-of-truth metadata":
    it.skip "preserves @hardware metadata through pure Simple AST HIR and MIR":
        # Fixture: @hardware full_add.
        # Expected: the pure Simple compiler selects it as a VHDL entity without
        # reparsing raw source text or relying on the Rust MIR backend.
        nil

    it.skip "preserves @generic metadata as structured VHDL generic declarations":
        # Fixture: @generic(WIDTH: u32 = 8) on a hardware function.
        # Expected: generated entity contains deterministic generic declarations
        # and expressions reference the structured generic value.
        nil

    it.skip "preserves @clocked reset-domain metadata as structured process metadata":
        # Fixture: @clocked(clk, reset_n, active_low, sync).
        # Expected: pure Simple lowering records clock, reset, polarity, and
        # synchrony without string-token facade parsing.
        nil

    it.skip "preserves labeled tuple return field names through pure Simple MIR":
        # Fixture: @hardware full_add returns (sum: bool, cout: bool).
        # Expected: pure Simple VHDL lowering can inspect labels from IR/type
        # metadata, not from the original source line.
        nil

describe "pure Simple VHDL return ABI and diagnostics":
    it.skip "emits labeled tuple return fields as VHDL output ports":
        # Expected: sum/cout are out ports, result_out is absent, and each field
        # has its own assignment.
        nil

    it.skip "accepts same-type labeled output ports":
        # Fixture: @hardware fn flags() -> (left: bool, right: bool).
        # Expected: same-type outputs are legal when labels define the ABI.
        nil

    it.skip "rejects same-type anonymous hardware outputs before VHDL emission":
        # Fixture: @hardware fn bad() -> (bool, bool).
        # Expected: common Simple repeated-anonymous-return diagnostic and no VHDL.
        nil

    it.skip "rejects duplicate sanitized pure Simple VHDL port names":
        # Expected: input/output and output/output collisions report both source
        # names and the sanitized VHDL name.
        nil

describe "pure Simple VHDL hardware calls":
    it.skip "lowers direct hardware calls to deterministic named entity instances":
        # Fixture: add2 calls full_add twice.
        # Expected: u_full_add_0/u_full_add_1 entity instances are emitted in
        # stable source order.
        nil

    it.skip "emits named port map connections for caller and callee ports":
        # Expected: every input and output is connected by sanitized VHDL port
        # name; positional port maps are not used.
        nil

    it.skip "allocates deterministic temp signals for multi-output hardware calls":
        # Expected: repeated pure Simple compilations produce byte-stable signal
        # names for full_add_0_sum/full_add_0_cout and later instances.
        nil

    it.skip "resolves labeled and numeric field access over hardware call results":
        # Fixture: lo.sum, lo.cout, lo.0, and lo.1.
        # Expected: labeled access lowers to temp signals; numeric access works
        # but emits the common labeled-tuple numeric-access warning.
        nil

    it.skip "rejects dynamic runtime tuple access during pure Simple VHDL lowering":
        # Fixture: lo[index] where index is not a compile-time constant.
        # Expected: hard diagnostic before VHDL emission.
        nil

describe "pure Simple VHDL fixed-width and domains":
    it.skip "lowers fixed-width slices concat shifts and comparisons from typed IR":
        # Expected: no facade string parsing; widths, signedness, and conversions
