    """
    ## Capsule Markers on Plug-In Stub Files

    Phase 5 SA-4 creates 4 stub files. TDD-red: these files do not exist before SA-4 runs.
    """

    it "AC-5: vhdl_emit_fp_stub.spl exists with capsule marker vhdl.emit.data.fp":
        val path = stub_fp_path()
        check_msg(rt_file_exists(path), "file not found (SA-4 not run yet): " + path)
        val has_marker = has_capsule_marker_value(path, "vhdl.emit.data.fp")
