# @cover src/compiler/70.backend/backend/vhdl_backend.spl 80%
# @cover src/compiler/70.backend/backend/vhdl/vhdl_builder.spl 80%
# @cover src/compiler/70.backend/backend/vhdl/vhdl_helpers.spl 80%
# @cover src/compiler/70.backend/backend/vhdl/vhdl_memory_templates.spl 80%
# @cover src/compiler/70.backend/backend/vhdl/vhdl_testbench.spl 80%
# @cover src/hardware/fpga_linux/fpga_linux_orchestrator.spl 80%
# @cover src/hardware/fpga_linux/fpga_linux_data.spl 80%
# @cover src/hardware/fpga_linux/fpga_linux_manifest.spl 80%
"""
# RTL MDSOC Capsule Boundary Specification

**Feature IDs:** #rtl-mdsoc-reorg
**Category:** Infrastructure
**Difficulty:** 3/5
**Status:** Draft
**Requirements:** doc/02_requirements/feature/rtl_riscv_mdsoc_reorg.md
**Design:** doc/05_design/rtl_riscv_mdsoc_capsules.md

## Overview

Verifies that every VHDL emitter `.spl` file carries a `# capsule:` marker
line near the top, and that no cross-capsule mutable state exists in the
emitter modules.

## Capsule Marker Contract

Every emitter `.spl` file MUST contain a `# capsule: vhdl.emit.<name>` line
near the top (within the first 40 lines). Re-export facade files
(`mod.spl`, `__init__.spl`) use `# capsule: re-export`.

The 14 emitter files (from Phase 2 research):
1.  src/compiler/70.backend/backend/vhdl_backend.spl
2.  src/compiler/70.backend/backend/vhdl/vhdl_builder.spl
3.  src/compiler/70.backend/backend/vhdl/vhdl_helpers.spl
4.  src/compiler/70.backend/backend/vhdl/vhdl_memory_templates.spl
5.  src/compiler/70.backend/backend/vhdl/vhdl_testbench.spl
6.  src/compiler/70.backend/backend/vhdl/mod.spl
7.  src/compiler/70.backend/backend/vhdl/__init__.spl
8.  src/compiler/70.backend/backend/vhdl_type_mapper.spl
9.  src/compiler/35.semantics/lint/riscv_rtl_debuggability_lint.spl
10. src/hardware/fpga_linux/fpga_linux_orchestrator.spl   (new — Phase 5 SA-3)
11. src/hardware/fpga_linux/fpga_linux_data.spl           (new — Phase 5 SA-3)
12. src/hardware/fpga_linux/fpga_linux_manifest.spl       (new — Phase 5 SA-3)
13. src/hardware/fpga_linux/riscv_fpga_linux.spl          (re-export facade — Phase 5 SA-3)
14. src/compiler/70.backend/backend/vhdl/vhdl_emit_fp_stub.spl    (new — Phase 5 SA-4)

## Acceptance Criteria

- AC-1: MDSOC capsule boundaries are explicit and marked in source
- AC-4: 8-agent plan annotations include Capsule: markers
- AC-5: Plug-in points for SIMD/FP and SMP/cache are present
"""

use std.spec

extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_read_text(path: text) -> text?
extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

fn check_msg(condition: bool, msg: text):
    if not condition:
        expect msg == ""

fn read_file(path: text) -> text:
    rt_file_read_text(path) ?? ""

fn has_capsule_marker(path: text) -> bool:
    val content = read_file(path)
    content.contains("# capsule:")

fn has_capsule_marker_value(path: text, capsule_name: text) -> bool:
    val content = read_file(path)
    content.contains("# capsule: " + capsule_name)

fn vhdl_backend_path() -> text:
    "src/compiler/70.backend/backend/vhdl_backend.spl"

fn vhdl_builder_path() -> text:
    "src/compiler/70.backend/backend/vhdl/vhdl_builder.spl"

fn vhdl_helpers_path() -> text:
    "src/compiler/70.backend/backend/vhdl/vhdl_helpers.spl"

fn vhdl_mem_templates_path() -> text:
    "src/compiler/70.backend/backend/vhdl/vhdl_memory_templates.spl"

fn vhdl_testbench_path() -> text:
    "src/compiler/70.backend/backend/vhdl/vhdl_testbench.spl"

fn vhdl_mod_path() -> text:
    "src/compiler/70.backend/backend/vhdl/mod.spl"

fn vhdl_init_path() -> text:
    "src/compiler/70.backend/backend/vhdl/__init__.spl"

fn vhdl_type_mapper_path() -> text:
    "src/compiler/70.backend/backend/vhdl_type_mapper.spl"

fn rtl_debug_lint_path() -> text:
    "src/compiler/35.semantics/lint/riscv_rtl_debuggability_lint.spl"

fn fpga_orch_path() -> text:
    "src/hardware/fpga_linux/fpga_linux_orchestrator.spl"

fn fpga_data_path() -> text:
    "src/hardware/fpga_linux/fpga_linux_data.spl"

fn fpga_manifest_path() -> text:
    "src/hardware/fpga_linux/fpga_linux_manifest.spl"

fn fpga_facade_path() -> text:
    "src/hardware/fpga_linux/riscv_fpga_linux.spl"

fn stub_fp_path() -> text:
    "src/compiler/70.backend/backend/vhdl/vhdl_emit_fp_stub.spl"

fn stub_simd_path() -> text:
    "src/compiler/70.backend/backend/vhdl/vhdl_emit_simd_stub.spl"

fn stub_cache_path() -> text:
    "src/compiler/70.backend/backend/vhdl/vhdl_emit_cache_stub.spl"

fn stub_hart_path() -> text:
    "src/compiler/70.backend/backend/vhdl/vhdl_emit_hart_stub.spl"

fn plan_path() -> text:
    "doc/03_plan/agent_tasks/pure_simple_vhdl_riscv_gap_spawn_plan.md"

describe "RTL MDSOC Capsule Markers: existing emitter files (AC-1)":
    """
    ## Capsule Markers on Existing Emitter Files

    Phase 5 SA-2 adds `# capsule: vhdl.emit.X` markers to these files.
    These tests are TDD-red: no markers exist before SA-2 runs.
    """

    it "AC-1: vhdl_backend.spl has a capsule marker":
        val path = vhdl_backend_path()
        check_msg(rt_file_exists(path), "file not found: " + path)
        val has_marker = has_capsule_marker(path)
        expect has_marker == true

    it "AC-1: vhdl_builder.spl has capsule marker vhdl.emit.data":
        val path = vhdl_builder_path()
        check_msg(rt_file_exists(path), "file not found: " + path)
        val has_marker = has_capsule_marker_value(path, "vhdl.emit.data")
        expect has_marker == true

    it "AC-1: vhdl_helpers.spl has capsule marker vhdl.emit.control":
        val path = vhdl_helpers_path()
        check_msg(rt_file_exists(path), "file not found: " + path)
        val has_marker = has_capsule_marker_value(path, "vhdl.emit.control")
        expect has_marker == true

    it "AC-1: vhdl_memory_templates.spl has capsule marker vhdl.emit.data":
        val path = vhdl_mem_templates_path()
        check_msg(rt_file_exists(path), "file not found: " + path)
        val has_marker = has_capsule_marker_value(path, "vhdl.emit.data")
        expect has_marker == true

    it "AC-1: vhdl_testbench.spl has capsule marker vhdl.emit.metadata":
        val path = vhdl_testbench_path()
        check_msg(rt_file_exists(path), "file not found: " + path)
        val has_marker = has_capsule_marker_value(path, "vhdl.emit.metadata")
        expect has_marker == true

    it "AC-1: vhdl/mod.spl has capsule marker re-export":
        val path = vhdl_mod_path()
        check_msg(rt_file_exists(path), "file not found: " + path)
        val has_marker = has_capsule_marker_value(path, "re-export")
        expect has_marker == true

    it "AC-1: vhdl/__init__.spl has capsule marker re-export":
        val path = vhdl_init_path()
        check_msg(rt_file_exists(path), "file not found: " + path)
        val has_marker = has_capsule_marker_value(path, "re-export")
        expect has_marker == true

    it "AC-1: vhdl_type_mapper.spl has capsule marker vhdl.emit.data":
        val path = vhdl_type_mapper_path()
        check_msg(rt_file_exists(path), "file not found: " + path)
        val has_marker = has_capsule_marker_value(path, "vhdl.emit.data")
        expect has_marker == true

    it "AC-1: riscv_rtl_debuggability_lint.spl has capsule marker vhdl.emit.metadata":
        val path = rtl_debug_lint_path()
        check_msg(rt_file_exists(path), "file not found: " + path)
        val has_marker = has_capsule_marker_value(path, "vhdl.emit.metadata")
        expect has_marker == true

describe "RTL MDSOC Capsule Markers: Phase 5 SA-3 split files (AC-1)":
    """
    ## Capsule Markers on New Split Files

    Phase 5 SA-3 creates three new files from riscv_fpga_linux.spl.
    TDD-red: these files do not exist before SA-3 runs.
    """

    it "AC-1: fpga_linux_orchestrator.spl exists with capsule marker vhdl.emit.control":
        val path = fpga_orch_path()
        check_msg(rt_file_exists(path), "file not found (SA-3 not run yet): " + path)
        val has_marker = has_capsule_marker_value(path, "vhdl.emit.control")
