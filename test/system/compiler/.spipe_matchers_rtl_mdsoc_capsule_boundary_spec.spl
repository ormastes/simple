    it "AC-5: vhdl_emit_cache_stub.spl exists with capsule marker vhdl.emit.state.cache":
        val path = stub_cache_path()
        check_msg(rt_file_exists(path), "file not found (SA-4 not run yet): " + path)
        val has_marker = has_capsule_marker_value(path, "vhdl.emit.state.cache")
        expect has_marker == true

    it "AC-5: vhdl_emit_hart_stub.spl exists with capsule marker vhdl.emit.state.hart":
        val path = stub_hart_path()
        check_msg(rt_file_exists(path), "file not found (SA-4 not run yet): " + path)
        val has_marker = has_capsule_marker_value(path, "vhdl.emit.state.hart")
        expect has_marker == true

describe "RTL MDSOC 8-Agent Plan Capsule Annotations (AC-4)":
    """
    ## 8-Agent Plan Capsule Annotations (AC-4)

    Verifies that the pure_simple_vhdl_riscv_gap_spawn_plan.md contains a
    `Capsule:` annotation line in the first paragraph of each of the 8 agent
    sections. Phase 5 SA-4 adds these annotations. TDD-red until SA-4 runs.
    """

    it "AC-4: plan file exists":
        val path = plan_path()
        val exists = rt_file_exists(path)
        expect exists == true

    it "AC-4: plan preamble mentions rtl_riscv_mdsoc_reorg capsule mapping":
        val path = plan_path()
        check_msg(rt_file_exists(path), "plan file not found: " + path)
        val content = read_file(path)
        val has_preamble = content.contains("rtl_riscv_mdsoc_reorg")
        expect has_preamble == true

    it "AC-4: Agent 1 section has Capsule annotation for vhdl.emit.metadata":
        val path = plan_path()
        check_msg(rt_file_exists(path), "plan file not found: " + path)
        val content = read_file(path)
        val has_annotation = content.contains("capsule: vhdl.emit.metadata")
        expect has_annotation == true

    it "AC-4: Agent 2 section has Capsule annotation for vhdl.emit.control":
        val path = plan_path()
        check_msg(rt_file_exists(path), "plan file not found: " + path)
        val content = read_file(path)
        val has_annotation = content.contains("capsule: vhdl.emit.control")
        expect has_annotation == true

    it "AC-4: Agent 5 section has Capsule annotation for vhdl.emit.state":
        val path = plan_path()
        check_msg(rt_file_exists(path), "plan file not found: " + path)
        val content = read_file(path)
        val has_annotation = content.contains("capsule: vhdl.emit.state")
        expect has_annotation == true