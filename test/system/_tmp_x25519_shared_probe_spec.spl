use std.sspec.*
use test.system.os_crypto_ref_helpers.{hex_to_bytes, bytes_to_hex}
use os.crypto.curve25519.{x25519}

describe "tmp x25519 shared probe":
    it "shared":
        val a = hex_to_bytes("77076d0a7318a57d3c16c17251b26645df4c2f87ebc0992ab177fba51db92c2a")
        val b = hex_to_bytes("5dab087e624a8a4b79e17f8b83800ee66f3bb1292618b6fd1c2f8b27ff88e0eb")
        val b_pub = hex_to_bytes("de9edb7d7b7dc1b4d35b61c2ece435373f8343c85b78674dadfc7e146f882b4f")
        val a_pub = hex_to_bytes("8520f0098930a754748b7ddcb43ef75a0dbf3a0d26381af4eba4a98eaa9b4e6a")
        print bytes_to_hex(x25519(a, b_pub))
        print bytes_to_hex(x25519(b, a_pub))
        expect(true).to_equal(true)
