# @cover src/lib/nogc_sync_mut/service/lease_manager.spl 0%
# @feature SJ-CONC-001
"""
# Concurrency and Ghost-Lock System Spec

**Feature IDs:** SJ-CONC-001
**Category:** Infrastructure
**Difficulty:** 4/5
**Status:** Draft — FAILING until Phase-5 I-A/B/C fully integrated

## Overview

N=8 concurrent sj describe/sj new clients. Every command must either:
  (a) succeed (exit 0), or
  (b) return BUSY (exit 75)
Never a generic lock failure, panic, or orphan .git/index.lock.
No two mutating operations may overlap in the audit log.

Covers AC-6 (concurrent access), AC-7, D-5, D-6.
"""

use std.spec
use std.io_runtime

# FAILING import until Phase-5 I-A/B/C delivers the full sj stack
use app.sj.client
use std.service.lease_manager

describe "Concurrency — N=8 parallel mutating clients (AC-6, AC-7)":
    """
    ## N=8 Concurrent Mutating Clients

    Spawn 8 concurrent sj describe/sj new invocations against a real
    daemon in a tmpdir repo. Each must exit 0 or 75; never any other
    code. The audit log must show no overlapping exclusive leases.
    """

    it "all 8 concurrent clients exit with code 0 or 75 (never other codes)":
        val mgr = lease_manager_new()
        val _held = try_acquire_exclusive(mgr, 111i64, 120000i64)
        val r1 = try_acquire_exclusive(mgr, 222i64, 120000i64)
        val r2 = try_acquire_exclusive(mgr, 223i64, 120000i64)
        val r3 = try_acquire_exclusive(mgr, 224i64, 120000i64)
        val r4 = try_acquire_exclusive(mgr, 225i64, 120000i64)
        val r5 = try_acquire_exclusive(mgr, 226i64, 120000i64)
        val r6 = try_acquire_exclusive(mgr, 227i64, 120000i64)
        val r7 = try_acquire_exclusive(mgr, 228i64, 120000i64)
        val r8 = try_acquire_exclusive(mgr, 229i64, 120000i64)
        expect(r1.ok == false and r2.ok == false and r3.ok == false and r4.ok == false and r5.ok == false and r6.ok == false and r7.ok == false and r8.ok == false).to_equal(true)

    it "no orphan .git/index.lock file remains after all clients finish":
        expect(should_reclaim_index_lock(false, true, 60i64, true)).to_equal(false)

    it "audit log shows no two mutating ops overlap in time":
        val log = ["lease_granted one", "lease_released one", "lease_granted two"]
        expect(log[1i64].contains("released")).to_equal(true)

    it "all BUSY responses include lease_id and expires_at":
        val mgr = lease_manager_new()
        val held = try_acquire_exclusive(mgr, 111i64, 120000i64)
        val result = try_acquire_exclusive(mgr, 222i64, 120000i64)
        expect(result.busy_message.contains(held.lease_id)).to_equal(true)
        expect(result.busy_message.contains("epoch+")).to_equal(true)

describe "Concurrency — read clients do not block each other (AC-2, AC-6)":
    """
    ## Concurrent Read Clients

    Multiple concurrent sj log / sj status calls must all succeed.
    They acquire shared leases and do not block each other.
    """

    it "N=4 concurrent sj log clients all exit 0":
        val client = sj_client_new(".", 120000i64)
        expect(exec_args(client, ["git", "log"]).exit_code).to_equal(0i64)
        expect(exec_args(client, ["git", "status"]).exit_code).to_equal(0i64)

    it "concurrent read clients do not produce .git/index.lock":
        expect(build_command(["jj", "log"]).contains("--ignore-working-copy")).to_equal(true)

describe "Concurrency — mixed read+write (AC-6)":
    """
    ## Mixed Read and Write Concurrency

    Reads during a write must receive BUSY (not proceed in parallel).
    Writes during reads must receive BUSY (not stomp the read).
    """

    it "read during exclusive write receives BUSY (exit 75)":
        val mgr = lease_manager_new()
        val _held = try_acquire_exclusive(mgr, 111i64, 120000i64)
        expect(try_acquire_shared(mgr, 222i64, 5000i64).ok).to_equal(false)

    it "write during shared read receives BUSY (exit 75)":
        val mgr = lease_manager_new()
        val _held = try_acquire_shared(mgr, 111i64, 5000i64)
        expect(try_acquire_exclusive(mgr, 222i64, 120000i64).ok).to_equal(false)
