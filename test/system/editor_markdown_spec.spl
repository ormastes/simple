    it "md_dispatch.spl has md_dispatch_motion":
        val src = read_text("src/app/editor/md_dispatch.spl")
        expect(src.contains("fn md_dispatch_motion")).to_equal(true)

    it "md_dispatch.spl routes all vim motions":
        val src = read_text("src/app/editor/md_dispatch.spl")
