# @tag:system
#
# System spec — SimpleOS desktop boot with a FAT32 disk image attached.
#
# This lane only validates the FAT32 disk artifact used by the
# resident-manifest compatibility bridge. It is not an arbitrary
# ELF-exec test; the direct native entrypoint lanes live in
# `browser_engine_in_qemu_spec.spl`.
#
# SYS-GUI-007 (storage-backed desktop lane). Boots the real x86_64
# desktop stack under QEMU with a FAT32 NVMe drive attached, waits for
# the guest-side `[vfs] mounted fat32` marker, then drives one launcher
# The current intent is to keep this lane focused on the disk-backed
# artifact needed by the resident-manifest bridge, not on arbitrary
# `native-build` ELF execution. The pre-milestone scaffold TODOs have
# been resolved:
#   - spawn_guest_with_qmp_scenario now threads scenario.qemu_extra
#     through the harness so the NVMe -drive reaches QEMU
#   - desktop_e2e_entry calls vfs_boot_init() and emits the
#     `[vfs] mounted fat32` marker on success (or `[vfs] mount_failed`
#     otherwise)
#   - the launcher marker is asserted on the live lane
#
# Single source of truth used:
#   - qemu_runner.desktop_disk_image_path() -> release-first disk selection
#   - get_desktop_browser_target() -> desktop kernel target
#   - scenario_x64_desktop_disk -> NVMe+FAT32 QEMU shape
#   - qemu_os_harness.spawn_guest_with_qmp_scenario -> live lane
#
# The spec still skips gracefully when QEMU or mkfs.fat/mformat are not
# available on the host — environment skips remain distinct from
# regressions.

use std.spec

use os.qemu_runner.{
    build_os,
    get_desktop_browser_target,
    scenario_x64_desktop_disk,
    ensure_desktop_disk_image,
    desktop_disk_image_path}
use std.nogc_sync_mut.ffi.io.{dir_create_all}

use test.qemu.os.common.qemu_os_harness.{
    can_run_target, file_exists, read_serial_log,
    spawn_guest_with_qmp_scenario, stop_guest, wait_for_serial_marker}

# ===========================================================================
# Helpers
# ===========================================================================

fn ensure_disk_image_or_skip() -> bool:
    dir_create_all("build/os")
    val ok = ensure_desktop_disk_image()
    if not ok:
        print "[simpleos_desktop_disk_boot_spec] disk image unavailable (missing mkfs.fat/mformat?), skipping"
        expect(true).to_equal(true)
        return false
    true

# ===========================================================================
# Spec
# ===========================================================================

describe "SimpleOS desktop boot with FAT32 disk (SYS-GUI-007)":

    it "materializes the selected desktop disk artifact":
        if not ensure_disk_image_or_skip():
            return
        val img_path = desktop_disk_image_path()
        expect(file_exists(img_path)).to_equal(true)

    it "boots the desktop disk lane and proves editor save/readback":
        if not ensure_disk_image_or_skip():
            return

        val target = get_desktop_browser_target()
        expect(build_os(target)).to_equal(true)
        expect(file_exists(target.output)).to_equal(true)

        if not can_run_target(target):
            print "[simpleos_desktop_disk_boot_spec] qemu-system-x86_64 not available, skipping live boot"
            expect(true).to_equal(true)
            return

        val scenario = scenario_x64_desktop_disk()
        val qmp_socket = "/tmp/simpleos_desktop_disk_editor_qmp.sock"
        val serial_log = "build/os/simpleos_desktop_disk_editor_serial.log"

        match spawn_guest_with_qmp_scenario(target, scenario, qmp_socket, serial_log):
            Ok(handle):
                val saw_pass = wait_for_serial_marker(handle, "TEST PASSED", 60000)
                val output = read_serial_log(handle)
                stop_guest(handle)

                expect(saw_pass).to_equal(true)
                expect(output.contains("[vfs] mounted fat32")).to_equal(true)
                expect(output.contains("[desktop-e2e] memory-bootstrap:ok")).to_equal(true)
                expect(output.contains("[desktop-e2e] desktop-ready")).to_equal(true)
                expect(output.contains("[desktop-e2e] remote-grouping:ok")).to_equal(true)
                expect(output.contains("[desktop-e2e] editor-shortcut:ok")).to_equal(true)
                expect(output.contains("[desktop-e2e] editor-save:ok")).to_equal(true)
                expect(output.contains("[desktop-e2e] cli-verify:ok")).to_equal(true)
                expect(output.contains("[c-syscall13] fat32 app image validated")).to_equal(false)
                expect(output.contains("[desktop-e2e] editor-save:fail")).to_equal(false)
                expect(output.contains("[desktop-e2e] editor-launch:fail")).to_equal(false)
                expect(output.contains("[desktop-e2e] cli-verify:fail")).to_equal(false)
                expect(output.contains("FAULT @")).to_equal(false)
                expect(output.contains("EXCEPTION")).to_equal(false)
                expect(output.contains("cr2=")).to_equal(false)
                expect(output.contains("cr3=")).to_equal(false)
            Err(err):
                print "[simpleos_desktop_disk_boot_spec] failed to spawn guest: {err}"
                expect(false).to_equal(true)
