# @cover src/lib/nogc_sync_mut/qemu/mod.spl 60%
#!/usr/bin/env simple
# Manual QEMU Test - Direct Execution
# Tests the unified execution system with QEMU x86_64

use std.qemu.mod.{QemuInstance, QemuConfig, QemuArch}

val NL = "\n"

# Process result structure
class ShellResult:
    stdout: text
    stderr: text
    exit_code: i64

# Shell function
extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

fn shell(cmd: text) -> ShellResult:
    val (stdout, stderr, exit_code) = rt_process_run("/bin/sh", ["-c", cmd])
    ShellResult(stdout: stdout, stderr: stderr, exit_code: exit_code)

fn main():
    print("{NL}╔════════════════════════════════════════════╗")
    print("║  QEMU Unified Execution - Manual Test     ║")
    print("╚════════════════════════════════════════════╝{NL}")

    # Test 1: Basic QEMU startup
    print("Test 1: QEMU Instance Startup")
    print("─────────────────────────────────────────────")

    val binary = "examples/baremetal/hello_x86_64.elf"

    # Check binary exists
    val check = shell("test -f {binary}")
    if check.exit_code != 0:
        print("❌ Binary not found: {binary}")
        print("   Run: cd examples/baremetal && bash build.sh")
        return

    print("✓ Binary found: {binary}")

    # Create QEMU config with GDB stub
    val config = QemuConfig__for_remote_debug(
        QemuArch.X86_64,
        binary,
        1234
    )

    print("✓ Config created:")
    print("  - Architecture: x86_64")
    print("  - Binary: {binary}")
    print("  - GDB port: 1234")

    # Start QEMU
    print("{NL}⏳ Starting QEMU...")
    val result = QemuInstance__start(config)

    match result:
        Ok(instance):
            print("✓ QEMU started successfully!")
            print("  - PID: {instance.get_pid()}")
            print("  - GDB port: {instance.get_gdb_port()}")

            # Wait for GDB stub to initialize
            shell("sleep 1")

            # Check if QEMU is running
            if instance.is_running():
                print("✓ QEMU instance is running")
            else:
                print("⚠ QEMU instance stopped unexpectedly")

            # Check GDB port
            print("{NL}⏳ Checking GDB stub...")
            val port_check = shell("ss -tlnp 2>/dev/null | grep ':1234' || true")
            if port_check.stdout.contains("1234"):
                print("✓ GDB stub is listening on port 1234")
            else:
                print("⚠ GDB port check inconclusive (may need elevated permissions)")
                print("  You can verify manually: ss -tlnp | grep 1234")

            # Stop QEMU
            print("{NL}⏳ Stopping QEMU...")
            instance.stop()
            shell("sleep 0.5")

            if not instance.is_running():
                print("✓ QEMU stopped successfully")
            else:
                print("⚠ QEMU may still be running")

            print("{NL}╔════════════════════════════════════════════╗")
            print("║  ✓ Test PASSED                             ║")
            print("╚════════════════════════════════════════════╝{NL}")

        Err(e):
            print("❌ Failed to start QEMU")
            print("   Error: {e}")
            print("{NL}   Troubleshooting:")
            print("   1. Check QEMU is installed:")
            print("      qemu-system-x86_64 --version")
            print("   2. Check binary exists:")
            print("      ls -l {binary}")
            print("   3. Check for permission issues")
            print("{NL}╔════════════════════════════════════════════╗")
            print("║  ✗ Test FAILED                             ║")
            print("╚════════════════════════════════════════════╝{NL}")

    # Test 2: Run to completion
    print("{NL}Test 2: Run Binary to Completion")
    print("─────────────────────────────────────────────")

    # Create config for test execution
    val test_config = QemuConfig__for_test_runner(QemuArch.X86_64, binary)

    print("✓ Test config created (stdio output, debug exit)")

    print("{NL}⏳ Starting QEMU and running binary...")
    val test_result = QemuInstance__start(test_config)

    match test_result:
        Ok(instance):
            print("✓ QEMU started")

            # Wait for completion
            val exit_result = instance.wait_exit(timeout_ms: 10000)

            match exit_result:
                Ok(exit_code):
                    # Debug-exit device encoding: exit(0) -> QEMU exits with 1
                    if exit_code == 1:
                        print("✓ Binary executed successfully")
                        print("  - Exit code: {exit_code} (debug-exit encoding of 0)")
                    else:
                        print("⚠ Binary exited with code: {exit_code}")

                    print("{NL}╔════════════════════════════════════════════╗")
                    print("║  ✓ Test PASSED                             ║")
                    print("╚════════════════════════════════════════════╝{NL}")

                Err(e):
                    instance.stop()
                    print("❌ Execution failed: {e}")
                    print("{NL}╔════════════════════════════════════════════╗")
                    print("║  ✗ Test FAILED                             ║")
                    print("╚════════════════════════════════════════════╝{NL}")

        Err(e):
            print("❌ Failed to start QEMU: {e}")
            print("{NL}╔════════════════════════════════════════════╗")
            print("║  ✗ Test FAILED                             ║")
            print("╚════════════════════════════════════════════╝{NL}")

    print("{NL}🎉 Manual test completed!{NL}")
