# OS Shell Integration Test
#
# Tests: ShellApp command execution with VFS backing
# QEMU scenario: x64-nvme-fat32
# Exercises: ls, cat, echo, mkdir, pwd, cd, help, env, mem, run, reboot,
# bootstrap-oriented which/uname/toolchain shims and recursive file ops
#
# Instead of injecting stdin (impossible in QEMU serial tests), this test
# creates a ShellApp.with_vfs() and calls execute() directly with command
# strings. Results are captured via shell.output_lines.
#
# This test runs as a baremetal OS entry point, not under the SSpec harness.

use os.kernel.boot.init_services.{init_services, services_storage_ready}
use os.services.vfs.vfs_init.{g_vfs, g_vfs_initialized}
use os.posix.mod.{posix_init}
use os.apps.shell.shell_app.{ShellApp}
use os.userlib.syscall_raw.{syscall}

extern fn serial_println(msg: text)
extern fn rt_exit(code: i32)

val ISA_DEBUG_EXIT_PORT: u64 = 0xf4

var _pass_count: u32 = 0
var _fail_count: u32 = 0

fn _assert(condition: bool, name: text):
    if condition:
        serial_println("[TEST PASS] {name}")
        _pass_count = _pass_count + 1
    else:
        serial_println("[TEST FAIL: {name}]")
        _fail_count = _fail_count + 1

fn _report():
    serial_println("")
    serial_println("Shell tests: {_pass_count} passed, {_fail_count} failed")
    if _fail_count == 0:
        serial_println("[ALL TESTS PASSED]")
    else:
        serial_println("[TESTS FAILED: {_fail_count}]")
    syscall(ISA_DEBUG_EXIT_PORT, 0, 0, 0, 0, 0)

fn os_shell_test():
    """Entry point for Shell + VFS integration tests."""
    serial_println("=== OS Shell Integration Test ===")
    serial_println("")

    # Initialize POSIX and boot services
    posix_init()
    init_services()

    if not g_vfs_initialized:
        serial_println("[SKIP] VFS not initialized -- cannot test shell")
        _assert(false, "VFS initialized for shell tests")
        _report()
        return

    # Create shell connected to VFS
    var shell = ShellApp.with_vfs(g_vfs)

    # ---- Test 1: Shell creation succeeds ----
    _assert(shell.running, "Shell is running after creation")

    # ---- Test 2: pwd returns root ----
    shell.output_lines = []
    shell.execute("pwd")
    val pwd_output = shell.output_lines
    serial_println("[INFO] pwd output: {pwd_output}")
    _assert(pwd_output.len() > 0, "pwd produces output")
    if pwd_output.len() > 0:
        _assert(pwd_output[0].contains("/"), "pwd shows root directory")

    # ---- Test 3: echo prints arguments ----
    shell.output_lines = []
    shell.execute("echo Hello World")
    val echo_output = shell.output_lines
    serial_println("[INFO] echo output: {echo_output}")
    _assert(echo_output.len() > 0, "echo produces output")
    if echo_output.len() > 0:
        _assert(echo_output[0].contains("Hello"), "echo prints arguments")

    # ---- Test 4: ls on root directory ----
    shell.output_lines = []
    shell.execute("ls /")
    val ls_output = shell.output_lines
    serial_println("[INFO] ls / output lines: {ls_output.len()}")
    _assert(ls_output.len() > 0, "ls / produces output")

    # ---- Test 5: ls shows hello.txt fixture ----
    var found_hello = false
    var li: u64 = 0
    while li < ls_output.len():
        if ls_output[li].contains("hello.txt"):
            found_hello = true
        li = li + 1
    _assert(found_hello, "ls / shows hello.txt fixture file")

    # ---- Test 6: cat reads file content ----
    shell.output_lines = []
    shell.execute("cat /hello.txt")
    val cat_output = shell.output_lines
    serial_println("[INFO] cat /hello.txt output: {cat_output}")
    _assert(cat_output.len() > 0, "cat /hello.txt produces output")
    if cat_output.len() > 0:
        _assert(cat_output[0].contains("Hello"), "cat shows file content")

    # ---- Test 7: mkdir creates directory ----
    shell.output_lines = []
    shell.execute("mkdir /shelltest")
    # Verify by listing
    shell.output_lines = []
    shell.execute("ls /")
    val ls2_output = shell.output_lines
    var found_dir = false
    var di: u64 = 0
    while di < ls2_output.len():
        if ls2_output[di].contains("shelltest"):
            found_dir = true
        di = di + 1
    _assert(found_dir, "mkdir /shelltest creates directory visible in ls")

    # ---- Test 8: cd changes directory ----
    shell.execute("cd /shelltest")
    shell.output_lines = []
    shell.execute("pwd")
    val cd_output = shell.output_lines
    serial_println("[INFO] pwd after cd: {cd_output}")
    if cd_output.len() > 0:
        _assert(cd_output[0].contains("shelltest"), "cd /shelltest changes cwd")
    else:
        _assert(false, "cd /shelltest changes cwd (no pwd output)")

    # ---- Test 9: help command lists commands ----
    shell.output_lines = []
    shell.execute("help")
    val help_output = shell.output_lines
    _assert(help_output.len() > 2, "help lists multiple commands (lines={help_output.len()})")

    # ---- Test 10: mem command is wired ----
    shell.output_lines = []
    shell.execute("mem --help")
    val mem_output = shell.output_lines
    _assert(mem_output.len() > 0, "mem --help produces output")

    # ---- Test 11: run command is wired ----
    shell.output_lines = []
    shell.execute("run --help")
    val run_output = shell.output_lines
    _assert(run_output.len() > 0, "run --help produces output")

    # ---- Test 12: reboot command is wired ----
    shell.output_lines = []
    shell.execute("reboot --help")
    val reboot_output = shell.output_lines
    _assert(reboot_output.len() > 0, "reboot --help produces output")

    # ---- Test 13: unknown command does not crash ----
    shell.output_lines = []
    shell.execute("nonexistent_command_xyz")
    _assert(true, "Unknown command does not crash shell")

    # ---- Test 14: exit sets running to false ----
    shell = ShellApp.with_vfs(g_vfs)

    # ---- Test 14: mkdir -p creates nested directories ----
    shell.output_lines = []
    shell.execute("mkdir -p /shelltree/inner/leaf")
    val nested_dir = g_vfs.stat("/shelltree/inner/leaf")
    _assert(nested_dir.is_ok(), "mkdir -p creates nested directories")

    # ---- Test 15: which resolves packaged /usr/bin cmake through PATH ----
    shell.output_lines = []
    shell.execute("which cmake")
    val which_cmake_output = shell.output_lines
    _assert(which_cmake_output.len() > 0, "which cmake produces output")
    if which_cmake_output.len() > 0:
        _assert(which_cmake_output[0].contains("/usr/bin/cmake"), "which cmake resolves packaged wrapper")

    # ---- Test 16: which resolves packaged /usr/bin clang through PATH ----
    shell.output_lines = []
    shell.execute("which clang")
    val which_output = shell.output_lines
    _assert(which_output.len() > 0, "which clang produces output")
    if which_output.len() > 0:
        _assert(which_output[0].contains("/usr/bin/clang"), "which clang resolves packaged wrapper")

    # ---- Test 17: uname reports SimpleOS identity ----
    shell.output_lines = []
    shell.execute("uname -a")
    val uname_output = shell.output_lines
    _assert(uname_output.len() > 0, "uname -a produces output")
    if uname_output.len() > 0:
        _assert(uname_output[0].contains("SimpleOS"), "uname -a reports SimpleOS")

    # ---- Test 18: cmake wrapper supports version/help discovery ----
    shell.output_lines = []
    shell.execute("cmake --version")
    val cmake_version_output = shell.output_lines
    _assert(cmake_version_output.len() > 0, "cmake --version produces output")
    if cmake_version_output.len() > 0:
        _assert(cmake_version_output[0].contains("simple_cmake native wrapper"), "cmake wrapper reports packaged version")

    shell.output_lines = []
    shell.execute("cmake -E capabilities")
    val cmake_capabilities_output = shell.output_lines
    _assert(cmake_capabilities_output.len() > 0, "cmake -E capabilities produces output")
    if cmake_capabilities_output.len() > 0:
        _assert(cmake_capabilities_output[0].contains("serverMode=false"), "cmake capabilities reports wrapper metadata")

    # ---- Test 19: ninja --version is available in guest bootstrap shim ----
    shell.output_lines = []
    shell.execute("ninja --version")
    val ninja_output = shell.output_lines
    _assert(ninja_output.len() > 0, "ninja --version produces output")

    # ---- Test 20: clang/rustc/cargo expose packaged guest wrappers ----
    shell.output_lines = []
    shell.execute("clang --version")
    val clang_output = shell.output_lines
    _assert(clang_output.len() > 0, "clang --version produces output")
    if clang_output.len() > 0:
        _assert(clang_output[0].contains("clang version"), "clang shim reports staged LLVM version")

    shell.output_lines = []
    shell.execute("rustc --version")
    val rustc_output = shell.output_lines
    _assert(rustc_output.len() > 0, "rustc --version produces output")
    if rustc_output.len() > 0:
        _assert(rustc_output[0].contains("rustc "), "rustc shim reports staged Rust version")

    shell.output_lines = []
    shell.execute("cargo --version")
    val cargo_output = shell.output_lines
    _assert(cargo_output.len() > 0, "cargo --version produces output")
    if cargo_output.len() > 0:
        _assert(cargo_output[0].contains("cargo "), "cargo shim reports staged Cargo version")

    # ---- Test 21: unsupported toolchain ops fail clearly instead of fake exec ----
    shell.output_lines = []
    shell.execute("cmake -S /src -B /build -G Ninja")
    val cmake_fail_output = shell.output_lines
    _assert(cmake_fail_output.len() > 0, "cmake unsupported configure reports an error")
    _assert(shell.last_exit_code != 0, "cmake unsupported configure exits nonzero")

    shell.output_lines = []
    shell.execute("clang -c /hello.c -o /tmp/hello.o")
    val clang_fail_output = shell.output_lines
    _assert(clang_fail_output.len() > 0, "clang unsupported op reports an error")
    _assert(shell.last_exit_code != 0, "clang unsupported op exits nonzero")

    # ---- Test 22: cp -r copies a directory tree and rm -rf removes it ----
    shell.output_lines = []
    shell.execute("mkdir -p /shellcopy/src")
    shell.execute("echo copied > /shellcopy/src/file.txt")
    shell.execute("cp -r /shellcopy/src /shellcopy/dst")
    val copied_file = g_vfs.stat("/shellcopy/dst/file.txt")
    _assert(copied_file.is_ok(), "cp -r copies directory trees")
    shell.execute("rm -rf /shellcopy")
    val removed_tree = g_vfs.stat("/shellcopy")
    _assert(removed_tree.is_err(), "rm -rf removes copied directory trees")

    # ---- Test 23: exit sets running to false ----
    shell.execute("exit")
    _assert(not shell.running, "exit command stops shell")

    # ---- Test 24: shell scripting engine — if/else executes correct branch ----
    shell = ShellApp.with_vfs(g_vfs)
    shell.output_lines = []
    shell.execute("if true; then echo branch-true; else echo branch-false; fi")
    val if_output = shell.output_lines
    _assert(if_output.len() > 0, "if/else script produces output")
    if if_output.len() > 0:
        _assert(if_output[0].contains("branch-true"), "if true takes then-branch")

    # ---- Test 25: shell scripting engine — for loop iterates word list ----
    shell.output_lines = []
    shell.execute("for W in alpha beta gamma; do echo $W; done")
    val for_output = shell.output_lines
    _assert(for_output.len() == 3, "for loop iterates 3 words (got {for_output.len()})")
    if for_output.len() == 3:
        _assert(for_output[0].contains("alpha"), "for loop first iteration is alpha")
        _assert(for_output[2].contains("gamma"), "for loop last iteration is gamma")

    # ---- Test 26: shell scripting engine — while loop with break ----
    shell.output_lines = []
    shell.execute("I=0; while true; do I=$((I+1)); if [ $I -eq 3 ]; then break; fi; done; echo done-$I")
    val while_output = shell.output_lines
    _assert(while_output.len() > 0, "while+break script produces output")
    if while_output.len() > 0:
        _assert(while_output[while_output.len() - 1].contains("done-3"), "while loop breaks at I=3")

    # ---- Test 27: variable expansion — $? reflects previous exit code ----
    shell.output_lines = []
    shell.execute("false; echo exitcode=$?")
    val exit_code_output = shell.output_lines
    _assert(exit_code_output.len() > 0, "$? expansion produces output")
    if exit_code_output.len() > 0:
        _assert(not exit_code_output[exit_code_output.len() - 1].contains("exitcode=0"),
            "$? is nonzero after false command")

    # ---- Test 28: alias builtin registers and expands alias ----
    shell.output_lines = []
    shell.execute("alias ll='ls -l'")
    shell.output_lines = []
    shell.execute("ll /")
    val alias_output = shell.output_lines
    _assert(alias_output.len() > 0, "alias ll expands to ls -l and produces output")

    # ---- Test 29: awk tool — field splitting and print ----
    shell.output_lines = []
    shell.execute("echo 'hello world' | awk '{ print $2 }'")
    val awk_output = shell.output_lines
    _assert(awk_output.len() > 0, "awk field print produces output")
    if awk_output.len() > 0:
        _assert(awk_output[0].contains("world"), "awk $2 extracts second field")

    _report()
