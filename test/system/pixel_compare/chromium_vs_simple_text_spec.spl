# @cover src/lib/gc_async_mut/gpu/browser_engine/simple_web_engine2d_renderer.spl 80%
# @cover src/os/compositor/web_render_surface.spl 60%
# @tag: rendering, pixel-compare, text, chromium

# Pixel-level comparison: real Chromium capture vs Simple web renderer
#
# Phase 1: Simple text — "Hello World" in monospace on white background.
# Reference: ARGB pixel buffer captured from real Electron/Chromium via
# tools/electron-live-bitmap/capture_html_argb.js under xvfb.

use std.spipe.*
use common.ui.web_render_api.{WebRenderRequest, WEB_RENDER_TARGET_PURE_SIMPLE}
use os.compositor.web_render_surface.{compositor_render_html_pixels}

extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_exists(path: text) -> bool

val W: i32 = 320
val H: i32 = 240

fn _abs_diff(a: i32, b: i32) -> i32:
    if a > b:
        return a - b
    b - a

fn _load_electron_argb(path: text) -> [u32]:
    val json_text = rt_file_read_text(path)
    # Minimal JSON array parser for "pixels":[...]
    val marker = "\"pixels\":["
    val start = json_text.index_of(marker)
    if start < 0:
        return []
    val rest = json_text.substring(start + marker.len())
    val end = rest.index_of("]")
    if end < 0:
        return []
    val nums_text = rest.substring(0, end)
    val parts = nums_text.split(",")
    var pixels: [u32] = []
    var i = 0
    while i < parts.len():
        val trimmed = parts[i].trim()
        if trimmed.len() > 0:
            pixels = pixels + [trimmed.to_i64().to_u32()]
        i = i + 1
    pixels

fn _render_simple_html(html_path: text) -> [u32]:
    val html = rt_file_read_text(html_path)
    val req = WebRenderRequest.html(
        WEB_RENDER_TARGET_PURE_SIMPLE, "pixel-compare", html, "", "", W, H
    ).with_pixel_output()
    compositor_render_html_pixels(req, html)

fn _diff_pixels(name: text, chrome: [u32], simple: [u32], w: i32, h: i32) -> i32:
    val total = w * h
    if chrome.len() != total:
        print("WARN: chrome pixel count " + chrome.len().to_text() + " != expected " + total.to_text())
        return -1
    if simple.len() != total:
        print("WARN: simple pixel count " + simple.len().to_text() + " != expected " + total.to_text())
        return -1
    var differing = 0
    var max_channel_delta = 0
    var total_channel_delta: i64 = 0
    var i = 0
    while i < total:
        val cp = chrome[i]
        val sp = simple[i]
        if cp != sp:
            val cr = (cp >> 16) & 0xFF
            val cg = (cp >> 8) & 0xFF
            val cb = cp & 0xFF
            val sr = (sp >> 16) & 0xFF
            val sg = (sp >> 8) & 0xFF
            val sb = sp & 0xFF
            val dr = _abs_diff(cr.to_i32(), sr.to_i32())
            val dg = _abs_diff(cg.to_i32(), sg.to_i32())
            val db = _abs_diff(cb.to_i32(), sb.to_i32())
            val d = dr + dg + db
            total_channel_delta = total_channel_delta + d.to_i64()
            if d > max_channel_delta:
                max_channel_delta = d
            differing = differing + 1
        i = i + 1
    print(name + " diff: " + differing.to_text() + "/" + total.to_text() + " pixels differ")
    print(name + " max_channel_delta=" + max_channel_delta.to_text() + " total_delta=" + total_channel_delta.to_text())
    differing

describe "Chromium vs Simple — simple text":
    val electron_path = "build/pixel_compare/electron_simple_text.json"
    val html_path = "test/fixtures/pixel_compare/simple_text.html"

    it "diagnostic: electron capture file exists":
        expect(rt_file_exists(electron_path)).to_equal(true)

    it "diagnostic: Simple renderer produces non-empty pixels":
        val pixels = _render_simple_html(html_path)
        expect(pixels.len()).to_equal(W * H)
        # At least some non-white pixels (text)
        var non_white = 0
        var i = 0
        while i < pixels.len():
            if pixels[i] != 0xFFFFFFFFu32:
                non_white = non_white + 1
            i = i + 1
        print("simple non-white pixels: " + non_white.to_text())
        expect(non_white).to_be_greater_than(0)

    it "diagnostic: pixel diff report — simple text":
        val chrome = _load_electron_argb(electron_path)
        val simple = _render_simple_html(html_path)
        val diff_count = _diff_pixels("simple_text", chrome, simple, W, H)
        print("differing_pixels=" + diff_count.to_text())
        # Diagnostic only — no hard threshold yet
        expect(diff_count).to_be_greater_than(-1)
