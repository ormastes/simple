"""
# Remote Baremetal Lane Status System Spec
#
# @cover src/lib/nogc_sync_mut/debug/remote/exec/lane_registry.spl 80%
#
# Validates that the lane descriptor, capability report, and lane
# registry infrastructure works correctly. This is the authoritative
# test for the lane classification and status reporting system.
"""

use std.nogc_sync_mut.debug.remote.exec.lane_descriptor.{
    LaneDescriptor, LaneStatus, ProofClass, AdapterKind, ResultChannelKind
}
use std.nogc_sync_mut.debug.remote.exec.capability_report.{
    CapabilityReport, CapabilityStatus, probe_command, probe_external_formal,
    probe_openocd_capability, probe_trace32_capability
}
use std.nogc_sync_mut.debug.remote.exec.result_channel.{
    ResultPacket, ResultVerifier
}
use std.nogc_sync_mut.debug.remote.exec.lane_registry.{
    LaneRegistry, probe_for_lane
}
use std.nogc_sync_mut.debug.remote.exec.lane_status.{
    LaneStatusReporter
}


# ============================================================================
# LaneDescriptor
# ============================================================================

describe "LaneDescriptor":
    it "creates a descriptor with all fields":
        val lane = LaneDescriptor(
            lane_id: "qemu_rv32",
            target_arch: "riscv32",
            adapter_kind: AdapterKind.qemu_gdb,
            proof_class: ProofClass.compiled,
            primary_result_channel: ResultChannelKind.semihost_text,
            fallback_result_channel: Some(ResultChannelKind.exit_code),
            authoritative_spec_path: "test/some_spec.spl",
            status: LaneStatus.stable
        )
        expect lane.lane_id == "qemu_rv32"
        expect lane.target_arch == "riscv32"
        expect lane.is_authoritative() == true

    it "formats to_text correctly":
        val lane = LaneDescriptor(
            lane_id: "qemu_rv32_semihost",
            target_arch: "riscv32",
            adapter_kind: AdapterKind.qemu_gdb,
            proof_class: ProofClass.compiled,
            primary_result_channel: ResultChannelKind.semihost_text,
            fallback_result_channel: nil,
            authoritative_spec_path: "",
            status: LaneStatus.stable
        )
        val text_repr = lane.to_text()
        expect (text_repr).contains("qemu_rv32_semihost")
        expect (text_repr).contains("riscv32")

    it "classifies stable lanes as authoritative":
        val lane = LaneDescriptor(
            lane_id: "stable_lane",
            target_arch: "riscv32",
            adapter_kind: AdapterKind.qemu_gdb,
            proof_class: ProofClass.compiled,
            primary_result_channel: ResultChannelKind.semihost_text,
            fallback_result_channel: nil,
            authoritative_spec_path: "",
            status: LaneStatus.stable
        )
        expect lane.is_authoritative() == true

    it "classifies in_progress lanes as non-authoritative":
        val lane = LaneDescriptor(
            lane_id: "wip_lane",
            target_arch: "arm32",
            adapter_kind: AdapterKind.openocd_gdb,
            proof_class: ProofClass.structural,
            primary_result_channel: ResultChannelKind.register_readback,
            fallback_result_channel: nil,
            authoritative_spec_path: "",
            status: LaneStatus.in_progress
        )
        expect lane.is_authoritative() == false

    it "treats host-aware lanes as authoritative when the lane contract is satisfied":
        val lane = LaneDescriptor(
            lane_id: "host_lane",
            target_arch: "arm32",
            adapter_kind: AdapterKind.trace32,
            proof_class: ProofClass.compiled,
            primary_result_channel: ResultChannelKind.debugger_console,
            fallback_result_channel: Some(ResultChannelKind.register_readback),
            authoritative_spec_path: "test/system/t32_terminal_power_remote_spec.spl",
            status: LaneStatus.host_aware
        )
        expect lane.is_authoritative() == true


# ============================================================================
# CapabilityReport
# ============================================================================

describe "CapabilityReport":
    it "creates ready reports":
        val report = CapabilityReport.ready("test_lane", "qemu-system-riscv32")
        expect report.is_runnable() == true
        expect report.is_acceptable() == true

    it "creates skip_tool reports":
        val report = CapabilityReport.skip_tool("test_lane", "missing_tool")
        expect report.is_runnable() == false
        expect report.is_acceptable() == true

    it "creates failed reports":
        val report = CapabilityReport.failed("test_lane", "critical error")
        expect report.is_runnable() == false
        expect report.is_acceptable() == false

    it "formats report text":
        val report = CapabilityReport.ready("my_lane", "tool_name")
        val text_repr = report.to_text()
        expect (text_repr).contains("my_lane")
        expect (text_repr).contains("ready")


# ============================================================================
# ResultPacket
# ============================================================================

describe "ResultPacket":
    it "creates semihost packets":
        val packet = ResultPacket.from_semihost("test_lane", "PASS: all tests passed", 100)
        expect packet.is_pass() == true

    it "creates register packets":
        val pass_packet = ResultPacket.from_register("test_lane", 0, 50)
        expect pass_packet.is_pass() == true
        val fail_packet = ResultPacket.from_register("test_lane", 1, 50)
        expect fail_packet.is_pass() == false

    it "creates exit code packets":
        val packet = ResultPacket.from_exit_code("test_lane", 0, "", 75)
        expect packet.is_pass() == true

    it "creates skipped packets":
        val packet = ResultPacket.skipped("test_lane", "exit_code", "missing toolchain", 5)
        expect packet.is_skip() == true
        expect packet.is_pass() == false
        expect (packet.to_text()).contains("SKIP")


# ============================================================================
# ResultVerifier
# ============================================================================

describe "ResultVerifier":
    it "verifies default pass":
        val verifier = ResultVerifier.default_pass()
        val packet = ResultPacket.from_exit_code("test_lane", 0, "", 10)
        val result = verifier.verify(packet)
        expect result.is_ok() == true

    it "rejects failed packets":
        val verifier = ResultVerifier.default_pass()
        val packet = ResultPacket.from_exit_code("test_lane", 1, "", 10)
        val result = verifier.verify(packet)
        expect result.is_err() == true

    it "checks output patterns":
        val verifier = ResultVerifier.with_output(["PASS"])
        val packet = ResultPacket.from_semihost("test_lane", "PASS: all tests passed", 10)
        val result = verifier.verify(packet)
        expect result.is_ok() == true

    it "accepts skipped packets when configured":
        val verifier = ResultVerifier.allow_skip()
        val packet = ResultPacket.skipped("test_lane", "exit_code", "missing toolchain", 5)
        val result = verifier.verify(packet)
        expect result.is_ok() == true


# ============================================================================
# LaneRegistry
# ============================================================================

describe "LaneRegistry":
    """The default registry is the source of truth for public lane classification."""
    it "contains exactly 12 lanes":
        val registry = LaneRegistry.default()
        expect registry.all().len() == 12

    it "has 3 stable lanes":
        val registry = LaneRegistry.default()
        expect registry.stable_lanes().len() == 3

    it "has 5 host-aware lanes":
        val registry = LaneRegistry.default()
        expect registry.host_aware_lanes().len() == 5

    it "has 3 transport-only lanes":
        val registry = LaneRegistry.default()
        expect registry.transport_only_lanes().len() == 3

    it "has no in-progress lanes":
        val registry = LaneRegistry.default()
        expect registry.in_progress_lanes().len() == 0

    it "has 1 publicly excluded lane":
        val registry = LaneRegistry.default()
        expect registry.excluded_public_lanes().len() == 1

    it "has 8 authoritative lanes":
        val registry = LaneRegistry.default()
        expect registry.authoritative_lanes().len() == 8

    it "assigns concrete result channels to every authoritative lane":
        val registry = LaneRegistry.default()
        val lanes = registry.authoritative_lanes()
        for lane in lanes:
            expect lane.authoritative_spec_path.len() > 0

        val qemu_rv32 = registry.find("qemu_rv32_semihost")
        match qemu_rv32:
            Some(l):
                expect l.primary_result_channel == ResultChannelKind.semihost_text
                expect l.fallback_result_channel == Some(ResultChannelKind.exit_code)
            nil: expect(false).to_equal(true)

        val direct_boot = registry.find("x86_64_direct_boot")
        match direct_boot:
            Some(l):
                expect l.primary_result_channel == ResultChannelKind.exit_code
                expect l.fallback_result_channel == nil
            nil: expect(false).to_equal(true)

        val openocd = registry.find("stm32h7_openocd")
        match openocd:
            Some(l):
                expect l.primary_result_channel == ResultChannelKind.register_readback
                expect l.fallback_result_channel == Some(ResultChannelKind.ram_sentinel)
            nil: expect(false).to_equal(true)

        val trace32 = registry.find("stm32h7_trace32")
        match trace32:
            Some(l):
                expect l.primary_result_channel == ResultChannelKind.debugger_console
                expect l.fallback_result_channel == Some(ResultChannelKind.register_readback)
            nil: expect(false).to_equal(true)

        val mailbox = registry.find("ghdl_rv32_mailbox")
        match mailbox:
            Some(l):
                expect l.primary_result_channel == ResultChannelKind.ram_sentinel
                expect l.fallback_result_channel == Some(ResultChannelKind.register_readback)
            nil: expect(false).to_equal(true)

    it "finds lanes by id":
        val registry = LaneRegistry.default()
        val lane = registry.find("qemu_rv32_semihost")
        match lane:
            Some(l): expect(l.lane_id).to_equal("qemu_rv32_semihost")
            nil: expect(false).to_equal(true)

    it "uses the x86_64 boot spec for the direct boot lane":
        val registry = LaneRegistry.default()
        val lane = registry.find("x86_64_direct_boot")
        match lane:
            Some(l):
                expect l.status == LaneStatus.stable
                expect l.authoritative_spec_path == "test/qemu/os/boot/x86_64_boot_qemu_spec.spl"
                expect l.is_authoritative() == true
            nil: expect(false).to_equal(true)

    it "returns nil for unknown lanes":
        val registry = LaneRegistry.default()
        val lane = registry.find("nonexistent")
        expect lane == nil

    it "looks up ghdl_rv32_semihost as host_aware":
        val registry = LaneRegistry.default()
        val lane = registry.find("ghdl_rv32_semihost")
        match lane:
            Some(l):
                expect l.status == LaneStatus.host_aware
                expect l.is_authoritative() == true
            nil: expect(false).to_equal(true)

    it "looks up ghdl_rv32_mailbox as host_aware":
        val registry = LaneRegistry.default()
        val lane = registry.find("ghdl_rv32_mailbox")
        match lane:
            Some(l):
                expect l.status == LaneStatus.host_aware
                expect l.is_authoritative() == true
            nil: expect(false).to_equal(true)

    it "looks up riscv_external_formal as transport_only":
        val registry = LaneRegistry.default()
        val lane = registry.find("riscv_external_formal")
        match lane:
            Some(l):
                expect l.status == LaneStatus.transport_only
                expect l.adapter_kind == AdapterKind.external_formal
                expect l.is_authoritative() == false
            nil: expect(false).to_equal(true)

    it "returns nil for removed ghdl_rv32_sim":
        val registry = LaneRegistry.default()
        val lane = registry.find("ghdl_rv32_sim")
        expect lane == nil

    it "looks up fpga_jtag_zedboard as publicly excluded":
        val registry = LaneRegistry.default()
        val lane = registry.find("fpga_jtag_zedboard")
        match lane:
            Some(l):
                expect l.status == LaneStatus.excluded_public
                expect l.is_authoritative() == false
            nil: expect(false).to_equal(true)


# ============================================================================
# LaneStatusReporter
# ============================================================================

describe "LaneStatusReporter":
    it "generates text report":
        val reporter = LaneStatusReporter.new()
        val report = reporter.report_text()
        expect (report).contains("Stable Lanes")
        expect (report).contains("Host-Aware")
        expect (report).contains("Publicly Excluded Lanes")
        expect (report).contains("stable and host-aware lanes are authoritative")

    it "generates markdown report":
        val reporter = LaneStatusReporter.new()
        val report = reporter.generate_matrix_markdown()
        expect (report).contains("| Lane ID |")
        expect (report).contains("| Authoritative |")
        expect (report).contains("- **Authoritative**: 8 lanes (stable + host-aware)")
        expect (report).contains("- **Publicly excluded**: 1 lanes")

    it "generates SDN report":
        val reporter = LaneStatusReporter.new()
        val report = reporter.report_sdn()
        expect (report).contains("[lane_matrix]")
        expect (report).contains("authoritative =")


# ============================================================================
# Probe infrastructure
# ============================================================================

describe "Probe infrastructure":
    it "detects available commands":
        val found = probe_command("ls")
        expect found == true

    it "detects missing commands":
        val found = probe_command("nonexistent_tool_xyz")
        expect found == false

    it "probes external formal capability cleanly":
        val report = probe_external_formal()
        expect report.lane_id == "riscv_external_formal"
        expect report.is_acceptable() == true
        expect report.detail.len() > 0

    it "treats missing OpenOCD and TRACE32 tools as acceptable host-aware skips":
        val registry = LaneRegistry.default()

        val openocd_lane = registry.find("stm32h7_openocd")
        match openocd_lane:
            Some(l):
                expect l.status == LaneStatus.host_aware
                val report = probe_openocd_capability(false)
                expect report.status == CapabilityStatus.skip_missing_tool
                expect report.tool_name == "openocd"
                expect report.is_runnable() == false
                expect report.is_acceptable() == true
            nil: expect(false).to_equal(true)

        val trace32_lane = registry.find("stm32h7_trace32")
        match trace32_lane:
            Some(l):
                expect l.status == LaneStatus.host_aware
                val report = probe_trace32_capability(false)
                expect report.status == CapabilityStatus.skip_missing_tool
                expect report.tool_name == "t32rem"
                expect report.is_runnable() == false
                expect report.is_acceptable() == true
            nil: expect(false).to_equal(true)

    slow_it "probes all lanes without crashing":
        val registry = LaneRegistry.default()
        val lanes = registry.all()
        var i = 0
        while i < lanes.len():
            val lane = lanes[i]
            val report = probe_for_lane(lane)
            expect report.is_acceptable() == true
            i = i + 1