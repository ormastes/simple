# @tag:system

use std.spec.*

use os.qemu_runner.{OsTarget, build_os}
use os.kernel.arch.arch_context.{Architecture}
use test.qemu.os.common.qemu_os_harness.{file_exists}

fn _runtime_target() -> OsTarget:
    OsTarget(
        arch: Architecture.X86_64,
        entry: "examples/simple_os/arch/x86_64/browser_runtime_probe_entry.spl",
        linker_script: "examples/simple_os/arch/x86_64/linker.ld",
        target_triple: "x86_64-unknown-none",
        output: "build/os/simpleos_browser_runtime_probe_x86_64.elf",
        qemu_system: "qemu-system-x86_64",
        qemu_machine: "q35",
        qemu_cpu: "qemu64",
        qemu_memory: "2G",
        qemu_bios: "",
        qemu_extra: ["-device", "isa-debug-exit,iobase=0xf4,iosize=0x04"],
        gui_mode: false
    )

describe "Browser runtime in QEMU Simple OS guest":

    it "builds the browser runtime probe kernel":
        val target = _runtime_target()
        val ok = build_os(target)
        expect(ok).to_equal(true)
        expect(file_exists(target.output)).to_equal(true)

    slow_it "boots guest and settles the runtime BrowserSession pump":
        print "[browser_runtime_in_qemu_spec] live guest runtime run is skipped: scripted BrowserSession documents still exhaust the x86_64 bare-metal bump heap during JS runtime bring-up"
        val target = _runtime_target()
        expect(target.entry).to_equal("examples/simple_os/arch/x86_64/browser_runtime_probe_entry.spl")
        expect(target.qemu_system).to_equal("qemu-system-x86_64")
        if not file_exists(target.output):
            expect(build_os(target)).to_equal(true)
        expect(file_exists(target.output)).to_equal(true)
