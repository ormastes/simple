@allow(primitive_api)
# Crypto Reference Harness — cross-vendor byte-level dispatch.
#
# Dispatches a uniform API (ref_sha256_via, ref_hmac_sha256_via, ref_x25519_via, ...)
# to multiple reference crypto implementations on the host so pure-Simple primitives
# in src/os/crypto/* and src/lib/common/crypto/* can be byte-compared against them.
#
# Vendors are installed by scripts/install_ref_crypto.shs and recorded in
# tools/ref_crypto/manifest.json. This module invokes their CLIs via rt_process_run
# and decodes hex-lowercase stdout back into [u8].
#
# Currently wired: OPENSSL, NODE.
# Declared but dispatch-pending (returns Skipped): GO, RING, BORINGSSL, MBEDTLS,
# WOLFSSL, LIBRESSL — installer/CLI for each is in tools/ref_crypto/<vendor>/.
#
# Negative path: every call returns Result<[u8], RefErr>. RefErr.Skipped is
# NOT a failure — it lets the caller gracefully exclude vendors that lack the
# primitive (e.g., Node has no raw Poly1305 export; Ring lacks raw X25519).

use test.system.os_crypto_ref_helpers.{
    hex_to_bytes, bytes_to_hex,
    openssl_sha256, openssl_sha512, openssl_hmac_sha256
}

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

# ============================================================================
# Types
# ============================================================================

enum Vendor:
    """Reference crypto vendors recognized by the harness."""
    OPENSSL
    BORINGSSL
    MBEDTLS
    WOLFSSL
    LIBRESSL
    GO
    NODE
    RING

enum RefErr:
    """Why a reference call did not return bytes.
    Skipped is not a test failure — it means the vendor declared it does not
    implement the requested primitive (per manifest.supported_primitives)."""
    Skipped(reason: text)
    NotInstalled(vendor_name: text)
    Timeout(seconds: i64)
    ProcessErr(code: i64, stderr: text)
    ParseErr(message: text)

# ============================================================================
# Input Matrix — 8 byte-shapes every primitive must be tested against.
# ============================================================================

fn crypto_input_matrix(block_size: u64) -> [[u8]]:
    """Return the 8-input byte-shape matrix for a primitive with the given
    block size. Order:
      0: empty
      1: single byte 0x00
      2: short ASCII b"abc"
      3: binary 0x00, 0xff, 0x55, 0xaa
      4: exact block size (filled with 0x42)
      5: block size + 1
      6: block size - 1
      7: 3 * block size (rolling 0..255)
    """
    var matrix: [[u8]] = []
    matrix.push([])
    matrix.push([0u8])
    matrix.push([0x61u8, 0x62u8, 0x63u8])
    matrix.push([0x00u8, 0xffu8, 0x55u8, 0xaau8])
    matrix.push(_filled(n: block_size, b: 0x42u8))
    matrix.push(_filled(n: block_size + 1, b: 0x42u8))
    if block_size > 0:
        matrix.push(_filled(n: block_size - 1, b: 0x42u8))
    else:
        matrix.push([])
    matrix.push(_rolling(n: block_size * 3))
    matrix

fn _filled(n: u64, b: u8) -> [u8]:
    var out: [u8] = []
    var i: u64 = 0
    while i < n:
        out.push(b)
        i = i + 1
    out

fn _rolling(n: u64) -> [u8]:
    var out: [u8] = []
    var i: u64 = 0
    while i < n:
        out.push((i % 256).to_u8())
        i = i + 1
    out

# ============================================================================
# Vendor tag
# ============================================================================

fn vendor_name(v: Vendor) -> text:
    match v:
        Vendor.OPENSSL:   "openssl"
        Vendor.BORINGSSL: "boringssl"
        Vendor.MBEDTLS:   "mbedtls"
        Vendor.WOLFSSL:   "wolfssl"
        Vendor.LIBRESSL:  "libressl"
        Vendor.GO:        "go"
        Vendor.NODE:      "node"
        Vendor.RING:      "ring"

# ============================================================================
# Dispatch — per primitive
# ============================================================================

fn ref_sha256_via(v: Vendor, input: [u8]) -> Result<[u8], RefErr>:
    """Compute SHA-256 via the named vendor.
    Returns Err(Skipped) if dispatch for that vendor is not yet wired."""
    match v:
        Vendor.OPENSSL: Ok(openssl_sha256(input))
        Vendor.NODE:    _hexcli_two_arg(vendor_tag: "node",   primitive: "sha256", a: bytes_to_hex(input), b: "")
        Vendor.GO:      Err(RefErr.Skipped("go dispatch pending (build tools/ref_crypto/go)"))
        Vendor.RING:    Err(RefErr.Skipped("ring dispatch pending (cargo-build tools/ref_crypto/ring)"))
        _:              Err(RefErr.Skipped(vendor_name(v) + " dispatch pending"))

fn ref_sha512_via(v: Vendor, input: [u8]) -> Result<[u8], RefErr>:
    match v:
        Vendor.OPENSSL: Ok(openssl_sha512(input))
        Vendor.NODE:    _hexcli_two_arg(vendor_tag: "node",   primitive: "sha512", a: bytes_to_hex(input), b: "")
        _:              Err(RefErr.Skipped(vendor_name(v) + " sha512 dispatch pending"))

fn ref_hmac_sha256_via(v: Vendor, key: [u8], msg: [u8]) -> Result<[u8], RefErr>:
    match v:
        Vendor.OPENSSL: Ok(openssl_hmac_sha256(key, msg))
        Vendor.NODE:    _hexcli_two_arg(vendor_tag: "node",   primitive: "hmac_sha256", a: bytes_to_hex(key), b: bytes_to_hex(msg))
        _:              Err(RefErr.Skipped(vendor_name(v) + " hmac_sha256 dispatch pending"))

fn ref_x25519_via(v: Vendor, scalar: [u8], peer: [u8]) -> Result<[u8], RefErr>:
    match v:
        Vendor.OPENSSL: Err(RefErr.Skipped("openssl x25519 dispatch pending (pkeyutl raw-key PEM)"))
        Vendor.NODE:    _hexcli_two_arg(vendor_tag: "node",   primitive: "x25519", a: bytes_to_hex(scalar), b: bytes_to_hex(peer))
        Vendor.RING:    Err(RefErr.Skipped("ring x25519 raw-scalar not in public API"))
        _:              Err(RefErr.Skipped(vendor_name(v) + " x25519 dispatch pending"))

fn ref_ed25519_sign_via(v: Vendor, sk: [u8], msg: [u8]) -> Result<[u8], RefErr>:
    match v:
        Vendor.NODE:   _hexcli_two_arg(vendor_tag: "node",   primitive: "ed25519_sign", a: bytes_to_hex(sk), b: bytes_to_hex(msg))
        _:             Err(RefErr.Skipped(vendor_name(v) + " ed25519_sign dispatch pending"))

fn ref_ed25519_verify_via(v: Vendor, pk: [u8], msg: [u8], sig: [u8]) -> Result<bool, RefErr>:
    """Verify an Ed25519 signature. Returns Ok(true) if valid, Ok(false) if not."""
    match v:
        Vendor.NODE:   _hexcli_three_arg_bool(vendor_tag: "node",   primitive: "ed25519_verify",
                                              a: bytes_to_hex(pk), b: bytes_to_hex(msg), c: bytes_to_hex(sig))
        _:             Err(RefErr.Skipped(vendor_name(v) + " ed25519_verify dispatch pending"))

# ============================================================================
# AEAD dispatch — AES-GCM (128/256) + ChaCha20-Poly1305 (encrypt/decrypt)
# ============================================================================

fn ref_aes_128_gcm_encrypt_via(v: Vendor, key: [u8], nonce: [u8], aad: [u8], plain: [u8]) -> Result<[u8], RefErr>:
    """Encrypt with AES-128-GCM. Output = ciphertext || 16-byte tag."""
    match v:
        Vendor.NODE:   _hexcli_four_arg(vendor_tag: "node",   primitive: "aes_128_gcm_encrypt",
                                        a: bytes_to_hex(key), b: bytes_to_hex(nonce),
                                        c: bytes_to_hex(aad), d: bytes_to_hex(plain))
        _:             Err(RefErr.Skipped(vendor_name(v) + " aes_128_gcm_encrypt dispatch pending"))

fn ref_aes_128_gcm_decrypt_via(v: Vendor, key: [u8], nonce: [u8], aad: [u8], cipher_tag: [u8]) -> Result<[u8], RefErr>:
    """Decrypt AES-128-GCM (input = ciphertext||tag). Returns ProcessErr on auth mismatch."""
    match v:
        Vendor.NODE:   _hexcli_four_arg(vendor_tag: "node",   primitive: "aes_128_gcm_decrypt",
                                        a: bytes_to_hex(key), b: bytes_to_hex(nonce),
                                        c: bytes_to_hex(aad), d: bytes_to_hex(cipher_tag))
        _:             Err(RefErr.Skipped(vendor_name(v) + " aes_128_gcm_decrypt dispatch pending"))

fn ref_chacha_poly_encrypt_via(v: Vendor, key: [u8], nonce: [u8], aad: [u8], plain: [u8]) -> Result<[u8], RefErr>:
    """Encrypt with ChaCha20-Poly1305. Output = ciphertext || 16-byte tag."""
    match v:
        Vendor.NODE:   _hexcli_four_arg(vendor_tag: "node",   primitive: "chacha20_poly1305_encrypt",
                                        a: bytes_to_hex(key), b: bytes_to_hex(nonce),
                                        c: bytes_to_hex(aad), d: bytes_to_hex(plain))
        _:             Err(RefErr.Skipped(vendor_name(v) + " chacha_poly_encrypt dispatch pending"))

fn ref_chacha_poly_decrypt_via(v: Vendor, key: [u8], nonce: [u8], aad: [u8], cipher_tag: [u8]) -> Result<[u8], RefErr>:
    """Decrypt ChaCha20-Poly1305 (input = ciphertext||tag). Returns ProcessErr on auth mismatch."""
    match v:
        Vendor.NODE:   _hexcli_four_arg(vendor_tag: "node",   primitive: "chacha20_poly1305_decrypt",
                                        a: bytes_to_hex(key), b: bytes_to_hex(nonce),
                                        c: bytes_to_hex(aad), d: bytes_to_hex(cipher_tag))
        _:             Err(RefErr.Skipped(vendor_name(v) + " chacha_poly_decrypt dispatch pending"))

# ============================================================================
# Hex-in / hex-out CLI dispatch (node; go/ring ready)
# ============================================================================

fn _hexcli_two_arg(vendor_tag: text, primitive: text, a: text, b: text) -> Result<[u8], RefErr>:
    """Invoke a vendor CLI with argv = [<primitive>, a, b] (b omitted if empty)
    and parse a single-line hex stdout."""
    val plan = _cli_plan(vendor_tag: vendor_tag, primitive: primitive, a: a, b: b)
    val r = rt_process_run(plan.0, plan.1)
    if r.2 != 0:
        return Err(RefErr.ProcessErr(r.2, r.1))
    _parse_hex_line(r.0)

fn _hexcli_three_arg_bool(vendor_tag: text, primitive: text, a: text, b: text, c: text) -> Result<bool, RefErr>:
    """Invoke a vendor CLI that returns 1/0 (e.g. ed25519_verify) and parse the result."""
    val plan = _cli_plan_three(vendor_tag: vendor_tag, primitive: primitive, a: a, b: b, c: c)
    val r = rt_process_run(plan.0, plan.1)
    if r.2 != 0:
        return Err(RefErr.ProcessErr(r.2, r.1))
    var line: text = r.0
    if line.ends_with("\n"):
        line = line[0..line.len() - 1]
    if line == "1":
        return Ok(true)
    if line == "0":
        return Ok(false)
    Err(RefErr.ParseErr("expected 1 or 0, got: " + line))

fn _hexcli_four_arg(vendor_tag: text, primitive: text, a: text, b: text, c: text, d: text) -> Result<[u8], RefErr>:
    """Invoke a vendor CLI with argv = [<primitive>, a, b, c, d] and parse a
    single-line hex stdout. Empty args (e.g. empty AAD) are still passed so
    positional indices stay aligned."""
    val plan = _cli_plan_four(vendor_tag: vendor_tag, primitive: primitive, a: a, b: b, c: c, d: d)
    val r = rt_process_run(plan.0, plan.1)
    if r.2 != 0:
        return Err(RefErr.ProcessErr(r.2, r.1))
    _parse_hex_line(r.0)

fn _cli_plan_three(vendor_tag: text, primitive: text, a: text, b: text, c: text) -> (text, [text]):
    if vendor_tag == "node":
        return ("node", ["tools/ref_crypto/node/cli.mjs", primitive, a, b, c])
    ("false", ["unknown-vendor:" + vendor_tag])

fn _cli_plan_four(vendor_tag: text, primitive: text, a: text, b: text, c: text, d: text) -> (text, [text]):
    if vendor_tag == "node":
        return ("node", ["tools/ref_crypto/node/cli.mjs", primitive, a, b, c, d])
    ("false", ["unknown-vendor:" + vendor_tag])

fn _cli_plan(vendor_tag: text, primitive: text, a: text, b: text) -> (text, [text]):
    """Return (program, argv) for the given vendor and 2-argument primitive.
    b is always passed (as empty string "" if blank) so positional indices
    stay aligned for CLIs that index by position."""
    if vendor_tag == "node":
        return ("node", ["tools/ref_crypto/node/cli.mjs", primitive, a, b])
    if vendor_tag == "go":
        return ("go", ["run", "tools/ref_crypto/go/cmd/hash.go", primitive, a, b])
    if vendor_tag == "ring":
        return ("tools/ref_crypto/ring/target/release/ref_ring", [primitive, a, b])
    ("false", ["unknown-vendor:" + vendor_tag])

# ============================================================================
# Output parsing
# ============================================================================

fn _parse_hex_line(stdout: text) -> Result<[u8], RefErr>:
    """Strip a trailing newline (and optional carriage return) from stdout and
    hex-decode the rest. Returns ParseErr if the payload is not valid hex."""
    var line: text = stdout
    if line.ends_with("\n"):
        line = line[0..line.len() - 1]
    if line.ends_with("\r"):
        line = line[0..line.len() - 1]
    val bytes = hex_to_bytes(line)
    if bytes.len() == 0 and line.len() > 0:
        return Err(RefErr.ParseErr("non-hex stdout: " + line))
    Ok(bytes)
