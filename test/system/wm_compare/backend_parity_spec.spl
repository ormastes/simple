# @tag: sys, wm_compare, parity, framebuffer, software
# @cover src/app/wm_compare/backend_parity.spl 0%
# @cover src/os/drivers/framebuffer/fb_driver.spl 0%
#
# wm_compare framebuffer/software backend parity
#
# Locks the contract that the same drawing scene rendered through framebuffer baseline
# (`FramebufferDriver.from_buffer`, the fb_backend code path) and software reference
# (the pure-Simple stand-in for the hosted_backend FFI math) produces
# byte-identical ARGB8888 buffers on the cells both code paths agree on.
#
# Scenes are deliberately tiny (32x16) so a failing run can dump the
# whole buffer to a PPM without bloating the spec output.
#
use std.spec.{describe, context, it, expect}
use app.wm_compare.backend_parity.{
    run_framebuffer_software_parity, render_framebuffer_baseline, render_software_reference, diff_buffers,
    scene_solid_fill, scene_fill_rect_row_edge, scene_text_with_bg, scene_glass_blend,
}

describe "wm_compare framebuffer/software parity":

    context "solid fill — clear() on both backends":

        it "produces zero per-channel delta":
            val r = run_framebuffer_software_parity(scene_solid_fill())
            expect(r.pass_exact).to_equal(true)

        it "produces zero perceptual diff":
            val r = run_framebuffer_software_parity(scene_solid_fill())
            expect(r.pass_perceptual).to_equal(true)

    context "fill_rect on the row edge — exercises [x,x+w) half-open contract":

        it "row 0 + row h-1 fill_rect matches framebuffer↔software":
            val r = run_framebuffer_software_parity(scene_fill_rect_row_edge())
            expect(r.pass_exact).to_equal(true)

        it "differs in zero pixels":
            val r = run_framebuffer_software_parity(scene_fill_rect_row_edge())
            expect(r.differing_pixels == 0u32).to_equal(true)

    context "text+bg — draw_text background cells match between backends":

        it "max channel delta on bg cells is 0":
            val r = run_framebuffer_software_parity(scene_text_with_bg())
            # software reference flat-block glyph stub matches framebuffer baseline bg writes; this
            # validates the bg-cell contract, NOT the glyph rasterizer.
            expect(r.pass_exact).to_equal(true)

    context "glass blend — degraded blend_rect math":

        it "exact-match blend output":
            val r = run_framebuffer_software_parity(scene_glass_blend())
            expect(r.pass_exact).to_equal(true)

        it "stays within ≤1% perceptual budget":
            val r = run_framebuffer_software_parity(scene_glass_blend())
            expect(r.pass_perceptual).to_equal(true)

    context "diff harness self-check":

        it "reports identical buffers as exact":
            val baseline = render_framebuffer_baseline(scene_solid_fill())
            val reference = render_software_reference(scene_solid_fill())
            val r = diff_buffers("self_check", 32u32, 16u32, baseline, reference)
            expect(r.max_channel_delta == 0u32).to_equal(true)
