# @tag: sys, wm_compare, parity, framebuffer, electron
# @cover src/app/wm_compare/backend_parity.spl 0%
# @cover src/os/compositor/electron_capture.spl 0%
#
# wm_compare framebuffer baseline/electron reference parity
#
# Locks the contract that the same drawing scene rendered through framebuffer baseline
# (`FramebufferDriver.from_buffer`, the fb_backend code path) and electron reference (the
# Electron dev-preview reference pipeline — `electron_capture` forwarding
# to `BrowserCompositorBackend` via `render_scene_to_backend`) stays
# exactly against the framebuffer baseline. Perceptual metrics are diagnostic
# only and are not an acceptance gate.
#
# Scenes are the exact `ParityScene` set framebuffer/software gate uses — scene_solid_fill,
# scene_fill_rect_row_edge, scene_text_with_bg, scene_glass_blend — so a
# failing spec is guaranteed to be a real framebuffer↔electron divergence, not a new
# scene pulling electron reference off its baseline.
#
# electron reference is dev-preview-only per
# `doc/01_research/domain/v4_electron_packaging_2026-04-14.md`: no live
# Electron runtime is spun up inside the interpreter. The electron reference render path
# drives the same `BrowserCompositorBackend` trait surface that
# `electron_capture.capture_electron_scene` forwards to in production, so
# the ParityOp sequence reaches the exact compositor electron reference would use.
#
use std.spec.{describe, context, it, expect}
use app.wm_compare.backend_parity.{
    run_electron_reference_parity, render_framebuffer_baseline, render_electron_reference, diff_buffers,
    scene_solid_fill, scene_fill_rect_row_edge, scene_text_with_bg, scene_glass_blend,
}

describe "wm_compare framebuffer baseline/electron reference parity (electron-reference gate — Electron dev-preview reference)":

    context "solid fill — electron reference clear() matches fb_driver":

        it "matches framebuffer exactly":
            val r = run_electron_reference_parity(scene_solid_fill())
            expect(r.pass_exact).to_equal(true)

    context "fill_rect row edge — exercises [x,x+w) half-open contract on electron reference":

        it "matches framebuffer exactly":
            val r = run_electron_reference_parity(scene_fill_rect_row_edge())
            expect(r.pass_exact).to_equal(true)

    context "text + bg — electron reference draw_char_8x16 bg cells":

        it "matches framebuffer exactly":
            val r = run_electron_reference_parity(scene_text_with_bg())
            expect(r.pass_exact).to_equal(true)

    context "glass blend — CompositorGlassCapable.blend_rect on electron reference":

        it "matches framebuffer exactly":
            val r = run_electron_reference_parity(scene_glass_blend())
            expect(r.pass_exact).to_equal(true)

        it "marks perceptual as diagnostic only":
            val r = run_electron_reference_parity(scene_glass_blend())
            expect(r.perceptual_diagnostic_only).to_equal(true)
            expect(r.exact_required).to_equal(true)
            expect(r.tolerance_acceptance_allowed).to_equal(false)

    context "electron reference render harness self-check":

        it "returns a buffer of the expected length":
            val electron_pixels = render_electron_reference(scene_solid_fill())
            expect(electron_pixels.len() == 32 * 16).to_equal(true)

        it "diffs identical electron reference buffers as exact":
            val a = render_electron_reference(scene_solid_fill())
            val b = render_electron_reference(scene_solid_fill())
            val r = diff_buffers("electron_reference_self_check", 32u32, 16u32, a, b)
            expect(r.pass_exact).to_equal(true)
