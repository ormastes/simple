use std.io_runtime
use std.common.engine.ids.{NodeId, RawHandle}
use std.common.engine.math2d.{Vec2}
use std.nogc_sync_mut.engine.physics2.config.{default_physics_config_2d}
use std.nogc_sync_mut.engine.physics2.backend.{PhysicsBackend}
use std.nogc_sync_mut.engine.physics2.world2d.{PhysicsWorld2D}

fn make_node(idx: i64) -> NodeId:
    NodeId(raw: RawHandle.new(idx, 1))

fn main():
    var config = default_physics_config_2d()
    config.backend = PhysicsBackend.CpuScalar
    config.gravity = Vec2(x: 0.0, y: 0.0)
    var world = PhysicsWorld2D.create(config)
    world.add_dynamic_body(make_node(0), 0.0, 0.0, 1.0)
    world.add_circle_collider(make_node(0), 0.5)
    world.add_dynamic_body(make_node(1), 0.8, 0.0, 1.0)
    world.add_circle_collider(make_node(1), 0.5)
    world.apply_impulse(make_node(0), 5.0, 0.0)
    world.step(0.016)
    print("constraints count=" + world.constraints.count.to_string())
    print("constraint body_a[0]=" + world.constraints.body_a[0].to_string())
    print("constraint body_b[0]=" + world.constraints.body_b[0].to_string())
    print("constraint normal_x[0]=" + world.constraints.normal_x[0].to_string())
    print("constraint pen[0]=" + world.constraints.penetration[0].to_string())
    print("inv_mass[0]=" + world.bodies.inv_mass[0].to_string())
    print("inv_mass[1]=" + world.bodies.inv_mass[1].to_string())
    print("vel_x[0]=" + world.bodies.vel_x[0].to_string())
    print("vel_x[1]=" + world.bodies.vel_x[1].to_string())
