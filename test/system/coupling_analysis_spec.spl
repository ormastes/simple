# @req REQ-coupling-analysis
# @feature coupling_analysis
tag: slow, system

use std.spec.{describe, it, expect}

describe "Coupling Analysis":

    # ========================================================================
    # AC-01: Basic coupling metrics
    # ========================================================================

    describe "CBO / Fan-in / Fan-out / Instability":

        # @scenario SC-001
        it "computes fan-out as count of distinct module dependencies":
            # Given a module that imports from 3 other modules
            # When coupling metrics are computed
            # Then fan_out = 3 and CBO = 3
            val graph = test_graph_3_deps()
            val metrics = compute_all_metrics(graph)
            val m = find_metric(metrics, "module_a")
            expect(m.fan_out).to_equal(3)
            expect(m.cbo).to_equal(3)

        # @scenario SC-002
        it "computes fan-in as count of modules depending on this module":
            val graph = test_graph_3_deps()
            val metrics = compute_all_metrics(graph)
            val m = find_metric(metrics, "module_d")
            expect(m.fan_in).to_be_greater_than(0)

        # @scenario SC-003
        it "computes instability as fan_out / (fan_in + fan_out)":
            val graph = test_graph_instability()
            val metrics = compute_all_metrics(graph)
            val m = find_metric(metrics, "module_a")
            # module_a: fan_out=2, fan_in=0 → I = 2/2 = 1.0
            expect(m.instability).to_equal(1.0)

        # @scenario SC-004
        it "handles zero fan-in and fan-out gracefully":
            val graph = test_graph_isolated()
            val metrics = compute_all_metrics(graph)
            val m = find_metric(metrics, "isolated")
            expect(m.instability).to_equal(0.0)

    # ========================================================================
    # AC-02: SCC cycle detection
    # ========================================================================

    describe "SCC Cycle Detection":

        # @scenario SC-005
        it "detects circular dependencies using Tarjan/Kosaraju":
            val graph = test_graph_with_cycle()
            val cycles = find_cycles(graph)
            expect(cycles.len()).to_be_greater_than(0)

        # @scenario SC-006
        it "does not report single-node SCCs":
            val graph = test_graph_no_cycle()
            val cycles = find_cycles(graph)
            expect(cycles.len()).to_equal(0)

        # @scenario SC-007
        it "finds all SCCs in a complex graph":
            val graph = test_graph_multi_cycle()
            val cycles = find_cycles(graph)
            expect(cycles.len()).to_equal(2)

    # ========================================================================
    # AC-03: Layer violation detection
    # ========================================================================

    describe "Layer Violations":

        # @scenario SC-008
        it "flags backward dependencies between numbered compiler layers":
            val graph = test_graph_layer_violation()
            val violations = find_layer_violations(graph)
            expect(violations.len()).to_be_greater_than(0)

        # @scenario SC-009
        it "allows forward dependencies (lower layer depending on nothing)":
            val graph = test_graph_layer_ok()
            val violations = find_layer_violations(graph)
            expect(violations.len()).to_equal(0)

        # @scenario SC-010
        it "extracts layer numbers from compiler paths":
            val layer = extract_layer_number("compiler/30.types/inference")
            expect(layer).to_equal(30)

    # ========================================================================
    # AC-04: DSM matrix
    # ========================================================================

    describe "DSM Matrix":

        # @scenario SC-011
        it "builds NxN matrix with dependency counts":
            val graph = test_graph_3_deps()
            val dsm = build_dsm(graph)
            expect(dsm.modules.len()).to_be_greater_than(0)
            expect(dsm.matrix.len()).to_equal(dsm.modules.len())

    # ========================================================================
    # AC-07: Output formats
    # ========================================================================

    describe "Output Formats":

        # @scenario SC-012
        it "produces text format report":
            val report = test_report()
            val text_out = format_text(report)
            expect(text_out).to_contain("Coupling Report")

        # @scenario SC-013
        it "produces JSON format report":
            val report = test_report()
            val json_out = format_json(report)
            expect(json_out).to_contain("\"modules\"")

        # @scenario SC-014
        it "produces Markdown format report":
            val report = test_report()
            val md_out = format_markdown(report)
            expect(md_out).to_contain("# Coupling Report")

    # ========================================================================
    # AC-08: Lint rules W0501-W0504
    # ========================================================================

    describe "Coupling Lint Rules":

        # @scenario SC-015
        it "W0501 flags high CBO":
            val warning = check_high_cbo("mod_x", 20, 15)
            expect(warning.?).to_equal(true)

        # @scenario SC-016
        it "W0502 flags circular dependency":
            val warning = check_circular_dependency(["mod_a", "mod_b"])
            expect(warning.?).to_equal(true)

        # @scenario SC-017
        it "W0503 flags layer violation":
            val warning = check_layer_violation("compiler/10.frontend/parser", "compiler/20.hir/types", 10, 20)
            expect(warning.?).to_equal(true)

        # @scenario SC-018
        it "W0504 flags instability inversion":
            val warning = check_instability_inversion("stable_mod", "unstable_mod", 0.2, 0.9)
            expect(warning.?).to_equal(true)

    # ========================================================================
    # AC-13: LCOM4
    # ========================================================================

    describe "LCOM4 Cohesion":

        # @scenario SC-019
        it "computes LCOM4 = 1 for cohesive class":
            val methods = [
                MethodFieldAccess(method_name: "get_x", fields_accessed: ["x"], methods_called: []),
                MethodFieldAccess(method_name: "get_y", fields_accessed: ["x", "y"], methods_called: [])
            ]
            val result = compute_lcom4("Point", methods)
            expect(result.lcom4).to_equal(1)

        # @scenario SC-020
        it "computes LCOM4 > 1 for uncohesive class":
            val methods = [
                MethodFieldAccess(method_name: "get_x", fields_accessed: ["x"], methods_called: []),
                MethodFieldAccess(method_name: "get_z", fields_accessed: ["z"], methods_called: [])
            ]
            val result = compute_lcom4("Mixed", methods)
            expect(result.lcom4).to_equal(2)

    # ========================================================================
    # AC-14-17: Public API Quality
    # ========================================================================

    describe "Public API Quality":

        # @scenario SC-021
        it "computes PSS as public methods + public fields":
            val pss = compute_pss(10, 5)
            expect(pss).to_equal(15)

        # @scenario SC-022
        it "computes EUR as externally used / total public":
            val usages = [
                MethodUsage(method_name: "foo", external_call_count: 5),
                MethodUsage(method_name: "bar", external_call_count: 0)
            ]
            val eur = compute_eur(usages, 2)
            expect(eur).to_equal(0.5)

        # @scenario SC-023
        it "computes normalized entropy for usage distribution":
            val usages = [
                MethodUsage(method_name: "a", external_call_count: 10),
                MethodUsage(method_name: "b", external_call_count: 10)
            ]
            val e = compute_entropy(usages)
            # Equal usage → max entropy → normalized = 1.0
            expect(e).to_equal(1.0)

    # ========================================================================
    # AC-20-21: ATSS (Argument Type Set Similarity)
    # ========================================================================

    describe "Argument Signature Similarity":

        # @scenario SC-024
        it "detects exact type-set duplicates (edit distance 0)":
            val dist = type_set_edit_distance(["i64", "text"], ["i64", "text"])
            expect(dist).to_equal(0)

        # @scenario SC-025
        it "detects near-duplicates with edit distance 1":
            val dist = type_set_edit_distance(["i64", "text"], ["i64"])
            expect(dist).to_equal(1)

        # @scenario SC-026
        it "computes correct edit distance for different type sets":
            val dist = type_set_edit_distance(["bool", "i64"], ["f64", "text"])
            expect(dist).to_equal(4)

    # ========================================================================
    # AC-22-23: Relaxed Token Duplication
    # ========================================================================

    describe "Relaxed Token Duplication":

        # @scenario SC-027
        it "matches token-kind-only sequences ignoring variable names":
            val hash_a = relaxed_rolling_hash(
                to_relaxed_tokens([
                    SimpleToken(kind: SimpleTokenKind.Identifier, value: "x", line: 1, column: 1),
                    SimpleToken(kind: SimpleTokenKind.Operator, value: "+", line: 1, column: 3),
                    SimpleToken(kind: SimpleTokenKind.Identifier, value: "y", line: 1, column: 5)
                ]), 0, 3)
            val hash_b = relaxed_rolling_hash(
                to_relaxed_tokens([
                    SimpleToken(kind: SimpleTokenKind.Identifier, value: "a", line: 1, column: 1),
                    SimpleToken(kind: SimpleTokenKind.Operator, value: "+", line: 1, column: 3),
                    SimpleToken(kind: SimpleTokenKind.Identifier, value: "b", line: 1, column: 5)
                ]), 0, 3)
            expect(hash_a).to_equal(hash_b)

    # ========================================================================
    # AC-18: Lint rules W0505-W0508
    # ========================================================================

    describe "Extended Lint Rules":

        # @scenario SC-028
        it "W0505 flags high LCOM":
            val warning = check_high_lcom("BigClass", 5, 3)
            expect(warning.?).to_equal(true)

        # @scenario SC-029
        it "W0506 flags high public surface ratio":
            val warning = check_high_public_ratio("module_x", 0.85, 0.7)
            expect(warning.?).to_equal(true)

        # @scenario SC-030
        it "W0507 flags dead public API":
            val warning = check_dead_public_api("module_y", 0.1, 0.3)
            expect(warning.?).to_equal(true)

        # @scenario SC-031
        it "W0508 flags high API complexity":
            val warning = check_high_api_complexity("module_z", 0.95, 0.8)
            expect(warning.?).to_equal(true)

# ============================================================================
# Test Helpers
# ============================================================================

fn test_graph_3_deps() -> ImportGraph:
    """Graph where module_a depends on module_b, module_c, module_d."""
    var graph = ImportGraph(edges: {}, detailed_edges: [])
    graph.edges["module_a"] = ["module_b", "module_c", "module_d"]
    graph.edges["module_b"] = []
    graph.edges["module_c"] = []
    graph.edges["module_d"] = []
    graph

fn test_graph_instability() -> ImportGraph:
    """module_a depends on b and c; nothing depends on a."""
    var graph = ImportGraph(edges: {}, detailed_edges: [])
    graph.edges["module_a"] = ["module_b", "module_c"]
    graph.edges["module_b"] = []
    graph.edges["module_c"] = []
    graph

fn test_graph_isolated() -> ImportGraph:
    """Single isolated module with no deps."""
    var graph = ImportGraph(edges: {}, detailed_edges: [])
    graph.edges["isolated"] = []
    graph

fn test_graph_with_cycle() -> ImportGraph:
    """a -> b -> a cycle."""
    var graph = ImportGraph(edges: {}, detailed_edges: [])
    graph.edges["mod_a"] = ["mod_b"]
    graph.edges["mod_b"] = ["mod_a"]
    graph

fn test_graph_no_cycle() -> ImportGraph:
    """a -> b -> c, no cycle."""
    var graph = ImportGraph(edges: {}, detailed_edges: [])
    graph.edges["a"] = ["b"]
    graph.edges["b"] = ["c"]
    graph.edges["c"] = []
    graph

fn test_graph_multi_cycle() -> ImportGraph:
    """Two independent cycles: a<->b and c<->d."""
    var graph = ImportGraph(edges: {}, detailed_edges: [])
    graph.edges["a"] = ["b"]
    graph.edges["b"] = ["a"]
    graph.edges["c"] = ["d"]
    graph.edges["d"] = ["c"]
    graph.edges["e"] = []
    graph

fn test_graph_layer_violation() -> ImportGraph:
    """Layer 10 depends on layer 20 — violation."""
    var graph = ImportGraph(edges: {}, detailed_edges: [])
    graph.edges["compiler/10.frontend/parser"] = ["compiler/20.hir/types"]
    graph.edges["compiler/20.hir/types"] = []
    graph

fn test_graph_layer_ok() -> ImportGraph:
    """Layer 20 depends on layer 10 — OK."""
    var graph = ImportGraph(edges: {}, detailed_edges: [])
    graph.edges["compiler/20.hir/lowering"] = ["compiler/10.frontend/ast"]
    graph.edges["compiler/10.frontend/ast"] = []
    graph

fn find_metric(metrics: [CouplingMetrics], name: text) -> CouplingMetrics:
    for m in metrics:
        if m.module_name == name:
            return m
    # Fallback — should not reach here in tests
    CouplingMetrics(module_name: name, cbo: 0, fan_in: 0, fan_out: 0, instability: 0.0, abstractness: 0.0, distance: 0.0)

fn test_report() -> CouplingReport:
    val graph = test_graph_3_deps()
    val metrics = compute_all_metrics(graph)
    CouplingReport(
        metrics: metrics,
        cycles: [],
        layer_violations: [],
        inversions: [],
        lcom_results: [],
        api_metrics: [],
        dsm: Option.None,
        atss_warnings: [],
        cbo_threshold: 15
    )
