"""
# Simple-Native 3D Game Engine — System Specification

**Feature IDs:** #ENG3D-001 through #ENG3D-005
**Category:** Stdlib
**Difficulty:** 4/5
**Status:** Implemented (pure Simple physics, software 3D renderer)
**Requirements:** doc/03_plan/requirements/engine_2d.md (3D extension)
**Design:** doc/05_design/engine_2d.md (3D extension)
"""

use std.spec.{describe, it, expect}
use std.common.engine.ids.{NodeId, RawHandle}
use std.common.engine.math3d.{Vec3, Quaternion, Transform3D}
use std.common.engine.color.{EngineColor}
use std.common.engine.units.{Seconds, Angle}
use std.nogc_sync_mut.engine.scene.node3d.{NodeStore3D, get_world_transform_3d}
use std.nogc_sync_mut.engine.component.registry3d.{ComponentRegistry3D, Component3D}
use std.nogc_sync_mut.engine.component.mesh.{MeshData, Vertex3D, create_cube, create_plane, directional_light, LightData}
use std.nogc_sync_mut.engine.component.camera3d.{Camera3DData}
use std.nogc_sync_mut.engine.render.material3d.{Material3D, pbr_material, unlit_material}
use std.nogc_sync_mut.engine.render.renderer3d.{ForwardRenderer3D}
use std.nogc_sync_mut.engine.physics.types3d.{PhysicsConfig3D, default_physics_config_3d}
use std.nogc_sync_mut.engine.physics.world3d.{PhysicsWorld3D}
use std.nogc_sync_mut.engine.physics.collision3d.{Contact3D, collide_sphere_sphere}
use std.nogc_sync_mut.engine.core.time.{Clock, FrameTime}

# ==========================================================================
# REQ-3D-001: Scene Graph
# ==========================================================================

describe "REQ-3D-001 Scene Graph":
    it "creates nodes and establishes parent-child hierarchy":
        var store = NodeStore3D.create()
        val root = store.create_node("root")
        val child = store.create_node("child")
        store.set_parent(child, root)
        val maybe_root = store.get_node(root)
        if val Some(root_node) = maybe_root:
            expect(root_node.children.len()).to_equal(1)
        else:
            expect("root not found").to_equal("found")

    it "computes world transform through parent chain":
        var store = NodeStore3D.create()
        val parent = store.create_node("parent")
        val child = store.create_node("child")
        store.set_parent(child, parent)
        store.set_position(parent, Vec3(x: 100.0, y: 50.0, z: 25.0))
        store.set_position(child, Vec3(x: 10.0, y: 5.0, z: 2.5))
        val world_tf = get_world_transform_3d(store, child)
        val wx = world_tf.position.x * 10.0
        val wy = world_tf.position.y * 10.0
        val wz = world_tf.position.z * 10.0
        expect(wx).to_be_greater_than(1099.0)
        expect(wx).to_be_less_than(1101.0)
        expect(wy).to_be_greater_than(549.0)
        expect(wy).to_be_less_than(551.0)
        expect(wz).to_be_greater_than(274.0)
        expect(wz).to_be_less_than(276.0)

# ==========================================================================
# REQ-3D-002: Components
# ==========================================================================

describe "REQ-3D-002 Components":
    it "attaches mesh, camera, and light components":
        var nodes = NodeStore3D.create()
        var components = ComponentRegistry3D.create()
        # Mesh node
        val mesh_id = nodes.create_node("cube")
        val mesh = create_cube(1.0)
        val material = pbr_material(EngineColor.red(), 0.0, 0.5)
        components.attach(mesh_id, Component3D.Mesh(mesh: mesh, material: material))
        # Camera node
        val cam_id = nodes.create_node("camera")
        val cam = Camera3DData.perspective(Angle(radians: 1.0), 1.333, 0.1, 100.0)
        components.attach(cam_id, Component3D.Camera(data: cam))
        # Light node
        val light_id = nodes.create_node("light")
        val light = directional_light(Vec3(x: 0.0, y: -1.0, z: 0.0), EngineColor.white(), 1.0)
        components.attach(light_id, Component3D.Light(data: light))
        # Verify all components are retrievable
        val mesh_result = components.get_mesh(mesh_id)
        val cam_result = components.get_camera(cam_id)
        val light_result = components.get_light(light_id)
        if val Some(m) = mesh_result:
            expect(m.0.vertex_count()).to_equal(24)
        else:
            expect("mesh not found").to_equal("found")
        if val Some(c) = cam_result:
            val near_i = c.near_plane * 1000.0
            expect(near_i).to_be_greater_than(99.0)
            expect(near_i).to_be_less_than(101.0)
        else:
            expect("camera not found").to_equal("found")
        if val Some(l) = light_result:
            val int_i = l.intensity * 1000.0
            expect(int_i).to_be_greater_than(999.0)
            expect(int_i).to_be_less_than(1001.0)
        else:
            expect("light not found").to_equal("found")

# ==========================================================================
# REQ-3D-003: Physics
# ==========================================================================

describe "REQ-3D-003 Physics":
    it "dynamic body falls under gravity":
        val config = default_physics_config_3d()
        var world = PhysicsWorld3D.create(config)
        val node = NodeId(raw: RawHandle.new(0, 1))
        world.add_dynamic_body(node, 0.0, 10.0, 0.0)
        world.add_sphere_collider(node, 0.5)
        # Step for 100ms
        world.step(Seconds(value: 0.1))
        val pos = world.get_position(node)
        # Y should decrease under gravity (-9.81)
        expect(pos.y).to_be_less_than(10.0)
        world.destroy()

# ==========================================================================
# REQ-3D-004: Collision
# ==========================================================================

describe "REQ-3D-004 Collision":
    it "sphere-sphere contact resolution":
        val contact = collide_sphere_sphere(
            Vec3(x: 0.0, y: 0.0, z: 0.0), 1.0,
            Vec3(x: 1.5, y: 0.0, z: 0.0), 1.0
        )
        if val Some(c) = contact:
            val pen = c.penetration * 100.0
            # Penetration = 2.0 - 1.5 = 0.5
            expect(pen).to_be_greater_than(49.0)
            expect(pen).to_be_less_than(51.0)
            # Normal should point along X
            expect(c.normal.x).to_be_greater_than(0.0)
        else:
            expect("no contact").to_equal("contact found")

# ==========================================================================
# REQ-3D-005: Renderer
# ==========================================================================

describe "REQ-3D-005 Renderer":
    it "render scene produces non-empty pixels":
        var nodes = NodeStore3D.create()
        var components = ComponentRegistry3D.create()
        var renderer = ForwardRenderer3D.create(64, 64)
        # Camera
        val cam_id = nodes.create_node("camera")
        nodes.set_position(cam_id, Vec3(x: 0.0, y: 0.0, z: 5.0))
        val cam = Camera3DData.perspective(Angle(radians: 1.0), 1.0, 0.1, 100.0)
        components.attach(cam_id, Component3D.Camera(data: cam))
        # Light
        val light_id = nodes.create_node("sun")
        val light = directional_light(Vec3(x: 0.0, y: -1.0, z: -1.0), EngineColor.white(), 1.0)
        components.attach(light_id, Component3D.Light(data: light))
        # Mesh
        val mesh_id = nodes.create_node("cube")
        val mesh = create_cube(2.0)
        val material = pbr_material(EngineColor.green(), 0.0, 0.5)
        components.attach(mesh_id, Component3D.Mesh(mesh: mesh, material: material))
        # Render
        renderer.clear()
        val stats = renderer.render_scene(nodes, components, cam_id)
        val pixels = renderer.get_pixels()
        expect(pixels.len()).to_be_greater_than(0)
        expect(stats.draw_calls).to_be_greater_than(0)
        expect(stats.triangles).to_be_greater_than(0)

# ==========================================================================
# Integration: Scene + Physics + Render Pipeline
# ==========================================================================

describe "Integration: 3D scene + physics + render pipeline":
    it "creates scene with physics body and renders frame":
        # Scene
        var nodes = NodeStore3D.create()
        var components = ComponentRegistry3D.create()
        val player_id = nodes.create_node("player")
        nodes.set_position(player_id, Vec3(x: 0.0, y: 5.0, z: 0.0))

        # Physics
        val config = default_physics_config_3d()
        var world = PhysicsWorld3D.create(config)
        world.add_dynamic_body(player_id, 0.0, 5.0, 0.0)
        world.add_sphere_collider(player_id, 0.5)

        # Step physics
        world.step(Seconds(value: 0.016666))

        # Sync physics to scene
        val transforms = world.get_all_dynamic_transforms()
        expect(transforms.len()).to_equal(1)
        val entry = transforms[0]
        val phys_pos = entry.1
        val phys_rot = entry.2
        nodes.set_position(player_id, phys_pos)
        nodes.set_rotation(player_id, phys_rot)

        # Camera
        val cam_id = nodes.create_node("camera")
        nodes.set_position(cam_id, Vec3(x: 0.0, y: 5.0, z: 10.0))
        val cam = Camera3DData.perspective(Angle(radians: 1.0), 1.333, 0.1, 100.0)
        components.attach(cam_id, Component3D.Camera(data: cam))

        # Light
        val light_id = nodes.create_node("sun")
        val light = directional_light(Vec3(x: 0.0, y: -1.0, z: -1.0), EngineColor.white(), 1.0)
        components.attach(light_id, Component3D.Light(data: light))

        # Mesh on player
        val mesh = create_cube(1.0)
        val material = unlit_material(EngineColor.blue())
        components.attach(player_id, Component3D.Mesh(mesh: mesh, material: material))

        # Render
        var renderer = ForwardRenderer3D.create(64, 64)
        renderer.clear()
        val stats = renderer.render_scene(nodes, components, cam_id)
        val pixels = renderer.get_pixels()
        expect(pixels.len()).to_be_greater_than(0)
        expect(stats.draw_calls).to_be_greater_than(0)

        world.destroy()

    it "clock produces frame timing for 3D game loop":
        var clock = Clock.create(Seconds(value: 0.016666))
        val f1 = clock.tick(1000000000)
        val f2 = clock.tick(1050000000)
        val steps = clock.consume_fixed_steps()
        expect(steps).to_be_greater_than(0)
        val alpha = clock.get_interpolation_alpha()
        expect(alpha).to_be_greater_than(-0.01)
        expect(alpha).to_be_less_than(1.01)
