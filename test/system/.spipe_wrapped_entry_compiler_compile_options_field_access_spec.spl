#![allow(spipe_empty_examples)]
#![allow(spipe_boolean_wrapper_assertions)]
@allow(spipe_empty_examples)
@allow(spipe_boolean_wrapper_assertions)
use compiler.common.driver_core_types.{CompileMode, CompileOptions}


fn main():
    """
    # Compiler CompileOptions Field Access
    
    System-level regression check for FR-COMPILER-001. The driver CompileOptions
    type must expose driver-only fields after explicit import resolution.
    """


    describe "compiler CompileOptions field access":
        it "reads driver-only fields from the explicitly imported CompileOptions":
            val opts = CompileOptions.default()
            expect opts.input_files.len() == 0
            expect opts.low_memory == false
            expect opts.mode == CompileMode.Jit

        it "does not resolve to backend CompileOptions":
            val opts = CompileOptions.default()
            expect opts.backend == "auto"
            expect opts.smf_output_mode == "code_only"