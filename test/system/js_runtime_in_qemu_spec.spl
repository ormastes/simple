# @tag:system
#
# System spec — minimal JsRuntime inside QEMU Simple OS guest
#
# Builds js_runtime_probe_entry.spl into a baremetal x86_64 kernel, boots it
# under QEMU, and verifies the guest reaches the serial success marker. This
# isolates the bare-metal JS engine from BrowserSession host-object wiring.
#
use std.spec.*

use os.qemu_runner.{OsTarget, build_os_with_backend}
use os.kernel.arch.arch_context.{Architecture}
use std.nogc_sync_mut.ffi.io.{dir_create_all}

use test.qemu.os.common.qemu_os_harness.{
    can_run_target, file_exists, spawn_guest_with_qmp,
    stop_guest, wait_for_serial_marker}

fn _js_runtime_target(backend: text) -> OsTarget:
    OsTarget(
        arch: Architecture.X86_64,
        entry: "examples/simple_os/arch/x86_64/js_runtime_probe_entry.spl",
        linker_script: "examples/simple_os/arch/x86_64/linker.ld",
        target_triple: "x86_64-unknown-none",
        output: "build/os/simpleos_js_runtime_probe_{backend}_x86_64.elf",
        qemu_system: "qemu-system-x86_64",
        qemu_machine: "q35",
        qemu_cpu: "qemu64",
        qemu_memory: "2G",
        qemu_bios: "",
        qemu_extra: ["-vga", "std", "-device", "isa-debug-exit,iobase=0xf4,iosize=0x04"],
        gui_mode: false
    )

fn _assert_runtime_probe_build(backend: text):
    val target = _js_runtime_target(backend)
    val ok = build_os_with_backend(target, backend)
    if not ok and backend == "llvm":
        print "[js_runtime_in_qemu_spec] LLVM backend unavailable, skipping LLVM build lane"
        expect(true).to_equal(true)
        return
    expect(ok).to_equal(true)
    expect(file_exists(target.output)).to_equal(true)

fn _ensure_runtime_probe_build(backend: text) -> bool:
    val target = _js_runtime_target(backend)
    if file_exists(target.output):
        return true

    val ok = build_os_with_backend(target, backend)
    if not ok and backend == "llvm":
        print "[js_runtime_in_qemu_spec] LLVM backend unavailable, skipping LLVM boot lane"
        return false
    ok

fn _assert_runtime_probe_boot(backend: text):
    val target = _js_runtime_target(backend)
    if not _ensure_runtime_probe_build(backend):
        expect(backend).to_equal("llvm")
        return
    expect(file_exists(target.output)).to_equal(true)

    if not can_run_target(target):
        print "[js_runtime_in_qemu_spec] qemu-system-x86_64 not available, skipping live run ({backend})"
        expect(target.qemu_system).to_equal("qemu-system-x86_64")
        expect(file_exists(target.output)).to_equal(true)
        return

    val qmp_socket = "/tmp/simpleos_js_runtime_spec_{backend}_qmp.sock"
    val serial_log = "build/os/js_runtime_qemu_spec_{backend}_serial.log"
    dir_create_all("build/os")

    match spawn_guest_with_qmp(target, qmp_socket, serial_log):
        Ok(handle):
            expect(wait_for_serial_marker(
                handle,
                "[JSR] Runtime probe passed",
                30000)).to_equal(true)
            expect(stop_guest(handle)).to_equal(true)
            expect(file_exists(qmp_socket)).to_equal(false)
            expect(file_exists(serial_log)).to_equal(false)
        Err(err):
            print "[js_runtime_in_qemu_spec] failed to spawn guest ({backend}): {err}"
            expect(err.len() > 0).to_equal(true)
            expect(file_exists(target.output)).to_equal(true)

describe "Minimal JsRuntime in QEMU Simple OS guest":

    it "builds js_runtime_probe_entry.spl into a Cranelift baremetal kernel":
        _assert_runtime_probe_build("cranelift")

    it "builds js_runtime_probe_entry.spl into an LLVM baremetal kernel":
        _assert_runtime_probe_build("llvm")

    slow_it "boots the Cranelift guest and reaches the runtime probe success marker":
        _assert_runtime_probe_boot("cranelift")

    slow_it "boots the LLVM guest and reaches the runtime probe success marker":
        _assert_runtime_probe_boot("llvm")
