extern fn sys_get_args() -> [text]

struct Inner:
    values: [i64]

struct Outer:
    inner: Inner
    nums: [i64]

fn make_inner() -> Inner:
    Inner(values: [10, 20, 30])

fn make_outer() -> Outer:
    Outer(
        inner: make_inner(),
        nums: [1, 2, 3]
    )

fn probe_struct_array() -> text:
    val s = make_inner()
    if s.values.len() != 3:
        return "len={s.values.len()}"
    "{s.values[1]}"

fn probe_nested_struct_array() -> text:
    val o = make_outer()
    if o.inner.values.len() != 3:
        return "inner_len={o.inner.values.len()}"
    "{o.inner.values[2]}"

fn probe_sibling_array() -> text:
    val o = make_outer()
    if o.nums.len() != 3:
        return "nums_len={o.nums.len()}"
    "{o.nums[0]}"

fn probe_copy_then_index() -> text:
    val o = make_outer()
    val vals = o.inner.values
    if vals.len() != 3:
        return "vals_len={vals.len()}"
    "{vals[0]}"

fn main() -> i64:
    val args = sys_get_args()
    val command = if args.len() > 1: args[1] else: "nested"
    val result = match command:
        case "struct_array": probe_struct_array()
        case "nested": probe_nested_struct_array()
        case "sibling": probe_sibling_array()
        case "copy": probe_copy_then_index()
        case _: "unknown"
    print result
    if result == "20" or result == "30" or result == "1" or result == "10":
        0
    else:
        1
