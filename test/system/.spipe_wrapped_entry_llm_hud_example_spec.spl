#![allow(spipe_empty_examples)]
#![allow(spipe_boolean_wrapper_assertions)]
@allow(spipe_empty_examples)
@allow(spipe_boolean_wrapper_assertions)


extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

fn run_hud(args: [text]) -> (text, text, i64):
    rt_process_run("bin/simple", ["examples/llm_hud/main.spl"] + args)

fn main():
    describe "llm_hud example":
        it "renders codex statusline output":
            val (stdout, stderr, code) = run_hud(["--provider", "codex", "--mode", "statusline", "--no-color"])
            expect code == 0
            expect (stdout).contains("[Codex]")
            expect (stdout).contains("tool ")

        it "renders gemini fallback output":
            val (stdout, stderr, code) = run_hud(["--provider", "gemini", "--mode", "statusline", "--no-color"])
            expect code == 0
            expect (stdout).contains("[Gemini]")
            expect (stdout).contains("Gemini")

        it "prints help":
            val (stdout, stderr, code) = run_hud(["--help"])
            expect code == 0
            expect (stdout).contains("Simple LLM HUD")