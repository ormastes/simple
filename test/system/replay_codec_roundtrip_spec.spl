use std.spec
use os.kernel.replay.event_kinds.{ReplayEntry, EventKind}
use std.nogc_sync_mut.replay.codec.{encode_entry, decode_entry, encode_entries, decode_entries}

describe "ReplayEntry codec roundtrip":
    it "encode then decode preserves event_id":
        val e = ReplayEntry.create(EventKind.Schedule, 10, 20, 0)
        val bytes = encode_entry(e)
        val r = decode_entry(bytes, 0)
        var ok = false
        if val Ok(de) = r:
            ok = de.event_id == e.event_id
        expect(ok).to_equal(true)

    it "encode then decode preserves thread_id":
        val e = ReplayEntry.create(EventKind.SyscallEnter, 42, 1, 0)
        val bytes = encode_entry(e)
        val r = decode_entry(bytes, 0)
        var ok = false
        if val Ok(de) = r:
            ok = de.thread_id == 42
        expect(ok).to_equal(true)

    it "encode then decode preserves kind":
        val e = ReplayEntry.create(EventKind.IpcSend, 5, 1, 0)
        val bytes = encode_entry(e)
        val r = decode_entry(bytes, 0)
        var ok = false
        if val Ok(de) = r:
            ok = de.kind == EventKind.IpcSend.to_i32()
        expect(ok).to_equal(true)

    it "encode produces 80 bytes":
        val e = ReplayEntry.create(EventKind.TimerRead, 1, 1, 0)
        val bytes = encode_entry(e)
        expect(bytes.len()).to_equal(80)

    it "decode_entry on insufficient bytes returns Err":
        val short: [i32] = [0, 1, 2]
        val r = decode_entry(short, 0)
        var is_err = true
        if val Ok(_) = r:
            is_err = false
        expect(is_err).to_equal(true)

    it "encode_entries then decode_entries roundtrips two events":
        val e1 = ReplayEntry.create(EventKind.ThreadCreate, 11, 1, 0)
        val e2 = ReplayEntry.create(EventKind.ThreadExit, 12, 1, 0)
        val entries = [e1, e2]
        val bytes = encode_entries(entries)
        val decoded = decode_entries(bytes)
        expect(decoded.len()).to_equal(2)
