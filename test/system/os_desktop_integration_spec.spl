# SimpleOS Desktop Integration — Serial Regression Lane
#
# @tag:system
#
# Implements the serial halves of:
#   SYS-GUI-001 Boot to desktop
#   SYS-GUI-002 Launcher and shortcut join
#
# See doc/03_plan/sys_test/simpleos_small_complete_gui.md and
# doc/03_plan/simpleos_small_complete_gui_status_2026-04-13.md Lane A.
#
# This spec replaces the previous placeholder-assertion version. It is the
# authoritative serial-only regression lane for the x86_64 SimpleOS desktop
# integration path. The framebuffer-capture lane (SYS-GUI-006) is owned by
# test/system/engine2d_in_qemu_spec.spl style coverage and Agent 3.
#
# Canonical markers emitted by examples/simple_os/arch/x86_64/desktop_e2e_entry.spl:
#   [desktop-e2e] spl_start
#   [desktop-e2e] boot
#   [desktop-e2e] shell-ready
#   [desktop-e2e] launcher-ready
#   [desktop-e2e] desktop-ready
#   [desktop-e2e] shortcut:ok
#   [desktop-e2e] wm:ok
#   TEST PASSED
#
# @cover examples/simple_os/arch/x86_64/desktop_e2e_entry.spl 90%
# @cover src/os/desktop/shell.spl 40%
# @cover src/os/services/launcher/launcher.spl 50%

use std.spec.*

use os.qemu_runner.{build_os, get_desktop_browser_target}
use test.qemu.os.common.qemu_os_harness.{
    can_run_target, file_exists, spawn_guest_with_qmp, wait_for_serial_marker,
    read_serial_log, stop_guest
}

extern fn rt_file_write_text(path: text, content: text) -> bool

describe "SimpleOS desktop integration (serial lane)":

    it "SYS-GUI-001 boots the x86_64 desktop target to desktop-ready":
        val target = get_desktop_browser_target()
        expect(build_os(target)).to_equal(true)
        expect(file_exists(target.output)).to_equal(true)

        if not can_run_target(target):
            # QEMU not available in this environment — the build+link check
            # above is the most this lane can assert here. Parent agents
            # must run this on a QEMU-capable host for full coverage.
            expect(true).to_equal(true)
            return

        val qmp_socket = "/tmp/simpleos_sys_gui_001_qmp.sock"
        val serial_log = "build/os/sys_gui_001_serial.log"
        match spawn_guest_with_qmp(target, qmp_socket, serial_log):
            Ok(handle):
                val saw_spl_start    = wait_for_serial_marker(handle, "[desktop-e2e] spl_start", 10000)
                val saw_boot         = wait_for_serial_marker(handle, "[desktop-e2e] boot", 10000)
                val saw_shell_ready  = wait_for_serial_marker(handle, "[desktop-e2e] shell-ready", 15000)
                val saw_launcher     = wait_for_serial_marker(handle, "[desktop-e2e] launcher-ready", 10000)
                val saw_desktop      = wait_for_serial_marker(handle, "[desktop-e2e] desktop-ready", 10000)
                val output = read_serial_log(handle)
                stop_guest(handle)
                expect(saw_spl_start).to_equal(true)
                expect(saw_boot).to_equal(true)
                expect(saw_shell_ready).to_equal(true)
                expect(saw_launcher).to_equal(true)
                expect(saw_desktop).to_equal(true)
                expect(output.contains("FAULT @")).to_equal(false)
                expect(output.contains("panic")).to_equal(false)
            Err(err):
                print "[os_desktop_integration_spec] SYS-GUI-001 spawn failed: {err}"
                expect(false).to_equal(true)

    it "SYS-GUI-002 drives the launcher shortcut and observes a wm join":
        val target = get_desktop_browser_target()
        expect(build_os(target)).to_equal(true)
        expect(file_exists(target.output)).to_equal(true)

        if not can_run_target(target):
            expect(file_exists(target.output)).to_equal(true)
            return

        val qmp_socket = "/tmp/simpleos_sys_gui_002_qmp.sock"
        val serial_log = "build/os/sys_gui_002_serial.log"
        match spawn_guest_with_qmp(target, qmp_socket, serial_log):
            Ok(handle):
                val saw_desktop   = wait_for_serial_marker(handle, "[desktop-e2e] desktop-ready", 20000)
                val saw_shortcut  = wait_for_serial_marker(handle, "[desktop-e2e] shortcut:ok", 10000)
                val saw_wm_join   = wait_for_serial_marker(handle, "[desktop-e2e] wm:ok", 10000)
                val saw_pass      = wait_for_serial_marker(handle, "TEST PASSED", 15000)
                val output = read_serial_log(handle)
                val clean_output = not output.contains("TEST FAILED") and
                    not output.contains("[desktop-e2e] shortcut:fail") and
                    not output.contains("[desktop-e2e] wm:fail") and
                    not output.contains("FAULT @")
                if not saw_desktop or not saw_shortcut or not saw_wm_join or not saw_pass or not clean_output:
                    rt_file_write_text("build/os/sys_gui_002_failure_serial.log", output)
                stop_guest(handle)
                expect(saw_desktop).to_equal(true)
                expect(saw_shortcut).to_equal(true)
                expect(saw_wm_join).to_equal(true)
                expect(saw_pass).to_equal(true)
                expect(clean_output).to_equal(true)
            Err(err):
                print "[os_desktop_integration_spec] SYS-GUI-002 spawn failed: {err}"
                expect(false).to_equal(true)
