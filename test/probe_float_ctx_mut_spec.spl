use std.spec

fn probe_push(c: FloatContext):
    c.left_floats.push(FloatBox(x: 1, y: 2, width: 3, height: 4, side: 1))

class FloatBox:
    x: i32
    y: i32
    width: i32
    height: i32
    side: i32

class FloatContext:
    left_floats: [FloatBox]
    right_floats: [FloatBox]
    current_y: i32

    static fn create() -> FloatContext:
        return FloatContext(left_floats: [], right_floats: [], current_y: 0)

describe "FloatContext mutation through params":
    it "push in callee visible to caller":
        var c = FloatContext.create()
        assert c.left_floats.len() == 0
        probe_push(c)
        assert c.left_floats.len() == 1
