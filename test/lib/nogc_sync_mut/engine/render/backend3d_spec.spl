use std.spec
use std.nogc_sync_mut.engine.render.backend3d.{
    PipelineHandle, BufferHandle, TextureHandle, RenderPassHandle,
    PipelineDesc3D, TextureFormat3D, AnyRenderBackend3D
}
use std.nogc_sync_mut.engine.render.capability3d.{
    RenderCapability3D, RenderBackendKind3D,
    capability_software_3d, capability_vulkan_3d, capability_webgpu_3d,
    detect_best_backend_3d
}
use std.nogc_sync_mut.engine.render.software_backend3d.{SoftwareRenderBackend3D}

# ============================================================================
# Module-level helpers
# ============================================================================

fn make_invalid_pipeline() -> PipelineHandle:
    PipelineHandle.invalid()

fn make_invalid_buffer() -> BufferHandle:
    BufferHandle.invalid()

fn make_invalid_texture() -> TextureHandle:
    TextureHandle.invalid()

fn make_invalid_render_pass() -> RenderPassHandle:
    RenderPassHandle.invalid()

fn make_pipeline_desc() -> PipelineDesc3D:
    PipelineDesc3D(
        vertex_shader_spirv: [],
        fragment_shader_spirv: [],
        vertex_shader_wgsl: "",
        fragment_shader_wgsl: "",
        vertex_stride: 32,
        cull_back_faces: true,
        depth_write: true,
        depth_test: true
    )

# ============================================================================
# Stream A — backend3d.spl specs
# AC-1, AC-2, AC-9, AC-10
# ============================================================================

describe "Stream A: Handle Types":

    describe "PipelineHandle":
        it "AC-1: invalid() returns id of -1":
            val h = PipelineHandle.invalid()
            expect(h.id).to_equal(-1)

        it "AC-1: constructed with positive id is distinct from invalid":
            val h = PipelineHandle(id: 42)
            val inv = PipelineHandle.invalid()
            expect(h.id).to_be_greater_than(inv.id)

    describe "BufferHandle":
        it "AC-1: invalid() returns id of -1":
            val h = BufferHandle.invalid()
            expect(h.id).to_equal(-1)

        it "AC-1: constructed handle has expected id":
            val h = BufferHandle(id: 7)
            expect(h.id).to_equal(7)

    describe "TextureHandle":
        it "AC-7: invalid() returns id of -1":
            val h = TextureHandle.invalid()
            expect(h.id).to_equal(-1)

        it "AC-7: constructed handle has expected id":
            val h = TextureHandle(id: 99)
            expect(h.id).to_equal(99)

    describe "RenderPassHandle":
        it "AC-1: invalid() returns id of -1":
            val h = RenderPassHandle.invalid()
            expect(h.id).to_equal(-1)

        it "AC-1: constructed handle has expected id":
            val h = RenderPassHandle(id: 3)
            expect(h.id).to_equal(3)

describe "Stream A: PipelineDesc3D":

    describe "PipelineDesc3D construction":
        it "AC-1: vertex_stride field is stored":
            val desc = make_pipeline_desc()
            expect(desc.vertex_stride).to_equal(32)

        it "AC-1: cull_back_faces flag is stored":
            val desc = make_pipeline_desc()
            expect(desc.cull_back_faces).to_equal(true)

        it "AC-1: depth_write flag is stored":
            val desc = make_pipeline_desc()
            expect(desc.depth_write).to_equal(true)

        it "AC-1: depth_test flag is stored":
            val desc = make_pipeline_desc()
            expect(desc.depth_test).to_equal(true)

describe "Stream A: RenderCapability3D factory functions":

    describe "capability_software_3d":
        it "AC-2: backend kind is Software":
            val cap = capability_software_3d()
            val is_software = cap.backend == RenderBackendKind3D.Software
            expect(is_software).to_equal(true)

        it "AC-2: supports_compute_shaders is false for software":
            val cap = capability_software_3d()
            expect(cap.supports_compute_shaders).to_equal(false)

        it "AC-2: max_texture_size is positive":
            val cap = capability_software_3d()
            expect(cap.max_texture_size).to_be_greater_than(0)

    describe "capability_vulkan_3d":
        it "AC-2: backend kind is Vulkan":
            val cap = capability_vulkan_3d()
            val is_vulkan = cap.backend == RenderBackendKind3D.Vulkan
            expect(is_vulkan).to_equal(true)

        it "AC-2: supports_compute_shaders is true for Vulkan":
            val cap = capability_vulkan_3d()
            expect(cap.supports_compute_shaders).to_equal(true)

        it "AC-2: supports_wgsl is false for Vulkan":
            val cap = capability_vulkan_3d()
            expect(cap.supports_wgsl).to_equal(false)

    describe "capability_webgpu_3d":
        it "AC-2: backend kind is WebGpu":
            val cap = capability_webgpu_3d()
            val is_webgpu = cap.backend == RenderBackendKind3D.WebGpu
            expect(is_webgpu).to_equal(true)

        it "AC-2: supports_wgsl is true for WebGpu":
            val cap = capability_webgpu_3d()
            expect(cap.supports_wgsl).to_equal(true)

    describe "detect_best_backend_3d":
        it "AC-2: returns a valid RenderBackendKind3D":
            val kind = detect_best_backend_3d()
            val is_software = kind == RenderBackendKind3D.Software
            val is_vulkan = kind == RenderBackendKind3D.Vulkan
            val is_webgpu = kind == RenderBackendKind3D.WebGpu
            val any_valid = is_software or is_vulkan or is_webgpu
            expect(any_valid).to_equal(true)

        it "AC-2: in CI (no GPU) returns Software":
            val kind = detect_best_backend_3d()
            val is_software = kind == RenderBackendKind3D.Software
            expect(is_software).to_equal(true)

describe "Stream A: SoftwareRenderBackend3D init + basic cycle":

    describe "init":
        it "AC-9: init returns true for software backend":
            var backend = SoftwareRenderBackend3D.create()
            val ok = backend.init(320, 240)
            expect(ok).to_equal(true)

        it "AC-9: capabilities returns Software kind":
            var backend = SoftwareRenderBackend3D.create()
            val _ = backend.init(320, 240)
            val cap = backend.capabilities()
            val is_software = cap.backend == RenderBackendKind3D.Software
            expect(is_software).to_equal(true)

    describe "create_vertex_buffer + upload_buffer":
        it "AC-9: create_vertex_buffer returns valid handle":
            var backend = SoftwareRenderBackend3D.create()
            val _ = backend.init(320, 240)
            val buf = backend.create_vertex_buffer(128)
            expect(buf.id).to_be_greater_than(-1)

        it "AC-9: upload_buffer does not panic for valid handle":
            var backend = SoftwareRenderBackend3D.create()
            val _ = backend.init(320, 240)
            val buf = backend.create_vertex_buffer(8)
            backend.upload_buffer(buf, [0, 1, 2, 3, 4, 5, 6, 7], 0)
            expect(buf.id).to_be_greater_than(-1)

    describe "create_texture + upload_texture":
        it "AC-9: create_texture returns valid TextureHandle":
            var backend = SoftwareRenderBackend3D.create()
            val _ = backend.init(320, 240)
            val tex = backend.create_texture(64, 64, TextureFormat3D.Rgba8Unorm)
            expect(tex.id).to_be_greater_than(-1)

    describe "frame lifecycle":
        it "AC-9: begin_frame then end_frame does not crash":
            var backend = SoftwareRenderBackend3D.create()
            val _ = backend.init(320, 240)
            backend.begin_frame()
            backend.end_frame()
            expect(true).to_equal(true)

    describe "AnyRenderBackend3D dispatch":
        it "AC-10: Software variant holds SoftwareRenderBackend3D":
            var sw = SoftwareRenderBackend3D.create()
            val _ = sw.init(64, 64)
            val any = AnyRenderBackend3D.Software(sw)
            val is_software = any == AnyRenderBackend3D.Software(sw)
            expect(is_software).to_equal(true)
