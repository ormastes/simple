# @cover src/lib/blink/url/url_parser.spl 80%
"""
# Blink URL Parser Specification

**Category:** Browser / Blink
**Status:** Stub

## Overview

Tests for the Blink-style WHATWG URL parser subset (mirrors Chromium's
url::GURL). Covers absolute URL shape parsing (scheme + authority + path +
query + fragment), percent-encoding/decoding round-trips, and the
application/x-www-form-urlencoded query_string_parse splitter.
"""

use std.spipe.*
use std.lib.blink.url.url_parser.{
    ParsedUrl,
    parse_url,
    percent_decode,
    percent_encode,
    query_string_parse
}

describe "parse_url scheme and host":
    it "extracts scheme=https and host=example.com":
        val u = parse_url("https://example.com")
        expect u.scheme == "https"
        expect u.host == "example.com"
        expect u.is_valid == true

describe "parse_url authority port and path":
    it "extracts port=8080 and path=/path":
        val u = parse_url("https://example.com:8080/path")
        expect u.host == "example.com"
        expect u.port == 8080
        expect u.path == "/path"
        expect u.is_valid == true

describe "parse_url query":
    it "extracts query a=1&b=2":
        val u = parse_url("https://example.com/?a=1&b=2")
        expect u.query == "a=1&b=2"
        expect u.path == "/"
        expect u.is_valid == true

describe "parse_url fragment":
    it "extracts fragment=section":
        val u = parse_url("https://example.com/#section")
        expect u.fragment == "section"
        expect u.is_valid == true

describe "percent_decode":
    it "%20 decodes to a single space":
        val decoded = percent_decode("%20")
        expect decoded == " "
        expect decoded.len().to_i64() == 1

describe "percent_encode":
    it "space is encoded to %20 when not in allowed list":
        val allowed: [i64] = [i64]()
        allowed.push(65)  # 'A'
        allowed.push(66)  # 'B'
        val encoded = percent_encode("A B", allowed)
        expect encoded == "A%20B"
        expect encoded.len().to_i64() > 3

describe "query_string_parse":
    it "splits a=1&b=2 into two pairs":
        val pairs = query_string_parse("a=1&b=2")
        expect pairs.len().to_i64() == 2
        val p0 = pairs[0]
        val p1 = pairs[1]
        expect p0.0 == "a"
        expect p0.1 == "1"
        expect p1.0 == "b"
        expect p1.1 == "2"

describe "parse_url empty":
    it "empty string yields is_valid=false":
        val u = parse_url("")
        expect u.is_valid == false
        expect u.scheme == ""
        expect u.host == ""