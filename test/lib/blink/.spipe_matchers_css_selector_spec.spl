# @cover src/lib/blink/css_parser/selector.spl 80%
"""
# CSS Selector Matcher Specification

**Category:** Browser / Blink
**Status:** Active

## Overview

Tests for `parse_selector` (tokenisation + AST construction) and
`matches_compound` (single-element matching logic) defined in
`src/lib/blink/css_parser/selector.spl`.
"""

use std.spipe.*
use std.lib.blink.css_parser.selector.{
    SimpleSelectorKind, SimpleSelector, CompoundSelector,
    Combinator, ComplexSelector,
    parse_selector, matches_compound, matches_complex,
    matches_compound_with_state, matches_complex_with_state,
    simple_selector_new, compound_selector_new
}
use std.lib.blink.dom.node.{
    DomNode, DomTree, NodeType, Attribute,
    dom_node_new, dom_tree_new, attribute_new
}
use std.lib.blink.dom.interaction_state.{
    InteractionState,
    interaction_state_empty, interaction_state_with_hover,
    interaction_state_with_focus
}

# ---------------------------------------------------------------------------
# parse_selector tests
# ---------------------------------------------------------------------------

describe "parse_selector: type selector":
    it "div produces 1 compound with Type selector":
        val result = parse_selector("div")
        expect result.is_none() == false
        val sel = result.unwrap()
        expect sel.compounds.len() == 1
        val compound = sel.compounds[0]
        expect compound.simples.len() == 1
        val simple = compound.simples[0]
        expect simple.kind == SimpleSelectorKind.Type == true
        expect simple.name == "div"

describe "parse_selector: class selector":
    it ".foo produces 1 compound with Class selector":
        val result = parse_selector(".foo")
        expect result.is_none() == false
        val sel = result.unwrap()
        expect sel.compounds.len() == 1
        val compound = sel.compounds[0]
        expect compound.simples.len() == 1
        val simple = compound.simples[0]
        expect simple.kind == SimpleSelectorKind.Class == true
        expect simple.name == "foo"

describe "parse_selector: id selector":
    it "#bar produces 1 compound with Id selector":
        val result = parse_selector("#bar")
        expect result.is_none() == false
        val sel = result.unwrap()
        expect sel.compounds.len() == 1
        val compound = sel.compounds[0]
        expect compound.simples.len() == 1
        val simple = compound.simples[0]
        expect simple.kind == SimpleSelectorKind.Id == true
        expect simple.name == "bar"

describe "parse_selector: compound selector":
    it "div.foo produces 1 compound with 2 simples (Type + Class)":
        val result = parse_selector("div.foo")
        expect result.is_none() == false
        val sel = result.unwrap()
        expect sel.compounds.len() == 1
        val compound = sel.compounds[0]
        expect compound.simples.len() == 2
        val s0 = compound.simples[0]
        val s1 = compound.simples[1]
        expect s0.kind == SimpleSelectorKind.Type == true
        expect s0.name == "div"
        expect s1.kind == SimpleSelectorKind.Class == true
        expect s1.name == "foo"

describe "parse_selector: descendant combinator":
    it "div p produces 2 compounds with Descendant combinator":
        val result = parse_selector("div p")
        expect result.is_none() == false
        val sel = result.unwrap()
        expect sel.compounds.len() == 2
        expect sel.combinators.len() == 1
        expect sel.combinators[0] == Combinator.Descendant == true
        expect sel.compounds[0].simples[0].name == "div"
        expect sel.compounds[1].simples[0].name == "p"

describe "parse_selector: child combinator":
    it "ul > li produces 2 compounds with Child combinator":
        val result = parse_selector("ul > li")
        expect result.is_none() == false
        val sel = result.unwrap()
        expect sel.compounds.len() == 2
        expect sel.combinators.len() == 1
        expect sel.combinators[0] == Combinator.Child == true
        expect sel.compounds[0].simples[0].name == "ul"
        expect sel.compounds[1].simples[0].name == "li"

# ---------------------------------------------------------------------------
# matches_compound tests
# ---------------------------------------------------------------------------

describe "matches_compound: type selector":
    it "node with tag div matches type selector div":
        val node = dom_node_new(1, NodeType.Element)
        node.tag_name = "div"
        val result = parse_selector("div")
        expect result.is_none() == false
        val compound = result.unwrap().compounds[0]
        expect matches_compound(node, compound) == true

describe "matches_compound: class selector":
    it "node without class foo does not match .foo selector":
        val node = dom_node_new(2, NodeType.Element)
        node.tag_name = "div"
        # No class attribute — should not match.
        val result = parse_selector(".foo")
        expect result.is_none() == false
        val compound = result.unwrap().compounds[0]
        expect matches_compound(node, compound) == false

# ---------------------------------------------------------------------------
# Pseudo-class tests: :hover, :focus
# ---------------------------------------------------------------------------

describe "parse_selector: pseudo-class :hover":
    it ".btn:hover produces 1 compound with 2 simples (Class + PseudoClass)":
        val result = parse_selector(".btn:hover")
        expect result.is_none() == false
        val sel = result.unwrap()
        expect sel.compounds.len() == 1
        val compound = sel.compounds[0]
        expect compound.simples.len() == 2
        val s0 = compound.simples[0]
        val s1 = compound.simples[1]
        expect s0.kind == SimpleSelectorKind.Class == true
        expect s0.name == "btn"
        expect s1.kind == SimpleSelectorKind.PseudoClass == true
        expect s1.name == "hover"

describe "parse_selector: pseudo-class :focus":
    it "#input:focus produces 1 compound with 2 simples (Id + PseudoClass)":
        val result = parse_selector("#input:focus")
        expect result.is_none() == false
        val sel = result.unwrap()
        expect sel.compounds.len() == 1
        val compound = sel.compounds[0]
        expect compound.simples.len() == 2
        val s0 = compound.simples[0]
        val s1 = compound.simples[1]
        expect s0.kind == SimpleSelectorKind.Id == true
        expect s0.name == "input"
        expect s1.kind == SimpleSelectorKind.PseudoClass == true
        expect s1.name == "focus"

describe "parse_selector: rejects unsupported pseudo-class":
    it ":nth-child(2) returns None":
        val result = parse_selector(":nth-child(2)")
        expect result.is_none() == true

describe "matches_compound_with_state: :hover":
    it ".btn:hover matches when hovered_id equals node id":
        val node = dom_node_new(7, NodeType.Element)
        node.tag_name = "button"
        node.attributes.push(attribute_new("class", "btn"))
        val result = parse_selector(".btn:hover")
        expect result.is_none() == false
        val compound = result.unwrap().compounds[0]
        val state = interaction_state_with_hover(7)
        expect matches_compound_with_state(node, 7, compound, state) == true

    it ".btn:hover does NOT match when hovered_id is -1":
        val node = dom_node_new(7, NodeType.Element)
        node.tag_name = "button"
        node.attributes.push(attribute_new("class", "btn"))
        val result = parse_selector(".btn:hover")
        expect result.is_none() == false
        val compound = result.unwrap().compounds[0]
        val state = interaction_state_empty()
        expect matches_compound_with_state(node, 7, compound, state) == false

describe "matches_compound_with_state: :focus":
    it "#input:focus matches when focused_id equals node id":
        val node = dom_node_new(11, NodeType.Element)
        node.tag_name = "input"
        node.attributes.push(attribute_new("id", "input"))
        val result = parse_selector("#input:focus")
        expect result.is_none() == false
        val compound = result.unwrap().compounds[0]
        val state = interaction_state_with_focus(11)
        expect matches_compound_with_state(node, 11, compound, state) == true

    it "#input:focus does NOT match when focused_id is -1":
        val node = dom_node_new(11, NodeType.Element)
        node.tag_name = "input"
        node.attributes.push(attribute_new("id", "input"))
        val result = parse_selector("#input:focus")
        expect result.is_none() == false
        val compound = result.unwrap().compounds[0]
        val state = interaction_state_empty()
        expect matches_compound_with_state(node, 11, compound, state) == false