#![allow(spipe_empty_examples)]
#![allow(spipe_boolean_wrapper_assertions)]
@allow(spipe_empty_examples)
@allow(spipe_boolean_wrapper_assertions)
use std.spipe.*
use std.skia.entity.geometry.{SkRect}
use std.blink.entity.paint_artifact.{PaintArtifact}
use std.content.entity.web_contents.{WebContents}

fn _rect() -> SkRect:
    SkRect(left: 0.0, top: 0.0, right: 800.0, bottom: 600.0)

fn main():
    # WebContents unit tests


    describe "WebContents.new":
        it "gives correct id":
            val wc = WebContents.new(42, _rect())
            expect wc.id == 42

        it "gives correct viewport":
            val wc = WebContents.new(1, _rect())
            expect wc.viewport.right == 800.0

        it "main_frame_surface has matching client_id":
            val wc = WebContents.new(7, _rect())
            expect wc.main_frame_surface.frame_sink_id.client_id == 7

        it "main_frame_surface sink_id is 1":
            val wc = WebContents.new(3, _rect())
            expect wc.main_frame_surface.frame_sink_id.sink_id == 1

    describe "WebContents mutations":
        it "navigate updates url":
            var wc = WebContents.new(1, _rect())
            wc.navigate("https://example.com")
            expect wc.url == "https://example.com"

        it "set_title updates title":
            var wc = WebContents.new(1, _rect())
            wc.set_title("Hello")
            expect wc.title == "Hello"

        it "update_paint populates last_paint":
            var wc = WebContents.new(1, _rect())
            val art = PaintArtifact.empty()
            wc.update_paint(art)
            val has_paint = wc.last_paint.is_some()
            expect has_paint == true