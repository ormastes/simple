# Type Inference Engine - Executable Coverage
#
# This spec mirrors the behavior of the real type inference module closely
# enough to exercise the core algorithms in interpreter mode without relying on
# parser-hostile imports or reserved identifiers.

fn check(condition: bool):
    expect(condition).to_equal(true)

fn same_ids(left: [i64], right: [i64]) -> bool:
    if left.len() != right.len():
        return false

    var i: i64 = 0
    while i < left.len():
        if left[i] != right[i]:
            return false
        i = i + 1

    true

fn same_types(left: [Type], right: [Type]) -> bool:
    if left.len() != right.len():
        return false

    var i: i64 = 0
    while i < left.len():
        if not type_equals(left[i], right[i]):
            return false
        i = i + 1

    true

fn same_pairs(left: [(text, Type)], right: [(text, Type)]) -> bool:
    if left.len() != right.len():
        return false

    var i: i64 = 0
    while i < left.len():
        if left[i].0 != right[i].0:
            return false
        if not type_equals(left[i].1, right[i].1):
            return false
        i = i + 1

    true

enum Type:
    Int
    Bool
    Str
    Float
    Unit
    Var(id: i64)
    Function(params: [Type], ret: Type)
    Generic(name: text, args: [Type])
    DynTrait(trait_name: text)
    Tuple(elements: [Type])
    Array(element: Type)
    Optional(inner: Type)

impl Type:
    fn to_string() -> text:
        match self:
            case Type.Int: "Int"
            case Type.Bool: "Bool"
            case Type.Str: "Str"
            case Type.Float: "Float"
            case Type.Unit: "Unit"
            case Type.Var(id): "T{id}"
            case Type.Function(params, ret):
                var parts: [text] = []
                var i: i64 = 0
                while i < params.len():
                    parts = parts.push(params[i].to_string())
                    i = i + 1
                "fn({parts.join(", ")}) -> {ret.to_string()}"
            case Type.Generic(name, args):
                if args.len() == 0:
                    name
                else:
                    var parts: [text] = []
                    var i: i64 = 0
                    while i < args.len():
                        parts = parts.push(args[i].to_string())
                        i = i + 1
                    "{name}<{parts.join(", ")}>"
            case Type.DynTrait(trait_name):
                "dyn {trait_name}"
            case Type.Tuple(elements):
                var parts: [text] = []
                var i: i64 = 0
                while i < elements.len():
                    parts = parts.push(elements[i].to_string())
                    i = i + 1
                "({parts.join(", ")})"
            case Type.Array(element):
                "[{element.to_string()}]"
            case Type.Optional(inner):
                "Option<{inner.to_string()}>"

    fn is_primitive() -> bool:
        match self:
            case Type.Int: true
            case Type.Bool: true
            case Type.Str: true
            case Type.Float: true
            case Type.Unit: true
            case _: false

fn type_equals(left: Type, right: Type) -> bool:
    match (left, right):
        case (Type.Int, Type.Int): true
        case (Type.Bool, Type.Bool): true
        case (Type.Str, Type.Str): true
        case (Type.Float, Type.Float): true
        case (Type.Unit, Type.Unit): true
        case (Type.Var(left_id), Type.Var(right_id)): left_id == right_id
        case (Type.Function(left_params, left_ret), Type.Function(right_params, right_ret)):
            same_types(left_params, right_params) and type_equals(left_ret, right_ret)
        case (Type.Generic(left_name, left_args), Type.Generic(right_name, right_args)):
            left_name == right_name and same_types(left_args, right_args)
        case (Type.DynTrait(left_name), Type.DynTrait(right_name)):
            left_name == right_name
        case (Type.Tuple(left_elems), Type.Tuple(right_elems)):
            same_types(left_elems, right_elems)
        case (Type.Array(left_elem), Type.Array(right_elem)):
            type_equals(left_elem, right_elem)
        case (Type.Optional(left_inner), Type.Optional(right_inner)):
            type_equals(left_inner, right_inner)
        case _: false

class TypeUnifier:
    substitution_ids: [i64]
    substitution_types: [Type]
    next_var: i64

impl TypeUnifier:
    static fn new() -> TypeUnifier:
        TypeUnifier(substitution_ids: [], substitution_types: [], next_var: 0)

    me fresh_var() -> Type:
        val var_id = self.next_var
        self.next_var = self.next_var + 1
        Type.Var(var_id)

    fn lookup_substitution(id: i64) -> Type?:
        var i: i64 = 0
        while i < self.substitution_ids.len():
            if self.substitution_ids[i] == id:
                return self.substitution_types[i]
            i = i + 1
        nil

    me record_substitution(id: i64, ty: Type):
        var i: i64 = 0
        while i < self.substitution_ids.len():
            if self.substitution_ids[i] == id:
                self.substitution_types[i] = ty
                return
            i = i + 1

        self.substitution_ids = self.substitution_ids.push(id)
        self.substitution_types = self.substitution_types.push(ty)

    fn resolve(ty: Type) -> Type:
        match ty:
            case Type.Var(id):
                var seen: [i64] = []
                var current_id = id
                while true:
                    if contains_i64(seen, current_id):
                        return Type.Var(current_id)
                    seen = seen.push(current_id)
                    match self.lookup_substitution(current_id):
                        case Some(next_ty):
                            match next_ty:
                                case Type.Var(next_id):
                                    current_id = next_id
                                case _:
                                    return self.resolve(next_ty)
                        case nil:
                            return Type.Var(current_id)
            case Type.Function(params, ret):
                var resolved_params: [Type] = []
                var i: i64 = 0
                while i < params.len():
                    resolved_params = resolved_params.push(self.resolve(params[i]))
                    i = i + 1
                Type.Function(resolved_params, self.resolve(ret))
            case Type.Generic(name, args):
                var resolved_args: [Type] = []
                var i: i64 = 0
                while i < args.len():
                    resolved_args = resolved_args.push(self.resolve(args[i]))
                    i = i + 1
                Type.Generic(name, resolved_args)
            case Type.Tuple(elements):
                var resolved_elements: [Type] = []
                var i: i64 = 0
                while i < elements.len():
                    resolved_elements = resolved_elements.push(self.resolve(elements[i]))
                    i = i + 1
                Type.Tuple(resolved_elements)
            case Type.Array(element):
                Type.Array(self.resolve(element))
            case Type.Optional(inner):
                Type.Optional(self.resolve(inner))
            case _: ty

    me unify(left: Type, right: Type) -> Result<(), text>:
        val resolved_left = self.resolve(left)
        val resolved_right = self.resolve(right)

        if type_equals(resolved_left, resolved_right):
            return Ok(())

        match (resolved_left, resolved_right):
            case (Type.Var(left_id), Type.Var(right_id)):
                self.record_substitution(left_id, Type.Var(right_id))
                Ok(())

            case (Type.Var(id), other):
                if self.occurs_check(id, other):
                    Err("Occurs check failed: infinite type")
                else:
                    self.record_substitution(id, other)
                    Ok(())

            case (other, Type.Var(id)):
                if self.occurs_check(id, other):
                    Err("Occurs check failed: infinite type")
                else:
                    self.record_substitution(id, other)
                    Ok(())

            case (Type.DynTrait(left_name), Type.DynTrait(right_name)):
                if left_name == right_name:
                    Ok(())
                else:
                    Err("Cannot unify dyn {left_name} with dyn {right_name}")

            case (Type.DynTrait(name), _):
                Err("Cannot unify dyn {name} with concrete type")

            case (_, Type.DynTrait(name)):
                Err("Cannot unify concrete type with dyn {name}")

            case (Type.Function(left_params, left_ret), Type.Function(right_params, right_ret)):
                if left_params.len() != right_params.len():
                    return Err("Function arity mismatch")

                var i: i64 = 0
                while i < left_params.len():
                    self.unify(left_params[i], right_params[i])?
                    i = i + 1

                self.unify(left_ret, right_ret)

            case (Type.Generic(left_name, left_args), Type.Generic(right_name, right_args)):
                if left_name != right_name:
                    return Err("Cannot unify {left_name} with {right_name}")
                if left_args.len() != right_args.len():
                    return Err("Generic arity mismatch for {left_name}")

                var i: i64 = 0
                while i < left_args.len():
                    self.unify(left_args[i], right_args[i])?
                    i = i + 1
                Ok(())

            case (Type.Tuple(left_elements), Type.Tuple(right_elements)):
                if left_elements.len() != right_elements.len():
                    return Err("Tuple arity mismatch")

                var i: i64 = 0
                while i < left_elements.len():
                    self.unify(left_elements[i], right_elements[i])?
                    i = i + 1
                Ok(())

            case (Type.Array(left_element), Type.Array(right_element)):
                self.unify(left_element, right_element)

            case (Type.Optional(left_inner), Type.Optional(right_inner)):
                self.unify(left_inner, right_inner)

            case _:
                Err("Cannot unify {resolved_left.to_string()} with {resolved_right.to_string()}")

    fn occurs_check(var_id: i64, ty: Type) -> bool:
        match self.resolve(ty):
            case Type.Var(id):
                id == var_id
            case Type.Function(params, ret):
                list_contains_type(params, \candidate: self.occurs_check(var_id, candidate)) or self.occurs_check(var_id, ret)
            case Type.Generic(_, args):
                list_contains_type(args, \candidate: self.occurs_check(var_id, candidate))
            case Type.Tuple(elements):
                list_contains_type(elements, \candidate: self.occurs_check(var_id, candidate))
            case Type.Array(element):
                self.occurs_check(var_id, element)
            case Type.Optional(inner):
                self.occurs_check(var_id, inner)
            case _:
                false

class DependencyInfo:
    name: text
    fields: [(text, Type)]
    required_deps: [text]

impl DependencyInfo:
    static fn new(name: text) -> DependencyInfo:
        DependencyInfo(name: name, fields: [], required_deps: [])

class DependencyResolver:
    dependencies: [DependencyInfo]

impl DependencyResolver:
    static fn new() -> DependencyResolver:
        DependencyResolver(dependencies: [])

    me register_dependency(info: DependencyInfo):
        self.dependencies = self.dependencies.push(info)

    fn lookup(name: text) -> DependencyInfo?:
        var i: i64 = 0
        while i < self.dependencies.len():
            if self.dependencies[i].name == name:
                return self.dependencies[i]
            i = i + 1
        nil

    fn resolve_transitive(initial_names: [text]) -> [text]:
        var seen: [text] = []
        var queue: [text] = initial_names
        var result: [text] = []
        var index: i64 = 0

        while index < queue.len():
            val name = queue[index]
            index = index + 1

            if contains_text(seen, name):
                continue

            seen = seen.push(name)
            match self.lookup(name):
                case Some(info):
                    result = result.push(name)
                    var j: i64 = 0
                    while j < info.required_deps.len():
                        val dep = info.required_deps[j]
                        if not contains_text(seen, dep):
                            queue = queue.push(dep)
                        j = j + 1
                case nil:
                    pass

        result

    fn collect_fields(initial_names: [text]) -> [(text, Type)]:
        val ordered_names = self.resolve_transitive(initial_names)
        var seen_fields: [text] = []
        var fields: [(text, Type)] = []

        var i: i64 = 0
        while i < ordered_names.len():
            match self.lookup(ordered_names[i]):
                case Some(info):
                    var j: i64 = 0
                    while j < info.fields.len():
                        val field_name = info.fields[j].0
                        val field_type = info.fields[j].1
                        if not contains_text(seen_fields, field_name):
                            seen_fields = seen_fields.push(field_name)
                            fields = fields.push((field_name, field_type))
                        j = j + 1
                case nil:
                    pass
            i = i + 1

        fields

enum DispatchMode:
    Static
    Dynamic

class TypeChecker:
    unifier: TypeUnifier
    resolver: DependencyResolver
    binding_names: [text]
    binding_types: [Type]
    trait_names: [text]
    trait_impl_types: [Type]

impl TypeChecker:
    static fn new() -> TypeChecker:
        TypeChecker(
            unifier: TypeUnifier.new(),
            resolver: DependencyResolver.new(),
            binding_names: [],
            binding_types: [],
            trait_names: [],
            trait_impl_types: []
        )

    me fresh_var() -> Type:
        self.unifier.fresh_var()

    me unify(left: Type, right: Type) -> Result<(), text>:
        self.unifier.unify(left, right)

    fn resolve(ty: Type) -> Type:
        self.unifier.resolve(ty)

    me bind_interface(trait_name: text, impl_type: Type):
        var i: i64 = 0
        while i < self.binding_names.len():
            if self.binding_names[i] == trait_name:
                self.binding_types[i] = impl_type
                return
            i = i + 1

        self.binding_names = self.binding_names.push(trait_name)
        self.binding_types = self.binding_types.push(impl_type)

    fn resolve_trait_type(trait_name: text) -> Type:
        var i: i64 = 0
        while i < self.binding_names.len():
            if self.binding_names[i] == trait_name:
                return self.binding_types[i]
            i = i + 1

        Type.DynTrait(trait_name)

    fn get_dispatch_mode(trait_name: text) -> DispatchMode:
        var i: i64 = 0
        while i < self.binding_names.len():
            if self.binding_names[i] == trait_name:
                return DispatchMode.Static
            i = i + 1
        DispatchMode.Dynamic

    me register_dependency(info: DependencyInfo):
        self.resolver.register_dependency(info)

    fn resolve_transitive(names: [text]) -> [text]:
        self.resolver.resolve_transitive(names)

    fn collect_fields(names: [text]) -> [(text, Type)]:
        self.resolver.collect_fields(names)

    me register_trait_impl(trait_name: text, impl_type: Type):
        var i: i64 = 0
        while i < self.trait_names.len():
            if self.trait_names[i] == trait_name:
                if not contains_type(self.trait_impl_types[i], impl_type):
                    self.trait_impl_types[i] = Type.Tuple([self.trait_impl_types[i], impl_type])
                return
            i = i + 1

        self.trait_names = self.trait_names.push(trait_name)
        self.trait_impl_types = self.trait_impl_types.push(Type.Tuple([impl_type]))

    fn can_coerce_to_dyn_trait(concrete_ty: Type, trait_name: text) -> bool:
        var i: i64 = 0
        while i < self.trait_names.len():
            if self.trait_names[i] == trait_name:
                return contains_type(self.trait_impl_types[i], concrete_ty)
            i = i + 1
        false

fn contains_i64(values: [i64], needle: i64) -> bool:
    var i: i64 = 0
    while i < values.len():
        if values[i] == needle:
            return true
        i = i + 1
    false

fn contains_text(values: [text], needle: text) -> bool:
    var i: i64 = 0
    while i < values.len():
        if values[i] == needle:
            return true
        i = i + 1
    false

fn list_contains_type(values: [Type], predicate: fn(Type) -> bool) -> bool:
    var i: i64 = 0
    while i < values.len():
        if predicate(values[i]):
            return true
        i = i + 1
    false

fn contains_type(values: Type, needle: Type) -> bool:
    match values:
        case Type.Tuple(elements):
            list_contains_type(elements, \candidate: type_equals(candidate, needle))
        case _:
            type_equals(values, needle)

fn make_primitive_suite():
    check(type_equals(Type.Int, Type.Int))
    check(type_equals(Type.Bool, Type.Bool))
    check(type_equals(Type.Str, Type.Str))
    check(type_equals(Type.Float, Type.Float))
    check(type_equals(Type.Unit, Type.Unit))

describe "Type Representation":
    it "renders primitive and compound types":
        check(Type.Int.to_string() == "Int")
        check(Type.Bool.to_string() == "Bool")
        check(Type.Str.to_string() == "Str")
        check(Type.Float.to_string() == "Float")
        check(Type.Unit.to_string() == "Unit")
        check(Type.Var(7).to_string() == "T7")
        check(Type.Function([Type.Int, Type.Bool], Type.Unit).to_string() == "fn(Int, Bool) -> Unit")
        check(Type.Generic("List", [Type.Int]).to_string() == "List<Int>")
        check(Type.DynTrait("Renderable").to_string() == "dyn Renderable")
        check(Type.Tuple([Type.Int, Type.Bool]).to_string() == "(Int, Bool)")
        check(Type.Array(Type.Str).to_string() == "[Str]")
        check(Type.Optional(Type.Int).to_string() == "Option<Int>")

    it "identifies primitive types":
        check(Type.Int.is_primitive())
        check(Type.Bool.is_primitive())
        check(Type.Str.is_primitive())
        check(Type.Float.is_primitive())
        check(Type.Unit.is_primitive())
        check(not Type.Var(0).is_primitive())

describe "Type Unification":
    it "unifies identical primitive types":
        val unifier = TypeUnifier.new()
        match unifier.unify(Type.Int, Type.Int):
            case Ok(()):
                check(true)
            case Err(msg):
                expect(msg).to_equal("")

    it "rejects different primitive types":
        val unifier = TypeUnifier.new()
        match unifier.unify(Type.Int, Type.Bool):
            case Ok(()):
                check(false)
            case Err(msg):
                check(msg == "Cannot unify Int with Bool")

    it "unifies variables and resolves chains":
        val unifier = TypeUnifier.new()
        val a = unifier.fresh_var()
        val b = unifier.fresh_var()
        check(unifier.unify(a, b).is_ok())
        check(unifier.unify(b, Type.Int).is_ok())
        check(type_equals(unifier.resolve(a), Type.Int))
        check(type_equals(unifier.resolve(b), Type.Int))

    it "detects occurs check failures":
        val unifier = TypeUnifier.new()
        val a = unifier.fresh_var()
        match unifier.unify(a, Type.Array(a)):
            case Ok(()):
                check(false)
            case Err(msg):
                check(msg == "Occurs check failed: infinite type")

    it "unifies function, generic, tuple, array, and optional types":
        val unifier = TypeUnifier.new()
        check(unifier.unify(
            Type.Function([Type.Int, Type.Bool], Type.Unit),
            Type.Function([Type.Int, Type.Bool], Type.Unit)
        ).is_ok())
        check(unifier.unify(
            Type.Function([Type.Int], Type.Unit),
            Type.Function([Type.Int, Type.Bool], Type.Unit)
        ).is_err())
        check(unifier.unify(
            Type.Generic("Map", [Type.Int, Type.Str]),
            Type.Generic("Map", [Type.Int, Type.Str])
        ).is_ok())
        check(unifier.unify(
            Type.Generic("Map", [Type.Int]),
            Type.Generic("Set", [Type.Int])
        ).is_err())
        check(unifier.unify(
            Type.Tuple([Type.Int, Type.Bool]),
            Type.Tuple([Type.Int, Type.Bool])
        ).is_ok())
        check(unifier.unify(
            Type.Tuple([Type.Int]),
            Type.Tuple([Type.Int, Type.Bool])
        ).is_err())
        check(unifier.unify(Type.Array(Type.Int), Type.Array(Type.Int)).is_ok())
        check(unifier.unify(Type.Array(Type.Int), Type.Array(Type.Bool)).is_err())
        check(unifier.unify(Type.Optional(Type.Str), Type.Optional(Type.Str)).is_ok())
        check(unifier.unify(Type.Optional(Type.Str), Type.Optional(Type.Bool)).is_err())

    it "rejects dyn trait mismatches":
        val unifier = TypeUnifier.new()
        check(unifier.unify(Type.DynTrait("Read"), Type.DynTrait("Write")).is_err())
        check(unifier.unify(Type.DynTrait("Read"), Type.Int).is_err())
        check(unifier.unify(Type.Int, Type.DynTrait("Read")).is_err())

describe "Dependency Resolution":
    it "resolves transitive dependencies and deduplicates diamonds":
        val resolver = DependencyResolver.new()

        val base = DependencyInfo.new("base")
        val left = DependencyInfo.new("left")
        val right = DependencyInfo.new("right")
        val top = DependencyInfo.new("top")

        left.required_deps = ["base"]
        right.required_deps = ["base"]
        top.required_deps = ["left", "right"]

        resolver.register_dependency(base)
        resolver.register_dependency(left)
        resolver.register_dependency(right)
        resolver.register_dependency(top)

        val resolved = resolver.resolve_transitive(["top"])
        check(resolved.len() == 4)
        check(contains_text(resolved, "base"))
        check(contains_text(resolved, "left"))
        check(contains_text(resolved, "right"))
        check(contains_text(resolved, "top"))
        check(resolved.len() == 4)

    it "skips missing dependencies without breaking resolution":
        val resolver = DependencyResolver.new()

        val leaf = DependencyInfo.new("leaf")
        leaf.required_deps = ["missing"]

        resolver.register_dependency(leaf)

        val resolved = resolver.resolve_transitive(["leaf"])
        check(resolved.len() == 1)
        check(contains_text(resolved, "leaf"))

    it "collects fields without duplicates":
        val resolver = DependencyResolver.new()

        val base = DependencyInfo.new("base")
        base.fields = [("id", Type.Int), ("name", Type.Str)]

        val extra = DependencyInfo.new("extra")
        extra.fields = [("name", Type.Bool), ("active", Type.Bool)]
        extra.required_deps = ["base"]

        resolver.register_dependency(base)
        resolver.register_dependency(extra)

        val fields = resolver.collect_fields(["extra"])
        check(fields.len() == 3)
        check(same_pairs(fields, [("id", Type.Int), ("name", Type.Str), ("active", Type.Bool)]))

describe "TypeChecker Integration":
    it "creates fresh variables and binds trait interfaces":
        val checker = TypeChecker.new()
        val first = checker.fresh_var()
        val second = checker.fresh_var()
        check(not type_equals(first, second))

        checker.bind_interface("Renderable", Type.Generic("Widget", []))
        check(type_equals(checker.resolve_trait_type("Renderable"), Type.Generic("Widget", [])))
        check(type_equals(checker.resolve_trait_type("Missing"), Type.DynTrait("Missing")))
        check(checker.get_dispatch_mode("Renderable") == DispatchMode.Static)
        check(checker.get_dispatch_mode("Missing") == DispatchMode.Dynamic)

    it "tracks trait implementations for dyn trait coercion":
        val checker = TypeChecker.new()
        checker.register_trait_impl("Display", Type.Int)
        checker.register_trait_impl("Display", Type.Bool)
        check(checker.can_coerce_to_dyn_trait(Type.Int, "Display"))
        check(checker.can_coerce_to_dyn_trait(Type.Bool, "Display"))
        check(not checker.can_coerce_to_dyn_trait(Type.Str, "Display"))

    it "resolves transitive dependencies through the checker":
        val checker = TypeChecker.new()

        val core = DependencyInfo.new("core")
        core.fields = [("id", Type.Int)]

        val model = DependencyInfo.new("model")
        model.fields = [("name", Type.Str)]
        model.required_deps = ["core"]

        checker.register_dependency(core)
        checker.register_dependency(model)

        val resolved = checker.resolve_transitive(["model"])
        check(resolved.len() == 2)
        check(contains_text(resolved, "core"))
        check(contains_text(resolved, "model"))
        check(same_pairs(checker.collect_fields(["model"]), [("id", Type.Int), ("name", Type.Str)]))
