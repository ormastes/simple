# SDN fixture/system tests
#
# These tests exercise the SDN document API against real files created in the
# test workspace. The historical checked-in SDN fixture directory is not present
# in this repository snapshot, so the spec owns the small fixture files it uses.

use std.spec.*
use std.io_runtime.{file_delete, file_exists, file_read, file_write}
use std.sdn.document.SdnDocument
use std.sdn.value.SdnValue

val TEMP_CONFIG = "/tmp/simple_sdn_fixture_config.sdn"
val TEMP_INVALID = "/tmp/simple_sdn_fixture_invalid.sdn"

describe "SDN Fixtures System Tests":
    it "loads a config fixture from disk":
        write_config_fixture(TEMP_CONFIG)

        val load_result = SdnDocument.from_file(TEMP_CONFIG)
        match load_result:
            Ok(doc):
                val app_name = doc.get("app.name")
                match app_name:
                    Some(value):
                        expect value.as_str() == Some("MyService")
                    nil:
                        fail("Missing app.name")
            Err(e):
                fail("Failed to load config fixture: ${e}")

        file_delete(TEMP_CONFIG)

    it "rejects an invalid fixture file":
        file_write(TEMP_INVALID, "app\n    name: MissingColon")

        val load_result = SdnDocument.from_file(TEMP_INVALID)
        match load_result:
            Ok(_):
                fail("Should have failed for invalid SDN")
            Err(_):
                pass

        file_delete(TEMP_INVALID)

    it "renders a fixture as JSON":
        write_config_fixture(TEMP_CONFIG)

        val load_result = SdnDocument.from_file(TEMP_CONFIG)
        match load_result:
            Ok(doc):
                val json_output = doc.to_json()
                expect json_output.contains("MyService") == true
                expect json_output.contains("8080") == true
            Err(e):
                fail("Failed to load fixture: ${e}")

        file_delete(TEMP_CONFIG)

    it "persists a parsed document":
        write_config_fixture(TEMP_CONFIG)

        val load_result = SdnDocument.from_file(TEMP_CONFIG)
        match load_result:
            Ok(doc):
                val write_result = doc.write_file(TEMP_CONFIG)
                match write_result:
                    Ok(_): pass
                    Err(e): fail("Failed to save: ${e}")
            Err(e):
                fail("Failed to load: ${e}")

        val content = file_read(TEMP_CONFIG)
        expect content.contains("MyService") == true
        file_delete(TEMP_CONFIG)

    it "keeps the checked-in fixture summary visible when present":
        val summary_path = "test/lib/std/system/sdn/fixtures/summary.txt"
        if file_exists(summary_path):
            val summary = file_read(summary_path)
            expect summary.len() > 0
        else:
            print "SKIP: optional SDN fixture summary is absent"

fn write_config_fixture(path: text):
    val content = "app:\n    name: MyService\n    version: \"2.1.0\"\nserver:\n    port: 8080\n    host: localhost\n"
    file_write(path, content)
